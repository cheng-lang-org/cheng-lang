import std/result
import std/rawmem_support
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/consensus as consensus
import cheng/chain/lsmr as lsmr
import cheng/chain/lsmr_types as lt
import cheng/chain/anti_entropy as anti
import std/strutils as strutil

type
    ChainNodeStamp =
        epoch: int32
        ganzhi: int32

    ChainNode =
        nodeId: str
        address: types.LsmrAddress
        nextEpoch: int32
        nextGanzhi: int32
        nextTick: int64
        servedCount: int32
        index: consensus.ChainIndex
        eventCids: layout.FixedBytes32[]
        events: consensus.ChainEvent[]
        forest: lt.StateLayerForest
        signature: lt.AntiEntropySignature
        tipEventCid: layout.FixedBytes32

    ChainNodeServeSnapshot =
        nodeId: str
        address: types.LsmrAddress
        serveCount: int32
        tipEventCid: layout.FixedBytes32
        eventCids: layout.FixedBytes32[]
        events: consensus.ChainEvent[]
        forest: lt.StateLayerForest
        signature: lt.AntiEntropySignature

fn ChainNodeCopyAddress(out: var types.LsmrAddress, address: types.LsmrAddress) =
    out.depth = address.depth
    for i in 0..<types.LsmrMaxDepth:
        out.digits[i] = address.digits[i]

fn ChainNodeCopySignature(out: var lt.AntiEntropySignature, signature: lt.AntiEntropySignature) =
    out.stampEpoch = signature.stampEpoch
    out.stampGanzhi = signature.stampGanzhi
    out.eventCount = signature.eventCount
    out.accountCount = signature.accountCount
    out.stateForestCid = signature.stateForestCid
    out.layerCount = signature.layerCount
    for i in 0..<3:
        out.layerSummaries[i].layerId = signature.layerSummaries[i].layerId
        out.layerSummaries[i].treeCid = signature.layerSummaries[i].treeCid
        out.layerSummaries[i].nodeCount = signature.layerSummaries[i].nodeCount
        out.layerSummaries[i].entryCount = signature.layerSummaries[i].entryCount
    out.rootCount = signature.rootCount
    for i in 0..<lt.BaguaRootSummaryMax:
        out.rootSummaries[i].layerId = signature.rootSummaries[i].layerId
        out.rootSummaries[i].baguaId = signature.rootSummaries[i].baguaId
        out.rootSummaries[i].nodeCid = signature.rootSummaries[i].nodeCid
        out.rootSummaries[i].entryDescCount = signature.rootSummaries[i].entryDescCount

fn ChainNodeCloneText(text: str): str =
    let textLen: int32 = len(text)
    if textLen <= 0:
        return ""
    let out: str = newStringAlloc(textLen)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    rawmem_support.RawmemCopy(outPtr, rawmemAsVoid(text), textLen)
    return out

fn ChainNodeCloneFixedBytes32Seq(values: layout.FixedBytes32[]): layout.FixedBytes32[] =
    var out: layout.FixedBytes32[]
    out = []
    for i in 0..<values.len:
        add(out, values[i])
    return out

fn ChainNodeCloneInt32Seq(values: int32[]): int32[] =
    var out: int32[]
    out = []
    for i in 0..<values.len:
        add(out, values[i])
    return out

fn ChainNodeCloneInt64Seq(values: int64[]): int64[] =
    var out: int64[]
    out = []
    for i in 0..<values.len:
        add(out, values[i])
    return out

fn ChainNodeCloneBoolSeq(values: bool[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<values.len:
        add(out, values[i])
    return out

fn ChainNodeClonePrefixRefSeq(values: lt.PrefixRef[]): lt.PrefixRef[] =
    var out: lt.PrefixRef[]
    out = []
    for i in 0..<values.len:
        add(out, values[i])
    return out

fn ChainNodeCloneAddressSeq(values: types.LsmrAddress[]): types.LsmrAddress[] =
    var out: types.LsmrAddress[]
    out = []
    for i in 0..<values.len:
        add(out, values[i])
    return out

fn ChainNodeCloneEventSeq(values: consensus.ChainEvent[]): consensus.ChainEvent[] =
    var out: consensus.ChainEvent[]
    out = []
    for i in 0..<values.len:
        add(out, values[i])
    return out

fn ChainNodeCloneBaguaPrefixTree(tree: lt.BaguaPrefixTree): lt.BaguaPrefixTree =
    var out = lt.BaguaPrefixTree()
    out.entryCount = tree.entryCount
    out.nodeCount = tree.nodeCount
    out.nodePrefixes = ChainNodeClonePrefixRefSeq(tree.nodePrefixes)
    out.nodeChildStarts = ChainNodeCloneInt32Seq(tree.nodeChildStarts)
    out.nodeChildCounts = ChainNodeCloneInt32Seq(tree.nodeChildCounts)
    out.nodeEntryStarts = ChainNodeCloneInt32Seq(tree.nodeEntryStarts)
    out.nodeEntryCounts = ChainNodeCloneInt32Seq(tree.nodeEntryCounts)
    out.nodeEntryDescCounts = ChainNodeCloneInt32Seq(tree.nodeEntryDescCounts)
    out.nodeCids = ChainNodeCloneFixedBytes32Seq(tree.nodeCids)
    out.entryKeyIds = ChainNodeCloneInt32Seq(tree.entryKeyIds)
    out.entryResolutionLevels = ChainNodeCloneInt32Seq(tree.entryResolutionLevels)
    out.entryLayerIds = ChainNodeCloneInt32Seq(tree.entryLayerIds)
    out.entryPrefixes = ChainNodeClonePrefixRefSeq(tree.entryPrefixes)
    out.entryAddresses = ChainNodeCloneAddressSeq(tree.entryAddresses)
    out.entryContentCids = ChainNodeCloneFixedBytes32Seq(tree.entryContentCids)
    out.entryLocalityHashes = ChainNodeCloneFixedBytes32Seq(tree.entryLocalityHashes)
    out.entryLocalityCids = ChainNodeCloneFixedBytes32Seq(tree.entryLocalityCids)
    out.entryCids = ChainNodeCloneFixedBytes32Seq(tree.entryCids)
    out.treeCid = tree.treeCid
    return out

fn ChainNodeCloneForest(forest: lt.StateLayerForest): lt.StateLayerForest =
    var out = lt.StateLayerForest()
    out.edgeTree = ChainNodeCloneBaguaPrefixTree(forest.edgeTree)
    out.regionalTree = ChainNodeCloneBaguaPrefixTree(forest.regionalTree)
    out.globalTree = ChainNodeCloneBaguaPrefixTree(forest.globalTree)
    out.forestCid = forest.forestCid
    return out

fn ChainNodeCopyInto(out: var ChainNode, node: var ChainNode) =
    out.nodeId = ChainNodeCloneText(node.nodeId)
    ChainNodeCopyAddress(out.address, node.address)
    out.nextEpoch = node.nextEpoch
    out.nextGanzhi = node.nextGanzhi
    out.nextTick = node.nextTick
    out.servedCount = node.servedCount
    out.index.eventCids = ChainNodeCloneFixedBytes32Seq(node.index.eventCids)
    out.index.eventKinds = ChainNodeCloneInt32Seq(node.index.eventKinds)
    out.index.logOffsets = ChainNodeCloneInt32Seq(node.index.logOffsets)
    out.index.accountAssetIds = ChainNodeCloneInt32Seq(node.index.accountAssetIds)
    out.index.accountIds = ChainNodeCloneInt32Seq(node.index.accountIds)
    out.index.accountHeads = ChainNodeCloneFixedBytes32Seq(node.index.accountHeads)
    out.index.balances = ChainNodeCloneInt64Seq(node.index.balances)
    out.index.clockEpochs = ChainNodeCloneInt32Seq(node.index.clockEpochs)
    out.index.clockGanzhi = ChainNodeCloneInt32Seq(node.index.clockGanzhi)
    out.index.diverged = ChainNodeCloneBoolSeq(node.index.diverged)
    out.index.stateTreeDirty = node.index.stateTreeDirty
    out.eventCids = ChainNodeCloneFixedBytes32Seq(node.eventCids)
    out.events = ChainNodeCloneEventSeq(node.events)
    out.forest = ChainNodeCloneForest(node.forest)
    ChainNodeCopySignature(out.signature, node.signature)
    out.tipEventCid = node.tipEventCid

fn ChainNodeZeroInto(out: var ChainNode, nodeId: str, address: types.LsmrAddress) =
    out.nodeId = ChainNodeCloneText(nodeId)
    ChainNodeCopyAddress(out.address, address)
    out.nextEpoch = 1
    out.nextGanzhi = 1
    out.nextTick = int64(1)
    out.servedCount = 0
    out.index.eventCids = []
    out.index.eventKinds = []
    out.index.logOffsets = []
    out.index.accountAssetIds = []
    out.index.accountIds = []
    out.index.accountHeads = []
    out.index.balances = []
    out.index.clockEpochs = []
    out.index.clockGanzhi = []
    out.index.diverged = []
    out.index.stateTreeDirty = false
    out.eventCids = []
    out.events = []
    lt.StateLayerForestZeroInto(out.forest)
    lt.AntiEntropySignatureZeroInto(out.signature)
    out.tipEventCid = layout.FixedBytes32()

fn ChainNodeStampLess(left: ChainNodeStamp, right: ChainNodeStamp): bool =
    if left.epoch != right.epoch:
        return left.epoch < right.epoch
    return left.ganzhi < right.ganzhi

fn ChainNodeMaxStamp(index: consensus.ChainIndex): ChainNodeStamp =
    var out = ChainNodeStamp(epoch: 1, ganzhi: 0)
    for i in 0..<index.clockEpochs.len:
        let candidate = ChainNodeStamp(epoch: index.clockEpochs[i], ganzhi: index.clockGanzhi[i])
        if ChainNodeStampLess(out, candidate):
            out = candidate
    return out

fn ChainNodeSpaceSlot(fromAccount: int32, toAccount: int32): int32 =
    let mixed = fromAccount * 131 + toAccount * 17
    let slot = mixed % 9
    if slot < 0:
        return slot + 9
    return slot

fn ChainNodeReasonText(reasonCode: int32): str =
    if reasonCode == 0:
        return "ok"
    if reasonCode == 1:
        return "duplicate"
    if reasonCode == 2:
        return "mint_applied"
    if reasonCode == 3:
        return "transfer_applied"
    if reasonCode == 4:
        return "diverged_target"
    if reasonCode == 5:
        return "fork_parent_mismatch"
    if reasonCode == 6:
        return "diverged_account"
    if reasonCode == 7:
        return "insufficient_balance"
    return "unknown"

fn ChainNodeAccountPos(index: consensus.ChainIndex, assetId: int32, accountId: int32): int32 =
    return consensus.ConsensusAccountPos(index, assetId, accountId)

fn ChainNodeAccountHead(index: consensus.ChainIndex, assetId: int32, accountId: int32): layout.FixedBytes32 =
    let pos = ChainNodeAccountPos(index, assetId, accountId)
    var out: layout.FixedBytes32
    if pos < 0:
        return out
    out = index.accountHeads[pos]
    return out

fn ChainNodeBalanceValue(index: consensus.ChainIndex, assetId: int32, accountId: int32): int64 =
    let pos = ChainNodeAccountPos(index, assetId, accountId)
    if pos < 0:
        return int64(0)
    return index.balances[pos]

fn ChainNodeKeyId(assetId: int32, accountId: int32): int32 =
    let key = assetId * 65537 + accountId
    if key > 0:
        return key
    return 0 - key

fn ChainNodeAccountAddress(assetId: int32, accountId: int32): types.LsmrAddress =
    var digits: int32[]
    digits = []
    var mixed = int64(assetId) * int64(65537) + int64(accountId) * int64(131)
    if mixed < 0:
        mixed = 0 - mixed
    for i in 0..<3:
        let digitMix = mixed +
                       int64(assetId) * int64(17) +
                       int64(accountId) * int64(7) +
                       int64(i) * int64(11)
        var digit = int32(digitMix % int64(9))
        if digit < 0:
            digit = 0 - digit
        add(digits, types.LsmrDigitMin + digit)
        mixed = (mixed / int64(9)) +
                int64(assetId) * int64(13) +
                int64(accountId) * int64(5) +
                int64(i)
        if mixed < 0:
            mixed = 0 - mixed
    let addrRes = types.LsmrAddressFromDigits(digits)
    if IsErr(addrRes):
        panic(Error(addrRes))
    return Value(addrRes)

fn ChainNodeAccountLocalityHash(assetId: int32, accountId: int32): layout.FixedBytes32 =
    var parts: int32[]
    parts = []
    add(parts, assetId)
    add(parts, accountId)
    return lt.HashInts("cheng.chain_node.locality", parts)

fn ChainNodeAccountContentCid(index: consensus.ChainIndex, pos: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.chain_node.account"))
    lt.AppendU32BE(buf, index.accountAssetIds[pos])
    lt.AppendU32BE(buf, index.accountIds[pos])
    lt.AppendU32BE(buf, int32(index.balances[pos] >> 32))
    lt.AppendU32BE(buf, int32(index.balances[pos] & int64(0xffffffff)))
    lt.AppendFixed32(buf, index.accountHeads[pos])
    lt.AppendU32BE(buf, index.clockEpochs[pos])
    lt.AppendU32BE(buf, index.clockGanzhi[pos])
    if index.diverged[pos]:
        lt.AppendU32BE(buf, 1)
    else:
        lt.AppendU32BE(buf, 0)
    return lt.FixedCidFromBuf(buf)

fn ChainNodeStateCells(index: consensus.ChainIndex): lt.StateCell[] =
    var out: lt.StateCell[]
    out = []
    for i in 0..<index.accountIds.len:
        let address = ChainNodeAccountAddress(index.accountAssetIds[i], index.accountIds[i])
        let localityHash = ChainNodeAccountLocalityHash(index.accountAssetIds[i], index.accountIds[i])
        let contentCid = ChainNodeAccountContentCid(index, i)
        var cell: lt.StateCell
        add(out, cell)
        let cellPos = out.len - 1
        lsmr.LsmrStateCellFill(
            out[cellPos],
            ChainNodeKeyId(index.accountAssetIds[i], index.accountIds[i]),
            address,
            3,
            contentCid,
            localityHash
        )
    return out

fn ChainNodeRebuildDerived(node: var ChainNode) =
    var cells = ChainNodeStateCells(node.index)
    var forest = lsmr.BuildStateLayerForest(cells)
    node.forest = forest
    let stamp = ChainNodeMaxStamp(node.index)
    node.signature = anti.AntiEntropySignatureFromForest(
        stamp.epoch,
        stamp.ganzhi,
        node.eventCids.len,
        node.index.accountIds.len,
        node.forest
    )
    var tipEventCid: layout.FixedBytes32
    if node.eventCids.len > 0:
        tipEventCid = node.eventCids[node.eventCids.len - 1]
    node.tipEventCid = tipEventCid
    node.nextEpoch = stamp.epoch
    node.nextGanzhi = stamp.ganzhi + 1
    if node.nextGanzhi <= 0:
        node.nextGanzhi = 1
    node.nextTick = int64(node.eventCids.len + 1)

fn ChainNodeInitInto(out: var ChainNode, nodeId: str, addressSeed: str): Result[bool] =
    let addrRes = ChainNodeAddressFromSeed(addressSeed)
    if IsErr(addrRes):
        return Err[bool](Error(addrRes))
    ChainNodeZeroInto(out, nodeId, Value(addrRes))
    ChainNodeRebuildDerived(out)
    return Ok[bool](true)

fn ChainNodeAddressFromSeed(addressSeed: str): Result[types.LsmrAddress] =
    return lsmr.LsmrAddressFromSeed(addressSeed, 3)

fn ChainNodeApplyEvent(node: var ChainNode, event: var consensus.ChainEvent): Result[layout.FixedBytes32] =
    return ChainNodeApplyEventWithDerived(node, event, true)

fn ChainNodeApplyEventWithDerived(node: var ChainNode,
                                    event: var consensus.ChainEvent,
                                    rebuildDerived: bool): Result[layout.FixedBytes32] =
    let eventCid = consensus.ChainEventCid(event)
    var nextIndex: consensus.ChainIndex
    nextIndex = node.index
    var decision: consensus.ConsensusDecision
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, node.eventCids.len, decision)
    node.index = nextIndex
    if !decision.accepted:
        return Err[layout.FixedBytes32](strutil.Join([" chain_node: consensus rejected ", ChainNodeReasonText(decision.reasonCode)], ""))
    if decision.applied:
        add(node.eventCids, eventCid)
        add(node.events, event)
        if rebuildDerived:
            ChainNodeRebuildDerived(node)
    return Ok[layout.FixedBytes32](eventCid)

fn ChainNodeMint(node: var ChainNode,
                   assetId: int32,
                   toAccount: int32,
                   amount: int64): Result[layout.FixedBytes32] =
    if assetId <= 0:
        return Err[layout.FixedBytes32](" chain_node: invalid mint target")
    if toAccount <= 0:
        return Err[layout.FixedBytes32](" chain_node: invalid mint target")
    if amount <= int64(0):
        return Err[layout.FixedBytes32](" chain_node: mint amount must be positive")
    let parentCid = ChainNodeAccountHead(node.index, assetId, toAccount)
    var event = consensus.ChainEventMint(
        assetId,
        toAccount,
        parentCid,
        amount,
        node.nextEpoch,
        node.nextGanzhi,
        ChainNodeSpaceSlot(toAccount, toAccount),
        node.nextTick
    )
    return ChainNodeApplyEvent(node, event)

fn ChainNodeBuildTransferEvent(node: ChainNode,
                                 assetId: int32,
                                 fromAccount: int32,
                                 toAccount: int32,
                                 amount: int64): consensus.ChainEvent =
    let fromParentCid = ChainNodeAccountHead(node.index, assetId, fromAccount)
    let toParentCid = ChainNodeAccountHead(node.index, assetId, toAccount)
    var event: consensus.ChainEvent
    event.version = 1
    event.kind = consensus.ConsensusKindTransferCommit
    event.assetId = assetId
    event.fromAccount = fromAccount
    event.toAccount = toAccount
    event.fromParentCid = fromParentCid
    event.toParentCid = toParentCid
    event.amount = amount
    event.epoch = node.nextEpoch
    event.ganzhiIndex = node.nextGanzhi
    event.spaceSlot = ChainNodeSpaceSlot(fromAccount, toAccount)
    event.tick = node.nextTick
    event.stem = event.ganzhiIndex % 10
    event.branch = event.ganzhiIndex % 12
    event.bodyCid = consensus.ChainEventBodyCid(event)
    return event

fn ChainNodeTransfer(node: var ChainNode,
                       assetId: int32,
                       fromAccount: int32,
                       toAccount: int32,
                       amount: int64): Result[layout.FixedBytes32] =
    if assetId <= 0:
        return Err[layout.FixedBytes32](" chain_node: invalid transfer accounts")
    if fromAccount <= 0:
        return Err[layout.FixedBytes32](" chain_node: invalid transfer accounts")
    if toAccount <= 0:
        return Err[layout.FixedBytes32](" chain_node: invalid transfer accounts")
    if fromAccount == toAccount:
        return Err[layout.FixedBytes32](" chain_node: same account transfer")
    if amount <= int64(0):
        return Err[layout.FixedBytes32](" chain_node: transfer amount must be positive")
    var event = ChainNodeBuildTransferEvent(node, assetId, fromAccount, toAccount, amount)
    return ChainNodeApplyEvent(node, event)

fn ChainNodeBalance(node: var ChainNode, assetId: int32, accountId: int32): Result[int64] =
    if assetId <= 0:
        return Err[int64](" chain_node: invalid balance target")
    if accountId <= 0:
        return Err[int64](" chain_node: invalid balance target")
    return Ok[int64](ChainNodeBalanceValue(node.index, assetId, accountId))

fn ChainNodeServeOnceInto(out: var ChainNodeServeSnapshot,
                            node: var ChainNode) =
    ChainNodeRebuildDerived(node)
    node.servedCount = node.servedCount + 1
    out.nodeId = ChainNodeCloneText(node.nodeId)
    ChainNodeCopyAddress(out.address, node.address)
    out.serveCount = node.servedCount
    out.tipEventCid = node.tipEventCid
    out.eventCids = ChainNodeCloneFixedBytes32Seq(node.eventCids)
    out.events = ChainNodeCloneEventSeq(node.events)
    out.forest = ChainNodeCloneForest(node.forest)
    ChainNodeCopySignature(out.signature, node.signature)

fn ChainNodeReplayFromSnapshotInto(out: var ChainNode,
                                     nodeId: str,
                                     address: types.LsmrAddress,
                                     snapshot: ChainNodeServeSnapshot): Result[bool] =
    if snapshot.eventCids.len != snapshot.events.len:
        return Err[bool](" chain_node: snapshot length mismatch")
    ChainNodeZeroInto(out, nodeId, address)
    for i in 0..<snapshot.events.len:
        var event = snapshot.events[i]
        event.stem = event.ganzhiIndex % 10
        event.branch = event.ganzhiIndex % 12
        event.bodyCid = consensus.ChainEventBodyCid(event)
        let applyRes = ChainNodeApplyEventWithDerived(out, event, false)
        if IsErr(applyRes):
            return Err[bool](Error(applyRes))
        if !layout.FixedBytes32Equal(Value(applyRes), snapshot.eventCids[i]):
            return Err[bool](" chain_node: snapshot cid mismatch")
    ChainNodeRebuildDerived(out)
    if !layout.FixedBytes32Equal(out.forest.forestCid, snapshot.forest.forestCid):
        return Err[bool](" chain_node: snapshot forest mismatch")
    if !anti.AntiEntropySignatureEqual(out.signature, snapshot.signature):
        return Err[bool](" chain_node: snapshot signature mismatch")
    out.servedCount = snapshot.serveCount
    return Ok[bool](true)

fn ChainNodeSyncOnce(node: var ChainNode, remote: ChainNodeServeSnapshot): Result[bool] =
    ChainNodeRebuildDerived(node)
    if !anti.PassiveAntiEntropySyncRequired(node.signature, remote.signature):
        return Ok[bool](false)
    if remote.eventCids.len < node.eventCids.len:
        return Err[bool](" chain_node: remote snapshot not newer")
    let replayRes = ChainNodeReplayFromSnapshotInto(node,
                                                      node.nodeId,
                                                      node.address,
                                                      remote)
    if IsErr(replayRes):
        return Err[bool](Error(replayRes))
    return Ok[bool](true)

fn ChainNodeForestCid(node: ChainNode): layout.FixedBytes32 =
    return node.forest.forestCid

fn ChainNodeAccountHeadFromNode(node: var ChainNode,
                                  assetId: int32,
                                  accountId: int32): layout.FixedBytes32 =
    return ChainNodeAccountHead(node.index, assetId, accountId)
