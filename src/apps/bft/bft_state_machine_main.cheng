@importc("cheng_sleep_ms_bridge")
fn cheng_sleep_ms_bridge(value: int32)

fn BftMainCurrentDir(): str =
    return os.GetCurrentDir()

fn BftMainReadTextFile(pathRaw: str): str =
    let cwd = BftMainCurrentDir()
    return chengpath.ReadTextFile(cwd, pathRaw)

fn BftMainWriteTextFile(pathRaw: str, text: str): bool =
    let cwd = BftMainCurrentDir()
    return chengpath.WriteTextFile(cwd, pathRaw, text)

fn BftMainFileExistsNonEmpty(pathRaw: str): bool =
    let cwd = BftMainCurrentDir()
    return chengpath.FileExistsNonEmpty(cwd, pathRaw)

fn BftMainAbsolutePath(pathRaw: str): str =
    let cwd = BftMainCurrentDir()
    return chengpath.PathAbsolute(cwd, pathRaw)

fn BftMainPrintErr(text: str) =
    let stderr = os.Get_stderr()
    os.WriteLine(stderr, text)

fn BftMainPrintOut(text: str) =
    let stdout = os.Get_stdout()
    os.WriteLine(stdout, text)

fn BftMainUsage() =
    BftMainPrintOut("usage: bft_state_machine <command> [flags]")
    BftMainPrintOut("")
    BftMainPrintOut("commands:")
    BftMainPrintOut("  self-test")
    BftMainPrintOut("  init --state:<file> --app-id:<id> --validator-slot:<n> [--force]")
    BftMainPrintOut("  submit-mint --queue:<file> --asset:<id> --account:<id> --amount:<n>")
    BftMainPrintOut("  submit-transfer --queue:<file> --asset:<id> --from:<id> --to:<id> --amount:<n>")
    BftMainPrintOut("  submit-transfer-series --queue:<file> --asset:<id> --from:<id> --to:<id> --amount:<n> --count:<n>")
    BftMainPrintOut("  show-state --state:<file>")
    BftMainPrintOut("  query-balance --state:<file> --asset:<id> --account:<id>")
    BftMainPrintOut("  query-summary --state:<file> --asset:<id> --account-a:<id> --account-b:<id>")
    BftMainPrintOut("  curve25519-probe")
    BftMainPrintOut("  curve25519-sweep [--count:<n>]")
    BftMainPrintOut("  curve25519-generated-sweep [--count:<n>]")
    BftMainPrintOut("  curve25519-shared --priv-hex:<64hex> --pub-hex:<64hex>")
    BftMainPrintOut("  tls13-finished-probe")
    BftMainPrintOut("  tls13-packet-flight-probe")
    BftMainPrintOut("  tls13-derive-probe --shared-hex:<64hex> --thash-hex:<64hex> [--cipher-id:<id>]")
    BftMainPrintOut("  probe-proposal --host:<ip> --port:<n> [--attempts:<n>] [--interval-ms:<n>] [--handshake-only] [--debug-tls13]")
    BftMainPrintOut("  proposal-serve-daemon --file:<file> --host:<ip> --port:<n> [--ready-path:<file>] [--interval-ms:<n>] [--max-serve-count:<n>] [--debug-tls13]")
    BftMainPrintOut("  commit-serve-daemon --file:<file> --host:<ip> --port:<n> [--ready-path:<file>] [--interval-ms:<n>] [--max-serve-count:<n>]")
    BftMainPrintOut("  state-serve-daemon --file:<file> --host:<ip> --port:<n> [--snapshot-dir:<dir>] [--ready-path:<file>] [--interval-ms:<n>] [--max-serve-count:<n>]")
    BftMainPrintOut("  vote-capture-daemon --file:<file> --host:<ip> --port:<n> [--ready-path:<file>] [--interval-ms:<n>] [--max-vote-count:<n>]")
    BftMainPrintOut("  validator-proposer-daemon --state:<file> --queue:<file> --proposal-host:<ip> --proposal-port:<n> --vote-host:<ip> --vote-port:<n> --commit-host:<ip> --commit-port:<n> [--vote-lock:<file>] [--queue-cursor:<file>] [--proposal-file:<file>] [--commit-file:<file>] [--state-sync-file:<file>] [--state-sync-dir:<dir>] [--proposal-ready-path:<file>] [--vote-ready-path:<file>] [--commit-ready-path:<file>] [--interval-ms:<n>] [--proposal-window-ms:<n>] [--vote-window-ms:<n>] [--commit-window-ms:<n>] [--max-rounds:<n>] [--max-txs:<n>]")
    BftMainPrintOut("  validator-follower-daemon --state:<file> --proposal-host:<ip> --proposal-port:<n> --vote-host:<ip> --vote-port:<n> --commit-host:<ip> --commit-port:<n> [--sync-host:<ip>] [--sync-port:<n>] [--vote-lock:<file>] [--interval-ms:<n>] [--max-rounds:<n>]")

fn BftMainTextStartsWith(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true

fn BftMainReadFlagValue(flag: str, outValue: var str): bool =
    outValue = ""
    let count = cmdline.ParamCount()
    let colonPrefix = flag + ":"
    let eqPrefix = flag + "="
    for i in 1..count:
        let arg = cmdline.ParamStr(i)
        if arg == flag:
            if i >= count:
                return false
            outValue = cmdline.ParamStr(i + 1)
            return true
        if BftMainTextStartsWith(arg, colonPrefix):
            outValue = chengpath.TextSlice(arg, len(colonPrefix), len(arg) - len(colonPrefix))
            return true
        if BftMainTextStartsWith(arg, eqPrefix):
            outValue = chengpath.TextSlice(arg, len(eqPrefix), len(arg) - len(eqPrefix))
            return true
    return false

fn BftMainReadRequiredFlag(flag: str, outValue: var str): Result[bool] =
    outValue = ""
    if !BftMainReadFlagValue(flag, outValue):
        return Err[bool](" bft main: missing " + flag)
    outValue = strutil.Strip(outValue)
    if len(outValue) <= 0:
        return Err[bool](" bft main: empty " + flag)
    return Ok[bool](true)

fn BftMainReadRequiredStatePath(outValue: var str): Result[bool] =
    return BftMainReadRequiredFlag("--state", outValue)

fn BftMainReadRequiredQueuePath(outValue: var str): Result[bool] =
    return BftMainReadRequiredFlag("--queue", outValue)

fn BftMainReadRequiredInt64Flag(flag: str): Result[int64] =
    var raw = ""
    let readRes = BftMainReadRequiredFlag(flag, raw)
    if IsErr(readRes):
        return Err[int64](Error(readRes))
    return host.BftValidatorParseInt64Text(raw)

fn BftMainReadServePort(flag: str): Result[int32] =
    let port = cmdline.ReadInt32FlagOrDefault(flag, -1)
    if port < 0 || port > 65535:
        return Err[int32](" bft main: invalid " + flag)
    return Ok[int32](port)

fn BftMainResolveReadyPortForSecondPhase(requestedPort: int32,
                                           readyPath: str): Result[int32] =
    if requestedPort > 0:
        return Ok[int32](requestedPort)
    if requestedPort == 0:
        if len(readyPath) <= 0:
            return Err[int32](" bft main: state-serve-daemon requires --ready-path when --port:0")
        let portTextRaw = BftMainReadTextFile(readyPath)
        let portText = strutil.Strip(portTextRaw)
        let parseRes = host.BftValidatorParseInt64Text(portText)
        if IsErr(parseRes):
            return Err[int32](" bft main: invalid ready port")
        if Value(parseRes) <= int64(0) || Value(parseRes) > int64(65535):
            return Err[int32](" bft main: invalid ready port")
        return Ok[int32](int32(Value(parseRes)))
    return Err[int32](" bft main: invalid --port")

fn BftMainSleepMs(value: int32) =
    if value <= 0:
        return
    cheng_sleep_ms_bridge(value)

fn BftMainFollowerVoteRetryLimit(): int32 =
    return 4

fn BftMainFollowerRetryableRecvError(err: str): bool =
    return BftMainTextStartsWith(err, " libp2p quic: dial") ||
           BftMainTextStartsWith(err, " libp2p quic: unexpected eof") ||
           BftMainTextStartsWith(err, "msquic: pipe closed") ||
           BftMainTextStartsWith(err, "msquic native: pipe read timeout") ||
           BftMainTextStartsWith(err, "msquic native: handshake ! ready") ||
           BftMainTextStartsWith(err, "msquic native: session ! ready")

fn BftMainFollowerRetryableLatestSyncError(err: str): bool =
    return BftMainFollowerRetryableRecvError(err) ||
           err == " bft validator: missing state snapshot" ||
           err == " bft validator: state sync ack unavailable" ||
           err == " bft validator: state sync payload unavailable"

fn BftMainSelfTest(): int32 =
    let appId = "bft-validator-self-test"
    let init1Res = host.BftValidatorStateInit(appId, 1)
    let init2Res = host.BftValidatorStateInit(appId, 2)
    let init3Res = host.BftValidatorStateInit(appId, 3)
    if IsErr(init1Res):
        panic(" bft main: init1 " + Error(init1Res))
    if IsErr(init2Res):
        panic(" bft main: init2 " + Error(init2Res))
    if IsErr(init3Res):
        panic(" bft main: init3 " + Error(init3Res))
    var state1 = Value(init1Res)
    var state2 = Value(init2Res)
    var state3 = Value(init3Res)

    let mintWire = bft.BftEncodeTx(bft.BftTxMint(7, 1001, int64(100)))
    var batch1: Bytes[]
    batch1 = []
    add(batch1, mintWire)
    let proposal1Res = host.BftValidatorProposalFromTxs(appId, int64(1), 1, batch1)
    if IsErr(proposal1Res):
        panic(" bft main: proposal1 " + Error(proposal1Res))
    let preview1Res = host.BftValidatorPreviewProposal(state1, Value(proposal1Res))
    let preview2Res = host.BftValidatorPreviewProposal(state2, Value(proposal1Res))
    if IsErr(preview1Res):
        panic(" bft main: preview1 " + Error(preview1Res))
    if IsErr(preview2Res):
        panic(" bft main: preview2 " + Error(preview2Res))
    assert(layout.fixedBytes32Equal(Value(preview1Res).proposalHash, Value(preview2Res).proposalHash), " bft main: preview proposal hash")
    assert(layout.fixedBytes32Equal(Value(preview1Res).appHash, Value(preview2Res).appHash), " bft main: preview app hash")
    let selfVote1Res = host.BftValidatorBuildVote(state1, Value(proposal1Res))
    let vote2Res = host.BftValidatorBuildVote(state2, Value(proposal1Res))
    if IsErr(selfVote1Res):
        panic(" bft main: self vote1 " + Error(selfVote1Res))
    if IsErr(vote2Res):
        panic(" bft main: vote2 " + Error(vote2Res))
    var votes1: host.BftVote[]
    votes1 = []
    add(votes1, Value(selfVote1Res))
    add(votes1, Value(vote2Res))
    let commit1Res = host.BftValidatorCommitFromVotes(Value(proposal1Res), Value(preview1Res), votes1)
    if IsErr(commit1Res):
        panic(" bft main: commit1 " + Error(commit1Res))
    let apply1Res = host.BftValidatorStateApplyCommit(state1, Value(commit1Res))
    let apply2Res = host.BftValidatorStateApplyCommit(state2, Value(commit1Res))
    if IsErr(apply1Res):
        panic(" bft main: apply commit1 state1 " + Error(apply1Res))
    if IsErr(apply2Res):
        panic(" bft main: apply commit1 state2 " + Error(apply2Res))

    let alice1 = host.BftValidatorQueryBalance(state1, 7, 1001)
    let alice2 = host.BftValidatorQueryBalance(state2, 7, 1001)
    let alice3 = host.BftValidatorQueryBalance(state3, 7, 1001)
    assert(alice1.balance == int64(100), " bft main: alice1")
    assert(alice2.balance == alice1.balance, " bft main: alice2")
    assert(alice3.balance == int64(0), " bft main: alice3")
    let statePath = "artifacts/bft_state_machine/self_test_state.txt"
    let _ = os.RemoveFile(statePath)
    if !host.BftValidatorWriteState(statePath, state1):
        panic(" bft main: write state")
    let reloadRes = host.BftValidatorLoadState(statePath)
    if IsErr(reloadRes):
        panic(" bft main: reload state " + Error(reloadRes))
    let reloaded = Value(reloadRes)
    let aliceReloaded = host.BftValidatorQueryBalance(reloaded, 7, 1001)
    if aliceReloaded.balance != int64(100):
        panic(" bft main: reload alice balance")
    let bobReloaded = host.BftValidatorQueryBalance(reloaded, 7, 2002)
    if bobReloaded.balance != int64(0):
        panic(" bft main: reload bob balance")
    let _ = os.RemoveFile(statePath)
    echo(" bft_state_machine self-test ok")
    return 0

fn BftMainInitCommand(): int32 =
    var statePath = ""
    let stateRes = BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        BftMainPrintErr(Error(stateRes))
        return 2
    let absoluteStatePath = BftMainAbsolutePath(statePath)
    if chengpath.PathFileExists(absoluteStatePath) && !cmdline.HasFlag("--force"):
        BftMainPrintErr(" bft main: state already exists: " + absoluteStatePath + " (pass --force to overwrite)")
        return 2
    var appId = ""
    let appIdRes = BftMainReadRequiredFlag("--app-id", appId)
    if IsErr(appIdRes):
        BftMainPrintErr(Error(appIdRes))
        return 2
    let validatorSlot = cmdline.ReadInt32FlagOrDefault("--validator-slot", 0)
    let initRes = host.BftValidatorStateInit(appId, validatorSlot)
    if IsErr(initRes):
        BftMainPrintErr(Error(initRes))
        return 2
    if !host.BftValidatorWriteState(statePath, Value(initRes)):
        BftMainPrintErr(" bft main: failed to write state: " + absoluteStatePath)
        return 2
    BftMainPrintOut(host.BftValidatorStateSummary(Value(initRes)))
    return 0

fn BftMainSubmitMintCommand(): int32 =
    var queuePath = ""
    let queueRes = BftMainReadRequiredQueuePath(queuePath)
    if IsErr(queueRes):
        BftMainPrintErr(Error(queueRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let accountId = cmdline.ReadInt32FlagOrDefault("--account", -1)
    let amountRes = BftMainReadRequiredInt64Flag("--amount")
    if assetId <= 0 || accountId <= 0 || IsErr(amountRes):
        if IsErr(amountRes):
            BftMainPrintErr(Error(amountRes))
        else:
            BftMainPrintErr(" bft main: submit-mint requires --asset --account --amount")
        return 2
    let txWire = bft.BftEncodeTx(bft.BftTxMint(assetId, accountId, Value(amountRes)))
    if !host.BftValidatorQueueAppend(queuePath, txWire):
        BftMainPrintErr(" bft main: failed to append queue")
        return 2
    BftMainPrintOut("queued_tx=" + bytesToHex(txWire))
    return 0

fn BftMainSubmitTransferCommand(): int32 =
    var queuePath = ""
    let queueRes = BftMainReadRequiredQueuePath(queuePath)
    if IsErr(queueRes):
        BftMainPrintErr(Error(queueRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let fromAccount = cmdline.ReadInt32FlagOrDefault("--from", -1)
    let toAccount = cmdline.ReadInt32FlagOrDefault("--to", -1)
    let amountRes = BftMainReadRequiredInt64Flag("--amount")
    if assetId <= 0 || fromAccount <= 0 || toAccount <= 0 || IsErr(amountRes):
        if IsErr(amountRes):
            BftMainPrintErr(Error(amountRes))
        else:
            BftMainPrintErr(" bft main: submit-transfer requires --asset --from --to --amount")
        return 2
    let txWire = bft.BftEncodeTx(bft.BftTxTransfer(assetId, fromAccount, toAccount, Value(amountRes)))
    if !host.BftValidatorQueueAppend(queuePath, txWire):
        BftMainPrintErr(" bft main: failed to append queue")
        return 2
    BftMainPrintOut("queued_tx=" + bytesToHex(txWire))
    return 0

fn BftMainSubmitTransferSeriesCommand(): int32 =
    var queuePath = ""
    let queueRes = BftMainReadRequiredQueuePath(queuePath)
    if IsErr(queueRes):
        BftMainPrintErr(Error(queueRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let fromAccount = cmdline.ReadInt32FlagOrDefault("--from", -1)
    let toAccount = cmdline.ReadInt32FlagOrDefault("--to", -1)
    let amountRes = BftMainReadRequiredInt64Flag("--amount")
    let count = cmdline.ReadInt32FlagOrDefault("--count", 0)
    if assetId <= 0 || fromAccount <= 0 || toAccount <= 0 || IsErr(amountRes) || count <= 0:
        if IsErr(amountRes):
            BftMainPrintErr(Error(amountRes))
        else:
            BftMainPrintErr(" bft main: submit-transfer-series requires --asset --from --to --amount --count")
        return 2
    let queueLoadRes = host.BftValidatorQueueLoad(queuePath)
    if IsErr(queueLoadRes):
        BftMainPrintErr(Error(queueLoadRes))
        return 2
    var txs = Value(queueLoadRes)
    let txWire = bft.BftEncodeTx(bft.BftTxTransfer(assetId, fromAccount, toAccount, Value(amountRes)))
    for i in 0..<count:
        i
        add(txs, txWire)
    if !host.BftValidatorQueueWrite(queuePath, txs):
        BftMainPrintErr(" bft main: failed to write queue")
        return 2
    let txWireBytes = int64(bytesLen(txWire))
    BftMainPrintOut("queued_count=" + host.BftValidatorInt64Text(int64(count)))
    BftMainPrintOut("tx_wire_bytes=" + host.BftValidatorInt64Text(txWireBytes))
    BftMainPrintOut("queued_bytes=" + host.BftValidatorInt64Text(txWireBytes * int64(count)))
    return 0

fn BftMainShowStateCommand(): int32 =
    var statePath = ""
    let stateRes = BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        BftMainPrintErr(Error(stateRes))
        return 2
    let loadRes = host.BftValidatorLoadState(statePath)
    if IsErr(loadRes):
        BftMainPrintErr(Error(loadRes))
        return 2
    BftMainPrintOut(host.BftValidatorStateSummary(Value(loadRes)))
    return 0

fn BftMainQueryBalanceCommand(): int32 =
    var statePath = ""
    let stateRes = BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        BftMainPrintErr(Error(stateRes))
        return 2
    let loadRes = host.BftValidatorLoadState(statePath)
    if IsErr(loadRes):
        BftMainPrintErr(Error(loadRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let accountId = cmdline.ReadInt32FlagOrDefault("--account", -1)
    if assetId <= 0 || accountId <= 0:
        BftMainPrintErr(" bft main: query-balance requires --asset and --account")
        return 2
    let res = host.BftValidatorQueryBalance(Value(loadRes), assetId, accountId)
    BftMainPrintOut("balance=" + host.BftValidatorInt64Text(res.balance))
    BftMainPrintOut("height=" + host.BftValidatorInt64Text(res.height))
    BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(res.appHash))
    return 0

fn BftMainQuerySummaryCommand(): int32 =
    var statePath = ""
    let stateRes = BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        BftMainPrintErr(Error(stateRes))
        return 2
    let loadRes = host.BftValidatorLoadState(statePath)
    if IsErr(loadRes):
        BftMainPrintErr(Error(loadRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let accountA = cmdline.ReadInt32FlagOrDefault("--account-a", -1)
    let accountB = cmdline.ReadInt32FlagOrDefault("--account-b", -1)
    if assetId <= 0 || accountA <= 0 || accountB <= 0:
        BftMainPrintErr(" bft main: query-summary requires --asset --account-a --account-b")
        return 2
    let state = Value(loadRes)
    let balanceA = host.BftValidatorQueryBalance(state, assetId, accountA)
    let balanceB = host.BftValidatorQueryBalance(state, assetId, accountB)
    BftMainPrintOut("height=" + host.BftValidatorInt64Text(state.machine.lastFinalizedHeight))
    BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(state.machine.lastCommitAppHash))
    BftMainPrintOut("balance_a=" + host.BftValidatorInt64Text(balanceA.balance))
    BftMainPrintOut("balance_b=" + host.BftValidatorInt64Text(balanceB.balance))
    return 0

fn BftMainProbeProposalCommand(): int32 =
    let hostText = cmdline.ReadFlagOrDefault("--host", "")
    let port = cmdline.ReadInt32FlagOrDefault("--port", -1)
    let attempts = cmdline.ReadInt32FlagOrDefault("--attempts", 256)
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 50)
    let handshakeOnlyText = cmdline.ReadFlagOrDefault("--handshake-only", "")
    let handshakeOnly = cmdline.HasFlag("--handshake-only") ||
                        (len(handshakeOnlyText) > 0 &&
                        handshakeOnlyText != "0" &&
                        handshakeOnlyText != "false" &&
                        handshakeOnlyText != "no" &&
                        handshakeOnlyText != "off")
    if len(hostText) <= 0 || port <= 0:
        BftMainPrintErr(" bft main: probe-proposal requires --host and --port")
        return 2
    var lastErr = ""
    for attempt in 0..<attempts:
        var client = qtransport.InitMsQuicTransport()
        var conn: qconn.Connection
        let dialRes = quic_transport.Libp2pQuicDialClientNamed(client,
                                                                 conn,
                                                                 hostText,
                                                                 port,
                                                                 host.BftValidatorPublicTransportServerName())
        if IsErr(dialRes):
            lastErr = Error(dialRes)
        else:
            BftMainPrintOut("probe_stage=dial_ok")
            let selectRes = quic_transport.Libp2pQuicClientSelectProtocol(client,
                                                                            conn,
                                                                            host.BftValidatorProposalProtocol())
            if IsErr(selectRes):
                lastErr = Error(selectRes)
                qconn.ConnClose(conn)
            else:
                BftMainPrintOut("probe_stage=select_ok")
                if handshakeOnly:
                    qconn.ConnClose(conn)
                    return 0
                let payloadRes = quic_transport.Libp2pQuicReadFrame(client, conn)
                qconn.ConnClose(conn)
                if IsErr(payloadRes):
                    lastErr = Error(payloadRes)
                else:
                    BftMainPrintOut("probe_stage=read_ok")
                    let proposalRes = host.BftValidatorDecodeProposal(Value(payloadRes))
                    if IsErr(proposalRes):
                        lastErr = Error(proposalRes)
                    else:
                        let proposal = Value(proposalRes)
                        BftMainPrintOut("probe_stage=decode_ok")
                        BftMainPrintOut("proposal_height=" + host.BftValidatorInt64Text(proposal.height))
                        BftMainPrintOut("proposal_txs=" + intToStr(proposal.txs.len))
                        return 0
        if !BftMainFollowerRetryableRecvError(lastErr):
            BftMainPrintErr(lastErr)
            return 1
        if attempt + 1 < attempts && intervalMs > 0:
            BftMainSleepMs(intervalMs)
    BftMainPrintErr(lastErr)
    return 1

fn BftMainCurve25519ProbeCommand(): int32 =
    let aliceRes = fixed256.scalar256FromHex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    let bobRes = fixed256.scalar256FromHex("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    if IsErr(aliceRes):
        BftMainPrintErr(Error(aliceRes))
        return 2
    if IsErr(bobRes):
        BftMainPrintErr(Error(bobRes))
        return 2
    let alicePubRes = fixed256.curve25519PublicKey(Value(aliceRes))
    let bobPubRes = fixed256.curve25519PublicKey(Value(bobRes))
    if IsErr(alicePubRes):
        BftMainPrintErr(Error(alicePubRes))
        return 2
    if IsErr(bobPubRes):
        BftMainPrintErr(Error(bobPubRes))
        return 2
    let sharedRes = fixed256.curve25519SharedKeyFixed(Value(aliceRes), Value(bobPubRes))
    if IsErr(sharedRes):
        BftMainPrintErr(Error(sharedRes))
        return 2
    BftMainPrintOut("alice=" + layout.fixedBytes32Hex(Value(alicePubRes)))
    BftMainPrintOut("bob=" + layout.fixedBytes32Hex(Value(bobPubRes)))
    BftMainPrintOut("shared=" + layout.fixedBytes32Hex(Value(sharedRes)))
    return 0

fn BftMainCurve25519SweepCommand(): int32 =
    let count = cmdline.ReadInt32FlagOrDefault("--count", 8)
    if count <= 0:
        BftMainPrintErr(" bft main: curve25519-sweep count must be positive")
        return 2
    for i in 0..<count:
        let privA = BftMainTls13ProbeSeed32(101 + i)
        let privB = BftMainTls13ProbeSeed32(201 + i)
        let pubARes = curve25519.curve25519PublicFromPrivate(privA)
        let pubBRes = curve25519.curve25519PublicFromPrivate(privB)
        if IsErr(pubARes):
            BftMainPrintErr(ErrorText(pubARes))
            return 2
        if IsErr(pubBRes):
            BftMainPrintErr(ErrorText(pubBRes))
            return 2
        let sharedRes = curve25519.curve25519SharedKey(privA, Value(pubBRes))
        if IsErr(sharedRes):
            BftMainPrintErr(ErrorText(sharedRes))
            return 2
        BftMainPrintOut("tag=" + intToStr(i))
        BftMainPrintOut("pub_a=" + bytesToHex(Value(pubARes)))
        BftMainPrintOut("pub_b=" + bytesToHex(Value(pubBRes)))
        BftMainPrintOut("shared=" + bytesToHex(Value(sharedRes)))
    return 0

fn BftMainCurve25519GeneratedSweepCommand(): int32 =
    let count = cmdline.ReadInt32FlagOrDefault("--count", 4)
    if count <= 0:
        BftMainPrintErr(" bft main: curve25519-generated-sweep count must be positive")
        return 2
    for i in 0..<count:
        let seed = BftMainTls13ProbeSeed32(301 + i)
        if !rand.setRandomSeed(seed):
            BftMainPrintErr(" bft main: failed to set random seed")
            return 2
        var privA = emptyBytes()
        var pubA = emptyBytes()
        var privB = emptyBytes()
        var pubB = emptyBytes()
        let genARes = curve25519.generateCurve25519KeyPairInto(privA, pubA)
        let genBRes = curve25519.generateCurve25519KeyPairInto(privB, pubB)
        if IsErr(genARes):
            BftMainPrintErr(ErrorText(genARes))
            return 2
        if IsErr(genBRes):
            BftMainPrintErr(ErrorText(genBRes))
            return 2
        let sharedRes = curve25519.curve25519SharedKey(privA, pubB)
        if IsErr(sharedRes):
            BftMainPrintErr(ErrorText(sharedRes))
            return 2
        BftMainPrintOut("tag=" + intToStr(i))
        BftMainPrintOut("priv_a=" + bytesToHex(privA))
        BftMainPrintOut("pub_a=" + bytesToHex(pubA))
        BftMainPrintOut("priv_b=" + bytesToHex(privB))
        BftMainPrintOut("pub_b=" + bytesToHex(pubB))
        BftMainPrintOut("shared=" + bytesToHex(Value(sharedRes)))
    return 0

fn BftMainCurve25519SharedCommand(): int32 =
    var privHex = ""
    let privHexRes = BftMainReadRequiredFlag("--priv-hex", privHex)
    if IsErr(privHexRes):
        BftMainPrintErr(ErrorText(privHexRes))
        return 2
    var pubHex = ""
    let pubHexRes = BftMainReadRequiredFlag("--pub-hex", pubHex)
    if IsErr(pubHexRes):
        BftMainPrintErr(ErrorText(pubHexRes))
        return 2
    let privRes = fixed256.scalar256FromHex(privHex)
    if IsErr(privRes):
        BftMainPrintErr(ErrorText(privRes))
        return 2
    let pubRes = layout.fixedBytes32FromHex(pubHex)
    if IsErr(pubRes):
        BftMainPrintErr(ErrorText(pubRes))
        return 2
    let sharedRes = curve25519.curve25519SharedKey(fixed256.scalar256ToBytes(Value(privRes)),
                                                   layout.fixedBytes32ToBytes(Value(pubRes)))
    if IsErr(sharedRes):
        BftMainPrintErr(ErrorText(sharedRes))
        return 2
    BftMainPrintOut(bytesToHex(Value(sharedRes)))
    return 0

fn BftMainTls13ProbeSeed32(tag: int32): Bytes =
    let out = bytesAlloc(32)
    for i in 0..<32:
        let v = (tag * 41 + i * 17 + 29) & 255
        bytesSet(out, i, v)
    return out

fn BftMainTls13FinishedProbeCommand(): int32 =
    let serverName = host.BftValidatorPublicTransportServerName()
    let policy = test_pki.msquicMakePublicTransportTlsPolicy(serverName)
    let clientPrivRes = fixed256.scalar256FromHex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    let serverPrivRes = fixed256.scalar256FromHex("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    if IsErr(clientPrivRes):
        BftMainPrintErr(ErrorText(clientPrivRes))
        return 2
    if IsErr(serverPrivRes):
        BftMainPrintErr(ErrorText(serverPrivRes))
        return 2
    let clientPubRes = fixed256.curve25519PublicKey(Value(clientPrivRes))
    let serverPubRes = fixed256.curve25519PublicKey(Value(serverPrivRes))
    if IsErr(clientPubRes):
        BftMainPrintErr(ErrorText(clientPubRes))
        return 2
    if IsErr(serverPubRes):
        BftMainPrintErr(ErrorText(serverPubRes))
        return 2
    let clientPriv = fixed256.scalar256ToBytes(Value(clientPrivRes))
    let clientPub = layout.fixedBytes32ToBytes(Value(clientPubRes))
    let serverPriv = fixed256.scalar256ToBytes(Value(serverPrivRes))
    let serverPub = layout.fixedBytes32ToBytes(Value(serverPubRes))
    handshake13.msquicTls13ResetClientDefault(true)
    handshake13.msquicTls13ResetServerDefault(true)
    handshake13.msquicTls13ClientSetServerName(serverName)
    handshake13.msquicTls13ServerSetServerName(serverName)
    let trustRootRes = handshake13.msquicTls13ClientAddTrustRoot(policy.trustRoot0)
    if IsErr(trustRootRes):
        BftMainPrintErr(ErrorText(trustRootRes))
        return 2
    handshake13.msquicTls13ClientSetLocalX25519(clientPriv, clientPub)
    handshake13.msquicTls13ServerSetLocalX25519(serverPriv, serverPub)

    let clientHelloRes = handshake13.msquicTls13ClientBuildClientHello(BftMainTls13ProbeSeed32(17),
                                                                       "dm",
                                                                       serverName,
                                                                       emptyBytes())
    if IsErr(clientHelloRes):
        BftMainPrintErr(ErrorText(clientHelloRes))
        return 2
    let clientHello = Value(clientHelloRes)
    handshake13.msquicTls13ClientAppendTranscript(clientHello)
    let serverFeedRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideServer, clientHello)
    if IsErr(serverFeedRes):
        BftMainPrintErr(ErrorText(serverFeedRes))
        return 2
    BftMainPrintOut("server_feed_count=" + intToStr(Value(serverFeedRes)))

    let serverHelloRes = handshake13.msquicTls13ServerBuildServerHello(BftMainTls13ProbeSeed32(23), false)
    if IsErr(serverHelloRes):
        BftMainPrintErr(ErrorText(serverHelloRes))
        return 2
    let serverHello = Value(serverHelloRes)
    handshake13.msquicTls13ServerAppendTranscript(serverHello)
    let serverSecretsRes = handshake13.msquicTls13SideComputeHandshakeSecrets(handshake13.msQuicTls13SideServer)
    if IsErr(serverSecretsRes):
        BftMainPrintErr(ErrorText(serverSecretsRes))
        return 2

    let encryptedExtensionsRes = handshake13.msquicTls13BuildEncryptedExtensions("dm", emptyBytes())
    if IsErr(encryptedExtensionsRes):
        BftMainPrintErr(ErrorText(encryptedExtensionsRes))
        return 2
    let encryptedExtensions = Value(encryptedExtensionsRes)
    handshake13.msquicTls13ServerAppendTranscript(encryptedExtensions)

    let certificateRes = handshake13.msquicTls13BuildCertificate(policy.certChain0)
    if IsErr(certificateRes):
        BftMainPrintErr(ErrorText(certificateRes))
        return 2
    let certificate = Value(certificateRes)
    handshake13.msquicTls13ServerAppendTranscript(certificate)

    let certVerifyRes = handshake13.msquicTls13ServerBuildCertificateVerify(policy.certLeafKeyKind,
                                                                            policy.certPrivateKey,
                                                                            true)
    if IsErr(certVerifyRes):
        BftMainPrintErr(ErrorText(certVerifyRes))
        return 2
    let certVerify = Value(certVerifyRes)
    handshake13.msquicTls13ServerAppendTranscript(certVerify)

    let serverFinishedRes = handshake13.msquicTls13ServerBuildFinished(true)
    if IsErr(serverFinishedRes):
        BftMainPrintErr(ErrorText(serverFinishedRes))
        return 2
    let serverFinished = Value(serverFinishedRes)

    let clientServerHelloRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, serverHello)
    let clientEncryptedExtensionsRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, encryptedExtensions)
    let clientCertificateRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, certificate)
    let clientCertVerifyRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, certVerify)
    if IsErr(clientServerHelloRes):
        BftMainPrintErr(ErrorText(clientServerHelloRes))
        return 2
    if IsErr(clientEncryptedExtensionsRes):
        BftMainPrintErr(ErrorText(clientEncryptedExtensionsRes))
        return 2
    if IsErr(clientCertificateRes):
        BftMainPrintErr(ErrorText(clientCertificateRes))
        return 2
    if IsErr(clientCertVerifyRes):
        BftMainPrintErr(ErrorText(clientCertVerifyRes))
        return 2
    BftMainPrintOut("client_server_hello_count=" + intToStr(Value(clientServerHelloRes)))
    BftMainPrintOut("client_encrypted_extensions_count=" + intToStr(Value(clientEncryptedExtensionsRes)))
    BftMainPrintOut("client_certificate_count=" + intToStr(Value(clientCertificateRes)))
    BftMainPrintOut("client_cert_verify_count=" + intToStr(Value(clientCertVerifyRes)))

    let clientExpectedServerFinishedRes = handshake13.msquicTls13ClientBuildFinished(true)
    if IsErr(clientExpectedServerFinishedRes):
        BftMainPrintErr(ErrorText(clientExpectedServerFinishedRes))
        return 2
    let clientExpectedServerFinished = Value(clientExpectedServerFinishedRes)
    let parseFinishedRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, serverFinished)

    BftMainPrintOut("server_finished=" + bytesToHex(serverFinished))
    BftMainPrintOut("client_expected_server_finished=" + bytesToHex(clientExpectedServerFinished))
    if bytesEqual(serverFinished, clientExpectedServerFinished):
        BftMainPrintOut("server_finished_match=true")
    else:
        BftMainPrintOut("server_finished_match=false")
    if IsErr(parseFinishedRes):
        BftMainPrintOut("client_parse_finished=err:" + ErrorText(parseFinishedRes))
    else:
        BftMainPrintOut("client_parse_finished=ok:" + intToStr(Value(parseFinishedRes)))
    if handshake13.msquicTls13ClientFinishedOk():
        BftMainPrintOut("client_finished_ok=true")
    else:
        BftMainPrintOut("client_finished_ok=false")

    handshake13.msquicTls13ResetClientDefault(true)
    handshake13.msquicTls13ClientSetServerName(serverName)
    let combinedTrustRootRes = handshake13.msquicTls13ClientAddTrustRoot(policy.trustRoot0)
    if IsErr(combinedTrustRootRes):
        BftMainPrintErr(ErrorText(combinedTrustRootRes))
        return 2
    handshake13.msquicTls13ClientSetLocalX25519(clientPriv, clientPub)
    let combinedClientHelloRes = handshake13.msquicTls13ClientBuildClientHello(BftMainTls13ProbeSeed32(17),
                                                                               "dm",
                                                                               serverName,
                                                                               emptyBytes())
    if IsErr(combinedClientHelloRes):
        BftMainPrintErr(ErrorText(combinedClientHelloRes))
        return 2
    handshake13.msquicTls13ClientAppendTranscript(Value(combinedClientHelloRes))
    var serverFlightBuf = newByteBuffer()
    appendBytes(serverFlightBuf, serverHello)
    appendBytes(serverFlightBuf, encryptedExtensions)
    appendBytes(serverFlightBuf, certificate)
    appendBytes(serverFlightBuf, certVerify)
    appendBytes(serverFlightBuf, serverFinished)
    let combinedFeedRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, toBytes(serverFlightBuf))
    if IsErr(combinedFeedRes):
        BftMainPrintOut("client_combined_feed=err:" + ErrorText(combinedFeedRes))
    else:
        BftMainPrintOut("client_combined_feed=ok:" + intToStr(Value(combinedFeedRes)))
    if handshake13.msquicTls13ClientFinishedOk():
        BftMainPrintOut("client_combined_finished_ok=true")
    else:
        BftMainPrintOut("client_combined_finished_ok=false")
    return 0

fn BftMainTls13PacketFlightProbeCommand(): int32 =
    let serverName = host.BftValidatorPublicTransportServerName()
    let policy = test_pki.msquicMakePublicTransportTlsPolicy(serverName)
    let clientPrivRes = fixed256.scalar256FromHex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    let serverPrivRes = fixed256.scalar256FromHex("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    if IsErr(clientPrivRes):
        BftMainPrintErr(ErrorText(clientPrivRes))
        return 2
    if IsErr(serverPrivRes):
        BftMainPrintErr(ErrorText(serverPrivRes))
        return 2
    let clientPubRes = fixed256.curve25519PublicKey(Value(clientPrivRes))
    let serverPubRes = fixed256.curve25519PublicKey(Value(serverPrivRes))
    if IsErr(clientPubRes):
        BftMainPrintErr(ErrorText(clientPubRes))
        return 2
    if IsErr(serverPubRes):
        BftMainPrintErr(ErrorText(serverPubRes))
        return 2
    let clientPriv = fixed256.scalar256ToBytes(Value(clientPrivRes))
    let clientPub = layout.fixedBytes32ToBytes(Value(clientPubRes))
    let serverPriv = fixed256.scalar256ToBytes(Value(serverPrivRes))
    let serverPub = layout.fixedBytes32ToBytes(Value(serverPubRes))

    qnative.msquicNativeResetSession()
    handshake13.msquicTls13ResetClientDefault(true)
    handshake13.msquicTls13ResetServerDefault(true)
    handshake13.msquicTls13ClientSetServerName(serverName)
    handshake13.msquicTls13ServerSetServerName(serverName)
    let trustRootRes = handshake13.msquicTls13ClientAddTrustRoot(policy.trustRoot0)
    if IsErr(trustRootRes):
        BftMainPrintErr(ErrorText(trustRootRes))
        return 2
    handshake13.msquicTls13ClientSetLocalX25519(clientPriv, clientPub)
    handshake13.msquicTls13ServerSetLocalX25519(serverPriv, serverPub)

    let clientHelloRes = handshake13.msquicTls13ClientBuildClientHello(BftMainTls13ProbeSeed32(17),
                                                                       "dm",
                                                                       serverName,
                                                                       emptyBytes())
    if IsErr(clientHelloRes):
        BftMainPrintErr(ErrorText(clientHelloRes))
        return 2
    let clientHello = Value(clientHelloRes)
    handshake13.msquicTls13ClientAppendTranscript(clientHello)
    let serverFeedRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideServer, clientHello)
    if IsErr(serverFeedRes):
        BftMainPrintErr(ErrorText(serverFeedRes))
        return 2

    let serverHelloRes = handshake13.msquicTls13ServerBuildServerHello(BftMainTls13ProbeSeed32(23), false)
    if IsErr(serverHelloRes):
        BftMainPrintErr(ErrorText(serverHelloRes))
        return 2
    let serverHello = Value(serverHelloRes)
    handshake13.msquicTls13ServerAppendTranscript(serverHello)
    let serverSecretsRes = handshake13.msquicTls13SideComputeHandshakeSecrets(handshake13.msQuicTls13SideServer)
    if IsErr(serverSecretsRes):
        BftMainPrintErr(ErrorText(serverSecretsRes))
        return 2

    let encryptedExtensionsRes = handshake13.msquicTls13BuildEncryptedExtensions("dm", emptyBytes())
    if IsErr(encryptedExtensionsRes):
        BftMainPrintErr(ErrorText(encryptedExtensionsRes))
        return 2
    let encryptedExtensions = Value(encryptedExtensionsRes)
    handshake13.msquicTls13ServerAppendTranscript(encryptedExtensions)

    let certificateRes = handshake13.msquicTls13BuildCertificate(policy.certChain0)
    if IsErr(certificateRes):
        BftMainPrintErr(ErrorText(certificateRes))
        return 2
    let certificate = Value(certificateRes)
    handshake13.msquicTls13ServerAppendTranscript(certificate)

    let certVerifyRes = handshake13.msquicTls13ServerBuildCertificateVerify(policy.certLeafKeyKind,
                                                                            policy.certPrivateKey,
                                                                            true)
    if IsErr(certVerifyRes):
        BftMainPrintErr(ErrorText(certVerifyRes))
        return 2
    let certVerify = Value(certVerifyRes)
    handshake13.msquicTls13ServerAppendTranscript(certVerify)

    let serverFinishedRes = handshake13.msquicTls13ServerBuildFinished(true)
    if IsErr(serverFinishedRes):
        BftMainPrintErr(ErrorText(serverFinishedRes))
        return 2
    let serverFinished = Value(serverFinishedRes)

    var cryptoBuf = buffer.NewByteBuffer()
    buffer.AppendBytes(cryptoBuf, serverHello)
    buffer.AppendBytes(cryptoBuf, encryptedExtensions)
    buffer.AppendBytes(cryptoBuf, certificate)
    buffer.AppendBytes(cryptoBuf, certVerify)
    buffer.AppendBytes(cryptoBuf, serverFinished)

    var pkt: qpacket.MsQuicPacket = qpacket.initMsQuicPacket(1)
    let addRes = qpacket.msquicPacketAddFrame(pkt, qframe.msquicFrameCrypto(0, buffer.ToBytes(cryptoBuf)))
    if IsErr(addRes):
        BftMainPrintErr(ErrorText(addRes))
        return 2
    let payloadRes = qpacket.msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        BftMainPrintErr(ErrorText(payloadRes))
        return 2
    let payload = Value(payloadRes)

    var header: qheader.QuicPacketHeader
    header.longHeader = true
    header.packetType = qheader.QuicPacketHandshake
    header.version = qnative.msquicNativeVersion
    header.dcid = qnative.msquicNativeConnId(0x11111111)
    header.scid = qnative.msquicNativeConnId(0x22222222)
    header.token = emptyBytes()
    header.payloadLength = int64(bytesLen(payload) + 2)
    header.packetNumber = 1
    header.packetNumberLen = 2
    header.spinBit = false
    header.keyPhase = false
    let headerRes = qheader.quicPacketHeaderEncode(header)
    if IsErr(headerRes):
        BftMainPrintErr(ErrorText(headerRes))
        return 2
    let wire = bytesConcat3(Value(headerRes), payload, emptyBytes())

    let decodeHeaderRes = qheader.quicPacketHeaderDecode(wire, qnative.msquicNativeConnIdLen)
    if IsErr(decodeHeaderRes):
        BftMainPrintErr(ErrorText(decodeHeaderRes))
        return 2
    let headerDec = Value(decodeHeaderRes)
    let payloadOffset: int32 = headerDec.next
    let decodedPayloadLen: int32 = int32(headerDec.header.payloadLength) - headerDec.header.packetNumberLen
    if decodedPayloadLen <= 0:
        BftMainPrintErr(" bft main: tls13 packet probe payload empty")
        return 2
    let decodedPayload = bytesSlice(wire, payloadOffset, decodedPayloadLen)
    var decodedPkt: qpacket.MsQuicPacket
    let decodePayloadRes = qpacket.msquicPacketPayloadDecodeInto(decodedPkt, decodedPayload, headerDec.header.packetNumber)
    if IsErr(decodePayloadRes):
        BftMainPrintErr(ErrorText(decodePayloadRes))
        return 2
    for i in 0..<decodedPkt.framesCount:
        if decodedPkt.frames[i].kind == qframe.FrameCrypto:
            let feedRes = qnative.msquicNativeHandleCryptoData(qnative.msquicNativeClientSide,
                                                               qnative.msquicNativePacketHandshakeCode,
                                                               decodedPkt.frames[i].offset,
                                                               decodedPkt.frames[i].data)
            if IsErr(feedRes):
                BftMainPrintOut("client_packet_feed=err:" + ErrorText(feedRes))
                BftMainPrintOut("client_last_error=" + handshake13.msquicTls13ClientLastErrorText())
                return 2
    var finishedOkText = "false"
    if handshake13.msquicTls13ClientFinishedOk():
        finishedOkText = "true"
    BftMainPrintOut("server_feed_count=" + intToStr(Value(serverFeedRes)))
    BftMainPrintOut("server_finished=" + bytesToHex(serverFinished))
    BftMainPrintOut("client_finished_ok=" + finishedOkText)
    BftMainPrintOut("client_message_count=" + intToStr(handshake13.msquicTls13ClientHandshakeMessageCount()))
    BftMainPrintOut("client_buffered=" + intToStr(handshake13.msquicTls13ClientBufferedHandshakeBytes()))
    BftMainPrintOut("client_last_error=" + handshake13.msquicTls13ClientLastErrorText())
    return 0

fn BftMainTls13DeriveProbeCommand(): int32 =
    var sharedHex = ""
    let sharedHexRes = BftMainReadRequiredFlag("--shared-hex", sharedHex)
    if IsErr(sharedHexRes):
        BftMainPrintErr(ErrorText(sharedHexRes))
        return 2
    var thashHex = ""
    let thashHexRes = BftMainReadRequiredFlag("--thash-hex", thashHex)
    if IsErr(thashHexRes):
        BftMainPrintErr(ErrorText(thashHexRes))
        return 2
    let sharedRes = tls13.msquicTls13HexDecode(sharedHex)
    if IsErr(sharedRes):
        BftMainPrintErr(ErrorText(sharedRes))
        return 2
    let thashRes = tls13.msquicTls13HexDecode(thashHex)
    if IsErr(thashRes):
        BftMainPrintErr(ErrorText(thashRes))
        return 2
    let cipherId = cmdline.ReadInt32FlagOrDefault("--cipher-id", 4865)
    let cipherRes = handshake13.msquicTls13CipherFromId(cipherId)
    if IsErr(cipherRes):
        BftMainPrintErr(ErrorText(cipherRes))
        return 2
    let shared = Value(sharedRes)
    let thash = Value(thashRes)
    let cipher = Value(cipherRes)
    let early = tls13.msquicTls13HkdfExtract(cipher, emptyBytes(), emptyBytes())
    let emptyHash = tls13.msquicTls13EmptyHash(cipher)
    let derived1Res = tls13.msquicTls13DeriveSecret(early, "derived", emptyHash, cipher)
    if IsErr(derived1Res):
        BftMainPrintErr(ErrorText(derived1Res))
        return 2
    let derived1 = Value(derived1Res)
    let handshake = tls13.msquicTls13HkdfExtract(cipher, shared, derived1)
    let chsRes = tls13.msquicTls13DeriveSecret(handshake, "c hs traffic", thash, cipher)
    if IsErr(chsRes):
        BftMainPrintErr(ErrorText(chsRes))
        return 2
    let shsRes = tls13.msquicTls13DeriveSecret(handshake, "s hs traffic", thash, cipher)
    if IsErr(shsRes):
        BftMainPrintErr(ErrorText(shsRes))
        return 2
    let derived2Res = tls13.msquicTls13DeriveSecret(handshake, "derived", emptyHash, cipher)
    if IsErr(derived2Res):
        BftMainPrintErr(ErrorText(derived2Res))
        return 2
    let derived2 = Value(derived2Res)
    let master = tls13.msquicTls13HkdfExtract(cipher, emptyBytes(), derived2)
    let hashLen = tls13.msquicTls13HashLen(cipher)
    let resumptionRes = tls13.msquicTls13ExpandLabel(master, "res master", emptyBytes(), hashLen, cipher)
    if IsErr(resumptionRes):
        BftMainPrintErr(ErrorText(resumptionRes))
        return 2
    let capRes = tls13.msquicTls13DeriveSecret(master, "c ap traffic", thash, cipher)
    if IsErr(capRes):
        BftMainPrintErr(ErrorText(capRes))
        return 2
    let sapRes = tls13.msquicTls13DeriveSecret(master, "s ap traffic", thash, cipher)
    if IsErr(sapRes):
        BftMainPrintErr(ErrorText(sapRes))
        return 2
    BftMainPrintOut("early=" + bytesToHex(early))
    BftMainPrintOut("empty_hash=" + bytesToHex(emptyHash))
    BftMainPrintOut("derived1=" + bytesToHex(derived1))
    BftMainPrintOut("handshake=" + bytesToHex(handshake))
    BftMainPrintOut("derived2=" + bytesToHex(derived2))
    BftMainPrintOut("chs=" + bytesToHex(Value(chsRes)))
    BftMainPrintOut("shs=" + bytesToHex(Value(shsRes)))
    BftMainPrintOut("cap=" + bytesToHex(Value(capRes)))
    BftMainPrintOut("sap=" + bytesToHex(Value(sapRes)))
    BftMainPrintOut("master=" + bytesToHex(master))
    BftMainPrintOut("resumption=" + bytesToHex(Value(resumptionRes)))
    return 0

fn BftMainServeHexDaemonCommand(protocol: types.Libp2pProtocolId): int32 =
    var filePath = ""
    let fileRes = BftMainReadRequiredFlag("--file", filePath)
    if IsErr(fileRes):
        BftMainPrintErr(Error(fileRes))
        return 2
    let hostText = cmdline.ReadFlagOrDefault("--host", "0.0.0.0")
    let portRes = BftMainReadServePort("--port")
    if IsErr(portRes):
        BftMainPrintErr(Error(portRes))
        return 2
    let port = Value(portRes)
    let readyPath = cmdline.ReadFlagOrDefault("--ready-path", "")
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 200)
    let maxServeCount = cmdline.ReadInt32FlagOrDefault("--max-serve-count", 0)
    var served = 0
    while maxServeCount <= 0 || served < maxServeCount:
        let payloadRes = host.BftValidatorReadHexFile(filePath)
        if IsOk(payloadRes) && bytesLen(Value(payloadRes)) > 0:
            let serveRes = host.BftValidatorServeHexFileOnce(filePath, hostText, port, protocol, readyPath)
            if IsErr(serveRes):
                BftMainPrintErr(Error(serveRes))
                return 2
            served = served + 1
        else:
            BftMainSleepMs(intervalMs)
    return 0

fn BftMainStateServeDaemonCommand(): int32 =
    var filePath = ""
    let fileRes = BftMainReadRequiredFlag("--file", filePath)
    if IsErr(fileRes):
        BftMainPrintErr(Error(fileRes))
        return 2
    let hostText = cmdline.ReadFlagOrDefault("--host", "0.0.0.0")
    let portRes = BftMainReadServePort("--port")
    if IsErr(portRes):
        BftMainPrintErr(Error(portRes))
        return 2
    let port = Value(portRes)
    var snapshotDir = cmdline.ReadFlagOrDefault("--snapshot-dir", "")
    if len(snapshotDir) <= 0:
        snapshotDir = host.BftValidatorDefaultStateSyncDir(filePath)
    let readyPath = cmdline.ReadFlagOrDefault("--ready-path", "")
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 0)
    let maxServeCount = cmdline.ReadInt32FlagOrDefault("--max-serve-count", 0)
    var served = 0
    while maxServeCount <= 0 || served < maxServeCount:
        let requestRes = quic_transport.Libp2pQuicServeRequestCaptureOnceNamed(hostText,
                                                                                 port,
                                                                                 host.BftValidatorPublicTransportServerName(),
                                                                                 host.BftValidatorStateSyncProtocol(),
                                                                                 bytesFromString(host.BftValidatorStateSyncAck),
                                                                                 readyPath)
        if IsErr(requestRes):
            BftMainPrintErr(Error(requestRes))
            return 2
        let heightRes = host.BftValidatorDecodeStateSyncRequest(Value(requestRes))
        var payload = host.BftValidatorEncodeStateSyncError(" bft validator: bad state sync request")
        if IsOk(heightRes):
            payload = host.BftValidatorStateSyncPayloadForHeight(snapshotDir, Value(heightRes))
        else:
            payload = host.BftValidatorEncodeStateSyncError(Error(heightRes))
        let payloadPortRes = BftMainResolveReadyPortForSecondPhase(port, readyPath)
        if IsErr(payloadPortRes):
            BftMainPrintErr(Error(payloadPortRes))
            return 2
        let serveRes = quic_transport.Libp2pQuicServePayloadOnceNamed(hostText,
                                                                        Value(payloadPortRes),
                                                                        host.BftValidatorPublicTransportServerName(),
                                                                        host.BftValidatorStateSyncProtocol(),
                                                                        payload,
                                                                        readyPath)
        if IsErr(serveRes):
            BftMainPrintErr(Error(serveRes))
            return 2
        served = served + 1
        if intervalMs > 0 && (maxServeCount <= 0 || served < maxServeCount):
            BftMainSleepMs(intervalMs)
    return 0

fn BftMainVoteCaptureDaemonCommand(): int32 =
    var filePath = ""
    let fileRes = BftMainReadRequiredFlag("--file", filePath)
    if IsErr(fileRes):
        BftMainPrintErr(Error(fileRes))
        return 2
    let hostText = cmdline.ReadFlagOrDefault("--host", "0.0.0.0")
    let portRes = BftMainReadServePort("--port")
    if IsErr(portRes):
        BftMainPrintErr(Error(portRes))
        return 2
    let port = Value(portRes)
    let readyPath = cmdline.ReadFlagOrDefault("--ready-path", "")
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 0)
    let maxVoteCount = cmdline.ReadInt32FlagOrDefault("--max-vote-count", 0)
    var captured = 0
    while maxVoteCount <= 0 || captured < maxVoteCount:
        let captureRes = host.BftValidatorCaptureVoteOnce(filePath, hostText, port, readyPath)
        if IsErr(captureRes):
            BftMainPrintErr(Error(captureRes))
            return 2
        captured = captured + 1
        if intervalMs > 0 && (maxVoteCount <= 0 || captured < maxVoteCount):
            BftMainSleepMs(intervalMs)
    return 0

fn BftMainClearFile(pathRaw: str) =
    let _ = BftMainWriteTextFile(pathRaw, "")

fn BftMainFollowerVoteStep(voteLockPath: str,
                             state: var host.BftValidatorState,
                             proposalHost: str,
                             proposalPort: int32,
                             voteHost: str,
                             votePort: int32): Result[bool] =
    let proposalRes = host.BftValidatorRecvProposal(proposalHost, proposalPort)
    if IsErr(proposalRes):
        if BftMainFollowerRetryableRecvError(Error(proposalRes)):
            return Ok[bool](false)
        return Err[bool](Error(proposalRes))
    let proposal = Value(proposalRes)
    if proposal.height <= state.machine.lastFinalizedHeight:
        return Ok[bool](false)
    let voteRes = host.BftValidatorBuildVote(state, proposal)
    if IsOk(voteRes):
        var voteSent = false
        for attempt in 0..<BftMainFollowerVoteRetryLimit():
            let sendRes = host.BftValidatorSendVote(voteHost, votePort, Value(voteRes))
            if IsOk(sendRes):
                voteSent = true
                break
            if !BftMainFollowerRetryableRecvError(Error(sendRes)):
                return Err[bool](Error(sendRes))
            if attempt + 1 < BftMainFollowerVoteRetryLimit():
                BftMainSleepMs(20)
        if !voteSent:
            return Ok[bool](false)
        state.lastVotedHeight = proposal.height
        state.lastVotedProposalHash = host.BftValidatorProposalHash(proposal)
        if !host.BftValidatorWriteVoteLock(voteLockPath, state):
            return Err[bool](" bft main: failed to persist vote lock")
        return Ok[bool](true)
    if Error(voteRes) == " bft validator: already voted for proposal" ||
       Error(voteRes) == " bft validator: proposal height mismatch":
        return Ok[bool](false)
    return Err[bool](Error(voteRes))

fn BftMainFollowerCommitStep(statePath: str,
                               voteLockPath: str,
                               state: var host.BftValidatorState,
                               commitHost: str,
                               commitPort: int32,
                               syncHost: str,
                               syncPort: int32): Result[int64] =
    let commitRes = host.BftValidatorRecvCommit(commitHost, commitPort)
    if IsErr(commitRes):
        if BftMainFollowerRetryableRecvError(Error(commitRes)):
            return Ok[int64](int64(0))
        return Err[int64](Error(commitRes))
    let commit = Value(commitRes)
    if commit.height <= state.machine.lastFinalizedHeight:
        return Ok[int64](int64(0))
    let applyRes = host.BftValidatorStateApplyCommit(state, commit)
    if IsErr(applyRes):
        if Error(applyRes) == " bft validator: proposal height mismatch":
            let syncRes = host.BftValidatorSyncMachineFromCommit(state, commit, syncHost, syncPort)
            if IsErr(syncRes):
                if Error(syncRes) == " bft validator: state sync commit mismatch":
                    return Ok[int64](int64(0))
                if BftMainFollowerRetryableRecvError(Error(syncRes)):
                    return Ok[int64](int64(0))
                return Err[int64](Error(syncRes))
            if !host.BftValidatorWriteState(statePath, state):
                return Err[int64](" bft main: failed to persist follower state")
            if !host.BftValidatorWriteVoteLock(voteLockPath, state):
                return Err[int64](" bft main: failed to persist vote lock")
            BftMainPrintOut("synced_height=" + host.BftValidatorInt64Text(commit.height))
            BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(commit.appHash))
            return Ok[int64](commit.height)
        return Err[int64](Error(applyRes))
    if !host.BftValidatorWriteState(statePath, state):
        return Err[int64](" bft main: failed to persist follower state")
    if !host.BftValidatorWriteVoteLock(voteLockPath, state):
        return Err[int64](" bft main: failed to persist vote lock")
    BftMainPrintOut("applied_height=" + host.BftValidatorInt64Text(commit.height))
    BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(commit.appHash))
    return Ok[int64](commit.height)

fn BftMainProposerDaemonCommand(): int32 =
    var statePath = ""
    let stateRes = BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        BftMainPrintErr(Error(stateRes))
        return 2
    var queuePath = ""
    let queueRes = BftMainReadRequiredQueuePath(queuePath)
    if IsErr(queueRes):
        BftMainPrintErr(Error(queueRes))
        return 2
    var voteLockPath = cmdline.ReadFlagOrDefault("--vote-lock", "")
    if len(voteLockPath) <= 0:
        voteLockPath = host.BftValidatorDefaultVoteLockPath(statePath)
    var queueCursorPath = cmdline.ReadFlagOrDefault("--queue-cursor", "")
    if len(queueCursorPath) <= 0:
        queueCursorPath = host.BftValidatorDefaultQueueCursorPath(queuePath)
    var proposalFile = cmdline.ReadFlagOrDefault("--proposal-file", "")
    if len(proposalFile) <= 0:
        proposalFile = statePath + ".proposal"
    var commitFile = cmdline.ReadFlagOrDefault("--commit-file", "")
    if len(commitFile) <= 0:
        commitFile = statePath + ".commit"
    var stateSyncFile = cmdline.ReadFlagOrDefault("--state-sync-file", "")
    if len(stateSyncFile) <= 0:
        stateSyncFile = statePath + ".machine"
    var stateSyncDir = cmdline.ReadFlagOrDefault("--state-sync-dir", "")
    if len(stateSyncDir) <= 0:
        stateSyncDir = host.BftValidatorDefaultStateSyncDir(stateSyncFile)
    let proposalHost = cmdline.ReadFlagOrDefault("--proposal-host", "")
    let proposalPort = cmdline.ReadInt32FlagOrDefault("--proposal-port", -1)
    let voteHost = cmdline.ReadFlagOrDefault("--vote-host", "")
    let votePort = cmdline.ReadInt32FlagOrDefault("--vote-port", -1)
    let commitHost = cmdline.ReadFlagOrDefault("--commit-host", "")
    let commitPort = cmdline.ReadInt32FlagOrDefault("--commit-port", -1)
    let proposalReadyPath = cmdline.ReadFlagOrDefault("--proposal-ready-path", "")
    let voteReadyPath = cmdline.ReadFlagOrDefault("--vote-ready-path", "")
    let commitReadyPath = cmdline.ReadFlagOrDefault("--commit-ready-path", "")
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 200)
    let proposalWindowMs = cmdline.ReadInt32FlagOrDefault("--proposal-window-ms", intervalMs)
    let voteWindowMs = cmdline.ReadInt32FlagOrDefault("--vote-window-ms", intervalMs)
    let commitWindowMs = cmdline.ReadInt32FlagOrDefault("--commit-window-ms", intervalMs)
    let maxRounds = cmdline.ReadInt32FlagOrDefault("--max-rounds", 0)
    let maxTxs = cmdline.ReadInt32FlagOrDefault("--max-txs", 128)
    if len(proposalHost) <= 0 || proposalPort <= 0 || len(voteHost) <= 0 || votePort <= 0 || len(commitHost) <= 0 || commitPort <= 0:
        BftMainPrintErr(" bft main: proposer daemon requires proposal/vote/commit host+port")
        return 2
    let loadRes = host.BftValidatorLoadLiveState(statePath, voteLockPath)
    if IsErr(loadRes):
        BftMainPrintErr(Error(loadRes))
        return 2
    var state = Value(loadRes)
    if !host.BftValidatorWriteHexFile(stateSyncFile, host.BftValidatorEncodeMachine(state.machine)):
        BftMainPrintErr(" bft main: failed to write state sync file")
        return 2
    if !host.BftValidatorWriteStateSnapshot(stateSyncDir, state.machine):
        BftMainPrintErr(" bft main: failed to write state sync snapshot")
        return 2
    let queueTrackerRes = host.BftValidatorQueueTrackerInit(queuePath, queueCursorPath)
    if IsErr(queueTrackerRes):
        BftMainPrintErr(Error(queueTrackerRes))
        return 2
    var queueTracker = Value(queueTrackerRes)
    var currentProposal: host.BftProposal
    var currentPreview: host.BftProposalPreview
    var currentVotes: host.BftVote[]
    currentVotes = []
    var hasCurrentProposal = false
    var currentCommit: host.BftCommit
    var hasCurrentCommit = false
    let replayCommitRes = host.BftValidatorLoadCommitFile(commitFile)
    if IsOk(replayCommitRes) && Value(replayCommitRes).height == state.machine.lastFinalizedHeight:
        currentCommit = Value(replayCommitRes)
        hasCurrentCommit = true
    let replayProposalRes = host.BftValidatorLoadProposalFile(proposalFile)
    if IsOk(replayProposalRes) &&
       Value(replayProposalRes).proposerSlot == state.validatorSlot &&
       Value(replayProposalRes).height == state.machine.lastFinalizedHeight + int64(1):
        let previewRes = host.BftValidatorPreviewProposal(state, Value(replayProposalRes))
        let selfVoteRes = host.BftValidatorBuildVoteAllowRepeat(state, Value(replayProposalRes), true)
        if IsErr(previewRes):
            BftMainPrintErr(Error(previewRes))
            return 2
        if IsErr(selfVoteRes):
            BftMainPrintErr(Error(selfVoteRes))
            return 2
        currentProposal = Value(replayProposalRes)
        currentPreview = Value(previewRes)
        currentVotes = []
        add(currentVotes, Value(selfVoteRes))
        hasCurrentProposal = true
    var committedRounds = 0
    while maxRounds <= 0 || committedRounds < maxRounds:
        let refreshRes = host.BftValidatorQueueTrackerRefresh(queuePath, queueTracker)
        if IsErr(refreshRes):
            BftMainPrintErr(Error(refreshRes))
            return 2
        var progressed = false
        if hasCurrentCommit:
            if commitWindowMs > 0:
                let serveCommitRes = host.BftValidatorServeCommitWindow(commitHost,
                                                                          commitPort,
                                                                          currentCommit,
                                                                          commitReadyPath,
                                                                          host.BftValidatorCount - 1,
                                                                          commitWindowMs)
                if IsErr(serveCommitRes):
                    BftMainPrintErr(Error(serveCommitRes))
                    return 2
                progressed = true
        if !hasCurrentProposal && queueTracker.pendingTxs.len > 0:
            var batch: Bytes[]
            batch = []
            let takeCount = (maxTxs > 0 && maxTxs < queueTracker.pendingTxs.len) ? maxTxs : queueTracker.pendingTxs.len
            for i in 0..<takeCount:
                add(batch, queueTracker.pendingTxs[i])
            let proposalRes = host.BftValidatorProposalFromTxs(state.machine.appId,
                                                                 state.machine.lastFinalizedHeight + int64(1),
                                                                 state.validatorSlot,
                                                                 batch)
            if IsErr(proposalRes):
                BftMainPrintErr(Error(proposalRes))
                return 2
            let previewRes = host.BftValidatorPreviewProposal(state, Value(proposalRes))
            if IsErr(previewRes):
                BftMainPrintErr(Error(previewRes))
                return 2
            let selfVoteRes = host.BftValidatorBuildVoteAllowRepeat(state, Value(proposalRes), true)
            if IsErr(selfVoteRes):
                BftMainPrintErr(Error(selfVoteRes))
                return 2
            currentProposal = Value(proposalRes)
            currentPreview = Value(previewRes)
            currentVotes = []
            add(currentVotes, Value(selfVoteRes))
            state.lastVotedHeight = currentProposal.height
            state.lastVotedProposalHash = currentPreview.proposalHash
            if !host.BftValidatorWriteVoteLock(voteLockPath, state):
                BftMainPrintErr(" bft main: failed to write vote lock")
                return 2
            if len(proposalFile) > 0 &&
               !host.BftValidatorWriteHexFile(proposalFile, host.BftValidatorEncodeProposal(currentProposal)):
                BftMainPrintErr(" bft main: failed to write proposal file")
                return 2
            hasCurrentProposal = true
            progressed = true
        if hasCurrentProposal:
            if proposalWindowMs > 0:
                let serveProposalRes = host.BftValidatorServeProposalWindow(proposalHost,
                                                                              proposalPort,
                                                                              currentProposal,
                                                                              proposalReadyPath,
                                                                              host.BftValidatorCount - 1,
                                                                              proposalWindowMs)
                if IsErr(serveProposalRes):
                    BftMainPrintErr(Error(serveProposalRes))
                    return 2
            progressed = true
            let captureVotesRes = host.BftValidatorCaptureVotesWindow(voteHost,
                                                                        votePort,
                                                                        voteReadyPath,
                                                                        host.BftValidatorCount - 1,
                                                                        voteWindowMs)
            if IsErr(captureVotesRes):
                BftMainPrintErr(Error(captureVotesRes))
                return 2
            let capturedVotes = Value(captureVotesRes)
            if capturedVotes.len > 0:
                progressed = true
            for i in 0..<capturedVotes.len:
                let addVoteRes = host.BftValidatorVoteSetAdd(currentVotes,
                                                               capturedVotes[i],
                                                               currentProposal,
                                                               currentPreview)
                if IsErr(addVoteRes):
                    continue
            if currentVotes.len >= host.BftValidatorQuorum:
                let commitRes = host.BftValidatorCommitFromVotes(currentProposal, currentPreview, currentVotes)
                if IsErr(commitRes):
                    BftMainPrintErr(Error(commitRes))
                    return 2
                let applyRes = host.BftValidatorStateApplyCommit(state, Value(commitRes))
                if IsErr(applyRes):
                    BftMainPrintErr(Error(applyRes))
                    return 2
                if !host.BftValidatorWriteState(statePath, state):
                    BftMainPrintErr(" bft main: failed to write proposer state")
                    return 2
                if !host.BftValidatorWriteHexFile(stateSyncFile, host.BftValidatorEncodeMachine(state.machine)):
                    BftMainPrintErr(" bft main: failed to write state sync file")
                    return 2
                if !host.BftValidatorWriteStateSnapshot(stateSyncDir, state.machine):
                    BftMainPrintErr(" bft main: failed to write state sync snapshot")
                    return 2
                if !host.BftValidatorWriteVoteLock(voteLockPath, state):
                    BftMainPrintErr(" bft main: failed to write vote lock")
                    return 2
                let commitQueueRes = host.BftValidatorQueueTrackerCommit(queueCursorPath,
                                                                           queueTracker,
                                                                           currentProposal.txs.len)
                if IsErr(commitQueueRes):
                    BftMainPrintErr(Error(commitQueueRes))
                    return 2
                if len(commitFile) > 0 &&
                   !host.BftValidatorWriteHexFile(commitFile, host.BftValidatorEncodeCommit(Value(commitRes))):
                    BftMainPrintErr(" bft main: failed to write commit file")
                    return 2
                currentCommit = Value(commitRes)
                hasCurrentCommit = true
                hasCurrentProposal = false
                currentVotes = []
                BftMainClearFile(proposalFile)
                if commitWindowMs > 0:
                    let serveCommitNowRes = host.BftValidatorServeCommitWindow(commitHost,
                                                                                 commitPort,
                                                                                 currentCommit,
                                                                                 commitReadyPath,
                                                                                 host.BftValidatorCount - 1,
                                                                                 commitWindowMs)
                    if IsErr(serveCommitNowRes):
                        BftMainPrintErr(Error(serveCommitNowRes))
                        return 2
                committedRounds = committedRounds + 1
                BftMainPrintOut("committed_height=" + host.BftValidatorInt64Text(currentCommit.height))
                BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(currentCommit.appHash))
                progressed = true
        if !(progressed || Value(refreshRes) > 0):
            BftMainSleepMs(intervalMs)
    return 0

fn BftMainFollowerDaemonCommand(): int32 =
    var statePath = ""
    let stateRes = BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        BftMainPrintErr(Error(stateRes))
        return 2
    var voteLockPath = cmdline.ReadFlagOrDefault("--vote-lock", "")
    if len(voteLockPath) <= 0:
        voteLockPath = host.BftValidatorDefaultVoteLockPath(statePath)
    let proposalHost = cmdline.ReadFlagOrDefault("--proposal-host", "")
    let proposalPort = cmdline.ReadInt32FlagOrDefault("--proposal-port", -1)
    let voteHost = cmdline.ReadFlagOrDefault("--vote-host", "")
    let votePort = cmdline.ReadInt32FlagOrDefault("--vote-port", -1)
    let commitHost = cmdline.ReadFlagOrDefault("--commit-host", "")
    let commitPort = cmdline.ReadInt32FlagOrDefault("--commit-port", -1)
    var syncHost = cmdline.ReadFlagOrDefault("--sync-host", "")
    if len(syncHost) <= 0:
        syncHost = commitHost
    let syncPort = cmdline.ReadInt32FlagOrDefault("--sync-port", -1)
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 100)
    let maxRounds = cmdline.ReadInt32FlagOrDefault("--max-rounds", 0)
    if len(proposalHost) <= 0 || proposalPort <= 0 || len(voteHost) <= 0 || votePort <= 0 || len(commitHost) <= 0 || commitPort <= 0:
        BftMainPrintErr(" bft main: follower daemon requires proposal/vote/commit host+port")
        return 2
    let loadRes = host.BftValidatorLoadLiveState(statePath, voteLockPath)
    if IsErr(loadRes):
        BftMainPrintErr(Error(loadRes))
        return 2
    var state = Value(loadRes)
    var appliedRounds = 0
    while maxRounds <= 0 || appliedRounds < maxRounds:
        let beforeHeight = state.machine.lastFinalizedHeight
        let voteStepRes = BftMainFollowerVoteStep(voteLockPath,
                                                    state,
                                                    proposalHost,
                                                    proposalPort,
                                                    voteHost,
                                                    votePort)
        if IsErr(voteStepRes):
            BftMainPrintErr(Error(voteStepRes))
            return 2
        let commitStepRes = BftMainFollowerCommitStep(statePath,
                                                        voteLockPath,
                                                        state,
                                                        commitHost,
                                                        commitPort,
                                                        syncHost,
                                                        syncPort)
        if IsErr(commitStepRes):
            BftMainPrintErr(Error(commitStepRes))
            return 2
        if Value(commitStepRes) > int64(0):
            let delta = state.machine.lastFinalizedHeight - beforeHeight
            if delta > int64(0):
                appliedRounds = appliedRounds + int32(delta)
            else:
                appliedRounds = appliedRounds + 1
            continue
        if Value(commitStepRes) <= int64(0) && !Value(voteStepRes):
            let syncLatestRes = host.BftValidatorSyncMachineLatest(state, syncHost, syncPort)
            if IsOk(syncLatestRes):
                let syncedHeight = Value(syncLatestRes)
                if syncedHeight > beforeHeight:
                    if !host.BftValidatorWriteState(statePath, state):
                        BftMainPrintErr(" bft main: failed to persist follower state")
                        return 2
                    if !host.BftValidatorWriteVoteLock(voteLockPath, state):
                        BftMainPrintErr(" bft main: failed to persist vote lock")
                        return 2
                    let commit = bft.BftStateMachineCommit(state.machine)
                    BftMainPrintOut("synced_height=" + host.BftValidatorInt64Text(commit.height))
                    BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(commit.appHash))
                    let delta = syncedHeight - beforeHeight
                    if delta > int64(0):
                        appliedRounds = appliedRounds + int32(delta)
                    else:
                        appliedRounds = appliedRounds + 1
                    continue
            elif !BftMainFollowerRetryableLatestSyncError(Error(syncLatestRes)):
                BftMainPrintErr(Error(syncLatestRes))
                return 2
        if maxRounds <= 0 || appliedRounds < maxRounds:
            BftMainSleepMs(intervalMs)
    return 0

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let debugTls13 = cmdline.HasFlag("--debug-tls13")
    qnative.msquicNativeSetDebugTls13(debugTls13)
    handshake13.msquicTls13SetDebug(debugTls13)
    let count = cmdline.ParamCount()
    if count <= 0:
        return BftMainSelfTest()
    let cmd = cmdline.ParamStr(1)
    if len(cmd) <= 0:
        return BftMainSelfTest()
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        BftMainUsage()
        return 0
    if cmd == "self-test":
        return BftMainSelfTest()
    if cmd == "init":
        return BftMainInitCommand()
    if cmd == "submit-mint":
        return BftMainSubmitMintCommand()
    if cmd == "submit-transfer":
        return BftMainSubmitTransferCommand()
    if cmd == "submit-transfer-series":
        return BftMainSubmitTransferSeriesCommand()
    if cmd == "show-state":
        return BftMainShowStateCommand()
    if cmd == "query-balance":
        return BftMainQueryBalanceCommand()
    if cmd == "query-summary":
        return BftMainQuerySummaryCommand()
    if cmd == "curve25519-probe":
        return BftMainCurve25519ProbeCommand()
    if cmd == "curve25519-sweep":
        return BftMainCurve25519SweepCommand()
    if cmd == "curve25519-generated-sweep":
        return BftMainCurve25519GeneratedSweepCommand()
    if cmd == "curve25519-shared":
        return BftMainCurve25519SharedCommand()
    if cmd == "tls13-finished-probe":
        return BftMainTls13FinishedProbeCommand()
    if cmd == "tls13-packet-flight-probe":
        return BftMainTls13PacketFlightProbeCommand()
    if cmd == "tls13-derive-probe":
        return BftMainTls13DeriveProbeCommand()
    if cmd == "probe-proposal":
        return BftMainProbeProposalCommand()
    if cmd == "proposal-serve-daemon":
        return BftMainServeHexDaemonCommand(host.BftValidatorProposalProtocol())
    if cmd == "commit-serve-daemon":
        return BftMainServeHexDaemonCommand(host.BftValidatorCommitProtocol())
    if cmd == "state-serve-daemon":
        return BftMainStateServeDaemonCommand()
    if cmd == "vote-capture-daemon":
        return BftMainVoteCaptureDaemonCommand()
    if cmd == "validator-proposer-daemon":
        return BftMainProposerDaemonCommand()
    if cmd == "validator-follower-daemon":
        return BftMainFollowerDaemonCommand()
    BftMainPrintErr(" bft main: unknown command: " + cmd)
    BftMainUsage()
    return 2
