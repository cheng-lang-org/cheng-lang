import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/consensus as consensus
import cheng/chain/lsmr_types as lt

const
    BftTxVersion: int32 = 1
    BftTxKindMint: int32 = 1
    BftTxKindTransfer: int32 = 2

    BftCodeOk: int32 = 0
    BftCodeBadVersion: int32 = 1
    BftCodeBadKind: int32 = 2
    BftCodeBadTarget: int32 = 3
    BftCodeBadAmount: int32 = 4
    BftCodeDecodeError: int32 = 5
    BftCodeStateRejected: int32 = 6
    BftCodeBadHeight: int32 = 7

    BftTxWireSize: int32 = 32

type
    BftTx =
        version: int32
        kind: int32
        assetId: int32
        fromAccount: int32
        toAccount: int32
        amount: int64
        reserved0: int32

    BftTxHeader =
        version: int32
        kind: int32
        assetId: int32

    BftTxBody =
        fromAccount: int32
        toAccount: int32
        amount: int64
        reserved0: int32

    BftBlockContext =
        height: int64
        txIndex: int32
        timeHint: int64
        proposerHint: layout.FixedBytes32

    BftTxCheckResult =
        code: int32
        accepted: bool
        applied: bool
        eventCid: layout.FixedBytes32
        appHash: layout.FixedBytes32
        nextHeight: int64

    BftTxBatch =
        versions: int32[]
        kinds: int32[]
        assetIds: int32[]
        fromAccounts: int32[]
        toAccounts: int32[]
        amounts: int64[]
        reserved0s: int32[]

    BftExecResult =
        code: int32
        accepted: bool
        applied: bool
        eventCid: layout.FixedBytes32

    BftBlockSummary =
        height: int64
        txCount: int32
        appliedCount: int32
        rejectedCount: int32
        appHash: layout.FixedBytes32
        tipEventCid: layout.FixedBytes32

    BftTxOutcomes =
        codes: int32[]
        accepted: bool[]
        applied: bool[]
        eventCids: layout.FixedBytes32[]

    BftBlockResult =
        height: int64
        txCount: int32
        appliedCount: int32
        rejectedCount: int32
        appHash: layout.FixedBytes32
        tipEventCid: layout.FixedBytes32
        txCodes: int32[]
        txAccepted: bool[]
        txApplied: bool[]
        txEventCids: layout.FixedBytes32[]

    BftCommitResult =
        height: int64
        appHash: layout.FixedBytes32
        tipEventCid: layout.FixedBytes32
        eventCount: int32
        accountCount: int32

    BftBalanceQueryResult =
        code: int32
        balance: int64
        height: int64
        appHash: layout.FixedBytes32

    BftStateMachine =
        appId: str
        index: consensus.ChainIndex
        eventCids: layout.FixedBytes32[]
        events: consensus.ChainEvent[]
        lastFinalizedHeight: int64
        lastCommitAppHash: layout.FixedBytes32
        lastCommitTipEventCid: layout.FixedBytes32

fn BftTxMint(assetId: int32, toAccount: int32, amount: int64): BftTx =
    var out: BftTx
    out.version = BftTxVersion
    out.kind = BftTxKindMint
    out.assetId = assetId
    out.fromAccount = 0
    out.toAccount = toAccount
    out.amount = amount
    out.reserved0 = 0
    return out

fn BftTxTransfer(assetId: int32, fromAccount: int32, toAccount: int32, amount: int64): BftTx =
    var out: BftTx
    out.version = BftTxVersion
    out.kind = BftTxKindTransfer
    out.assetId = assetId
    out.fromAccount = fromAccount
    out.toAccount = toAccount
    out.amount = amount
    out.reserved0 = 0
    return out

fn BftTxHeaderFromTx(tx: BftTx): BftTxHeader =
    var out: BftTxHeader
    out.version = tx.version
    out.kind = tx.kind
    out.assetId = tx.assetId
    return out

fn BftTxBodyFromTx(tx: BftTx): BftTxBody =
    var out: BftTxBody
    out.fromAccount = tx.fromAccount
    out.toAccount = tx.toAccount
    out.amount = tx.amount
    out.reserved0 = tx.reserved0
    return out

fn BftTxFromParts(header: BftTxHeader, body: BftTxBody): BftTx =
    var out: BftTx
    out.version = header.version
    out.kind = header.kind
    out.assetId = header.assetId
    out.fromAccount = body.fromAccount
    out.toAccount = body.toAccount
    out.amount = body.amount
    out.reserved0 = body.reserved0
    return out

fn BftBlockContextMake(height: int64,
                         txIndex: int32,
                         timeHint: int64,
                         proposerHint: layout.FixedBytes32): BftBlockContext =
    var out: BftBlockContext
    out.height = height
    out.txIndex = txIndex
    out.timeHint = timeHint
    out.proposerHint = proposerHint
    return out

fn BftBlockSummaryZero(height: int64): BftBlockSummary =
    var out: BftBlockSummary
    out.height = height
    out.txCount = 0
    out.appliedCount = 0
    out.rejectedCount = 0
    out.appHash = layout.FixedBytes32()
    out.tipEventCid = layout.FixedBytes32()
    return out

fn BftTxOutcomesAdd(outcomes: var BftTxOutcomes, exec: BftExecResult) =
    add(outcomes.codes, exec.code)
    add(outcomes.accepted, exec.accepted)
    add(outcomes.applied, exec.applied)
    add(outcomes.eventCids, exec.eventCid)

fn BftBlockResultZero(height: int64): BftBlockResult =
    var out: BftBlockResult
    out.height = height
    out.txCount = 0
    out.appliedCount = 0
    out.rejectedCount = 0
    out.appHash = layout.FixedBytes32()
    out.tipEventCid = layout.FixedBytes32()
    out.txCodes = []
    out.txAccepted = []
    out.txApplied = []
    out.txEventCids = []
    return out

fn BftTxBatchAdd(batch: var BftTxBatch, tx: BftTx) =
    add(batch.versions, tx.version)
    add(batch.kinds, tx.kind)
    add(batch.assetIds, tx.assetId)
    add(batch.fromAccounts, tx.fromAccount)
    add(batch.toAccounts, tx.toAccount)
    add(batch.amounts, tx.amount)
    add(batch.reserved0s, tx.reserved0)

fn BftTxBatchLen(batch: BftTxBatch): int32 =
    return batch.kinds.len

fn BftTxBatchGet(batch: BftTxBatch, idx: int32): BftTx =
    var out: BftTx
    out.version = batch.versions[idx]
    out.kind = batch.kinds[idx]
    out.assetId = batch.assetIds[idx]
    out.fromAccount = batch.fromAccounts[idx]
    out.toAccount = batch.toAccounts[idx]
    out.amount = batch.amounts[idx]
    out.reserved0 = batch.reserved0s[idx]
    return out

fn BftTxBatchAddDecoded(batch: var BftTxBatch, rawTx: Bytes): Result[bool] =
    let txRes = BftDecodeTx(layout.byteSpanFromBytes(rawTx))
    if IsErr(txRes):
        return Err[bool](Error(txRes))
    BftTxBatchAdd(batch, Value(txRes))
    return Ok[bool](true)

fn BftStateMachineInit(appId: str): BftStateMachine =
    var eventCids: layout.FixedBytes32[]
    var events: consensus.ChainEvent[]
    eventCids = []
    events = []
    var out: BftStateMachine
    out.appId = appId
    out.index = consensus.ChainIndex()
    out.eventCids = eventCids
    out.events = events
    out.lastFinalizedHeight = int64(0)
    out.lastCommitAppHash = layout.FixedBytes32()
    out.lastCommitTipEventCid = layout.FixedBytes32()
    return out

fn BftCodeText(code: int32): str =
    if code == BftCodeOk:
        return "ok"
    if code == BftCodeBadVersion:
        return "bad_version"
    if code == BftCodeBadKind:
        return "bad_kind"
    if code == BftCodeBadTarget:
        return "bad_target"
    if code == BftCodeBadAmount:
        return "bad_amount"
    if code == BftCodeDecodeError:
        return "decode_error"
    if code == BftCodeStateRejected:
        return "state_rejected"
    if code == BftCodeBadHeight:
        return "bad_height"
    return "unknown"

fn BftAppendU32BE(buf: var layout.ByteBuf, value: int64) =
    lt.AppendU32BE(buf, value)

fn BftReadU32BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    if offset < 0 || offset + 4 > layout.byteSpanLen(span):
        return Err[int64](" bft: short u32")
    let b0: int64 = int64(layout.byteSpanAt(span, offset))
    let b1: int64 = int64(layout.byteSpanAt(span, offset + 1))
    let b2: int64 = int64(layout.byteSpanAt(span, offset + 2))
    let b3: int64 = int64(layout.byteSpanAt(span, offset + 3))
    return Ok[int64]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn BftEncodeTx(tx: BftTx): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(BftTxWireSize)
    BftAppendU32BE(buf, tx.version)
    BftAppendU32BE(buf, tx.kind)
    BftAppendU32BE(buf, tx.assetId)
    BftAppendU32BE(buf, tx.fromAccount)
    BftAppendU32BE(buf, tx.toAccount)
    BftAppendU32BE(buf, int32(tx.amount >> 32))
    BftAppendU32BE(buf, int32(tx.amount & int64(0xffffffff)))
    BftAppendU32BE(buf, tx.reserved0)
    return layout.byteBufToBytes(buf)

fn BftDecodeTx(data: layout.ByteSpan): Result[BftTx] =
    if layout.byteSpanLen(data) != BftTxWireSize:
        return Err[BftTx](" bft: bad tx size")
    let versionRes = BftReadU32BE(data, 0)
    if IsErr(versionRes):
        return Err[BftTx](Error(versionRes))
    let kindRes = BftReadU32BE(data, 4)
    if IsErr(kindRes):
        return Err[BftTx](Error(kindRes))
    let assetRes = BftReadU32BE(data, 8)
    if IsErr(assetRes):
        return Err[BftTx](Error(assetRes))
    let fromRes = BftReadU32BE(data, 12)
    if IsErr(fromRes):
        return Err[BftTx](Error(fromRes))
    let toRes = BftReadU32BE(data, 16)
    if IsErr(toRes):
        return Err[BftTx](Error(toRes))
    let amountHiRes = BftReadU32BE(data, 20)
    if IsErr(amountHiRes):
        return Err[BftTx](Error(amountHiRes))
    let amountLoRes = BftReadU32BE(data, 24)
    if IsErr(amountLoRes):
        return Err[BftTx](Error(amountLoRes))
    let reservedRes = BftReadU32BE(data, 28)
    if IsErr(reservedRes):
        return Err[BftTx](Error(reservedRes))
    let amountHi = int32(Value(amountHiRes))
    let amountLo = Value(amountLoRes)
    let amount = (int64(amountHi) << 32) | (amountLo & int64(0xffffffff))
    return Ok[BftTx](BftTx(
        version: int32(Value(versionRes)),
        kind: int32(Value(kindRes)),
        assetId: int32(Value(assetRes)),
        fromAccount: int32(Value(fromRes)),
        toAccount: int32(Value(toRes)),
        amount: amount,
        reserved0: int32(Value(reservedRes))
    ))

fn BftTxShapeCode(tx: BftTx): int32 =
    if tx.version != BftTxVersion:
        return BftCodeBadVersion
    if tx.kind != BftTxKindMint:
        if tx.kind != BftTxKindTransfer:
            return BftCodeBadKind
    if tx.assetId <= 0:
        return BftCodeBadTarget
    if tx.amount <= int64(0):
        return BftCodeBadAmount
    if tx.kind == BftTxKindMint:
        if tx.fromAccount != 0:
            return BftCodeBadTarget
        if tx.toAccount <= 0:
            return BftCodeBadTarget
        return BftCodeOk
    if tx.fromAccount <= 0:
        return BftCodeBadTarget
    if tx.toAccount <= 0:
        return BftCodeBadTarget
    if tx.fromAccount == tx.toAccount:
        return BftCodeBadTarget
    return BftCodeOk

fn BftTxShapeCodeFields(version: int32,
                          kind: int32,
                          assetId: int32,
                          fromAccount: int32,
                          toAccount: int32,
                          amount: int64): int32 =
    var tx: BftTx
    tx.version = version
    tx.kind = kind
    tx.assetId = assetId
    tx.fromAccount = fromAccount
    tx.toAccount = toAccount
    tx.amount = amount
    tx.reserved0 = 0
    return BftTxShapeCode(tx)

fn BftTxBatchShapeCodeAt(batch: BftTxBatch, idx: int32): int32 =
    return BftTxShapeCodeFields(batch.versions[idx],
                                  batch.kinds[idx],
                                  batch.assetIds[idx],
                                  batch.fromAccounts[idx],
                                  batch.toAccounts[idx],
                                  batch.amounts[idx])

fn BftHeightOk(height: int64): bool =
    if height <= int64(0):
        return false
    if height > int64(2147483647):
        return false
    return true

fn BftEpoch(height: int64): int32 =
    return int32(height)

fn BftGanzhiIndex(height: int64, txIndex: int32): int32 =
    let offset = ((height - int64(1)) * int64(60)) + int64(txIndex)
    let whole = int32(offset % int64(60))
    return whole + 1

fn BftTick(height: int64, txIndex: int32): int64 =
    return (height << 32) | int64(txIndex + 1)

fn BftAccountPos(index: consensus.ChainIndex, assetId: int32, accountId: int32): int32 =
    return consensus.ConsensusAccountPos(index, assetId, accountId)

fn BftAccountHead(index: consensus.ChainIndex, assetId: int32, accountId: int32): layout.FixedBytes32 =
    let pos = BftAccountPos(index, assetId, accountId)
    if pos < 0:
        return layout.FixedBytes32()
    return index.accountHeads[pos]

fn BftBalanceValue(index: consensus.ChainIndex, assetId: int32, accountId: int32): int64 =
    let pos = BftAccountPos(index, assetId, accountId)
    if pos < 0:
        return int64(0)
    return index.balances[pos]

fn BftTipEventCidIndex(index: consensus.ChainIndex): layout.FixedBytes32 =
    if index.eventCids.len <= 0:
        return layout.FixedBytes32()
    return index.eventCids[index.eventCids.len - 1]

fn BftTipEventCid(machine: BftStateMachine): layout.FixedBytes32 =
    return BftTipEventCidIndex(machine.index)

fn BftBuildMintEvent(index: consensus.ChainIndex, tx: BftTx, height: int64, txIndex: int32): consensus.ChainEvent =
    let parentCid = BftAccountHead(index, tx.assetId, tx.toAccount)
    return consensus.ChainEventMint(
        tx.assetId,
        tx.toAccount,
        parentCid,
        tx.amount,
        BftEpoch(height),
        BftGanzhiIndex(height, txIndex),
        BftSpaceSlot(tx.toAccount, tx.toAccount),
        BftTick(height, txIndex)
    )

fn BftSpaceSlot(fromAccount: int32, toAccount: int32): int32 =
    let mixed = fromAccount * 131 + toAccount * 17
    let slot = mixed % 9
    if slot < 0:
        return slot + 9
    return slot

fn BftBuildTransferEvent(index: consensus.ChainIndex, tx: BftTx, height: int64, txIndex: int32): consensus.ChainEvent =
    let fromParentCid = BftAccountHead(index, tx.assetId, tx.fromAccount)
    let toParentCid = BftAccountHead(index, tx.assetId, tx.toAccount)
    var event: consensus.ChainEvent
    event.version = BftTxVersion
    event.kind = consensus.ConsensusKindTransferCommit
    event.assetId = tx.assetId
    event.fromAccount = tx.fromAccount
    event.toAccount = tx.toAccount
    event.fromParentCid = fromParentCid
    event.toParentCid = toParentCid
    event.amount = tx.amount
    event.epoch = BftEpoch(height)
    event.ganzhiIndex = BftGanzhiIndex(height, txIndex)
    event.spaceSlot = BftSpaceSlot(tx.fromAccount, tx.toAccount)
    event.tick = BftTick(height, txIndex)
    event.stem = event.ganzhiIndex % 10
    event.branch = event.ganzhiIndex % 12
    event.bodyCid = consensus.ChainEventBodyCid(event)
    return event

fn BftApplyEvent(machine: var BftStateMachine, event: var consensus.ChainEvent): BftExecResult =
    return BftApplyEventToIndex(machine.index, event)

fn BftApplyEventToIndex(index: var consensus.ChainIndex, event: var consensus.ChainEvent): BftExecResult =
    var out = BftExecResult()
    let eventCid = consensus.ChainEventCid(event)
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(index, event, eventCid, index.eventCids.len, decision)
    out.eventCid = eventCid
    out.accepted = decision.accepted
    out.applied = decision.applied
    if !decision.accepted:
        out.code = BftCodeStateRejected
        return out
    out.code = BftCodeOk
    return out

fn BftCloneFixedBytes32Seq(xs: layout.FixedBytes32[]): layout.FixedBytes32[] =
    var out: layout.FixedBytes32[]
    out = []
    for i in 0..<xs.len:
        add(out, xs[i])
    return out

fn BftCloneInt32Seq(xs: int32[]): int32[] =
    var out: int32[]
    out = []
    for i in 0..<xs.len:
        add(out, xs[i])
    return out

fn BftCloneInt64Seq(xs: int64[]): int64[] =
    var out: int64[]
    out = []
    for i in 0..<xs.len:
        add(out, xs[i])
    return out

fn BftCloneBoolSeq(xs: bool[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<xs.len:
        add(out, xs[i])
    return out

fn BftCloneChainEventSeq(xs: consensus.ChainEvent[]): consensus.ChainEvent[] =
    var out: consensus.ChainEvent[]
    out = []
    for i in 0..<xs.len:
        add(out, xs[i])
    return out

fn BftCloneChainIndex(index: consensus.ChainIndex): consensus.ChainIndex =
    var out: consensus.ChainIndex
    out.eventCids = BftCloneFixedBytes32Seq(index.eventCids)
    out.eventKinds = BftCloneInt32Seq(index.eventKinds)
    out.logOffsets = BftCloneInt32Seq(index.logOffsets)
    out.accountAssetIds = BftCloneInt32Seq(index.accountAssetIds)
    out.accountIds = BftCloneInt32Seq(index.accountIds)
    out.accountHeads = BftCloneFixedBytes32Seq(index.accountHeads)
    out.balances = BftCloneInt64Seq(index.balances)
    out.clockEpochs = BftCloneInt32Seq(index.clockEpochs)
    out.clockGanzhi = BftCloneInt32Seq(index.clockGanzhi)
    out.diverged = BftCloneBoolSeq(index.diverged)
    out.stateTreeDirty = index.stateTreeDirty
    return out

fn BftStateMachineClone(machine: BftStateMachine): BftStateMachine =
    var out: BftStateMachine
    out.appId = machine.appId
    out.index = BftCloneChainIndex(machine.index)
    out.eventCids = BftCloneFixedBytes32Seq(machine.eventCids)
    out.events = BftCloneChainEventSeq(machine.events)
    out.lastFinalizedHeight = machine.lastFinalizedHeight
    out.lastCommitAppHash = machine.lastCommitAppHash
    out.lastCommitTipEventCid = machine.lastCommitTipEventCid
    return out

fn BftPreviewEvent(machine: var BftStateMachine, event: var consensus.ChainEvent): BftExecResult =
    var out = BftExecResult()
    let eventCid = consensus.ChainEventCid(event)
    var nextIndex = BftCloneChainIndex(machine.index)
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, machine.index.eventCids.len, decision)
    out.eventCid = eventCid
    out.accepted = decision.accepted
    out.applied = decision.applied
    if decision.accepted:
        out.code = BftCodeOk
    else:
        out.code = BftCodeStateRejected
    return out

fn BftApplyTx(machine: var BftStateMachine, tx: BftTx, height: int64, txIndex: int32): BftExecResult =
    return BftApplyTxToIndex(machine.index, tx, height, txIndex)

fn BftApplyTxToIndexInto(index: var consensus.ChainIndex,
                           tx: BftTx,
                           height: int64,
                           txIndex: int32,
                           out: var BftExecResult) =
    let exec = BftApplyTxToIndex(index, tx, height, txIndex)
    out.code = exec.code
    out.accepted = exec.accepted
    out.applied = exec.applied
    out.eventCid = exec.eventCid
    return

fn BftApplyTxToIndex(index: var consensus.ChainIndex, tx: BftTx, height: int64, txIndex: int32): BftExecResult =
    var out = BftExecResult()
    let code = BftTxShapeCode(tx)
    out.code = code
    if code != BftCodeOk:
        return out
    var event: consensus.ChainEvent
    if tx.kind == BftTxKindMint:
        event = BftBuildMintEvent(index, tx, height, txIndex)
    else:
        event = BftBuildTransferEvent(index, tx, height, txIndex)
    let eventCid = consensus.ChainEventCid(event)
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(index, event, eventCid, index.eventCids.len, decision)
    out.eventCid = eventCid
    out.accepted = decision.accepted
    out.applied = decision.applied
    if !decision.accepted:
        out.code = BftCodeStateRejected
        return out
    out.code = BftCodeOk
    return out

fn BftStateMachineCheckTx(machine: var BftStateMachine, tx: BftTx): BftExecResult =
    let nextHeight = machine.lastFinalizedHeight + int64(1)
    if !BftHeightOk(nextHeight):
        var out = BftExecResult()
        out.code = BftCodeBadHeight
        return out
    var out = BftExecResult()
    let code = BftTxShapeCode(tx)
    out.code = code
    if code != BftCodeOk:
        return out
    var event: consensus.ChainEvent
    if tx.kind == BftTxKindMint:
        event = BftBuildMintEvent(machine.index, tx, nextHeight, 0)
    else:
        event = BftBuildTransferEvent(machine.index, tx, nextHeight, 0)
    let eventCid = consensus.ChainEventCid(event)
    var nextIndex = BftCloneChainIndex(machine.index)
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, machine.index.eventCids.len, decision)
    out.eventCid = eventCid
    out.accepted = decision.accepted
    out.applied = decision.applied
    if decision.accepted:
        out.code = BftCodeOk
    else:
        out.code = BftCodeStateRejected
    return out

fn BftStateMachineCheckTxWithContext(machine: var BftStateMachine,
                                       context: BftBlockContext,
                                       header: BftTxHeader,
                                       body: BftTxBody): BftTxCheckResult =
    var out = BftTxCheckResult()
    out.appHash = BftStateMachineAppHash(machine)
    out.nextHeight = context.height
    if !BftHeightOk(context.height):
        out.code = BftCodeBadHeight
        return out
    if context.height <= machine.lastFinalizedHeight:
        out.code = BftCodeBadHeight
        return out
    let tx = BftTxFromParts(header, body)
    let code = BftTxShapeCode(tx)
    out.code = code
    if code != BftCodeOk:
        return out
    var event: consensus.ChainEvent
    if tx.kind == BftTxKindMint:
        event = BftBuildMintEvent(machine.index, tx, context.height, context.txIndex)
    else:
        event = BftBuildTransferEvent(machine.index, tx, context.height, context.txIndex)
    let eventCid = consensus.ChainEventCid(event)
    var nextIndex = BftCloneChainIndex(machine.index)
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, machine.index.eventCids.len, decision)
    out.eventCid = eventCid
    out.accepted = decision.accepted
    out.applied = decision.applied
    if decision.accepted:
        out.code = BftCodeOk
    else:
        out.code = BftCodeStateRejected
    return out

fn BftStateMachineCheckTxBytesWithContext(machine: var BftStateMachine,
                                            context: BftBlockContext,
                                            rawTx: Bytes): BftTxCheckResult =
    let txRes = BftDecodeTx(layout.byteSpanFromBytes(rawTx))
    if IsErr(txRes):
        var out = BftTxCheckResult()
        out.code = BftCodeDecodeError
        out.appHash = BftStateMachineAppHash(machine)
        out.nextHeight = context.height
        return out
    let tx = Value(txRes)
    return BftStateMachineCheckTxWithContext(machine, context, BftTxHeaderFromTx(tx), BftTxBodyFromTx(tx))

fn BftStateMachineCheckTxBytes(machine: var BftStateMachine, rawTx: Bytes): BftExecResult =
    let txRes = BftDecodeTx(layout.byteSpanFromBytes(rawTx))
    if IsErr(txRes):
        var out = BftExecResult()
        out.code = BftCodeDecodeError
        return out
    return BftStateMachineCheckTx(machine, Value(txRes))

fn BftStateMachineFinalizeBlock(machine: var BftStateMachine, height: int64, txs: BftTx[]): BftBlockResult =
    var batch = BftTxBatch()
    for i in 0..<txs.len:
        BftTxBatchAdd(batch, txs[i])
    var out = BftBlockResultZero(height)
    BftStateMachineFinalizeBatchInto(machine, height, batch, out)
    return out

fn BftStateMachineFinalizeBatchSummary(machine: var BftStateMachine,
                                         height: int64,
                                         batch: BftTxBatch,
                                         summary: var BftBlockSummary) =
    var batchCount = 0
    batchCount = BftTxBatchLen(batch)
    summary.height = height
    summary.txCount = batchCount
    summary.appliedCount = 0
    summary.rejectedCount = 0
    summary.appHash = layout.FixedBytes32()
    summary.tipEventCid = layout.FixedBytes32()
    if !BftHeightOk(height):
        summary.rejectedCount = summary.txCount
        summary.appHash = machine.lastCommitAppHash
        summary.tipEventCid = BftTipEventCidIndex(machine.index)
        return
    if height <= machine.lastFinalizedHeight:
        summary.rejectedCount = summary.txCount
        summary.appHash = machine.lastCommitAppHash
        summary.tipEventCid = BftTipEventCidIndex(machine.index)
        return
    var nextIndex = BftCloneChainIndex(machine.index)
    var appliedCount = 0
    var rejectedCount = 0
    for i in 0..<batchCount:
        let version = batch.versions[i]
        let kind = batch.kinds[i]
        let assetId = batch.assetIds[i]
        let fromAccount = batch.fromAccounts[i]
        let toAccount = batch.toAccounts[i]
        let amount = batch.amounts[i]
        let code = BftTxShapeCodeFields(version, kind, assetId, fromAccount, toAccount, amount)
        if code != BftCodeOk:
            rejectedCount = rejectedCount + 1
            continue
        if kind == BftTxKindMint:
            let exec = BftApplyTxToIndex(nextIndex, BftTxMint(assetId, toAccount, amount), height, i)
            if exec.applied:
                appliedCount = appliedCount + 1
            else:
                rejectedCount = rejectedCount + 1
            continue
        let exec = BftApplyTxToIndex(nextIndex, BftTxTransfer(assetId, fromAccount, toAccount, amount), height, i)
        if exec.applied:
            appliedCount = appliedCount + 1
        else:
            rejectedCount = rejectedCount + 1
    summary.appliedCount = appliedCount
    summary.rejectedCount = rejectedCount
    summary.appHash = BftChainIndexAppHash(machine.appId, nextIndex)
    summary.tipEventCid = BftTipEventCidIndex(nextIndex)
    machine.index = nextIndex
    machine.lastFinalizedHeight = height
    return

fn BftStateMachineFinalizeBlockSummary(machine: var BftStateMachine,
                                         height: int64,
                                         txs: BftTx[],
                                         summary: var BftBlockSummary) =
    var batch = BftTxBatch()
    for i in 0..<txs.len:
        BftTxBatchAdd(batch, txs[i])
    BftStateMachineFinalizeBatchSummary(machine, height, batch, summary)

fn BftStateMachineFinalizeBlockBytesSummary(machine: var BftStateMachine,
                                              height: int64,
                                              rawTxs: Bytes[],
                                              summary: var BftBlockSummary) =
    var batch = BftTxBatch()
    for i in 0..<rawTxs.len:
        let addRes = BftTxBatchAddDecoded(batch, rawTxs[i])
        if IsErr(addRes):
            summary.height = height
            summary.txCount = rawTxs.len
            summary.appliedCount = 0
            summary.rejectedCount = rawTxs.len
            summary.appHash = BftStateMachineAppHash(machine)
            summary.tipEventCid = BftTipEventCid(machine)
            return
    BftStateMachineFinalizeBatchSummary(machine, height, batch, summary)

fn BftStateMachineFinalizeBatchSoA(machine: var BftStateMachine,
                                     height: int64,
                                     batch: BftTxBatch,
                                     summary: var BftBlockSummary,
                                     txCodes: var int32[],
                                     txAccepted: var bool[],
                                     txApplied: var bool[],
                                     txEventCids: var layout.FixedBytes32[]) =
    var batchCount = 0
    batchCount = BftTxBatchLen(batch)
    summary.height = height
    summary.txCount = 0
    summary.appliedCount = 0
    summary.rejectedCount = 0
    summary.appHash = layout.FixedBytes32()
    summary.tipEventCid = layout.FixedBytes32()
    txCodes = []
    txAccepted = []
    txApplied = []
    txEventCids = []
    summary.txCount = batchCount
    if !BftHeightOk(height):
        for i in 0..<batchCount:
            add(txCodes, BftCodeBadHeight)
            add(txAccepted, false)
            add(txApplied, false)
            add(txEventCids, layout.FixedBytes32())
            summary.rejectedCount = summary.rejectedCount + 1
        summary.appHash = machine.lastCommitAppHash
        summary.tipEventCid = BftTipEventCidIndex(machine.index)
        return
    if height <= machine.lastFinalizedHeight:
        for i in 0..<batchCount:
            add(txCodes, BftCodeBadHeight)
            add(txAccepted, false)
            add(txApplied, false)
            add(txEventCids, layout.FixedBytes32())
            summary.rejectedCount = summary.rejectedCount + 1
        summary.appHash = machine.lastCommitAppHash
        summary.tipEventCid = BftTipEventCidIndex(machine.index)
        return
    var nextIndex = BftCloneChainIndex(machine.index)
    var appliedCount = 0
    var rejectedCount = 0
    for i in 0..<batchCount:
        let version = batch.versions[i]
        let kind = batch.kinds[i]
        let assetId = batch.assetIds[i]
        let fromAccount = batch.fromAccounts[i]
        let toAccount = batch.toAccounts[i]
        let amount = batch.amounts[i]
        let code = BftTxShapeCodeFields(version, kind, assetId, fromAccount, toAccount, amount)
        if code != BftCodeOk:
            add(txCodes, code)
            add(txAccepted, false)
            add(txApplied, false)
            add(txEventCids, layout.FixedBytes32())
            rejectedCount = rejectedCount + 1
            continue
        if kind == BftTxKindMint:
            let exec = BftApplyTxToIndex(nextIndex, BftTxMint(assetId, toAccount, amount), height, i)
            add(txCodes, exec.code)
            add(txAccepted, exec.accepted)
            add(txApplied, exec.applied)
            add(txEventCids, exec.eventCid)
            if exec.applied:
                appliedCount = appliedCount + 1
            else:
                rejectedCount = rejectedCount + 1
            continue
        let exec = BftApplyTxToIndex(nextIndex, BftTxTransfer(assetId, fromAccount, toAccount, amount), height, i)
        add(txCodes, exec.code)
        add(txAccepted, exec.accepted)
        add(txApplied, exec.applied)
        add(txEventCids, exec.eventCid)
        if exec.applied:
            appliedCount = appliedCount + 1
        else:
            rejectedCount = rejectedCount + 1
    summary.appliedCount = appliedCount
    summary.rejectedCount = rejectedCount
    summary.appHash = BftChainIndexAppHash(machine.appId, nextIndex)
    summary.tipEventCid = BftTipEventCidIndex(nextIndex)
    machine.index = nextIndex
    machine.lastFinalizedHeight = height
    return

fn BftStateMachineFinalizeBlockSoA(machine: var BftStateMachine,
                                     height: int64,
                                     txs: BftTx[],
                                     summary: var BftBlockSummary,
                                     txCodes: var int32[],
                                     txAccepted: var bool[],
                                     txApplied: var bool[],
                                     txEventCids: var layout.FixedBytes32[]) =
    var batch = BftTxBatch()
    for i in 0..<txs.len:
        BftTxBatchAdd(batch, txs[i])
    BftStateMachineFinalizeBatchSoA(machine, height, batch, summary, txCodes, txAccepted, txApplied, txEventCids)

fn BftStateMachineFinalizeBlockBytesSoA(machine: var BftStateMachine,
                                          height: int64,
                                          rawTxs: Bytes[],
                                          summary: var BftBlockSummary,
                                          txCodes: var int32[],
                                          txAccepted: var bool[],
                                          txApplied: var bool[],
                                          txEventCids: var layout.FixedBytes32[]) =
    var batch = BftTxBatch()
    for i in 0..<rawTxs.len:
        let addRes = BftTxBatchAddDecoded(batch, rawTxs[i])
        if IsErr(addRes):
            summary.height = height
            summary.txCount = 0
            summary.appliedCount = 0
            summary.rejectedCount = 0
            summary.appHash = layout.FixedBytes32()
            summary.tipEventCid = layout.FixedBytes32()
            txCodes = []
            txAccepted = []
            txApplied = []
            txEventCids = []
            summary.txCount = rawTxs.len
            for j in 0..<rawTxs.len:
                add(txCodes, BftCodeDecodeError)
                add(txAccepted, false)
                add(txApplied, false)
                add(txEventCids, layout.FixedBytes32())
                summary.rejectedCount = summary.rejectedCount + 1
            summary.appHash = BftStateMachineAppHash(machine)
            summary.tipEventCid = BftTipEventCid(machine)
            return
    BftStateMachineFinalizeBatchSoA(machine, height, batch, summary, txCodes, txAccepted, txApplied, txEventCids)

fn BftStateMachineFinalizeBatchInto(machine: var BftStateMachine,
                                      height: int64,
                                      batch: BftTxBatch,
                                      out: var BftBlockResult) =
    var batchCount = 0
    batchCount = BftTxBatchLen(batch)
    out = BftBlockResultZero(height)
    var txCodes: int32[]
    var txAccepted: bool[]
    var txApplied: bool[]
    var txEventCids: layout.FixedBytes32[]
    txCodes = []
    txAccepted = []
    txApplied = []
    txEventCids = []
    out.txCount = batchCount
    if !BftHeightOk(height):
        for i in 0..<batchCount:
            add(txCodes, BftCodeBadHeight)
            add(txAccepted, false)
            add(txApplied, false)
            add(txEventCids, layout.FixedBytes32())
            out.rejectedCount = out.rejectedCount + 1
        out.txCodes = txCodes
        out.txAccepted = txAccepted
        out.txApplied = txApplied
        out.txEventCids = txEventCids
        out.appHash = machine.lastCommitAppHash
        out.tipEventCid = BftTipEventCidIndex(machine.index)
        return
    if height <= machine.lastFinalizedHeight:
        for i in 0..<batchCount:
            add(txCodes, BftCodeBadHeight)
            add(txAccepted, false)
            add(txApplied, false)
            add(txEventCids, layout.FixedBytes32())
            out.rejectedCount = out.rejectedCount + 1
        out.txCodes = txCodes
        out.txAccepted = txAccepted
        out.txApplied = txApplied
        out.txEventCids = txEventCids
        out.appHash = machine.lastCommitAppHash
        out.tipEventCid = BftTipEventCidIndex(machine.index)
        return
    var nextIndex = BftCloneChainIndex(machine.index)
    var appliedCount = 0
    var rejectedCount = 0
    for i in 0..<batchCount:
        let version = batch.versions[i]
        let kind = batch.kinds[i]
        let assetId = batch.assetIds[i]
        let fromAccount = batch.fromAccounts[i]
        let toAccount = batch.toAccounts[i]
        let amount = batch.amounts[i]
        let code = BftTxShapeCodeFields(version, kind, assetId, fromAccount, toAccount, amount)
        if code != BftCodeOk:
            add(txCodes, code)
            add(txAccepted, false)
            add(txApplied, false)
            add(txEventCids, layout.FixedBytes32())
            rejectedCount = rejectedCount + 1
            continue
        if kind == BftTxKindMint:
            let exec = BftApplyTxToIndex(nextIndex, BftTxMint(assetId, toAccount, amount), height, i)
            add(txCodes, exec.code)
            add(txAccepted, exec.accepted)
            add(txApplied, exec.applied)
            add(txEventCids, exec.eventCid)
            if exec.applied:
                appliedCount = appliedCount + 1
            else:
                rejectedCount = rejectedCount + 1
            continue
        let exec = BftApplyTxToIndex(nextIndex, BftTxTransfer(assetId, fromAccount, toAccount, amount), height, i)
        add(txCodes, exec.code)
        add(txAccepted, exec.accepted)
        add(txApplied, exec.applied)
        add(txEventCids, exec.eventCid)
        if exec.applied:
            appliedCount = appliedCount + 1
        else:
            rejectedCount = rejectedCount + 1
    out.txCodes = txCodes
    out.txAccepted = txAccepted
    out.txApplied = txApplied
    out.txEventCids = txEventCids
    out.appliedCount = appliedCount
    out.rejectedCount = rejectedCount
    out.appHash = BftChainIndexAppHash(machine.appId, nextIndex)
    out.tipEventCid = BftTipEventCidIndex(nextIndex)
    machine.index = nextIndex
    machine.lastFinalizedHeight = height
    return

fn BftStateMachineFinalizeBatch(machine: var BftStateMachine, height: int64, batch: BftTxBatch): BftBlockResult =
    var out = BftBlockResultZero(height)
    BftStateMachineFinalizeBatchInto(machine, height, batch, out)
    return out

fn BftStateMachineFinalizeBlockBytes(machine: var BftStateMachine, height: int64, rawTxs: Bytes[]): BftBlockResult =
    var batch = BftTxBatch()
    for i in 0..<rawTxs.len:
        let addRes = BftTxBatchAddDecoded(batch, rawTxs[i])
        if IsErr(addRes):
            var out = BftBlockResultZero(height)
            out.txCount = rawTxs.len
            for j in 0..<rawTxs.len:
                add(out.txCodes, BftCodeDecodeError)
                add(out.txAccepted, false)
                add(out.txApplied, false)
                add(out.txEventCids, layout.FixedBytes32())
                out.rejectedCount = out.rejectedCount + 1
            out.appHash = BftStateMachineAppHash(machine)
            out.tipEventCid = BftTipEventCid(machine)
            return out
    var out = BftBlockResultZero(height)
    BftStateMachineFinalizeBatchInto(machine, height, batch, out)
    return out

fn BftChainIndexAppHash(appId: str, index: consensus.ChainIndex): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    let prefix = bytesFromString("cheng.bft.app_hash")
    let appIdBytes = bytesFromString(appId)
    layout.byteBufAppendBytes(buf, prefix)
    layout.byteBufAppendBytes(buf, appIdBytes)
    lt.AppendU32BE(buf, index.eventCids.len)
    lt.AppendU32BE(buf, index.accountIds.len)
    for i in 0..<index.eventCids.len:
        lt.AppendFixed32(buf, index.eventCids[i])
    for i in 0..<index.accountIds.len:
        lt.AppendU32BE(buf, index.accountAssetIds[i])
        lt.AppendU32BE(buf, index.accountIds[i])
        lt.AppendU32BE(buf, int32(index.balances[i] >> 32))
        lt.AppendU32BE(buf, int32(index.balances[i] & int64(0xffffffff)))
        lt.AppendFixed32(buf, index.accountHeads[i])
        lt.AppendU32BE(buf, index.clockEpochs[i])
        lt.AppendU32BE(buf, index.clockGanzhi[i])
        if index.diverged[i]:
            lt.AppendU32BE(buf, 1)
        else:
            lt.AppendU32BE(buf, 0)
    return lt.FixedCidFromBuf(buf)

fn BftStateMachineAppHash(machine: BftStateMachine): layout.FixedBytes32 =
    return BftChainIndexAppHash(machine.appId, machine.index)

fn BftStateMachineCommit(machine: var BftStateMachine): BftCommitResult =
    var out = BftCommitResult()
    out.height = machine.lastFinalizedHeight
    out.appHash = BftStateMachineAppHash(machine)
    out.tipEventCid = BftTipEventCid(machine)
    out.eventCount = machine.index.eventCids.len
    out.accountCount = machine.index.accountIds.len
    machine.lastCommitAppHash = out.appHash
    machine.lastCommitTipEventCid = out.tipEventCid
    return out

fn BftStateMachineQueryAppHash(machine: BftStateMachine): layout.FixedBytes32 =
    return BftStateMachineAppHash(machine)

fn BftStateMachineQueryBalance(machine: BftStateMachine, assetId: int32, accountId: int32): BftBalanceQueryResult =
    var out = BftBalanceQueryResult()
    out.height = machine.lastFinalizedHeight
    out.appHash = BftStateMachineAppHash(machine)
    if assetId <= 0:
        out.code = BftCodeBadTarget
        return out
    if accountId <= 0:
        out.code = BftCodeBadTarget
        return out
    out.balance = BftBalanceValue(machine.index, assetId, accountId)
    return out

fn BftTxSeq1(a: BftTx): BftTx[] =
    var out: BftTx[]
    out = []
    add(out, a)
    return out

fn BftTxSeq2(a: BftTx, b: BftTx): BftTx[] =
    var out: BftTx[]
    out = []
    add(out, a)
    add(out, b)
    return out

fn BftBytesSeq1(a: Bytes): Bytes[] =
    var out: Bytes[]
    out = []
    add(out, a)
    return out

fn BftSelfTest(): int32 =
    var machine = BftStateMachineInit("bft-self-test")
    let badRaw = bytesFromString("bad")
    let badCheck = BftStateMachineCheckTxBytes(machine, badRaw)
    if badCheck.code != BftCodeDecodeError:
        echo(" bft self-test: decode error check failed")
        return 1

    let mint = BftTxMint(7, 1001, int64(100))
    let mintRaw = BftEncodeTx(mint)
    let mintRoundtripRes = BftDecodeTx(layout.byteSpanFromBytes(mintRaw))
    if !mintRoundtripRes.ok:
        echo(" bft self-test: mint decode failed")
        return 1
    if mintRoundtripRes.value.kind != BftTxKindMint:
        echo(" bft self-test: mint kind mismatch")
        return 1

    let mintCheck = BftStateMachineCheckTx(machine, mint)
    if mintCheck.code != BftCodeOk:
        echo(" bft self-test: mint check failed")
        return 1
    if machine.index.eventCids.len != 0:
        echo(" bft self-test: checktx mutated event log")
        return 1
    if machine.index.accountIds.len != 0:
        echo(" bft self-test: checktx mutated state")
        return 1

    let badTransfer = BftTxTransfer(7, 1001, 1001, int64(1))
    let badTransferCheck = BftStateMachineCheckTx(machine, badTransfer)
    if badTransferCheck.code != BftCodeBadTarget:
        echo(" bft self-test: bad transfer not rejected")
        return 1
    if machine.index.eventCids.len != 0:
        echo(" bft self-test: bad transfer check mutated event log")
        return 1

    var block1Batch = BftTxBatch()
    BftTxBatchAdd(block1Batch, mint)
    BftTxBatchAdd(block1Batch, badTransfer)
    let block1BadCode = BftTxBatchShapeCodeAt(block1Batch, 1)
    if block1BadCode != BftCodeBadTarget:
        echo(" bft self-test: block1 seq bad transfer shape")
        return 1
    if block1Batch.versions[0] != BftTxVersion:
        echo(" bft self-test: block1 batch version")
        return 1
    if block1Batch.kinds[0] != BftTxKindMint:
        echo(" bft self-test: block1 batch mint kind")
        return 1
    if block1Batch.assetIds[0] != 7:
        echo(" bft self-test: block1 batch asset")
        return 1
    if block1Batch.toAccounts[0] != 1001:
        echo(" bft self-test: block1 batch target")
        return 1
    if block1Batch.amounts[0] != int64(100):
        echo(" bft self-test: block1 batch amount")
        return 1
    let block1MintBatchCode = BftTxBatchShapeCodeAt(block1Batch, 0)
    if block1MintBatchCode != BftCodeOk:
        echo(" bft self-test: block1 batch mint shape")
        return 1
    var block1ProbeIndex = BftCloneChainIndex(machine.index)
    let block1MintExec = BftApplyTxToIndex(block1ProbeIndex, mint, int64(1), 0)
    if block1MintExec.code != BftCodeOk:
        echo(" bft self-test: block1 mint exec code")
        return 1
    if !block1MintExec.accepted:
        echo(" bft self-test: block1 mint exec accepted")
        return 1
    if !block1MintExec.applied:
        echo(" bft self-test: block1 mint exec applied")
        return 1
    let block1BadExec = BftApplyTxToIndex(block1ProbeIndex, badTransfer, int64(1), 1)
    if block1BadExec.code != BftCodeBadTarget:
        echo(" bft self-test: block1 bad exec code")
        return 1
    if block1BadExec.accepted:
        echo(" bft self-test: block1 bad exec accepted")
        return 1
    if block1BadExec.applied:
        echo(" bft self-test: block1 bad exec applied")
        return 1
    var block1MachineValue = BftStateMachineInit("bft-self-test-value")
    let block1Value = BftStateMachineFinalizeBatch(block1MachineValue, int64(1), block1Batch)
    if block1Value.txCount != 2:
        echo(" bft self-test: block1 value tx count")
        return 1
    if block1Value.appliedCount != 1:
        if block1Value.appliedCount == 0:
            if block1Value.rejectedCount == 0:
                echo(" bft self-test: block1 value applied zero rejected zero")
            elif block1Value.rejectedCount == 1:
                echo(" bft self-test: block1 value applied zero rejected one")
            elif block1Value.rejectedCount == 2:
                echo(" bft self-test: block1 value applied zero rejected two")
            else:
                echo(" bft self-test: block1 value applied zero rejected other")
        elif block1Value.appliedCount == 2:
            echo(" bft self-test: block1 value applied count two")
        else:
            echo(" bft self-test: block1 value applied count other")
        return 1
    if block1Value.rejectedCount != 1:
        echo(" bft self-test: block1 value rejected count")
        return 1
    var block1Summary = BftBlockSummaryZero(int64(0))
    BftStateMachineFinalizeBatchSummary(machine, int64(1), block1Batch, block1Summary)
    if block1Summary.txCount != 2:
        echo(" bft self-test: block1 tx count")
        return 1
    if block1Summary.appliedCount != 1:
        echo(" bft self-test: block1 applied count")
        return 1
    if block1Summary.rejectedCount != 1:
        echo(" bft self-test: block1 rejected count")
        return 1

    let transfer = BftTxTransfer(7, 1001, 2002, int64(40))
    let transferRaw = BftEncodeTx(transfer)
    var block2Batch = BftTxBatch()
    let block2AddRes = BftTxBatchAddDecoded(block2Batch, transferRaw)
    if IsErr(block2AddRes):
        echo(" bft self-test: block2 decode")
        return 1
    var block2Summary = BftBlockSummaryZero(int64(0))
    BftStateMachineFinalizeBatchSummary(machine, int64(2), block2Batch, block2Summary)
    if block2Summary.appliedCount != 1:
        echo(" bft self-test: block2 applied count")
        return 1
    if !layout.fixedBytes32Equal(block2Summary.tipEventCid, BftTipEventCid(machine)):
        echo(" bft self-test: block2 tip mismatch")
        return 1

    let commit = BftStateMachineCommit(machine)
    if commit.height != int64(2):
        echo(" bft self-test: commit height")
        return 1
    if commit.eventCount != 2:
        echo(" bft self-test: commit event count")
        return 1
    if commit.accountCount != 2:
        echo(" bft self-test: commit account count")
        return 1

    let alice = BftStateMachineQueryBalance(machine, 7, 1001)
    let bob = BftStateMachineQueryBalance(machine, 7, 2002)
    if alice.code != BftCodeOk:
        echo(" bft self-test: alice query")
        return 1
    if bob.code != BftCodeOk:
        echo(" bft self-test: bob query")
        return 1
    if alice.balance != int64(60):
        echo(" bft self-test: alice balance")
        return 1
    if bob.balance != int64(40):
        echo(" bft self-test: bob balance")
        return 1
    if !layout.fixedBytes32Equal(commit.appHash, bob.appHash):
        echo(" bft self-test: app hash mismatch")
        return 1

    var staleBatch = BftTxBatch()
    BftTxBatchAdd(staleBatch, transfer)
    var staleSummary = BftBlockSummaryZero(int64(0))
    BftStateMachineFinalizeBatchSummary(machine, int64(2), staleBatch, staleSummary)
    if staleSummary.rejectedCount != 1:
        echo(" bft self-test: stale height")
        return 1

    echo(" bft_state_machine ok")
    return 0
