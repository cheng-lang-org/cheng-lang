import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
type
    RwadAccumulatorProof =
        leafCid: layout.FixedBytes32
        leafIndex: int32
        leafCount: int32
        siblingCount: int32
        siblingHashes: layout.FixedBytes32[]
        rootCid: layout.FixedBytes32

fn RwadAccumulatorEmptyRoot(): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(64)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.rwad.accumulator.empty"))
    return lt.FixedCidFromBuf(buf)

fn RwadAccumulatorLeafHash(leafCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(96)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.rwad.accumulator.leaf"))
    lt.AppendFixed32(buf, leafCid)
    return lt.FixedCidFromBuf(buf)

fn RwadAccumulatorNodeHash(left: layout.FixedBytes32,
                             right: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.rwad.accumulator.node"))
    lt.AppendFixed32(buf, left)
    lt.AppendFixed32(buf, right)
    return lt.FixedCidFromBuf(buf)

fn RwadAccumulatorLeafHashes(leaves: layout.FixedBytes32[]): layout.FixedBytes32[] =
    var out: layout.FixedBytes32[]
    out = []
    for i in 0..<leaves.len:
        add(out, RwadAccumulatorLeafHash(leaves[i]))
    return out

fn RwadAccumulatorRoot(leaves: layout.FixedBytes32[]): layout.FixedBytes32 =
    if leaves.len <= 0:
        return RwadAccumulatorEmptyRoot()
    var level = RwadAccumulatorLeafHashes(leaves)
    while level.len > 1:
        var next: layout.FixedBytes32[]
        next = []
        var i = 0
        while i < level.len:
            let left = level[i]
            let right = if i + 1 < level.len: level[i + 1] else: level[i]
            add(next, RwadAccumulatorNodeHash(left, right))
            i = i + 2
        level = next
    return level[0]

fn RwadAccumulatorProofInputCode(leaves: layout.FixedBytes32[],
                                   leafIndex: int32): int32 =
    if leaves.len <= 0:
        return 1
    if leafIndex < 0 || leafIndex >= leaves.len:
        return 2
    return 0

fn RwadAccumulatorProofBuildWithCode(inputCode: int32,
                                       leaves: layout.FixedBytes32[],
                                       leafIndex: int32,
                                       out: var RwadAccumulatorProof): bool =
    out = RwadAccumulatorProof()
    if inputCode == 1:
        return false
    if inputCode == 2:
        return false
    out.leafCid = layout.FixedBytes32()
    out.leafIndex = -1
    out.leafCount = 0
    out.siblingCount = 0
    out.siblingHashes = []
    out.rootCid = RwadAccumulatorEmptyRoot()
    out.leafCid = leaves[leafIndex]
    out.leafIndex = leafIndex
    out.leafCount = leaves.len
    out.rootCid = RwadAccumulatorRoot(leaves)
    var level = RwadAccumulatorLeafHashes(leaves)
    var index = leafIndex
    while level.len > 1:
        let siblingIndex = if (index % 2) == 0:
            if index + 1 < level.len: index + 1 else: index
        else:
            index - 1
        add(out.siblingHashes, level[siblingIndex])
        out.siblingCount = out.siblingHashes.len
        var next: layout.FixedBytes32[]
        next = []
        var i = 0
        while i < level.len:
            let left = level[i]
            let right = if i + 1 < level.len: level[i + 1] else: level[i]
            add(next, RwadAccumulatorNodeHash(left, right))
            i = i + 2
        index = index / 2
        level = next
    return true

fn RwadAccumulatorProofBuild(leaves: layout.FixedBytes32[],
                               leafIndex: int32,
                               out: var RwadAccumulatorProof): bool =
    return RwadAccumulatorProofBuildWithCode(
        RwadAccumulatorProofInputCode(leaves, leafIndex),
        leaves,
        leafIndex,
        out
    )

fn RwadAccumulatorProofMake(leaves: layout.FixedBytes32[],
                              leafIndex: int32,
                              out: var RwadAccumulatorProof): bool =
    return RwadAccumulatorProofBuild(leaves, leafIndex, out)

fn RwadAccumulatorProofVerify(proof: RwadAccumulatorProof): bool =
    if proof.leafCount <= 0:
        return false
    if proof.leafIndex < 0 || proof.leafIndex >= proof.leafCount:
        return false
    if proof.siblingCount != proof.siblingHashes.len:
        return false
    var hash = RwadAccumulatorLeafHash(proof.leafCid)
    var index = proof.leafIndex
    for i in 0..<proof.siblingHashes.len:
        let sibling = proof.siblingHashes[i]
        if (index % 2) == 0:
            hash = RwadAccumulatorNodeHash(hash, sibling)
        else:
            hash = RwadAccumulatorNodeHash(sibling, hash)
        index = index / 2
    return layout.fixedBytes32Equal(hash, proof.rootCid)
