import std/cmdline as cmdline
import std/os
import std/result
import std/rawbytes
import std/strings
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/apps/rwad/rwad_accumulator as accum
import cheng/apps/rwad/rwad_serial_state_machine as serial
import cheng/apps/rwad/rwad_bft_state_machine as rwad
import cheng/core/tooling/path as chengpath

const
    RwadBftStateMagic: str = "cheng.rwad.bft.state.v1"

fn RwadMainUsage() =
    os.WriteLine(os.Get_stdout(), "usage: rwad_bft_state_machine <command> [flags]")
    os.WriteLine(os.Get_stdout(), "")
    os.WriteLine(os.Get_stdout(), "commands:")
    os.WriteLine(os.Get_stdout(), "  self-test")
    os.WriteLine(os.Get_stdout(), "  init --state:<file> --app-id:<id> [--force]")
    os.WriteLine(os.Get_stdout(), "  mint --state:<file> --height:<n> --owner:<text> --amount:<n>")
    os.WriteLine(os.Get_stdout(), "  transfer --state:<file> --height:<n> --input-note-id:<n> --from:<text> --to:<text> --start:<n> --end:<n>")
    os.WriteLine(os.Get_stdout(), "  query-owner --state:<file> --owner:<text>")
    os.WriteLine(os.Get_stdout(), "  query-app-hash --state:<file>")
    os.WriteLine(os.Get_stdout(), "  show-state --state:<file>")
    os.WriteLine(os.Get_stdout(), "  note-proof --state:<file> --note-id:<n>")
    os.WriteLine(os.Get_stdout(), "  nullifier-proof --state:<file> --note-id:<n>")

fn RwadMainInt64Text(value: int64): str =
    return strings.Int64ToStr(value)

fn RwadMainHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn RwadMainBytesFromHex(text: str): Result[Bytes] =
    if (len(text) % 2) != 0:
        return Err[Bytes](" rwad: invalid hex length")
    var out = bytesAlloc(len(text) / 2)
    var i = 0
    while i < len(text):
        let hi = RwadMainHexValue(text[i])
        let lo = RwadMainHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes](" rwad: invalid hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn RwadMainReadRequiredFlag(flag: str,
                              outValue: var str): Result[bool] =
    outValue = ""
    let rawValue = cmdline.ReadFlagOrDefault(flag, "")
    if len(rawValue) <= 0:
        return Err[bool](strutil.Join([" rwad: missing ", flag], ""))
    outValue = strutil.Strip(rawValue)
    if len(outValue) <= 0:
        return Err[bool](strutil.Join([" rwad: empty ", flag], ""))
    return Ok[bool](true)

fn RwadMainParseInt64Text(raw: str): Result[int64] =
    let text = strutil.Strip(raw)
    if len(text) <= 0:
        return Err[int64](strutil.Join([" rwad: invalid integer: ", raw], ""))
    var sign = int64(1)
    var i = int32(0)
    if text[0] == '+':
        i = 1
    elif text[0] == '-':
        sign = int64(-1)
        i = 1
    if i >= len(text):
        return Err[int64](strutil.Join([" rwad: invalid integer: ", raw], ""))
    var value = int64(0)
    for i in i..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int64](strutil.Join([" rwad: invalid integer: ", raw], ""))
        let digit = int64(int32(ch) - int32('0'))
        value = value * int64(10) + digit
    return Ok[int64](value * sign)

fn RwadMainReadRequiredInt64Flag(flag: str,
                                   outValue: var int64): Result[bool] =
    var raw = ""
    let readRes = RwadMainReadRequiredFlag(flag, raw)
    if IsErr(readRes):
        return Err[bool](Error(readRes))
    let parsedRes = RwadMainParseInt64Text(raw)
    if IsErr(parsedRes):
        return Err[bool](strutil.Join([" rwad: invalid integer for ", flag, ": ", raw], ""))
    outValue = Value(parsedRes)
    return Ok[bool](true)

fn RwadMainReadRequiredStatePath(outValue: var str): Result[bool] =
    return RwadMainReadRequiredFlag("--state", outValue)

fn RwadMainPrefixValue(line: str,
                         prefix: str): str =
    if !strutil.StartsWith(line, prefix):
        return ""
    let rawValue = chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
    return strutil.Strip(rawValue)

fn RwadMainParseInt64(text: str,
                        outValue: var int64): bool =
    let parsedRes = RwadMainParseInt64Text(text)
    if IsErr(parsedRes):
        return false
    outValue = Value(parsedRes)
    return true

fn RwadMainParseFixed32(text: str,
                          outValue: var layout.FixedBytes32): bool =
    let fixedRes = layout.FixedBytes32FromHex(strutil.Strip(text))
    if IsErr(fixedRes):
        return false
    outValue = Value(fixedRes)
    return true

fn RwadMainStateText(machine: var rwad.RwadBftStateMachine): str =
    var out = ""
    out = strutil.Join([out, RwadBftStateMagic, "\n"], "")
    out = strutil.Join([out, "app_id_hex=", bytesToHex(bytesFromString(machine.ledger.appId)), "\n"], "")
    out = strutil.Join([out, "next_serial=", RwadMainInt64Text(machine.ledger.nextSerial), "\n"], "")
    out = strutil.Join([out, "next_note_id=", RwadMainInt64Text(machine.ledger.nextNoteId), "\n"], "")
    out = strutil.Join([out, "last_finalized_height=", RwadMainInt64Text(machine.ledger.lastFinalizedHeight), "\n"], "")
    out = strutil.Join([out, "last_apply_order_key=", RwadMainInt64Text(machine.ledger.lastApplyOrderKey), "\n"], "")
    out = strutil.Join([out, "last_commit_app_hash=", layout.FixedBytes32Hex(machine.ledger.lastCommitAppHash), "\n"], "")
    out = strutil.Join([out, "note_count=", IntToStr(machine.ledger.notes.len), "\n"], "")
    for i in 0..<machine.ledger.notes.len:
        let note = machine.ledger.notes[i]
        out = strutil.Join([out, "note[", IntToStr(i), "]="], "")
        out = strutil.Join([out, RwadMainInt64Text(note.noteId)], "")
        out = strutil.Join([out, "|"], "")
        out = strutil.Join([out, RwadMainInt64Text(note.startSerial)], "")
        out = strutil.Join([out, "|"], "")
        out = strutil.Join([out, RwadMainInt64Text(note.endSerial)], "")
        out = strutil.Join([out, "|"], "")
        out = strutil.Join([out, layout.FixedBytes32Hex(note.ownerId)], "")
        out = strutil.Join([out, "|"], "")
        out = strutil.Join([out, RwadMainInt64Text(note.createdHeight)], "")
        out = strutil.Join([out, "|"], "")
        if note.live:
            out = strutil.Join([out, "1"], "")
        else:
            out = strutil.Join([out, "0"], "")
        out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, "nullifier_count=", IntToStr(machine.ledger.nullifiers.len), "\n"], "")
    for i in 0..<machine.ledger.nullifiers.len:
        let item = machine.ledger.nullifiers[i]
        out = strutil.Join([out, "nullifier[", IntToStr(i), "]="], "")
        out = strutil.Join([out, RwadMainInt64Text(item.noteId)], "")
        out = strutil.Join([out, "|"], "")
        out = strutil.Join([out, layout.FixedBytes32Hex(item.nullifierCid)], "")
        out = strutil.Join([out, "|"], "")
        out = strutil.Join([out, RwadMainInt64Text(item.spendHeight)], "")
        out = strutil.Join([out, "\n"], "")
    return out

fn RwadMainWriteState(pathRaw: str,
                        machine: var rwad.RwadBftStateMachine): bool =
    let stateText = RwadMainStateText(machine)
    let cwd = os.GetCurrentDir()
    return chengpath.WriteTextFile(cwd, pathRaw, stateText)

fn RwadMainParseNote(line: str,
                       out: var serial.RwadIntervalNote): bool =
    let prefixPos = strutil.Split(line, '=')
    if prefixPos.len != 2:
        return false
    let valueText = prefixPos[1]
    let parts = strutil.Split(valueText, '|')
    if parts.len != 6:
        return false
    if !RwadMainParseInt64(parts[0], out.noteId):
        return false
    if !RwadMainParseInt64(parts[1], out.startSerial):
        return false
    if !RwadMainParseInt64(parts[2], out.endSerial):
        return false
    if !RwadMainParseFixed32(parts[3], out.ownerId):
        return false
    if !RwadMainParseInt64(parts[4], out.createdHeight):
        return false
    let liveRaw = parts[5]
    let liveText = strutil.Strip(liveRaw)
    if liveText == "1":
        out.live = true
    elif liveText == "0":
        out.live = false
    else:
        return false
    return true

fn RwadMainParseNullifier(line: str,
                            out: var serial.RwadNullifier): bool =
    let prefixPos = strutil.Split(line, '=')
    if prefixPos.len != 2:
        return false
    let valueText = prefixPos[1]
    let parts = strutil.Split(valueText, '|')
    if parts.len != 3:
        return false
    if !RwadMainParseInt64(parts[0], out.noteId):
        return false
    if !RwadMainParseFixed32(parts[1], out.nullifierCid):
        return false
    if !RwadMainParseInt64(parts[2], out.spendHeight):
        return false
    return true

fn RwadMainLoadState(pathRaw: str): Result[rwad.RwadBftStateMachine] =
    let cwd = os.GetCurrentDir()
    let text = chengpath.ReadTextFile(cwd, pathRaw)
    let trimmedText = strutil.Strip(text)
    if len(trimmedText) <= 0:
        return Err[rwad.RwadBftStateMachine](strutil.Join([" rwad: missing or empty state file: ", pathRaw], ""))
    let lines = strutil.Split(text, '\n')
    var sawMagic = false
    var appId = ""
    var nextSerial = int64(1)
    var nextNoteId = int64(1)
    var lastFinalizedHeight = int64(0)
    var lastApplyOrderKey = int64(0)
    var lastCommitAppHash = layout.FixedBytes32()
    var notes: serial.RwadIntervalNote[]
    var nullifiers: serial.RwadNullifier[]
    notes = []
    nullifiers = []
    for i in 0..<lines.len:
        let rawLine = lines[i]
        let line = strutil.Strip(rawLine)
        if len(line) <= 0:
            continue
        if line == RwadBftStateMagic:
            sawMagic = true
        elif strutil.StartsWith(line, "app_id_hex="):
            let appRes = RwadMainBytesFromHex(RwadMainPrefixValue(line, "app_id_hex="))
            if IsErr(appRes):
                return Err[rwad.RwadBftStateMachine](Error(appRes))
            appId = bytesToString(Value(appRes))
        elif strutil.StartsWith(line, "next_serial="):
            if !RwadMainParseInt64(RwadMainPrefixValue(line, "next_serial="), nextSerial):
                return Err[rwad.RwadBftStateMachine](" rwad: invalid next_serial")
        elif strutil.StartsWith(line, "next_note_id="):
            if !RwadMainParseInt64(RwadMainPrefixValue(line, "next_note_id="), nextNoteId):
                return Err[rwad.RwadBftStateMachine](" rwad: invalid next_note_id")
        elif strutil.StartsWith(line, "last_finalized_height="):
            if !RwadMainParseInt64(RwadMainPrefixValue(line, "last_finalized_height="), lastFinalizedHeight):
                return Err[rwad.RwadBftStateMachine](" rwad: invalid last_finalized_height")
        elif strutil.StartsWith(line, "last_apply_order_key="):
            if !RwadMainParseInt64(RwadMainPrefixValue(line, "last_apply_order_key="), lastApplyOrderKey):
                return Err[rwad.RwadBftStateMachine](" rwad: invalid last_apply_order_key")
        elif strutil.StartsWith(line, "last_commit_app_hash="):
            if !RwadMainParseFixed32(RwadMainPrefixValue(line, "last_commit_app_hash="), lastCommitAppHash):
                return Err[rwad.RwadBftStateMachine](" rwad: invalid last_commit_app_hash")
        elif strutil.StartsWith(line, "note["):
            var note: serial.RwadIntervalNote
            if !RwadMainParseNote(line, note):
                return Err[rwad.RwadBftStateMachine](" rwad: invalid note line")
            add(notes, note)
        elif strutil.StartsWith(line, "nullifier["):
            var item: serial.RwadNullifier
            if !RwadMainParseNullifier(line, item):
                return Err[rwad.RwadBftStateMachine](" rwad: invalid nullifier line")
            add(nullifiers, item)
    if !sawMagic || len(appId) <= 0:
        return Err[rwad.RwadBftStateMachine](" rwad: invalid state header")
    var machine = rwad.RwadBftStateMachineInit(appId)
    machine.ledger.nextSerial = nextSerial
    machine.ledger.nextNoteId = nextNoteId
    machine.ledger.lastFinalizedHeight = lastFinalizedHeight
    machine.ledger.lastApplyOrderKey = lastApplyOrderKey
    machine.ledger.lastCommitAppHash = lastCommitAppHash
    machine.ledger.notes = notes
    machine.ledger.nullifiers = nullifiers
    return Ok[rwad.RwadBftStateMachine](machine)

fn RwadMainCommitReport(machine: var rwad.RwadBftStateMachine): str =
    let commit = serial.RwadStateMachineCommit(machine.ledger)
    var out = ""
    out = strutil.Join([out, "height=", RwadMainInt64Text(commit.height), "\n"], "")
    out = strutil.Join([out, "next_serial=", RwadMainInt64Text(commit.nextSerial), "\n"], "")
    out = strutil.Join([out, "next_note_id=", RwadMainInt64Text(commit.nextNoteId), "\n"], "")
    out = strutil.Join([out, "live_note_count=", IntToStr(commit.liveNoteCount), "\n"], "")
    out = strutil.Join([out, "nullifier_count=", IntToStr(commit.nullifierCount), "\n"], "")
    out = strutil.Join([out, "serial_root=", layout.FixedBytes32Hex(commit.serialRoot), "\n"], "")
    out = strutil.Join([out, "nullifier_root=", layout.FixedBytes32Hex(commit.nullifierRoot), "\n"], "")
    out = strutil.Join([out, "serial_accumulator_root=", layout.FixedBytes32Hex(commit.serialAccumulatorRoot), "\n"], "")
    out = strutil.Join([out, "nullifier_accumulator_root=", layout.FixedBytes32Hex(commit.nullifierAccumulatorRoot), "\n"], "")
    out = strutil.Join([out, "app_hash=", layout.FixedBytes32Hex(commit.appHash)], "")
    return out

fn RwadMainBlockSummaryReport(summary: rwad.RwadBftBlockSummary): str =
    var out = ""
    out = strutil.Join([out, "height=", RwadMainInt64Text(summary.height), "\n"], "")
    out = strutil.Join([out, "tx_count=", IntToStr(summary.txCount), "\n"], "")
    out = strutil.Join([out, "applied_count=", IntToStr(summary.appliedCount), "\n"], "")
    out = strutil.Join([out, "rejected_count=", IntToStr(summary.rejectedCount), "\n"], "")
    out = strutil.Join([out, "serial_root=", layout.FixedBytes32Hex(summary.serialRoot), "\n"], "")
    out = strutil.Join([out, "nullifier_root=", layout.FixedBytes32Hex(summary.nullifierRoot), "\n"], "")
    out = strutil.Join([out, "serial_accumulator_root=", layout.FixedBytes32Hex(summary.serialAccumulatorRoot), "\n"], "")
    out = strutil.Join([out, "nullifier_accumulator_root=", layout.FixedBytes32Hex(summary.nullifierAccumulatorRoot), "\n"], "")
    out = strutil.Join([out, "app_hash=", layout.FixedBytes32Hex(summary.appHash)], "")
    return out

fn RwadMainProofReport(proof: var accum.RwadAccumulatorProof): str =
    var out = ""
    out = strutil.Join([out, "leaf_cid=", layout.FixedBytes32Hex(proof.leafCid), "\n"], "")
    out = strutil.Join([out, "leaf_index=", IntToStr(proof.leafIndex), "\n"], "")
    out = strutil.Join([out, "leaf_count=", IntToStr(proof.leafCount), "\n"], "")
    out = strutil.Join([out, "sibling_count=", IntToStr(proof.siblingCount), "\n"], "")
    for i in 0..<proof.siblingHashes.len:
        out = strutil.Join([out, "sibling[", IntToStr(i), "]=", layout.FixedBytes32Hex(proof.siblingHashes[i]), "\n"], "")
    out = strutil.Join([out, "root_cid=", layout.FixedBytes32Hex(proof.rootCid), "\n"], "")
    out = strutil.Join([out, "proof_valid=", IntToStr(accum.RwadAccumulatorProofVerify(proof) ? 1 : 0)], "")
    return out

fn RwadMainInitCommand(): int32 =
    var statePath = ""
    let statePathRes = RwadMainReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        let errText = Error(statePathRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let cwd = os.GetCurrentDir()
    let absoluteStatePath = chengpath.PathAbsolute(cwd, statePath)
    let stateExists = chengpath.PathFileExists(absoluteStatePath)
    let forceOverwrite = cmdline.HasFlag("--force")
    if stateExists && !forceOverwrite:
        let errText = strutil.Join([" rwad: state already exists: ", absoluteStatePath, " (pass --force to overwrite)"], "")
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var appId = ""
    let appRes = RwadMainReadRequiredFlag("--app-id", appId)
    if IsErr(appRes):
        let errText = Error(appRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var machine = rwad.RwadBftStateMachineInit(appId)
    if !RwadMainWriteState(statePath, machine):
        let errText = strutil.Join([" rwad: failed to write state: ", absoluteStatePath], "")
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let reportText = RwadMainCommitReport(machine)
    os.WriteLine(os.Get_stdout(), reportText)
    return 0

fn RwadMainMintCommand(): int32 =
    var statePath = ""
    let statePathRes = RwadMainReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        let errText = Error(statePathRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let loadRes = RwadMainLoadState(statePath)
    if IsErr(loadRes):
        let errText = Error(loadRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var machine = Value(loadRes)
    var height = int64(0)
    let heightRes = RwadMainReadRequiredInt64Flag("--height", height)
    if IsErr(heightRes):
        let errText = Error(heightRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var ownerText = ""
    let ownerRes = RwadMainReadRequiredFlag("--owner", ownerText)
    if IsErr(ownerRes):
        let errText = Error(ownerRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var amount = int64(0)
    let amountRes = RwadMainReadRequiredInt64Flag("--amount", amount)
    if IsErr(amountRes):
        let errText = Error(amountRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let tx = rwad.RwadBftTxMint(serial.RwadOwnerIdFromText(ownerText), amount)
    var block: rwad.RwadBftTx[]
    block = []
    add(block, tx)
    var summary = rwad.RwadBftBlockSummaryZero(height)
    rwad.RwadBftStateMachineFinalizeBlockSummary(machine, height, block, summary)
    if summary.appliedCount != 1 || summary.rejectedCount != 0:
        let reportText = RwadMainBlockSummaryReport(summary)
        os.WriteLine(os.Get_stderr(), reportText)
        return 2
    if !RwadMainWriteState(statePath, machine):
        let errText = strutil.Join([" rwad: failed to persist state: ", statePath], "")
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let reportText = RwadMainBlockSummaryReport(summary)
    os.WriteLine(os.Get_stdout(), reportText)
    return 0

fn RwadMainTransferCommand(): int32 =
    var statePath = ""
    let statePathRes = RwadMainReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        let errText = Error(statePathRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let loadRes = RwadMainLoadState(statePath)
    if IsErr(loadRes):
        let errText = Error(loadRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var machine = Value(loadRes)
    var height = int64(0)
    var inputNoteId = int64(0)
    var spendStart = int64(0)
    var spendEnd = int64(0)
    let heightRes = RwadMainReadRequiredInt64Flag("--height", height)
    let noteRes = RwadMainReadRequiredInt64Flag("--input-note-id", inputNoteId)
    let startRes = RwadMainReadRequiredInt64Flag("--start", spendStart)
    let endRes = RwadMainReadRequiredInt64Flag("--end", spendEnd)
    if IsErr(heightRes) || IsErr(noteRes) || IsErr(startRes) || IsErr(endRes):
        if IsErr(heightRes):
            let errText = Error(heightRes)
            os.WriteLine(os.Get_stderr(), errText)
        elif IsErr(noteRes):
            let errText = Error(noteRes)
            os.WriteLine(os.Get_stderr(), errText)
        elif IsErr(startRes):
            let errText = Error(startRes)
            os.WriteLine(os.Get_stderr(), errText)
        else:
            let errText = Error(endRes)
            os.WriteLine(os.Get_stderr(), errText)
        return 2
    var fromOwnerText = ""
    var toOwnerText = ""
    let fromRes = RwadMainReadRequiredFlag("--from", fromOwnerText)
    let toRes = RwadMainReadRequiredFlag("--to", toOwnerText)
    if IsErr(fromRes) || IsErr(toRes):
        if IsErr(fromRes):
            let errText = Error(fromRes)
            os.WriteLine(os.Get_stderr(), errText)
        else:
            let errText = Error(toRes)
            os.WriteLine(os.Get_stderr(), errText)
        return 2
    let tx = rwad.RwadBftTxTransfer(inputNoteId,
                                      serial.RwadOwnerIdFromText(fromOwnerText),
                                      serial.RwadOwnerIdFromText(toOwnerText),
                                      spendStart,
                                      spendEnd)
    var block: rwad.RwadBftTx[]
    block = []
    add(block, tx)
    var summary = rwad.RwadBftBlockSummaryZero(height)
    rwad.RwadBftStateMachineFinalizeBlockSummary(machine, height, block, summary)
    if summary.appliedCount != 1 || summary.rejectedCount != 0:
        let reportText = RwadMainBlockSummaryReport(summary)
        os.WriteLine(os.Get_stderr(), reportText)
        return 2
    if !RwadMainWriteState(statePath, machine):
        let errText = strutil.Join([" rwad: failed to persist state: ", statePath], "")
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let reportText = RwadMainBlockSummaryReport(summary)
    os.WriteLine(os.Get_stdout(), reportText)
    return 0

fn RwadMainQueryOwnerCommand(): int32 =
    var statePath = ""
    let statePathRes = RwadMainReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        let errText = Error(statePathRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let loadRes = RwadMainLoadState(statePath)
    if IsErr(loadRes):
        let errText = Error(loadRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let machine = Value(loadRes)
    var ownerText = ""
    let ownerRes = RwadMainReadRequiredFlag("--owner", ownerText)
    if IsErr(ownerRes):
        let errText = Error(ownerRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let ownerId = serial.RwadOwnerIdFromText(ownerText)
    let query = rwad.RwadBftStateMachineQueryOwner(machine, ownerId)
    let ownerLine = strutil.Join(["owner_id=", layout.FixedBytes32Hex(ownerId)], "")
    let balanceLine = strutil.Join(["balance=", RwadMainInt64Text(query.balance)], "")
    let liveNoteLine = strutil.Join(["live_note_count=", IntToStr(query.liveNoteCount)], "")
    let ownerRootLine = strutil.Join(["owner_root=", layout.FixedBytes32Hex(query.ownerRoot)], "")
    let appHashLine = strutil.Join(["app_hash=", layout.FixedBytes32Hex(query.appHash)], "")
    let heightLine = strutil.Join(["height=", RwadMainInt64Text(query.height)], "")
    os.WriteLine(os.Get_stdout(), ownerLine)
    os.WriteLine(os.Get_stdout(), balanceLine)
    os.WriteLine(os.Get_stdout(), liveNoteLine)
    os.WriteLine(os.Get_stdout(), ownerRootLine)
    os.WriteLine(os.Get_stdout(), appHashLine)
    os.WriteLine(os.Get_stdout(), heightLine)
    return 0

fn RwadMainQueryAppHashCommand(): int32 =
    var statePath = ""
    let statePathRes = RwadMainReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        let errText = Error(statePathRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let loadRes = RwadMainLoadState(statePath)
    if IsErr(loadRes):
        let errText = Error(loadRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let machine = Value(loadRes)
    let appHash = rwad.RwadBftStateMachineQueryAppHash(machine)
    let appHashLine = strutil.Join(["app_hash=", layout.FixedBytes32Hex(appHash)], "")
    os.WriteLine(os.Get_stdout(), appHashLine)
    return 0

fn RwadMainShowStateCommand(): int32 =
    var statePath = ""
    let statePathRes = RwadMainReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        let errText = Error(statePathRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let loadRes = RwadMainLoadState(statePath)
    if IsErr(loadRes):
        let errText = Error(loadRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var machine = Value(loadRes)
    let reportText = RwadMainCommitReport(machine)
    os.WriteLine(os.Get_stdout(), reportText)
    return 0

fn RwadMainNoteProofCommand(): int32 =
    var statePath = ""
    let statePathRes = RwadMainReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        let errText = Error(statePathRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let loadRes = RwadMainLoadState(statePath)
    if IsErr(loadRes):
        let errText = Error(loadRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let machine = Value(loadRes)
    var noteId = int64(0)
    let noteRes = RwadMainReadRequiredInt64Flag("--note-id", noteId)
    if IsErr(noteRes):
        let errText = Error(noteRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var proof: accum.RwadAccumulatorProof
    if !serial.RwadSerialAccumulatorProof(machine.ledger, noteId, proof):
        let errText = strutil.Join([" rwad: missing live note for proof: ", RwadMainInt64Text(noteId)], "")
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let reportText = RwadMainProofReport(proof)
    os.WriteLine(os.Get_stdout(), reportText)
    return 0

fn RwadMainNullifierProofCommand(): int32 =
    var statePath = ""
    let statePathRes = RwadMainReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        let errText = Error(statePathRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let loadRes = RwadMainLoadState(statePath)
    if IsErr(loadRes):
        let errText = Error(loadRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let machine = Value(loadRes)
    var noteId = int64(0)
    let noteRes = RwadMainReadRequiredInt64Flag("--note-id", noteId)
    if IsErr(noteRes):
        let errText = Error(noteRes)
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    var proof: accum.RwadAccumulatorProof
    if !serial.RwadNullifierAccumulatorProof(machine.ledger, noteId, proof):
        let errText = strutil.Join([" rwad: missing nullifier for note: ", RwadMainInt64Text(noteId)], "")
        os.WriteLine(os.Get_stderr(), errText)
        return 2
    let reportText = RwadMainProofReport(proof)
    os.WriteLine(os.Get_stdout(), reportText)
    return 0

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    cmdline.CaptureCmdLine(argc, argv)
    let count = cmdline.ParamCount()
    if count <= 0:
        RwadMainUsage()
        return 0
    let cmd = cmdline.ParamStr(1)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        RwadMainUsage()
        return 0
    if cmd == "self-test":
        return rwad.RwadBftSelfTest()
    if cmd == "init":
        return RwadMainInitCommand()
    if cmd == "mint":
        return RwadMainMintCommand()
    if cmd == "transfer":
        return RwadMainTransferCommand()
    if cmd == "query-owner":
        return RwadMainQueryOwnerCommand()
    if cmd == "query-app-hash":
        return RwadMainQueryAppHashCommand()
    if cmd == "show-state":
        return RwadMainShowStateCommand()
    if cmd == "note-proof":
        return RwadMainNoteProofCommand()
    if cmd == "nullifier-proof":
        return RwadMainNullifierProofCommand()
    let errText = strutil.Join([" rwad: unknown command: ", cmd], "")
    os.WriteLine(os.Get_stderr(), errText)
    RwadMainUsage()
    return 2
