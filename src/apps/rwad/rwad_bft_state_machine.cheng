import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/apps/rwad/rwad_serial_state_machine as serial

const
    RwadBftVersion: int32 = 1
    RwadBftTxKindMint: int32 = 1
    RwadBftTxKindTransfer: int32 = 2
    RwadBftTxWireSize: int32 = 144
    RwadBftCodeDecodeError: int32 = 100
    RwadBftCodeBadVersion: int32 = 101
    RwadBftCodeBadKind: int32 = 102

type
    RwadBftTx =
        kind: int32
        ownerId: layout.FixedBytes32
        amount: int64
        inputNoteId: int64
        fromOwner: layout.FixedBytes32
        toOwner: layout.FixedBytes32
        spendStart: int64
        spendEnd: int64

    RwadBftBlockContext =
        height: int64
        txIndex: int32
        timeHint: int64
        proposerHint: layout.FixedBytes32

    RwadBftTxCheckResult =
        code: int32
        accepted: bool
        applied: bool
        spentNullifier: layout.FixedBytes32
        primaryNoteId: int64
        secondaryNoteId: int64
        tertiaryNoteId: int64
        appHash: layout.FixedBytes32
        nextHeight: int64

    RwadBftBlockSummary =
        height: int64
        txCount: int32
        appliedCount: int32
        rejectedCount: int32
        serialRoot: layout.FixedBytes32
        nullifierRoot: layout.FixedBytes32
        serialAccumulatorRoot: layout.FixedBytes32
        nullifierAccumulatorRoot: layout.FixedBytes32
        appHash: layout.FixedBytes32

    RwadBftOwnerQueryResult =
        code: int32
        balance: int64
        liveNoteCount: int32
        ownerRoot: layout.FixedBytes32
        appHash: layout.FixedBytes32
        height: int64

    RwadBftStateMachine =
        ledger: serial.RwadStateMachine

fn RwadBftStateMachineInit(appId: str): RwadBftStateMachine =
    var out: RwadBftStateMachine
    out.ledger = serial.RwadStateMachineInit(appId)
    return out

fn RwadBftAppendU32BE(buf: var layout.ByteBuf, value: int64) =
    lt.AppendU32BE(buf, value)

fn RwadBftAppendI64BE(buf: var layout.ByteBuf, value: int64) =
    RwadBftAppendU32BE(buf, int32((value >> 32) & int64(0xffffffff)))
    RwadBftAppendU32BE(buf, int32(value & int64(0xffffffff)))

fn RwadBftReadU32BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    if offset < 0:
        return Err[int64](" rwad_bft: short u32")
    let endOffset: int32 = offset + 4
    if endOffset > layout.byteSpanLen(span):
        return Err[int64](" rwad_bft: short u32")
    let b0: int64 = int64(layout.byteSpanAt(span, offset))
    let b1: int64 = int64(layout.byteSpanAt(span, offset + 1))
    let b2: int64 = int64(layout.byteSpanAt(span, offset + 2))
    let b3: int64 = int64(layout.byteSpanAt(span, offset + 3))
    return Ok[int64]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn RwadBftReadI64BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    let hiRes = RwadBftReadU32BE(span, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = RwadBftReadU32BE(span, offset + 4)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    let hi = int32(Value(hiRes))
    let lo = Value(loRes)
    return Ok[int64]((int64(hi) << 32) | (lo & int64(0xffffffff)))

fn RwadBftReadFixed32(span: layout.ByteSpan, offset: int32): Result[layout.FixedBytes32] =
    if offset < 0:
        return Err[layout.FixedBytes32](" rwad_bft: short fixed32")
    let endOffset: int32 = offset + 32
    if endOffset > layout.byteSpanLen(span):
        return Err[layout.FixedBytes32](" rwad_bft: short fixed32")
    let bytes = layout.byteSpanToBytes(layout.byteSpanSlice(span, offset, 32))
    return layout.fixedBytes32FromBytes(bytes)

fn RwadBftTxMint(ownerId: layout.FixedBytes32, amount: int64): RwadBftTx =
    var out: RwadBftTx
    out.kind = RwadBftTxKindMint
    out.ownerId = ownerId
    out.amount = amount
    out.inputNoteId = int64(0)
    out.fromOwner = layout.FixedBytes32()
    out.toOwner = layout.FixedBytes32()
    out.spendStart = int64(0)
    out.spendEnd = int64(0)
    return out

fn RwadBftTxTransfer(inputNoteId: int64,
                       fromOwner: layout.FixedBytes32,
                       toOwner: layout.FixedBytes32,
                       spendStart: int64,
                       spendEnd: int64): RwadBftTx =
    var out: RwadBftTx
    out.kind = RwadBftTxKindTransfer
    out.ownerId = layout.FixedBytes32()
    out.amount = int64(0)
    out.inputNoteId = inputNoteId
    out.fromOwner = fromOwner
    out.toOwner = toOwner
    out.spendStart = spendStart
    out.spendEnd = spendEnd
    return out

fn RwadBftTxShapeCode(tx: RwadBftTx): int32 =
    if tx.kind == RwadBftTxKindMint:
        if serial.RwadOwnerZero(tx.ownerId):
            return serial.RwadSerialCodeBadOwner
        if tx.amount <= int64(0):
            return serial.RwadSerialCodeBadAmount
        return serial.RwadSerialCodeOk
    if tx.kind == RwadBftTxKindTransfer:
        if tx.inputNoteId <= int64(0):
            return serial.RwadSerialCodeBadNote
        if serial.RwadOwnerZero(tx.fromOwner):
            return serial.RwadSerialCodeBadOwner
        if serial.RwadOwnerZero(tx.toOwner):
            return serial.RwadSerialCodeBadTarget
        if tx.spendStart > tx.spendEnd:
            return serial.RwadSerialCodeBadRange
        return serial.RwadSerialCodeOk
    return RwadBftCodeBadKind

fn RwadBftEncodeTx(tx: RwadBftTx): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(RwadBftTxWireSize)
    RwadBftAppendU32BE(buf, RwadBftVersion)
    RwadBftAppendU32BE(buf, tx.kind)
    RwadBftAppendU32BE(buf, 0)
    RwadBftAppendU32BE(buf, 0)
    lt.AppendFixed32(buf, tx.ownerId)
    RwadBftAppendI64BE(buf, tx.amount)
    RwadBftAppendI64BE(buf, tx.inputNoteId)
    lt.AppendFixed32(buf, tx.fromOwner)
    lt.AppendFixed32(buf, tx.toOwner)
    RwadBftAppendI64BE(buf, tx.spendStart)
    RwadBftAppendI64BE(buf, tx.spendEnd)
    return layout.byteBufToBytes(buf)

fn RwadBftDecodeTx(data: layout.ByteSpan): Result[RwadBftTx] =
    if layout.byteSpanLen(data) != RwadBftTxWireSize:
        return Err[RwadBftTx](" rwad_bft: bad tx size")
    let versionRes = RwadBftReadU32BE(data, 0)
    if IsErr(versionRes):
        return Err[RwadBftTx](Error(versionRes))
    if int32(Value(versionRes)) != RwadBftVersion:
        return Err[RwadBftTx](" rwad_bft: bad version")
    let kindRes = RwadBftReadU32BE(data, 4)
    if IsErr(kindRes):
        return Err[RwadBftTx](Error(kindRes))
    let ownerRes = RwadBftReadFixed32(data, 16)
    if IsErr(ownerRes):
        return Err[RwadBftTx](Error(ownerRes))
    let amountRes = RwadBftReadI64BE(data, 48)
    if IsErr(amountRes):
        return Err[RwadBftTx](Error(amountRes))
    let inputNoteIdRes = RwadBftReadI64BE(data, 56)
    if IsErr(inputNoteIdRes):
        return Err[RwadBftTx](Error(inputNoteIdRes))
    let fromOwnerRes = RwadBftReadFixed32(data, 64)
    if IsErr(fromOwnerRes):
        return Err[RwadBftTx](Error(fromOwnerRes))
    let toOwnerRes = RwadBftReadFixed32(data, 96)
    if IsErr(toOwnerRes):
        return Err[RwadBftTx](Error(toOwnerRes))
    let spendStartRes = RwadBftReadI64BE(data, 128)
    if IsErr(spendStartRes):
        return Err[RwadBftTx](Error(spendStartRes))
    let spendEndRes = RwadBftReadI64BE(data, 136)
    if IsErr(spendEndRes):
        return Err[RwadBftTx](Error(spendEndRes))
    var out: RwadBftTx
    out.kind = int32(Value(kindRes))
    out.ownerId = Value(ownerRes)
    out.amount = Value(amountRes)
    out.inputNoteId = Value(inputNoteIdRes)
    out.fromOwner = Value(fromOwnerRes)
    out.toOwner = Value(toOwnerRes)
    out.spendStart = Value(spendStartRes)
    out.spendEnd = Value(spendEndRes)
    return Ok[RwadBftTx](out)

fn RwadBftBlockContextMake(height: int64,
                             txIndex: int32,
                             timeHint: int64,
                             proposerHint: layout.FixedBytes32): RwadBftBlockContext =
    var out: RwadBftBlockContext
    out.height = height
    out.txIndex = txIndex
    out.timeHint = timeHint
    out.proposerHint = proposerHint
    return out

fn RwadBftBlockSummaryZero(height: int64): RwadBftBlockSummary =
    var out: RwadBftBlockSummary
    out.height = height
    out.txCount = 0
    out.appliedCount = 0
    out.rejectedCount = 0
    out.serialRoot = layout.FixedBytes32()
    out.nullifierRoot = layout.FixedBytes32()
    out.serialAccumulatorRoot = layout.FixedBytes32()
    out.nullifierAccumulatorRoot = layout.FixedBytes32()
    out.appHash = layout.FixedBytes32()
    return out

fn RwadBftApplyResultIntoCheckResult(apply: serial.RwadApplyResult,
                                       height: int64): RwadBftTxCheckResult =
    var out = RwadBftTxCheckResult()
    out.code = apply.code
    out.accepted = apply.accepted
    out.applied = apply.applied
    out.spentNullifier = apply.spentNullifier
    out.primaryNoteId = apply.primaryNoteId
    out.secondaryNoteId = apply.secondaryNoteId
    out.tertiaryNoteId = apply.tertiaryNoteId
    out.appHash = apply.appHash
    out.nextHeight = height
    return out

fn RwadBftApplyTxOrdered(machine: var RwadBftStateMachine,
                           context: RwadBftBlockContext,
                           tx: RwadBftTx): serial.RwadApplyResult =
    let shapeCode = RwadBftTxShapeCode(tx)
    if shapeCode != serial.RwadSerialCodeOk:
        var out = serial.RwadApplyResult()
        out.code = shapeCode
        out.appHash = serial.RwadStateMachineQueryAppHash(machine.ledger)
        return out
    if tx.kind == RwadBftTxKindMint:
        let mintTx = serial.RwadMintTxMake(tx.ownerId, tx.amount)
        return serial.RwadStateMachineApplyMintOrdered(machine.ledger,
                                                         context.height,
                                                         serial.RwadOrderKey(context.height, context.txIndex),
                                                         mintTx)
    let transferTx = serial.RwadTransferTxMake(tx.inputNoteId,
                                                 tx.fromOwner,
                                                 tx.toOwner,
                                                 tx.spendStart,
                                                 tx.spendEnd)
    return serial.RwadStateMachineApplyTransferOrdered(machine.ledger,
                                                         context.height,
                                                         serial.RwadOrderKey(context.height, context.txIndex),
                                                         transferTx)

fn RwadBftStateMachineCheckTx(machine: RwadBftStateMachine,
                                context: RwadBftBlockContext,
                                tx: RwadBftTx): RwadBftTxCheckResult =
    var preview = machine
    preview.ledger = serial.RwadCloneState(machine.ledger)
    let apply = RwadBftApplyTxOrdered(preview, context, tx)
    return RwadBftApplyResultIntoCheckResult(apply, context.height)

fn RwadBftStateMachineCheckTxBytes(machine: RwadBftStateMachine,
                                     context: RwadBftBlockContext,
                                     rawTx: Bytes): RwadBftTxCheckResult =
    let txRes = RwadBftDecodeTx(layout.byteSpanFromBytes(rawTx))
    if IsErr(txRes):
        var out = RwadBftTxCheckResult()
        out.code = Error(txRes) == " rwad_bft: bad version" ? RwadBftCodeBadVersion : RwadBftCodeDecodeError
        out.appHash = serial.RwadStateMachineQueryAppHash(machine.ledger)
        out.nextHeight = context.height
        return out
    return RwadBftStateMachineCheckTx(machine, context, Value(txRes))

fn RwadBftStateMachineFinalizeBlockSummary(machine: var RwadBftStateMachine,
                                             height: int64,
                                             txs: RwadBftTx[],
                                             summary: var RwadBftBlockSummary) =
    summary = RwadBftBlockSummaryZero(height)
    summary.txCount = txs.len
    var next = machine
    next.ledger = serial.RwadCloneState(machine.ledger)
    for i in 0..<txs.len:
        let context = RwadBftBlockContextMake(height, i, int64(0), layout.FixedBytes32())
        let apply = RwadBftApplyTxOrdered(next, context, txs[i])
        if apply.applied:
            summary.appliedCount = summary.appliedCount + 1
        else:
            summary.rejectedCount = summary.rejectedCount + 1
    machine = next
    let commit = serial.RwadStateMachineCommit(machine.ledger)
    summary.serialRoot = commit.serialRoot
    summary.nullifierRoot = commit.nullifierRoot
    summary.serialAccumulatorRoot = commit.serialAccumulatorRoot
    summary.nullifierAccumulatorRoot = commit.nullifierAccumulatorRoot
    summary.appHash = commit.appHash

fn RwadBftStateMachineFinalizeBlockBytesSummary(machine: var RwadBftStateMachine,
                                                  height: int64,
                                                  rawTxs: Bytes[],
                                                  summary: var RwadBftBlockSummary) =
    summary = RwadBftBlockSummaryZero(height)
    summary.txCount = rawTxs.len
    var txs: RwadBftTx[]
    txs = []
    for i in 0..<rawTxs.len:
        let txRes = RwadBftDecodeTx(layout.byteSpanFromBytes(rawTxs[i]))
        if IsErr(txRes):
            summary.rejectedCount = rawTxs.len
            summary.serialRoot = serial.RwadSerialRoot(machine.ledger)
            summary.nullifierRoot = serial.RwadNullifierRoot(machine.ledger)
            summary.serialAccumulatorRoot = serial.RwadSerialAccumulatorRoot(machine.ledger)
            summary.nullifierAccumulatorRoot = serial.RwadNullifierAccumulatorRoot(machine.ledger)
            summary.appHash = serial.RwadStateMachineQueryAppHash(machine.ledger)
            return
        add(txs, Value(txRes))
    RwadBftStateMachineFinalizeBlockSummary(machine, height, txs, summary)

fn RwadBftStateMachineQueryOwner(machine: RwadBftStateMachine,
                                   ownerId: layout.FixedBytes32): RwadBftOwnerQueryResult =
    let inner = serial.RwadStateMachineQueryOwner(machine.ledger, ownerId)
    var out: RwadBftOwnerQueryResult
    out.code = inner.code
    out.balance = inner.balance
    out.liveNoteCount = inner.liveNoteCount
    out.ownerRoot = inner.ownerRoot
    out.appHash = inner.appHash
    out.height = inner.height
    return out

fn RwadBftStateMachineQueryAppHash(machine: RwadBftStateMachine): layout.FixedBytes32 =
    return serial.RwadStateMachineQueryAppHash(machine.ledger)

fn RwadBftSelfTest(): int32 =
    let alice = serial.RwadOwnerIdFromText("alice")
    let bob = serial.RwadOwnerIdFromText("bob")
    var machine = RwadBftStateMachineInit("rwad-bft-self-test")

    let mint = RwadBftTxMint(alice, int64(100))
    let mintRaw = RwadBftEncodeTx(mint)
    let mintRoundtripRes = RwadBftDecodeTx(layout.byteSpanFromBytes(mintRaw))
    if IsErr(mintRoundtripRes):
        echo(" rwad_bft self-test: mint decode")
        return 1
    let mintCheck = RwadBftStateMachineCheckTx(machine,
                                                 RwadBftBlockContextMake(int64(1), 0, int64(0), layout.FixedBytes32()),
                                                 mint)
    if mintCheck.code != serial.RwadSerialCodeOk:
        echo(" rwad_bft self-test: mint check")
        return 1
    if machine.ledger.notes.len != 0:
        echo(" rwad_bft self-test: mint check mutated")
        return 1

    var block1: RwadBftTx[]
    block1 = []
    add(block1, mint)
    var summary1 = RwadBftBlockSummaryZero(int64(0))
    RwadBftStateMachineFinalizeBlockSummary(machine, int64(1), block1, summary1)
    if summary1.appliedCount != 1:
        echo(" rwad_bft self-test: block1 applied")
        return 1

    let transfer = RwadBftTxTransfer(int64(1), alice, bob, int64(21), int64(40))
    let transferRaw = RwadBftEncodeTx(transfer)
    let transferCheckBytes = RwadBftStateMachineCheckTxBytes(machine,
                                                               RwadBftBlockContextMake(int64(2), 0, int64(0), layout.FixedBytes32()),
                                                               transferRaw)
    if transferCheckBytes.code != serial.RwadSerialCodeOk:
        echo(" rwad_bft self-test: transfer check bytes")
        return 1
    let transferCheck = RwadBftStateMachineCheckTx(machine,
                                                     RwadBftBlockContextMake(int64(2), 0, int64(0), layout.FixedBytes32()),
                                                     transfer)
    if transferCheck.code != serial.RwadSerialCodeOk:
        echo(" rwad_bft self-test: transfer check")
        return 1

    var block2: RwadBftTx[]
    block2 = []
    add(block2, transfer)
    var summary2 = RwadBftBlockSummaryZero(int64(0))
    RwadBftStateMachineFinalizeBlockSummary(machine, int64(2), block2, summary2)
    if summary2.appliedCount != 1:
        echo(" rwad_bft self-test: block2 applied")
        return 1

    let aliceQuery = RwadBftStateMachineQueryOwner(machine, alice)
    let bobQuery = RwadBftStateMachineQueryOwner(machine, bob)
    if aliceQuery.balance != int64(80):
        echo(" rwad_bft self-test: alice balance")
        return 1
    if bobQuery.balance != int64(20):
        echo(" rwad_bft self-test: bob balance")
        return 1
    if layout.fixedBytes32Equal(summary2.serialRoot, layout.FixedBytes32()):
        echo(" rwad_bft self-test: serial root")
        return 1
    if !layout.fixedBytes32Equal(summary2.appHash, RwadBftStateMachineQueryAppHash(machine)):
        echo(" rwad_bft self-test: app hash")
        return 1

    var bytesMachine = RwadBftStateMachineInit("rwad-bft-self-test-bytes")
    var rawBlock1: Bytes[]
    rawBlock1 = []
    add(rawBlock1, mintRaw)
    var rawBlock1Summary = RwadBftBlockSummaryZero(int64(0))
    RwadBftStateMachineFinalizeBlockBytesSummary(bytesMachine, int64(1), rawBlock1, rawBlock1Summary)
    if rawBlock1Summary.appliedCount != 1:
        echo(" rwad_bft self-test: raw block1")
        return 1
    var rawBlock2: Bytes[]
    rawBlock2 = []
    add(rawBlock2, transferRaw)
    var rawBlock2Summary = RwadBftBlockSummaryZero(int64(0))
    RwadBftStateMachineFinalizeBlockBytesSummary(bytesMachine, int64(2), rawBlock2, rawBlock2Summary)
    if rawBlock2Summary.appliedCount != 1:
        echo(" rwad_bft self-test: raw block2")
        return 1

    var stale: RwadBftTx[]
    stale = []
    add(stale, transfer)
    var staleSummary = RwadBftBlockSummaryZero(int64(0))
    RwadBftStateMachineFinalizeBlockSummary(machine, int64(2), stale, staleSummary)
    if staleSummary.rejectedCount != 1:
        echo(" rwad_bft self-test: stale rejected")
        return 1

    echo(" rwad_bft_state_machine ok")
    return 0
