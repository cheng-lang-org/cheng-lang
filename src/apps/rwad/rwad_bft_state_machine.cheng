import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/apps/rwad/rwad_serial_state_machine as serial

const
    v3RwadBftVersion: int32 = 1
    v3RwadBftTxKindMint: int32 = 1
    v3RwadBftTxKindTransfer: int32 = 2
    v3RwadBftTxWireSize: int32 = 144
    v3RwadBftCodeDecodeError: int32 = 100
    v3RwadBftCodeBadVersion: int32 = 101
    v3RwadBftCodeBadKind: int32 = 102

type
    V3RwadBftTx =
        kind: int32
        ownerId: layout.FixedBytes32
        amount: int64
        inputNoteId: int64
        fromOwner: layout.FixedBytes32
        toOwner: layout.FixedBytes32
        spendStart: int64
        spendEnd: int64

    V3RwadBftBlockContext =
        height: int64
        txIndex: int32
        timeHint: int64
        proposerHint: layout.FixedBytes32

    V3RwadBftTxCheckResult =
        code: int32
        accepted: bool
        applied: bool
        spentNullifier: layout.FixedBytes32
        primaryNoteId: int64
        secondaryNoteId: int64
        tertiaryNoteId: int64
        appHash: layout.FixedBytes32
        nextHeight: int64

    V3RwadBftBlockSummary =
        height: int64
        txCount: int32
        appliedCount: int32
        rejectedCount: int32
        serialRoot: layout.FixedBytes32
        nullifierRoot: layout.FixedBytes32
        serialAccumulatorRoot: layout.FixedBytes32
        nullifierAccumulatorRoot: layout.FixedBytes32
        appHash: layout.FixedBytes32

    V3RwadBftOwnerQueryResult =
        code: int32
        balance: int64
        liveNoteCount: int32
        ownerRoot: layout.FixedBytes32
        appHash: layout.FixedBytes32
        height: int64

    V3RwadBftStateMachine =
        ledger: serial.V3RwadStateMachine

fn v3RwadBftStateMachineInit(appId: str): V3RwadBftStateMachine =
    var out: V3RwadBftStateMachine
    out.ledger = serial.v3RwadStateMachineInit(appId)
    return out

fn v3RwadBftAppendU32BE(buf: var layout.ByteBuf, value: int64) =
    lt.v3AppendU32BE(buf, value)

fn v3RwadBftAppendI64BE(buf: var layout.ByteBuf, value: int64) =
    v3RwadBftAppendU32BE(buf, int32((value >> 32) & int64(0xffffffff)))
    v3RwadBftAppendU32BE(buf, int32(value & int64(0xffffffff)))

fn v3RwadBftReadU32BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    if offset < 0 || offset + 4 > layout.byteSpanLen(span):
        return Err[int64]("v3 rwad_bft: short u32")
    let b0: int64 = int64(layout.byteSpanAt(span, offset))
    let b1: int64 = int64(layout.byteSpanAt(span, offset + 1))
    let b2: int64 = int64(layout.byteSpanAt(span, offset + 2))
    let b3: int64 = int64(layout.byteSpanAt(span, offset + 3))
    return Ok[int64]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn v3RwadBftReadI64BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    let hiRes = v3RwadBftReadU32BE(span, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = v3RwadBftReadU32BE(span, offset + 4)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    let hi = int32(Value(hiRes))
    let lo = Value(loRes)
    return Ok[int64]((int64(hi) << 32) | (lo & int64(0xffffffff)))

fn v3RwadBftReadFixed32(span: layout.ByteSpan, offset: int32): Result[layout.FixedBytes32] =
    if offset < 0 || offset + layout.fixedBytes32Size > layout.byteSpanLen(span):
        return Err[layout.FixedBytes32]("v3 rwad_bft: short fixed32")
    let bytes = layout.byteSpanToBytes(layout.byteSpanSlice(span, offset, layout.fixedBytes32Size))
    return layout.fixedBytes32FromBytes(bytes)

fn v3RwadBftTxMint(ownerId: layout.FixedBytes32, amount: int64): V3RwadBftTx =
    var out: V3RwadBftTx
    out.kind = v3RwadBftTxKindMint
    out.ownerId = ownerId
    out.amount = amount
    out.inputNoteId = int64(0)
    out.fromOwner = layout.FixedBytes32()
    out.toOwner = layout.FixedBytes32()
    out.spendStart = int64(0)
    out.spendEnd = int64(0)
    return out

fn v3RwadBftTxTransfer(inputNoteId: int64,
                       fromOwner: layout.FixedBytes32,
                       toOwner: layout.FixedBytes32,
                       spendStart: int64,
                       spendEnd: int64): V3RwadBftTx =
    var out: V3RwadBftTx
    out.kind = v3RwadBftTxKindTransfer
    out.ownerId = layout.FixedBytes32()
    out.amount = int64(0)
    out.inputNoteId = inputNoteId
    out.fromOwner = fromOwner
    out.toOwner = toOwner
    out.spendStart = spendStart
    out.spendEnd = spendEnd
    return out

fn v3RwadBftTxShapeCode(tx: V3RwadBftTx): int32 =
    if tx.kind == v3RwadBftTxKindMint:
        if serial.v3RwadOwnerZero(tx.ownerId):
            return serial.v3RwadSerialCodeBadOwner
        if tx.amount <= int64(0):
            return serial.v3RwadSerialCodeBadAmount
        return serial.v3RwadSerialCodeOk
    if tx.kind == v3RwadBftTxKindTransfer:
        if tx.inputNoteId <= int64(0):
            return serial.v3RwadSerialCodeBadNote
        if serial.v3RwadOwnerZero(tx.fromOwner):
            return serial.v3RwadSerialCodeBadOwner
        if serial.v3RwadOwnerZero(tx.toOwner):
            return serial.v3RwadSerialCodeBadTarget
        if tx.spendStart > tx.spendEnd:
            return serial.v3RwadSerialCodeBadRange
        return serial.v3RwadSerialCodeOk
    return v3RwadBftCodeBadKind

fn v3RwadBftEncodeTx(tx: V3RwadBftTx): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(v3RwadBftTxWireSize)
    v3RwadBftAppendU32BE(buf, v3RwadBftVersion)
    v3RwadBftAppendU32BE(buf, tx.kind)
    v3RwadBftAppendU32BE(buf, 0)
    v3RwadBftAppendU32BE(buf, 0)
    lt.v3AppendFixed32(buf, tx.ownerId)
    v3RwadBftAppendI64BE(buf, tx.amount)
    v3RwadBftAppendI64BE(buf, tx.inputNoteId)
    lt.v3AppendFixed32(buf, tx.fromOwner)
    lt.v3AppendFixed32(buf, tx.toOwner)
    v3RwadBftAppendI64BE(buf, tx.spendStart)
    v3RwadBftAppendI64BE(buf, tx.spendEnd)
    return layout.byteBufToBytes(buf)

fn v3RwadBftDecodeTx(data: layout.ByteSpan): Result[V3RwadBftTx] =
    if layout.byteSpanLen(data) != v3RwadBftTxWireSize:
        return Err[V3RwadBftTx]("v3 rwad_bft: bad tx size")
    let versionRes = v3RwadBftReadU32BE(data, 0)
    if IsErr(versionRes):
        return Err[V3RwadBftTx](Error(versionRes))
    if int32(Value(versionRes)) != v3RwadBftVersion:
        return Err[V3RwadBftTx]("v3 rwad_bft: bad version")
    let kindRes = v3RwadBftReadU32BE(data, 4)
    if IsErr(kindRes):
        return Err[V3RwadBftTx](Error(kindRes))
    let ownerRes = v3RwadBftReadFixed32(data, 16)
    if IsErr(ownerRes):
        return Err[V3RwadBftTx](Error(ownerRes))
    let amountRes = v3RwadBftReadI64BE(data, 48)
    if IsErr(amountRes):
        return Err[V3RwadBftTx](Error(amountRes))
    let inputNoteIdRes = v3RwadBftReadI64BE(data, 56)
    if IsErr(inputNoteIdRes):
        return Err[V3RwadBftTx](Error(inputNoteIdRes))
    let fromOwnerRes = v3RwadBftReadFixed32(data, 64)
    if IsErr(fromOwnerRes):
        return Err[V3RwadBftTx](Error(fromOwnerRes))
    let toOwnerRes = v3RwadBftReadFixed32(data, 96)
    if IsErr(toOwnerRes):
        return Err[V3RwadBftTx](Error(toOwnerRes))
    let spendStartRes = v3RwadBftReadI64BE(data, 128)
    if IsErr(spendStartRes):
        return Err[V3RwadBftTx](Error(spendStartRes))
    let spendEndRes = v3RwadBftReadI64BE(data, 136)
    if IsErr(spendEndRes):
        return Err[V3RwadBftTx](Error(spendEndRes))
    var out: V3RwadBftTx
    out.kind = int32(Value(kindRes))
    out.ownerId = Value(ownerRes)
    out.amount = Value(amountRes)
    out.inputNoteId = Value(inputNoteIdRes)
    out.fromOwner = Value(fromOwnerRes)
    out.toOwner = Value(toOwnerRes)
    out.spendStart = Value(spendStartRes)
    out.spendEnd = Value(spendEndRes)
    return Ok[V3RwadBftTx](out)

fn v3RwadBftBlockContextMake(height: int64,
                             txIndex: int32,
                             timeHint: int64,
                             proposerHint: layout.FixedBytes32): V3RwadBftBlockContext =
    var out: V3RwadBftBlockContext
    out.height = height
    out.txIndex = txIndex
    out.timeHint = timeHint
    out.proposerHint = proposerHint
    return out

fn v3RwadBftBlockSummaryZero(height: int64): V3RwadBftBlockSummary =
    var out: V3RwadBftBlockSummary
    out.height = height
    out.txCount = 0
    out.appliedCount = 0
    out.rejectedCount = 0
    out.serialRoot = layout.FixedBytes32()
    out.nullifierRoot = layout.FixedBytes32()
    out.serialAccumulatorRoot = layout.FixedBytes32()
    out.nullifierAccumulatorRoot = layout.FixedBytes32()
    out.appHash = layout.FixedBytes32()
    return out

fn v3RwadBftApplyResultIntoCheckResult(apply: serial.V3RwadApplyResult,
                                       height: int64): V3RwadBftTxCheckResult =
    var out = V3RwadBftTxCheckResult()
    out.code = apply.code
    out.accepted = apply.accepted
    out.applied = apply.applied
    out.spentNullifier = apply.spentNullifier
    out.primaryNoteId = apply.primaryNoteId
    out.secondaryNoteId = apply.secondaryNoteId
    out.tertiaryNoteId = apply.tertiaryNoteId
    out.appHash = apply.appHash
    out.nextHeight = height
    return out

fn v3RwadBftApplyTxOrdered(machine: var V3RwadBftStateMachine,
                           context: V3RwadBftBlockContext,
                           tx: V3RwadBftTx): serial.V3RwadApplyResult =
    let shapeCode = v3RwadBftTxShapeCode(tx)
    if shapeCode != serial.v3RwadSerialCodeOk:
        var out = serial.V3RwadApplyResult()
        out.code = shapeCode
        out.appHash = serial.v3RwadStateMachineQueryAppHash(machine.ledger)
        return out
    if tx.kind == v3RwadBftTxKindMint:
        let mintTx = serial.v3RwadMintTxMake(tx.ownerId, tx.amount)
        return serial.v3RwadStateMachineApplyMintOrdered(machine.ledger,
                                                         context.height,
                                                         serial.v3RwadOrderKey(context.height, context.txIndex),
                                                         mintTx)
    let transferTx = serial.v3RwadTransferTxMake(tx.inputNoteId,
                                                 tx.fromOwner,
                                                 tx.toOwner,
                                                 tx.spendStart,
                                                 tx.spendEnd)
    return serial.v3RwadStateMachineApplyTransferOrdered(machine.ledger,
                                                         context.height,
                                                         serial.v3RwadOrderKey(context.height, context.txIndex),
                                                         transferTx)

fn v3RwadBftStateMachineCheckTx(machine: V3RwadBftStateMachine,
                                context: V3RwadBftBlockContext,
                                tx: V3RwadBftTx): V3RwadBftTxCheckResult =
    var preview = machine
    preview.ledger = serial.v3RwadCloneState(machine.ledger)
    let apply = v3RwadBftApplyTxOrdered(preview, context, tx)
    return v3RwadBftApplyResultIntoCheckResult(apply, context.height)

fn v3RwadBftStateMachineCheckTxBytes(machine: V3RwadBftStateMachine,
                                     context: V3RwadBftBlockContext,
                                     rawTx: Bytes): V3RwadBftTxCheckResult =
    let txRes = v3RwadBftDecodeTx(layout.byteSpanFromBytes(rawTx))
    if IsErr(txRes):
        var out = V3RwadBftTxCheckResult()
        out.code = Error(txRes) == "v3 rwad_bft: bad version" ? v3RwadBftCodeBadVersion : v3RwadBftCodeDecodeError
        out.appHash = serial.v3RwadStateMachineQueryAppHash(machine.ledger)
        out.nextHeight = context.height
        return out
    return v3RwadBftStateMachineCheckTx(machine, context, Value(txRes))

fn v3RwadBftStateMachineFinalizeBlockSummary(machine: var V3RwadBftStateMachine,
                                             height: int64,
                                             txs: V3RwadBftTx[],
                                             summary: var V3RwadBftBlockSummary) =
    summary = v3RwadBftBlockSummaryZero(height)
    summary.txCount = txs.len
    var next = machine
    next.ledger = serial.v3RwadCloneState(machine.ledger)
    for i in 0..<txs.len:
        let context = v3RwadBftBlockContextMake(height, i, int64(0), layout.FixedBytes32())
        let apply = v3RwadBftApplyTxOrdered(next, context, txs[i])
        if apply.applied:
            summary.appliedCount = summary.appliedCount + 1
        else:
            summary.rejectedCount = summary.rejectedCount + 1
    machine = next
    let commit = serial.v3RwadStateMachineCommit(machine.ledger)
    summary.serialRoot = commit.serialRoot
    summary.nullifierRoot = commit.nullifierRoot
    summary.serialAccumulatorRoot = commit.serialAccumulatorRoot
    summary.nullifierAccumulatorRoot = commit.nullifierAccumulatorRoot
    summary.appHash = commit.appHash

fn v3RwadBftStateMachineFinalizeBlockBytesSummary(machine: var V3RwadBftStateMachine,
                                                  height: int64,
                                                  rawTxs: Bytes[],
                                                  summary: var V3RwadBftBlockSummary) =
    summary = v3RwadBftBlockSummaryZero(height)
    summary.txCount = rawTxs.len
    var txs: V3RwadBftTx[]
    txs = []
    for i in 0..<rawTxs.len:
        let txRes = v3RwadBftDecodeTx(layout.byteSpanFromBytes(rawTxs[i]))
        if IsErr(txRes):
            summary.rejectedCount = rawTxs.len
            summary.serialRoot = serial.v3RwadSerialRoot(machine.ledger)
            summary.nullifierRoot = serial.v3RwadNullifierRoot(machine.ledger)
            summary.serialAccumulatorRoot = serial.v3RwadSerialAccumulatorRoot(machine.ledger)
            summary.nullifierAccumulatorRoot = serial.v3RwadNullifierAccumulatorRoot(machine.ledger)
            summary.appHash = serial.v3RwadStateMachineQueryAppHash(machine.ledger)
            return
        add(txs, Value(txRes))
    v3RwadBftStateMachineFinalizeBlockSummary(machine, height, txs, summary)

fn v3RwadBftStateMachineQueryOwner(machine: V3RwadBftStateMachine,
                                   ownerId: layout.FixedBytes32): V3RwadBftOwnerQueryResult =
    let inner = serial.v3RwadStateMachineQueryOwner(machine.ledger, ownerId)
    var out: V3RwadBftOwnerQueryResult
    out.code = inner.code
    out.balance = inner.balance
    out.liveNoteCount = inner.liveNoteCount
    out.ownerRoot = inner.ownerRoot
    out.appHash = inner.appHash
    out.height = inner.height
    return out

fn v3RwadBftStateMachineQueryAppHash(machine: V3RwadBftStateMachine): layout.FixedBytes32 =
    return serial.v3RwadStateMachineQueryAppHash(machine.ledger)

fn v3RwadBftSelfTest(): int32 =
    let alice = serial.v3RwadOwnerIdFromText("alice")
    let bob = serial.v3RwadOwnerIdFromText("bob")
    var machine = v3RwadBftStateMachineInit("rwad-bft-self-test")

    let mint = v3RwadBftTxMint(alice, int64(100))
    let mintRaw = v3RwadBftEncodeTx(mint)
    let mintRoundtripRes = v3RwadBftDecodeTx(layout.byteSpanFromBytes(mintRaw))
    if IsErr(mintRoundtripRes):
        echo("v3 rwad_bft self-test: mint decode")
        return 1
    let mintCheck = v3RwadBftStateMachineCheckTx(machine,
                                                 v3RwadBftBlockContextMake(int64(1), 0, int64(0), layout.FixedBytes32()),
                                                 mint)
    if mintCheck.code != serial.v3RwadSerialCodeOk:
        echo("v3 rwad_bft self-test: mint check")
        return 1
    if machine.ledger.notes.len != 0:
        echo("v3 rwad_bft self-test: mint check mutated")
        return 1

    var block1: V3RwadBftTx[]
    block1 = []
    add(block1, mint)
    var summary1 = v3RwadBftBlockSummaryZero(int64(0))
    v3RwadBftStateMachineFinalizeBlockSummary(machine, int64(1), block1, summary1)
    if summary1.appliedCount != 1:
        echo("v3 rwad_bft self-test: block1 applied")
        return 1

    let transfer = v3RwadBftTxTransfer(int64(1), alice, bob, int64(21), int64(40))
    let transferRaw = v3RwadBftEncodeTx(transfer)
    let transferCheckBytes = v3RwadBftStateMachineCheckTxBytes(machine,
                                                               v3RwadBftBlockContextMake(int64(2), 0, int64(0), layout.FixedBytes32()),
                                                               transferRaw)
    if transferCheckBytes.code != serial.v3RwadSerialCodeOk:
        echo("v3 rwad_bft self-test: transfer check bytes")
        return 1
    let transferCheck = v3RwadBftStateMachineCheckTx(machine,
                                                     v3RwadBftBlockContextMake(int64(2), 0, int64(0), layout.FixedBytes32()),
                                                     transfer)
    if transferCheck.code != serial.v3RwadSerialCodeOk:
        echo("v3 rwad_bft self-test: transfer check")
        return 1

    var block2: V3RwadBftTx[]
    block2 = []
    add(block2, transfer)
    var summary2 = v3RwadBftBlockSummaryZero(int64(0))
    v3RwadBftStateMachineFinalizeBlockSummary(machine, int64(2), block2, summary2)
    if summary2.appliedCount != 1:
        echo("v3 rwad_bft self-test: block2 applied")
        return 1

    let aliceQuery = v3RwadBftStateMachineQueryOwner(machine, alice)
    let bobQuery = v3RwadBftStateMachineQueryOwner(machine, bob)
    if aliceQuery.balance != int64(80):
        echo("v3 rwad_bft self-test: alice balance")
        return 1
    if bobQuery.balance != int64(20):
        echo("v3 rwad_bft self-test: bob balance")
        return 1
    if layout.fixedBytes32Equal(summary2.serialRoot, layout.FixedBytes32()):
        echo("v3 rwad_bft self-test: serial root")
        return 1
    if !layout.fixedBytes32Equal(summary2.appHash, v3RwadBftStateMachineQueryAppHash(machine)):
        echo("v3 rwad_bft self-test: app hash")
        return 1

    var bytesMachine = v3RwadBftStateMachineInit("rwad-bft-self-test-bytes")
    var rawBlock1: Bytes[]
    rawBlock1 = []
    add(rawBlock1, mintRaw)
    var rawBlock1Summary = v3RwadBftBlockSummaryZero(int64(0))
    v3RwadBftStateMachineFinalizeBlockBytesSummary(bytesMachine, int64(1), rawBlock1, rawBlock1Summary)
    if rawBlock1Summary.appliedCount != 1:
        echo("v3 rwad_bft self-test: raw block1")
        return 1
    var rawBlock2: Bytes[]
    rawBlock2 = []
    add(rawBlock2, transferRaw)
    var rawBlock2Summary = v3RwadBftBlockSummaryZero(int64(0))
    v3RwadBftStateMachineFinalizeBlockBytesSummary(bytesMachine, int64(2), rawBlock2, rawBlock2Summary)
    if rawBlock2Summary.appliedCount != 1:
        echo("v3 rwad_bft self-test: raw block2")
        return 1

    var stale: V3RwadBftTx[]
    stale = []
    add(stale, transfer)
    var staleSummary = v3RwadBftBlockSummaryZero(int64(0))
    v3RwadBftStateMachineFinalizeBlockSummary(machine, int64(2), stale, staleSummary)
    if staleSummary.rejectedCount != 1:
        echo("v3 rwad_bft self-test: stale rejected")
        return 1

    echo("v3 rwad_bft_state_machine ok")
    return 0
