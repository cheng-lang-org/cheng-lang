import std/cmdline as cmdline
import std/result
import std/strings as strings
import cheng/apps/wow_export/asset_export as asset_export
import cheng/apps/wow_export/manifest/northshire_retail_12_0_5 as northshire

fn readOutDir(): str =
    let count: int32 = cmdline.ParamCount()
    var i: int32 = 1
    while i <= count:
        let arg: str = cmdline.ParamStr(i)
        if arg == "--out-dir":
            if i < count:
                return cmdline.ParamStr(i + 1)
            return ""
        if strings.HasPrefix(arg, "--out-dir="):
            return strings.SliceBytes(arg, 10, strings.Len(arg) - 10)
        if strings.HasPrefix(arg, "--out-dir:"):
            return strings.SliceBytes(arg, 10, strings.Len(arg) - 10)
        i = i + 1
    return ""

fn main(argc: int32, argv: ptr): int32 =
    cmdline.CaptureCmdLine(argc, argv)
    let outDir: str = readOutDir()
    if strings.Len(outDir) == 0:
        echo("wowExport placement export: missing --out-dir")
        return 1
    let exportRes: Result[asset_export.AssetExportPlacementDependencyBundleSummary] =
        asset_export.ExportNorthshirePlacementDependenciesBundle(northshire.Manifest(), outDir)
    if IsErr(exportRes):
        echo(Error(exportRes))
        return 1
    echo(asset_export.AssetExportPlacementDependencyBundleSummaryText(Value(exportRes)))
    return 0
