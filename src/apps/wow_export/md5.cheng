import std/bytes as bytes
import std/rawbytes

fn u32(x: int64): int64 =
    return x & int64(0xffffffff)

fn rotl32(x: int64, n: int32): int64 =
    let v: int64 = u32(x)
    return u32((v << n) | (v >> (32 - n)))

fn getU32LE(data: rawbytes.Bytes, offset: int32): int64 =
    let b0: int64 = int64(rawbytes.BytesGet(data, offset))
    let b1: int64 = int64(rawbytes.BytesGet(data, offset + 1))
    let b2: int64 = int64(rawbytes.BytesGet(data, offset + 2))
    let b3: int64 = int64(rawbytes.BytesGet(data, offset + 3))
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn setU32LE(data: var rawbytes.Bytes, offset: int32, value: int64) =
    let v: int64 = u32(value)
    rawbytes.BytesSet(data, offset, int32(v & 255))
    rawbytes.BytesSet(data, offset + 1, int32((v >> 8) & 255))
    rawbytes.BytesSet(data, offset + 2, int32((v >> 16) & 255))
    rawbytes.BytesSet(data, offset + 3, int32((v >> 24) & 255))

fn md5K(i: int32): int64 =
    case i
    of 0: return int64(0xd76aa478)
    of 1: return int64(0xe8c7b756)
    of 2: return int64(0x242070db)
    of 3: return int64(0xc1bdceee)
    of 4: return int64(0xf57c0faf)
    of 5: return int64(0x4787c62a)
