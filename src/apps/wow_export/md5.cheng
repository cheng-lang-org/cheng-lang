    of 7: return int64(0xfd469501)
    of 8: return int64(0x698098d8)
    of 9: return int64(0x8b44f7af)
    of 10: return int64(0xffff5bb1)
    of 11: return int64(0x895cd7be)
    of 12: return int64(0x6b901122)
    of 13: return int64(0xfd987193)
    of 14: return int64(0xa679438e)
    of 15: return int64(0x49b40821)
    of 16: return int64(0xf61e2562)
    of 17: return int64(0xc040b340)
    of 18: return int64(0x265e5a51)
    of 19: return int64(0xe9b6c7aa)
    of 20: return int64(0xd62f105d)
    of 21: return int64(0x02441453)
    of 22: return int64(0xd8a1e681)
    of 23: return int64(0xe7d3fbc8)
    of 24: return int64(0x21e1cde6)
    of 25: return int64(0xc33707d6)
    of 26: return int64(0xf4d50d87)
    of 27: return int64(0x455a14ed)
    of 28: return int64(0xa9e3e905)
    of 29: return int64(0xfcefa3f8)
    of 30: return int64(0x676f02d9)
    of 31: return int64(0x8d2a4c8a)
    of 32: return int64(0xfffa3942)
    of 33: return int64(0x8771f681)
    of 34: return int64(0x6d9d6122)
    of 35: return int64(0xfde5380c)
    of 36: return int64(0xa4beea44)
    of 37: return int64(0x4bdecfa9)
    of 38: return int64(0xf6bb4b60)
    of 39: return int64(0xbebfbc70)
    of 40: return int64(0x289b7ec6)
    of 41: return int64(0xeaa127fa)
    of 42: return int64(0xd4ef3085)
    of 43: return int64(0x04881d05)
    of 44: return int64(0xd9d4d039)
    of 45: return int64(0xe6db99e5)
    of 46: return int64(0x1fa27cf8)
    of 47: return int64(0xc4ac5665)
    of 48: return int64(0xf4292244)
    of 49: return int64(0x432aff97)
    of 50: return int64(0xab9423a7)
    of 51: return int64(0xfc93a039)
    of 52: return int64(0x655b59c3)
    of 53: return int64(0x8f0ccc92)
    of 54: return int64(0xffeff47d)
    of 55: return int64(0x85845dd1)
    of 56: return int64(0x6fa87e4f)
    of 57: return int64(0xfe2ce6e0)
    of 58: return int64(0xa3014314)
    of 59: return int64(0x4e0811a1)
    of 60: return int64(0xf7537e82)
    of 61: return int64(0xbd3af235)
    of 62: return int64(0x2ad7d2bb)
    of 63: return int64(0xeb86d391)
    else: return int64(0)

fn md5Shift(i: int32): int32 =
    case i
    of 0: return 7
    of 1: return 12
    of 2: return 17
    of 3: return 22
    of 4: return 7
    of 5: return 12
    of 6: return 17
    of 7: return 22
    of 8: return 7
    of 9: return 12
    of 10: return 17
    of 11: return 22
    of 12: return 7
    of 13: return 12
    of 14: return 17
    of 15: return 22
    of 16: return 5
    of 17: return 9
    of 18: return 14
    of 19: return 20
    of 20: return 5
    of 21: return 9
    of 22: return 14
    of 23: return 20
    of 24: return 5
    of 25: return 9
    of 26: return 14
    of 27: return 20
    of 28: return 5
    of 29: return 9
    of 30: return 14
    of 31: return 20
    of 32: return 4
    of 33: return 11
    of 34: return 16
    of 35: return 23
    of 36: return 4
    of 37: return 11
    of 38: return 16
    of 39: return 23
    of 40: return 4
    of 41: return 11
    of 42: return 16
    of 43: return 23
    of 44: return 4
    of 45: return 11
    of 46: return 16
    of 47: return 23
    of 48: return 6
    of 49: return 10
    of 50: return 15
    of 51: return 21
    of 52: return 6
    of 53: return 10
    of 54: return 15
    of 55: return 21
    of 56: return 6
    of 57: return 10
    of 58: return 15
    of 59: return 21
    of 60: return 6
    of 61: return 10
    of 62: return 15
    else: return 21

fn md5RoundF(i: int32, b: int64, c: int64, d: int64): int64 =
    let mask: int64 = int64(0xffffffff)
    let bu: int64 = u32(b)
    let cu: int64 = u32(c)
    let du: int64 = u32(d)
    if i < 16:
        return u32((bu & cu) | ((bu ^ mask) & du))
    if i < 32:
        return u32((du & bu) | ((du ^ mask) & cu))
    if i < 48:
        return u32(bu ^ cu ^ du)
    return u32(cu ^ (bu | (du ^ mask)))

fn md5WordIndex(i: int32): int32 =
    if i < 16:
        return i
    if i < 32:
        return (5 * i + 1) % 16
    if i < 48:
        return (3 * i + 5) % 16
    return (7 * i) % 16

fn Md5Digest(data: rawbytes.Bytes): rawbytes.Bytes =
    var a0: int64 = int64(0x67452301)
    var b0: int64 = int64(0xefcdab89)
    var c0: int64 = int64(0x98badcfe)
    var d0: int64 = int64(0x10325476)

    let inputLen: int32 = rawbytes.BytesLen(data)
    var padZero: int32
    while ((inputLen + 1 + padZero) % 64) != 56:
        padZero = padZero + 1
    let totalLen: int32 = inputLen + 1 + padZero + 8
    var msg: rawbytes.Bytes = rawbytes.BytesAlloc(totalLen)
    if inputLen > 0:
        rawbytes.BytesCopyInto(msg, 0, data)
    rawbytes.BytesSet(msg, inputLen, 0x80)
    var bitLen: int64 = int64(inputLen) * int64(8)
    var lenIdx: int32
    for lenIdx in lenIdx..<8:
        rawbytes.BytesSet(msg, totalLen - 8 + lenIdx, int32(bitLen & 255))
        bitLen = bitLen >> 8

    var offset: int32
    while offset < totalLen:
        var a: int64 = a0
        var b: int64 = b0
        var c: int64 = c0
        var d: int64 = d0
        var i: int32
        for i in i..<64:
            let f: int64 = md5RoundF(i, b, c, d)
            let g: int32 = md5WordIndex(i)
            let word: int64 = getU32LE(msg, offset + g * 4)
            let sum: int64 = u32(a + f + md5K(i) + word)
            let rotated: int64 = rotl32(sum, md5Shift(i))
            let nextB: int64 = u32(b + rotated)
            a = d
            d = c
            c = b
            b = nextB
        a0 = u32(a0 + a)
        b0 = u32(b0 + b)
        c0 = u32(c0 + c)
        d0 = u32(d0 + d)
        offset = offset + 64

    var out: rawbytes.Bytes = rawbytes.BytesAlloc(16)
    setU32LE(out, 0, a0)
    setU32LE(out, 4, b0)
    setU32LE(out, 8, c0)
    setU32LE(out, 12, d0)
    rawbytes.BytesFree(msg)
    return out

fn Md5Hex(data: rawbytes.Bytes): str =
    var digest: rawbytes.Bytes = Md5Digest(data)
    let out: str = rawbytes.BytesToHex(digest)
    rawbytes.BytesFree(digest)
    return out

fn Md5StringHex(text: str): str =
    let bytes: rawbytes.Bytes = rawbytes.BytesFromString(text)
    let out: str = Md5Hex(bytes)
    rawbytes.BytesFree(bytes)
    return out

fn Md5ByteBufferSliceHex(buf: bytes.ByteBuffer, start: int32, count: int32): str =
    if start < 0 || count < 0:
        return ""
    if start + count > buf.len:
        return ""
    if count <= 0:
        return Md5Hex(rawbytes.EmptyBytes())
    var slice: rawbytes.Bytes = rawbytes.BytesAlloc(count)
    var i: int32
    for i in i..<count:
        rawbytes.BytesSet(slice, i, bytes.BufByteAt(buf, start + i))
    let out: str = Md5Hex(slice)
    rawbytes.BytesFree(slice)
    return out

fn Md5ByteBufferHex(buf: bytes.ByteBuffer): str =
    return Md5ByteBufferSliceHex(buf, 0, buf.len)
