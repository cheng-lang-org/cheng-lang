import std/bytes as bytes
import std/result
import std/seqs
import std/strings as strings
import std/strformat
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/casc_index as casc_index
import cheng/apps/wow_export/local_files as local_files
import cheng/apps/wow_export/md5 as md5

type
    NorthshireAuditedFile =
        label: str
        kind: str
        path: str
        fileDataID: int32
        contentKey: str
        encodingKey: str
        archiveIndex: int32
        offset: int32
        size: int32

    NorthshireAuditedDependency =
        label: str
        sourceLabel: str
        relationKind: str
        fileDataID: int32
        contentKey: str
        encodingKey: str
        archiveIndex: int32
        offset: int32
        size: int32

    NorthshireManifest =
        product: str
        version: str
        buildKey: str
        locale: str
        clientPath: str
        auditedFileCount: int32
        auditedFiles: NorthshireAuditedFile[]
        auditedDependencyCount: int32
        auditedDependencies: NorthshireAuditedDependency[]

    NorthshireAuditSummary =
        matchedFileCount: int32
        matchedDependencyCount: int32

fn northshireAddWmoModiDependency(out: var NorthshireManifest,
                                  label: str,
                                  fileDataID: int32,
                                  contentKey: str,
                                  encodingKey: str,
                                  archiveIndex: int32,
                                  offset: int32,
                                  size: int32) =
    add(out.auditedDependencies,
        NorthshireAuditedDependency(label: label,
                                    sourceLabel: "northshire-abbey-wmo",
                                    relationKind: "wmo_modi",
                                    fileDataID: fileDataID,
                                    contentKey: contentKey,
                                    encodingKey: encodingKey,
                                    archiveIndex: archiveIndex,
                                    offset: offset,
                                    size: size))

