fn ManifestReady(m: NorthshireManifest): bool =
    if m.auditedFileCount <= 0 || m.auditedFiles.len != m.auditedFileCount:
        return false
    if m.auditedDependencies.len != m.auditedDependencyCount:
        return false
    var i: int32
    for i in i..<m.auditedFiles.len:
        let file: NorthshireAuditedFile = m.auditedFiles[i]
        if file.fileDataID <= 0:
            return false
        if strings.Len(file.path) == 0 || strings.Len(file.kind) == 0:
            return false
        if strings.Len(file.contentKey) != 32 || strings.Len(file.encodingKey) != 32:
            return false
        if file.archiveIndex < 0 || file.offset < 0 || file.size <= 0:
            return false
    i = 0
    for i in i..<m.auditedDependencies.len:
        let dep: NorthshireAuditedDependency = m.auditedDependencies[i]
        if strings.Len(dep.label) == 0 ||
            strings.Len(dep.sourceLabel) == 0 ||
            strings.Len(dep.relationKind) == 0:
            return false
        if dep.fileDataID <= 0:
            return false
        if strings.Len(dep.formatKind) == 0:
            return false
        if strings.Len(dep.contentKey) != 32 || strings.Len(dep.encodingKey) != 32:
            return false
        if dep.archiveIndex < 0 || dep.offset < 0 || dep.size <= 0:
            return false
    return true

fn northshireManifestFileDataIDs(m: NorthshireManifest): int32[] =
    var out: int32[]
    var i: int32
    for i in i..<m.auditedFiles.len:
        add(out, m.auditedFiles[i].fileDataID)
    return out

fn CountDependenciesForSource(m: NorthshireManifest,
                              sourceLabel: str,
                              relationKind: str): int32 =
    var out: int32
    var i: int32
    for i in i..<m.auditedDependencies.len:
        let dep: NorthshireAuditedDependency = m.auditedDependencies[i]
        if dep.sourceLabel == sourceLabel && dep.relationKind == relationKind:
            out = out + 1
    return out

fn HasDependencyFileDataID(m: NorthshireManifest,
                           sourceLabel: str,
                           relationKind: str,
                           fileDataID: int32): bool =
    var i: int32
    for i in i..<m.auditedDependencies.len:
        let dep: NorthshireAuditedDependency = m.auditedDependencies[i]
        if dep.sourceLabel == sourceLabel &&
            dep.relationKind == relationKind &&
            dep.fileDataID == fileDataID:
            return true
    return false

fn northshireValidatePlacementAuditRange(label: str,
                                         clientPath: str,
                                         expectedFormatKind: str,
                                         fileDataIDs: int32[],
                                         stats: local_files.LocalFileAuditEntryStat[],
                                         startIndex: int32,
                                         matchedCount: var int32,
                                         firstFileDataID: var int32,
                                         encodedBytes: var int32,
                                         decodedBytes: var int32,
                                         assetCount: var int32): Result[bool] =
    if fileDataIDs.len <= 0:
        return Err[bool](strutil.Join(["wowExport northshire manifest: empty ", label, " placement dependency list"], ""))
    if startIndex < 0 || startIndex > stats.len || fileDataIDs.len > stats.len - startIndex:
        return Err[bool](strutil.Join(["wowExport northshire manifest: ", label, " placement dependency audit range invalid"], ""))
    var i: int32
    for i in i..<fileDataIDs.len:
        let stat: local_files.LocalFileAuditEntryStat = stats[startIndex + i]
        if stat.fileDataID != fileDataIDs[i]:
            return Err[bool](strutil.Join(["wowExport northshire manifest: ", label, " placement fileDataID order mismatch"], ""))
        if stat.archiveIndex < 0 || stat.offset < 0 || stat.size <= 0:
            return Err[bool](strutil.Join(["wowExport northshire manifest: ", label, " placement index entry invalid"], ""))
        let fileRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByEntry(clientPath, stat.archiveIndex, stat.offset, stat.size)
        if IsErr(fileRes):
            return Err[bool](strutil.Join(["wowExport northshire manifest: ", label, " placement asset load failed ", strings.IntToStr(stat.fileDataID), ": ", Error(fileRes)], ""))
        let fileBuf: bytes.ByteBuffer = Value(fileRes)
        if expectedFormatKind == "m2":
            let m2Res: Result[asset_formats.M2Header] = asset_formats.ParseM2Header(fileBuf)
            if IsErr(m2Res):
        bytes.FreeByteBuffer(fileBuf)
        return Err[bool](strutil.Join(["wowExport northshire manifest: ", label, " placement asset is not M2 ", strings.IntToStr(stat.fileDataID), ": ", Error(m2Res)], ""))
elif expectedFormatKind == "wmo":
    let wmoRes: Result[asset_formats.WmoRootSummary] = asset_formats.ParseWmoRootSummary(fileBuf)
    if IsErr(wmoRes):
        bytes.FreeByteBuffer(fileBuf)
        return Err[bool](strutil.Join(["wowExport northshire manifest: ", label, " placement asset is not WMO ", strings.IntToStr(stat.fileDataID), ": ", Error(wmoRes)], ""))
else:
    bytes.FreeByteBuffer(fileBuf)
    return Err[bool](strutil.Join(["wowExport northshire manifest: unsupported placement asset format ", expectedFormatKind], ""))
if matchedCount == 0:
    firstFileDataID = stat.fileDataID
matchedCount = matchedCount + 1
encodedBytes = encodedBytes + stat.size
decodedBytes = decodedBytes + fileBuf.len
assetCount = assetCount + 1
bytes.FreeByteBuffer(fileBuf)
    return Ok[bool](true)

fn AuditWdtMaidPlacementReferencesAgainstLocal(m: NorthshireManifest,
                                               doodadFileDataIDs: int32[],
                                               worldModelFileDataIDs: int32[]): Result[NorthshireMaidPlacementDependencyAuditSummary] =
    if !ManifestReady(m):
        return Err[NorthshireMaidPlacementDependencyAuditSummary]("wowExport northshire manifest: incomplete audited dependency table")
    if m.product != build_info.DefaultProduct ||
        m.version != build_info.DefaultVersion ||
        m.buildKey != build_info.DefaultBuildKey:
        return Err[NorthshireMaidPlacementDependencyAuditSummary]("wowExport northshire manifest: build identity drift")
    if doodadFileDataIDs.len <= 0:
        return Err[NorthshireMaidPlacementDependencyAuditSummary]("wowExport northshire manifest: empty WDT MAID doodad placement dependency list")
    if worldModelFileDataIDs.len <= 0:
        return Err[NorthshireMaidPlacementDependencyAuditSummary]("wowExport northshire manifest: empty WDT MAID world model placement dependency list")
    var allFileDataIDs: int32[]
    var allIndex: int32
    for allIndex in allIndex..<doodadFileDataIDs.len:
        add(allFileDataIDs, doodadFileDataIDs[allIndex])
    allIndex = 0
    for allIndex in allIndex..<worldModelFileDataIDs.len:
        add(allFileDataIDs, worldModelFileDataIDs[allIndex])
    let statsRes: Result[local_files.LocalFileAuditEntryStat[]] =
        local_files.ResolveLocalFileAuditEntryStatsRanged(m.clientPath, allFileDataIDs)
    if IsErr(statsRes):
        return Err[NorthshireMaidPlacementDependencyAuditSummary](strutil.Join(["wowExport northshire manifest: WDT MAID placement dependency audit failed: ", Error(statsRes)], ""))
    let stats: local_files.LocalFileAuditEntryStat[] = Value(statsRes)
    if stats.len != allFileDataIDs.len:
        return Err[NorthshireMaidPlacementDependencyAuditSummary]("wowExport northshire manifest: WDT MAID placement dependency audit count mismatch")
    var out: NorthshireMaidPlacementDependencyAuditSummary
    let doodadRes: Result[bool] =
        northshireValidatePlacementAuditRange("WDT MAID doodad",
                                              m.clientPath,
                                              "m2",
                                              doodadFileDataIDs,
                                              stats,
                                              0,
                                              out.matchedDoodadDependencyCount,
                                              out.firstDoodadFileDataID,
                                              out.doodadEncodedBytes,
                                              out.doodadDecodedBytes,
                                              out.doodadM2AssetCount)
    if IsErr(doodadRes):
        return Err[NorthshireMaidPlacementDependencyAuditSummary](Error(doodadRes))
    let worldRes: Result[bool] =
        northshireValidatePlacementAuditRange("WDT MAID world model",
                                              m.clientPath,
                                              "wmo",
                                              worldModelFileDataIDs,
                                              stats,
                                              doodadFileDataIDs.len,
                                              out.matchedWorldModelDependencyCount,
                                              out.firstWorldModelFileDataID,
                                              out.worldModelEncodedBytes,
                                              out.worldModelDecodedBytes,
                                              out.worldModelWmoAssetCount)
    if IsErr(worldRes):
        return Err[NorthshireMaidPlacementDependencyAuditSummary](Error(worldRes))
    return Ok[NorthshireMaidPlacementDependencyAuditSummary](out)

fn AuditManifestAgainstLocal(m: NorthshireManifest): Result[NorthshireAuditSummary] =
    if !ManifestReady(m):
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: incomplete audited file table")
    if m.product != build_info.DefaultProduct ||
        m.version != build_info.DefaultVersion ||
        m.buildKey != build_info.DefaultBuildKey:
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: build identity drift")
    let fileIDs: int32[] = northshireManifestFileDataIDs(m)
    let auditsRes: Result[local_files.LocalFileAudit[]] =
        local_files.ResolveLocalFileAuditsRanged(m.clientPath, fileIDs)
    if IsErr(auditsRes):
        return Err[NorthshireAuditSummary](Error(auditsRes))
    let audits: local_files.LocalFileAudit[] = Value(auditsRes)
    var out: NorthshireAuditSummary
    var i: int32
    for i in i..<m.auditedFiles.len:
        let file: NorthshireAuditedFile = m.auditedFiles[i]
        let audit: local_files.LocalFileAudit = audits[i]
        if audit.contentKey != file.contentKey:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " contentKey mismatch want=", file.contentKey, " got=", audit.contentKey], ""))
        if audit.encodingKey != file.encodingKey:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " encodingKey mismatch want=", file.encodingKey, " got=", audit.encodingKey], ""))
        if audit.entry.archiveIndex != file.archiveIndex:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " archive mismatch want=", strings.IntToStr(file.archiveIndex), " got=", strings.IntToStr(audit.entry.archiveIndex)], ""))
        if audit.entry.offset != file.offset:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " offset mismatch want=", strings.IntToStr(file.offset), " got=", strings.IntToStr(audit.entry.offset)], ""))
        if audit.entry.size != file.size:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " size mismatch want=", strings.IntToStr(file.size), " got=", strings.IntToStr(audit.entry.size)], ""))
        out.matchedFileCount = out.matchedFileCount + 1
    return Ok[NorthshireAuditSummary](out)

fn AuditManifestDependenciesAgainstLocal(m: NorthshireManifest): Result[NorthshireAuditSummary] =
    if !ManifestReady(m):
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: incomplete audited dependency table")
    if m.product != build_info.DefaultProduct ||
        m.version != build_info.DefaultVersion ||
        m.buildKey != build_info.DefaultBuildKey:
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: build identity drift")
    var encodingKeys: str[]
    var keyIndex: int32
    for keyIndex in keyIndex..<m.auditedDependencies.len:
        add(encodingKeys, m.auditedDependencies[keyIndex].encodingKey)
    let idxEntriesRes: Result[casc_index.CascIndexEntry[]] =
        casc_index.LoadLocalIndexEntries(m.clientPath, encodingKeys)
    if IsErr(idxEntriesRes):
        return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: dependency encoding index failed: ", Error(idxEntriesRes)], ""))
    let idxEntries: casc_index.CascIndexEntry[] = Value(idxEntriesRes)
    var out: NorthshireAuditSummary
    var i: int32
    for i in i..<m.auditedDependencies.len:
        let dep: NorthshireAuditedDependency = m.auditedDependencies[i]
        let entry: casc_index.CascIndexEntry = idxEntries[i]
        if entry.archiveIndex != dep.archiveIndex:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", dep.label, " dependency archive mismatch want=", strings.IntToStr(dep.archiveIndex), " got=", strings.IntToStr(entry.archiveIndex)], ""))
        if entry.offset != dep.offset:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", dep.label, " dependency offset mismatch want=", strings.IntToStr(dep.offset), " got=", strings.IntToStr(entry.offset)], ""))
        if entry.size != dep.size:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", dep.label, " dependency size mismatch want=", strings.IntToStr(dep.size), " got=", strings.IntToStr(entry.size)], ""))
        let fileRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByEntry(m.clientPath, dep.archiveIndex, dep.offset, dep.size)
        if IsErr(fileRes):
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", dep.label, " dependency payload load failed: ", Error(fileRes)], ""))
        let fileBuf: bytes.ByteBuffer = Value(fileRes)
        let contentHash: str = md5.Md5ByteBufferHex(fileBuf)
        bytes.FreeByteBuffer(fileBuf)
        if contentHash != dep.contentKey:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", dep.label, " dependency contentKey mismatch want=", dep.contentKey, " got=", contentHash], ""))
        out.matchedDependencyCount = out.matchedDependencyCount + 1
    return Ok[NorthshireAuditSummary](out)

fn AuditManifestPayloadsAgainstLocal(m: NorthshireManifest): Result[NorthshireAuditSummary] =
    if !ManifestReady(m):
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: incomplete audited file table")
    if m.product != build_info.DefaultProduct ||
        m.version != build_info.DefaultVersion ||
        m.buildKey != build_info.DefaultBuildKey:
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: build identity drift")
    var out: NorthshireAuditSummary
    var i: int32
    for i in i..<m.auditedFiles.len:
        let file: NorthshireAuditedFile = m.auditedFiles[i]
        let idxEntryRes: Result[casc_index.CascIndexEntry] =
            casc_index.LoadLocalIndexEntry(m.clientPath, file.encodingKey)
        if IsErr(idxEntryRes):
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " encoding index failed: ", Error(idxEntryRes)], ""))
        let entry: casc_index.CascIndexEntry = Value(idxEntryRes)
        if entry.archiveIndex != file.archiveIndex:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " archive mismatch want=", strings.IntToStr(file.archiveIndex), " got=", strings.IntToStr(entry.archiveIndex)], ""))
        if entry.offset != file.offset:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " offset mismatch want=", strings.IntToStr(file.offset), " got=", strings.IntToStr(entry.offset)], ""))
        if entry.size != file.size:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " size mismatch want=", strings.IntToStr(file.size), " got=", strings.IntToStr(entry.size)], ""))
        let fileRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByEntry(m.clientPath, file.archiveIndex, file.offset, file.size)
        if IsErr(fileRes):
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " payload load failed: ", Error(fileRes)], ""))
        let fileBuf: bytes.ByteBuffer = Value(fileRes)
        let contentHash: str = md5.Md5ByteBufferHex(fileBuf)
        bytes.FreeByteBuffer(fileBuf)
        if contentHash != file.contentKey:
            return Err[NorthshireAuditSummary](strutil.Join(["wowExport northshire manifest: ", file.label, " contentKey mismatch want=", file.contentKey, " got=", contentHash], ""))
        out.matchedFileCount = out.matchedFileCount + 1
    return Ok[NorthshireAuditSummary](out)

fn NorthshireAuditSummaryText(summary: NorthshireAuditSummary): str =
    var out: str = Fmt"northshireAudit matchedFiles={strings.IntToStr(summary.matchedFileCount)}"
    out = Fmt"{out} matchedDependencies={strings.IntToStr(summary.matchedDependencyCount)}"
    return out

fn ManifestText(m: NorthshireManifest): str =
    var out: str = Fmt"northshire_retail_12_0_5 product={m.product}"
    out = Fmt"{out} version={m.version}"
    out = Fmt"{out} buildKey={m.buildKey}"
    out = Fmt"{out} locale={m.locale}"
    out = Fmt"{out} auditedFiles={strings.IntToStr(m.auditedFileCount)}"
    out = Fmt"{out} auditedDependencies={strings.IntToStr(m.auditedDependencyCount)}"
    return out
