import std/bytes as bytes
import std/result
import std/seqs
import std/strings as strings
import std/strformat
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/casc_index as casc_index
import cheng/apps/wow_export/local_files as local_files
import cheng/apps/wow_export/md5 as md5

type
    NorthshireAuditedFile =
        label: str
        kind: str
        path: str
        fileDataID: int32
        contentKey: str
        encodingKey: str
        archiveIndex: int32
        offset: int32
        size: int32

    NorthshireManifest =
        product: str
        version: str
        buildKey: str
        locale: str
        clientPath: str
        auditedFileCount: int32
        auditedFiles: NorthshireAuditedFile[]

    NorthshireAuditSummary =
        matchedFileCount: int32

fn Manifest(): NorthshireManifest =
    var out: NorthshireManifest
    out.product = build_info.DefaultProduct
    out.version = build_info.DefaultVersion
    out.buildKey = build_info.DefaultBuildKey
    out.locale = build_info.DefaultLocale
    out.clientPath = build_info.DefaultClientPath
    out.auditedFiles = []
    add(out.auditedFiles, NorthshireAuditedFile(label: "azeroth-wdt",
                                                kind: "wdt",
                                                path: "World/Maps/Azeroth/Azeroth.wdt",
                                                fileDataID: 775971,
                                                contentKey: "2c3ad0761f1baa8032c6c7ee84f77049",
                                                encodingKey: "ed96d69da38751d830a8fe8d3f728529",
                                                archiveIndex: 3,
                                                offset: 77206312,
                                                size: 19820))
    add(out.auditedFiles, NorthshireAuditedFile(label: "northshire-abbey-wmo",
                                                kind: "wmo",
                                                path: "World/wmo/Azeroth/Buildings/NSabbey/NSabbey.wmo",
                                                fileDataID: 107074,
                                                contentKey: "7bee98b184d1f1e6ae514f1eae490b23",
                                                encodingKey: "47d231e98004a43cc57ef6ca9836afaf",
                                                archiveIndex: 52,
                                                offset: 500200207,
                                                size: 4780))
    add(out.auditedFiles, NorthshireAuditedFile(label: "abbey-bell-texture",
                                                kind: "blp",
                                                path: "World/Azeroth/Elwynn/ActiveDoodads/AbbeyBell/ABBEYBELL.BLP",
                                                fileDataID: 189598,
                                                contentKey: "181baf573792fd5e108aa4ccec399f92",
                                                encodingKey: "9dddb8c93d8746f5fabedb3a98719b5b",
                                                archiveIndex: 57,
                                                offset: 305877890,
                                                size: 35831))
    add(out.auditedFiles, NorthshireAuditedFile(label: "abbey-bell-model",
                                                kind: "m2",
                                                path: "World/Azeroth/ELWYNN/ActiveDoodads/AbbeyBell/nsabbeyBell.m2",
                                                fileDataID: 189599,
                                                contentKey: "c253d5be7f958452992ca4315200ced3",
                                                encodingKey: "0f08d9373d5f0b3f15feeca0295f6917",
                                                archiveIndex: 57,
                                                offset: 627291208,
                                                size: 6898))
    out.auditedFileCount = out.auditedFiles.len
    return out

fn ManifestReady(m: NorthshireManifest): bool =
    if m.auditedFileCount <= 0 || m.auditedFiles.len != m.auditedFileCount:
        return false
    var i: int32
    while i < m.auditedFiles.len:
        let file: NorthshireAuditedFile = m.auditedFiles[i]
        if file.fileDataID <= 0:
            return false
        if strings.Len(file.path) == 0 || strings.Len(file.kind) == 0:
            return false
        if strings.Len(file.contentKey) != 32 || strings.Len(file.encodingKey) != 32:
            return false
        if file.archiveIndex < 0 || file.offset < 0 || file.size <= 0:
            return false
        i = i + 1
    return true

fn northshireManifestFileDataIDs(m: NorthshireManifest): int32[] =
    var out: int32[]
    var i: int32
    while i < m.auditedFiles.len:
        add(out, m.auditedFiles[i].fileDataID)
        i = i + 1
    return out

fn AuditManifestAgainstLocal(m: NorthshireManifest): Result[NorthshireAuditSummary] =
    if !ManifestReady(m):
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: incomplete audited file table")
    if m.product != build_info.DefaultProduct ||
        m.version != build_info.DefaultVersion ||
        m.buildKey != build_info.DefaultBuildKey:
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: build identity drift")
    let fileIDs: int32[] = northshireManifestFileDataIDs(m)
    let auditsRes: Result[local_files.LocalFileAudit[]] =
        local_files.ResolveLocalFileAuditsRanged(m.clientPath, fileIDs)
    if IsErr(auditsRes):
        return Err[NorthshireAuditSummary](Error(auditsRes))
    let audits: local_files.LocalFileAudit[] = Value(auditsRes)
    var out: NorthshireAuditSummary
    var i: int32
    while i < m.auditedFiles.len:
        let file: NorthshireAuditedFile = m.auditedFiles[i]
        let audit: local_files.LocalFileAudit = audits[i]
        if audit.contentKey != file.contentKey:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " contentKey mismatch want=" + file.contentKey + " got=" + audit.contentKey)
        if audit.encodingKey != file.encodingKey:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " encodingKey mismatch want=" + file.encodingKey + " got=" + audit.encodingKey)
        if audit.entry.archiveIndex != file.archiveIndex:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " archive mismatch want=" + strings.IntToStr(file.archiveIndex) + " got=" + strings.IntToStr(audit.entry.archiveIndex))
        if audit.entry.offset != file.offset:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " offset mismatch want=" + strings.IntToStr(file.offset) + " got=" + strings.IntToStr(audit.entry.offset))
        if audit.entry.size != file.size:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " size mismatch want=" + strings.IntToStr(file.size) + " got=" + strings.IntToStr(audit.entry.size))
        out.matchedFileCount = out.matchedFileCount + 1
        i = i + 1
    return Ok[NorthshireAuditSummary](out)

fn AuditManifestPayloadsAgainstLocal(m: NorthshireManifest): Result[NorthshireAuditSummary] =
    if !ManifestReady(m):
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: incomplete audited file table")
    if m.product != build_info.DefaultProduct ||
        m.version != build_info.DefaultVersion ||
        m.buildKey != build_info.DefaultBuildKey:
        return Err[NorthshireAuditSummary]("wowExport northshire manifest: build identity drift")
    var out: NorthshireAuditSummary
    var i: int32
    while i < m.auditedFiles.len:
        let file: NorthshireAuditedFile = m.auditedFiles[i]
        let idxEntryRes: Result[casc_index.CascIndexEntry] =
            casc_index.LoadLocalIndexEntry(m.clientPath, file.encodingKey)
        if IsErr(idxEntryRes):
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " encoding index failed: " + Error(idxEntryRes))
        let entry: casc_index.CascIndexEntry = Value(idxEntryRes)
        if entry.archiveIndex != file.archiveIndex:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " archive mismatch want=" + strings.IntToStr(file.archiveIndex) + " got=" + strings.IntToStr(entry.archiveIndex))
        if entry.offset != file.offset:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " offset mismatch want=" + strings.IntToStr(file.offset) + " got=" + strings.IntToStr(entry.offset))
        if entry.size != file.size:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " size mismatch want=" + strings.IntToStr(file.size) + " got=" + strings.IntToStr(entry.size))
        let fileRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByEntry(m.clientPath, file.archiveIndex, file.offset, file.size)
        if IsErr(fileRes):
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " payload load failed: " + Error(fileRes))
        let fileBuf: bytes.ByteBuffer = Value(fileRes)
        let contentHash: str = md5.Md5ByteBufferHex(fileBuf)
        bytes.FreeByteBuffer(fileBuf)
        if contentHash != file.contentKey:
            return Err[NorthshireAuditSummary]("wowExport northshire manifest: " + file.label + " contentKey mismatch want=" + file.contentKey + " got=" + contentHash)
        out.matchedFileCount = out.matchedFileCount + 1
        i = i + 1
    return Ok[NorthshireAuditSummary](out)

fn NorthshireAuditSummaryText(summary: NorthshireAuditSummary): str =
    return Fmt"northshireAudit matchedFiles={strings.IntToStr(summary.matchedFileCount)}"

fn ManifestText(m: NorthshireManifest): str =
    return Fmt"northshire_retail_12_0_5 product={m.product} version={m.version} buildKey={m.buildKey} locale={m.locale} auditedFiles={strings.IntToStr(m.auditedFileCount)}"
