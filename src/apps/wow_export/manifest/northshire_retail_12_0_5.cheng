type
    NorthshireAuditedFile =
        label: str
        kind: str
        path: str
        fileDataID: int32
        contentKey: str
        encodingKey: str
        archiveIndex: int32
        offset: int32
        size: int32

    NorthshireAuditedDependency =
        label: str
        sourceLabel: str
        relationKind: str
        formatKind: str
        fileDataID: int32
        contentKey: str
        encodingKey: str
        archiveIndex: int32
        offset: int32
        size: int32

    NorthshireManifest =
        product: str
        version: str
        buildKey: str
        locale: str
        clientPath: str
        auditedFileCount: int32
        auditedFiles: NorthshireAuditedFile[]
        auditedDependencyCount: int32
        auditedDependencies: NorthshireAuditedDependency[]

    NorthshireAuditSummary =
        matchedFileCount: int32
        matchedDependencyCount: int32

    NorthshireMaidPlacementDependencyAuditSummary =
        matchedDoodadDependencyCount: int32
        matchedWorldModelDependencyCount: int32
        firstDoodadFileDataID: int32
        firstWorldModelFileDataID: int32
        doodadEncodedBytes: int32
        worldModelEncodedBytes: int32
        doodadDecodedBytes: int32
        worldModelDecodedBytes: int32
        doodadM2AssetCount: int32
        worldModelWmoAssetCount: int32

fn northshireAddWmoModiDependency(out: var NorthshireManifest,
                                  label: str,
                                  fileDataID: int32,
                                  contentKey: str,
                                  encodingKey: str,
                                  archiveIndex: int32,
                                  offset: int32,
                                  size: int32) =
    add(out.auditedDependencies,
        NorthshireAuditedDependency(label: label,
                                    sourceLabel: "northshire-abbey-wmo",
                                    relationKind: "wmo_modi",
                                    formatKind: "m2",
                                    fileDataID: fileDataID,
                                    contentKey: contentKey,
                                    encodingKey: encodingKey,
                                    archiveIndex: archiveIndex,
                                    offset: offset,
                                    size: size))

fn northshireAddWdtMaidSplitDependency(out: var NorthshireManifest,
                                        label: str,
                                        formatKind: str,
                                        fileDataID: int32,
                                        contentKey: str,
                                        encodingKey: str,
                                        archiveIndex: int32,
                                        offset: int32,
                                        size: int32) =
    add(out.auditedDependencies,
        NorthshireAuditedDependency(label: label,
                                    sourceLabel: "azeroth-wdt",
                                    relationKind: "wdt_maid_split",
                                    formatKind: formatKind,
                                    fileDataID: fileDataID,
                                    contentKey: contentKey,
                                    encodingKey: encodingKey,
                                    archiveIndex: archiveIndex,
                                    offset: offset,
                                    size: size))

