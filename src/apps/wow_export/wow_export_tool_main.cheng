import std/cmdline as cmdline
import std/bytes as bytes
import std/result
import std/strings as strings
import std/strformat
import std/strutils as strutils
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/asset_export as asset_export
import cheng/apps/wow_export/blp as blp
import cheng/apps/wow_export/config as config
import cheng/apps/wow_export/casc_archive as casc_archive
import cheng/apps/wow_export/casc_index as casc_index
import cheng/apps/wow_export/encoding as encoding
import cheng/apps/wow_export/install as install
import cheng/apps/wow_export/local_files as local_files
import cheng/apps/wow_export/preview as preview
import cheng/apps/wow_export/render as render
import cheng/apps/wow_export/root as wow_root
import cheng/apps/wow_export/tact_keys as tact_keys
import cheng/apps/wow_export/manifest/northshire_retail_12_0_5 as northshire

fn PrintUsage() =
    echo("wow-export commands: list-builds | probe | manifest | audit-file | extract-file | convert-blp | export-m2 | export-wmo | export-map | export-dependencies | preview-northshire | render-northshire")
    echo("export examples: extract-file --label abbey-bell-model --out /tmp/nsabbeyBell.m2 | convert-blp --out /tmp/abbeyBell.tga | render-northshire --out /tmp/northshire.tga")

fn RunListBuilds(): int32 =
    let buildsRes: Result[build_info.WowBuildEntry[]] = build_info.LoadBuildInfo(build_info.DefaultClientPath)
    if IsErr(buildsRes):
        echo(Error(buildsRes))
        return 1
    let builds: build_info.WowBuildEntry[] = Value(buildsRes)
    var i: int32
    while i < builds.len:
        echo(build_info.BuildSummary(builds[i]))
        i = i + 1
    return 0

fn RunProbe(): int32 =
    let buildRes: Result[build_info.WowBuildEntry] = build_info.ProbeRetailDefault()
    if IsErr(buildRes):
        echo(Error(buildRes))
        return 1
    let build: build_info.WowBuildEntry = Value(buildRes)
    echo(build_info.BuildSummary(build))
    let cfgRes: Result[config.BuildConfig] = config.LoadBuildConfig(build_info.DefaultClientPath, build.buildKey)
    if IsErr(cfgRes):
        echo(Error(cfgRes))
        return 1
    let cfg: config.BuildConfig = Value(cfgRes)
    echo(config.BuildConfigSummary(cfg))
    let idxRes: Result[casc_index.CascIndexSummary] = casc_index.LoadFirstJournalIndexSummary(build_info.DefaultClientPath)
    if IsErr(idxRes):
        echo(Error(idxRes))
        return 1
    echo(casc_index.CascIndexSummaryText(Value(idxRes)))
    let encEntryRes: Result[casc_index.CascIndexEntry] =
        casc_index.LoadLocalIndexEntry(build_info.DefaultClientPath, cfg.encodingEncodingKey)
    if IsErr(encEntryRes):
        echo(Error(encEntryRes))
        return 1
    echo(Fmt"encodingEntry={casc_index.CascIndexEntryText(Value(encEntryRes))}")
    let encFullRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryFull(build_info.DefaultClientPath, Value(encEntryRes))
    if IsErr(encFullRes):
        echo(Error(encFullRes))
        return 1
    let encSummaryRes: Result[encoding.EncodingSummary] = encoding.WowEncodingSummary(Value(encFullRes))
    if IsErr(encSummaryRes):
        echo(Error(encSummaryRes))
        return 1
    echo(encoding.WowEncodingSummaryText(Value(encSummaryRes)))
    let rootKeyRes: Result[str] = encoding.WowEncodingFindEncodingKey(Value(encFullRes), cfg.root)
    if IsErr(rootKeyRes):
        echo(Error(rootKeyRes))
        return 1
    echo(Fmt"rootEncodingKey={Value(rootKeyRes)}")
    let rootEntryRes: Result[casc_index.CascIndexEntry] =
        casc_index.LoadLocalIndexEntry(build_info.DefaultClientPath, Value(rootKeyRes))
    if IsErr(rootEntryRes):
        echo(Error(rootEntryRes))
        return 1
    let rootBytesRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryFirstBlock(build_info.DefaultClientPath, Value(rootEntryRes))
    if IsErr(rootBytesRes):
        echo(Error(rootBytesRes))
        return 1
    let rootHeaderRes: Result[wow_root.RootHeader] = wow_root.WowRootParseHeader(Value(rootBytesRes))
    if IsErr(rootHeaderRes):
        echo(Error(rootHeaderRes))
        return 1
    let rootFirstRes: Result[wow_root.RootEntry] = wow_root.WowRootFirstEntry(Value(rootBytesRes))
    if IsErr(rootFirstRes):
        echo(Error(rootFirstRes))
        return 1
    echo(Fmt"rootVersion={strings.IntToStr(Value(rootHeaderRes).version)} totalFiles={strings.IntToStr(Value(rootHeaderRes).totalFiles)} firstFileDataID={strings.IntToStr(Value(rootFirstRes).fileDataID)} firstCKey={Value(rootFirstRes).contentKey}")
    let installEntryRes: Result[casc_index.CascIndexEntry] =
        casc_index.LoadLocalIndexEntry(build_info.DefaultClientPath, cfg.installEncodingKey)
    if IsErr(installEntryRes):
        echo(Error(installEntryRes))
        return 1
    let installBytesRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryFull(build_info.DefaultClientPath, Value(installEntryRes))
    if IsErr(installBytesRes):
        echo(Error(installBytesRes))
        return 1
    let installSummaryRes: Result[install.InstallSummary] = install.WowInstallSummary(Value(installBytesRes))
    if IsErr(installSummaryRes):
        echo(Error(installSummaryRes))
        return 1
    echo(install.WowInstallSummaryText(Value(installSummaryRes)))
    let keyRes: Result[tact_keys.TactKeyTable] = tact_keys.LoadTactKeyTable(build_info.DefaultClientPath, build.keyRing)
    if IsErr(keyRes):
        echo(Error(keyRes))
        return 1
    echo(tact_keys.TactKeyTableSummary(Value(keyRes)))
    return 0

fn RunPreviewNorthshire(): int32 =
    let frames: int32 = cmdline.ReadInt32FlagOrDefault("--frames", 120)
    let summaryRes: Result[preview.PreviewSummary] = preview.PreviewNorthshire(frames)
    if IsErr(summaryRes):
        echo(Error(summaryRes))
        return 1
    echo(preview.PreviewSummaryText(Value(summaryRes)))
    return 0

fn RunManifest(): int32 =
    echo(northshire.ManifestText(northshire.Manifest()))
    return 0

fn RunAuditFile(): int32 =
    let count: int32 = cmdline.ParamCount()
    var wanted: int32[]
    if count >= 2 && !strings.HasPrefix(cmdline.ParamStr(2), "-"):
        var i: int32 = 2
        while i <= count:
            let raw: str = cmdline.ParamStr(i)
            let fileDataID: int32 = int32(strutils.ParseInt(raw))
            if fileDataID < 0:
                echo(Fmt"wowExport audit-file: invalid fileDataID {raw}")
                return 1
            add(wanted, fileDataID)
            i = i + 1
    else:
        let fileDataID: int32 = cmdline.ReadInt32FlagOrDefault("--file-data-id", -1)
        if fileDataID < 0:
            echo("wowExport audit-file: missing --file-data-id or positional fileDataIDs")
            return 1
        add(wanted, fileDataID)
    if wanted.len <= 0:
        echo("wowExport audit-file: no fileDataIDs supplied")
        return 1
    let auditsRes: Result[local_files.LocalFileAudit[]] =
        local_files.ResolveLocalFileAuditsRanged(build_info.DefaultClientPath, wanted)
    if IsErr(auditsRes):
        echo(Error(auditsRes))
        return 1
    let audits: local_files.LocalFileAudit[] = Value(auditsRes)
    var printed: int32
    while printed < audits.len:
        echo(local_files.AuditText(audits[printed]))
        printed = printed + 1
    return 0

fn RunExtractFile(): int32 =
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    let outPath: str = cmdline.ReadFlagOrDefault("--out", "")
    if strings.Len(outPath) == 0:
        echo("wowExport extract-file: missing --out")
        return 1
    var label: str
    if cmdline.ReadFirstFlagValue("--label", label):
        let exportRes: Result[asset_export.AssetExportSummary] =
            asset_export.ExportNorthshireLabel(manifest, label, outPath)
        if IsErr(exportRes):
            echo(Error(exportRes))
            return 1
        echo(asset_export.AssetExportSummaryText(Value(exportRes)))
        return 0
    let fileDataID: int32 = cmdline.ReadInt32FlagOrDefault("--file-data-id", -1)
    if fileDataID < 0:
        echo("wowExport extract-file: missing --label or audited --file-data-id")
        return 1
    let exportRes: Result[asset_export.AssetExportSummary] =
        asset_export.ExportNorthshireFileDataID(manifest, fileDataID, outPath)
    if IsErr(exportRes):
        echo(Error(exportRes))
        return 1
    echo(asset_export.AssetExportSummaryText(Value(exportRes)))
    return 0

fn RunExportKind(kind: str): int32 =
    let outPath: str = cmdline.ReadFlagOrDefault("--out", "")
    if strings.Len(outPath) == 0:
        echo(Fmt"wowExport export-{kind}: missing --out")
        return 1
    let exportRes: Result[asset_export.AssetExportSummary] =
        asset_export.ExportNorthshireKind(northshire.Manifest(), kind, outPath)
    if IsErr(exportRes):
        echo(Error(exportRes))
        return 1
    echo(asset_export.AssetExportSummaryText(Value(exportRes)))
    return 0

fn RunExportMap(): int32 =
    let outDir: str = cmdline.ReadFlagOrDefault("--out-dir", "")
    if strings.Len(outDir) == 0:
        echo("wowExport export-map: missing --out-dir")
        return 1
    let exportRes: Result[asset_export.AssetExportBundleSummary] =
        asset_export.ExportNorthshireBundle(northshire.Manifest(), outDir)
    if IsErr(exportRes):
        echo(Error(exportRes))
        return 1
    echo(asset_export.AssetExportBundleSummaryText(Value(exportRes)))
    return 0

fn RunExportDependencies(): int32 =
    let outDir: str = cmdline.ReadFlagOrDefault("--out-dir", "")
    if strings.Len(outDir) == 0:
        echo("wowExport export-dependencies: missing --out-dir")
        return 1
    let exportRes: Result[asset_export.AssetExportDependencyBundleSummary] =
        asset_export.ExportNorthshireDependenciesBundle(northshire.Manifest(), outDir)
    if IsErr(exportRes):
        echo(Error(exportRes))
        return 1
    echo(asset_export.AssetExportDependencyBundleSummaryText(Value(exportRes)))
    return 0

fn RunConvertBlp(): int32 =
    let outPath: str = cmdline.ReadFlagOrDefault("--out", "")
    if strings.Len(outPath) == 0:
        echo("wowExport convert-blp: missing --out")
        return 1
    var inPath: str
    if cmdline.ReadFirstFlagValue("--in", inPath):
        let blpBuf: bytes.ByteBuffer = bytes.ReadFileBytes(inPath)
        if blpBuf.len <= 0:
            echo(Fmt"wowExport convert-blp: input read failed {inPath}")
            return 1
        let tgaRes: Result[bytes.ByteBuffer] = blp.Blp2DecodeFirstMipTga(blpBuf)
        bytes.FreeByteBuffer(blpBuf)
        if IsErr(tgaRes):
            echo(Error(tgaRes))
            return 1
        var tgaBuf: bytes.ByteBuffer = Value(tgaRes)
        let writeRes: Result[int32] = asset_export.AssetExportWriteBufferAtomic(outPath, tgaBuf)
        bytes.FreeByteBuffer(tgaBuf)
        if IsErr(writeRes):
            echo(Error(writeRes))
            return 1
        echo(Fmt"converted blp bytes={strings.IntToStr(Value(writeRes))} out={outPath}")
        return 0
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    var label: str
    if cmdline.ReadFirstFlagValue("--label", label):
        let exportRes: Result[asset_export.AssetExportSummary] =
            asset_export.ConvertNorthshireBlpLabel(manifest, label, outPath)
        if IsErr(exportRes):
            echo(Error(exportRes))
            return 1
        echo(asset_export.AssetExportSummaryText(Value(exportRes)))
        return 0
    let fileDataID: int32 = cmdline.ReadInt32FlagOrDefault("--file-data-id", -1)
    if fileDataID >= 0:
        let exportRes: Result[asset_export.AssetExportSummary] =
            asset_export.ConvertNorthshireBlpFileDataID(manifest, fileDataID, outPath)
        if IsErr(exportRes):
            echo(Error(exportRes))
            return 1
        echo(asset_export.AssetExportSummaryText(Value(exportRes)))
        return 0
    let exportRes: Result[asset_export.AssetExportSummary] =
        asset_export.ConvertNorthshireFirstBlp(manifest, outPath)
    if IsErr(exportRes):
        echo(Error(exportRes))
        return 1
    echo(asset_export.AssetExportSummaryText(Value(exportRes)))
    return 0

fn RunRenderNorthshire(): int32 =
    let outPath: str = cmdline.ReadFlagOrDefault("--out", "")
    if strings.Len(outPath) == 0:
        echo("wowExport render-northshire: missing --out")
        return 1
    let width: int32 = cmdline.ReadInt32FlagOrDefault("--width", 1280)
    let height: int32 = cmdline.ReadInt32FlagOrDefault("--height", 720)
    let renderRes: Result[render.RenderSummary] =
        render.RenderNorthshireTga(outPath, width, height)
    if IsErr(renderRes):
        echo(Error(renderRes))
        return 1
    echo(render.RenderSummaryText(Value(renderRes)))
    return 0

fn RunNotImplemented(cmd: str): int32 =
    echo(Fmt"wowExport {cmd}: blocked until real BLP pixel decoding and target encoding are implemented; no fake conversion")
    return 1

fn main(argc: int32, argv: ptr): int32 =
    cmdline.CaptureCmdLine(argc, argv)
    let count: int32 = cmdline.ParamCount()
    if count < 1:
        PrintUsage()
        return 1
    let cmd: str = cmdline.ParamStr(1)
    if cmd == "list-builds":
        return RunListBuilds()
    if cmd == "probe":
        return RunProbe()
    if cmd == "manifest":
        return RunManifest()
    if cmd == "audit-file":
        return RunAuditFile()
    if cmd == "extract-file":
        return RunExtractFile()
    if cmd == "export-m2":
        return RunExportKind("m2")
    if cmd == "export-wmo":
        return RunExportKind("wmo")
    if cmd == "export-map":
        return RunExportMap()
    if cmd == "export-dependencies":
        return RunExportDependencies()
    if cmd == "preview-northshire":
        return RunPreviewNorthshire()
    if cmd == "convert-blp":
        return RunConvertBlp()
    if cmd == "render-northshire":
        return RunRenderNorthshire()
    echo(Fmt"wowExport: unknown command {cmd}")
    PrintUsage()
    return 1
