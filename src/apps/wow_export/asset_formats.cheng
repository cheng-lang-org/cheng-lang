import std/bytes as bytes
import std/rawbytes as rawbytes
import std/result
import std/strings as strings
import std/strformat
import std/strutils as strutil

type
    FormatHeader =
        magic: str
        versionOrSize: int32
        chunkCount: int32

    WdtSummary =
        header: FormatHeader
        mainEntryCount: int32
        activeTileCount: int32
        modelPlacementCount: int32
        maidEntryCount: int32
        maidReferencedFileCount: int32
        firstMaidFileDataID: int32

    WdtMaidTile =
        tileX: int32
        tileY: int32
        fileDataIDCount: int32
        firstFileDataID: int32
        fileDataIDs: int32[]

    WdtMaidResourceSummary =
        formatKind: str
        firstMagic: str
        secondMagic: str
        version: int32

    WdtMaidAdtSplitSummary =
        version: int32
        chunkCount: int32
        firstDataMagic: str
        mapChunkCount: int32
        doodadPlacementCount: int32
        firstDoodadNameID: int32
        firstDoodadUniqueID: int32
        doodadPlacementFileDataIDCount: int32
        firstDoodadPlacementFileDataID: int32
        doodadPlacementFileDataIDs: int32[]
        doodadPlacementPositionBoundsReady: bool
        minDoodadPlacementX1000: int32
        minDoodadPlacementY1000: int32
        minDoodadPlacementZ1000: int32
        maxDoodadPlacementX1000: int32
        maxDoodadPlacementY1000: int32
        maxDoodadPlacementZ1000: int32
        minDoodadScale: int32
        maxDoodadScale: int32
        worldModelPlacementCount: int32
        firstWorldModelNameID: int32
        firstWorldModelUniqueID: int32
        worldModelPlacementFileDataIDCount: int32
        firstWorldModelPlacementFileDataID: int32
        worldModelPlacementFileDataIDs: int32[]
        worldModelPlacementPositionBoundsReady: bool
        minWorldModelPlacementX1000: int32
        minWorldModelPlacementY1000: int32
        minWorldModelPlacementZ1000: int32
        maxWorldModelPlacementX1000: int32
        maxWorldModelPlacementY1000: int32
        maxWorldModelPlacementZ1000: int32
        minWorldModelScale: int32
        maxWorldModelScale: int32

    WmoRootSummary =
        header: FormatHeader
        materialCount: int32
        groupCount: int32
        portalCount: int32
        lightCount: int32
        modelCount: int32
        doodadCount: int32
        doodadSetCount: int32
        doodadSetDefinitionCount: int32
        doodadPlacementCount: int32
        doodadSetPlacementCount: int32
        firstDoodadNameIndex: int32
        doodadBoundsReady: bool
        minDoodadX1000: int32
        minDoodadY1000: int32
        minDoodadZ1000: int32
        maxDoodadX1000: int32
        maxDoodadY1000: int32
        maxDoodadZ1000: int32
        groupFileDataIDCount: int32
        firstGroupFileDataID: int32
        modelSlotCount: int32
        modelFileDataIDCount: int32
        firstModelFileDataID: int32
        doodadResolvedModelPlacementCount: int32
        doodadReferencedModelFileDataIDCount: int32
        firstDoodadModelFileDataID: int32

    WmoGroupSummary =
        header: FormatHeader
        vertexCount: int32
        indexCount: int32
        batchCount: int32
        materialInfoCount: int32

    AdtTerrainSummary =
        header: FormatHeader
        mapChunkCount: int32
        heightChunkCount: int32
        heightSampleCount: int32
        minHeight1000: int32
        maxHeight1000: int32

    M2DependencySummary =
        skinFileDataIDCount: int32
        firstSkinFileDataID: int32
        textureFileDataIDCount: int32
        firstTextureFileDataID: int32

    M2SkinSummary =
        indexCount: int32
        triangleIndexCount: int32
        propertyCount: int32
        submeshCount: int32
        textureUnitCount: int32

    M2Header =
        version: int32
        sequenceCount: int32
        boneCount: int32
        vertexCount: int32
        vertexOffset: int32
        skinProfileCount: int32
        textureCount: int32

    M2GeometrySummary =
        header: M2Header
        vertexStride: int32
        minX1000: int32
        minY1000: int32
        minZ1000: int32
        maxX1000: int32
        maxY1000: int32
        maxZ1000: int32

const
    m2InnerHeaderOffset = 8
    m2SequenceCountOffset = 0x1c
    m2BoneCountOffset = 0x2c
    m2VertexCountOffset = 0x3c
    m2VertexOffsetOffset = 0x40
    m2SkinProfileCountOffset = 0x44
    m2TextureCountOffset = 0x50
    m2ClassicHeaderBytes = 0x54
    m2VertexStride = 48
    adtMcnkHeaderBytes = 128
    adtMcnkBaseZOffset = 112
    adtHeightSamplesPerChunk = 145
    adtMcvTByteCount = 580
    adtMddfStride = 36
    adtModfStride = 64
    wmoDoodadSetStride = 32
    wmoDoodadPlacementStride = 40

fn int32ListContains(values: int32[], value: int32): bool =
    var i: int32
    for i in i..<values.len:
        if values[i] == value:
            return true
    return false

fn wmoResolveDoodadModelSlots(modelSlots: int32[], doodadSlots: int32[]): Result[int32[]] =
    if doodadSlots.len > 0 && modelSlots.len <= 0:
        return Err[int32[]]("wowExport WMO: MODD references missing MODI table")
    var out: int32[]
    var i: int32
    for i in i..<doodadSlots.len:
        let slot: int32 = doodadSlots[i]
        if slot < 0 || slot >= modelSlots.len:
            return Err[int32[]](strutil.Join(["wowExport WMO: MODD model slot out of MODI range ", strings.IntToStr(slot)], ""))
        let fileDataID: int32 = modelSlots[slot]
        if fileDataID <= 0:
            return Err[int32[]](strutil.Join(["wowExport WMO: MODD model slot has no MODI fileDataID ", strings.IntToStr(slot)], ""))
        add(out, fileDataID)
    return Ok[int32[]](out)

fn m2HasMagic(buf: bytes.ByteBuffer,
              start: int32,
              b0: int32,
              b1: int32,
              b2: int32,
              b3: int32): bool =
    if start < 0 || start + 4 > buf.len:
        return false
    return bytes.BufByteAt(buf, start) == b0 &&
        bytes.BufByteAt(buf, start + 1) == b1 &&
        bytes.BufByteAt(buf, start + 2) == b2 &&
        bytes.BufByteAt(buf, start + 3) == b3

fn parseClassicM2Header(buf: bytes.ByteBuffer, start: int32): Result[M2Header] =
    if start < 0 || start + m2ClassicHeaderBytes > buf.len:
        return Err[M2Header]("wowExport M2: classic header too small")
    if !m2HasMagic(buf, start, int32('M'), int32('D'), int32('2'), int32('0')):
        return Err[M2Header]("wowExport M2: missing MD20 header")
    var out: M2Header
    out.version = bytes.ReadU32LEAt(buf, start + 4)
    out.sequenceCount = bytes.ReadU32LEAt(buf, start + m2SequenceCountOffset)
    out.boneCount = bytes.ReadU32LEAt(buf, start + m2BoneCountOffset)
    out.vertexCount = bytes.ReadU32LEAt(buf, start + m2VertexCountOffset)
    out.vertexOffset = start + bytes.ReadU32LEAt(buf, start + m2VertexOffsetOffset)
    out.skinProfileCount = bytes.ReadU32LEAt(buf, start + m2SkinProfileCountOffset)
    out.textureCount = bytes.ReadU32LEAt(buf, start + m2TextureCountOffset)
    return Ok[M2Header](out)

fn m2HeaderStart(buf: bytes.ByteBuffer): Result[int32] =
    if buf.len < 8:
        return Err[int32]("wowExport M2: header too small")
    if m2HasMagic(buf, 0, int32('M'), int32('D'), int32('2'), int32('0')):
        return Ok[int32](0)
    if m2HasMagic(buf, 0, int32('M'), int32('D'), int32('2'), int32('1')):
        return Ok[int32](m2InnerHeaderOffset)
    return Err[int32]("wowExport M2: invalid magic")

fn ParseM2Header(buf: bytes.ByteBuffer): Result[M2Header] =
    let startRes: Result[int32] = m2HeaderStart(buf)
    if IsErr(startRes):
        return Err[M2Header](Error(startRes))
    return parseClassicM2Header(buf, Value(startRes))

fn m2ClampI64ToI32(value: int64): int32 =
    if value > int64(2147483647):
        return 2147483647
    if value < int64(-2147483647):
        return -2147483647
    return int32(value)

fn m2F32Scaled1000At(buf: bytes.ByteBuffer, idx: int32): int32 =
    let bits: int32 = bytes.ReadU32LEAt(buf, idx)
    let exponentRaw: int32 = (bits >> 23) & 255
    var mantissa: int64 = int64(bits & 0x7fffff)
    var exponent: int32 = exponentRaw - 127
    if exponentRaw == 0:
        exponent = -126
    else:
        mantissa = mantissa | int64(0x800000)
    var scaled: int64 = mantissa * int64(1000)
    let shift: int32 = exponent - 23
    if shift > 0:
        var i: int32
        for i in i..<shift:
            scaled = scaled * int64(2)
    elif shift < 0:
        var i: int32
        for i in i..<0 - shift:
            scaled = scaled / int64(2)
    if bits < 0:
        scaled = int64(0) - scaled
    return m2ClampI64ToI32(scaled)

fn finiteF32Scaled1000At(buf: bytes.ByteBuffer, idx: int32, label: str): Result[int32] =
    if idx < 0 || idx + 4 > buf.len:
        return Err[int32](strutil.Join(["wowExport ", label, ": f32 out of bounds"], ""))
    let bits: int32 = bytes.ReadU32LEAt(buf, idx)
    let exponentRaw: int32 = (bits >> 23) & 255
    if exponentRaw == 255:
        return Err[int32](strutil.Join(["wowExport ", label, ": non-finite f32"], ""))
    return Ok[int32](m2F32Scaled1000At(buf, idx))

fn ParseM2GeometrySummary(buf: bytes.ByteBuffer): Result[M2GeometrySummary] =
    let headerRes: Result[M2Header] = ParseM2Header(buf)
    if IsErr(headerRes):
        return Err[M2GeometrySummary](Error(headerRes))
    let header: M2Header = Value(headerRes)
    if header.vertexCount <= 0:
        return Err[M2GeometrySummary]("wowExport M2: missing vertex array")
    if header.vertexOffset < 0 ||
        header.vertexOffset + header.vertexCount * m2VertexStride > buf.len:
        return Err[M2GeometrySummary]("wowExport M2: vertex array out of bounds")
    var out: M2GeometrySummary
    out.header = header
    out.vertexStride = m2VertexStride
    var i: int32
    for i in i..<header.vertexCount:
        let pos: int32 = header.vertexOffset + i * m2VertexStride
        let x: int32 = m2F32Scaled1000At(buf, pos)
        let y: int32 = m2F32Scaled1000At(buf, pos + 4)
        let z: int32 = m2F32Scaled1000At(buf, pos + 8)
        if i == 0:
            out.minX1000 = x
            out.maxX1000 = x
            out.minY1000 = y
            out.maxY1000 = y
            out.minZ1000 = z
            out.maxZ1000 = z
        else:
            if x < out.minX1000: out.minX1000 = x
            if x > out.maxX1000: out.maxX1000 = x
            if y < out.minY1000: out.minY1000 = y
            if y > out.maxY1000: out.maxY1000 = y
            if z < out.minZ1000: out.minZ1000 = z
            if z > out.maxZ1000: out.maxZ1000 = z
    return Ok[M2GeometrySummary](out)

fn M2GeometrySpanX1000(summary: M2GeometrySummary): int32 =
    return summary.maxX1000 - summary.minX1000

fn M2GeometrySpanY1000(summary: M2GeometrySummary): int32 =
    return summary.maxY1000 - summary.minY1000

fn M2GeometrySpanZ1000(summary: M2GeometrySummary): int32 =
    return summary.maxZ1000 - summary.minZ1000

fn formatFourCCTextAt(buf: bytes.ByteBuffer, pos: int32): Result[str] =
    if pos < 0 || pos + 4 > buf.len:
        return Err[str]("wowExport format: fourCC out of bounds")
    var raw: rawbytes.Bytes = rawbytes.BytesAlloc(4)
    if rawbytes.BytesLen(raw) != 4:
        return Err[str]("wowExport format: fourCC allocation failed")
    let b0: int32 = bytes.BufByteAt(buf, pos)
    let b1: int32 = bytes.BufByteAt(buf, pos + 1)
    let b2: int32 = bytes.BufByteAt(buf, pos + 2)
    let b3: int32 = bytes.BufByteAt(buf, pos + 3)
    rawbytes.BytesSet(raw, 0, b0)
    rawbytes.BytesSet(raw, 1, b1)
    rawbytes.BytesSet(raw, 2, b2)
    rawbytes.BytesSet(raw, 3, b3)
    let out: str = rawbytes.BytesToString(raw)
    rawbytes.BytesFree(raw)
    return Ok[str](out)

fn ParseChunkedHeader(buf: bytes.ByteBuffer, label: str): Result[FormatHeader] =
    if buf.len < 8:
        return Err[FormatHeader](strutil.Join(["wowExport ", label, ": header too small"], ""))
    var pos: int32
    var firstMagic: str
    var firstSize: int32
    var count: int32
    for pos in range(0, buf.len, 8):

        if pos + 8 > buf.len:
            return Err[FormatHeader](strutil.Join(["wowExport ", label, ": truncated chunk header"], ""))
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        if size < 0:
            return Err[FormatHeader](strutil.Join(["wowExport ", label, ": negative chunk size"], ""))
        if pos == 0:
            let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
            if IsErr(magicRes):
                return Err[FormatHeader](Error(magicRes))
            firstMagic = Value(magicRes)
            firstSize = size
        if pos + 8 + size > buf.len:
            return Err[FormatHeader](strutil.Join(["wowExport ", label, ": chunk extends past buffer"], ""))
        count = count + 1
        pos = pos + 8 + size
    var out: FormatHeader
    out.magic = firstMagic
    out.versionOrSize = firstSize
    out.chunkCount = count
    return Ok[FormatHeader](out)

fn ParseWdtMaidResourceSummary(buf: bytes.ByteBuffer): Result[WdtMaidResourceSummary] =
    if buf.len < 8:
        return Err[WdtMaidResourceSummary]("wowExport WDT MAID resource: header too small")
    if m2HasMagic(buf, 0, int32('R'), int32('E'), int32('V'), int32('M')):
        if buf.len < 12:
            return Err[WdtMaidResourceSummary]("wowExport WDT MAID split: MVER chunk too small")
        let mverSize: int32 = bytes.ReadU32LEAt(buf, 4)
        let version: int32 = bytes.ReadU32LEAt(buf, 8)
        if mverSize != 4:
            return Err[WdtMaidResourceSummary]("wowExport WDT MAID split: invalid MVER size")
        if version != 18:
            return Err[WdtMaidResourceSummary]("wowExport WDT MAID split: invalid MVER version")
        var out: WdtMaidResourceSummary
        out.formatKind = "adt_split"
        out.firstMagic = "REVM"
        out.version = version
        if buf.len >= 16:
            let secondRes: Result[str] = formatFourCCTextAt(buf, 12)
            if IsErr(secondRes):
                return Err[WdtMaidResourceSummary](Error(secondRes))
            out.secondMagic = Value(secondRes)
        return Ok[WdtMaidResourceSummary](out)
    if m2HasMagic(buf, 0, int32('B'), int32('L'), int32('P'), int32('2')):
        let version: int32 = bytes.ReadU32LEAt(buf, 4)
        if version <= 0:
            return Err[WdtMaidResourceSummary]("wowExport WDT MAID BLP: invalid version")
        var out: WdtMaidResourceSummary
        out.formatKind = "blp"
        out.firstMagic = "BLP2"
        out.version = version
        return Ok[WdtMaidResourceSummary](out)
    return Err[WdtMaidResourceSummary]("wowExport WDT MAID resource: unsupported magic")

fn wdtMaidApplyDoodadPlacementRecord(out: var WdtMaidAdtSplitSummary,
                                     buf: bytes.ByteBuffer,
                                     rec: int32): Result[bool] =
    if rec < 0 || rec + adtMddfStride > buf.len:
        return Err[bool]("wowExport WDT MAID split: MDDF record out of bounds")
    let nameID: int32 = bytes.ReadU32LEAt(buf, rec)
    let uniqueID: int32 = bytes.ReadU32LEAt(buf, rec + 4)
    let xRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 8, "WDT MAID MDDF x")
    let yRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 12, "WDT MAID MDDF y")
    let zRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 16, "WDT MAID MDDF z")
    let rxRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 20, "WDT MAID MDDF rotation x")
    let ryRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 24, "WDT MAID MDDF rotation y")
    let rzRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 28, "WDT MAID MDDF rotation z")
    if IsErr(xRes): return Err[bool](Error(xRes))
    if IsErr(yRes): return Err[bool](Error(yRes))
    if IsErr(zRes): return Err[bool](Error(zRes))
    if IsErr(rxRes): return Err[bool](Error(rxRes))
    if IsErr(ryRes): return Err[bool](Error(ryRes))
    if IsErr(rzRes): return Err[bool](Error(rzRes))
    let scale: int32 = bytes.ReadU16LEAt(buf, rec + 32)
    if scale <= 0:
        return Err[bool]("wowExport WDT MAID split: MDDF scale is not positive")
    let x: int32 = Value(xRes)
    let y: int32 = Value(yRes)
    let z: int32 = Value(zRes)
    if out.doodadPlacementCount == 0:
        out.firstDoodadNameID = nameID
        out.firstDoodadUniqueID = uniqueID
        out.doodadPlacementPositionBoundsReady = true
        out.minDoodadPlacementX1000 = x
        out.maxDoodadPlacementX1000 = x
        out.minDoodadPlacementY1000 = y
        out.maxDoodadPlacementY1000 = y
        out.minDoodadPlacementZ1000 = z
        out.maxDoodadPlacementZ1000 = z
        out.minDoodadScale = scale
        out.maxDoodadScale = scale
    else:
        if x < out.minDoodadPlacementX1000: out.minDoodadPlacementX1000 = x
        if x > out.maxDoodadPlacementX1000: out.maxDoodadPlacementX1000 = x
        if y < out.minDoodadPlacementY1000: out.minDoodadPlacementY1000 = y
        if y > out.maxDoodadPlacementY1000: out.maxDoodadPlacementY1000 = y
        if z < out.minDoodadPlacementZ1000: out.minDoodadPlacementZ1000 = z
        if z > out.maxDoodadPlacementZ1000: out.maxDoodadPlacementZ1000 = z
        if scale < out.minDoodadScale: out.minDoodadScale = scale
        if scale > out.maxDoodadScale: out.maxDoodadScale = scale
    if !int32ListContains(out.doodadPlacementFileDataIDs, nameID):
        add(out.doodadPlacementFileDataIDs, nameID)
        if out.doodadPlacementFileDataIDs.len == 1:
            out.firstDoodadPlacementFileDataID = nameID
        out.doodadPlacementFileDataIDCount = out.doodadPlacementFileDataIDs.len
    out.doodadPlacementCount = out.doodadPlacementCount + 1
    return Ok[bool](true)

fn wdtMaidApplyWorldModelPlacementRecord(out: var WdtMaidAdtSplitSummary,
                                         buf: bytes.ByteBuffer,
                                         rec: int32): Result[bool] =
    if rec < 0 || rec + adtModfStride > buf.len:
        return Err[bool]("wowExport WDT MAID split: MODF record out of bounds")
    let nameID: int32 = bytes.ReadU32LEAt(buf, rec)
    let uniqueID: int32 = bytes.ReadU32LEAt(buf, rec + 4)
    let xRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 8, "WDT MAID MODF x")
    let yRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 12, "WDT MAID MODF y")
    let zRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 16, "WDT MAID MODF z")
    let rxRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 20, "WDT MAID MODF rotation x")
    let ryRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 24, "WDT MAID MODF rotation y")
    let rzRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 28, "WDT MAID MODF rotation z")
    let minXRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 32, "WDT MAID MODF min x")
    let minYRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 36, "WDT MAID MODF min y")
    let minZRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 40, "WDT MAID MODF min z")
    let maxXRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 44, "WDT MAID MODF max x")
    let maxYRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 48, "WDT MAID MODF max y")
    let maxZRes: Result[int32] = finiteF32Scaled1000At(buf, rec + 52, "WDT MAID MODF max z")
    if IsErr(xRes): return Err[bool](Error(xRes))
    if IsErr(yRes): return Err[bool](Error(yRes))
    if IsErr(zRes): return Err[bool](Error(zRes))
    if IsErr(rxRes): return Err[bool](Error(rxRes))
    if IsErr(ryRes): return Err[bool](Error(ryRes))
    if IsErr(rzRes): return Err[bool](Error(rzRes))
    if IsErr(minXRes): return Err[bool](Error(minXRes))
    if IsErr(minYRes): return Err[bool](Error(minYRes))
    if IsErr(minZRes): return Err[bool](Error(minZRes))
    if IsErr(maxXRes): return Err[bool](Error(maxXRes))
    if IsErr(maxYRes): return Err[bool](Error(maxYRes))
    if IsErr(maxZRes): return Err[bool](Error(maxZRes))
    let scale: int32 = bytes.ReadU16LEAt(buf, rec + 62)
    if scale <= 0:
        return Err[bool]("wowExport WDT MAID split: MODF scale is not positive")
    let x: int32 = Value(xRes)
    let y: int32 = Value(yRes)
    let z: int32 = Value(zRes)
    if out.worldModelPlacementCount == 0:
        out.firstWorldModelNameID = nameID
        out.firstWorldModelUniqueID = uniqueID
        out.worldModelPlacementPositionBoundsReady = true
        out.minWorldModelPlacementX1000 = x
        out.maxWorldModelPlacementX1000 = x
        out.minWorldModelPlacementY1000 = y
        out.maxWorldModelPlacementY1000 = y
        out.minWorldModelPlacementZ1000 = z
        out.maxWorldModelPlacementZ1000 = z
        out.minWorldModelScale = scale
        out.maxWorldModelScale = scale
    else:
        if x < out.minWorldModelPlacementX1000: out.minWorldModelPlacementX1000 = x
        if x > out.maxWorldModelPlacementX1000: out.maxWorldModelPlacementX1000 = x
        if y < out.minWorldModelPlacementY1000: out.minWorldModelPlacementY1000 = y
        if y > out.maxWorldModelPlacementY1000: out.maxWorldModelPlacementY1000 = y
        if z < out.minWorldModelPlacementZ1000: out.minWorldModelPlacementZ1000 = z
        if z > out.maxWorldModelPlacementZ1000: out.maxWorldModelPlacementZ1000 = z
        if scale < out.minWorldModelScale: out.minWorldModelScale = scale
        if scale > out.maxWorldModelScale: out.maxWorldModelScale = scale
    if !int32ListContains(out.worldModelPlacementFileDataIDs, nameID):
        add(out.worldModelPlacementFileDataIDs, nameID)
        if out.worldModelPlacementFileDataIDs.len == 1:
            out.firstWorldModelPlacementFileDataID = nameID
        out.worldModelPlacementFileDataIDCount = out.worldModelPlacementFileDataIDs.len
    out.worldModelPlacementCount = out.worldModelPlacementCount + 1
    return Ok[bool](true)

fn ParseWdtMaidAdtSplitSummary(buf: bytes.ByteBuffer): Result[WdtMaidAdtSplitSummary] =
    let resourceRes: Result[WdtMaidResourceSummary] = ParseWdtMaidResourceSummary(buf)
    if IsErr(resourceRes):
        return Err[WdtMaidAdtSplitSummary](Error(resourceRes))
    let resource: WdtMaidResourceSummary = Value(resourceRes)
    if resource.formatKind != "adt_split":
        return Err[WdtMaidAdtSplitSummary]("wowExport WDT MAID split: resource is not ADT split")
    var out: WdtMaidAdtSplitSummary
    out.version = resource.version
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[WdtMaidAdtSplitSummary]("wowExport WDT MAID split: truncated chunk header")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[WdtMaidAdtSplitSummary](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[WdtMaidAdtSplitSummary]("wowExport WDT MAID split: chunk out of bounds")
        out.chunkCount = out.chunkCount + 1
        if pos == 0:
            if magic != "REVM" || size != 4 || bytes.ReadU32LEAt(buf, dataPos) != 18:
                return Err[WdtMaidAdtSplitSummary]("wowExport WDT MAID split: invalid MVER chunk")
        else:
            if strings.Len(out.firstDataMagic) == 0:
                out.firstDataMagic = magic
            if magic == "KNCM":
                out.mapChunkCount = out.mapChunkCount + 1
            elif magic == "FDDM":
                if (size % adtMddfStride) != 0:
                    return Err[WdtMaidAdtSplitSummary]("wowExport WDT MAID split: MDDF chunk size invalid")
                var i: int32
                for i in i..<size / adtMddfStride:
                    let applyRes: Result[bool] =
                        wdtMaidApplyDoodadPlacementRecord(out, buf, dataPos + i * adtMddfStride)
                    if IsErr(applyRes):
                        return Err[WdtMaidAdtSplitSummary](Error(applyRes))
            elif magic == "FDOM":
                if (size % adtModfStride) != 0:
                    return Err[WdtMaidAdtSplitSummary]("wowExport WDT MAID split: MODF chunk size invalid")
                var i: int32
                for i in i..<size / adtModfStride:
                    let applyRes: Result[bool] =
                        wdtMaidApplyWorldModelPlacementRecord(out, buf, dataPos + i * adtModfStride)
                    if IsErr(applyRes):
                        return Err[WdtMaidAdtSplitSummary](Error(applyRes))
        pos = dataPos + size
    if strings.Len(out.firstDataMagic) == 0:
        return Err[WdtMaidAdtSplitSummary]("wowExport WDT MAID split: data chunks missing")
    return Ok[WdtMaidAdtSplitSummary](out)

fn WdtMaidDoodadPlacementSpanX1000(summary: WdtMaidAdtSplitSummary): int32 =
    return summary.maxDoodadPlacementX1000 - summary.minDoodadPlacementX1000

fn WdtMaidDoodadPlacementSpanY1000(summary: WdtMaidAdtSplitSummary): int32 =
    return summary.maxDoodadPlacementY1000 - summary.minDoodadPlacementY1000

fn WdtMaidDoodadPlacementSpanZ1000(summary: WdtMaidAdtSplitSummary): int32 =
    return summary.maxDoodadPlacementZ1000 - summary.minDoodadPlacementZ1000

fn WdtMaidWorldModelPlacementSpanX1000(summary: WdtMaidAdtSplitSummary): int32 =
    return summary.maxWorldModelPlacementX1000 - summary.minWorldModelPlacementX1000

fn WdtMaidWorldModelPlacementSpanY1000(summary: WdtMaidAdtSplitSummary): int32 =
    return summary.maxWorldModelPlacementY1000 - summary.minWorldModelPlacementY1000

fn WdtMaidWorldModelPlacementSpanZ1000(summary: WdtMaidAdtSplitSummary): int32 =
    return summary.maxWorldModelPlacementZ1000 - summary.minWorldModelPlacementZ1000

fn ParseWdtSummary(buf: bytes.ByteBuffer): Result[WdtSummary] =
    let headerRes: Result[FormatHeader] = ParseChunkedHeader(buf, "WDT")
    if IsErr(headerRes):
        return Err[WdtSummary](Error(headerRes))
    var out: WdtSummary
    out.header = Value(headerRes)
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[WdtSummary]("wowExport WDT: truncated chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[WdtSummary](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if dataPos + size > buf.len:
            return Err[WdtSummary]("wowExport WDT: chunk out of bounds")
        if magic == "NIAM":
            if (size % 8) != 0:
                return Err[WdtSummary]("wowExport WDT: MAIN chunk size invalid")
            out.mainEntryCount = size / 8
            var i: int32
            for i in i..<out.mainEntryCount:
                let entryPos: int32 = dataPos + i * 8
                let flags: int32 = bytes.ReadU32LEAt(buf, entryPos)
                let asyncId: int32 = bytes.ReadU32LEAt(buf, entryPos + 4)
                if flags != 0 || asyncId != 0:
                    out.activeTileCount = out.activeTileCount + 1
        elif magic == "FDOM":
            if (size % 64) != 0:
                return Err[WdtSummary]("wowExport WDT: MODF chunk size invalid")
            out.modelPlacementCount = size / 64
        elif magic == "DIAM":
            if (size % 32) != 0:
                return Err[WdtSummary]("wowExport WDT: MAID chunk size invalid")
            out.maidEntryCount = size / 32
            var entryIndex: int32
            for entryIndex in range(out.maidEntryCount):

                var slot: int32
                for slot in slot..<8:
                    let fileDataID: int32 = bytes.ReadU32LEAt(buf, dataPos + entryIndex * 32 + slot * 4)
                    if fileDataID > 0:
                        if out.firstMaidFileDataID == 0:
                            out.firstMaidFileDataID = fileDataID
                        out.maidReferencedFileCount = out.maidReferencedFileCount + 1

        pos = dataPos + size
    if out.mainEntryCount <= 0:
        return Err[WdtSummary]("wowExport WDT: MAIN chunk missing")
    return Ok[WdtSummary](out)

fn ParseWdtMaidTileFileDataIDs(buf: bytes.ByteBuffer,
                               tileX: int32,
                               tileY: int32): Result[WdtMaidTile] =
    if tileX < 0 || tileX >= 64 || tileY < 0 || tileY >= 64:
        return Err[WdtMaidTile]("wowExport WDT: MAID tile coordinate out of range")
    let headerRes: Result[FormatHeader] = ParseChunkedHeader(buf, "WDT")
    if IsErr(headerRes):
        return Err[WdtMaidTile](Error(headerRes))
    var out: WdtMaidTile
    out.tileX = tileX
    out.tileY = tileY
    let entryIndex: int32 = tileY * 64 + tileX
    var found: bool
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[WdtMaidTile]("wowExport WDT: truncated chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[WdtMaidTile](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[WdtMaidTile]("wowExport WDT: chunk out of bounds")
        if magic == "DIAM":
            if found:
                return Err[WdtMaidTile]("wowExport WDT: duplicate MAID chunk")
            if (size % 32) != 0:
                return Err[WdtMaidTile]("wowExport WDT: MAID chunk size invalid")
            let entryCount: int32 = size / 32
            if entryIndex >= entryCount:
                return Err[WdtMaidTile]("wowExport WDT: MAID tile entry missing")
            let entryPos: int32 = dataPos + entryIndex * 32
            var slot: int32
            for slot in slot..<8:
                let fileDataID: int32 = bytes.ReadU32LEAt(buf, entryPos + slot * 4)
                add(out.fileDataIDs, fileDataID)
                if fileDataID > 0:
                    if out.firstFileDataID == 0:
                        out.firstFileDataID = fileDataID
                    out.fileDataIDCount = out.fileDataIDCount + 1
            found = true
        pos = dataPos + size
    if !found:
        return Err[WdtMaidTile]("wowExport WDT: MAID chunk missing")
    return Ok[WdtMaidTile](out)

fn WdtMaidTileText(tile: WdtMaidTile): str =
    let xText: str = strings.IntToStr(tile.tileX)
    let yText: str = strings.IntToStr(tile.tileY)
    let countText: str = strings.IntToStr(tile.fileDataIDCount)
    let firstText: str = strings.IntToStr(tile.firstFileDataID)
    var idsText: str
    var i: int32
    for i in i..<tile.fileDataIDs.len:
        if i > 0:
            idsText = strutil.Join([idsText, ","], "")
        idsText = strutil.Join([idsText, strings.IntToStr(tile.fileDataIDs[i])], "")
    return Fmt"tile={xText},{yText} maidFileDataIDs={countText} firstFileDataID={firstText} slots={idsText}"

fn ParseWmoRootSummary(buf: bytes.ByteBuffer): Result[WmoRootSummary] =
    let headerRes: Result[FormatHeader] = ParseChunkedHeader(buf, "WMO")
    if IsErr(headerRes):
        return Err[WmoRootSummary](Error(headerRes))
    var out: WmoRootSummary
    out.header = Value(headerRes)
    var modelSlots: int32[]
    var doodadModelSlots: int32[]
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[WmoRootSummary]("wowExport WMO: truncated chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[WmoRootSummary](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[WmoRootSummary]("wowExport WMO: chunk out of bounds")
        if magic == "DHOM":
            if size < 28:
                return Err[WmoRootSummary]("wowExport WMO: MOHD chunk too small")
            out.materialCount = bytes.ReadU32LEAt(buf, dataPos)
            out.groupCount = bytes.ReadU32LEAt(buf, dataPos + 4)
            out.portalCount = bytes.ReadU32LEAt(buf, dataPos + 8)
            out.lightCount = bytes.ReadU32LEAt(buf, dataPos + 12)
            out.modelCount = bytes.ReadU32LEAt(buf, dataPos + 16)
            out.doodadCount = bytes.ReadU32LEAt(buf, dataPos + 20)
            out.doodadSetCount = bytes.ReadU32LEAt(buf, dataPos + 24)
        elif magic == "DIFG":
            if (size % 4) != 0:
                return Err[WmoRootSummary]("wowExport WMO: GFID chunk size invalid")
            out.groupFileDataIDCount = size / 4
            if out.groupFileDataIDCount > 0:
                out.firstGroupFileDataID = bytes.ReadU32LEAt(buf, dataPos)
        elif magic == "IDOM":
            if (size % 4) != 0:
                return Err[WmoRootSummary]("wowExport WMO: MODI chunk size invalid")
            out.modelSlotCount = size / 4
            var i: int32
            for i in i..<out.modelSlotCount:
                let fileDataID: int32 = bytes.ReadU32LEAt(buf, dataPos + i * 4)
                add(modelSlots, fileDataID)
                if fileDataID > 0:
                    if out.firstModelFileDataID == 0:
                        out.firstModelFileDataID = fileDataID
                    out.modelFileDataIDCount = out.modelFileDataIDCount + 1
        elif magic == "SDOM":
            if (size % wmoDoodadSetStride) != 0:
                return Err[WmoRootSummary]("wowExport WMO: MODS chunk size invalid")
            out.doodadSetDefinitionCount = size / wmoDoodadSetStride
            var i: int32
            for i in i..<out.doodadSetDefinitionCount:
                let entryPos: int32 = dataPos + i * wmoDoodadSetStride
                let firstIndex: int32 = bytes.ReadU32LEAt(buf, entryPos + 20)
                let count: int32 = bytes.ReadU32LEAt(buf, entryPos + 24)
                if firstIndex < 0 || count < 0:
                    return Err[WmoRootSummary]("wowExport WMO: MODS negative range")
                out.doodadSetPlacementCount = out.doodadSetPlacementCount + count
        elif magic == "DDOM":
            if (size % wmoDoodadPlacementStride) != 0:
                return Err[WmoRootSummary]("wowExport WMO: MODD chunk size invalid")
            out.doodadPlacementCount = size / wmoDoodadPlacementStride
            var i: int32
            for i in i..<out.doodadPlacementCount:
                let entryPos: int32 = dataPos + i * wmoDoodadPlacementStride
                let nameIndex: int32 = bytes.ReadU32LEAt(buf, entryPos) & 0x00ffffff
                add(doodadModelSlots, nameIndex)
                let x: int32 = m2F32Scaled1000At(buf, entryPos + 4)
                let y: int32 = m2F32Scaled1000At(buf, entryPos + 8)
                let z: int32 = m2F32Scaled1000At(buf, entryPos + 12)
                if i == 0:
                    out.firstDoodadNameIndex = nameIndex
                    out.doodadBoundsReady = true
                    out.minDoodadX1000 = x
                    out.maxDoodadX1000 = x
                    out.minDoodadY1000 = y
                    out.maxDoodadY1000 = y
                    out.minDoodadZ1000 = z
                    out.maxDoodadZ1000 = z
                else:
                    if x < out.minDoodadX1000: out.minDoodadX1000 = x
                    if x > out.maxDoodadX1000: out.maxDoodadX1000 = x
                    if y < out.minDoodadY1000: out.minDoodadY1000 = y
                    if y > out.maxDoodadY1000: out.maxDoodadY1000 = y
                    if z < out.minDoodadZ1000: out.minDoodadZ1000 = z
                    if z > out.maxDoodadZ1000: out.maxDoodadZ1000 = z
        pos = dataPos + size
    if out.groupCount <= 0:
        return Err[WmoRootSummary]("wowExport WMO: MOHD group count missing")
    if out.doodadSetDefinitionCount > 0 && out.doodadSetPlacementCount != out.doodadPlacementCount:
        return Err[WmoRootSummary]("wowExport WMO: doodad set placement count mismatch")
    let resolvedRes: Result[int32[]] = wmoResolveDoodadModelSlots(modelSlots, doodadModelSlots)
    if IsErr(resolvedRes):
        return Err[WmoRootSummary](Error(resolvedRes))
    let resolvedModels: int32[] = Value(resolvedRes)
    out.doodadResolvedModelPlacementCount = resolvedModels.len
    var referencedModels: int32[]
    var modelIndex: int32
    for modelIndex in modelIndex..<resolvedModels.len:
        let fileDataID: int32 = resolvedModels[modelIndex]
        if out.firstDoodadModelFileDataID == 0:
            out.firstDoodadModelFileDataID = fileDataID
        if !int32ListContains(referencedModels, fileDataID):
            add(referencedModels, fileDataID)
            out.doodadReferencedModelFileDataIDCount = out.doodadReferencedModelFileDataIDCount + 1
    return Ok[WmoRootSummary](out)

fn ParseWmoModelFileDataIDs(buf: bytes.ByteBuffer): Result[int32[]] =
    let headerRes: Result[FormatHeader] = ParseChunkedHeader(buf, "WMO")
    if IsErr(headerRes):
        return Err[int32[]](Error(headerRes))
    var out: int32[]
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[int32[]]("wowExport WMO: truncated chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[int32[]](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[int32[]]("wowExport WMO: chunk out of bounds")
        if magic == "IDOM":
            if (size % 4) != 0:
                return Err[int32[]]("wowExport WMO: MODI chunk size invalid")
            var i: int32
            for i in i..<size / 4:
                let fileDataID: int32 = bytes.ReadU32LEAt(buf, dataPos + i * 4)
                if fileDataID > 0:
                    add(out, fileDataID)
        pos = dataPos + size
    if out.len <= 0:
        return Err[int32[]]("wowExport WMO: MODI model fileDataIDs missing")
    return Ok[int32[]](out)

fn ParseWmoDoodadModelFileDataIDs(buf: bytes.ByteBuffer): Result[int32[]] =
    let headerRes: Result[FormatHeader] = ParseChunkedHeader(buf, "WMO")
    if IsErr(headerRes):
        return Err[int32[]](Error(headerRes))
    var modelSlots: int32[]
    var doodadSlots: int32[]
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[int32[]]("wowExport WMO: truncated chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[int32[]](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[int32[]]("wowExport WMO: chunk out of bounds")
        if magic == "IDOM":
            if (size % 4) != 0:
                return Err[int32[]]("wowExport WMO: MODI chunk size invalid")
            var i: int32
            for i in i..<size / 4:
                add(modelSlots, bytes.ReadU32LEAt(buf, dataPos + i * 4))
        elif magic == "DDOM":
            if (size % wmoDoodadPlacementStride) != 0:
                return Err[int32[]]("wowExport WMO: MODD chunk size invalid")
            var i: int32
            for i in i..<size / wmoDoodadPlacementStride:
                add(doodadSlots, bytes.ReadU32LEAt(buf, dataPos + i * wmoDoodadPlacementStride) & 0x00ffffff)
        pos = dataPos + size
    let resolvedRes: Result[int32[]] = wmoResolveDoodadModelSlots(modelSlots, doodadSlots)
    if IsErr(resolvedRes):
        return Err[int32[]](Error(resolvedRes))
    let resolved: int32[] = Value(resolvedRes)
    if resolved.len <= 0:
        return Err[int32[]]("wowExport WMO: MODD doodad model fileDataIDs missing")
    return Ok[int32[]](resolved)

fn wmoGroupApplyChunk(magic: str,
                      size: int32,
                      summary: var WmoGroupSummary): Result[bool] =
    if magic == "TVOM":
        if (size % 12) != 0:
            return Err[bool]("wowExport WMO group: MOVT chunk size invalid")
        summary.vertexCount = size / 12
    elif magic == "IVOM":
        if (size % 2) != 0:
            return Err[bool]("wowExport WMO group: MOVI chunk size invalid")
        summary.indexCount = size / 2
    elif magic == "ABOM":
        if (size % 24) != 0:
            return Err[bool]("wowExport WMO group: MOBA chunk size invalid")
        summary.batchCount = size / 24
    elif magic == "YPOM":
        if (size % 2) != 0:
            return Err[bool]("wowExport WMO group: MOPY chunk size invalid")
        summary.materialInfoCount = size / 2
    return Ok[bool](true)

fn wmoGroupParseNestedChunks(buf: bytes.ByteBuffer,
                             start: int32,
                             end: int32,
                             summary: var WmoGroupSummary): Result[bool] =
    if start < 0 || end < start || end > buf.len:
        return Err[bool]("wowExport WMO group: nested range out of bounds")
    var pos: int32 = start
    while pos < end:
        if pos + 8 > end:
            return Err[bool]("wowExport WMO group: truncated nested chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[bool](Error(magicRes))
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > end:
            return Err[bool]("wowExport WMO group: nested chunk out of bounds")
        let applyRes: Result[bool] = wmoGroupApplyChunk(Value(magicRes), size, summary)
        if IsErr(applyRes):
            return Err[bool](Error(applyRes))
        pos = dataPos + size
    return Ok[bool](true)

fn ParseWmoGroupSummary(buf: bytes.ByteBuffer): Result[WmoGroupSummary] =
    let headerRes: Result[FormatHeader] = ParseChunkedHeader(buf, "WMO group")
    if IsErr(headerRes):
        return Err[WmoGroupSummary](Error(headerRes))
    var out: WmoGroupSummary
    out.header = Value(headerRes)
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[WmoGroupSummary]("wowExport WMO group: truncated chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[WmoGroupSummary](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[WmoGroupSummary]("wowExport WMO group: chunk out of bounds")
        if magic == "PGOM":
            if size < 68:
                return Err[WmoGroupSummary]("wowExport WMO group: MOGP header too small")
            let nestedRes: Result[bool] =
                wmoGroupParseNestedChunks(buf, dataPos + 68, dataPos + size, out)
            if IsErr(nestedRes):
                return Err[WmoGroupSummary](Error(nestedRes))
        else:
            let applyRes: Result[bool] = wmoGroupApplyChunk(magic, size, out)
            if IsErr(applyRes):
                return Err[WmoGroupSummary](Error(applyRes))
        pos = dataPos + size
    if out.vertexCount <= 0:
        return Err[WmoGroupSummary]("wowExport WMO group: MOVT vertex data missing")
    if out.indexCount <= 0:
        return Err[WmoGroupSummary]("wowExport WMO group: MOVI index data missing")
    return Ok[WmoGroupSummary](out)

fn adtApplyHeightSample(summary: var AdtTerrainSummary, height1000: int32) =
    if summary.heightSampleCount == 0:
        summary.minHeight1000 = height1000
        summary.maxHeight1000 = height1000
    else:
        if height1000 < summary.minHeight1000: summary.minHeight1000 = height1000
        if height1000 > summary.maxHeight1000: summary.maxHeight1000 = height1000
    summary.heightSampleCount = summary.heightSampleCount + 1

fn adtParseMcvT(buf: bytes.ByteBuffer,
                start: int32,
                size: int32,
                baseZ1000: int32,
                summary: var AdtTerrainSummary): Result[bool] =
    if size != adtMcvTByteCount:
        return Err[bool]("wowExport ADT: MCVT height chunk size invalid")
    if start < 0 || start + size > buf.len:
        return Err[bool]("wowExport ADT: MCVT height chunk out of bounds")
    var i: int32
    for i in i..<adtHeightSamplesPerChunk:
        let sample1000: int32 = baseZ1000 + m2F32Scaled1000At(buf, start + i * 4)
        adtApplyHeightSample(summary, sample1000)
    return Ok[bool](true)

fn adtParseMcnkNestedChunks(buf: bytes.ByteBuffer,
                            start: int32,
                            end: int32,
                            baseZ1000: int32,
                            summary: var AdtTerrainSummary): Result[bool] =
    if start < 0 || end < start || end > buf.len:
        return Err[bool]("wowExport ADT: MCNK nested range out of bounds")
    var foundHeight: bool
    var pos: int32 = start
    while pos < end:
        if pos + 8 > end:
            return Err[bool]("wowExport ADT: truncated MCNK nested chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[bool](Error(magicRes))
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > end:
            return Err[bool]("wowExport ADT: MCNK nested chunk out of bounds")
        if Value(magicRes) == "TVCM":
            if foundHeight:
                return Err[bool]("wowExport ADT: duplicate MCVT height chunk")
            let heightRes: Result[bool] = adtParseMcvT(buf, dataPos, size, baseZ1000, summary)
            if IsErr(heightRes):
                return Err[bool](Error(heightRes))
            summary.heightChunkCount = summary.heightChunkCount + 1
            foundHeight = true
        pos = dataPos + size
    if !foundHeight:
        return Err[bool]("wowExport ADT: MCNK missing MCVT height chunk")
    return Ok[bool](true)

fn ParseAdtTerrainSummary(buf: bytes.ByteBuffer): Result[AdtTerrainSummary] =
    let headerRes: Result[FormatHeader] = ParseChunkedHeader(buf, "ADT")
    if IsErr(headerRes):
        return Err[AdtTerrainSummary](Error(headerRes))
    var out: AdtTerrainSummary
    out.header = Value(headerRes)
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[AdtTerrainSummary]("wowExport ADT: truncated chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[AdtTerrainSummary](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[AdtTerrainSummary]("wowExport ADT: chunk out of bounds")
        if magic == "KNCM":
            if size < adtMcnkHeaderBytes:
                return Err[AdtTerrainSummary]("wowExport ADT: MCNK header too small")
            out.mapChunkCount = out.mapChunkCount + 1
            let baseZ1000: int32 = m2F32Scaled1000At(buf, dataPos + adtMcnkBaseZOffset)
            let nestedRes: Result[bool] =
                adtParseMcnkNestedChunks(buf,
                                         dataPos + adtMcnkHeaderBytes,
                                         dataPos + size,
                                         baseZ1000,
                                         out)
            if IsErr(nestedRes):
                return Err[AdtTerrainSummary](Error(nestedRes))
        pos = dataPos + size
    if out.mapChunkCount <= 0:
        return Err[AdtTerrainSummary]("wowExport ADT: MCNK chunks missing")
    if out.heightChunkCount != out.mapChunkCount:
        return Err[AdtTerrainSummary]("wowExport ADT: height chunk count mismatch")
    if out.heightSampleCount != out.heightChunkCount * adtHeightSamplesPerChunk:
        return Err[AdtTerrainSummary]("wowExport ADT: height sample count mismatch")
    return Ok[AdtTerrainSummary](out)

fn ParseM2DependencySummary(buf: bytes.ByteBuffer): Result[M2DependencySummary] =
    if buf.len < 8:
        return Err[M2DependencySummary]("wowExport M2 deps: file too small")
    var out: M2DependencySummary
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[M2DependencySummary]("wowExport M2 deps: truncated chunk")
        let magicRes: Result[str] = formatFourCCTextAt(buf, pos)
        if IsErr(magicRes):
            return Err[M2DependencySummary](Error(magicRes))
        let magic: str = Value(magicRes)
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[M2DependencySummary]("wowExport M2 deps: chunk out of bounds")
        if magic == "SFID":
            if (size % 4) != 0:
                return Err[M2DependencySummary]("wowExport M2 deps: SFID chunk size invalid")
            out.skinFileDataIDCount = size / 4
            if out.skinFileDataIDCount > 0:
                out.firstSkinFileDataID = bytes.ReadU32LEAt(buf, dataPos)
        elif magic == "TXID":
            if (size % 4) != 0:
                return Err[M2DependencySummary]("wowExport M2 deps: TXID chunk size invalid")
            var i: int32
            for i in i..<size / 4:
                let fileDataID: int32 = bytes.ReadU32LEAt(buf, dataPos + i * 4)
                if fileDataID > 0:
                    if out.firstTextureFileDataID == 0:
                        out.firstTextureFileDataID = fileDataID
                    out.textureFileDataIDCount = out.textureFileDataIDCount + 1
        pos = dataPos + size
    if out.skinFileDataIDCount <= 0 && out.textureFileDataIDCount <= 0:
        return Err[M2DependencySummary]("wowExport M2 deps: no dependency chunks found")
    return Ok[M2DependencySummary](out)

fn m2SkinRangeValid(offset: int32, count: int32, stride: int32, len: int32): bool =
    if offset < 0 || count < 0 || stride <= 0:
        return false
    if offset > len:
        return false
    return offset + count * stride <= len

fn ParseM2SkinSummary(buf: bytes.ByteBuffer): Result[M2SkinSummary] =
    if buf.len < 44:
        return Err[M2SkinSummary]("wowExport M2 skin: header too small")
    if !m2HasMagic(buf, 0, int32('S'), int32('K'), int32('I'), int32('N')):
        return Err[M2SkinSummary]("wowExport M2 skin: invalid magic")
    var out: M2SkinSummary
    out.indexCount = bytes.ReadU32LEAt(buf, 4)
    let indexOffset: int32 = bytes.ReadU32LEAt(buf, 8)
    out.triangleIndexCount = bytes.ReadU32LEAt(buf, 12)
    let triangleOffset: int32 = bytes.ReadU32LEAt(buf, 16)
    out.propertyCount = bytes.ReadU32LEAt(buf, 20)
    let propertyOffset: int32 = bytes.ReadU32LEAt(buf, 24)
    out.submeshCount = bytes.ReadU32LEAt(buf, 28)
    let submeshOffset: int32 = bytes.ReadU32LEAt(buf, 32)
    out.textureUnitCount = bytes.ReadU32LEAt(buf, 36)
    let textureUnitOffset: int32 = bytes.ReadU32LEAt(buf, 40)
    if out.indexCount <= 0 || out.triangleIndexCount <= 0:
        return Err[M2SkinSummary]("wowExport M2 skin: empty index data")
    if !m2SkinRangeValid(indexOffset, out.indexCount, 2, buf.len):
        return Err[M2SkinSummary]("wowExport M2 skin: index array out of bounds")
    if !m2SkinRangeValid(triangleOffset, out.triangleIndexCount, 2, buf.len):
        return Err[M2SkinSummary]("wowExport M2 skin: triangle array out of bounds")
    if !m2SkinRangeValid(propertyOffset, out.propertyCount, 4, buf.len):
        return Err[M2SkinSummary]("wowExport M2 skin: property array out of bounds")
    if !m2SkinRangeValid(submeshOffset, out.submeshCount, 48, buf.len):
        return Err[M2SkinSummary]("wowExport M2 skin: submesh array out of bounds")
    if !m2SkinRangeValid(textureUnitOffset, out.textureUnitCount, 24, buf.len):
        return Err[M2SkinSummary]("wowExport M2 skin: texture unit array out of bounds")
    return Ok[M2SkinSummary](out)

fn FormatHeaderText(header: FormatHeader): str =
    return Fmt"magic={header.magic} value={strings.IntToStr(header.versionOrSize)} chunks={strings.IntToStr(header.chunkCount)}"

fn M2HeaderText(header: M2Header): str =
    return Fmt"version={strings.IntToStr(header.version)} sequences={strings.IntToStr(header.sequenceCount)} bones={strings.IntToStr(header.boneCount)} vertices={strings.IntToStr(header.vertexCount)} vertexOffset={strings.IntToStr(header.vertexOffset)} skins={strings.IntToStr(header.skinProfileCount)} textures={strings.IntToStr(header.textureCount)}"

fn WdtSummaryText(summary: WdtSummary): str =
    let mainText: str = strings.IntToStr(summary.mainEntryCount)
    let activeText: str = strings.IntToStr(summary.activeTileCount)
    let placementText: str = strings.IntToStr(summary.modelPlacementCount)
    let maidText: str = strings.IntToStr(summary.maidEntryCount)
    let maidFileText: str = strings.IntToStr(summary.maidReferencedFileCount)
    let firstMaidText: str = strings.IntToStr(summary.firstMaidFileDataID)
    var out: str = Fmt"wdt mainEntries={mainText}"
    out = Fmt"{out} activeTiles={activeText}"
    out = Fmt"{out} modelPlacements={placementText}"
    out = Fmt"{out} maidEntries={maidText}"
    out = Fmt"{out} maidFileIDs={maidFileText}"
    out = Fmt"{out} firstMaidFileDataID={firstMaidText}"
    return out

fn WmoRootSummaryText(summary: WmoRootSummary): str =
    let matText: str = strings.IntToStr(summary.materialCount)
    let groupText: str = strings.IntToStr(summary.groupCount)
    let doodadText: str = strings.IntToStr(summary.doodadCount)
    let setText: str = strings.IntToStr(summary.doodadSetCount)
    let setDefText: str = strings.IntToStr(summary.doodadSetDefinitionCount)
    let placementText: str = strings.IntToStr(summary.doodadPlacementCount)
    let setPlacementText: str = strings.IntToStr(summary.doodadSetPlacementCount)
    let firstDoodadText: str = strings.IntToStr(summary.firstDoodadNameIndex)
    let gfidText: str = strings.IntToStr(summary.groupFileDataIDCount)
    let firstGroupText: str = strings.IntToStr(summary.firstGroupFileDataID)
    let modelIdText: str = strings.IntToStr(summary.modelFileDataIDCount)
    let firstModelText: str = strings.IntToStr(summary.firstModelFileDataID)
    var out: str = Fmt"wmo materials={matText}"
    out = Fmt"{out} groups={groupText}"
    out = Fmt"{out} doodads={doodadText}"
    out = Fmt"{out} doodadSets={setText}"
    out = Fmt"{out} doodadSetDefs={setDefText}"
    out = Fmt"{out} doodadPlacements={placementText}"
    out = Fmt"{out} doodadSetPlacements={setPlacementText}"
    out = Fmt"{out} firstDoodadNameIndex={firstDoodadText}"
    out = Fmt"{out} groupFileIDs={gfidText}"
    out = Fmt"{out} firstGroupFileDataID={firstGroupText}"
    out = Fmt"{out} modelFileIDs={modelIdText}"
    out = Fmt"{out} firstModelFileDataID={firstModelText}"
    return out

fn WmoGroupSummaryText(summary: WmoGroupSummary): str =
    let vertexText: str = strings.IntToStr(summary.vertexCount)
    let indexText: str = strings.IntToStr(summary.indexCount)
    let batchText: str = strings.IntToStr(summary.batchCount)
    let materialText: str = strings.IntToStr(summary.materialInfoCount)
    var out: str = Fmt"wmoGroup vertices={vertexText}"
    out = Fmt"{out} indices={indexText}"
    out = Fmt"{out} batches={batchText}"
    out = Fmt"{out} materialInfo={materialText}"
    return out

fn AdtTerrainSummaryText(summary: AdtTerrainSummary): str =
    let chunkText: str = strings.IntToStr(summary.mapChunkCount)
    let heightChunkText: str = strings.IntToStr(summary.heightChunkCount)
    let sampleText: str = strings.IntToStr(summary.heightSampleCount)
    let minText: str = strings.IntToStr(summary.minHeight1000)
    let maxText: str = strings.IntToStr(summary.maxHeight1000)
    var out: str = Fmt"adt mapChunks={chunkText}"
    out = Fmt"{out} heightChunks={heightChunkText}"
    out = Fmt"{out} heightSamples={sampleText}"
    out = Fmt"{out} heightMinMax1000={minText},{maxText}"
    return out

fn M2DependencySummaryText(summary: M2DependencySummary): str =
    let skinText: str = strings.IntToStr(summary.skinFileDataIDCount)
    let firstSkinText: str = strings.IntToStr(summary.firstSkinFileDataID)
    let textureText: str = strings.IntToStr(summary.textureFileDataIDCount)
    let firstTextureText: str = strings.IntToStr(summary.firstTextureFileDataID)
    var out: str = Fmt"m2Deps skinFileIDs={skinText}"
    out = Fmt"{out} firstSkinFileDataID={firstSkinText}"
    out = Fmt"{out} textureFileIDs={textureText}"
    out = Fmt"{out} firstTextureFileDataID={firstTextureText}"
    return out

fn M2SkinSummaryText(summary: M2SkinSummary): str =
    let indexText: str = strings.IntToStr(summary.indexCount)
    let triText: str = strings.IntToStr(summary.triangleIndexCount)
    let submeshText: str = strings.IntToStr(summary.submeshCount)
    let textureUnitText: str = strings.IntToStr(summary.textureUnitCount)
    var out: str = Fmt"m2Skin indices={indexText}"
    out = Fmt"{out} triangleIndices={triText}"
    out = Fmt"{out} submeshes={submeshText}"
    out = Fmt"{out} textureUnits={textureUnitText}"
    return out
