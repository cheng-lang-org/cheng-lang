fn renderDrawMaidDoodadModelInstances(tga: bytes.ByteBuffer,
                                      width: int32,
                                      height: int32,
                                      assets: RenderMaidDoodadAssets,
                                      bounds: RenderBounds,
                                      pixels: var int32): Result[bool] =
    if assets.doodadPlacements.len <= 0 || assets.doodadModels.len <= 0:
        return Err[bool]("wowExport render: no MAID doodad draw instances")
    var i: int32
    while i < assets.doodadPlacements.len:
        let placement: RenderMaidDoodadPlacement = assets.doodadPlacements[i]
        let modelIndex: int32 = renderFindDoodadModelIndex(assets.doodadModels, placement.fileDataID)
        if modelIndex < 0:
            return Err[bool](strutil.Join(["wowExport render: MAID doodad model not loaded for draw ", strings.IntToStr(placement.fileDataID)], ""))
        let drawRes: Result[bool] =
            renderDrawMaidDoodadModelInstance(tga,
                                             width,
                                             height,
                                             assets.doodadModels[modelIndex],
                                             placement,
                                             bounds,
                                             pixels)
        if IsErr(drawRes):
            return Err[bool](Error(drawRes))
        i = i + 1
    return Ok[bool](true)

fn renderScanMaidWorldModelGroupInstance(model: RenderWmoGroupModel,
                                         placement: RenderMaidWorldModelPlacement,
                                         bounds: var RenderBounds,
                                         countOut: var int32,
                                         triangleCountOut: var int32): Result[bool] =
    if model.indexCount <= 0 || (model.indexCount % 3) != 0:
        return Err[bool]("wowExport render: MAID WMO group instance index count invalid")
    if model.materialInfoCount != model.indexCount / 3:
        return Err[bool]("wowExport render: MAID WMO group instance material count mismatch")
    var transform: RenderMaidWorldModelTransform
    renderMakeMaidWorldModelTransform(placement, transform)
    var i: int32
    while i < model.vertexCount:
        let pos: int32 = model.vertexOffset + i * 12
        let xRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos, "WDT MAID WMO group x")
        let yRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 4, "WDT MAID WMO group y")
        let zRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 8, "WDT MAID WMO group z")
        if IsErr(xRes): return Err[bool](Error(xRes))
        if IsErr(yRes): return Err[bool](Error(yRes))
        if IsErr(zRes): return Err[bool](Error(zRes))
        var outX1000: int32
        var outY1000: int32
        var outZ1000: int32
        renderApplyMaidWorldModelTransform(transform,
                                           Value(xRes),
                                           Value(yRes),
                                           Value(zRes),
                                           outX1000,
                                           outY1000,
                                           outZ1000)
        renderAccumulateBounds(bounds, outX1000, outY1000, outZ1000)
        countOut = countOut + 1
        i = i + 1
    triangleCountOut = triangleCountOut + model.indexCount / 3
    return Ok[bool](true)

fn renderScanMaidWorldModelInstances(assets: RenderMaidDoodadAssets,
                                     bounds: var RenderBounds,
                                     countOut: var int32,
                                     triangleCountOut: var int32): Result[bool] =
    if assets.worldModelPlacements.len <= 0 ||
        assets.worldModelGroupRefs.len <= 0 ||
        assets.worldModelGroups.len <= 0:
        return Err[bool]("wowExport render: no MAID world-model instances")
    var placementIndex: int32
    while placementIndex < assets.worldModelPlacements.len:
        let placement: RenderMaidWorldModelPlacement = assets.worldModelPlacements[placementIndex]
        var groupCount: int32
        var refIndex: int32
        while refIndex < assets.worldModelGroupRefs.len:
            let groupRef: RenderMaidWorldModelGroupRef = assets.worldModelGroupRefs[refIndex]
            if groupRef.rootFileDataID == placement.fileDataID:
                let modelIndex: int32 =
                    renderFindWmoGroupModelIndex(assets.worldModelGroups, groupRef.groupFileDataID)
                if modelIndex < 0:
                    return Err[bool](strutil.Join(["wowExport render: MAID WMO group not loaded ", strings.IntToStr(groupRef.groupFileDataID)], ""))
                let scanRes: Result[bool] =
                    renderScanMaidWorldModelGroupInstance(assets.worldModelGroups[modelIndex],
                                                          placement,
                                                          bounds,
                                                          countOut,
                                                          triangleCountOut)
                if IsErr(scanRes):
                    return Err[bool](Error(scanRes))
                groupCount = groupCount + 1
            refIndex = refIndex + 1
        if groupCount <= 0:
            return Err[bool](strutil.Join(["wowExport render: MAID WMO placement has no groups ", strings.IntToStr(placement.fileDataID)], ""))
        placementIndex = placementIndex + 1
    return Ok[bool](true)

fn renderDrawMaidWorldModelGroupInstance(tga: bytes.ByteBuffer,
                                         width: int32,
                                         height: int32,
                                         model: RenderWmoGroupModel,
                                         placement: RenderMaidWorldModelPlacement,
                                         bounds: RenderBounds,
                                         pixels: var int32): Result[bool] =
    if model.indexCount <= 0 || (model.indexCount % 3) != 0:
        return Err[bool]("wowExport render: MAID WMO draw index count invalid")
    if model.materialInfoCount != model.indexCount / 3:
        return Err[bool]("wowExport render: MAID WMO draw material count mismatch")
    var screenX: int32[]
    var screenY: int32[]
    reserve(screenX, model.vertexCount)
    reserve(screenY, model.vertexCount)
    var transform: RenderMaidWorldModelTransform
    renderMakeMaidWorldModelTransform(placement, transform)
    var i: int32
    while i < model.vertexCount:
        let pos: int32 = model.vertexOffset + i * 12
        let xRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos, "WDT MAID WMO group x")
        let yRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 4, "WDT MAID WMO group y")
        let zRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 8, "WDT MAID WMO group z")
        if IsErr(xRes): return Err[bool](Error(xRes))
        if IsErr(yRes): return Err[bool](Error(yRes))
        if IsErr(zRes): return Err[bool](Error(zRes))
        var outX1000: int32
        var outY1000: int32
        var outZ1000: int32
        renderApplyMaidWorldModelTransform(transform,
                                           Value(xRes),
                                           Value(yRes),
                                           Value(zRes),
                                           outX1000,
                                           outY1000,
                                           outZ1000)
        let px: int32 = renderMapCoord(outX1000, bounds.minX1000, bounds.maxX1000,
                                        renderMargin, width - renderMargin - 1)
        let pyRaw: int32 = renderMapCoord(outY1000, bounds.minY1000, bounds.maxY1000,
                                           renderMargin, height - renderMargin - 1)
        add(screenX, px)
        add(screenY, height - 1 - pyRaw)
        i = i + 1
    var tri: int32
    while tri < model.indexCount / 3:
        let indexPos: int32 = model.indexOffset + tri * 6
        let i0: int32 = bytes.ReadU16LEAt(model.buf, indexPos)
        let i1: int32 = bytes.ReadU16LEAt(model.buf, indexPos + 2)
        let i2: int32 = bytes.ReadU16LEAt(model.buf, indexPos + 4)
        if i0 < 0 || i0 >= screenX.len ||
            i1 < 0 || i1 >= screenX.len ||
            i2 < 0 || i2 >= screenX.len:
            return Err[bool]("wowExport render: MAID WMO draw index out of MOVT range")
        let materialID: int32 = bytes.BufByteAt(model.buf, model.materialInfoOffset + tri * 2 + 1)
        var r: int32
        var g: int32
        var b: int32
        renderWmoMaterialColor(materialID, r, g, b)
        let px: int32 = (screenX[i0] + screenX[i1] + screenX[i2]) / 3
        let py: int32 = (screenY[i0] + screenY[i1] + screenY[i2]) / 3
        renderPlot(tga, width, height, px, py, r, g, b, pixels)
        tri = tri + 1
    return Ok[bool](true)

fn renderDrawMaidWorldModelInstances(tga: bytes.ByteBuffer,
                                     width: int32,
                                     height: int32,
                                     assets: RenderMaidDoodadAssets,
                                     bounds: RenderBounds,
                                     pixels: var int32): Result[bool] =
    if assets.worldModelPlacements.len <= 0 ||
        assets.worldModelGroupRefs.len <= 0 ||
        assets.worldModelGroups.len <= 0:
        return Err[bool]("wowExport render: no MAID world-model draw instances")
    var placementIndex: int32
    while placementIndex < assets.worldModelPlacements.len:
        let placement: RenderMaidWorldModelPlacement = assets.worldModelPlacements[placementIndex]
        var groupCount: int32
        var refIndex: int32
        while refIndex < assets.worldModelGroupRefs.len:
            let groupRef: RenderMaidWorldModelGroupRef = assets.worldModelGroupRefs[refIndex]
            if groupRef.rootFileDataID == placement.fileDataID:
                let modelIndex: int32 =
                    renderFindWmoGroupModelIndex(assets.worldModelGroups, groupRef.groupFileDataID)
                if modelIndex < 0:
                    return Err[bool](strutil.Join(["wowExport render: MAID WMO group not loaded for draw ", strings.IntToStr(groupRef.groupFileDataID)], ""))
                let drawRes: Result[bool] =
                    renderDrawMaidWorldModelGroupInstance(tga,
                                                          width,
                                                          height,
                                                          assets.worldModelGroups[modelIndex],
                                                          placement,
                                                          bounds,
                                                          pixels)
                if IsErr(drawRes):
                    return Err[bool](Error(drawRes))
                groupCount = groupCount + 1
            refIndex = refIndex + 1
        if groupCount <= 0:
            return Err[bool](strutil.Join(["wowExport render: MAID WMO placement has no draw groups ", strings.IntToStr(placement.fileDataID)], ""))
        placementIndex = placementIndex + 1
    return Ok[bool](true)

fn renderScanM2Bounds(buf: bytes.ByteBuffer,
                      bounds: var RenderBounds,
                      countOut: var int32): Result[bool] =
    let headerRes: Result[asset_formats.M2Header] = asset_formats.ParseM2Header(buf)
    if IsErr(headerRes):
        return Err[bool](Error(headerRes))
    let header: asset_formats.M2Header = Value(headerRes)
    if header.vertexOffset < 0 || header.vertexOffset + header.vertexCount * 48 > buf.len:
        return Err[bool]("wowExport render: M2 vertex array out of bounds")
    var i: int32
    while i < header.vertexCount:
        let pos: int32 = header.vertexOffset + i * 48
        let x: int32 = renderF32Scaled1000At(buf, pos)
        let y: int32 = renderF32Scaled1000At(buf, pos + 4)
        let z: int32 = renderF32Scaled1000At(buf, pos + 8)
        renderAccumulateBounds(bounds, x, y, z)
        countOut = countOut + 1
        i = i + 1
    return Ok[bool](true)

fn renderDrawM2Inset(tga: bytes.ByteBuffer,
                     width: int32,
                     height: int32,
                     buf: bytes.ByteBuffer,
                     bounds: RenderBounds,
                     pixels: var int32): Result[bool] =
    let headerRes: Result[asset_formats.M2Header] = asset_formats.ParseM2Header(buf)
    if IsErr(headerRes):
        return Err[bool](Error(headerRes))
    let header: asset_formats.M2Header = Value(headerRes)
    if header.vertexOffset < 0 || header.vertexOffset + header.vertexCount * 48 > buf.len:
        return Err[bool]("wowExport render: M2 vertex array out of bounds")
    let left: int32 = width * 2 / 3
    let right: int32 = width - renderMargin - 1
    let top: int32 = renderMargin
    let bottom: int32 = height / 3
    var i: int32
    while i < header.vertexCount:
        let pos: int32 = header.vertexOffset + i * 48
        let x1000: int32 = renderF32Scaled1000At(buf, pos)
        let y1000: int32 = renderF32Scaled1000At(buf, pos + 4)
        let px: int32 = renderMapCoord(x1000, bounds.minX1000, bounds.maxX1000, left, right)
        let py: int32 = renderMapCoord(y1000, bounds.minY1000, bounds.maxY1000, bottom, top)
        renderPlotCross(tga, width, height, px, py, 96, 210, 240, pixels)
        i = i + 1
    return Ok[bool](true)

fn renderLoadFile(manifest: northshire.NorthshireManifest,
                  file: northshire.NorthshireAuditedFile): Result[bytes.ByteBuffer] =
    return local_files.ReadLocalFileByEntryCached(manifest.clientPath,
                                                  file.encodingKey,
                                                  file.archiveIndex,
                                                  file.offset,
                                                  file.size)

fn renderCheckWdtMaidTileDependencies(summary: var RenderSummary,
                                      manifest: northshire.NorthshireManifest,
                                      buf: bytes.ByteBuffer,
                                      sourceLabel: str,
                                      tileX: int32,
                                      tileY: int32): Result[bool] =
    let tileRes: Result[asset_formats.WdtMaidTile] =
        asset_formats.ParseWdtMaidTileFileDataIDs(buf, tileX, tileY)
    if IsErr(tileRes):
        return Err[bool](Error(tileRes))
    let tile: asset_formats.WdtMaidTile = Value(tileRes)
    if tile.fileDataIDs.len != 8:
        return Err[bool]("wowExport render: WDT MAID tile slot count mismatch")
    var slot: int32 = 1
    while slot < tile.fileDataIDs.len:
        let fileDataID: int32 = tile.fileDataIDs[slot]
        if fileDataID > 0:
            if !northshire.HasDependencyFileDataID(manifest, sourceLabel, "wdt_maid_split", fileDataID):
                return Err[bool](strutil.Join(["wowExport render: WDT MAID split dependency is not audited ", strings.IntToStr(fileDataID)], ""))
            summary.wdtMaidSplitDependencyCount = summary.wdtMaidSplitDependencyCount + 1
        slot = slot + 1
    return Ok[bool](true)

fn renderInt32ListContains(values: int32[], value: int32): bool =
    var i: int32
    while i < values.len:
        if values[i] == value:
            return true
        i = i + 1
    return false

fn renderMergeUniqueFileDataIDs(source: int32[],
                                unique: var int32[],
                                firstOut: var int32,
                                countOut: var int32): Result[bool] =
    var i: int32
    while i < source.len:
        let fileDataID: int32 = source[i]
        if fileDataID <= 0:
            return Err[bool]("wowExport render: WDT MAID placement fileDataID invalid")
        if !renderInt32ListContains(unique, fileDataID):
            add(unique, fileDataID)
            if unique.len == 1:
                firstOut = fileDataID
            countOut = unique.len
        i = i + 1
    return Ok[bool](true)

fn renderReadMaidDoodadPlacement(buf: bytes.ByteBuffer,
                                 rec: int32): Result[RenderMaidDoodadPlacement] =
    if rec < 0 || rec + renderWdtMaidMddfStride > buf.len:
        return Err[RenderMaidDoodadPlacement]("wowExport render: WDT MAID MDDF record out of bounds")
    let fileDataID: int32 = bytes.ReadU32LEAt(buf, rec)
    if fileDataID <= 0:
        return Err[RenderMaidDoodadPlacement]("wowExport render: WDT MAID MDDF fileDataID invalid")
    let xRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 8, "WDT MAID MDDF x")
    let yRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 12, "WDT MAID MDDF y")
    let zRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 16, "WDT MAID MDDF z")
    let rxRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 20, "WDT MAID MDDF rotation x")
    let ryRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 24, "WDT MAID MDDF rotation y")
    let rzRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 28, "WDT MAID MDDF rotation z")
    if IsErr(xRes): return Err[RenderMaidDoodadPlacement](Error(xRes))
    if IsErr(yRes): return Err[RenderMaidDoodadPlacement](Error(yRes))
    if IsErr(zRes): return Err[RenderMaidDoodadPlacement](Error(zRes))
    if IsErr(rxRes): return Err[RenderMaidDoodadPlacement](Error(rxRes))
    if IsErr(ryRes): return Err[RenderMaidDoodadPlacement](Error(ryRes))
    if IsErr(rzRes): return Err[RenderMaidDoodadPlacement](Error(rzRes))
    let scale: int32 = bytes.ReadU16LEAt(buf, rec + 32)
    if scale <= 0:
        return Err[RenderMaidDoodadPlacement]("wowExport render: WDT MAID MDDF scale is not positive")
    var out: RenderMaidDoodadPlacement
    out.fileDataID = fileDataID
    out.x1000 = Value(xRes)
    out.y1000 = Value(yRes)
    out.z1000 = Value(zRes)
    out.rotationX1000 = Value(rxRes)
    out.rotationY1000 = Value(ryRes)
    out.rotationZ1000 = Value(rzRes)
    out.scale1024 = scale
    return Ok[RenderMaidDoodadPlacement](out)

fn renderReadMaidWorldModelPlacement(buf: bytes.ByteBuffer,
                                     rec: int32): Result[RenderMaidWorldModelPlacement] =
    if rec < 0 || rec + renderWdtMaidModfStride > buf.len:
        return Err[RenderMaidWorldModelPlacement]("wowExport render: WDT MAID MODF record out of bounds")
    let fileDataID: int32 = bytes.ReadU32LEAt(buf, rec)
    if fileDataID <= 0:
        return Err[RenderMaidWorldModelPlacement]("wowExport render: WDT MAID MODF fileDataID invalid")
    let xRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 8, "WDT MAID MODF x")
    let yRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 12, "WDT MAID MODF y")
    let zRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 16, "WDT MAID MODF z")
    let rxRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 20, "WDT MAID MODF rotation x")
    let ryRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 24, "WDT MAID MODF rotation y")
    let rzRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 28, "WDT MAID MODF rotation z")
    if IsErr(xRes): return Err[RenderMaidWorldModelPlacement](Error(xRes))
    if IsErr(yRes): return Err[RenderMaidWorldModelPlacement](Error(yRes))
    if IsErr(zRes): return Err[RenderMaidWorldModelPlacement](Error(zRes))
    if IsErr(rxRes): return Err[RenderMaidWorldModelPlacement](Error(rxRes))
    if IsErr(ryRes): return Err[RenderMaidWorldModelPlacement](Error(ryRes))
    if IsErr(rzRes): return Err[RenderMaidWorldModelPlacement](Error(rzRes))
    let scale: int32 = bytes.ReadU16LEAt(buf, rec + 62)
    if scale <= 0:
        return Err[RenderMaidWorldModelPlacement]("wowExport render: WDT MAID MODF scale is not positive")
    var out: RenderMaidWorldModelPlacement
    out.fileDataID = fileDataID
    out.x1000 = Value(xRes)
    out.y1000 = Value(yRes)
    out.z1000 = Value(zRes)
    out.rotationX1000 = Value(rxRes)
    out.rotationY1000 = Value(ryRes)
    out.rotationZ1000 = Value(rzRes)
    out.scale1024 = scale
    return Ok[RenderMaidWorldModelPlacement](out)

fn renderCollectMaidDoodadPlacementsFromSplit(buf: bytes.ByteBuffer,
                                              placements: var RenderMaidDoodadPlacement[]): Result[int32] =
    var count: int32
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[int32]("wowExport render: WDT MAID split truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[int32]("wowExport render: WDT MAID split chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('F'), int32('D'), int32('D'), int32('M')):
            if (size % renderWdtMaidMddfStride) != 0:
                return Err[int32]("wowExport render: WDT MAID MDDF chunk size invalid")
            var i: int32
            while i < size / renderWdtMaidMddfStride:
                let placementRes: Result[RenderMaidDoodadPlacement] =
                    renderReadMaidDoodadPlacement(buf, dataPos + i * renderWdtMaidMddfStride)
                if IsErr(placementRes):
                    return Err[int32](Error(placementRes))
                add(placements, Value(placementRes))
                count = count + 1
                i = i + 1
        pos = dataPos + size
    return Ok[int32](count)

fn renderCollectMaidWorldModelPlacementsFromSplit(buf: bytes.ByteBuffer,
                                                  placements: var RenderMaidWorldModelPlacement[]): Result[int32] =
    var count: int32
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[int32]("wowExport render: WDT MAID split truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[int32]("wowExport render: WDT MAID split chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('F'), int32('D'), int32('O'), int32('M')):
            if (size % renderWdtMaidModfStride) != 0:
                return Err[int32]("wowExport render: WDT MAID MODF chunk size invalid")
            var i: int32
            while i < size / renderWdtMaidModfStride:
                let placementRes: Result[RenderMaidWorldModelPlacement] =
                    renderReadMaidWorldModelPlacement(buf, dataPos + i * renderWdtMaidModfStride)
                if IsErr(placementRes):
                    return Err[int32](Error(placementRes))
                add(placements, Value(placementRes))
                count = count + 1
                i = i + 1
        pos = dataPos + size
    return Ok[int32](count)

fn renderMergeWdtMaidSplitRecordFacts(summary: var RenderSummary,
                                      split: asset_formats.WdtMaidAdtSplitSummary): Result[bool] =
    if split.doodadPlacementCount > 0:
        if !split.doodadPlacementPositionBoundsReady:
            return Err[bool]("wowExport render: WDT MAID MDDF placement bounds missing")
        if !summary.wdtMaidDoodadPlacementBoundsReady:
            summary.wdtMaidDoodadPlacementBoundsReady = true
            summary.wdtMaidDoodadPlacementMinX1000 = split.minDoodadPlacementX1000
            summary.wdtMaidDoodadPlacementMaxX1000 = split.maxDoodadPlacementX1000
            summary.wdtMaidDoodadPlacementMinY1000 = split.minDoodadPlacementY1000
            summary.wdtMaidDoodadPlacementMaxY1000 = split.maxDoodadPlacementY1000
            summary.wdtMaidDoodadPlacementMinZ1000 = split.minDoodadPlacementZ1000
            summary.wdtMaidDoodadPlacementMaxZ1000 = split.maxDoodadPlacementZ1000
            summary.wdtMaidDoodadMinScale = split.minDoodadScale
            summary.wdtMaidDoodadMaxScale = split.maxDoodadScale
        else:
            if split.minDoodadPlacementX1000 < summary.wdtMaidDoodadPlacementMinX1000:
                summary.wdtMaidDoodadPlacementMinX1000 = split.minDoodadPlacementX1000
            if split.maxDoodadPlacementX1000 > summary.wdtMaidDoodadPlacementMaxX1000:
                summary.wdtMaidDoodadPlacementMaxX1000 = split.maxDoodadPlacementX1000
            if split.minDoodadPlacementY1000 < summary.wdtMaidDoodadPlacementMinY1000:
                summary.wdtMaidDoodadPlacementMinY1000 = split.minDoodadPlacementY1000
            if split.maxDoodadPlacementY1000 > summary.wdtMaidDoodadPlacementMaxY1000:
                summary.wdtMaidDoodadPlacementMaxY1000 = split.maxDoodadPlacementY1000
            if split.minDoodadPlacementZ1000 < summary.wdtMaidDoodadPlacementMinZ1000:
                summary.wdtMaidDoodadPlacementMinZ1000 = split.minDoodadPlacementZ1000
            if split.maxDoodadPlacementZ1000 > summary.wdtMaidDoodadPlacementMaxZ1000:
                summary.wdtMaidDoodadPlacementMaxZ1000 = split.maxDoodadPlacementZ1000
            if split.minDoodadScale < summary.wdtMaidDoodadMinScale:
                summary.wdtMaidDoodadMinScale = split.minDoodadScale
            if split.maxDoodadScale > summary.wdtMaidDoodadMaxScale:
                summary.wdtMaidDoodadMaxScale = split.maxDoodadScale
    if split.worldModelPlacementCount > 0:
        if !split.worldModelPlacementPositionBoundsReady:
            return Err[bool]("wowExport render: WDT MAID MODF placement bounds missing")
        if !summary.wdtMaidWorldModelPlacementBoundsReady:
            summary.wdtMaidWorldModelPlacementBoundsReady = true
            summary.wdtMaidWorldModelPlacementMinX1000 = split.minWorldModelPlacementX1000
            summary.wdtMaidWorldModelPlacementMaxX1000 = split.maxWorldModelPlacementX1000
            summary.wdtMaidWorldModelPlacementMinY1000 = split.minWorldModelPlacementY1000
            summary.wdtMaidWorldModelPlacementMaxY1000 = split.maxWorldModelPlacementY1000
            summary.wdtMaidWorldModelPlacementMinZ1000 = split.minWorldModelPlacementZ1000
            summary.wdtMaidWorldModelPlacementMaxZ1000 = split.maxWorldModelPlacementZ1000
            summary.wdtMaidWorldModelMinScale = split.minWorldModelScale
            summary.wdtMaidWorldModelMaxScale = split.maxWorldModelScale
        else:
            if split.minWorldModelPlacementX1000 < summary.wdtMaidWorldModelPlacementMinX1000:
                summary.wdtMaidWorldModelPlacementMinX1000 = split.minWorldModelPlacementX1000
            if split.maxWorldModelPlacementX1000 > summary.wdtMaidWorldModelPlacementMaxX1000:
                summary.wdtMaidWorldModelPlacementMaxX1000 = split.maxWorldModelPlacementX1000
            if split.minWorldModelPlacementY1000 < summary.wdtMaidWorldModelPlacementMinY1000:
                summary.wdtMaidWorldModelPlacementMinY1000 = split.minWorldModelPlacementY1000
            if split.maxWorldModelPlacementY1000 > summary.wdtMaidWorldModelPlacementMaxY1000:
                summary.wdtMaidWorldModelPlacementMaxY1000 = split.maxWorldModelPlacementY1000
            if split.minWorldModelPlacementZ1000 < summary.wdtMaidWorldModelPlacementMinZ1000:
                summary.wdtMaidWorldModelPlacementMinZ1000 = split.minWorldModelPlacementZ1000
            if split.maxWorldModelPlacementZ1000 > summary.wdtMaidWorldModelPlacementMaxZ1000:
                summary.wdtMaidWorldModelPlacementMaxZ1000 = split.maxWorldModelPlacementZ1000
            if split.minWorldModelScale < summary.wdtMaidWorldModelMinScale:
                summary.wdtMaidWorldModelMinScale = split.minWorldModelScale
            if split.maxWorldModelScale > summary.wdtMaidWorldModelMaxScale:
                summary.wdtMaidWorldModelMaxScale = split.maxWorldModelScale
    return Ok[bool](true)

fn renderLoadWdtMaidDependencyAssets(summary: var RenderSummary,
                                     manifest: northshire.NorthshireManifest,
                                     assets: var RenderMaidDoodadAssets): Result[bool] =
    var doodadFileDataIDs: int32[]
    var worldModelFileDataIDs: int32[]
    var i: int32
    while i < manifest.auditedDependencies.len:
        let dep: northshire.NorthshireAuditedDependency = manifest.auditedDependencies[i]
        if dep.relationKind == "wdt_maid_split":
            let fileRes: Result[bytes.ByteBuffer] =
                local_files.ReadLocalFileByEntryCached(manifest.clientPath,
                                                       dep.encodingKey,
                                                       dep.archiveIndex,
                                                       dep.offset,
                                                       dep.size)
            if IsErr(fileRes):
                return Err[bool](strutil.Join(["wowExport render: WDT MAID dependency load failed ", dep.label, ": ", Error(fileRes)], ""))
            let fileBuf: bytes.ByteBuffer = Value(fileRes)
            let resourceRes: Result[asset_formats.WdtMaidResourceSummary] =
                asset_formats.ParseWdtMaidResourceSummary(fileBuf)
            if IsErr(resourceRes):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(resourceRes))
            let resource: asset_formats.WdtMaidResourceSummary = Value(resourceRes)
            if resource.formatKind != dep.formatKind:
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](strutil.Join(["wowExport render: WDT MAID dependency format mismatch ", dep.label], ""))
            summary.wdtMaidParsedDependencyCount = summary.wdtMaidParsedDependencyCount + 1
            if dep.formatKind == "adt_split":
                let splitRes: Result[asset_formats.WdtMaidAdtSplitSummary] =
                    asset_formats.ParseWdtMaidAdtSplitSummary(fileBuf)
                if IsErr(splitRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(splitRes))
                let split: asset_formats.WdtMaidAdtSplitSummary = Value(splitRes)
                let placementCountRes: Result[int32] =
                    renderCollectMaidDoodadPlacementsFromSplit(fileBuf, assets.doodadPlacements)
                if IsErr(placementCountRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(placementCountRes))
                if Value(placementCountRes) != split.doodadPlacementCount:
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool]("wowExport render: WDT MAID MDDF placement collect count mismatch")
                let worldPlacementCountRes: Result[int32] =
                    renderCollectMaidWorldModelPlacementsFromSplit(fileBuf, assets.worldModelPlacements)
                if IsErr(worldPlacementCountRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(worldPlacementCountRes))
                if Value(worldPlacementCountRes) != split.worldModelPlacementCount:
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool]("wowExport render: WDT MAID MODF placement collect count mismatch")
                summary.wdtMaidAdtSplitResourceCount = summary.wdtMaidAdtSplitResourceCount + 1
                summary.wdtMaidAdtSplitChunkCount =
                    summary.wdtMaidAdtSplitChunkCount + split.chunkCount
                summary.wdtMaidAdtSplitMapChunkCount =
                    summary.wdtMaidAdtSplitMapChunkCount + split.mapChunkCount
                summary.wdtMaidDoodadPlacementCount =
                    summary.wdtMaidDoodadPlacementCount + split.doodadPlacementCount
                summary.wdtMaidWorldModelPlacementCount =
                    summary.wdtMaidWorldModelPlacementCount + split.worldModelPlacementCount
                let recordFactsRes: Result[bool] =
                    renderMergeWdtMaidSplitRecordFacts(summary, split)
                if IsErr(recordFactsRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(recordFactsRes))
                let doodadIDsRes: Result[bool] =
                    renderMergeUniqueFileDataIDs(split.doodadPlacementFileDataIDs,
                                                 doodadFileDataIDs,
                                                 summary.wdtMaidFirstDoodadReferencedFileDataID,
                                                 summary.wdtMaidDoodadReferencedFileDataIDCount)
                if IsErr(doodadIDsRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(doodadIDsRes))
                let worldIDsRes: Result[bool] =
                    renderMergeUniqueFileDataIDs(split.worldModelPlacementFileDataIDs,
                                                 worldModelFileDataIDs,
                                                 summary.wdtMaidFirstWorldModelReferencedFileDataID,
                                                 summary.wdtMaidWorldModelReferencedFileDataIDCount)
                if IsErr(worldIDsRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(worldIDsRes))
            elif dep.formatKind == "blp":
                let blpRes: Result[blp.Blp2Header] = blp.ParseBlp2Header(fileBuf)
                if IsErr(blpRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(blpRes))
                let header: blp.Blp2Header = Value(blpRes)
                if header.width <= 0 || header.height <= 0:
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool]("wowExport render: WDT MAID BLP has invalid dimensions")
                summary.wdtMaidBlpResourceCount = summary.wdtMaidBlpResourceCount + 1
            else:
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](strutil.Join(["wowExport render: unsupported WDT MAID dependency format ", dep.formatKind], ""))
            bytes.FreeByteBuffer(fileBuf)
        i = i + 1
    if summary.wdtMaidParsedDependencyCount !=
        northshire.CountDependenciesForSource(manifest, "azeroth-wdt", "wdt_maid_split"):
        return Err[bool]("wowExport render: WDT MAID parsed dependency count mismatch")
    let placementAuditRes: Result[northshire.NorthshireMaidPlacementDependencyAuditSummary] =
        northshire.AuditWdtMaidPlacementReferencesAgainstLocal(manifest,
                                                              doodadFileDataIDs,
                                                              worldModelFileDataIDs)
    if IsErr(placementAuditRes):
        return Err[bool](Error(placementAuditRes))
    let placementAudit: northshire.NorthshireMaidPlacementDependencyAuditSummary =
        Value(placementAuditRes)
    summary.wdtMaidDoodadPlacementDependencyCount = placementAudit.matchedDoodadDependencyCount
    summary.wdtMaidDoodadM2AssetCount = placementAudit.doodadM2AssetCount
    summary.wdtMaidWorldModelPlacementDependencyCount = placementAudit.matchedWorldModelDependencyCount
    summary.wdtMaidWorldModelWmoAssetCount = placementAudit.worldModelWmoAssetCount
    summary.wdtMaidPlacementDependencyEncodedBytes =
        placementAudit.doodadEncodedBytes + placementAudit.worldModelEncodedBytes
    summary.wdtMaidPlacementDependencyDecodedBytes =
        placementAudit.doodadDecodedBytes + placementAudit.worldModelDecodedBytes
    summary.wdtMaidPlacementDependencyAuditReady =
        placementAudit.matchedDoodadDependencyCount == summary.wdtMaidDoodadReferencedFileDataIDCount &&
        placementAudit.matchedWorldModelDependencyCount == summary.wdtMaidWorldModelReferencedFileDataIDCount &&
        placementAudit.doodadM2AssetCount == summary.wdtMaidDoodadReferencedFileDataIDCount &&
        placementAudit.worldModelWmoAssetCount == summary.wdtMaidWorldModelReferencedFileDataIDCount &&
        placementAudit.firstDoodadFileDataID == summary.wdtMaidFirstDoodadReferencedFileDataID &&
        placementAudit.firstWorldModelFileDataID == summary.wdtMaidFirstWorldModelReferencedFileDataID
    if assets.doodadPlacements.len != summary.wdtMaidDoodadPlacementCount:
        return Err[bool]("wowExport render: WDT MAID doodad placement instance count mismatch")
    if assets.worldModelPlacements.len != summary.wdtMaidWorldModelPlacementCount:
        return Err[bool]("wowExport render: WDT MAID world-model placement instance count mismatch")
    let maidModelsRes: Result[RenderDoodadModel[]] =
        renderLoadMaidDoodadModels(manifest, doodadFileDataIDs)
    if IsErr(maidModelsRes):
        return Err[bool](Error(maidModelsRes))
    assets.doodadModels = Value(maidModelsRes)
    var modelIndex: int32
    while modelIndex < assets.doodadModels.len:
        if assets.doodadModels[modelIndex].vertexCount > 0:
            summary.wdtMaidDoodadM2RenderableAssetCount =
                summary.wdtMaidDoodadM2RenderableAssetCount + 1
        else:
            summary.wdtMaidDoodadM2ZeroVertexAssetCount =
                summary.wdtMaidDoodadM2ZeroVertexAssetCount + 1
        modelIndex = modelIndex + 1
    summary.wdtMaidDoodadM2InstancePlacementCount = assets.doodadPlacements.len
    let groupModelsRes: Result[RenderWmoGroupModel[]] =
        renderLoadMaidWorldModelGroups(manifest,
                                       worldModelFileDataIDs,
                                       assets.worldModelGroupRefs,
                                       summary.wdtMaidWorldModelGroupReferenceCount,
                                       summary.wdtMaidWorldModelMaterialCount,
                                       summary.wdtMaidWorldModelLightCount,
                                       summary.wdtMaidWorldModelGroupBatchCount,
                                       summary.wdtMaidWorldModelGroupMaterialInfoCount,
                                       summary.wdtMaidWorldModelGroupTriangleIndexCount,
                                       summary.wdtMaidWorldModelGroupTriangleCount)
    if IsErr(groupModelsRes):
        return Err[bool](Error(groupModelsRes))
    assets.worldModelGroups = Value(groupModelsRes)
    summary.wdtMaidWorldModelGroupAssetCount = assets.worldModelGroups.len
    summary.wdtMaidWorldModelMaterialPassReady =
        summary.wdtMaidWorldModelMaterialCount > 0 &&
        summary.wdtMaidWorldModelGroupBatchCount > 0 &&
        summary.wdtMaidWorldModelGroupMaterialInfoCount > 0 &&
        summary.wdtMaidWorldModelGroupMaterialInfoCount == summary.wdtMaidWorldModelGroupTriangleCount
    summary.wdtMaidWorldModelInstancePlacementCount = assets.worldModelPlacements.len
    return Ok[bool](true)

fn renderNorthshireTgaWithDoodadModels(manifest: northshire.NorthshireManifest,
                                       doodadModels: RenderDoodadModel[],
                                       outPath: str,
                                       width: int32,
                                       height: int32): Result[RenderSummary] =
    var terrainBounds: RenderBounds
    var wmoDoodadWorldBounds: RenderBounds
    var m2Bounds: RenderBounds
    var maidDoodadBounds: RenderBounds
    var maidWorldModelBounds: RenderBounds
    var worldBounds: RenderBounds
    var maidAssets: RenderMaidDoodadAssets
    var summary: RenderSummary
    summary.outPath = outPath
    summary.width = width
    summary.height = height
    var i: int32
    while i < manifest.auditedFiles.len:
        let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[i]
        if file.kind == "wdt":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let maid31x48Res: Result[bool] =
                renderCheckWdtMaidTileDependencies(summary, manifest, buf, file.label, 31, 48)
            if IsErr(maid31x48Res):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(maid31x48Res))
            let maid32x48Res: Result[bool] =
                renderCheckWdtMaidTileDependencies(summary, manifest, buf, file.label, 32, 48)
            if IsErr(maid32x48Res):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(maid32x48Res))
            let maid31x49Res: Result[bool] =
                renderCheckWdtMaidTileDependencies(summary, manifest, buf, file.label, 31, 49)
            if IsErr(maid31x49Res):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(maid31x49Res))
            let maid32x49Res: Result[bool] =
                renderCheckWdtMaidTileDependencies(summary, manifest, buf, file.label, 32, 49)
            bytes.FreeByteBuffer(buf)
            if IsErr(maid32x49Res):
                return Err[RenderSummary](Error(maid32x49Res))
            summary.wdtMaidSplitDependenciesReady =
                summary.wdtMaidSplitDependencyCount > 0 &&
                summary.wdtMaidSplitDependencyCount == northshire.CountDependenciesForSource(manifest, file.label, "wdt_maid_split")
        elif file.kind == "adt":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let scanRes: Result[bool] =
                renderScanAdtTerrain(buf, terrainBounds, summary.adtHeightSampleCount)
            bytes.FreeByteBuffer(buf)
            if IsErr(scanRes):
                return Err[RenderSummary](Error(scanRes))
        elif file.kind == "wmo":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let wmoRes: Result[asset_formats.WmoRootSummary] = asset_formats.ParseWmoRootSummary(buf)
            if IsErr(wmoRes):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(wmoRes))
            let wmo: asset_formats.WmoRootSummary = Value(wmoRes)
            summary.wmoMaterialCount = summary.wmoMaterialCount + wmo.materialCount
            summary.wmoLightCount = summary.wmoLightCount + wmo.lightCount
            summary.wmoDoodadModelPlacementCount =
                summary.wmoDoodadModelPlacementCount + wmo.doodadResolvedModelPlacementCount
            summary.wmoDoodadReferencedModelFileDataIDCount =
                summary.wmoDoodadReferencedModelFileDataIDCount + wmo.doodadReferencedModelFileDataIDCount
            let modelIdsRes: Result[int32[]] = asset_formats.ParseWmoModelFileDataIDs(buf)
            if IsErr(modelIdsRes):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(modelIdsRes))
            let modelIds: int32[] = Value(modelIdsRes)
            var modelIndex: int32
            while modelIndex < modelIds.len:
                if !northshire.HasDependencyFileDataID(manifest, file.label, "wmo_modi", modelIds[modelIndex]):
                    bytes.FreeByteBuffer(buf)
                    return Err[RenderSummary](strutil.Join(["wowExport render: WMO MODI dependency is not audited ", strings.IntToStr(modelIds[modelIndex])], ""))
                summary.wmoDoodadModelDependencyCount = summary.wmoDoodadModelDependencyCount + 1
                modelIndex = modelIndex + 1
            let doodadModelIdsRes: Result[int32[]] = asset_formats.ParseWmoDoodadModelFileDataIDs(buf)
            if IsErr(doodadModelIdsRes):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(doodadModelIdsRes))
            let doodadModelIds: int32[] = Value(doodadModelIdsRes)
            var doodadIndex: int32
            while doodadIndex < doodadModelIds.len:
                if !northshire.HasDependencyFileDataID(manifest, file.label, "wmo_modi", doodadModelIds[doodadIndex]):
                    bytes.FreeByteBuffer(buf)
                    return Err[RenderSummary](strutil.Join(["wowExport render: WMO MODD model dependency is not audited ", strings.IntToStr(doodadModelIds[doodadIndex])], ""))
                doodadIndex = doodadIndex + 1
            let placementCountRes: Result[bool] =
                renderCountWmoDoodadPlacements(buf, summary.wmoDoodadPlacementCount)
            if IsErr(placementCountRes):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(placementCountRes))
            let modelScanRes: Result[bool] =
                renderCountWmoDoodadModelInstanceVertices(buf,
                                                          doodadModels,
                                                          summary.wmoDoodadModelVertexCount)
            bytes.FreeByteBuffer(buf)
            if IsErr(modelScanRes):
                return Err[RenderSummary](Error(modelScanRes))
        elif file.kind == "wmo_group":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let groupRes: Result[asset_formats.WmoGroupSummary] =
                asset_formats.ParseWmoGroupSummary(buf)
            if IsErr(groupRes):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(groupRes))
            let group: asset_formats.WmoGroupSummary = Value(groupRes)
            summary.wmoGroupBatchCount = summary.wmoGroupBatchCount + group.batchCount
            summary.wmoGroupMaterialInfoCount =
                summary.wmoGroupMaterialInfoCount + group.materialInfoCount
            var chunks: RenderWmoGroupChunks
            let scanRes: Result[bool] = renderFindWmoGroupChunks(buf, chunks)
            bytes.FreeByteBuffer(buf)
            if IsErr(scanRes):
                return Err[RenderSummary](Error(scanRes))
            if chunks.vertexCount != group.vertexCount ||
                chunks.indexCount != group.indexCount ||
                chunks.materialInfoCount != group.materialInfoCount ||
                chunks.batchCount != group.batchCount:
                return Err[RenderSummary]("wowExport render: WMO group material pass chunk count mismatch")
            summary.wmoGroupTriangleIndexCount =
                summary.wmoGroupTriangleIndexCount + chunks.indexCount
            summary.wmoGroupTriangleCount = summary.wmoGroupTriangleCount + chunks.indexCount / 3
            summary.wmoVertexCount = summary.wmoVertexCount + chunks.vertexCount
        elif file.kind == "m2":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let scanRes: Result[bool] = renderScanM2Bounds(buf, m2Bounds, summary.m2VertexCount)
            bytes.FreeByteBuffer(buf)
            if IsErr(scanRes):
                return Err[RenderSummary](Error(scanRes))
        elif file.kind == "skin":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let skinRes: Result[asset_formats.M2SkinSummary] = asset_formats.ParseM2SkinSummary(buf)
            bytes.FreeByteBuffer(buf)
            if IsErr(skinRes):
                return Err[RenderSummary](Error(skinRes))
            summary.skinTriangleIndexCount = summary.skinTriangleIndexCount + Value(skinRes).triangleIndexCount
        elif file.kind == "blp":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let headerRes: Result[blp.Blp2Header] = blp.ParseBlp2Header(buf)
            if IsErr(headerRes):
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary](Error(headerRes))
            let header: blp.Blp2Header = Value(headerRes)
            if header.width <= 0 || header.height <= 0:
                bytes.FreeByteBuffer(buf)
                return Err[RenderSummary]("wowExport render: BLP texture dimensions invalid")
            summary.textureFileCount = summary.textureFileCount + 1
            if header.width > summary.textureMaxWidth:
                summary.textureMaxWidth = header.width
            if header.height > summary.textureMaxHeight:
                summary.textureMaxHeight = header.height
            let tgaRes: Result[bytes.ByteBuffer] = blp.Blp2DecodeFirstMipTga(buf)
            bytes.FreeByteBuffer(buf)
            if IsErr(tgaRes):
                return Err[RenderSummary](Error(tgaRes))
            let tgaBuf: bytes.ByteBuffer = Value(tgaRes)
            summary.textureDecodedTgaBytes = summary.textureDecodedTgaBytes + tgaBuf.len
            bytes.FreeByteBuffer(tgaBuf)
        i = i + 1
    if !terrainBounds.ready || !m2Bounds.ready:
        return Err[RenderSummary]("wowExport render: missing geometry bounds")
    summary.wmoMaterialLightPassReady =
        summary.wmoMaterialCount > 0 &&
        summary.wmoGroupBatchCount > 0 &&
        summary.wmoGroupMaterialInfoCount > 0 &&
        summary.wmoGroupMaterialInfoCount == summary.wmoGroupTriangleCount
    summary.texturePassReady =
        summary.textureFileCount > 0 &&
        summary.textureMaxWidth > 0 &&
        summary.textureMaxHeight > 0 &&
        summary.textureDecodedTgaBytes > 0
    let maidDependencyRes: Result[bool] = renderLoadWdtMaidDependencyAssets(summary, manifest, maidAssets)
    if IsErr(maidDependencyRes):
        renderFreeMaidDoodadAssets(maidAssets)
        return Err[RenderSummary](Error(maidDependencyRes))
    let maidScanRes: Result[bool] =
        renderScanMaidDoodadModelInstances(maidAssets,
                                           maidDoodadBounds,
                                           summary.wdtMaidDoodadM2InstanceVertexCount)
    if IsErr(maidScanRes):
        renderFreeMaidDoodadAssets(maidAssets)
        return Err[RenderSummary](Error(maidScanRes))
    summary.wdtMaidDoodadM2InstanceBoundsReady = maidDoodadBounds.ready
    let maidWorldModelScanRes: Result[bool] =
        renderScanMaidWorldModelInstances(maidAssets,
                                          maidWorldModelBounds,
                                          summary.wdtMaidWorldModelInstanceVertexCount,
                                          summary.wdtMaidWorldModelInstanceTriangleCount)
    if IsErr(maidWorldModelScanRes):
        renderFreeMaidDoodadAssets(maidAssets)
        return Err[RenderSummary](Error(maidWorldModelScanRes))
    summary.wdtMaidWorldModelInstanceBoundsReady = maidWorldModelBounds.ready
    summary.wdtMaidWorldModelIndexedTrianglePassReady =
        summary.wdtMaidWorldModelGroupTriangleCount > 0 &&
        summary.wdtMaidWorldModelGroupTriangleIndexCount == summary.wdtMaidWorldModelGroupTriangleCount * 3 &&
        summary.wdtMaidWorldModelGroupMaterialInfoCount == summary.wdtMaidWorldModelGroupTriangleCount &&
        summary.wdtMaidWorldModelInstanceTriangleCount > 0
    i = 0
    while i < manifest.auditedFiles.len:
        let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[i]
        if file.kind == "wmo":
            let rootPlacementCount: int32 =
                renderCountMaidWorldModelPlacementsForFileDataID(maidAssets, file.fileDataID)
            if rootPlacementCount <= 0:
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](strutil.Join(["wowExport render: audited WMO root is not placed by MAID ", strings.IntToStr(file.fileDataID)], ""))
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let scanRes: Result[bool] =
                renderScanWmoRootDoodadsInWorld(buf,
                                                doodadModels,
                                                maidAssets,
                                                file.fileDataID,
                                                wmoDoodadWorldBounds,
                                                summary.wmoRootWorldPlacementCount,
                                                summary.wmoDoodadWorldPlacementCount,
                                                summary.wmoDoodadModelWorldInstanceVertexCount)
            bytes.FreeByteBuffer(buf)
            if IsErr(scanRes):
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](Error(scanRes))
        i = i + 1
    summary.wmoDoodadWorldBoundsReady = wmoDoodadWorldBounds.ready
    renderMergeBounds(worldBounds, terrainBounds)
    renderMergeBounds(worldBounds, maidDoodadBounds)
    renderMergeBounds(worldBounds, maidWorldModelBounds)
    renderMergeBounds(worldBounds, wmoDoodadWorldBounds)
    if !worldBounds.ready:
        renderFreeMaidDoodadAssets(maidAssets)
        return Err[RenderSummary]("wowExport render: missing world geometry bounds")
    if summary.wmoDoodadModelPlacementCount != summary.wmoDoodadPlacementCount ||
        summary.wmoDoodadReferencedModelFileDataIDCount <= 0 ||
        summary.wmoDoodadModelDependencyCount != northshire.CountDependenciesForSource(manifest, "northshire-abbey-wmo", "wmo_modi") ||
        summary.wmoRootWorldPlacementCount <= 0 ||
        summary.wmoDoodadWorldPlacementCount <= 0 ||
        !summary.wmoDoodadWorldBoundsReady ||
        !summary.wmoMaterialLightPassReady ||
        !summary.texturePassReady ||
        summary.wmoGroupTriangleIndexCount != summary.wmoGroupTriangleCount * 3 ||
        summary.wmoGroupMaterialInfoCount != summary.wmoGroupTriangleCount ||
        summary.wmoDoodadModelVertexCount <= 0 ||
        summary.wmoDoodadModelWorldInstanceVertexCount <= 0:
        renderFreeMaidDoodadAssets(maidAssets)
        return Err[RenderSummary]("wowExport render: WMO doodad model dependency audit mismatch")
    if summary.wdtMaidSplitDependencyCount <= 0 ||
        !summary.wdtMaidSplitDependenciesReady ||
        summary.wdtMaidParsedDependencyCount != summary.wdtMaidSplitDependencyCount ||
        summary.wdtMaidAdtSplitResourceCount <= 0 ||
        summary.wdtMaidBlpResourceCount <= 0 ||
        summary.wdtMaidAdtSplitChunkCount <= 0 ||
        summary.wdtMaidAdtSplitMapChunkCount <= 0 ||
        summary.wdtMaidDoodadPlacementCount <= 0 ||
        summary.wdtMaidDoodadReferencedFileDataIDCount <= 0 ||
        summary.wdtMaidFirstDoodadReferencedFileDataID <= 0 ||
        summary.wdtMaidDoodadPlacementDependencyCount != summary.wdtMaidDoodadReferencedFileDataIDCount ||
        summary.wdtMaidDoodadM2AssetCount != summary.wdtMaidDoodadReferencedFileDataIDCount ||
        summary.wdtMaidDoodadM2RenderableAssetCount <= 0 ||
        summary.wdtMaidDoodadM2RenderableAssetCount + summary.wdtMaidDoodadM2ZeroVertexAssetCount != summary.wdtMaidDoodadM2AssetCount ||
        summary.wdtMaidDoodadM2InstancePlacementCount != summary.wdtMaidDoodadPlacementCount ||
        summary.wdtMaidDoodadM2InstanceVertexCount <= 0 ||
        !summary.wdtMaidDoodadM2InstanceBoundsReady ||
        !summary.wdtMaidDoodadPlacementBoundsReady ||
        summary.wdtMaidDoodadPlacementMaxX1000 <= summary.wdtMaidDoodadPlacementMinX1000 ||
        summary.wdtMaidDoodadPlacementMaxY1000 <= summary.wdtMaidDoodadPlacementMinY1000 ||
        summary.wdtMaidDoodadPlacementMaxZ1000 <= summary.wdtMaidDoodadPlacementMinZ1000 ||
        summary.wdtMaidDoodadMaxScale <= 0 ||
        summary.wdtMaidWorldModelPlacementCount <= 0 ||
        summary.wdtMaidWorldModelReferencedFileDataIDCount <= 0 ||
        summary.wdtMaidFirstWorldModelReferencedFileDataID <= 0 ||
        summary.wdtMaidWorldModelPlacementDependencyCount != summary.wdtMaidWorldModelReferencedFileDataIDCount ||
        summary.wdtMaidWorldModelWmoAssetCount != summary.wdtMaidWorldModelReferencedFileDataIDCount ||
        summary.wdtMaidWorldModelGroupReferenceCount <= 0 ||
        summary.wdtMaidWorldModelGroupAssetCount <= 0 ||
        summary.wdtMaidWorldModelGroupTriangleIndexCount <= 0 ||
        summary.wdtMaidWorldModelGroupTriangleCount <= 0 ||
        summary.wdtMaidWorldModelGroupTriangleIndexCount != summary.wdtMaidWorldModelGroupTriangleCount * 3 ||
        !summary.wdtMaidWorldModelMaterialPassReady ||
        summary.wdtMaidWorldModelInstancePlacementCount != summary.wdtMaidWorldModelPlacementCount ||
        summary.wdtMaidWorldModelInstanceVertexCount <= 0 ||
        summary.wdtMaidWorldModelInstanceTriangleCount <= 0 ||
        !summary.wdtMaidWorldModelInstanceBoundsReady ||
        !summary.wdtMaidWorldModelIndexedTrianglePassReady ||
        !summary.wdtMaidPlacementDependencyAuditReady ||
        summary.wdtMaidPlacementDependencyEncodedBytes <= 0 ||
        summary.wdtMaidPlacementDependencyDecodedBytes <= 0 ||
        !summary.wdtMaidWorldModelPlacementBoundsReady ||
        summary.wdtMaidWorldModelPlacementMaxX1000 <= summary.wdtMaidWorldModelPlacementMinX1000 ||
        summary.wdtMaidWorldModelPlacementMaxY1000 <= summary.wdtMaidWorldModelPlacementMinY1000 ||
        summary.wdtMaidWorldModelPlacementMaxZ1000 <= summary.wdtMaidWorldModelPlacementMinZ1000 ||
        summary.wdtMaidWorldModelMaxScale <= 0:
        renderFreeMaidDoodadAssets(maidAssets)
        return Err[RenderSummary]("wowExport render: WDT MAID split dependency audit mismatch")
    let tgaRes: Result[bytes.ByteBuffer] = renderMakeTga(width, height)
    if IsErr(tgaRes):
        renderFreeMaidDoodadAssets(maidAssets)
        return Err[RenderSummary](Error(tgaRes))
    var tga: bytes.ByteBuffer = Value(tgaRes)
    i = 0
    while i < manifest.auditedFiles.len:
        let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[i]
        if file.kind == "adt":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                bytes.FreeByteBuffer(tga)
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let drawRes: Result[bool] =
                renderDrawAdtTerrain(tga, width, height, buf, worldBounds, summary.pixelsTouched)
            bytes.FreeByteBuffer(buf)
            if IsErr(drawRes):
                bytes.FreeByteBuffer(tga)
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](Error(drawRes))
        elif file.kind == "m2":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                bytes.FreeByteBuffer(tga)
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let drawRes: Result[bool] =
                renderDrawM2Inset(tga, width, height, buf, m2Bounds, summary.pixelsTouched)
            bytes.FreeByteBuffer(buf)
            if IsErr(drawRes):
                bytes.FreeByteBuffer(tga)
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](Error(drawRes))
        i = i + 1
    i = 0
    while i < manifest.auditedFiles.len:
        let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[i]
        if file.kind == "wmo":
            let bufRes: Result[bytes.ByteBuffer] = renderLoadFile(manifest, file)
            if IsErr(bufRes):
                bytes.FreeByteBuffer(tga)
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](Error(bufRes))
            let buf: bytes.ByteBuffer = Value(bufRes)
            let modelDrawRes: Result[bool] =
                renderDrawWmoRootDoodadsInWorld(tga,
                                                width,
                                                height,
                                                buf,
                                                doodadModels,
                                                maidAssets,
                                                file.fileDataID,
                                                worldBounds,
                                                summary.pixelsTouched)
            bytes.FreeByteBuffer(buf)
            if IsErr(modelDrawRes):
                bytes.FreeByteBuffer(tga)
                renderFreeMaidDoodadAssets(maidAssets)
                return Err[RenderSummary](Error(modelDrawRes))
        i = i + 1
    let maidDrawRes: Result[bool] =
        renderDrawMaidDoodadModelInstances(tga,
                                           width,
                                           height,
                                           maidAssets,
                                           worldBounds,
                                           summary.pixelsTouched)
    if IsErr(maidDrawRes):
        renderFreeMaidDoodadAssets(maidAssets)
        bytes.FreeByteBuffer(tga)
        return Err[RenderSummary](Error(maidDrawRes))
    let maidWorldModelDrawRes: Result[bool] =
        renderDrawMaidWorldModelInstances(tga,
                                          width,
                                          height,
                                          maidAssets,
                                          worldBounds,
                                          summary.pixelsTouched)
    renderFreeMaidDoodadAssets(maidAssets)
    if IsErr(maidWorldModelDrawRes):
        bytes.FreeByteBuffer(tga)
        return Err[RenderSummary](Error(maidWorldModelDrawRes))
    let writeRes: Result[int32] = asset_export.AssetExportWriteBufferAtomic(outPath, tga)
    bytes.FreeByteBuffer(tga)
    if IsErr(writeRes):
        return Err[RenderSummary](Error(writeRes))
    summary.bytesWritten = Value(writeRes)
    if summary.pixelsTouched <= 0:
        return Err[RenderSummary]("wowExport render: no pixels drawn")
    return Ok[RenderSummary](summary)

fn RenderNorthshireTga(outPath: str, width: int32, height: int32): Result[RenderSummary] =
    if strings.Len(outPath) == 0:
        return Err[RenderSummary]("wowExport render: missing output path")
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    if !northshire.ManifestReady(manifest):
        return Err[RenderSummary]("wowExport render: manifest not ready")
    let auditRes: Result[northshire.NorthshireAuditSummary] =
        northshire.AuditManifestPayloadsAgainstLocal(manifest)
    if IsErr(auditRes):
        return Err[RenderSummary](Error(auditRes))
    let depAuditRes: Result[northshire.NorthshireAuditSummary] =
        northshire.AuditManifestDependenciesAgainstLocal(manifest)
    if IsErr(depAuditRes):
        return Err[RenderSummary](Error(depAuditRes))
    let doodadModelsRes: Result[RenderDoodadModel[]] = renderLoadDoodadModels(manifest)
    if IsErr(doodadModelsRes):
        return Err[RenderSummary](Error(doodadModelsRes))
    var doodadModels: RenderDoodadModel[] = Value(doodadModelsRes)
    let renderRes: Result[RenderSummary] =
        renderNorthshireTgaWithDoodadModels(manifest, doodadModels, outPath, width, height)
    renderFreeDoodadModels(doodadModels)
    if IsErr(renderRes):
        return Err[RenderSummary](Error(renderRes))
    return Ok[RenderSummary](Value(renderRes))

fn RenderSummaryText(summary: RenderSummary): str =
    let widthText: str = strings.IntToStr(summary.width)
    let heightText: str = strings.IntToStr(summary.height)
    let bytesText: str = strings.IntToStr(summary.bytesWritten)
    let adtText: str = strings.IntToStr(summary.adtHeightSampleCount)
    let wmoText: str = strings.IntToStr(summary.wmoVertexCount)
    let doodadText: str = strings.IntToStr(summary.wmoDoodadPlacementCount)
    let doodadModelText: str = strings.IntToStr(summary.wmoDoodadModelPlacementCount)
    let doodadReferencedText: str = strings.IntToStr(summary.wmoDoodadReferencedModelFileDataIDCount)
    let doodadDepText: str = strings.IntToStr(summary.wmoDoodadModelDependencyCount)
    let wmoRootWorldPlacementText: str = strings.IntToStr(summary.wmoRootWorldPlacementCount)
    let wmoDoodadWorldPlacementText: str = strings.IntToStr(summary.wmoDoodadWorldPlacementCount)
    let wmoDoodadWorldBoundsText: str = summary.wmoDoodadWorldBoundsReady ? "ready" : "missing"
    let wmoDoodadModelWorldVertexText: str =
        strings.IntToStr(summary.wmoDoodadModelWorldInstanceVertexCount)
    let wmoMaterialText: str = strings.IntToStr(summary.wmoMaterialCount)
    let wmoLightText: str = strings.IntToStr(summary.wmoLightCount)
    let wmoGroupBatchText: str = strings.IntToStr(summary.wmoGroupBatchCount)
    let wmoGroupMaterialInfoText: str = strings.IntToStr(summary.wmoGroupMaterialInfoCount)
    let wmoGroupTriangleIndexText: str = strings.IntToStr(summary.wmoGroupTriangleIndexCount)
    let wmoGroupTriangleText: str = strings.IntToStr(summary.wmoGroupTriangleCount)
    let wmoMaterialPassText: str = summary.wmoMaterialLightPassReady ? "ready" : "missing"
    let textureFileText: str = strings.IntToStr(summary.textureFileCount)
    let textureWidthText: str = strings.IntToStr(summary.textureMaxWidth)
    let textureHeightText: str = strings.IntToStr(summary.textureMaxHeight)
    let textureSizeText: str = Fmt"{textureWidthText}x{textureHeightText}"
    let textureTgaBytesText: str = strings.IntToStr(summary.textureDecodedTgaBytes)
    let texturePassText: str = summary.texturePassReady ? "ready" : "missing"
    let wdtMaidSplitText: str = strings.IntToStr(summary.wdtMaidSplitDependencyCount)
    let wdtMaidSplitReadyText: str = summary.wdtMaidSplitDependenciesReady ? "ready" : "missing"
    let wdtMaidParsedText: str = strings.IntToStr(summary.wdtMaidParsedDependencyCount)
    let wdtMaidAdtSplitText: str = strings.IntToStr(summary.wdtMaidAdtSplitResourceCount)
    let wdtMaidBlpText: str = strings.IntToStr(summary.wdtMaidBlpResourceCount)
    let wdtMaidSplitChunkText: str = strings.IntToStr(summary.wdtMaidAdtSplitChunkCount)
    let wdtMaidSplitMcnkText: str = strings.IntToStr(summary.wdtMaidAdtSplitMapChunkCount)
    let wdtMaidDoodadText: str = strings.IntToStr(summary.wdtMaidDoodadPlacementCount)
    let wdtMaidWorldModelText: str = strings.IntToStr(summary.wdtMaidWorldModelPlacementCount)
    let wdtMaidDoodadRefText: str = strings.IntToStr(summary.wdtMaidDoodadReferencedFileDataIDCount)
    let wdtMaidFirstDoodadRefText: str = strings.IntToStr(summary.wdtMaidFirstDoodadReferencedFileDataID)
    let wdtMaidWorldModelRefText: str = strings.IntToStr(summary.wdtMaidWorldModelReferencedFileDataIDCount)
    let wdtMaidFirstWorldModelRefText: str = strings.IntToStr(summary.wdtMaidFirstWorldModelReferencedFileDataID)
    let wdtMaidDoodadDepText: str = strings.IntToStr(summary.wdtMaidDoodadPlacementDependencyCount)
    let wdtMaidWorldModelDepText: str = strings.IntToStr(summary.wdtMaidWorldModelPlacementDependencyCount)
    let wdtMaidDoodadM2AssetText: str = strings.IntToStr(summary.wdtMaidDoodadM2AssetCount)
    let wdtMaidDoodadM2RenderableAssetText: str =
        strings.IntToStr(summary.wdtMaidDoodadM2RenderableAssetCount)
    let wdtMaidDoodadM2ZeroVertexAssetText: str =
        strings.IntToStr(summary.wdtMaidDoodadM2ZeroVertexAssetCount)
    let wdtMaidDoodadM2InstancePlacementText: str =
        strings.IntToStr(summary.wdtMaidDoodadM2InstancePlacementCount)
    let wdtMaidDoodadM2InstanceVertexText: str =
        strings.IntToStr(summary.wdtMaidDoodadM2InstanceVertexCount)
    let wdtMaidDoodadM2InstanceBoundsText: str =
        summary.wdtMaidDoodadM2InstanceBoundsReady ? "ready" : "missing"
    let wdtMaidWorldModelWmoAssetText: str = strings.IntToStr(summary.wdtMaidWorldModelWmoAssetCount)
    let wdtMaidWorldModelGroupRefText: str = strings.IntToStr(summary.wdtMaidWorldModelGroupReferenceCount)
    let wdtMaidWorldModelGroupAssetText: str = strings.IntToStr(summary.wdtMaidWorldModelGroupAssetCount)
    let wdtMaidWorldModelMaterialText: str = strings.IntToStr(summary.wdtMaidWorldModelMaterialCount)
    let wdtMaidWorldModelLightText: str = strings.IntToStr(summary.wdtMaidWorldModelLightCount)
    let wdtMaidWorldModelGroupBatchText: str = strings.IntToStr(summary.wdtMaidWorldModelGroupBatchCount)
    let wdtMaidWorldModelGroupMaterialInfoText: str =
        strings.IntToStr(summary.wdtMaidWorldModelGroupMaterialInfoCount)
    let wdtMaidWorldModelGroupTriangleIndexText: str =
        strings.IntToStr(summary.wdtMaidWorldModelGroupTriangleIndexCount)
    let wdtMaidWorldModelGroupTriangleText: str =
        strings.IntToStr(summary.wdtMaidWorldModelGroupTriangleCount)
    let wdtMaidWorldModelMaterialPassText: str =
        summary.wdtMaidWorldModelMaterialPassReady ? "ready" : "missing"
    let wdtMaidWorldModelInstancePlacementText: str =
        strings.IntToStr(summary.wdtMaidWorldModelInstancePlacementCount)
    let wdtMaidWorldModelInstanceVertexText: str =
        strings.IntToStr(summary.wdtMaidWorldModelInstanceVertexCount)
    let wdtMaidWorldModelInstanceTriangleText: str =
        strings.IntToStr(summary.wdtMaidWorldModelInstanceTriangleCount)
    let wdtMaidWorldModelInstanceBoundsText: str =
        summary.wdtMaidWorldModelInstanceBoundsReady ? "ready" : "missing"
    let wdtMaidWorldModelIndexedTrianglePassText: str =
        summary.wdtMaidWorldModelIndexedTrianglePassReady ? "ready" : "missing"
    let wdtMaidPlacementAuditText: str = summary.wdtMaidPlacementDependencyAuditReady ? "ready" : "missing"
    let wdtMaidPlacementEncodedBytesText: str = strings.IntToStr(summary.wdtMaidPlacementDependencyEncodedBytes)
    let wdtMaidPlacementDecodedBytesText: str = strings.IntToStr(summary.wdtMaidPlacementDependencyDecodedBytes)
    let wdtMaidDoodadBoundsText: str = summary.wdtMaidDoodadPlacementBoundsReady ? "ready" : "missing"
    let wdtMaidDoodadSpanXText: str =
        strings.IntToStr(summary.wdtMaidDoodadPlacementMaxX1000 - summary.wdtMaidDoodadPlacementMinX1000)
    let wdtMaidDoodadSpanYText: str =
        strings.IntToStr(summary.wdtMaidDoodadPlacementMaxY1000 - summary.wdtMaidDoodadPlacementMinY1000)
    let wdtMaidDoodadSpanZText: str =
        strings.IntToStr(summary.wdtMaidDoodadPlacementMaxZ1000 - summary.wdtMaidDoodadPlacementMinZ1000)
    let wdtMaidDoodadSpanText: str = Fmt"{wdtMaidDoodadSpanXText},{wdtMaidDoodadSpanYText},{wdtMaidDoodadSpanZText}"
    let wdtMaidDoodadMinScaleText: str = strings.IntToStr(summary.wdtMaidDoodadMinScale)
    let wdtMaidDoodadMaxScaleText: str = strings.IntToStr(summary.wdtMaidDoodadMaxScale)
    let wdtMaidDoodadScaleText: str = Fmt"{wdtMaidDoodadMinScaleText},{wdtMaidDoodadMaxScaleText}"
    let wdtMaidWorldModelBoundsText: str = summary.wdtMaidWorldModelPlacementBoundsReady ? "ready" : "missing"
    let wdtMaidWorldModelSpanXText: str =
        strings.IntToStr(summary.wdtMaidWorldModelPlacementMaxX1000 - summary.wdtMaidWorldModelPlacementMinX1000)
    let wdtMaidWorldModelSpanYText: str =
        strings.IntToStr(summary.wdtMaidWorldModelPlacementMaxY1000 - summary.wdtMaidWorldModelPlacementMinY1000)
    let wdtMaidWorldModelSpanZText: str =
        strings.IntToStr(summary.wdtMaidWorldModelPlacementMaxZ1000 - summary.wdtMaidWorldModelPlacementMinZ1000)
    let wdtMaidWorldModelSpanText: str = Fmt"{wdtMaidWorldModelSpanXText},{wdtMaidWorldModelSpanYText},{wdtMaidWorldModelSpanZText}"
    let wdtMaidWorldModelMinScaleText: str = strings.IntToStr(summary.wdtMaidWorldModelMinScale)
    let wdtMaidWorldModelMaxScaleText: str = strings.IntToStr(summary.wdtMaidWorldModelMaxScale)
    let wdtMaidWorldModelScaleText: str = Fmt"{wdtMaidWorldModelMinScaleText},{wdtMaidWorldModelMaxScaleText}"
    let doodadVertexText: str = strings.IntToStr(summary.wmoDoodadModelVertexCount)
    let m2Text: str = strings.IntToStr(summary.m2VertexCount)
    let skinText: str = strings.IntToStr(summary.skinTriangleIndexCount)
    let pixelText: str = strings.IntToStr(summary.pixelsTouched)
    var out: str = Fmt"rendered width={widthText}"
    out = Fmt"{out} height={heightText}"
    out = Fmt"{out} bytes={bytesText}"
    out = Fmt"{out} adtHeightSamples={adtText}"
    out = Fmt"{out} wmoVertices={wmoText}"
    out = Fmt"{out} wmoDoodadPlacements={doodadText}"
    out = Fmt"{out} wmoDoodadModelPlacements={doodadModelText}"
    out = Fmt"{out} wmoDoodadReferencedModelFileIDs={doodadReferencedText}"
    out = Fmt"{out} wmoDoodadModelDependencies={doodadDepText}"
    out = Fmt"{out} wmoRootWorldPlacements={wmoRootWorldPlacementText}"
    out = Fmt"{out} wmoDoodadWorldPlacements={wmoDoodadWorldPlacementText}"
    out = Fmt"{out} wmoDoodadWorldBounds={wmoDoodadWorldBoundsText}"
    out = Fmt"{out} wmoDoodadModelWorldInstanceVertices={wmoDoodadModelWorldVertexText}"
    out = Fmt"{out} wmoMaterials={wmoMaterialText}"
    out = Fmt"{out} wmoLights={wmoLightText}"
    out = Fmt"{out} wmoGroupBatches={wmoGroupBatchText}"
    out = Fmt"{out} wmoGroupMaterialInfo={wmoGroupMaterialInfoText}"
    out = Fmt"{out} wmoGroupTriangleIndices={wmoGroupTriangleIndexText}"
    out = Fmt"{out} wmoGroupTriangles={wmoGroupTriangleText}"
    out = Fmt"{out} wmoMaterialLightPass={wmoMaterialPassText}"
    out = Fmt"{out} textureFiles={textureFileText}"
    out = Fmt"{out} textureMax={textureSizeText}"
    out = Fmt"{out} textureTgaBytes={textureTgaBytesText}"
    out = Fmt"{out} texturePass={texturePassText}"
    out = Fmt"{out} wdtMaidSplitDependencies={wdtMaidSplitText}"
    out = Fmt"{out} wdtMaidSplitDependencyAudit={wdtMaidSplitReadyText}"
    out = Fmt"{out} wdtMaidParsedDependencies={wdtMaidParsedText}"
    out = Fmt"{out} wdtMaidAdtSplits={wdtMaidAdtSplitText}"
    out = Fmt"{out} wdtMaidBlps={wdtMaidBlpText}"
    out = Fmt"{out} wdtMaidAdtSplitChunks={wdtMaidSplitChunkText}"
    out = Fmt"{out} wdtMaidAdtSplitMcnks={wdtMaidSplitMcnkText}"
    out = Fmt"{out} wdtMaidDoodadPlacements={wdtMaidDoodadText}"
    out = Fmt"{out} wdtMaidDoodadReferencedFileIDs={wdtMaidDoodadRefText}"
    out = Fmt"{out} wdtMaidFirstDoodadReferencedFileID={wdtMaidFirstDoodadRefText}"
    out = Fmt"{out} wdtMaidDoodadPlacementDependencies={wdtMaidDoodadDepText}"
    out = Fmt"{out} wdtMaidDoodadM2Assets={wdtMaidDoodadM2AssetText}"
    out = strutil.Join([out, " wdtMaidDoodadM2RenderableAssets=", wdtMaidDoodadM2RenderableAssetText], "")
    out = strutil.Join([out, " wdtMaidDoodadM2ZeroVertexAssets=", wdtMaidDoodadM2ZeroVertexAssetText], "")
    out = strutil.Join([out, " wdtMaidDoodadM2InstancePlacements=", wdtMaidDoodadM2InstancePlacementText], "")
    out = strutil.Join([out, " wdtMaidDoodadM2InstanceVertices=", wdtMaidDoodadM2InstanceVertexText], "")
    out = strutil.Join([out, " wdtMaidDoodadM2InstanceBounds=", wdtMaidDoodadM2InstanceBoundsText], "")
    out = Fmt"{out} wdtMaidDoodadPlacementBounds={wdtMaidDoodadBoundsText}"
    out = Fmt"{out} wdtMaidDoodadPlacementSpan1000={wdtMaidDoodadSpanText}"
    out = Fmt"{out} wdtMaidDoodadScaleMinMax={wdtMaidDoodadScaleText}"
    out = Fmt"{out} wdtMaidWorldModelPlacements={wdtMaidWorldModelText}"
    out = Fmt"{out} wdtMaidWorldModelReferencedFileIDs={wdtMaidWorldModelRefText}"
    out = Fmt"{out} wdtMaidFirstWorldModelReferencedFileID={wdtMaidFirstWorldModelRefText}"
    out = Fmt"{out} wdtMaidWorldModelPlacementDependencies={wdtMaidWorldModelDepText}"
    out = Fmt"{out} wdtMaidWorldModelWmoAssets={wdtMaidWorldModelWmoAssetText}"
    out = strutil.Join([out, " wdtMaidWorldModelGroupReferences=", wdtMaidWorldModelGroupRefText], "")
    out = strutil.Join([out, " wdtMaidWorldModelGroupAssets=", wdtMaidWorldModelGroupAssetText], "")
    out = strutil.Join([out, " wdtMaidWorldModelMaterials=", wdtMaidWorldModelMaterialText], "")
    out = strutil.Join([out, " wdtMaidWorldModelLights=", wdtMaidWorldModelLightText], "")
    out = strutil.Join([out, " wdtMaidWorldModelGroupBatches=", wdtMaidWorldModelGroupBatchText], "")
    out = strutil.Join([out, " wdtMaidWorldModelGroupMaterialInfo=", wdtMaidWorldModelGroupMaterialInfoText], "")
    out = strutil.Join([out, " wdtMaidWorldModelGroupTriangleIndices=", wdtMaidWorldModelGroupTriangleIndexText], "")
    out = strutil.Join([out, " wdtMaidWorldModelGroupTriangles=", wdtMaidWorldModelGroupTriangleText], "")
    out = strutil.Join([out, " wdtMaidWorldModelMaterialPass=", wdtMaidWorldModelMaterialPassText], "")
    out = strutil.Join([out, " wdtMaidWorldModelInstancePlacements=", wdtMaidWorldModelInstancePlacementText], "")
    out = strutil.Join([out, " wdtMaidWorldModelInstanceVertices=", wdtMaidWorldModelInstanceVertexText], "")
    out = strutil.Join([out, " wdtMaidWorldModelInstanceTriangles=", wdtMaidWorldModelInstanceTriangleText], "")
    out = strutil.Join([out, " wdtMaidWorldModelInstanceBounds=", wdtMaidWorldModelInstanceBoundsText], "")
    out = strutil.Join([out, " wdtMaidWorldModelIndexedTrianglePass=", wdtMaidWorldModelIndexedTrianglePassText], "")
    out = Fmt"{out} wdtMaidPlacementDependencyAudit={wdtMaidPlacementAuditText}"
    out = Fmt"{out} wdtMaidPlacementDependencyEncodedBytes={wdtMaidPlacementEncodedBytesText}"
    out = Fmt"{out} wdtMaidPlacementDependencyDecodedBytes={wdtMaidPlacementDecodedBytesText}"
    out = Fmt"{out} wdtMaidWorldModelPlacementBounds={wdtMaidWorldModelBoundsText}"
    out = Fmt"{out} wdtMaidWorldModelPlacementSpan1000={wdtMaidWorldModelSpanText}"
    out = Fmt"{out} wdtMaidWorldModelScaleMinMax={wdtMaidWorldModelScaleText}"
    out = Fmt"{out} wmoDoodadModelVertices={doodadVertexText}"
    out = Fmt"{out} m2Vertices={m2Text}"
    out = Fmt"{out} skinTriangleIndices={skinText}"
    out = Fmt"{out} pixels={pixelText}"
    out = Fmt"{out} out={summary.outPath}"
    return out
