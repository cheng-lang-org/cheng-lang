const
    renderTgaHeaderSize = 18
    renderMargin = 18
    renderAdtMcnkHeaderBytes = 128
    renderAdtMcnkBaseXOffset = 104
    renderAdtMcnkBaseYOffset = 108
    renderAdtMcnkBaseZOffset = 112
    renderAdtHeightSamplesPerChunk = 145
    renderAdtMcvTByteCount = 580
    renderAdtChunkStep1000 = 33333
    renderWmoDoodadPlacementStride = 40
    renderWdtMaidMddfStride = 36
    renderWdtMaidModfStride = 64
    renderTileCenter1000 = 17066667

fn renderMakeByteBuffer(len: int32): bytes.ByteBuffer =
    var out: bytes.ByteBuffer
    if len <= 0:
        out.len = 0
        out.data = nil
        return out
    out.len = len
    out.data = alloc(len)
    return out

fn renderWriteU16LEAt(buf: bytes.ByteBuffer, pos: int32, value: int32) =
    bytes.BufSetByte(buf, pos, value & 255)
    bytes.BufSetByte(buf, pos + 1, (value >> 8) & 255)

fn renderFillTgaBackground(buf: bytes.ByteBuffer, width: int32, height: int32) =
    var y: int32
    while y < height:
        var x: int32
        while x < width:
            let pos: int32 = renderTgaHeaderSize + (y * width + x) * 4
            let shade: int32 = 18 + ((x + y) % 31)
            bytes.BufSetByte(buf, pos, shade)
            bytes.BufSetByte(buf, pos + 1, 24 + (y % 29))
            bytes.BufSetByte(buf, pos + 2, 30 + (x % 41))
            bytes.BufSetByte(buf, pos + 3, 255)
            x = x + 1
        y = y + 1

fn renderMakeTga(width: int32, height: int32): Result[bytes.ByteBuffer] =
    if width <= renderMargin * 2 || height <= renderMargin * 2:
        return Err[bytes.ByteBuffer]("wowExport render: invalid image size")
    if width > 4096 || height > 4096:
        return Err[bytes.ByteBuffer]("wowExport render: image size too large")
    let total: int32 = renderTgaHeaderSize + width * height * 4
    let out: bytes.ByteBuffer = renderMakeByteBuffer(total)
    if out.data == nil || out.len != total:
        return Err[bytes.ByteBuffer]("wowExport render: TGA allocation failed")
    var i: int32
    while i < renderTgaHeaderSize:
        bytes.BufSetByte(out, i, 0)
        i = i + 1
    bytes.BufSetByte(out, 2, 2)
    renderWriteU16LEAt(out, 12, width)
    renderWriteU16LEAt(out, 14, height)
    bytes.BufSetByte(out, 16, 32)
    bytes.BufSetByte(out, 17, 0x20)
    renderFillTgaBackground(out, width, height)
    return Ok[bytes.ByteBuffer](out)

fn renderF32ClampI64ToI32(value: int64): int32 =
    if value > int64(2147483647):
        return 2147483647
    if value < int64(-2147483647):
        return -2147483647
    return int32(value)

fn renderF32Scaled1000At(buf: bytes.ByteBuffer, idx: int32): int32 =
    let bits: int32 = bytes.ReadU32LEAt(buf, idx)
    let exponentRaw: int32 = (bits >> 23) & 255
    var mantissa: int64 = int64(bits & 0x7fffff)
    var exponent: int32 = exponentRaw - 127
    if exponentRaw == 0:
        exponent = -126
    else:
        mantissa = mantissa | int64(0x800000)
    var scaled: int64 = mantissa * int64(1000)
    let shift: int32 = exponent - 23
    if shift > 0:
        var i: int32
        while i < shift:
            scaled = scaled * int64(2)
            i = i + 1
    elif shift < 0:
        var i: int32
        while i < 0 - shift:
            scaled = scaled / int64(2)
            i = i + 1
    if bits < 0:
        scaled = int64(0) - scaled
    return renderF32ClampI64ToI32(scaled)

fn renderF32FiniteScaled1000At(buf: bytes.ByteBuffer,
                               idx: int32,
                               label: str): Result[int32] =
    if idx < 0 || idx + 4 > buf.len:
        return Err[int32](strutil.Join(["wowExport render: ", label, " f32 out of bounds"], ""))
    let bits: int32 = bytes.ReadU32LEAt(buf, idx)
    let exponentRaw: int32 = (bits >> 23) & 255
    if exponentRaw == 255:
        return Err[int32](strutil.Join(["wowExport render: ", label, " non-finite f32"], ""))
    return Ok[int32](renderF32Scaled1000At(buf, idx))

fn renderMulDiv1000(a: int32, b: int32): int32 =
    return renderF32ClampI64ToI32((int64(a) * int64(b)) / int64(1000))

fn renderMulDivScale(a: int32, b: int32, scale: int32): int32 =
    return renderF32ClampI64ToI32((int64(a) * int64(b)) / int64(scale))

fn renderDouble(value: int32): int32 =
    return renderF32ClampI64ToI32(int64(value) * int64(2))

fn renderDivPow2(value: int64, shift: int32): int64 =
    var out: int64 = value
    var i: int32
    while i < shift:
        out = out / int64(2)
        i = i + 1
    return out

fn renderCordicAtanDeg1000(index: int32): int32 =
    if index == 0: return 45000
    if index == 1: return 26565
    if index == 2: return 14036
    if index == 3: return 7125
    if index == 4: return 3576
    if index == 5: return 1790
    if index == 6: return 895
    if index == 7: return 448
    if index == 8: return 224
    if index == 9: return 112
    if index == 10: return 56
    if index == 11: return 28
    if index == 12: return 14
    if index == 13: return 7
    if index == 14: return 3
    if index == 15: return 2
    return 1

fn renderNormalizeDeg1000(angleDeg1000: int32): int32 =
    var out: int32 = angleDeg1000
    while out > 180000:
        out = out - 360000
    while out <= -180000:
        out = out + 360000
    return out

fn renderSinCosDeg1000(angleDeg1000: int32,
                       sinOut1000: var int32,
                       cosOut1000: var int32) =
    var angle: int32 = renderNormalizeDeg1000(angleDeg1000)
    var sign: int32 = 1
    if angle > 90000:
        angle = angle - 180000
        sign = -1
    elif angle < -90000:
        angle = angle + 180000
        sign = -1
    var x: int64 = int64(607253)
    var y: int64
    var z: int32 = angle
    var i: int32
    while i < 20:
        let xShift: int64 = renderDivPow2(x, i)
        let yShift: int64 = renderDivPow2(y, i)
        var nextX: int64
        var nextY: int64
        if z >= 0:
            nextX = x - yShift
            nextY = y + xShift
            z = z - renderCordicAtanDeg1000(i)
        else:
            nextX = x + yShift
            nextY = y - xShift
            z = z + renderCordicAtanDeg1000(i)
        x = nextX
        y = nextY
        i = i + 1
    cosOut1000 = int32((x * int64(sign)) / int64(1000))
    sinOut1000 = int32((y * int64(sign)) / int64(1000))

fn renderRotateXDeg1000(angleDeg1000: int32,
                        x1000: int32,
                        y1000: int32,
                        z1000: int32,
                        outX1000: var int32,
                        outY1000: var int32,
                        outZ1000: var int32) =
    var sin1000: int32
    var cos1000: int32
    renderSinCosDeg1000(angleDeg1000, sin1000, cos1000)
    outX1000 = x1000
    outY1000 = renderMulDiv1000(y1000, cos1000) - renderMulDiv1000(z1000, sin1000)
    outZ1000 = renderMulDiv1000(y1000, sin1000) + renderMulDiv1000(z1000, cos1000)

fn renderRotateYDeg1000(angleDeg1000: int32,
                        x1000: int32,
                        y1000: int32,
                        z1000: int32,
                        outX1000: var int32,
                        outY1000: var int32,
                        outZ1000: var int32) =
    var sin1000: int32
    var cos1000: int32
    renderSinCosDeg1000(angleDeg1000, sin1000, cos1000)
    outX1000 = renderMulDiv1000(x1000, cos1000) + renderMulDiv1000(z1000, sin1000)
    outY1000 = y1000
    outZ1000 = 0 - renderMulDiv1000(x1000, sin1000) + renderMulDiv1000(z1000, cos1000)

fn renderRotateZDeg1000(angleDeg1000: int32,
                        x1000: int32,
                        y1000: int32,
                        z1000: int32,
                        outX1000: var int32,
                        outY1000: var int32,
                        outZ1000: var int32) =
    var sin1000: int32
    var cos1000: int32
    renderSinCosDeg1000(angleDeg1000, sin1000, cos1000)
    outX1000 = renderMulDiv1000(x1000, cos1000) - renderMulDiv1000(y1000, sin1000)
    outY1000 = renderMulDiv1000(x1000, sin1000) + renderMulDiv1000(y1000, cos1000)
    outZ1000 = z1000

fn renderRotateXSinCos1000(sin1000: int32,
                           cos1000: int32,
                           x1000: int32,
                           y1000: int32,
                           z1000: int32,
                           outX1000: var int32,
                           outY1000: var int32,
                           outZ1000: var int32) =
    outX1000 = x1000
    outY1000 = renderMulDiv1000(y1000, cos1000) - renderMulDiv1000(z1000, sin1000)
    outZ1000 = renderMulDiv1000(y1000, sin1000) + renderMulDiv1000(z1000, cos1000)

fn renderRotateYSinCos1000(sin1000: int32,
                           cos1000: int32,
                           x1000: int32,
                           y1000: int32,
                           z1000: int32,
                           outX1000: var int32,
                           outY1000: var int32,
                           outZ1000: var int32) =
    outX1000 = renderMulDiv1000(x1000, cos1000) + renderMulDiv1000(z1000, sin1000)
    outY1000 = y1000
    outZ1000 = 0 - renderMulDiv1000(x1000, sin1000) + renderMulDiv1000(z1000, cos1000)

fn renderRotateZSinCos1000(sin1000: int32,
                           cos1000: int32,
                           x1000: int32,
                           y1000: int32,
                           z1000: int32,
                           outX1000: var int32,
                           outY1000: var int32,
                           outZ1000: var int32) =
    outX1000 = renderMulDiv1000(x1000, cos1000) - renderMulDiv1000(y1000, sin1000)
    outY1000 = renderMulDiv1000(x1000, sin1000) + renderMulDiv1000(y1000, cos1000)
    outZ1000 = z1000

fn renderMakeMaidWorldModelTransform(placement: RenderMaidWorldModelPlacement,
                                     out: var RenderMaidWorldModelTransform) =
    out.scale1024 = placement.scale1024
    out.translateX1000 = renderTileCenter1000 - placement.x1000
    out.translateY1000 = placement.y1000
    out.translateZ1000 = renderTileCenter1000 - placement.z1000
    renderSinCosDeg1000(placement.rotationZ1000 - 90000, out.x1Sin1000, out.x1Cos1000)
    renderSinCosDeg1000(0 - placement.rotationX1000, out.z1Sin1000, out.z1Cos1000)
    renderSinCosDeg1000(placement.rotationY1000 - 270000, out.y1Sin1000, out.y1Cos1000)
    renderSinCosDeg1000(90000, out.y2Sin1000, out.y2Cos1000)
    renderSinCosDeg1000(90000, out.x2Sin1000, out.x2Cos1000)

fn renderMakeMaidDoodadTransform(placement: RenderMaidDoodadPlacement,
                                 out: var RenderMaidWorldModelTransform) =
    out.scale1024 = placement.scale1024
    out.translateX1000 = renderTileCenter1000 - placement.x1000
    out.translateY1000 = placement.y1000
    out.translateZ1000 = renderTileCenter1000 - placement.z1000
    renderSinCosDeg1000(placement.rotationZ1000 - 90000, out.x1Sin1000, out.x1Cos1000)
    renderSinCosDeg1000(0 - placement.rotationX1000, out.z1Sin1000, out.z1Cos1000)
    renderSinCosDeg1000(placement.rotationY1000 - 270000, out.y1Sin1000, out.y1Cos1000)
    renderSinCosDeg1000(90000, out.y2Sin1000, out.y2Cos1000)
    renderSinCosDeg1000(90000, out.x2Sin1000, out.x2Cos1000)

fn renderApplyMaidWorldModelTransform(transform: RenderMaidWorldModelTransform,
                                      localX1000: int32,
                                      localY1000: int32,
                                      localZ1000: int32,
                                      outX1000: var int32,
                                      outY1000: var int32,
                                      outZ1000: var int32) =
    var x: int32 = renderMulDivScale(localX1000, transform.scale1024, 1024)
    var y: int32 = renderMulDivScale(localY1000, transform.scale1024, 1024)
    var z: int32 = renderMulDivScale(localZ1000, transform.scale1024, 1024)
    renderRotateXSinCos1000(transform.x1Sin1000, transform.x1Cos1000, x, y, z, x, y, z)
    renderRotateZSinCos1000(transform.z1Sin1000, transform.z1Cos1000, x, y, z, x, y, z)
    renderRotateYSinCos1000(transform.y1Sin1000, transform.y1Cos1000, x, y, z, x, y, z)
    x = x + transform.translateX1000
    y = y + transform.translateY1000
    z = z + transform.translateZ1000
    renderRotateYSinCos1000(transform.y2Sin1000, transform.y2Cos1000, x, y, z, x, y, z)
    renderRotateXSinCos1000(transform.x2Sin1000, transform.x2Cos1000, x, y, z, outX1000, outY1000, outZ1000)

fn renderTransformDoodadVertex(placement: RenderDoodadPlacement,
                               localX1000: int32,
                               localY1000: int32,
                               localZ1000: int32,
                               outX1000: var int32,
                               outY1000: var int32,
                               outZ1000: var int32) =
    let tx: int32 = renderDouble(renderMulDiv1000(placement.qy1000, localZ1000) -
        renderMulDiv1000(placement.qz1000, localY1000))
    let ty: int32 = renderDouble(renderMulDiv1000(placement.qz1000, localX1000) -
        renderMulDiv1000(placement.qx1000, localZ1000))
    let tz: int32 = renderDouble(renderMulDiv1000(placement.qx1000, localY1000) -
        renderMulDiv1000(placement.qy1000, localX1000))
    let rx: int32 = localX1000 +
        renderMulDiv1000(placement.qw1000, tx) +
        renderMulDiv1000(placement.qy1000, tz) -
        renderMulDiv1000(placement.qz1000, ty)
    let ry: int32 = localY1000 +
        renderMulDiv1000(placement.qw1000, ty) +
        renderMulDiv1000(placement.qz1000, tx) -
        renderMulDiv1000(placement.qx1000, tz)
    let rz: int32 = localZ1000 +
        renderMulDiv1000(placement.qw1000, tz) +
        renderMulDiv1000(placement.qx1000, ty) -
        renderMulDiv1000(placement.qy1000, tx)
    outX1000 = placement.x1000 + renderMulDiv1000(rx, placement.scale1000)
    outY1000 = placement.y1000 + renderMulDiv1000(ry, placement.scale1000)
    outZ1000 = placement.z1000 + renderMulDiv1000(rz, placement.scale1000)

fn renderTransformMaidDoodadVertex(placement: RenderMaidDoodadPlacement,
                                   localX1000: int32,
                                   localY1000: int32,
                                   localZ1000: int32,
                                   outX1000: var int32,
                                   outY1000: var int32,
                                   outZ1000: var int32) =
    var x: int32 = renderMulDivScale(localX1000, placement.scale1024, 1024)
    var y: int32 = renderMulDivScale(localY1000, placement.scale1024, 1024)
    var z: int32 = renderMulDivScale(localZ1000, placement.scale1024, 1024)
    renderRotateXDeg1000(placement.rotationZ1000 - 90000, x, y, z, x, y, z)
    renderRotateZDeg1000(0 - placement.rotationX1000, x, y, z, x, y, z)
    renderRotateYDeg1000(placement.rotationY1000 - 270000, x, y, z, x, y, z)
    x = x + renderTileCenter1000 - placement.x1000
    y = y + placement.y1000
    z = z + renderTileCenter1000 - placement.z1000
    renderRotateYDeg1000(90000, x, y, z, x, y, z)
    renderRotateXDeg1000(90000, x, y, z, outX1000, outY1000, outZ1000)

fn renderTransformMaidWorldModelVertex(placement: RenderMaidWorldModelPlacement,
                                       localX1000: int32,
                                       localY1000: int32,
                                       localZ1000: int32,
                                       outX1000: var int32,
                                       outY1000: var int32,
                                       outZ1000: var int32) =
    var x: int32 = renderMulDivScale(localX1000, placement.scale1024, 1024)
    var y: int32 = renderMulDivScale(localY1000, placement.scale1024, 1024)
    var z: int32 = renderMulDivScale(localZ1000, placement.scale1024, 1024)
    renderRotateXDeg1000(placement.rotationZ1000 - 90000, x, y, z, x, y, z)
    renderRotateZDeg1000(0 - placement.rotationX1000, x, y, z, x, y, z)
    renderRotateYDeg1000(placement.rotationY1000 - 270000, x, y, z, x, y, z)
    x = x + renderTileCenter1000 - placement.x1000
    y = y + placement.y1000
    z = z + renderTileCenter1000 - placement.z1000
    renderRotateYDeg1000(90000, x, y, z, x, y, z)
    renderRotateXDeg1000(90000, x, y, z, outX1000, outY1000, outZ1000)

fn renderHasFourCC(buf: bytes.ByteBuffer,
                   pos: int32,
                   a: int32,
                   b: int32,
                   c: int32,
                   d: int32): bool =
    if pos < 0 || pos + 4 > buf.len:
        return false
    return bytes.BufByteAt(buf, pos) == a &&
        bytes.BufByteAt(buf, pos + 1) == b &&
        bytes.BufByteAt(buf, pos + 2) == c &&
        bytes.BufByteAt(buf, pos + 3) == d

fn renderAccumulateBounds(bounds: var RenderBounds,
                          x: int32,
                          y: int32,
                          z: int32) =
    if !bounds.ready:
        bounds.ready = true
        bounds.minX1000 = x
        bounds.maxX1000 = x
        bounds.minY1000 = y
        bounds.maxY1000 = y
        bounds.minZ1000 = z
        bounds.maxZ1000 = z
        return
    if x < bounds.minX1000: bounds.minX1000 = x
    if x > bounds.maxX1000: bounds.maxX1000 = x
    if y < bounds.minY1000: bounds.minY1000 = y
    if y > bounds.maxY1000: bounds.maxY1000 = y
    if z < bounds.minZ1000: bounds.minZ1000 = z
    if z > bounds.maxZ1000: bounds.maxZ1000 = z

fn renderMergeBounds(out: var RenderBounds,
                     source: RenderBounds) =
    if !source.ready:
        return
    renderAccumulateBounds(out, source.minX1000, source.minY1000, source.minZ1000)
    renderAccumulateBounds(out, source.maxX1000, source.maxY1000, source.maxZ1000)

fn renderFindWmoMovt(buf: bytes.ByteBuffer,
                     outStart: var int32,
                     outCount: var int32): Result[bool] =
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO group truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO group chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('P'), int32('G'), int32('O'), int32('M')):
            if size < 68:
                return Err[bool]("wowExport render: WMO MOGP header too small")
            var inner: int32 = dataPos + 68
            let end: int32 = dataPos + size
            while inner < end:
                if inner + 8 > end:
                    return Err[bool]("wowExport render: WMO nested chunk truncated")
                let innerSize: int32 = bytes.ReadU32LEAt(buf, inner + 4)
                let innerData: int32 = inner + 8
                if innerSize < 0 || innerData + innerSize > end:
                    return Err[bool]("wowExport render: WMO nested chunk out of bounds")
                if renderHasFourCC(buf, inner, int32('T'), int32('V'), int32('O'), int32('M')):
                    if (innerSize % 12) != 0:
                        return Err[bool]("wowExport render: WMO MOVT chunk size invalid")
                    outStart = innerData
                    outCount = innerSize / 12
                    return Ok[bool](true)
                inner = innerData + innerSize
        pos = dataPos + size
    return Err[bool]("wowExport render: WMO MOVT missing")

fn renderApplyWmoGroupChunk(buf: bytes.ByteBuffer,
                            chunkPos: int32,
                            dataPos: int32,
                            size: int32,
                            chunks: var RenderWmoGroupChunks): Result[bool] =
    if renderHasFourCC(buf, chunkPos, int32('T'), int32('V'), int32('O'), int32('M')):
        if (size % 12) != 0:
            return Err[bool]("wowExport render: WMO MOVT chunk size invalid")
        if chunks.vertexCount > 0:
            return Err[bool]("wowExport render: duplicate WMO MOVT chunk")
        chunks.vertexOffset = dataPos
        chunks.vertexCount = size / 12
    elif renderHasFourCC(buf, chunkPos, int32('I'), int32('V'), int32('O'), int32('M')):
        if (size % 2) != 0:
            return Err[bool]("wowExport render: WMO MOVI chunk size invalid")
        if chunks.indexCount > 0:
            return Err[bool]("wowExport render: duplicate WMO MOVI chunk")
        chunks.indexOffset = dataPos
        chunks.indexCount = size / 2
    elif renderHasFourCC(buf, chunkPos, int32('Y'), int32('P'), int32('O'), int32('M')):
        if (size % 2) != 0:
            return Err[bool]("wowExport render: WMO MOPY chunk size invalid")
        if chunks.materialInfoCount > 0:
            return Err[bool]("wowExport render: duplicate WMO MOPY chunk")
        chunks.materialInfoOffset = dataPos
        chunks.materialInfoCount = size / 2
    elif renderHasFourCC(buf, chunkPos, int32('A'), int32('B'), int32('O'), int32('M')):
        if (size % 24) != 0:
            return Err[bool]("wowExport render: WMO MOBA chunk size invalid")
        if chunks.batchCount > 0:
            return Err[bool]("wowExport render: duplicate WMO MOBA chunk")
        chunks.batchOffset = dataPos
        chunks.batchCount = size / 24
    return Ok[bool](true)

fn renderFindWmoGroupChunks(buf: bytes.ByteBuffer,
                            chunks: var RenderWmoGroupChunks): Result[bool] =
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO group truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO group chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('P'), int32('G'), int32('O'), int32('M')):
            if size < 68:
                return Err[bool]("wowExport render: WMO MOGP header too small")
            var inner: int32 = dataPos + 68
            let end: int32 = dataPos + size
            while inner < end:
                if inner + 8 > end:
                    return Err[bool]("wowExport render: WMO nested chunk truncated")
                let innerSize: int32 = bytes.ReadU32LEAt(buf, inner + 4)
                let innerData: int32 = inner + 8
                if innerSize < 0 || innerData + innerSize > end:
                    return Err[bool]("wowExport render: WMO nested chunk out of bounds")
                let applyRes: Result[bool] =
                    renderApplyWmoGroupChunk(buf, inner, innerData, innerSize, chunks)
                if IsErr(applyRes):
                    return Err[bool](Error(applyRes))
                inner = innerData + innerSize
        else:
            let applyRes: Result[bool] =
                renderApplyWmoGroupChunk(buf, pos, dataPos, size, chunks)
            if IsErr(applyRes):
                return Err[bool](Error(applyRes))
        pos = dataPos + size
    if chunks.vertexCount <= 0:
        return Err[bool]("wowExport render: WMO MOVT missing")
    if chunks.indexCount <= 0:
        return Err[bool]("wowExport render: WMO MOVI missing")
    if (chunks.indexCount % 3) != 0:
        return Err[bool]("wowExport render: WMO MOVI triangle index count invalid")
    if chunks.materialInfoCount <= 0:
        return Err[bool]("wowExport render: WMO MOPY missing")
    if chunks.materialInfoCount != chunks.indexCount / 3:
        return Err[bool]("wowExport render: WMO MOPY triangle count mismatch")
    return Ok[bool](true)

fn renderAdtSampleLocalOffset(sampleIndex: int32,
                              xOut: var int32,
                              yOut: var int32): Result[bool] =
    if sampleIndex < 0 || sampleIndex >= renderAdtHeightSamplesPerChunk:
        return Err[bool]("wowExport render: ADT height sample index out of range")
    var row: int32
    var remaining: int32 = sampleIndex
    while row < 17:
        if (row % 2) == 0:
            if remaining < 9:
                xOut = remaining * renderAdtChunkStep1000 / 8
                yOut = (row / 2) * renderAdtChunkStep1000 / 8
                return Ok[bool](true)
            remaining = remaining - 9
        else:
            if remaining < 8:
                xOut = (remaining * 2 + 1) * renderAdtChunkStep1000 / 16
                yOut = row * renderAdtChunkStep1000 / 16
                return Ok[bool](true)
            remaining = remaining - 8
        row = row + 1
    return Err[bool]("wowExport render: ADT height sample layout failed")

fn renderScanAdtMcvT(buf: bytes.ByteBuffer,
                     start: int32,
                     size: int32,
                     baseX1000: int32,
                     baseY1000: int32,
                     baseZ1000: int32,
                     bounds: var RenderBounds,
                     countOut: var int32): Result[bool] =
    if size != renderAdtMcvTByteCount:
        return Err[bool]("wowExport render: ADT MCVT size invalid")
    if start < 0 || start + size > buf.len:
        return Err[bool]("wowExport render: ADT MCVT out of bounds")
    var i: int32
    while i < renderAdtHeightSamplesPerChunk:
        var localX1000: int32
        var localY1000: int32
        let offsetRes: Result[bool] = renderAdtSampleLocalOffset(i, localX1000, localY1000)
        if IsErr(offsetRes):
            return Err[bool](Error(offsetRes))
        let x1000: int32 = baseX1000 - localX1000
        let y1000: int32 = baseY1000 - localY1000
        let z1000: int32 = baseZ1000 + renderF32Scaled1000At(buf, start + i * 4)
        renderAccumulateBounds(bounds, x1000, y1000, z1000)
        countOut = countOut + 1
        i = i + 1
    return Ok[bool](true)

fn renderScanAdtMcnkNested(buf: bytes.ByteBuffer,
                           start: int32,
                           end: int32,
                           baseX1000: int32,
                           baseY1000: int32,
                           baseZ1000: int32,
                           bounds: var RenderBounds,
                           countOut: var int32): Result[bool] =
    if start < 0 || end < start || end > buf.len:
        return Err[bool]("wowExport render: ADT MCNK nested range out of bounds")
    var foundHeight: bool
    var pos: int32 = start
    while pos < end:
        if pos + 8 > end:
            return Err[bool]("wowExport render: ADT MCNK nested chunk truncated")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > end:
            return Err[bool]("wowExport render: ADT MCNK nested chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('T'), int32('V'), int32('C'), int32('M')):
            if foundHeight:
                return Err[bool]("wowExport render: ADT duplicate MCVT chunk")
            let scanRes: Result[bool] =
                renderScanAdtMcvT(buf,
                                  dataPos,
                                  size,
                                  baseX1000,
                                  baseY1000,
                                  baseZ1000,
                                  bounds,
                                  countOut)
            if IsErr(scanRes):
                return Err[bool](Error(scanRes))
            foundHeight = true
        pos = dataPos + size
    if !foundHeight:
        return Err[bool]("wowExport render: ADT MCNK missing MCVT")
    return Ok[bool](true)

fn renderScanAdtTerrain(buf: bytes.ByteBuffer,
                        bounds: var RenderBounds,
                        countOut: var int32): Result[bool] =
    var pos: int32
    var mcnkCount: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: ADT truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: ADT chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('K'), int32('N'), int32('C'), int32('M')):
            if size < renderAdtMcnkHeaderBytes:
                return Err[bool]("wowExport render: ADT MCNK header too small")
            mcnkCount = mcnkCount + 1
            let baseX1000: int32 = renderF32Scaled1000At(buf, dataPos + renderAdtMcnkBaseXOffset)
            let baseY1000: int32 = renderF32Scaled1000At(buf, dataPos + renderAdtMcnkBaseYOffset)
            let baseZ1000: int32 = renderF32Scaled1000At(buf, dataPos + renderAdtMcnkBaseZOffset)
            let nestedRes: Result[bool] =
                renderScanAdtMcnkNested(buf,
                                        dataPos + renderAdtMcnkHeaderBytes,
                                        dataPos + size,
                                        baseX1000,
                                        baseY1000,
                                        baseZ1000,
                                        bounds,
                                        countOut)
            if IsErr(nestedRes):
                return Err[bool](Error(nestedRes))
        pos = dataPos + size
    if mcnkCount <= 0:
        return Err[bool]("wowExport render: ADT MCNK chunks missing")
    return Ok[bool](true)

fn renderMapCoord(value: int32,
                  minValue: int32,
                  maxValue: int32,
                  screenMin: int32,
                  screenMax: int32): int32 =
    if maxValue <= minValue:
        return (screenMin + screenMax) / 2
    let span: int64 = int64(maxValue) - int64(minValue)
    let rel: int64 = int64(value) - int64(minValue)
    let screenSpan: int64 = int64(screenMax - screenMin)
    return screenMin + int32((rel * screenSpan) / span)

fn renderPlot(tga: bytes.ByteBuffer,
              width: int32,
              height: int32,
              x: int32,
              y: int32,
              r: int32,
              g: int32,
              b: int32,
              pixels: var int32) =
    if x < 0 || y < 0 || x >= width || y >= height:
        return
    let pos: int32 = renderTgaHeaderSize + (y * width + x) * 4
    bytes.BufSetByte(tga, pos, b)
    bytes.BufSetByte(tga, pos + 1, g)
    bytes.BufSetByte(tga, pos + 2, r)
    bytes.BufSetByte(tga, pos + 3, 255)
    pixels = pixels + 1

fn renderWmoMaterialColor(materialID: int32,
                          rOut: var int32,
                          gOut: var int32,
                          bOut: var int32) =
    let m: int32 = materialID & 255
    rOut = 136 + ((m * 37) % 96)
    gOut = 92 + ((m * 53) % 112)
    bOut = 54 + ((m * 29) % 96)

fn renderPlotCross(tga: bytes.ByteBuffer,
                   width: int32,
                   height: int32,
                   x: int32,
                   y: int32,
                   r: int32,
                   g: int32,
                   b: int32,
                   pixels: var int32) =
    renderPlot(tga, width, height, x, y, r, g, b, pixels)
    renderPlot(tga, width, height, x - 1, y, r, g, b, pixels)
    renderPlot(tga, width, height, x + 1, y, r, g, b, pixels)
    renderPlot(tga, width, height, x, y - 1, r, g, b, pixels)
    renderPlot(tga, width, height, x, y + 1, r, g, b, pixels)

fn renderDrawAdtMcvT(tga: bytes.ByteBuffer,
                     width: int32,
                     height: int32,
                     buf: bytes.ByteBuffer,
                     start: int32,
                     size: int32,
                     baseX1000: int32,
                     baseY1000: int32,
                     baseZ1000: int32,
                     bounds: RenderBounds,
                     pixels: var int32): Result[bool] =
    if size != renderAdtMcvTByteCount:
        return Err[bool]("wowExport render: ADT draw MCVT size invalid")
    var i: int32
    while i < renderAdtHeightSamplesPerChunk:
        var localX1000: int32
        var localY1000: int32
        let offsetRes: Result[bool] = renderAdtSampleLocalOffset(i, localX1000, localY1000)
        if IsErr(offsetRes):
            return Err[bool](Error(offsetRes))
        let x1000: int32 = baseX1000 - localX1000
        let y1000: int32 = baseY1000 - localY1000
        let z1000: int32 = baseZ1000 + renderF32Scaled1000At(buf, start + i * 4)
        let px: int32 = renderMapCoord(x1000, bounds.minX1000, bounds.maxX1000,
                                        renderMargin, width - renderMargin - 1)
        let pyRaw: int32 = renderMapCoord(y1000, bounds.minY1000, bounds.maxY1000,
                                           renderMargin, height - renderMargin - 1)
        let shade: int32 = renderMapCoord(z1000, bounds.minZ1000, bounds.maxZ1000, 72, 190)
        renderPlot(tga, width, height, px, height - 1 - pyRaw, 66, shade, 92, pixels)
        i = i + 1
    return Ok[bool](true)

fn renderDrawAdtTerrain(tga: bytes.ByteBuffer,
                        width: int32,
                        height: int32,
                        buf: bytes.ByteBuffer,
                        bounds: RenderBounds,
                        pixels: var int32): Result[bool] =
    var pos: int32
    var mcnkCount: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: ADT draw truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: ADT draw chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('K'), int32('N'), int32('C'), int32('M')):
            if size < renderAdtMcnkHeaderBytes:
                return Err[bool]("wowExport render: ADT draw MCNK header too small")
            mcnkCount = mcnkCount + 1
            let baseX1000: int32 = renderF32Scaled1000At(buf, dataPos + renderAdtMcnkBaseXOffset)
            let baseY1000: int32 = renderF32Scaled1000At(buf, dataPos + renderAdtMcnkBaseYOffset)
            let baseZ1000: int32 = renderF32Scaled1000At(buf, dataPos + renderAdtMcnkBaseZOffset)
            var inner: int32 = dataPos + renderAdtMcnkHeaderBytes
            let end: int32 = dataPos + size
            var foundHeight: bool
            while inner < end:
                if inner + 8 > end:
                    return Err[bool]("wowExport render: ADT draw nested chunk truncated")
                let innerSize: int32 = bytes.ReadU32LEAt(buf, inner + 4)
                let innerData: int32 = inner + 8
                if innerSize < 0 || innerData + innerSize > end:
                    return Err[bool]("wowExport render: ADT draw nested chunk out of bounds")
                if renderHasFourCC(buf, inner, int32('T'), int32('V'), int32('C'), int32('M')):
                    if foundHeight:
                        return Err[bool]("wowExport render: ADT draw duplicate MCVT")
                    let drawRes: Result[bool] =
                        renderDrawAdtMcvT(tga,
                                          width,
                                          height,
                                          buf,
                                          innerData,
                                          innerSize,
                                          baseX1000,
                                          baseY1000,
                                          baseZ1000,
                                          bounds,
                                          pixels)
                    if IsErr(drawRes):
                        return Err[bool](Error(drawRes))
                    foundHeight = true
                inner = innerData + innerSize
            if !foundHeight:
                return Err[bool]("wowExport render: ADT draw MCNK missing MCVT")
        pos = dataPos + size
    if mcnkCount <= 0:
        return Err[bool]("wowExport render: ADT draw MCNK chunks missing")
    return Ok[bool](true)

fn renderScanWmoVertices(buf: bytes.ByteBuffer,
                         bounds: var RenderBounds,
                         countOut: var int32): Result[bool] =
    var start: int32
    var count: int32
    let movtRes: Result[bool] = renderFindWmoMovt(buf, start, count)
    if IsErr(movtRes):
        return Err[bool](Error(movtRes))
    var i: int32
    while i < count:
        let pos: int32 = start + i * 12
        let x: int32 = renderF32Scaled1000At(buf, pos)
        let y: int32 = renderF32Scaled1000At(buf, pos + 4)
        let z: int32 = renderF32Scaled1000At(buf, pos + 8)
        renderAccumulateBounds(bounds, x, y, z)
        countOut = countOut + 1
        i = i + 1
    return Ok[bool](true)

fn renderCountWmoVertices(buf: bytes.ByteBuffer,
                          countOut: var int32): Result[bool] =
    var start: int32
    var count: int32
    let movtRes: Result[bool] = renderFindWmoMovt(buf, start, count)
    if IsErr(movtRes):
        return Err[bool](Error(movtRes))
    countOut = countOut + count
    return Ok[bool](true)

fn renderDrawWmoVertices(tga: bytes.ByteBuffer,
                         width: int32,
                         height: int32,
                         buf: bytes.ByteBuffer,
                         bounds: RenderBounds,
                         pixels: var int32): Result[bool] =
    var start: int32
    var count: int32
    let movtRes: Result[bool] = renderFindWmoMovt(buf, start, count)
    if IsErr(movtRes):
        return Err[bool](Error(movtRes))
    var i: int32
    while i < count:
        let pos: int32 = start + i * 12
        let x1000: int32 = renderF32Scaled1000At(buf, pos)
        let y1000: int32 = renderF32Scaled1000At(buf, pos + 4)
        let px: int32 = renderMapCoord(x1000, bounds.minX1000, bounds.maxX1000,
                                        renderMargin, width - renderMargin - 1)
        let pyRaw: int32 = renderMapCoord(y1000, bounds.minY1000, bounds.maxY1000,
                                           renderMargin, height - renderMargin - 1)
        let py: int32 = height - 1 - pyRaw
        renderPlot(tga, width, height, px, py, 224, 190, 96, pixels)
        i = i + 1
    return Ok[bool](true)

fn renderScanWmoDoodadPlacements(buf: bytes.ByteBuffer,
                                 bounds: var RenderBounds,
                                 countOut: var int32): Result[bool] =
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('D'), int32('D'), int32('O'), int32('M')):
            if (size % renderWmoDoodadPlacementStride) != 0:
                return Err[bool]("wowExport render: WMO MODD size invalid")
            var i: int32
            while i < size / renderWmoDoodadPlacementStride:
                let rec: int32 = dataPos + i * renderWmoDoodadPlacementStride
                let x: int32 = renderF32Scaled1000At(buf, rec + 4)
                let y: int32 = renderF32Scaled1000At(buf, rec + 8)
                let z: int32 = renderF32Scaled1000At(buf, rec + 12)
                renderAccumulateBounds(bounds, x, y, z)
                countOut = countOut + 1
                i = i + 1
            return Ok[bool](true)
        pos = dataPos + size
    return Err[bool]("wowExport render: WMO MODD placements missing")

fn renderDrawWmoDoodadPlacements(tga: bytes.ByteBuffer,
                                 width: int32,
                                 height: int32,
                                 buf: bytes.ByteBuffer,
                                 bounds: RenderBounds,
                                 pixels: var int32): Result[bool] =
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO draw root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO draw root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('D'), int32('D'), int32('O'), int32('M')):
            if (size % renderWmoDoodadPlacementStride) != 0:
                return Err[bool]("wowExport render: WMO draw MODD size invalid")
            var i: int32
            while i < size / renderWmoDoodadPlacementStride:
                let rec: int32 = dataPos + i * renderWmoDoodadPlacementStride
                let x1000: int32 = renderF32Scaled1000At(buf, rec + 4)
                let y1000: int32 = renderF32Scaled1000At(buf, rec + 8)
                let px: int32 = renderMapCoord(x1000, bounds.minX1000, bounds.maxX1000,
                                                renderMargin, width - renderMargin - 1)
                let pyRaw: int32 = renderMapCoord(y1000, bounds.minY1000, bounds.maxY1000,
                                                   renderMargin, height - renderMargin - 1)
                renderPlotCross(tga, width, height, px, height - 1 - pyRaw, 238, 92, 72, pixels)
                i = i + 1
            return Ok[bool](true)
        pos = dataPos + size
    return Err[bool]("wowExport render: WMO draw MODD placements missing")

fn renderCountWmoDoodadPlacements(buf: bytes.ByteBuffer,
                                  countOut: var int32): Result[bool] =
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO count root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO count root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('D'), int32('D'), int32('O'), int32('M')):
            if (size % renderWmoDoodadPlacementStride) != 0:
                return Err[bool]("wowExport render: WMO count MODD size invalid")
            countOut = countOut + size / renderWmoDoodadPlacementStride
            return Ok[bool](true)
        pos = dataPos + size
    return Err[bool]("wowExport render: WMO count MODD placements missing")

fn renderScanWmoDoodadPlacementsPlaced(buf: bytes.ByteBuffer,
                                       rootPlacement: RenderMaidWorldModelPlacement,
                                       bounds: var RenderBounds,
                                       countOut: var int32): Result[bool] =
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO placed root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO placed root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('D'), int32('D'), int32('O'), int32('M')):
            if (size % renderWmoDoodadPlacementStride) != 0:
                return Err[bool]("wowExport render: WMO placed MODD size invalid")
            var i: int32
            while i < size / renderWmoDoodadPlacementStride:
                let rec: int32 = dataPos + i * renderWmoDoodadPlacementStride
                let xRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 4, "WMO placed MODD x")
                let yRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 8, "WMO placed MODD y")
                let zRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 12, "WMO placed MODD z")
                if IsErr(xRes): return Err[bool](Error(xRes))
                if IsErr(yRes): return Err[bool](Error(yRes))
                if IsErr(zRes): return Err[bool](Error(zRes))
                var outX1000: int32
                var outY1000: int32
                var outZ1000: int32
                renderTransformMaidWorldModelVertex(rootPlacement,
                                                    Value(xRes),
                                                    Value(yRes),
                                                    Value(zRes),
                                                    outX1000,
                                                    outY1000,
                                                    outZ1000)
                renderAccumulateBounds(bounds, outX1000, outY1000, outZ1000)
                countOut = countOut + 1
                i = i + 1
            return Ok[bool](true)
        pos = dataPos + size
    return Err[bool]("wowExport render: WMO placed MODD placements missing")

fn renderDrawWmoDoodadPlacementsPlaced(tga: bytes.ByteBuffer,
                                       width: int32,
                                       height: int32,
                                       buf: bytes.ByteBuffer,
                                       rootPlacement: RenderMaidWorldModelPlacement,
                                       bounds: RenderBounds,
                                       pixels: var int32): Result[bool] =
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO draw placed root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO draw placed root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('D'), int32('D'), int32('O'), int32('M')):
            if (size % renderWmoDoodadPlacementStride) != 0:
                return Err[bool]("wowExport render: WMO draw placed MODD size invalid")
            var i: int32
            while i < size / renderWmoDoodadPlacementStride:
                let rec: int32 = dataPos + i * renderWmoDoodadPlacementStride
                let xRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 4, "WMO draw placed MODD x")
                let yRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 8, "WMO draw placed MODD y")
                let zRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 12, "WMO draw placed MODD z")
                if IsErr(xRes): return Err[bool](Error(xRes))
                if IsErr(yRes): return Err[bool](Error(yRes))
                if IsErr(zRes): return Err[bool](Error(zRes))
                var outX1000: int32
                var outY1000: int32
                var outZ1000: int32
                renderTransformMaidWorldModelVertex(rootPlacement,
                                                    Value(xRes),
                                                    Value(yRes),
                                                    Value(zRes),
                                                    outX1000,
                                                    outY1000,
                                                    outZ1000)
                let px: int32 = renderMapCoord(outX1000, bounds.minX1000, bounds.maxX1000,
                                                renderMargin, width - renderMargin - 1)
                let pyRaw: int32 = renderMapCoord(outY1000, bounds.minY1000, bounds.maxY1000,
                                                   renderMargin, height - renderMargin - 1)
                renderPlotCross(tga, width, height, px, height - 1 - pyRaw, 238, 92, 72, pixels)
                i = i + 1
            return Ok[bool](true)
        pos = dataPos + size
    return Err[bool]("wowExport render: WMO draw placed MODD placements missing")

fn renderFindDoodadModelIndex(models: RenderDoodadModel[], fileDataID: int32): int32 =
    var i: int32
    while i < models.len:
        if models[i].fileDataID == fileDataID:
            return i
        i = i + 1
    return -1

fn renderFindWmoGroupModelIndex(models: RenderWmoGroupModel[], fileDataID: int32): int32 =
    var i: int32
    while i < models.len:
        if models[i].fileDataID == fileDataID:
            return i
        i = i + 1
    return -1

fn renderFreeDoodadModels(models: var RenderDoodadModel[]) =
    var i: int32
    while i < models.len:
        bytes.FreeByteBuffer(models[i].buf)
        i = i + 1

fn renderFreeWmoGroupModels(models: var RenderWmoGroupModel[]) =
    var i: int32
    while i < models.len:
        bytes.FreeByteBuffer(models[i].buf)
        i = i + 1

fn renderFreeMaidDoodadAssets(assets: var RenderMaidDoodadAssets) =
    renderFreeDoodadModels(assets.doodadModels)
    renderFreeWmoGroupModels(assets.worldModelGroups)

fn renderLoadM2ModelFromEntry(clientPath: str,
                              fileDataID: int32,
                              encodingKey: str,
                              archiveIndex: int32,
                              offset: int32,
                              size: int32,
                              label: str,
                              requireVertices: bool): Result[RenderDoodadModel] =
    let bufRes: Result[bytes.ByteBuffer] =
        local_files.ReadLocalFileByEntryCached(clientPath,
                                               encodingKey,
                                               archiveIndex,
                                               offset,
                                               size)
    if IsErr(bufRes):
        return Err[RenderDoodadModel](Error(bufRes))
    let buf: bytes.ByteBuffer = Value(bufRes)
    let headerRes: Result[asset_formats.M2Header] = asset_formats.ParseM2Header(buf)
    if IsErr(headerRes):
        bytes.FreeByteBuffer(buf)
        return Err[RenderDoodadModel](Error(headerRes))
    let header: asset_formats.M2Header = Value(headerRes)
    if header.vertexCount <= 0:
        if requireVertices:
            bytes.FreeByteBuffer(buf)
            return Err[RenderDoodadModel](strutil.Join(["wowExport render: ", label, " M2 has no vertices ", strings.IntToStr(fileDataID)], ""))
    elif header.vertexOffset < 0 || header.vertexOffset + header.vertexCount * 48 > buf.len:
        bytes.FreeByteBuffer(buf)
        return Err[RenderDoodadModel](strutil.Join(["wowExport render: ", label, " M2 vertex array out of bounds ", strings.IntToStr(fileDataID)], ""))
    var model: RenderDoodadModel
    model.fileDataID = fileDataID
    model.vertexCount = header.vertexCount
    model.vertexOffset = header.vertexOffset
    model.buf = buf
    return Ok[RenderDoodadModel](model)

fn renderLoadDoodadModels(manifest: northshire.NorthshireManifest): Result[RenderDoodadModel[]] =
    var out: RenderDoodadModel[]
    var i: int32
    while i < manifest.auditedDependencies.len:
        let dep: northshire.NorthshireAuditedDependency = manifest.auditedDependencies[i]
        if dep.sourceLabel == "northshire-abbey-wmo" && dep.relationKind == "wmo_modi":
            if renderFindDoodadModelIndex(out, dep.fileDataID) >= 0:
                renderFreeDoodadModels(out)
                return Err[RenderDoodadModel[]](strutil.Join(["wowExport render: duplicate WMO doodad model dependency ", strings.IntToStr(dep.fileDataID)], ""))
            let modelRes: Result[RenderDoodadModel] =
                renderLoadM2ModelFromEntry(manifest.clientPath,
                                           dep.fileDataID,
                                           dep.encodingKey,
                                           dep.archiveIndex,
                                           dep.offset,
                                           dep.size,
                                           "WMO doodad",
                                           true)
            if IsErr(modelRes):
                renderFreeDoodadModels(out)
                return Err[RenderDoodadModel[]](Error(modelRes))
            let model: RenderDoodadModel = Value(modelRes)
            add(out, model)
        i = i + 1
    if out.len <= 0:
        return Err[RenderDoodadModel[]]("wowExport render: no WMO doodad models loaded")
    return Ok[RenderDoodadModel[]](out)

fn renderLoadMaidDoodadModels(manifest: northshire.NorthshireManifest,
                              fileDataIDs: int32[]): Result[RenderDoodadModel[]] =
    if fileDataIDs.len <= 0:
        return Err[RenderDoodadModel[]]("wowExport render: no MAID doodad model fileDataIDs")
    let statsRes: Result[local_files.LocalFileAuditEntryStat[]] =
        local_files.ResolveLocalFileAuditEntryStatsRanged(manifest.clientPath, fileDataIDs)
    if IsErr(statsRes):
        return Err[RenderDoodadModel[]](Error(statsRes))
    let stats: local_files.LocalFileAuditEntryStat[] = Value(statsRes)
    if stats.len != fileDataIDs.len:
        return Err[RenderDoodadModel[]]("wowExport render: MAID doodad model stat count mismatch")
    var out: RenderDoodadModel[]
    var i: int32
    while i < fileDataIDs.len:
        let stat: local_files.LocalFileAuditEntryStat = stats[i]
        if stat.fileDataID != fileDataIDs[i]:
            renderFreeDoodadModels(out)
            return Err[RenderDoodadModel[]]("wowExport render: MAID doodad model stat order mismatch")
        if renderFindDoodadModelIndex(out, stat.fileDataID) >= 0:
            renderFreeDoodadModels(out)
            return Err[RenderDoodadModel[]](strutil.Join(["wowExport render: duplicate MAID doodad model ", strings.IntToStr(stat.fileDataID)], ""))
        let modelRes: Result[RenderDoodadModel] =
            renderLoadM2ModelFromEntry(manifest.clientPath,
                                       stat.fileDataID,
                                       stat.encodingKey,
                                       stat.archiveIndex,
                                       stat.offset,
                                       stat.size,
                                       "MAID doodad",
                                       false)
        if IsErr(modelRes):
            renderFreeDoodadModels(out)
            return Err[RenderDoodadModel[]](Error(modelRes))
        add(out, Value(modelRes))
        i = i + 1
    return Ok[RenderDoodadModel[]](out)

fn renderCollectWmoGroupFileDataIDs(buf: bytes.ByteBuffer,
                                    groupCount: int32): Result[int32[]] =
    if groupCount <= 0:
        return Err[int32[]]("wowExport render: WMO group count invalid")
    let headerRes: Result[asset_formats.FormatHeader] = asset_formats.ParseChunkedHeader(buf, "WMO")
    if IsErr(headerRes):
        return Err[int32[]](Error(headerRes))
    var out: int32[]
    var found: bool
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[int32[]]("wowExport render: WMO root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[int32[]]("wowExport render: WMO root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('D'), int32('I'), int32('F'), int32('G')):
            if found:
                return Err[int32[]]("wowExport render: duplicate WMO GFID chunk")
            let baseGroupBytes: int32 = groupCount * 4
            if (size % 4) != 0 ||
                size < baseGroupBytes ||
                (size % baseGroupBytes) != 0:
                return Err[int32[]]("wowExport render: WMO GFID chunk size invalid")
            var i: int32
            while i < groupCount:
                let fileDataID: int32 = bytes.ReadU32LEAt(buf, dataPos + i * 4)
                if fileDataID <= 0:
                    return Err[int32[]]("wowExport render: WMO GFID fileDataID invalid")
                add(out, fileDataID)
                i = i + 1
            found = true
        pos = dataPos + size
    if !found || out.len <= 0:
        return Err[int32[]]("wowExport render: WMO GFID group fileDataIDs missing")
    return Ok[int32[]](out)

fn renderAppendMaidWorldModelGroupRefs(rootFileDataID: int32,
                                       groupFileDataIDs: int32[],
                                       refs: var RenderMaidWorldModelGroupRef[],
                                       uniqueGroupFileDataIDs: var int32[]): Result[bool] =
    var i: int32
    while i < groupFileDataIDs.len:
        let groupFileDataID: int32 = groupFileDataIDs[i]
        if groupFileDataID <= 0:
            return Err[bool]("wowExport render: MAID WMO group fileDataID invalid")
        var refIndex: int32
        while refIndex < refs.len:
            if refs[refIndex].rootFileDataID == rootFileDataID &&
                refs[refIndex].groupFileDataID == groupFileDataID:
                return Err[bool]("wowExport render: duplicate MAID WMO GFID reference")
            refIndex = refIndex + 1
        var groupRef: RenderMaidWorldModelGroupRef
        groupRef.rootFileDataID = rootFileDataID
        groupRef.groupFileDataID = groupFileDataID
        add(refs, groupRef)
        if !renderInt32ListContains(uniqueGroupFileDataIDs, groupFileDataID):
            add(uniqueGroupFileDataIDs, groupFileDataID)
        i = i + 1
    return Ok[bool](true)

fn renderLoadMaidWorldModelGroups(manifest: northshire.NorthshireManifest,
                                  rootFileDataIDs: int32[],
                                  groupRefs: var RenderMaidWorldModelGroupRef[],
                                  groupReferenceCountOut: var int32,
                                  materialCountOut: var int32,
                                  lightCountOut: var int32,
                                  groupBatchCountOut: var int32,
                                  groupMaterialInfoCountOut: var int32,
                                  groupTriangleIndexCountOut: var int32,
                                  groupTriangleCountOut: var int32): Result[RenderWmoGroupModel[]] =
    if rootFileDataIDs.len <= 0:
        return Err[RenderWmoGroupModel[]]("wowExport render: no MAID world-model WMO fileDataIDs")
    let rootStatsRes: Result[local_files.LocalFileAuditEntryStat[]] =
        local_files.ResolveLocalFileAuditEntryStatsRanged(manifest.clientPath, rootFileDataIDs)
    if IsErr(rootStatsRes):
        return Err[RenderWmoGroupModel[]](Error(rootStatsRes))
    let rootStats: local_files.LocalFileAuditEntryStat[] = Value(rootStatsRes)
    if rootStats.len != rootFileDataIDs.len:
        return Err[RenderWmoGroupModel[]]("wowExport render: MAID world-model root stat count mismatch")
    var uniqueGroupFileDataIDs: int32[]
    var rootIndex: int32
    while rootIndex < rootFileDataIDs.len:
        let rootStat: local_files.LocalFileAuditEntryStat = rootStats[rootIndex]
        if rootStat.fileDataID != rootFileDataIDs[rootIndex]:
            return Err[RenderWmoGroupModel[]]("wowExport render: MAID world-model root stat order mismatch")
        let rootBufRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByStat(manifest.clientPath, rootStat)
        if IsErr(rootBufRes):
            return Err[RenderWmoGroupModel[]](Error(rootBufRes))
        let rootBuf: bytes.ByteBuffer = Value(rootBufRes)
        let rootSummaryRes: Result[asset_formats.WmoRootSummary] =
            asset_formats.ParseWmoRootSummary(rootBuf)
        if IsErr(rootSummaryRes):
            bytes.FreeByteBuffer(rootBuf)
            return Err[RenderWmoGroupModel[]](Error(rootSummaryRes))
        let rootSummary: asset_formats.WmoRootSummary = Value(rootSummaryRes)
        materialCountOut = materialCountOut + rootSummary.materialCount
        lightCountOut = lightCountOut + rootSummary.lightCount
        let groupIDsRes: Result[int32[]] =
            renderCollectWmoGroupFileDataIDs(rootBuf, rootSummary.groupCount)
        if IsErr(groupIDsRes):
            bytes.FreeByteBuffer(rootBuf)
            return Err[RenderWmoGroupModel[]](Error(groupIDsRes))
        let groupIDs: int32[] = Value(groupIDsRes)
        if groupIDs.len != rootSummary.groupCount ||
            rootSummary.groupFileDataIDCount < rootSummary.groupCount:
            bytes.FreeByteBuffer(rootBuf)
            return Err[RenderWmoGroupModel[]]("wowExport render: MAID WMO GFID count mismatch")
        let refRes: Result[bool] =
            renderAppendMaidWorldModelGroupRefs(rootStat.fileDataID,
                                                groupIDs,
                                                groupRefs,
                                                uniqueGroupFileDataIDs)
        bytes.FreeByteBuffer(rootBuf)
        if IsErr(refRes):
            return Err[RenderWmoGroupModel[]](Error(refRes))
        rootIndex = rootIndex + 1
    groupReferenceCountOut = groupRefs.len
    if uniqueGroupFileDataIDs.len <= 0:
        return Err[RenderWmoGroupModel[]]("wowExport render: no MAID WMO group fileDataIDs")
    let groupStatsRes: Result[local_files.LocalFileAuditEntryStat[]] =
        local_files.ResolveLocalFileAuditEntryStatsRanged(manifest.clientPath, uniqueGroupFileDataIDs)
    if IsErr(groupStatsRes):
        return Err[RenderWmoGroupModel[]](Error(groupStatsRes))
    let groupStats: local_files.LocalFileAuditEntryStat[] = Value(groupStatsRes)
    if groupStats.len != uniqueGroupFileDataIDs.len:
        return Err[RenderWmoGroupModel[]]("wowExport render: MAID WMO group stat count mismatch")
    var out: RenderWmoGroupModel[]
    var groupIndex: int32
    while groupIndex < uniqueGroupFileDataIDs.len:
        let groupStat: local_files.LocalFileAuditEntryStat = groupStats[groupIndex]
        if groupStat.fileDataID != uniqueGroupFileDataIDs[groupIndex]:
            renderFreeWmoGroupModels(out)
            return Err[RenderWmoGroupModel[]]("wowExport render: MAID WMO group stat order mismatch")
        let groupBufRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByStat(manifest.clientPath, groupStat)
        if IsErr(groupBufRes):
            renderFreeWmoGroupModels(out)
            return Err[RenderWmoGroupModel[]](Error(groupBufRes))
        let groupBuf: bytes.ByteBuffer = Value(groupBufRes)
        let groupSummaryRes: Result[asset_formats.WmoGroupSummary] =
            asset_formats.ParseWmoGroupSummary(groupBuf)
        if IsErr(groupSummaryRes):
            bytes.FreeByteBuffer(groupBuf)
            renderFreeWmoGroupModels(out)
            return Err[RenderWmoGroupModel[]](Error(groupSummaryRes))
        let groupSummary: asset_formats.WmoGroupSummary = Value(groupSummaryRes)
        groupBatchCountOut = groupBatchCountOut + groupSummary.batchCount
        groupMaterialInfoCountOut = groupMaterialInfoCountOut + groupSummary.materialInfoCount
        var chunks: RenderWmoGroupChunks
        let chunksRes: Result[bool] = renderFindWmoGroupChunks(groupBuf, chunks)
        if IsErr(chunksRes):
            bytes.FreeByteBuffer(groupBuf)
            renderFreeWmoGroupModels(out)
            return Err[RenderWmoGroupModel[]](Error(chunksRes))
        if chunks.vertexCount <= 0 ||
            chunks.vertexCount != groupSummary.vertexCount ||
            chunks.indexCount != groupSummary.indexCount ||
            chunks.materialInfoCount != groupSummary.materialInfoCount ||
            chunks.batchCount != groupSummary.batchCount:
            bytes.FreeByteBuffer(groupBuf)
            renderFreeWmoGroupModels(out)
            return Err[RenderWmoGroupModel[]]("wowExport render: MAID WMO group chunk count mismatch")
        groupTriangleIndexCountOut = groupTriangleIndexCountOut + chunks.indexCount
        groupTriangleCountOut = groupTriangleCountOut + chunks.indexCount / 3
        var group: RenderWmoGroupModel
        group.fileDataID = groupStat.fileDataID
        group.vertexCount = chunks.vertexCount
        group.vertexOffset = chunks.vertexOffset
        group.indexCount = chunks.indexCount
        group.indexOffset = chunks.indexOffset
        group.materialInfoCount = chunks.materialInfoCount
        group.materialInfoOffset = chunks.materialInfoOffset
        group.batchCount = chunks.batchCount
        group.batchOffset = chunks.batchOffset
        group.buf = groupBuf
        add(out, group)
        groupIndex = groupIndex + 1
    return Ok[RenderWmoGroupModel[]](out)

fn renderCollectWmoModelSlots(buf: bytes.ByteBuffer): Result[int32[]] =
    var out: int32[]
    var found: bool
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[int32[]]("wowExport render: WMO root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[int32[]]("wowExport render: WMO root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('I'), int32('D'), int32('O'), int32('M')):
            if found:
                return Err[int32[]]("wowExport render: duplicate WMO MODI chunk")
            if (size % 4) != 0:
                return Err[int32[]]("wowExport render: WMO MODI chunk size invalid")
            var i: int32
            while i < size / 4:
                add(out, bytes.ReadU32LEAt(buf, dataPos + i * 4))
                i = i + 1
            found = true
        pos = dataPos + size
    if !found || out.len <= 0:
        return Err[int32[]]("wowExport render: WMO MODI slots missing")
    return Ok[int32[]](out)

fn renderResolveWmoModelSlot(modelSlots: int32[], slot: int32): Result[int32] =
    if slot < 0 || slot >= modelSlots.len:
        return Err[int32](strutil.Join(["wowExport render: WMO MODD model slot out of MODI range ", strings.IntToStr(slot)], ""))
    let fileDataID: int32 = modelSlots[slot]
    if fileDataID <= 0:
        return Err[int32](strutil.Join(["wowExport render: WMO MODD model slot has no MODI fileDataID ", strings.IntToStr(slot)], ""))
    return Ok[int32](fileDataID)

fn renderReadDoodadPlacement(buf: bytes.ByteBuffer,
                             rec: int32,
                             modelSlots: int32[]): Result[RenderDoodadPlacement] =
    if rec < 0 || rec + renderWmoDoodadPlacementStride > buf.len:
        return Err[RenderDoodadPlacement]("wowExport render: WMO MODD record out of bounds")
    let slot: int32 = bytes.ReadU32LEAt(buf, rec) & 0x00ffffff
    let fileDataIDRes: Result[int32] = renderResolveWmoModelSlot(modelSlots, slot)
    if IsErr(fileDataIDRes):
        return Err[RenderDoodadPlacement](Error(fileDataIDRes))
    let xRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 4, "WMO MODD x")
    let yRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 8, "WMO MODD y")
    let zRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 12, "WMO MODD z")
    let qxRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 16, "WMO MODD quaternion x")
    let qyRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 20, "WMO MODD quaternion y")
    let qzRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 24, "WMO MODD quaternion z")
    let qwRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 28, "WMO MODD quaternion w")
    let scaleRes: Result[int32] = renderF32FiniteScaled1000At(buf, rec + 32, "WMO MODD scale")
    if IsErr(xRes): return Err[RenderDoodadPlacement](Error(xRes))
    if IsErr(yRes): return Err[RenderDoodadPlacement](Error(yRes))
    if IsErr(zRes): return Err[RenderDoodadPlacement](Error(zRes))
    if IsErr(qxRes): return Err[RenderDoodadPlacement](Error(qxRes))
    if IsErr(qyRes): return Err[RenderDoodadPlacement](Error(qyRes))
    if IsErr(qzRes): return Err[RenderDoodadPlacement](Error(qzRes))
    if IsErr(qwRes): return Err[RenderDoodadPlacement](Error(qwRes))
    if IsErr(scaleRes): return Err[RenderDoodadPlacement](Error(scaleRes))
    var out: RenderDoodadPlacement
    out.fileDataID = Value(fileDataIDRes)
    out.x1000 = Value(xRes)
    out.y1000 = Value(yRes)
    out.z1000 = Value(zRes)
    out.qx1000 = Value(qxRes)
    out.qy1000 = Value(qyRes)
    out.qz1000 = Value(qzRes)
    out.qw1000 = Value(qwRes)
    out.scale1000 = Value(scaleRes)
    if out.qx1000 == 0 && out.qy1000 == 0 && out.qz1000 == 0 && out.qw1000 == 0:
        return Err[RenderDoodadPlacement]("wowExport render: WMO MODD quaternion is zero")
    if out.scale1000 <= 0:
        return Err[RenderDoodadPlacement]("wowExport render: WMO MODD scale is not positive")
    return Ok[RenderDoodadPlacement](out)

fn renderCountWmoDoodadModelInstanceVertices(buf: bytes.ByteBuffer,
                                             models: RenderDoodadModel[],
                                             countOut: var int32): Result[bool] =
    let modelSlotsRes: Result[int32[]] = renderCollectWmoModelSlots(buf)
    if IsErr(modelSlotsRes):
        return Err[bool](Error(modelSlotsRes))
    let modelSlots: int32[] = Value(modelSlotsRes)
    var found: bool
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO model count root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO model count root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('D'), int32('D'), int32('O'), int32('M')):
            if found:
                return Err[bool]("wowExport render: duplicate WMO model count MODD chunk")
            if (size % renderWmoDoodadPlacementStride) != 0:
                return Err[bool]("wowExport render: WMO model count MODD size invalid")
            var i: int32
            while i < size / renderWmoDoodadPlacementStride:
                let rec: int32 = dataPos + i * renderWmoDoodadPlacementStride
                let placementRes: Result[RenderDoodadPlacement] =
                    renderReadDoodadPlacement(buf, rec, modelSlots)
                if IsErr(placementRes):
                    return Err[bool](Error(placementRes))
                let placement: RenderDoodadPlacement = Value(placementRes)
                let modelIndex: int32 = renderFindDoodadModelIndex(models, placement.fileDataID)
                if modelIndex < 0:
                    return Err[bool](strutil.Join(["wowExport render: WMO doodad model not loaded for count ", strings.IntToStr(placement.fileDataID)], ""))
                countOut = countOut + models[modelIndex].vertexCount
                i = i + 1
            found = true
        pos = dataPos + size
    if !found:
        return Err[bool]("wowExport render: WMO model count MODD placements missing")
    return Ok[bool](true)

fn renderScanDoodadModelInstance(model: RenderDoodadModel,
                                 placement: RenderDoodadPlacement,
                                 bounds: var RenderBounds,
                                 countOut: var int32): Result[bool] =
    var i: int32
    while i < model.vertexCount:
        let pos: int32 = model.vertexOffset + i * 48
        let xRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos, "WMO doodad M2 x")
        let yRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 4, "WMO doodad M2 y")
        let zRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 8, "WMO doodad M2 z")
        if IsErr(xRes): return Err[bool](Error(xRes))
        if IsErr(yRes): return Err[bool](Error(yRes))
        if IsErr(zRes): return Err[bool](Error(zRes))
        var outX1000: int32
        var outY1000: int32
        var outZ1000: int32
        renderTransformDoodadVertex(placement,
                                    Value(xRes),
                                    Value(yRes),
                                    Value(zRes),
                                    outX1000,
                                    outY1000,
                                    outZ1000)
        renderAccumulateBounds(bounds, outX1000, outY1000, outZ1000)
        countOut = countOut + 1
        i = i + 1
    return Ok[bool](true)

fn renderScanDoodadModelInstancePlaced(model: RenderDoodadModel,
                                       placement: RenderDoodadPlacement,
                                       rootPlacement: RenderMaidWorldModelPlacement,
                                       bounds: var RenderBounds,
                                       countOut: var int32): Result[bool] =
    var i: int32
    while i < model.vertexCount:
        let pos: int32 = model.vertexOffset + i * 48
        let xRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos, "WMO placed doodad M2 x")
        let yRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 4, "WMO placed doodad M2 y")
        let zRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 8, "WMO placed doodad M2 z")
        if IsErr(xRes): return Err[bool](Error(xRes))
        if IsErr(yRes): return Err[bool](Error(yRes))
        if IsErr(zRes): return Err[bool](Error(zRes))
        var localX1000: int32
        var localY1000: int32
        var localZ1000: int32
        renderTransformDoodadVertex(placement,
                                    Value(xRes),
                                    Value(yRes),
                                    Value(zRes),
                                    localX1000,
                                    localY1000,
                                    localZ1000)
        var outX1000: int32
        var outY1000: int32
        var outZ1000: int32
        renderTransformMaidWorldModelVertex(rootPlacement,
                                            localX1000,
                                            localY1000,
                                            localZ1000,
                                            outX1000,
                                            outY1000,
