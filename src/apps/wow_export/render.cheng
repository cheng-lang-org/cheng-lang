fn renderCountMaidWorldModelPlacementsForFileDataID(assets: RenderMaidDoodadAssets,
                                                    fileDataID: int32): int32 =
    var out: int32
    var i: int32
    while i < assets.worldModelPlacements.len:
        if assets.worldModelPlacements[i].fileDataID == fileDataID:
            out = out + 1
        i = i + 1
    return out

fn renderScanWmoRootDoodadsInWorld(buf: bytes.ByteBuffer,
                                   models: RenderDoodadModel[],
                                   assets: RenderMaidDoodadAssets,
                                   rootFileDataID: int32,
                                   bounds: var RenderBounds,
                                   rootPlacementCountOut: var int32,
                                   doodadPlacementCountOut: var int32,
                                   modelVertexCountOut: var int32): Result[bool] =
    var matched: int32
    var i: int32
    while i < assets.worldModelPlacements.len:
        let rootPlacement: RenderMaidWorldModelPlacement = assets.worldModelPlacements[i]
        if rootPlacement.fileDataID == rootFileDataID:
            let placementScanRes: Result[bool] =
                renderScanWmoDoodadPlacementsPlaced(buf,
                                                    rootPlacement,
                                                    bounds,
                                                    doodadPlacementCountOut)
            if IsErr(placementScanRes):
                return Err[bool](Error(placementScanRes))
            let modelScanRes: Result[bool] =
                renderScanWmoDoodadModelInstancesPlaced(buf,
                                                        models,
                                                        rootPlacement,
                                                        bounds,
                                                        modelVertexCountOut)
            if IsErr(modelScanRes):
                return Err[bool](Error(modelScanRes))
            matched = matched + 1
        i = i + 1
    if matched <= 0:
        return Err[bool](strutil.Join(["wowExport render: WMO root has no MAID world placement ", strings.IntToStr(rootFileDataID)], ""))
    rootPlacementCountOut = rootPlacementCountOut + matched
    return Ok[bool](true)

fn renderDrawWmoRootDoodadsInWorld(tga: bytes.ByteBuffer,
                                   width: int32,
                                   height: int32,
                                   buf: bytes.ByteBuffer,
                                   models: RenderDoodadModel[],
                                   assets: RenderMaidDoodadAssets,
                                   rootFileDataID: int32,
                                   bounds: RenderBounds,
                                   pixels: var int32): Result[bool] =
    var matched: int32
    var i: int32
    while i < assets.worldModelPlacements.len:
        let rootPlacement: RenderMaidWorldModelPlacement = assets.worldModelPlacements[i]
        if rootPlacement.fileDataID == rootFileDataID:
            let modelDrawRes: Result[bool] =
                renderDrawWmoDoodadModelInstancesPlaced(tga,
                                                        width,
                                                        height,
                                                        buf,
                                                        models,
                                                        rootPlacement,
                                                        bounds,
                                                        pixels)
            if IsErr(modelDrawRes):
                return Err[bool](Error(modelDrawRes))
            let placementDrawRes: Result[bool] =
                renderDrawWmoDoodadPlacementsPlaced(tga,
                                                    width,
                                                    height,
                                                    buf,
                                                    rootPlacement,
                                                    bounds,
                                                    pixels)
            if IsErr(placementDrawRes):
                return Err[bool](Error(placementDrawRes))
            matched = matched + 1
        i = i + 1
    if matched <= 0:
        return Err[bool](strutil.Join(["wowExport render: WMO root has no MAID draw placement ", strings.IntToStr(rootFileDataID)], ""))
    return Ok[bool](true)

fn renderScanMaidDoodadModelInstance(model: RenderDoodadModel,
                                     placement: RenderMaidDoodadPlacement,
                                     bounds: var RenderBounds,
                                     countOut: var int32): Result[bool] =
    var transform: RenderMaidWorldModelTransform
    renderMakeMaidDoodadTransform(placement, transform)
    var i: int32
    while i < model.vertexCount:
        let pos: int32 = model.vertexOffset + i * 48
        let xRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos, "WDT MAID doodad M2 x")
        let yRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 4, "WDT MAID doodad M2 y")
        let zRes: Result[int32] = renderF32FiniteScaled1000At(model.buf, pos + 8, "WDT MAID doodad M2 z")
        if IsErr(xRes): return Err[bool](Error(xRes))
        if IsErr(yRes): return Err[bool](Error(yRes))
        if IsErr(zRes): return Err[bool](Error(zRes))
        var outX1000: int32
        var outY1000: int32
        var outZ1000: int32
        renderApplyMaidWorldModelTransform(transform,
                                           Value(xRes),
                                           Value(yRes),
                                           Value(zRes),
                                           outX1000,
                                           outY1000,
                                           outZ1000)
        renderAccumulateBounds(bounds, outX1000, outY1000, outZ1000)
        countOut = countOut + 1
        i = i + 1
    return Ok[bool](true)

fn renderScanMaidDoodadModelInstances(assets: RenderMaidDoodadAssets,
                                      bounds: var RenderBounds,
                                      countOut: var int32): Result[bool] =
    if assets.doodadPlacements.len <= 0 || assets.doodadModels.len <= 0:
        return Err[bool]("wowExport render: no MAID doodad model instances")
    var i: int32
    while i < assets.doodadPlacements.len:
        let placement: RenderMaidDoodadPlacement = assets.doodadPlacements[i]
        let modelIndex: int32 = renderFindDoodadModelIndex(assets.doodadModels, placement.fileDataID)
        if modelIndex < 0:
            return Err[bool](strutil.Join(["wowExport render: MAID doodad model not loaded ", strings.IntToStr(placement.fileDataID)], ""))
        let scanRes: Result[bool] =
            renderScanMaidDoodadModelInstance(assets.doodadModels[modelIndex],
                                             placement,
                                             bounds,
                                             countOut)
        if IsErr(scanRes):
            return Err[bool](Error(scanRes))
        i = i + 1
    return Ok[bool](true)

