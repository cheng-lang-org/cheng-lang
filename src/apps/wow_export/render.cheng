        renderAccumulateBounds(bounds, outX1000, outY1000, outZ1000)
        countOut = countOut + 1
        i = i + 1
    return Ok[bool](true)

fn renderScanWmoDoodadModelInstances(buf: bytes.ByteBuffer,
                                     models: RenderDoodadModel[],
                                     bounds: var RenderBounds,
                                     countOut: var int32): Result[bool] =
    let modelSlotsRes: Result[int32[]] = renderCollectWmoModelSlots(buf)
    if IsErr(modelSlotsRes):
        return Err[bool](Error(modelSlotsRes))
    let modelSlots: int32[] = Value(modelSlotsRes)
    var found: bool
    var pos: int32
    while pos < buf.len:
        if pos + 8 > buf.len:
            return Err[bool]("wowExport render: WMO root truncated chunk")
        let size: int32 = bytes.ReadU32LEAt(buf, pos + 4)
        let dataPos: int32 = pos + 8
        if size < 0 || dataPos + size > buf.len:
            return Err[bool]("wowExport render: WMO root chunk out of bounds")
        if renderHasFourCC(buf, pos, int32('D'), int32('D'), int32('O'), int32('M')):
            if found:
                return Err[bool]("wowExport render: duplicate WMO MODD chunk")
            if (size % renderWmoDoodadPlacementStride) != 0:
                return Err[bool]("wowExport render: WMO MODD size invalid")
            var i: int32
            while i < size / renderWmoDoodadPlacementStride:
                let rec: int32 = dataPos + i * renderWmoDoodadPlacementStride
                let placementRes: Result[RenderDoodadPlacement] =
                    renderReadDoodadPlacement(buf, rec, modelSlots)
                if IsErr(placementRes):
                    return Err[bool](Error(placementRes))
                let placement: RenderDoodadPlacement = Value(placementRes)
                let modelIndex: int32 = renderFindDoodadModelIndex(models, placement.fileDataID)
                if modelIndex < 0:
                    return Err[bool](strutil.Join(["wowExport render: WMO doodad model not loaded ", strings.IntToStr(placement.fileDataID)], ""))
                let scanRes: Result[bool] =
                    renderScanDoodadModelInstance(models[modelIndex], placement, bounds, countOut)
                if IsErr(scanRes):
                    return Err[bool](Error(scanRes))
                i = i + 1
            found = true
        pos = dataPos + size
    if !found:
        return Err[bool]("wowExport render: WMO MODD placements missing")
    return Ok[bool](true)

