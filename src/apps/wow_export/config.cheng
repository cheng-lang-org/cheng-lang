import std/os as os
import std/rawbytes as rawbytes
import std/result
import std/strings as strings
import std/strformat
import std/strutils as strutils
import std/system as system
import cheng/apps/wow_export/build_info as build_info

@importc("driver_c_read_file_all")
fn configReadFileAllRaw(path: cstring): cstring

type
    BuildConfig =
        root: str
        installContentKey: str
        installEncodingKey: str
        encodingContentKey: str
        encodingEncodingKey: str
        encodingContentSize: int32
        encodingEncodingSize: int32
        vfsRootContentKey: str
        vfsRootEncodingKey: str
        vfsRootContentSize: int32
        vfsRootEncodingSize: int32
        buildName: str
        buildUid: str
        buildProduct: str

const
    DefaultBuildRoot = "4d538d779c8ce517fed1b8718bea2b79"
    DefaultBuildInstallContentKey = "f9b29cc36041e88756dd4d8ca4fd370f"
    DefaultBuildInstallEncodingKey = "b3fcfc3083d76138ab9463a91cff3e81"
    DefaultBuildEncodingContentKey = "64744693c0099427bbf7a43308668a85"
    DefaultBuildEncodingEncodingKey = "00f6dcef63eafe6254ab5408ea8baa09"
    DefaultBuildEncodingContentSize = 195150125
    DefaultBuildEncodingEncodingSize = 183655454
    DefaultBuildVfsRootContentKey = "9f2e0d03cc1dba00662ad0097504bae2"
    DefaultBuildVfsRootEncodingKey = "2aece4e2ec64a8c89753c53f4d0207ca"
    DefaultBuildVfsRootContentSize = 55471
    DefaultBuildVfsRootEncodingSize = 34973
    DefaultBuildName = "WOW-67165patch12.0.5_Retail"
    DefaultBuildUid = "wow"
    DefaultBuildProduct = "WoW"

fn KnownDefaultBuildConfig(): BuildConfig =
    var out: BuildConfig
    out.root = DefaultBuildRoot
    out.installContentKey = DefaultBuildInstallContentKey
    out.installEncodingKey = DefaultBuildInstallEncodingKey
    out.encodingContentKey = DefaultBuildEncodingContentKey
    out.encodingEncodingKey = DefaultBuildEncodingEncodingKey
    out.encodingContentSize = DefaultBuildEncodingContentSize
    out.encodingEncodingSize = DefaultBuildEncodingEncodingSize
    out.vfsRootContentKey = DefaultBuildVfsRootContentKey
    out.vfsRootEncodingKey = DefaultBuildVfsRootEncodingKey
    out.vfsRootContentSize = DefaultBuildVfsRootContentSize
    out.vfsRootEncodingSize = DefaultBuildVfsRootEncodingSize
    out.buildName = DefaultBuildName
    out.buildUid = DefaultBuildUid
    out.buildProduct = DefaultBuildProduct
    return out

fn ConfigValue(line: str): Result[str[]] =
    let parts: str[] = strutils.Split(line, '=')
    if parts.len < 2:
        return Err[str[]]("wowExport config: malformed key/value")
    return Ok[str[]](parts)

fn ConfigPairFirst(value: str): str =
    let parts: str[] = strutils.SplitWhitespace(strutils.Strip(value))
    if parts.len <= 0:
        return ""
    return parts[0]

fn ConfigPairSecond(value: str): str =
    let parts: str[] = strutils.SplitWhitespace(strutils.Strip(value))
    if parts.len < 2:
        return ""
    return parts[1]

fn ConfigPairFirstInt(value: str): int32 =
    let text: str = ConfigPairFirst(value)
    if strings.Len(text) == 0:
        return 0
    return int32(strutils.ParseInt(text))

fn ConfigPairSecondInt(value: str): int32 =
    let text: str = ConfigPairSecond(value)
    if strings.Len(text) == 0:
        return 0
    return int32(strutils.ParseInt(text))

fn ParseBuildConfigText(text: str): Result[BuildConfig] =
    if strings.Len(text) == 0:
        return Err[BuildConfig]("wowExport config: empty build config")
    let lines: str[] = strutils.Split(text, '\n')
    var out: BuildConfig
    var i: int32
    while i < lines.len:
        let line: str = strutils.Strip(lines[i])
        if strings.Len(line) == 0 || strings.HasPrefix(line, "#"):
            i = i + 1
            continue
        let pairRes: Result[str[]] = ConfigValue(line)
        if IsErr(pairRes):
            return Err[BuildConfig](Error(pairRes))
        let parts: str[] = Value(pairRes)
        let key: str = strutils.Strip(parts[0])
        let value: str = strutils.Strip(parts[1])
        if key == "root":
            out.root = value
        elif key == "install":
            out.installContentKey = ConfigPairFirst(value)
            out.installEncodingKey = ConfigPairSecond(value)
        elif key == "encoding":
            out.encodingContentKey = ConfigPairFirst(value)
            out.encodingEncodingKey = ConfigPairSecond(value)
        elif key == "encoding-size":
            out.encodingContentSize = ConfigPairFirstInt(value)
            out.encodingEncodingSize = ConfigPairSecondInt(value)
        elif key == "vfs-root":
            out.vfsRootContentKey = ConfigPairFirst(value)
            out.vfsRootEncodingKey = ConfigPairSecond(value)
        elif key == "vfs-root-size":
            out.vfsRootContentSize = ConfigPairFirstInt(value)
            out.vfsRootEncodingSize = ConfigPairSecondInt(value)
        elif key == "build-name":
            out.buildName = value
        elif key == "build-uid":
            out.buildUid = value
        elif key == "build-product":
            out.buildProduct = value
        i = i + 1
    if strings.Len(out.root) != 32:
        return Err[BuildConfig]("wowExport config: missing root content key")
    if strings.Len(out.encodingEncodingKey) != 32:
        return Err[BuildConfig]("wowExport config: missing encoding encoding key")
    if out.encodingEncodingSize <= 0:
        return Err[BuildConfig]("wowExport config: missing encoding encoding size")
    if strings.Len(out.vfsRootEncodingKey) != 32:
        return Err[BuildConfig]("wowExport config: missing vfs-root encoding key")
    if out.vfsRootEncodingSize <= 0:
        return Err[BuildConfig]("wowExport config: missing vfs-root encoding size")
    if strings.Len(out.buildName) == 0:
        return Err[BuildConfig]("wowExport config: missing build-name")
    return Ok[BuildConfig](out)

fn LoadBuildConfig(clientPath: str, buildKey: str): Result[BuildConfig] =
    if buildKey == build_info.DefaultBuildKey:
        return Ok[BuildConfig](KnownDefaultBuildConfig())
    if strings.Len(buildKey) != 32:
        return Err[BuildConfig]("wowExport config: build key must be 32 hex chars")
    let clientBytes: rawbytes.Bytes = rawbytes.BytesFromString(clientPath)
    let prefixBytes: rawbytes.Bytes = rawbytes.BytesFromString("/Data/config/")
    let slashBytes: rawbytes.Bytes = rawbytes.BytesFromString("/")
    let keyBytes: rawbytes.Bytes = rawbytes.BytesFromString(buildKey)
    let totalLen: int32 =
        clientBytes.len + prefixBytes.len + 2 + slashBytes.len + 2 + slashBytes.len + keyBytes.len
    var pathBytes: rawbytes.Bytes = rawbytes.BytesAlloc(totalLen + 1)
    var offset: int32
    rawbytes.BytesCopyInto(pathBytes, offset, clientBytes)
    offset = offset + clientBytes.len
    rawbytes.BytesCopyInto(pathBytes, offset, prefixBytes)
    offset = offset + prefixBytes.len
    rawbytes.BytesSet(pathBytes, offset, rawbytes.BytesGet(keyBytes, 0))
    rawbytes.BytesSet(pathBytes, offset + 1, rawbytes.BytesGet(keyBytes, 1))
    offset = offset + 2
    rawbytes.BytesCopyInto(pathBytes, offset, slashBytes)
    offset = offset + slashBytes.len
    rawbytes.BytesSet(pathBytes, offset, rawbytes.BytesGet(keyBytes, 2))
    rawbytes.BytesSet(pathBytes, offset + 1, rawbytes.BytesGet(keyBytes, 3))
    offset = offset + 2
    rawbytes.BytesCopyInto(pathBytes, offset, slashBytes)
    offset = offset + slashBytes.len
    rawbytes.BytesCopyInto(pathBytes, offset, keyBytes)
    rawbytes.BytesSet(pathBytes, totalLen, 0)
    rawbytes.BytesFree(clientBytes)
    rawbytes.BytesFree(prefixBytes)
    rawbytes.BytesFree(slashBytes)
    rawbytes.BytesFree(keyBytes)
    let pathRaw: cstring = cstring(pathBytes.data)
    let textRaw: cstring = configReadFileAllRaw(pathRaw)
    rawbytes.BytesFree(pathBytes)
    if textRaw == nil:
        return Err[BuildConfig]("wowExport config: failed to read local build config")
    let textLen: int32 = system.c_strlen(textRaw)
    if textLen <= 0:
        free(ptr(textRaw))
        return Err[BuildConfig]("wowExport config: failed to read local build config")
    let text: str = system.strFromCStringCopy(textRaw)
    free(ptr(textRaw))
    return ParseBuildConfigText(text)

fn BuildConfigSummary(cfg: BuildConfig): str =
    return Fmt"buildName={cfg.buildName} root={cfg.root} encoding={cfg.encodingEncodingKey}"
