import std/bytes as bytes
import std/os as os
import std/rawbytes as rawbytes
import std/result
import std/strings as strings
import std/strformat
import cheng/apps/wow_export/binary as binary
import cheng/apps/wow_export/build_info as build_info
import std/strutils as strutil

type
    CascIndexEntry =
        keyPrefix: str
        archiveIndex: int32
        offset: int32
        size: int32

    CascIndexSummary =
        entryCount: int32
        first: CascIndexEntry

fn cascIndexReadFileBytes(path: str): Result[bytes.ByteBuffer] =
    let out: bytes.ByteBuffer = bytes.ReadFileBytes(path)
    if out.len <= 0:
        return Err[bytes.ByteBuffer]("wowExport index: failed to open local idx")
    return Ok[bytes.ByteBuffer](out)

fn cascIndexListDataDir(clientPath: str): Result[str[]] =
    let dataDirPath: str = build_info.DataDataPath(clientPath)
    if !os.DirExists(dataDirPath):
        return Err[str[]](strutil.Join(["wowExport index: missing data dir ", dataDirPath], ""))
    let names: str[] = os.ListDir(dataDirPath)
    if names.len <= 0:
        return Err[str[]](strutil.Join(["wowExport index: failed to list data dir ", dataDirPath], ""))
    return Ok[str[]](names)

fn ReadBE24TopArchiveBits(buf: bytes.ByteBuffer, idx: int32): Result[int32] =
    if idx < 0 || idx + 4 > buf.len:
        return Err[int32]("wowExport index: truncated idxLow")
    let b0: int32 = bytes.BufByteAt(buf, idx)
    return Ok[int32](b0 / 64)

fn ReadOffset30(buf: bytes.ByteBuffer, idx: int32): Result[int32] =
    if idx < 0 || idx + 4 > buf.len:
        return Err[int32]("wowExport index: truncated offset")
    let b0: int32 = bytes.BufByteAt(buf, idx) & 63
    let b1: int32 = bytes.BufByteAt(buf, idx + 1)
    let b2: int32 = bytes.BufByteAt(buf, idx + 2)
    let b3: int32 = bytes.BufByteAt(buf, idx + 3)
    return Ok[int32]((b0 << 24) + (b1 << 16) + (b2 << 8) + b3)

fn ParseJournalIndex(buf: bytes.ByteBuffer): Result[CascIndexSummary] =
    if buf.len < 16:
        return Err[CascIndexSummary]("wowExport index: file too small")
    let headerHashSize: int32 = bytes.ReadU32LEAt(buf, 0)
    if headerHashSize < 0 || headerHashSize > buf.len:
        return Err[CascIndexSummary]("wowExport index: invalid header hash size")
    let headerEnd: int32 = 8 + headerHashSize
    let aligned: int32 = ((headerEnd + 15) / 16) * 16
    if aligned + 8 > buf.len:
        return Err[CascIndexSummary]("wowExport index: truncated data header")
    let dataLength: int32 = bytes.ReadU32LEAt(buf, aligned)
    if dataLength <= 0:
        return Err[CascIndexSummary]("wowExport index: empty data section")
    if dataLength % 18 != 0:
        return Err[CascIndexSummary]("wowExport index: entry section is not 18-byte aligned")
    let entryStart: int32 = aligned + 8
    if entryStart + dataLength > buf.len:
        return Err[CascIndexSummary]("wowExport index: truncated entries")
    let entryCount: int32 = dataLength / 18
    if entryCount <= 0:
        return Err[CascIndexSummary]("wowExport index: no entries")

    let keyRes: Result[str] = binary.HexSlice(buf, entryStart, 9)
    if IsErr(keyRes):
        return Err[CascIndexSummary](Error(keyRes))
    let idxHigh: int32 = bytes.BufByteAt(buf, entryStart + 9)
    let topBitsRes: Result[int32] = ReadBE24TopArchiveBits(buf, entryStart + 10)
    if IsErr(topBitsRes):
        return Err[CascIndexSummary](Error(topBitsRes))
    let offsetRes: Result[int32] = ReadOffset30(buf, entryStart + 10)
    if IsErr(offsetRes):
        return Err[CascIndexSummary](Error(offsetRes))
    let size: int32 = bytes.ReadU32LEAt(buf, entryStart + 14)
    if size < 0:
        return Err[CascIndexSummary]("wowExport index: invalid first entry size")

    var first: CascIndexEntry
    first.keyPrefix = Value(keyRes)
    first.archiveIndex = idxHigh * 4 + Value(topBitsRes)
    first.offset = Value(offsetRes)
    first.size = size
    var out: CascIndexSummary
    out.entryCount = entryCount
    out.first = first
    return Ok[CascIndexSummary](out)

fn ParseEntryAt(buf: bytes.ByteBuffer, pos: int32): Result[CascIndexEntry] =
    if pos < 0 || pos + 18 > buf.len:
        return Err[CascIndexEntry]("wowExport index: entry out of bounds")
    let keyRes: Result[str] = binary.HexSlice(buf, pos, 9)
    if IsErr(keyRes):
        return Err[CascIndexEntry](Error(keyRes))
    let idxHigh: int32 = bytes.BufByteAt(buf, pos + 9)
    let topBitsRes: Result[int32] = ReadBE24TopArchiveBits(buf, pos + 10)
    if IsErr(topBitsRes):
        return Err[CascIndexEntry](Error(topBitsRes))
    let offsetRes: Result[int32] = ReadOffset30(buf, pos + 10)
    if IsErr(offsetRes):
        return Err[CascIndexEntry](Error(offsetRes))
    let size: int32 = bytes.ReadU32LEAt(buf, pos + 14)
    if size < 0:
        return Err[CascIndexEntry]("wowExport index: invalid entry size")
    var out: CascIndexEntry
    out.keyPrefix = Value(keyRes)
    out.archiveIndex = idxHigh * 4 + Value(topBitsRes)
    out.offset = Value(offsetRes)
    out.size = size
    return Ok[CascIndexEntry](out)

fn HexCharValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn KeyPrefixByte(keyPrefix: str, byteIndex: int32): int32 =
    let pos: int32 = byteIndex * 2
    if pos < 0 || pos + 1 >= strings.Len(keyPrefix):
        return -1
    let hi: int32 = HexCharValue(keyPrefix[pos])
    let lo: int32 = HexCharValue(keyPrefix[pos + 1])
    if hi < 0 || lo < 0:
        return -1
    return (hi << 4) | lo

fn EntryKeyMatches(buf: bytes.ByteBuffer, pos: int32, keyPrefix: str): bool =
    if pos < 0 || pos + 9 > buf.len:
        return false
    var i: int32
    for i in i..<9:
        let want: int32 = KeyPrefixByte(keyPrefix, i)
        if want < 0:
            return false
        if bytes.BufByteAt(buf, pos + i) != want:
            return false
    return true

fn BuildKeyPrefixBytes(keyPrefixes: str[]): Result[int32[]] =
    if keyPrefixes.len <= 0:
        return Err[int32[]]("wowExport index: empty key prefix list")
    var out: int32[]
    var keyIndex: int32
    for keyIndex in range(keyPrefixes.len):

        let keyPrefix: str = keyPrefixes[keyIndex]
        if strings.Len(keyPrefix) != 18:
            return Err[int32[]]("wowExport index: key prefix must be 18 hex chars")
        var byteIndex: int32
        for byteIndex in byteIndex..<9:
            let pos: int32 = byteIndex * 2
            let hi: int32 = HexCharValue(keyPrefix[pos])
            let lo: int32 = HexCharValue(keyPrefix[pos + 1])
            if hi < 0 || lo < 0:
                return Err[int32[]]("wowExport index: invalid key prefix hex")
            add(out, (hi << 4) | lo)

    return Ok[int32[]](out)

fn EntryKeyBytesMatches(buf: bytes.ByteBuffer,
                        pos: int32,
                        keyPrefixBytes: int32[],
                        keyIndex: int32): bool =
    if pos < 0 || pos + 9 > buf.len:
        return false
    let keyOffset: int32 = keyIndex * 9
    if keyOffset < 0 || keyOffset + 9 > keyPrefixBytes.len:
        return false
    var i: int32
    for i in i..<9:
        if bytes.BufByteAt(buf, pos + i) != keyPrefixBytes[keyOffset + i]:
            return false
    return true

fn FindJournalIndexEntry(buf: bytes.ByteBuffer, keyPrefix: str): Result[CascIndexEntry] =
    if strings.Len(keyPrefix) != 18:
        return Err[CascIndexEntry]("wowExport index: key prefix must be 18 hex chars")
    if buf.len < 16:
        return Err[CascIndexEntry]("wowExport index: file too small")
    let headerHashSize: int32 = bytes.ReadU32LEAt(buf, 0)
    if headerHashSize < 0 || headerHashSize > buf.len:
        return Err[CascIndexEntry]("wowExport index: invalid header hash size")
    let headerEnd: int32 = 8 + headerHashSize
    let aligned: int32 = ((headerEnd + 15) / 16) * 16
    if aligned + 8 > buf.len:
        return Err[CascIndexEntry]("wowExport index: truncated data header")
    let dataLength: int32 = bytes.ReadU32LEAt(buf, aligned)
    if dataLength <= 0 || dataLength % 18 != 0:
        return Err[CascIndexEntry]("wowExport index: invalid entry section")
    let entryStart: int32 = aligned + 8
    if entryStart + dataLength > buf.len:
        return Err[CascIndexEntry]("wowExport index: truncated entries")
    let entryCount: int32 = dataLength / 18
    var i: int32
    for i in i..<entryCount:
        let pos: int32 = entryStart + i * 18
        if EntryKeyMatches(buf, pos, keyPrefix):
            return ParseEntryAt(buf, pos)
    return Err[CascIndexEntry](strutil.Join(["wowExport index: key prefix not found ", keyPrefix], ""))

fn cascIndexInitEntryArray(count: int32): CascIndexEntry[] =
    var out: CascIndexEntry[]
    var i: int32
    for i in i..<count:
        var entry: CascIndexEntry
        add(out, entry)
    return out

fn cascIndexInitBoolArray(count: int32): bool[] =
    var out: bool[]
    var i: int32
    for i in i..<count:
        add(out, false)
    return out

fn FindJournalIndexEntries(buf: bytes.ByteBuffer,
                           keyPrefixBytes: int32[],
                           keyPrefixCount: int32,
                           foundFlags: var bool[],
                           entries: var CascIndexEntry[],
                           matchedCount: var int32): Result[bool] =
    if keyPrefixCount <= 0:
        return Err[bool]("wowExport index: empty key prefix list")
    if keyPrefixBytes.len != keyPrefixCount * 9:
        return Err[bool]("wowExport index: key prefix byte table size mismatch")
    if buf.len < 16:
        return Err[bool]("wowExport index: file too small")
    let headerHashSize: int32 = bytes.ReadU32LEAt(buf, 0)
    if headerHashSize < 0 || headerHashSize > buf.len:
        return Err[bool]("wowExport index: invalid header hash size")
    let headerEnd: int32 = 8 + headerHashSize
    let aligned: int32 = ((headerEnd + 15) / 16) * 16
    if aligned + 8 > buf.len:
        return Err[bool]("wowExport index: truncated data header")
    let dataLength: int32 = bytes.ReadU32LEAt(buf, aligned)
    if dataLength <= 0 || dataLength % 18 != 0:
        return Err[bool]("wowExport index: invalid entry section")
    let entryStart: int32 = aligned + 8
    if entryStart + dataLength > buf.len:
        return Err[bool]("wowExport index: truncated entries")
    let entryCount: int32 = dataLength / 18
    var i: int32
    while i < entryCount && matchedCount < keyPrefixCount:
        let pos: int32 = entryStart + i * 18
        var wantedIndex: int32
        for wantedIndex in wantedIndex..<keyPrefixCount:
            if !foundFlags[wantedIndex] && EntryKeyBytesMatches(buf, pos, keyPrefixBytes, wantedIndex):
                let entryRes: Result[CascIndexEntry] = ParseEntryAt(buf, pos)
                if IsErr(entryRes):
                    return Err[bool](Error(entryRes))
                entries[wantedIndex] = Value(entryRes)
                foundFlags[wantedIndex] = true
                matchedCount = matchedCount + 1
        i = i + 1
    return Ok[bool](true)

fn LoadFirstJournalIndexSummary(clientPath: str): Result[CascIndexSummary] =
    let namesRes: Result[str[]] = cascIndexListDataDir(clientPath)
    if IsErr(namesRes):
        return Err[CascIndexSummary](Error(namesRes))
    let names: str[] = Value(namesRes)
    let dataDirPath: str = build_info.DataDataPath(clientPath)
    var i: int32
    for i in i..<names.len:
        let name: str = names[i]
        if strings.HasSuffix(name, ".idx"):
            let readRes: Result[bytes.ByteBuffer] =
                cascIndexReadFileBytes(build_info.StablePathJoin(dataDirPath, name))
            if IsErr(readRes):
                return Err[CascIndexSummary](strutil.Join([Error(readRes), " name=", name], ""))
            let buf: bytes.ByteBuffer = Value(readRes)
            let summaryRes: Result[CascIndexSummary] = ParseJournalIndex(buf)
            bytes.FreeByteBuffer(buf)
            return summaryRes
    return Err[CascIndexSummary](strutil.Join(["wowExport index: no .idx files in ", build_info.DataDataPath(clientPath)], ""))

fn EncodingKeyPrefix(encodingKey: str): Result[str] =
    if strings.Len(encodingKey) < 18:
        return Err[str]("wowExport index: encoding key too short")
    return Ok[str](strings.SliceBytes(encodingKey, 0, 18))

fn LoadLocalIndexEntry(clientPath: str, encodingKey: str): Result[CascIndexEntry] =
    let prefixRes: Result[str] = EncodingKeyPrefix(encodingKey)
    if IsErr(prefixRes):
        return Err[CascIndexEntry](Error(prefixRes))
    let prefix: str = Value(prefixRes)
    let namesRes: Result[str[]] = cascIndexListDataDir(clientPath)
    if IsErr(namesRes):
        return Err[CascIndexEntry](Error(namesRes))
    let names: str[] = Value(namesRes)
    let dataDirPath: str = build_info.DataDataPath(clientPath)
    var i: int32
    for i in i..<names.len:
        let name: str = names[i]
        if strings.HasSuffix(name, ".idx"):
            let readRes: Result[bytes.ByteBuffer] =
                cascIndexReadFileBytes(build_info.StablePathJoin(dataDirPath, name))
            if IsErr(readRes):
                return Err[CascIndexEntry](strutil.Join([Error(readRes), " name=", name], ""))
            let buf: bytes.ByteBuffer = Value(readRes)
            let entryRes: Result[CascIndexEntry] = FindJournalIndexEntry(buf, prefix)
            bytes.FreeByteBuffer(buf)
            if IsOk(entryRes):
                return entryRes
    return Err[CascIndexEntry](strutil.Join(["wowExport index: local encoding key not found ", encodingKey], ""))

fn LoadLocalIndexEntries(clientPath: str, encodingKeys: str[]): Result[CascIndexEntry[]] =
    if encodingKeys.len <= 0:
        return Err[CascIndexEntry[]]("wowExport index: empty encoding key list")
    var keyPrefixes: str[]
    var keyIndex: int32
    for keyIndex in keyIndex..<encodingKeys.len:
        let prefixRes: Result[str] = EncodingKeyPrefix(encodingKeys[keyIndex])
        if IsErr(prefixRes):
            return Err[CascIndexEntry[]](Error(prefixRes))
        add(keyPrefixes, Value(prefixRes))
    let keyPrefixBytesRes: Result[int32[]] = BuildKeyPrefixBytes(keyPrefixes)
    if IsErr(keyPrefixBytesRes):
        return Err[CascIndexEntry[]](Error(keyPrefixBytesRes))
    let keyPrefixBytes: int32[] = Value(keyPrefixBytesRes)
    let namesRes: Result[str[]] = cascIndexListDataDir(clientPath)
    if IsErr(namesRes):
        return Err[CascIndexEntry[]](Error(namesRes))
    let names: str[] = Value(namesRes)
    let dataDirPath: str = build_info.DataDataPath(clientPath)
    var entries: CascIndexEntry[] = cascIndexInitEntryArray(encodingKeys.len)
    var foundFlags: bool[] = cascIndexInitBoolArray(encodingKeys.len)
    var matchedCount: int32
    var i: int32
    while i < names.len && matchedCount < encodingKeys.len:
        let name: str = names[i]
        if strings.HasSuffix(name, ".idx"):
            let readRes: Result[bytes.ByteBuffer] =
                cascIndexReadFileBytes(build_info.StablePathJoin(dataDirPath, name))
            if IsErr(readRes):
                return Err[CascIndexEntry[]](strutil.Join([Error(readRes), " name=", name], ""))
            let buf: bytes.ByteBuffer = Value(readRes)
            let findRes: Result[bool] =
                FindJournalIndexEntries(buf, keyPrefixBytes, keyPrefixes.len,
                    foundFlags, entries, matchedCount)
            bytes.FreeByteBuffer(buf)
            if IsErr(findRes):
                return Err[CascIndexEntry[]](strutil.Join([Error(findRes), " name=", name], ""))
        i = i + 1
    if matchedCount != encodingKeys.len:
        return Err[CascIndexEntry[]]("wowExport index: not all local encoding keys found")
    return Ok[CascIndexEntry[]](entries)

fn DataArchivePath(clientPath: str, archiveIndex: int32): Result[str] =
    if archiveIndex < 0 || archiveIndex > 999:
        return Err[str]("wowExport index: archive index out of supported range")
    var idText: str = strings.IntToStr(archiveIndex)
    if archiveIndex < 10:
        idText = build_info.StableConcat("00", idText)
    elif archiveIndex < 100:
        idText = build_info.StableConcat("0", idText)
    let archiveName: str = build_info.StableConcat("data.", idText)
    return Ok[str](build_info.StablePathJoin(build_info.DataDataPath(clientPath), archiveName))

fn CascIndexSummaryText(summary: CascIndexSummary): str =
    return Fmt"entries={strings.IntToStr(summary.entryCount)} firstKey={summary.first.keyPrefix} archive={strings.IntToStr(summary.first.archiveIndex)} offset={strings.IntToStr(summary.first.offset)} size={strings.IntToStr(summary.first.size)}"

fn CascIndexEntryText(entry: CascIndexEntry): str =
    return Fmt"key={entry.keyPrefix} archive={strings.IntToStr(entry.archiveIndex)} offset={strings.IntToStr(entry.offset)} size={strings.IntToStr(entry.size)}"
