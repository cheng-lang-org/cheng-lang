import std/bytes as bytes
import std/result
import std/strings as strings
import std/strformat
import cheng/apps/wow_export/binary as binary
import cheng/apps/wow_export/casc_archive as casc_archive
import cheng/apps/wow_export/casc_index as casc_index
import std/strutils as strutil

type
    EncodingHeader =
        version: int32
        contentKeySize: int32
        encodingKeySize: int32
        contentPageSizeKB: int32
        encodingPageSizeKB: int32
        contentPageCount: int32
        encodingPageCount: int32
        specBlockSize: int32

    EncodingEntry =
        contentSize: int32
        contentKey: str
        encodingKey: str
        encodingKeyCount: int32

    EncodingSummary =
        header: EncodingHeader
        first: EncodingEntry

    EncodingLookupResult =
        contentKey: str
        encodingKey: str
        contentSize: int32
        encodingKeyCount: int32

const
    encodingHeaderSize = 22
    encodingPageHeaderSize = 32

fn encodingU16LEAt(buf: bytes.ByteBuffer, idx: int32): Result[int32] =
    if idx < 0 || idx + 2 > buf.len:
        return Err[int32]("wowExport encoding: truncated u16le")
    return Ok[int32](bytes.BufByteAt(buf, idx) + (bytes.BufByteAt(buf, idx + 1) << 8))

fn encodingU16BEAt(buf: bytes.ByteBuffer, idx: int32): Result[int32] =
    if idx < 0 || idx + 2 > buf.len:
        return Err[int32]("wowExport encoding: truncated u16be")
    return Ok[int32]((bytes.BufByteAt(buf, idx) << 8) + bytes.BufByteAt(buf, idx + 1))

fn encodingU32BEAt(buf: bytes.ByteBuffer, idx: int32): Result[int32] =
    if idx < 0 || idx + 4 > buf.len:
        return Err[int32]("wowExport encoding: truncated u32be")
    let b0: int32 = bytes.BufByteAt(buf, idx)
    let b1: int32 = bytes.BufByteAt(buf, idx + 1)
    let b2: int32 = bytes.BufByteAt(buf, idx + 2)
    let b3: int32 = bytes.BufByteAt(buf, idx + 3)
    return Ok[int32]((b0 << 24) + (b1 << 16) + (b2 << 8) + b3)

fn WowEncodingParseHeader(buf: bytes.ByteBuffer): Result[EncodingHeader] =
    let headerRes: Result[EncodingHeader] = WowEncodingParseHeaderPrefix(buf)
    if IsErr(headerRes):
        return Err[EncodingHeader](Error(headerRes))
    let out: EncodingHeader = Value(headerRes)
    let minNeed: int32 = encodingHeaderSize + out.specBlockSize +
        out.contentPageCount * encodingPageHeaderSize
    if minNeed > buf.len:
        return Err[EncodingHeader]("wowExport encoding: truncated page table")
    return Ok[EncodingHeader](out)

fn WowEncodingParseHeaderPrefix(buf: bytes.ByteBuffer): Result[EncodingHeader] =
    if buf.len < encodingHeaderSize:
        return Err[EncodingHeader]("wowExport encoding: header too small")
    if bytes.BufByteAt(buf, 0) != int32('E') || bytes.BufByteAt(buf, 1) != int32('N'):
        return Err[EncodingHeader]("wowExport encoding: invalid magic")
    let cPageSizeRes: Result[int32] = encodingU16BEAt(buf, 5)
    let ePageSizeRes: Result[int32] = encodingU16BEAt(buf, 7)
    let cPageCountRes: Result[int32] = encodingU32BEAt(buf, 9)
    let ePageCountRes: Result[int32] = encodingU32BEAt(buf, 13)
    let specBlockSizeRes: Result[int32] = encodingU32BEAt(buf, 18)
    if IsErr(cPageSizeRes): return Err[EncodingHeader](Error(cPageSizeRes))
    if IsErr(ePageSizeRes): return Err[EncodingHeader](Error(ePageSizeRes))
    if IsErr(cPageCountRes): return Err[EncodingHeader](Error(cPageCountRes))
    if IsErr(ePageCountRes): return Err[EncodingHeader](Error(ePageCountRes))
    if IsErr(specBlockSizeRes): return Err[EncodingHeader](Error(specBlockSizeRes))
    var out: EncodingHeader
    out.version = bytes.BufByteAt(buf, 2)
    out.contentKeySize = bytes.BufByteAt(buf, 3)
    out.encodingKeySize = bytes.BufByteAt(buf, 4)
    out.contentPageSizeKB = Value(cPageSizeRes)
    out.encodingPageSizeKB = Value(ePageSizeRes)
    out.contentPageCount = Value(cPageCountRes)
    out.encodingPageCount = Value(ePageCountRes)
    out.specBlockSize = Value(specBlockSizeRes)
    if out.version <= 0:
        return Err[EncodingHeader]("wowExport encoding: invalid version")
    if out.contentKeySize != 16 || out.encodingKeySize != 16:
        return Err[EncodingHeader]("wowExport encoding: unsupported key size")
    if out.contentPageCount <= 0 || out.encodingPageCount <= 0:
        return Err[EncodingHeader]("wowExport encoding: empty page table")
    if out.contentPageSizeKB <= 0 || out.encodingPageSizeKB <= 0:
        return Err[EncodingHeader]("wowExport encoding: invalid page size")
    if out.specBlockSize < 0:
        return Err[EncodingHeader]("wowExport encoding: invalid spec block size")
    return Ok[EncodingHeader](out)

fn encodingContentPageHeadersOffset(header: EncodingHeader): int32 =
    return encodingHeaderSize + header.specBlockSize

fn encodingContentPagesOffset(header: EncodingHeader): int32 =
    return encodingContentPageHeadersOffset(header) + header.contentPageCount * encodingPageHeaderSize

fn encodingContentPageSizeBytes(header: EncodingHeader): int32 =
    return header.contentPageSizeKB * 1024

fn encodingEntrySize(keyCount: int32): int32 =
    return 2 + 4 + 16 + keyCount * 16

fn encodingParseEntryAt(buf: bytes.ByteBuffer, pos: int32, pageEnd: int32): Result[EncodingEntry] =
    let countRes: Result[int32] = encodingU16LEAt(buf, pos)
    if IsErr(countRes):
        return Err[EncodingEntry](Error(countRes))
    let keyCount: int32 = Value(countRes)
    if keyCount <= 0:
        return Err[EncodingEntry]("wowExport encoding: end of content page")
    let sizeNeed: int32 = encodingEntrySize(keyCount)
    if pos + sizeNeed > pageEnd:
        return Err[EncodingEntry]("wowExport encoding: truncated content entry")
    let contentSizeRes: Result[int32] = encodingU32BEAt(buf, pos + 2)
    if IsErr(contentSizeRes):
        return Err[EncodingEntry](Error(contentSizeRes))
    let contentKeyRes: Result[str] = binary.HexSlice(buf, pos + 6, 16)
    if IsErr(contentKeyRes):
        return Err[EncodingEntry](Error(contentKeyRes))
    let encodingKeyRes: Result[str] = binary.HexSlice(buf, pos + 22, 16)
    if IsErr(encodingKeyRes):
        return Err[EncodingEntry](Error(encodingKeyRes))
    var out: EncodingEntry
    out.contentSize = Value(contentSizeRes)
    out.contentKey = Value(contentKeyRes)
    out.encodingKey = Value(encodingKeyRes)
    out.encodingKeyCount = keyCount
    return Ok[EncodingEntry](out)

fn encodingPageBounds(buf: bytes.ByteBuffer,
                      header: EncodingHeader,
                      pageIndex: int32,
                      pageStart: var int32,
                      pageEnd: var int32): Result[bool] =
    if pageIndex < 0 || pageIndex >= header.contentPageCount:
        return Err[bool]("wowExport encoding: page index out of bounds")
    let pageSize: int32 = encodingContentPageSizeBytes(header)
    pageStart = encodingContentPagesOffset(header) + pageIndex * pageSize
    pageEnd = pageStart + pageSize
    if pageStart < 0 || pageEnd > buf.len:
        return Err[bool]("wowExport encoding: truncated content page")
    return Ok[bool](true)

fn WowEncodingFirstEntry(buf: bytes.ByteBuffer): Result[EncodingEntry] =
    let headerRes: Result[EncodingHeader] = WowEncodingParseHeader(buf)
    if IsErr(headerRes):
        return Err[EncodingEntry](Error(headerRes))
    let header: EncodingHeader = Value(headerRes)
    var pageStart: int32
    var pageEnd: int32
    let boundsRes: Result[bool] = encodingPageBounds(buf, header, 0, pageStart, pageEnd)
    if IsErr(boundsRes):
        return Err[EncodingEntry](Error(boundsRes))
    return encodingParseEntryAt(buf, pageStart, pageEnd)

fn WowEncodingFindEntry(buf: bytes.ByteBuffer, contentKey: str): Result[EncodingEntry] =
    if strings.Len(contentKey) != 32:
        return Err[EncodingEntry]("wowExport encoding: content key must be 16-byte hex")
    let headerRes: Result[EncodingHeader] = WowEncodingParseHeader(buf)
    if IsErr(headerRes):
        return Err[EncodingEntry](Error(headerRes))
    let header: EncodingHeader = Value(headerRes)
    var pageIndex: int32
    while pageIndex < header.contentPageCount:
        var pageStart: int32
        var pageEnd: int32
        let boundsRes: Result[bool] = encodingPageBounds(buf, header, pageIndex, pageStart, pageEnd)
        if IsErr(boundsRes):
            return Err[EncodingEntry](Error(boundsRes))
        var pos: int32 = pageStart
        while pos + 2 <= pageEnd:
            let keyCountRes: Result[int32] = encodingU16LEAt(buf, pos)
            if IsErr(keyCountRes):
                return Err[EncodingEntry](Error(keyCountRes))
            let keyCount: int32 = Value(keyCountRes)
            if keyCount == 0:
                break
            let sizeNeed: int32 = encodingEntrySize(keyCount)
            if pos + sizeNeed > pageEnd:
                return Err[EncodingEntry]("wowExport encoding: truncated content page entry")
            if binary.ByteSliceMatchesHex(buf, pos + 6, contentKey):
                return encodingParseEntryAt(buf, pos, pageEnd)
            pos = pos + sizeNeed
        pageIndex = pageIndex + 1
    return Err[EncodingEntry](strutil.Join(["wowExport encoding: content key not found ", contentKey], ""))

fn encodingCompareSliceHex(buf: bytes.ByteBuffer, start: int32, hexText: str): Result[int32] =
    let byteCount: int32 = strings.Len(hexText) / 2
    if strings.Len(hexText) % 2 != 0 || byteCount <= 0:
        return Err[int32]("wowExport encoding: invalid hex key")
    if start < 0 || start + byteCount > buf.len:
        return Err[int32]("wowExport encoding: compare slice out of bounds")
    var i: int32
    while i < byteCount:
        let lhs: int32 = bytes.BufByteAt(buf, start + i)
        let rhs: int32 = binary.HexTextByteAt(hexText, i)
        if rhs < 0:
            return Err[int32]("wowExport encoding: invalid hex key")
        if lhs < rhs:
            return Ok[int32](-1)
        if lhs > rhs:
            return Ok[int32](1)
        i = i + 1
    return Ok[int32](0)

fn encodingFindCandidateContentPage(tableBuf: bytes.ByteBuffer,
                                    header: EncodingHeader,
                                    contentKey: str): Result[int32] =
    var bestPage: int32
    var pageIndex: int32
    while pageIndex < header.contentPageCount:
        let pageHeaderPos: int32 = encodingContentPageHeadersOffset(header) + pageIndex * encodingPageHeaderSize
        let cmpRes: Result[int32] = encodingCompareSliceHex(tableBuf, pageHeaderPos, contentKey)
        if IsErr(cmpRes):
            return Err[int32](Error(cmpRes))
        if Value(cmpRes) <= 0:
            bestPage = pageIndex
        else:
            break
        pageIndex = pageIndex + 1
    return Ok[int32](bestPage)

fn encodingFindEntryInPage(pageBuf: bytes.ByteBuffer,
                           contentKey: str): Result[EncodingEntry] =
    var pos: int32
    while pos + 2 <= pageBuf.len:
        let keyCountRes: Result[int32] = encodingU16LEAt(pageBuf, pos)
        if IsErr(keyCountRes):
            return Err[EncodingEntry](Error(keyCountRes))
        let keyCount: int32 = Value(keyCountRes)
        if keyCount == 0:
            break
        let sizeNeed: int32 = encodingEntrySize(keyCount)
        if pos + sizeNeed > pageBuf.len:
            return Err[EncodingEntry]("wowExport encoding: truncated ranged content page entry")
        if binary.ByteSliceMatchesHex(pageBuf, pos + 6, contentKey):
            return encodingParseEntryAt(pageBuf, pos, pageBuf.len)
        pos = pos + sizeNeed
    return Err[EncodingEntry](strutil.Join(["wowExport encoding: content key not found in ranged page ", contentKey], ""))
 
fn WowEncodingFindEntryRanged(clientPath: str,
                              encodingIndexEntry: casc_index.CascIndexEntry,
                              contentKey: str): Result[EncodingEntry] =
    if strings.Len(contentKey) != 32:
        return Err[EncodingEntry]("wowExport encoding: content key must be 16-byte hex")
    let headerBytesRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryRange(clientPath, encodingIndexEntry, 0, encodingHeaderSize)
    if IsErr(headerBytesRes):
        return Err[EncodingEntry](Error(headerBytesRes))
    let headerBytes: bytes.ByteBuffer = Value(headerBytesRes)
    let headerRes: Result[EncodingHeader] = WowEncodingParseHeaderPrefix(headerBytes)
    bytes.FreeByteBuffer(headerBytes)
    if IsErr(headerRes):
        return Err[EncodingEntry](Error(headerRes))
    let header: EncodingHeader = Value(headerRes)
    let tableEnd: int32 = encodingContentPagesOffset(header)
    let tableBufRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryRange(clientPath, encodingIndexEntry, 0, tableEnd)
    if IsErr(tableBufRes):
        return Err[EncodingEntry](Error(tableBufRes))
    let tableBuf: bytes.ByteBuffer = Value(tableBufRes)
    let tableHeaderRes: Result[EncodingHeader] = WowEncodingParseHeader(tableBuf)
    if IsErr(tableHeaderRes):
        bytes.FreeByteBuffer(tableBuf)
        return Err[EncodingEntry](Error(tableHeaderRes))
    let pageIndexRes: Result[int32] = encodingFindCandidateContentPage(tableBuf, header, contentKey)
    bytes.FreeByteBuffer(tableBuf)
    if IsErr(pageIndexRes):
        return Err[EncodingEntry](Error(pageIndexRes))
    let pageSize: int32 = encodingContentPageSizeBytes(header)
    let pageStart: int32 = encodingContentPagesOffset(header) + Value(pageIndexRes) * pageSize
    let pageBufRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryRange(clientPath, encodingIndexEntry, pageStart, pageSize)
    if IsErr(pageBufRes):
        return Err[EncodingEntry](Error(pageBufRes))
    let pageBuf: bytes.ByteBuffer = Value(pageBufRes)
    let foundRes: Result[EncodingEntry] = encodingFindEntryInPage(pageBuf, contentKey)
    bytes.FreeByteBuffer(pageBuf)
    return foundRes

fn encodingInitEntryArray(count: int32): EncodingEntry[] =
    var out: EncodingEntry[]
    var i: int32
    while i < count:
        var entry: EncodingEntry
        add(out, entry)
        i = i + 1
    return out

fn encodingInitBoolArray(count: int32): bool[] =
    var out: bool[]
    var i: int32
    while i < count:
        add(out, false)
        i = i + 1
    return out

fn encodingInitIntArray(count: int32, value: int32): int32[] =
    var out: int32[]
    var i: int32
    while i < count:
        add(out, value)
        i = i + 1
    return out

fn encodingFindManyEntriesInPage(pageBuf: bytes.ByteBuffer,
                                 contentKeys: str[],
                                 pageForKey: int32[],
                                 pageIndex: int32,
                                 foundFlags: var bool[],
                                 entries: var EncodingEntry[],
                                 matchedCount: var int32): Result[bool] =
    var pos: int32
    while pos + 2 <= pageBuf.len:
        let keyCountRes: Result[int32] = encodingU16LEAt(pageBuf, pos)
        if IsErr(keyCountRes):
            return Err[bool](Error(keyCountRes))
        let keyCount: int32 = Value(keyCountRes)
        if keyCount == 0:
            break
        let sizeNeed: int32 = encodingEntrySize(keyCount)
        if pos + sizeNeed > pageBuf.len:
            return Err[bool]("wowExport encoding: truncated ranged content page entry")
        var wantedIndex: int32
        while wantedIndex < contentKeys.len:
            if !foundFlags[wantedIndex] && pageForKey[wantedIndex] == pageIndex:
                if binary.ByteSliceMatchesHex(pageBuf, pos + 6, contentKeys[wantedIndex]):
                    let entryRes: Result[EncodingEntry] = encodingParseEntryAt(pageBuf, pos, pageBuf.len)
                    if IsErr(entryRes):
                        return Err[bool](Error(entryRes))
                    entries[wantedIndex] = Value(entryRes)
                    foundFlags[wantedIndex] = true
                    matchedCount = matchedCount + 1
            wantedIndex = wantedIndex + 1
        pos = pos + sizeNeed
    return Ok[bool](true)

fn WowEncodingFindEntriesRanged(clientPath: str,
                                encodingIndexEntry: casc_index.CascIndexEntry,
                                contentKeys: str[]): Result[EncodingEntry[]] =
    if contentKeys.len <= 0:
        return Err[EncodingEntry[]]("wowExport encoding: empty content key list")
    var keyIndex: int32
    while keyIndex < contentKeys.len:
        if strings.Len(contentKeys[keyIndex]) != 32:
            return Err[EncodingEntry[]]("wowExport encoding: content key must be 16-byte hex")
        keyIndex = keyIndex + 1
    let headerBytesRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryRange(clientPath, encodingIndexEntry, 0, encodingHeaderSize)
    if IsErr(headerBytesRes):
        return Err[EncodingEntry[]](Error(headerBytesRes))
    let headerBytes: bytes.ByteBuffer = Value(headerBytesRes)
    let headerRes: Result[EncodingHeader] = WowEncodingParseHeaderPrefix(headerBytes)
    bytes.FreeByteBuffer(headerBytes)
    if IsErr(headerRes):
        return Err[EncodingEntry[]](Error(headerRes))
    let header: EncodingHeader = Value(headerRes)
    let tableEnd: int32 = encodingContentPagesOffset(header)
    let tableBufRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryRange(clientPath, encodingIndexEntry, 0, tableEnd)
    if IsErr(tableBufRes):
        return Err[EncodingEntry[]](Error(tableBufRes))
    let tableBuf: bytes.ByteBuffer = Value(tableBufRes)
    let tableHeaderRes: Result[EncodingHeader] = WowEncodingParseHeader(tableBuf)
    if IsErr(tableHeaderRes):
        bytes.FreeByteBuffer(tableBuf)
        return Err[EncodingEntry[]](Error(tableHeaderRes))
    var pageForKey: int32[] = encodingInitIntArray(contentKeys.len, -1)
    keyIndex = 0
    while keyIndex < contentKeys.len:
        let pageIndexRes: Result[int32] =
            encodingFindCandidateContentPage(tableBuf, header, contentKeys[keyIndex])
        if IsErr(pageIndexRes):
            bytes.FreeByteBuffer(tableBuf)
            return Err[EncodingEntry[]](Error(pageIndexRes))
        pageForKey[keyIndex] = Value(pageIndexRes)
        keyIndex = keyIndex + 1
    bytes.FreeByteBuffer(tableBuf)
    var entries: EncodingEntry[] = encodingInitEntryArray(contentKeys.len)
    var foundFlags: bool[] = encodingInitBoolArray(contentKeys.len)
    var matchedCount: int32
    let pageSize: int32 = encodingContentPageSizeBytes(header)
    var pageIndex: int32
    while pageIndex < header.contentPageCount && matchedCount < contentKeys.len:
        var needPage: bool
        keyIndex = 0
        while keyIndex < contentKeys.len:
            if !foundFlags[keyIndex] && pageForKey[keyIndex] == pageIndex:
                needPage = true
                break
            keyIndex = keyIndex + 1
        if needPage:
            let pageStart: int32 = encodingContentPagesOffset(header) + pageIndex * pageSize
            let pageBufRes: Result[bytes.ByteBuffer] =
                casc_archive.CascArchiveDecodeLocalEntryRange(clientPath, encodingIndexEntry, pageStart, pageSize)
            if IsErr(pageBufRes):
                return Err[EncodingEntry[]](Error(pageBufRes))
            let pageBuf: bytes.ByteBuffer = Value(pageBufRes)
            let findRes: Result[bool] =
                encodingFindManyEntriesInPage(pageBuf, contentKeys, pageForKey, pageIndex,
                    foundFlags, entries, matchedCount)
            bytes.FreeByteBuffer(pageBuf)
            if IsErr(findRes):
                return Err[EncodingEntry[]](Error(findRes))
        pageIndex = pageIndex + 1
    if matchedCount != contentKeys.len:
        return Err[EncodingEntry[]]("wowExport encoding: not all ranged content keys found")
    return Ok[EncodingEntry[]](entries)

fn WowEncodingFindEncodingKeyRanged(clientPath: str,
                                    encodingIndexEntry: casc_index.CascIndexEntry,
                                    contentKey: str): Result[str] =
    let entryRes: Result[EncodingEntry] =
        WowEncodingFindEntryRanged(clientPath, encodingIndexEntry, contentKey)
    if IsErr(entryRes):
        return Err[str](Error(entryRes))
    return Ok[str](Value(entryRes).encodingKey)

fn WowEncodingFindEncodingKey(buf: bytes.ByteBuffer, contentKey: str): Result[str] =
    let entryRes: Result[EncodingEntry] = WowEncodingFindEntry(buf, contentKey)
    if IsErr(entryRes):
        return Err[str](Error(entryRes))
    return Ok[str](Value(entryRes).encodingKey)

fn WowEncodingSummary(buf: bytes.ByteBuffer): Result[EncodingSummary] =
    let headerRes: Result[EncodingHeader] = WowEncodingParseHeader(buf)
    if IsErr(headerRes):
        return Err[EncodingSummary](Error(headerRes))
    let firstRes: Result[EncodingEntry] = WowEncodingFirstEntry(buf)
    if IsErr(firstRes):
        return Err[EncodingSummary](Error(firstRes))
    var out: EncodingSummary
    out.header = Value(headerRes)
    out.first = Value(firstRes)
    return Ok[EncodingSummary](out)

fn WowEncodingHeaderText(header: EncodingHeader): str =
    return Fmt"encodingVersion={strings.IntToStr(header.version)} cKeySize={strings.IntToStr(header.contentKeySize)} eKeySize={strings.IntToStr(header.encodingKeySize)} cPages={strings.IntToStr(header.contentPageCount)} ePages={strings.IntToStr(header.encodingPageCount)} spec={strings.IntToStr(header.specBlockSize)}"

fn WowEncodingSummaryText(summary: EncodingSummary): str =
    let headerText: str = WowEncodingHeaderText(summary.header)
    let firstSizeText: str = strings.IntToStr(summary.first.contentSize)
    let eKeysText: str = strings.IntToStr(summary.first.encodingKeyCount)
    return Fmt"{headerText} firstCKey={summary.first.contentKey} firstEKey={summary.first.encodingKey} firstSize={firstSizeText} eKeys={eKeysText}"

fn WowEncodingLookupContentKey(clientPath: str,
                               entry: casc_index.CascIndexEntry,
                               contentKey: str): Result[EncodingLookupResult] =
    let encodingBufRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveDecodeLocalEntryFull(clientPath, entry)
    if IsErr(encodingBufRes):
        return Err[EncodingLookupResult](Error(encodingBufRes))
    let entryRes: Result[EncodingEntry] = WowEncodingFindEntry(Value(encodingBufRes), contentKey)
    if IsErr(entryRes):
        return Err[EncodingLookupResult](Error(entryRes))
    let found: EncodingEntry = Value(entryRes)
    var out: EncodingLookupResult
    out.contentKey = found.contentKey
    out.encodingKey = found.encodingKey
    out.contentSize = found.contentSize
    out.encodingKeyCount = found.encodingKeyCount
    return Ok[EncodingLookupResult](out)

fn EncodingLookupText(result: EncodingLookupResult): str =
    return Fmt"contentKey={result.contentKey} encodingKey={result.encodingKey} contentSize={strings.IntToStr(result.contentSize)} eKeys={strings.IntToStr(result.encodingKeyCount)}"
