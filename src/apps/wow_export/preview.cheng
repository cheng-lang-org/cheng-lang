    out = out + Fmt" m2SkinFileIDs={m2SkinText}"
    out = out + Fmt" m2FirstSkinFileDataID={m2FirstSkinText}"
    out = out + Fmt" m2TextureFileIDs={m2TextureIdText}"
    out = out + Fmt" m2FirstTextureFileDataID={m2FirstTextureIdText}"
    out = out + Fmt" m2SkinIndices={m2SkinIndexText}"
    out = out + Fmt" m2SkinTriangleIndices={m2SkinTriText}"
    out = out + Fmt" m2SkinSubmeshes={m2SkinSubmeshText}"
    out = out + Fmt" texture={textureText}"
    out = out + Fmt" textureTgaBytes={tgaText}"
    out = out + Fmt" assetBytes={assetBytesText}"
    out = out + Fmt" characterVertices={vertexText}"
    out = out + Fmt" animationSequences={sequenceText}"
    out = out + Fmt" modelBounds={boundsText}"
    out = out + Fmt" modelSpan1000={spanText}"
    out = out + Fmt" memoryOutstanding={memoryText}"
    return out
