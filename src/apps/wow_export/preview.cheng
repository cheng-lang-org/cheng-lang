import cheng/apps/wow_export/blp as blp
import cheng/apps/wow_export/local_files as local_files
import cheng/apps/wow_export/manifest/northshire_retail_12_0_5 as northshire
import std/strutils as strutil

type
    PreviewSummary =
        width: int32
        height: int32
        frames: int32
        sceneNonEmpty: bool
        auditedFileCount: int32
        auditedDependencyCount: int32
        loadedFileCount: int32
        chunkFileCount: int32
        totalChunkCount: int32
        textureWidth: int32
        textureHeight: int32
        textureTgaBytes: int32
        wdtActiveTileCount: int32
        wdtModelPlacementCount: int32
        wdtMaidFileDataIDCount: int32
        wdtFirstMaidFileDataID: int32
        wdtMaidSplitDependencyCount: int32
        wdtMaidSplitDependenciesReady: bool
        wdtMaidParsedDependencyCount: int32
        wdtMaidAdtSplitResourceCount: int32
        wdtMaidBlpResourceCount: int32
        wdtMaidAdtSplitChunkCount: int32
        wdtMaidAdtSplitMapChunkCount: int32
        wdtMaidDoodadPlacementCount: int32
        wdtMaidDoodadReferencedFileDataIDCount: int32
        wdtMaidFirstDoodadReferencedFileDataID: int32
        wdtMaidDoodadPlacementDependencyCount: int32
        wdtMaidDoodadM2AssetCount: int32
        wdtMaidDoodadPlacementBoundsReady: bool
        wdtMaidDoodadPlacementMinX1000: int32
        wdtMaidDoodadPlacementMinY1000: int32
        wdtMaidDoodadPlacementMinZ1000: int32
        wdtMaidDoodadPlacementMaxX1000: int32
        wdtMaidDoodadPlacementMaxY1000: int32
        wdtMaidDoodadPlacementMaxZ1000: int32
        wdtMaidDoodadMinScale: int32
        wdtMaidDoodadMaxScale: int32
        wdtMaidWorldModelPlacementCount: int32
        wdtMaidWorldModelReferencedFileDataIDCount: int32
        wdtMaidFirstWorldModelReferencedFileDataID: int32
        wdtMaidWorldModelPlacementDependencyCount: int32
        wdtMaidWorldModelWmoAssetCount: int32
        wdtMaidPlacementDependencyAuditReady: bool
        wdtMaidPlacementDependencyEncodedBytes: int32
        wdtMaidPlacementDependencyDecodedBytes: int32
        wdtMaidWorldModelPlacementBoundsReady: bool
        wdtMaidWorldModelPlacementMinX1000: int32
        wdtMaidWorldModelPlacementMinY1000: int32
        wdtMaidWorldModelPlacementMinZ1000: int32
        wdtMaidWorldModelPlacementMaxX1000: int32
        wdtMaidWorldModelPlacementMaxY1000: int32
        wdtMaidWorldModelPlacementMaxZ1000: int32
        wdtMaidWorldModelMinScale: int32
        wdtMaidWorldModelMaxScale: int32
        wdtMaidDependencyBytes: int32
        adtTileCount: int32
        adtChunkCount: int32
        adtHeightChunkCount: int32
        adtHeightSampleCount: int32
        adtMinHeight1000: int32
        adtMaxHeight1000: int32
        wmoChunkCount: int32
        wmoMaterialCount: int32
        wmoGroupCount: int32
        wmoDoodadCount: int32
        wmoGroupFileDataIDCount: int32
        wmoFirstGroupFileDataID: int32
        wmoDoodadSetDefinitionCount: int32
        wmoDoodadPlacementCount: int32
        wmoDoodadSetPlacementCount: int32
        wmoFirstDoodadNameIndex: int32
        wmoDoodadBoundsReady: bool
        wmoDoodadSpanX1000: int32
        wmoDoodadSpanY1000: int32
        wmoDoodadSpanZ1000: int32
        wmoGroupAssetCount: int32
        wmoGroupVertexCount: int32
        wmoGroupIndexCount: int32
        wmoModelSlotCount: int32
        wmoModelFileDataIDCount: int32
        wmoModelDependencyCount: int32
        wmoModelDependenciesReady: bool
        wmoFirstModelFileDataID: int32
        wmoDoodadModelPlacementCount: int32
        wmoDoodadReferencedModelFileDataIDCount: int32
        wmoDoodadModelDependenciesReady: bool
        wmoFirstDoodadModelFileDataID: int32
        m2Version: int32
        m2SkinFileDataIDCount: int32
        m2FirstSkinFileDataID: int32
        m2TextureFileDataIDCount: int32
        m2FirstTextureFileDataID: int32
        m2SkinIndexCount: int32
        m2SkinTriangleIndexCount: int32
        m2SkinSubmeshCount: int32
        assetBytes: int32
        characterVertexCount: int32
        animationSequenceCount: int32
        modelBoundsReady: bool
        modelSpanX1000: int32
        modelSpanY1000: int32
        modelSpanZ1000: int32
        memoryOutstanding: int32

fn previewApplyChunkedAsset(summary: var PreviewSummary, buf: bytes.ByteBuffer, label: str): Result[bool] =
    let headerRes: Result[asset_formats.FormatHeader] = asset_formats.ParseChunkedHeader(buf, label)
    if IsErr(headerRes):
        return Err[bool](Error(headerRes))
    summary.chunkFileCount = summary.chunkFileCount + 1
    summary.totalChunkCount = summary.totalChunkCount + Value(headerRes).chunkCount
    if label == "northshire-wmo":
        summary.wmoChunkCount = Value(headerRes).chunkCount
    return Ok[bool](true)

fn previewCheckWdtMaidTileDependencies(summary: var PreviewSummary,
                                       manifest: northshire.NorthshireManifest,
                                       buf: bytes.ByteBuffer,
                                       sourceLabel: str,
                                       tileX: int32,
                                       tileY: int32): Result[bool] =
    let tileRes: Result[asset_formats.WdtMaidTile] =
        asset_formats.ParseWdtMaidTileFileDataIDs(buf, tileX, tileY)
    if IsErr(tileRes):
        return Err[bool](Error(tileRes))
    let tile: asset_formats.WdtMaidTile = Value(tileRes)
    if tile.fileDataIDs.len != 8:
        return Err[bool]("wowExport preview: WDT MAID tile slot count mismatch")
    for slot in 1..<tile.fileDataIDs.len:
        let fileDataID: int32 = tile.fileDataIDs[slot]
        if fileDataID > 0:
            if !northshire.HasDependencyFileDataID(manifest, sourceLabel, "wdt_maid_split", fileDataID):
                return Err[bool](strutil.Join(["wowExport preview: WDT MAID split dependency is not audited ", strings.IntToStr(fileDataID)], ""))
            summary.wdtMaidSplitDependencyCount = summary.wdtMaidSplitDependencyCount + 1
    return Ok[bool](true)

fn previewInt32ListContains(values: int32[], value: int32): bool =
    var i: int32
    for i in i..<values.len:
        if values[i] == value:
            return true
    return false

fn previewMergeUniqueFileDataIDs(source: int32[],
                                 unique: var int32[],
                                 firstOut: var int32,
                                 countOut: var int32): Result[bool] =
    var i: int32
    for i in i..<source.len:
        let fileDataID: int32 = source[i]
        if fileDataID <= 0:
            return Err[bool]("wowExport preview: WDT MAID placement fileDataID invalid")
        if !previewInt32ListContains(unique, fileDataID):
            add(unique, fileDataID)
            if unique.len == 1:
                firstOut = fileDataID
            countOut = unique.len
    return Ok[bool](true)

fn previewMergeWdtMaidSplitRecordFacts(summary: var PreviewSummary,
                                       split: asset_formats.WdtMaidAdtSplitSummary): Result[bool] =
    if split.doodadPlacementCount > 0:
        if !split.doodadPlacementPositionBoundsReady:
            return Err[bool]("wowExport preview: WDT MAID MDDF placement bounds missing")
        if !summary.wdtMaidDoodadPlacementBoundsReady:
            summary.wdtMaidDoodadPlacementBoundsReady = true
            summary.wdtMaidDoodadPlacementMinX1000 = split.minDoodadPlacementX1000
            summary.wdtMaidDoodadPlacementMaxX1000 = split.maxDoodadPlacementX1000
            summary.wdtMaidDoodadPlacementMinY1000 = split.minDoodadPlacementY1000
            summary.wdtMaidDoodadPlacementMaxY1000 = split.maxDoodadPlacementY1000
            summary.wdtMaidDoodadPlacementMinZ1000 = split.minDoodadPlacementZ1000
            summary.wdtMaidDoodadPlacementMaxZ1000 = split.maxDoodadPlacementZ1000
            summary.wdtMaidDoodadMinScale = split.minDoodadScale
            summary.wdtMaidDoodadMaxScale = split.maxDoodadScale
        else:
            if split.minDoodadPlacementX1000 < summary.wdtMaidDoodadPlacementMinX1000:
                summary.wdtMaidDoodadPlacementMinX1000 = split.minDoodadPlacementX1000
            if split.maxDoodadPlacementX1000 > summary.wdtMaidDoodadPlacementMaxX1000:
                summary.wdtMaidDoodadPlacementMaxX1000 = split.maxDoodadPlacementX1000
            if split.minDoodadPlacementY1000 < summary.wdtMaidDoodadPlacementMinY1000:
                summary.wdtMaidDoodadPlacementMinY1000 = split.minDoodadPlacementY1000
            if split.maxDoodadPlacementY1000 > summary.wdtMaidDoodadPlacementMaxY1000:
                summary.wdtMaidDoodadPlacementMaxY1000 = split.maxDoodadPlacementY1000
            if split.minDoodadPlacementZ1000 < summary.wdtMaidDoodadPlacementMinZ1000:
                summary.wdtMaidDoodadPlacementMinZ1000 = split.minDoodadPlacementZ1000
            if split.maxDoodadPlacementZ1000 > summary.wdtMaidDoodadPlacementMaxZ1000:
                summary.wdtMaidDoodadPlacementMaxZ1000 = split.maxDoodadPlacementZ1000
            if split.minDoodadScale < summary.wdtMaidDoodadMinScale:
                summary.wdtMaidDoodadMinScale = split.minDoodadScale
            if split.maxDoodadScale > summary.wdtMaidDoodadMaxScale:
                summary.wdtMaidDoodadMaxScale = split.maxDoodadScale
    if split.worldModelPlacementCount > 0:
        if !split.worldModelPlacementPositionBoundsReady:
            return Err[bool]("wowExport preview: WDT MAID MODF placement bounds missing")
        if !summary.wdtMaidWorldModelPlacementBoundsReady:
            summary.wdtMaidWorldModelPlacementBoundsReady = true
            summary.wdtMaidWorldModelPlacementMinX1000 = split.minWorldModelPlacementX1000
            summary.wdtMaidWorldModelPlacementMaxX1000 = split.maxWorldModelPlacementX1000
            summary.wdtMaidWorldModelPlacementMinY1000 = split.minWorldModelPlacementY1000
            summary.wdtMaidWorldModelPlacementMaxY1000 = split.maxWorldModelPlacementY1000
            summary.wdtMaidWorldModelPlacementMinZ1000 = split.minWorldModelPlacementZ1000
            summary.wdtMaidWorldModelPlacementMaxZ1000 = split.maxWorldModelPlacementZ1000
            summary.wdtMaidWorldModelMinScale = split.minWorldModelScale
            summary.wdtMaidWorldModelMaxScale = split.maxWorldModelScale
        else:
            if split.minWorldModelPlacementX1000 < summary.wdtMaidWorldModelPlacementMinX1000:
                summary.wdtMaidWorldModelPlacementMinX1000 = split.minWorldModelPlacementX1000
            if split.maxWorldModelPlacementX1000 > summary.wdtMaidWorldModelPlacementMaxX1000:
                summary.wdtMaidWorldModelPlacementMaxX1000 = split.maxWorldModelPlacementX1000
            if split.minWorldModelPlacementY1000 < summary.wdtMaidWorldModelPlacementMinY1000:
                summary.wdtMaidWorldModelPlacementMinY1000 = split.minWorldModelPlacementY1000
            if split.maxWorldModelPlacementY1000 > summary.wdtMaidWorldModelPlacementMaxY1000:
                summary.wdtMaidWorldModelPlacementMaxY1000 = split.maxWorldModelPlacementY1000
            if split.minWorldModelPlacementZ1000 < summary.wdtMaidWorldModelPlacementMinZ1000:
                summary.wdtMaidWorldModelPlacementMinZ1000 = split.minWorldModelPlacementZ1000
            if split.maxWorldModelPlacementZ1000 > summary.wdtMaidWorldModelPlacementMaxZ1000:
                summary.wdtMaidWorldModelPlacementMaxZ1000 = split.maxWorldModelPlacementZ1000
            if split.minWorldModelScale < summary.wdtMaidWorldModelMinScale:
                summary.wdtMaidWorldModelMinScale = split.minWorldModelScale
            if split.maxWorldModelScale > summary.wdtMaidWorldModelMaxScale:
                summary.wdtMaidWorldModelMaxScale = split.maxWorldModelScale
    return Ok[bool](true)

fn previewLoadWdtMaidDependencyAssets(summary: var PreviewSummary,
                                      manifest: northshire.NorthshireManifest): Result[bool] =
    var doodadFileDataIDs: int32[]
    var worldModelFileDataIDs: int32[]
    var i: int32
    for i in i..<manifest.auditedDependencies.len:
        let dep: northshire.NorthshireAuditedDependency = manifest.auditedDependencies[i]
        if dep.relationKind == "wdt_maid_split":
            let fileRes: Result[bytes.ByteBuffer] =
                local_files.ReadLocalFileByEntry(manifest.clientPath,
                                                dep.archiveIndex,
                                                dep.offset,
                                                dep.size)
            if IsErr(fileRes):
                return Err[bool](strutil.Join(["wowExport preview: WDT MAID dependency load failed ", dep.label, ": ", Error(fileRes)], ""))
            let fileBuf: bytes.ByteBuffer = Value(fileRes)
            summary.wdtMaidDependencyBytes = summary.wdtMaidDependencyBytes + fileBuf.len
            let resourceRes: Result[asset_formats.WdtMaidResourceSummary] =
                asset_formats.ParseWdtMaidResourceSummary(fileBuf)
            if IsErr(resourceRes):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(resourceRes))
            let resource: asset_formats.WdtMaidResourceSummary = Value(resourceRes)
            if resource.formatKind != dep.formatKind:
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](strutil.Join(["wowExport preview: WDT MAID dependency format mismatch ", dep.label], ""))
            summary.wdtMaidParsedDependencyCount = summary.wdtMaidParsedDependencyCount + 1
            if dep.formatKind == "adt_split":
                let splitRes: Result[asset_formats.WdtMaidAdtSplitSummary] =
                    asset_formats.ParseWdtMaidAdtSplitSummary(fileBuf)
                if IsErr(splitRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(splitRes))
                let split: asset_formats.WdtMaidAdtSplitSummary = Value(splitRes)
                summary.wdtMaidAdtSplitResourceCount = summary.wdtMaidAdtSplitResourceCount + 1
                summary.wdtMaidAdtSplitChunkCount =
                    summary.wdtMaidAdtSplitChunkCount + split.chunkCount
                summary.wdtMaidAdtSplitMapChunkCount =
                    summary.wdtMaidAdtSplitMapChunkCount + split.mapChunkCount
                summary.wdtMaidDoodadPlacementCount =
                    summary.wdtMaidDoodadPlacementCount + split.doodadPlacementCount
                summary.wdtMaidWorldModelPlacementCount =
                    summary.wdtMaidWorldModelPlacementCount + split.worldModelPlacementCount
                let recordFactsRes: Result[bool] =
                    previewMergeWdtMaidSplitRecordFacts(summary, split)
                if IsErr(recordFactsRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(recordFactsRes))
                let doodadIDsRes: Result[bool] =
                    previewMergeUniqueFileDataIDs(split.doodadPlacementFileDataIDs,
                                                  doodadFileDataIDs,
                                                  summary.wdtMaidFirstDoodadReferencedFileDataID,
                                                  summary.wdtMaidDoodadReferencedFileDataIDCount)
                if IsErr(doodadIDsRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(doodadIDsRes))
                let worldIDsRes: Result[bool] =
                    previewMergeUniqueFileDataIDs(split.worldModelPlacementFileDataIDs,
                                                  worldModelFileDataIDs,
                                                  summary.wdtMaidFirstWorldModelReferencedFileDataID,
                                                  summary.wdtMaidWorldModelReferencedFileDataIDCount)
                if IsErr(worldIDsRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(worldIDsRes))
            elif dep.formatKind == "blp":
                let blpRes: Result[blp.Blp2Header] = blp.ParseBlp2Header(fileBuf)
                if IsErr(blpRes):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](Error(blpRes))
                let header: blp.Blp2Header = Value(blpRes)
                if header.width <= 0 || header.height <= 0:
            bytes.FreeByteBuffer(fileBuf)
            return Err[bool]("wowExport preview: WDT MAID BLP has invalid dimensions")
        summary.wdtMaidBlpResourceCount = summary.wdtMaidBlpResourceCount + 1
    else:
        bytes.FreeByteBuffer(fileBuf)
        return Err[bool](strutil.Join(["wowExport preview: unsupported WDT MAID dependency format ", dep.formatKind], ""))
    bytes.FreeByteBuffer(fileBuf)
    if summary.wdtMaidParsedDependencyCount !=
        northshire.CountDependenciesForSource(manifest, "azeroth-wdt", "wdt_maid_split"):
        return Err[bool]("wowExport preview: WDT MAID parsed dependency count mismatch")
    let placementAuditRes: Result[northshire.NorthshireMaidPlacementDependencyAuditSummary] =
        northshire.AuditWdtMaidPlacementReferencesAgainstLocal(manifest,
                                                              doodadFileDataIDs,
                                                              worldModelFileDataIDs)
    if IsErr(placementAuditRes):
        return Err[bool](Error(placementAuditRes))
    let placementAudit: northshire.NorthshireMaidPlacementDependencyAuditSummary =
        Value(placementAuditRes)
    summary.wdtMaidDoodadPlacementDependencyCount = placementAudit.matchedDoodadDependencyCount
    summary.wdtMaidDoodadM2AssetCount = placementAudit.doodadM2AssetCount
    summary.wdtMaidWorldModelPlacementDependencyCount = placementAudit.matchedWorldModelDependencyCount
    summary.wdtMaidWorldModelWmoAssetCount = placementAudit.worldModelWmoAssetCount
    summary.wdtMaidPlacementDependencyEncodedBytes =
        placementAudit.doodadEncodedBytes + placementAudit.worldModelEncodedBytes
    summary.wdtMaidPlacementDependencyDecodedBytes =
        placementAudit.doodadDecodedBytes + placementAudit.worldModelDecodedBytes
    summary.wdtMaidPlacementDependencyAuditReady =
        placementAudit.matchedDoodadDependencyCount == summary.wdtMaidDoodadReferencedFileDataIDCount &&
        placementAudit.matchedWorldModelDependencyCount == summary.wdtMaidWorldModelReferencedFileDataIDCount &&
        placementAudit.doodadM2AssetCount == summary.wdtMaidDoodadReferencedFileDataIDCount &&
        placementAudit.worldModelWmoAssetCount == summary.wdtMaidWorldModelReferencedFileDataIDCount &&
        placementAudit.firstDoodadFileDataID == summary.wdtMaidFirstDoodadReferencedFileDataID &&
        placementAudit.firstWorldModelFileDataID == summary.wdtMaidFirstWorldModelReferencedFileDataID
    return Ok[bool](true)

fn previewLoadAuditedAssets(summary: var PreviewSummary,
                            manifest: northshire.NorthshireManifest): Result[bool] =
    var i: int32
    while i < manifest.auditedFiles.len:
        let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[i]
        let fileRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByEntry(manifest.clientPath, file.archiveIndex, file.offset, file.size)
        if IsErr(fileRes):
            return Err[bool](strutil.Join(["wowExport preview: failed to load ", file.path, ": ", Error(fileRes)], ""))
        let fileBuf: bytes.ByteBuffer = Value(fileRes)
        summary.loadedFileCount = summary.loadedFileCount + 1
        summary.assetBytes = summary.assetBytes + fileBuf.len
        if file.kind == "wdt":
            let wdtRes: Result[asset_formats.WdtSummary] = asset_formats.ParseWdtSummary(fileBuf)
            if IsErr(wdtRes):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(wdtRes))
            summary.wdtActiveTileCount = Value(wdtRes).activeTileCount
            summary.wdtModelPlacementCount = Value(wdtRes).modelPlacementCount
            summary.wdtMaidFileDataIDCount = Value(wdtRes).maidReferencedFileCount
            summary.wdtFirstMaidFileDataID = Value(wdtRes).firstMaidFileDataID
            let maid31x48Res: Result[bool] =
                previewCheckWdtMaidTileDependencies(summary, manifest, fileBuf, file.label, 31, 48)
            if IsErr(maid31x48Res):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(maid31x48Res))
            let maid32x48Res: Result[bool] =
                previewCheckWdtMaidTileDependencies(summary, manifest, fileBuf, file.label, 32, 48)
            if IsErr(maid32x48Res):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(maid32x48Res))
            let maid31x49Res: Result[bool] =
                previewCheckWdtMaidTileDependencies(summary, manifest, fileBuf, file.label, 31, 49)
            if IsErr(maid31x49Res):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(maid31x49Res))
            let maid32x49Res: Result[bool] =
                previewCheckWdtMaidTileDependencies(summary, manifest, fileBuf, file.label, 32, 49)
            if IsErr(maid32x49Res):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(maid32x49Res))
            summary.wdtMaidSplitDependenciesReady =
                summary.wdtMaidSplitDependencyCount > 0 &&
                summary.wdtMaidSplitDependencyCount == northshire.CountDependenciesForSource(manifest, file.label, "wdt_maid_split")
            let chunkRes: Result[bool] = previewApplyChunkedAsset(summary, fileBuf, "northshire-wdt")
            bytes.FreeByteBuffer(fileBuf)
            if IsErr(chunkRes):
                return Err[bool](Error(chunkRes))
        elif file.kind == "adt":
            let adtRes: Result[asset_formats.AdtTerrainSummary] =
                asset_formats.ParseAdtTerrainSummary(fileBuf)
            bytes.FreeByteBuffer(fileBuf)
            if IsErr(adtRes):
                return Err[bool](Error(adtRes))
            let adt: asset_formats.AdtTerrainSummary = Value(adtRes)
            if summary.adtTileCount == 0:
                summary.adtMinHeight1000 = adt.minHeight1000
                summary.adtMaxHeight1000 = adt.maxHeight1000
            else:
                if adt.minHeight1000 < summary.adtMinHeight1000:
                    summary.adtMinHeight1000 = adt.minHeight1000
                if adt.maxHeight1000 > summary.adtMaxHeight1000:
                    summary.adtMaxHeight1000 = adt.maxHeight1000
            summary.adtTileCount = summary.adtTileCount + 1
            summary.adtChunkCount = summary.adtChunkCount + adt.mapChunkCount
            summary.adtHeightChunkCount = summary.adtHeightChunkCount + adt.heightChunkCount
            summary.adtHeightSampleCount = summary.adtHeightSampleCount + adt.heightSampleCount
            summary.chunkFileCount = summary.chunkFileCount + 1
            summary.totalChunkCount = summary.totalChunkCount + adt.header.chunkCount
        elif file.kind == "wmo":
            let wmoRes: Result[asset_formats.WmoRootSummary] = asset_formats.ParseWmoRootSummary(fileBuf)
            if IsErr(wmoRes):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(wmoRes))
            summary.wmoMaterialCount = Value(wmoRes).materialCount
            summary.wmoGroupCount = Value(wmoRes).groupCount
            summary.wmoDoodadCount = Value(wmoRes).doodadCount
            summary.wmoGroupFileDataIDCount = Value(wmoRes).groupFileDataIDCount
            summary.wmoFirstGroupFileDataID = Value(wmoRes).firstGroupFileDataID
            summary.wmoDoodadSetDefinitionCount = Value(wmoRes).doodadSetDefinitionCount
            summary.wmoDoodadPlacementCount = Value(wmoRes).doodadPlacementCount
            summary.wmoDoodadSetPlacementCount = Value(wmoRes).doodadSetPlacementCount
            summary.wmoFirstDoodadNameIndex = Value(wmoRes).firstDoodadNameIndex
            summary.wmoDoodadBoundsReady = Value(wmoRes).doodadBoundsReady
            summary.wmoDoodadSpanX1000 = Value(wmoRes).maxDoodadX1000 - Value(wmoRes).minDoodadX1000
            summary.wmoDoodadSpanY1000 = Value(wmoRes).maxDoodadY1000 - Value(wmoRes).minDoodadY1000
            summary.wmoDoodadSpanZ1000 = Value(wmoRes).maxDoodadZ1000 - Value(wmoRes).minDoodadZ1000
            summary.wmoModelSlotCount = Value(wmoRes).modelSlotCount
            summary.wmoModelFileDataIDCount = Value(wmoRes).modelFileDataIDCount
            summary.wmoFirstModelFileDataID = Value(wmoRes).firstModelFileDataID
            summary.wmoDoodadModelPlacementCount = Value(wmoRes).doodadResolvedModelPlacementCount
            summary.wmoDoodadReferencedModelFileDataIDCount = Value(wmoRes).doodadReferencedModelFileDataIDCount
            summary.wmoFirstDoodadModelFileDataID = Value(wmoRes).firstDoodadModelFileDataID
            let modelIdsRes: Result[int32[]] = asset_formats.ParseWmoModelFileDataIDs(fileBuf)
            if IsErr(modelIdsRes):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(modelIdsRes))
            let modelIds: int32[] = Value(modelIdsRes)
            var modelIndex: int32
            for modelIndex in modelIndex..<modelIds.len:
                if !northshire.HasDependencyFileDataID(manifest, file.label, "wmo_modi", modelIds[modelIndex]):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](strutil.Join(["wowExport preview: WMO MODI dependency is not audited ", strings.IntToStr(modelIds[modelIndex])], ""))
                summary.wmoModelDependencyCount = summary.wmoModelDependencyCount + 1
            summary.wmoModelDependenciesReady =
                summary.wmoModelDependencyCount == summary.wmoModelFileDataIDCount &&
                summary.wmoModelDependencyCount == northshire.CountDependenciesForSource(manifest, file.label, "wmo_modi")
            let doodadModelIdsRes: Result[int32[]] = asset_formats.ParseWmoDoodadModelFileDataIDs(fileBuf)
            if IsErr(doodadModelIdsRes):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(doodadModelIdsRes))
            let doodadModelIds: int32[] = Value(doodadModelIdsRes)
            var doodadModelIndex: int32
            for doodadModelIndex in doodadModelIndex..<doodadModelIds.len:
                if !northshire.HasDependencyFileDataID(manifest, file.label, "wmo_modi", doodadModelIds[doodadModelIndex]):
                    bytes.FreeByteBuffer(fileBuf)
                    return Err[bool](strutil.Join(["wowExport preview: WMO MODD model dependency is not audited ", strings.IntToStr(doodadModelIds[doodadModelIndex])], ""))
            summary.wmoDoodadModelDependenciesReady =
                doodadModelIds.len == summary.wmoDoodadModelPlacementCount &&
                summary.wmoDoodadModelPlacementCount == summary.wmoDoodadPlacementCount &&
                summary.wmoDoodadReferencedModelFileDataIDCount > 0
            let chunkRes: Result[bool] = previewApplyChunkedAsset(summary, fileBuf, "northshire-wmo")
            bytes.FreeByteBuffer(fileBuf)
            if IsErr(chunkRes):
                return Err[bool](Error(chunkRes))
        elif file.kind == "wmo_group":
            let groupRes: Result[asset_formats.WmoGroupSummary] =
                asset_formats.ParseWmoGroupSummary(fileBuf)
            bytes.FreeByteBuffer(fileBuf)
            if IsErr(groupRes):
                return Err[bool](Error(groupRes))
            summary.wmoGroupAssetCount = summary.wmoGroupAssetCount + 1
            summary.wmoGroupVertexCount = summary.wmoGroupVertexCount + Value(groupRes).vertexCount
            summary.wmoGroupIndexCount = summary.wmoGroupIndexCount + Value(groupRes).indexCount
        elif file.kind == "m2":
            let geometryRes: Result[asset_formats.M2GeometrySummary] = asset_formats.ParseM2GeometrySummary(fileBuf)
            if IsErr(geometryRes):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(geometryRes))
            let geometry: asset_formats.M2GeometrySummary = Value(geometryRes)
            summary.m2Version = geometry.header.version
            summary.characterVertexCount = geometry.header.vertexCount
            summary.animationSequenceCount = geometry.header.sequenceCount
            summary.modelBoundsReady = true
            summary.modelSpanX1000 = asset_formats.M2GeometrySpanX1000(geometry)
            summary.modelSpanY1000 = asset_formats.M2GeometrySpanY1000(geometry)
            summary.modelSpanZ1000 = asset_formats.M2GeometrySpanZ1000(geometry)
            let depRes: Result[asset_formats.M2DependencySummary] =
                asset_formats.ParseM2DependencySummary(fileBuf)
            bytes.FreeByteBuffer(fileBuf)
            if IsErr(depRes):
                return Err[bool](Error(depRes))
            summary.m2SkinFileDataIDCount = Value(depRes).skinFileDataIDCount
            summary.m2FirstSkinFileDataID = Value(depRes).firstSkinFileDataID
            summary.m2TextureFileDataIDCount = Value(depRes).textureFileDataIDCount
            summary.m2FirstTextureFileDataID = Value(depRes).firstTextureFileDataID
        elif file.kind == "skin":
            let skinRes: Result[asset_formats.M2SkinSummary] =
                asset_formats.ParseM2SkinSummary(fileBuf)
            bytes.FreeByteBuffer(fileBuf)
            if IsErr(skinRes):
                return Err[bool](Error(skinRes))
            summary.m2SkinIndexCount = summary.m2SkinIndexCount + Value(skinRes).indexCount
            summary.m2SkinTriangleIndexCount = summary.m2SkinTriangleIndexCount + Value(skinRes).triangleIndexCount
            summary.m2SkinSubmeshCount = summary.m2SkinSubmeshCount + Value(skinRes).submeshCount
        elif file.kind == "blp":
            let headerRes: Result[blp.Blp2Header] = blp.ParseBlp2Header(fileBuf)
            if IsErr(headerRes):
                bytes.FreeByteBuffer(fileBuf)
                return Err[bool](Error(headerRes))
            summary.textureWidth = Value(headerRes).width
            summary.textureHeight = Value(headerRes).height
            let tgaRes: Result[bytes.ByteBuffer] = blp.Blp2DecodeFirstMipTga(fileBuf)
            bytes.FreeByteBuffer(fileBuf)
            if IsErr(tgaRes):
                return Err[bool](Error(tgaRes))
            let tgaBuf: bytes.ByteBuffer = Value(tgaRes)
            summary.textureTgaBytes = tgaBuf.len
            bytes.FreeByteBuffer(tgaBuf)
        else:
            bytes.FreeByteBuffer(fileBuf)
            return Err[bool](strutil.Join(["wowExport preview: unsupported audited file kind ", file.kind], ""))
        i = i + 1
    return Ok[bool](true)

fn previewWdtMaidSceneReady(summary: PreviewSummary): bool =
    return summary.wdtActiveTileCount > 0 &&
        summary.wdtMaidFileDataIDCount > 0 &&
        summary.wdtMaidSplitDependenciesReady &&
        summary.wdtMaidSplitDependencyCount > 0 &&
        summary.wdtMaidParsedDependencyCount == summary.wdtMaidSplitDependencyCount &&
        summary.wdtMaidAdtSplitResourceCount > 0 &&
        summary.wdtMaidBlpResourceCount > 0 &&
        summary.wdtMaidAdtSplitChunkCount > 0 &&
        summary.wdtMaidAdtSplitMapChunkCount > 0

fn previewWdtMaidDoodadSceneReady(summary: PreviewSummary): bool =
    return summary.wdtMaidDoodadPlacementCount > 0 &&
        summary.wdtMaidDoodadReferencedFileDataIDCount > 0 &&
        summary.wdtMaidFirstDoodadReferencedFileDataID > 0 &&
        summary.wdtMaidDoodadPlacementDependencyCount == summary.wdtMaidDoodadReferencedFileDataIDCount &&
        summary.wdtMaidDoodadM2AssetCount == summary.wdtMaidDoodadReferencedFileDataIDCount &&
        summary.wdtMaidDoodadPlacementBoundsReady &&
        summary.wdtMaidDoodadPlacementMaxX1000 > summary.wdtMaidDoodadPlacementMinX1000 &&
        summary.wdtMaidDoodadPlacementMaxY1000 > summary.wdtMaidDoodadPlacementMinY1000 &&
        summary.wdtMaidDoodadPlacementMaxZ1000 > summary.wdtMaidDoodadPlacementMinZ1000 &&
        summary.wdtMaidDoodadMaxScale > 0

fn previewWdtMaidWorldModelSceneReady(summary: PreviewSummary): bool =
    return summary.wdtMaidWorldModelPlacementCount > 0 &&
        summary.wdtMaidWorldModelReferencedFileDataIDCount > 0 &&
        summary.wdtMaidFirstWorldModelReferencedFileDataID > 0 &&
        summary.wdtMaidWorldModelPlacementDependencyCount == summary.wdtMaidWorldModelReferencedFileDataIDCount &&
        summary.wdtMaidWorldModelWmoAssetCount == summary.wdtMaidWorldModelReferencedFileDataIDCount &&
        summary.wdtMaidPlacementDependencyAuditReady &&
        summary.wdtMaidPlacementDependencyEncodedBytes > 0 &&
        summary.wdtMaidPlacementDependencyDecodedBytes > 0 &&
        summary.wdtMaidWorldModelPlacementBoundsReady &&
        summary.wdtMaidWorldModelPlacementMaxX1000 > summary.wdtMaidWorldModelPlacementMinX1000 &&
        summary.wdtMaidWorldModelPlacementMaxY1000 > summary.wdtMaidWorldModelPlacementMinY1000 &&
        summary.wdtMaidWorldModelPlacementMaxZ1000 > summary.wdtMaidWorldModelPlacementMinZ1000 &&
        summary.wdtMaidWorldModelMaxScale > 0

fn previewAdtSceneReady(summary: PreviewSummary): bool =
    return summary.adtTileCount > 0 &&
        summary.adtChunkCount > 0 &&
        summary.adtHeightChunkCount == summary.adtChunkCount &&
        summary.adtHeightSampleCount > 0 &&
        summary.adtMaxHeight1000 > summary.adtMinHeight1000

fn previewWmoSceneReady(summary: PreviewSummary): bool =
    return summary.wmoGroupCount > 0 &&
        summary.wmoMaterialCount > 0 &&
        summary.wmoDoodadPlacementCount > 0 &&
        summary.wmoDoodadSetPlacementCount == summary.wmoDoodadPlacementCount &&
        summary.wmoDoodadBoundsReady &&
        summary.wmoDoodadSpanX1000 > 0 &&
        summary.wmoDoodadSpanY1000 > 0 &&
        summary.wmoDoodadSpanZ1000 > 0 &&
        summary.wmoGroupFileDataIDCount == summary.wmoGroupCount &&
        summary.wmoGroupAssetCount == summary.wmoGroupCount &&
        summary.wmoGroupVertexCount > 0 &&
        summary.wmoGroupIndexCount > 0 &&
        summary.wmoModelFileDataIDCount > 0 &&
        summary.wmoModelDependenciesReady &&
        summary.wmoModelDependencyCount == summary.wmoModelFileDataIDCount &&
        summary.wmoModelSlotCount >= summary.wmoModelFileDataIDCount &&
        summary.wmoDoodadModelDependenciesReady &&
        summary.wmoDoodadModelPlacementCount == summary.wmoDoodadPlacementCount &&
        summary.wmoDoodadReferencedModelFileDataIDCount > 0 &&
        summary.auditedDependencyCount >= summary.wmoModelDependencyCount &&
        summary.wmoChunkCount > 0

fn previewModelTextureSceneReady(summary: PreviewSummary): bool =
    return summary.m2Version > 0 &&
        summary.m2SkinFileDataIDCount > 0 &&
        summary.m2SkinIndexCount > 0 &&
        summary.m2SkinTriangleIndexCount > 0 &&
        summary.m2SkinSubmeshCount > 0 &&
        summary.m2TextureFileDataIDCount > 0 &&
        summary.characterVertexCount > 0 &&
        summary.modelBoundsReady &&
        summary.modelSpanX1000 > 0 &&
        summary.modelSpanY1000 > 0 &&
        summary.modelSpanZ1000 > 0 &&
        summary.animationSequenceCount > 0 &&
        summary.textureWidth > 0 &&
        summary.textureHeight > 0 &&
        summary.textureTgaBytes > 0

fn previewSceneReady(summary: PreviewSummary): bool =
    return summary.loadedFileCount == summary.auditedFileCount &&
        previewWdtMaidSceneReady(summary) &&
        previewWdtMaidDoodadSceneReady(summary) &&
        previewWdtMaidWorldModelSceneReady(summary) &&
        previewAdtSceneReady(summary) &&
        previewWmoSceneReady(summary) &&
        previewModelTextureSceneReady(summary)

fn PreviewNorthshire(frames: int32): Result[PreviewSummary] =
    if frames <= 0:
        return Err[PreviewSummary]("wowExport preview: frames must be positive")
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    if !northshire.ManifestReady(manifest):
        return Err[PreviewSummary]("wowExport preview: northshire manifest has no audited fileDataIDs; refusing to render fake geometry")
    let auditRes: Result[northshire.NorthshireAuditSummary] = northshire.AuditManifestPayloadsAgainstLocal(manifest)
    if IsErr(auditRes):
        return Err[PreviewSummary](Error(auditRes))
    let depAuditRes: Result[northshire.NorthshireAuditSummary] =
        northshire.AuditManifestDependenciesAgainstLocal(manifest)
    if IsErr(depAuditRes):
        return Err[PreviewSummary](Error(depAuditRes))
    var out: PreviewSummary
    out.width = 1280
    out.height = 720
    out.frames = frames
    out.auditedFileCount = Value(auditRes).matchedFileCount
    out.auditedDependencyCount = Value(depAuditRes).matchedDependencyCount
    let loadRes: Result[bool] = previewLoadAuditedAssets(out, manifest)
    if IsErr(loadRes):
        return Err[PreviewSummary](Error(loadRes))
    let maidDependencyRes: Result[bool] = previewLoadWdtMaidDependencyAssets(out, manifest)
    if IsErr(maidDependencyRes):
        return Err[PreviewSummary](Error(maidDependencyRes))
    out.sceneNonEmpty = previewSceneReady(out)
    out.memoryOutstanding = 0
    return Ok[PreviewSummary](out)

fn previewJoin2(a: str, b: str): str =
    return strings.ConcatStr(a, b)

fn previewJoin3(a: str, b: str, c: str): str =
    return strings.ConcatStr(strings.ConcatStr(a, b), c)

fn previewFieldText(name: str, value: str): str =
    return previewJoin3(" ", name, previewJoin2("=", value))

fn previewAppendField(out: var str, name: str, value: str) =
    out = strings.ConcatStr(out, previewFieldText(name, value))

fn previewBoolText(value: bool, trueText: str, falseText: str): str =
    if value:
        return trueText
    return falseText

fn previewIntText(value: int32): str =
    return strings.IntToStr(value)

fn previewPairText(a: int32, b: int32): str =
    return previewJoin3(previewIntText(a), ",", previewIntText(b))

fn previewTripleText(a: int32, b: int32, c: int32): str =
    return previewJoin3(previewPairText(a, b), ",", previewIntText(c))

fn previewSizeText(width: int32, height: int32): str =
    return previewJoin3(previewIntText(width), "x", previewIntText(height))

fn previewAppendCoreSummary(out: var str, summary: PreviewSummary) =
    previewAppendField(out, "frames", previewIntText(summary.frames))
    previewAppendField(out, "scene", previewBoolText(summary.sceneNonEmpty, "non-empty", "empty"))
    previewAppendField(out, "auditedFiles", previewIntText(summary.auditedFileCount))
    previewAppendField(out, "auditedDependencies", previewIntText(summary.auditedDependencyCount))
    previewAppendField(out, "loadedFiles", previewIntText(summary.loadedFileCount))
    previewAppendField(out, "chunkFiles", previewIntText(summary.chunkFileCount))
    previewAppendField(out, "totalChunks", previewIntText(summary.totalChunkCount))
    previewAppendField(out, "wdtActiveTiles", previewIntText(summary.wdtActiveTileCount))
    previewAppendField(out, "wdtModelPlacements", previewIntText(summary.wdtModelPlacementCount))
    previewAppendField(out, "wdtMaidFileIDs", previewIntText(summary.wdtMaidFileDataIDCount))
    previewAppendField(out, "wdtFirstMaidFileDataID", previewIntText(summary.wdtFirstMaidFileDataID))

fn previewAppendMaidSplitSummary(out: var str, summary: PreviewSummary) =
    previewAppendField(out, "wdtMaidSplitDependencies", previewIntText(summary.wdtMaidSplitDependencyCount))
    previewAppendField(out, "wdtMaidSplitDependencyAudit",
                       previewBoolText(summary.wdtMaidSplitDependenciesReady, "ready", "missing"))
    previewAppendField(out, "wdtMaidParsedDependencies", previewIntText(summary.wdtMaidParsedDependencyCount))
    previewAppendField(out, "wdtMaidAdtSplits", previewIntText(summary.wdtMaidAdtSplitResourceCount))
    previewAppendField(out, "wdtMaidBlps", previewIntText(summary.wdtMaidBlpResourceCount))
    previewAppendField(out, "wdtMaidAdtSplitChunks", previewIntText(summary.wdtMaidAdtSplitChunkCount))
    previewAppendField(out, "wdtMaidAdtSplitMcnks", previewIntText(summary.wdtMaidAdtSplitMapChunkCount))

fn previewAppendMaidDoodadSummary(out: var str, summary: PreviewSummary) =
    previewAppendField(out, "wdtMaidDoodadPlacements", previewIntText(summary.wdtMaidDoodadPlacementCount))
    previewAppendField(out, "wdtMaidDoodadReferencedFileIDs",
                       previewIntText(summary.wdtMaidDoodadReferencedFileDataIDCount))
    previewAppendField(out, "wdtMaidFirstDoodadReferencedFileID",
                       previewIntText(summary.wdtMaidFirstDoodadReferencedFileDataID))
    previewAppendField(out, "wdtMaidDoodadPlacementDependencies",
                       previewIntText(summary.wdtMaidDoodadPlacementDependencyCount))
    previewAppendField(out, "wdtMaidDoodadM2Assets", previewIntText(summary.wdtMaidDoodadM2AssetCount))
    previewAppendField(out, "wdtMaidDoodadPlacementBounds",
                       previewBoolText(summary.wdtMaidDoodadPlacementBoundsReady, "ready", "missing"))
    previewAppendField(out, "wdtMaidDoodadPlacementSpan1000",
                       previewTripleText(summary.wdtMaidDoodadPlacementMaxX1000 - summary.wdtMaidDoodadPlacementMinX1000,
                                         summary.wdtMaidDoodadPlacementMaxY1000 - summary.wdtMaidDoodadPlacementMinY1000,
                                         summary.wdtMaidDoodadPlacementMaxZ1000 - summary.wdtMaidDoodadPlacementMinZ1000))
    previewAppendField(out, "wdtMaidDoodadScaleMinMax",
                       previewPairText(summary.wdtMaidDoodadMinScale, summary.wdtMaidDoodadMaxScale))

fn previewAppendMaidWorldModelSummary(out: var str, summary: PreviewSummary) =
    previewAppendField(out, "wdtMaidWorldModelPlacements",
                       previewIntText(summary.wdtMaidWorldModelPlacementCount))
    previewAppendField(out, "wdtMaidWorldModelReferencedFileIDs",
                       previewIntText(summary.wdtMaidWorldModelReferencedFileDataIDCount))
    previewAppendField(out, "wdtMaidFirstWorldModelReferencedFileID",
                       previewIntText(summary.wdtMaidFirstWorldModelReferencedFileDataID))
    previewAppendField(out, "wdtMaidWorldModelPlacementDependencies",
                       previewIntText(summary.wdtMaidWorldModelPlacementDependencyCount))
    previewAppendField(out, "wdtMaidWorldModelWmoAssets", previewIntText(summary.wdtMaidWorldModelWmoAssetCount))
    previewAppendField(out, "wdtMaidPlacementDependencyAudit",
                       previewBoolText(summary.wdtMaidPlacementDependencyAuditReady, "ready", "missing"))
    previewAppendField(out, "wdtMaidPlacementDependencyEncodedBytes",
                       previewIntText(summary.wdtMaidPlacementDependencyEncodedBytes))
    previewAppendField(out, "wdtMaidPlacementDependencyDecodedBytes",
                       previewIntText(summary.wdtMaidPlacementDependencyDecodedBytes))
    previewAppendField(out, "wdtMaidWorldModelPlacementBounds",
                       previewBoolText(summary.wdtMaidWorldModelPlacementBoundsReady, "ready", "missing"))
    previewAppendField(out, "wdtMaidWorldModelPlacementSpan1000",
                       previewTripleText(summary.wdtMaidWorldModelPlacementMaxX1000 - summary.wdtMaidWorldModelPlacementMinX1000,
                                         summary.wdtMaidWorldModelPlacementMaxY1000 - summary.wdtMaidWorldModelPlacementMinY1000,
                                         summary.wdtMaidWorldModelPlacementMaxZ1000 - summary.wdtMaidWorldModelPlacementMinZ1000))
    previewAppendField(out, "wdtMaidWorldModelScaleMinMax",
                       previewPairText(summary.wdtMaidWorldModelMinScale, summary.wdtMaidWorldModelMaxScale))
    previewAppendField(out, "wdtMaidDependencyBytes", previewIntText(summary.wdtMaidDependencyBytes))

fn previewAppendAdtSummary(out: var str, summary: PreviewSummary) =
    previewAppendField(out, "adtTiles", previewIntText(summary.adtTileCount))
    previewAppendField(out, "adtChunks", previewIntText(summary.adtChunkCount))
    previewAppendField(out, "adtHeightChunks", previewIntText(summary.adtHeightChunkCount))
    previewAppendField(out, "adtHeightSamples", previewIntText(summary.adtHeightSampleCount))
    previewAppendField(out, "adtHeightMinMax1000",
                       previewPairText(summary.adtMinHeight1000, summary.adtMaxHeight1000))

fn previewAppendWmoSummary(out: var str, summary: PreviewSummary) =
    previewAppendField(out, "wmoChunks", previewIntText(summary.wmoChunkCount))
    previewAppendField(out, "wmoGroups", previewIntText(summary.wmoGroupCount))
    previewAppendField(out, "wmoMaterials", previewIntText(summary.wmoMaterialCount))
    previewAppendField(out, "wmoDoodads", previewIntText(summary.wmoDoodadCount))
    previewAppendField(out, "wmoDoodadSetDefs", previewIntText(summary.wmoDoodadSetDefinitionCount))
    previewAppendField(out, "wmoDoodadPlacements", previewIntText(summary.wmoDoodadPlacementCount))
    previewAppendField(out, "wmoDoodadSetPlacements", previewIntText(summary.wmoDoodadSetPlacementCount))
    previewAppendField(out, "wmoFirstDoodadNameIndex", previewIntText(summary.wmoFirstDoodadNameIndex))
    previewAppendField(out, "wmoDoodadBounds", previewBoolText(summary.wmoDoodadBoundsReady, "ready", "missing"))
    previewAppendField(out, "wmoDoodadSpan1000",
                       previewTripleText(summary.wmoDoodadSpanX1000,
                                         summary.wmoDoodadSpanY1000,
                                         summary.wmoDoodadSpanZ1000))
    previewAppendField(out, "wmoGroupFileIDs", previewIntText(summary.wmoGroupFileDataIDCount))
    previewAppendField(out, "wmoFirstGroupFileDataID", previewIntText(summary.wmoFirstGroupFileDataID))
    previewAppendField(out, "wmoGroupAssets", previewIntText(summary.wmoGroupAssetCount))
    previewAppendField(out, "wmoGroupVertices", previewIntText(summary.wmoGroupVertexCount))
    previewAppendField(out, "wmoGroupIndices", previewIntText(summary.wmoGroupIndexCount))
    previewAppendField(out, "wmoModelSlots", previewIntText(summary.wmoModelSlotCount))
    previewAppendField(out, "wmoModelFileIDs", previewIntText(summary.wmoModelFileDataIDCount))
    previewAppendField(out, "wmoModelDependencies", previewIntText(summary.wmoModelDependencyCount))
    previewAppendField(out, "wmoModelDependencyAudit",
                       previewBoolText(summary.wmoModelDependenciesReady, "ready", "missing"))
    previewAppendField(out, "wmoFirstModelFileDataID", previewIntText(summary.wmoFirstModelFileDataID))
    previewAppendField(out, "wmoDoodadModelPlacements", previewIntText(summary.wmoDoodadModelPlacementCount))
    previewAppendField(out, "wmoDoodadReferencedModelFileIDs",
                       previewIntText(summary.wmoDoodadReferencedModelFileDataIDCount))
    previewAppendField(out, "wmoDoodadModelDependencyAudit",
                       previewBoolText(summary.wmoDoodadModelDependenciesReady, "ready", "missing"))
    previewAppendField(out, "wmoFirstDoodadModelFileDataID",
                       previewIntText(summary.wmoFirstDoodadModelFileDataID))

fn previewAppendModelSummary(out: var str, summary: PreviewSummary) =
    previewAppendField(out, "m2Version", previewIntText(summary.m2Version))
    previewAppendField(out, "m2SkinFileIDs", previewIntText(summary.m2SkinFileDataIDCount))
    previewAppendField(out, "m2FirstSkinFileDataID", previewIntText(summary.m2FirstSkinFileDataID))
    previewAppendField(out, "m2TextureFileIDs", previewIntText(summary.m2TextureFileDataIDCount))
    previewAppendField(out, "m2FirstTextureFileDataID", previewIntText(summary.m2FirstTextureFileDataID))
    previewAppendField(out, "m2SkinIndices", previewIntText(summary.m2SkinIndexCount))
    previewAppendField(out, "m2SkinTriangleIndices", previewIntText(summary.m2SkinTriangleIndexCount))
    previewAppendField(out, "m2SkinSubmeshes", previewIntText(summary.m2SkinSubmeshCount))
    previewAppendField(out, "texture", previewSizeText(summary.textureWidth, summary.textureHeight))
    previewAppendField(out, "textureTgaBytes", previewIntText(summary.textureTgaBytes))
    previewAppendField(out, "assetBytes", previewIntText(summary.assetBytes))
    previewAppendField(out, "characterVertices", previewIntText(summary.characterVertexCount))
    previewAppendField(out, "animationSequences", previewIntText(summary.animationSequenceCount))
    previewAppendField(out, "modelBounds", previewBoolText(summary.modelBoundsReady, "ready", "missing"))
    previewAppendField(out, "modelSpan1000",
                       previewTripleText(summary.modelSpanX1000,
                                         summary.modelSpanY1000,
                                         summary.modelSpanZ1000))
    previewAppendField(out, "memoryOutstanding", previewIntText(summary.memoryOutstanding))

fn PreviewSummaryText(summary: PreviewSummary): str =
    var out: str = strings.ConcatStr("size=", previewSizeText(summary.width, summary.height))
    previewAppendCoreSummary(out, summary)
    previewAppendMaidSplitSummary(out, summary)
    previewAppendMaidDoodadSummary(out, summary)
    previewAppendMaidWorldModelSummary(out, summary)
    previewAppendAdtSummary(out, summary)
    previewAppendWmoSummary(out, summary)
    previewAppendModelSummary(out, summary)
    return out
