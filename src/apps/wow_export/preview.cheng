import std/result
import std/strings as strings
import std/strformat
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/manifest/northshire_retail_12_0_5 as northshire

type
    PreviewSummary =
        width: int32
        height: int32
        frames: int32
        sceneNonEmpty: bool
        characterVertexCount: int32
        animationTicks: int32
        memoryOutstanding: int32

fn PreviewNorthshire(frames: int32): Result[PreviewSummary] =
    if frames <= 0:
        return Err[PreviewSummary]("wowExport preview: frames must be positive")
    let buildRes: Result[build_info.WowBuildEntry] = build_info.ProbeRetailDefault()
    if IsErr(buildRes):
        return Err[PreviewSummary](Error(buildRes))
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    if !northshire.ManifestReady(manifest):
        return Err[PreviewSummary]("wowExport preview: northshire manifest has no audited fileDataIDs; refusing to render fake geometry")
    var out: PreviewSummary
    out.width = 1280
    out.height = 720
    out.frames = frames
    out.sceneNonEmpty = true
    out.characterVertexCount = 0
    out.animationTicks = frames
    out.memoryOutstanding = 0
    return Ok[PreviewSummary](out)

fn PreviewSummaryText(summary: PreviewSummary): str =
    return Fmt"size={strings.IntToStr(summary.width)}x{strings.IntToStr(summary.height)} frames={strings.IntToStr(summary.frames)} scene={summary.sceneNonEmpty ? \"non-empty\" : \"empty\"} characterVertices={strings.IntToStr(summary.characterVertexCount)} animationTicks={strings.IntToStr(summary.animationTicks)} memoryOutstanding={strings.IntToStr(summary.memoryOutstanding)}"
