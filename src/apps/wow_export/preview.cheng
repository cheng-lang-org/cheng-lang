    out = out + Fmt" wdtMaidWorldModelPlacementBounds={wdtMaidWorldModelBoundsText}"
    out = out + Fmt" wdtMaidWorldModelPlacementSpan1000={wdtMaidWorldModelSpanText}"
    out = out + Fmt" wdtMaidWorldModelScaleMinMax={wdtMaidWorldModelScaleText}"
