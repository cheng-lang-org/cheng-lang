import std/rawbytes as rawbytes
import std/result
import std/strings as strings
import std/strformat
import std/strutils as strutils
import cheng/apps/wow_export/build_info as build_info

@importc("driver_c_read_file_all_bridge")
fn cdnConfigReadFileAllBridge(path: cstring): str

type
    CdnConfig =
        archiveGroup: str
        fileIndex: str
        fileIndexSize: int32
        patchFileIndex: str
        patchFileIndexSize: int32

fn cdnConfigReadText(path: str): Result[str] =
    let pathBytesNoNull: rawbytes.Bytes = rawbytes.BytesFromString(path)
    var pathBytes: rawbytes.Bytes = rawbytes.BytesAlloc(pathBytesNoNull.len + 1)
    rawbytes.BytesCopyInto(pathBytes, 0, pathBytesNoNull)
    rawbytes.BytesSet(pathBytes, pathBytesNoNull.len, 0)
    rawbytes.BytesFree(pathBytesNoNull)
    let pathRaw: cstring = cstring(pathBytes.data)
    let text: str = cdnConfigReadFileAllBridge(pathRaw)
    rawbytes.BytesFree(pathBytes)
    if strings.Len(text) == 0:
        return Err[str]("wowExport CDN config: failed to read local CDN config")
    return Ok[str](text)

fn cdnConfigIsSpace(ch: char): bool =
    return ch == ' ' || ch == '\t'

fn cdnConfigIsHexChar(ch: char): bool =
    if ch >= '0' && ch <= '9':
        return true
    if ch >= 'a' && ch <= 'f':
        return true
    if ch >= 'A' && ch <= 'F':
        return true
    return false

fn cdnConfigIsHexKey(key: str): bool =
    if strings.Len(key) != 32:
        return false
    var pos: int32
    while pos < strings.Len(key):
        if !cdnConfigIsHexChar(key[pos]):
            return false
        pos = pos + 1
    return true

fn cdnConfigLineKeyMatches(text: str, lineStart: int32, lineEnd: int32, key: str): bool =
    var pos: int32 = lineStart
    while pos < lineEnd && cdnConfigIsSpace(text[pos]):
        pos = pos + 1
    var keyPos: int32
    while keyPos < strings.Len(key):
        if pos + keyPos >= lineEnd:
            return false
        if text[pos + keyPos] != key[keyPos]:
            return false
        keyPos = keyPos + 1
    pos = pos + strings.Len(key)
    while pos < lineEnd && cdnConfigIsSpace(text[pos]):
        pos = pos + 1
    if pos >= lineEnd:
        return false
    let ch: char = text[pos]
    if ch == '=':
        return true
    return false

fn cdnConfigLineValue(text: str, lineStart: int32, lineEnd: int32): str =
    var pos: int32 = lineStart
    while pos < lineEnd && text[pos] != '=':
        pos = pos + 1
    if pos >= lineEnd:
        return ""
    return strutils.Strip(strings.SliceBytes(text, pos + 1, lineEnd - pos - 1))

fn ParseCdnConfigText(text: str): Result[CdnConfig] =
    if strings.Len(text) == 0:
        return Err[CdnConfig]("wowExport CDN config: empty config")
    var out: CdnConfig
    let n: int32 = strings.Len(text)
    var lineStart: int32
    var pos: int32
    while pos <= n:
        if pos == n || text[pos] == '\n':
            var lineEnd: int32 = pos
            if lineEnd > lineStart && text[lineEnd - 1] == '\r':
                lineEnd = lineEnd - 1
            if lineEnd > lineStart:
                if cdnConfigLineKeyMatches(text, lineStart, lineEnd, "archive-group"):
                    out.archiveGroup = cdnConfigLineValue(text, lineStart, lineEnd)
                elif cdnConfigLineKeyMatches(text, lineStart, lineEnd, "file-index"):
                    out.fileIndex = cdnConfigLineValue(text, lineStart, lineEnd)
                elif cdnConfigLineKeyMatches(text, lineStart, lineEnd, "file-index-size"):
                    out.fileIndexSize = int32(strutils.ParseInt(cdnConfigLineValue(text, lineStart, lineEnd)))
                elif cdnConfigLineKeyMatches(text, lineStart, lineEnd, "patch-file-index"):
                    out.patchFileIndex = cdnConfigLineValue(text, lineStart, lineEnd)
                elif cdnConfigLineKeyMatches(text, lineStart, lineEnd, "patch-file-index-size"):
                    out.patchFileIndexSize = int32(strutils.ParseInt(cdnConfigLineValue(text, lineStart, lineEnd)))
            lineStart = pos + 1
        pos = pos + 1
    if strings.Len(out.archiveGroup) != 32:
        return Err[CdnConfig]("wowExport CDN config: missing archive-group")
    if strings.Len(out.fileIndex) != 32:
        return Err[CdnConfig]("wowExport CDN config: missing file-index")
    if out.fileIndexSize <= 0:
        return Err[CdnConfig]("wowExport CDN config: missing file-index-size")
    if strings.Len(out.patchFileIndex) != 32:
        return Err[CdnConfig]("wowExport CDN config: missing patch-file-index")
    if out.patchFileIndexSize <= 0:
        return Err[CdnConfig]("wowExport CDN config: missing patch-file-index-size")
    return Ok[CdnConfig](out)

fn LoadCdnConfig(clientPath: str, cdnKey: str): Result[CdnConfig] =
    let pathRes: Result[str] = build_info.ConfigPathForKey(clientPath, cdnKey)
    if IsErr(pathRes):
        return Err[CdnConfig](Error(pathRes))
    let textRes: Result[str] = cdnConfigReadText(Value(pathRes))
    if IsErr(textRes):
        return Err[CdnConfig](Error(textRes))
    return ParseCdnConfigText(Value(textRes))

fn CdnLooseDataPath(ekey: str): Result[str] =
    if !cdnConfigIsHexKey(ekey):
        return Err[str]("wowExport CDN config: loose ekey must be 32 hex chars")
    let shardA: str = strings.SliceBytes(ekey, 0, 2)
    let shardB: str = strings.SliceBytes(ekey, 2, 2)
    let withA: str = build_info.StablePathJoin("data", shardA)
    let withB: str = build_info.StablePathJoin(withA, shardB)
    return Ok[str](build_info.StablePathJoin(withB, ekey))

fn CdnFirstHost(hosts: str): Result[str] =
    let trimmed: str = strutils.Strip(hosts)
    if strings.Len(trimmed) == 0:
        return Err[str]("wowExport CDN config: missing CDN host")
    var pos: int32
    while pos < strings.Len(trimmed):
        if cdnConfigIsSpace(trimmed[pos]) || trimmed[pos] == '\n' || trimmed[pos] == '\r':
            if pos == 0:
                return Err[str]("wowExport CDN config: missing CDN host")
            return Ok[str](strings.SliceBytes(trimmed, 0, pos))
        pos = pos + 1
    return Ok[str](trimmed)

fn CdnLooseDataUrl(entry: build_info.WowBuildEntry, ekey: str, useHttps: bool): Result[str] =
    if strings.Len(entry.cdnPath) == 0:
        return Err[str]("wowExport CDN config: missing CDN path")
    let hostRes: Result[str] = CdnFirstHost(entry.cdnHosts)
    if IsErr(hostRes):
        return Err[str](Error(hostRes))
    let pathRes: Result[str] = CdnLooseDataPath(ekey)
    if IsErr(pathRes):
        return pathRes
    let scheme: str = useHttps ? "https://" : "http://"
    let origin: str = build_info.StableConcat(scheme, Value(hostRes))
    let cdnRoot: str = build_info.StablePathJoin(origin, entry.cdnPath)
    return Ok[str](build_info.StablePathJoin(cdnRoot, Value(pathRes)))

fn CdnConfigSummary(cfg: CdnConfig): str =
    return Fmt"archiveGroup={cfg.archiveGroup} fileIndex={cfg.fileIndex} fileIndexSize={strings.IntToStr(cfg.fileIndexSize)}"
