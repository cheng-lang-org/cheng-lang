import std/result
import std/system as system
import std/os as os
import std/strings as strings
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/core/tooling/path as chengpath
import cheng/mobile/mobile_sdk as mobile_sdk
import cheng/apps/unimaker/unimaker_edge_types as types
import cheng/evomap/unimaker_evomap_protocol as proto

type
    UnimakerAgent =
        cfg: types.UnimakerAgentConfig
        sdk: mobile_sdk.MobileSdk
        identity: types.AgentIdentity
        genes: types.EvoGene[]
        capsules: types.EvoCapsule[]
        nodes: types.MemoryNode[]
        edges: types.MemoryEdge[]
        headCid: layout.FixedBytes32
        nextSequence: int32

fn UnimakerAgentRootDir(cfg: types.UnimakerAgentConfig): str =
    let rootDirText: str = strutil.Strip(cfg.rootDir)
    if strings.Len(rootDirText) > 0:
        return cfg.rootDir
    return chengpath.PathCurrentDir()

fn UnimakerAgentAbsoluteIdentityStorePath(cfg: types.UnimakerAgentConfig): str =
    return chengpath.PathAbsolute(UnimakerAgentRootDir(cfg), cfg.identityStorePath)

fn UnimakerAgentAbsoluteEventLogPath(cfg: types.UnimakerAgentConfig): str =
    return chengpath.PathAbsolute(UnimakerAgentRootDir(cfg), cfg.eventLogPath)

fn UnimakerAgentRequire(ok: bool, message: str) =
    if !ok:
        system.panic(message)

fn UnimakerAgentFindGenePos(genes: types.EvoGene[],
                              capability: str): int32 =
    for i in 0..<genes.len:
        if genes[i].capability == capability:
            return i
    return -1

fn UnimakerAgentFindCapsulePos(capsules: types.EvoCapsule[],
                                 capsuleCid: layout.FixedBytes32): int32 =
    for i in 0..<capsules.len:
        if layout.FixedBytes32Equal(capsules[i].capsuleCid, capsuleCid):
            return i
    return -1

fn UnimakerAgentCloneCapsules(values: types.EvoCapsule[]): types.EvoCapsule[] =
    var out: types.EvoCapsule[]
    for i in 0..<values.len:
        add(out, types.UnimakerCapsuleClone(values[i]))
    return out

fn UnimakerAgentEdgeExists(edges: types.MemoryEdge[],
                             edgeKind: str,
                             fromCid: layout.FixedBytes32,
                             toCid: layout.FixedBytes32): bool =
    for i in 0..<edges.len:
        if edges[i].edgeKind != edgeKind:
            continue
        if !layout.FixedBytes32Equal(edges[i].fromCid, fromCid):
            continue
        if !layout.FixedBytes32Equal(edges[i].toCid, toCid):
            continue
        return true
    return false

fn UnimakerAgentCurrentCursor(agent: UnimakerAgent): types.SyncCursor =
    return types.UnimakerCursorMake(agent.capsules.len, agent.headCid)

fn UnimakerAgentCapsuleCount(agent: UnimakerAgent): int32 =
    return agent.capsules.len

fn UnimakerAgentNodeCount(agent: UnimakerAgent): int32 =
    return agent.nodes.len

fn UnimakerAgentEdgeCount(agent: UnimakerAgent): int32 =
    return agent.edges.len

fn UnimakerAgentHeadCid(agent: UnimakerAgent): layout.FixedBytes32 =
    return agent.headCid

fn UnimakerAgentHelloPayload(agent: UnimakerAgent): str =
    var hello = proto.EvoMapA2AHello()
    hello.version = types.UnimakerProtocolVersion
    hello.identity = agent.identity
    hello.cursor = UnimakerAgentCurrentCursor(agent)
    hello.genes = agent.genes
    return proto.UnimakerProtocolEncodeHello(hello)

fn UnimakerAgentResultPayload(agent: UnimakerAgent,
                                plan: types.AgentPlan): str =
    var resultValue = proto.EvoMapA2AResult()
    resultValue.version = types.UnimakerProtocolVersion
    resultValue.taskId = plan.taskId
    resultValue.actionKind = plan.actionKind
    resultValue.planText = plan.planText
    resultValue.headCid = agent.headCid
    resultValue.selectedCapsuleCids = types.UnimakerCloneFixed32Seq(plan.selectedCapsuleCids)
    resultValue.memoryHitCount = plan.memoryHitCount
    resultValue.confidenceScore = plan.confidenceScore
    resultValue.geneCid = plan.geneCid
    return proto.UnimakerProtocolEncodeResult(resultValue)

fn UnimakerAgentPersistCapsules(cfg: types.UnimakerAgentConfig,
                                  capsules: types.EvoCapsule[]): Result[bool] =
    let path = UnimakerAgentAbsoluteEventLogPath(cfg)
    if len(path) <= 0:
        return Err[bool](" unimaker agent: empty event log path")
    let tmpPath = strutil.Join([path, ".tmp"], "")
    if os.FileExists(tmpPath):
        let _ = os.RemoveFile(tmpPath)
    var lines: str[]
    for i in 0..<capsules.len:
        let line = proto.UnimakerProtocolEncodeCapsuleNode(capsules[i])
        add(lines, line)
    var text = strutil.Join(lines, "\n")
    if len(text) > 0:
        text = strutil.Join([text, "\n"], "")
    if !chengpath.WriteTextFile("", tmpPath, text):
        return Err[bool](" unimaker agent: write tmp event log failed")
    if os.FileExists(path):
        let _ = os.RemoveFile(path)
    if !os.RenameFile(tmpPath, path):
        return Err[bool](" unimaker agent: rename event log failed")
    return Ok[bool](true)

fn UnimakerAgentLoadCapsules(cfg: types.UnimakerAgentConfig): Result[types.EvoCapsule[]] =
    let path = UnimakerAgentAbsoluteEventLogPath(cfg)
    if len(path) <= 0:
        return Err[types.EvoCapsule[]](" unimaker agent: empty event log path")
    if !chengpath.PathFileExists(path):
        return Ok[types.EvoCapsule[]]([])
    let text = chengpath.ReadTextFile("", path)
    if len(text) <= 0:
        return Ok[types.EvoCapsule[]]([])
    let lines = strutil.Split(text, '\n')
    var out: types.EvoCapsule[]
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if len(line) <= 0:
            continue
        let nodeRes = proto.UnimakerProtocolParseText(line)
        if IsErr(nodeRes):
            return Err[types.EvoCapsule[]](Error(nodeRes))
        let capsuleRes = proto.UnimakerProtocolDecodeCapsuleNode(Value(nodeRes))
        if IsErr(capsuleRes):
            return Err[types.EvoCapsule[]](Error(capsuleRes))
        add(out, Value(capsuleRes))
    return Ok[types.EvoCapsule[]](out)

fn UnimakerAgentRebuildGraph(agent: var UnimakerAgent) =
    agent.nodes = []
    agent.edges = []
    for i in 0..<agent.capsules.len:
        let capsule = agent.capsules[i]
        add(agent.nodes, types.UnimakerMemoryNodeFromCapsule(capsule))
        if !UnimakerAgentEdgeExists(agent.edges,
                                      types.UnimakerEdgeKindFromDevice,
                                      agent.identity.identityCid,
                                      capsule.capsuleCid):
            add(agent.edges, types.UnimakerMemoryEdgeMake(types.UnimakerEdgeKindFromDevice,
                                                            agent.identity.identityCid,
                                                            capsule.capsuleCid))
        for j in 0..<capsule.parentCids.len:
            if !UnimakerAgentEdgeExists(agent.edges,
                                          capsule.relationKind,
                                          capsule.capsuleCid,
                                          capsule.parentCids[j]):
                add(agent.edges, types.UnimakerMemoryEdgeMake(capsule.relationKind,
                                                                capsule.capsuleCid,
                                                                capsule.parentCids[j]))
    agent.headCid = types.UnimakerGraphHeadCid(agent.capsules)
    agent.nextSequence = agent.capsules.len + 1

fn UnimakerAgentValidateEvent(event: types.EvolutionEvent): Result[bool] =
    if !types.UnimakerEventKindValid(event.eventKind):
        return Err[bool](" unimaker agent: invalid event kind")
    let contentText: str = strutil.Strip(event.contentText)
    if strings.Len(contentText) <= 0:
        return Err[bool](" unimaker agent: empty event content")
    if event.createdAtEpochSeconds <= int64(0):
        return Err[bool](" unimaker agent: invalid event timestamp")
    if len(event.relationKind) > 0:
        if !types.UnimakerEdgeKindValid(event.relationKind):
            return Err[bool](" unimaker agent: invalid event relation kind")
        if event.relationKind == types.UnimakerEdgeKindFromDevice:
            return Err[bool](" unimaker agent: from_device is reserved")
    return Ok[bool](true)

fn UnimakerAgentValidateIncomingCapsule(existing: types.EvoCapsule[],
                                          staged: types.EvoCapsule[],
                                          capsule: types.EvoCapsule): Result[bool] =
    for i in 0..<capsule.parentCids.len:
        if UnimakerAgentFindCapsulePos(existing, capsule.parentCids[i]) >= 0:
            continue
        if UnimakerAgentFindCapsulePos(staged, capsule.parentCids[i]) >= 0:
            continue
        return Err[bool](" unimaker agent: parent capsule missing")
    return Ok[bool](true)

fn UnimakerAgentHitBetter(left: types.MemoryHit,
                            right: types.MemoryHit): bool =
    if left.score != right.score:
        return left.score > right.score
    if left.capsule.createdAtEpochSeconds != right.capsule.createdAtEpochSeconds:
        return left.capsule.createdAtEpochSeconds > right.capsule.createdAtEpochSeconds
    return left.capsule.sequence > right.capsule.sequence

fn UnimakerAgentSortHits(hits: var types.MemoryHit[]) =
    if hits.len <= 1:
        return
    for i in 1..<hits.len:
        let value = hits[i]
        var j = i
        while j > 0:
            if !UnimakerAgentHitBetter(value, hits[j - 1]):
                break
            hits[j] = hits[j - 1]
            j = j - 1
        hits[j] = value

fn UnimakerAgentMatchCapsule(capsule: types.EvoCapsule,
                               query: types.MemoryQuery): types.MemoryHit =
    var hit = types.MemoryHit()
    hit.capsule = types.UnimakerCapsuleClone(capsule)
    var labels: str[]
    if len(query.taskId) > 0:
        if capsule.taskId == query.taskId:
            hit.score = hit.score + 3
            add(labels, "task")
    if len(query.keyword) > 0:
        if types.UnimakerCapsuleKeywordMatch(capsule, query.keyword):
            hit.score = hit.score + 1
            add(labels, "keyword")
    if query.hasParent:
        if types.UnimakerFixed32SeqContains(capsule.parentCids, query.parentCid):
            hit.score = hit.score + 2
            add(labels, "parent")
    hit.matchedBy = strutil.Join(labels, "+")
    return hit

fn UnimakerAgentPlanHits(agent: UnimakerAgent,
                           task: types.AgentTask): types.MemoryHit[] =
    var hits: types.MemoryHit[]
    for i in 0..<agent.capsules.len:
        var query = types.MemoryQuery()
        query.taskId = task.taskId
        query.limit = agent.capsules.len
        var hit = UnimakerAgentMatchCapsule(agent.capsules[i], query)
        for j in 0..<task.keywords.len:
            if types.UnimakerCapsuleKeywordMatch(agent.capsules[i], task.keywords[j]):
                hit.score = hit.score + 1
                if len(hit.matchedBy) > 0:
                    hit.matchedBy = strutil.Join([hit.matchedBy, "+"], "")
                hit.matchedBy = strutil.Join([hit.matchedBy, "task_keyword"], "")
                break
        if hit.score <= 0:
            continue
        add(hits, hit)
    UnimakerAgentSortHits(hits)
    return hits

fn UnimakerAgentInit(cfg: types.UnimakerAgentConfig): UnimakerAgent =
    let rootDir = UnimakerAgentRootDir(cfg)
    let eventLogPathText: str = strutil.Strip(cfg.eventLogPath)
    let identityStorePathText: str = strutil.Strip(cfg.identityStorePath)
    UnimakerAgentRequire(strings.Len(eventLogPathText) > 0,
                           " unimaker agent: event log path required")
    UnimakerAgentRequire(strings.Len(identityStorePathText) > 0,
                           " unimaker agent: identity store path required")
    var out = UnimakerAgent()
    out.cfg = cfg
    out.cfg.rootDir = rootDir
    let identityStorePath = UnimakerAgentAbsoluteIdentityStorePath(out.cfg)
    let eventLogPath = UnimakerAgentAbsoluteEventLogPath(out.cfg)
    UnimakerAgentRequire(len(identityStorePath) > 0,
                           " unimaker agent: invalid identity store path")
    UnimakerAgentRequire(len(eventLogPath) > 0,
                           " unimaker agent: invalid event log path")
    var sdk = mobile_sdk.MobileSdkInit("")
    let initRes = mobile_sdk.MobileSdkInitWithDidStoreFill(sdk,
                                                             identityStorePath,
                                                             cfg.rootSeedHint,
                                                             cfg.deviceSeedHint,
                                                             cfg.deviceLabelHint,
                                                             cfg.epochSeconds)
    if IsErr(initRes):
        system.panic(strutil.Join([" unimaker agent: identity init failed: ", Error(initRes)], ""))
    mobile_sdk.MobileSdkStart(sdk)
    mobile_sdk.MobileSdkSetMdns(sdk, true, 15)
    mobile_sdk.MobileSdkSetTrustedInfra(sdk, true)
    UnimakerAgentRequire(sdk.host.hasDidIdentity,
                           " unimaker agent: sdk missing did identity")
    out.sdk = sdk
    out.identity = types.UnimakerAgentIdentityMake(sdk.host.didIdentity)
    out.genes = types.UnimakerDefaultGenes()
    let loadRes = UnimakerAgentLoadCapsules(out.cfg)
    if IsErr(loadRes):
        system.panic(strutil.Join([" unimaker agent: load capsules failed: ", Error(loadRes)], ""))
    out.capsules = Value(loadRes)
    UnimakerAgentRebuildGraph(out)
    return out

fn UnimakerAgentIngest(agent: var UnimakerAgent,
                         event: types.EvolutionEvent): Result[types.EvoCapsule] =
    let validateRes = UnimakerAgentValidateEvent(event)
    if IsErr(validateRes):
        return Err[types.EvoCapsule](Error(validateRes))
    let genePos = UnimakerAgentFindGenePos(agent.genes, "event_ingest")
    if genePos < 0:
        return Err[types.EvoCapsule](" unimaker agent: missing event_ingest gene")
    let capsule = types.UnimakerCapsuleMake(agent.nextSequence,
                                              agent.identity,
                                              event,
                                              agent.genes[genePos])
    if UnimakerAgentFindCapsulePos(agent.capsules, capsule.capsuleCid) >= 0:
        return Err[types.EvoCapsule](" unimaker agent: duplicate capsule")
    var staged = UnimakerAgentCloneCapsules(agent.capsules)
    add(staged, capsule)
    let persistRes = UnimakerAgentPersistCapsules(agent.cfg, staged)
    if IsErr(persistRes):
        return Err[types.EvoCapsule](Error(persistRes))
    agent.capsules = staged
    UnimakerAgentRebuildGraph(agent)
    return Ok[types.EvoCapsule](types.UnimakerCapsuleClone(capsule))

fn UnimakerAgentRecall(agent: UnimakerAgent,
                         query: types.MemoryQuery): Result[types.MemoryHit[]] =
    if query.limit <= 0:
        return Err[types.MemoryHit[]](" unimaker agent: query limit must be > 0")
    if len(query.taskId) <= 0 && len(query.keyword) <= 0 && !query.hasParent:
        return Err[types.MemoryHit[]](" unimaker agent: empty memory query")
    var hits: types.MemoryHit[]
    for i in 0..<agent.capsules.len:
        let hit = UnimakerAgentMatchCapsule(agent.capsules[i], query)
        if hit.score <= 0:
            continue
        add(hits, hit)
    UnimakerAgentSortHits(hits)
    if hits.len <= query.limit:
        return Ok[types.MemoryHit[]](hits)
    var limited: types.MemoryHit[]
    for i in 0..<query.limit:
        add(limited, hits[i])
    return Ok[types.MemoryHit[]](limited)

fn UnimakerAgentPlan(agent: UnimakerAgent,
                       task: types.AgentTask): Result[types.AgentPlan] =
    let genePos = UnimakerAgentFindGenePos(agent.genes, "task_planning")
    if genePos < 0:
        return Err[types.AgentPlan](" unimaker agent: missing task_planning gene")
    let taskIdText: str = strutil.Strip(task.taskId)
    if strings.Len(taskIdText) <= 0:
        return Err[types.AgentPlan](" unimaker agent: task id required")
    let hits = UnimakerAgentPlanHits(agent, task)
    var out = types.AgentPlan()
    out.taskId = task.taskId
    out.geneCid = agent.genes[genePos].geneCid
    out.memoryHitCount = hits.len
    if hits.len > 0:
        out.actionKind = types.UnimakerPlanActionReuseMemory
        out.confidenceScore = hits[0].score
        add(out.selectedCapsuleCids, hits[0].capsule.capsuleCid)
        if hits.len > 1:
            add(out.selectedCapsuleCids, hits[1].capsule.capsuleCid)
        out.planText = strutil.Join(["reuse memory capsules for task ", task.taskId], "")
        return Ok[types.AgentPlan](out)
    out.actionKind = types.UnimakerPlanActionCaptureFirst
    out.confidenceScore = 1
    out.planText = strutil.Join(["capture first capsule for task ", task.taskId], "")
    return Ok[types.AgentPlan](out)

fn UnimakerAgentSyncPush(agent: UnimakerAgent,
                           peer: var types.UnimakerSyncPeer): Result[types.SyncReport] =
    if !types.UnimakerTransportKindValid(peer.transportKind):
        return Err[types.SyncReport](" unimaker agent: invalid peer transport kind")
    peer.lastHelloPayload = UnimakerAgentHelloPayload(agent)
    let start = peer.remoteCursor.eventCount
    var push = proto.EvoMapGeppush()
    push.version = types.UnimakerProtocolVersion
    push.cursor = UnimakerAgentCurrentCursor(agent)
    for i in start..<agent.capsules.len:
        add(push.capsules, types.UnimakerCapsuleClone(agent.capsules[i]))
    let payload = proto.UnimakerProtocolEncodePush(push)
    peer.outboundPushPayload = payload
    peer.remoteCursor = push.cursor
    var report = types.SyncReport()
    report.pushedCount = push.capsules.len
    report.headCid = agent.headCid
    report.cursor = push.cursor
    report.requestPath = proto.UnimakerProtocolPushPath()
    report.payloadText = payload
    return Ok[types.SyncReport](report)

fn UnimakerAgentSyncPull(agent: var UnimakerAgent,
                           peer: var types.UnimakerSyncPeer,
                           cursor: types.SyncCursor): Result[types.SyncReport] =
    if !types.UnimakerTransportKindValid(peer.transportKind):
        return Err[types.SyncReport](" unimaker agent: invalid peer transport kind")
    var pull = proto.EvoMapGeppull()
    pull.version = types.UnimakerProtocolVersion
    pull.cursor = cursor
    peer.outboundPullPayload = proto.UnimakerProtocolEncodePull(pull)
    var report = types.SyncReport()
    report.requestPath = proto.UnimakerProtocolPullPath()
    report.payloadText = peer.outboundPullPayload
    let inboundPushPayload: str = strutil.Strip(peer.inboundPushPayload)
    if strings.Len(inboundPushPayload) <= 0:
        report.headCid = agent.headCid
        report.cursor = UnimakerAgentCurrentCursor(agent)
        return Ok[types.SyncReport](report)
    let pushRes = proto.UnimakerProtocolDecodePush(peer.inboundPushPayload)
    if IsErr(pushRes):
        return Err[types.SyncReport](Error(pushRes))
    let push = Value(pushRes)
    report.pulledCount = push.capsules.len
    var staged = UnimakerAgentCloneCapsules(agent.capsules)
    var mergedCount: int32
    var duplicateCount: int32
    for i in 0..<push.capsules.len:
        let capsule = push.capsules[i]
        if UnimakerAgentFindCapsulePos(staged, capsule.capsuleCid) >= 0:
            duplicateCount = duplicateCount + 1
            continue
        let validateRes = UnimakerAgentValidateIncomingCapsule(agent.capsules, staged, capsule)
        if IsErr(validateRes):
            return Err[types.SyncReport](Error(validateRes))
        add(staged, types.UnimakerCapsuleClone(capsule))
        mergedCount = mergedCount + 1
    let expectedHead = types.UnimakerGraphHeadCid(staged)
    if !layout.FixedBytes32Equal(expectedHead, push.cursor.headCid):
        return Err[types.SyncReport](" unimaker agent: remote head cid mismatch")
    if mergedCount > 0:
        let persistRes = UnimakerAgentPersistCapsules(agent.cfg, staged)
        if IsErr(persistRes):
            return Err[types.SyncReport](Error(persistRes))
        agent.capsules = staged
        UnimakerAgentRebuildGraph(agent)
    report.mergedCount = mergedCount
    report.duplicateCount = duplicateCount
    report.headCid = agent.headCid
    report.cursor = UnimakerAgentCurrentCursor(agent)
    return Ok[types.SyncReport](report)
