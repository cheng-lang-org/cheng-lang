import std/strings as strings
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/lsmr_types as lt
import cheng/libp2p/identity/did
import cheng/libp2p/core/peer_id

const
    UnimakerCapsuleVersion: int32 = 1
    UnimakerProtocolVersion: int32 = 1
    UnimakerEdgeKindCausedBy: str = "caused_by"
    UnimakerEdgeKindRefines: str = "refines"
    UnimakerEdgeKindContradicts: str = "contradicts"
    UnimakerEdgeKindUsefulFor: str = "useful_for"
    UnimakerEdgeKindFromDevice: str = "from_device"
    UnimakerEventUserInput: str = "user_input"
    UnimakerEventToolResult: str = "tool_result"
    UnimakerEventSystemNotice: str = "system_notice"
    UnimakerEventNetworkMessage: str = "network_message"
    UnimakerEventAppLifecycle: str = "app_lifecycle"
    UnimakerPlanActionReuseMemory: str = "reuse_memory"
    UnimakerPlanActionCaptureFirst: str = "capture_first"
    UnimakerTransportHttpJson: str = "http_json"
    UnimakerTransportLibp2pReqResp: str = "libp2p_request_response"
    UnimakerTransportLibp2pTopic: str = "libp2p_topic"

type
    EvoGene =
        capability: str
        strategy: str
        condition: str
        geneCid: layout.FixedBytes32

    AgentIdentity =
        didText: str
        peerIdText: str
        deviceLabel: str
        identityCid: layout.FixedBytes32
        signatureCid: layout.FixedBytes32

    SyncCursor =
        eventCount: int32
        headCid: layout.FixedBytes32

    EvolutionEvent =
        version: int32
        eventKind: str
        taskId: str
        contentText: str
        keywords: str[]
        parentCids: layout.FixedBytes32[]
        relationKind: str
        createdAtEpochSeconds: int64

    EvoCapsule =
        version: int32
        sequence: int32
        capsuleKind: str
        taskId: str
        contentText: str
        keywords: str[]
        parentCids: layout.FixedBytes32[]
        relationKind: str
        sourceDidText: str
        sourcePeerIdText: str
        sourceDeviceLabel: str
        createdAtEpochSeconds: int64
        contentCid: layout.FixedBytes32
        capsuleCid: layout.FixedBytes32
        signatureCid: layout.FixedBytes32
        geneCid: layout.FixedBytes32

    MemoryNode =
        nodeCid: layout.FixedBytes32
        capsuleCid: layout.FixedBytes32
        taskId: str
        capsuleKind: str
        summaryText: str
        createdAtEpochSeconds: int64

    MemoryEdge =
        edgeKind: str
        fromCid: layout.FixedBytes32
        toCid: layout.FixedBytes32

    MemoryQuery =
        taskId: str
        keyword: str
        parentCid: layout.FixedBytes32
        hasParent: bool
        limit: int32

    MemoryHit =
        capsule: EvoCapsule
        score: int32
        matchedBy: str

    AgentTask =
        taskId: str
        promptText: str
        keywords: str[]

    AgentPlan =
        taskId: str
        actionKind: str
        planText: str
        selectedCapsuleCids: layout.FixedBytes32[]
        memoryHitCount: int32
        confidenceScore: int32
        geneCid: layout.FixedBytes32

    SyncReport =
        pushedCount: int32
        pulledCount: int32
        mergedCount: int32
        duplicateCount: int32
        headCid: layout.FixedBytes32
        cursor: SyncCursor
        requestPath: str
        payloadText: str

    UnimakerSyncPeer =
        peerIdText: str
        endpointText: str
        transportKind: str
        trusted: bool
        remoteCursor: SyncCursor
        inboundPushPayload: str
        outboundPushPayload: str
        outboundPullPayload: str
        lastHelloPayload: str
        lastTaskPayload: str

    UnimakerAgentConfig =
        rootDir: str
        eventLogPath: str
        identityStorePath: str
        rootSeedHint: str
        deviceSeedHint: str
        deviceLabelHint: str
        epochSeconds: int64

fn UnimakerOwnText(text: str): str =
    if strLenFast(text) <= 0:
        return ""
    return newStringCopy(strDataPtr(text), strLenFast(text))

fn UnimakerAppendText(buf: var layout.ByteBuf, text: str) =
    lt.AppendU32BE(buf, len(text))
    let textBytes = bytesFromString(text)
    layout.ByteBufAppendBytes(buf, textBytes)

fn UnimakerAppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    layout.ByteBufAppendBytes(buf, layout.FixedBytes32ToBytes(value))

fn UnimakerAppendFixed32Seq(buf: var layout.ByteBuf, values: layout.FixedBytes32[]) =
    lt.AppendU32BE(buf, values.len)
    for i in 0..<values.len:
        UnimakerAppendFixed32(buf, values[i])

fn UnimakerAppendStrSeq(buf: var layout.ByteBuf, values: str[]) =
    lt.AppendU32BE(buf, values.len)
    for i in 0..<values.len:
        UnimakerAppendText(buf, values[i])

fn UnimakerHashText(tag: str, pieces: str[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    UnimakerAppendText(buf, tag)
    UnimakerAppendStrSeq(buf, pieces)
    return hash256.sha256Fixed(layout.ByteBufView(buf))

fn UnimakerHashCapsuleFields(tag: str,
                               capsuleKind: str,
                               taskId: str,
                               contentText: str,
                               keywords: str[],
                               parentCids: layout.FixedBytes32[],
                               relationKind: str,
                               sourceDidText: str,
                               sourcePeerIdText: str,
                               sourceDeviceLabel: str,
                               createdAtEpochSeconds: int64,
                               sequence: int32,
                               geneCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(512)
    UnimakerAppendText(buf, tag)
    UnimakerAppendText(buf, capsuleKind)
    UnimakerAppendText(buf, taskId)
    UnimakerAppendText(buf, contentText)
    UnimakerAppendStrSeq(buf, keywords)
    UnimakerAppendFixed32Seq(buf, parentCids)
    UnimakerAppendText(buf, relationKind)
    UnimakerAppendText(buf, sourceDidText)
    UnimakerAppendText(buf, sourcePeerIdText)
    UnimakerAppendText(buf, sourceDeviceLabel)
    lt.AppendU32BE(buf, sequence)
    lt.AppendU32BE(buf, int32(createdAtEpochSeconds >> 32))
    lt.AppendU32BE(buf, int32(createdAtEpochSeconds & int64(0xffffffff)))
    UnimakerAppendFixed32(buf, geneCid)
    return hash256.sha256Fixed(layout.ByteBufView(buf))

fn UnimakerCloneStrSeq(values: str[]): str[] =
    var out: str[]
    for i in 0..<values.len:
        add(out, UnimakerOwnText(values[i]))
    return out

fn UnimakerCloneFixed32Seq(values: layout.FixedBytes32[]): layout.FixedBytes32[] =
    var out: layout.FixedBytes32[]
    for i in 0..<values.len:
        add(out, values[i])
    return out

fn UnimakerStrLess(left: str,
                     right: str): bool =
    if left == right:
        return false
    let sharedLen = len(left) < len(right) ? len(left) : len(right)
    for i in 0..<sharedLen:
        if left[i] == right[i]:
            continue
        return left[i] < right[i]
    return len(left) < len(right)

fn UnimakerEdgeKindValid(kind: str): bool =
    if kind == UnimakerEdgeKindCausedBy:
        return true
    if kind == UnimakerEdgeKindRefines:
        return true
    if kind == UnimakerEdgeKindContradicts:
        return true
    if kind == UnimakerEdgeKindUsefulFor:
        return true
    if kind == UnimakerEdgeKindFromDevice:
        return true
    return false

fn UnimakerEventKindValid(kind: str): bool =
    if kind == UnimakerEventUserInput:
        return true
    if kind == UnimakerEventToolResult:
        return true
    if kind == UnimakerEventSystemNotice:
        return true
    if kind == UnimakerEventNetworkMessage:
        return true
    if kind == UnimakerEventAppLifecycle:
        return true
    return false

fn UnimakerCapsuleKindValid(kind: str): bool =
    return UnimakerEventKindValid(kind)

fn UnimakerTransportKindValid(kind: str): bool =
    if kind == UnimakerTransportHttpJson:
        return true
    if kind == UnimakerTransportLibp2pReqResp:
        return true
    if kind == UnimakerTransportLibp2pTopic:
        return true
    return false

fn UnimakerGeneMake(capability: str,
                      strategy: str,
                      condition: str): EvoGene =
    var out = EvoGene()
    out.capability = UnimakerOwnText(capability)
    out.strategy = UnimakerOwnText(strategy)
    out.condition = UnimakerOwnText(condition)
    out.geneCid = UnimakerHashText("cheng.unimaker.gene",
                                     [out.capability, out.strategy, out.condition])
    return out

fn UnimakerDefaultGenes(): EvoGene[] =
    var out: EvoGene[]
    add(out, UnimakerGeneMake("event_ingest",
                                "capsule_per_event",
                                "user_input|tool_result|system_notice|network_message|app_lifecycle"))
    add(out, UnimakerGeneMake("memory_query",
                                "task_keyword_parent_exact",
                                "query"))
    add(out, UnimakerGeneMake("task_planning",
                                "memory_first_then_capture",
                                "task"))
    return out

fn UnimakerAgentIdentityMake(identity: did.DidIdentity): AgentIdentity =
    var out = AgentIdentity()
    let didText = did.DidIdentityDid(identity)
    let peerText = peer_id.Libp2pPeerIdText(identity.selfDevice.devicePeerId)
    out.didText = UnimakerOwnText(didText)
    out.peerIdText = UnimakerOwnText(peerText)
    out.deviceLabel = UnimakerOwnText(identity.selfDevice.deviceLabel)
    out.signatureCid = identity.selfDevice.proofDigest
    out.identityCid = UnimakerHashText("cheng.unimaker.identity",
                                         [out.didText,
                                          out.peerIdText,
                                          out.deviceLabel,
                                          layout.FixedBytes32Hex(out.signatureCid)])
    return out

fn UnimakerCursorMake(eventCount: int32,
                        headCid: layout.FixedBytes32): SyncCursor =
    var out = SyncCursor()
    out.eventCount = eventCount
    out.headCid = headCid
    return out

fn UnimakerEventMake(eventKind: str,
                       taskId: str,
                       contentText: str,
                       keywords: str[],
                       parentCids: layout.FixedBytes32[],
                       relationKind: str,
                       createdAtEpochSeconds: int64): EvolutionEvent =
    var out = EvolutionEvent()
    out.eventKind = UnimakerOwnText(eventKind)
    out.taskId = UnimakerOwnText(taskId)
    out.contentText = UnimakerOwnText(contentText)
    out.keywords = UnimakerCloneStrSeq(keywords)
    out.parentCids = UnimakerCloneFixed32Seq(parentCids)
    out.relationKind = UnimakerOwnText(relationKind)
    out.createdAtEpochSeconds = createdAtEpochSeconds
    return out

fn UnimakerCapsuleClone(value: EvoCapsule): EvoCapsule =
    var out = EvoCapsule()
    out.version = value.version
    out.sequence = value.sequence
    out.capsuleKind = UnimakerOwnText(value.capsuleKind)
    out.taskId = UnimakerOwnText(value.taskId)
    out.contentText = UnimakerOwnText(value.contentText)
    out.keywords = UnimakerCloneStrSeq(value.keywords)
    out.parentCids = UnimakerCloneFixed32Seq(value.parentCids)
    out.relationKind = UnimakerOwnText(value.relationKind)
    out.sourceDidText = UnimakerOwnText(value.sourceDidText)
    out.sourcePeerIdText = UnimakerOwnText(value.sourcePeerIdText)
    out.sourceDeviceLabel = UnimakerOwnText(value.sourceDeviceLabel)
    out.createdAtEpochSeconds = value.createdAtEpochSeconds
    out.contentCid = value.contentCid
    out.capsuleCid = value.capsuleCid
    out.signatureCid = value.signatureCid
    out.geneCid = value.geneCid
    return out

fn UnimakerCapsuleContentCid(capsuleKind: str,
                               taskId: str,
                               contentText: str,
                               keywords: str[],
                               parentCids: layout.FixedBytes32[],
                               relationKind: str,
                               createdAtEpochSeconds: int64): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(512)
    UnimakerAppendText(buf, "cheng.unimaker.capsule.content")
    UnimakerAppendText(buf, capsuleKind)
    UnimakerAppendText(buf, taskId)
    UnimakerAppendText(buf, contentText)
    UnimakerAppendStrSeq(buf, keywords)
    UnimakerAppendFixed32Seq(buf, parentCids)
    UnimakerAppendText(buf, relationKind)
    lt.AppendU32BE(buf, int32(createdAtEpochSeconds >> 32))
    lt.AppendU32BE(buf, int32(createdAtEpochSeconds & int64(0xffffffff)))
    return hash256.sha256Fixed(layout.ByteBufView(buf))

fn UnimakerCapsuleSignatureCid(identity: AgentIdentity,
                                 contentCid: layout.FixedBytes32,
                                 parentCids: layout.FixedBytes32[],
                                 createdAtEpochSeconds: int64): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(320)
    UnimakerAppendText(buf, "cheng.unimaker.capsule.signature")
    UnimakerAppendText(buf, identity.didText)
    UnimakerAppendText(buf, identity.peerIdText)
    UnimakerAppendText(buf, identity.deviceLabel)
    UnimakerAppendFixed32(buf, contentCid)
    UnimakerAppendFixed32Seq(buf, parentCids)
    lt.AppendU32BE(buf, int32(createdAtEpochSeconds >> 32))
    lt.AppendU32BE(buf, int32(createdAtEpochSeconds & int64(0xffffffff)))
    return hash256.sha256Fixed(layout.ByteBufView(buf))

fn UnimakerCapsuleCid(value: EvoCapsule): layout.FixedBytes32 =
    return UnimakerHashCapsuleFields("cheng.unimaker.capsule",
                                       value.capsuleKind,
                                       value.taskId,
                                       value.contentText,
                                       value.keywords,
                                       value.parentCids,
                                       value.relationKind,
                                       value.sourceDidText,
                                       value.sourcePeerIdText,
                                       value.sourceDeviceLabel,
                                       value.createdAtEpochSeconds,
                                       value.sequence,
                                       value.geneCid)

fn UnimakerCapsuleMake(sequence: int32,
                         identity: AgentIdentity,
                         event: EvolutionEvent,
                         gene: EvoGene): EvoCapsule =
    var out = EvoCapsule()
    out.version = UnimakerCapsuleVersion
    out.sequence = sequence
    out.capsuleKind = UnimakerOwnText(event.eventKind)
    out.taskId = UnimakerOwnText(event.taskId)
    out.contentText = UnimakerOwnText(event.contentText)
    out.keywords = UnimakerCloneStrSeq(event.keywords)
    out.parentCids = UnimakerCloneFixed32Seq(event.parentCids)
    out.relationKind = len(event.relationKind) > 0 ? UnimakerOwnText(event.relationKind) : UnimakerEdgeKindCausedBy
    out.sourceDidText = UnimakerOwnText(identity.didText)
    out.sourcePeerIdText = UnimakerOwnText(identity.peerIdText)
    out.sourceDeviceLabel = UnimakerOwnText(identity.deviceLabel)
    out.createdAtEpochSeconds = event.createdAtEpochSeconds
    out.geneCid = gene.geneCid
    out.contentCid = UnimakerCapsuleContentCid(out.capsuleKind,
                                                 out.taskId,
                                                 out.contentText,
                                                 out.keywords,
                                                 out.parentCids,
                                                 out.relationKind,
                                                 out.createdAtEpochSeconds)
    out.signatureCid = UnimakerCapsuleSignatureCid(identity,
                                                     out.contentCid,
                                                     out.parentCids,
                                                     out.createdAtEpochSeconds)
    out.capsuleCid = UnimakerCapsuleCid(out)
    return out

fn UnimakerMemoryNodeFromCapsule(capsule: EvoCapsule): MemoryNode =
    var out = MemoryNode()
    out.nodeCid = capsule.capsuleCid
    out.capsuleCid = capsule.capsuleCid
    out.taskId = UnimakerOwnText(capsule.taskId)
    out.capsuleKind = UnimakerOwnText(capsule.capsuleKind)
    out.summaryText = UnimakerOwnText(capsule.contentText)
    out.createdAtEpochSeconds = capsule.createdAtEpochSeconds
    return out

fn UnimakerMemoryEdgeMake(edgeKind: str,
                            fromCid: layout.FixedBytes32,
                            toCid: layout.FixedBytes32): MemoryEdge =
    var out = MemoryEdge()
    out.edgeKind = UnimakerOwnText(edgeKind)
    out.fromCid = fromCid
    out.toCid = toCid
    return out

fn UnimakerFixed32SeqContains(values: layout.FixedBytes32[],
                                needle: layout.FixedBytes32): bool =
    for i in 0..<values.len:
        if layout.FixedBytes32Equal(values[i], needle):
            return true
    return false

fn UnimakerStrSeqContains(values: str[],
                            needle: str): bool =
    let normalizedNeedle = strutil.ToLowerAscii(strutil.Strip(needle))
    if len(normalizedNeedle) <= 0:
        return false
    for i in 0..<values.len:
        let normalizedValue = strutil.ToLowerAscii(strutil.Strip(values[i]))
        if normalizedValue == normalizedNeedle:
            return true
    return false

fn UnimakerCapsuleKeywordMatch(capsule: EvoCapsule,
                                 keyword: str): bool =
    if UnimakerStrSeqContains(capsule.keywords, keyword):
        return true
    let normalizedKeyword = strutil.ToLowerAscii(strutil.Strip(keyword))
    if len(normalizedKeyword) <= 0:
        return false
    let normalizedText = strutil.ToLowerAscii(capsule.contentText)
    return strutil.Contains(normalizedText, normalizedKeyword)

fn UnimakerGraphHeadCid(capsules: EvoCapsule[]): layout.FixedBytes32 =
    var ordered: str[]
    for i in 0..<capsules.len:
        add(ordered, layout.FixedBytes32Hex(capsules[i].capsuleCid))
    if ordered.len > 1:
        for i in 1..<ordered.len:
            let value = ordered[i]
            var j = i
            while j > 0:
                if !UnimakerStrLess(value, ordered[j - 1]):
                    break
                ordered[j] = ordered[j - 1]
                j = j - 1
            ordered[j] = value
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    UnimakerAppendText(buf, "cheng.unimaker.graph.head")
    lt.AppendU32BE(buf, ordered.len)
    for i in 0..<ordered.len:
        UnimakerAppendText(buf, ordered[i])
    return hash256.sha256Fixed(layout.ByteBufView(buf))
