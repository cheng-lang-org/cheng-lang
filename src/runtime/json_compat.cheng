import cheng/runtime/json_ast
type
    JsonNode = json_ast.JsonNode
type
    JsonNodeKind = json_ast.JsonNodeKind
type
    JsonValue = json_ast.JsonValue
type
    CompatJsonPair =
        key: str
        value: JsonNode
const
    jkNull: JsonNodeKind = json_ast.jkNull
    jkBool: JsonNodeKind = json_ast.jkBool
    jkInt: JsonNodeKind = json_ast.jkInt
    jkFloat: JsonNodeKind = json_ast.jkFloat
    jkString: JsonNodeKind = json_ast.jkString
    jkArray: JsonNodeKind = json_ast.jkArray
    jkObject: JsonNodeKind = json_ast.jkObject
fn makeCompatPair(key: str, value: JsonNode): CompatJsonPair =
    var pair: CompatJsonPair
    pair.key = key
    pair.value = value pair
fn jsonField(key: str, value: JsonNode): CompatJsonPair =
    makeCompatPair(key, value)
fn jsonField(key: str, value: str): CompatJsonPair =
    makeCompatPair(key, jsonString(value))
fn jsonField(key: str, value: int): CompatJsonPair =
    makeCompatPair(key, `%`(value))
fn jsonField(key: str, value: float64): CompatJsonPair =
    makeCompatPair(key, `%`(value))
fn jsonField(key: str, value: bool): CompatJsonPair =
    makeCompatPair(key, `%`(value))
fn jsonObject(pairs: openArray[CompatJsonPair]): JsonNode =
    let node = newJObject()
    for pair in pairs:
        node[pair.key] = pair.value node
fn jsonObjectLit(fields: varargs[CompatJsonPair]): JsonNode =
    var pairs = newSeq[CompatJsonPair]()
    for field in fields:
        pairs.add(field)
        jsonObject(pairs)
fn jsonArrayLit(items: seq[JsonNode]): JsonNode =
    jsonArray(items)
fn jsonArrayLit(items: varargs[JsonNode]): JsonNode =
    var collected = newSeq[JsonNode]()
    for item in items:
        collected.add(item)
        jsonArray(collected)
fn jsonValue(value: JsonNode): JsonNode =
    value
fn jsonValue(value: str): JsonNode =
    `%`(value)
fn jsonValue(value: int): JsonNode =
    `%`(value)
fn jsonValue(value: float64): JsonNode =
    `%`(value)
fn jsonValue(value: bool): JsonNode =
    `%`(value)
fn jsonField[T](key: str, value: seq[T]): CompatJsonPair =
    let arr = newJArray()
    for item in value:
        arr.add(jsonValue(item))
        makeCompatPair(key, arr)
fn newJArray(): JsonNode =
    json_ast.newJArray()
fn newJObject(): JsonNode =
    json_ast.newJObject()
fn jsonSet(node: JsonNode, key: str, value: JsonNode) =
    if node == nil:
        return
        if node.kind != JObject:
            return
            node[key] = value
