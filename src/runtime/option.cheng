# Minimal `Option[T]` for pure Cheng toolchain (compatible with IDE code).
type
    Option[T] =
        has: bool
        value: T

fn Some[T](value: T): Option[T] =
    Option[T](has: true, value: value)

fn None[T](): Option[T] =
    var out: Option[T]
    out.has = false
    return out

fn some[T](value: T): Option[T] =
    return Some[T](value)

fn none[T](_: typedesc[T]): Option[T] =
    var out: Option[T]
    out.has = false
    return out

fn IsSome[T](opt: Option[T]): bool =
    opt.has

fn isSome[T](opt: Option[T]): bool =
    return IsSome[T](opt)

fn Get[T](opt: Option[T]): T =
    opt.value

fn get[T](opt: Option[T]): T =
    return Get[T](opt)
