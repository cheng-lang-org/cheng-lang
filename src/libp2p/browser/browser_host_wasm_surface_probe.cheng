import std/rawbytes
import std/result

@importc("cheng_browser_now_ms_bridge")
fn cheng_browser_now_ms_bridge(): int32
@importc("cheng_browser_echo_i32_bridge")
fn cheng_browser_echo_i32_bridge(value: int32): int32
@importc("cheng_browser_peer_handle_bridge")
fn cheng_browser_peer_handle_bridge(): int32
@importc("cheng_browser_did_handle_bridge")
fn cheng_browser_did_handle_bridge(): int32
@importc("cheng_browser_dm_active_count_bridge")
fn cheng_browser_dm_active_count_bridge(): int32
@importc("cheng_browser_dm_connect_start_bridge")
fn cheng_browser_dm_connect_start_bridge(peerHandle: int32): int32
@importc("cheng_browser_dm_wait_start_bridge")
fn cheng_browser_dm_wait_start_bridge(peerHandle: int32, timeoutMs: int32): int32
@importc("cheng_browser_dm_send_start_bridge")
fn cheng_browser_dm_send_start_bridge(peerHandle: int32,
                                         conversationHandle: int32,
                                         messageHandle: int32,
                                         timestampMs: int32): int32
@importc("cheng_browser_distributed_video_build_bridge")
fn cheng_browser_distributed_video_build_bridge(blobHandle: int32,
                                                   ownerPeerHandle: int32,
                                                   remotePeersHandle: int32,
                                                   dataShardCount: int32,
                                                   parityShardCount: int32,
                                                   shardPayloadBytes: int32): int32
@importc("cheng_browser_distributed_video_rebuild_bridge")
fn cheng_browser_distributed_video_rebuild_bridge(manifestPayloadHandle: int32,
                                                     shardSpecsHandle: int32,
                                                     dataShardCount: int32,
                                                     parityShardCount: int32,
                                                     shardPayloadBytes: int32): int32
@importc("cheng_browser_distributed_video_last_error_handle_bridge")
fn cheng_browser_distributed_video_last_error_handle_bridge(): int32
@importc("cheng_browser_input_len_bridge")
fn cheng_browser_input_len_bridge(handle: int32): int32
@importc("cheng_browser_input_copy_bridge")
fn cheng_browser_input_copy_bridge(handle: int32, data: ptr, n: int32): int32
@importc("cheng_buffer_handle_from_raw_bridge")
fn cheng_buffer_handle_from_raw_bridge(data: ptr, n: int32): int32
@importc("cheng_buffer_handle_from_text_bridge")
fn cheng_buffer_handle_from_text_bridge(text: str): int32
@importc("cheng_browser_buffer_handle_len_bridge")
fn cheng_browser_buffer_handle_len_bridge(handle: int32): int32
@importc("cheng_browser_buffer_handle_byte_bridge")
fn cheng_browser_buffer_handle_byte_bridge(handle: int32, idx: int32): int32
@importc("cheng_browser_buffer_handle_release_bridge")
fn cheng_browser_buffer_handle_release_bridge(handle: int32): int32
@importc("cheng_browser_moq_fountain_last_error_store_bridge")
fn cheng_browser_moq_fountain_last_error_store_bridge(text: str): int32
@importc("cheng_browser_moq_fountain_last_error_handle_bridge")
fn cheng_browser_moq_fountain_last_error_handle_bridge(): int32

fn browserSurfaceReadInputBytes(handle: int32): Result[Bytes] =
    if handle <= 0:
        return Err[Bytes]("browser_surface_missing_input_handle")
    let inputLen = cheng_browser_input_len_bridge(handle)
    if inputLen <= 0:
        return Err[Bytes]("browser_surface_missing_input_payload")
    var payload = bytesAlloc(inputLen)
    if cheng_browser_input_copy_bridge(handle, payload.data, inputLen) <= 0:
        return Err[Bytes]("browser_surface_copy_input_failed")
    return Ok[Bytes](payload)

fn browserSurfaceReadInputText(handle: int32): Result[str] =
    let payloadRes = browserSurfaceReadInputBytes(handle)
    if IsErr(payloadRes):
        return Err[str](Error(payloadRes))
    return Ok[str](bytesToString(Value(payloadRes)))

fn browserSurfaceStoreLastError(text: str): int32 =
    let _ = cheng_browser_moq_fountain_last_error_store_bridge(text)
    return 0

fn browserSurfaceTouchImports() =
    let _ = cheng_browser_did_handle_bridge()
    let _ = cheng_browser_dm_active_count_bridge()
    let _ = cheng_browser_dm_connect_start_bridge(1)
    let _ = cheng_browser_dm_wait_start_bridge(2, 3)
    let _ = cheng_browser_dm_send_start_bridge(4, 5, 6, 7)
    let _ = cheng_browser_distributed_video_last_error_handle_bridge()
    let raw = bytesFromString("x")
    let rawHandle = cheng_buffer_handle_from_raw_bridge(raw.data, bytesLen(raw))
    let textHandle = cheng_buffer_handle_from_text_bridge("x")
    let _ = cheng_browser_buffer_handle_len_bridge(rawHandle)
    let _ = cheng_browser_buffer_handle_byte_bridge(textHandle, 0)
    let _ = cheng_browser_buffer_handle_release_bridge(rawHandle)
    let _ = cheng_browser_moq_fountain_last_error_store_bridge("")
    let _ = cheng_browser_moq_fountain_last_error_handle_bridge()

fn browserNowMs(): int32 =
    return cheng_browser_now_ms_bridge()

fn browserEchoI32(value: int32): int32 =
    return cheng_browser_echo_i32_bridge(value)

fn browserPeerHandle(): int32 =
    return cheng_browser_peer_handle_bridge()

fn browserDistributedVideoBuild(blobHandle: int32,
                                ownerPeerHandle: int32,
                                remotePeersHandle: int32,
                                dataShardCount: int32,
                                parityShardCount: int32,
                                shardPayloadBytes: int32): int32 =
    return cheng_browser_distributed_video_build_bridge(blobHandle,
                                                           ownerPeerHandle,
                                                           remotePeersHandle,
                                                           dataShardCount,
                                                           parityShardCount,
                                                           shardPayloadBytes)

fn browserDistributedVideoRebuild(manifestPayloadHandle: int32,
                                  shardSpecsHandle: int32,
                                  dataShardCount: int32,
                                  parityShardCount: int32,
                                  shardPayloadBytes: int32): int32 =
    return cheng_browser_distributed_video_rebuild_bridge(manifestPayloadHandle,
                                                             shardSpecsHandle,
                                                             dataShardCount,
                                                             parityShardCount,
                                                             shardPayloadBytes)

fn browserMoqFountainBuild(blobHandle: int32,
                           ownerPeerHandle: int32,
                           remotePeersHandle: int32,
                           mimeTypeHandle: int32,
                           objectTargetBytes: int32,
                           sourceBlockBytes: int32,
                           repairDropletCount: int32): int32 =
    let blobRes = browserSurfaceReadInputBytes(blobHandle)
    if IsErr(blobRes):
        return browserSurfaceStoreLastError(Error(blobRes))
    let ownerRes = browserSurfaceReadInputText(ownerPeerHandle)
    if IsErr(ownerRes):
        return browserSurfaceStoreLastError(Error(ownerRes))
    let peersRes = browserSurfaceReadInputText(remotePeersHandle)
    if IsErr(peersRes):
        return browserSurfaceStoreLastError(Error(peersRes))
    if mimeTypeHandle > 0:
        let mimeRes = browserSurfaceReadInputText(mimeTypeHandle)
        if IsErr(mimeRes):
            return browserSurfaceStoreLastError(Error(mimeRes))
    let _ = objectTargetBytes
    let _ = sourceBlockBytes
    let _ = repairDropletCount
    return cheng_buffer_handle_from_text_bridge("browser_host_wasm_surface_probe_build")

fn browserMoqFountainBuildBytes(blobHandle: int32,
                                ownerPeerHandle: int32,
                                remotePeersHandle: int32,
                                mimeTypeHandle: int32,
                                objectTargetBytes: int32,
                                sourceBlockBytes: int32,
                                repairDropletCount: int32): int32 =
    let textHandle = browserMoqFountainBuild(blobHandle,
                                             ownerPeerHandle,
                                             remotePeersHandle,
                                             mimeTypeHandle,
                                             objectTargetBytes,
                                             sourceBlockBytes,
                                             repairDropletCount)
    if textHandle <= 0:
        return 0
    let payload = bytesFromString("browser_host_wasm_surface_probe_build_bytes")
    return cheng_buffer_handle_from_raw_bridge(payload.data, bytesLen(payload))

fn browserMoqFountainRebuild(requestWireHandle: int32): int32 =
    let requestRes = browserSurfaceReadInputText(requestWireHandle)
    if IsErr(requestRes):
        return browserSurfaceStoreLastError(Error(requestRes))
    return cheng_buffer_handle_from_text_bridge(Value(requestRes))

fn browserMoqBuildLongBlobComputedBundleCidLenProbe(): int32 =
    return 64

fn browserMoqPeerCsvCountProbe(): int32 =
    return 2

fn main(): int32 =
    browserSurfaceTouchImports()
    return 0
