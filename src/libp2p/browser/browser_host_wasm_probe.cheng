fn browserStrformatFmtLenProbe(): int32 =
    var parts: str[]
    parts = []
    add(parts, "left")
    add(parts, "right")
    let text = strutil.Join(parts, "")
    return text.len

fn browserStrformatLinesLenProbe(): int32 =
    var parts: str[]
    parts = []
    add(parts, "left")
    add(parts, "right")
    let text = Lines(parts)
    return text.len

