fn browserProbeTextHandle(text: str): int32 =
    let handleRes = codecabi.browserBufferHandleFromTextRequired(text,
                                                                 "browser_probe_text_handle_failed")
    if IsErr(handleRes):
        return 0
    return Value(handleRes)

fn main(): int32 =
    return 0
