import std/rawbytes
import std/strings
import cheng/core/lang/browser_abi_rule as barule
import cheng/libp2p/browser/browser_content_codec_rule_schema as browsercodec
import std/strutils as strutil

@importc("cheng_browser_input_len_bridge")
fn cheng_browser_input_len_bridge(handle: int32): int32
@importc("cheng_browser_input_copy_bridge")
fn cheng_browser_input_copy_bridge(handle: int32, data: ptr, n: int32): int32
@importc("cheng_browser_buffer_handle_from_raw_bridge")
fn cheng_browser_buffer_handle_from_raw_bridge(data: ptr, n: int32): int32
@importc("cheng_browser_buffer_handle_from_text_bridge")
fn cheng_browser_buffer_handle_from_text_bridge(text: str): int32
importc fn cheng_browser_buffer_handle_len_bridge(handle: int32): int32
importc fn cheng_browser_buffer_handle_byte_bridge(handle: int32, idx: int32): int32
importc fn cheng_browser_buffer_handle_release_bridge(handle: int32): int32
importc fn cheng_browser_moq_fountain_last_error_store_bridge(text: str): int32
importc fn cheng_browser_moq_fountain_last_error_handle_bridge(): int32
importc fn cheng_browser_distributed_video_build_bridge(blobHandle: int32,
                                                           ownerPeerHandle: int32,
                                                           remotePeersHandle: int32,
                                                           dataShardCount: int32,
                                                           parityShardCount: int32,
                                                           shardPayloadBytes: int32): int32
importc fn cheng_browser_distributed_video_rebuild_bridge(manifestPayloadHandle: int32,
                                                             shardSpecsHandle: int32,
                                                             dataShardCount: int32,
                                                             parityShardCount: int32,
                                                             shardPayloadBytes: int32): int32
importc fn cheng_browser_distributed_video_last_error_handle_bridge(): int32

type BrowserCodecInputSchema = object
    kind: int32
    missingError: str
    copyError: str

type BrowserCodecOutputSchema = object
    kind: int32
    handleError: str

type BrowserCodecExportSchema = object
    output: BrowserCodecOutputSchema
    error: int32

type BrowserAbiBridgeSpec = barule.BrowserAbiBridgeSpec
type BrowserAbiBridgePlan = barule.BrowserAbiBridgePlan

const BrowserCodecInputBytesRequired = 1
const BrowserCodecInputTextRequired = 2
const BrowserCodecInputTextOptional = 3
const BrowserCodecOutputBytesHandle = 1
const BrowserCodecOutputTextHandle = 2
const BrowserCodecErrorInlineResultError = 1
const BrowserCodecErrorMoqFountainLastError = 2

fn BrowserCodecInputBytesRequiredKind(): int32 =
    return BrowserCodecInputBytesRequired

fn BrowserCodecInputTextRequiredKind(): int32 =
    return BrowserCodecInputTextRequired

fn BrowserCodecInputTextOptionalKind(): int32 =
    return BrowserCodecInputTextOptional

fn BrowserCodecOutputBytesHandleKind(): int32 =
    return BrowserCodecOutputBytesHandle

fn BrowserCodecOutputTextHandleKind(): int32 =
    return BrowserCodecOutputTextHandle

fn BrowserCodecErrorInlineResultErrorKind(): int32 =
    return BrowserCodecErrorInlineResultError

fn BrowserCodecErrorMoqFountainLastErrorKind(): int32 =
    return BrowserCodecErrorMoqFountainLastError

fn BrowserCodecInputSchemaMake(kind: int32,
                                 missingError: str,
                                 copyError: str): BrowserCodecInputSchema =
    var out: BrowserCodecInputSchema
    out.kind = kind
    out.missingError = missingError
    out.copyError = copyError
    return out

fn BrowserCodecOutputSchemaMake(kind: int32,
                                  handleError: str): BrowserCodecOutputSchema =
    var out: BrowserCodecOutputSchema
    out.kind = kind
    out.handleError = handleError
    return out

fn BrowserCodecExportSchemaMake(output: BrowserCodecOutputSchema,
                                  error: int32): BrowserCodecExportSchema =
    var out: BrowserCodecExportSchema
    out.output = output
    out.error = error
    return out

fn BrowserCodecBridgeSpecForSourceRuleName(sourcePath: str,
                                             ruleName: str): BrowserAbiBridgeSpec =
    let rule = browsercodec.BrowserContentCodecRuleByName(sourcePath,
                                                            ruleName)
    return barule.BrowserAbiBridgeSpecForRule(rule)

fn BrowserCodecBridgeSpecForRuleName(ruleName: str): BrowserAbiBridgeSpec =
    return BrowserCodecBridgeSpecForSourceRuleName(browsercodec.BrowserContentCodecModulePath(),
                                                     ruleName)

fn BrowserCodecBridgePlanForSourceRuleName(sourcePath: str,
                                             ruleName: str): BrowserAbiBridgePlan =
    let rule = browsercodec.BrowserContentCodecRuleByName(sourcePath,
                                                            ruleName)
    return barule.BrowserAbiBridgePlanForRule(rule)

fn BrowserCodecBridgePlanForRuleName(ruleName: str): BrowserAbiBridgePlan =
    return BrowserCodecBridgePlanForSourceRuleName(browsercodec.BrowserContentCodecModulePath(),
                                                     ruleName)

fn BrowserCodecBridgeKeyForSourceRuleName(sourcePath: str,
                                            ruleName: str): str =
    let spec = BrowserCodecBridgeSpecForSourceRuleName(sourcePath, ruleName)
    return spec.bridgeKey

fn BrowserCodecBridgeKeyForRuleName(ruleName: str): str =
    let spec = BrowserCodecBridgeSpecForRuleName(ruleName)
    return spec.bridgeKey

fn BrowserCodecBridgeHelperNameForSourceRuleName(sourcePath: str,
                                                   ruleName: str): str =
    let spec = BrowserCodecBridgeSpecForSourceRuleName(sourcePath, ruleName)
    return barule.BrowserAbiBridgeHelperName(spec)

fn BrowserCodecBridgeHelperNameForRuleName(ruleName: str): str =
    let spec = BrowserCodecBridgeSpecForRuleName(ruleName)
    return barule.BrowserAbiBridgeHelperName(spec)

fn BrowserCodecBridgeEmitLineForSourceRuleName(sourcePath: str,
                                                 ruleName: str): str =
    let spec = BrowserCodecBridgeSpecForSourceRuleName(sourcePath, ruleName)
    return barule.BrowserAbiBridgeEmitLine(spec)

fn BrowserCodecBridgeEmitLineForRuleName(ruleName: str): str =
    let spec = BrowserCodecBridgeSpecForRuleName(ruleName)
    return barule.BrowserAbiBridgeEmitLine(spec)

fn BrowserCodecBridgeManifest(sourcePath: str): str =
    let rules = browsercodec.BrowserContentCodecRules(sourcePath)
    return barule.BrowserAbiBridgePlanManifestTextFromRules(rules)

fn BrowserCodecBridgeRuleCount(): int32 =
    return 8

fn BrowserCodecAppendBridgeReportLine(out: var str,
                                        index: int32,
                                        sourcePath: str,
                                        ruleName: str) =
    out = strutil.Join([out, "browser_bridge_plan["], "")
    out = strutil.Join([out, intToStr(index)], "")
    out = strutil.Join([out, "]="], "")
    out = strutil.Join([out, BrowserCodecBridgeEmitLineForSourceRuleName(sourcePath, ruleName)], "")
    out = strutil.Join([out, "\n"], "")

fn BrowserCodecAppendBridgeReportLines(out: var str,
                                         sourcePath: str,
                                         startIndex: int32): int32 =
    var nextIndex = startIndex
    BrowserCodecAppendBridgeReportLine(out,
                                         nextIndex,
                                         sourcePath,
                                         browsercodec.BrowserContentCodecRuleInputBytesRequiredName())
    nextIndex = nextIndex + 1
    BrowserCodecAppendBridgeReportLine(out,
                                         nextIndex,
                                         sourcePath,
                                         browsercodec.BrowserContentCodecRuleInputTextRequiredName())
    nextIndex = nextIndex + 1
    BrowserCodecAppendBridgeReportLine(out,
                                         nextIndex,
                                         sourcePath,
                                         browsercodec.BrowserContentCodecRuleInputTextOptionalName())
    nextIndex = nextIndex + 1
    BrowserCodecAppendBridgeReportLine(out,
                                         nextIndex,
                                         sourcePath,
                                         browsercodec.BrowserContentCodecRuleOutputBytesHandleName())
    nextIndex = nextIndex + 1
    BrowserCodecAppendBridgeReportLine(out,
                                         nextIndex,
                                         sourcePath,
                                         browsercodec.BrowserContentCodecRuleOutputTextHandleName())
    nextIndex = nextIndex + 1
    BrowserCodecAppendBridgeReportLine(out,
                                         nextIndex,
                                         sourcePath,
                                         browsercodec.BrowserContentCodecRuleExportMoqFountainBytesResultName())
    nextIndex = nextIndex + 1
    BrowserCodecAppendBridgeReportLine(out,
                                         nextIndex,
                                         sourcePath,
                                         browsercodec.BrowserContentCodecRuleExportMoqFountainTextResultName())
    nextIndex = nextIndex + 1
    BrowserCodecAppendBridgeReportLine(out,
                                         nextIndex,
                                         sourcePath,
                                         browsercodec.BrowserContentCodecRuleMoqFountainLastErrorHandleName())
    return nextIndex + 1

fn BrowserCodecInputSchemaKindFromBridgePlan(plan: BrowserAbiBridgePlan): int32 =
    if plan.ruleName == browsercodec.BrowserContentCodecRuleInputBytesRequiredName():
        return BrowserCodecInputBytesRequired
    if plan.ruleName == browsercodec.BrowserContentCodecRuleInputTextRequiredName():
        return BrowserCodecInputTextRequired
    if plan.ruleName == browsercodec.BrowserContentCodecRuleInputTextOptionalName():
        return BrowserCodecInputTextOptional
    return 0

fn BrowserCodecOutputSchemaKindFromBridgePlan(plan: BrowserAbiBridgePlan): int32 =
    if plan.ruleName == browsercodec.BrowserContentCodecRuleOutputBytesHandleName():
        return BrowserCodecOutputBytesHandle
    if plan.ruleName == browsercodec.BrowserContentCodecRuleExportMoqFountainBytesResultName():
        return BrowserCodecOutputBytesHandle
    if plan.ruleName == browsercodec.BrowserContentCodecRuleOutputTextHandleName():
        return BrowserCodecOutputTextHandle
    if plan.ruleName == browsercodec.BrowserContentCodecRuleExportMoqFountainTextResultName():
        return BrowserCodecOutputTextHandle
    if plan.ruleName == browsercodec.BrowserContentCodecRuleMoqFountainLastErrorHandleName():
        return BrowserCodecOutputTextHandle
    return 0

fn BrowserCodecErrorSchemaKindFromBridgePlan(plan: BrowserAbiBridgePlan): int32 =
    if plan.ruleName == browsercodec.BrowserContentCodecRuleExportMoqFountainBytesResultName():
        return BrowserCodecErrorMoqFountainLastError
    if plan.ruleName == browsercodec.BrowserContentCodecRuleExportMoqFountainTextResultName():
        return BrowserCodecErrorMoqFountainLastError
    if plan.ruleName == browsercodec.BrowserContentCodecRuleMoqFountainLastErrorHandleName():
        return BrowserCodecErrorMoqFountainLastError
    if plan.ruleName == browsercodec.BrowserContentCodecRuleInputBytesRequiredName():
        return BrowserCodecErrorInlineResultError
    if plan.ruleName == browsercodec.BrowserContentCodecRuleInputTextRequiredName():
        return BrowserCodecErrorInlineResultError
    if plan.ruleName == browsercodec.BrowserContentCodecRuleInputTextOptionalName():
        return BrowserCodecErrorInlineResultError
    if plan.ruleName == browsercodec.BrowserContentCodecRuleOutputBytesHandleName():
        return BrowserCodecErrorInlineResultError
    if plan.ruleName == browsercodec.BrowserContentCodecRuleOutputTextHandleName():
        return BrowserCodecErrorInlineResultError
    return 0

fn BrowserCodecInputSchemaForRuleName(ruleName: str,
                                        missingError: str,
                                        copyError: str): BrowserCodecInputSchema =
    var kind: int32
    if ruleName == "input_bytes_required":
        kind = BrowserCodecInputBytesRequired
    elif ruleName == "input_text_required":
        kind = BrowserCodecInputTextRequired
    elif ruleName == "input_text_optional":
        kind = BrowserCodecInputTextOptional
    return BrowserCodecInputSchemaMake(kind,
                                         missingError,
                                         copyError)

fn BrowserCodecOutputSchemaForRuleName(ruleName: str,
                                         handleError: str): BrowserCodecOutputSchema =
    var kind: int32
    if ruleName == "output_bytes_handle" ||
       ruleName == "export_moq_fountain_bytes_result":
        kind = BrowserCodecOutputBytesHandle
    elif ruleName == "output_text_handle" ||
         ruleName == "export_moq_fountain_text_result" ||
         ruleName == "moq_fountain_last_error_handle":
        kind = BrowserCodecOutputTextHandle
    return BrowserCodecOutputSchemaMake(kind,
                                          handleError)

fn BrowserCodecErrorSchemaForRuleName(ruleName: str): int32 =
    var kind: int32
    if ruleName == "export_moq_fountain_bytes_result" ||
       ruleName == "export_moq_fountain_text_result" ||
       ruleName == "moq_fountain_last_error_handle":
        kind = BrowserCodecErrorMoqFountainLastError
    elif ruleName == "input_bytes_required" ||
         ruleName == "input_text_required" ||
         ruleName == "input_text_optional" ||
         ruleName == "output_bytes_handle" ||
         ruleName == "output_text_handle":
        kind = BrowserCodecErrorInlineResultError
    return kind

fn BrowserCodecExportSchemaForRuleName(ruleName: str,
                                         handleError: str): BrowserCodecExportSchema =
    let output = BrowserCodecOutputSchemaForRuleName(ruleName, handleError)
    let err = BrowserCodecErrorSchemaForRuleName(ruleName)
    return BrowserCodecExportSchemaMake(output, err)

fn BrowserCodecPublishError(text: str,
                              schema: int32) =
    if schema == BrowserCodecErrorMoqFountainLastErrorKind():
        cheng_browser_moq_fountain_last_error_store_bridge(text)

fn BrowserCodecClearError(schema: int32) =
    BrowserCodecPublishError("", schema)

fn BrowserCodecReadInputBytes(handle: int32,
                                schema: BrowserCodecInputSchema): Result[Bytes] =
    let inputLen = cheng_browser_input_len_bridge(handle)
    if handle <= 0 || inputLen <= 0:
        if schema.kind == BrowserCodecInputTextOptionalKind():
            return Ok[Bytes](bytesAlloc(0))
        return Err[Bytes](schema.missingError)
    var inputBytes = bytesAlloc(inputLen)
    if cheng_browser_input_copy_bridge(handle, inputBytes.data, inputLen) <= 0:
        return Err[Bytes](schema.copyError)
    return Ok[Bytes](inputBytes)

fn BrowserCodecReadInputText(handle: int32,
                               schema: BrowserCodecInputSchema): Result[str] =
    let bytesRes = BrowserCodecReadInputBytes(handle, schema)
    if IsErr(bytesRes):
        return Err[str](Error(bytesRes))
    return Ok[str](bytesToString(Value(bytesRes)))

fn BrowserCodecWriteOutputBytesHandle(payload: Bytes,
                                        schema: BrowserCodecOutputSchema): Result[int32] =
    if schema.kind != BrowserCodecOutputBytesHandleKind():
        return Err[int32](schema.handleError)
    let handle = cheng_browser_buffer_handle_from_raw_bridge(payload.data, bytesLen(payload))
    if handle <= 0:
        return Err[int32](schema.handleError)
    return Ok[int32](handle)

fn BrowserCodecWriteOutputTextHandle(text: str,
                                       schema: BrowserCodecOutputSchema): Result[int32] =
    if schema.kind != BrowserCodecOutputTextHandleKind() || len(text) <= 0:
        return Err[int32](schema.handleError)
    let handle = cheng_browser_buffer_handle_from_text_bridge(text)
    if handle <= 0:
        return Err[int32](schema.handleError)
    return Ok[int32](handle)

fn BrowserCodecLiftTextHandle(textRes: Result[str],
                                schema: BrowserCodecOutputSchema): Result[int32] =
    if IsErr(textRes):
        return Err[int32](Error(textRes))
    return BrowserCodecWriteOutputTextHandle(Value(textRes), schema)

fn BrowserCodecLiftBytesHandle(bytesRes: Result[Bytes],
                                 schema: BrowserCodecOutputSchema): Result[int32] =
    if IsErr(bytesRes):
        return Err[int32](Error(bytesRes))
    return BrowserCodecWriteOutputBytesHandle(Value(bytesRes), schema)

fn BrowserCodecExportHandleResult(handleRes: Result[int32],
                                    schema: BrowserCodecExportSchema): int32 =
    BrowserCodecClearError(schema.error)
    if IsErr(handleRes):
        BrowserCodecPublishError(Error(handleRes), schema.error)
        return 0
    return Value(handleRes)

fn BrowserCodecExportTextResult(textRes: Result[str],
                                  schema: BrowserCodecExportSchema): int32 =
    let handleRes = BrowserCodecLiftTextHandle(textRes, schema.output)
    return BrowserCodecExportHandleResult(handleRes, schema)

fn BrowserCodecExportBytesResult(bytesRes: Result[Bytes],
                                   schema: BrowserCodecExportSchema): int32 =
    let handleRes = BrowserCodecLiftBytesHandle(bytesRes, schema.output)
    return BrowserCodecExportHandleResult(handleRes, schema)

fn BrowserCodecReadInputBytesRequired(handle: int32,
                                        missingError: str,
                                        copyError: str): Result[Bytes] =
    var schema: BrowserCodecInputSchema
    schema.kind = BrowserCodecInputBytesRequired
    schema.missingError = missingError
    schema.copyError = copyError
    return BrowserCodecReadInputBytes(handle, schema)

fn BrowserCodecReadInputTextRequired(handle: int32,
                                       missingError: str,
                                       copyError: str): Result[str] =
    var schema: BrowserCodecInputSchema
    schema.kind = BrowserCodecInputTextRequired
    schema.missingError = missingError
    schema.copyError = copyError
    return BrowserCodecReadInputText(handle, schema)

fn BrowserCodecReadInputTextOptional(handle: int32,
                                       copyError: str): Result[str] =
    var schema: BrowserCodecInputSchema
    schema.kind = BrowserCodecInputTextOptional
    schema.missingError = ""
    schema.copyError = copyError
    return BrowserCodecReadInputText(handle, schema)

fn BrowserCodecWriteOutputBytesHandleRequired(payload: Bytes,
                                                handleError: str): Result[int32] =
    var schema: BrowserCodecOutputSchema
    schema.kind = BrowserCodecOutputBytesHandle
    schema.handleError = handleError
    return BrowserCodecWriteOutputBytesHandle(payload, schema)

fn BrowserCodecWriteOutputTextHandleRequired(text: str,
                                               handleError: str): Result[int32] =
    var schema: BrowserCodecOutputSchema
    schema.kind = BrowserCodecOutputTextHandle
    schema.handleError = handleError
    return BrowserCodecWriteOutputTextHandle(text, schema)

fn BrowserCodecExportMoqFountainTextResult(textRes: Result[str],
                                             handleError: str): int32 =
    var output: BrowserCodecOutputSchema
    output.kind = BrowserCodecOutputTextHandle
    output.handleError = handleError
    let err: int32 = BrowserCodecErrorMoqFountainLastError
    BrowserCodecClearError(err)
    let handleRes = BrowserCodecLiftTextHandle(textRes, output)
    if IsErr(handleRes):
        BrowserCodecPublishError(Error(handleRes), err)
        return 0
    return Value(handleRes)

fn BrowserCodecExportMoqFountainBytesResult(bytesRes: Result[Bytes],
                                              handleError: str): int32 =
    var output: BrowserCodecOutputSchema
    output.kind = BrowserCodecOutputBytesHandle
    output.handleError = handleError
    let err: int32 = BrowserCodecErrorMoqFountainLastError
    BrowserCodecClearError(err)
    let handleRes = BrowserCodecLiftBytesHandle(bytesRes, output)
    if IsErr(handleRes):
        BrowserCodecPublishError(Error(handleRes), err)
        return 0
    return Value(handleRes)

fn BrowserCodecMoqFountainLastErrorHandle(): int32 =
    return cheng_browser_moq_fountain_last_error_handle_bridge()

fn BrowserBufferHandleLen(handle: int32): int32 =
    return cheng_browser_buffer_handle_len_bridge(handle)

fn BrowserBufferHandleByte(handle: int32, idx: int32): int32 =
    return cheng_browser_buffer_handle_byte_bridge(handle, idx)

fn BrowserBufferHandleRelease(handle: int32): int32 =
    return cheng_browser_buffer_handle_release_bridge(handle)

fn BrowserCodecDistributedVideoBuild(blobHandle: int32,
                                       ownerPeerHandle: int32,
                                       remotePeersHandle: int32,
                                       dataShardCount: int32,
                                       parityShardCount: int32,
                                       shardPayloadBytes: int32): int32 =
    return cheng_browser_distributed_video_build_bridge(blobHandle,
                                                           ownerPeerHandle,
                                                           remotePeersHandle,
                                                           dataShardCount,
                                                           parityShardCount,
                                                           shardPayloadBytes)

fn BrowserCodecDistributedVideoRebuild(manifestPayloadHandle: int32,
                                         shardSpecsHandle: int32,
                                         dataShardCount: int32,
                                         parityShardCount: int32,
                                         shardPayloadBytes: int32): int32 =
    return cheng_browser_distributed_video_rebuild_bridge(manifestPayloadHandle,
                                                             shardSpecsHandle,
                                                             dataShardCount,
                                                             parityShardCount,
                                                             shardPayloadBytes)

fn BrowserCodecDistributedVideoLastErrorHandle(): int32 =
    return cheng_browser_distributed_video_last_error_handle_bridge()
