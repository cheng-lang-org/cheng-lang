import cheng/core/lang/browser_abi_rule as barule
import cheng/libp2p/browser/browser_host_probe_rule_schema as browserprobe
import std/strutils as strutil

importc fn cheng_browser_now_ms_bridge(): int32
importc fn cheng_browser_echo_i32_bridge(value: int32): int32
importc fn cheng_browser_peer_handle_bridge(): int32
importc fn cheng_browser_did_handle_bridge(): int32
importc fn cheng_browser_dm_active_count_bridge(): int32
importc fn cheng_browser_dm_connect_start_bridge(peerHandle: int32): int32
importc fn cheng_browser_dm_wait_start_bridge(peerHandle: int32, timeoutMs: int32): int32
importc fn cheng_browser_dm_send_start_bridge(peerHandle: int32,
                                                 conversationHandle: int32,
                                                 messageHandle: int32,
                                                 timestampMs: int32): int32

type BrowserHostProbeBridgePlan = barule.BrowserAbiBridgePlan

const BrowserHostProbeInputScalarNone = 0
const BrowserHostProbeInputScalarI32_1 = 1
const BrowserHostProbeInputScalarI32_2 = 2
const BrowserHostProbeInputScalarI32_4 = 4
const BrowserHostProbeOutputScalarI32 = 1

fn BrowserHostProbeBridgePlanForSourceRuleName(sourcePath: str,
                                                 ruleName: str): BrowserHostProbeBridgePlan =
    let rule = browserprobe.BrowserHostProbeRuleByName(sourcePath, ruleName)
    return barule.BrowserAbiBridgePlanForRule(rule)

fn BrowserHostProbeBridgePlanForRuleName(ruleName: str): BrowserHostProbeBridgePlan =
    return BrowserHostProbeBridgePlanForSourceRuleName(browserprobe.BrowserHostProbeModulePath(),
                                                         ruleName)

fn BrowserHostProbeInputSchemaKindFromBridgePlan(plan: BrowserHostProbeBridgePlan): int32 =
    if plan.ruleName == browserprobe.BrowserHostProbeRuleNowMsName():
        return BrowserHostProbeInputScalarNone
    if plan.ruleName == browserprobe.BrowserHostProbeRulePeerHandleName():
        return BrowserHostProbeInputScalarNone
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDidHandleName():
        return BrowserHostProbeInputScalarNone
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDmActiveCountName():
        return BrowserHostProbeInputScalarNone
    if plan.ruleName == browserprobe.BrowserHostProbeRuleEchoI32Name():
        return BrowserHostProbeInputScalarI32_1
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDmConnectStartName():
        return BrowserHostProbeInputScalarI32_1
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDmWaitStartName():
        return BrowserHostProbeInputScalarI32_2
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDmSendStartName():
        return BrowserHostProbeInputScalarI32_4
    return -1

fn BrowserHostProbeOutputSchemaKindFromBridgePlan(plan: BrowserHostProbeBridgePlan): int32 =
    if plan.ruleName == browserprobe.BrowserHostProbeRuleNowMsName():
        return BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.BrowserHostProbeRuleEchoI32Name():
        return BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.BrowserHostProbeRulePeerHandleName():
        return BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDidHandleName():
        return BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDmActiveCountName():
        return BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDmConnectStartName():
        return BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDmWaitStartName():
        return BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.BrowserHostProbeRuleDmSendStartName():
        return BrowserHostProbeOutputScalarI32
    return -1

fn BrowserHostProbeBridgeKeyForSourceRuleName(sourcePath: str,
                                                ruleName: str): str =
    let rule = browserprobe.BrowserHostProbeRuleByName(sourcePath, ruleName)
    let spec = barule.BrowserAbiBridgeSpecForRule(rule)
    return spec.bridgeKey

fn BrowserHostProbeBridgeKeyForRuleName(ruleName: str): str =
    return BrowserHostProbeBridgeKeyForSourceRuleName(browserprobe.BrowserHostProbeModulePath(),
                                                        ruleName)

fn BrowserHostProbeBridgeHelperNameForSourceRuleName(sourcePath: str,
                                                       ruleName: str): str =
    let rule = browserprobe.BrowserHostProbeRuleByName(sourcePath, ruleName)
    let spec = barule.BrowserAbiBridgeSpecForRule(rule)
    return barule.BrowserAbiBridgeHelperName(spec)

fn BrowserHostProbeBridgeHelperNameForRuleName(ruleName: str): str =
    return BrowserHostProbeBridgeHelperNameForSourceRuleName(browserprobe.BrowserHostProbeModulePath(),
                                                               ruleName)

fn BrowserHostProbeBridgeEmitLineForSourceRuleName(sourcePath: str,
                                                     ruleName: str): str =
    let rule = browserprobe.BrowserHostProbeRuleByName(sourcePath, ruleName)
    let spec = barule.BrowserAbiBridgeSpecForRule(rule)
    return barule.BrowserAbiBridgeEmitLine(spec)

fn BrowserHostProbeBridgeEmitLineForRuleName(ruleName: str): str =
    return BrowserHostProbeBridgeEmitLineForSourceRuleName(browserprobe.BrowserHostProbeModulePath(),
                                                             ruleName)

fn BrowserHostProbeAppendBridgeReportLine(out: var str,
                                            index: int32,
                                            sourcePath: str,
                                            ruleName: str) =
    out = strutil.Join([out, "browser_bridge_plan["], "")
    out = strutil.Join([out, intToStr(index)], "")
    out = strutil.Join([out, "]="], "")
    out = strutil.Join([out, BrowserHostProbeBridgeEmitLineForSourceRuleName(sourcePath, ruleName)], "")
    out = strutil.Join([out, "\n"], "")

fn BrowserHostProbeAppendBridgeReportLines(out: var str,
                                             sourcePath: str,
                                             startIndex: int32): int32 =
    var nextIndex = startIndex
    BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.BrowserHostProbeRuleNowMsName())
    nextIndex = nextIndex + 1
    BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.BrowserHostProbeRuleEchoI32Name())
    nextIndex = nextIndex + 1
    BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.BrowserHostProbeRulePeerHandleName())
    nextIndex = nextIndex + 1
    BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.BrowserHostProbeRuleDidHandleName())
    nextIndex = nextIndex + 1
    BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.BrowserHostProbeRuleDmActiveCountName())
    nextIndex = nextIndex + 1
    BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.BrowserHostProbeRuleDmConnectStartName())
    nextIndex = nextIndex + 1
    BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.BrowserHostProbeRuleDmWaitStartName())
    nextIndex = nextIndex + 1
    BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.BrowserHostProbeRuleDmSendStartName())
    return nextIndex + 1

fn BrowserHostProbeNowMs(): int32 =
    return cheng_browser_now_ms_bridge()

fn BrowserHostProbeEchoI32(value: int32): int32 =
    return cheng_browser_echo_i32_bridge(value)

fn BrowserHostProbePeerHandle(): int32 =
    return cheng_browser_peer_handle_bridge()

fn BrowserHostProbeDidHandle(): int32 =
    return cheng_browser_did_handle_bridge()

fn BrowserHostProbeDmActiveCount(): int32 =
    return cheng_browser_dm_active_count_bridge()

fn BrowserHostProbeDmConnectStart(peerHandle: int32): int32 =
    return cheng_browser_dm_connect_start_bridge(peerHandle)

fn BrowserHostProbeDmWaitStart(peerHandle: int32,
                                 timeoutMs: int32): int32 =
    return cheng_browser_dm_wait_start_bridge(peerHandle, timeoutMs)

fn BrowserHostProbeDmSendStart(peerHandle: int32,
                                 conversationHandle: int32,
                                 messageHandle: int32,
                                 timestampMs: int32): int32 =
    return cheng_browser_dm_send_start_bridge(peerHandle,
                                                 conversationHandle,
                                                 messageHandle,
                                                 timestampMs)
