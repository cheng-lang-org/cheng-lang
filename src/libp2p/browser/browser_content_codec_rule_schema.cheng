import cheng/core/lang/browser_abi_rule as barule

fn v3BrowserContentCodecModulePath(): str =
    return "cheng/libp2p/browser/browser_content_codec_abi"

fn v3BrowserContentCodecRuleInputBytesRequiredName(): str =
    return "input_bytes_required"

fn v3BrowserContentCodecRuleInputTextRequiredName(): str =
    return "input_text_required"

fn v3BrowserContentCodecRuleInputTextOptionalName(): str =
    return "input_text_optional"

fn v3BrowserContentCodecRuleOutputBytesHandleName(): str =
    return "output_bytes_handle"

fn v3BrowserContentCodecRuleOutputTextHandleName(): str =
    return "output_text_handle"

fn v3BrowserContentCodecRuleExportMoqFountainBytesResultName(): str =
    return "export_moq_fountain_bytes_result"

fn v3BrowserContentCodecRuleExportMoqFountainTextResultName(): str =
    return "export_moq_fountain_text_result"

fn v3BrowserContentCodecRuleMoqFountainLastErrorHandleName(): str =
    return "moq_fountain_last_error_handle"

fn v3BrowserContentCodecRuleNames(): str[] =
    return [
        v3BrowserContentCodecRuleInputBytesRequiredName(),
        v3BrowserContentCodecRuleInputTextRequiredName(),
        v3BrowserContentCodecRuleInputTextOptionalName(),
        v3BrowserContentCodecRuleOutputBytesHandleName(),
        v3BrowserContentCodecRuleOutputTextHandleName(),
        v3BrowserContentCodecRuleExportMoqFountainBytesResultName(),
        v3BrowserContentCodecRuleExportMoqFountainTextResultName(),
        v3BrowserContentCodecRuleMoqFountainLastErrorHandleName()
    ]

fn v3BrowserContentCodecRuleTriggerNames(ruleName: str): str[] =
    var out: str[]
    if ruleName == v3BrowserContentCodecRuleInputBytesRequiredName():
        add(out, "browserInputBytesRequired")
        add(out, "v3BrowserCodecReadInputBytesRequired")
        add(out, "browserMoqFountainBuildRequest")
        add(out, "browserMoqFountainBuildWireFromHandles")
        add(out, "browserMoqFountainBuildWireBytesFromHandles")
        add(out, "browserMoqFountainBuildRemotePeerCount")
        add(out, "browserMoqFountainBuildWireRemotePeerCsvLen")
        add(out, "browserMoqFountainBuild")
        add(out, "browserMoqFountainBuildBytes")
        return out
    if ruleName == v3BrowserContentCodecRuleInputTextRequiredName():
        add(out, "browserInputTextRequired")
        add(out, "v3BrowserCodecReadInputTextRequired")
        add(out, "browserInputTextRoundtripLen")
        add(out, "browserInputRemotePeerCount")
        add(out, "browserMoqFountainPeerInput")
        add(out, "browserMoqFountainBuildRequest")
        add(out, "browserMoqFountainBuildWireFromHandles")
        add(out, "browserMoqFountainBuildWireBytesFromHandles")
        add(out, "browserMoqFountainBuildRemotePeerCount")
        add(out, "browserMoqFountainBuildWireRemotePeerCsvLen")
        add(out, "browserMoqFountainBuild")
        add(out, "browserMoqFountainBuildBytes")
        add(out, "browserMoqFountainRebuildWireText")
        add(out, "browserMoqFountainRebuildWireBytes")
        add(out, "browserMoqFountainInputRemotePeerCount")
        add(out, "browserMoqFountainRebuild")
        add(out, "browserMoqFountainRebuildBytes")
        return out
    if ruleName == v3BrowserContentCodecRuleInputTextOptionalName():
        add(out, "browserInputTextOptional")
        add(out, "v3BrowserCodecReadInputTextOptional")
        add(out, "browserMoqFountainPeerInput")
        add(out, "browserMoqFountainBuildRequest")
        add(out, "browserMoqFountainBuildWireFromHandles")
        add(out, "browserMoqFountainBuildWireBytesFromHandles")
        add(out, "browserMoqFountainBuildRemotePeerCount")
        add(out, "browserMoqFountainBuildWireRemotePeerCsvLen")
        add(out, "browserMoqFountainBuild")
        add(out, "browserMoqFountainBuildBytes")
        add(out, "browserMoqFountainInputRemotePeerCount")
        return out
    if ruleName == v3BrowserContentCodecRuleOutputBytesHandleName():
        add(out, "browserBufferHandleFromBytesRequired")
        add(out, "v3BrowserCodecWriteOutputBytesHandleRequired")
        return out
    if ruleName == v3BrowserContentCodecRuleOutputTextHandleName():
        add(out, "browserBufferHandleFromTextRequired")
        add(out, "v3BrowserCodecWriteOutputTextHandleRequired")
        return out
    if ruleName == v3BrowserContentCodecRuleExportMoqFountainBytesResultName():
        add(out, "browserMoqFountainBuildBytes")
        add(out, "browserMoqFountainRebuildBytes")
        add(out, "v3BrowserCodecExportMoqFountainBytesResult")
        return out
    if ruleName == v3BrowserContentCodecRuleExportMoqFountainTextResultName():
        add(out, "browserMoqFountainBuild")
        add(out, "browserMoqFountainRebuild")
        add(out, "v3BrowserCodecExportMoqFountainTextResult")
        return out
    if ruleName == v3BrowserContentCodecRuleMoqFountainLastErrorHandleName():
        add(out, "browserMoqFountainLastErrorHandle")
        add(out, "v3BrowserCodecMoqFountainLastErrorHandle")
        return out
    return out

fn v3BrowserContentCodecRuleByName(sourcePath: str,
                                   ruleName: str): barule.V3BrowserAbiRule =
    if ruleName == v3BrowserContentCodecRuleInputBytesRequiredName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.v3BrowserAbiInputBytesRequired,
                                          barule.v3BrowserAbiOutputBytes,
                                          barule.v3BrowserAbiErrorInlineResultError,
                                          barule.v3BrowserAbiResultBytes,
                                          barule.v3BrowserAbiOutBufferNone)
    if ruleName == v3BrowserContentCodecRuleInputTextRequiredName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.v3BrowserAbiInputTextRequired,
                                          barule.v3BrowserAbiOutputText,
                                          barule.v3BrowserAbiErrorInlineResultError,
                                          barule.v3BrowserAbiResultText,
                                          barule.v3BrowserAbiOutBufferNone)
    if ruleName == v3BrowserContentCodecRuleInputTextOptionalName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.v3BrowserAbiInputTextOptional,
                                          barule.v3BrowserAbiOutputText,
                                          barule.v3BrowserAbiErrorInlineResultError,
                                          barule.v3BrowserAbiResultText,
                                          barule.v3BrowserAbiOutBufferNone)
    if ruleName == v3BrowserContentCodecRuleOutputBytesHandleName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.v3BrowserAbiInputNone,
                                          barule.v3BrowserAbiOutputBytes,
                                          barule.v3BrowserAbiErrorInlineResultError,
                                          barule.v3BrowserAbiResultHandle,
                                          barule.v3BrowserAbiOutBufferRawHandle)
    if ruleName == v3BrowserContentCodecRuleOutputTextHandleName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.v3BrowserAbiInputNone,
                                          barule.v3BrowserAbiOutputText,
                                          barule.v3BrowserAbiErrorInlineResultError,
                                          barule.v3BrowserAbiResultHandle,
                                          barule.v3BrowserAbiOutBufferTextHandle)
    if ruleName == v3BrowserContentCodecRuleExportMoqFountainBytesResultName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.v3BrowserAbiInputNone,
                                          barule.v3BrowserAbiOutputBytes,
                                          barule.v3BrowserAbiErrorMoqFountainLastError,
                                          barule.v3BrowserAbiResultStatusI32,
                                          barule.v3BrowserAbiOutBufferRawHandle)
    if ruleName == v3BrowserContentCodecRuleExportMoqFountainTextResultName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.v3BrowserAbiInputNone,
                                          barule.v3BrowserAbiOutputText,
                                          barule.v3BrowserAbiErrorMoqFountainLastError,
                                          barule.v3BrowserAbiResultStatusI32,
                                          barule.v3BrowserAbiOutBufferTextHandle)
    if ruleName == v3BrowserContentCodecRuleMoqFountainLastErrorHandleName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.v3BrowserAbiInputNone,
                                          barule.v3BrowserAbiOutputText,
                                          barule.v3BrowserAbiErrorMoqFountainLastError,
                                          barule.v3BrowserAbiResultHandle,
                                          barule.v3BrowserAbiOutBufferTextHandle)
    return barule.v3BrowserAbiRuleNew(sourcePath,
                                      ruleName,
                                      barule.v3BrowserAbiInputNone,
                                      barule.v3BrowserAbiOutputNone,
                                      barule.v3BrowserAbiErrorInlineResultError,
                                      barule.v3BrowserAbiResultNone,
                                      barule.v3BrowserAbiOutBufferNone)

fn v3BrowserContentCodecRules(sourcePath: str): barule.V3BrowserAbiRule[] =
    var out: barule.V3BrowserAbiRule[]
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleInputBytesRequiredName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleInputTextRequiredName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleInputTextOptionalName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleOutputBytesHandleName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleOutputTextHandleName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleExportMoqFountainBytesResultName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleExportMoqFountainTextResultName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleMoqFountainLastErrorHandleName()))
    return out
