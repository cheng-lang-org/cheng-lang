import cheng/core/lang/browser_abi_rule as barule

fn BrowserContentCodecModulePath(): str =
    return "cheng/libp2p/browser/browser_content_codec_abi"

fn BrowserContentCodecRuleInputBytesRequiredName(): str =
    return "input_bytes_required"

fn BrowserContentCodecRuleInputTextRequiredName(): str =
    return "input_text_required"

fn BrowserContentCodecRuleInputTextOptionalName(): str =
    return "input_text_optional"

fn BrowserContentCodecRuleOutputBytesHandleName(): str =
    return "output_bytes_handle"

fn BrowserContentCodecRuleOutputTextHandleName(): str =
    return "output_text_handle"

fn BrowserContentCodecRuleExportMoqFountainBytesResultName(): str =
    return "export_moq_fountain_bytes_result"

fn BrowserContentCodecRuleExportMoqFountainTextResultName(): str =
    return "export_moq_fountain_text_result"

fn BrowserContentCodecRuleMoqFountainLastErrorHandleName(): str =
    return "moq_fountain_last_error_handle"

fn BrowserContentCodecRuleNames(): str[] =
    return [
        BrowserContentCodecRuleInputBytesRequiredName(),
        BrowserContentCodecRuleInputTextRequiredName(),
        BrowserContentCodecRuleInputTextOptionalName(),
        BrowserContentCodecRuleOutputBytesHandleName(),
        BrowserContentCodecRuleOutputTextHandleName(),
        BrowserContentCodecRuleExportMoqFountainBytesResultName(),
        BrowserContentCodecRuleExportMoqFountainTextResultName(),
        BrowserContentCodecRuleMoqFountainLastErrorHandleName()
    ]

fn BrowserContentCodecRuleTriggerNames(ruleName: str): str[] =
    var out: str[]
    if ruleName == BrowserContentCodecRuleInputBytesRequiredName():
        add(out, "browserInputBytesRequired")
        add(out, "BrowserCodecReadInputBytesRequired")
        add(out, "browserMoqFountainBuildRequest")
        add(out, "browserMoqFountainBuildWireFromHandles")
        add(out, "browserMoqFountainBuildWireBytesFromHandles")
        add(out, "browserMoqFountainBuildRemotePeerCount")
        add(out, "browserMoqFountainBuildWireRemotePeerCsvLen")
        add(out, "browserMoqFountainBuild")
        add(out, "browserMoqFountainBuildBytes")
        return out
    if ruleName == BrowserContentCodecRuleInputTextRequiredName():
        add(out, "browserInputTextRequired")
        add(out, "BrowserCodecReadInputTextRequired")
        add(out, "browserInputTextRoundtripLen")
        add(out, "browserInputRemotePeerCount")
        add(out, "browserMoqFountainPeerInput")
        add(out, "browserMoqFountainBuildRequest")
        add(out, "browserMoqFountainBuildWireFromHandles")
        add(out, "browserMoqFountainBuildWireBytesFromHandles")
        add(out, "browserMoqFountainBuildRemotePeerCount")
        add(out, "browserMoqFountainBuildWireRemotePeerCsvLen")
        add(out, "browserMoqFountainBuild")
        add(out, "browserMoqFountainBuildBytes")
        add(out, "browserMoqFountainRebuildWireText")
        add(out, "browserMoqFountainRebuildWireBytes")
        add(out, "browserMoqFountainInputRemotePeerCount")
        add(out, "browserMoqFountainRebuild")
        add(out, "browserMoqFountainRebuildBytes")
        return out
    if ruleName == BrowserContentCodecRuleInputTextOptionalName():
        add(out, "browserInputTextOptional")
        add(out, "BrowserCodecReadInputTextOptional")
        add(out, "browserMoqFountainPeerInput")
        add(out, "browserMoqFountainBuildRequest")
        add(out, "browserMoqFountainBuildWireFromHandles")
        add(out, "browserMoqFountainBuildWireBytesFromHandles")
        add(out, "browserMoqFountainBuildRemotePeerCount")
        add(out, "browserMoqFountainBuildWireRemotePeerCsvLen")
        add(out, "browserMoqFountainBuild")
        add(out, "browserMoqFountainBuildBytes")
        add(out, "browserMoqFountainInputRemotePeerCount")
        return out
    if ruleName == BrowserContentCodecRuleOutputBytesHandleName():
        add(out, "browserBufferHandleFromBytesRequired")
        add(out, "BrowserCodecWriteOutputBytesHandleRequired")
        return out
    if ruleName == BrowserContentCodecRuleOutputTextHandleName():
        add(out, "browserBufferHandleFromTextRequired")
        add(out, "BrowserCodecWriteOutputTextHandleRequired")
        return out
    if ruleName == BrowserContentCodecRuleExportMoqFountainBytesResultName():
        add(out, "browserMoqFountainBuildBytes")
        add(out, "browserMoqFountainRebuildBytes")
        add(out, "BrowserCodecExportMoqFountainBytesResult")
        return out
    if ruleName == BrowserContentCodecRuleExportMoqFountainTextResultName():
        add(out, "browserMoqFountainBuild")
        add(out, "browserMoqFountainRebuild")
        add(out, "BrowserCodecExportMoqFountainTextResult")
        return out
    if ruleName == BrowserContentCodecRuleMoqFountainLastErrorHandleName():
        add(out, "browserMoqFountainLastErrorHandle")
        add(out, "BrowserCodecMoqFountainLastErrorHandle")
        return out
    return out

fn BrowserContentCodecRuleByName(sourcePath: str,
                                   ruleName: str): barule.BrowserAbiRule =
    if ruleName == BrowserContentCodecRuleInputBytesRequiredName():
        return barule.BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.BrowserAbiInputBytesRequired,
                                          barule.BrowserAbiOutputBytes,
                                          barule.BrowserAbiErrorInlineResultError,
                                          barule.BrowserAbiResultBytes,
                                          barule.BrowserAbiOutBufferNone)
    if ruleName == BrowserContentCodecRuleInputTextRequiredName():
        return barule.BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.BrowserAbiInputTextRequired,
                                          barule.BrowserAbiOutputText,
                                          barule.BrowserAbiErrorInlineResultError,
                                          barule.BrowserAbiResultText,
                                          barule.BrowserAbiOutBufferNone)
    if ruleName == BrowserContentCodecRuleInputTextOptionalName():
        return barule.BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.BrowserAbiInputTextOptional,
                                          barule.BrowserAbiOutputText,
                                          barule.BrowserAbiErrorInlineResultError,
                                          barule.BrowserAbiResultText,
                                          barule.BrowserAbiOutBufferNone)
    if ruleName == BrowserContentCodecRuleOutputBytesHandleName():
        return barule.BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.BrowserAbiInputNone,
                                          barule.BrowserAbiOutputBytes,
                                          barule.BrowserAbiErrorInlineResultError,
                                          barule.BrowserAbiResultHandle,
                                          barule.BrowserAbiOutBufferRawHandle)
    if ruleName == BrowserContentCodecRuleOutputTextHandleName():
        return barule.BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.BrowserAbiInputNone,
                                          barule.BrowserAbiOutputText,
                                          barule.BrowserAbiErrorInlineResultError,
                                          barule.BrowserAbiResultHandle,
                                          barule.BrowserAbiOutBufferTextHandle)
    if ruleName == BrowserContentCodecRuleExportMoqFountainBytesResultName():
        return barule.BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.BrowserAbiInputNone,
                                          barule.BrowserAbiOutputBytes,
                                          barule.BrowserAbiErrorMoqFountainLastError,
                                          barule.BrowserAbiResultStatusI32,
                                          barule.BrowserAbiOutBufferRawHandle)
    if ruleName == BrowserContentCodecRuleExportMoqFountainTextResultName():
        return barule.BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.BrowserAbiInputNone,
                                          barule.BrowserAbiOutputText,
                                          barule.BrowserAbiErrorMoqFountainLastError,
                                          barule.BrowserAbiResultStatusI32,
                                          barule.BrowserAbiOutBufferTextHandle)
    if ruleName == BrowserContentCodecRuleMoqFountainLastErrorHandleName():
        return barule.BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          barule.BrowserAbiInputNone,
                                          barule.BrowserAbiOutputText,
                                          barule.BrowserAbiErrorMoqFountainLastError,
                                          barule.BrowserAbiResultHandle,
                                          barule.BrowserAbiOutBufferTextHandle)
    return barule.BrowserAbiRuleNew(sourcePath,
                                      ruleName,
                                      barule.BrowserAbiInputNone,
                                      barule.BrowserAbiOutputNone,
                                      barule.BrowserAbiErrorInlineResultError,
                                      barule.BrowserAbiResultNone,
                                      barule.BrowserAbiOutBufferNone)

fn BrowserContentCodecRules(sourcePath: str): barule.BrowserAbiRule[] =
    var out: barule.BrowserAbiRule[]
    add(out, BrowserContentCodecRuleByName(sourcePath, BrowserContentCodecRuleInputBytesRequiredName()))
    add(out, BrowserContentCodecRuleByName(sourcePath, BrowserContentCodecRuleInputTextRequiredName()))
    add(out, BrowserContentCodecRuleByName(sourcePath, BrowserContentCodecRuleInputTextOptionalName()))
    add(out, BrowserContentCodecRuleByName(sourcePath, BrowserContentCodecRuleOutputBytesHandleName()))
    add(out, BrowserContentCodecRuleByName(sourcePath, BrowserContentCodecRuleOutputTextHandleName()))
    add(out, BrowserContentCodecRuleByName(sourcePath, BrowserContentCodecRuleExportMoqFountainBytesResultName()))
    add(out, BrowserContentCodecRuleByName(sourcePath, BrowserContentCodecRuleExportMoqFountainTextResultName()))
    add(out, BrowserContentCodecRuleByName(sourcePath, BrowserContentCodecRuleMoqFountainLastErrorHandleName()))
    return out
