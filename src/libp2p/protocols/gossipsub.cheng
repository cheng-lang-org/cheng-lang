import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types as core

type
    Libp2pTopicDescriptor =
        topicId: core.Libp2pTopicId
        scope: overlay.OverlayTopicScope
        address: types.LsmrAddress
        protocol: core.Libp2pProtocolId

    Libp2pPubRecord =
        topicId: core.Libp2pTopicId
        sourcePeerId: core.Libp2pPeerId
        payloadKind: int32
        payloadCid: layout.FixedBytes32
        payloadLen: int32
        stampEpoch: int32
        stampGanzhi: int32

fn Libp2pTopicForScope(scope: overlay.OverlayTopicScope,
                         address: types.LsmrAddress): core.Libp2pTopicId =
    var ints: int32[]
    ints = []
    add(ints, int32(scope))
    add(ints, address.depth)
    for i in 0..<address.depth:
        add(ints, address.digits[i])
    let topicHash = lt.HashInts("cheng.libp2p.topic", ints)
    var out: core.Libp2pTopicId
    out.value = topicHash
    return out

fn Libp2pTopicDescriptor(scope: overlay.OverlayTopicScope,
                           address: types.LsmrAddress): Libp2pTopicDescriptor =
    var out: Libp2pTopicDescriptor
    out.topicId = Libp2pTopicForScope(scope, address)
    out.scope = scope
    out.address = address
    out.protocol = core.Libp2pProtocolGossipsub
    return out

fn Libp2pPubRecordFillFromIngress(out: var Libp2pPubRecord,
                                    sourcePeerId: core.Libp2pPeerId,
                                    env: overlay.IngressEnvelope) =
    let topicScope = env.topicScope
    let address = env.address
    let topicId = Libp2pTopicForScope(topicScope, address)
    out.topicId = topicId
    out.sourcePeerId = sourcePeerId
    out.payloadKind = env.payloadKind
    out.payloadCid = env.payloadCid
    out.payloadLen = env.payloadLen
    out.stampEpoch = env.stampEpoch
    out.stampGanzhi = env.stampGanzhi

fn Libp2pPubRecordFromIngress(sourcePeerId: core.Libp2pPeerId,
                                env: overlay.IngressEnvelope): Libp2pPubRecord =
    var out: Libp2pPubRecord
    Libp2pPubRecordFillFromIngress(out, sourcePeerId, env)
    return out
