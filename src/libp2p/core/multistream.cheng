import std/rawbytes
import cheng/libp2p/core/types

fn Libp2pMultistreamHeaderText(): str =
    return "/multistream/1.0.0\n"

fn Libp2pMultistreamProtocolLine(protocol: types.Libp2pProtocolId): str =
    return types.Libp2pProtocolWireText(protocol) + "\n"

fn Libp2pMultistreamSelectBytes(protocol: types.Libp2pProtocolId): Bytes =
    let header = Libp2pMultistreamHeaderText()
    let line = Libp2pMultistreamProtocolLine(protocol)
    let text = header + line
    let payload = bytesFromString(text)
    return payload

fn Libp2pMultistreamAccepts(payload: Bytes,
                              protocol: types.Libp2pProtocolId): bool =
    let expected = Libp2pMultistreamSelectBytes(protocol)
    if bytesLen(payload) != bytesLen(expected):
        return false
    for i in 0..<bytesLen(payload):
        if bytesGet(payload, i) != bytesGet(expected, i):
            return false
    return true
