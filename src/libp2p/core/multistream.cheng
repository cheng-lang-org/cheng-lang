import std/rawbytes
import cheng/libp2p/core/types

fn v3Libp2pMultistreamHeaderText(): str =
    return "/multistream/1.0.0\n"

fn v3Libp2pMultistreamProtocolLine(protocol: types.V3Libp2pProtocolId): str =
    return types.v3Libp2pProtocolWireText(protocol) + "\n"

fn v3Libp2pMultistreamSelectBytes(protocol: types.V3Libp2pProtocolId): Bytes =
    let header = v3Libp2pMultistreamHeaderText()
    let line = v3Libp2pMultistreamProtocolLine(protocol)
    let text = header + line
    let payload = bytesFromString(text)
    return payload

fn v3Libp2pMultistreamAccepts(payload: Bytes,
                              protocol: types.V3Libp2pProtocolId): bool =
    let expected = v3Libp2pMultistreamSelectBytes(protocol)
    if bytesLen(payload) != bytesLen(expected):
        return false
    for i in 0..<bytesLen(payload):
        if bytesGet(payload, i) != bytesGet(expected, i):
            return false
    return true
