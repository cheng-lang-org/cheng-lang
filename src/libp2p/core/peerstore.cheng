import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/resources

const
    Libp2pPeerCacheEntryCap: int32 = 8

type
    Libp2pPeerCacheEntry =
        cacheKey: str
        lastHitEpochSeconds: int64
        hitCount: int32
        admittedAtEpochSeconds: int64
        residentBytes: int64

    Libp2pPeerEndpoint =
        addr: types.Libp2pMultiaddr
        lastDialOk: bool
        reachability: types.Libp2pReachabilityKind
        priority: int32 = 100

    Libp2pPeerRelayCacheEntry =
        descriptor: types.Libp2pRelayDescriptor
        successCount: int32
        failureCount: int32
        lastSuccessEpochSeconds: int64
        lastFailureEpochSeconds: int64
        failureCooldownUntilEpochSeconds: int64

    Libp2pPeerRecord =
        peerId: types.Libp2pPeerId
        endpoints: Libp2pPeerEndpoint[]
        routingRole: int32
        connected: bool
        bootstrap: bool
        trustedInfra: bool
        placementGroup: str
        replicaWithdrawn: bool
        rttEwmaMicros: int32
        lossPermille: int32
        loadPermille: int32
        trustPermille: int32
        resources: types.Libp2pNodeResource
        cacheEntries: Libp2pPeerCacheEntry[]
        relayEntries: Libp2pPeerRelayCacheEntry[]

    Libp2pPeerstore =
        peers: Libp2pPeerRecord[]

fn Libp2pPeerCacheEntryClone(entry: Libp2pPeerCacheEntry): Libp2pPeerCacheEntry =
    var out: Libp2pPeerCacheEntry
    out.cacheKey = entry.cacheKey
    out.lastHitEpochSeconds = entry.lastHitEpochSeconds
    out.hitCount = entry.hitCount
    out.admittedAtEpochSeconds = entry.admittedAtEpochSeconds
    out.residentBytes = entry.residentBytes
    return out

fn Libp2pPeerCacheEntryBetter(left: Libp2pPeerCacheEntry,
                                right: Libp2pPeerCacheEntry): bool =
    if left.hitCount > right.hitCount:
        return true
    if left.hitCount < right.hitCount:
        return false
    if left.lastHitEpochSeconds > right.lastHitEpochSeconds:
        return true
    if left.lastHitEpochSeconds < right.lastHitEpochSeconds:
        return false
    if left.admittedAtEpochSeconds > right.admittedAtEpochSeconds:
        return true
    if left.admittedAtEpochSeconds < right.admittedAtEpochSeconds:
        return false
    if left.residentBytes < right.residentBytes:
        return true
    if left.residentBytes > right.residentBytes:
        return false
    return left.cacheKey < right.cacheKey

fn Libp2pPeerCacheResidentBytes(record: Libp2pPeerRecord): int64 =
    var total = int64(0)
    for i in 0..<record.cacheEntries.len:
        if record.cacheEntries[i].residentBytes > int64(0):
            total = total + record.cacheEntries[i].residentBytes
    return total

fn Libp2pPeerEndpointClone(endpoint: Libp2pPeerEndpoint): Libp2pPeerEndpoint =
    var out: Libp2pPeerEndpoint
    out.addr = multiaddr.Libp2pMultiaddrClone(endpoint.addr)
    out.lastDialOk = endpoint.lastDialOk
    out.reachability = endpoint.reachability
    out.priority = endpoint.priority
    return out

fn Libp2pPeerRelayCacheEntryClone(entry: Libp2pPeerRelayCacheEntry): Libp2pPeerRelayCacheEntry =
    var out: Libp2pPeerRelayCacheEntry
    out.descriptor.peerId = entry.descriptor.peerId
    out.descriptor.serviceKind = entry.descriptor.serviceKind
    out.descriptor.region = entry.descriptor.region
    out.descriptor.endpointText = entry.descriptor.endpointText
    out.descriptor.authScope = entry.descriptor.authScope
    out.descriptor.requiresLease = entry.descriptor.requiresLease
    out.descriptor.advertisedAtEpochSeconds = entry.descriptor.advertisedAtEpochSeconds
    out.descriptor.ttlSeconds = entry.descriptor.ttlSeconds
    out.descriptor.health.healthy = entry.descriptor.health.healthy
    out.descriptor.health.sampledAtEpochSeconds = entry.descriptor.health.sampledAtEpochSeconds
    out.descriptor.health.successPermille = entry.descriptor.health.successPermille
    out.descriptor.health.loadPermille = entry.descriptor.health.loadPermille
    out.descriptor.health.capacityPermille = entry.descriptor.health.capacityPermille
    out.descriptor.health.failureCooldownUntilEpochSeconds = entry.descriptor.health.failureCooldownUntilEpochSeconds
    out.descriptor.health.lastError = entry.descriptor.health.lastError
    out.successCount = entry.successCount
    out.failureCount = entry.failureCount
    out.lastSuccessEpochSeconds = entry.lastSuccessEpochSeconds
    out.lastFailureEpochSeconds = entry.lastFailureEpochSeconds
    out.failureCooldownUntilEpochSeconds = entry.failureCooldownUntilEpochSeconds
    return out

fn Libp2pPeerstorePos(store: Libp2pPeerstore,
                        peerId: types.Libp2pPeerId): int32 =
    for i in 0..<store.peers.len:
        let candidatePeerId = store.peers[i].peerId
        if types.Libp2pPeerIdEqual(candidatePeerId, peerId):
            return i
    return -1

fn Libp2pPeerRecordEndpointPos(record: Libp2pPeerRecord,
                                 addr: types.Libp2pMultiaddr): int32 =
    for i in 0..<record.endpoints.len:
        if multiaddr.Libp2pMultiaddrEqual(record.endpoints[i].addr, addr):
            return i
    return -1

fn Libp2pPeerRecordCacheEntryPos(record: Libp2pPeerRecord,
                                   cacheKey: str): int32 =
    for i in 0..<record.cacheEntries.len:
        if record.cacheEntries[i].cacheKey == cacheKey:
            return i
    return -1

fn Libp2pPeerRelayCacheEntryPos(record: Libp2pPeerRecord,
                                  serviceKind: types.Libp2pRelayServiceKind,
                                  region: str,
                                  endpointText: str): int32 =
    for i in 0..<record.relayEntries.len:
        let descriptor = record.relayEntries[i].descriptor
        if descriptor.serviceKind != serviceKind:
            continue
        if descriptor.region != region:
            continue
        if descriptor.endpointText != endpointText:
            continue
        return i
    return -1

fn Libp2pPeerRecordWorstCacheEntryPos(record: Libp2pPeerRecord): int32 =
    if record.cacheEntries.len <= 0:
        return -1
    var worstPos = 0
    for i in 1..<record.cacheEntries.len:
        if Libp2pPeerCacheEntryBetter(record.cacheEntries[worstPos], record.cacheEntries[i]):
            worstPos = i
    return worstPos

fn Libp2pPeerRecordCacheRemovePos(record: var Libp2pPeerRecord,
                                    pos: int32) =
    if pos < 0 || pos >= record.cacheEntries.len:
        return
    var next: Libp2pPeerCacheEntry[]
    next = []
    for i in 0..<record.cacheEntries.len:
        if i == pos:
            continue
        add(next, Libp2pPeerCacheEntryClone(record.cacheEntries[i]))
    record.cacheEntries = next

fn Libp2pPeerRecordEvictCache(record: var Libp2pPeerRecord,
                                cacheKey: str): bool =
    let pos = Libp2pPeerRecordCacheEntryPos(record, cacheKey)
    if pos < 0:
        return false
    Libp2pPeerRecordCacheRemovePos(record, pos)
    return true

fn Libp2pPeerRecordRelayRemovePos(record: var Libp2pPeerRecord,
                                    pos: int32) =
    if pos < 0 || pos >= record.relayEntries.len:
        return
    var next: Libp2pPeerRelayCacheEntry[]
    next = []
    for i in 0..<record.relayEntries.len:
        if i == pos:
            continue
        add(next, Libp2pPeerRelayCacheEntryClone(record.relayEntries[i]))
    record.relayEntries = next

fn Libp2pPeerRecordPutRelayDescriptor(record: var Libp2pPeerRecord,
                                        descriptor: types.Libp2pRelayDescriptor) =
    if descriptor.serviceKind == types.Libp2pRelayServiceNone:
        return
    if len(descriptor.endpointText) <= 0:
        return
    let pos = Libp2pPeerRelayCacheEntryPos(record,
                                             descriptor.serviceKind,
                                             descriptor.region,
                                             descriptor.endpointText)
    if pos >= 0:
        let prev = record.relayEntries[pos]
        var next = Libp2pPeerRelayCacheEntryClone(prev)
        next.descriptor.peerId = descriptor.peerId
        next.descriptor.serviceKind = descriptor.serviceKind
        next.descriptor.region = descriptor.region
        next.descriptor.endpointText = descriptor.endpointText
        next.descriptor.authScope = descriptor.authScope
        next.descriptor.requiresLease = descriptor.requiresLease
        next.descriptor.advertisedAtEpochSeconds = descriptor.advertisedAtEpochSeconds
        next.descriptor.ttlSeconds = descriptor.ttlSeconds
        next.descriptor.health.healthy = descriptor.health.healthy
        next.descriptor.health.sampledAtEpochSeconds = descriptor.health.sampledAtEpochSeconds
        next.descriptor.health.successPermille = descriptor.health.successPermille
        next.descriptor.health.loadPermille = descriptor.health.loadPermille
        next.descriptor.health.capacityPermille = descriptor.health.capacityPermille
        next.descriptor.health.failureCooldownUntilEpochSeconds = descriptor.health.failureCooldownUntilEpochSeconds
        next.descriptor.health.lastError = descriptor.health.lastError
        if next.failureCooldownUntilEpochSeconds < descriptor.health.failureCooldownUntilEpochSeconds:
            next.failureCooldownUntilEpochSeconds = descriptor.health.failureCooldownUntilEpochSeconds
        record.relayEntries[pos] = next
        return
    var insert: Libp2pPeerRelayCacheEntry
    insert.descriptor.peerId = descriptor.peerId
    insert.descriptor.serviceKind = descriptor.serviceKind
    insert.descriptor.region = descriptor.region
    insert.descriptor.endpointText = descriptor.endpointText
    insert.descriptor.authScope = descriptor.authScope
    insert.descriptor.requiresLease = descriptor.requiresLease
    insert.descriptor.advertisedAtEpochSeconds = descriptor.advertisedAtEpochSeconds
    insert.descriptor.ttlSeconds = descriptor.ttlSeconds
    insert.descriptor.health.healthy = descriptor.health.healthy
    insert.descriptor.health.sampledAtEpochSeconds = descriptor.health.sampledAtEpochSeconds
    insert.descriptor.health.successPermille = descriptor.health.successPermille
    insert.descriptor.health.loadPermille = descriptor.health.loadPermille
    insert.descriptor.health.capacityPermille = descriptor.health.capacityPermille
    insert.descriptor.health.failureCooldownUntilEpochSeconds = descriptor.health.failureCooldownUntilEpochSeconds
    insert.descriptor.health.lastError = descriptor.health.lastError
    insert.failureCooldownUntilEpochSeconds = descriptor.health.failureCooldownUntilEpochSeconds
    add(record.relayEntries, insert)

fn Libp2pPeerRecordRemoveRelayDescriptor(record: var Libp2pPeerRecord,
                                           serviceKind: types.Libp2pRelayServiceKind,
                                           region: str,
                                           endpointText: str): bool =
    let pos = Libp2pPeerRelayCacheEntryPos(record, serviceKind, region, endpointText)
    if pos < 0:
        return false
    Libp2pPeerRecordRelayRemovePos(record, pos)
    return true

fn Libp2pPeerRecordRelayEntryAtFill(out: var Libp2pPeerRelayCacheEntry,
                                      record: Libp2pPeerRecord,
                                      pos: int32): bool =
    if pos < 0 || pos >= record.relayEntries.len:
        return false
    out = Libp2pPeerRelayCacheEntryClone(record.relayEntries[pos])
    return true

fn Libp2pPeerRecordObserveRelaySuccess(record: var Libp2pPeerRecord,
                                         serviceKind: types.Libp2pRelayServiceKind,
                                         region: str,
                                         endpointText: str,
                                         observedAtEpochSeconds: int64) =
    var pos = Libp2pPeerRelayCacheEntryPos(record, serviceKind, region, endpointText)
    if pos < 0:
        return
    record.relayEntries[pos].successCount = record.relayEntries[pos].successCount + 1
    record.relayEntries[pos].lastSuccessEpochSeconds = observedAtEpochSeconds
    record.relayEntries[pos].failureCooldownUntilEpochSeconds = int64(0)
    record.relayEntries[pos].descriptor.health.failureCooldownUntilEpochSeconds = int64(0)
    record.relayEntries[pos].descriptor.health.healthy = true
    record.relayEntries[pos].descriptor.health.lastError = ""
    var total = record.relayEntries[pos].successCount + record.relayEntries[pos].failureCount
    var successPermille = record.relayEntries[pos].descriptor.health.successPermille
    if total > 0:
        successPermille = (record.relayEntries[pos].successCount * 1000) / total
    record.relayEntries[pos].descriptor.health.successPermille = successPermille

fn Libp2pPeerRecordObserveRelayFailure(record: var Libp2pPeerRecord,
                                         serviceKind: types.Libp2pRelayServiceKind,
                                         region: str,
                                         endpointText: str,
                                         observedAtEpochSeconds: int64,
                                         cooldownSeconds: int32,
                                         errText: str) =
    var pos = Libp2pPeerRelayCacheEntryPos(record, serviceKind, region, endpointText)
    if pos < 0:
        return
    record.relayEntries[pos].failureCount = record.relayEntries[pos].failureCount + 1
    record.relayEntries[pos].lastFailureEpochSeconds = observedAtEpochSeconds
    record.relayEntries[pos].failureCooldownUntilEpochSeconds =
        observedAtEpochSeconds + int64(cooldownSeconds)
    record.relayEntries[pos].descriptor.health.failureCooldownUntilEpochSeconds =
        record.relayEntries[pos].failureCooldownUntilEpochSeconds
    record.relayEntries[pos].descriptor.health.lastError = errText
    record.relayEntries[pos].descriptor.health.healthy = false
    var total = record.relayEntries[pos].successCount + record.relayEntries[pos].failureCount
    var successPermille = record.relayEntries[pos].descriptor.health.successPermille
    if total > 0:
        successPermille = (record.relayEntries[pos].successCount * 1000) / total
    record.relayEntries[pos].descriptor.health.successPermille = successPermille

fn Libp2pPeerRecordObserveCache(record: var Libp2pPeerRecord,
                                  cacheKey: str,
                                  observedAtEpochSeconds: int64) =
    if len(cacheKey) <= 0:
        return
    let pos = Libp2pPeerRecordCacheEntryPos(record, cacheKey)
    if pos >= 0:
        if observedAtEpochSeconds > record.cacheEntries[pos].lastHitEpochSeconds:
            record.cacheEntries[pos].lastHitEpochSeconds = observedAtEpochSeconds
        record.cacheEntries[pos].hitCount = record.cacheEntries[pos].hitCount + 1
        if record.cacheEntries[pos].admittedAtEpochSeconds <= int64(0):
            record.cacheEntries[pos].admittedAtEpochSeconds = observedAtEpochSeconds
        if record.cacheEntries[pos].residentBytes <= int64(0):
            record.cacheEntries[pos].residentBytes = int64(1)
        return
    var insert: Libp2pPeerCacheEntry
    insert.cacheKey = cacheKey
    insert.lastHitEpochSeconds = observedAtEpochSeconds
    insert.hitCount = 1
    insert.admittedAtEpochSeconds = observedAtEpochSeconds
    insert.residentBytes = int64(1)
    if record.cacheEntries.len < Libp2pPeerCacheEntryCap:
        add(record.cacheEntries, insert)
        return
    let worstPos = Libp2pPeerRecordWorstCacheEntryPos(record)
    if worstPos < 0:
        return
    if !Libp2pPeerCacheEntryBetter(insert, record.cacheEntries[worstPos]):
        return
    record.cacheEntries[worstPos] = insert

fn Libp2pPeerRecordAdmitCache(record: var Libp2pPeerRecord,
                                cacheKey: str,
                                observedAtEpochSeconds: int64,
                                residentBytes: int64,
                                maxEntryCount: int32,
                                maxResidentBytes: int64): bool =
    if len(cacheKey) <= 0:
        return false
    if residentBytes <= int64(0):
        return false
    if maxEntryCount <= 0 || maxResidentBytes <= int64(0):
        return false
    if residentBytes > maxResidentBytes:
        return false
    let pos = Libp2pPeerRecordCacheEntryPos(record, cacheKey)
    if pos >= 0:
        record.cacheEntries[pos].residentBytes = residentBytes
        if observedAtEpochSeconds > record.cacheEntries[pos].admittedAtEpochSeconds:
            record.cacheEntries[pos].admittedAtEpochSeconds = observedAtEpochSeconds
        elif record.cacheEntries[pos].admittedAtEpochSeconds <= int64(0):
            record.cacheEntries[pos].admittedAtEpochSeconds = observedAtEpochSeconds
    else:
        var insert: Libp2pPeerCacheEntry
        insert.cacheKey = cacheKey
        insert.lastHitEpochSeconds = int64(0)
        insert.hitCount = 0
        insert.admittedAtEpochSeconds = observedAtEpochSeconds
        insert.residentBytes = residentBytes
        if record.cacheEntries.len < Libp2pPeerCacheEntryCap:
            add(record.cacheEntries, insert)
        else:
            let worstPos = Libp2pPeerRecordWorstCacheEntryPos(record)
            if worstPos < 0:
                return false
            if !Libp2pPeerCacheEntryBetter(insert, record.cacheEntries[worstPos]):
                return false
            record.cacheEntries[worstPos] = insert
    while record.cacheEntries.len > maxEntryCount ||
      Libp2pPeerCacheResidentBytes(record) > maxResidentBytes:
        let worstPos = Libp2pPeerRecordWorstCacheEntryPos(record)
        if worstPos < 0:
            break
        let evictedKey = record.cacheEntries[worstPos].cacheKey
        Libp2pPeerRecordCacheRemovePos(record, worstPos)
        if evictedKey == cacheKey:
            return false
    return Libp2pPeerRecordCacheEntryPos(record, cacheKey) >= 0

fn Libp2pPeerRecordCacheHitFill(record: Libp2pPeerRecord,
                                  cacheKey: str,
                                  outLastHitEpochSeconds: var int64,
                                  outHitCount: var int32): bool =
    outLastHitEpochSeconds = int64(0)
    outHitCount = 0
    if len(cacheKey) <= 0:
        return false
    let pos = Libp2pPeerRecordCacheEntryPos(record, cacheKey)
    if pos < 0:
        return false
    outLastHitEpochSeconds = record.cacheEntries[pos].lastHitEpochSeconds
    outHitCount = record.cacheEntries[pos].hitCount
    return true

fn Libp2pPeerRecordCacheResidencyFill(record: Libp2pPeerRecord,
                                        cacheKey: str,
                                        outResidentBytes: var int64,
                                        outAdmittedAtEpochSeconds: var int64): bool =
    outResidentBytes = int64(0)
    outAdmittedAtEpochSeconds = int64(0)
    if len(cacheKey) <= 0:
        return false
    let pos = Libp2pPeerRecordCacheEntryPos(record, cacheKey)
    if pos < 0:
        return false
    outResidentBytes = record.cacheEntries[pos].residentBytes
    outAdmittedAtEpochSeconds = record.cacheEntries[pos].admittedAtEpochSeconds
    return true

fn Libp2pPeerRecordResetLastDialOk(record: var Libp2pPeerRecord) =
    for i in 0..<record.endpoints.len:
        record.endpoints[i].lastDialOk = false

fn Libp2pPeerRecordPutEndpoint(record: var Libp2pPeerRecord,
                                 addr: types.Libp2pMultiaddr,
                                 lastDialOk: bool,
                                 reachability: types.Libp2pReachabilityKind,
                                 priority: int32) =
    let pos = Libp2pPeerRecordEndpointPos(record, addr)
    if pos >= 0:
        record.endpoints[pos].addr = multiaddr.Libp2pMultiaddrClone(addr)
        record.endpoints[pos].lastDialOk = lastDialOk
        record.endpoints[pos].reachability = reachability
        record.endpoints[pos].priority = priority
        return
    let insert: Libp2pPeerEndpoint
    add(record.endpoints, insert)
    let idx = record.endpoints.len - 1
    record.endpoints[idx].addr = multiaddr.Libp2pMultiaddrClone(addr)
    record.endpoints[idx].lastDialOk = lastDialOk
    record.endpoints[idx].reachability = reachability
    record.endpoints[idx].priority = priority

fn Libp2pPeerRecordVisibleAddrs(record: Libp2pPeerRecord,
                                  trustedView: bool): types.Libp2pMultiaddr[] =
    var out: types.Libp2pMultiaddr[]
    out = []
    for i in 0..<record.endpoints.len:
        let endpoint = record.endpoints[i]
        if !multiaddr.Libp2pMultiaddrVisible(endpoint.addr, trustedView):
            continue
        add(out, multiaddr.Libp2pMultiaddrClone(endpoint.addr))
    return out

fn Libp2pPeerEndpointRank(record: Libp2pPeerRecord,
                            endpoint: Libp2pPeerEndpoint,
                            trustedView: bool): int32 =
    let addr = endpoint.addr
    if !multiaddr.Libp2pMultiaddrVisible(addr, trustedView):
        return 100000
    var relayPenalty = 0
    if endpoint.reachability == types.Libp2pReachabilityRelayed:
        relayPenalty = 100
    if record.connected && endpoint.lastDialOk:
        return 0
    if addr.networkDomain == types.Libp2pNetworkDomainTailnet:
        if addr.transport == types.Libp2pTransportQuic:
            return 10 + relayPenalty
        if addr.transport == types.Libp2pTransportTcp:
            return 20 + relayPenalty
        return 30 + relayPenalty
    if addr.networkDomain == types.Libp2pNetworkDomainLan:
        if addr.transport == types.Libp2pTransportQuic:
            return 40 + relayPenalty
        if addr.transport == types.Libp2pTransportTcp:
            return 50 + relayPenalty
        return 60 + relayPenalty
    if addr.networkDomain == types.Libp2pNetworkDomainBrowserWebrtc:
        if addr.transport == types.Libp2pTransportWebrtc:
            return 65 + relayPenalty
        return 66 + relayPenalty
    if addr.networkDomain == types.Libp2pNetworkDomainPublic:
        if addr.transport == types.Libp2pTransportQuic:
            return 70 + relayPenalty
        if addr.transport == types.Libp2pTransportTcp:
            return 80 + relayPenalty
        return 90 + relayPenalty
    return 200 + relayPenalty

fn Libp2pPeerRecordSelectEndpoint(record: Libp2pPeerRecord,
                                    trustedView: bool,
                                    out: var Libp2pPeerEndpoint): bool =
    var bestRank = 100000
    var bestPriority = -2147483647
    var found = false
    for i in 0..<record.endpoints.len:
        let endpoint = record.endpoints[i]
        let rank = Libp2pPeerEndpointRank(record, endpoint, trustedView)
        if rank >= 100000:
            continue
        let priority = endpoint.priority
        if !found || rank < bestRank || (rank == bestRank && priority > bestPriority):
            out = Libp2pPeerEndpointClone(endpoint)
            bestRank = rank
            bestPriority = priority
            found = true
    return found

fn Libp2pPeerstoreSelectEndpoint(store: Libp2pPeerstore,
                                   peerId: types.Libp2pPeerId,
                                   trustedView: bool,
                                   out: var Libp2pPeerEndpoint): bool =
    let pos = Libp2pPeerstorePos(store, peerId)
    if pos < 0:
        return false
    return Libp2pPeerRecordSelectEndpoint(store.peers[pos], trustedView, out)

fn Libp2pPeerstoreUpsert(store: var Libp2pPeerstore,
                           record: Libp2pPeerRecord) =
    var next: Libp2pPeerRecord
    next.peerId = record.peerId
    next.endpoints = []
    for i in 0..<record.endpoints.len:
        add(next.endpoints, Libp2pPeerEndpointClone(record.endpoints[i]))
    next.routingRole = record.routingRole
    next.connected = record.connected
    next.bootstrap = record.bootstrap
    next.trustedInfra = record.trustedInfra
    next.placementGroup = record.placementGroup
    next.replicaWithdrawn = record.replicaWithdrawn
    next.rttEwmaMicros = record.rttEwmaMicros
    next.lossPermille = record.lossPermille
    next.loadPermille = record.loadPermille
    next.trustPermille = record.trustPermille
    next.resources = resources.Libp2pNodeResourceClone(record.resources)
    next.cacheEntries = []
    for i in 0..<record.cacheEntries.len:
        add(next.cacheEntries, Libp2pPeerCacheEntryClone(record.cacheEntries[i]))
    next.relayEntries = []
    for i in 0..<record.relayEntries.len:
        add(next.relayEntries, Libp2pPeerRelayCacheEntryClone(record.relayEntries[i]))
    let targetPeerId = record.peerId
    let pos = Libp2pPeerstorePos(store, targetPeerId)
    if pos >= 0:
        store.peers[pos].peerId = next.peerId
        store.peers[pos].endpoints = []
        for i in 0..<next.endpoints.len:
            add(store.peers[pos].endpoints, Libp2pPeerEndpointClone(next.endpoints[i]))
        store.peers[pos].routingRole = next.routingRole
        store.peers[pos].connected = next.connected
        store.peers[pos].bootstrap = next.bootstrap
        store.peers[pos].trustedInfra = next.trustedInfra
        store.peers[pos].placementGroup = next.placementGroup
        store.peers[pos].replicaWithdrawn = next.replicaWithdrawn
        store.peers[pos].rttEwmaMicros = next.rttEwmaMicros
        store.peers[pos].lossPermille = next.lossPermille
        store.peers[pos].loadPermille = next.loadPermille
        store.peers[pos].trustPermille = next.trustPermille
        store.peers[pos].resources = resources.Libp2pNodeResourceClone(next.resources)
        store.peers[pos].cacheEntries = []
        for i in 0..<next.cacheEntries.len:
            add(store.peers[pos].cacheEntries, Libp2pPeerCacheEntryClone(next.cacheEntries[i]))
        store.peers[pos].relayEntries = []
        for i in 0..<next.relayEntries.len:
            add(store.peers[pos].relayEntries, Libp2pPeerRelayCacheEntryClone(next.relayEntries[i]))
        return
    let insert: Libp2pPeerRecord
    add(store.peers, insert)
    let idx = store.peers.len - 1
    store.peers[idx].peerId = next.peerId
    store.peers[idx].endpoints = []
    for i in 0..<next.endpoints.len:
        add(store.peers[idx].endpoints, Libp2pPeerEndpointClone(next.endpoints[i]))
    store.peers[idx].routingRole = next.routingRole
    store.peers[idx].connected = next.connected
    store.peers[idx].bootstrap = next.bootstrap
    store.peers[idx].trustedInfra = next.trustedInfra
    store.peers[idx].placementGroup = next.placementGroup
    store.peers[idx].replicaWithdrawn = next.replicaWithdrawn
    store.peers[idx].rttEwmaMicros = next.rttEwmaMicros
    store.peers[idx].lossPermille = next.lossPermille
    store.peers[idx].loadPermille = next.loadPermille
    store.peers[idx].trustPermille = next.trustPermille
    store.peers[idx].resources = resources.Libp2pNodeResourceClone(next.resources)
    store.peers[idx].cacheEntries = []
    for i in 0..<next.cacheEntries.len:
        add(store.peers[idx].cacheEntries, Libp2pPeerCacheEntryClone(next.cacheEntries[i]))
    store.peers[idx].relayEntries = []
    for i in 0..<next.relayEntries.len:
        add(store.peers[idx].relayEntries, Libp2pPeerRelayCacheEntryClone(next.relayEntries[i]))

fn Libp2pPeerstoreCount(store: Libp2pPeerstore): int32 =
    return store.peers.len
