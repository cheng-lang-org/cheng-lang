import std/times
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/resources
import cheng/libp2p/core/peerstore as ps

const
    v3Libp2pWorkloadOther: int32 = 0
    v3Libp2pWorkloadTrain: int32 = 1
    v3Libp2pWorkloadInfer: int32 = 2

type
    V3Libp2pWorkloadKind = int32

    V3Libp2pWorkloadRequest =
        workloadKind: V3Libp2pWorkloadKind
        stickyKey: str
        cacheHintManifestCid: str
        cacheHintBlobCid: str
        affinityKey: str
        affinityPeerId: types.V3Libp2pPeerId
        hasAffinityPeer: bool
        antiAffinityPeerId: types.V3Libp2pPeerId
        hasAntiAffinityPeer: bool
        preferPlacementGroupSpread: bool
        minCpuLogicalCores: int32
        minMemoryAvailableBytes: int64
        minDiskAvailableBytes: int64
        minGpuDeviceCount: int32
        minGpuCoreCount: int32
        minNpuDeviceCount: int32
        minNpuCoreCount: int32
        maxLoadPermille: int32
        minTrustPermille: int32
        maxSampleAgeSeconds: int64
        requireConnected: bool = true

    V3Libp2pPlacementScore =
        eligible: bool
        cpuSlack: int32
        memorySlackBytes: int64
        diskSlackBytes: int64
        gpuDeviceSlack: int32
        gpuCoreSlack: int32
        npuDeviceSlack: int32
        npuCoreSlack: int32
        loadPermille: int32
        trustPermille: int32
        rttEwmaMicros: int32
        cacheKeyMatches: int32
        cacheHitCount: int32
        cacheLastHitEpochSeconds: int64
        manifestCacheHit: bool
        blobCacheHit: bool
        cacheHit: bool

fn v3Libp2pWorkloadKindText(kind: V3Libp2pWorkloadKind): str =
    if kind == v3Libp2pWorkloadTrain:
        return "train"
    if kind == v3Libp2pWorkloadInfer:
        return "infer"
    return "other"

fn v3Libp2pPlacementPeerIdLess(left: types.V3Libp2pPeerId,
                               right: types.V3Libp2pPeerId): bool =
    for i in 0..<32:
        let lv = int32(left.value.data[i]) & 255
        let rv = int32(right.value.data[i]) & 255
        if lv < rv:
            return true
        if lv > rv:
            return false
    return false

fn v3Libp2pCompareRequestedSlackI32(requested: int32,
                                    leftSlack: int32,
                                    rightSlack: int32): int32 =
    if requested <= 0:
        return 0
    if leftSlack < rightSlack:
        return -1
    if leftSlack > rightSlack:
        return 1
    return 0

fn v3Libp2pCompareRequestedSlackI64(requested: int64,
                                    leftSlack: int64,
                                    rightSlack: int64): int32 =
    if requested <= int64(0):
        return 0
    if leftSlack < rightSlack:
        return -1
    if leftSlack > rightSlack:
        return 1
    return 0

fn v3Libp2pCompareLowerBetter(left: int32, right: int32): int32 =
    if left < right:
        return -1
    if left > right:
        return 1
    return 0

fn v3Libp2pCompareHigherBetter(left: int32, right: int32): int32 =
    if left > right:
        return -1
    if left < right:
        return 1
    return 0

fn v3Libp2pCompareLowerBetterI64(left: int64, right: int64): int32 =
    if left < right:
        return -1
    if left > right:
        return 1
    return 0

fn v3Libp2pCompareHigherBetterI64(left: int64, right: int64): int32 =
    if left > right:
        return -1
    if left < right:
        return 1
    return 0

fn v3Libp2pWorkloadHasCacheHint(request: V3Libp2pWorkloadRequest): bool =
    return len(request.cacheHintManifestCid) > 0 || len(request.cacheHintBlobCid) > 0

fn v3Libp2pNodeResourceFreshEnough(sample: types.V3Libp2pNodeResource,
                                   maxSampleAgeSeconds: int64): bool =
    if !resources.v3Libp2pNodeResourceVisible(sample):
        return false
    if maxSampleAgeSeconds <= int64(0):
        return true
    let now = times.EpochTimeSeconds()
    if sample.sampledAtEpochSeconds > now:
        return false
    return (now - sample.sampledAtEpochSeconds) <= maxSampleAgeSeconds

fn v3Libp2pNodeResourceSatisfies(sample: types.V3Libp2pNodeResource,
                                 request: V3Libp2pWorkloadRequest): bool =
    if !v3Libp2pNodeResourceFreshEnough(sample, request.maxSampleAgeSeconds):
        return false
    if sample.cpuLogicalCores < request.minCpuLogicalCores:
        return false
    if sample.memoryAvailableBytes < request.minMemoryAvailableBytes:
        return false
    if sample.diskAvailableBytes < request.minDiskAvailableBytes:
        return false
    if sample.gpuDeviceCount < request.minGpuDeviceCount:
        return false
    if sample.gpuCoreCount < request.minGpuCoreCount:
        return false
    if sample.npuDeviceCount < request.minNpuDeviceCount:
        return false
    if sample.npuCoreCount < request.minNpuCoreCount:
        return false
    return true

fn v3Libp2pPeerPlacementScoreFill(out: var V3Libp2pPlacementScore,
                                  record: ps.V3Libp2pPeerRecord,
                                  trustedView: bool,
                                  request: V3Libp2pWorkloadRequest): bool =
    out = V3Libp2pPlacementScore()
    if !trustedView:
        return false
    if request.requireConnected && !record.connected:
        return false
    if request.maxLoadPermille > 0 && record.loadPermille > request.maxLoadPermille:
        return false
    if request.minTrustPermille > 0 && record.trustPermille < request.minTrustPermille:
        return false
    let sample = record.resources
    if !v3Libp2pNodeResourceSatisfies(sample, request):
        return false
    out.eligible = true
    out.cpuSlack = sample.cpuLogicalCores - request.minCpuLogicalCores
    out.memorySlackBytes = sample.memoryAvailableBytes - request.minMemoryAvailableBytes
    out.diskSlackBytes = sample.diskAvailableBytes - request.minDiskAvailableBytes
    out.gpuDeviceSlack = sample.gpuDeviceCount - request.minGpuDeviceCount
    out.gpuCoreSlack = sample.gpuCoreCount - request.minGpuCoreCount
    out.npuDeviceSlack = sample.npuDeviceCount - request.minNpuDeviceCount
    out.npuCoreSlack = sample.npuCoreCount - request.minNpuCoreCount
    out.loadPermille = record.loadPermille
    out.trustPermille = record.trustPermille
    out.rttEwmaMicros = record.rttEwmaMicros
    if v3Libp2pWorkloadHasCacheHint(request):
        for i in 0..<record.cacheEntries.len:
            let entry = record.cacheEntries[i]
            if entry.residentBytes <= int64(0):
                continue
            let matchesManifest = len(request.cacheHintManifestCid) > 0 &&
              entry.cacheKey == request.cacheHintManifestCid
            let matchesBlob = len(request.cacheHintBlobCid) > 0 &&
              entry.cacheKey == request.cacheHintBlobCid
            if !matchesManifest && !matchesBlob:
                continue
            if matchesManifest:
                out.manifestCacheHit = true
            if matchesBlob:
                out.blobCacheHit = true
            out.cacheKeyMatches = out.cacheKeyMatches + 1
            out.cacheHitCount = out.cacheHitCount + entry.hitCount
            if out.cacheLastHitEpochSeconds <= int64(0) ||
              entry.lastHitEpochSeconds > out.cacheLastHitEpochSeconds:
                out.cacheLastHitEpochSeconds = entry.lastHitEpochSeconds
        out.cacheHit = out.manifestCacheHit || out.blobCacheHit
    return true

fn v3Libp2pPlacementCompareCommon(left: V3Libp2pPlacementScore,
                                  right: V3Libp2pPlacementScore,
                                  leftPeerId: types.V3Libp2pPeerId,
                                  rightPeerId: types.V3Libp2pPeerId): int32 =
    let loadCmp = v3Libp2pCompareLowerBetter(left.loadPermille, right.loadPermille)
    if loadCmp != 0:
        return loadCmp
    let trustCmp = v3Libp2pCompareHigherBetter(left.trustPermille, right.trustPermille)
    if trustCmp != 0:
        return trustCmp
    let rttCmp = v3Libp2pCompareLowerBetter(left.rttEwmaMicros, right.rttEwmaMicros)
    if rttCmp != 0:
        return rttCmp
    if v3Libp2pPlacementPeerIdLess(leftPeerId, rightPeerId):
        return -1
    if v3Libp2pPlacementPeerIdLess(rightPeerId, leftPeerId):
        return 1
    return 0

fn v3Libp2pWorkloadAffinityTargetFill(out: var types.V3Libp2pPeerId,
                                      request: V3Libp2pWorkloadRequest): bool =
    out = types.V3Libp2pPeerId()
    if request.hasAffinityPeer:
        out = request.affinityPeerId
        return true
    if len(request.affinityKey) <= 0:
        return false
    peer_id.v3Libp2pPeerIdFillFromSeed(out, "v3.libp2p.affinity|" + request.affinityKey)
    return true

fn v3Libp2pPlacementCompareAffinity(request: V3Libp2pWorkloadRequest,
                                    leftPeerId: types.V3Libp2pPeerId,
                                    rightPeerId: types.V3Libp2pPeerId): int32 =
    var target: types.V3Libp2pPeerId
    if !v3Libp2pWorkloadAffinityTargetFill(target, request):
        return 0
    let leftDist = peer_id.v3Libp2pPeerIdDistance(leftPeerId, target)
    let rightDist = peer_id.v3Libp2pPeerIdDistance(rightPeerId, target)
    return v3Libp2pCompareLowerBetterI64(leftDist, rightDist)

fn v3Libp2pPlacementCompareCache(left: V3Libp2pPlacementScore,
                                 right: V3Libp2pPlacementScore,
                                 request: V3Libp2pWorkloadRequest): int32 =
    if !v3Libp2pWorkloadHasCacheHint(request):
        return 0
    if left.cacheHit && !right.cacheHit:
        return -1
    if !left.cacheHit && right.cacheHit:
        return 1
    if !left.cacheHit && !right.cacheHit:
        return 0
    let matchCmp = v3Libp2pCompareHigherBetter(left.cacheKeyMatches, right.cacheKeyMatches)
    if matchCmp != 0:
        return matchCmp
    let hitCmp = v3Libp2pCompareHigherBetter(left.cacheHitCount, right.cacheHitCount)
    if hitCmp != 0:
        return hitCmp
    let freshCmp = v3Libp2pCompareHigherBetterI64(left.cacheLastHitEpochSeconds,
                                                  right.cacheLastHitEpochSeconds)
    if freshCmp != 0:
        return freshCmp
    return 0

fn v3Libp2pPlacementScoreAddedCacheCoverage(score: V3Libp2pPlacementScore,
                                            request: V3Libp2pWorkloadRequest,
                                            coveredManifest: bool,
                                            coveredBlob: bool): int32 =
    var out = 0
    if len(request.cacheHintManifestCid) > 0 && score.manifestCacheHit && !coveredManifest:
        out = out + 1
    if len(request.cacheHintBlobCid) > 0 && score.blobCacheHit && !coveredBlob:
        out = out + 1
    return out

fn v3Libp2pPlacementCompareTrain(left: V3Libp2pPlacementScore,
                                 right: V3Libp2pPlacementScore,
                                 request: V3Libp2pWorkloadRequest): int32 =
    let gpuCoreCmp = v3Libp2pCompareRequestedSlackI32(request.minGpuCoreCount,
                                                      left.gpuCoreSlack,
                                                      right.gpuCoreSlack)
    if gpuCoreCmp != 0:
        return gpuCoreCmp
    let npuCoreCmp = v3Libp2pCompareRequestedSlackI32(request.minNpuCoreCount,
                                                      left.npuCoreSlack,
                                                      right.npuCoreSlack)
    if npuCoreCmp != 0:
        return npuCoreCmp
    let gpuDeviceCmp = v3Libp2pCompareRequestedSlackI32(request.minGpuDeviceCount,
                                                        left.gpuDeviceSlack,
                                                        right.gpuDeviceSlack)
    if gpuDeviceCmp != 0:
        return gpuDeviceCmp
    let npuDeviceCmp = v3Libp2pCompareRequestedSlackI32(request.minNpuDeviceCount,
                                                        left.npuDeviceSlack,
                                                        right.npuDeviceSlack)
    if npuDeviceCmp != 0:
        return npuDeviceCmp
    let cpuCmp = v3Libp2pCompareRequestedSlackI32(request.minCpuLogicalCores,
                                                  left.cpuSlack,
                                                  right.cpuSlack)
    if cpuCmp != 0:
        return cpuCmp
    let memoryCmp = v3Libp2pCompareRequestedSlackI64(request.minMemoryAvailableBytes,
                                                     left.memorySlackBytes,
                                                     right.memorySlackBytes)
    if memoryCmp != 0:
        return memoryCmp
    return v3Libp2pCompareRequestedSlackI64(request.minDiskAvailableBytes,
                                            left.diskSlackBytes,
                                            right.diskSlackBytes)

fn v3Libp2pPlacementCompareInfer(left: V3Libp2pPlacementScore,
                                 right: V3Libp2pPlacementScore,
                                 request: V3Libp2pWorkloadRequest): int32 =
    let gpuCoreCmp = v3Libp2pCompareRequestedSlackI32(request.minGpuCoreCount,
                                                      left.gpuCoreSlack,
                                                      right.gpuCoreSlack)
    if gpuCoreCmp != 0:
        return gpuCoreCmp
    let npuCoreCmp = v3Libp2pCompareRequestedSlackI32(request.minNpuCoreCount,
                                                      left.npuCoreSlack,
                                                      right.npuCoreSlack)
    if npuCoreCmp != 0:
        return npuCoreCmp
    let memoryCmp = v3Libp2pCompareRequestedSlackI64(request.minMemoryAvailableBytes,
                                                     left.memorySlackBytes,
                                                     right.memorySlackBytes)
    if memoryCmp != 0:
        return memoryCmp
    let cpuCmp = v3Libp2pCompareRequestedSlackI32(request.minCpuLogicalCores,
                                                  left.cpuSlack,
                                                  right.cpuSlack)
    if cpuCmp != 0:
        return cpuCmp
    let gpuDeviceCmp = v3Libp2pCompareRequestedSlackI32(request.minGpuDeviceCount,
                                                        left.gpuDeviceSlack,
                                                        right.gpuDeviceSlack)
    if gpuDeviceCmp != 0:
        return gpuDeviceCmp
    let npuDeviceCmp = v3Libp2pCompareRequestedSlackI32(request.minNpuDeviceCount,
                                                        left.npuDeviceSlack,
                                                        right.npuDeviceSlack)
    if npuDeviceCmp != 0:
        return npuDeviceCmp
    return v3Libp2pCompareRequestedSlackI64(request.minDiskAvailableBytes,
                                            left.diskSlackBytes,
                                            right.diskSlackBytes)

fn v3Libp2pPlacementCompareOther(left: V3Libp2pPlacementScore,
                                 right: V3Libp2pPlacementScore,
                                 request: V3Libp2pWorkloadRequest): int32 =
    let cpuCmp = v3Libp2pCompareRequestedSlackI32(request.minCpuLogicalCores,
                                                  left.cpuSlack,
                                                  right.cpuSlack)
    if cpuCmp != 0:
        return cpuCmp
    let memoryCmp = v3Libp2pCompareRequestedSlackI64(request.minMemoryAvailableBytes,
                                                     left.memorySlackBytes,
                                                     right.memorySlackBytes)
    if memoryCmp != 0:
        return memoryCmp
    let diskCmp = v3Libp2pCompareRequestedSlackI64(request.minDiskAvailableBytes,
                                                   left.diskSlackBytes,
                                                   right.diskSlackBytes)
    if diskCmp != 0:
        return diskCmp
    let gpuCoreCmp = v3Libp2pCompareRequestedSlackI32(request.minGpuCoreCount,
                                                      left.gpuCoreSlack,
                                                      right.gpuCoreSlack)
    if gpuCoreCmp != 0:
        return gpuCoreCmp
    let npuCoreCmp = v3Libp2pCompareRequestedSlackI32(request.minNpuCoreCount,
                                                      left.npuCoreSlack,
                                                      right.npuCoreSlack)
    if npuCoreCmp != 0:
        return npuCoreCmp
    let gpuDeviceCmp = v3Libp2pCompareRequestedSlackI32(request.minGpuDeviceCount,
                                                        left.gpuDeviceSlack,
                                                        right.gpuDeviceSlack)
    if gpuDeviceCmp != 0:
        return gpuDeviceCmp
    return v3Libp2pCompareRequestedSlackI32(request.minNpuDeviceCount,
                                            left.npuDeviceSlack,
                                            right.npuDeviceSlack)

fn v3Libp2pPlacementScoreCompare(left: V3Libp2pPlacementScore,
                                 right: V3Libp2pPlacementScore,
                                 request: V3Libp2pWorkloadRequest,
                                 leftPeerId: types.V3Libp2pPeerId,
                                 rightPeerId: types.V3Libp2pPeerId): int32 =
    if !left.eligible:
        return !right.eligible ? 0 : 1
    if !right.eligible:
        return -1
    let cacheCmp = v3Libp2pPlacementCompareCache(left, right, request)
    if cacheCmp != 0:
        return cacheCmp
    var fitCmp = 0
    if request.workloadKind == v3Libp2pWorkloadTrain:
        fitCmp = v3Libp2pPlacementCompareTrain(left, right, request)
    elif request.workloadKind == v3Libp2pWorkloadInfer:
        fitCmp = v3Libp2pPlacementCompareInfer(left, right, request)
    else:
        fitCmp = v3Libp2pPlacementCompareOther(left, right, request)
    if fitCmp < 0:
        return -1
    if fitCmp > 0:
        return 1
    let affinityCmp = v3Libp2pPlacementCompareAffinity(request, leftPeerId, rightPeerId)
    if affinityCmp != 0:
        return affinityCmp
    return v3Libp2pPlacementCompareCommon(left, right, leftPeerId, rightPeerId)

fn v3Libp2pPlacementScoreBetter(left: V3Libp2pPlacementScore,
                                right: V3Libp2pPlacementScore,
                                request: V3Libp2pWorkloadRequest,
                                leftPeerId: types.V3Libp2pPeerId,
                                rightPeerId: types.V3Libp2pPeerId): bool =
    return v3Libp2pPlacementScoreCompare(left, right, request, leftPeerId, rightPeerId) < 0

fn v3Libp2pReplicaCandidateCompare(left: V3Libp2pPlacementScore,
                                   right: V3Libp2pPlacementScore,
                                   request: V3Libp2pWorkloadRequest,
                                   coveredManifest: bool,
                                   coveredBlob: bool,
                                   leftPeerId: types.V3Libp2pPeerId,
                                   rightPeerId: types.V3Libp2pPeerId): int32 =
    let leftAdded = v3Libp2pPlacementScoreAddedCacheCoverage(left,
                                                             request,
                                                             coveredManifest,
                                                             coveredBlob)
    let rightAdded = v3Libp2pPlacementScoreAddedCacheCoverage(right,
                                                              request,
                                                              coveredManifest,
                                                              coveredBlob)
    let coverageCmp = v3Libp2pCompareHigherBetter(leftAdded, rightAdded)
    if coverageCmp != 0:
        return coverageCmp
    return v3Libp2pPlacementScoreCompare(left, right, request, leftPeerId, rightPeerId)
