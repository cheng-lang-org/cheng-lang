import std/result
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id

type
    Libp2pSegmentRead =
        seg: str
        next: int32

fn Libp2pReadSegmentBytes(data: Bytes, start: int32): Result[Libp2pSegmentRead] =
    let dataLen = BytesLen(data)
    if start >= dataLen:
        return Err[Libp2pSegmentRead](" libp2p multiaddr: trailing slash")
    var i = start
    while i < dataLen:
        if BytesGet(data, i) == int32('/'):
            break
        i = i + 1
    var out: Libp2pSegmentRead
    let segBytes = BytesSliceView(data, start, i - start)
    let segText = BytesToString(segBytes)
    out.seg = segText
    out.next = i
    if i < dataLen:
        if BytesGet(data, i) == int32('/'):
            out.next = i + 1
    return Ok[Libp2pSegmentRead](out)

fn Libp2pReadSegment(text: str, start: int32): Result[Libp2pSegmentRead] =
    if start >= len(text):
        return Err[Libp2pSegmentRead](" libp2p multiaddr: trailing slash")
    var i = start
    while i < len(text):
        if text[i] == '/':
            break
        i = i + 1
    var out: Libp2pSegmentRead
    out.seg = Libp2pTextSlice(text, start, i - start)
    out.next = i
    if i < len(text):
        if text[i] == '/':
            out.next = i + 1
    return Ok[Libp2pSegmentRead](out)

fn Libp2pTextSlice(text: str, start: int32, count: int32): str =
    if count <= 0:
        return ""
    let out = BytesAlloc(count)
    for i in 0..<count:
        BytesSet(out, i, int32(text[start + i]))
    return BytesToString(out)

fn Libp2pParsePositiveI32(text: str): Result[int32] =
    if len(text) <= 0:
        return Err[int32](" libp2p multiaddr: empty number")
    var out = 0
    for i in 0..<len(text):
        let c = text[i]
        if c < '0' || c > '9':
            return Err[int32](" libp2p multiaddr: invalid number")
        out = out * 10 + (int32(c) - int32('0'))
    return Ok[int32](out)

fn Libp2pMultiaddrFillTcp(out: var types.Libp2pMultiaddr,
                            host: str,
                            port: int32) =
    out.raw = ""
    out.host = host
    out.port = port
    out.transport = types.Libp2pTransportTcp
    out.networkDomain = types.Libp2pNetworkDomainPublic
    out.visibility = types.Libp2pVisibilityPublic
    out.priority = 100
    out.secure = types.Libp2pSecureNoise
    out.mux = types.Libp2pMuxYamux
    out.hasPeerId = false

fn Libp2pMultiaddrFillQuic(out: var types.Libp2pMultiaddr,
                             host: str,
                             port: int32) =
    out.raw = ""
    out.host = host
    out.port = port
    out.transport = types.Libp2pTransportQuic
    out.networkDomain = types.Libp2pNetworkDomainPublic
    out.visibility = types.Libp2pVisibilityPublic
    out.priority = 100
    out.secure = types.Libp2pSecureTls
    out.mux = types.Libp2pMuxNone
    out.hasPeerId = false

fn Libp2pMultiaddrSetRoutingMeta(out: var types.Libp2pMultiaddr,
                                   networkDomain: types.Libp2pNetworkDomainKind,
                                   visibility: types.Libp2pVisibilityKind,
                                   priority: int32) =
    out.networkDomain = networkDomain
    out.visibility = visibility
    out.priority = priority

fn Libp2pMultiaddrVisible(addr: types.Libp2pMultiaddr,
                            trustedView: bool): bool =
    if addr.visibility == types.Libp2pVisibilityPublic:
        return true
    if addr.visibility == types.Libp2pVisibilityTrustedOnly:
        return trustedView
    return false

fn Libp2pMultiaddrEqual(left: types.Libp2pMultiaddr,
                          right: types.Libp2pMultiaddr): bool =
    if left.host != right.host:
        return false
    if left.port != right.port:
        return false
    if left.transport != right.transport:
        return false
    if left.networkDomain != right.networkDomain:
        return false
    if left.visibility != right.visibility:
        return false
    if left.secure != right.secure:
        return false
    if left.mux != right.mux:
        return false
    if left.priority != right.priority:
        return false
    return true

fn Libp2pMultiaddrFillFromBytes(out: var types.Libp2pMultiaddr,
                                  data: Bytes): Result[bool] =
    let dataLen = BytesLen(data)
    if dataLen <= 0:
        return Err[bool](" libp2p multiaddr: empty")
    if BytesGet(data, 0) != int32('/'):
        return Err[bool](" libp2p multiaddr: must start with slash")
    let hostProtoRes = Libp2pReadSegmentBytes(data, 1)
    if IsErr(hostProtoRes):
        return Err[bool](Error(hostProtoRes))
    let hostProto = Value(hostProtoRes)
    let hostProtoSeg = hostProto.seg
    if hostProtoSeg != "ip4" && hostProtoSeg != "ip6" &&
       hostProtoSeg != "dns" && hostProtoSeg != "dns4" &&
       hostProtoSeg != "dns6" && hostProtoSeg != "dnsaddr":
        return Err[bool](" libp2p multiaddr: unsupported host protocol")
    let hostRes = Libp2pReadSegmentBytes(data, hostProto.next)
    if IsErr(hostRes):
        return Err[bool](" libp2p multiaddr: host missing")
    let hostRead = Value(hostRes)
    let transportProtoRes = Libp2pReadSegmentBytes(data, hostRead.next)
    if IsErr(transportProtoRes):
        return Err[bool](" libp2p multiaddr: missing transport")
    let transportProto = Value(transportProtoRes)
    var port: int32
    var transport = types.Libp2pTransportNone
    var secure = types.Libp2pSecureNone
    var mux = types.Libp2pMuxNone
    var hasPeerId = false
    var peerId: types.Libp2pPeerId
    var idx = transportProto.next
    if transportProto.seg == "tcp":
        let tcpPortRes = Libp2pReadSegmentBytes(data, idx)
        if IsErr(tcpPortRes):
            return Err[bool](" libp2p multiaddr: tcp port missing")
        let tcpPort = Value(tcpPortRes)
        let portRes = Libp2pParsePositiveI32(tcpPort.seg)
        if IsErr(portRes):
            return Err[bool](Error(portRes))
        port = Value(portRes)
        transport = types.Libp2pTransportTcp
        secure = types.Libp2pSecureNoise
        mux = types.Libp2pMuxYamux
        idx = tcpPort.next
    elif transportProto.seg == "udp":
        let udpPortRes = Libp2pReadSegmentBytes(data, idx)
        if IsErr(udpPortRes):
            return Err[bool](" libp2p multiaddr: udp port missing")
        let udpPort = Value(udpPortRes)
        let portRes = Libp2pParsePositiveI32(udpPort.seg)
        if IsErr(portRes):
            return Err[bool](Error(portRes))
        port = Value(portRes)
        idx = udpPort.next
        if idx >= dataLen:
            return Err[bool](" libp2p multiaddr: missing quic transport")
        let secureOrQuicRes = Libp2pReadSegmentBytes(data, idx)
        if IsErr(secureOrQuicRes):
            return Err[bool](" libp2p multiaddr: missing quic transport")
        var quicProto = Value(secureOrQuicRes)
        idx = quicProto.next
        if quicProto.seg == "tls":
            if idx >= dataLen:
                return Err[bool](" libp2p multiaddr: missing quic transport")
            let quicRes = Libp2pReadSegmentBytes(data, idx)
            if IsErr(quicRes):
                return Err[bool](" libp2p multiaddr: missing quic transport")
            quicProto = Value(quicRes)
            idx = quicProto.next
        if quicProto.seg != "quic" && quicProto.seg != "quic-v1":
            return Err[bool](" libp2p multiaddr: unsupported udp protocol")
        transport = types.Libp2pTransportQuic
        secure = types.Libp2pSecureTls
        mux = types.Libp2pMuxNone
    else:
        return Err[bool](" libp2p multiaddr: unsupported transport")
    if idx < dataLen:
        let peerProtoRes = Libp2pReadSegmentBytes(data, idx)
        if IsErr(peerProtoRes):
            return Err[bool](Error(peerProtoRes))
        let peerProto = Value(peerProtoRes)
        if peerProto.seg != "p2p" && peerProto.seg != "ipfs":
            return Err[bool](" libp2p multiaddr: unsupported trailing protocol")
        let peerRes = Libp2pReadSegmentBytes(data, peerProto.next)
        if IsErr(peerRes):
            return Err[bool](" libp2p multiaddr: peer id missing")
        let peerRead = Value(peerRes)
        let peerFillRes = peer_id.Libp2pPeerIdFillFromText(peerId, peerRead.seg)
        if IsErr(peerFillRes):
            return Err[bool](Error(peerFillRes))
        hasPeerId = true
        idx = peerRead.next
    if idx < dataLen:
        return Err[bool](" libp2p multiaddr: unsupported trailing data")
    out.raw = BytesToString(data)
    out.encoded = data
    out.host = hostRead.seg
    out.port = port
    out.transport = transport
    out.networkDomain = types.Libp2pNetworkDomainPublic
    out.visibility = types.Libp2pVisibilityPublic
    out.priority = 100
    out.secure = secure
    out.mux = mux
    out.hasPeerId = hasPeerId
    out.peerId = peerId
    return Ok[bool](true)

fn Libp2pMultiaddrParseBytes(data: Bytes): Result[types.Libp2pMultiaddr] =
    var out: types.Libp2pMultiaddr
    let fillRes = Libp2pMultiaddrFillFromBytes(out, data)
    if IsErr(fillRes):
        return Err[types.Libp2pMultiaddr](Error(fillRes))
    return Ok[types.Libp2pMultiaddr](out)

fn Libp2pMultiaddrFillFromText(out: var types.Libp2pMultiaddr,
                                 text: str): Result[bool] =
    let encoded = BytesFromString(text)
    return Libp2pMultiaddrFillFromBytes(out, encoded)

fn Libp2pMultiaddrParse(text: str): Result[types.Libp2pMultiaddr] =
    var out: types.Libp2pMultiaddr
    let fillRes = Libp2pMultiaddrFillFromText(out, text)
    if IsErr(fillRes):
        return Err[types.Libp2pMultiaddr](Error(fillRes))
    return Ok[types.Libp2pMultiaddr](out)

fn Libp2pMultiaddrText(addr: types.Libp2pMultiaddr): str =
    return addr.raw

fn Libp2pMultiaddrClone(addr: types.Libp2pMultiaddr): types.Libp2pMultiaddr =
    var out: types.Libp2pMultiaddr
    out.raw = addr.raw
    out.encoded = addr.encoded
    out.host = addr.host
    out.port = addr.port
    out.transport = addr.transport
    out.networkDomain = addr.networkDomain
    out.visibility = addr.visibility
    out.priority = addr.priority
    out.secure = addr.secure
    out.mux = addr.mux
    out.hasPeerId = addr.hasPeerId
    out.peerId = addr.peerId
    return out
