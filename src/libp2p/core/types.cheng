import std/rawbytes
import cheng/std/bytes_layout as layout

const
    v3Libp2pTransportNone: int32 = 0
    v3Libp2pTransportTcp: int32 = 1
    v3Libp2pTransportQuic: int32 = 2
    v3Libp2pTransportWebrtc: int32 = 3

    v3Libp2pNetworkDomainPublic: int32 = 0
    v3Libp2pNetworkDomainTailnet: int32 = 1
    v3Libp2pNetworkDomainLan: int32 = 2
    v3Libp2pNetworkDomainBrowserWebrtc: int32 = 3

    v3Libp2pVisibilityPublic: int32 = 0
    v3Libp2pVisibilityTrustedOnly: int32 = 1
    v3Libp2pVisibilityLocalOnly: int32 = 2

    v3Libp2pReachabilityUnknown: int32 = 0
    v3Libp2pReachabilityDirect: int32 = 1
    v3Libp2pReachabilityRelayed: int32 = 2

    v3Libp2pSecureNone: int32 = 0
    v3Libp2pSecureNoise: int32 = 1
    v3Libp2pSecureTls: int32 = 2

    v3Libp2pMuxNone: int32 = 0
    v3Libp2pMuxYamux: int32 = 1

    v3Libp2pProtocolIdentify: int32 = 1
    v3Libp2pProtocolPing: int32 = 2
    v3Libp2pProtocolKad: int32 = 3
    v3Libp2pProtocolGossipsub: int32 = 4
    v3Libp2pProtocolStore: int32 = 5
    v3Libp2pProtocolSync: int32 = 6
    v3Libp2pProtocolIngress: int32 = 7
    v3Libp2pProtocolWitness: int32 = 8
    v3Libp2pProtocolContent: int32 = 9
    v3Libp2pProtocolWebrtcSignal: int32 = 10
    v3Libp2pProtocolPin: int32 = 11
    v3Libp2pProtocolBftProposal: int32 = 12
    v3Libp2pProtocolBftVote: int32 = 13
    v3Libp2pProtocolBftCommit: int32 = 14
    v3Libp2pProtocolBftStateSync: int32 = 15
    v3Libp2pProtocolRelayDescribe: int32 = 16
    v3Libp2pProtocolRelayLease: int32 = 17
    v3Libp2pProtocolDiLoCo: int32 = 18
    V3Libp2pProtocolDiLoCo: int32 = v3Libp2pProtocolDiLoCo
    v3Libp2pProtocolProxyTcp: int32 = 19
    V3Libp2pProtocolSync: int32 = v3Libp2pProtocolSync

    v3Libp2pRelayServiceNone: int32 = 0
    v3Libp2pRelayServiceStun: int32 = 1
    v3Libp2pRelayServiceTurn: int32 = 2
    v3Libp2pRelayServiceTsnet: int32 = 3

type
    V3Libp2pTransportKind = int32
    V3Libp2pNetworkDomainKind = int32
    V3Libp2pVisibilityKind = int32
    V3Libp2pReachabilityKind = int32
    V3Libp2pSecureKind = int32
    V3Libp2pMuxKind = int32
    V3Libp2pProtocolId = int32
    V3Libp2pConnId = int32
    V3Libp2pStreamId = int32
    V3Libp2pRelayServiceKind = int32

    V3Libp2pPeerId =
        value: layout.FixedBytes32

    V3Libp2pTopicId =
        value: layout.FixedBytes32

    V3Libp2pNodeResource =
        sampledAtEpochSeconds: int64
        cpuLogicalCores: int32
        memoryAvailableBytes: int64
        memoryTotalBytes: int64
        diskAvailableBytes: int64
        diskTotalBytes: int64
        gpuDeviceCount: int32
        gpuCoreCount: int32
        npuDeviceCount: int32
        npuCoreCount: int32

    V3Libp2pMultiaddr =
        raw: str
        encoded: Bytes
        host: str
        port: int32
        transport: V3Libp2pTransportKind
        networkDomain: V3Libp2pNetworkDomainKind
        visibility: V3Libp2pVisibilityKind
        priority: int32 = 100
        secure: V3Libp2pSecureKind
        mux: V3Libp2pMuxKind
        hasPeerId: bool
        peerId: V3Libp2pPeerId

    V3Libp2pRelayHealth =
        healthy: bool
        sampledAtEpochSeconds: int64
        successPermille: int32
        loadPermille: int32 = 1000
        capacityPermille: int32
        failureCooldownUntilEpochSeconds: int64
        lastError: str

    V3Libp2pRelayDescriptor =
        peerId: V3Libp2pPeerId
        serviceKind: V3Libp2pRelayServiceKind
        region: str
        endpointText: str
        authScope: str
        requiresLease: bool
        advertisedAtEpochSeconds: int64
        ttlSeconds: int32
        health: V3Libp2pRelayHealth

    V3Libp2pRelayLease =
        relayPeerId: V3Libp2pPeerId
        requesterPeerId: V3Libp2pPeerId
        serviceKind: V3Libp2pRelayServiceKind
        region: str
        endpointText: str
        username: str
        credential: str
        issuedAtEpochSeconds: int64
        expiresAtEpochSeconds: int64
        nonce: layout.FixedBytes32

fn v3Libp2pPeerIdEqual(a: V3Libp2pPeerId, b: V3Libp2pPeerId): bool =
    let left = a.value
    let right = b.value
    return layout.fixedBytes32Equal(left, right)

fn v3Libp2pTopicIdEqual(a: V3Libp2pTopicId, b: V3Libp2pTopicId): bool =
    let left = a.value
    let right = b.value
    return layout.fixedBytes32Equal(left, right)

fn v3Libp2pTransportText(kind: V3Libp2pTransportKind): str =
    if kind == v3Libp2pTransportTcp:
        return "tcp"
    if kind == v3Libp2pTransportQuic:
        return "quic"
    if kind == v3Libp2pTransportWebrtc:
        return "webrtc"
    return "none"

fn v3Libp2pNetworkDomainText(kind: V3Libp2pNetworkDomainKind): str =
    if kind == v3Libp2pNetworkDomainTailnet:
        return "tailnet"
    if kind == v3Libp2pNetworkDomainLan:
        return "lan"
    if kind == v3Libp2pNetworkDomainBrowserWebrtc:
        return "browser-webrtc"
    return "public"

fn v3Libp2pVisibilityText(kind: V3Libp2pVisibilityKind): str =
    if kind == v3Libp2pVisibilityTrustedOnly:
        return "trusted-only"
    if kind == v3Libp2pVisibilityLocalOnly:
        return "local-only"
    return "public"

fn v3Libp2pSecureText(kind: V3Libp2pSecureKind): str =
    if kind == v3Libp2pSecureNoise:
        return "noise"
    if kind == v3Libp2pSecureTls:
        return "tls"
    return "none"

fn v3Libp2pMuxText(kind: V3Libp2pMuxKind): str =
    if kind == v3Libp2pMuxYamux:
        return "yamux"
    return "none"

fn v3Libp2pRelayServiceText(kind: V3Libp2pRelayServiceKind): str =
    if kind == v3Libp2pRelayServiceStun:
        return "stun"
    if kind == v3Libp2pRelayServiceTurn:
        return "turn"
    if kind == v3Libp2pRelayServiceTsnet:
        return "tsnet"
    return "none"

fn v3Libp2pRelayServiceRequiresLease(kind: V3Libp2pRelayServiceKind): bool =
    if kind == v3Libp2pRelayServiceTurn:
        return true
    if kind == v3Libp2pRelayServiceTsnet:
        return true
    return false

fn v3Libp2pRelayDescriptorActiveAt(descriptor: V3Libp2pRelayDescriptor,
                                   epochSeconds: int64): bool =
    if descriptor.serviceKind == v3Libp2pRelayServiceNone:
        return false
    if len(descriptor.endpointText) <= 0:
        return false
    if descriptor.ttlSeconds <= 0:
        return false
    if descriptor.advertisedAtEpochSeconds <= int64(0):
        return false
    if epochSeconds < descriptor.advertisedAtEpochSeconds:
        return false
    return epochSeconds <= descriptor.advertisedAtEpochSeconds + int64(descriptor.ttlSeconds)

fn v3Libp2pRelayLeaseActiveAt(lease: V3Libp2pRelayLease,
                              epochSeconds: int64): bool =
    if lease.serviceKind == v3Libp2pRelayServiceNone:
        return false
    if len(lease.endpointText) <= 0:
        return false
    if lease.issuedAtEpochSeconds <= int64(0):
        return false
    if lease.expiresAtEpochSeconds < lease.issuedAtEpochSeconds:
        return false
    if epochSeconds < lease.issuedAtEpochSeconds:
        return false
    return epochSeconds <= lease.expiresAtEpochSeconds

fn v3Libp2pProtocolWireText(protocol: V3Libp2pProtocolId): str =
    if protocol == v3Libp2pProtocolIdentify:
        return "/ipfs/id/1.0.0"
    if protocol == v3Libp2pProtocolPing:
        return "/ipfs/ping/1.0.0"
    if protocol == v3Libp2pProtocolKad:
        return "/ipfs/kad/1.0.0"
    if protocol == v3Libp2pProtocolGossipsub:
        return "/meshsub/1.1.0"
    if protocol == v3Libp2pProtocolStore:
        return "/cheng/store/1.0.0"
    if protocol == v3Libp2pProtocolSync:
        return "/cheng/sync/1.0.0"
    if protocol == v3Libp2pProtocolIngress:
        return "/cheng/ingress/1.0.0"
    if protocol == v3Libp2pProtocolWitness:
        return "/cheng/witness/1.0.0"
    if protocol == v3Libp2pProtocolContent:
        return "/cheng/content/1.0.0"
    if protocol == v3Libp2pProtocolWebrtcSignal:
        return "/cheng/webrtc-signal/1.0.0"
    if protocol == v3Libp2pProtocolPin:
        return "/cheng/pin/1.0.0"
    if protocol == v3Libp2pProtocolBftProposal:
        return "/cheng/bft-proposal/1.0.0"
    if protocol == v3Libp2pProtocolBftVote:
        return "/cheng/bft-vote/1.0.0"
    if protocol == v3Libp2pProtocolBftCommit:
        return "/cheng/bft-commit/1.0.0"
    if protocol == v3Libp2pProtocolBftStateSync:
        return "/cheng/bft-state-sync/1.0.0"
    if protocol == v3Libp2pProtocolRelayDescribe:
        return "/cheng/relay-describe/1.0.0"
    if protocol == v3Libp2pProtocolRelayLease:
        return "/cheng/relay-lease/1.0.0"
    if protocol == v3Libp2pProtocolDiLoCo:
        return "/cheng/diloco/1.0.0"
    if protocol == v3Libp2pProtocolProxyTcp:
        return "/cheng/proxy/tcp/1.0.0"
    return "/cheng/unknown/0.0.0"

fn V3Libp2pPeerIdEqual(a: V3Libp2pPeerId, b: V3Libp2pPeerId): bool =
    return v3Libp2pPeerIdEqual(a, b)
