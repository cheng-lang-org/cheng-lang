import std/result
import std/rawbytes
import std/strings
import std/multiformats/base58
import std/crypto/sha256
import std/crypto/sha512
import std/crypto/ed25519/ref10
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types
import std/strutils as strutil

const
    Libp2pEd25519KeyType: int32 = 1
    Libp2pEd25519PubKeySize: int32 = 32
    Libp2pPeerProtoSize: int32 = 36
    Libp2pPeerIdBytesSize: int32 = 38
    Libp2pPeerIdIdentityCode: int32 = 0

fn Libp2pEncodeBase58(data: Bytes): str =
    return base58.EncodeBase58(data)

fn Libp2pDecodeBase58(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Err[Bytes](" libp2p peer: empty peer text")
    let decoded = base58.DecodeBase58(text)
    if IsErr(decoded):
        return Err[Bytes](" libp2p peer: invalid peer text")
    if BytesLen(Value(decoded)) <= 0:
        return Err[Bytes](" libp2p peer: invalid peer text")
    return decoded

fn Libp2pPeerSeedBytes(seed: str): Bytes =
    return sha256.Sha256Digest(BytesFromString(strutil.Join(["cheng.libp2p.peer|", seed], "")))

fn Libp2pClampEd25519Scalar(out: var Bytes) =
    if BytesLen(out) != Libp2pEd25519PubKeySize:
        return
    BytesSet(out, 0, BytesGet(out, 0) & 248)
    BytesSet(out, 31, (BytesGet(out, 31) & 63) | 64)

fn Libp2pPeerPublicKeyValid(pubKeyBytes: Bytes): bool =
    if BytesLen(pubKeyBytes) != Libp2pEd25519PubKeySize:
        return false
    var point: ref10.GeP3
    return ref10.GeFromBytesNegateVartime(point, pubKeyBytes)

fn Libp2pPeerPublicKeyFromSeedBytes(seedBytes: Bytes): Result[layout.FixedBytes32] =
    if BytesLen(seedBytes) != Libp2pEd25519PubKeySize:
        return Err[layout.FixedBytes32](" libp2p peer: invalid seed size")
    let expanded = sha512.Sha512Digest(seedBytes)
    if BytesLen(expanded) < Libp2pEd25519PubKeySize:
        return Err[layout.FixedBytes32](" libp2p peer: invalid expanded seed")
    var scalar = BytesSlice(expanded, 0, Libp2pEd25519PubKeySize)
    Libp2pClampEd25519Scalar(scalar)
    var point: ref10.GeP3
    ref10.GeScalarMultBase(point, scalar)
    return layout.FixedBytes32FromBytes(ref10.GeP3ToBytes(point))

fn Libp2pPeerProtoBytes(pubKey: layout.FixedBytes32): Bytes =
    let out = BytesAlloc(Libp2pPeerProtoSize)
    let pubKeyBytes = layout.FixedBytes32ToBytes(pubKey)
    BytesSet(out, 0, 0x08)
    BytesSet(out, 1, Libp2pEd25519KeyType)
    BytesSet(out, 2, 0x12)
    BytesSet(out, 3, 0x20)
    for i in 0..<Libp2pEd25519PubKeySize:
        BytesSet(out, 4 + i, BytesGet(pubKeyBytes, i))
    return out

fn Libp2pPeerIdBytes(pubKey: layout.FixedBytes32): Bytes =
    let out = BytesAlloc(Libp2pPeerIdBytesSize)
    let protoBytes = Libp2pPeerProtoBytes(pubKey)
    BytesSet(out, 0, Libp2pPeerIdIdentityCode)
    BytesSet(out, 1, Libp2pPeerProtoSize)
    for i in 0..<Libp2pPeerProtoSize:
        BytesSet(out, 2 + i, BytesGet(protoBytes, i))
    return out

fn Libp2pPeerPublicKeyFromPeerIdBytes(peerIdBytes: Bytes): Result[layout.FixedBytes32] =
    if BytesLen(peerIdBytes) != Libp2pPeerIdBytesSize:
        return Err[layout.FixedBytes32](" libp2p peer: invalid peer id size")
    if BytesGet(peerIdBytes, 0) != Libp2pPeerIdIdentityCode:
        return Err[layout.FixedBytes32](" libp2p peer: unsupported multihash")
    if BytesGet(peerIdBytes, 1) != Libp2pPeerProtoSize:
        return Err[layout.FixedBytes32](" libp2p peer: invalid peer id payload")
    if BytesGet(peerIdBytes, 2) != 0x08 ||
       BytesGet(peerIdBytes, 3) != Libp2pEd25519KeyType ||
       BytesGet(peerIdBytes, 4) != 0x12 ||
       BytesGet(peerIdBytes, 5) != 0x20:
        return Err[layout.FixedBytes32](" libp2p peer: unsupported key protobuf")
    let pubKeyBytes = BytesSlice(peerIdBytes, 6, Libp2pEd25519PubKeySize)
    if !Libp2pPeerPublicKeyValid(pubKeyBytes):
        return Err[layout.FixedBytes32](" libp2p peer: invalid ed25519 public key")
    return layout.FixedBytes32FromBytes(pubKeyBytes)

fn Libp2pPeerIdBytesFromText(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Err[Bytes](" libp2p peer: empty peer text")
    if text[0] == 'z':
        if len(text) <= 1:
            return Err[Bytes](" libp2p peer: invalid peer text")
        return Libp2pDecodeBase58(strings.SliceBytes(text, 1, len(text) - 1))
    return Libp2pDecodeBase58(text)

fn Libp2pPeerIdFillFromSeed(out: var types.Libp2pPeerId, seed: str) =
    let pubKeyRes = Libp2pPeerPublicKeyFromSeedBytes(Libp2pPeerSeedBytes(seed))
    if IsErr(pubKeyRes):
        out = types.Libp2pPeerId()
        return
    out.value = Value(pubKeyRes)

fn Libp2pPeerIdFillFromText(out: var types.Libp2pPeerId, text: str): Result[bool] =
    let peerIdBytesRes = Libp2pPeerIdBytesFromText(text)
    if IsErr(peerIdBytesRes):
        return Err[bool](Error(peerIdBytesRes))
    let pubKeyRes = Libp2pPeerPublicKeyFromPeerIdBytes(Value(peerIdBytesRes))
    if IsErr(pubKeyRes):
        return Err[bool](Error(pubKeyRes))
    out.value = Value(pubKeyRes)
    return Ok[bool](true)

fn Libp2pPeerIdFromBytes(data: Bytes): types.Libp2pPeerId =
    var out: types.Libp2pPeerId
    if BytesLen(data) == Libp2pEd25519PubKeySize && Libp2pPeerPublicKeyValid(data):
        let fixedRes = layout.FixedBytes32FromBytes(data)
        if IsOk(fixedRes):
            out.value = Value(fixedRes)
            return out
    let hashed = sha256.Sha256Digest(data)
    let pubKeyRes = Libp2pPeerPublicKeyFromSeedBytes(hashed)
    if IsOk(pubKeyRes):
        out.value = Value(pubKeyRes)
    return out

fn Libp2pPeerIdFromSeed(seed: str): types.Libp2pPeerId =
    var out: types.Libp2pPeerId
    Libp2pPeerIdFillFromSeed(out, seed)
    return out

fn Libp2pPeerIdFromText(text: str): Result[types.Libp2pPeerId] =
    var out: types.Libp2pPeerId
    let fillRes = Libp2pPeerIdFillFromText(out, text)
    if IsErr(fillRes):
        return Err[types.Libp2pPeerId](Error(fillRes))
    return Ok[types.Libp2pPeerId](out)

fn Libp2pPeerIdText(peerId: types.Libp2pPeerId): str =
    return Libp2pEncodeBase58(Libp2pPeerIdBytes(peerId.value))

fn Libp2pPeerIdDistance(left: types.Libp2pPeerId,
                          right: types.Libp2pPeerId): int64 =
    var out: int64 = int64(0)
    for i in 0..<4:
        let lv = int32(left.value.data[i]) & 255
        let rv = int32(right.value.data[i]) & 255
        out = (out << 8) | int64(lv ^ rv)
    return out
