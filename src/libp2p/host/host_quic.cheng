import std/result
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/core/multistream
import cheng/libp2p/protocols/store_sync
import cheng/libp2p/transports/quic_transport
import cheng/libp2p/host/host as host_base

fn v3Libp2pQuicExchange(remoteHost: var host_base.V3Libp2pHost,
                        remoteAddr: types.V3Libp2pMultiaddr,
                        protocol: types.V3Libp2pProtocolId,
                        requestPayload: Bytes,
                        outPayload: var Bytes): Result[bool] =
    var pair: quic_transport.V3Libp2pQuicLoopbackPair
    let openRes = quic_transport.v3Libp2pQuicLoopbackOpenInto(pair, remoteAddr)
    if IsErr(openRes):
        return Err[bool]("v3 libp2p quic: open: " + ErrorText(openRes))
    let selectBytes = multistream.v3Libp2pMultistreamSelectBytes(protocol)
    let selectWriteRes = quic_transport.v3Libp2pQuicLoopbackWriteClient(pair, selectBytes)
    if IsErr(selectWriteRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: select write: " + ErrorText(selectWriteRes))
    let selectReadRes = quic_transport.v3Libp2pQuicLoopbackReadServer(pair, bytesLen(selectBytes))
    if IsErr(selectReadRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: select read: " + ErrorText(selectReadRes))
    if !multistream.v3Libp2pMultistreamAccepts(Value(selectReadRes), protocol):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: select mismatch")
    let requestWriteRes = quic_transport.v3Libp2pQuicLoopbackWriteClient(pair, requestPayload)
    if IsErr(requestWriteRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: request write: " + ErrorText(requestWriteRes))
    let requestReadRes = quic_transport.v3Libp2pQuicLoopbackReadServer(pair, bytesLen(requestPayload))
    if IsErr(requestReadRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: request read: " + ErrorText(requestReadRes))
    var serverRequestPayload: Bytes
    serverRequestPayload = Value(requestReadRes)
    let servePayloadRes = host_base.v3Libp2pServePayload(remoteHost, protocol, serverRequestPayload)
    if IsErr(servePayloadRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: serve: " + ErrorText(servePayloadRes))
    var responsePayload: Bytes
    responsePayload = Value(servePayloadRes)
    let responseWriteRes = quic_transport.v3Libp2pQuicLoopbackWriteServer(pair, responsePayload)
    if IsErr(responseWriteRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: response write: " + ErrorText(responseWriteRes))
    let responseReadRes = quic_transport.v3Libp2pQuicLoopbackReadClient(pair, bytesLen(responsePayload))
    quic_transport.v3Libp2pQuicLoopbackClose(pair)
    if IsErr(responseReadRes):
        return Err[bool]("v3 libp2p quic: response read: " + ErrorText(responseReadRes))
    var clientResponsePayload: Bytes
    clientResponsePayload = Value(responseReadRes)
    outPayload = clientResponsePayload
    return Ok[bool](true)

fn v3Libp2pRequestResponse(localHost: var host_base.V3Libp2pHost,
                           remoteHost: var host_base.V3Libp2pHost,
                           remotePeerId: types.V3Libp2pPeerId,
                           protocol: types.V3Libp2pProtocolId,
                           requestPayload: Bytes,
                           outPayload: var Bytes): Result[bool] =
    if !types.v3Libp2pPeerIdEqual(remoteHost.selfPeerId, remotePeerId):
        return Err[bool]("v3 libp2p host: peer mismatch")
    if !host_base.v3Libp2pProtocolRegistered(remoteHost, protocol):
        return Err[bool]("v3 libp2p host: remote protocol handler missing")
    var endpoint: ps.V3Libp2pPeerEndpoint
    let endpointRes = host_base.v3Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[bool](Error(endpointRes))
    let remoteAddr = multiaddr.v3Libp2pMultiaddrClone(endpoint.addr)
    if remoteAddr.transport != types.v3Libp2pTransportQuic:
        return host_base.v3Libp2pRequestResponse(localHost,
                                                 remoteHost,
                                                 remotePeerId,
                                                 protocol,
                                                 requestPayload,
                                                 outPayload)
    let streamRes = host_base.v3Libp2pOpenStream(localHost, remotePeerId, protocol)
    if IsErr(streamRes):
        return Err[bool](Error(streamRes))
    if protocol == types.v3Libp2pProtocolSync:
        localHost.syncRequestCount = localHost.syncRequestCount + 1
    return v3Libp2pQuicExchange(remoteHost, remoteAddr, protocol, requestPayload, outPayload)

fn v3Libp2pSyncRequest(localHost: var host_base.V3Libp2pHost,
                       remoteHost: var host_base.V3Libp2pHost,
                       remotePeerId: types.V3Libp2pPeerId,
                       query: overlay.V3StoreQuery,
                       out: var overlay.V3IngressEnvelope[]): Result[bool] =
    if !types.v3Libp2pPeerIdEqual(remoteHost.selfPeerId, remotePeerId):
        return Err[bool]("v3 libp2p host: sync peer mismatch")
    if !host_base.v3Libp2pProtocolRegistered(remoteHost, types.v3Libp2pProtocolSync):
        return Err[bool]("v3 libp2p host: remote sync handler missing")
    let streamRes = host_base.v3Libp2pOpenStream(localHost, remotePeerId, types.v3Libp2pProtocolSync)
    if IsErr(streamRes):
        return Err[bool](Error(streamRes))
    localHost.syncRequestCount = localHost.syncRequestCount + 1
    let requestPayload = store_sync.v3Libp2pStoreQueryEncode(query)
    var endpoint: ps.V3Libp2pPeerEndpoint
    let endpointRes = host_base.v3Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[bool](Error(endpointRes))
    let remoteAddr = multiaddr.v3Libp2pMultiaddrClone(endpoint.addr)
    if remoteAddr.transport != types.v3Libp2pTransportQuic:
        return host_base.v3Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, out)
    var pair: quic_transport.V3Libp2pQuicLoopbackPair
    let openRes = quic_transport.v3Libp2pQuicLoopbackOpenInto(pair, remoteAddr)
    if IsErr(openRes):
        return Err[bool]("v3 libp2p quic: open: " + ErrorText(openRes))
    let selectRes = quic_transport.v3Libp2pQuicLoopbackSelectProtocol(pair, types.v3Libp2pProtocolSync)
    if IsErr(selectRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: select: " + ErrorText(selectRes))
    let requestWriteRes = quic_transport.v3Libp2pQuicLoopbackWriteClient(pair, requestPayload)
    if IsErr(requestWriteRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: request write: " + ErrorText(requestWriteRes))
    let requestReadRes = quic_transport.v3Libp2pQuicLoopbackReadServer(pair, bytesLen(requestPayload))
    if IsErr(requestReadRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: request read: " + ErrorText(requestReadRes))
    var serverRequestPayload: Bytes
    serverRequestPayload = Value(requestReadRes)
    let servePayloadRes = host_base.v3Libp2pSyncServePayload(remoteHost, serverRequestPayload)
    if IsErr(servePayloadRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: serve: " + ErrorText(servePayloadRes))
    var servePayload: Bytes
    servePayload = Value(servePayloadRes)
    let responseWriteRes = quic_transport.v3Libp2pQuicLoopbackWriteServer(pair, servePayload)
    if IsErr(responseWriteRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: response write: " + ErrorText(responseWriteRes))
    let responseReadRes = quic_transport.v3Libp2pQuicLoopbackReadClient(pair, bytesLen(servePayload))
    quic_transport.v3Libp2pQuicLoopbackClose(pair)
    if IsErr(responseReadRes):
        return Err[bool]("v3 libp2p quic: response read: " + ErrorText(responseReadRes))
    var responsePayload: Bytes
    responsePayload = Value(responseReadRes)
    out = []
    let decodeRes = store_sync.v3Libp2pStoreEntriesDecodeFill(responsePayload, out)
    if IsErr(decodeRes):
        return Err[bool](Error(decodeRes))
    return Ok[bool](true)
