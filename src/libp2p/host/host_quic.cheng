import std/result
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/core/multistream
import cheng/libp2p/protocols/store_sync
import cheng/libp2p/transports/quic_transport
import cheng/libp2p/host/host as host_base
import std/strutils as strutil

fn Libp2pQuicExchange(remoteHost: var host_base.Libp2pHost,
                        remoteAddr: types.Libp2pMultiaddr,
                        protocol: types.Libp2pProtocolId,
                        requestPayload: Bytes,
                        outPayload: var Bytes): Result[bool] =
    var pair: quic_transport.Libp2pQuicLoopbackPair
    let openRes = quic_transport.Libp2pQuicLoopbackOpenInto(pair, remoteAddr)
    if IsErr(openRes):
        return Err[bool](strutil.Join([" libp2p quic: open: ", ErrorText(openRes)], ""))
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let selectWriteRes = quic_transport.Libp2pQuicLoopbackWriteClient(pair, selectBytes)
    if IsErr(selectWriteRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: select write: ", ErrorText(selectWriteRes)], ""))
    let selectReadRes = quic_transport.Libp2pQuicLoopbackReadServer(pair, BytesLen(selectBytes))
    if IsErr(selectReadRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: select read: ", ErrorText(selectReadRes)], ""))
    if !multistream.Libp2pMultistreamAccepts(Value(selectReadRes), protocol):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](" libp2p quic: select mismatch")
    let requestWriteRes = quic_transport.Libp2pQuicLoopbackWriteClient(pair, requestPayload)
    if IsErr(requestWriteRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: request write: ", ErrorText(requestWriteRes)], ""))
    let requestReadRes = quic_transport.Libp2pQuicLoopbackReadServer(pair, BytesLen(requestPayload))
    if IsErr(requestReadRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: request read: ", ErrorText(requestReadRes)], ""))
    var serverRequestPayload: Bytes
    serverRequestPayload = Value(requestReadRes)
    let servePayloadRes = host_base.Libp2pServePayload(remoteHost, protocol, serverRequestPayload)
    if IsErr(servePayloadRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: serve: ", ErrorText(servePayloadRes)], ""))
    var responsePayload: Bytes
    responsePayload = Value(servePayloadRes)
    let responseWriteRes = quic_transport.Libp2pQuicLoopbackWriteServer(pair, responsePayload)
    if IsErr(responseWriteRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: response write: ", ErrorText(responseWriteRes)], ""))
    let responseReadRes = quic_transport.Libp2pQuicLoopbackReadClient(pair, BytesLen(responsePayload))
    quic_transport.Libp2pQuicLoopbackClose(pair)
    if IsErr(responseReadRes):
        return Err[bool](strutil.Join([" libp2p quic: response read: ", ErrorText(responseReadRes)], ""))
    var clientResponsePayload: Bytes
    clientResponsePayload = Value(responseReadRes)
    outPayload = clientResponsePayload
    return Ok[bool](true)

fn Libp2pHostQuicRequestResponse(localHost: var host_base.Libp2pHost,
                                   remoteHost: var host_base.Libp2pHost,
                                   remotePeerId: types.Libp2pPeerId,
                                   protocol: types.Libp2pProtocolId,
                                   requestPayload: Bytes,
                                   outPayload: var Bytes): Result[bool] =
    if !types.Libp2pPeerIdEqual(remoteHost.selfPeerId, remotePeerId):
        return Err[bool](" libp2p host: peer mismatch")
    if !host_base.Libp2pProtocolRegistered(remoteHost, protocol):
        return Err[bool](" libp2p host: remote protocol handler missing")
    var endpoint: ps.Libp2pPeerEndpoint
    let endpointRes = host_base.Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[bool](Error(endpointRes))
    let remoteAddr = multiaddr.Libp2pMultiaddrClone(endpoint.addr)
    if remoteAddr.transport != types.Libp2pTransportQuic:
        return host_base.Libp2pRequestResponse(localHost,
                                                 remoteHost,
                                                 remotePeerId,
                                                 protocol,
                                                 requestPayload,
                                                 outPayload)
    let streamRes = host_base.Libp2pOpenStream(localHost, remotePeerId, protocol)
    if IsErr(streamRes):
        return Err[bool](Error(streamRes))
    if protocol == types.Libp2pProtocolSync:
        localHost.syncRequestCount = localHost.syncRequestCount + 1
    return Libp2pQuicExchange(remoteHost, remoteAddr, protocol, requestPayload, outPayload)

fn Libp2pQuicSyncRequest(localHost: var host_base.Libp2pHost,
                           remoteHost: var host_base.Libp2pHost,
                           remotePeerId: types.Libp2pPeerId,
                           query: overlay.StoreQuery,
                           out: var overlay.IngressEnvelope[]): Result[bool] =
    if !types.Libp2pPeerIdEqual(remoteHost.selfPeerId, remotePeerId):
        return Err[bool](" libp2p host: sync peer mismatch")
    if !host_base.Libp2pProtocolRegistered(remoteHost, types.Libp2pProtocolSync):
        return Err[bool](" libp2p host: remote sync handler missing")
    let streamRes = host_base.Libp2pOpenStream(localHost, remotePeerId, types.Libp2pProtocolSync)
    if IsErr(streamRes):
        return Err[bool](Error(streamRes))
    localHost.syncRequestCount = localHost.syncRequestCount + 1
    let requestPayload = store_sync.Libp2pStoreQueryEncode(query)
    var endpoint: ps.Libp2pPeerEndpoint
    let endpointRes = host_base.Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[bool](Error(endpointRes))
    let remoteAddr = multiaddr.Libp2pMultiaddrClone(endpoint.addr)
    if remoteAddr.transport != types.Libp2pTransportQuic:
        return host_base.Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, out)
    var pair: quic_transport.Libp2pQuicLoopbackPair
    let openRes = quic_transport.Libp2pQuicLoopbackOpenInto(pair, remoteAddr)
    if IsErr(openRes):
        return Err[bool](strutil.Join([" libp2p quic: open: ", ErrorText(openRes)], ""))
    let selectRes = quic_transport.Libp2pQuicLoopbackSelectProtocol(pair, types.Libp2pProtocolSync)
    if IsErr(selectRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: select: ", ErrorText(selectRes)], ""))
    let requestWriteRes = quic_transport.Libp2pQuicLoopbackWriteClient(pair, requestPayload)
    if IsErr(requestWriteRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: request write: ", ErrorText(requestWriteRes)], ""))
    let requestReadRes = quic_transport.Libp2pQuicLoopbackReadServer(pair, BytesLen(requestPayload))
    if IsErr(requestReadRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: request read: ", ErrorText(requestReadRes)], ""))
    var serverRequestPayload: Bytes
    serverRequestPayload = Value(requestReadRes)
    let servePayloadRes = host_base.Libp2pSyncServePayload(remoteHost, serverRequestPayload)
    if IsErr(servePayloadRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: serve: ", ErrorText(servePayloadRes)], ""))
    var servePayload: Bytes
    servePayload = Value(servePayloadRes)
    let responseWriteRes = quic_transport.Libp2pQuicLoopbackWriteServer(pair, servePayload)
    if IsErr(responseWriteRes):
        quic_transport.Libp2pQuicLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p quic: response write: ", ErrorText(responseWriteRes)], ""))
    let responseReadRes = quic_transport.Libp2pQuicLoopbackReadClient(pair, BytesLen(servePayload))
    quic_transport.Libp2pQuicLoopbackClose(pair)
    if IsErr(responseReadRes):
        return Err[bool](strutil.Join([" libp2p quic: response read: ", ErrorText(responseReadRes)], ""))
    var responsePayload: Bytes
    responsePayload = Value(responseReadRes)
    out = []
    let decodeRes = store_sync.Libp2pStoreEntriesDecodeFill(responsePayload, out)
    if IsErr(decodeRes):
        return Err[bool](Error(decodeRes))
    return Ok[bool](true)
