import std/result
import std/rawbytes
import std/os
import cheng/libp2p/core/multistream
import cheng/libp2p/core/multiaddr as core_multiaddr
import cheng/libp2p/core/types
import cheng/quic/multiaddress as qaddr
import cheng/quic/connection as qconn
import cheng/quic/msquictransport_native as qtransport
import cheng/quic/tls/policy as qpolicy
import cheng/quic/tls/test_pki as testpki
import std/strutils as strutil

type
    Libp2pQuicTransportConfig =
        secure: types.Libp2pSecureKind
        nativeStreams: bool

    Libp2pQuicLoopbackPair =
        listener: qtransport.MsQuicTransport
        client: qtransport.MsQuicTransport
        listenAddr: qaddr.MultiAddress
        outbound: qconn.Connection
        inbound: qconn.Connection

const
    Libp2pQuicOneShotHandshakeTimeoutMs = 2000
    Libp2pQuicOneShotIdleTimeoutMs = 5000
    Libp2pQuicOneShotDisconnectTimeoutMs = 1000

fn Libp2pQuicTransportConfigDefault(): Libp2pQuicTransportConfig =
    return Libp2pQuicTransportConfig(
        secure: types.Libp2pSecureTls,
        nativeStreams: true
    )

fn Libp2pQuicTransportSupportsAddr(addr: types.Libp2pMultiaddr): bool =
    if addr.transport != types.Libp2pTransportQuic:
        return false
    if addr.secure != types.Libp2pSecureTls:
        return false
    if addr.mux != types.Libp2pMuxNone:
        return false
    return true

fn Libp2pQuicTransportText(): str =
    return "quic(tls)->native_stream"

fn Libp2pQuicBytesAppend(dst: var Bytes, extra: Bytes) =
    let oldLen: int32 = bytesLen(dst)
    let addLen: int32 = bytesLen(extra)
    if addLen <= 0:
        return
    let out: Bytes = bytesAlloc(oldLen + addLen)
    for i in 0..<oldLen:
        bytesSet(out, i, bytesGet(dst, i))
    for j in 0..<addLen:
        bytesSet(out, oldLen + j, bytesGet(extra, j))
    dst = out

fn Libp2pQuicEncodeFrame(payload: Bytes): Bytes =
    let payloadLen: int32 = bytesLen(payload)
    let out: Bytes = bytesAlloc(4 + payloadLen)
    bytesSet(out, 0, (payloadLen >> 24) & 0xff)
    bytesSet(out, 1, (payloadLen >> 16) & 0xff)
    bytesSet(out, 2, (payloadLen >> 8) & 0xff)
    bytesSet(out, 3, payloadLen & 0xff)
    for i in 0..<payloadLen:
        bytesSet(out, 4 + i, bytesGet(payload, i))
    return out

fn Libp2pQuicDecodeFrameLen(header: Bytes): Result[int32] =
    if bytesLen(header) != 4:
        return Err[int32](" libp2p quic: invalid frame header")
    let b0 = bytesGet(header, 0)
    let b1 = bytesGet(header, 1)
    let b2 = bytesGet(header, 2)
    let b3 = bytesGet(header, 3)
    return Ok[int32]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn Libp2pQuicReadExact(t: var qtransport.MsQuicTransport,
                         conn: var qconn.Connection,
                         count: int32): Result[Bytes] =
    if count <= 0:
        return Ok[Bytes](emptyBytes())
    var out: Bytes
    out = emptyBytes()
    while bytesLen(out) < count:
        let chunkRes = qtransport.msquicTransportRead(t, conn, count - bytesLen(out))
        if IsErr(chunkRes):
            return Err[Bytes](ErrorText(chunkRes))
        let chunk = Value(chunkRes)
        if bytesLen(chunk) <= 0:
            return Err[Bytes](" libp2p quic: unexpected eof")
        Libp2pQuicBytesAppend(out, chunk)
    return Ok[Bytes](out)

fn Libp2pQuicWriteExact(t: var qtransport.MsQuicTransport,
                          conn: var qconn.Connection,
                          payload: Bytes): Result[bool] =
    let writeRes = qtransport.msquicTransportWrite(t, conn, payload)
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    if Value(writeRes) != bytesLen(payload):
        return Err[bool](" libp2p quic: short write")
    return Ok[bool](true)

fn Libp2pQuicReadFrame(t: var qtransport.MsQuicTransport,
                         conn: var qconn.Connection): Result[Bytes] =
    let headerRes = Libp2pQuicReadExact(t, conn, 4)
    if IsErr(headerRes):
        return Err[Bytes](ErrorText(headerRes))
    let lenRes = Libp2pQuicDecodeFrameLen(Value(headerRes))
    if IsErr(lenRes):
        return Err[Bytes](ErrorText(lenRes))
    let payloadLen = Value(lenRes)
    if payloadLen <= 0:
        return Ok[Bytes](emptyBytes())
    return Libp2pQuicReadExact(t, conn, payloadLen)

fn Libp2pQuicTextStartsWith(text: str, prefix: str): bool =
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn Libp2pQuicCreateDirAll(path: str): bool =
    if len(path) <= 0:
        return false
    if os.DirExists(path):
        return true
    let parent = os.ParentDir(path)
    if len(parent) > 0 && parent != path && !os.DirExists(parent):
        if !Libp2pQuicCreateDirAll(parent):
            return false
    if !os.DirExists(path):
        os.CreateDir(path)
    return os.DirExists(path)

fn Libp2pQuicWriteReadyPort(readyPath: str, boundPort: int32): bool =
    if len(readyPath) <= 0:
        return true
    let boundPortText: str = intToStr(boundPort)
    let readyText: str = strutil.Join([boundPortText, "\n"], "")
    let parent = os.ParentDir(readyPath)
    if len(parent) > 0:
        if !Libp2pQuicCreateDirAll(parent):
            return false
    os.WriteFile(readyPath, readyText)
    return os.FileExists(readyPath)

fn Libp2pQuicWriteStderr(text: str) =
    let stderrOut = os.Get_stderr()
    os.WriteLine(stderrOut, text)

fn Libp2pQuicRetryableAcceptError(err: str): bool =
    return Libp2pQuicTextStartsWith(err, "msquic native: accept handshake ! ready") ||
           Libp2pQuicTextStartsWith(err, "msquic native: handshake ! ready") ||
           Libp2pQuicTextStartsWith(err, "msquic native: session ! ready") ||
           Libp2pQuicTextStartsWith(err, "msquic native: pipe read timeout")

fn Libp2pQuicAddrFromHostPort(host: str, port: int32): Result[qaddr.MultiAddress] =
    if port < 0 || port > 65535:
        return Err[qaddr.MultiAddress](" libp2p quic: invalid port")
    var addr: types.Libp2pMultiaddr
    core_multiaddr.Libp2pMultiaddrFillQuic(addr, host, port)
    return Libp2pQuicParseAddr(addr)

fn Libp2pQuicBoundPort(addr: qaddr.MultiAddress): int32 =
    let text = qaddr.quicMultiAddressToString(addr)
    if len(text) <= 0:
        return 0
    var parsed: types.Libp2pMultiaddr
    let fillRes = core_multiaddr.Libp2pMultiaddrFillFromBytes(parsed, bytesFromString(text))
    if IsErr(fillRes):
        return 0
    return parsed.port

fn Libp2pQuicConfigureTlsWithPolicy(t: var qtransport.MsQuicTransport,
                                      policy: qpolicy.MsQuicTlsPolicy): Result[bool] =
    return qtransport.setMsQuicTransportTlsPolicy(t, policy)

fn Libp2pQuicConfigureTlsWithServerName(t: var qtransport.MsQuicTransport,
                                          serverName: str): Result[bool] =
    if len(serverName) > 0 && serverName != "localhost":
        let policy: qpolicy.MsQuicTlsPolicy = testpki.msquicMakePublicTransportTlsPolicy(serverName)
        return Libp2pQuicConfigureTlsWithPolicy(t, policy)
    let policy: qpolicy.MsQuicTlsPolicy = testpki.msquicMakeLocalhostTransportTlsPolicy()
    return Libp2pQuicConfigureTlsWithPolicy(t, policy)

fn Libp2pQuicConfigureOneShotClientSettings(t: var qtransport.MsQuicTransport): Result[bool] =
    var settings = qtransport.msquicTransportSettings(t)
    settings.handshakeIdleTimeoutMs = int64(Libp2pQuicOneShotHandshakeTimeoutMs)
    settings.idleTimeoutMs = int64(Libp2pQuicOneShotIdleTimeoutMs)
    settings.disconnectTimeoutMs = Libp2pQuicOneShotDisconnectTimeoutMs
    return qtransport.setMsQuicTransportSettings(t, settings)

fn Libp2pQuicDialOneShotClientNamed(client: var qtransport.MsQuicTransport,
                                      conn: var qconn.Connection,
                                      host: str,
                                      port: int32,
                                      serverName: str): Result[bool] =
    let addrRes = Libp2pQuicAddrFromHostPort(host, port)
    if IsErr(addrRes):
        return Err[bool](ErrorText(addrRes))
    client = qtransport.InitMsQuicTransport()
    let settingsRes = Libp2pQuicConfigureOneShotClientSettings(client)
    if IsErr(settingsRes):
        return Err[bool](strutil.Join([" libp2p quic: client settings: ", ErrorText(settingsRes)], ""))
    let tlsRes = Libp2pQuicConfigureTlsWithServerName(client, serverName)
    if IsErr(tlsRes):
        return Err[bool](strutil.Join([" libp2p quic: client tls: ", ErrorText(tlsRes)], ""))
    let dialRes = qtransport.dial(client, Value(addrRes))
    if IsErr(dialRes):
        return Err[bool](strutil.Join([" libp2p quic: dial: ", ErrorText(dialRes)], ""))
    conn = Value(dialRes)
    return Ok[bool](true)

fn Libp2pQuicStartListenerNamed(listener: var qtransport.MsQuicTransport,
                                  host: str,
                                  port: int32,
                                  serverName: str): Result[int32] =
    let addrRes = Libp2pQuicAddrFromHostPort(host, port)
    if IsErr(addrRes):
        return Err[int32](ErrorText(addrRes))
    listener = qtransport.InitMsQuicTransport()
    let tlsRes = Libp2pQuicConfigureTlsWithServerName(listener, serverName)
    if IsErr(tlsRes):
        return Err[int32](strutil.Join([" libp2p quic: listener tls: ", ErrorText(tlsRes)], ""))
    qtransport.start(listener, Value(addrRes))
    if !listener.running:
        return Err[int32](strutil.Join([" libp2p quic: listener start: ", listener.lastError], ""))
    return Ok[int32](Libp2pQuicBoundPort(listener.listenAddr))

fn Libp2pQuicStartListener(listener: var qtransport.MsQuicTransport,
                             host: str,
                             port: int32): Result[int32] =
    return Libp2pQuicStartListenerNamed(listener, host, port, "localhost")

fn Libp2pQuicDialClientNamed(client: var qtransport.MsQuicTransport,
                               conn: var qconn.Connection,
                               host: str,
                               port: int32,
                               serverName: str): Result[bool] =
    let addrRes = Libp2pQuicAddrFromHostPort(host, port)
    if IsErr(addrRes):
        return Err[bool](ErrorText(addrRes))
    client = qtransport.InitMsQuicTransport()
    let tlsRes = Libp2pQuicConfigureTlsWithServerName(client, serverName)
    if IsErr(tlsRes):
        return Err[bool](strutil.Join([" libp2p quic: client tls: ", ErrorText(tlsRes)], ""))
    let dialRes = qtransport.dial(client, Value(addrRes))
    if IsErr(dialRes):
        return Err[bool](strutil.Join([" libp2p quic: dial: ", ErrorText(dialRes)], ""))
    conn = Value(dialRes)
    return Ok[bool](true)

fn Libp2pQuicDialClient(client: var qtransport.MsQuicTransport,
                          conn: var qconn.Connection,
                          host: str,
                          port: int32): Result[bool] =
    return Libp2pQuicDialClientNamed(client, conn, host, port, "localhost")

fn Libp2pQuicClientSelectProtocol(client: var qtransport.MsQuicTransport,
                                    conn: var qconn.Connection,
                                    protocol: types.Libp2pProtocolId): Result[bool] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let writeRes = Libp2pQuicWriteExact(client, conn, selectBytes)
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    let echoRes = Libp2pQuicReadExact(client, conn, bytesLen(selectBytes))
    if IsErr(echoRes):
        return Err[bool](ErrorText(echoRes))
    if !multistream.Libp2pMultistreamAccepts(Value(echoRes), protocol):
        return Err[bool](" libp2p quic: multistream response mismatch")
    return Ok[bool](true)

fn Libp2pQuicServerSelectProtocol(listener: var qtransport.MsQuicTransport,
                                    conn: var qconn.Connection,
                                    protocol: types.Libp2pProtocolId): Result[bool] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let recvRes = Libp2pQuicReadExact(listener, conn, bytesLen(selectBytes))
    if IsErr(recvRes):
        return Err[bool](ErrorText(recvRes))
    if !multistream.Libp2pMultistreamAccepts(Value(recvRes), protocol):
        return Err[bool](strutil.Join([" libp2p quic: multistream request mismatch got=", bytesToHex(Value(recvRes))], ""))
    return Libp2pQuicWriteExact(listener, conn, selectBytes)

fn Libp2pQuicAddrText(addr: types.Libp2pMultiaddr): str =
    if len(addr.raw) > 0:
        return addr.raw
    var out: str = "/ip4/"
    out = strutil.Join([out, addr.host], "")
    out = strutil.Join([out, "/udp/"], "")
    out = strutil.Join([out, intToStr(addr.port)], "")
    out = strutil.Join([out, "/quic-v1"], "")
    return out

fn Libp2pQuicParseAddr(addr: types.Libp2pMultiaddr): Result[qaddr.MultiAddress] =
    if !Libp2pQuicTransportSupportsAddr(addr):
        return Err[qaddr.MultiAddress](" libp2p quic: unsupported multiaddr")
    return qaddr.parseMultiAddress(Libp2pQuicAddrText(addr))

fn Libp2pQuicConfigureTls(t: var qtransport.MsQuicTransport): Result[bool] =
    return Libp2pQuicConfigureTlsWithServerName(t, "localhost")

fn Libp2pQuicLoopbackOpenInto(out: var Libp2pQuicLoopbackPair,
                                addr: types.Libp2pMultiaddr): Result[bool] =
    let parsedRes = Libp2pQuicParseAddr(addr)
    if IsErr(parsedRes):
        return Err[bool](strutil.Join([" libp2p quic open: parse: ", ErrorText(parsedRes)], ""))
    out.listener = qtransport.InitMsQuicTransport()
    out.client = qtransport.InitMsQuicTransport()
    let listenerTlsRes = Libp2pQuicConfigureTls(out.listener)
    if IsErr(listenerTlsRes):
        return Err[bool](strutil.Join([" libp2p quic open: listener tls: ", ErrorText(listenerTlsRes)], ""))
    let clientTlsRes = Libp2pQuicConfigureTls(out.client)
    if IsErr(clientTlsRes):
        return Err[bool](strutil.Join([" libp2p quic open: client tls: ", ErrorText(clientTlsRes)], ""))
    out.listenAddr = Value(parsedRes)
    qtransport.start(out.listener, out.listenAddr)
    if !out.listener.running:
        return Err[bool](strutil.Join([" libp2p quic open: listener start: ", out.listener.lastError], ""))
    out.listenAddr = out.listener.listenAddr
    let dialRes = qtransport.dial(out.client, out.listenAddr)
    if IsErr(dialRes):
        qtransport.Stop(out.listener)
        return Err[bool](strutil.Join([" libp2p quic open: dial: ", ErrorText(dialRes)], ""))
    out.outbound = Value(dialRes)
    let acceptRes = qtransport.accept(out.listener)
    if IsErr(acceptRes):
        qconn.ConnClose(out.outbound)
        qtransport.Stop(out.listener)
        return Err[bool](strutil.Join([" libp2p quic open: accept: ", ErrorText(acceptRes)], ""))
    out.inbound = Value(acceptRes)
    return Ok[bool](true)

fn Libp2pQuicLoopbackClose(pair: var Libp2pQuicLoopbackPair) =
    qconn.ConnClose(pair.outbound)
    qconn.ConnClose(pair.inbound)
    qtransport.Stop(pair.listener)

fn Libp2pQuicLoopbackWriteClient(pair: var Libp2pQuicLoopbackPair,
                                   payload: Bytes): Result[int32] =
    return qtransport.msquicTransportWrite(pair.client, pair.outbound, payload)

fn Libp2pQuicLoopbackReadClient(pair: var Libp2pQuicLoopbackPair,
                                  count: int32): Result[Bytes] =
    return qtransport.msquicTransportRead(pair.client, pair.outbound, count)

fn Libp2pQuicLoopbackWriteServer(pair: var Libp2pQuicLoopbackPair,
                                   payload: Bytes): Result[int32] =
    return qtransport.msquicTransportWrite(pair.listener, pair.inbound, payload)

fn Libp2pQuicLoopbackReadServer(pair: var Libp2pQuicLoopbackPair,
                                  count: int32): Result[Bytes] =
    return qtransport.msquicTransportRead(pair.listener, pair.inbound, count)

fn Libp2pQuicLoopbackSelectProtocol(pair: var Libp2pQuicLoopbackPair,
                                      protocol: types.Libp2pProtocolId): Result[bool] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let writeRes = Libp2pQuicLoopbackWriteClient(pair, selectBytes)
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    let readRes = Libp2pQuicLoopbackReadServer(pair, bytesLen(selectBytes))
    if IsErr(readRes):
        return Err[bool](ErrorText(readRes))
    if !multistream.Libp2pMultistreamAccepts(Value(readRes), protocol):
        return Err[bool](" libp2p quic: multistream select mismatch")
    return Ok[bool](true)

fn Libp2pQuicServePayloadOnce(host: str,
                                port: int32,
                                protocol: types.Libp2pProtocolId,
                                payload: Bytes,
                                readyPath: str): Result[bool] =
    return Libp2pQuicServePayloadWindow(host, port, protocol, payload, readyPath, 1, -1)

fn Libp2pQuicServePayloadOnceNamed(host: str,
                                     port: int32,
                                     serverName: str,
                                     protocol: types.Libp2pProtocolId,
                                     payload: Bytes,
                                     readyPath: str): Result[bool] =
    return Libp2pQuicServePayloadWindowNamed(host,
                                               port,
                                               serverName,
                                               protocol,
                                               payload,
                                               readyPath,
                                               1,
                                               -1)

fn Libp2pQuicRecvPayloadOnce(host: str,
                               port: int32,
                               protocol: types.Libp2pProtocolId): Result[Bytes] =
    return Libp2pQuicRecvPayloadOnceNamed(host, port, "localhost", protocol)

fn Libp2pQuicRecvPayloadOnceNamed(host: str,
                                    port: int32,
                                    serverName: str,
                                    protocol: types.Libp2pProtocolId): Result[Bytes] =
    var client = qtransport.InitMsQuicTransport()
    var conn: qconn.Connection
    let dialRes = Libp2pQuicDialOneShotClientNamed(client, conn, host, port, serverName)
    if IsErr(dialRes):
        return Err[Bytes](ErrorText(dialRes))
    let selectRes = Libp2pQuicClientSelectProtocol(client, conn, protocol)
    if IsErr(selectRes):
        qconn.ConnClose(conn)
        return Err[Bytes](ErrorText(selectRes))
    let payloadRes = Libp2pQuicReadFrame(client, conn)
    qconn.ConnClose(conn)
    if IsErr(payloadRes):
        return Err[Bytes](ErrorText(payloadRes))
    return Ok[Bytes](Value(payloadRes))

fn Libp2pQuicRequestResponse(host: str,
                               port: int32,
                               protocol: types.Libp2pProtocolId,
                               requestPayload: Bytes): Result[Bytes] =
    return Libp2pQuicRequestResponseNamed(host, port, "localhost", protocol, requestPayload)

fn Libp2pQuicRequestResponseNamed(host: str,
                                    port: int32,
                                    serverName: str,
                                    protocol: types.Libp2pProtocolId,
                                    requestPayload: Bytes): Result[Bytes] =
    var client = qtransport.InitMsQuicTransport()
    var conn: qconn.Connection
    let dialRes = Libp2pQuicDialOneShotClientNamed(client, conn, host, port, serverName)
    if IsErr(dialRes):
        return Err[Bytes](ErrorText(dialRes))
    let selectRes = Libp2pQuicClientSelectProtocol(client, conn, protocol)
    if IsErr(selectRes):
        qconn.ConnClose(conn)
        return Err[Bytes](ErrorText(selectRes))
    let writeRes = Libp2pQuicWriteExact(client, conn, Libp2pQuicEncodeFrame(requestPayload))
    if IsErr(writeRes):
        qconn.ConnClose(conn)
        return Err[Bytes](ErrorText(writeRes))
    let responseRes = Libp2pQuicReadFrame(client, conn)
    qconn.ConnClose(conn)
    if IsErr(responseRes):
        return Err[Bytes](ErrorText(responseRes))
    return Ok[Bytes](Value(responseRes))

fn Libp2pQuicServeRequestCaptureOnce(host: str,
                                       port: int32,
                                       protocol: types.Libp2pProtocolId,
                                       responsePayload: Bytes,
                                       readyPath: str): Result[Bytes] =
    return Libp2pQuicServeRequestCaptureOnceNamed(host,
                                                    port,
                                                    "localhost",
                                                    protocol,
                                                    responsePayload,
                                                    readyPath)

fn Libp2pQuicServeRequestCaptureOnceNamed(host: str,
                                            port: int32,
                                            serverName: str,
                                            protocol: types.Libp2pProtocolId,
                                            responsePayload: Bytes,
                                            readyPath: str): Result[Bytes] =
    let captureRes = Libp2pQuicServeRequestCaptureWindowNamed(host,
                                                                port,
                                                                serverName,
                                                                protocol,
                                                                responsePayload,
                                                                readyPath,
                                                                1,
                                                                -1)
    if IsErr(captureRes):
        return Err[Bytes](Error(captureRes))
    let captured = Value(captureRes)
    if captured.len <= 0:
        return Err[Bytes](" libp2p quic: capture empty")
    return Ok[Bytes](captured[0])

fn Libp2pQuicServePayloadWindow(host: str,
                                  port: int32,
                                  protocol: types.Libp2pProtocolId,
                                  payload: Bytes,
                                  readyPath: str,
                                  maxServeCount: int32,
                                  waitMs: int32): Result[bool] =
    return Libp2pQuicServePayloadWindowNamed(host,
                                               port,
                                               "localhost",
                                               protocol,
                                               payload,
                                               readyPath,
                                               maxServeCount,
                                               waitMs)

fn Libp2pQuicServePayloadWindowNamed(host: str,
                                       port: int32,
                                       serverName: str,
                                       protocol: types.Libp2pProtocolId,
                                       payload: Bytes,
                                       readyPath: str,
                                       maxServeCount: int32,
                                       waitMs: int32): Result[bool] =
    var listener = qtransport.InitMsQuicTransport()
    let startRes = Libp2pQuicStartListenerNamed(listener, host, port, serverName)
    if IsErr(startRes):
        return Err[bool](Error(startRes))
    if !Libp2pQuicWriteReadyPort(readyPath, Value(startRes)):
        qtransport.Stop(listener)
        return Err[bool](" libp2p quic: ready path write failed")
    var servedCount = 0
    while maxServeCount <= 0 || servedCount < maxServeCount:
        let acceptRes = qtransport.AcceptTimed(listener, waitMs)
        if IsErr(acceptRes):
            if ErrorText(acceptRes) == "msquic: accept timeout" ||
               Libp2pQuicRetryableAcceptError(ErrorText(acceptRes)):
                break
            qtransport.Stop(listener)
            return Err[bool](strutil.Join([" libp2p quic: accept: ", ErrorText(acceptRes)], ""))
        var conn = Value(acceptRes)
        var dropConn = false
        let selectRes = Libp2pQuicServerSelectProtocol(listener, conn, protocol)
        if IsErr(selectRes):
            let errText: str = strutil.Join(["quic_serve_select_err=", ErrorText(selectRes)], "")
            Libp2pQuicWriteStderr(errText)
            dropConn = true
        if !dropConn:
            let writeRes = Libp2pQuicWriteExact(listener, conn, Libp2pQuicEncodeFrame(payload))
            if IsErr(writeRes):
                let errText: str = strutil.Join(["quic_serve_write_err=", ErrorText(writeRes)], "")
                Libp2pQuicWriteStderr(errText)
                dropConn = true
        qconn.ConnClose(conn)
        if dropConn:
            continue
        servedCount = servedCount + 1
    qtransport.Stop(listener)
    return Ok[bool](true)

fn Libp2pQuicServeRequestCaptureWindow(host: str,
                                         port: int32,
                                         protocol: types.Libp2pProtocolId,
                                         responsePayload: Bytes,
                                         readyPath: str,
                                         maxCaptureCount: int32,
                                         waitMs: int32): Result[Bytes[]] =
    return Libp2pQuicServeRequestCaptureWindowNamed(host,
                                                      port,
                                                      "localhost",
                                                      protocol,
                                                      responsePayload,
                                                      readyPath,
                                                      maxCaptureCount,
                                                      waitMs)

fn Libp2pQuicServeRequestCaptureWindowNamed(host: str,
                                              port: int32,
                                              serverName: str,
                                              protocol: types.Libp2pProtocolId,
                                              responsePayload: Bytes,
                                              readyPath: str,
                                              maxCaptureCount: int32,
                                              waitMs: int32): Result[Bytes[]] =
    var listener = qtransport.InitMsQuicTransport()
    let startRes = Libp2pQuicStartListenerNamed(listener, host, port, serverName)
    if IsErr(startRes):
        return Err[Bytes[]](Error(startRes))
    if !Libp2pQuicWriteReadyPort(readyPath, Value(startRes)):
        qtransport.Stop(listener)
        return Err[Bytes[]](" libp2p quic: ready path write failed")
    var captured: Bytes[]
    captured = []
    while maxCaptureCount <= 0 || captured.len < maxCaptureCount:
        let acceptRes = qtransport.AcceptTimed(listener, waitMs)
        if IsErr(acceptRes):
            if ErrorText(acceptRes) == "msquic: accept timeout" ||
               Libp2pQuicRetryableAcceptError(ErrorText(acceptRes)):
                break
            qtransport.Stop(listener)
            return Err[Bytes[]](strutil.Join([" libp2p quic: accept: ", ErrorText(acceptRes)], ""))
        var conn = Value(acceptRes)
        var dropConn = false
        let selectRes = Libp2pQuicServerSelectProtocol(listener, conn, protocol)
        var requestPayload = emptyBytes()
        if IsErr(selectRes):
            dropConn = true
        if !dropConn:
            let requestRes = Libp2pQuicReadFrame(listener, conn)
            if IsErr(requestRes):
                dropConn = true
            else:
                requestPayload = Value(requestRes)
        if !dropConn:
            let writeRes = Libp2pQuicWriteExact(listener, conn, Libp2pQuicEncodeFrame(responsePayload))
            if IsErr(writeRes):
                dropConn = true
        qconn.ConnClose(conn)
        if dropConn:
            continue
        add(captured, requestPayload)
    qtransport.Stop(listener)
    return Ok[Bytes[]](captured)
