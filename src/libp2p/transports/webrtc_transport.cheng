import std/rawbytes
import std/result
import std/times
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/libp2p/core/multistream
import cheng/libp2p/core/types
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/core/runtime/tcp_bridge_abi as tcpabi
import std/strutils as strutil

@importc("cheng_buffer_handle_len_bridge")
fn Libp2pWebrtcBufferHandleLenBridge(handle: uint64): int32
@importc("cheng_buffer_handle_byte_bridge")
fn Libp2pWebrtcBufferHandleByteBridge(handle: uint64, idx: int32): int32
@importc("cheng_buffer_handle_release_bridge")
fn Libp2pWebrtcBufferHandleReleaseBridge(handle: uint64): int32
importc fn cheng_webrtc_last_error_handle_bridge(): uint64
importc fn cheng_webrtc_datachannel_request_response_handle_bridge(protocolText: str, signalWire: str, requestWire: str, responseWire: str): uint64
importc fn cheng_webrtc_browser_session_open_handle_bridge(policyText: str, labelText: str): uint64
importc fn cheng_webrtc_browser_session_signal_handle_bridge(handle: uint64): uint64
importc fn cheng_webrtc_browser_session_exchange_handle_bridge(handle: uint64, protocolText: str, requestWire: str, responseWire: str): uint64
importc fn cheng_webrtc_browser_session_close_simple_bridge(handle: uint64): int32
importc fn cheng_webrtc_browser_session_active_count_bridge(): int32

var Libp2pWebrtcNativeDatachannelOpenCount: int32
var Libp2pWebrtcNativeDatachannelRequestCount: int32
var Libp2pWebrtcBrowserDatachannelOpenCount: int32
var Libp2pWebrtcBrowserDatachannelRequestCount: int32
var Libp2pWebrtcLoopbackRequestResponseCount: int32
var Libp2pWebrtcLastProtocol: types.Libp2pProtocolId
var Libp2pWebrtcLastRelayOnly: bool
var Libp2pWebrtcLastSessionId: layout.FixedBytes32

fn Libp2pWebrtcOwnedBytesFromString(text: str): Bytes =
    return bytesSlice(bytesFromString(text), 0, len(text))

fn Libp2pWebrtcBytesFromHandle(handle: uint64): Result[Bytes] =
    if handle == uint64(0):
        return Err[Bytes](" libp2p webrtc: bridge failed")
    var n: int32
    n = Libp2pWebrtcBufferHandleLenBridge(handle)
    if n < 0:
        let _ = Libp2pWebrtcBufferHandleReleaseBridge(handle)
        return Err[Bytes](" libp2p webrtc: bridge handle len failed")
    var out = bytesAlloc(n)
    for i in 0..<n:
        var b: int32
        b = Libp2pWebrtcBufferHandleByteBridge(handle, i)
        if b < 0:
            let _ = Libp2pWebrtcBufferHandleReleaseBridge(handle)
            return Err[Bytes](" libp2p webrtc: bridge handle byte failed")
        bytesSet(out, i, b)
    let _ = Libp2pWebrtcBufferHandleReleaseBridge(handle)
    return Ok[Bytes](out)

fn Libp2pWebrtcLastErrorText(fallback: str): str =
    let handle = cheng_webrtc_last_error_handle_bridge()
    if handle == uint64(0):
        return fallback
    let errRes = Libp2pWebrtcBytesFromHandle(handle)
    if IsErr(errRes):
        return fallback
    let errBytes = Value(errRes)
    if bytesLen(errBytes) <= 0:
        return fallback
    return bytesToString(errBytes)

type
    Libp2pWebrtcTransportConfig =
        relayOnly: bool
        stunUrls: str[]
        turnServers: signal.Libp2pWebrtcTurnServer[]
        dataChannelLabel: str = "cheng-libp2p"

    Libp2pWebrtcLoopbackPair =
        cfg: Libp2pWebrtcTransportConfig
        remoteAddr: types.Libp2pMultiaddr
        signalSession: signal.Libp2pWebrtcSignalSession
        signalTranscript: signal.Libp2pWebrtcSignalMessage[]
        selectedProtocol: types.Libp2pProtocolId
        clientToServer: Bytes
        serverToClient: Bytes

    Libp2pWebrtcBrowserSession =
        handle: uint64
        cfg: Libp2pWebrtcTransportConfig
        remoteAddr: types.Libp2pMultiaddr
        sessionId: layout.FixedBytes32
        signalWire: Bytes
        ready: bool
        relayOnly: bool

fn Libp2pWebrtcTransportConfigApplyRelayLease(cfg: var Libp2pWebrtcTransportConfig,
                                                lease: types.Libp2pRelayLease): Result[bool] =
    if !types.Libp2pRelayLeaseActiveAt(lease, times.EpochTimeSeconds()):
        return Err[bool](" libp2p webrtc: relay lease inactive")
    if lease.serviceKind == types.Libp2pRelayServiceStun:
        if len(lease.endpointText) <= 0:
            return Err[bool](" libp2p webrtc: stun endpoint missing")
        add(cfg.stunUrls, lease.endpointText)
        return Ok[bool](true)
    if lease.serviceKind == types.Libp2pRelayServiceTurn:
        if len(lease.endpointText) <= 0:
            return Err[bool](" libp2p webrtc: turn endpoint missing")
        var server: signal.Libp2pWebrtcTurnServer
        server.url = lease.endpointText
        server.username = lease.username
        server.credential = lease.credential
        add(cfg.turnServers, server)
        cfg.relayOnly = true
        return Ok[bool](true)
    return Err[bool](" libp2p webrtc: unsupported relay lease service")

fn Libp2pWebrtcTransportSupportsAddr(addr: types.Libp2pMultiaddr): bool =
    if addr.transport != types.Libp2pTransportWebrtc:
        return false
    if addr.networkDomain != types.Libp2pNetworkDomainBrowserWebrtc:
        return false
    return true

fn Libp2pWebrtcAddrText(addr: types.Libp2pMultiaddr): str =
    if len(addr.raw) > 0:
        return addr.raw
    var out: str = "/ip4/"
    out = strutil.Join([out, addr.host], "")
    out = strutil.Join([out, "/udp/"], "")
    out = strutil.Join([out, IntToStr(addr.port)], "")
    out = strutil.Join([out, "/webrtc-direct"], "")
    return out

fn Libp2pWebrtcTransportSessionId(addr: types.Libp2pMultiaddr,
                                    label: str): layout.FixedBytes32 =
    let sessionText = strutil.Join(["cheng.libp2p.webrtc.session\n", Libp2pWebrtcAddrText(addr), "\n", label], "")
    return hash256.sha256Fixed(layout.ByteSpanFromBytes(bytesFromString(sessionText)))

fn Libp2pWebrtcOfferSdp(addr: types.Libp2pMultiaddr,
                          label: str): str =
    return strutil.Join(["v=0\no=- 1 1 IN IP4 ", addr.host, "\n", "m=application ", IntToStr(addr.port), " UDP/DTLS/SCTP webrtc-datachannel\n", "a=dcmap:0 label=", label], "")

fn Libp2pWebrtcAnswerSdp(sessionId: layout.FixedBytes32,
                           label: str): str =
    let payload = signal.Libp2pWebrtcSignalEncode(signal.Libp2pWebrtcSignalMakeOffer(sessionId, label))
    return strutil.Join(["v=0\no=- 2 2 IN IP4 127.0.0.1\n", "a=answer-bytes=", IntToStr(bytesLen(payload)), "\n", "a=dcmap:0 label=", label], "")

fn Libp2pWebrtcCandidateText(addr: types.Libp2pMultiaddr,
                               relayOnly: bool,
                               side: str): str =
    var out = "candidate:1 1 udp 2130706431 "
    out = strutil.Join([out, addr.host], "")
    out = strutil.Join([out, " "], "")
    out = strutil.Join([out, IntToStr(addr.port)], "")
    if relayOnly:
        out = strutil.Join([out, " typ relay generation 0 ufrag "], "")
        out = strutil.Join([out, side], "")
        return out
    out = strutil.Join([out, " typ host generation 0 ufrag "], "")
    out = strutil.Join([out, side], "")
    return out

fn Libp2pWebrtcTransportSignalPolicy(cfg: Libp2pWebrtcTransportConfig,
                                       sessionId: layout.FixedBytes32): signal.Libp2pWebrtcSignalMessage =
    return signal.Libp2pWebrtcSignalMakeTurnPolicy(sessionId,
                                                     cfg.relayOnly,
                                                     cfg.stunUrls,
                                                     cfg.turnServers)

fn Libp2pWebrtcLoopbackAppendTranscript(pair: var Libp2pWebrtcLoopbackPair,
                                          msg: signal.Libp2pWebrtcSignalMessage): Result[bool] =
    let applyRes = signal.Libp2pWebrtcSignalSessionApply(pair.signalSession, msg)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    add(pair.signalTranscript, signal.Libp2pWebrtcSignalMessageClone(msg))
    return Ok[bool](true)

fn Libp2pWebrtcLoopbackOpenInto(pair: var Libp2pWebrtcLoopbackPair,
                                  cfg: Libp2pWebrtcTransportConfig,
                                  remoteAddr: types.Libp2pMultiaddr): Result[bool] =
    if !Libp2pWebrtcTransportSupportsAddr(remoteAddr):
        return Err[bool](" libp2p webrtc: unsupported multiaddr")
    pair = Libp2pWebrtcLoopbackPair()
    pair.cfg = cfg
    pair.remoteAddr = remoteAddr
    let sessionId = Libp2pWebrtcTransportSessionId(remoteAddr, cfg.dataChannelLabel)
    let policy = Libp2pWebrtcTransportSignalPolicy(cfg, sessionId)
    let offer = signal.Libp2pWebrtcSignalMakeOffer(sessionId,
                                                     Libp2pWebrtcOfferSdp(remoteAddr,
                                                                            cfg.dataChannelLabel))
    let answer = signal.Libp2pWebrtcSignalMakeAnswer(sessionId,
                                                       Libp2pWebrtcAnswerSdp(sessionId,
                                                                               cfg.dataChannelLabel))
    let clientCandidate = signal.Libp2pWebrtcSignalMakeCandidate(sessionId,
                                                                   "0",
                                                                   0,
                                                                   Libp2pWebrtcCandidateText(remoteAddr,
                                                                                              cfg.relayOnly,
                                                                                              "client"))
    let serverCandidate = signal.Libp2pWebrtcSignalMakeCandidate(sessionId,
                                                                   "0",
                                                                   0,
                                                                   Libp2pWebrtcCandidateText(remoteAddr,
                                                                                              cfg.relayOnly,
                                                                                              "server"))
    let policyRes = Libp2pWebrtcLoopbackAppendTranscript(pair, policy)
    if IsErr(policyRes):
        return Err[bool](Error(policyRes))
    let offerRes = Libp2pWebrtcLoopbackAppendTranscript(pair, offer)
    if IsErr(offerRes):
        return Err[bool](Error(offerRes))
    let answerRes = Libp2pWebrtcLoopbackAppendTranscript(pair, answer)
    if IsErr(answerRes):
        return Err[bool](Error(answerRes))
    let clientRes = Libp2pWebrtcLoopbackAppendTranscript(pair, clientCandidate)
    if IsErr(clientRes):
        return Err[bool](Error(clientRes))
    let serverRes = Libp2pWebrtcLoopbackAppendTranscript(pair, serverCandidate)
    if IsErr(serverRes):
        return Err[bool](Error(serverRes))
    if !signal.Libp2pWebrtcSignalSessionReady(pair.signalSession):
        return Err[bool](" libp2p webrtc: signal session not ready")
    return Ok[bool](true)

fn Libp2pWebrtcLoopbackClose(pair: var Libp2pWebrtcLoopbackPair) =
    pair.selectedProtocol = 0
    pair.clientToServer = emptyBytes()
    pair.serverToClient = emptyBytes()

fn Libp2pWebrtcLoopbackSelectProtocol(pair: var Libp2pWebrtcLoopbackPair,
                                        protocol: types.Libp2pProtocolId): Result[bool] =
    if !signal.Libp2pWebrtcSignalSessionReady(pair.signalSession):
        return Err[bool](" libp2p webrtc: signal session not ready")
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    if !multistream.Libp2pMultistreamAccepts(selectBytes, protocol):
        return Err[bool](" libp2p webrtc: multistream select mismatch")
    pair.selectedProtocol = protocol
    return Ok[bool](true)

fn Libp2pWebrtcLoopbackWriteClient(pair: var Libp2pWebrtcLoopbackPair,
                                     payload: Bytes): Result[int32] =
    if pair.selectedProtocol == 0:
        return Err[int32](" libp2p webrtc: protocol not selected")
    pair.clientToServer = payload
    return Ok[int32](bytesLen(payload))

fn Libp2pWebrtcLoopbackReadServer(pair: var Libp2pWebrtcLoopbackPair,
                                    count: int32): Result[Bytes] =
    if bytesLen(pair.clientToServer) != count:
        return Err[Bytes](" libp2p webrtc: short client payload")
    let out = pair.clientToServer
    pair.clientToServer = emptyBytes()
    return Ok[Bytes](out)

fn Libp2pWebrtcLoopbackWriteServer(pair: var Libp2pWebrtcLoopbackPair,
                                     payload: Bytes): Result[int32] =
    if pair.selectedProtocol == 0:
        return Err[int32](" libp2p webrtc: protocol not selected")
    pair.serverToClient = payload
    return Ok[int32](bytesLen(payload))

fn Libp2pWebrtcLoopbackReadClient(pair: var Libp2pWebrtcLoopbackPair,
                                    count: int32): Result[Bytes] =
    if bytesLen(pair.serverToClient) != count:
        return Err[Bytes](" libp2p webrtc: short server payload")
    let out = pair.serverToClient
    pair.serverToClient = emptyBytes()
    return Ok[Bytes](out)

fn Libp2pWebrtcLoopbackSignalCount(pair: Libp2pWebrtcLoopbackPair): int32 =
    return pair.signalTranscript.len

fn Libp2pWebrtcLoopbackSignalPayloadsFill(out: var Bytes[],
                                            pair: Libp2pWebrtcLoopbackPair) =
    out = []
    for i in 0..<pair.signalTranscript.len:
        let payload = signal.Libp2pWebrtcSignalEncode(pair.signalTranscript[i])
        add(out, payload)

fn Libp2pWebrtcLoopbackSignalTranscriptPayload(pair: Libp2pWebrtcLoopbackPair): Bytes =
    return signal.Libp2pWebrtcSignalTranscriptEncode(pair.signalTranscript)

fn Libp2pWebrtcTransportResetStats() =
    Libp2pWebrtcNativeDatachannelOpenCount = 0
    Libp2pWebrtcNativeDatachannelRequestCount = 0
    Libp2pWebrtcBrowserDatachannelOpenCount = 0
    Libp2pWebrtcBrowserDatachannelRequestCount = 0
    Libp2pWebrtcLoopbackRequestResponseCount = 0
    Libp2pWebrtcLastProtocol = 0
    Libp2pWebrtcLastRelayOnly = false
    Libp2pWebrtcLastSessionId = layout.FixedBytes32()

fn Libp2pWebrtcNativeDatachannelOpenCountNow(): int32 =
    return Libp2pWebrtcNativeDatachannelOpenCount

fn Libp2pWebrtcNativeDatachannelRequestCountNow(): int32 =
    return Libp2pWebrtcNativeDatachannelRequestCount

fn Libp2pWebrtcBrowserDatachannelOpenCountNow(): int32 =
    return Libp2pWebrtcBrowserDatachannelOpenCount

fn Libp2pWebrtcBrowserDatachannelRequestCountNow(): int32 =
    return Libp2pWebrtcBrowserDatachannelRequestCount

fn Libp2pWebrtcLoopbackRequestResponseCountNow(): int32 =
    return Libp2pWebrtcLoopbackRequestResponseCount

fn Libp2pWebrtcLastProtocolNow(): types.Libp2pProtocolId =
    return Libp2pWebrtcLastProtocol

fn Libp2pWebrtcLastRelayOnlyNow(): bool =
    return Libp2pWebrtcLastRelayOnly

fn Libp2pWebrtcLastSessionIdNow(): layout.FixedBytes32 =
    return Libp2pWebrtcLastSessionId

fn Libp2pWebrtcRememberStats(sessionId: layout.FixedBytes32,
                               protocol: types.Libp2pProtocolId,
                               relayOnly: bool) =
    Libp2pWebrtcLastSessionId = sessionId
    Libp2pWebrtcLastProtocol = protocol
    Libp2pWebrtcLastRelayOnly = relayOnly

fn Libp2pWebrtcLoopbackRequestResponse(protocol: types.Libp2pProtocolId,
                                         cfg: Libp2pWebrtcTransportConfig,
                                         remoteAddr: types.Libp2pMultiaddr,
                                         requestPayload: Bytes,
                                         responsePayload: Bytes,
                                         outPayload: var Bytes): Result[bool] =
    var pair: Libp2pWebrtcLoopbackPair
    let openRes = Libp2pWebrtcLoopbackOpenInto(pair, cfg, remoteAddr)
    if IsErr(openRes):
        return Err[bool](strutil.Join([" libp2p webrtc: open: ", ErrorText(openRes)], ""))
    let selectRes = Libp2pWebrtcLoopbackSelectProtocol(pair, protocol)
    if IsErr(selectRes):
        Libp2pWebrtcLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p webrtc: select: ", ErrorText(selectRes)], ""))
    let requestWriteRes = Libp2pWebrtcLoopbackWriteClient(pair, requestPayload)
    if IsErr(requestWriteRes):
        Libp2pWebrtcLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p webrtc: request write: ", ErrorText(requestWriteRes)], ""))
    let requestReadRes = Libp2pWebrtcLoopbackReadServer(pair, bytesLen(requestPayload))
    if IsErr(requestReadRes):
        Libp2pWebrtcLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p webrtc: request read: ", ErrorText(requestReadRes)], ""))
    let serverPayload = Value(requestReadRes)
    if bytesLen(serverPayload) != bytesLen(requestPayload):
        Libp2pWebrtcLoopbackClose(pair)
        return Err[bool](" libp2p webrtc: request payload mismatch")
    let responseWriteRes = Libp2pWebrtcLoopbackWriteServer(pair, responsePayload)
    if IsErr(responseWriteRes):
        Libp2pWebrtcLoopbackClose(pair)
        return Err[bool](strutil.Join([" libp2p webrtc: response write: ", ErrorText(responseWriteRes)], ""))
    let responseReadRes = Libp2pWebrtcLoopbackReadClient(pair, bytesLen(responsePayload))
    Libp2pWebrtcLoopbackClose(pair)
    if IsErr(responseReadRes):
        return Err[bool](strutil.Join([" libp2p webrtc: response read: ", ErrorText(responseReadRes)], ""))
    Libp2pWebrtcLoopbackRequestResponseCount = Libp2pWebrtcLoopbackRequestResponseCount + 1
    Libp2pWebrtcRememberStats(pair.signalSession.sessionId,
                                protocol,
                                pair.signalSession.relayOnly)
    outPayload = Value(responseReadRes)
    return Ok[bool](true)

fn Libp2pWebrtcNativeRequestResponse(protocol: types.Libp2pProtocolId,
                                       signalWire: Bytes,
                                       requestPayload: Bytes,
                                       responsePayload: Bytes,
                                       outPayload: var Bytes): Result[bool] =
    var session: signal.Libp2pWebrtcSignalSession
    let applyRes = signal.Libp2pWebrtcSignalTranscriptApply(session, signalWire)
    if IsErr(applyRes):
        return Err[bool](strutil.Join([" libp2p webrtc: signal transcript: ", ErrorText(applyRes)], ""))
    if !signal.Libp2pWebrtcSignalSessionReady(session):
        return Err[bool](" libp2p webrtc: signal session not ready")
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let responseHandle = cheng_webrtc_datachannel_request_response_handle_bridge(bytesToString(selectBytes),
                                                                                    bytesToString(signalWire),
                                                                                    bytesToString(requestPayload),
                                                                                    bytesToString(responsePayload))
    if responseHandle == uint64(0):
        return Err[bool](Libp2pWebrtcLastErrorText(" libp2p webrtc: native datachannel bridge failed"))
    let responseRes = Libp2pWebrtcBytesFromHandle(responseHandle)
    if IsErr(responseRes):
        return Err[bool](Error(responseRes))
    outPayload = Value(responseRes)
    Libp2pWebrtcNativeDatachannelOpenCount = Libp2pWebrtcNativeDatachannelOpenCount + 1
    Libp2pWebrtcNativeDatachannelRequestCount = Libp2pWebrtcNativeDatachannelRequestCount + 1
    Libp2pWebrtcRememberStats(session.sessionId, protocol, session.relayOnly)
    return Ok[bool](true)

fn Libp2pWebrtcBrowserSessionOpenInto(out: var Libp2pWebrtcBrowserSession,
                                        cfg: Libp2pWebrtcTransportConfig,
                                        remoteAddr: types.Libp2pMultiaddr): Result[bool] =
    if !Libp2pWebrtcTransportSupportsAddr(remoteAddr):
        return Err[bool](" libp2p webrtc browser: unsupported multiaddr")
    let sessionId = Libp2pWebrtcTransportSessionId(remoteAddr, cfg.dataChannelLabel)
    let policyMsg = Libp2pWebrtcTransportSignalPolicy(cfg, sessionId)
    let policyWire = signal.Libp2pWebrtcSignalEncode(policyMsg)
    let handle = cheng_webrtc_browser_session_open_handle_bridge(bytesToString(policyWire),
                                                                    cfg.dataChannelLabel)
    if handle == uint64(0):
        return Err[bool](Libp2pWebrtcLastErrorText(" libp2p webrtc browser: session open failed"))
    out = Libp2pWebrtcBrowserSession()
    out.handle = handle
    out.cfg = cfg
    out.remoteAddr.raw = remoteAddr.raw
    out.remoteAddr.host = remoteAddr.host
    out.remoteAddr.port = remoteAddr.port
    out.remoteAddr.transport = remoteAddr.transport
    out.remoteAddr.secure = remoteAddr.secure
    out.remoteAddr.mux = remoteAddr.mux
    out.remoteAddr.networkDomain = remoteAddr.networkDomain
    out.remoteAddr.visibility = remoteAddr.visibility
    out.remoteAddr.priority = remoteAddr.priority
    let signalHandle = cheng_webrtc_browser_session_signal_handle_bridge(handle)
    if signalHandle == uint64(0):
        let closeOk = cheng_webrtc_browser_session_close_simple_bridge(handle)
        closeOk
        return Err[bool](Libp2pWebrtcLastErrorText(" libp2p webrtc browser: signal transcript missing"))
    let signalRes = Libp2pWebrtcBytesFromHandle(signalHandle)
    if IsErr(signalRes):
        let closeOk = cheng_webrtc_browser_session_close_simple_bridge(handle)
        closeOk
        return Err[bool](Error(signalRes))
    out.signalWire = Value(signalRes)
    var session: signal.Libp2pWebrtcSignalSession
    let applyRes = signal.Libp2pWebrtcSignalTranscriptApply(session, out.signalWire)
    if IsErr(applyRes):
        let closeOk = cheng_webrtc_browser_session_close_simple_bridge(handle)
        closeOk
        return Err[bool](strutil.Join([" libp2p webrtc browser: signal transcript: ", ErrorText(applyRes)], ""))
    if !signal.Libp2pWebrtcSignalSessionReady(session):
        let closeOk = cheng_webrtc_browser_session_close_simple_bridge(handle)
        closeOk
        return Err[bool](" libp2p webrtc browser: signal session not ready")
    if !layout.FixedBytes32Equal(session.sessionId, sessionId):
        let closeOk = cheng_webrtc_browser_session_close_simple_bridge(handle)
        closeOk
        return Err[bool](" libp2p webrtc browser: session id mismatch")
    out.sessionId = session.sessionId
    out.ready = true
    out.relayOnly = session.relayOnly
    Libp2pWebrtcBrowserDatachannelOpenCount = Libp2pWebrtcBrowserDatachannelOpenCount + 1
    return Ok[bool](true)

fn Libp2pWebrtcBrowserSessionExchange(session: var Libp2pWebrtcBrowserSession,
                                        protocol: types.Libp2pProtocolId,
                                        requestPayload: Bytes,
                                        responsePayload: Bytes,
                                        outPayload: var Bytes): Result[bool] =
    if !session.ready || session.handle == uint64(0):
        return Err[bool](" libp2p webrtc browser: session missing")
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let responseHandle = cheng_webrtc_browser_session_exchange_handle_bridge(session.handle,
                                                                                bytesToString(selectBytes),
                                                                                bytesToString(requestPayload),
                                                                                bytesToString(responsePayload))
    if responseHandle == uint64(0):
        return Err[bool](Libp2pWebrtcLastErrorText(" libp2p webrtc browser: session exchange failed"))
    let responseRes = Libp2pWebrtcBytesFromHandle(responseHandle)
    if IsErr(responseRes):
        return Err[bool](Error(responseRes))
    outPayload = Value(responseRes)
    Libp2pWebrtcBrowserDatachannelRequestCount = Libp2pWebrtcBrowserDatachannelRequestCount + 1
    Libp2pWebrtcRememberStats(session.sessionId, protocol, session.relayOnly)
    return Ok[bool](true)

fn Libp2pWebrtcBrowserSessionClose(session: var Libp2pWebrtcBrowserSession): Result[bool] =
    if session.handle == uint64(0):
        session = Libp2pWebrtcBrowserSession()
        return Ok[bool](true)
    let ok = cheng_webrtc_browser_session_close_simple_bridge(session.handle)
    let hadError = ok == 0
    session = Libp2pWebrtcBrowserSession()
    if hadError:
        return Err[bool](Libp2pWebrtcLastErrorText(" libp2p webrtc browser: session close failed"))
    return Ok[bool](true)

fn Libp2pWebrtcBrowserSessionActiveCountNow(): int32 =
    return cheng_webrtc_browser_session_active_count_bridge()

fn Libp2pWebrtcBrowserRequestResponse(protocol: types.Libp2pProtocolId,
                                        cfg: Libp2pWebrtcTransportConfig,
                                        remoteAddr: types.Libp2pMultiaddr,
                                        requestPayload: Bytes,
                                        responsePayload: Bytes,
                                        outSignalWire: var Bytes,
                                        outPayload: var Bytes): Result[bool] =
    var session: Libp2pWebrtcBrowserSession
    let openRes = Libp2pWebrtcBrowserSessionOpenInto(session, cfg, remoteAddr)
    if IsErr(openRes):
        return Err[bool](Error(openRes))
    outSignalWire = session.signalWire
    let exchangeRes = Libp2pWebrtcBrowserSessionExchange(session,
                                                           protocol,
                                                           requestPayload,
                                                           responsePayload,
                                                           outPayload)
    let closeRes = Libp2pWebrtcBrowserSessionClose(session)
    if IsErr(exchangeRes):
        return Err[bool](Error(exchangeRes))
    if IsErr(closeRes):
        return Err[bool](Error(closeRes))
    return Ok[bool](true)
