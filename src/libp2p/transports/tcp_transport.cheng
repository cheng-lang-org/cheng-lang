import std/result
import std/rawbytes
import cheng/libp2p/core/multistream
import cheng/libp2p/core/types
import std/strutils as strutil

@importc("cheng_buffer_handle_len_bridge")
fn Libp2pTcpBufferHandleLenBridge(handle: uint64): int32
@importc("cheng_buffer_handle_byte_bridge")
fn Libp2pTcpBufferHandleByteBridge(handle: uint64, idx: int32): int32
@importc("cheng_buffer_handle_release_bridge")
fn Libp2pTcpBufferHandleReleaseBridge(handle: uint64): int32
@importc("cheng_buffer_handle_from_raw_bridge")
fn Libp2pTcpBufferHandleFromRawBridge(data: ptr, n: int32): uint64
@importc("cheng_tcp_last_error_handle_bridge")
fn Libp2pTcpLastErrorHandleBridge(): uint64
@importc("cheng_tcp_loopback_request_response_handle_bridge")
fn Libp2pTcpLoopbackRequestResponseHandleBridge(protocolText: str,
                                                  requestHandle: uint64,
                                                  responseHandle: uint64): uint64
@importc("cheng_tcp_serve_payload_once_bridge")
fn Libp2pTcpServePayloadOnceBridge(hostText: str,
                                     port: int32,
                                     protocolText: str,
                                     payloadWire: str,
                                     readyPath: str): int32
@importc("cheng_tcp_serve_payload_window_bridge")
fn Libp2pTcpServePayloadWindowBridge(hostText: str,
                                       port: int32,
                                       protocolText: str,
                                       payloadWire: str,
                                       readyPath: str,
                                       maxServeCount: int32,
                                       waitMs: int32): int32
@importc("cheng_tcp_recv_payload_once_bridge")
fn Libp2pTcpRecvPayloadOnceBridge(hostText: str,
                                    port: int32,
                                    protocolText: str): uint64
@importc("cheng_tcp_request_response_bridge")
fn Libp2pTcpRequestResponseBridge(hostText: str,
                                    port: int32,
                                    protocolText: str,
                                    requestWire: str): uint64
@importc("cheng_tcp_serve_request_capture_once_bridge")
fn Libp2pTcpServeRequestCaptureOnceBridge(hostText: str,
                                            port: int32,
                                            protocolText: str,
                                            responseWire: str,
                                            readyPath: str): uint64
@importc("cheng_tcp_serve_request_capture_window_bridge")
fn Libp2pTcpServeRequestCaptureWindowBridge(hostText: str,
                                              port: int32,
                                              protocolText: str,
                                              responseWire: str,
                                              readyPath: str,
                                              maxCaptureCount: int32,
                                              waitMs: int32): uint64

type
    Libp2pTcpTransportConfig =
        secure: types.Libp2pSecureKind
        mux: types.Libp2pMuxKind

fn Libp2pTcpOwnedBytesFromString(text: str): Bytes =
    return bytesSlice(bytesFromString(text), 0, len(text))

fn Libp2pTcpHexDigit(value: int32): int32 =
    if value < 10:
        return int32('0') + value
    return int32('a') + (value - 10)

fn Libp2pTcpBridgeHexFrom(data: ptr, n: int32): str =
    if data == nil || n <= 0:
        return ""
    var out = bytesAlloc(n * 2)
    for i in 0..<n:
        let value = chengRawbytesGetAt(data, i)
        let hi = value / 16
        let lo = value - (hi * 16)
        bytesSet(out, i * 2, Libp2pTcpHexDigit(hi))
        bytesSet(out, i * 2 + 1, Libp2pTcpHexDigit(lo))
    return bytesToString(out)

fn Libp2pTcpBytesFromHandle(handle: uint64): Result[Bytes] =
    if handle == uint64(0):
        return Err[Bytes](" libp2p tcp: bridge failed")
    var n: int32
    n = Libp2pTcpBufferHandleLenBridge(handle)
    if n < 0:
        let _ = Libp2pTcpBufferHandleReleaseBridge(handle)
        return Err[Bytes](" libp2p tcp: bridge handle len failed")
    var out = bytesAlloc(n)
    for i in 0..<n:
        var b: int32
        b = Libp2pTcpBufferHandleByteBridge(handle, i)
        if b < 0:
            let _ = Libp2pTcpBufferHandleReleaseBridge(handle)
            return Err[Bytes](" libp2p tcp: bridge handle byte failed")
        bytesSet(out, i, b)
    let _ = Libp2pTcpBufferHandleReleaseBridge(handle)
    return Ok[Bytes](out)

fn Libp2pTcpBridgeError(defaultText: str): str =
    let handle = Libp2pTcpLastErrorHandleBridge()
    if handle == uint64(0):
        return defaultText
    let bytesRes = Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return defaultText
    let detail = bytesToString(Value(bytesRes))
    if len(detail) <= 0:
        return defaultText
    return strutil.Join([defaultText, ": ", detail], "")

fn Libp2pTcpHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn Libp2pTcpBytesFromHex(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](emptyBytes())
    if (len(text) % 2) != 0:
        return Err[Bytes](" libp2p tcp: invalid capture hex length")
    var out = bytesAlloc(len(text) / 2)
    var i = 0
    while i < len(text):
        let hi = Libp2pTcpHexValue(text[i])
        let lo = Libp2pTcpHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes](" libp2p tcp: invalid capture hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn Libp2pTcpDecodeCapturedLines(text: str): Result[Bytes[]] =
    var out: Bytes[]
    out = []
    var start = 0
    for i in 0..len(text):
        let atEnd = i >= len(text)
        var sawLineBreak = false
        if !atEnd:
            sawLineBreak = text[i] == '\n'
        if atEnd || sawLineBreak:
            let count = i - start
            if count > 0:
                let line = bytesToString(bytesSlice(bytesFromString(text), start, count))
                let bytesRes = Libp2pTcpBytesFromHex(line)
                if IsErr(bytesRes):
                    return Err[Bytes[]](Error(bytesRes))
                add(out, Value(bytesRes))
            start = i + 1
    return Ok[Bytes[]](out)

fn Libp2pTcpTransportConfigDefault(): Libp2pTcpTransportConfig =
    return Libp2pTcpTransportConfig(
        secure: types.Libp2pSecureNoise,
        mux: types.Libp2pMuxYamux
    )

fn Libp2pTcpTransportSupportsAddr(addr: types.Libp2pMultiaddr): bool =
    return addr.transport == types.Libp2pTransportTcp &&
        addr.secure == types.Libp2pSecureNoise &&
        addr.mux == types.Libp2pMuxYamux

fn Libp2pTcpLoopbackRoundtrip(protocol: types.Libp2pProtocolId,
                                payload: Bytes): Result[Bytes] =
    return Libp2pTcpLoopbackRequestResponseRaw(protocol,
                                                 payload.data,
                                                 payload.len,
                                                 payload.data,
                                                 payload.len)

fn Libp2pTcpLoopbackMultistream(protocol: types.Libp2pProtocolId): Result[bool] =
    let roundtripRes = Libp2pTcpLoopbackRoundtrip(protocol, emptyBytes())
    if IsErr(roundtripRes):
        return Err[bool](Error(roundtripRes))
    if bytesLen(Value(roundtripRes)) != 0:
        return Err[bool](" libp2p tcp: unexpected loopback payload")
    return Ok[bool](true)

fn Libp2pTcpLoopbackRequestResponseRaw(protocol: types.Libp2pProtocolId,
                                         requestData: ptr,
                                         requestLen: int32,
                                         responseData: ptr,
                                         responseLen: int32): Result[Bytes] =
    var selectBytes = emptyBytes()
    selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    var selectText: str
    selectText = bytesToString(selectBytes)
    var requestHandle: uint64 = uint64(0)
    requestHandle = Libp2pTcpBufferHandleFromRawBridge(requestData, requestLen)
    var responseHandle: uint64 = uint64(0)
    responseHandle = Libp2pTcpBufferHandleFromRawBridge(responseData, responseLen)
    if requestHandle == uint64(0) || responseHandle == uint64(0):
        if requestHandle != uint64(0):
            let _ = Libp2pTcpBufferHandleReleaseBridge(requestHandle)
        if responseHandle != uint64(0):
            let _ = Libp2pTcpBufferHandleReleaseBridge(responseHandle)
        return Err[Bytes](" libp2p tcp: loopback input handle failed")
    var handle: uint64 = uint64(0)
    handle = Libp2pTcpLoopbackRequestResponseHandleBridge(selectText,
                                                            requestHandle,
                                                            responseHandle)
    let _ = Libp2pTcpBufferHandleReleaseBridge(requestHandle)
    let _ = Libp2pTcpBufferHandleReleaseBridge(responseHandle)
    var bytesRes = Ok[Bytes](emptyBytes())
    bytesRes = Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return Err[Bytes](Libp2pTcpBridgeError(" libp2p tcp: loopback request-response bridge failed"))
    return Ok[Bytes](Value(bytesRes))

fn Libp2pTcpLoopbackRequestResponse(protocol: types.Libp2pProtocolId,
                                      requestPayload: Bytes,
                                      responsePayload: Bytes): Result[Bytes] =
    return Libp2pTcpLoopbackRequestResponseRaw(protocol,
                                                 requestPayload.data,
                                                 requestPayload.len,
                                                 responsePayload.data,
                                                 responsePayload.len)

fn Libp2pTcpServePayloadOnce(host: str,
                               port: int32,
                               protocol: types.Libp2pProtocolId,
                               payload: Bytes,
                               readyPath: str): Result[bool] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let payloadHex = Libp2pTcpBridgeHexFrom(payload.data, payload.len)
    let ok: int32 = Libp2pTcpServePayloadOnceBridge(host,
                                                      port,
                                                      selectText,
                                                      payloadHex,
                                                      readyPath)
    if ok == 0:
        return Err[bool](Libp2pTcpBridgeError(" libp2p tcp: serve payload bridge failed"))
    return Ok[bool](true)

fn Libp2pTcpRecvPayloadOnce(host: str,
                              port: int32,
                              protocol: types.Libp2pProtocolId): Result[Bytes] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let handle = Libp2pTcpRecvPayloadOnceBridge(host, port, selectText)
    let bytesRes = Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return Err[Bytes](Libp2pTcpBridgeError(" libp2p tcp: recv payload bridge failed"))
    return Ok[Bytes](Value(bytesRes))

fn Libp2pTcpRequestResponse(host: str,
                              port: int32,
                              protocol: types.Libp2pProtocolId,
                              requestPayload: Bytes): Result[Bytes] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let requestHex = Libp2pTcpBridgeHexFrom(requestPayload.data, requestPayload.len)
    let handle = Libp2pTcpRequestResponseBridge(host, port, selectText, requestHex)
    let bytesRes = Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return Err[Bytes](Libp2pTcpBridgeError(" libp2p tcp: request-response bridge failed"))
    return Ok[Bytes](Value(bytesRes))

fn Libp2pTcpServeRequestCaptureOnce(host: str,
                                      port: int32,
                                      protocol: types.Libp2pProtocolId,
                                      responsePayload: Bytes,
                                      readyPath: str): Result[Bytes] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let responseHex = Libp2pTcpBridgeHexFrom(responsePayload.data, responsePayload.len)
    let handle = Libp2pTcpServeRequestCaptureOnceBridge(host, port, selectText, responseHex, readyPath)
    let bytesRes = Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return Err[Bytes](Libp2pTcpBridgeError(" libp2p tcp: serve request capture bridge failed"))
    return Ok[Bytes](Value(bytesRes))

fn Libp2pTcpServePayloadWindow(host: str,
                                 port: int32,
                                 protocol: types.Libp2pProtocolId,
                                 payload: Bytes,
                                 readyPath: str,
                                 maxServeCount: int32,
                                 waitMs: int32): Result[bool] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let payloadHex = Libp2pTcpBridgeHexFrom(payload.data, payload.len)
    let ok: int32 = Libp2pTcpServePayloadWindowBridge(host,
                                                        port,
                                                        selectText,
                                                        payloadHex,
                                                        readyPath,
                                                        maxServeCount,
                                                        waitMs)
    if ok == 0:
        return Err[bool](Libp2pTcpBridgeError(" libp2p tcp: serve payload window bridge failed"))
    return Ok[bool](true)

fn Libp2pTcpServeRequestCaptureWindow(host: str,
                                        port: int32,
                                        protocol: types.Libp2pProtocolId,
                                        responsePayload: Bytes,
                                        readyPath: str,
                                        maxCaptureCount: int32,
                                        waitMs: int32): Result[Bytes[]] =
    let selectBytes = multistream.Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let responseHex = Libp2pTcpBridgeHexFrom(responsePayload.data, responsePayload.len)
    let handle = Libp2pTcpServeRequestCaptureWindowBridge(host,
                                                            port,
                                                            selectText,
                                                            responseHex,
                                                            readyPath,
                                                            maxCaptureCount,
                                                            waitMs)
    let capturedRes = Libp2pTcpBytesFromHandle(handle)
    if IsErr(capturedRes):
        return Err[Bytes[]](Libp2pTcpBridgeError(" libp2p tcp: serve request capture window bridge failed"))
    let decodeRes = Libp2pTcpDecodeCapturedLines(bytesToString(Value(capturedRes)))
    if IsErr(decodeRes):
        return Err[Bytes[]](Error(decodeRes))
    return Ok[Bytes[]](Value(decodeRes))
