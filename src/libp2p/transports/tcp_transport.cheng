import std/result
import std/rawbytes
import cheng/libp2p/core/multistream
import cheng/libp2p/core/types

@importc("cheng_buffer_handle_len_bridge")
fn v3Libp2pTcpBufferHandleLenBridge(handle: uint64): int32
@importc("cheng_buffer_handle_byte_bridge")
fn v3Libp2pTcpBufferHandleByteBridge(handle: uint64, idx: int32): int32
@importc("cheng_buffer_handle_release_bridge")
fn v3Libp2pTcpBufferHandleReleaseBridge(handle: uint64): int32
@importc("cheng_buffer_handle_from_raw_bridge")
fn v3Libp2pTcpBufferHandleFromRawBridge(data: ptr, n: int32): uint64
@importc("cheng_tcp_last_error_handle_bridge")
fn v3Libp2pTcpLastErrorHandleBridge(): uint64
@importc("cheng_tcp_loopback_request_response_handle_bridge")
fn v3Libp2pTcpLoopbackRequestResponseHandleBridge(protocolText: str,
                                                  requestHandle: uint64,
                                                  responseHandle: uint64): uint64
@importc("cheng_tcp_serve_payload_once_bridge")
fn v3Libp2pTcpServePayloadOnceBridge(hostText: str,
                                     port: int32,
                                     protocolText: str,
                                     payloadWire: str,
                                     readyPath: str): int32
