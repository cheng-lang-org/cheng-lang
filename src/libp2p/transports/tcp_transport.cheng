fn v3Libp2pTcpServePayloadWindowBridge(hostText: str,
                                       port: int32,
                                       protocolText: str,
                                       payloadWire: str,
                                       readyPath: str,
                                       maxServeCount: int32,
                                       waitMs: int32): int32
@importc("cheng_tcp_recv_payload_once_bridge")
fn v3Libp2pTcpRecvPayloadOnceBridge(hostText: str,
                                    port: int32,
                                    protocolText: str): uint64
@importc("cheng_tcp_request_response_bridge")
fn v3Libp2pTcpRequestResponseBridge(hostText: str,
                                    port: int32,
                                    protocolText: str,
                                    requestWire: str): uint64
@importc("cheng_tcp_serve_request_capture_once_bridge")
fn v3Libp2pTcpServeRequestCaptureOnceBridge(hostText: str,
                                            port: int32,
                                            protocolText: str,
                                            responseWire: str,
                                            readyPath: str): uint64
@importc("cheng_tcp_serve_request_capture_window_bridge")
fn v3Libp2pTcpServeRequestCaptureWindowBridge(hostText: str,
                                              port: int32,
                                              protocolText: str,
                                              responseWire: str,
                                              readyPath: str,
                                              maxCaptureCount: int32,
                                              waitMs: int32): uint64

type
    V3Libp2pTcpTransportConfig =
        secure: types.V3Libp2pSecureKind
        mux: types.V3Libp2pMuxKind

fn v3Libp2pTcpOwnedBytesFromString(text: str): Bytes =
    return bytesSlice(bytesFromString(text), 0, len(text))

fn v3Libp2pTcpHexDigit(value: int32): int32 =
    if value < 10:
        return int32('0') + value
    return int32('a') + (value - 10)

fn v3Libp2pTcpBridgeHexFrom(data: ptr, n: int32): str =
    if data == nil || n <= 0:
        return ""
    var out = bytesAlloc(n * 2)
    var i = 0
    while i < n:
        let value = chengRawbytesGetAt(data, i)
        let hi = value / 16
        let lo = value - (hi * 16)
        bytesSet(out, i * 2, v3Libp2pTcpHexDigit(hi))
        bytesSet(out, i * 2 + 1, v3Libp2pTcpHexDigit(lo))
        i = i + 1
    return bytesToString(out)

fn v3Libp2pTcpBytesFromHandle(handle: uint64): Result[Bytes] =
    if handle == uint64(0):
        return Err[Bytes]("v3 libp2p tcp: bridge failed")
    var n: int32
    n = v3Libp2pTcpBufferHandleLenBridge(handle)
    if n < 0:
        let _ = v3Libp2pTcpBufferHandleReleaseBridge(handle)
        return Err[Bytes]("v3 libp2p tcp: bridge handle len failed")
    var out = bytesAlloc(n)
    var i = 0
    while i < n:
        var b: int32
        b = v3Libp2pTcpBufferHandleByteBridge(handle, i)
        if b < 0:
            let _ = v3Libp2pTcpBufferHandleReleaseBridge(handle)
            return Err[Bytes]("v3 libp2p tcp: bridge handle byte failed")
        bytesSet(out, i, b)
        i = i + 1
    let _ = v3Libp2pTcpBufferHandleReleaseBridge(handle)
    return Ok[Bytes](out)

fn v3Libp2pTcpBridgeError(defaultText: str): str =
    let handle = v3Libp2pTcpLastErrorHandleBridge()
    if handle == uint64(0):
        return defaultText
    let bytesRes = v3Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return defaultText
    let detail = bytesToString(Value(bytesRes))
    if len(detail) <= 0:
        return defaultText
    return defaultText + ": " + detail

fn v3Libp2pTcpHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn v3Libp2pTcpBytesFromHex(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](emptyBytes())
    if (len(text) % 2) != 0:
        return Err[Bytes]("v3 libp2p tcp: invalid capture hex length")
    var out = bytesAlloc(len(text) / 2)
    var i = 0
    while i < len(text):
        let hi = v3Libp2pTcpHexValue(text[i])
        let lo = v3Libp2pTcpHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("v3 libp2p tcp: invalid capture hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn v3Libp2pTcpDecodeCapturedLines(text: str): Result[Bytes[]] =
    var out: Bytes[]
    out = []
    var start = 0
    var i = 0
    while i <= len(text):
        let atEnd = i >= len(text)
        var sawLineBreak = false
        if !atEnd:
            sawLineBreak = text[i] == '\n'
        if atEnd || sawLineBreak:
            let count = i - start
            if count > 0:
                let line = bytesToString(bytesSlice(bytesFromString(text), start, count))
                let bytesRes = v3Libp2pTcpBytesFromHex(line)
                if IsErr(bytesRes):
                    return Err[Bytes[]](Error(bytesRes))
                add(out, Value(bytesRes))
            start = i + 1
        i = i + 1
    return Ok[Bytes[]](out)

fn v3Libp2pTcpTransportConfigDefault(): V3Libp2pTcpTransportConfig =
    return V3Libp2pTcpTransportConfig(
        secure: types.v3Libp2pSecureNoise,
        mux: types.v3Libp2pMuxYamux
    )

fn v3Libp2pTcpTransportSupportsAddr(addr: types.V3Libp2pMultiaddr): bool =
    return addr.transport == types.v3Libp2pTransportTcp &&
        addr.secure == types.v3Libp2pSecureNoise &&
        addr.mux == types.v3Libp2pMuxYamux

fn v3Libp2pTcpLoopbackRoundtrip(protocol: types.V3Libp2pProtocolId,
                                payload: Bytes): Result[Bytes] =
    return v3Libp2pTcpLoopbackRequestResponseRaw(protocol,
                                                 payload.data,
                                                 payload.len,
                                                 payload.data,
                                                 payload.len)

fn v3Libp2pTcpLoopbackMultistream(protocol: types.V3Libp2pProtocolId): Result[bool] =
    let roundtripRes = v3Libp2pTcpLoopbackRoundtrip(protocol, emptyBytes())
    if IsErr(roundtripRes):
        return Err[bool](Error(roundtripRes))
    if bytesLen(Value(roundtripRes)) != 0:
        return Err[bool]("v3 libp2p tcp: unexpected loopback payload")
    return Ok[bool](true)

fn v3Libp2pTcpLoopbackRequestResponseRaw(protocol: types.V3Libp2pProtocolId,
                                         requestData: ptr,
                                         requestLen: int32,
                                         responseData: ptr,
                                         responseLen: int32): Result[Bytes] =
    var selectBytes = emptyBytes()
    selectBytes = multistream.v3Libp2pMultistreamSelectBytes(protocol)
    var selectText: str
    selectText = bytesToString(selectBytes)
    var requestHandle: uint64 = uint64(0)
    requestHandle = v3Libp2pTcpBufferHandleFromRawBridge(requestData, requestLen)
    var responseHandle: uint64 = uint64(0)
    responseHandle = v3Libp2pTcpBufferHandleFromRawBridge(responseData, responseLen)
    if requestHandle == uint64(0) || responseHandle == uint64(0):
        if requestHandle != uint64(0):
            let _ = v3Libp2pTcpBufferHandleReleaseBridge(requestHandle)
        if responseHandle != uint64(0):
            let _ = v3Libp2pTcpBufferHandleReleaseBridge(responseHandle)
        return Err[Bytes]("v3 libp2p tcp: loopback input handle failed")
    var handle: uint64 = uint64(0)
    handle = v3Libp2pTcpLoopbackRequestResponseHandleBridge(selectText,
                                                            requestHandle,
                                                            responseHandle)
    let _ = v3Libp2pTcpBufferHandleReleaseBridge(requestHandle)
    let _ = v3Libp2pTcpBufferHandleReleaseBridge(responseHandle)
    var bytesRes = Ok[Bytes](emptyBytes())
    bytesRes = v3Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return Err[Bytes](v3Libp2pTcpBridgeError("v3 libp2p tcp: loopback request-response bridge failed"))
    return Ok[Bytes](Value(bytesRes))

fn v3Libp2pTcpLoopbackRequestResponse(protocol: types.V3Libp2pProtocolId,
                                      requestPayload: Bytes,
                                      responsePayload: Bytes): Result[Bytes] =
    return v3Libp2pTcpLoopbackRequestResponseRaw(protocol,
                                                 requestPayload.data,
                                                 requestPayload.len,
                                                 responsePayload.data,
                                                 responsePayload.len)

fn v3Libp2pTcpServePayloadOnce(host: str,
                               port: int32,
                               protocol: types.V3Libp2pProtocolId,
                               payload: Bytes,
                               readyPath: str): Result[bool] =
    let selectBytes = multistream.v3Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let payloadHex = v3Libp2pTcpBridgeHexFrom(payload.data, payload.len)
    let ok: int32 = v3Libp2pTcpServePayloadOnceBridge(host,
                                                      port,
                                                      selectText,
                                                      payloadHex,
                                                      readyPath)
    if ok == 0:
        return Err[bool](v3Libp2pTcpBridgeError("v3 libp2p tcp: serve payload bridge failed"))
    return Ok[bool](true)

fn v3Libp2pTcpRecvPayloadOnce(host: str,
                              port: int32,
                              protocol: types.V3Libp2pProtocolId): Result[Bytes] =
    let selectBytes = multistream.v3Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let handle = v3Libp2pTcpRecvPayloadOnceBridge(host, port, selectText)
    let bytesRes = v3Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return Err[Bytes](v3Libp2pTcpBridgeError("v3 libp2p tcp: recv payload bridge failed"))
    return Ok[Bytes](Value(bytesRes))

fn v3Libp2pTcpRequestResponse(host: str,
                              port: int32,
                              protocol: types.V3Libp2pProtocolId,
                              requestPayload: Bytes): Result[Bytes] =
    let selectBytes = multistream.v3Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let requestHex = v3Libp2pTcpBridgeHexFrom(requestPayload.data, requestPayload.len)
    let handle = v3Libp2pTcpRequestResponseBridge(host, port, selectText, requestHex)
    let bytesRes = v3Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return Err[Bytes](v3Libp2pTcpBridgeError("v3 libp2p tcp: request-response bridge failed"))
    return Ok[Bytes](Value(bytesRes))

fn v3Libp2pTcpServeRequestCaptureOnce(host: str,
                                      port: int32,
                                      protocol: types.V3Libp2pProtocolId,
                                      responsePayload: Bytes,
                                      readyPath: str): Result[Bytes] =
    let selectBytes = multistream.v3Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let responseHex = v3Libp2pTcpBridgeHexFrom(responsePayload.data, responsePayload.len)
    let handle = v3Libp2pTcpServeRequestCaptureOnceBridge(host, port, selectText, responseHex, readyPath)
    let bytesRes = v3Libp2pTcpBytesFromHandle(handle)
    if IsErr(bytesRes):
        return Err[Bytes](v3Libp2pTcpBridgeError("v3 libp2p tcp: serve request capture bridge failed"))
    return Ok[Bytes](Value(bytesRes))

fn v3Libp2pTcpServePayloadWindow(host: str,
                                 port: int32,
                                 protocol: types.V3Libp2pProtocolId,
                                 payload: Bytes,
                                 readyPath: str,
                                 maxServeCount: int32,
                                 waitMs: int32): Result[bool] =
    let selectBytes = multistream.v3Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let payloadHex = v3Libp2pTcpBridgeHexFrom(payload.data, payload.len)
    let ok: int32 = v3Libp2pTcpServePayloadWindowBridge(host,
                                                        port,
                                                        selectText,
                                                        payloadHex,
                                                        readyPath,
                                                        maxServeCount,
                                                        waitMs)
    if ok == 0:
        return Err[bool](v3Libp2pTcpBridgeError("v3 libp2p tcp: serve payload window bridge failed"))
    return Ok[bool](true)

fn v3Libp2pTcpServeRequestCaptureWindow(host: str,
                                        port: int32,
                                        protocol: types.V3Libp2pProtocolId,
                                        responsePayload: Bytes,
                                        readyPath: str,
                                        maxCaptureCount: int32,
                                        waitMs: int32): Result[Bytes[]] =
    let selectBytes = multistream.v3Libp2pMultistreamSelectBytes(protocol)
    let selectText = bytesToString(selectBytes)
    let responseHex = v3Libp2pTcpBridgeHexFrom(responsePayload.data, responsePayload.len)
    let handle = v3Libp2pTcpServeRequestCaptureWindowBridge(host,
                                                            port,
                                                            selectText,
                                                            responseHex,
                                                            readyPath,
                                                            maxCaptureCount,
                                                            waitMs)
    let capturedRes = v3Libp2pTcpBytesFromHandle(handle)
    if IsErr(capturedRes):
        return Err[Bytes[]](v3Libp2pTcpBridgeError("v3 libp2p tcp: serve request capture window bridge failed"))
    let decodeRes = v3Libp2pTcpDecodeCapturedLines(bytesToString(Value(capturedRes)))
    if IsErr(decodeRes):
        return Err[Bytes[]](Error(decodeRes))
    return Ok[Bytes[]](Value(decodeRes))

fn V3Libp2pTcpServePayloadOnce(host: str,
                               port: int32,
                               protocol: types.V3Libp2pProtocolId,
                               payload: Bytes,
                               readyPath: str): Result[bool] =
    return v3Libp2pTcpServePayloadOnce(host, port, protocol, payload, readyPath)

fn V3Libp2pTcpRecvPayloadOnce(host: str,
                              port: int32,
                              protocol: types.V3Libp2pProtocolId): Result[Bytes] =
    return v3Libp2pTcpRecvPayloadOnce(host, port, protocol)
