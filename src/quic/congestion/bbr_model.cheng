# BBR congestion control model.

import cheng/quic/congestion/common
type
    BbrBandwidthFilter =
        appLimited: bool
        appLimitedExitTarget: int64
        lastSampleBandwidth: int64
        window: SlidingWindowExtremumModel

    BbrModel =
        btlbwFound: bool
        exitingQuiescence: bool
        endOfRecoveryValid: bool
        endOfRoundTripValid: bool
        ackAggregationStartTimeValid: bool
        probeRttRoundValid: bool
        probeRttEndTimeValid: bool
        rttSampleExpired: bool
        minRttTimestampValid: bool

        initialCongestionWindowPackets: int32
        congestionWindow: int64
        initialCongestionWindow: int64
        recoveryWindow: int64

        bytesInFlight: int64
        bytesInFlightMax: int64
        exemptions: int32

        roundTripCounter: int64
        cwndGain: int64
        pacingGain: int64
        sendQuantum: int64
        slowStartupRoundCounter: int32
        pacingCycleIndex: int32

        ackAggregationStartTime: int64
        aggregatedAckBytes: int64

        recoveryState: BbrRecoveryState
        state: BbrState
        cycleStart: int64
        endOfRoundTrip: int64
        endOfRecovery: int64
        lastStartupBandwidth: int64
        probeRttRound: int64
        probeRttEndTime: int64

        maxAckHeightFilter: SlidingWindowExtremumModel
        minRtt: int64
        minRttTimestamp: int64
        bandwidthFilter: BbrBandwidthFilter
        bandwidthEstimate: int64
        deliveryRateBps: int64
        pacingRateBps: int64
        targetCongestionWindow: int64
        minCongestionWindow: int64
        datagramPayloadBytes: int64

fn bbrMaxInt64(a: int64, b: int64): int64 =
    if a > b:
        return a
    return b

fn bbrMinInt64(a: int64, b: int64): int64 =
    if a < b:
        return a
    return b

fn bbrClampToInt64(value: int64): int64 =
    if value < 0:
        return 0
    if value > maxInt64Value:
        return maxInt64Value
    return value

fn bbrInitBandwidthFilter(): BbrBandwidthFilter =
    var filter: BbrBandwidthFilter
    filter.appLimited = false
    filter.appLimitedExitTarget = 0
    filter.lastSampleBandwidth = 0
    filter.window = initSlidingWindowExtremum(
        int64(bbrMaxBandwidthFilterLen),
        bbrDefaultFilterCapacity,
        swMax
    )
    return filter

fn bbrInit(
    initialWindowPackets: int32,
    datagramPayloadBytes: int32
): BbrModel =
    let initialWindowBytes: int64 = int64(datagramPayloadBytes) * int64(initialWindowPackets)
    let minPackets: int64 = int64(minCwndInMss)
    let minCwndByMss: int64 = int64(datagramPayloadBytes) * minPackets
    let minCwndByTwo: int64 = int64(datagramPayloadBytes) * 2
    var minCwnd: int64 = minCwndByTwo
    if minCwndByMss > minCwnd:
        minCwnd = minCwndByMss
    var model: BbrModel
    model.btlbwFound = false
    model.exitingQuiescence = true
    model.endOfRecoveryValid = false
    model.endOfRoundTripValid = false
    model.ackAggregationStartTimeValid = false
    model.probeRttRoundValid = false
    model.probeRttEndTimeValid = false
    model.rttSampleExpired = true
    model.minRttTimestampValid = false
    model.initialCongestionWindowPackets = initialWindowPackets
    model.congestionWindow = initialWindowBytes
    model.initialCongestionWindow = initialWindowBytes
    model.recoveryWindow = initialWindowBytes
    model.bytesInFlight = 0
    model.bytesInFlightMax = initialWindowBytes / 2
    model.exemptions = 0
    model.roundTripCounter = 0
    model.cwndGain = bbrCwndGain
    model.pacingGain = bbrHighGain
    model.sendQuantum = int64(datagramPayloadBytes)
    model.slowStartupRoundCounter = 0
    model.pacingCycleIndex = 0
    model.ackAggregationStartTime = 0
    model.aggregatedAckBytes = 0
    model.recoveryState = recoveryNone
    model.state = bbrStartup
    model.cycleStart = 0
    model.endOfRoundTrip = 0
    model.endOfRecovery = 0
    model.lastStartupBandwidth = 0
    model.probeRttRound = 0
    model.probeRttEndTime = 0
    model.maxAckHeightFilter = initSlidingWindowExtremum(
        int64(bbrMaxAckHeightFilterLen),
        bbrDefaultFilterCapacity,
        swMax
    )
    model.minRtt = maxInt64Value
    model.minRttTimestamp = 0
    model.bandwidthFilter = bbrInitBandwidthFilter()
    model.bandwidthEstimate = 0
    model.deliveryRateBps = 0
    model.pacingRateBps = 0
    model.targetCongestionWindow = initialWindowBytes
    model.minCongestionWindow = minCwnd
    model.datagramPayloadBytes = int64(datagramPayloadBytes)
    return model

fn bbrResetAckAggregation(model: var BbrModel) =
    model.ackAggregationStartTimeValid = false
    model.ackAggregationStartTime = 0
    model.aggregatedAckBytes = 0
    slidingWindowReset(model.maxAckHeightFilter)

fn bbrFilterCurrentBandwidth(filter: BbrBandwidthFilter): int64 =
    return slidingWindowCurrentValue(filter.window, 0)

fn bbrCurrentBandwidth(model: BbrModel): int64 =
    return bbrFilterCurrentBandwidth(model.bandwidthFilter)

fn bbrBytesPerSecondFromBandwidth(rate: int64): int64 =
    if rate <= 0:
        return 0
    return rate / bwUnit

fn bbrUpdateSendQuantum(model: var BbrModel) =
    let payload: int64 = model.datagramPayloadBytes
    var quantum: int64 = payload
    let pacingGain: int64 = model.pacingGain
    let pacingRate: int64 = (model.bandwidthEstimate * pacingGain) / gainUnit
    let pacingBytesPerSec: int64 = bbrBytesPerSecondFromBandwidth(pacingRate)
    if pacingBytesPerSec <= 0:
        quantum = payload
    elif pacingBytesPerSec < lowPacingRateThresholdBps:
        quantum = payload
    elif pacingBytesPerSec < highPacingRateThresholdBps:
        quantum = payload * 2
    else:
        let burst: int64 = pacingBytesPerSec / milliSecsInSec
        let limit: int64 = 64 * 1024
        if burst < limit:
            quantum = burst
        else:
            quantum = limit
    if quantum < payload:
        quantum = payload
    model.sendQuantum = quantum

fn bbrUpdateAckAggregation(model: var BbrModel, ack: AckEventSnapshot): int64 =
    if ack.ackedRetransmittableBytes <= 0:
        return 0
    if ! model.ackAggregationStartTimeValid:
        model.ackAggregationStartTime = ack.timeNow
        model.ackAggregationStartTimeValid = true
        model.aggregatedAckBytes = ack.ackedRetransmittableBytes
        return 0
    if ack.timeNow < model.ackAggregationStartTime:
        model.ackAggregationStartTime = ack.timeNow
        model.aggregatedAckBytes = ack.ackedRetransmittableBytes
        return 0
    let elapsedUs: int64 = ack.timeNow - model.ackAggregationStartTime
    let bandwidth: int64 = bbrCurrentBandwidth(model)
    if bandwidth <= 0:
        model.ackAggregationStartTime = ack.timeNow
        model.aggregatedAckBytes = ack.ackedRetransmittableBytes
        return 0
    let bandwidthBytesPerSec: int64 = bbrBytesPerSecondFromBandwidth(bandwidth)
    let expected: int64 = (bandwidthBytesPerSec * elapsedUs) / microSecsInSec
    if model.aggregatedAckBytes <= expected:
        model.aggregatedAckBytes = ack.ackedRetransmittableBytes
        model.ackAggregationStartTime = ack.timeNow
        return 0
    model.aggregatedAckBytes = model.aggregatedAckBytes + ack.ackedRetransmittableBytes
    if model.aggregatedAckBytes < 0:
        model.aggregatedAckBytes = maxInt64Value
    let ackHeight: int64 = model.aggregatedAckBytes - expected
    slidingWindowUpdate(model.maxAckHeightFilter, ackHeight, model.roundTripCounter)
    return ackHeight

fn bbrPacingIntervalUs(model: BbrModel): int64 =
    if model.pacingRateBps <= 0 || model.sendQuantum <= 0:
        return 0
    let interval: int64 = (model.sendQuantum * microSecsInSec) / model.pacingRateBps
    if interval <= 0:
        return 1
    return interval

fn bbrAdvancePacingCycle(model: var BbrModel) =
    let nextIndex: int32 = (model.pacingCycleIndex + 1) % gainCycleLength
    model.pacingCycleIndex = nextIndex
    model.pacingGain = bbrPacingGainAt(nextIndex)

fn bbrFilterRecordBandwidthSample(
    filter: var BbrBandwidthFilter,
    rate: int64,
    timestamp: int64,
    appLimitedSample: bool
) =
    if rate <= 0:
        return
    if appLimitedSample && rate < slidingWindowCurrentValue(filter.window, 0):
        return
    filter.lastSampleBandwidth = rate
    slidingWindowUpdate(filter.window, rate, timestamp)
    if ! appLimitedSample:
        filter.appLimited = false

fn bbrRecordBandwidthSample(
    model: var BbrModel,
    rate: int64,
    timestamp: int64,
    appLimitedSample: bool
) =
    bbrFilterRecordBandwidthSample(model.bandwidthFilter, rate, timestamp, appLimitedSample)

fn bbrUpdateTargetCongestionWindow(model: var BbrModel, rttUs: int64) =
    if rttUs <= 0:
        return
    let bandwidth: int64 = bbrCurrentBandwidth(model)
    if bandwidth <= 0:
        return
    let bdpBytes: int64 = (bandwidth * rttUs) / (bwUnit * microSecsInSec)
    let scaled: int64 = (bdpBytes * model.cwndGain) / gainUnit
    let target: int64 = bbrMaxInt64(model.minCongestionWindow, scaled)
    model.targetCongestionWindow = bbrClampToInt64(target)

fn bbrCanSend(model: BbrModel): bool =
    return model.bytesInFlight < model.congestionWindow || model.exemptions > 0

fn bbrSendAllowance(model: BbrModel): int64 =
    if model.congestionWindow > model.bytesInFlight:
        return model.congestionWindow - model.bytesInFlight
    return 0

fn bbrBytesInFlight(model: BbrModel): int64 =
    return model.bytesInFlight

fn bbrOnPacketSent(model: var BbrModel, bytes: int64, appLimited: bool) =
    model.bytesInFlight = bbrClampToInt64(model.bytesInFlight + bytes)
    if model.bytesInFlight > model.bytesInFlightMax:
        model.bytesInFlightMax = model.bytesInFlight
    if appLimited:
        model.bandwidthFilter.appLimited = true

fn bbrOnDataAcked(model: var BbrModel, ack: AckEventSnapshot): int64 =
    let acked: int64 = ack.ackedRetransmittableBytes
    if acked <= 0:
        return 0
    if model.bytesInFlight > acked:
        model.bytesInFlight = model.bytesInFlight - acked
    else:
        model.bytesInFlight = 0

    var sampleRtt: int64 = ack.smoothedRtt
    if sampleRtt == 0:
        sampleRtt = ack.minRtt
    var effectiveMinRtt: int64
    if model.minRtt != maxInt64Value:
        effectiveMinRtt = model.minRtt
    if sampleRtt == 0 && model.minRttTimestampValid && effectiveMinRtt != 0:
        sampleRtt = model.minRtt

    if ack.minRttValid:
        if (! model.minRttTimestampValid) ||
           (ack.minRtt < model.minRtt) ||
           (ack.timeNow > model.minRttTimestamp &&
            ack.timeNow - model.minRttTimestamp > bbrMinRttExpirationUs):
            model.minRtt = ack.minRtt
            model.minRttTimestamp = ack.timeNow
            model.minRttTimestampValid = true
            model.rttSampleExpired = false

    if sampleRtt == 0 && model.minRttTimestampValid:
        sampleRtt = model.minRtt

    var deliveryRate: int64
    if sampleRtt == 0:
        deliveryRate = 0
    else:
        deliveryRate = (acked * microSecsInSec * bwUnit) / sampleRtt

    model.deliveryRateBps = bbrBytesPerSecondFromBandwidth(deliveryRate)
    bbrRecordBandwidthSample(model, deliveryRate, ack.timeNow, ack.largestAckAppLimited)
    if model.bandwidthEstimate < bbrCurrentBandwidth(model):
        model.bandwidthEstimate = bbrCurrentBandwidth(model)

    var newRound: bool
    if ! model.endOfRoundTripValid || ack.largestAck >= model.endOfRoundTrip:
        model.endOfRoundTripValid = true
        model.endOfRoundTrip = ack.largestSentPacketNumber
        model.roundTripCounter = model.roundTripCounter + 1
        newRound = true

    let ackHeight: int64 = bbrUpdateAckAggregation(model, ack)

    if model.state == bbrStartup:
        if newRound:
            var startupAdvance: bool
            if model.lastStartupBandwidth == 0:
                startupAdvance = true
            else:
                let startupTarget: int64 = (model.lastStartupBandwidth * bbrStartupGrowthTarget) / gainUnit
                if model.bandwidthEstimate > startupTarget:
                    startupAdvance = true
            if startupAdvance:
                model.lastStartupBandwidth = model.bandwidthEstimate
                model.slowStartupRoundCounter = 0
            else:
                if model.slowStartupRoundCounter < 2147483647:
                    model.slowStartupRoundCounter = model.slowStartupRoundCounter + 1
            if model.slowStartupRoundCounter >= bbrStartupSlowGrowRoundLimit:
                model.state = bbrDrain
                model.pacingGain = bbrDrainGain
                model.cycleStart = ack.timeNow
        if model.bandwidthEstimate > 0:
            model.btlbwFound = true

    if model.state == bbrDrain:
        if model.bytesInFlight <= model.targetCongestionWindow:
            model.state = bbrProbeBandwidth
            model.pacingGain = bbrPacingGainAt(model.pacingCycleIndex)
            model.cycleStart = ack.timeNow

    if model.state == bbrProbeBandwidth && newRound:
        bbrAdvancePacingCycle(model)
        model.cycleStart = ack.timeNow

    if model.minRttTimestampValid &&
       ack.timeNow > model.minRttTimestamp &&
       ack.timeNow - model.minRttTimestamp > bbrMinRttExpirationUs &&
       model.state != bbrProbeRtt:
        model.state = bbrProbeRtt
        model.pacingGain = gainUnit
        model.cwndGain = gainUnit
        model.probeRttEndTime = ack.timeNow + probeRttTimeUs
        model.probeRttEndTimeValid = true
        model.targetCongestionWindow = bbrMaxInt64(model.minCongestionWindow, model.datagramPayloadBytes * 2)

    if model.state == bbrProbeRtt:
        if model.probeRttEndTimeValid && ack.timeNow >= model.probeRttEndTime &&
           model.bytesInFlight <= model.targetCongestionWindow:
            model.state = bbrProbeBandwidth
            model.probeRttEndTimeValid = false
            model.cwndGain = bbrCwndGain
            model.pacingGain = bbrPacingGainAt(model.pacingCycleIndex)
            model.minRttTimestamp = ack.timeNow
            model.minRttTimestampValid = true

    var targetRtt: int64
    if sampleRtt != 0:
        targetRtt = sampleRtt
    elif model.minRttTimestampValid && effectiveMinRtt != 0:
        targetRtt = effectiveMinRtt

    if targetRtt > 0:
        bbrUpdateTargetCongestionWindow(model, targetRtt)

    bbrUpdateSendQuantum(model)

    let pacingBytesPerSec: int64 = (bbrBytesPerSecondFromBandwidth(model.bandwidthEstimate) * model.pacingGain) / gainUnit
    if pacingBytesPerSec > 0:
        model.pacingRateBps = pacingBytesPerSec

    var desired: int64 = bbrMaxInt64(model.targetCongestionWindow, model.minCongestionWindow)
    let quantaPadding: int64 = quantaFactor * model.sendQuantum
    if quantaPadding > 0 && desired <= maxInt64Value - quantaPadding:
        desired = desired + quantaPadding
    else:
        desired = bbrMaxInt64(desired, model.minCongestionWindow)

    if model.btlbwFound:
        var entry: SlidingWindowExtremumEntry
        if slidingWindowPeek(model.maxAckHeightFilter, entry):
            if desired <= maxInt64Value - entry.value:
                desired = desired + entry.value
            else:
                desired = maxInt64Value

    model.congestionWindow = bbrClampToInt64(desired)
    model.recoveryWindow = model.congestionWindow

    if model.congestionWindow < model.minCongestionWindow:
        model.congestionWindow = model.minCongestionWindow

    if model.bytesInFlight > model.congestionWindow:
        model.bytesInFlight = model.congestionWindow
    return ackHeight

fn bbrOnDataLost(model: var BbrModel, loss: LossEventSnapshot) =
    let lostBytes: int64 = loss.retransmittableBytesLost
    if model.bytesInFlight > lostBytes:
        model.bytesInFlight = model.bytesInFlight - lostBytes
    else:
        model.bytesInFlight = 0

    bbrResetAckAggregation(model)

    model.recoveryState = recoveryConservative
    model.state = bbrProbeBandwidth
    model.endOfRecoveryValid = true
    model.endOfRecovery = loss.largestSentPacketNumber

    let halved: int64 = model.congestionWindow / 2
    model.congestionWindow = bbrMaxInt64(halved, model.minCongestionWindow)
    model.targetCongestionWindow = model.congestionWindow
    model.recoveryWindow = model.congestionWindow
    model.bytesInFlight = bbrMinInt64(model.bytesInFlight, model.congestionWindow)
