# CUBIC congestion control model.

import cheng/quic/congestion/common

const
    cubicScale = 1024
    cubicBetaScaledDefault = 717
    cubicCScaledDefault = 410
    cubicMillisPerSecond = 1000
    cubicMillisCubeScale = 1000000000

type
    CubicModel =
        hasHadCongestionEvent: bool
        isInRecovery: bool
        isInPersistentCongestion: bool
        timeOfLastAckValid: bool

        initialWindowPackets: int32
        sendIdleTimeoutMs: int32

        congestionWindow: int64
        prevCongestionWindow: int64
        slowStartThreshold: int64
        prevSlowStartThreshold: int64
        aimdWindow: int64
        prevAimdWindow: int64
        aimdAccumulator: int64

        bytesInFlight: int64
        bytesInFlightMax: int64
        lastSendAllowance: int64
        exemptions: int32

        timeOfLastAck: int64
        timeOfCongAvoidStart: int64
        kCubic: int64
        prevKCubic: int64
        windowPrior: int64
        prevWindowPrior: int64
        windowMax: int64
        prevWindowMax: int64
        windowLastMax: int64
        prevWindowLastMax: int64

        hyStartState: HyStartState
        hyStartAckCount: int64
        minRttInLastRound: int64
        minRttInCurrentRound: int64
        cssBaselineMinRtt: int64
        hyStartRoundEnd: int64
        cWndSlowStartGrowthDivisor: int64
        conservativeSlowStartRounds: int64

        recoverySentPacketNumber: int64
        datagramPayloadBytes: int64
        betaScaled: int64
        cParamScaled: int64

fn cubicMaxInt64(a: int64, b: int64): int64 =
    if a > b:
        return a
    return b

fn cubicMinInt64(a: int64, b: int64): int64 =
    if a < b:
        return a
    return b

fn cubicComputeMinCwnd(model: CubicModel): int64 =
    let twoPackets: int64 = model.datagramPayloadBytes * 2
    let minPackets: int64 = model.datagramPayloadBytes * int64(minCwndInMss)
    if twoPackets > minPackets:
        return twoPackets
    return minPackets

fn cubicSaturatingAdd(a: int64, b: int64): int64 =
    if b > 0 && a > maxInt64Value - b:
        return maxInt64Value
    return a + b

fn cubicSaturatingMulPositive(a: int64, b: int64): int64 =
    if a <= 0 || b <= 0:
        return 0
    if a > maxInt64Value / b:
        return maxInt64Value
    return a * b

fn cubicSaturatingMulSigned(a: int64, b: int64): int64 =
    if a == 0 || b == 0:
        return 0
    var neg: bool
    var x: int64 = a
    var y: int64 = b
    if x < 0:
        x = -x
        neg = !neg
    if y < 0:
        y = -y
        neg = !neg
    let product: int64 = cubicSaturatingMulPositive(x, y)
    if !neg:
        return product
    if product >= maxInt64Value:
        return -maxInt64Value
    return -product

fn cubicCubePositive(value: int64): int64 =
    if value <= 0:
        return 0
    let square: int64 = cubicSaturatingMulPositive(value, value)
    return cubicSaturatingMulPositive(square, value)

fn cubicIntegerCbrt(value: int64): int64 =
    if value <= 0:
        return 0
    var hi: int64 = 1
    while hi < maxInt64Value && cubicCubePositive(hi) < value:
        if hi > maxInt64Value / 2:
            hi = maxInt64Value
            break
        hi = hi * 2
    var lo: int64
    while lo < hi:
        let gap: int64 = hi - lo
        let mid: int64 = lo + ((gap + 1) / 2)
        let cube: int64 = cubicCubePositive(mid)
        if cube == value:
            return mid
        if cube < value:
            lo = mid
        else:
            hi = mid - 1
    return lo

fn cubicAddSignedClamped(base: int64, delta: int64): int64 =
    if delta >= 0:
        return cubicSaturatingAdd(base, delta)
    let magnitude: int64 = -delta
    if magnitude >= base:
        return 0
    return base - magnitude

fn cubicBytesToPackets(model: CubicModel, bytes: int64): int64 =
    if bytes <= 0 || model.datagramPayloadBytes <= 0:
        return 0
    var packets: int64 = bytes / model.datagramPayloadBytes
    if packets <= 0:
        packets = 1
    return packets

fn cubicPacketsToBytes(model: CubicModel, packets: int64): int64 =
    if packets <= 0 || model.datagramPayloadBytes <= 0:
        return 0
    return cubicSaturatingMulPositive(packets, model.datagramPayloadBytes)

fn cubicPacketsScaledToBytes(model: CubicModel, packetsScaled: int64): int64 =
    if packetsScaled <= 0 || model.datagramPayloadBytes <= 0:
        return 0
    let scaledBytes: int64 = cubicSaturatingMulPositive(packetsScaled, model.datagramPayloadBytes)
    var bytes: int64 = scaledBytes / cubicScale
    if scaledBytes % cubicScale != 0:
        bytes = bytes + 1
    return bytes

fn cubicReducedWindow(model: CubicModel): int64 =
    let minCwnd: int64 = cubicComputeMinCwnd(model)
    if model.congestionWindow <= 0:
        return minCwnd
    let scaled: int64 = cubicSaturatingMulPositive(model.congestionWindow, model.betaScaled)
    var reduced: int64 = scaled / cubicScale
    if reduced < minCwnd:
        reduced = minCwnd
    return reduced

fn cubicScaledPacketOffset(model: CubicModel, diffMs: int64): int64 =
    if diffMs == 0 || model.cParamScaled <= 0:
        return 0
    let square: int64 = cubicSaturatingMulSigned(diffMs, diffMs)
    let cube: int64 = cubicSaturatingMulSigned(square, diffMs)
    if cube == 0:
        return 0
    let numerator: int64 = cubicSaturatingMulSigned(model.cParamScaled, cube)
    return numerator / cubicMillisCubeScale

fn cubicUpdateKCubic(model: var CubicModel) =
    if model.cParamScaled <= 0 || model.windowMax <= 0:
        model.kCubic = 0
        return
    let windowMaxPackets: int64 = cubicBytesToPackets(model, model.windowMax)
    if windowMaxPackets <= 0:
        model.kCubic = 0
        return
    let oneMinusBetaScaled: int64 = cubicScale - model.betaScaled
    if oneMinusBetaScaled <= 0:
        model.kCubic = 0
        return
    var cubicRootInput: int64 = cubicSaturatingMulPositive(windowMaxPackets, oneMinusBetaScaled)
    cubicRootInput = cubicSaturatingMulPositive(cubicRootInput, cubicMillisCubeScale)
    cubicRootInput = cubicRootInput / model.cParamScaled
    if cubicRootInput <= 0:
        model.kCubic = 0
        return
    model.kCubic = cubicIntegerCbrt(cubicRootInput)

fn cubicComputeTargetWindow(model: CubicModel, nowUs: int64): int64 =
    if model.timeOfCongAvoidStart == 0:
        return model.congestionWindow
    let windowMaxPackets: int64 = cubicBytesToPackets(model, model.windowMax)
    if windowMaxPackets <= 0:
        return model.congestionWindow
    var elapsedUs: int64
    if nowUs > model.timeOfCongAvoidStart:
        elapsedUs = nowUs - model.timeOfCongAvoidStart
    let elapsedMs: int64 = elapsedUs / cubicMillisPerSecond
    let diffMs: int64 = elapsedMs - model.kCubic
    let basePacketsScaled: int64 = cubicSaturatingMulPositive(windowMaxPackets, cubicScale)
    let deltaPacketsScaled: int64 = cubicScaledPacketOffset(model, diffMs)
    let desiredPacketsScaled: int64 = cubicAddSignedClamped(basePacketsScaled, deltaPacketsScaled)
    return cubicPacketsScaledToBytes(model, desiredPacketsScaled)

fn cubicComputeRenoTarget(model: var CubicModel, acked: int64): int64 =
    if acked <= 0:
        return model.congestionWindow
    if model.congestionWindow <= 0:
        return cubicPacketsToBytes(model, 1)
    let growthUnits: int64 = cubicSaturatingMulPositive(model.datagramPayloadBytes, acked)
    model.aimdAccumulator = cubicSaturatingAdd(model.aimdAccumulator, growthUnits)
    if model.aimdAccumulator < model.congestionWindow:
        return model.congestionWindow
    let renoInc: int64 = model.aimdAccumulator / model.congestionWindow
    model.aimdAccumulator = model.aimdAccumulator % model.congestionWindow
    return cubicSaturatingAdd(model.congestionWindow, renoInc)

fn cubicInit(
    initialWindowPackets: int32,
    datagramPayloadBytes: int32,
    sendIdleTimeoutMs: int32
): CubicModel =
    let initialWindowBytes: int64 = int64(datagramPayloadBytes) * int64(initialWindowPackets)
    var model: CubicModel
    model.hasHadCongestionEvent = false
    model.isInRecovery = false
    model.isInPersistentCongestion = false
    model.timeOfLastAckValid = false
    model.initialWindowPackets = initialWindowPackets
    model.sendIdleTimeoutMs = sendIdleTimeoutMs
    model.congestionWindow = initialWindowBytes
    model.prevCongestionWindow = initialWindowBytes
    model.slowStartThreshold = maxInt64Value
    model.prevSlowStartThreshold = maxInt64Value
    model.aimdWindow = initialWindowBytes
    model.prevAimdWindow = initialWindowBytes
    model.aimdAccumulator = 0
    model.bytesInFlight = 0
    model.bytesInFlightMax = initialWindowBytes / 2
    model.lastSendAllowance = 0
    model.exemptions = 0
    model.timeOfLastAck = 0
    model.timeOfCongAvoidStart = 0
    model.kCubic = 0
    model.prevKCubic = 0
    model.windowPrior = initialWindowBytes
    model.prevWindowPrior = initialWindowBytes
    model.windowMax = initialWindowBytes
    model.prevWindowMax = initialWindowBytes
    model.windowLastMax = initialWindowBytes
    model.prevWindowLastMax = initialWindowBytes
    model.hyStartState = hyStartNotStarted
    model.hyStartAckCount = 0
    model.minRttInLastRound = 0
    model.minRttInCurrentRound = maxInt64Value
    model.cssBaselineMinRtt = 0
    model.hyStartRoundEnd = 0
    model.cWndSlowStartGrowthDivisor = 1
    model.conservativeSlowStartRounds = 0
    model.recoverySentPacketNumber = 0
    model.datagramPayloadBytes = int64(datagramPayloadBytes)
    model.betaScaled = cubicBetaScaledDefault
    model.cParamScaled = cubicCScaledDefault
    return model

fn cubicEnterRecovery(model: var CubicModel, lostBytes: int64) =
    model.isInRecovery = true
    model.hasHadCongestionEvent = true
    if model.bytesInFlight > lostBytes:
        model.bytesInFlight = model.bytesInFlight - lostBytes
    else:
        model.bytesInFlight = 0
    model.congestionWindow = cubicReducedWindow(model)
    model.slowStartThreshold = model.congestionWindow
    model.aimdWindow = model.congestionWindow
    model.aimdAccumulator = 0
    model.timeOfCongAvoidStart = 0
    cubicUpdateKCubic(model)

fn cubicCanSend(model: CubicModel): bool =
    return model.bytesInFlight < model.congestionWindow || model.exemptions > 0

fn cubicSendAllowance(model: CubicModel): int64 =
    if model.congestionWindow > model.bytesInFlight:
        return model.congestionWindow - model.bytesInFlight
    return 0

fn cubicOnPacketSent(model: var CubicModel, bytes: int64, ackEliciting: bool) =
    if ackEliciting:
        model.bytesInFlight = cubicSaturatingAdd(model.bytesInFlight, bytes)
    if model.bytesInFlight > model.bytesInFlightMax:
        model.bytesInFlightMax = model.bytesInFlight

fn cubicOnDataAcked(model: var CubicModel, ack: AckEventSnapshot) =
    let acked: int64 = ack.ackedRetransmittableBytes
    if acked <= 0:
        return
    if model.bytesInFlight > acked:
        model.bytesInFlight = model.bytesInFlight - acked
    else:
        model.bytesInFlight = 0

    model.timeOfLastAck = ack.timeNow
    model.timeOfLastAckValid = true

    if model.isInRecovery && ack.largestAck > model.recoverySentPacketNumber:
        model.isInRecovery = false

    let minCwnd: int64 = cubicComputeMinCwnd(model)

    if model.congestionWindow < model.slowStartThreshold:
        model.congestionWindow = cubicSaturatingAdd(model.congestionWindow, acked)
        if model.congestionWindow >= model.slowStartThreshold:
            model.timeOfCongAvoidStart = ack.timeNow
            model.windowPrior = model.congestionWindow
            if model.congestionWindow > model.windowMax:
                model.windowMax = model.congestionWindow
            cubicUpdateKCubic(model)
    else:
        if model.timeOfCongAvoidStart == 0:
            model.timeOfCongAvoidStart = ack.timeNow
        let cubicTarget: int64 = cubicComputeTargetWindow(model, ack.timeNow)
        let renoTarget: int64 = cubicComputeRenoTarget(model, acked)
        if cubicTarget > renoTarget:
            model.congestionWindow = cubicTarget
        else:
            model.congestionWindow = renoTarget

    if model.congestionWindow < minCwnd:
        model.congestionWindow = minCwnd

    model.aimdWindow = model.congestionWindow
    if model.bytesInFlight > model.congestionWindow:
        model.bytesInFlight = model.congestionWindow
    if model.bytesInFlight > model.bytesInFlightMax:
        model.bytesInFlightMax = model.bytesInFlight

fn cubicOnDataLost(model: var CubicModel, loss: LossEventSnapshot) =
    let lostBytes: int64 = loss.retransmittableBytesLost
    if model.bytesInFlight > lostBytes:
        model.bytesInFlight = model.bytesInFlight - lostBytes
    else:
        model.bytesInFlight = 0

    model.isInRecovery = true
    model.hasHadCongestionEvent = true
    model.isInPersistentCongestion = loss.persistentCongestion
    model.recoverySentPacketNumber = loss.largestSentPacketNumber

    model.windowLastMax = model.windowMax
    model.windowPrior = model.congestionWindow

    let minCwnd: int64 = cubicComputeMinCwnd(model)
    model.windowMax = cubicMaxInt64(model.congestionWindow, minCwnd)
    var ssthresh: int64 = cubicReducedWindow(model)
    if loss.persistentCongestion:
        ssthresh = minCwnd
    model.slowStartThreshold = ssthresh
    model.congestionWindow = ssthresh
    model.aimdWindow = ssthresh
    model.aimdAccumulator = 0
    model.timeOfCongAvoidStart = 0

    cubicUpdateKCubic(model)
    model.bytesInFlight = cubicMinInt64(model.bytesInFlight, model.congestionWindow)

fn cubicOnProbeTimeout(model: var CubicModel) =
    let minCwnd: int64 = cubicComputeMinCwnd(model)
    model.slowStartThreshold = cubicReducedWindow(model)
    if model.slowStartThreshold < minCwnd:
        model.slowStartThreshold = minCwnd
    model.congestionWindow = minCwnd
    model.aimdWindow = minCwnd
    model.aimdAccumulator = 0
    model.bytesInFlight = cubicMinInt64(model.bytesInFlight, model.congestionWindow)
    model.isInRecovery = false
    model.isInPersistentCongestion = false
    model.timeOfCongAvoidStart = 0
    cubicUpdateKCubic(model)

fn cubicBytesInFlight(model: CubicModel): int64 =
    return model.bytesInFlight
