import std/strutils as strutil
# MsQuic datapath model(minimal).

import std/result
import std/strings
import cheng/quic/platform/common
type
    MsQuicDatapathKind = enum
        MsQuicDatapathBasic = 0
        MsQuicDatapathHighPerf = 1

    MsQuicDatapath =
        id: int32
        kind: MsQuicDatapathKind
        active: bool
        udpSocketId: int32
        udpUseLenField: bool
        udpLastTos: int32
        udpLastTosIsV6: bool
        udpAddr: str
        packetsSent: int64
        packetsRecv: int64
        bytesSent: int64
        bytesRecv: int64

fn initMsQuicDatapath(id: int32, kind: MsQuicDatapathKind): MsQuicDatapath =
    MsQuicDatapath(
        id: id,
        kind: kind,
        active: false,
        udpSocketId: -1,
        udpUseLenField: false,
        udpLastTos: -1,
        udpLastTosIsV6: false,
        udpAddr: "",
        packetsSent: 0,
        packetsRecv: 0,
        bytesSent: 0,
        bytesRecv: 0
    )

fn msquicDatapathStart(dp: var MsQuicDatapath) =
    dp.active = true

fn msquicDatapathStop(dp: var MsQuicDatapath) =
    dp.active = false

fn msquicDatapathRecordSend(dp: var MsQuicDatapath, bytes: int64) =
    dp.packetsSent = dp.packetsSent + 1
    if bytes > 0:
        dp.bytesSent = dp.bytesSent + bytes

fn msquicDatapathRecordRecv(dp: var MsQuicDatapath, bytes: int64) =
    dp.packetsRecv = dp.packetsRecv + 1
    if bytes > 0:
        dp.bytesRecv = dp.bytesRecv + bytes

fn msquicDatapathKindName(kind: MsQuicDatapathKind): str =
    if kind == MsQuicDatapathHighPerf:
        return "highperf"
    return "basic"

fn msquicDatapathSummary(dp: MsQuicDatapath): str =
    var out: str = msquicDatapathKindName(dp.kind)
    out = strutil.Join([out, " id="], "")
    out = strutil.Join([out, msquicPlatformIntToString(dp.id)], "")
    out = strutil.Join([out, " packetsSent="], "")
    out = strutil.Join([out, msquicPlatformIntToString(dp.packetsSent)], "")
    out = strutil.Join([out, " packetsRecv="], "")
    out = strutil.Join([out, msquicPlatformIntToString(dp.packetsRecv)], "")
    return out
