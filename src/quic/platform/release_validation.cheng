import std/strutils as strutil
# MsQuic platform release validation(minimal).

import std/result
import std/strings
import cheng/quic/platform/common
import cheng/quic/platform/platform_matrix
import cheng/quic/msquicruntime

fn msquicReleaseValidatePlatform(kind: common.MsQuicPlatformKind): Result[bool] =
    let matrix = platform_matrix.initMsQuicPlatformMatrix()
    if !platform_matrix.msquicPlatformMatrixHas(matrix, kind):
        return Err[bool]("msquic release: unsupported platform")
    return Ok[bool](true)

fn msquicReleaseValidateSettings(settings: msquicruntime.MsQuicSettings): Result[bool] =
    var next = settings
    return msquicruntime.validateMsQuicSettings(next)

fn msquicReleaseValidationSummary(kind: common.MsQuicPlatformKind,
                                  settings: msquicruntime.MsQuicSettings): str =
    var out = "msquic release"
    out = strutil.Join([out, " platform=", common.msquicPlatformKindToString(kind)], "")
    out = strutil.Join([out, " maxPending=", strings.IntToStr(settings.maxPending)], "")
    out = strutil.Join([out, " idleTimeoutMs=", strings.Int64ToStr(settings.idleTimeoutMs)], "")
    out = strutil.Join([out, " maxDatagram=", strings.IntToStr(settings.maxDatagram)], "")
    out = strutil.Join([out, " allowDatagram=", if], "") settings.allowDatagram: "true" else: "false"
    out = strutil.Join([out, " allow0Rtt=", if], "") settings.allow0Rtt: "true" else: "false"
    out = strutil.Join([out, " useBbr=", if], "") settings.useBbr: "true" else: "false"
    return out
