# MsQuic settings && related structs(port scaffold).

import std/rawbytes
import cheng/quic/inc/msquic_constants
const
    qUIC_TLS_SECRETS_MAX_SECRET_LEN = 64

type
    QuicGlobalSettingsIsSet =
        retryMemoryLimit: bool
        loadBalancingMode: bool
        fixedServerId: bool

    QUIC_GLOBAL_SETTINGS =
        isSet: QuicGlobalSettingsIsSet
        retryMemoryLimit: int32
        loadBalancingMode: int32
        fixedServerId: int32

    QuicSettingsIsSet =
        maxBytesPerKey: bool
        handshakeIdleTimeoutMs: bool
        idleTimeoutMs: bool
        mtuDiscoverySearchCompleteTimeoutUs: bool
        tlsClientMaxSendBuffer: bool
        tlsServerMaxSendBuffer: bool
        streamRecvWindowDefault: bool
        streamRecvBufferDefault: bool
        connFlowControlWindow: bool
        maxWorkerQueueDelayUs: bool
        maxStatelessOperations: bool
        initialWindowPackets: bool
        sendIdleTimeoutMs: bool
        initialRttMs: bool
        maxAckDelayMs: bool
        disconnectTimeoutMs: bool
        keepAliveIntervalMs: bool
        congestionControlAlgorithm: bool
        peerBidiStreamCount: bool
        peerUnidiStreamCount: bool
        maxBindingStatelessOperations: bool
        statelessOperationExpirationMs: bool
        minimumMtu: bool
        maximumMtu: bool
        sendBufferingEnabled: bool
        pacingEnabled: bool
        migrationEnabled: bool
        datagramReceiveEnabled: bool
        serverResumptionLevel: bool
        maxOperationsPerDrain: bool
        mtuDiscoveryMissingProbeCount: bool
        destCidUpdateIdleTimeoutMs: bool
        eventSampleEvery: bool
        greaseQuicBitEnabled: bool
        versionNegotiationExtEnabled: bool
        ecnEnabled: bool
        hyStartEnabled: bool
        streamRecvWindowBidiLocalDefault: bool
        streamRecvWindowBidiRemoteDefault: bool
        streamRecvWindowUnidiDefault: bool
        encryptionOffloadAllowed: bool
        reliableResetEnabled: bool
        oneWayDelayEnabled: bool
        netStatsEventEnabled: bool
        streamMultiReceiveEnabled: bool
        xdpEnabled: bool
        qtipEnabled: bool
        reservedRioEnabled: bool

    QuicSettingsFlags =
        hyStartEnabled: bool
        encryptionOffloadAllowed: bool
        reliableResetEnabled: bool
        oneWayDelayEnabled: bool
        netStatsEventEnabled: bool
        streamMultiReceiveEnabled: bool
        xdpEnabled: bool
        qtipEnabled: bool
        reservedRioEnabled: bool

    QUIC_SETTINGS =
        isSet: QuicSettingsIsSet
        maxBytesPerKey: int64
        handshakeIdleTimeoutMs: int64
        idleTimeoutMs: int64
        mtuDiscoverySearchCompleteTimeoutUs: int64
        tlsClientMaxSendBuffer: int32
        tlsServerMaxSendBuffer: int32
        streamRecvWindowDefault: int32
        streamRecvBufferDefault: int32
        connFlowControlWindow: int32
        maxWorkerQueueDelayUs: int32
        maxStatelessOperations: int32
        initialWindowPackets: int32
        sendIdleTimeoutMs: int32
        initialRttMs: int32
        maxAckDelayMs: int32
        disconnectTimeoutMs: int32
        keepAliveIntervalMs: int32
        congestionControlAlgorithm: QUIC_CONGESTION_CONTROL_ALGORITHM
        peerBidiStreamCount: int32
        peerUnidiStreamCount: int32
        maxBindingStatelessOperations: int32
        statelessOperationExpirationMs: int32
        minimumMtu: int32
        maximumMtu: int32
        sendBufferingEnabled: bool
        pacingEnabled: bool
        migrationEnabled: bool
        datagramReceiveEnabled: bool
        serverResumptionLevel: QUIC_SERVER_RESUMPTION_LEVEL
        greaseQuicBitEnabled: bool
        versionNegotiationExtEnabled: bool
        ecnEnabled: bool
        maxOperationsPerDrain: int32
        mtuDiscoveryMissingProbeCount: int32
        destCidUpdateIdleTimeoutMs: int32
        eventSampleEvery: int32
        flags: QuicSettingsFlags
        streamRecvWindowBidiLocalDefault: int32
        streamRecvWindowBidiRemoteDefault: int32
        streamRecvWindowUnidiDefault: int32

    QuicTlsSecretsIsSet =
        clientRandom: bool
        clientEarlyTrafficSecret: bool
        clientHandshakeTrafficSecret: bool
        serverHandshakeTrafficSecret: bool
        clientTrafficSecret0: bool
        serverTrafficSecret0: bool

    QUIC_TLS_SECRETS =
        secretLength: int32
        isSet: QuicTlsSecretsIsSet
        clientRandom: Bytes
        clientEarlyTrafficSecret: Bytes
        clientHandshakeTrafficSecret: Bytes
        serverHandshakeTrafficSecret: Bytes
        clientTrafficSecret0: Bytes
        serverTrafficSecret0: Bytes

    QUIC_STREAM_STATISTICS =
        connBlockedBySchedulingUs: int64
        connBlockedByPacingUs: int64
        connBlockedByAmplificationProtUs: int64
        connBlockedByCongestionControlUs: int64
        connBlockedByFlowControlUs: int64
        streamBlockedByIdFlowControlUs: int64
        streamBlockedByFlowControlUs: int64
        streamBlockedByAppUs: int64

    QUIC_AEAD_ALGORITHM_TYPE = enum
        QUIC_AEAD_ALGORITHM_AES_128_GCM = 0
        QUIC_AEAD_ALGORITHM_AES_256_GCM = 1

    QUIC_STATELESS_RETRY_CONFIG =
        algorithm: QUIC_AEAD_ALGORITHM_TYPE
        rotationMs: int32
        secretLength: int32
        secret: Bytes

fn initQuicSettings(): QUIC_SETTINGS =
    var out: QUIC_SETTINGS
    out.isSet = QuicSettingsIsSet()
    out.flags = QuicSettingsFlags()
    return out

fn initQuicGlobalSettings(): QUIC_GLOBAL_SETTINGS =
    var out: QUIC_GLOBAL_SETTINGS
    out.isSet = QuicGlobalSettingsIsSet()
    return out

fn initQuicTlsSecrets(): QUIC_TLS_SECRETS =
    var out: QUIC_TLS_SECRETS
    out.isSet = QuicTlsSecretsIsSet()
    out.secretLength = qUIC_TLS_SECRETS_MAX_SECRET_LEN
    out.clientRandom = emptyBytes()
    out.clientEarlyTrafficSecret = emptyBytes()
    out.clientHandshakeTrafficSecret = emptyBytes()
    out.serverHandshakeTrafficSecret = emptyBytes()
    out.clientTrafficSecret0 = emptyBytes()
    out.serverTrafficSecret0 = emptyBytes()
    return out

fn initQuicStatelessRetryConfig(): QUIC_STATELESS_RETRY_CONFIG =
    var out: QUIC_STATELESS_RETRY_CONFIG
    out.algorithm = QUIC_AEAD_ALGORITHM_AES_128_GCM
    out.rotationMs = 0
    out.secretLength = 0
    out.secret = emptyBytes()
    return out

fn initQuicStreamStatistics(): QUIC_STREAM_STATISTICS =
    return QUIC_STREAM_STATISTICS(
        connBlockedBySchedulingUs: 0,
        connBlockedByPacingUs: 0,
        connBlockedByAmplificationProtUs: 0,
        connBlockedByCongestionControlUs: 0,
        connBlockedByFlowControlUs: 0,
        streamBlockedByIdFlowControlUs: 0,
        streamBlockedByFlowControlUs: 0,
        streamBlockedByAppUs: 0
    )
