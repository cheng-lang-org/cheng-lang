    qUIC_VERSION_LATEST = qUIC_VERSION_1
    qUIC_VERSION_LATEST_H = qUIC_VERSION_1_H

type
    QUIC_DATAGRAM_SEND_STATE = enum
        QUIC_DATAGRAM_SEND_SENT = 0
        QUIC_DATAGRAM_SEND_LOST_SUSPECT = 1
        QUIC_DATAGRAM_SEND_LOST_DISCARDED = 2
        QUIC_DATAGRAM_SEND_ACKNOWLEDGED = 3
        QUIC_DATAGRAM_SEND_ACKNOWLEDGED_SPURIOUS = 4
        QUIC_DATAGRAM_SEND_CANCELED = 5

fn quicDatagramSendStateIsFinal(state: QUIC_DATAGRAM_SEND_STATE): bool =
    return state >= QUIC_DATAGRAM_SEND_LOST_DISCARDED

