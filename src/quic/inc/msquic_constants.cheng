    qUIC_MAX_SNI_LENGTH = 65535
    qUIC_MAX_RESUMPTION_APP_DATA_LENGTH = 1000
    qUIC_STATELESS_RESET_KEY_LENGTH = 32
    qUIC_VERSION_VER_NEG = 0x00000000
    qUIC_VERSION_2: int32 = 0xcf43336b
    qUIC_VERSION_1 = 0x01000000
    qUIC_VERSION_MS_1 = 0x0000cdab
    qUIC_VERSION_DRAFT_29 = 0x1d0000ff
    qUIC_VERSION_VER_NEG_H = 0x00000000
    qUIC_VERSION_2_H: int32 = 0x6b3343cf
    qUIC_VERSION_1_H = 0x00000001
    qUIC_VERSION_MS_1_H: int32 = 0xabcd0000
    qUIC_VERSION_DRAFT_29_H: int32 = 0xff00001d
