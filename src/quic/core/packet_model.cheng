# MsQuic core packet model (no-pointer, in-process).

import std/result
import std/rawbytes
import std/buffer
import std/varint
import cheng/quic/core/frame_model
import cheng/quic/core/quic_varint

const
    msQuicMaxFramesPerPacket = 32

type
    MsQuicPacket =
        number: int64
        ackEliciting: bool
        framesCount: int32
        frames: MsQuicFrame[msQuicMaxFramesPerPacket]

    MsQuicFrameDecoded =
        frame: MsQuicFrame
        next: int32

var
    msquicZeroPacketTemplate: MsQuicPacket

fn initMsQuicPacket(number: int64): MsQuicPacket =
    var out: MsQuicPacket = msquicZeroPacketTemplate
    out.number = number
    out.ackEliciting = false
    out.framesCount = 0
    return out

fn msquicPacketReset(out: var MsQuicPacket, number: int64) =
    out.number = number
    out.ackEliciting = false
    out.framesCount = 0

fn msquicPacketSize(p: var MsQuicPacket): int32 =
    var size: int32 = 16
    for i in 0..<p.framesCount:
        size = size + msquicFrameSize(p.frames[i])
    return size

fn msquicPacketAckEliciting(p: var MsQuicPacket): bool =
    return p.ackEliciting

fn msquicPacketAddFrame(p: var MsQuicPacket, frame: MsQuicFrame): Result[bool] =
    if p.framesCount >= msQuicMaxFramesPerPacket:
        return Err[bool]("msquic packet: frame list full")
    p.frames[p.framesCount] = frame
    p.framesCount = p.framesCount + 1
    if frame.kind != FrameAck &&
       frame.kind != FramePadding &&
       frame.kind != FrameConnectionClose &&
       frame.kind != FrameConnectionCloseApp:
        p.ackEliciting = true
    return Ok[bool](true)

fn msquicFrameDecode(data: Bytes, offset: int32): Result[MsQuicFrameDecoded] =
    let kindRes: Result[VarintDecoded] = decodeUVarint(data, offset)
    if IsErr(kindRes):
        return Err[MsQuicFrameDecoded](ErrorText(kindRes))
    let kindDec: VarintDecoded = Value(kindRes)

    let streamRes: Result[VarintDecoded] = decodeUVarint(data, kindDec.next)
    if IsErr(streamRes):
        return Err[MsQuicFrameDecoded](ErrorText(streamRes))
    let streamDec: VarintDecoded = Value(streamRes)

    let offRes: Result[VarintDecoded] = decodeUVarint(data, streamDec.next)
    if IsErr(offRes):
        return Err[MsQuicFrameDecoded](ErrorText(offRes))
    let offDec: VarintDecoded = Value(offRes)

    let valRes: Result[VarintDecoded] = decodeUVarint(data, offDec.next)
    if IsErr(valRes):
        return Err[MsQuicFrameDecoded](ErrorText(valRes))
    let valDec: VarintDecoded = Value(valRes)

    let lenRes: Result[VarintDecoded] = decodeUVarint(data, valDec.next)
    if IsErr(lenRes):
        return Err[MsQuicFrameDecoded](ErrorText(lenRes))
    let lenDec: VarintDecoded = Value(lenRes)

    let dataLen: int32 = int32(lenDec.value)
    if dataLen < 0:
        return Err[MsQuicFrameDecoded]("msquic packet: negative frame length")
    let endPos: int32 = lenDec.next + dataLen
    if endPos > bytesLen(data):
        return Err[MsQuicFrameDecoded]("msquic packet: frame data truncated")

    let payload: Bytes = if dataLen > 0: bytesSlice(data, lenDec.next, dataLen) else: emptyBytes()
    let kindRes2: Result[MsQuicFrameType] = msquicFrameTypeFromInt(kindDec.value)
    if IsErr(kindRes2):
        return Err[MsQuicFrameDecoded](ErrorText(kindRes2))
    var frame: MsQuicFrame
    frame.kind = Value(kindRes2)
    frame.streamId = streamDec.value
    frame.offset = offDec.value
    frame.value = valDec.value
    frame.data = payload
    var decoded: MsQuicFrameDecoded
    decoded.frame = frame
    decoded.next = endPos
    return Ok[MsQuicFrameDecoded](decoded)

fn msquicPacketDecode(data: Bytes): Result[MsQuicPacket] =
    let numRes: Result[VarintDecoded] = decodeUVarint(data, 0)
    if IsErr(numRes):
        return Err[MsQuicPacket](ErrorText(numRes))
    let numDec: VarintDecoded = Value(numRes)

    let countRes: Result[VarintDecoded] = decodeUVarint(data, numDec.next)
    if IsErr(countRes):
        return Err[MsQuicPacket](ErrorText(countRes))
    let countDec: VarintDecoded = Value(countRes)

    let count: int32 = int32(countDec.value)
    if count < 0:
        return Err[MsQuicPacket]("msquic packet: negative frame count")

    var pkt: MsQuicPacket
    msquicPacketReset(pkt, numDec.value)
    var offset: int32 = countDec.next
    for i in 0..<count:
        let frameRes: Result[MsQuicFrameDecoded] = msquicFrameDecode(data, offset)
        if IsErr(frameRes):
            return Err[MsQuicPacket](ErrorText(frameRes))
        let decoded: MsQuicFrameDecoded = Value(frameRes)
        let addRes: Result[bool] = msquicPacketAddFrame(pkt, decoded.frame)
        if IsErr(addRes):
            return Err[MsQuicPacket](ErrorText(addRes))
        offset = decoded.next
    return Ok[MsQuicPacket](pkt)

fn msquicFrameEncode(frame: MsQuicFrame): Bytes =
    var buf: ByteBuffer = newByteBuffer()
    let kindBytes: Bytes = encodeUVarint(msquicFrameTypeWireCode(frame.kind))
    appendBytes(buf, kindBytes)
    let streamIdBytes: Bytes = encodeUVarint(frame.streamId)
    appendBytes(buf, streamIdBytes)
    let offsetBytes: Bytes = encodeUVarint(frame.offset)
    appendBytes(buf, offsetBytes)
    let valueBytes: Bytes = encodeUVarint(frame.value)
    appendBytes(buf, valueBytes)
    let dataLen: int64 = int64(bytesLen(frame.data))
    let dataLenBytes: Bytes = encodeUVarint(dataLen)
    appendBytes(buf, dataLenBytes)
    if dataLen > 0:
        let frameData: Bytes = frame.data
        appendBytes(buf, frameData)
    return toBytes(buf)

fn msquicPacketEncode(p: MsQuicPacket): Bytes =
    var buf: ByteBuffer = newByteBuffer()
    let packetNumberBytes: Bytes = encodeUVarint(p.number)
    appendBytes(buf, packetNumberBytes)
    let frameCountBytes: Bytes = encodeUVarint(int64(p.framesCount))
    appendBytes(buf, frameCountBytes)
    for i in 0..<p.framesCount:
        let frameBytes: Bytes = msquicFrameEncode(p.frames[i])
        appendBytes(buf, frameBytes)
    return toBytes(buf)

fn msquicFramePayloadDecode(data: Bytes, offset: int32): Result[MsQuicFrameDecoded] =
    let kindRes: Result[QuicVarIntDecoded] = quicVarIntDecode(data, offset)
    if IsErr(kindRes):
        return Err[MsQuicFrameDecoded](ErrorText(kindRes))
    let kindDec: QuicVarIntDecoded = Value(kindRes)

    let streamRes: Result[QuicVarIntDecoded] = quicVarIntDecode(data, kindDec.next)
    if IsErr(streamRes):
        return Err[MsQuicFrameDecoded](ErrorText(streamRes))
    let streamDec: QuicVarIntDecoded = Value(streamRes)

    let offRes: Result[QuicVarIntDecoded] = quicVarIntDecode(data, streamDec.next)
    if IsErr(offRes):
        return Err[MsQuicFrameDecoded](ErrorText(offRes))
    let offDec: QuicVarIntDecoded = Value(offRes)

    let valRes: Result[QuicVarIntDecoded] = quicVarIntDecode(data, offDec.next)
    if IsErr(valRes):
        return Err[MsQuicFrameDecoded](ErrorText(valRes))
    let valDec: QuicVarIntDecoded = Value(valRes)

    let lenRes: Result[QuicVarIntDecoded] = quicVarIntDecode(data, valDec.next)
    if IsErr(lenRes):
        return Err[MsQuicFrameDecoded](ErrorText(lenRes))
    let lenDec: QuicVarIntDecoded = Value(lenRes)

    let dataLen: int32 = int32(lenDec.value)
    if dataLen < 0:
        return Err[MsQuicFrameDecoded]("msquic payload: negative frame length")
    let endPos: int32 = lenDec.next + dataLen
    if endPos > bytesLen(data):
        return Err[MsQuicFrameDecoded]("msquic payload: frame data truncated")

    let payload: Bytes = if dataLen > 0: bytesSlice(data, lenDec.next, dataLen) else: emptyBytes()
    let kindRes2: Result[MsQuicFrameType] = msquicFrameTypeFromInt(kindDec.value)
    if IsErr(kindRes2):
        return Err[MsQuicFrameDecoded](ErrorText(kindRes2))
    var frame: MsQuicFrame
    frame.kind = Value(kindRes2)
    frame.streamId = streamDec.value
    frame.offset = offDec.value
    frame.value = valDec.value
    frame.data = payload
    var decoded: MsQuicFrameDecoded
    decoded.frame = frame
    decoded.next = endPos
    return Ok[MsQuicFrameDecoded](decoded)

fn msquicPacketPayloadDecode(payload: Bytes, packetNumber: int64): Result[MsQuicPacket] =
    var out: MsQuicPacket
    let decodeRes: Result[bool] = msquicPacketPayloadDecodeInto(out, payload, packetNumber)
    if IsErr(decodeRes):
        return Err[MsQuicPacket](ErrorText(decodeRes))
    return Ok[MsQuicPacket](out)

fn msquicPacketPayloadDecodeInto(out: var MsQuicPacket, payload: Bytes, packetNumber: int64): Result[bool] =
    if packetNumber < 0:
        return Err[bool]("msquic payload: negative packet number")
    msquicPacketReset(out, packetNumber)
    var offset: int32
    while offset < bytesLen(payload):
        let frameRes: Result[MsQuicFrameDecoded] = msquicFramePayloadDecode(payload, offset)
        if IsErr(frameRes):
            return Err[bool](ErrorText(frameRes))
        let decoded: MsQuicFrameDecoded = Value(frameRes)
        let addRes: Result[bool] = msquicPacketAddFrame(out, decoded.frame)
        if IsErr(addRes):
            return Err[bool](ErrorText(addRes))
        offset = decoded.next
    return Ok[bool](true)

fn msquicPacketPayloadEncode(p: var MsQuicPacket): Result[Bytes] =
    var buf: ByteBuffer = newByteBuffer()
    for i in 0..<p.framesCount:
        let kindAppendRes: Result[bool] = quicVarIntAppend(buf, msquicFrameTypeWireCode(p.frames[i].kind))
        if IsErr(kindAppendRes):
            return Err[Bytes](ErrorText(kindAppendRes))
        let streamAppendRes: Result[bool] = quicVarIntAppend(buf, p.frames[i].streamId)
        if IsErr(streamAppendRes):
            return Err[Bytes](ErrorText(streamAppendRes))
        let offsetAppendRes: Result[bool] = quicVarIntAppend(buf, p.frames[i].offset)
        if IsErr(offsetAppendRes):
            return Err[Bytes](ErrorText(offsetAppendRes))
        let valueAppendRes: Result[bool] = quicVarIntAppend(buf, p.frames[i].value)
        if IsErr(valueAppendRes):
            return Err[Bytes](ErrorText(valueAppendRes))
        let dataLenAppendRes: Result[bool] = quicVarIntAppend(buf, int64(bytesLen(p.frames[i].data)))
        if IsErr(dataLenAppendRes):
            return Err[Bytes](ErrorText(dataLenAppendRes))
        if bytesLen(p.frames[i].data) > 0:
            let frameData: Bytes = p.frames[i].data
            appendBytes(buf, frameData)
    return Ok[Bytes](toBytes(buf))
