import std/strutils as strutil
# MsQuic core common helpers(pure Cheng, in-process).

import std/result
import std/strings
import std/times
type
    MsQuicCoreState = enum
        MsQuicCoreIdle = 0
        MsQuicCoreActive = 1
        MsQuicCoreClosing = 2

    MsQuicCoreDirection = enum
        MsQuicDirBidi = 0
        MsQuicDirUni = 1

    MsQuicCoreStatus = enum
        MsQuicOk = 0
        MsQuicError = 1

fn msquicCoreNowMs(): int64 =
    epochTimeNs() / 1000000

fn msquicCoreClampInt32(value: int32, minVal: int32, maxVal: int32): int32 =
    var v: int32 = value
    if v < minVal:
        v = minVal
    if v > maxVal:
        v = maxVal
    return v

fn msquicCoreCheckRange(value: int32, minVal: int32, maxVal: int32, name: str): Result[bool] =
    if value < minVal || value > maxVal:
        let head: str = "msquic core: "
        let msg: str = strutil.Join([head, name, " out of range"], "")
        return Err[bool](msg)
    return Ok[bool](true)
