fn osHostProcessCommandText(filePath: str, argv: str[], envOverrides: str[]): str =
    var out = ""
    if envOverrides.len > 0:
        out = "env"
        for i in 0..<envOverrides.len:
            let envText = envOverrides[i]
            if strings.Len(envText) > 0:
                out = strutil.Join([out, " "], "")
                out = strutil.Join([out, os.QuoteShell(envText)], "")
    if strings.Len(filePath) > 0:
        if strings.Len(out) > 0:
            out = strutil.Join([out, " "], "")
        out = strutil.Join([out, os.QuoteShell(filePath)], "")
    for i in 0..<argv.len:
        out = strutil.Join([out, " "], "")
        out = strutil.Join([out, os.QuoteShell(argv[i])], "")
    return out

fn osHostProcessStdoutOnlyCommand(command: str): str =
    return strutil.Join([command, " 2>/dev/null"], "")

fn osHostProcessEncodeWire(items: str[]): str =
    var out: buffer.ByteBuffer
    out.data = rawbytes.emptyBytes()
    for i in 0..<items.len:
        buffer.AppendBytes(out, items[i])
        buffer.appendByte(out, 0)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn osHostProcessCloseFd(fd: var int32) =
    if fd >= 0:
        cheng_pty_close_bridge(fd)
        fd = -1

fn osHostProcessAppendOutput(output: var str, chunk: str) =
    output = strings.ConcatStr(output, chunk)

fn osHostProcessDrainReadFd(readFd: var int32, output: var str, timeoutMs: int32) =
    if readFd < 0:
        return
    var waitMs = timeoutMs
    while readFd >= 0:
        let readRes = fdReadWait(readFd, 65536, waitMs)
        if strings.Len(readRes.text) <= 0:
            if readRes.eof:
                osHostProcessCloseFd(readFd)
            break
        osHostProcessAppendOutput(output, readRes.text)
        waitMs = 0

fn osHostProcessCStringCopy(text: str): cstring =
    let n: int32 = strLenFast(text)
    if n <= 0:
        return driver_c_new_string(0)
    return driver_c_new_string_copy_n(strDataPtr(text), n)

fn osHostProcessPipeSpawnCommand(command: str, workingDir: str): os.ExecFilePipeSpawnResult =
    var out: os.ExecFilePipeSpawnResult
    osHostProcessPipeSpawnCommandFill(command,
                                      workingDir,
                                      out.readFd,
                                      out.writeFd,
                                      out.pid,
                                      out.ok)
    return out

fn osHostProcessPipeSpawnCommandFill(command: str, workingDir: str,
                                     outReadFd: var int32, outWriteFd: var int32,
                                     outPid: var int64, outOk: var bool) =
    outReadFd = -1
    outWriteFd = -1
    outPid = -1
    outOk = false
    if strings.Len(command) == 0:
        return
    let commandText: cstring = osHostProcessCStringCopy(command)
    let workingDirText: cstring = osHostProcessCStringCopy(workingDir)
    let status: int32 = cheng_pipe_spawn_bridge(commandText, workingDirText)
    outReadFd = cheng_pipe_spawn_bridge_last_read_fd()
    outWriteFd = cheng_pipe_spawn_bridge_last_write_fd()
    outPid = int64(cheng_pipe_spawn_bridge_last_pid_i32())
    outOk = status != 0
    cheng_free_raw(ptr(commandText))
    cheng_free_raw(ptr(workingDirText))

fn osHostProcessExecFilePipeSpawn(filePath: str, argv: str[], envOverrides: str[],
                                  workingDir: str): os.ExecFilePipeSpawnResult =
    return osHostProcessExecFilePipeSpawnMerge(filePath, argv, envOverrides, workingDir, true)

fn osHostProcessExecFilePipeSpawnMerge(filePath: str, argv: str[], envOverrides: str[],
                                       workingDir: str, mergeStderr: bool): os.ExecFilePipeSpawnResult =
    var out: os.ExecFilePipeSpawnResult
    out.ok = false
    out.readFd = -1
    out.writeFd = -1
    out.pid = -1
    if strings.Len(filePath) == 0:
        return out
    let filePathText: cstring = osHostProcessCStringCopy(filePath)
    let workingDirText: cstring = osHostProcessCStringCopy(workingDir)
    let argvWire: str = osHostProcessEncodeWire(argv)
    let envWire: str = osHostProcessEncodeWire(envOverrides)
    var mergeStderrI32: int32
    if mergeStderr:
        mergeStderrI32 = 1
    let status: int32 = cheng_host_exec_file_pipe_spawn_bridge(filePathText,
                                                                  argvWire,
                                                                  envWire,
                                                                  workingDirText,
                                                                  mergeStderrI32)
    out.readFd = cheng_host_exec_file_pipe_spawn_bridge_last_read_fd()
    out.writeFd = cheng_host_exec_file_pipe_spawn_bridge_last_write_fd()
    out.pid = int64(cheng_host_exec_file_pipe_spawn_bridge_last_pid_i32())
    out.ok = status != 0
    cheng_free_raw(ptr(filePathText))
    cheng_free_raw(ptr(workingDirText))
    return out

fn osHostProcessExecFileCaptureFill(filePath: str, argv: str[], envOverrides: str[],
                                    workingDir: str, mergeStderr: bool, timeoutSec: int32,
                                    outOutput: var str, outExitCode: var int32) =
    outOutput = ""
    outExitCode = -1
    if strings.Len(filePath) == 0:
        return
    let spawn: os.ExecFilePipeSpawnResult = osHostProcessExecFilePipeSpawnMerge(filePath,
                                                                                argv,
                                                                                envOverrides,
                                                                                workingDir,
                                                                                mergeStderr)
    if !spawn.ok:
        return
    var readFd: int32 = spawn.readFd
    var writeFd: int32 = spawn.writeFd
    let pid: int64 = spawn.pid
    osHostProcessCloseFd(writeFd)
    let startNs: int64 = times.EpochTimeNs()
    let timeoutNs: int64 = int64(timeoutSec) * int64(1000000000)
    var timedOut: bool
    var termSent: bool
    var termAtNs: int64
    var processExited: bool
    while true:
        osHostProcessDrainReadFd(readFd, outOutput, 20)
        if !processExited:
            let waitRes: os.PtyWaitResult = ptyWait(pid)
            if waitRes.waitStatus == 1:
                outExitCode = waitRes.exitCode
                processExited = true
            elif waitRes.waitStatus < 0:
                outExitCode = -12
                processExited = true
        if readFd < 0 && processExited:
            break
        if !processExited && timeoutSec > 0:
            let nowNs: int64 = times.EpochTimeNs() - startNs
            if nowNs >= timeoutNs:
                timedOut = true
                if !termSent:
                    let _term: bool = processSignal(pid, 15)
                    termSent = true
                    termAtNs = nowNs
                elif nowNs - termAtNs >= int64(500000000):
                    let _kill: bool = processSignal(pid, 9)
                os.SleepMs(20)
                continue
        os.SleepMs(10)
    osHostProcessCloseFd(readFd)
    if timedOut:
        outExitCode = 124

fn execFileCapture(filePath: str, argv: str[], envOverrides: str[],
                   workingDir: str, mergeStderr: bool, timeoutSec: int32): os.ExecCmdResult =
    var out: os.ExecCmdResult
    osHostProcessExecFileCaptureFill(filePath,
                                     argv,
                                     envOverrides,
                                     workingDir,
                                     mergeStderr,
                                     timeoutSec,
                                     out.output,
                                     out.exitCode)
    return out

fn execFileStatus(filePath: str, argv: str[], envOverrides: str[],
                  workingDir: str, timeoutSec: int32): int32 =
    if strings.Len(filePath) == 0:
        return -1
    let filePathText: cstring = osHostProcessCStringCopy(filePath)
    let workingDirText: cstring = osHostProcessCStringCopy(workingDir)
    let argvWire: str = osHostProcessEncodeWire(argv)
    let envWire: str = osHostProcessEncodeWire(envOverrides)
    let rc: int32 = cheng_exec_file_status_bridge(filePathText,
                                                     argvWire,
                                                     envWire,
                                                     workingDirText,
                                                     timeoutSec)
    cheng_free_raw(ptr(filePathText))
    cheng_free_raw(ptr(workingDirText))
    return rc

fn execFilePipeSpawn(filePath: str, argv: str[], envOverrides: str[],
                     workingDir: str): os.ExecFilePipeSpawnResult =
    return osHostProcessExecFilePipeSpawn(filePath, argv, envOverrides, workingDir)

fn ptySupported(): bool =
    cheng_pty_is_supported_bridge() != 0

fn ptySpawn(command: str, workingDir: str): os.PtySpawnResult =
    var masterFd: int32 = -1
    var pid: int64 = -1
    let commandText: cstring = osHostProcessCStringCopy(command)
    let workingDirText: cstring = osHostProcessCStringCopy(workingDir)
    let status: int32 = cheng_pty_spawn_bridge(commandText, workingDirText)
    masterFd = cheng_pty_spawn_bridge_last_master_fd()
    pid = int64(cheng_pty_spawn_bridge_last_pid_i32())
    let ok: bool = status != 0
    cheng_free_raw(ptr(commandText))
    cheng_free_raw(ptr(workingDirText))
    var out: os.PtySpawnResult
    out.ok = ok
    out.masterFd = masterFd
    out.pid = pid
    return out

fn pipeSpawn(command: str, workingDir: str): os.PipeSpawnResult =
    var readFd: int32 = -1
    var writeFd: int32 = -1
    var pid: int64 = -1
    let commandText: cstring = osHostProcessCStringCopy(command)
    let workingDirText: cstring = osHostProcessCStringCopy(workingDir)
    let status: int32 = cheng_pipe_spawn_bridge(commandText, workingDirText)
    readFd = cheng_pipe_spawn_bridge_last_read_fd()
    writeFd = cheng_pipe_spawn_bridge_last_write_fd()
    pid = int64(cheng_pipe_spawn_bridge_last_pid_i32())
    let ok: bool = status != 0
    cheng_free_raw(ptr(commandText))
    cheng_free_raw(ptr(workingDirText))
    var out: os.PipeSpawnResult
    out.ok = ok
    out.readFd = readFd
    out.writeFd = writeFd
    out.pid = pid
    return out

fn ptyRead(fd: int32, maxBytes: int32): os.TextReadResult =
    let raw: cstring = cheng_pty_read_bridge(fd, maxBytes)
    let text: str = strFromCStringCopy(raw)
    cheng_free_raw(ptr(raw))
    let eof: int32 = cheng_pty_read_bridge_last_eof()
    var out: os.TextReadResult
    out.text = text
    out.eof = eof != 0
    return out

fn fdRead(fd: int32, maxBytes: int32): os.TextReadResult =
    let raw: cstring = cheng_fd_read_bridge(fd, maxBytes)
    let text: str = strFromCStringCopy(raw)
    cheng_free_raw(ptr(raw))
    let eof: int32 = cheng_fd_read_bridge_last_eof()
    var out: os.TextReadResult
    out.text = text
    out.eof = eof != 0
    return out

fn fdReadWait(fd: int32, maxBytes: int32, timeoutMs: int32): os.TextReadResult =
    let raw: cstring = cheng_fd_read_wait_bridge(fd, maxBytes, timeoutMs)
    let text: str = strFromCStringCopy(raw)
    cheng_free_raw(ptr(raw))
    let eof: int32 = cheng_fd_read_wait_bridge_last_eof()
    var out: os.TextReadResult
    out.text = text
    out.eof = eof != 0
    return out

fn ptyWrite(fd: int32, data: str): int32 =
    let n: int32 = strings.Len(data)
    if n <= 0:
        return 0
    let dataPtr: ptr = strDataPtr(data)
    if dataPtr == nil:
        return 0
    return cheng_pty_write_bridge(fd, dataPtr, n)

fn ptyClose(fd: int32) =
    cheng_pty_close_bridge(fd)

fn ptyWait(pid: int64): os.PtyWaitResult =
    let waitStatus = cheng_pty_wait_bridge(pid)
    let exitCode: int32 = cheng_pty_wait_bridge_last_exit_code()
    var out: os.PtyWaitResult
    out.waitStatus = waitStatus
    out.exitCode = exitCode
    return out

fn processSignal(pid: int64, signalCode: int32): bool =
    if pid <= 0 || signalCode <= 0:
        return false
    let targetPid: int32 = int32(pid)
    let groupPid: int32 = 0 - targetPid
    if libc_kill(groupPid, signalCode) == 0:
        return true
    return libc_kill(targetPid, signalCode) == 0

fn processExists(pid: int64): bool =
    if pid <= 0:
        return false
    return libc_kill(int32(pid), 0) == 0

fn FdReadWait(fd: int32, maxBytes: int32, timeoutMs: int32): os.TextReadResult =
    return fdReadWait(fd, maxBytes, timeoutMs)

fn OsHostProcessCommandText(filePath: str, argv: str[], envOverrides: str[]): str =
    return osHostProcessCommandText(filePath, argv, envOverrides)

fn PipeSpawn(command: str, workingDir: str): os.PipeSpawnResult =
    return pipeSpawn(command, workingDir)

fn ProcessExists(pid: int64): bool =
    return processExists(pid)

fn ProcessSignal(pid: int64, signalCode: int32): bool =
    return processSignal(pid, signalCode)

fn PtyWrite(fd: int32, data: str): int32 =
    return ptyWrite(fd, data)

fn PtyClose(fd: int32) =
    ptyClose(fd)

fn PtyWait(pid: int64): os.PtyWaitResult =
    return ptyWait(pid)

fn ExecFileCapture(filePath: str, argv: str[], envOverrides: str[],
                   workingDir: str, mergeStderr: bool, timeoutSec: int32): os.ExecCmdResult =
    return execFileCapture(filePath, argv, envOverrides, workingDir, mergeStderr, timeoutSec)

fn ExecFileCaptureFill(filePath: str, argv: str[], envOverrides: str[],
                       workingDir: str, mergeStderr: bool, timeoutSec: int32,
                       outOutput: var str, outExitCode: var int32) =
    osHostProcessExecFileCaptureFill(filePath,
                                     argv,
                                     envOverrides,
                                     workingDir,
                                     mergeStderr,
                                     timeoutSec,
                                     outOutput,
                                     outExitCode)

fn ExecFileStatus(filePath: str, argv: str[], envOverrides: str[],
                  workingDir: str, timeoutSec: int32): int32 =
    return execFileStatus(filePath, argv, envOverrides, workingDir, timeoutSec)

fn ExecFilePipeSpawn(filePath: str, argv: str[], envOverrides: str[],
                     workingDir: str): os.ExecFilePipeSpawnResult =
    return execFilePipeSpawn(filePath, argv, envOverrides, workingDir)

fn OsHostProcessExecFileCaptureFill(filePath: str, argv: str[], envOverrides: str[],
                                    workingDir: str, mergeStderr: bool, timeoutSec: int32,
                                    outOutput: var str, outExitCode: var int32) =
    osHostProcessExecFileCaptureFill(filePath,
                                     argv,
                                     envOverrides,
                                     workingDir,
                                     mergeStderr,
                                     timeoutSec,
                                     outOutput,
                                     outExitCode)
