import std/os as os
import std/monotimes
import std/strings

@importc("cheng_pty_is_supported_bridge")
fn cheng_pty_is_supported_bridge(): int32
@importc("cheng_pty_spawn_bridge")
fn cheng_pty_spawn_bridge(command: cstring, workingDir: cstring): int32
@importc("cheng_pty_spawn_bridge_last_master_fd")
fn cheng_pty_spawn_bridge_last_master_fd(): int32
@importc("cheng_pty_spawn_bridge_last_pid_i32")
fn cheng_pty_spawn_bridge_last_pid_i32(): int32
@importc("cheng_pipe_spawn_bridge")
fn cheng_pipe_spawn_bridge(command: cstring, workingDir: cstring): int32
@importc("cheng_pipe_spawn_bridge_last_read_fd")
fn cheng_pipe_spawn_bridge_last_read_fd(): int32
@importc("cheng_pipe_spawn_bridge_last_write_fd")
fn cheng_pipe_spawn_bridge_last_write_fd(): int32
@importc("cheng_pipe_spawn_bridge_last_pid_i32")
fn cheng_pipe_spawn_bridge_last_pid_i32(): int32
@importc("cheng_pty_read_bridge")
fn cheng_pty_read_bridge(fd: int32, maxBytes: int32): cstring
@importc("cheng_pty_read_bridge_last_eof")
fn cheng_pty_read_bridge_last_eof(): int32
@importc("cheng_fd_read_bridge")
fn cheng_fd_read_bridge(fd: int32, maxBytes: int32): cstring
@importc("cheng_fd_read_bridge_last_eof")
fn cheng_fd_read_bridge_last_eof(): int32
@importc("cheng_fd_read_wait_bridge")
fn cheng_fd_read_wait_bridge(fd: int32, maxBytes: int32, timeoutMs: int32): cstring
@importc("cheng_fd_read_wait_bridge_last_eof")
fn cheng_fd_read_wait_bridge_last_eof(): int32
@importc("cheng_pty_write_bridge")
fn cheng_pty_write_bridge(fd: int32, data: cstring, len: int32): int32
@importc("cheng_pty_close_bridge")
fn cheng_pty_close_bridge(fd: int32): int32
@importc("cheng_pty_wait_bridge")
fn cheng_pty_wait_bridge(pid: int64): int32
@importc("cheng_pty_wait_bridge_last_exit_code")
fn cheng_pty_wait_bridge_last_exit_code(): int32
@importc("cheng_free")
fn cheng_free_raw(p: ptr)
@importc("kill")
fn libc_kill(pid: int32, signalCode: int32): int32

fn osHostProcessCommandText(filePath: str, argv: str[], envOverrides: str[]): str =
    var out = ""
    if envOverrides.len > 0:
        out = "env"
        for i in 0..<envOverrides.len:
            let envText = envOverrides[i]
            if strings.len(envText) > 0:
                out = out + " "
                out = out + os.quoteShell(envText)
    if strings.len(filePath) > 0:
        if strings.len(out) > 0:
            out = out + " "
        out = out + os.quoteShell(filePath)
    for i in 0..<argv.len:
        out = out + " "
        out = out + os.quoteShell(argv[i])
    return out

fn osHostProcessStdoutOnlyCommand(command: str): str =
    return command + " 2>/dev/null"

fn osHostProcessCloseFd(fd: var int32) =
    if fd >= 0:
        cheng_pty_close_bridge(fd)
        fd = -1

fn osHostProcessDrainReadFd(readFd: var int32, output: var str, timeoutMs: int32) =
    if readFd < 0:
        return
    var waitMs = timeoutMs
    while readFd >= 0:
        let readRes = fdReadWait(readFd, 65536, waitMs)
        if strings.len(readRes.text) > 0:
            output = output + readRes.text
            waitMs = 0
            continue
        if readRes.eof:
            osHostProcessCloseFd(readFd)
        break

fn osHostProcessPipeSpawnCommand(command: str, workingDir: str): os.ExecFilePipeSpawnResult =
    if strings.len(command) == 0:
        return os.ExecFilePipeSpawnResult(ok: false, readFd: -1, writeFd: -1, pid: -1)
    var readFd: int32 = -1
    var writeFd: int32 = -1
    var pid: int64 = -1
    let commandText: cstring = strToCStringTemp(command)
    let workingDirText: cstring = strToCStringTemp(workingDir)
    let status: int32 = cheng_pipe_spawn_bridge(commandText, workingDirText)
    readFd = cheng_pipe_spawn_bridge_last_read_fd()
    writeFd = cheng_pipe_spawn_bridge_last_write_fd()
    pid = int64(cheng_pipe_spawn_bridge_last_pid_i32())
    let ok: bool = status != 0
    return os.ExecFilePipeSpawnResult(ok: ok, readFd: readFd, writeFd: writeFd, pid: pid)

fn osHostProcessPipeSpawnCommandFill(command: str, workingDir: str,
                                     outReadFd: var int32, outWriteFd: var int32,
                                     outPid: var int64, outOk: var bool) =
    outReadFd = -1
    outWriteFd = -1
    outPid = -1
    outOk = false
    if strings.len(command) == 0:
        return
    let commandText: cstring = strToCStringTemp(command)
    let workingDirText: cstring = strToCStringTemp(workingDir)
    let status: int32 = cheng_pipe_spawn_bridge(commandText, workingDirText)
    outReadFd = cheng_pipe_spawn_bridge_last_read_fd()
    outWriteFd = cheng_pipe_spawn_bridge_last_write_fd()
    outPid = int64(cheng_pipe_spawn_bridge_last_pid_i32())
    outOk = status != 0

fn osHostProcessExecFilePipeSpawn(filePath: str, argv: str[], envOverrides: str[],
                                  workingDir: str): os.ExecFilePipeSpawnResult =
    if strings.len(filePath) == 0:
        return os.ExecFilePipeSpawnResult(ok: false, readFd: -1, writeFd: -1, pid: -1)
    let command: str = osHostProcessCommandText(filePath, argv, envOverrides)
    return osHostProcessPipeSpawnCommand(command, workingDir)

fn osHostProcessExecFileCaptureFill(filePath: str, argv: str[], envOverrides: str[],
                                    workingDir: str, mergeStderr: bool, timeoutSec: int32,
                                    outOutput: var str, outExitCode: var int32) =
    outOutput = ""
    outExitCode = -1
    if strings.len(filePath) == 0:
        return
    var command: str = osHostProcessCommandText(filePath, argv, envOverrides)
    if !mergeStderr:
        command = osHostProcessStdoutOnlyCommand(command)
    var readFd: int32 = -1
    var writeFd: int32 = -1
    var pid: int64 = -1
    var spawnOk = false
    osHostProcessPipeSpawnCommandFill(command, workingDir, readFd, writeFd, pid, spawnOk)
    if !spawnOk:
        outExitCode = -11
        return
    if pid <= 0:
        outExitCode = -13
        return
    osHostProcessCloseFd(writeFd)
    let start = monotimes.getMonoTime()
    let timeoutNs: int64 = int64(timeoutSec) * int64(1000000000)
    var timedOut = false
    var termSent = false
    var termAtNs: int64 = 0
    var output = ""
    var exitCode = -1
    while pid > 0:
        osHostProcessDrainReadFd(readFd, output, 20)
        let waitRes = ptyWait(pid)
        if waitRes.waitStatus == 1:
            exitCode = waitRes.exitCode
            pid = 0
            break
        if waitRes.waitStatus < 0:
            exitCode = -12
            pid = 0
            break
        if timeoutSec > 0:
            let nowNs: int64 = monotimes.monoTimeNs(monotimes.getMonoTime()) - monotimes.monoTimeNs(start)
            if nowNs >= timeoutNs:
                timedOut = true
                if !termSent:
                    let _term = processSignal(pid, 15)
                    termSent = true
                    termAtNs = nowNs
                elif nowNs - termAtNs >= int64(500000000):
                    let _kill = processSignal(pid, 9)
                os.sleepMs(20)
                continue
        os.sleepMs(10)
    osHostProcessDrainReadFd(readFd, output, 0)
    osHostProcessCloseFd(writeFd)
    osHostProcessCloseFd(readFd)
    if timedOut:
        exitCode = 124
    outOutput = output
    outExitCode = exitCode

fn execFileCapture(filePath: str, argv: str[], envOverrides: str[],
                   workingDir: str, mergeStderr: bool, timeoutSec: int32): os.ExecCmdResult =
    if strings.len(filePath) == 0:
        return os.ExecCmdResult(output: "", exitCode: -1)
    var command: str = osHostProcessCommandText(filePath, argv, envOverrides)
    if !mergeStderr:
        command = osHostProcessStdoutOnlyCommand(command)
    let spawnRes: os.ExecFilePipeSpawnResult = osHostProcessPipeSpawnCommand(command, workingDir)
    if !spawnRes.ok:
        return os.ExecCmdResult(output: "", exitCode: -11)
    if spawnRes.pid <= 0:
        return os.ExecCmdResult(output: "", exitCode: -13)
    var readFd: int32 = spawnRes.readFd
    var writeFd: int32 = spawnRes.writeFd
    var pid: int64 = spawnRes.pid
    osHostProcessCloseFd(writeFd)
    let start = monotimes.getMonoTime()
    let timeoutNs: int64 = int64(timeoutSec) * int64(1000000000)
    var timedOut = false
    var termSent = false
    var termAtNs: int64 = 0
    var output = ""
    var exitCode = -1
    while pid > 0:
        osHostProcessDrainReadFd(readFd, output, 20)
        let waitRes = ptyWait(pid)
        if waitRes.waitStatus == 1:
            exitCode = waitRes.exitCode
            pid = 0
            break
        if waitRes.waitStatus < 0:
            exitCode = -12
            pid = 0
            break
        if timeoutSec > 0:
            let nowNs: int64 = monotimes.monoTimeNs(monotimes.getMonoTime()) - monotimes.monoTimeNs(start)
            if nowNs >= timeoutNs:
                timedOut = true
                if !termSent:
                    let _term = processSignal(pid, 15)
                    termSent = true
                    termAtNs = nowNs
                elif nowNs - termAtNs >= int64(500000000):
                    let _kill = processSignal(pid, 9)
                os.sleepMs(20)
                continue
        os.sleepMs(10)
    osHostProcessDrainReadFd(readFd, output, 0)
    osHostProcessCloseFd(writeFd)
    osHostProcessCloseFd(readFd)
    if timedOut:
        exitCode = 124
    return os.ExecCmdResult(output: output, exitCode: exitCode)

fn execFileStatus(filePath: str, argv: str[], envOverrides: str[],
                  workingDir: str, timeoutSec: int32): int32 =
    if strings.len(filePath) == 0:
        return -1
    let res: os.ExecCmdResult = execFileCapture(filePath, argv, envOverrides, workingDir, true, timeoutSec)
    return res.exitCode

fn execFilePipeSpawn(filePath: str, argv: str[], envOverrides: str[],
                     workingDir: str): os.ExecFilePipeSpawnResult =
    return osHostProcessExecFilePipeSpawn(filePath, argv, envOverrides, workingDir)

fn ptySupported(): bool =
    cheng_pty_is_supported_bridge() != 0

fn ptySpawn(command: str, workingDir: str): os.PtySpawnResult =
    var masterFd: int32 = -1
    var pid: int64 = -1
    let commandText: cstring = strToCStringTemp(command)
    let workingDirText: cstring = strToCStringTemp(workingDir)
    let status: int32 = cheng_pty_spawn_bridge(commandText, workingDirText)
    masterFd = cheng_pty_spawn_bridge_last_master_fd()
    pid = int64(cheng_pty_spawn_bridge_last_pid_i32())
    let ok: bool = status != 0
    return os.PtySpawnResult(ok: ok, masterFd: masterFd, pid: pid)

fn pipeSpawn(command: str, workingDir: str): os.PipeSpawnResult =
    var readFd: int32 = -1
    var writeFd: int32 = -1
    var pid: int64 = -1
    let commandText: cstring = strToCStringTemp(command)
    let workingDirText: cstring = strToCStringTemp(workingDir)
    let status: int32 = cheng_pipe_spawn_bridge(commandText, workingDirText)
    readFd = cheng_pipe_spawn_bridge_last_read_fd()
    writeFd = cheng_pipe_spawn_bridge_last_write_fd()
    pid = int64(cheng_pipe_spawn_bridge_last_pid_i32())
    let ok: bool = status != 0
    return os.PipeSpawnResult(ok: ok, readFd: readFd, writeFd: writeFd, pid: pid)

fn ptyRead(fd: int32, maxBytes: int32): os.TextReadResult =
    let raw: cstring = cheng_pty_read_bridge(fd, maxBytes)
    let text: str = strFromCStringCopy(raw)
    cheng_free_raw(ptr(raw))
    let eof: int32 = cheng_pty_read_bridge_last_eof()
    return os.TextReadResult(text: text, eof: eof != 0)

fn fdRead(fd: int32, maxBytes: int32): os.TextReadResult =
    let raw: cstring = cheng_fd_read_bridge(fd, maxBytes)
    let text: str = strFromCStringCopy(raw)
    cheng_free_raw(ptr(raw))
    let eof: int32 = cheng_fd_read_bridge_last_eof()
    return os.TextReadResult(text: text, eof: eof != 0)

fn fdReadWait(fd: int32, maxBytes: int32, timeoutMs: int32): os.TextReadResult =
    let raw: cstring = cheng_fd_read_wait_bridge(fd, maxBytes, timeoutMs)
    let text: str = strFromCStringCopy(raw)
    cheng_free_raw(ptr(raw))
    let eof: int32 = cheng_fd_read_wait_bridge_last_eof()
    return os.TextReadResult(text: text, eof: eof != 0)

fn ptyWrite(fd: int32, data: str): int32 =
    let dataText: cstring = strToCStringTemp(data)
    return cheng_pty_write_bridge(fd, dataText, strings.len(data))

fn ptyClose(fd: int32) =
    cheng_pty_close_bridge fd

fn ptyWait(pid: int64): os.PtyWaitResult =
    let waitStatus = cheng_pty_wait_bridge(pid)
    let exitCode: int32 = cheng_pty_wait_bridge_last_exit_code()
    return os.PtyWaitResult(waitStatus: waitStatus, exitCode: exitCode)

fn processSignal(pid: int64, signalCode: int32): bool =
    if pid <= 0 || signalCode <= 0:
        return false
    let targetPid: int32 = int32(pid)
    let groupPid: int32 = 0 - targetPid
    if libc_kill(groupPid, signalCode) == 0:
        return true
    return libc_kill(targetPid, signalCode) == 0
