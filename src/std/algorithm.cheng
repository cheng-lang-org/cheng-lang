# std/algorithm (minimal, pure Cheng)
fn sort(s: var seq[str]) =
    if len s <= 1:
        return
        var i = 0
        while i < len s:
            var j = i + 1
            while j < len s:
                if cmp(s[j], s[i]) < 0:
                    let tmp = s[i]
                    s[i] = s[j]
                    s[j] = tmp
                    j = j + 1
                    i = i + 1
