# std/result
type
    ErrorInfo =
        code: int32
        msg: str

type
    Result[T] =
        ok: bool
        value: T
        err: ErrorInfo

@importc("cheng_error_info_init_compat")
fn errorInfoInitCompat(out: var ErrorInfo, code: int32, msg: str)

@importc("cheng_error_info_code_compat")
fn errorInfoCodeCompat(e: ErrorInfo): int32

@importc("cheng_error_info_msg_compat")
fn errorInfoMsgCompat(e: ErrorInfo): str

fn ErrorOkInto(out: var ErrorInfo) =
    errorInfoInitCompat(out, 0, "")

fn ErrorNewInto(out: var ErrorInfo, msg: str) =
    errorInfoInitCompat(out, 0, msg)

fn IsError(e: ErrorInfo): bool =
    if errorInfoCodeCompat(e) != 0:
        return true
    return len(errorInfoMsgCompat(e)) > 0

fn ErrorCodeOf(e: ErrorInfo): int32 =
    return errorInfoCodeCompat(e)

fn ErrorMessage(e: ErrorInfo): str =
    let msg: str = errorInfoMsgCompat(e)
    if len(msg) == 0:
        return ""
    return msg

fn ErrorFormat(e: ErrorInfo): str =
    let msg: str = errorInfoMsgCompat(e)
    if len(msg) == 0:
        return "error"
    return msg

fn Ok(value: T): Result[T] =
    var out: Result[T]
    out.ok = true
    out.value = value
    ErrorOkInto(out.err)
    return out

fn Err(err: str): Result[T] =
    var out: Result[T]
    out.ok = false
    ErrorNewInto(out.err, err)
    return out

fn ErrCode(code: int32, msg: str): Result[T] =
    var out: Result[T]
    out.ok = false
    errorInfoInitCompat(out.err, code, msg)
    return out

fn ErrInfo(err: ErrorInfo): Result[T] =
    var out: Result[T]
    out.ok = false
    out.err = err
    return out

fn IsOk(r: Result[T]): bool =
    return r.ok

fn IsErr(r: Result[T]): bool =
    return !r.ok

fn Value(r: Result[T]): T =
    return r.value

fn ErrorInfoOf(r: Result[T]): ErrorInfo =
    return r.err

fn Error(r: Result[bool]): str =
    let err: ErrorInfo = ErrorInfoOf[bool](r)
    return ErrorMessage(err)

fn Error(r: Result[T]): str =
    return ErrorMessage(r.err)
