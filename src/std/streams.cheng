import std/os

type
    Stream =
        f: File

fn newFileStream(path: str, mode: FileMode): Stream =
    var s: Stream
    s.f = open(path, mode)
    return s

fn write(s: Stream, data: str) =
    if s.f == nil:
        return
    write(s.f, data)

fn close(s: Stream) =
    if s.f == nil:
        return
    close s.f

fn isNil(s: Stream): bool =
    return s.f == nil

fn Close(s: Stream) =
    close(s)

fn IsNil(s: Stream): bool =
    return isNil(s)

fn NewFileStream(path: str, mode: FileMode): Stream =
    return newFileStream(path, mode)
