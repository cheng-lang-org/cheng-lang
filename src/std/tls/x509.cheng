        if oid[8] != '1':
            return x509OidCodeUnknown
        if oid[9] != '0':
            return x509OidCodeUnknown
        if oid[10] != '0':
            return x509OidCodeUnknown
        if oid[11] != '4':
            return x509OidCodeUnknown
        if oid[12] != '5':
            return x509OidCodeUnknown
        if oid[13] != '.':
            return x509OidCodeUnknown
        if oid[14] == '3':
            if oid[15] != '.':
                return x509OidCodeUnknown
