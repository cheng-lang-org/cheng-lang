import std/strutils as strutil
# Minimal X.509 DER parser && chain validator(pure Cheng).

import std/result
import std/rawbytes
import std/buffer
import std/strings
import std/crypto/minasn1
import std/crypto/rsa
import std/crypto/ecnist
const
    x509Asn1TagBoolean = 0x01
    x509Asn1TagBitString = 0x03
    x509Asn1TagOctetString = 0x04
    x509Asn1TagOid = 0x06
    x509Asn1TagSequence = 0x30
    x509TagUtcTime = 0x17
    x509TagGeneralizedTime = 0x18
    x509TagContext0 = 0xa0
    x509TagContext3 = 0xa3
    x509TagDnsName = 0x82
    x509MaxChain = 8
    x509MaxCrls = 8
    x509MaxRevoked = 128
    x509MonthsInYear = 12

    oidRsaEncryption = "1.2.840.113549.1.1.1"
    oidRsaPss = "1.2.840.113549.1.1.10"
    oidMgf1 = "1.2.840.113549.1.1.8"
    oidSha256WithRsa = "1.2.840.113549.1.1.11"
    oidSha384WithRsa = "1.2.840.113549.1.1.12"
    oidSha256 = "2.16.840.1.101.3.4.2.1"
    oidSha384 = "2.16.840.1.101.3.4.2.2"
    oidEcdsaPublicKey = "1.2.840.10045.2.1"
    oidPrime256v1 = "1.2.840.10045.3.1.7"
    oidEcdsaWithSha256 = "1.2.840.10045.4.3.2"
    oidEcdsaWithSha384 = "1.2.840.10045.4.3.3"
    oidOcspBasic = "1.3.6.1.5.5.7.48.1.1"
    oidBasicConstraints = "2.5.29.19"
    oidKeyUsage = "2.5.29.15"
    oidExtKeyUsage = "2.5.29.37"
    oidSubjectAltName = "2.5.29.17"
    oidServerAuth = "1.3.6.1.5.5.7.3.1"

    x509KeyUsageDigitalSignature = 1
    x509KeyUsageKeyEncipherment = 4
    x509KeyUsageKeyCertSign = 32

    x509OidCodeUnknown = 0
    x509OidCodeRsaEncryption = 1
    x509OidCodeRsaPss = 2
    x509OidCodeMgf1 = 3
    x509OidCodeSha256WithRsa = 4
    x509OidCodeSha384WithRsa = 5
    x509OidCodeSha256 = 6
    x509OidCodeSha384 = 7
    x509OidCodeEcdsaPublicKey = 8
    x509OidCodePrime256v1 = 9
    x509OidCodeEcdsaWithSha256 = 10
    x509OidCodeEcdsaWithSha384 = 11
    x509OidCodeOcspBasic = 12
    x509OidCodeBasicConstraints = 13
    x509OidCodeKeyUsage = 14
    x509OidCodeExtKeyUsage = 15
    x509OidCodeSubjectAltName = 16
    x509OidCodeServerAuth = 17

type
    X509SignatureKind = enum
        X509SigUnknown = 0
        X509SigRsaSha256 = 1
        X509SigRsaSha384 = 2
        X509SigEcdsaSha256 = 3
        X509SigEcdsaSha384 = 4
        X509SigRsaPss = 5

    X509HashKind = enum
        X509HashUnknown = 0
        X509HashSha256 = 1
        X509HashSha384 = 2

    X509PublicKeyKind = enum
        X509KeyUnknown = 0
        X509KeyRsa = 1
        X509KeyEcdsaP256 = 2

    X509OidNext =
        oid: str
        next: int32

    X509BitStringNext =
        bytes: Bytes
        unused: int32
        next: int32

    X509RawTlv =
        tag: int32
        raw: Bytes
        value: Bytes
        next: int32

    X509HashSaltLen =
        hash: X509HashKind
        saltLen: int32

    X509SigAlgNext =
        sigAlg: X509SignatureKind
        pssHash: X509HashKind
        pssSaltLen: int32
        next: int32

    X509AlgIdParamNext =
        oid: str
        paramOid: str
        next: int32

    X509PublicKey =
        kind: X509PublicKeyKind
        rsaN: Bytes
        rsaE: Bytes
        ecdsaBytes: Bytes

    X509Certificate =
        tbs: Bytes
        signature: Bytes
        sigAlg: X509SignatureKind
        pssHash: X509HashKind
        pssSaltLen: int32
        tbsSigAlg: X509SignatureKind
        tbsPssHash: X509HashKind
        tbsPssSaltLen: int32
        serial: Bytes
        issuer: Bytes
        subject: Bytes
        notBefore: int64
        notAfter: int64
        isCa: bool
        hasBasicConstraints: bool
        keyUsage: int32
        hasKeyUsage: bool
        extKeyUsageCount: int32
        hasServerAuthEku: bool
        dnsNameCount: int32
        dnsNamesDer: Bytes
        hasUnknownCritical: bool
        publicKey: X509PublicKey

    X509CertList =
        count: int32
        items: X509Certificate[x509MaxChain]

    X509RevocationMode = enum
        X509RevocationOff = 0
        X509RevocationBestEffort = 1
        X509RevocationStrict = 2

    X509RevocationStatus = enum
        X509RevocationGood = 0
        X509RevocationRevoked = 1
        X509RevocationUnknown = 2

    X509Crl =
        issuer: Bytes
        thisUpdate: int64
        nextUpdate: int64
        revokedSerials: Bytes[]

fn initX509PublicKey(): X509PublicKey =
    var out: X509PublicKey
    initX509PublicKeyInto(out)
    return out

fn initX509PublicKeyInto(out: var X509PublicKey) =
    out.kind = X509KeyUnknown
    out.rsaN = emptyBytes()
    out.rsaE = emptyBytes()
    out.ecdsaBytes = emptyBytes()

fn initX509Certificate(): X509Certificate =
    var out: X509Certificate
    initX509CertificateInto(out)
    return out

fn initX509CertificateInto(out: var X509Certificate) =
    out.tbs = emptyBytes()
    out.signature = emptyBytes()
    out.sigAlg = X509SigUnknown
    out.pssHash = X509HashUnknown
    out.pssSaltLen = -1
    out.tbsSigAlg = X509SigUnknown
    out.tbsPssHash = X509HashUnknown
    out.tbsPssSaltLen = -1
    out.serial = emptyBytes()
    out.issuer = emptyBytes()
    out.subject = emptyBytes()
    out.notBefore = 0
    out.notAfter = 0
    out.isCa = false
    out.hasBasicConstraints = false
    out.keyUsage = 0
    out.hasKeyUsage = false
    out.extKeyUsageCount = 0
    out.hasServerAuthEku = false
    out.dnsNameCount = 0
    out.dnsNamesDer = emptyBytes()
    out.hasUnknownCritical = false
    initX509PublicKeyInto(out.publicKey)

fn initX509CertList(): X509CertList =
    var out: X509CertList
    initX509CertListInto(out)
    return out

fn initX509CertListInto(out: var X509CertList) =
    out.count = 0
    for i in 0..<x509MaxChain:
        initX509CertificateInto(out.items[i])

fn initX509Crl(): X509Crl =
    var out: X509Crl
    initX509CrlInto(out)
    return out

fn initX509CrlInto(out: var X509Crl) =
    out.issuer = emptyBytes()
    out.thisUpdate = 0
    out.nextUpdate = 0
    out.revokedSerials = []

fn x509CertListAdd(list: var X509CertList, cert: X509Certificate): Result[bool] =
    if list.count >= x509MaxChain:
        return Err[bool]("x509: cert list full")
    list.items[list.count] = cert
    list.count = list.count + 1
    return Ok[bool](true)

fn x509CertListAllocSlot(list: var X509CertList): Result[int32] =
    if list.count >= x509MaxChain:
        return Err[int32]("x509: cert list full")
    let idx: int32 = list.count
    list.items[idx] = initX509Certificate()
    list.count = list.count + 1
    return Ok[int32](idx)


fn x509CertListFindBySubject(list: X509CertList, subject: Bytes): Result[X509Certificate] =
    for i in 0..<list.count:
        let cert: X509Certificate = list.items[i]
        if bytesEqual(cert.subject, subject):
            return Ok[X509Certificate](cert)
    return Err[X509Certificate]("x509: issuer ! found")

fn x509CertListFindBySubjectIndex(list: X509CertList, subject: Bytes): int32 =
    for i in 0..<list.count:
        let cert: X509Certificate = list.items[i]
        if bytesEqual(cert.subject, subject):
            return i
    return -1

fn x509IntToString(value: int64): str =
    return int64ToStr(value)

fn x509StrEqual(a: str, b: str): bool =
    if len(a) != len(b):
        return false
    for i in 0..<len(a):
        if a[i] != b[i]:
            return false
    return true

fn x509HashLenCode(hashCode: int32): int32 =
    if hashCode == 1:
        return 32
    if hashCode == 2:
        return 48
    return 0

fn x509OidCode(oid: str): int32 =
    let n: int32 = len(oid)
    if n == 20:
        if oid[0] != '1' || oid[1] != '.':
            return x509OidCodeUnknown
        if oid[2] == '2':
            if oid[3] != '.':
                return x509OidCodeUnknown
            if oid[4] != '8':
                return x509OidCodeUnknown
            if oid[5] != '4':
