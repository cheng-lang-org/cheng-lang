                return x509OidCodeUnknown
            if oid[11] != '.':
                return x509OidCodeUnknown
            if oid[12] != '7':
                return x509OidCodeUnknown
            if oid[13] != '.':
                return x509OidCodeUnknown
            if oid[14] != '3':
                return x509OidCodeUnknown
