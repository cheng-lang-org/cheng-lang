# rawbytes.cheng - raw pointer bytes helpers (binary-safe)
#
# 注意：这里的 Bytes 与 pkg://cheng/libp2p 的 utils/bytes 对齐，方便机械替换 import。

import std/system
import std/strings
import std/rawmem_support

@importc("cheng_rawbytes_get_at")
fn chengRawbytesGetAt(base: ptr, idx: int32): int32
@importc("cheng_rawbytes_set_at")
fn chengRawbytesSetAt(base: ptr, idx: int32, value: int32)

type
    byte = int32
    Bytes =
        data: ptr
        len: int32

fn emptyBytes(): Bytes =
    return Bytes(data: nil, len: 0)

fn bytesAlloc(length: int32): Bytes =
    if length <= 0:
        return emptyBytes()
    let p: ptr = alloc length
    rawmem_support.rawmemSet(p, 0, length)
    return Bytes(data: p, len: length)

fn bytesFromString(s: str): Bytes =
    if len(s) == 0:
        return emptyBytes()
    return Bytes(data: rawmemAsVoid(s), len: len(s))

fn bytesToString(b: Bytes): str =
    if b.data == nil || b.len <= 0:
        return ""
    return newStringCopy(b.data, b.len)

fn bytesLen(b: Bytes): int32 =
    b.len

fn bytesGet(b: Bytes, idx: int32): int32 =
    if idx < 0 || idx >= b.len:
        return 0
    return chengRawbytesGetAt(b.data, idx)

fn bytesSet(b: var Bytes, idx: int32, val: int32) =
    if idx < 0 || idx >= b.len:
        return
    chengRawbytesSetAt(b.data, idx, val)

fn bytesSlice(b: Bytes, start: int32, count: int32): Bytes =
    if count <= 0 || start < 0 || start >= b.len:
        return emptyBytes()
    var n: int32 = count
    if start + n > b.len:
        n = b.len - start
    let out: Bytes = bytesAlloc n
    rawmem_support.rawmemCopy(out.data, rawmem_support.rawmemPtrAdd(b.data, start), n)
    return Bytes(data: out.data, len: out.len)

fn bytesSliceView(b: Bytes, start: int32, count: int32): Bytes =
    if count <= 0 || start < 0 || start >= b.len:
        return emptyBytes()
    var n: int32 = count
    if start + n > b.len:
        n = b.len - start
    if n <= 0:
        return emptyBytes()
    return Bytes(data: rawmem_support.rawmemPtrAdd(b.data, start), len: n)

fn bytesEqual(a: Bytes, b: Bytes): bool =
    if a.len != b.len:
        return false
    for i in 0..<a.len:
        let av: int32 = bytesGet(a, i)
        let bv: int32 = bytesGet(b, i)
        if av != bv:
            return false
    return true

fn __cheng_bytes_eq(a, b: Bytes): bool =
    return bytesEqual(a, b)

fn __cheng_bytes_neq(a, b: Bytes): bool =
    return !bytesEqual(a, b)

fn `$`(b: Bytes): str =
    return bytesToHex b

fn bytesToHex(b: Bytes): str =
    if b.data == nil || b.len <= 0:
        return ""
    let outLen: int32 = b.len * 2
    let out: Bytes = bytesAlloc outLen
    for i in 0..<b.len:
        let value: int32 = bytesGet(b, i)
        let hi: int32 = value >> 4
        let lo: int32 = value & 15
        let hiChar: int32 = if hi < 10: int32('0') + hi else: int32('a') + (hi - 10)
        let loChar: int32 = if lo < 10: int32('0') + lo else: int32('a') + (lo - 10)
        bytesSet(out, i * 2, hiChar)
        bytesSet(out, i * 2 + 1, loChar)
    return bytesToString out

fn bytesConcat(a: Bytes, b: Bytes): Bytes =
    let aLen: int32 = bytesLen a
    let bLen: int32 = bytesLen b
    if aLen <= 0 && bLen <= 0:
        return emptyBytes()
    let outLen: int32 = aLen + bLen
    var out: Bytes = bytesAlloc outLen
    for i in 0..<aLen:
        bytesSet(out, i, bytesGet(a, i))
    for i in 0..<bLen:
        bytesSet(out, aLen + i, bytesGet(b, i))
    return out

fn bytesConcat3(a: Bytes, b: Bytes, c: Bytes): Bytes =
    let aLen: int32 = bytesLen a
    let bLen: int32 = bytesLen b
    let cLen: int32 = bytesLen c
    if aLen <= 0 && bLen <= 0 && cLen <= 0:
        return emptyBytes()
    let outLen: int32 = aLen + bLen + cLen
    var out: Bytes = bytesAlloc outLen
    var offset: int32 = 0
    for i in 0..<aLen:
        bytesSet(out, offset + i, bytesGet(a, i))
    offset = offset + aLen
    for i in 0..<bLen:
        bytesSet(out, offset + i, bytesGet(b, i))
    offset = offset + bLen
    for i in 0..<cLen:
        bytesSet(out, offset + i, bytesGet(c, i))
    return out
