# rawbytes.cheng - raw pointer bytes helpers (binary-safe)
#
# 注意：这里的 Bytes 与 pkg://cheng/libp2p 的 utils/bytes 对齐，方便机械替换 import。

import std/system
import std/strings
import std/rawmem_support

@importc("cheng_rawbytes_get_at")
fn chengRawbytesGetAt(base: ptr, idx: int32): int32
@importc("cheng_rawbytes_set_at")
fn chengRawbytesSetAt(base: ptr, idx: int32, value: int32)

type
    byte = int32
    Bytes =
        data: ptr
        len: int32

fn bytesView(data: ptr, length: int32): Bytes =
    var safeLen: int32 = length
    if safeLen < 0:
        safeLen = 0
    var out: Bytes
    out.data = data
    out.len = safeLen
    return out

fn emptyBytes(): Bytes =
    var out: Bytes
    out.data = nil
    out.len = 0
    return out

fn bytesAlloc(length: int32): Bytes =
    var out: Bytes
    if length <= 0:
        out.data = nil
        out.len = 0
        return out
    let p: ptr = alloc length
    rawmem_support.RawmemSet(p, 0, length)
    out.data = p
    out.len = length
    return out

fn bytesFromString(s: str): Bytes =
    var out: Bytes
    let n = strLenFast(s)
    if n <= 0:
        out.data = nil
        out.len = 0
        return out
    out.data = rawmemAsVoid(s)
    out.len = n
    return out

fn bytesToString(b: Bytes): str =
    if b.data == nil || b.len <= 0:
        return ""
    return newStringCopy(b.data, b.len)

fn bytesLen(b: Bytes): int32 =
    b.len

fn bytesGet(b: Bytes, idx: int32): int32 =
    if idx < 0 || idx >= b.len:
        return 0
    return chengRawbytesGetAt(b.data, idx)

fn bytesSet(b: var Bytes, idx: int32, val: int32) =
    if idx < 0 || idx >= b.len:
        return
    chengRawbytesSetAt(b.data, idx, val)

fn bytesSlice(b: Bytes, start: int32, count: int32): Bytes =
    var out: Bytes
    var start0: int32 = start
    var n: int32 = count
    if n <= 0:
        out.data = nil
        out.len = 0
        return out
    if start0 < 0:
        out.data = nil
        out.len = 0
        return out
    if start0 >= b.len:
        out.data = nil
        out.len = 0
        return out
    if start0 + n > b.len:
        n = b.len - start0
    if n <= 0:
        out.data = nil
        out.len = 0
        return out
    out = bytesAlloc(n)
    rawmem_support.RawmemCopy(out.data, rawmem_support.RawmemPtrAdd(b.data, start0), n)
    return out

fn bytesSliceView(b: Bytes, start: int32, count: int32): Bytes =
    var out: Bytes
    var start0: int32 = start
    var n: int32 = count
    if n <= 0:
        out.data = nil
        out.len = 0
        return out
    if start0 < 0:
        out.data = nil
        out.len = 0
        return out
    if start0 >= b.len:
        out.data = nil
        out.len = 0
        return out
    if start0 + n > b.len:
        n = b.len - start0
    if n <= 0:
        out.data = nil
        out.len = 0
        return out
    out.data = rawmem_support.RawmemPtrAdd(b.data, start0)
    out.len = n
    return out

fn bytesCopyInto(dst: Bytes, offset: int32, src: Bytes) =
    let n: int32 = bytesLen(src)
    if n <= 0:
        return
    assert(dst.data != nil, "bytesCopyInto: nil dst")
    assert(src.data != nil, "bytesCopyInto: nil src")
    assert(offset >= 0, "bytesCopyInto: negative offset")
    assert(offset + n <= dst.len, "bytesCopyInto: range overflow")
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(dst.data, offset), src.data, n)

fn bytesEqual(a: Bytes, b: Bytes): bool =
    if a.len != b.len:
        return false
    var i: int32
    while i < a.len:
        let av: int32 = bytesGet(a, i)
        let bv: int32 = bytesGet(b, i)
        if av != bv:
            return false
        i = i + 1
    return true

fn __cheng_bytes_eq(a, b: Bytes): bool =
    return bytesEqual(a, b)

fn __cheng_bytes_neq(a, b: Bytes): bool =
    return !bytesEqual(a, b)

fn `$`(b: Bytes): str =
    return bytesToHex b

fn bytesToHex(b: Bytes): str =
    if b.data == nil || b.len <= 0:
        return ""
    let outLen: int32 = b.len * 2
    let out: Bytes = bytesAlloc outLen
    var i: int32
    while i < b.len:
        let value: int32 = bytesGet(b, i)
        let hi: int32 = value >> 4
        let lo: int32 = value & 15
        var hiChar: int32 = int32('0') + hi
        if hi >= 10:
            hiChar = int32('a') + (hi - 10)
        var loChar: int32 = int32('0') + lo
        if lo >= 10:
            loChar = int32('a') + (lo - 10)
        bytesSet(out, i * 2, hiChar)
        bytesSet(out, i * 2 + 1, loChar)
        i = i + 1
    return bytesToString out

fn bytesConcat(a: Bytes, b: Bytes): Bytes =
    let aLen: int32 = bytesLen a
    let bLen: int32 = bytesLen b
    if aLen <= 0 && bLen <= 0:
        return emptyBytes()
    let outLen: int32 = aLen + bLen
    var out: Bytes = bytesAlloc outLen
    bytesCopyInto(out, 0, a)
    bytesCopyInto(out, aLen, b)
    return out

fn bytesConcat3(a: Bytes, b: Bytes, c: Bytes): Bytes =
    let aLen: int32 = bytesLen a
    let bLen: int32 = bytesLen b
    let cLen: int32 = bytesLen c
    if aLen <= 0 && bLen <= 0 && cLen <= 0:
        return emptyBytes()
    let outLen: int32 = aLen + bLen + cLen
    var out: Bytes = bytesAlloc outLen
    var offset: int32
    bytesCopyInto(out, offset, a)
    offset = offset + aLen
    bytesCopyInto(out, offset, b)
    offset = offset + bLen
    bytesCopyInto(out, offset, c)
    return out

fn EmptyBytes(): Bytes =
    return emptyBytes()

fn BytesAlloc(length: int32): Bytes =
    return bytesAlloc(length)

fn BytesFromString(s: str): Bytes =
    return bytesFromString(s)

fn BytesToString(b: Bytes): str =
    return bytesToString(b)

fn BytesLen(b: Bytes): int32 =
    return bytesLen(b)

fn BytesGet(b: Bytes, idx: int32): int32 =
    return bytesGet(b, idx)

fn BytesSet(b: var Bytes, idx: int32, val: int32) =
    bytesSet(b, idx, val)

fn BytesSlice(b: Bytes, start: int32, count: int32): Bytes =
    return bytesSlice(b, start, count)

fn BytesSliceView(b: Bytes, start: int32, count: int32): Bytes =
    return bytesSliceView(b, start, count)

fn BytesCopyInto(dst: Bytes, offset: int32, src: Bytes) =
    bytesCopyInto(dst, offset, src)

fn BytesEqual(a: Bytes, b: Bytes): bool =
    return bytesEqual(a, b)

fn BytesToHex(b: Bytes): str =
    return bytesToHex(b)

fn BytesConcat(a: Bytes, b: Bytes): Bytes =
    return bytesConcat(a, b)
