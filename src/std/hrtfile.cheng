# std/hrtfile (hard-rt file rings)
import std/hrt_ring

type
    HrtFileOp = int32
    HrtFileReq =
        op: int32
        fileId: int32
        offset: int64
        len: int32
        data: void*
        flags: int32
    HrtFileCpl =
        op: int32
        fileId: int32
        offset: int64
        len: int32
        data: void*
        status: int32
    HrtFileQueue =
        submit: hrt_ring.HrtRingView
        complete: hrt_ring.HrtRingView

const
    hfoRead: int32 = 0
    hfoWrite: int32 = 1

fn hrtFileRingIsPowerOfTwo(x: int32): bool =
    if x <= 0:
        return false
    let v: int32 = x - 1
    return (x & v) == 0

fn hrtFileRingAttach(view: var hrt_ring.HrtRingView, meta: hrt_ring.HrtRingMeta*, slots: void*): bool =
    if meta == nil:
        return false
    if slots == nil:
        return false
    let cap: int32 = meta->cap
    if hrtFileRingIsPowerOfTwo cap == false:
        return false
    view.meta = meta
    view.slots = slots
    return true

fn hrtFileRingIsEmpty(view: hrt_ring.HrtRingView): bool =
    if view.meta == nil:
        return true
    let meta: hrt_ring.HrtRingMeta* = view.meta
    return meta->head == meta->tail

fn hrtFileRingIsFull(view: hrt_ring.HrtRingView): bool =
    if view.meta == nil:
        return true
    let meta: hrt_ring.HrtRingMeta* = view.meta
    let next: int32 = (meta->tail + 1) & meta->mask
    return next == meta->head

fn hrtFileRingCount(view: hrt_ring.HrtRingView): int32 =
    if view.meta == nil:
        return 0
    let meta: hrt_ring.HrtRingMeta* = view.meta
    return (meta->tail - meta->head) & meta->mask

fn hrtFileRingCapacity(view: hrt_ring.HrtRingView): int32 =
    if view.meta == nil:
        return 0
    let meta: hrt_ring.HrtRingMeta* = view.meta
    return meta->cap

@importc("cheng_hrt_file_req_ptr")
fn cheng_hrt_file_req_ptr(slots: void*, idx: int32): HrtFileReq*

@importc("cheng_hrt_file_cpl_ptr")
fn cheng_hrt_file_cpl_ptr(slots: void*, idx: int32): HrtFileCpl*

fn hrtFileReqPtr(slots: void*, idx: int32): HrtFileReq* =
    return cheng_hrt_file_req_ptr(slots, idx)

fn hrtFileCplPtr(slots: void*, idx: int32): HrtFileCpl* =
    return cheng_hrt_file_cpl_ptr(slots, idx)

fn hrtFileBindSubmit(queue: var HrtFileQueue, meta: hrt_ring.HrtRingMeta*, slots: HrtFileReq*): bool =
    return hrtFileRingAttach(queue.submit, meta, void*(slots))

fn hrtFileBindComplete(queue: var HrtFileQueue, meta: hrt_ring.HrtRingMeta*, slots: HrtFileCpl*): bool =
    return hrtFileRingAttach(queue.complete, meta, void*(slots))

fn hrtFileSubmitReserve(queue: HrtFileQueue, outReq: HrtFileReq**): bool =
    if outReq == nil:
        return false
    let submit: hrt_ring.HrtRingView = queue.submit
    if submit.meta == nil:
        return false
    if submit.slots == nil:
        return false
    if hrtFileRingIsFull submit:
        return false
    let meta: hrt_ring.HrtRingMeta* = submit.meta
    let tail: int32 = meta->tail
    var slot: HrtFileReq* = hrtFileReqPtr(submit.slots, tail)
    *outReq = slot
    return true

fn hrtFileSubmitCommit(queue: var HrtFileQueue) =
    let submit: hrt_ring.HrtRingView = queue.submit
    if submit.meta == nil:
        return
    if hrtFileRingIsFull submit:
        return
    let meta: hrt_ring.HrtRingMeta* = submit.meta
    meta->tail = (meta->tail + 1) & meta->mask

fn hrtFileCompletePeek(queue: HrtFileQueue, outCpl: HrtFileCpl**): bool =
    if outCpl == nil:
        return false
    let complete: hrt_ring.HrtRingView = queue.complete
    if complete.meta == nil:
        return false
    if complete.slots == nil:
        return false
    if hrtFileRingIsEmpty complete:
        return false
    let meta: hrt_ring.HrtRingMeta* = complete.meta
    let head: int32 = meta->head
    var slot: HrtFileCpl* = hrtFileCplPtr(complete.slots, head)
    *outCpl = slot
    return true

fn hrtFileCompleteConsume(queue: var HrtFileQueue) =
    let complete: hrt_ring.HrtRingView = queue.complete
    if complete.meta == nil:
        return
    if hrtFileRingIsEmpty complete:
        return
    let meta: hrt_ring.HrtRingMeta* = complete.meta
    meta->head = (meta->head + 1) & meta->mask

fn hrtFileSubmitFree(queue: HrtFileQueue): int32 =
    let cap: int32 = hrtFileRingCapacity queue.submit
    if cap <= 1:
        return 0
    let used: int32 = hrtFileRingCount queue.submit
    let free: int32 = (cap - 1) - used
    if free < 0:
        return 0
    return free

fn hrtFileCompleteCount(queue: HrtFileQueue): int32 =
    return hrtFileRingCount queue.complete
