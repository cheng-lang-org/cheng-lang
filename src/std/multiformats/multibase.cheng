import std/strutils as strutil
# MultiBase(scaffold).

import std/result
import std/strings
import std/rawbytes
import std/buffer
import std/multiformats/base58
type
    MultiBaseCodec =
        code: str
        name: str

var
    baseIdentity: MultiBaseCodec = MultiBaseCodec(code: "0", name: "identity")
    baseBase16: MultiBaseCodec = MultiBaseCodec(code: "f", name: "base16")
    baseBase16Upper: MultiBaseCodec = MultiBaseCodec(code: "F", name: "base16upper")
    baseBase58Btc: MultiBaseCodec = MultiBaseCodec(code: "z", name: "base58btc")
    baseBase58Flickr: MultiBaseCodec = MultiBaseCodec(code: "Z", name: "base58flickr")
    baseBase32: MultiBaseCodec = MultiBaseCodec(code: "b", name: "base32")
    baseBase32Upper: MultiBaseCodec = MultiBaseCodec(code: "B", name: "base32upper")
    baseBase32Pad: MultiBaseCodec = MultiBaseCodec(code: "c", name: "base32pad")
    baseBase32PadUpper: MultiBaseCodec = MultiBaseCodec(code: "C", name: "base32padupper")
    baseBase32Hex: MultiBaseCodec = MultiBaseCodec(code: "v", name: "base32hex")
    baseBase32HexUpper: MultiBaseCodec = MultiBaseCodec(code: "V", name: "base32hexupper")
    baseBase32HexPad: MultiBaseCodec = MultiBaseCodec(code: "t", name: "base32hexpad")
    baseBase32HexPadUpper: MultiBaseCodec = MultiBaseCodec(code: "T", name: "base32hexpadupper")
    baseBase32Z: MultiBaseCodec = MultiBaseCodec(code: "h", name: "base32z")
    baseBase36: MultiBaseCodec = MultiBaseCodec(code: "k", name: "base36")
    baseBase64: MultiBaseCodec = MultiBaseCodec(code: "m", name: "base64")
    baseBase64Pad: MultiBaseCodec = MultiBaseCodec(code: "M", name: "base64pad")
    baseBase64Url: MultiBaseCodec = MultiBaseCodec(code: "u", name: "base64url")
    baseBase64UrlPad: MultiBaseCodec = MultiBaseCodec(code: "U", name: "base64urlpad")
    mbBase16Alphabet = "0123456789abcdef"
    mbBase16UpperAlphabet = "0123456789ABCDEF"
    mbBase32Alphabet = "abcdefghijklmnopqrstuvwxyz234567"
    mbBase32UpperAlphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567"
    mbBase32ZAlphabet = "ybndrfg8ejkmcpqxot1uwisza345h769"
    mbBase32HexAlphabet = "0123456789abcdefghijklmnopqrstuv"
    mbBase32HexUpperAlphabet = "0123456789ABCDEFGHIJKLMNOPQRSTUV"
    mbBase36Alphabet = "0123456789abcdefghijklmnopqrstuvwxyz"
    mbBase58Alphabet = "123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz"
    mbBase58FlickrAlphabet = "123456789abcdefghijkmnopqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ"
    mbBase64Alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
    mbBase64UrlAlphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"

fn base16Value(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'f':
        return 10 + (int32(c) - int32('a'))
    if c >= 'A' && c <= 'F':
        return 10 + (int32(c) - int32('A'))
    return -1

fn base16UpperAlphabet(alphabet: str): bool =
    if len(alphabet) <= 10:
        return false
    return alphabet[10] == 'A'

fn base16Char(digit: int32, upper: bool): int32 =
    if digit < 10:
        return int32('0') + digit
    if upper:
        return int32('A') + (digit - 10)
    return int32('a') + (digit - 10)

fn base32AlphabetKind(alphabet: str): int32 =
    if len(alphabet) <= 0:
        return 0
    if alphabet[0] == 'A':
        return 1
    if alphabet[0] == 'y':
        return 2
    if alphabet[0] == '0':
        if len(alphabet) > 10 && alphabet[10] == 'A':
            return 4
        return 3
    return 0

fn base32zChar(digit: int32): int32 =
    if digit == 0: return int32('y')
    if digit == 1: return int32('b')
    if digit == 2: return int32('n')
    if digit == 3: return int32('d')
    if digit == 4: return int32('r')
    if digit == 5: return int32('f')
    if digit == 6: return int32('g')
    if digit == 7: return int32('8')
    if digit == 8: return int32('e')
    if digit == 9: return int32('j')
    if digit == 10: return int32('k')
    if digit == 11: return int32('m')
    if digit == 12: return int32('c')
    if digit == 13: return int32('p')
    if digit == 14: return int32('q')
    if digit == 15: return int32('x')
    if digit == 16: return int32('o')
    if digit == 17: return int32('t')
    if digit == 18: return int32('1')
    if digit == 19: return int32('u')
    if digit == 20: return int32('w')
    if digit == 21: return int32('i')
    if digit == 22: return int32('s')
    if digit == 23: return int32('z')
    if digit == 24: return int32('a')
    if digit == 25: return int32('3')
    if digit == 26: return int32('4')
    if digit == 27: return int32('5')
    if digit == 28: return int32('h')
    if digit == 29: return int32('7')
    if digit == 30: return int32('6')
    return int32('9')

fn base32zValue(c: char): int32 =
    if c == 'y': return 0
    if c == 'b': return 1
    if c == 'n': return 2
    if c == 'd': return 3
    if c == 'r': return 4
    if c == 'f': return 5
    if c == 'g': return 6
    if c == '8': return 7
    if c == 'e': return 8
    if c == 'j': return 9
    if c == 'k': return 10
    if c == 'm': return 11
    if c == 'c': return 12
    if c == 'p': return 13
    if c == 'q': return 14
    if c == 'x': return 15
    if c == 'o': return 16
    if c == 't': return 17
    if c == '1': return 18
    if c == 'u': return 19
    if c == 'w': return 20
    if c == 'i': return 21
    if c == 's': return 22
    if c == 'z': return 23
    if c == 'a': return 24
    if c == '3': return 25
    if c == '4': return 26
    if c == '5': return 27
    if c == 'h': return 28
    if c == '7': return 29
    if c == '6': return 30
    if c == '9': return 31
    return -1

fn base32CharWithKind(kind: int32, digit: int32): int32 =
    if kind == 1:
        if digit < 26:
            return int32('A') + digit
        return int32('2') + (digit - 26)
    if kind == 2:
        return base32zChar(digit)
    if kind == 3:
        if digit < 10:
            return int32('0') + digit
        return int32('a') + (digit - 10)
    if kind == 4:
        if digit < 10:
            return int32('0') + digit
        return int32('A') + (digit - 10)
    if digit < 26:
        return int32('a') + digit
    return int32('2') + (digit - 26)

fn base32ValueWithKind(kind: int32, c: char): int32 =
    if kind == 1:
        if c >= 'A' && c <= 'Z':
            return int32(c) - int32('A')
        if c >= '2' && c <= '7':
            return 26 + (int32(c) - int32('2'))
        return -1
    if kind == 2:
        return base32zValue(c)
    if kind == 3:
        if c >= '0' && c <= '9':
            return int32(c) - int32('0')
        if c >= 'a' && c <= 'v':
            return 10 + (int32(c) - int32('a'))
        return -1
    if kind == 4:
        if c >= '0' && c <= '9':
            return int32(c) - int32('0')
        if c >= 'A' && c <= 'V':
            return 10 + (int32(c) - int32('A'))
        return -1
    if c >= 'a' && c <= 'z':
        return int32(c) - int32('a')
    if c >= '2' && c <= '7':
        return 26 + (int32(c) - int32('2'))
    return -1

fn base32ValueWithAlphabet(c: char, alphabet: str): int32 =
    return base32ValueWithKind(base32AlphabetKind(alphabet), c)

fn base32Value(c: char): int32 =
    return base32ValueWithAlphabet(c, mbBase32Alphabet)

fn base32zValue(c: char): int32 =
    return base32ValueWithAlphabet(c, mbBase32ZAlphabet)

fn base36Value(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'z':
        return 10 + (int32(c) - int32('a'))
    if c >= 'A' && c <= 'Z':
        return 10 + (int32(c) - int32('A'))
    return -1

fn base58AlphabetIsFlickr(alphabet: str): bool =
    if len(alphabet) <= 9:
        return false
    return alphabet[9] == 'a'

fn base58FlickrChar(digit: int32): int32 =
    if digit < 9:
        return int32('1') + digit
    if digit < 20:
        return int32('a') + (digit - 9)
    if digit < 34:
        return int32('m') + (digit - 20)
    if digit < 42:
        return int32('A') + (digit - 34)
    if digit < 47:
        return int32('J') + (digit - 42)
    return int32('P') + (digit - 47)

fn base58Char(digit: int32): int32 =
    if digit < 9:
        return int32('1') + digit
    if digit < 17:
        return int32('A') + (digit - 9)
    if digit < 22:
        return int32('J') + (digit - 17)
    if digit < 33:
        return int32('P') + (digit - 22)
    if digit < 44:
        return int32('a') + (digit - 33)
    return int32('m') + (digit - 44)

fn base58FlickrValue(c: char): int32 =
    let code = int32(c)
    if code >= int32('1') && code <= int32('9'):
        return code - int32('1')
    if code >= int32('a') && code <= int32('k'):
        return 9 + (code - int32('a'))
    if code >= int32('m') && code <= int32('z'):
        return 20 + (code - int32('m'))
    if code >= int32('A') && code <= int32('H'):
        return 34 + (code - int32('A'))
    if code >= int32('J') && code <= int32('N'):
        return 42 + (code - int32('J'))
    if code >= int32('P') && code <= int32('Z'):
        return 47 + (code - int32('P'))
    return -1

fn base58ValueWithAlphabet(c: char, alphabet: str): int32 =
    if base58AlphabetIsFlickr(alphabet):
        return base58FlickrValue(c)
    return base58Value(c)

fn base58Value(c: char): int32 =
    let code = int32(c)
    if code >= int32('1') && code <= int32('9'):
        return code - int32('1')
    if code >= int32('A') && code <= int32('H'):
        return 9 + (code - int32('A'))
    if code >= int32('J') && code <= int32('N'):
        return 17 + (code - int32('J'))
    if code >= int32('P') && code <= int32('Z'):
        return 22 + (code - int32('P'))
    if code >= int32('a') && code <= int32('k'):
        return 33 + (code - int32('a'))
    if code >= int32('m') && code <= int32('z'):
        return 44 + (code - int32('m'))
    return -1

fn encodeBase58Named(data: Bytes, useFlickr: bool): str =
    if BytesLen(data) <= 0:
        return ""
    var zeros: int32
    while zeros < BytesLen(data) && BytesGet(data, zeros) == 0:
        zeros = zeros + 1
    let size: int32 = (BytesLen(data) * 138) / 100 + 1
    let b58: Bytes = BytesAlloc(size)
    for i in 0..<BytesLen(data):
        var carry: int32 = BytesGet(data, i)
        let jStart4 = size - 1
        if jStart4 >= 0:
            for jOffset4 in 0..jStart4:
                let j = jStart4 - jOffset4
                let value: int32 = BytesGet(b58, j)
                carry = carry + value * 256
                BytesSet(b58, j, carry % 58)
                carry = carry / 58
    var start: int32
    while start < size && BytesGet(b58, start) == 0:
        start = start + 1
    let outLen: int32 = zeros + (size - start)
    let out: Bytes = BytesAlloc(outLen)
    var outIdx: int32
    for outIdx in outIdx..<zeros:
        BytesSet(out, outIdx, int32('1'))
                outIdx = zeros
    for k in start..<size:
        let digit: int32 = BytesGet(b58, k)
        if useFlickr:
            BytesSet(out, outIdx, base58FlickrChar(digit))
        else:
            BytesSet(out, outIdx, base58Char(digit))
        outIdx = outIdx + 1
    return BytesToString(out)

fn decodeBase58Named(text: str, label: str, useFlickr: bool): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](EmptyBytes())
    var zeros: int32
    while zeros < len(text) && text[zeros] == '1':
        zeros = zeros + 1
    let size: int32 = (len(text) * 733) / 1000 + 1
    let b256: Bytes = BytesAlloc(size)
    for i in 0..<len(text):
        var val: int32 = base58Value(text[i])
        if useFlickr:
            val = base58FlickrValue(text[i])
        if val < 0:
            return Err[Bytes](strutil.Join(["multibase: invalid ", label], ""))
        var carry: int32 = val
        let jStart3 = size - 1
        if jStart3 >= 0:
            for jOffset3 in 0..jStart3:
                let j = jStart3 - jOffset3
                let value: int32 = BytesGet(b256, j)
                carry = carry + value * 58
                BytesSet(b256, j, carry % 256)
                carry = carry / 256
    var start: int32
    while start < size && BytesGet(b256, start) == 0:
        start = start + 1
    let outLen: int32 = zeros + (size - start)
    let out: Bytes = BytesAlloc(outLen)
    var outIdx: int32
    for outIdx in outIdx..<zeros:
        BytesSet(out, outIdx, 0)
                outIdx = zeros
    for k in start..<size:
        BytesSet(out, outIdx, BytesGet(b256, k))
        outIdx = outIdx + 1
    return Ok[Bytes](out)

fn base64Value(c: char, url: bool): int32 =
    if c >= 'A' && c <= 'Z':
        return int32(c) - int32('A')
    if c >= 'a' && c <= 'z':
        return 26 + (int32(c) - int32('a'))
    if c >= '0' && c <= '9':
        return 52 + (int32(c) - int32('0'))
    if url:
        if c == '-':
            return 62
        if c == '_':
            return 63
        return -1
    if c == '+':
        return 62
    if c == '/':
        return 63
    return -1

fn base64Char(digit: int32, url: bool): int32 =
    if digit < 26:
        return int32('A') + digit
    if digit < 52:
        return int32('a') + (digit - 26)
    if digit < 62:
        return int32('0') + (digit - 52)
    if digit == 62:
        if url:
            return int32('-')
        return int32('+')
    if url:
        return int32('_')
    return int32('/')

fn encodeBase16WithAlphabet(data: Bytes, alphabet: str): str =
    if BytesLen(data) <= 0:
        return ""
    let upper: bool = base16UpperAlphabet(alphabet)
    let out: Bytes = BytesAlloc(BytesLen(data) * 2)
    for i in 0..<BytesLen(data):
        let value: int32 = BytesGet(data, i)
        let hi: int32 = value >> 4
        let lo: int32 = value & 15
        BytesSet(out, i * 2, base16Char(hi, upper))
        BytesSet(out, i * 2 + 1, base16Char(lo, upper))
    return BytesToString(out)

fn encodeBase16Named(data: Bytes, upper: bool): str =
    if BytesLen(data) <= 0:
        return ""
    let out: Bytes = BytesAlloc(BytesLen(data) * 2)
    for i in 0..<BytesLen(data):
        let value: int32 = BytesGet(data, i)
        let hi: int32 = value >> 4
        let lo: int32 = value & 15
        BytesSet(out, i * 2, base16Char(hi, upper))
        BytesSet(out, i * 2 + 1, base16Char(lo, upper))
    return BytesToString(out)

fn encodeBase16(data: Bytes): str =
    return encodeBase16Named(data, false)

fn encodeBase16Upper(data: Bytes): str =
    return encodeBase16Named(data, true)

fn decodeBase16(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](EmptyBytes())
    if (len(text) % 2) != 0:
        return Err[Bytes]("multibase: invalid base16")
    let out: Bytes = BytesAlloc(len(text) / 2)
    var i: int32
    var outIdx: int32
    for _ in range(len(text) / 2):
        let hi: int32 = base16Value(text[i])
        let lo: int32 = base16Value(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("multibase: invalid base16")
        BytesSet(out, outIdx, (hi << 4) | lo)
        outIdx = outIdx + 1
        i = i + 2
    return Ok[Bytes](out)

fn encodeBase32WithAlphabet(data: Bytes, alphabet: str): str =
    if BytesLen(data) <= 0:
        return ""
    let kind: int32 = base32AlphabetKind(alphabet)
    return encodeBase32Named(data, kind)

fn encodeBase32Named(data: Bytes, kind: int32): str =
    if BytesLen(data) <= 0:
        return ""
    var buf: ByteBuffer = newByteBuffer()
    var acc: int64
    var bits: int32
    for i in 0..<BytesLen(data):
        acc = (acc << 8) | int64(BytesGet(data, i))
        bits = bits + 8
        while bits >= 5:
            let shift: int32 = bits - 5
            let idx: int32 = int32((acc >> shift) & 31)
            appendByte(buf, base32CharWithKind(kind, idx))
            bits = bits - 5
    if bits > 0:
        let idx: int32 = int32((acc << (5 - bits)) & 31)
        appendByte(buf, base32CharWithKind(kind, idx))
    return BytesToString(toBytes(buf))

fn decodeBase32WithAlphabet(text: str, alphabet: str, label: str, allowPad: bool): Result[Bytes] =
    return decodeBase32Named(text, label, allowPad, base32AlphabetKind(alphabet))

fn decodeBase32Named(text: str, label: str, allowPad: bool, kind: int32): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](EmptyBytes())
    var buf: ByteBuffer = newByteBuffer()
    var acc: int64
    var bits: int32
    for i in 0..<len(text):
        let c: char = text[i]
        if c == '=':
            if allowPad:
                break
            return Err[Bytes](strutil.Join(["multibase: invalid ", label], ""))
        let v: int32 = base32ValueWithKind(kind, c)
        if v < 0:
            return Err[Bytes](strutil.Join(["multibase: invalid ", label], ""))
        acc = (acc << 5) | int64(v)
        bits = bits + 5
        if bits >= 8:
            let shift: int32 = bits - 8
            let outByte: int32 = int32((acc >> shift) & 255)
            appendByte(buf, outByte)
            bits = bits - 8
    return Ok[Bytes](toBytes(buf))

fn encodeBase32(data: Bytes): str =
    return encodeBase32Named(data, 0)

fn decodeBase32(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32", false, 0)

fn encodeBase32z(data: Bytes): str =
    return encodeBase32Named(data, 2)

fn decodeBase32z(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32z", false, 2)

fn encodeBase36(data: Bytes): str =
    if BytesLen(data) <= 0:
        return ""
    var zeros: int32
    while zeros < BytesLen(data) && BytesGet(data, zeros) == 0:
        zeros = zeros + 1
    let size: int32 = BytesLen(data) * 2 + 1
    let b36: Bytes = BytesAlloc(size)
    for i in 0..<BytesLen(data):
        var carry: int32 = BytesGet(data, i)
        let jStart2 = size - 1
        if jStart2 >= 0:
            for jOffset2 in 0..jStart2:
                let j = jStart2 - jOffset2
                let value: int32 = BytesGet(b36, j)
                carry = carry + value * 256
                BytesSet(b36, j, carry % 36)
                carry = carry / 36
    var start: int32
    while start < size && BytesGet(b36, start) == 0:
        start = start + 1
    let outLen: int32 = zeros + (size - start)
    let out: Bytes = BytesAlloc(outLen)
    var outIdx: int32
    for outIdx in outIdx..<zeros:
        BytesSet(out, outIdx, int32('0'))
                outIdx = zeros
    for k in start..<size:
        let digit: int32 = BytesGet(b36, k)
        if digit < 10:
            BytesSet(out, outIdx, int32('0') + digit)
        else:
            BytesSet(out, outIdx, int32('a') + (digit - 10))
        outIdx = outIdx + 1
    return BytesToString(out)

fn decodeBase36(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](EmptyBytes())
    var zeros: int32
    while zeros < len(text) && text[zeros] == '0':
        zeros = zeros + 1
    let size: int32 = len(text) + 1
    let b256: Bytes = BytesAlloc(size)
    for i in 0..<len(text):
        let val: int32 = base36Value(text[i])
        if val < 0:
            return Err[Bytes]("multibase: invalid base36")
        var carry: int32 = val
        let jStart = size - 1
        if jStart >= 0:
            for jOffset in 0..jStart:
                let j = jStart - jOffset
                let value: int32 = BytesGet(b256, j)
                carry = carry + value * 36
                BytesSet(b256, j, carry % 256)
                carry = carry / 256
    var start: int32
    while start < size && BytesGet(b256, start) == 0:
        start = start + 1
    let outLen: int32 = zeros + (size - start)
    let out: Bytes = BytesAlloc(outLen)
    var outIdx: int32
    for outIdx in outIdx..<zeros:
        BytesSet(out, outIdx, 0)
                outIdx = zeros
    for k in start..<size:
        BytesSet(out, outIdx, BytesGet(b256, k))
        outIdx = outIdx + 1
    return Ok[Bytes](out)

fn encodeBase58WithAlphabet(data: Bytes, alphabet: str): str =
    if base58AlphabetIsFlickr(alphabet):
        return base58.EncodeBase58Flickr(data)
    return base58.EncodeBase58(data)

fn decodeBase58WithAlphabet(text: str, alphabet: str, label: str): Result[Bytes] =
    if base58AlphabetIsFlickr(alphabet):
        return base58.DecodeBase58Flickr(text)
    return base58.DecodeBase58(text)

fn encodeBase58(data: Bytes): str =
    return base58.EncodeBase58(data)

fn decodeBase58(text: str): Result[Bytes] =
    return base58.DecodeBase58(text)

fn encodeBase58Flickr(data: Bytes): str =
    return base58.EncodeBase58Flickr(data)

fn decodeBase58Flickr(text: str): Result[Bytes] =
    return base58.DecodeBase58Flickr(text)

fn encodeBase64(data: Bytes, url: bool): str =
    if BytesLen(data) <= 0:
        return ""
    var buf: ByteBuffer = newByteBuffer()
    var acc: int64
    var bits: int32
    for i in 0..<BytesLen(data):
        acc = (acc << 8) | int64(BytesGet(data, i))
        bits = bits + 8
        while bits >= 6:
            let shift: int32 = bits - 6
            let idx: int32 = int32((acc >> shift) & 63)
            appendByte(buf, base64Char(idx, url))
            bits = bits - 6
    if bits > 0:
        let idx: int32 = int32((acc << (6 - bits)) & 63)
        appendByte(buf, base64Char(idx, url))
    return BytesToString(toBytes(buf))

fn decodeBase64(text: str, url: bool): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](EmptyBytes())
    var buf: ByteBuffer = newByteBuffer()
    var acc: int64
    var bits: int32
    for i in 0..<len(text):
        let c: char = text[i]
        if c == '=':
            break
        let v: int32 = base64Value(c, url)
        if v < 0:
            return Err[Bytes]("multibase: invalid base64")
        acc = (acc << 6) | int64(v)
        bits = bits + 6
        if bits >= 8:
            let shift: int32 = bits - 8
            let outByte: int32 = int32((acc >> shift) & 255)
            appendByte(buf, outByte)
            bits = bits - 8
    return Ok[Bytes](toBytes(buf))

fn padToMultiple(text: str, block: int32): str =
    if block <= 0:
        return text
    let size: int32 = len(text)
    if size <= 0:
        return ""
    let rem: int32 = size % block
    if rem == 0:
        return text
    let pad: int32 = block - rem
    var buf: ByteBuffer = newByteBuffer()
    appendBytes(buf, BytesFromString(text))
    for i in 0..<pad:
        appendByte(buf, int32('='))
    return BytesToString(toBytes(buf))

fn encodeBase32Padded(data: Bytes, alphabet: str): str =
    return padToMultiple(encodeBase32WithAlphabet(data, alphabet), 8)

fn decodeBase32Padded(text: str, alphabet: str, label: str): Result[Bytes] =
    return decodeBase32WithAlphabet(text, alphabet, label, true)

fn encodeBase64Padded(data: Bytes, url: bool): str =
    return padToMultiple(encodeBase64(data, url), 4)

fn encodeBase32Upper(data: Bytes): str =
    return encodeBase32Named(data, 1)

fn decodeBase32Upper(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32upper", false, 1)

fn encodeBase32Pad(data: Bytes): str =
    return padToMultiple(encodeBase32Named(data, 0), 8)

fn decodeBase32Pad(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32pad", true, 0)

fn encodeBase32PadUpper(data: Bytes): str =
    return padToMultiple(encodeBase32Named(data, 1), 8)

fn decodeBase32PadUpper(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32padupper", true, 1)

fn encodeBase32Hex(data: Bytes): str =
    return encodeBase32Named(data, 3)

fn decodeBase32Hex(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32hex", false, 3)

fn encodeBase32HexUpper(data: Bytes): str =
    return encodeBase32Named(data, 4)

fn decodeBase32HexUpper(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32hexupper", false, 4)

fn encodeBase32HexPad(data: Bytes): str =
    return padToMultiple(encodeBase32Named(data, 3), 8)

fn decodeBase32HexPad(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32hexpad", true, 3)

fn encodeBase32HexPadUpper(data: Bytes): str =
    return padToMultiple(encodeBase32Named(data, 4), 8)

fn decodeBase32HexPadUpper(text: str): Result[Bytes] =
    return decodeBase32Named(text, "base32hexpadupper", true, 4)

fn encodeBase64Pad(data: Bytes): str =
    return encodeBase64Padded(data, false)

fn encodeBase64Url(data: Bytes): str =
    return encodeBase64(data, true)

fn encodeBase64UrlPad(data: Bytes): str =
    return encodeBase64Padded(data, true)

fn decodeBase64Pad(text: str): Result[Bytes] =
    return decodeBase64(text, false)

fn decodeBase64Url(text: str): Result[Bytes] =
    return decodeBase64(text, true)

fn decodeBase64UrlPad(text: str): Result[Bytes] =
    return decodeBase64(text, true)

fn encodeBase58Multibase(data: Bytes): Result[str] =
    return Ok[str](strutil.Join(["z", base58.EncodeBase58(data)], ""))

fn encodeBase32Multibase(data: Bytes): Result[str] =
    return Ok[str](strutil.Join(["b", encodeBase32(data)], ""))

fn encodeBase64UrlMultibase(data: Bytes): Result[str] =
    return Ok[str](strutil.Join(["u", encodeBase64Url(data)], ""))

fn codecByName(name: str): Result[MultiBaseCodec] =
    if name == "identity": return Ok[MultiBaseCodec](MultiBaseCodec(code: "0", name: "identity"))
    if name == "base16": return Ok[MultiBaseCodec](MultiBaseCodec(code: "f", name: "base16"))
    if name == "base16upper": return Ok[MultiBaseCodec](MultiBaseCodec(code: "F", name: "base16upper"))
    if name == "base58btc": return Ok[MultiBaseCodec](MultiBaseCodec(code: "z", name: "base58btc"))
    if name == "base58flickr": return Ok[MultiBaseCodec](MultiBaseCodec(code: "Z", name: "base58flickr"))
    if name == "base32": return Ok[MultiBaseCodec](MultiBaseCodec(code: "b", name: "base32"))
    if name == "base32upper": return Ok[MultiBaseCodec](MultiBaseCodec(code: "B", name: "base32upper"))
    if name == "base32pad": return Ok[MultiBaseCodec](MultiBaseCodec(code: "c", name: "base32pad"))
    if name == "base32padupper": return Ok[MultiBaseCodec](MultiBaseCodec(code: "C", name: "base32padupper"))
    if name == "base32hex": return Ok[MultiBaseCodec](MultiBaseCodec(code: "v", name: "base32hex"))
    if name == "base32hexupper": return Ok[MultiBaseCodec](MultiBaseCodec(code: "V", name: "base32hexupper"))
    if name == "base32hexpad": return Ok[MultiBaseCodec](MultiBaseCodec(code: "t", name: "base32hexpad"))
    if name == "base32hexpadupper": return Ok[MultiBaseCodec](MultiBaseCodec(code: "T", name: "base32hexpadupper"))
    if name == "base32z": return Ok[MultiBaseCodec](MultiBaseCodec(code: "h", name: "base32z"))
    if name == "base36": return Ok[MultiBaseCodec](MultiBaseCodec(code: "k", name: "base36"))
    if name == "base64": return Ok[MultiBaseCodec](MultiBaseCodec(code: "m", name: "base64"))
    if name == "base64pad": return Ok[MultiBaseCodec](MultiBaseCodec(code: "M", name: "base64pad"))
    if name == "base64url": return Ok[MultiBaseCodec](MultiBaseCodec(code: "u", name: "base64url"))
    if name == "base64urlpad": return Ok[MultiBaseCodec](MultiBaseCodec(code: "U", name: "base64urlpad"))
    return Err[MultiBaseCodec]("multibase: unknown codec")

fn codecByCode(code: str): Result[MultiBaseCodec] =
    if code == "0": return Ok[MultiBaseCodec](MultiBaseCodec(code: "0", name: "identity"))
    if code == "f": return Ok[MultiBaseCodec](MultiBaseCodec(code: "f", name: "base16"))
    if code == "F": return Ok[MultiBaseCodec](MultiBaseCodec(code: "F", name: "base16upper"))
    if code == "z": return Ok[MultiBaseCodec](MultiBaseCodec(code: "z", name: "base58btc"))
    if code == "Z": return Ok[MultiBaseCodec](MultiBaseCodec(code: "Z", name: "base58flickr"))
    if code == "b": return Ok[MultiBaseCodec](MultiBaseCodec(code: "b", name: "base32"))
    if code == "B": return Ok[MultiBaseCodec](MultiBaseCodec(code: "B", name: "base32upper"))
    if code == "c": return Ok[MultiBaseCodec](MultiBaseCodec(code: "c", name: "base32pad"))
    if code == "C": return Ok[MultiBaseCodec](MultiBaseCodec(code: "C", name: "base32padupper"))
    if code == "v": return Ok[MultiBaseCodec](MultiBaseCodec(code: "v", name: "base32hex"))
    if code == "V": return Ok[MultiBaseCodec](MultiBaseCodec(code: "V", name: "base32hexupper"))
    if code == "t": return Ok[MultiBaseCodec](MultiBaseCodec(code: "t", name: "base32hexpad"))
    if code == "T": return Ok[MultiBaseCodec](MultiBaseCodec(code: "T", name: "base32hexpadupper"))
    if code == "h": return Ok[MultiBaseCodec](MultiBaseCodec(code: "h", name: "base32z"))
    if code == "k": return Ok[MultiBaseCodec](MultiBaseCodec(code: "k", name: "base36"))
    if code == "m": return Ok[MultiBaseCodec](MultiBaseCodec(code: "m", name: "base64"))
    if code == "M": return Ok[MultiBaseCodec](MultiBaseCodec(code: "M", name: "base64pad"))
    if code == "u": return Ok[MultiBaseCodec](MultiBaseCodec(code: "u", name: "base64url"))
    if code == "U": return Ok[MultiBaseCodec](MultiBaseCodec(code: "U", name: "base64urlpad"))
    return Err[MultiBaseCodec]("multibase: unknown code")

fn encodeMultibase(codec: MultiBaseCodec, data: Bytes): Result[str] =
    var body: str
    if codec.code == "0":
        body = BytesToString(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "f":
        body = encodeBase16(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "F":
        body = encodeBase16Upper(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "z":
        body = encodeBase58(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "Z":
        body = encodeBase58Flickr(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "b":
        body = encodeBase32(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "B":
        body = encodeBase32Upper(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "c":
        body = encodeBase32Pad(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "C":
        body = encodeBase32PadUpper(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "v":
        body = encodeBase32Hex(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "V":
        body = encodeBase32HexUpper(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "t":
        body = encodeBase32HexPad(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "T":
        body = encodeBase32HexPadUpper(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "h":
        body = encodeBase32z(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "k":
        body = encodeBase36(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "m":
        body = encodeBase64(data, false)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "M":
        body = encodeBase64Pad(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "u":
        body = encodeBase64Url(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    if codec.code == "U":
        body = encodeBase64UrlPad(data)
        return Ok[str](strutil.Join([codec.code, body], ""))
    return Err[str]("multibase encode ! implemented")

fn decodeMultibase(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Err[Bytes]("multibase: empty input")
    if len(text) <= 1:
        return Err[Bytes]("multibase: missing payload")
    let code: str = charToStr(text[0])
    if code == "0":
        return Ok[Bytes](BytesFromString(sliceBytes(text, 1, len(text) - 1)))
    let payload: str = sliceBytes(text, 1, len(text) - 1)
    if code == "f":
        return decodeBase16(payload)
    if code == "F":
        return decodeBase16(payload)
    if code == "z":
        return decodeBase58(payload)
    if code == "Z":
        return decodeBase58Flickr(payload)
    if code == "b":
        return decodeBase32(payload)
    if code == "B":
        return decodeBase32Upper(payload)
    if code == "c":
        return decodeBase32Pad(payload)
    if code == "C":
        return decodeBase32PadUpper(payload)
    if code == "v":
        return decodeBase32Hex(payload)
    if code == "V":
        return decodeBase32HexUpper(payload)
    if code == "t":
        return decodeBase32HexPad(payload)
    if code == "T":
        return decodeBase32HexPadUpper(payload)
    if code == "h":
        return decodeBase32z(payload)
    if code == "k":
        return decodeBase36(payload)
    if code == "m":
        return decodeBase64(payload, false)
    if code == "M":
        return decodeBase64Pad(payload)
    if code == "u":
        return decodeBase64Url(payload)
    if code == "U":
        return decodeBase64UrlPad(payload)
    return Err[Bytes]("multibase decode ! implemented")
