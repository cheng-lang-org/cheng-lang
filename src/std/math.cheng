# std/math - Math functions (pure Cheng)
import std/system

# --- Integer helpers ---

fn absInt(value: int32): int32 =
    if value < 0:
        return -value
    return value

fn absInt64(value: int64): int64 =
    if value < 0:
        return -value
    return value

fn absFloat(value: float64): float64 =
    if value < 0.0:
        return -value
    return value

fn minInt(a: int32, b: int32): int32 =
    return a < b ? a : b

fn maxInt(a: int32, b: int32): int32 =
    return a > b ? a : b

fn minInt64(a: int64, b: int64): int64 =
    return a < b ? a : b

fn maxInt64(a: int64, b: int64): int64 =
    return a > b ? a : b

fn minFloat(a: float64, b: float64): float64 =
    return a < b ? a : b

fn maxFloat(a: float64, b: float64): float64 =
    return a > b ? a : b

fn clampInt(value: int32, lo: int32, hi: int32): int32 =
    if value < lo:
        return lo
    if value > hi:
        return hi
    return value

fn clampInt64(value: int64, lo: int64, hi: int64): int64 =
    if value < lo:
        return lo
    if value > hi:
        return hi
    return value

fn clampFloat(value: float64, lo: float64, hi: float64): float64 =
    if value < lo:
        return lo
    if value > hi:
        return hi
    return value

# --- Exponentiation ---

fn powInt(base: int32, exp: int32): int32 =
    if exp <= 0:
        return 1
    var result: int32 = 1
    var b: int32 = base
    var e: int32 = exp
    while e > 0:
        if (e & 1) != 0:
            result = result * b
        b = b * b
        e = e >> 1
    return result

fn powInt64(base: int64, exp: int32): int64 =
    if exp <= 0:
        return int64(1)
    var result: int64 = int64(1)
    var b: int64 = base
    var e: int32 = exp
    while e > 0:
        if (e & 1) != 0:
            result = result * b
        b = b * b
        e = e >> 1
    return result

fn powFloat(base: float64, exp: int32): float64 =
    if exp == 0:
        return 1.0
    var result: float64 = 1.0
    var b: float64 = base
    var e: int32 = exp
    if e < 0:
        b = 1.0 / b
        e = -e
    while e > 0:
        if (e & 1) != 0:
            result = result * b
        b = b * b
        e = e >> 1
    return result

# --- Square root (Newton's method) ---

fn sqrtFloat(value: float64): float64 =
    if value <= 0.0:
        return 0.0
    var x: float64 = value
    var y: float64 = 1.0
    let epsilon: float64 = 0.000001
    while x - y > epsilon:
        x = (x + y) / 2.0
        y = value / x
    return x

# --- Integer square root (floor sqrt for int32) ---

fn isqrt(value: int32): int32 =
    if value <= 0:
        return 0
    if value >= 46340 * 46340:
        return 46340
    var lo: int32 = 1
    var hi: int32 = value
    if hi > 46340:
        hi = 46340
    while lo <= hi:
        let mid: int32 = lo + (hi - lo) / 2
        let sq: int32 = mid * mid
        if sq == value:
            return mid
        if sq < value:
            lo = mid + 1
        else:
            hi = mid - 1
    return hi

# --- Float floor/ceil ---

fn floorFloat(value: float64): float64 =
    var n: int64 = int64(value)
    var f: float64 = float64(n)
    if value >= 0.0:
        return f
    if f == value:
        return f
    return f - 1.0

fn ceilFloat(value: float64): float64 =
    var n: int64 = int64(value)
    var f: float64 = float64(n)
    if f == value:
        return f
    if value > 0.0:
        return f + 1.0
    return f

# --- Round ---

fn roundFloat(value: float64): float64 =
    if value >= 0.0:
        let n: int64 = int64(value + 0.5)
        return float64(n)
    let n: int64 = int64(value - 0.5)
    return float64(n)

# --- Trigonometric approximations (Taylor series) ---

fn sinFloat(x: float64): float64 =
    var term: float64 = x
    var result: float64 = x
    var n: int32 = 1
    while n < 10:
        term = -term * x * x / float64((2 * n) * (2 * n + 1))
        result = result + term
        n = n + 1
    return result

fn cosFloat(x: float64): float64 =
    var term: float64 = 1.0
    var result: float64 = 1.0
    var n: int32 = 1
    while n < 10:
        term = -term * x * x / float64((2 * n - 1) * (2 * n))
        result = result + term
        n = n + 1
    return result

# --- Positive modulo ---

fn modInt(a: int32, b: int32): int32 =
    if b == 0:
        return 0
    let r: int32 = a % b
    if r < 0:
        return r + b
    return r

fn modInt64(a: int64, b: int64): int64 =
    if b == int64(0):
        return int64(0)
    let r: int64 = a % b
    if r < int64(0):
        return r + b
    return r

# --- Greatest Common Divisor ---

fn gcdInt(a: int32, b: int32): int32 =
    var x: int32 = a
    var y: int32 = b
    if x < 0:
        x = -x
    if y < 0:
        y = -y
    while y != 0:
        let t: int32 = y
        y = x % y
        x = t
    return x

fn gcdInt64(a: int64, b: int64): int64 =
    var x: int64 = a
    var y: int64 = b
    if x < int64(0):
        x = -x
    if y < int64(0):
        y = -y
    while y != int64(0):
        let t: int64 = y
        y = x % y
        x = t
    return x

# --- Floating point equality with epsilon ---

fn approxEq(a: float64, b: float64, epsilon: float64): bool =
    let diff: float64 = a - b
    if diff < 0.0:
        return -diff <= epsilon
    return diff <= epsilon

# ---- Public exports ----

fn Abs(value: int32): int32 =
    return absInt(value)

fn Abs(value: int64): int64 =
    return absInt64(value)

fn Abs(value: float64): float64 =
    return absFloat(value)

fn Min(a: int32, b: int32): int32 =
    return minInt(a, b)

fn Min(a: int64, b: int64): int64 =
    return minInt64(a, b)

fn Min(a: float64, b: float64): float64 =
    return minFloat(a, b)

fn Max(a: int32, b: int32): int32 =
    return maxInt(a, b)

fn Max(a: int64, b: int64): int64 =
    return maxInt64(a, b)

fn Max(a: float64, b: float64): float64 =
    return maxFloat(a, b)

fn Clamp(value: int32, lo: int32, hi: int32): int32 =
    return clampInt(value, lo, hi)

fn Clamp(value: int64, lo: int64, hi: int64): int64 =
    return clampInt64(value, lo, hi)

fn Clamp(value: float64, lo: float64, hi: float64): float64 =
    return clampFloat(value, lo, hi)

fn Pow(base: int32, exp: int32): int32 =
    return powInt(base, exp)

fn Pow(base: int64, exp: int32): int64 =
    return powInt64(base, exp)

fn Pow(base: float64, exp: int32): float64 =
    return powFloat(base, exp)

fn Sqrt(value: float64): float64 =
    return sqrtFloat(value)

fn ISqrt(value: int32): int32 =
    return isqrt(value)

fn Floor(value: float64): float64 =
    return floorFloat(value)

fn Ceil(value: float64): float64 =
    return ceilFloat(value)

fn Round(value: float64): float64 =
    return roundFloat(value)

fn Sin(x: float64): float64 =
    return sinFloat(x)

fn Cos(x: float64): float64 =
    return cosFloat(x)

fn Gcd(a: int32, b: int32): int32 =
    return gcdInt(a, b)

fn Gcd(a: int64, b: int64): int64 =
    return gcdInt64(a, b)

fn Mod(a: int32, b: int32): int32 =
    return modInt(a, b)

fn Mod(a: int64, b: int64): int64 =
    return modInt64(a, b)

fn ApproxEq(a: float64, b: float64, epsilon: float64): bool =
    return approxEq(a, b, epsilon)

const
    Pi: float64 = 3.141592653589793
    E: float64 = 2.718281828459045
    Epsilon: float64 = 0.000001
