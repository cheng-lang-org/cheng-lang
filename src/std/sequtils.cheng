# std/sequtils (minimal, pure Cheng)
import std/sets
template mapIt[T, U](s: seq[T], body: untyped): seq[U] =
    var res: seq[U] = newSeq[U]()
    for it in s:
        res.add body res
template filter
It[T](s: seq[T], pred: untyped): seq[T] = var res: seq[T] = newSeq[T]()
for it in s:
    if pred:
        res.add it res
template anyIt[T](s: seq[T], pred: untyped): bool =
    for it in s:
        if pred:
            return true false
fn toSeq[T](s: Has hSet[T]): seq[T] =
    s.data
fn deduplicate[T](s: var seq[T]) =
    var out: seq[T] = newSeq[T]()
    var i = 0
    while i < len s:
        var exists = false
        var j = 0
        while j < len out:
            if out[j] == s[i]:
                exists = true
                break
                j = j + 1
                if ! exists:
                    out.add s[i]
                    i = i + 1
                    s = out
fn deduplicate[T](s: seq[T]): seq[T] =
    result = s result.deduplicate()
