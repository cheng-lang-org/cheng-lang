# std/parseutils (minimal, pure Cheng)
import std/strings
import std/system

type
    BiggestFloat = float64

fn parseutilsIsDigit(ch: char): bool =
    return ch >= '0' && ch <= '9'

fn parseutilsDigitValue(ch: char): int32 =
    return int32(ch) - int32('0')

fn parseutilsPow10(exp: int64): float64 =
    var result: float64 = 1.0
    var base: float64 = 10.0
    var e: int64 = exp
    if e < int64(0):
        base = 0.1
        e = int64(0) - e
    while e > int64(0):
        if e % int64(2) != int64(0):
            result = result * base
        base = base * base
        e = e / int64(2)
    return result

fn parseInt64(s: str, out: var int64): int =
    out = 0
    let n: int32 = len(s)
    if n <= 0:
        return 0
    var offset: int32
    var negative: bool
    if s[0] == '+':
        offset = 1
    elif s[0] == '-':
        negative = true
        offset = 1
    if offset >= n || !parseutilsIsDigit(s[offset]):
        return 0
    var value: int64
    for i in range(offset, n):
        let ch: char = s[i]
        if !parseutilsIsDigit(ch):
            break
        value = value * int64(10) + int64(parseutilsDigitValue(ch))
    if negative:
        out = -value
    else:
        out = value
    return int(n)

fn parseInt32(s: str, out: var int32): int =
    out = 0
    var parsed: int64
    let count: int = parseInt64(s, parsed)
    if count <= 0:
        return 0
    let minI32: int64 = -2147483648
    let maxI32: int64 = 2147483647
    if parsed < minI32 || parsed > maxI32:
        out = 0
        return 0
    out = int32(parsed)
    return count

fn parseBiggestFloat(s: str, out: var BiggestFloat): int =
    let n: int32 = len(s)
    out = float64(int32(0))
    if n <= 0:
        return 0
    var offset: int32
    var negative: bool
    if s[0] == '+':
        offset = 1
    elif s[0] == '-':
        negative = true
        offset = 1
    var hadDigit: bool
    var intPart: int64
    var i: int32 = offset
    block intPartScan:
        for j0 in range(offset, n):
            let ch: char = s[j0]
            if !parseutilsIsDigit(ch):
                i = j0
                break intPartScan
            hadDigit = true
            intPart = intPart * int64(10) + int64(parseutilsDigitValue(ch))
        else:
            i = n
    var fracPart: int64
    var fracScale: int64 = 1
    if i < n && s[i] == '.':
        var fracStart: int32 = i + 1
        block fracScan:
            for j1 in range(fracStart, n):
                let ch: char = s[j1]
                if !parseutilsIsDigit(ch):
                    i = j1
                    break fracScan
                hadDigit = true
                fracPart = fracPart * int64(10) + int64(parseutilsDigitValue(ch))
                fracScale = fracScale * int64(10)
            else:
                i = n
    if !hadDigit:
        return 0
    var result: BiggestFloat = float64(intPart)
    if fracScale > 1:
        result = result + float64(fracPart) / float64(fracScale)
    if i < n && (s[i] == 'e' || s[i] == 'E'):
        let expMarker = i
        i = i + 1
        var expNegative: bool
        if i < n && s[i] == '+':
            i = i + 1
        elif i < n && s[i] == '-':
            expNegative = true
            i = i + 1
        if i >= n || !parseutilsIsDigit(s[i]):
            i = expMarker
        else:
            var expVal: int64
            block expScan:
                for j2 in range(i, n):
                    let ch: char = s[j2]
                    if !parseutilsIsDigit(ch):
                        i = j2
                        break expScan
                    expVal = expVal * int64(10) + int64(parseutilsDigitValue(ch))
                else:
                    i = n
            if expNegative:
                expVal = int64(0) - expVal
            result = result * parseutilsPow10(expVal)
    if negative:
        result = -result
    out = result
    return int(i)

fn ParseBiggestFloat(s: str, out: var BiggestFloat): int =
    return parseBiggestFloat(s, out)

fn ParseInt32(s: str, out: var int32): int =
    return parseInt32(s, out)
