# std/parseutils (minimal, pure Cheng)
import std/strings

type
    BiggestFloat = float64

fn parseutilsIsDigit(ch: char): bool =
    return ch >= '0' && ch <= '9'

fn parseutilsDigitValue(ch: char): int32 =
    return int32(ch) - int32('0')

fn parseInt64(s: str, out: var int64): int =
    out = 0
    let n: int32 = len s
    if n <= 0:
        return 0
    var i: int32 = 0
    var negative: bool = false
    if s[0] == '+':
        i = 1
    elif s[0] == '-':
        negative = true
        i = 1
    if i >= n || !parseutilsIsDigit(s[i]):
        return 0
    var value: int64 = 0
    while i < n:
        let ch: char = s[i]
        if !parseutilsIsDigit(ch):
            break
        value = value * int64(10) + int64(parseutilsDigitValue(ch))
        i = i + 1
    if negative:
        out = -value
    else:
        out = value
    return int(i)

fn parseInt32(s: str, out: var int32): int =
    out = 0
    var parsed: int64 = 0
    let count: int = parseInt64(s, parsed)
    if count <= 0:
        return 0
    let minI32: int64 = -2147483648
    let maxI32: int64 = 2147483647
    if parsed < minI32 || parsed > maxI32:
        out = 0
        return 0
    out = int32(parsed)
    return count

fn parseBiggestFloat(s: str, out: var BiggestFloat): int =
    out = 0.0
    let n: int32 = len s
    if n <= 0:
        return 0
    var i: int32 = 0
    var sign: float64 = 1.0
    if s[0] == '+':
        i = 1
    elif s[0] == '-':
        sign = -1.0
        i = 1
    var intPart: float64 = 0.0
    var fracPart: float64 = 0.0
    var fracScale: float64 = 0.1
    var hadDigit: bool = false
    while i < n:
        let ch: char = s[i]
        if !parseutilsIsDigit(ch):
            break
        hadDigit = true
        intPart = intPart * 10.0 + float64(parseutilsDigitValue(ch))
        i = i + 1
    if i < n && s[i] == '.':
        i = i + 1
        while i < n:
            let ch: char = s[i]
            if !parseutilsIsDigit(ch):
                break
            hadDigit = true
            fracPart = fracPart + float64(parseutilsDigitValue(ch)) * fracScale
            fracScale = fracScale * 0.1
            i = i + 1
    if !hadDigit:
        out = 0.0
        return 0
    out = sign * (intPart + fracPart)
    return int(i)
