# Internal crash breadcrumb bridge for compiler/runtime bring-up.
import std/system

@importc("cheng_crash_trace_enabled")
fn crashTraceEnabledC(): int32

@importc("cheng_crash_trace_set_phase")
fn crashTraceSetPhaseC(phase: cstring)

@importc("cheng_crash_trace_mark")
fn crashTraceMarkC(tag: cstring, a: int32, b: int32, c: int32, d: int32)

var crashTraceReady: bool
var crashTraceOn: bool

fn crashTraceEnabled(): bool =
    if !crashTraceReady:
        crashTraceOn = crashTraceEnabledC() != 0
        crashTraceReady = true
    return crashTraceOn

fn crashTraceSetPhase(phase: cstring) =
    if crashTraceEnabled():
        crashTraceSetPhaseC(phase)

fn crashTraceMark(tag: cstring, a: int32, b: int32, c: int32, d: int32) =
    if crashTraceEnabled():
        crashTraceMarkC(tag, a, b, c, d)
