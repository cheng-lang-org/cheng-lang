# std/json (minimal, self-contained)
import std/system
import std/strings
import std/strutils
import std/rawmem_support
import std/parseutils

@importc("cheng_seq_set_grow")
fn json_cheng_seq_set_grow(seqPtr: ptr, idx: int32, elemSize: int32): ptr

type
    JsonNodeKind = enum
        JNull
        JBool
        JInt
        JFloat
        JString
        JArray
        JObject

type
    JsonNode =
        kind: JsonNodeKind
        b: bool
        i: int64
        f: float64
        s: str
        a: JsonNode[]
        okeys: str[]
        ovalues: JsonNode[]

    JsonPair =
        key: str
        value: JsonNode

    CompatJsonPair =
        key: str
        value: JsonNode

    JsonValue = JsonNode

    JsonParseResult =
        success: bool
        value: JsonNode
        message: str

    JsonParserState =
        content: str
        pos: int32
        len: int32
        error: bool
        errorMsg: str

fn newJsonNode(kind: JsonNodeKind): JsonNode =
    var node: JsonNode
    node.kind = kind
    return node

fn newJNull(): JsonNode =
    return newJsonNode(JNull)

fn newJBool(value: bool): JsonNode =
    var node: JsonNode = newJsonNode(JBool)
    node.b = value
    return node

fn newJInt(value: int64): JsonNode =
    var node: JsonNode = newJsonNode(JInt)
    node.i = value
    return node

fn newJFloat(value: float64): JsonNode =
    var node: JsonNode = newJsonNode(JFloat)
    node.f = value
    return node

fn newJString(value: str): JsonNode =
    var node: JsonNode = newJsonNode(JString)
    node.s = value
    return node

fn newJArray(): JsonNode =
    var node: JsonNode = newJsonNode(JArray)
    var items: JsonNode[]
    node.a = items
    return node

fn newJObject(): JsonNode =
    var node: JsonNode = newJsonNode(JObject)
    var keys: str[]
    var values: JsonNode[]
    node.okeys = keys
    node.ovalues = values
    return node

fn jsonNil(): JsonNode =
    return newJNull()

fn jsonBool(value: bool): JsonNode =
    return newJBool(value)

fn jsonNumber(value: float64): JsonNode =
    return newJFloat(value)

fn jsonString(value: str): JsonNode =
    return newJString(value)

fn jsonAppendNode(seqInst: var JsonNode[], value: JsonNode) =
    let writeAt: int32 = seqInst.len
    let slot: ptr = json_cheng_seq_set_grow(&seqInst, writeAt, elemSize[JsonNode]())
    if slot == nil:
        return
    store(slot, value)

fn jsonAppendStr(seqInst: var str[], value: str) =
    strutilsAppendStr(seqInst, value)

fn jsonAddNode(node: var JsonNode, item: JsonNode) =
    if node.kind != JArray:
        return
    jsonAppendNode(node.a, item)

fn add(node: var JsonNode, item: JsonNode) =
    jsonAddNode(node, item)

fn jsonArray(items: JsonNode[]): JsonNode =
    var node: JsonNode = newJArray()
    for i in 0..<items.len:
        let item: JsonNode = items[i]
        jsonAddNode(node, item)
    return node

fn jsonPair(key: str, value: JsonNode): JsonPair =
    var pair: JsonPair
    pair.key = key
    pair.value = value
    return pair

fn jsonCompatPair(key: str, value: JsonNode): CompatJsonPair =
    var pair: CompatJsonPair
    pair.key = key
    pair.value = value
    return pair

fn jsonObject(pairs: JsonPair[]): JsonNode =
    var node: JsonNode = newJObject()
    for i in 0..<pairs.len:
        let pair: JsonPair = pairs[i]
        jsonSetField(node, pair.key, pair.value)
    return node

fn len(node: JsonNode): int =
    if node.kind == JArray:
        return int(node.a.len)
    if node.kind == JObject:
        return int(node.okeys.len)
    return 0

fn hasKey(node: JsonNode, key: str): bool =
    if node.kind != JObject:
        return false
    for i in 0..<node.okeys.len:
        if node.okeys[i] == key:
            return true
    return false

fn jsonGetField(node: JsonNode, key: str): JsonNode =
    if node.kind != JObject:
        return jsonNil()
    for i in 0..<node.okeys.len:
        if node.okeys[i] == key:
            return node.ovalues[i]
    return jsonNil()

fn jsonSetField(node: var JsonNode, key: str, value: JsonNode) =
    if node.kind != JObject:
        return
    for i in 0..<node.okeys.len:
        if node.okeys[i] == key:
            node.ovalues[i] = value
            return
    jsonAppendStr(node.okeys, key)
    jsonAppendNode(node.ovalues, value)

fn jsonObjectFieldSlot(node: var JsonNode, key: str): int32 =
    if node.kind != JObject:
        return -1
    for i in 0..<node.okeys.len:
        if node.okeys[i] == key:
            return i
    let idx: int32 = node.okeys.len
    jsonAppendStr(node.okeys, key)
    jsonAppendNode(node.ovalues, newJNull())
    return idx

fn `[]`(node: JsonNode, key: str): JsonNode =
    return jsonGetField(node, key)

fn `[]=`(node: var JsonNode, key: str, value: JsonNode) =
    jsonSetField(node, key, value)

fn `[]=`(node: var JsonNode, key: str, value: str) =
    var boxed: JsonNode = newJString(value)
    jsonSetField(node, key, boxed)

fn `[]=`(node: var JsonNode, key: str, value: bool) =
    var boxed: JsonNode = newJBool(value)
    jsonSetField(node, key, boxed)

fn `[]=`(node: var JsonNode, key: str, value: int) =
    var boxed: JsonNode = newJInt(int64(value))
    jsonSetField(node, key, boxed)

fn `[]=`(node: var JsonNode, key: str, value: int32) =
    var boxed: JsonNode = newJInt(int64(value))
    jsonSetField(node, key, boxed)

fn `[]=`(node: var JsonNode, key: str, value: int64) =
    var boxed: JsonNode = newJInt(value)
    jsonSetField(node, key, boxed)

fn `[]=`(node: var JsonNode, key: str, value: float64) =
    var boxed: JsonNode = newJFloat(value)
    jsonSetField(node, key, boxed)

fn getInt(node: JsonNode): int64 =
    if node.kind == JInt:
        return node.i
    return 0

fn getInt64(node: JsonNode): int64 =
    return getInt(node)

fn getInt64(node: JsonNode, fallback: int64): int64 =
    if node.kind == JInt:
        return node.i
    if node.kind == JFloat:
        return int64(node.f)
    return fallback

fn getBool(node: JsonNode): bool =
    if node.kind == JBool:
        return node.b
    return false

fn getBool(node: JsonNode, fallback: bool): bool =
    if node.kind == JBool:
        return node.b
    return fallback

fn getFloat(node: JsonNode): float64 =
    if node.kind == JFloat:
        return node.f
    if node.kind == JInt:
        return float64(node.i)
    return 0.0

fn getStr(node: JsonNode): str =
    if node.kind == JString:
        return node.s
    return ""

fn getStr(node: JsonNode, fallback: str): str =
    if node.kind == JString:
        return node.s
    return fallback

fn jsonTryGetStr(node: JsonNode, key: str, out: var str): bool =
    if node.kind != JObject:
        return false
    for i in 0..<node.okeys.len:
        if node.okeys[i] != key:
            continue
        if node.ovalues[i].kind != JString:
            return false
        out = node.ovalues[i].s
        return true
    return false

fn jsonTryGetBool(node: JsonNode, key: str, out: var bool): bool =
    if node.kind != JObject:
        return false
    for i in 0..<node.okeys.len:
        if node.okeys[i] != key:
            continue
        if node.ovalues[i].kind != JBool:
            return false
        out = node.ovalues[i].b
        return true
    return false

fn jsonTryGetInt64(node: JsonNode, key: str, out: var int64): bool =
    if node.kind != JObject:
        return false
    for i in 0..<node.okeys.len:
        if node.okeys[i] != key:
            continue
        if node.ovalues[i].kind == JInt:
            out = node.ovalues[i].i
            return true
        if node.ovalues[i].kind == JFloat:
            out = int64(node.ovalues[i].f)
            return true
        return false
    return false

fn jsonNodeTryGetStr(node: JsonNode, out: var str): bool =
    if node.kind != JString:
        return false
    out = node.s
    return true

fn jsonNodeTryGetBool(node: JsonNode, out: var bool): bool =
    if node.kind != JBool:
        return false
    out = node.b
    return true

fn jsonNodeTryGetInt64(node: JsonNode, out: var int64): bool =
    if node.kind == JInt:
        out = node.i
        return true
    if node.kind == JFloat:
        out = int64(node.f)
        return true
    return false

fn getStrArray(node: JsonNode): str[] =
    var out: str[]
    if node.kind != JArray:
        return out
    for i in 0..<node.a.len:
        var value: str
        if node.a[i].kind == JString:
            value = node.a[i].s
        if len(value) > 0:
            seqs.Add(out, value)
    return out

fn getStrArray(node: JsonNode, key: str): str[] =
    return getStrArray(node[key])

fn `%`(node: JsonNode): JsonNode =
    return node

fn `%`(value: str): JsonNode =
    return newJString(value)

fn `%`(value: bool): JsonNode =
    return newJBool(value)

fn `%`(value: int): JsonNode =
    return newJInt(int64(value))

fn `%`(value: int32): JsonNode =
    return newJInt(int64(value))

fn `%`(value: int64): JsonNode =
    return newJInt(value)

fn `%`(value: float64): JsonNode =
    return newJFloat(value)

fn toJsonNode(node: JsonNode): JsonNode =
    return node

fn toJsonValue(node: JsonNode): JsonNode =
    return node

fn toJsonValue(value: str): JsonNode =
    return newJString(value)

fn toJsonValue(value: bool): JsonNode =
    return newJBool(value)

fn toJsonValue(value: int): JsonNode =
    return newJInt(int64(value))

fn toJsonValue(value: int32): JsonNode =
    return newJInt(int64(value))

fn toJsonValue(value: int64): JsonNode =
    return newJInt(value)

fn toJsonValue(value: float64): JsonNode =
    return newJFloat(value)

fn toJsonValue(value: T[]): JsonNode =
    var node: JsonNode = newJArray()
    for item in value:
        let boxed: JsonNode = toJsonValue(item)
        jsonAddNode(node, boxed)
    return node

fn jsonValue(node: JsonNode): JsonNode =
    return node

fn jsonValue(value: str): JsonNode =
    return toJsonValue(value)

fn jsonValue(value: bool): JsonNode =
    return toJsonValue(value)

fn jsonValue(value: int): JsonNode =
    return toJsonValue(value)

fn jsonValue(value: int32): JsonNode =
    return toJsonValue(value)

fn jsonValue(value: int64): JsonNode =
    return toJsonValue(value)

fn jsonValue(value: float64): JsonNode =
    return toJsonValue(value)

fn jsonValue(value: T[]): JsonNode =
    return toJsonValue(value)

fn jsonHexNibble(value: int32): char =
    if value < 10:
        return char(int32('0') + value)
    return char(int32('a') + (value - 10))

// NOTE: jsonEscapedCharLen and jsonEscapedLen compute the length of an escaped
// string in a first pass, then jsonWriteEscapedContent writes the escaped
// content in a second pass. This is O(2N). If performance on large strings
// becomes an issue, an alternative would be to write directly into a growable
// buffer in a single pass (avoiding the pre-measurement). The two-pass design
// is kept here because it integrates cleanly with the pre-allocation pattern
// used by stringify() and avoids dynamic reallocation overhead.
fn jsonEscapedCharLen(ch: char): int32 =
    let chCode: int32 = int32(ch)
    if chCode == 92:
        return 2
    if chCode == 34:
        return 2
    if chCode == 10:
        return 2
    if chCode == 13:
        return 2
    if chCode == 9:
        return 2
    if chCode >= 0 && chCode < 32:
        return 6
    return 1

fn jsonEscapedLen(value: str): int32 =
    var total: int32
    let n: int32 = strings.Len(value)
    for i in 0..<n:
        total = total + jsonEscapedCharLen(value[i])
    return total

fn jsonQuotedLen(value: str): int32 =
    return jsonEscapedLen(value) + 2

// Depth-limited recursive length computation. When depth exceeds 256, returns
// 5 (the length of "\"...\"" in the truncated output) to prevent stack overflow.
fn jsonStringifiedLenDepth(node: JsonNode, depth: int32): int32 =
    if depth > 256:
        return 5
    if node.kind == JNull:
        return 4
    if node.kind == JBool:
        return node.b ? 4 : 5
    if node.kind == JInt:
        return strings.Len(int64ToStr(node.i))
    if node.kind == JFloat:
        return strings.Len(strutils.FormatFloat(node.f))
    if node.kind == JString:
        return jsonQuotedLen(node.s)
    if node.kind == JArray:
        var total: int32 = 2
        for i in 0..<node.a.len:
            if i > 0:
                total = total + 1
            total = total + jsonStringifiedLenDepth(node.a[i], depth + 1)
        return total
    if node.kind == JObject:
        var total: int32 = 2
        for i in 0..<node.okeys.len:
            if i > 0:
                total = total + 1
            total = total + jsonQuotedLen(node.okeys[i]) + 1 + jsonStringifiedLenDepth(node.ovalues[i], depth + 1)
        return total
    return 4

fn jsonStringifiedLen(node: JsonNode): int32 =
    return jsonStringifiedLenDepth(node, 0)

// Compute pretty-printed length with indentation.
fn jsonPrettyStringifiedLenDepth(node: JsonNode, indentCount: int32, depth: int32): int32 =
    if depth > 256:
        return 5
    if node.kind == JNull:
        return 4
    if node.kind == JBool:
        return node.b ? 4 : 5
    if node.kind == JInt:
        return strings.Len(int64ToStr(node.i))
    if node.kind == JFloat:
        return strings.Len(strutils.FormatFloat(node.f))
    if node.kind == JString:
        return jsonQuotedLen(node.s)
    if node.kind == JArray:
        if node.a.len == 0:
            return 2
        var total: int32 = 2
        // [ + newline
        total = total + 1
        for i in 0..<node.a.len:
            if i > 0:
                // , + newline
                total = total + 2
            // indent for this element
            total = total + indentCount * (depth + 1)
            total = total + jsonPrettyStringifiedLenDepth(node.a[i], indentCount, depth + 1)
        // newline + indent + ]
        total = total + 1 + indentCount * depth
        return total
    if node.kind == JObject:
        if node.okeys.len == 0:
            return 2
        var total: int32 = 2
        // { + newline
        total = total + 1
        for i in 0..<node.okeys.len:
            if i > 0:
                // , + newline
                total = total + 2
            // indent for this entry
            total = total + indentCount * (depth + 1)
            total = total + jsonQuotedLen(node.okeys[i]) + 2  // ": "
            total = total + jsonPrettyStringifiedLenDepth(node.ovalues[i], indentCount, depth + 1)
        // newline + indent + }
        total = total + 1 + indentCount * depth
        return total
    return 4

fn jsonWriteByte(out: str, pos: var int32, value: int32) =
    rawmem_support.RawmemWriteI8(strDataPtr(out), pos, int8(value))
    pos = pos + 1

fn jsonWriteSlice(out: str, pos: var int32, value: str, start: int32, count: int32) =
    if count <= 0:
        return
    let dst: ptr = rawmem_support.RawmemPtrAdd(strDataPtr(out), pos)
    let src: ptr = rawmem_support.RawmemPtrAdd(strDataPtr(value), start)
    rawmem_support.RawmemCopy(dst, src, count)
    pos = pos + count

fn jsonWriteLiteral(out: str, pos: var int32, value: str) =
    jsonWriteSlice(out, pos, value, 0, strings.Len(value))

fn jsonWriteUnicodeEscape(out: str, pos: var int32, chCode: int32) =
    jsonWriteByte(out, pos, 92)
    jsonWriteByte(out, pos, 117)
    jsonWriteByte(out, pos, 48)
    jsonWriteByte(out, pos, 48)
    jsonWriteByte(out, pos, int32(jsonHexNibble((chCode >> 4) & 15)))
    jsonWriteByte(out, pos, int32(jsonHexNibble(chCode & 15)))

fn jsonWriteEscapedContent(out: str, pos: var int32, value: str) =
    let n: int32 = strings.Len(value)
    var runStart: int32
    for i in range(n):
        let ch: char = value[i]
        let chCode: int32 = int32(ch)
        var escaped: bool
        if chCode == 92 || chCode == 34 || chCode == 10 || chCode == 13 || chCode == 9 || (chCode >= 0 && chCode < 32):
            escaped = true
        if escaped:
            jsonWriteSlice(out, pos, value, runStart, i - runStart)
            if chCode == 92:
                jsonWriteLiteral(out, pos, "\\\\")
            elif chCode == 34:
                jsonWriteLiteral(out, pos, "\\\"")
            elif chCode == 10:
                jsonWriteLiteral(out, pos, "\\n")
            elif chCode == 13:
                jsonWriteLiteral(out, pos, "\\r")
            elif chCode == 9:
                jsonWriteLiteral(out, pos, "\\t")
            else:
                jsonWriteUnicodeEscape(out, pos, chCode)
            runStart = i + 1
    jsonWriteSlice(out, pos, value, runStart, n - runStart)

fn jsonWriteQuoted(out: str, pos: var int32, value: str) =
    jsonWriteByte(out, pos, 34)
    jsonWriteEscapedContent(out, pos, value)
    jsonWriteByte(out, pos, 34)

// Write indentation spaces: indentCount * depth spaces.
fn jsonWriteIndent(out: str, pos: var int32, indentCount: int32, depth: int32) =
    let total: int32 = indentCount * depth
    for i in range(total):
        jsonWriteByte(out, pos, 32)

// Depth-limited recursive JSON writer. When depth exceeds 256, writes "..."
// as a truncation marker and returns to prevent stack overflow.
fn jsonWriteNodeDepth(out: str, pos: var int32, node: JsonNode, depth: int32) =
    if depth > 256:
        jsonWriteLiteral(out, pos, "\"...\"")
        return
    if node.kind == JNull:
        jsonWriteLiteral(out, pos, "null")
        return
    if node.kind == JBool:
        if node.b:
            jsonWriteLiteral(out, pos, "true")
        else:
            jsonWriteLiteral(out, pos, "false")
        return
    if node.kind == JInt:
        jsonWriteLiteral(out, pos, int64ToStr(node.i))
        return
    if node.kind == JFloat:
        jsonWriteLiteral(out, pos, strutils.FormatFloat(node.f))
        return
    if node.kind == JString:
        jsonWriteQuoted(out, pos, node.s)
        return
    if node.kind == JArray:
        jsonWriteByte(out, pos, 91)
        for i in 0..<node.a.len:
            if i > 0:
                jsonWriteByte(out, pos, 44)
            jsonWriteNodeDepth(out, pos, node.a[i], depth + 1)
        jsonWriteByte(out, pos, 93)
        return
    if node.kind == JObject:
        jsonWriteByte(out, pos, 123)
        for i in 0..<node.okeys.len:
            if i > 0:
                jsonWriteByte(out, pos, 44)
            jsonWriteQuoted(out, pos, node.okeys[i])
            jsonWriteByte(out, pos, 58)
            jsonWriteNodeDepth(out, pos, node.ovalues[i], depth + 1)
        jsonWriteByte(out, pos, 125)
        return
    jsonWriteLiteral(out, pos, "null")

fn jsonWriteNode(out: str, pos: var int32, node: JsonNode) =
    jsonWriteNodeDepth(out, pos, node, 0)

fn stringify(node: JsonNode): str =
    let total: int32 = jsonStringifiedLen(node)
    let out: str = newStringAlloc(total)
    var pos: int32
    jsonWriteNode(out, pos, node)
    assert(pos == total, "std/json stringify length mismatch")
    return out

fn escapeJsonString(value: str): str =
    let total: int32 = jsonEscapedLen(value)
    if total <= 0:
        return ""
    let out: str = newStringAlloc(total)
    var pos: int32
    jsonWriteEscapedContent(out, pos, value)
    assert(pos == total, "std/json escape length mismatch")
    return out

// Pretty-print a JSON node with indentation.
fn jsonWriteNodePrettyDepth(out: str, pos: var int32, node: JsonNode, indentCount: int32, depth: int32) =
    if depth > 256:
        jsonWriteLiteral(out, pos, "\"...\"")
        return
    if node.kind == JNull:
        jsonWriteLiteral(out, pos, "null")
        return
    if node.kind == JBool:
        if node.b:
            jsonWriteLiteral(out, pos, "true")
        else:
            jsonWriteLiteral(out, pos, "false")
        return
    if node.kind == JInt:
        jsonWriteLiteral(out, pos, int64ToStr(node.i))
        return
    if node.kind == JFloat:
        jsonWriteLiteral(out, pos, strutils.FormatFloat(node.f))
        return
    if node.kind == JString:
        jsonWriteQuoted(out, pos, node.s)
        return
    if node.kind == JArray:
        if node.a.len == 0:
            jsonWriteLiteral(out, pos, "[]")
            return
        jsonWriteByte(out, pos, 91)
        jsonWriteByte(out, pos, 10)
        for i in 0..<node.a.len:
            if i > 0:
                jsonWriteByte(out, pos, 44)
                jsonWriteByte(out, pos, 10)
            jsonWriteIndent(out, pos, indentCount, depth + 1)
            jsonWriteNodePrettyDepth(out, pos, node.a[i], indentCount, depth + 1)
        jsonWriteByte(out, pos, 10)
        jsonWriteIndent(out, pos, indentCount, depth)
        jsonWriteByte(out, pos, 93)
        return
    if node.kind == JObject:
        if node.okeys.len == 0:
            jsonWriteLiteral(out, pos, "{}")
            return
        jsonWriteByte(out, pos, 123)
        jsonWriteByte(out, pos, 10)
        for i in 0..<node.okeys.len:
            if i > 0:
                jsonWriteByte(out, pos, 44)
                jsonWriteByte(out, pos, 10)
            jsonWriteIndent(out, pos, indentCount, depth + 1)
            jsonWriteQuoted(out, pos, node.okeys[i])
            jsonWriteLiteral(out, pos, ": ")
            jsonWriteNodePrettyDepth(out, pos, node.ovalues[i], indentCount, depth + 1)
        jsonWriteByte(out, pos, 10)
        jsonWriteIndent(out, pos, indentCount, depth)
        jsonWriteByte(out, pos, 125)
        return
    jsonWriteLiteral(out, pos, "null")

fn pretty(node: JsonNode, indent: int): str =
    let total: int32 = jsonPrettyStringifiedLenDepth(node, int32(indent), 0)
    let out: str = newStringAlloc(total)
    var pos: int32
    jsonWriteNodePrettyDepth(out, pos, node, int32(indent), 0)
    assert(pos == total, "std/json pretty length mismatch")
    return out

fn toPretty(node: JsonNode, indent: int): str =
    return pretty(node, indent)

fn toJsonString(node: JsonNode): str =
    return stringify(node)

fn `$`(node: JsonNode): str =
    return stringify(node)

// ---------------------------------------------------------------------------
// JSON Parser
// ---------------------------------------------------------------------------

fn jsonParserSkipWhitespace(state: var JsonParserState) =
    while state.pos < state.len:
        let ch: char = state.content[state.pos]
        if ch == char(32) || ch == char(10) || ch == char(13) || ch == char(9):
            state.pos = state.pos + 1
        else:
            break

fn jsonParserPeek(state: var JsonParserState): char =
    if state.pos < state.len:
        return state.content[state.pos]
    return char(0)

fn jsonParserNext(state: var JsonParserState): char =
    let ch: char = jsonParserPeek(state)
    state.pos = state.pos + 1
    return ch

fn jsonParserSetError(state: var JsonParserState, msg: str) =
    state.error = true
    state.errorMsg = msg

// Read a string (unescaped) from the parser state. Assumes state.pos is at
// the opening double-quote. Returns the unescaped string, or sets error.
fn jsonParseRawString(state: var JsonParserState): str =
    if jsonParserPeek(state) != char(34):
        jsonParserSetError(state, "expected opening quote for string")
        return ""
    state.pos = state.pos + 1  // skip opening "
    // First pass: compute unescaped length and find closing quote.
    var unescapedLen: int32
    var scanPos: int32 = state.pos
    var foundClose: bool
    while scanPos < state.len:
        let ch: char = state.content[scanPos]
        if ch == char(34):
            foundClose = true
            break
        if ch == char(92):
            scanPos = scanPos + 1
            if scanPos >= state.len:
                jsonParserSetError(state, "unexpected end of input in string escape")
                return ""
            let esc: char = state.content[scanPos]
            if esc == char(117):
                scanPos = scanPos + 4  // skip 4 hex digits
        unescapedLen = unescapedLen + 1
        scanPos = scanPos + 1
    if !foundClose:
        jsonParserSetError(state, "unterminated string")
        return ""
    // Second pass: build unescaped string.
    let out: str = newStringAlloc(unescapedLen)
    var outPos: int32
    while state.pos < scanPos:
        let ch: char = state.content[state.pos]
        if ch == char(92):
            state.pos = state.pos + 1
            let esc: char = state.content[state.pos]
            if esc == char(34):
                jsonWriteByte(out, outPos, 34)
            elif esc == char(92):
                jsonWriteByte(out, outPos, 92)
            elif esc == char(47):
                jsonWriteByte(out, outPos, 47)
            elif esc == char(98):
                jsonWriteByte(out, outPos, 8)
            elif esc == char(102):
                jsonWriteByte(out, outPos, 12)
            elif esc == char(110):
                jsonWriteByte(out, outPos, 10)
            elif esc == char(114):
                jsonWriteByte(out, outPos, 13)
            elif esc == char(116):
                jsonWriteByte(out, outPos, 9)
            elif esc == char(117):
                state.pos = state.pos + 1
                var hexVal: int32
                for k in 0..<4:
                    let hexCh: char = state.content[state.pos]
                    state.pos = state.pos + 1
                    var digitVal: int32
                    if hexCh >= char(48) && hexCh <= char(57):
                        digitVal = int32(hexCh) - 48
                    elif hexCh >= char(65) && hexCh <= char(70):
                        digitVal = int32(hexCh) - 55
                    elif hexCh >= char(97) && hexCh <= char(102):
                        digitVal = int32(hexCh) - 87
                    else:
                        jsonParserSetError(state, "invalid hex digit in unicode escape")
                        return ""
                    hexVal = (hexVal << 4) | digitVal
                state.pos = state.pos - 1  // loop will increment past the last hex digit
                if hexVal <= 127:
                    jsonWriteByte(out, outPos, hexVal)
                else:
                    // Non-ASCII: store raw; caller can handle or ignore.
                    // For a minimal parser, encode as UTF-8-like single byte
                    // or just store the low byte for simplicity.
                    jsonWriteByte(out, outPos, hexVal & 255)
            else:
                jsonParserSetError(state, "invalid escape sequence")
                return ""
        else:
            jsonWriteByte(out, outPos, int32(ch))
        state.pos = state.pos + 1
    state.pos = scanPos + 1  // skip closing "
    return out

fn jsonParseValue(state: var JsonParserState): JsonNode

fn jsonParseArray(state: var JsonParserState): JsonNode =
    // state.pos is at opening '['
    state.pos = state.pos + 1
    var node: JsonNode = newJArray()
    jsonParserSkipWhitespace(state)
    if jsonParserPeek(state) != char(93):
        while true:
            let item: JsonNode = jsonParseValue(state)
            if state.error:
                return jsonNil()
            jsonAddNode(node, item)
            jsonParserSkipWhitespace(state)
            if jsonParserPeek(state) == char(93):
                break
            if jsonParserPeek(state) != char(44):
                jsonParserSetError(state, "expected , or ] in array")
                return jsonNil()
            state.pos = state.pos + 1  // skip ,
            jsonParserSkipWhitespace(state)
    state.pos = state.pos + 1  // skip ]
    return node

fn jsonParseObject(state: var JsonParserState): JsonNode =
    // state.pos is at opening '{'
    state.pos = state.pos + 1
    var node: JsonNode = newJObject()
    jsonParserSkipWhitespace(state)
    if jsonParserPeek(state) != char(125):
        while true:
            jsonParserSkipWhitespace(state)
            let key: str = jsonParseRawString(state)
            if state.error:
                return jsonNil()
            jsonParserSkipWhitespace(state)
            if jsonParserPeek(state) != char(58):
                jsonParserSetError(state, "expected : in object")
                return jsonNil()
            state.pos = state.pos + 1  // skip :
            jsonParserSkipWhitespace(state)
            let value: JsonNode = jsonParseValue(state)
            if state.error:
                return jsonNil()
            jsonSetField(node, key, value)
            jsonParserSkipWhitespace(state)
            if jsonParserPeek(state) == char(125):
                break
            if jsonParserPeek(state) != char(44):
                jsonParserSetError(state, "expected , or } in object")
                return jsonNil()
            state.pos = state.pos + 1  // skip ,
    state.pos = state.pos + 1  // skip }
    return node

fn jsonParseValue(state: var JsonParserState): JsonNode =
    jsonParserSkipWhitespace(state)
    let ch: char = jsonParserPeek(state)
    if ch == char(0):
        jsonParserSetError(state, "unexpected end of input")
        return jsonNil()
    // String
    if ch == char(34):
        let value: str = jsonParseRawString(state)
        if state.error:
            return jsonNil()
        return newJString(value)
    // Number: leading digit or minus
    if (ch >= char(48) && ch <= char(57)) || ch == char(45):
        var start: int32 = state.pos
        if ch == char(45):
            state.pos = state.pos + 1
        // Integer part (digits)
        var hasDigits: bool
        while state.pos < state.len:
            let d: char = state.content[state.pos]
            if d >= char(48) && d <= char(57):
                hasDigits = true
                state.pos = state.pos + 1
            else:
                break
        if !hasDigits:
            jsonParserSetError(state, "expected digits in number")
            return jsonNil()
        var isFloat: bool
        // Fractional part
        if state.pos < state.len && state.content[state.pos] == char(46):
            isFloat = true
            state.pos = state.pos + 1
            var hasFrac: bool
            while state.pos < state.len:
                let d: char = state.content[state.pos]
                if d >= char(48) && d <= char(57):
                    hasFrac = true
                    state.pos = state.pos + 1
                else:
                    break
            if !hasFrac:
                jsonParserSetError(state, "expected digits after decimal point")
                return jsonNil()
        // Exponent part
        if state.pos < state.len && (state.content[state.pos] == char(101) || state.content[state.pos] == char(69)):
            isFloat = true
            state.pos = state.pos + 1
            if state.pos < state.len && (state.content[state.pos] == char(43) || state.content[state.pos] == char(45)):
                state.pos = state.pos + 1
            var hasExp: bool
            while state.pos < state.len:
                let d: char = state.content[state.pos]
                if d >= char(48) && d <= char(57):
                    hasExp = true
                    state.pos = state.pos + 1
                else:
                    break
            if !hasExp:
                jsonParserSetError(state, "expected digits in exponent")
                return jsonNil()
        // Extract the number substring and parse.
        let numStr: str = jsonSubstring(state.content, start, state.pos)
        if isFloat:
            let f: float64 = jsonParseFloat(numStr)
            return newJFloat(f)
        else:
            let i: int64 = jsonParseInt(numStr)
            return newJInt(i)
    // true
    if ch == char(116):
        if state.pos + 4 <= state.len:
            let sub: str = jsonSubstring(state.content, state.pos, state.pos + 4)
            if sub == "true":
                state.pos = state.pos + 4
                return newJBool(true)
        jsonParserSetError(state, "expected true")
        return jsonNil()
    // false
    if ch == char(102):
        if state.pos + 5 <= state.len:
            let sub: str = jsonSubstring(state.content, state.pos, state.pos + 5)
            if sub == "false":
                state.pos = state.pos + 5
                return newJBool(false)
        jsonParserSetError(state, "expected false")
        return jsonNil()
    // null
    if ch == char(110):
        if state.pos + 4 <= state.len:
            let sub: str = jsonSubstring(state.content, state.pos, state.pos + 4)
            if sub == "null":
                state.pos = state.pos + 4
                return newJNull()
        jsonParserSetError(state, "expected null")
        return jsonNil()
    // Array
    if ch == char(91):
        return jsonParseArray(state)
    // Object
    if ch == char(123):
        return jsonParseObject(state)
    jsonParserSetError(state, "unexpected character")
    return jsonNil()

// Create a substring from content[start..end) (end exclusive).
fn jsonSubstring(content: str, start: int32, end: int32): str =
    let count: int32 = end - start
    if count <= 0:
        return ""
    let out: str = newStringAlloc(count)
    var outPos: int32
    jsonWriteSlice(out, outPos, content, start, count)
    return out

// Parse an integer from a decimal string (no validation; assumes valid input).
fn jsonParseInt(value: str): int64 =
    var result: int64
    var neg: bool
    let n: int32 = strings.Len(value)
    if n > 0 && value[0] == char(45):
        neg = true
        for i in range(1, n):
            result = result * 10 + int64(int32(value[i]) - 48)
    else:
        for i in range(n):
            result = result * 10 + int64(int32(value[i]) - 48)
    if neg:
        return -result
    return result

fn jsonParseFloat(value: str): float64 =
    var out: parseutils.BiggestFloat
    let parsed = parseutils.ParseBiggestFloat(value, out)
    if parsed <= 0:
        return 0.0
    return out

fn parseJson(content: str): JsonNode =
    var state: JsonParserState
    state.content = content
    state.pos = 0
    state.len = strings.Len(content)
    state.error = false
    state.errorMsg = ""
    let result: JsonNode = jsonParseValue(state)
    if state.error:
        return jsonNil()
    jsonParserSkipWhitespace(state)
    if state.pos != state.len:
        // Trailing content after the top-level value.
        return jsonNil()
    return result

fn parseJsonNode(content: str): JsonNode =
    return parseJson(content)

fn parseJsonSafe(content: str): JsonParseResult =
    var state: JsonParserState
    state.content = content
    state.pos = 0
    state.len = strings.Len(content)
    state.error = false
    state.errorMsg = ""
    let result: JsonNode = jsonParseValue(state)
    var out: JsonParseResult
    if state.error:
        out.success = false
        out.value = jsonNil()
        out.message = state.errorMsg
        return out
    jsonParserSkipWhitespace(state)
    if state.pos != state.len:
        out.success = false
        out.value = jsonNil()
        out.message = "trailing content after json value"
        return out
    out.success = true
    out.value = result
    out.message = ""
    return out

fn jsonField(key: str, value: JsonNode): CompatJsonPair =
    return jsonCompatPair(key, value)

fn jsonField(key: str, value: str): CompatJsonPair =
    return jsonCompatPair(key, newJString(value))

fn jsonField(key: str, value: bool): CompatJsonPair =
    return jsonCompatPair(key, newJBool(value))

fn jsonField(key: str, value: int): CompatJsonPair =
    return jsonCompatPair(key, newJInt(int64(value)))

fn jsonField(key: str, value: int32): CompatJsonPair =
    return jsonCompatPair(key, newJInt(int64(value)))

fn jsonField(key: str, value: int64): CompatJsonPair =
    return jsonCompatPair(key, newJInt(value))

fn jsonField(key: str, value: float64): CompatJsonPair =
    return jsonCompatPair(key, newJFloat(value))

fn jsonField(key: str, value: T[]): CompatJsonPair =
    return jsonCompatPair(key, toJsonValue(value))

fn jsonObjectLit(fields: CompatJsonPair[]): JsonNode =
    var node: JsonNode = newJObject()
    for i in 0..<fields.len:
        let field: CompatJsonPair = fields[i]
        jsonSetField(node, field.key, field.value)
    return node

fn jsonArrayLit(items: JsonNode[]): JsonNode =
    return jsonArray(items)

fn GetBool(node: JsonNode): bool =
    return getBool(node)

fn GetBool(node: JsonNode, fallback: bool): bool =
    if node.kind == JBool:
        return node.b
    return fallback

fn GetInt(node: JsonNode): int64 =
    return getInt(node)

fn GetInt64(node: JsonNode): int64 =
    return getInt64(node)

fn GetInt64(node: JsonNode, fallback: int64): int64 =
    return getInt64(node, fallback)

fn GetStr(node: JsonNode): str =
    return getStr(node)

fn GetStr(node: JsonNode, fallback: str): str =
    if node.kind == JString:
        return node.s
    return fallback

fn HasKey(node: JsonNode, key: str): bool =
    return hasKey(node, key)

fn JsonGetField(node: JsonNode, key: str): JsonNode =
    return jsonGetField(node, key)

fn JsonSetField(node: var JsonNode, key: str, value: JsonNode) =
    jsonSetField(node, key, value)

fn JsonSetFieldStr(node: var JsonNode, key: str, value: str) =
    var boxed: JsonNode = newJString(value)
    jsonSetField(node, key, boxed)

fn JsonSetFieldBool(node: var JsonNode, key: str, value: bool) =
    var boxed: JsonNode = newJBool(value)
    jsonSetField(node, key, boxed)

fn JsonSetFieldInt(node: var JsonNode, key: str, value: int) =
    var boxed: JsonNode = newJInt(int64(value))
    jsonSetField(node, key, boxed)

fn JsonSetFieldInt32(node: var JsonNode, key: str, value: int32) =
    var boxed: JsonNode = newJInt(int64(value))
    jsonSetField(node, key, boxed)

fn JsonSetFieldInt64(node: var JsonNode, key: str, value: int64) =
    var boxed: JsonNode = newJInt(value)
    jsonSetField(node, key, boxed)

fn JsonSetFieldFloat64(node: var JsonNode, key: str, value: float64) =
    var boxed: JsonNode = newJFloat(value)
    jsonSetField(node, key, boxed)

fn NewJNull(): JsonNode =
    return newJNull()

fn NewJBool(value: bool): JsonNode =
    return newJBool(value)

fn NewJInt(value: int64): JsonNode =
    return newJInt(value)

fn NewJFloat(value: float64): JsonNode =
    return newJFloat(value)

fn NewJArray(): JsonNode =
    return newJArray()

fn NewJObject(): JsonNode =
    return newJObject()

fn NewJString(value: str): JsonNode =
    return newJString(value)

fn JsonAdd(node: var JsonNode, item: JsonNode) =
    jsonAddNode(node, item)

fn JsonAddStr(node: var JsonNode, value: str) =
    var item: JsonNode = newJString(value)
    jsonAddNode(node, item)

fn JsonAddBool(node: var JsonNode, value: bool) =
    var item: JsonNode = newJBool(value)
    jsonAddNode(node, item)

fn JsonAddInt(node: var JsonNode, value: int) =
    var item: JsonNode = newJInt(int64(value))
    jsonAddNode(node, item)

fn JsonAddInt32(node: var JsonNode, value: int32) =
    var item: JsonNode = newJInt(int64(value))
    jsonAddNode(node, item)

fn JsonAddInt64(node: var JsonNode, value: int64) =
    var item: JsonNode = newJInt(value)
    jsonAddNode(node, item)

fn JsonAddFloat64(node: var JsonNode, value: float64) =
    var item: JsonNode = newJFloat(value)
    jsonAddNode(node, item)

fn ParseJsonSafe(content: str): JsonParseResult =
    return parseJsonSafe(content)

fn JsonTryGetStr(node: JsonNode, key: str, out: var str): bool =
    return jsonTryGetStr(node, key, out)

fn JsonTryGetBool(node: JsonNode, key: str, out: var bool): bool =
    return jsonTryGetBool(node, key, out)

fn JsonTryGetInt64(node: JsonNode, key: str, out: var int64): bool =
    return jsonTryGetInt64(node, key, out)

fn JsonNodeTryGetStr(node: JsonNode, out: var str): bool =
    return jsonNodeTryGetStr(node, out)

fn JsonNodeTryGetBool(node: JsonNode, out: var bool): bool =
    return jsonNodeTryGetBool(node, out)

fn JsonNodeTryGetInt64(node: JsonNode, out: var int64): bool =
    return jsonNodeTryGetInt64(node, out)

fn Pretty(node: JsonNode, indent: int): str =
    return pretty(node, indent)

fn ToPretty(node: JsonNode, indent: int): str =
    return toPretty(node, indent)

fn Stringify(node: JsonNode): str =
    return stringify(node)

fn JsonStringify(node: JsonNode): str =
    return stringify(node)

fn ToJsonString(node: JsonNode): str =
    return toJsonString(node)
