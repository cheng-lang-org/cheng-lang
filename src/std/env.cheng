# std/env - Environment variables
import std/system
import std/strings
import std/result
import std/seqs
import std/rawmem_support

@importc("cheng_host_getenv")
fn host_getenv(name: cstring): cstring
@importc("cheng_host_setenv")
fn host_setenv(name: cstring, value: cstring, overwrite: int32): int32
importc fn _NSGetEnviron(): ptr

fn envGet(key: str): str =
    if strings.Len(key) <= 0:
        return ""
    let ckey: cstring = strToCStringTemp(key)
    let val: cstring = host_getenv(ckey)
    if val == nil:
        return ""
    return strFromCStringBorrow(val)

fn envGetDefault(key: str, defaultVal: str): str =
    let val: str = envGet(key)
    if strings.Len(val) <= 0:
        return defaultVal
    return val

fn envSet(key: str, value: str): Result[bool] =
    if strings.Len(key) <= 0:
        return Err[bool]("empty key")
    let rc: int32 = host_setenv(strToCStringTemp(key), strToCStringTemp(value), 1)
    if rc == 0:
        return Ok[bool](true)
    return Err[bool]("setenv failed")

fn envUnset(key: str): Result[bool] =
    if strings.Len(key) <= 0:
        return Err[bool]("empty key")
    let rc: int32 = host_setenv(strToCStringTemp(key), "", 1)
    return rc == 0 ? Ok[bool](true) : Err[bool]("unset failed")

fn envHas(key: str): bool =
    let val: str = envGet(key)
    return strings.Len(val) > 0

fn envEnvironPtr(): ptr =
    let pp: ptr = _NSGetEnviron()
    if pp == nil:
        return nil
    return *[ptr](pp)

fn envList(): str[] =
    var out: str[]
    let envp: ptr = envEnvironPtr()
    if envp == nil:
        return out
    var i: int32
    while true:
        let entry: ptr = *[ptr](rawmem_support.RawmemPtrAdd(envp, i * elemSize[ptr]()))
        if entry == nil:
            break
        let val: str = strFromCStringBorrow(cstring(entry))
        seqs.Add(out, val)
        i = i + 1
    return out

fn envCount(): int32 =
    let envp: ptr = envEnvironPtr()
    if envp == nil:
        return 0
    var count: int32
    while true:
        let entry: ptr = *[ptr](rawmem_support.RawmemPtrAdd(envp, count * elemSize[ptr]()))
        if entry == nil:
            break
        count = count + 1
    return count

fn envSplit(keyValue: str, key: var str, value: var str): bool =
    let n: int32 = strings.Len(keyValue)
    if n <= 0:
        return false
    for i in 0..<n:
        if keyValue[i] == '=':
            key = strings.SliceBytes(keyValue, 0, i)
            value = strings.SliceBytes(keyValue, i + 1, n - i - 1)
            return true
    key = keyValue
    value = ""
    return true

# ---- Public exports ----

fn Get(key: str): str =
    return envGet(key)

fn GetDefault(key: str, defaultVal: str): str =
    return envGetDefault(key, defaultVal)

fn Set(key: str, value: str): Result[bool] =
    return envSet(key, value)

fn Unset(key: str): Result[bool] =
    return envUnset(key)

fn Has(key: str): bool =
    return envHas(key)

fn List(): str[] =
    return envList()

fn Count(): int32 =
    return envCount()

fn Split(keyValue: str, key: var str, value: var str): bool =
    return envSplit(keyValue, key, value)
