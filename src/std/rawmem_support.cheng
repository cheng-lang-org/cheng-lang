# Shared raw memory helpers.
# Keep low-level pointer/mem ops centralized outside stage1/backend-uir surfaces.
import std/system

@importc("cheng_memcpy")
fn rawmemMemcpyBridgeCompat(dst: ptr, src: ptr, n: int64): ptr

@importc("ptr_add")
fn rawmemPtrAdd(p: ptr, off: int32): ptr

@importc("copyMem")
fn rawmemCopyRaw(dst: ptr, src: ptr, n: int32)

@importc("setMem")
fn rawmemSet(dst: ptr, byte: int32, n: int32)

@importc("cheng_rawmem_write_i8")
fn rawmemWriteI8(dst: ptr, idx: int32, v: int8)

@importc("cheng_rawmem_write_char")
fn rawmemWriteChar(dst: ptr, idx: int32, c: char)

fn rawmemAsVoid(v: str): ptr =
    return strDataPtr(v)

fn rawmemAsVoid(v: cstring): ptr =
    return ptr(v)

fn rawmemAsVoid(v: ptr): ptr =
    return v

fn rawmemAsVoid(v: T[]): ptr =
    return v.buffer

fn rawmemAsVoid(v: var T[]): ptr =
    return v.buffer

fn rawmemAsVoid[T](v: T): ptr =
    return ptr(v)

fn rawmemCopy(dst: ptr, src: ptr, n: int32) =
    let dst0: ptr = dst
    let src0: ptr = src
    rawmemCopyRaw(dst0, src0, n)

fn rawmemStrFromOffset(s: str, off: int32): str =
    return strSubView(s, off, strLenFast(s) - off)

fn RawmemPtrAdd(p: ptr, off: int32): ptr =
    return rawmemPtrAdd(p, off)

fn RawmemAsVoid(v: str): ptr =
    return rawmemAsVoid(v)

fn RawmemAsVoid(v: cstring): ptr =
    return rawmemAsVoid(v)

fn RawmemAsVoid(v: ptr): ptr =
    return rawmemAsVoid(v)

fn RawmemAsVoid(v: T[]): ptr =
    return rawmemAsVoid(v)

fn RawmemAsVoid(v: var T[]): ptr =
    return rawmemAsVoid(v)

fn RawmemAsVoid[T](v: T): ptr =
    return rawmemAsVoid(v)

fn RawmemCopy(dst: ptr, src: ptr, n: int32) =
    rawmemCopy(dst, src, n)

fn RawmemSet(dst: ptr, byte: int32, n: int32) =
    rawmemSet(dst, byte, n)

fn RawmemWriteI8(dst: ptr, idx: int32, v: int8) =
    rawmemWriteI8(dst, idx, v)
