# Shared raw memory helpers.
# Keep low-level pointer/mem ops centralized outside stage1/backend-uir surfaces.

@importc("cheng_memcpy")
fn rawmemMemcpyBridgeCompat(dst: ptr, src: ptr, n: int64): ptr

@importc("ptr_add")
fn rawmemPtrAdd(p: ptr, off: int32): ptr

@importc("copyMem")
fn rawmemCopy(dst: ptr, src: ptr, n: int32)

@importc("setMem")
fn rawmemSet(dst: ptr, byte: int32, n: int32)

@importc("cheng_rawmem_write_i8")
fn rawmemWriteI8(dst: ptr, idx: int32, v: int8)

@importc("cheng_rawmem_write_char")
fn rawmemWriteChar(dst: ptr, idx: int32, c: char)

fn rawmemAsVoid[T](v: T): ptr =
    return ptr(v)

@importc("cheng_rawmem_str_from_offset")
fn rawmemStrFromOffset(s: str, off: int32): str
