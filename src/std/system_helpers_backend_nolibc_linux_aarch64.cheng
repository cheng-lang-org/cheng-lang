fn cheng_sha256_get_u32be(data: ptr, offset: int32): int64 =
    let b0: int64 = int64(*(UInt8Ptr(ptr(uint64(data) + uint64(offset))))
)
    let b1: int64 = int64(*(UInt8Ptr(ptr(uint64(data) + uint64(offset + 1))))
)
    let b2: int64 = int64(*(UInt8Ptr(ptr(uint64(data) + uint64(offset + 2))))
)
    let b3: int64 = int64(*(UInt8Ptr(ptr(uint64(data) + uint64(offset + 3))))
)
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

fn cheng_sha256_set_u32be(data: ptr, offset: int32, value: int64) =
    let v: int64 = cheng_sha256_u32(value)
    *(UInt8Ptr(ptr(uint64(data) + uint64(offset)))) = uint8((v >> 24) & 255)
    *(UInt8Ptr(ptr(uint64(data) + uint64(offset + 1)))) = uint8((v >> 16) & 255)
    *(UInt8Ptr(ptr(uint64(data) + uint64(offset + 2)))) = uint8((v >> 8) & 255)
    *(UInt8Ptr(ptr(uint64(data) + uint64(offset + 3)))) = uint8(v & 255)

fn cheng_sha256_digest_into(data: ptr, length: int32, out32: ptr): bool =
    if out32 == nil:
        return false
    var h0: int64 = cheng_sha256_u32_from_bytes(0x6a, 0x09, 0xe6, 0x67)
    var h1: int64 = cheng_sha256_u32_from_bytes(0xbb, 0x67, 0xae, 0x85)
    var h2: int64 = cheng_sha256_u32_from_bytes(0x3c, 0x6e, 0xf3, 0x72)
    var h3: int64 = cheng_sha256_u32_from_bytes(0xa5, 0x4f, 0xf5, 0x3a)
    var h4: int64 = cheng_sha256_u32_from_bytes(0x51, 0x0e, 0x52, 0x7f)
    var h5: int64 = cheng_sha256_u32_from_bytes(0x9b, 0x05, 0x68, 0x8c)
    var h6: int64 = cheng_sha256_u32_from_bytes(0x1f, 0x83, 0xd9, 0xab)
    var h7: int64 = cheng_sha256_u32_from_bytes(0x5b, 0xe0, 0xcd, 0x19)
    let inputLen: int32 = length > 0 ? length : 0
    var padZero: int32
    while ((inputLen + 1 + padZero) % 64) != 56:
        padZero = padZero + 1
    let totalLen: int32 = inputLen + 1 + padZero + 8
    let msg: ptr = chengAllocCompat(totalLen)
    let wbuf: ptr = chengAllocCompat(64 * 4)
    if msg == nil || wbuf == nil:
        chengFreeCompat(msg)
        chengFreeCompat(wbuf)
        return false
    cheng_bytes_set(msg, 0, int64(totalLen))
    if data != nil && inputLen > 0:
        cheng_bytes_copy(msg, data, int64(inputLen))
    *(UInt8Ptr(ptr(uint64(msg) + uint64(inputLen)))) = uint8(0x80)
    var bitLen: int64 = int64(inputLen) * 8
    var i: int32
    for i in i..<8:
        *(UInt8Ptr(ptr(uint64(msg) + uint64(totalLen - 1 - i)))) = uint8(bitLen & 255)
        bitLen = bitLen >> 8
    var offset: int32
    while offset < totalLen:
        var t: int32
        for t in t..<16:
            cheng_sha256_set_u32be(wbuf, t * 4, cheng_sha256_get_u32be(msg, offset + t * 4))
        t = 16
        for t in t..<64:
            let w2: int64 = cheng_sha256_get_u32be(wbuf, (t - 2) * 4)
            let w7: int64 = cheng_sha256_get_u32be(wbuf, (t - 7) * 4)
            let w15: int64 = cheng_sha256_get_u32be(wbuf, (t - 15) * 4)
            let w16: int64 = cheng_sha256_get_u32be(wbuf, (t - 16) * 4)
            cheng_sha256_set_u32be(wbuf,
                                   t * 4,
                                   cheng_sha256_u32(w16 + cheng_sha256_small_sigma0(w15) +
                                                    w7 + cheng_sha256_small_sigma1(w2)))
        var a: int64 = h0
        var b: int64 = h1
        var c: int64 = h2
        var d: int64 = h3
        var e: int64 = h4
        var f: int64 = h5
        var g: int64 = h6
        var h: int64 = h7
        t = 0
        for t in t..<64:
            let wt: int64 = cheng_sha256_get_u32be(wbuf, t * 4)
            let t1: int64 = cheng_sha256_u32(h + cheng_sha256_big_sigma1(e) +
                                             cheng_sha256_ch(e, f, g) + cheng_sha256_k(t) + wt)
            let t2: int64 = cheng_sha256_u32(cheng_sha256_big_sigma0(a) + cheng_sha256_maj(a, b, c))
            h = g
            g = f
            f = e
            e = cheng_sha256_u32(d + t1)
            d = c
            c = b
            b = a
            a = cheng_sha256_u32(t1 + t2)
        h0 = cheng_sha256_u32(h0 + a)
        h1 = cheng_sha256_u32(h1 + b)
        h2 = cheng_sha256_u32(h2 + c)
        h3 = cheng_sha256_u32(h3 + d)
        h4 = cheng_sha256_u32(h4 + e)
        h5 = cheng_sha256_u32(h5 + f)
        h6 = cheng_sha256_u32(h6 + g)
        h7 = cheng_sha256_u32(h7 + h)
        offset = offset + 64
    cheng_sha256_set_u32be(out32, 0, h0)
    cheng_sha256_set_u32be(out32, 4, h1)
    cheng_sha256_set_u32be(out32, 8, h2)
    cheng_sha256_set_u32be(out32, 12, h3)
    cheng_sha256_set_u32be(out32, 16, h4)
    cheng_sha256_set_u32be(out32, 20, h5)
    cheng_sha256_set_u32be(out32, 24, h6)
    cheng_sha256_set_u32be(out32, 28, h7)
    chengFreeCompat(msg)
    chengFreeCompat(wbuf)
    return true

@exportc("cheng_sha256_word_bridge")
fn cheng_sha256_word_bridge_export(text: str, wordIndex: int32): int64 =
    if wordIndex < 0 || wordIndex >= 4:
        return 0
    let digest: ptr = chengAllocCompat(32)
    if digest == nil:
        return 0
    if !cheng_sha256_digest_into(cheng_runtime_str_data(text), cheng_runtime_str_len(text), digest):
        chengFreeCompat(digest)
        return 0
    var out: uint64 = uint64(0)
    var i: int32
    let base: int32 = wordIndex * 8
    while i < 8:
        out = (out << uint64(8)) | uint64(*(UInt8Ptr(ptr(uint64(digest) + uint64(base + i))))
)
        i = i + 1
    chengFreeCompat(digest)
    return int64(out)

@exportc("cheng_system_cpu_logical_cores_bridge")
fn cheng_system_cpu_logical_cores_bridge_export(): int32 =
    let maskBytes: int32 = 128
    let mask: ptr = chengAllocCompat(maskBytes)
    if mask == nil:
        return 1
    cheng_bytes_set(mask, 0, int64(maskBytes))
    let ret: int64 = cheng_linux_syscall3(cheng_sys_sched_getaffinity, 0, int64(maskBytes), uint64(mask))
    var count: int32
    if !cheng_sys_is_err(ret) && ret > 0:
        var i: int32
        for i in i..<int32(ret):
            count = count + cheng_runtime_u8_popcount(*(UInt8Ptr(ptr(uint64(mask) + uint64(i)))))
    chengFreeCompat(mask)
    if count > 0:
        return count
    return 1

fn cheng_runtime_sysinfo_query(out: ChengLinuxSysinfoPtr): bool =
    if out == nil:
        return false
    let ret: int64 = cheng_linux_syscall1(cheng_sys_sysinfo, uint64(out))
    return !cheng_sys_is_err(ret)

fn cheng_runtime_statfs_query(out: ChengLinuxStatfsPtr): bool =
    if out == nil:
        return false
    let root: ptr = "/"
    let ret: int64 = cheng_linux_syscall2(cheng_sys_statfs, uint64(root), uint64(out))
    return !cheng_sys_is_err(ret)

@exportc("cheng_system_memory_total_bytes_bridge")
fn cheng_system_memory_total_bytes_bridge_export(): int64 =
    var info: ChengLinuxSysinfo
    if !cheng_runtime_sysinfo_query(&info):
        return 0
    let unit: uint64 = info.memUnit == uint32(0) ? uint64(1) : uint64(info.memUnit)
    return int64(info.totalram * unit)

@exportc("cheng_system_memory_available_bytes_bridge")
fn cheng_system_memory_available_bytes_bridge_export(): int64 =
    var info: ChengLinuxSysinfo
    if !cheng_runtime_sysinfo_query(&info):
        return 0
    let unit: uint64 = info.memUnit == uint32(0) ? uint64(1) : uint64(info.memUnit)
    return int64((info.freeram + info.bufferram) * unit)

@exportc("cheng_system_disk_total_bytes_bridge")
fn cheng_system_disk_total_bytes_bridge_export(): int64 =
    var fs: ChengLinuxStatfs
    if !cheng_runtime_statfs_query(&fs):
        return 0
    let blockSize: int64 = fs.fFrsize > 0 ? fs.fFrsize : fs.fBsize
    if blockSize <= 0:
        return 0
    return fs.fBlocks * blockSize

@exportc("cheng_system_disk_available_bytes_bridge")
fn cheng_system_disk_available_bytes_bridge_export(): int64 =
    var fs: ChengLinuxStatfs
    if !cheng_runtime_statfs_query(&fs):
        return 0
    let blockSize: int64 = fs.fFrsize > 0 ? fs.fFrsize : fs.fBsize
    if blockSize <= 0:
        return 0
    return fs.fBavail * blockSize

