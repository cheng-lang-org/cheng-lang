fn cheng_runtime_u64_to_string(value0: uint64): ptr =
    let scratch: ptr = chengAllocCompat(64)
    if scratch == nil:
        return nil
    cheng_bytes_set(scratch, 0, 64)
    var value: uint64 = value0
    var idx: int32 = 63
    if value == uint64(0):
        idx = idx - 1
        *(UInt8Ptr(ptr(uint64(scratch) + uint64(idx)))) = uint8('0')
    else:
        while value != uint64(0) && idx > 0:
            idx = idx - 1
            *(UInt8Ptr(ptr(uint64(scratch) + uint64(idx)))) = uint8(int32('0') + int32(value % uint64(10)))
            value = value / uint64(10)
    let outLen: int32 = 63 - idx
    let out: ptr = cheng_runtime_string_copy(ptr(uint64(scratch) + uint64(idx)), outLen)
    chengFreeCompat(scratch)
    return out

