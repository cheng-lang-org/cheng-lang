fn puts_runtime(text: ptr): int32 =
    return cheng_puts(text)
fn cheng_strlen_runtime(s: ptr): int32 =
    if s == nil:
        return 0
    var n: int32
    while *(ptr(cheng_rawmem_ptr_add(ptr(s), n))) != '\0':
        n = n + 1
    return n
fn cheng_memcpy_ffi_runtime(dest: ptr, src: ptr, n: int64): ptr =
    return cheng_memcpy(dest, src, n)
fn cheng_memset_ffi_runtime(dest: ptr, val: int32, n: int64): ptr =
    return cheng_memset(dest, val, n)
fn cheng_memcpy_ffi(dest: ptr, src: ptr, n: int64): ptr =
    return cheng_memcpy_ffi_runtime(dest, src, n)
fn cheng_memset_ffi(dest: ptr, val: int32, n: int64): ptr =
    return cheng_memset_ffi_runtime(dest, val, n)
fn cheng_ptr_size_runtime(): int32 =
    return cheng_ptr_size()
fn cheng_ptr_to_u64_runtime(p: ptr): uint64 =
    return cheng_ptr_to_u64(p)
fn cheng_seq_get_runtime(buffer: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    return cheng_seq_get(buffer, len, idx, elemSize)
fn cheng_seq_set_runtime(buffer: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    return cheng_seq_set(buffer, len, idx, elemSize)

fn cheng_ptr_size(): int32 =
    return 8

fn cheng_ptr_to_u64(p: ptr): uint64 =
    return uint64(p)

fn cheng_align_up(v: int64, a: int64): int64 =
    if a <= 1:
        return v
    let m: int64 = v % a
    if m == 0:
        return v
    return v + (a - m)

fn cheng_sys_is_err(v: int64): bool =
    return v < 0 && v >= -4095

@weak
fn store_int32(p: ptr, val: int32) =
    if p == nil:
        return
    let pp: Int32Ptr = Int32Ptr(p)
    *pp = val

fn load_int32(p: ptr): int32 =
    if p == nil:
        return 0
    let pp: Int32Ptr = Int32Ptr(p)
    return *pp

@weak
fn store_bool(p: ptr, val: int8) =
    if p == nil:
        return
    let pp: Int8Ptr = Int8Ptr(p)
    *pp = val

@weak
fn load_bool(p: ptr): int8 =
    if p == nil:
        return 0
    let pp: Int8Ptr = Int8Ptr(p)
    return *pp

fn cheng_bytes_copy(dst: ptr, src: ptr, n: int64) =
    if dst == nil || src == nil || n <= 0:
        return
    for i in 0..<n:
        let b: uint8 = *(UInt8Ptr(cheng_rawmem_ptr_add(src, int32(i))))
        *(UInt8Ptr(cheng_rawmem_ptr_add(dst, int32(i)))) = b

fn cheng_bytes_set(dst: ptr, value: int32, n: int64) =
    if dst == nil || n <= 0:
        return
    let b: uint8 = uint8(value & 0xFF)
    for i in 0..<n:
        *(UInt8Ptr(cheng_rawmem_ptr_add(dst, int32(i)))) = b

fn cheng_bytes_cmp(a: ptr, b: ptr, n: int64): int32 =
    if n <= 0:
        return 0
    for i in 0..<n:
        let av: uint8 = *(UInt8Ptr(cheng_rawmem_ptr_add(a, int32(i))))
        let bv: uint8 = *(UInt8Ptr(cheng_rawmem_ptr_add(b, int32(i))))
        if av < bv:
            return -1
        if av > bv:
            return 1
    return 0

fn cheng_strlen(s: ptr): int32 =
    if s == nil:
        return 0
    var n: int32
    while *(ptr(cheng_rawmem_ptr_add(ptr(s), n))) != '\0':
        n = n + 1
    return n

fn cheng_strcmp(a: ptr, b: ptr): int32 =
    if a == b:
        return 0
    var pa: ptr = a
    var pb: ptr = b
    if pa == nil:
        pa = ""
    if pb == nil:
        pb = ""
    var i: int32
    while true:
        let ca: uint8 = uint8(int32(*(ptr(cheng_rawmem_ptr_add(ptr(pa), i)))) & 0xFF)
        let cb: uint8 = uint8(int32(*(ptr(cheng_rawmem_ptr_add(ptr(pb), i)))) & 0xFF)
        if ca < cb:
            return -1
        if ca > cb:
            return 1
        if ca == 0:
            return 0
        i = i + 1

fn cheng_memcpy(dest: ptr, src: ptr, n: int64): ptr =
    cheng_bytes_copy(dest, src, n)
    return dest

fn cheng_memset(dest: ptr, val: int32, n: int64): ptr =
    cheng_bytes_set(dest, val, n)
    return dest

fn cheng_memcmp(a: ptr, b: ptr, n: int64): int32 =
    return cheng_bytes_cmp(a, b, n)

fn chengMapPages(total: int64): ptr =
    let ret: int64 = cheng_linux_syscall6(cheng_sys_mmap,
                                          0,
                                          total,
                                          cheng_prot_read | cheng_prot_write,
                                          cheng_map_private | cheng_map_anon,
                                          -1,
                                          0)
    if cheng_sys_is_err(ret):
        return nil
    return ptr(uint64(ret))

fn cheng_munmap_region(addr: ptr, total: int64): int32 =
    if addr == nil || total <= 0:
        return 0
    let ret: int64 = cheng_linux_syscall2(cheng_sys_munmap, int64(uint64(addr)), total)
    return cheng_sys_is_err(ret) ? -1 : 0

fn cheng_runtime_lock() =
    while cheng_linux_atomic_cas_i32(ptr(&cheng_runtime_lock_word), 0, 1) == 0:
        let _ = cheng_linux_syscall0(cheng_sys_sched_yield)

fn cheng_runtime_unlock() =
    cheng_linux_atomic_store_i32(ptr(&cheng_runtime_lock_word), 0)

fn chengRawBytes(size: int64): ptr =
    var n: int64 = size
    if n <= 0:
        n = 1
    let header: int64 = int64(sizeof(ChengRawHdr))
    let total: int64 = cheng_align_up(header + n, cheng_page_size)
    let raw: ptr = chengMapPages(total)
    if raw == nil:
        return nil
    let hdr: ChengRawHdrPtr = ChengRawHdrPtr(raw)
    hdr->mapSize = total
    return cheng_rawmem_ptr_add(raw, int32(header))

fn cheng_raw_free(p: ptr) =
    if p == nil:
        return
    let header: int32 = int32(sizeof(ChengRawHdr))
    let raw: ptr = cheng_rawmem_ptr_add(p, -header)
    let hdr: ChengRawHdrPtr = ChengRawHdrPtr(raw)
    let total: int64 = hdr->mapSize
    cheng_munmap_region(raw, total)

fn cheng_mem_global(): ChengMemScopePtr =
    if cheng_global_scope != nil:
        return cheng_global_scope
    let mem: ptr = chengRawBytes(int64(sizeof(ChengMemScope)))
    if mem == nil:
        return nil
    let scope: ChengMemScopePtr = ChengMemScopePtr(mem)
    scope->parent = nil
    scope->head = nil
    cheng_global_scope = scope
    return scope

fn cheng_mem_current(): ChengMemScopePtr =
    if cheng_scope_current == nil:
        cheng_scope_current = cheng_mem_global()
    return cheng_scope_current

fn cheng_ptr_hash(v0: uint64): uint64 =
    var v: uint64 = v0
    v = v ^ (v >> uint64(33))
    v = v * uint64(0xff51afd7ed558ccd)
    v = v ^ (v >> uint64(33))
    v = v * uint64(0xc4ceb9fe1a85ec53)
    v = v ^ (v >> uint64(33))
    return v

fn cheng_ptrmap_init(cap: int64) =
    var n: int64 = 1
    while n < cap:
        n = n << 1
    let keysMem: ptr = chengRawBytes(n * int64(sizeof(uint64)))
    let valsMem: ptr = chengRawBytes(n * int64(sizeof(VoidPtr)))
    if keysMem == nil || valsMem == nil:
        cheng_raw_free(keysMem)
        cheng_raw_free(valsMem)
        cheng_block_map_keys = nil
        cheng_block_map_vals = nil
        cheng_block_map_cap = 0
        cheng_block_map_count = 0
        cheng_block_map_tombs = 0
        return
    cheng_block_map_keys = UInt64Ptr(keysMem)
    cheng_block_map_vals = ChengMemBlockPtrPtr(valsMem)
    cheng_block_map_cap = n
    cheng_block_map_count = 0
    cheng_block_map_tombs = 0

fn cheng_ptrmap_get(key: ptr): ChengMemBlockPtr =
    if key == nil || cheng_block_map_cap == 0:
        return nil
    let k: uint64 = uint64(key)
    if k == 0 || k == cheng_ptrmap_tomb:
        return nil
    let mask: uint64 = uint64(cheng_block_map_cap - 1)
    let keysBase: uint64 = uint64(cheng_block_map_keys)
    let valsBase: uint64 = uint64(cheng_block_map_vals)
    var idx: uint64 = cheng_ptr_hash(k) & mask
    while true:
        let cur: uint64 = *(UInt64Ptr(ptr(keysBase + (idx * uint64(8)))))
        if cur == 0:
            return nil
        if cur == k:
            return *(ChengMemBlockPtrPtr(ptr(valsBase + (idx * uint64(8)))))
        idx = (idx + 1) & mask

fn cheng_ptrmap_grow() =
    let oldcap: int64 = cheng_block_map_cap
    let oldkeys: UInt64Ptr = cheng_block_map_keys
    let oldvals: ChengMemBlockPtrPtr = cheng_block_map_vals
    let oldcount: int64 = cheng_block_map_count
    let oldtombs: int64 = cheng_block_map_tombs
    let newcap: int64 = oldcap > 0 ? (oldcap * 2) : 1024

    cheng_block_map_keys = nil
    cheng_block_map_vals = nil
    cheng_block_map_cap = 0
    cheng_block_map_count = 0
    cheng_block_map_tombs = 0
    cheng_ptrmap_init(newcap)
    if cheng_block_map_cap == 0:
        cheng_block_map_keys = oldkeys
        cheng_block_map_vals = oldvals
        cheng_block_map_cap = oldcap
        cheng_block_map_count = oldcount
        cheng_block_map_tombs = oldtombs
        return

    if oldkeys != nil && oldcap > 0:
        let newMask: uint64 = uint64(cheng_block_map_cap - 1)
        let keysBase: uint64 = uint64(cheng_block_map_keys)
        let valsBase: uint64 = uint64(cheng_block_map_vals)
        let oldKeysBase: uint64 = uint64(oldkeys)
        let oldValsBase: uint64 = uint64(oldvals)
        for i in 0..<oldcap:
            let k: uint64 = *(UInt64Ptr(ptr(oldKeysBase + (uint64(i) * uint64(8)))))
            if k > cheng_ptrmap_tomb:
                let v: ChengMemBlockPtr = *(ChengMemBlockPtrPtr(ptr(oldValsBase + (uint64(i) * uint64(8)))))
                if v != nil:
                    var idx: uint64 = cheng_ptr_hash(k) & newMask
                    while true:
                        let cur: uint64 = *(UInt64Ptr(ptr(keysBase + (idx * uint64(8)))))
                        if cur == 0:
                            *(UInt64Ptr(ptr(keysBase + (idx * uint64(8))))) = k
                            *(ChengMemBlockPtrPtr(ptr(valsBase + (idx * uint64(8))))) = v
                            cheng_block_map_count = cheng_block_map_count + 1
                            break
                        idx = (idx + 1) & newMask
        cheng_raw_free(ptr(oldkeys))
        cheng_raw_free(ptr(oldvals))

fn cheng_ptrmap_put(key: ptr, val: ChengMemBlockPtr) =
    if key == nil:
        return
    let k: uint64 = uint64(key)
    if k == 0 || k == cheng_ptrmap_tomb:
        return
    if cheng_block_map_cap == 0:
        cheng_ptrmap_init(65536)
        if cheng_block_map_cap == 0:
            return

    if (cheng_block_map_count + cheng_block_map_tombs) * 10 >= cheng_block_map_cap * 7:
        cheng_ptrmap_grow()
        if cheng_block_map_cap == 0:
            return

    let mask: uint64 = uint64(cheng_block_map_cap - 1)
    let keysBase: uint64 = uint64(cheng_block_map_keys)
    let valsBase: uint64 = uint64(cheng_block_map_vals)
    var idx: uint64 = cheng_ptr_hash(k) & mask
    var firstTomb: int64 = -1
    while true:
        let cur: uint64 = *(UInt64Ptr(ptr(keysBase + (idx * uint64(8)))))
        if cur == k:
            *(ChengMemBlockPtrPtr(ptr(valsBase + (idx * uint64(8))))) = val
            return
        if cur == cheng_ptrmap_tomb && firstTomb < 0:
            firstTomb = int64(idx)
        if cur == 0:
            var useIdx: uint64 = idx
            if firstTomb >= 0:
                useIdx = uint64(firstTomb)
                cheng_block_map_tombs = cheng_block_map_tombs - 1
            *(UInt64Ptr(ptr(keysBase + (useIdx * uint64(8))))) = k
            *(ChengMemBlockPtrPtr(ptr(valsBase + (useIdx * uint64(8))))) = val
            cheng_block_map_count = cheng_block_map_count + 1
            return
        idx = (idx + 1) & mask

fn cheng_ptrmap_del(key: ptr) =
    if key == nil || cheng_block_map_cap == 0:
        return
    let k: uint64 = uint64(key)
    if k == 0 || k == cheng_ptrmap_tomb:
        return
    let mask: uint64 = uint64(cheng_block_map_cap - 1)
    let keysBase: uint64 = uint64(cheng_block_map_keys)
    let valsBase: uint64 = uint64(cheng_block_map_vals)
    var idx: uint64 = cheng_ptr_hash(k) & mask
    while true:
        let cur: uint64 = *(UInt64Ptr(ptr(keysBase + (idx * uint64(8)))))
        if cur == 0:
            return
        if cur == k:
            *(UInt64Ptr(ptr(keysBase + (idx * uint64(8))))) = cheng_ptrmap_tomb
            *(ChengMemBlockPtrPtr(ptr(valsBase + (idx * uint64(8))))) = nil
            if cheng_block_map_count > 0:
                cheng_block_map_count = cheng_block_map_count - 1
            cheng_block_map_tombs = cheng_block_map_tombs + 1
            return
        idx = (idx + 1) & mask

fn cheng_mem_link(scope: ChengMemScopePtr, memBlock: ChengMemBlockPtr) =
    if scope == nil || memBlock == nil:
        return
    memBlock->scope = scope
    memBlock->prev = nil
    memBlock->next = scope->head
    let head: ChengMemBlockPtr = ChengMemBlockPtr(scope->head)
    if head != nil:
        head->prev = memBlock
    scope->head = memBlock

fn cheng_mem_unlink(memBlock: ChengMemBlockPtr) =
    if memBlock == nil:
        return
    let scope: ChengMemScopePtr = ChengMemScopePtr(memBlock->scope)
    if scope == nil:
        return
    let prev: ChengMemBlockPtr = ChengMemBlockPtr(memBlock->prev)
    let next: ChengMemBlockPtr = ChengMemBlockPtr(memBlock->next)
    if prev != nil:
        prev->next = next
    elif scope->head == memBlock:
        scope->head = next
    if next != nil:
        next->prev = prev
    memBlock->prev = nil
    memBlock->next = nil
    memBlock->scope = nil

fn cheng_mem_find_block_any(p: ptr): ChengMemBlockPtr =
    return cheng_ptrmap_get(p)

fn chengHeapNew(size: int32): ptr =
    var n: int32 = size
    if n <= 0:
        n = 1
    let scope: ChengMemScopePtr = cheng_mem_current()
    let header: int64 = int64(sizeof(ChengMemBlock))
    let total: int64 = cheng_align_up(header + int64(n), cheng_page_size)
    let raw: ptr = chengMapPages(total)
    if raw == nil:
        return nil
    let memBlock: ChengMemBlockPtr = ChengMemBlockPtr(raw)
    memBlock->prev = nil
    memBlock->next = nil
    memBlock->scope = nil
    memBlock->size = int64(n)
    memBlock->mapSize = total
    memBlock->rc = 1
    memBlock->_pad = 0
    cheng_mem_link(scope, memBlock)
    let payload: ptr = cheng_rawmem_ptr_add(raw, int32(header))
    cheng_ptrmap_put(payload, memBlock)
    cheng_mm_alloc_total = cheng_mm_alloc_total + 1
    cheng_mm_live_total = cheng_mm_live_total + 1
    return payload

fn cheng_free(p: ptr) =
    if p == nil:
        return
    let memBlock: ChengMemBlockPtr = cheng_mem_find_block_any(p)
    if memBlock == nil:
        return
    cheng_mem_unlink(memBlock)
    cheng_ptrmap_del(p)
    cheng_munmap_region(ptr(memBlock), memBlock->mapSize)
    cheng_mm_free_total = cheng_mm_free_total + 1
    if cheng_mm_live_total > 0:
        cheng_mm_live_total = cheng_mm_live_total - 1

fn chengAllocCompat(size: int32): ptr =
    return chengHeapNew(size)

fn chengFreeCompat(p: ptr) =
    cheng_free(p)

fn chengHeapResize(p: ptr, size: int32): ptr =
    if p == nil:
        return chengHeapNew(size)
    let memBlock: ChengMemBlockPtr = cheng_mem_find_block_any(p)
    if memBlock == nil:
        return nil
    var n: int32 = size
    if n <= 0:
        n = 1
    let out: ptr = chengHeapNew(n)
    if out == nil:
        return nil
    let copyN: int64 = memBlock->size < int64(n) ? memBlock->size : int64(n)
    if copyN > 0:
        cheng_bytes_copy(out, p, copyN)
    cheng_free(p)
    return out

fn cheng_mem_scope_push(): ptr =
    let mem: ptr = chengRawBytes(int64(sizeof(ChengMemScope)))
    if mem == nil:
        return nil
    let scope: ChengMemScopePtr = ChengMemScopePtr(mem)
    scope->parent = cheng_mem_current()
    scope->head = nil
    cheng_scope_current = scope
    return mem

fn cheng_mem_scope_pop() =
    let scope: ChengMemScopePtr = cheng_mem_current()
    if scope == nil || scope == cheng_global_scope:
        return
    var cur: ChengMemBlockPtr = ChengMemBlockPtr(scope->head)
    while cur != nil:
        let next: ChengMemBlockPtr = ChengMemBlockPtr(cur->next)
        let payload: ptr = cheng_rawmem_ptr_add(ptr(cur), int32(sizeof(ChengMemBlock)))
        cheng_ptrmap_del(payload)
        cheng_munmap_region(ptr(cur), cur->mapSize)
        cheng_mm_free_total = cheng_mm_free_total + 1
        if cheng_mm_live_total > 0:
            cheng_mm_live_total = cheng_mm_live_total - 1
        cur = next
    cheng_scope_current = scope->parent != nil ? ChengMemScopePtr(scope->parent) : cheng_global_scope
    cheng_raw_free(ptr(scope))

fn cheng_mem_scope_escape(p: ptr) =
    if p == nil:
        return
    let memBlock: ChengMemBlockPtr = cheng_mem_find_block_any(p)
    if memBlock == nil:
        return
    let scope: ChengMemScopePtr = ChengMemScopePtr(memBlock->scope)
    if scope == nil || scope == cheng_global_scope:
        return
    let target: ChengMemScopePtr = scope->parent != nil ? ChengMemScopePtr(scope->parent) : cheng_global_scope
    if target == scope:
        return
    cheng_mem_unlink(memBlock)
    cheng_mem_link(target, memBlock)

fn cheng_mem_scope_escape_global(p: ptr) =
    if p == nil:
        return
    let memBlock: ChengMemBlockPtr = cheng_mem_find_block_any(p)
    if memBlock == nil:
        return
    let scope: ChengMemScopePtr = ChengMemScopePtr(memBlock->scope)
    if scope == nil || scope == cheng_global_scope:
        return
    cheng_mem_unlink(memBlock)
    cheng_mem_link(cheng_mem_global(), memBlock)

fn cheng_mem_retain_unlocked(p: ptr) =
    let memBlock: ChengMemBlockPtr = cheng_mem_find_block_any(p)
    if memBlock == nil:
        return
    memBlock->rc = memBlock->rc + 1
    cheng_mm_retain_total = cheng_mm_retain_total + 1

fn cheng_mem_release_unlocked(p: ptr) =
    let memBlock: ChengMemBlockPtr = cheng_mem_find_block_any(p)
    if memBlock == nil:
        return
    if memBlock->rc > 0:
        memBlock->rc = memBlock->rc - 1
    cheng_mm_release_total = cheng_mm_release_total + 1
    if memBlock->rc <= 0:
        cheng_mem_unlink(memBlock)
        cheng_ptrmap_del(p)
        cheng_munmap_region(ptr(memBlock), memBlock->mapSize)
        cheng_mm_free_total = cheng_mm_free_total + 1
        if cheng_mm_live_total > 0:
            cheng_mm_live_total = cheng_mm_live_total - 1

fn cheng_mem_refcount_unlocked(p: ptr): int32 =
    let memBlock: ChengMemBlockPtr = cheng_mem_find_block_any(p)
    if memBlock == nil:
        return 0
    return memBlock->rc

@exportc("cheng_mem_retain")
fn cheng_mem_retain(p: ptr) =
    cheng_runtime_lock()
    cheng_mem_retain_unlocked(p)
    cheng_runtime_unlock()

@exportc("cheng_mem_release")
fn cheng_mem_release(p: ptr) =
    cheng_runtime_lock()
    cheng_mem_release_unlocked(p)
    cheng_runtime_unlock()

@exportc("cheng_mem_refcount")
fn cheng_mem_refcount(p: ptr): int32 =
    cheng_runtime_lock()
    let out = cheng_mem_refcount_unlocked(p)
    cheng_runtime_unlock()
    return out

@exportc("cheng_mem_retain_atomic")
fn cheng_mem_retain_atomic(p: ptr) =
    cheng_mem_retain(p)

@exportc("cheng_mem_release_atomic")
fn cheng_mem_release_atomic(p: ptr) =
    cheng_mem_release(p)

@exportc("cheng_mem_refcount_atomic")
fn cheng_mem_refcount_atomic(p: ptr): int32 =
    return cheng_mem_refcount(p)

@exportc("cheng_atomic_cas_i32")
fn cheng_atomic_cas_i32(p: ptr, expect: int32, desired: int32): int32 =
    if p == nil:
        return 0
    return cheng_linux_atomic_cas_i32(p, expect, desired)

@exportc("cheng_atomic_store_i32")
fn cheng_atomic_store_i32(p: ptr, val: int32) =
