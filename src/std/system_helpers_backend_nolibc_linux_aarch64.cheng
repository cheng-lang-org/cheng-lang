const
    chengBufferHandleMagic: int32 = 1128817459

fn cheng_buffer_handle_payload_ptr(raw: ptr): ptr =
    if raw == nil:
        return nil
    return ptr(uint64(raw) + uint64(8))

fn cheng_buffer_handle_new_from_str(value: str): uint64 =
    let n: int32 = cheng_runtime_str_len(value)
    let raw: ptr = chengAllocCompat(8 + n)
    if raw == nil:
        return uint64(0)
    store_int32(raw, chengBufferHandleMagic)
    store_int32(ptr(uint64(raw) + uint64(4)), n)
    if n > 0:
        cheng_bytes_copy(cheng_buffer_handle_payload_ptr(raw),
                         cheng_runtime_str_data(value),
                         int64(n))
    return uint64(raw)

fn cheng_buffer_handle_new_from_buf(data: ptr, n: int32): uint64 =
    if n < 0:
        return uint64(0)
    let raw: ptr = chengAllocCompat(8 + n)
    if raw == nil:
        return uint64(0)
    store_int32(raw, chengBufferHandleMagic)
    store_int32(ptr(uint64(raw) + uint64(4)), n)
    if n > 0:
        cheng_bytes_copy(cheng_buffer_handle_payload_ptr(raw), data, int64(n))
    return uint64(raw)

fn cheng_buffer_handle_len(raw: ptr): int32 =
    if raw == nil || load_int32(raw) != chengBufferHandleMagic:
        return -1
    return load_int32(ptr(uint64(raw) + uint64(4)))

fn cheng_tcp_hex_value(ch: uint8): int32 =
    if ch >= uint8(int32('0')) && ch <= uint8(int32('9')):
        return int32(ch) - int32(uint8(int32('0')))
    if ch >= uint8(int32('a')) && ch <= uint8(int32('f')):
        return 10 + int32(ch) - int32(uint8(int32('a')))
    if ch >= uint8(int32('A')) && ch <= uint8(int32('F')):
        return 10 + int32(ch) - int32(uint8(int32('A')))
    return -1

fn cheng_tcp_hex_decode_str(text: str, out: var str, errWire: var str): bool =
    out = cheng_runtime_str_empty()
    if (cheng_runtime_str_len(text) % 2) != 0:
        errWire = cheng_runtime_error_str(" libp2p tcp: invalid capture hex length")
        return false
    let outRaw: ptr = chengAllocCompat(cheng_runtime_str_len(text) / 2 + 1)
    if outRaw == nil:
        errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
        return false
    var i = 0
    while i < cheng_runtime_str_len(text):
        let hi = cheng_tcp_hex_value(*(UInt8Ptr(ptr(uint64(cheng_runtime_str_data(text)) + uint64(i)))))
        let lo = cheng_tcp_hex_value(*(UInt8Ptr(ptr(uint64(cheng_runtime_str_data(text)) + uint64(i + 1)))))
        if hi < 0 || lo < 0:
            chengFreeCompat(outRaw)
            errWire = cheng_runtime_error_str(" libp2p tcp: invalid capture hex")
            return false
        *(UInt8Ptr(ptr(uint64(outRaw) + uint64(i / 2)))) = uint8((hi << 4) | lo)
        i = i + 2
    *(UInt8Ptr(ptr(uint64(outRaw) + uint64(cheng_runtime_str_len(text) / 2)))) = uint8(0)
    out = cheng_runtime_str_view_owned(outRaw, cheng_runtime_str_len(text) / 2)
    return true
