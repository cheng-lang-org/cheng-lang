        return false
    if !cheng_runtime_write_text_file_raw(pathRaw, cheng_runtime_str_data(lineText), cheng_runtime_str_len(lineText)):
        errWire = cheng_runtime_tcp_error_str(" libp2p tcp: write ready path")
        chengFreeCompat(pathRaw)
