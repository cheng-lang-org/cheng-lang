fn cheng_runtime_join_path(left: str, right: str): str =
    let leftLen: int32 = cheng_runtime_str_len(left)
    let rightLen: int32 = cheng_runtime_str_len(right)
    if rightLen <= 0:
        return cheng_runtime_str_copy(cheng_runtime_str_data(left), leftLen)
    if leftLen <= 0 || cheng_runtime_path_is_absolute(right):
        return cheng_runtime_str_copy(cheng_runtime_str_data(right), rightLen)
    let leftData: ptr = cheng_runtime_str_data(left)
    let rightData: ptr = cheng_runtime_str_data(right)
    var needSep: int32
    let lastCh: uint8 = *(UInt8Ptr(ptr(uint64(leftData) + uint64(leftLen - 1))))
    if lastCh != uint8('/') && lastCh != uint8('\\'):
        needSep = 1
    let outLen: int32 = leftLen + needSep + rightLen
    let out: ptr = chengAllocCompat(outLen + 1)
    if out == nil:
        return cheng_runtime_str_empty()
    cheng_bytes_set(out, 0, int64(outLen + 1))
    cheng_bytes_copy(out, leftData, int64(leftLen))
    if needSep != 0:
        *(UInt8Ptr(ptr(uint64(out) + uint64(leftLen)))) = uint8('/')
    cheng_bytes_copy(ptr(uint64(out) + uint64(leftLen + needSep)), rightData, int64(rightLen))
    return cheng_runtime_str_view_owned(out, outLen)

fn cheng_runtime_sockaddr_port(addr: ptr): int32 =
