fn cheng_runtime_tcp_last_error_clear() =
    cheng_runtime_str_dispose(cheng_tcp_bridge_last_error)
    cheng_tcp_bridge_last_error = cheng_runtime_str_empty()

fn cheng_runtime_tcp_last_error_set(value: str) =
    cheng_runtime_str_dispose(cheng_tcp_bridge_last_error)
    cheng_tcp_bridge_last_error = cheng_runtime_str_copy(cheng_runtime_str_data(value),
                                                         cheng_runtime_str_len(value))

fn cheng_runtime_tcp_last_error_set_ptr(text: ptr) =
    cheng_runtime_str_dispose(cheng_tcp_bridge_last_error)
    cheng_tcp_bridge_last_error = cheng_runtime_error_str(text)

fn cheng_runtime_tcp_last_error_apply(value: str, fallbackText: ptr) =
    if cheng_runtime_str_len(value) > 0:
        cheng_runtime_tcp_last_error_set(value)
    else:
        cheng_runtime_tcp_last_error_set_ptr(fallbackText)

fn cheng_runtime_tcp_last_error_request_hex_decode(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: request hex decode failed")

fn cheng_runtime_tcp_last_error_response_hex_decode(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: response hex decode failed")

fn cheng_runtime_tcp_last_error_loopback_request_response(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: loopback request-response failed")

fn cheng_runtime_tcp_last_error_loopback_response_handle(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: loopback response handle failed")

fn cheng_runtime_tcp_last_error_invalid_input_handle() =
    cheng_runtime_tcp_last_error_set_ptr(" libp2p tcp: invalid input handle")

fn cheng_runtime_tcp_last_error_loopback_handle_bridge(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: loopback handle bridge failed")

fn cheng_runtime_tcp_last_error_loopback_input_handle(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: loopback input handle failed")

fn cheng_runtime_tcp_last_error_payload_hex_decode(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: payload hex decode failed")

fn cheng_runtime_tcp_last_error_serve_payload_once(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: serve payload once failed")

fn cheng_runtime_tcp_last_error_recv_payload_bridge(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: recv payload bridge failed")

fn cheng_runtime_tcp_last_error_recv_payload_handle(value: str) =
    cheng_runtime_tcp_last_error_apply(value, " libp2p tcp: recv payload handle failed")

@exportc("cheng_tcp_last_error_handle_bridge")
fn cheng_tcp_last_error_handle_bridge_export(): uint64 =
    if cheng_runtime_str_len(cheng_tcp_bridge_last_error) == 0:
        return uint64(0)
    return cheng_buffer_handle_new_from_str(cheng_tcp_bridge_last_error)
@exportc("cheng_buffer_handle_len_bridge")
fn cheng_buffer_handle_len_bridge_export(handle: uint64): int32 =
    return cheng_buffer_handle_len(ptr(handle))

@exportc("cheng_buffer_handle_byte_bridge")
fn cheng_buffer_handle_byte_bridge_export(handle: uint64, idx: int32): int32 =
    let raw: ptr = ptr(handle)
    let n: int32 = cheng_buffer_handle_len(raw)
    if n < 0 || idx < 0 || idx >= n:
        return -1
    return int32(*(UInt8Ptr(ptr(uint64(cheng_buffer_handle_payload_ptr(raw)) + uint64(idx)))))

@exportc("cheng_buffer_handle_release_bridge")
fn cheng_buffer_handle_release_bridge_export(handle: uint64): int32 =
    let raw: ptr = ptr(handle)
    if cheng_buffer_handle_len(raw) < 0:
        return -1
    store_int32(raw, 0)
    chengFreeCompat(raw)
    return 0
@exportc("cheng_buffer_handle_from_raw_bridge")
fn cheng_buffer_handle_from_raw_bridge_export(data: ptr, n: int32): uint64 =
    return cheng_buffer_handle_new_from_buf(data, n)

fn cheng_tcp_loopback_request_response_fill(protocolText: str,
                                               requestWire: str,
                                               responseWire: str,
                                               clientResponseWire: var str,
                                               errWire: var str): int32 =
    clientResponseWire = cheng_runtime_str_empty()
    errWire = cheng_runtime_str_empty()
    var listenerFd: int32 = -1
    var clientFd: int32 = -1
    var serverFd: int32 = -1
    let listenerAddr: ptr = cheng_runtime_sockaddr_loopback(0)
    let clientAddr: ptr = cheng_runtime_sockaddr_loopback(0)
    let addrLenMem: ptr = chengAllocCompat(4)
    let frameBuf: ptr = chengAllocCompat(4)
    var protocolBuf: ptr = nil
    var protocolEcho: ptr = nil
    var requestBuf: ptr = nil
    var responseBuf: ptr = nil
    if listenerAddr == nil || clientAddr == nil || addrLenMem == nil || frameBuf == nil:
        errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
    if cheng_runtime_str_len(errWire) == 0:
        listenerFd = socket(cheng_af_inet, cheng_sock_stream, cheng_ipproto_ip)
        if listenerFd < 0:
            errWire = cheng_runtime_error_str(" libp2p tcp: socket")
    if cheng_runtime_str_len(errWire) == 0:
        let reuse: int32 = 1
        setsockopt(listenerFd, cheng_sol_socket, cheng_so_reuseaddr, &reuse, int32(sizeof(int32)))
        if bind(listenerFd, listenerAddr, cheng_sockaddr_in_len) != 0:
            errWire = cheng_runtime_error_str(" libp2p tcp: bind")
    if cheng_runtime_str_len(errWire) == 0 && listen(listenerFd, 8) != 0:
        errWire = cheng_runtime_error_str(" libp2p tcp: listen")
    if cheng_runtime_str_len(errWire) == 0:
        store(addrLenMem, cheng_sockaddr_in_len)
        if getsockname(listenerFd, listenerAddr, addrLenMem) != 0:
            errWire = cheng_runtime_error_str(" libp2p tcp: getsockname")
    if cheng_runtime_str_len(errWire) == 0:
        *(UInt8Ptr(ptr(uint64(clientAddr) + uint64(2)))) = *(UInt8Ptr(ptr(uint64(listenerAddr) + uint64(2))))
        *(UInt8Ptr(ptr(uint64(clientAddr) + uint64(3)))) = *(UInt8Ptr(ptr(uint64(listenerAddr) + uint64(3))))
        clientFd = socket(cheng_af_inet, cheng_sock_stream, cheng_ipproto_ip)
        if clientFd < 0:
            errWire = cheng_runtime_error_str(" libp2p tcp: client socket")
    if cheng_runtime_str_len(errWire) == 0 && connect(clientFd, clientAddr, cheng_sockaddr_in_len) != 0:
        errWire = cheng_runtime_error_str(" libp2p tcp: connect")
    if cheng_runtime_str_len(errWire) == 0:
        serverFd = accept(listenerFd, nil, nil)
        if serverFd < 0:
            errWire = cheng_runtime_error_str(" libp2p tcp: accept")
    if cheng_runtime_str_len(errWire) == 0 && cheng_runtime_str_len(protocolText) > 0:
        let protocolLen: int32 = cheng_runtime_str_len(protocolText)
        protocolBuf = chengAllocCompat(protocolLen)
        protocolEcho = chengAllocCompat(protocolLen)
        if protocolBuf == nil || protocolEcho == nil:
            errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
        elif !cheng_runtime_send_all(clientFd, cheng_runtime_str_data(protocolText), protocolLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: send request")
        elif !cheng_runtime_recv_exact(serverFd, protocolBuf, protocolLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: recv request")
        elif !cheng_runtime_bytes_equal(protocolBuf, cheng_runtime_str_data(protocolText), protocolLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: multistream request mismatch")
        elif !cheng_runtime_send_all(serverFd, cheng_runtime_str_data(protocolText), protocolLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: send response")
        elif !cheng_runtime_recv_exact(clientFd, protocolEcho, protocolLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: recv response")
        elif !cheng_runtime_bytes_equal(protocolEcho, cheng_runtime_str_data(protocolText), protocolLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: multistream response mismatch")
    if cheng_runtime_str_len(errWire) == 0:
        cheng_runtime_write_u32be(frameBuf, uint32(cheng_runtime_str_len(requestWire)))
        if !cheng_runtime_send_all(clientFd, frameBuf, 4):
            errWire = cheng_runtime_error_str(" libp2p tcp: send request len")
        elif cheng_runtime_str_len(requestWire) > 0 &&
             !cheng_runtime_send_all(clientFd, cheng_runtime_str_data(requestWire), cheng_runtime_str_len(requestWire)):
            errWire = cheng_runtime_error_str(" libp2p tcp: send request payload")
        elif !cheng_runtime_recv_exact(serverFd, frameBuf, 4):
            errWire = cheng_runtime_error_str(" libp2p tcp: recv request len")
    let requestLen: int32 = int32(cheng_runtime_read_u32be(frameBuf))
    if cheng_runtime_str_len(errWire) == 0 && requestLen != cheng_runtime_str_len(requestWire):
        errWire = cheng_runtime_error_str(" libp2p tcp: request payload length mismatch")
    if cheng_runtime_str_len(errWire) == 0 && requestLen > 0:
        requestBuf = chengAllocCompat(requestLen)
        if requestBuf == nil:
            errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
        elif !cheng_runtime_recv_exact(serverFd, requestBuf, requestLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: recv request payload")
        elif !cheng_runtime_bytes_equal(requestBuf, cheng_runtime_str_data(requestWire), requestLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: request payload mismatch")
    if cheng_runtime_str_len(errWire) == 0:
        cheng_runtime_write_u32be(frameBuf, uint32(cheng_runtime_str_len(responseWire)))
        if !cheng_runtime_send_all(serverFd, frameBuf, 4):
            errWire = cheng_runtime_error_str(" libp2p tcp: send response len")
        elif cheng_runtime_str_len(responseWire) > 0 &&
             !cheng_runtime_send_all(serverFd, cheng_runtime_str_data(responseWire), cheng_runtime_str_len(responseWire)):
            errWire = cheng_runtime_error_str(" libp2p tcp: send response payload")
        elif !cheng_runtime_recv_exact(clientFd, frameBuf, 4):
            errWire = cheng_runtime_error_str(" libp2p tcp: recv response len")
    let responseLen: int32 = int32(cheng_runtime_read_u32be(frameBuf))
    if cheng_runtime_str_len(errWire) == 0 && responseLen > 0:
        responseBuf = chengAllocCompat(responseLen)
        if responseBuf == nil:
            errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
        elif !cheng_runtime_recv_exact(clientFd, responseBuf, responseLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: recv response payload")
    if cheng_runtime_str_len(errWire) == 0:
        clientResponseWire = cheng_runtime_str_copy(responseBuf, responseLen)
    if protocolBuf != nil:
        chengFreeCompat(protocolBuf)
    if protocolEcho != nil:
        chengFreeCompat(protocolEcho)
    if requestBuf != nil:
        chengFreeCompat(requestBuf)
    if responseBuf != nil:
        chengFreeCompat(responseBuf)
    if frameBuf != nil:
        chengFreeCompat(frameBuf)
    if addrLenMem != nil:
        chengFreeCompat(addrLenMem)
    if clientAddr != nil:
        chengFreeCompat(clientAddr)
    if listenerAddr != nil:
        chengFreeCompat(listenerAddr)
    cheng_runtime_close_if_open(serverFd)
    cheng_runtime_close_if_open(clientFd)
    cheng_runtime_close_if_open(listenerFd)
    return cheng_runtime_str_len(errWire) == 0 ? 1 : 0

@exportc("cheng_tcp_loopback_request_response_impl_bridge")
fn cheng_tcp_loopback_request_response_impl_bridge_export(protocolText: str,
                                                             requestWire: str,
                                                             responseWire: str,
                                                             clientResponseWire: var str,
                                                             errWire: var str): int32 =
    return cheng_tcp_loopback_request_response_fill(protocolText,
                                                       requestWire,
                                                       responseWire,
                                                       clientResponseWire,
                                                       errWire)

@exportc("cheng_tcp_loopback_request_response_bridge")
fn cheng_tcp_loopback_request_response_bridge_export(protocolText: str,
                                                        requestHex: str,
                                                        responseHex: str): uint64 =
    var requestWire: str = cheng_runtime_str_empty()
    var responseWire: str = cheng_runtime_str_empty()
    var decodeErr: str = cheng_runtime_str_empty()
    if !cheng_tcp_hex_decode_str(requestHex, requestWire, decodeErr):
        cheng_runtime_str_dispose(requestWire)
        cheng_runtime_str_dispose(responseWire)
        cheng_runtime_tcp_last_error_request_hex_decode(decodeErr)
        cheng_runtime_str_dispose(decodeErr)
        return uint64(0)
    if !cheng_tcp_hex_decode_str(responseHex, responseWire, decodeErr):
        cheng_runtime_str_dispose(requestWire)
        cheng_runtime_str_dispose(responseWire)
        cheng_runtime_tcp_last_error_response_hex_decode(decodeErr)
        cheng_runtime_str_dispose(decodeErr)
        return uint64(0)
    var clientResponseWire: str = cheng_runtime_str_empty()
    var errWire: str = cheng_runtime_str_empty()
    let ok: int32 = cheng_tcp_loopback_request_response_impl_bridge_export(protocolText,
                                                                              requestWire,
                                                                              responseWire,
                                                                              clientResponseWire,
                                                                              errWire)
    cheng_runtime_str_dispose(requestWire)
    cheng_runtime_str_dispose(responseWire)
    cheng_runtime_str_dispose(decodeErr)
    if ok == 0:
        cheng_runtime_str_dispose(clientResponseWire)
        cheng_runtime_tcp_last_error_loopback_request_response(errWire)
        cheng_runtime_str_dispose(errWire)
        return uint64(0)
    let handle: uint64 = cheng_buffer_handle_new_from_str(clientResponseWire)
    if handle == uint64(0):
        cheng_runtime_tcp_last_error_loopback_response_handle(errWire)
    else:
        cheng_runtime_tcp_last_error_clear()
    cheng_runtime_str_dispose(clientResponseWire)
    cheng_runtime_str_dispose(errWire)
    return handle
@exportc("cheng_tcp_loopback_request_response_handle_bridge")
fn cheng_tcp_loopback_request_response_handle_bridge_export(protocolText: str,
                                                               requestHandle: uint64,
                                                               responseHandle: uint64): uint64 =
    let requestRaw: ptr = ptr(requestHandle)
    let responseRaw: ptr = ptr(responseHandle)
    let requestLen: int32 = cheng_buffer_handle_len(requestRaw)
    let responseLen: int32 = cheng_buffer_handle_len(responseRaw)
    if requestLen < 0 || responseLen < 0:
        cheng_runtime_tcp_last_error_invalid_input_handle()
        return uint64(0)
    let requestWire: str = cheng_runtime_str_copy(cheng_buffer_handle_payload_ptr(requestRaw), requestLen)
    let responseWire: str = cheng_runtime_str_copy(cheng_buffer_handle_payload_ptr(responseRaw), responseLen)
    var clientResponseWire: str = cheng_runtime_str_empty()
    var errWire: str = cheng_runtime_str_empty()
    let ok: int32 = cheng_tcp_loopback_request_response_impl_bridge_export(protocolText,
                                                                              requestWire,
                                                                              responseWire,
                                                                              clientResponseWire,
                                                                              errWire)
    cheng_runtime_str_dispose(requestWire)
    cheng_runtime_str_dispose(responseWire)
    if ok == 0:
        cheng_runtime_str_dispose(clientResponseWire)
        cheng_runtime_tcp_last_error_loopback_handle_bridge(errWire)
        cheng_runtime_str_dispose(errWire)
        return uint64(0)
    let handle: uint64 = cheng_buffer_handle_new_from_str(clientResponseWire)
    if handle == uint64(0):
        cheng_runtime_tcp_last_error_loopback_input_handle(errWire)
    else:
        cheng_runtime_tcp_last_error_clear()
    cheng_runtime_str_dispose(clientResponseWire)
    cheng_runtime_str_dispose(errWire)
    return handle

@exportc("cheng_tcp_loopback_payload_bridge")
fn cheng_tcp_loopback_payload_bridge_export(protocolText: str,
                                               payloadHex: str): uint64 =
    return cheng_tcp_loopback_request_response_bridge_export(protocolText,
                                                                payloadHex,
                                                                payloadHex)

fn cheng_tcp_serve_payload_once_fill(hostText: str,
                                        port: int32,
                                        protocolText: str,
                                        payloadWire: str,
                                        readyPath: str,
                                        errWire: var str): int32 =
    errWire = cheng_runtime_str_empty()
    var listenerFd: int32 = -1
    var serverFd: int32 = -1
    let bindAddr: ptr = cheng_runtime_sockaddr_ipv4(hostText, port)
    let addrLenMem: ptr = chengAllocCompat(int32(sizeof(int32)))
    let frameBuf: ptr = chengAllocCompat(4)
    var protocolBuf: ptr = nil
    if port < 0 || port > 65535:
        errWire = cheng_runtime_error_str(" libp2p tcp: invalid port")
    if cheng_runtime_str_len(errWire) == 0 && bindAddr == nil:
        errWire = cheng_runtime_error_str(" libp2p tcp: invalid host")
    if cheng_runtime_str_len(errWire) == 0 && (addrLenMem == nil || frameBuf == nil):
        errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
    if cheng_runtime_str_len(errWire) == 0:
        listenerFd = socket(cheng_af_inet, cheng_sock_stream, cheng_ipproto_ip)
        if listenerFd < 0:
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: socket")
    if cheng_runtime_str_len(errWire) == 0:
        let reuse: int32 = 1
        setsockopt(listenerFd, cheng_sol_socket, cheng_so_reuseaddr, ptr(&reuse), int32(sizeof(int32)))
        if bind(listenerFd, bindAddr, cheng_sockaddr_in_len) != 0:
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: bind")
    if cheng_runtime_str_len(errWire) == 0 && listen(listenerFd, 8) != 0:
        errWire = cheng_runtime_tcp_error_str(" libp2p tcp: listen")
    if cheng_runtime_str_len(errWire) == 0:
        store_int32(addrLenMem, cheng_sockaddr_in_len)
        if getsockname(listenerFd, bindAddr, addrLenMem) != 0:
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: getsockname")
    if cheng_runtime_str_len(errWire) == 0:
        let boundPort: int32 = cheng_runtime_sockaddr_port(bindAddr)
        let readyOk: bool = cheng_runtime_write_ready_port(readyPath, boundPort, errWire)
        readyOk
    if cheng_runtime_str_len(errWire) == 0:
        serverFd = accept(listenerFd, nil, nil)
        if serverFd < 0:
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: accept")
    if cheng_runtime_str_len(errWire) == 0 && cheng_runtime_str_len(protocolText) > 0:
        let protocolLen: int32 = cheng_runtime_str_len(protocolText)
        protocolBuf = chengAllocCompat(protocolLen)
        if protocolBuf == nil:
            errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
        elif !cheng_runtime_recv_exact(serverFd, protocolBuf, protocolLen):
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: recv request")
        elif !cheng_runtime_bytes_equal(protocolBuf, cheng_runtime_str_data(protocolText), protocolLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: multistream request mismatch")
        elif !cheng_runtime_send_all(serverFd, cheng_runtime_str_data(protocolText), protocolLen):
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: send response")
    if cheng_runtime_str_len(errWire) == 0:
        cheng_runtime_write_u32be(frameBuf, uint32(cheng_runtime_str_len(payloadWire)))
        if !cheng_runtime_send_all(serverFd, frameBuf, 4):
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: send frame len")
        elif cheng_runtime_str_len(payloadWire) > 0 &&
             !cheng_runtime_send_all(serverFd, cheng_runtime_str_data(payloadWire), cheng_runtime_str_len(payloadWire)):
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: send payload")
    if protocolBuf != nil:
        chengFreeCompat(protocolBuf)
    if frameBuf != nil:
        chengFreeCompat(frameBuf)
    if addrLenMem != nil:
        chengFreeCompat(addrLenMem)
    if bindAddr != nil:
        chengFreeCompat(bindAddr)
    cheng_runtime_close_if_open(serverFd)
    cheng_runtime_close_if_open(listenerFd)
    if cheng_runtime_str_len(errWire) == 0:
        return 1
    return 0

@exportc("cheng_tcp_serve_payload_once_bridge")
fn cheng_tcp_serve_payload_once_bridge_export(hostText: str,
                                                 port: int32,
                                                 protocolText: str,
                                                 payloadHex: str,
                                                 readyPath: str): int32 =
    var payloadWire: str = cheng_runtime_str_empty()
    var errWire: str = cheng_runtime_str_empty()
    if !cheng_tcp_hex_decode_str(payloadHex, payloadWire, errWire):
        cheng_runtime_str_dispose(payloadWire)
        cheng_runtime_tcp_last_error_payload_hex_decode(errWire)
        cheng_runtime_str_dispose(errWire)
        return 0
    let ok: int32 = cheng_tcp_serve_payload_once_fill(hostText,
                                                         port,
                                                         protocolText,
                                                         payloadWire,
                                                         readyPath,
                                                         errWire)
    if ok != 0:
        cheng_runtime_tcp_last_error_clear()
    else:
        cheng_runtime_tcp_last_error_serve_payload_once(errWire)
    cheng_runtime_str_dispose(payloadWire)
    cheng_runtime_str_dispose(errWire)
    return ok

fn cheng_tcp_recv_payload_once_fill(hostText: str,
                                       port: int32,
                                       protocolText: str,
                                       responseWire: var str,
                                       errWire: var str): int32 =
    responseWire = cheng_runtime_str_empty()
    errWire = cheng_runtime_str_empty()
    var clientFd: int32 = -1
    let connectAddr: ptr = cheng_runtime_sockaddr_ipv4(hostText, port)
    let frameBuf: ptr = chengAllocCompat(4)
    var protocolBuf: ptr = nil
    var payloadBuf: ptr = nil
    if port < 0 || port > 65535:
        errWire = cheng_runtime_error_str(" libp2p tcp: invalid port")
    if cheng_runtime_str_len(errWire) == 0 && connectAddr == nil:
        errWire = cheng_runtime_error_str(" libp2p tcp: invalid host")
    if cheng_runtime_str_len(errWire) == 0 && frameBuf == nil:
        errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
    if cheng_runtime_str_len(errWire) == 0:
        clientFd = socket(cheng_af_inet, cheng_sock_stream, cheng_ipproto_ip)
        if clientFd < 0:
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: client socket")
    if cheng_runtime_str_len(errWire) == 0 && connect(clientFd, connectAddr, cheng_sockaddr_in_len) != 0:
        errWire = cheng_runtime_tcp_error_str(" libp2p tcp: connect")
    if cheng_runtime_str_len(errWire) == 0 && cheng_runtime_str_len(protocolText) > 0:
        let protocolLen: int32 = cheng_runtime_str_len(protocolText)
        protocolBuf = chengAllocCompat(protocolLen)
        if protocolBuf == nil:
            errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
        elif !cheng_runtime_send_all(clientFd, cheng_runtime_str_data(protocolText), protocolLen):
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: send request")
        elif !cheng_runtime_recv_exact(clientFd, protocolBuf, protocolLen):
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: recv response")
        elif !cheng_runtime_bytes_equal(protocolBuf, cheng_runtime_str_data(protocolText), protocolLen):
            errWire = cheng_runtime_error_str(" libp2p tcp: multistream response mismatch")
    if cheng_runtime_str_len(errWire) == 0 && !cheng_runtime_recv_exact(clientFd, frameBuf, 4):
        errWire = cheng_runtime_tcp_error_str(" libp2p tcp: recv frame len")
    let payloadLen: int32 = int32(cheng_runtime_read_u32be(frameBuf))
    if cheng_runtime_str_len(errWire) == 0 && payloadLen > 0:
        payloadBuf = chengAllocCompat(payloadLen)
        if payloadBuf == nil:
            errWire = cheng_runtime_error_str(" libp2p tcp: alloc failed")
        elif !cheng_runtime_recv_exact(clientFd, payloadBuf, payloadLen):
            errWire = cheng_runtime_tcp_error_str(" libp2p tcp: recv payload")
    if cheng_runtime_str_len(errWire) == 0:
        responseWire = cheng_runtime_str_copy(payloadBuf, payloadLen)
    if payloadBuf != nil:
        chengFreeCompat(payloadBuf)
    if protocolBuf != nil:
        chengFreeCompat(protocolBuf)
    if frameBuf != nil:
        chengFreeCompat(frameBuf)
    if connectAddr != nil:
        chengFreeCompat(connectAddr)
    cheng_runtime_close_if_open(clientFd)
    if cheng_runtime_str_len(errWire) == 0:
        return 1
    return 0

@exportc("cheng_tcp_recv_payload_once_impl_bridge")
fn cheng_tcp_recv_payload_once_impl_bridge_export(hostText: str,
                                                     port: int32,
