fn cheng_normalize_bind_sockaddr_linux(addr: ptr, len: int32, needFree: BoolPtr): ptr =
    if needFree != nil:
        *needFree = false
    if addr == nil || len != cheng_sockaddr_in_len:
        return addr
    let b0: uint8 = *(UInt8Ptr(addr))
    let b1: uint8 = *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 1)))
    if b0 == uint8(cheng_af_inet) && b1 == 0:
        return addr
    if b0 != uint8(cheng_sockaddr_in_len) || b1 != uint8(cheng_af_inet):
        return addr
    let normalized: ptr = chengAllocCompat(cheng_sockaddr_in_len)
    if normalized == nil:
        return addr
    cheng_bytes_copy(normalized, addr, int64(cheng_sockaddr_in_len))
    *(UInt8Ptr(normalized)) = uint8(cheng_af_inet)
    *(UInt8Ptr(cheng_rawmem_ptr_add(normalized, 1))) = uint8(0)
    if needFree != nil:
        *needFree = true
    return normalized
fn cheng_tcp_listener(port: int32, outPort: ptr): int32 =
    let fd: int32 = socket(cheng_af_inet, cheng_sock_stream, cheng_ipproto_ip)
    if fd < 0:
        return -1
    let sockOptVal: int32 = 1
    # Best effort socket options; ignore failures and keep listener usable.
    setsockopt(fd, cheng_sol_socket, cheng_so_reuseaddr, ptr(&sockOptVal), int32(sizeof(int32)))
    setsockopt(fd, cheng_sol_socket, cheng_so_reuseport, ptr(&sockOptVal), int32(sizeof(int32)))

    let addr: ptr = chengAllocCompat(cheng_sockaddr_in_len)
    if addr == nil:
        cheng_errno_code = 1
        close(fd)
        return -1
    cheng_bytes_set(addr, 0, cheng_sockaddr_in_len)
    *(UInt8Ptr(addr)) = uint8(cheng_af_inet)
    *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 1))) = uint8(0)
    *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 2))) = uint8((port >> 8) & 0xFF)
    *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 3))) = uint8(port & 0xFF)
    *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 4))) = uint8((cheng_inaddr_loopback >> 24) & 0xFF)
    *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 5))) = uint8((cheng_inaddr_loopback >> 16) & 0xFF)
    *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 6))) = uint8((cheng_inaddr_loopback >> 8) & 0xFF)
    *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 7))) = uint8(cheng_inaddr_loopback & 0xFF)

    let bindRes: int32 = bind(fd, addr, cheng_sockaddr_in_len)
    if bindRes < 0:
        # no-libc profile does not depend on libc getenv, keep fallback deterministic.
        let allowAny: bool
        if !allowAny:
            close(fd)
            chengFreeCompat(addr)
            return -1
        *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 4))) = uint8(0)
        *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 5))) = uint8(0)
        *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 6))) = uint8(0)
        *(UInt8Ptr(cheng_rawmem_ptr_add(addr, 7))) = uint8(0)
        if bind(fd, addr, cheng_sockaddr_in_len) < 0:
            close(fd)
            chengFreeCompat(addr)
            return -1

    let listenRes: int32 = listen(fd, 128)
    if listenRes != 0:
        close(fd)
        chengFreeCompat(addr)
        return -1

    if outPort != nil:
        let name: ptr = chengAllocCompat(cheng_sockaddr_in_len)
        if name == nil:
            close(fd)
            cheng_errno_code = 1
            chengFreeCompat(addr)
            return -1
        let namelen: ptr = chengAllocCompat(4)
        if namelen == nil:
            close(fd)
            chengFreeCompat(name)
            chengFreeCompat(addr)
            cheng_errno_code = 1
            return -1
        store(namelen, cheng_sockaddr_in_len)
        if getsockname(fd, name, namelen) != 0:
            close(fd)
            chengFreeCompat(name)
            chengFreeCompat(namelen)
            chengFreeCompat(addr)
            return -1
        let hiPortByte: int32 = int32(*(UInt8Ptr(cheng_rawmem_ptr_add(name, 2))))
        let loPortByte: int32 = int32(*(UInt8Ptr(cheng_rawmem_ptr_add(name, 3))))
        store(outPort, (hiPortByte << 8) | loPortByte)
        chengFreeCompat(name)
        chengFreeCompat(namelen)
    cheng_errno_code = 0
    chengFreeCompat(addr)
    return fd
fn cheng_errno(): int32 =
    return cheng_errno_code
fn cheng_strerror(err: int32): ptr =
    if err == 0:
        return "Success"
    if err == 1:
        return "Operation not permitted"
    if err == 2:
        return "No such file or directory"
    if err == 9:
        return "Bad file descriptor"
    if err == 11:
        return "Resource temporarily unavailable"
    if err == 12:
        return "Out of memory"
    if err == 13:
        return "Permission denied"
    if err == 22:
        return "Invalid argument"
    if err == 35:
        return "Operation would block"
    if err == 95:
        return "Operation not supported"
    if err == 97:
        return "Address family not supported by protocol"
    if err == 98:
        return "Address already in use"
    if err == 99:
        return "Cannot assign requested address"
    if err == 111:
        return "Connection refused"
    if err == 104:
        return "Connection reset by peer"
    if err == 125:
        return "Operation canceled"
    if err == 113:
        return "No route to host"
    if err == 115:
        return "Operation now in progress"
    if err == 116:
        return "Operation already in progress"
    if err == 32:
        return "Broken pipe"
    return "unknown error"

fn close(fd: int32): int32 =
    let ret: int64 = cheng_linux_syscall1(cheng_sys_close, int64(fd))
    if cheng_sys_is_err(ret):
        cheng_errno_code = int32(-ret)
        return -1
    cheng_errno_code = 0
    return 0

fn socket(domain: int32, typ: int32, protocol: int32): int32 =
    let ret: int64 = cheng_linux_syscall3(cheng_sys_socket, int64(domain), int64(typ), int64(protocol))
    if cheng_sys_is_err(ret):
        cheng_errno_code = int32(-ret)
        return -1
    cheng_errno_code = 0
    return int32(ret)

fn socketpair(domain: int32, typ: int32, protocol: int32, sv: ptr): int32 =
