fn cheng_runtime_ensure_getcwd_buf(minCap: int32): bool =
    if minCap <= cheng_getcwd_buf_cap && cheng_getcwd_buf != nil:
        return true
    var newCap: int32 = cheng_getcwd_buf_cap
    if newCap < 4096:
        newCap = 4096
    while newCap < minCap:
        if newCap > 1073741823:
            return false
        newCap = newCap * 2
    let nextBuf: ptr = chengHeapResize(cheng_getcwd_buf, newCap)
    if nextBuf == nil:
        return false
    cheng_getcwd_buf = nextBuf
    cheng_getcwd_buf_cap = newCap
    return true
fn cheng_getcwd(): ptr =
    if !cheng_runtime_ensure_getcwd_buf(4096):
        return ""
    let ret: int64 = cheng_linux_syscall2(cheng_sys_getcwd, uint64(cheng_getcwd_buf), int64(cheng_getcwd_buf_cap))
    if cheng_sys_is_err(ret) || ret <= 0:
        if cheng_sys_is_err(ret):
            cheng_errno_code = int32(-ret)
        return ""
    *(UInt8Ptr(ptr(uint64(cheng_getcwd_buf) + uint64(int32(ret) - 1)))) = uint8(0)
    cheng_errno_code = 0
    return cheng_getcwd_buf
