fn cheng_monotime_ns(): int64 =
    var ts: ChengLinuxTimespec
    let ret: int64 = cheng_linux_syscall2(cheng_sys_clock_gettime, int64(cheng_clock_monotonic), uint64(&ts))
    if cheng_sys_is_err(ret):
        return 0
    return ts.tvSec * int64(1000000000) + ts.tvNsec
fn cheng_list_dir(path: ptr): ptr =
    path
    return ""
fn cheng_read_file(path: ptr): ptr =
    if path == nil || cheng_strlen_runtime(path) <= 0:
        return ""
    let fd: int32 = cheng_runtime_openat(path, cheng_o_rdonly, 0)
    if fd < 0:
        return ""
    var st: ChengLinuxStat
    var sizeHint: int32
    if cheng_runtime_stat_path(path, &st) && st.stSize > 0 && st.stSize < int64(2147483646):
        sizeHint = int32(st.stSize)
    var cap: int32 = sizeHint + 1
    if cap < 256:
        cap = 256
    var out: ptr = chengAllocCompat(cap)
    if out == nil:
        close(fd)
        return ""
    var total: int32
    while true:
        if total + 64 >= cap:
            let nextCap: int32 = cap > 1073741823 ? cap : cap * 2
            let nextOut: ptr = chengHeapResize(out, nextCap)
            if nextOut == nil:
                close(fd)
                return ""
            out = nextOut
            cap = nextCap
        let readBuf: ptr = ptr(uint64(out) + uint64(total))
        let got: int32 = cheng_runtime_read_fd(fd, readBuf, cap - total - 1)
        if got < 0:
            close(fd)
            return ""
        if got == 0:
            break
        total = total + got
    *(UInt8Ptr(ptr(uint64(out) + uint64(total)))) = uint8(0)
    close(fd)
    return out
fn cheng_write_file(path: ptr, content: ptr): int32 =
    if path == nil || cheng_strlen_runtime(path) <= 0:
        return 0
    let fd: int32 = cheng_runtime_openat(path, cheng_o_wronly | cheng_o_creat | cheng_o_trunc, cheng_mode_0644)
    if fd < 0:
        return 0
    let n: int32 = cheng_strlen_runtime(content)
    let ok: bool = n <= 0 || cheng_runtime_write_fd(fd, content, n) >= 0
    close(fd)
    return ok ? 1 : 0
