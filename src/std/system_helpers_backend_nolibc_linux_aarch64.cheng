fn cheng_strformat_join_runtime(parts: str[], sep: str): str =
    if parts.len <= 0:
        return cheng_runtime_str_empty()
    let sepLen: int32 = cheng_runtime_str_len(sep)
    let sepData: ptr = cheng_runtime_str_data(sep)
    var total: int32
    for i in 0..<parts.len:
        if i > 0:
            total = total + sepLen
        total = total + cheng_runtime_str_len(parts[i])
    let outRaw: ptr = driver_c_new_string_export(total)
    if outRaw == nil:
        return cheng_runtime_str_empty()
    var writeAt: int32
    for i in 0..<parts.len:
        if i > 0 && sepLen > 0:
            cheng_bytes_copy(cheng_rawmem_ptr_add(outRaw, writeAt), sepData, int64(sepLen))
            writeAt = writeAt + sepLen
        let part: str = parts[i]
        let partLen: int32 = cheng_runtime_str_len(part)
        if partLen > 0:
            cheng_bytes_copy(cheng_rawmem_ptr_add(outRaw, writeAt),
                             cheng_runtime_str_data(part),
                             int64(partLen))
            writeAt = writeAt + partLen
    let out: str = cheng_runtime_str_view_owned(outRaw, total)
    return out

