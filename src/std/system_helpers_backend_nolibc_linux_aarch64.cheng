    if out_raw == nil:
        return
    let outPtr: ChengErrorInfoBridgeCompatPtr = ChengErrorInfoBridgeCompatPtr(out_raw)
    let empty: str = cheng_runtime_str_empty()
    outPtr->code = 0
    outPtr->msg.data = empty.data
    outPtr->msg.len = empty.len
    outPtr->msg.store_id = empty.store_id
    outPtr->msg.flags = empty.flags

