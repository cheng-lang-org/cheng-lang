    if buf == nil || size <= 0 || n <= 0:
        return 0
    let totalBytes: int64 = size * n
    if totalBytes <= 0 || totalBytes > int64(2147483647):
        return 0
    let wrote: int32 = cheng_runtime_write_fd(cheng_runtime_stream_fd(stream), buf, int32(totalBytes))
    if wrote < 0:
        return 0
    return int32(int64(wrote) / size)

