    return out

@exportc("cheng_mm_diag_reset")
fn cheng_mm_diag_reset() =
    cheng_runtime_lock()
    cheng_mm_retain_total = 0
    cheng_mm_release_total = 0
    cheng_runtime_unlock()

fn cheng_write_all(fd: int32, data: ptr, len: int64): int32 =
    if data == nil || len <= 0:
        return 0
    var off: int64
    while off < len:
        let n: int64 = cheng_linux_syscall3(cheng_sys_write,
                                            int64(fd),
                                            int64(uint64(cheng_rawmem_ptr_add(data, int32(off)))),
                                            len - off)
        if n == -4:
            continue
        if n <= 0:
            return -1
        off = off + n
    return 0

fn puts(text: ptr): int32 =
    var s: ptr = text
    if s == nil:
        s = "(null)"
    let n: int64 = int64(cheng_strlen_runtime(s))
    if cheng_write_all(1, ptr(s), n) != 0:
        return -1
    var nl: char = '\n'
    if cheng_write_all(1, ptr(&nl), 1) != 0:
        return -1
    return 0

fn cheng_puts(text: ptr): int32 =
    var s: ptr = text
    if s == nil:
        s = "(null)"
    let n: int64 = int64(cheng_strlen_runtime(s))
    if cheng_write_all(1, ptr(s), n) != 0:
        return -1
    var nl: char = '\n'
    if cheng_write_all(1, ptr(&nl), 1) != 0:
        return -1
    return 0

fn cheng_exit(code: int32) =
    cheng_linux_syscall1(cheng_sys_exit_group, int64(code))
    cheng_linux_syscall1(cheng_sys_exit, int64(code))
    while true:
        0

fn cheng_bounds_check(len: int32, idx: int32) =
    if idx < 0 || idx >= len:
        cheng_puts("cheng: bounds check failed")
        cheng_exit(1)

fn cheng_index_ptr(base: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    cheng_bounds_check(len, idx)
    if base == nil || elemSize <= 0:
        return base
    let off: int64 = int64(idx) * int64(elemSize)
    return cheng_rawmem_ptr_add(base, int32(off))

fn cheng_seq_get(buffer: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    return cheng_index_ptr(buffer, len, idx, elemSize)

fn cheng_seq_set(buffer: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    return cheng_index_ptr(buffer, len, idx, elemSize)

@weak
fn paramCount(): int32 =
    if cheng_saved_argc > 0 && cheng_saved_argv != nil:
        return cheng_saved_argc
    return 0

@weak
fn paramStr(i: int32): str =
    if i < 0 || i >= paramCount() || cheng_saved_argv == nil:
        return cheng_runtime_str_empty()
    let slot: VoidPtrPtr = VoidPtrPtr(ptr(uint64(cheng_saved_argv) + uint64(i * cheng_ptr_size())))
    let raw: ptr = *slot
    if raw == nil:
        return cheng_runtime_str_empty()
    var out: str
    out.data = raw
    out.len = cheng_strlen_runtime(raw)
    out.store_id = 0
    out.flags = 0
    return out

fn cheng_runtime_param_raw(i: int32): ptr =
    if i < 0 || i >= paramCount() || cheng_saved_argv == nil:
        return nil
    let slot: VoidPtrPtr = VoidPtrPtr(ptr(uint64(cheng_saved_argv) + uint64(i * cheng_ptr_size())))
    let raw: ptr = *slot
    if raw == nil:
        return ""
    return raw

fn cheng_runtime_param_copy_raw(i: int32): ptr =
    let raw: ptr = cheng_runtime_param_raw(i)
    if raw == nil:
        return driver_c_new_string_export(0)
    let out: ptr = cheng_runtime_string_copy(raw, cheng_strlen_runtime(raw))
    if out == nil:
        return ""
    return out

fn cheng_env_name_matches(entry: ptr, name: ptr, nameLen: int32): bool =
    if entry == nil || name == nil || nameLen <= 0:
        return false
    var i: int32
    for i in i..<nameLen:
        if *(UInt8Ptr(cheng_rawmem_ptr_add(entry, i))) != *(UInt8Ptr(cheng_rawmem_ptr_add(name, i))):
            return false
    return *(UInt8Ptr(cheng_rawmem_ptr_add(entry, nameLen))) == uint8(int32('='))

@exportc("getenv")
fn cheng_getenv_export(name: ptr): ptr =
    if name == nil || cheng_saved_envp == nil:
        return nil
    let nameLen: int32 = cheng_strlen_runtime(name)
    if nameLen <= 0:
        return nil
    var slot: VoidPtrPtr = VoidPtrPtr(cheng_saved_envp)
    while slot != nil:
        let entry: ptr = *slot
        if entry == nil:
            return nil
        if cheng_env_name_matches(entry, name, nameLen):
            return cheng_rawmem_ptr_add(entry, nameLen + 1)
        slot = VoidPtrPtr(cheng_rawmem_ptr_add(ptr(slot), cheng_ptr_size()))
    return nil

fn __cheng_next_cap(curCap: int32, need: int32): int32 =
    if need <= 0:
        return need
    var cap: int32 = curCap
    if cap < 4:
        cap = 4
    while cap < need:
        let doubled: int32 = cap * 2
        if doubled <= 0:
            return need
        cap = doubled
    return cap

@weak
fn reserve(seq: ptr, newCap: int32) =
    if seq == nil:
        return
    if newCap < 0:
        return
    let seqHdr: ChengSeqHeaderPtr = ChengSeqHeaderPtr(seq)
    if seqHdr->buffer != nil && newCap <= seqHdr->cap:
        return
    if newCap == 0:
        return
    let targetCap: int32 = __cheng_next_cap(seqHdr->cap, newCap)
    if targetCap <= 0:
        return
    let newBuf: ptr = chengHeapResize(seqHdr->buffer, targetCap)
    if newBuf == nil:
        return
    seqHdr->buffer = newBuf
    seqHdr->cap = targetCap

# Compatibility alias for stage0/seed outputs that still reference
# the legacy monomorphized reserve symbol name.
@weak
fn reserve_ptr_void(seq: ptr, newCap: int32) =
    reserve(seq, newCap)

@weak
fn setLen(seq: ptr, newLen: int32) =
    if seq == nil:
        return
    let seqHdr: ChengSeqHeaderPtr = ChengSeqHeaderPtr(seq)
    var target: int32 = newLen
    if target < 0:
        target = 0
    if target > seqHdr->cap:
        reserve(seqHdr, target)
    seqHdr->len = target

fn cheng_seq_set_grow(seqPtr: ptr, idx: int32, elemSize: int32): ptr =
    if seqPtr == nil || elemSize <= 0:
        return cheng_index_ptr(nil, 0, idx, elemSize)
    let seqHdr: ChengSeqHeaderPtr = ChengSeqHeaderPtr(seqPtr)
    if idx < 0:
        return cheng_index_ptr(seqHdr->buffer, seqHdr->len, idx, elemSize)
    let needLen: int32 = idx + 1
    if needLen > seqHdr->cap || seqHdr->buffer == nil:
        var newCap: int32 = seqHdr->cap
        if newCap < 4:
            newCap = 4
        while newCap < needLen:
            let doubled: int32 = newCap * 2
            if doubled <= 0:
                newCap = needLen
                break
            newCap = doubled
        let oldCap: int32 = seqHdr->cap
        let bytes: int64 = int64(newCap) * int64(elemSize)
        let newBuf: ptr = chengHeapResize(seqHdr->buffer, int32(bytes))
        if newBuf == nil:
            return cheng_index_ptr(seqHdr->buffer, seqHdr->len, idx, elemSize)
        if newCap > oldCap:
            let off: int64 = int64(oldCap) * int64(elemSize)
            let zeroBytes: int64 = (int64(newCap) - int64(oldCap)) * int64(elemSize)
            cheng_bytes_set(cheng_rawmem_ptr_add(newBuf, int32(off)), 0, zeroBytes)
        seqHdr->buffer = newBuf
        seqHdr->cap = newCap
    if needLen > seqHdr->len:
        seqHdr->len = needLen
    return cheng_index_ptr(seqHdr->buffer, seqHdr->len, idx, elemSize)

fn cheng_slice_get(ptr: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    return cheng_index_ptr(ptr, len, idx, elemSize)

fn cheng_slice_set(ptr: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    return cheng_index_ptr(ptr, len, idx, elemSize)

@exportc("__cheng_call_indirect_void")
fn __cheng_call_indirect_void_export(fn_ptr: ptr, ctx: ptr) =
    let _ = fn_ptr
    let _ = ctx
    return

@exportc("__cheng_call_indirect_i32")
fn __cheng_call_indirect_i32_export(fn_ptr: ptr, ctx: int64, a: int32, b: int32): int32 =
    let _ = fn_ptr
    let _ = ctx
    let _ = a
    let _ = b
    return 0

fn cheng_thread_handle_destroy(handle: ChengLinuxThreadHandlePtr) =
    if handle == nil:
        return
    let stackBase = handle->stackBase
    let stackSize = handle->stackSize
    let cleanupStackBase = handle->cleanupStackBase
    let cleanupStackSize = handle->cleanupStackSize
    handle->stackBase = nil
    handle->cleanupStackBase = nil
    handle->stackSize = 0
    handle->cleanupStackSize = 0
    if stackBase != nil && stackSize > 0:
        let _ = cheng_munmap_region(stackBase, stackSize)
    if cleanupStackBase != nil && cleanupStackSize > 0:
        let _ = cheng_munmap_region(cleanupStackBase, cleanupStackSize)
    let _ = cheng_munmap_region(ptr(handle), cheng_page_size)

fn cheng_thread_tid_addr(handle: ChengLinuxThreadHandlePtr): ptr =
    if handle == nil:
        return nil
    return ptr(&handle->tidWord)

fn cheng_thread_wait_tid_zero(handle: ChengLinuxThreadHandlePtr): bool =
    if handle == nil:
        return false
    let addr = cheng_thread_tid_addr(handle)
    if addr == nil:
        return false
    while true:
        let tid = cheng_atomic_load_i32(addr)
        if tid == 0:
            return true
        let _ = cheng_linux_syscall6(cheng_sys_futex,
                                    int64(uint64(addr)),
                                    cheng_futex_wait_private,
                                    int64(tid),
                                    0,
                                    0,
                                    0)

@exportc("cheng_spawn")
fn cheng_spawn(fn_ptr: ptr, ctx: ptr) =
    if cheng_thread_spawn(fn_ptr, ctx) == 0:
        cheng_puts("cheng_thread_spawn_failed")
        cheng_exit(1)

@exportc("cheng_thread_spawn")
fn cheng_thread_spawn(fn_ptr: ptr, ctx: ptr): int32 =
    let thread = cheng_thread_start(fn_ptr, ctx)
    if thread == nil:
        return 0
    return cheng_thread_detach(thread)

@exportc("cheng_thread_start")
fn cheng_thread_start(fn_ptr: ptr, ctx: ptr): ptr =
    if fn_ptr == nil:
        return nil
    let handleMem = chengMapPages(cheng_page_size)
    if handleMem == nil:
        return nil
    let stack = chengMapPages(cheng_thread_stack_size)
    if stack == nil:
        let _ = cheng_munmap_region(handleMem, cheng_page_size)
        return nil
    let cleanupStack = chengMapPages(cheng_thread_cleanup_stack_size)
    if cleanupStack == nil:
        let _ = cheng_munmap_region(stack, cheng_thread_stack_size)
        let _ = cheng_munmap_region(handleMem, cheng_page_size)
        return nil
    let handle: ChengLinuxThreadHandlePtr = ChengLinuxThreadHandlePtr(handleMem)
    handle->stackBase = stack
    handle->cleanupStackBase = cleanupStack
    handle->stackSize = cheng_thread_stack_size
    handle->cleanupStackSize = cheng_thread_cleanup_stack_size
    handle->tidWord = 0
    handle->state = 0
    let stackTop = ptr(uint64(stack) + uint64(cheng_thread_stack_size))
    let tid = cheng_linux_thread_start_raw(fn_ptr, ctx, stackTop, handleMem)
    if tid <= 0 || cheng_sys_is_err(tid):
        let _ = cheng_munmap_region(cleanupStack, cheng_thread_cleanup_stack_size)
        let _ = cheng_munmap_region(stack, cheng_thread_stack_size)
        let _ = cheng_munmap_region(handleMem, cheng_page_size)
        return nil
    return handleMem

@exportc("cheng_thread_join")
fn cheng_thread_join(handle: ptr): int32 =
    if handle == nil:
        return 0
    let h: ChengLinuxThreadHandlePtr = ChengLinuxThreadHandlePtr(handle)
    if h->state != 0 && h->state != 2:
        return 0
    if !cheng_thread_wait_tid_zero(h):
        return 0
    h->state = 2
    cheng_thread_handle_destroy(h)
    return 1

@exportc("cheng_thread_detach")
fn cheng_thread_detach(handle: ptr): int32 =
    if handle == nil:
        return 0
    let h: ChengLinuxThreadHandlePtr = ChengLinuxThreadHandlePtr(handle)
    let statePtr = ptr(&h->state)
    if cheng_atomic_cas_i32(statePtr, 0, 1) != 0:
        return 1
    if cheng_atomic_load_i32(statePtr) == 2:
        if !cheng_thread_wait_tid_zero(h):
            return 0
        cheng_thread_handle_destroy(h)
        return 1
    return 0

@exportc("cheng_thread_spawn_i32")
fn cheng_thread_spawn_i32(fn_ptr: ptr, ctx: int32): int32 =
    let thread = cheng_thread_start(fn_ptr, ptr(uint64(uint32(ctx))))
    if thread == nil:
        return 0
    return cheng_thread_detach(thread)

@exportc("cheng_thread_parallelism")
fn cheng_thread_parallelism(): int32 =
    return cheng_system_cpu_logical_cores_bridge_export()

@exportc("cheng_thread_yield")
fn cheng_thread_yield() =
    let _ = cheng_linux_syscall0(cheng_sys_sched_yield)

var
    cheng_thread_local_i32_slot0: int32
    cheng_thread_local_i32_slot1: int32
    cheng_thread_local_i32_slot2: int32
    cheng_thread_local_i32_slot3: int32

fn cheng_thread_local_i32_get(slot: int32): int32 =
    if slot == 0:
        return cheng_thread_local_i32_slot0
    if slot == 1:
        return cheng_thread_local_i32_slot1
    if slot == 2:
        return cheng_thread_local_i32_slot2
    if slot == 3:
        return cheng_thread_local_i32_slot3
    return 0

fn cheng_thread_local_i32_set(slot: int32, value: int32) =
    if slot == 0:
        cheng_thread_local_i32_slot0 = value
    elif slot == 1:
        cheng_thread_local_i32_slot1 = value
