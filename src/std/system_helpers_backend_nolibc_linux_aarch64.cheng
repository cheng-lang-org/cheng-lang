        return
    cheng_linux_atomic_store_i32(p, val)

@exportc("cheng_atomic_load_i32")
fn cheng_atomic_load_i32(p: ptr): int32 =
    if p == nil:
        return 0
    return cheng_linux_atomic_load_i32(p)

@exportc("cheng_mm_retain_count")
fn cheng_mm_retain_count(): int64 =
    cheng_runtime_lock()
    let out = cheng_mm_retain_total
    cheng_runtime_unlock()
    return out

@exportc("cheng_mm_release_count")
fn cheng_mm_release_count(): int64 =
    cheng_runtime_lock()
    let out = cheng_mm_release_total
    cheng_runtime_unlock()
    return out

@exportc("cheng_mm_alloc_count")
fn cheng_mm_alloc_count(): int64 =
