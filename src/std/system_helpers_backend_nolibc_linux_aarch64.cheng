@exportc("store")
fn store_str_export(p: ptr, val: str) =
    if p == nil:
        return
    let pp: StrPtr = StrPtr(p)
    var next: str = val
    if val.flags != chengStrFlagOwned && val.data != nil && val.len > 0:
        next = cheng_runtime_str_copy(val.data, val.len)
    elif val.flags == chengStrFlagOwned && val.data != nil:
        cheng_mem_retain(val.data)
    var prev: str
    prev.data = pp->data
    prev.len = pp->len
    prev.store_id = pp->store_id
    prev.flags = pp->flags
    if prev.flags == chengStrFlagOwned && prev.data != nil:
        cheng_mem_release(prev.data)
    pp->data = next.data
    pp->len = next.len
    pp->store_id = next.store_id
    pp->flags = next.flags

