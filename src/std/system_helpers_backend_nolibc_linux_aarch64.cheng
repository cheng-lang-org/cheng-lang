fn __addr(value: int64): int64 = value
fn _addr(value: int64): int64 = value

fn cheng_runtime_str_empty(): str =
    var out: str
    out.data = nil
    out.len = 0
    out.store_id = 0
    out.flags = 0
    return out

fn cheng_runtime_str_view_owned(data: ptr, len: int32): str =
    var out: str
    if data != nil && len > 0:
        out.data = data
        out.len = len
        out.store_id = 0
        out.flags = chengStrFlagOwned
    return out

fn cheng_runtime_str_len(s: str): int32 =
    if s.data == nil || s.len <= 0:
        return 0
    return s.len

fn cheng_runtime_str_data(s: str): ptr =
    if s.data == nil || s.len <= 0:
        return nil
    return s.data

fn cheng_runtime_string_copy(raw: ptr, n0: int32): ptr =
    var n: int32 = n0
    if n < 0:
        n = 0
    let out: ptr = chengAllocCompat(n + 1)
    if out == nil:
        return nil
    cheng_bytes_set(out, 0, int64(n + 1))
    if raw != nil && n > 0:
        cheng_bytes_copy(out, raw, int64(n))
    return out

fn cheng_runtime_str_copy(raw: ptr, n: int32): str =
    let outRaw: ptr = cheng_runtime_string_copy(raw, n)
    if outRaw == nil:
        return cheng_runtime_str_empty()
    return cheng_runtime_str_view_owned(outRaw, n)

fn cheng_runtime_str_dispose(value: var str) =
    if value.flags == chengStrFlagOwned && value.data != nil:
        chengFreeCompat(value.data)
    value = cheng_runtime_str_empty()

fn cheng_exec_program_seq_add(out: var str[], value: str) =
    let seqPtr: ptr = &out
    let hdr: ChengSeqHeaderPtr = ChengSeqHeaderPtr(seqPtr)
    let slot: ptr = cheng_seq_set_grow(seqPtr, hdr->len, int32(sizeof(str)))
    store_str_export(slot, value)

fn driver_c_raw_env_truthy(name: ptr): bool =
    let raw: ptr = cheng_getenv_export(name)
    if raw == nil:
        return false
    let n: int32 = cheng_strlen_runtime(raw)
    if n <= 0:
        return false
    if n == 1 && *(UInt8Ptr(raw)) == uint8(int32('0')):
        return false
    if n == 5 && cheng_runtime_bytes_equal(raw, "false", 5):
        return false
    return true

fn driver_c_progress_line(phase: str,
                           status: str): str =
    var p0: str = driver_c_str_concat_bridge_export("compile_progress phase=", phase)
    var p1: str = driver_c_str_concat_bridge_export(p0, " status=")
    let line: str = driver_c_str_concat_bridge_export(p1, status)
    cheng_runtime_str_dispose(p0)
    cheng_runtime_str_dispose(p1)
    return line

@exportc("cheng_tcp_bridge_str_dispose_bridge")
fn cheng_tcp_bridge_str_dispose_bridge_export(value: var str) =
    cheng_runtime_str_dispose(value)

fn cheng_runtime_error_str(text: ptr): str =
    if text == nil:
        return cheng_runtime_str_empty()
    return cheng_runtime_str_copy(text, cheng_strlen_runtime(text))

fn cheng_runtime_bytes_equal(a: ptr, b: ptr, n: int32): bool =
    if n <= 0:
        return true
    if a == b:
        return true
    if a == nil || b == nil:
        return false
    var i: int32
    for i in i..<n:
        let av: uint8 = *(UInt8Ptr(ptr(uint64(a) + uint64(i))))
        let bv: uint8 = *(UInt8Ptr(ptr(uint64(b) + uint64(i))))
        if av != bv:
            return false
    return true

fn cheng_runtime_write_u32be(dst: ptr, value: uint32) =
    if dst == nil:
        return
    *(UInt8Ptr(dst)) = uint8((value >> uint32(24)) & uint32(0xff))
    *(UInt8Ptr(ptr(uint64(dst) + uint64(1)))) = uint8((value >> uint32(16)) & uint32(0xff))
    *(UInt8Ptr(ptr(uint64(dst) + uint64(2)))) = uint8((value >> uint32(8)) & uint32(0xff))
    *(UInt8Ptr(ptr(uint64(dst) + uint64(3)))) = uint8(value & uint32(0xff))

fn cheng_runtime_read_u32be(src: ptr): uint32 =
    if src == nil:
        return uint32(0)
    let b0: uint32 = uint32(*(UInt8Ptr(src)))
    let b1: uint32 = uint32(*(UInt8Ptr(ptr(uint64(src) + uint64(1)))))
    let b2: uint32 = uint32(*(UInt8Ptr(ptr(uint64(src) + uint64(2)))))
    let b3: uint32 = uint32(*(UInt8Ptr(ptr(uint64(src) + uint64(3)))))
    return (b0 << uint32(24)) | (b1 << uint32(16)) | (b2 << uint32(8)) | b3

fn cheng_runtime_send_all(fd: int32, data: ptr, len: int32): bool =
    if len <= 0:
        return true
    if data == nil:
        return false
    var off: int32
    while off < len:
        let wrote: int32 = send(fd, ptr(uint64(data) + uint64(off)), len - off, 0)
        if wrote <= 0:
            return false
        off = off + wrote
    return true

fn cheng_runtime_recv_exact(fd: int32, data: ptr, len: int32): bool =
    if len <= 0:
        return true
    if data == nil:
        return false
    var off: int32
    while off < len:
        let got: int32 = recv(fd, ptr(uint64(data) + uint64(off)), len - off, 0)
        if got <= 0:
            return false
        off = off + got
    return true

fn cheng_runtime_sockaddr_loopback(port: int32): ptr =
    let addr: ptr = chengAllocCompat(cheng_sockaddr_in_len)
    if addr == nil:
        return nil
    cheng_bytes_set(addr, 0, cheng_sockaddr_in_len)
    *(UInt8Ptr(addr)) = uint8(cheng_af_inet)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(1)))) = uint8(0)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(2)))) = uint8((port >> 8) & 0xff)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(3)))) = uint8(port & 0xff)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(4)))) = uint8((cheng_inaddr_loopback >> 24) & 0xff)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(5)))) = uint8((cheng_inaddr_loopback >> 16) & 0xff)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(6)))) = uint8((cheng_inaddr_loopback >> 8) & 0xff)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(7)))) = uint8(cheng_inaddr_loopback & 0xff)
    return addr

fn cheng_runtime_close_if_open(fd: int32) =
    if fd >= 0:
        close(fd)

fn cheng_runtime_str_has_prefix(text: str, prefix: str): bool =
    let textLen: int32 = cheng_runtime_str_len(text)
    let prefixLen: int32 = cheng_runtime_str_len(prefix)
    if prefixLen <= 0:
        return true
    if prefixLen > textLen:
        return false
    return cheng_runtime_bytes_equal(cheng_runtime_str_data(text), cheng_runtime_str_data(prefix), prefixLen)

fn cheng_runtime_str_contains(text: str, sub: str): bool =
    let textLen: int32 = cheng_runtime_str_len(text)
    let subLen: int32 = cheng_runtime_str_len(sub)
    if subLen <= 0:
        return true
    if textLen < subLen:
        return false
    let textData: ptr = cheng_runtime_str_data(text)
    let subData: ptr = cheng_runtime_str_data(sub)
    var i: int32
    while i + subLen <= textLen:
        if cheng_runtime_bytes_equal(ptr(uint64(textData) + uint64(i)), subData, subLen):
            return true
        i = i + 1
    return false

fn cheng_runtime_str_slice(text: str, start: int32, count: int32): str =
    let textLen: int32 = cheng_runtime_str_len(text)
    if count <= 0 || textLen <= 0:
        return cheng_runtime_str_empty()
    var s0: int32 = start
    if s0 < 0:
        s0 = 0
    if s0 >= textLen:
        return cheng_runtime_str_empty()
    var need: int32 = count
    if s0 + need > textLen:
        need = textLen - s0
    return cheng_runtime_str_copy(ptr(uint64(cheng_runtime_str_data(text)) + uint64(s0)), need)

fn cheng_runtime_flag_key_matches(arg: str, key: str): bool =
    return driver_c_str_eq_bridge_export(arg, key) != 0

fn cheng_runtime_flag_inline_value(arg: str, key: str, outValue: var str): bool =
    outValue = cheng_runtime_str_empty()
    let keyLen: int32 = cheng_runtime_str_len(key)
    let argLen: int32 = cheng_runtime_str_len(arg)
    if keyLen <= 0 || argLen <= keyLen:
        return false
    if !cheng_runtime_str_has_prefix(arg, key):
        return false
    let sep: uint8 = *(UInt8Ptr(ptr(uint64(cheng_runtime_str_data(arg)) + uint64(keyLen))))
    if sep != uint8(':') && sep != uint8('='):
        return false
    outValue = cheng_runtime_str_copy(ptr(uint64(cheng_runtime_str_data(arg)) + uint64(keyLen + 1)),
                                      argLen - keyLen - 1)
    return true

fn cheng_runtime_parse_int32(text: str, defaultValue: int32): int32 =
    let n: int32 = cheng_runtime_str_len(text)
    if n <= 0:
        return defaultValue
    var sign: int64 = 1
    var i: int32
    let data: ptr = cheng_runtime_str_data(text)
    if *(UInt8Ptr(data)) == uint8('+'):
        i = 1
    elif *(UInt8Ptr(data)) == uint8('-'):
        sign = -1
        i = 1
    if i >= n:
        return defaultValue
    var value: int64
    for i in i..<n:
        let ch: uint8 = *(UInt8Ptr(ptr(uint64(data) + uint64(i))))
        if ch < uint8('0') || ch > uint8('9'):
            return defaultValue
        value = value * int64(10) + int64(int32(ch) - int32('0'))
    value = value * sign
    if value < int64(-2147483648) || value > int64(2147483647):
        return defaultValue
    return int32(value)

fn cheng_runtime_mkdir_if_needed(path: ptr) =
    if path == nil || cheng_strlen_runtime(path) <= 0:
        return
    if cheng_dir_exists(path) != 0:
        return
    if cheng_mkdir1(path) == 0:
        return
    if cheng_dir_exists(path) != 0:
        return
    cheng_puts("cheng linux nolibc: mkdir failed")
    cheng_exit(1)

fn cheng_runtime_mkdir_all_raw(path: ptr, includeLeaf: bool) =
    if path == nil:
        return
    let work: ptr = cheng_runtime_string_copy(path, cheng_strlen_runtime(path))
    if work == nil:
        cheng_puts("cheng linux nolibc: mkdir_all alloc failed")
        cheng_exit(1)
    let n: int32 = cheng_strlen_runtime(work)
    var i: int32 = if n > 0 && *(UInt8Ptr(work)) == uint8('/'): 1 else: 0
    for i in i..<n:
        let ch: uint8 = *(UInt8Ptr(ptr(uint64(work) + uint64(i))))
        if ch == uint8('/') || ch == uint8('\\'):
            *(UInt8Ptr(ptr(uint64(work) + uint64(i)))) = uint8(0)
            cheng_runtime_mkdir_if_needed(work)
            *(UInt8Ptr(ptr(uint64(work) + uint64(i)))) = ch
    if includeLeaf:
        cheng_runtime_mkdir_if_needed(work)
    chengFreeCompat(work)

fn cheng_runtime_last_sep(path: ptr): int32 =
    if path == nil:
        return -1
    let n: int32 = cheng_strlen_runtime(path)
    var last: int32 = -1
    var i: int32
    for i in i..<n:
        let ch: uint8 = *(UInt8Ptr(ptr(uint64(path) + uint64(i))))
        if ch == uint8('/') || ch == uint8('\\'):
            last = i
    return last

fn cheng_runtime_prepare_parent_dirs(path: ptr) =
    let lastSep: int32 = cheng_runtime_last_sep(path)
    if lastSep <= 0:
        return
    let saved: uint8 = *(UInt8Ptr(ptr(uint64(path) + uint64(lastSep))))
    *(UInt8Ptr(ptr(uint64(path) + uint64(lastSep)))) = uint8(0)
    cheng_runtime_mkdir_all_raw(path, true)
    *(UInt8Ptr(ptr(uint64(path) + uint64(lastSep)))) = saved

fn cheng_runtime_write_text_file_raw(path: ptr, contentData: ptr, contentLen: int32): bool =
    if path == nil || cheng_strlen_runtime(path) <= 0:
        return false
    cheng_runtime_prepare_parent_dirs(path)
    let fd: int32 = cheng_runtime_openat(path, cheng_o_wronly | cheng_o_creat | cheng_o_trunc, cheng_mode_0644)
    if fd < 0:
        return false
    let ok: bool = contentLen <= 0 || cheng_runtime_write_fd(fd, contentData, contentLen) >= 0
    close(fd)
    return ok

fn cheng_runtime_tcp_error_str(prefix: ptr): str =
    let base: str = cheng_runtime_error_str(prefix)
    let textPtr: ptr = cheng_strerror(cheng_errno())
    let text: str = cheng_runtime_error_str(textPtr == nil ? "unknown" : textPtr)
    let code: str = cheng_runtime_error_str(driver_c_i32_to_str_export(cheng_errno()))
    return driver_c_str_concat_bridge_export(driver_c_str_concat_bridge_export(driver_c_str_concat_bridge_export(base, ": "),
                                                                              text),
                                            driver_c_str_concat_bridge_export(" (",
                                                                              driver_c_str_concat_bridge_export(code, ")")))

fn cheng_runtime_parse_ipv4_host(hostText: str, outAddr: ptr): bool =
    if outAddr == nil:
        return false
    cheng_bytes_set(outAddr, 0, 4)
    let n: int32 = cheng_runtime_str_len(hostText)
    if n <= 0:
        *(UInt8Ptr(outAddr)) = uint8(127)
        *(UInt8Ptr(ptr(uint64(outAddr) + uint64(1)))) = uint8(0)
        *(UInt8Ptr(ptr(uint64(outAddr) + uint64(2)))) = uint8(0)
        *(UInt8Ptr(ptr(uint64(outAddr) + uint64(3)))) = uint8(1)
        return true
    var octetIndex: int32
    var value: int32
    var hasDigit: bool
    let data: ptr = cheng_runtime_str_data(hostText)
    var i: int32
    for i in i..<n:
        let ch: uint8 = *(UInt8Ptr(ptr(uint64(data) + uint64(i))))
        if ch >= uint8('0') && ch <= uint8('9'):
            value = value * 10 + int32(ch - uint8('0'))
            if value > 255:
                return false
            hasDigit = true
        elif ch == uint8('.'):
            if !hasDigit || octetIndex >= 3:
                return false
            *(UInt8Ptr(ptr(uint64(outAddr) + uint64(octetIndex)))) = uint8(value)
            octetIndex = octetIndex + 1
            value = 0
            hasDigit = false
        else:
            return false
    if !hasDigit || octetIndex != 3:
        return false
    *(UInt8Ptr(ptr(uint64(outAddr) + uint64(3)))) = uint8(value)
    return true

fn cheng_runtime_sockaddr_ipv4(hostText: str, port: int32): ptr =
    let addr: ptr = chengAllocCompat(cheng_sockaddr_in_len)
    if addr == nil:
        return nil
    cheng_bytes_set(addr, 0, cheng_sockaddr_in_len)
    *(UInt8Ptr(addr)) = uint8(cheng_af_inet)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(1)))) = uint8(0)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(2)))) = uint8((port >> 8) & 0xff)
    *(UInt8Ptr(ptr(uint64(addr) + uint64(3)))) = uint8(port & 0xff)
    if !cheng_runtime_parse_ipv4_host(hostText, ptr(uint64(addr) + uint64(4))):
        chengFreeCompat(addr)
        return nil
    return addr

fn cheng_runtime_sleep_ms(value: int32) =
    if value <= 0:
        return
    var req: ChengLinuxTimespec
    req.tvSec = int64(value / 1000)
    req.tvNsec = int64(value % 1000) * int64(1000000)
    while true:
        let ret: int64 = cheng_linux_syscall2(cheng_sys_nanosleep, uint64(&req), 0)
        if !cheng_sys_is_err(ret):
            return
        if int32(-ret) != 4:
            return

fn cheng_runtime_u8_popcount(v0: uint8): int32 =
    var v: int32 = int32(v0)
    var count: int32
    while v != 0:
        count = count + (v & 1)
        v = v >> 1
    return count

fn cheng_runtime_ascii_is_space(ch: uint8): bool =
    if ch == uint8(32):
        return true
    if ch == uint8(9):
        return true
    if ch == uint8(10):
        return true
    if ch == uint8(13):
        return true
    return false

fn cheng_runtime_str_strip_ascii(raw: str): str =
    let n: int32 = cheng_runtime_str_len(raw)
    if n <= 0:
        return cheng_runtime_str_empty()
    let data: ptr = cheng_runtime_str_data(raw)
    var start: int32
    while start < n && cheng_runtime_ascii_is_space(*(UInt8Ptr(ptr(uint64(data) + uint64(start))))):
        start = start + 1
    if start >= n:
        return cheng_runtime_str_empty()
    var stop: int32 = n
