fn cheng_fread(buf: ptr, size: int64, n: int64, stream: ptr): int32 =
    if buf == nil || size <= 0 || n <= 0:
        return 0
    let totalBytes: int64 = size * n
    if totalBytes <= 0 || totalBytes > int64(2147483647):
        return 0
    let got: int32 = cheng_runtime_read_fd(cheng_runtime_stream_fd(stream), buf, int32(totalBytes))
    if got <= 0:
        return 0
    return int32(int64(got) / size)
