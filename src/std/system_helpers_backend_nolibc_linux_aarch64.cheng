    if out_raw == nil:
        return
    let outPtr: StrPtr = StrPtr(out_raw)
    if p == nil:
        outPtr->data = nil
        outPtr->len = 0
        outPtr->store_id = 0
        outPtr->flags = 0
        return
    let inPtr: StrPtr = StrPtr(p)
    outPtr->data = inPtr->data
    outPtr->len = inPtr->len
    outPtr->store_id = inPtr->store_id
    outPtr->flags = inPtr->flags

@exportc("cheng_error_info_bridge_ok")
