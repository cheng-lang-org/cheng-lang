fn cheng_sha256_u32(x: int64): int64 =
    return x & int64(0xffffffff)

fn cheng_sha256_rotr32(x: int64, n: int32): int64 =
    let v: int64 = cheng_sha256_u32(x)
    return cheng_sha256_u32((v >> n) | (v << (32 - n)))

fn cheng_sha256_ch(x: int64, y: int64, z: int64): int64 =
    let xu: int64 = cheng_sha256_u32(x)
    let yu: int64 = cheng_sha256_u32(y)
    let zu: int64 = cheng_sha256_u32(z)
    return cheng_sha256_u32((xu & yu) ^ ((xu ^ int64(0xffffffff)) & zu))

fn cheng_sha256_maj(x: int64, y: int64, z: int64): int64 =
    let xu: int64 = cheng_sha256_u32(x)
    let yu: int64 = cheng_sha256_u32(y)
    let zu: int64 = cheng_sha256_u32(z)
    return cheng_sha256_u32((xu & yu) ^ (xu & zu) ^ (yu & zu))

fn cheng_sha256_big_sigma0(x: int64): int64 =
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 2) ^ cheng_sha256_rotr32(x, 13) ^ cheng_sha256_rotr32(x, 22))

fn cheng_sha256_big_sigma1(x: int64): int64 =
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 6) ^ cheng_sha256_rotr32(x, 11) ^ cheng_sha256_rotr32(x, 25))

fn cheng_sha256_small_sigma0(x: int64): int64 =
    let xu: int64 = cheng_sha256_u32(x)
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 7) ^ cheng_sha256_rotr32(x, 18) ^ (xu >> 3))

fn cheng_sha256_small_sigma1(x: int64): int64 =
    let xu: int64 = cheng_sha256_u32(x)
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 17) ^ cheng_sha256_rotr32(x, 19) ^ (xu >> 10))

fn cheng_sha256_u32_from_bytes(b0: int32, b1: int32, b2: int32, b3: int32): int64 =
    return (int64(b0) << 24) | (int64(b1) << 16) | (int64(b2) << 8) | int64(b3)

fn cheng_sha256_k(i: int32): int64 =
    case i
    of 0: return cheng_sha256_u32_from_bytes(0x42, 0x8a, 0x2f, 0x98)
    of 1: return cheng_sha256_u32_from_bytes(0x71, 0x37, 0x44, 0x91)
