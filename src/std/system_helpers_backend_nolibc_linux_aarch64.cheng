@exportc("cheng_tcp_recv_payload_once_bridge")
fn cheng_tcp_recv_payload_once_bridge_export(hostText: str,
                                                port: int32,
                                                protocolText: str): uint64 =
    var responseWire: str = cheng_runtime_str_empty()
