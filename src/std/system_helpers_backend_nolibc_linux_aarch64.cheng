                                                                      port,
                                                                      protocolText,
                                                                      responseWire,
                                                                      errWire)
    if ok == 0:
        cheng_runtime_str_dispose(responseWire)
        cheng_runtime_tcp_last_error_recv_payload_bridge(errWire)
        cheng_runtime_str_dispose(errWire)
        return uint64(0)
    let handle: uint64 = cheng_buffer_handle_new_from_str(responseWire)
    if handle == uint64(0):
