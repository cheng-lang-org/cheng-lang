# std/sync (minimal, pure Cheng)
import std/thread

@importc("cheng_panic_cstring_and_exit")
fn syncPanicRaw(text: ptr): void

type
    Arc[T] = ref
        value: T

type
    Mutex[T] = ref
        lock: int32
        value: T

type
    RwLock[T] = ref
        state: int32
        value: T

type
    Atomic[T] = ref
        value: int32

type
    AtomicI32 = ref
        value: int32

fn arcNew(value: T): Arc[T] =
    var a: Arc[T] = new[Arc[T]]()
    if a != nil:
        a.value = value
    return a
    
fn share_mt(value: T): Arc[T] =
    return arcNew(value)

fn arcClone(a: Arc[T]): Arc[T] =
    if a == nil:
        syncPanicRaw("std_sync_arc_clone_nil")
        return a
    memRetainAtomic(a)
    return a

fn arcGet(a: Arc[T]): ptr =
    if a == nil:
        syncPanicRaw("std_sync_arc_get_nil")
        return nil
    return &a.value

fn arcUseCount(a: Arc[T]): int32 =
    if a == nil:
        syncPanicRaw("std_sync_arc_use_count_nil")
        return 0
    return memRefCountAtomic(a)

fn mutexNew(value: T): Mutex[T] =
    var m: Mutex[T] = new[Mutex[T]]()
    if m != nil:
        m.lock = 0
        m.value = value
    return m

fn mutexTryLock(m: Mutex[T]): ptr =
    if m == nil:
        syncPanicRaw("std_sync_mutex_try_lock_nil")
        return nil
    if atomicCasI32(&m.lock, 0, 1) != 0:
        return &m.value
    return nil

fn mutexLock(m: Mutex[T]): ptr =
    if m == nil:
        syncPanicRaw("std_sync_mutex_lock_nil")
        return nil
    while atomicCasI32(&m.lock, 0, 1) == 0:
        thread.Yield()
    return &m.value

fn mutexUnlock(m: Mutex[T]) =
    if m == nil:
        syncPanicRaw("std_sync_mutex_unlock_nil")
        return
    atomicStoreI32(&m.lock, 0)

fn rwLockNew(value: T): RwLock[T] =
    var l: RwLock[T] = new[RwLock[T]]()
    if l != nil:
        l.state = 0
        l.value = value
    return l

fn rwLockTryRead(l: RwLock[T]): ptr =
    if l == nil:
        syncPanicRaw("std_sync_rwlock_try_read_nil")
        return nil
    let cur: int32 = atomicLoadI32(&l.state)
    if cur >= 0 && atomicCasI32(&l.state, cur, cur + 1) != 0:
        return &l.value
    return nil

fn rwLockRead(l: RwLock[T]): ptr =
    if l == nil:
        syncPanicRaw("std_sync_rwlock_read_nil")
        return nil
    while true:
        let cur: int32 = atomicLoadI32(&l.state)
        if cur >= 0 && atomicCasI32(&l.state, cur, cur + 1) != 0:
            return &l.value
        thread.Yield()
fn rwLockReadUnlock(l: RwLock[T]) =
    if l == nil:
        syncPanicRaw("std_sync_rwlock_read_unlock_nil")
        return
    var cur: int32 = atomicLoadI32(&l.state)
    while cur > 0:
        if atomicCasI32(&l.state, cur, cur - 1) != 0:
            return
        cur = atomicLoadI32(&l.state)

fn rwLockTryWrite(l: RwLock[T]): ptr =
    if l == nil:
        syncPanicRaw("std_sync_rwlock_try_write_nil")
        return nil
    if atomicCasI32(&l.state, 0, -1) != 0:
        return &l.value
    return nil

fn rwLockWrite(l: RwLock[T]): ptr =
    if l == nil:
        syncPanicRaw("std_sync_rwlock_write_nil")
        return nil
    while atomicCasI32(&l.state, 0, -1) == 0:
        thread.Yield()
    return &l.value

fn rwLockWriteUnlock(l: RwLock[T]) =
    if l == nil:
        syncPanicRaw("std_sync_rwlock_write_unlock_nil")
        return
    atomicStoreI32(&l.state, 0)

fn atomicNew(value: T): Atomic[T] =
    var a: Atomic[T] = new[Atomic[T]]()
    if a != nil:
        a.value = int32(value)
    return a

fn atomicLoad(a: Atomic[T]): T =
    if a == nil:
        syncPanicRaw("std_sync_atomic_load_nil")
        return T(0)
    let v: int32 = atomicLoadI32(&a.value)
    return T(v)

fn atomicStore(a: Atomic[T], value: T) =
    if a == nil:
        syncPanicRaw("std_sync_atomic_store_nil")
        return
    atomicStoreI32(&a.value, int32(value))

fn atomicCas(a: Atomic[T], expect: T, desired: T): bool =
    if a == nil:
        syncPanicRaw("std_sync_atomic_cas_nil")
        return false
    return atomicCasI32(&a.value, int32(expect), int32(desired)) != 0

fn AtomicI32New(value: int32): AtomicI32 =
    var a: AtomicI32 = new[AtomicI32]()
    if a != nil:
        a.value = value
    return a

fn AtomicI32Load(a: AtomicI32): int32 =
    if a == nil:
        syncPanicRaw("std_sync_atomic_i32_load_nil")
        return 0
    return atomicLoadI32(&a.value)

fn AtomicI32Store(a: AtomicI32, value: int32) =
    if a == nil:
        syncPanicRaw("std_sync_atomic_i32_store_nil")
        return
    atomicStoreI32(&a.value, value)

fn AtomicI32Cas(a: AtomicI32,
                 expect: int32,
                 desired: int32): bool =
    if a == nil:
        syncPanicRaw("std_sync_atomic_i32_cas_nil")
        return false
    return atomicCasI32(&a.value, expect, desired) != 0
