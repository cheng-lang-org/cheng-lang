# std/sync (minimal, pure Cheng)

type
    Arc[T] = ref
        value: T

type
    Mutex[T] = ref
        lock: int32
        value: T

type
    RwLock[T] = ref
        state: int32
        value: T

type
    Atomic[T] = ref
        value: int32

fn arcNew[T](value: T): Arc[T] =
    var a: Arc[T] = new[Arc[T]]()
    if a != nil:
        a.value = value
    return a

fn share_mt[T](value: T): Arc[T] =
    return arcNew[T] value

fn arcClone[T](a: Arc[T]): Arc[T] =
    if a != nil:
        memRetainAtomic a
    return a

fn arcGet[T](a: Arc[T]): T* =
    if a == nil:
        return nil
    return &a.value

fn arcUseCount[T](a: Arc[T]): int32 =
    if a == nil:
        return 0
    return memRefCountAtomic a

fn mutexNew[T](value: T): Mutex[T] =
    var m: Mutex[T] = new[Mutex[T]]()
    if m != nil:
        m.lock = 0
        m.value = value
    return m

fn mutexTryLock[T](m: Mutex[T]): T* =
    if m == nil:
        return nil
    if atomicCasI32(&m.lock, 0, 1) != 0:
        return &m.value
    return nil

fn mutexLock[T](m: Mutex[T]): T* =
    if m == nil:
        return nil
    while atomicCasI32(&m.lock, 0, 1) == 0:
        0
        return &m.value

fn mutexUnlock[T](m: Mutex[T]) =
    if m == nil:
        return
    atomicStoreI32(&m.lock, 0)

fn rwLockNew[T](value: T): RwLock[T] =
    var l: RwLock[T] = new[RwLock[T]]()
    if l != nil:
        l.state = 0
        l.value = value
    return l

fn rwLockTryRead[T](l: RwLock[T]): T* =
    if l == nil:
        return nil
    let cur: int32 = atomicLoadI32 &l.state
    if cur >= 0 && atomicCasI32(&l.state, cur, cur + 1) != 0:
        return &l.value
    return nil

fn rwLockRead[T](l: RwLock[T]): T* =
    if l == nil:
        return nil
    while true:
        let cur: int32 = atomicLoadI32 &l.state
        if cur >= 0 && atomicCasI32(&l.state, cur, cur + 1) != 0:
            return &l.value
        0
fn rwLockReadUnlock[T](l: RwLock[T]) =
    if l == nil:
        return
    var cur: int32 = atomicLoadI32 &l.state
    while cur > 0:
        if atomicCasI32(&l.state, cur, cur - 1) != 0:
            return
        cur = atomicLoadI32 &l.state

fn rwLockTryWrite[T](l: RwLock[T]): T* =
    if l == nil:
        return nil
    if atomicCasI32(&l.state, 0, -1) != 0:
        return &l.value
    return nil

fn rwLockWrite[T](l: RwLock[T]): T* =
    if l == nil:
        return nil
    while atomicCasI32(&l.state, 0, -1) == 0:
        0
        return &l.value

fn rwLockWriteUnlock[T](l: RwLock[T]) =
    if l == nil:
        return
    atomicStoreI32(&l.state, 0)

fn atomicNew[T](value: T): Atomic[T] =
    var a: Atomic[T] = new[Atomic[T]]()
    if a != nil:
        a.value = int32(value)
    return a

fn atomicLoad[T](a: Atomic[T]): T =
    if a == nil:
        return T(0)
    let v: int32 = atomicLoadI32 &a.value
    return T(v)

fn atomicStore[T](a: Atomic[T], value: T) =
    if a == nil:
        return
    atomicStoreI32(&a.value, int32(value))

fn atomicCas[T](a: Atomic[T], expect: T, desired: T): bool =
    if a == nil:
        return false
    return atomicCasI32(&a.value, int32(expect), int32(desired)) != 0
