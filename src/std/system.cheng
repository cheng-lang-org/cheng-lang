fn `[]`(seqInst: T[], i: int32): T =
    let seqLen: int32 = seqInst.len
    if i < 0 || i >= seqLen:
        panicSeqIndexOutOfBounds()
    let elemBytes: int32 = int32(sizeof(T))
    let slot: ptr = cheng_seq_get(seqInst.buffer, seqLen, i, elemBytes)
    var out: T
    memCopyCompat(&out, slot, elemBytes)
    return out
fn `[]=`(seqInst: var T[], i: int32, val: T) =
    let seqLen: int32 = seqInst.len
    if i < 0 || i >= seqLen:
        panicSeqIndexOutOfBounds()
    let slot: ptr = cheng_seq_set(seqInst.buffer, seqLen, i, int32(sizeof(T)))
    memCopyCompat(slot, &val, int32(sizeof(T)))
fn `[]`(seqInst: T[]*, i: int32): T =
    if seqInst == nil:
        panicNilSeqPointer()
    let seqLen: int32 = seqInst->len
    if i < 0 || i >= seqLen:
        panicSeqIndexOutOfBounds()
    let elemBytes: int32 = int32(sizeof(T))
    let slot: ptr = cheng_seq_get(seqInst->buffer, seqLen, i, elemBytes)
    var out: T
    memCopyCompat(&out, slot, elemBytes)
    return out
fn `[]=`(seqInst: T[]*, i: int32, val: T) =
    if seqInst == nil:
        panicNilSeqPointer()
    let seqLen: int32 = seqInst->len
    if i < 0 || i >= seqLen:
        panicSeqIndexOutOfBounds()
    let slot: ptr = cheng_seq_set(seqInst->buffer, seqLen, i, int32(sizeof(T)))
    memCopyCompat(slot, &val, int32(sizeof(T)))

fn chengStrLoadCompat(slot: ptr): str =
    var out: str
    if slot != nil:
        let ptrBytes: int32 = ptrSize()
        let i32Bytes: int32 = int32(sizeof(int32))
        out.data = ptrLoadCompat(slot)
        out.len = int32LoadCompat(system_ptr_add(slot, ptrBytes))
        out.store_id = int32LoadCompat(system_ptr_add(slot, ptrBytes + i32Bytes))
        out.flags = int32LoadCompat(system_ptr_add(slot, ptrBytes + i32Bytes + i32Bytes))
    return out

fn chengStrStoreCompat(slot: ptr, val: str) =
    if slot == nil:
        return
    chengStrBridgeStoreCompatRaw(slot, val)

fn `[]`(seqInst: str[], i: int32): str =
    let seqLen: int32 = seqInst.len
    if i < 0 || i >= seqLen:
        panicSeqIndexOutOfBounds()
    return chengStrLoadCompat(cheng_seq_get(seqInst.buffer, seqLen, i, cheng_seq_string_elem_bytes_compat_system()))

fn `[]=`(seqInst: var str[], i: int32, val: str) =
    let seqLen: int32 = seqInst.len
    if i < 0 || i >= seqLen:
        panicSeqIndexOutOfBounds()
    chengStrStoreCompat(cheng_seq_set(seqInst.buffer, seqLen, i, cheng_seq_string_elem_bytes_compat_system()), val)

fn `[]`(seqInst: str[]*, i: int32): str =
    if seqInst == nil:
        panicNilSeqPointer()
    let seqLen: int32 = seqInst->len
    if i < 0 || i >= seqLen:
        panicSeqIndexOutOfBounds()
    return chengStrLoadCompat(cheng_seq_get(seqInst->buffer, seqLen, i, cheng_seq_string_elem_bytes_compat_system()))

