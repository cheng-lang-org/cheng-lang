const chengStrFlagOwned: int32 = 1

fn strEmpty(): str =
    var out: str
    out.data = nil
    out.len = 0
    out.store_id = 0
    out.flags = 0
    return out

fn strDataPtr(s: str): ptr =
    if s.data == nil:
        return nil
    if s.len <= 0:
        return nil
    return s.data

fn strLenFast(s: str): int32 =
    if s.data == nil:
        return 0
    if s.len <= 0:
        return 0
    return s.len

fn strViewWithFlags(data: ptr, len: int32, storeId: int32, flags: int32): str =
    var out: str
    if data != nil:
        if len > 0:
            out.data = data
            out.len = len
            out.store_id = storeId
            out.flags = flags
    return out

fn strViewUnsafe(data: ptr, len: int32): str =
    return strViewWithFlags(data, len, 0, 0)

fn strSubView(s: str, start: int32, count: int32): str =
    let n: int32 = strLenFast(s)
    var out: str
    var start0: int32 = start
    if count > 0 && n > 0:
        if start0 < 0:
            start0 = 0
        if start0 < n:
            var kept: int32 = count
            if start0 + kept > n:
                kept = n - start0
            out = strViewWithFlags(system_ptr_add(strDataPtr(s), start0), kept, s.store_id, 0)
    return out

fn echo(msg: cstring) =
    puts(msg)
importc fn exit(code: int32)
importc fn cheng_dump_backtrace_if_enabled()
importc fn driver_c_new_string(size: int32): cstring
importc fn driver_c_new_string_copy_n(raw: ptr, count: int32): cstring
fn panicCString(msg: str): cstring =
    if strLenFast(msg) == 0:
        return driver_c_new_string(0)
    let dataPtr0: ptr = strDataPtr(msg)
    if dataPtr0 == nil:
        return driver_c_new_string(0)
    if msg.flags == chengStrFlagOwned:
        return cstring(dataPtr0)
    return driver_c_new_string_copy_n(dataPtr0, strLenFast(msg))
fn panic(msg: ptr) =
    puts(cstring(msg))
    exit(1)
fn panic(msg: str) =
    let raw: cstring = panicCString(msg)
    puts(raw)
    exit(1)
fn panicStr(msg: str) =
    panic(msg)
fn panicErr(err: result.ErrorInfo) =
    let msgText: str = ErrorMessage(err)
    if strLenFast(msgText) == 0:
        let rawEmpty: cstring = panicCString("error")
        puts(rawEmpty)
        exit(1)
    let raw: cstring = panicCString(msgText)
    puts(raw)
    exit(1)
fn assert(cond: bool, msg: str) =
    if ! cond:
        let raw: cstring = panicCString(msg)
        puts(raw)
        exit(1)
fn assert(cond: bool, msg: ptr) =
    if ! cond:
        puts(cstring(msg))
        exit(1)
fn panicSeqIndexOutOfBounds() =
    let raw: cstring = panicCString("seq index out of bounds")
    puts(raw)
    exit(1)
fn panicNilSeqPointer() =
    let raw: cstring = panicCString("cheng: nil seq pointer")
    puts(raw)
    exit(1)
