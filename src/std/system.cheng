fn `[]`(seqInst: T[], i: int32): T =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    let seqLen: int32 = seqHdr->len
    if i < 0 || i >= seqLen:
        panic "seq index out of bounds"
    var offset64: int64 = int64(i) * int64(elemSize[T]())
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqHdr->buffer, offset32)
    var pt: T* = T*(p)
    var out: T
    out = *pt
    return out
fn `[]=`(seqInst: var T[], i: int32, val: T) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    let seqLen: int32 = seqHdr->len
    if i < 0 || i >= seqLen:
        panic "seq index out of bounds"
    var offset64: int64 = int64(i) * int64(elemSize[T]())
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqHdr->buffer, offset32)
    var pt: T* = T*(p)
    *pt = val
fn `[]`(seqInst: T[]*, i: int32): T =
    if seqInst == nil:
        panic "cheng: nil seq pointer"
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(seqInst)
    let seqLen: int32 = seqHdr->len
    if i < 0 || i >= seqLen:
        panic "seq index out of bounds"
    var offset64: int64 = int64(i) * int64(elemSize[T]())
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqHdr->buffer, offset32)
    var pt: T* = T*(p)
    var out: T
    out = *pt
    return out
fn `[]=`(seqInst: T[]*, i: int32, val: T) =
    if seqInst == nil:
        panic "cheng: nil seq pointer"
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(seqInst)
    let seqLen: int32 = seqHdr->len
    if i < 0 || i >= seqLen:
        panic "seq index out of bounds"
    var offset64: int64 = int64(i) * int64(elemSize[T]())
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqHdr->buffer, offset32)
    var pt: T* = T*(p)
    *pt = val
fn `[]`(seqInst: ptr[], i: int32): ptr =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    let seqLen: int32 = seqHdr->len
    if i < 0 || i >= seqLen:
        panic "seq index out of bounds"
    var offset64: int64 = int64(i) * int64(elemSize[ptr]())
    var offset32: int32 = int32(offset64)
    let p: void* = ptr_add(seqHdr->buffer, offset32)
    let pp: void** = void**(p)
    return *pp

fn `[]=`(seqInst: var ptr[], i: int32, val: ptr) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    let seqLen: int32 = seqHdr->len
    if i < 0 || i >= seqLen:
        panic "seq index out of bounds"
    var offset64: int64 = int64(i) * int64(elemSize[ptr]())
    var offset32: int32 = int32(offset64)
    let p: void* = ptr_add(seqHdr->buffer, offset32)
    let pp: void** = void**(p)
    *pp = void*(val)
fn store_ptr(p: void*, val: void*) =
    if p == nil:
        return
    let pp: void** = void**(p)
    *pp = val

fn load_ptr(p: void*): void* =
    if p == nil:
        return nil
    let pp: void** = void**(p)
    return *pp
