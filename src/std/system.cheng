@importc("driver_c_bool_identity")
fn defined(x: bool): bool
fn systemToStringStr(x: str): str =
    return newStringCopy(strDataPtr(x), strLenFast(x))

fn boolToString(x: bool): str =
    if x:
        return "true"
    return "false"

fn charToString(x: char): str =
    let out: str = newStringAlloc(1)
    if out.data != nil && out.len == 1:
        rawmemWriteI8Compat(out.data, 0, int8(int32(x)))
    return out
fn ParseF64Bits(text: str): int64 =
    return parseF64BitsRaw(strToCStringTemp(text))
fn BitsToF64(bits: int64): float64 =
    return bitsToF64(bits)
fn newException(t: typedesc[T], message: str): T =
    t
    message
    var e: T
    return e
fn repr(x: T): str =
    x
    return "<repr>"
fn abs(x: T): T =
    if x < T():
        return T() - x
    else:
        return x
fn max(a: T, b: T): T =
    if a >= b:
        return a
    else:
        return b
fn min(a: T, b: T): T =
    if a <= b:
        return a
    else:
        return b
fn clamp(x: T, lo: T, hi: T): T =
    if x < lo:
        return lo
    elif x > hi:
        return hi
    else:
        return x
fn cmp(a: str, b: str): int32 =
    return cheng_strcmp(strToCStringTemp(a), strToCStringTemp(b))
fn cmpInt(a: int, b: int): int32 =
    if a < b:
        return -1
    elif a > b:
        return 1
    else:
        return 0
    return 0
fn cmpFloat(a: float64, b: float64): int32 =
    if a != a || b != b:
        return 0
    if a == 0.0 && b == 0.0:
        return 0
    if a < b:
        return -1
    elif a > b:
        return 1
    else:
        return 0
    return 0
fn cmpGeneric(a: T, b: T): int32 =
    if a < b:
        return -1
    elif a > b:
        return 1
    else:
        return 0
fn inc(x: var T, delta: T) =
    x = x + delta
fn inc(x: var T) =
    x = x + T(1)
fn dec(x: var T, delta: T) =
    x = x - delta
fn dec(x: var T) =
    x = x - T(1)
fn __cheng_concat_str(a: str, b: str): str =
    let nLeft: int32 = strLenFast(a)
    let nRight: int32 = strLenFast(b)
    let out: str = newStringAlloc(nLeft + nRight)
    if nLeft > 0:
        memCopyCompat(strDataPtr(out), strDataPtr(a), nLeft)
    if nRight > 0:
        memCopyCompat(system_ptr_add(strDataPtr(out), nLeft), strDataPtr(b), nRight)
    if strDataPtr(out) != nil:
        rawmemWriteI8Compat(strDataPtr(out), nLeft + nRight, int8(0))
    return out
fn __cheng_set_range_mask(start: int32, stop: int32, exclusive: bool): uint64 =
    var s: int32
    s = start
    var e: int32
    e = stop
    if exclusive:
        e = e - 1
    if s < 0:
        s = 0
    if e < s:
        return uint64(0)
    if e > 63:
        e = 63
    var mask: uint64
    mask = uint64(0)
    var i: int32
    i = s
    while i <= e:
        mask = mask |(uint64(1) << uint64(i))
        i = i + 1
    return mask
fn setHas(s: set[T], value: T): bool =
    let idx64 = int64(value)
    let idx = uint64(idx64)
    let mask = uint64(1) << idx
    let bits = uint64(s)
    var out: bool
    out = (bits & mask) != 0
    return out
fn newString(len: int32): str =
    var out: str
    if len > 0:
        out = strOwnedAlloc(len)
    return out

fn strOwnedAlloc(len: int32): str =
    var out: str
    if len > 0:
        let raw: cstring = driver_c_new_string(len)
        if raw != nil:
            out = strViewWithFlags(ptr(raw), len, 0, chengStrFlagOwned)
    return out

fn strFromBytesCopy(src: ptr, len: int32): str =
    var out: str
    if src != nil && len > 0:
        let raw: cstring = driver_c_new_string_copy_n(src, len)
        if raw != nil:
            out = strViewWithFlags(ptr(raw), len, 0, chengStrFlagOwned)
    return out

fn strFromCStringBorrow(raw: cstring): str =
    var out: str
    if raw != nil:
        let n: int32 = c_strlen(raw)
        out = strViewUnsafe(ptr(raw), n)
    return out

fn strFromCStringCopy(raw: cstring): str =
    var out: str
    if raw != nil:
        let n: int32 = c_strlen(raw)
        out = strFromBytesCopy(ptr(raw), n)
    return out

fn cheng_str_param_to_cstring_compat(s: str): cstring =
    let n: int32 = strLenFast(s)
    if n <= 0:
        return driver_c_new_string(0)
    if s.flags == chengStrFlagOwned:
        return cstring(s.data)
    return driver_c_new_string_copy_n(s.data, n)

fn strToCStringTemp(s: str): cstring =
    return cheng_str_param_to_cstring_compat(s)
fn strToCStringTemp(s: ptr): cstring =
    if s == nil:
        return driver_c_new_string(0)
    return cstring(s)

fn newStringAlloc(len: int32): str =
    return strOwnedAlloc(len)

fn newStringCopy(raw: ptr, count: int32): str =
    return strFromBytesCopy(raw, count)
fn newStringOfCap(len: int32): str =
    return strOwnedAlloc(len)
fn new(): ref T =
    var r: ref T = new(T)
    return r

fn SystemToStringStr(x: str): str =
    return systemToStringStr(x)
