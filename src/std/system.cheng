fn ptrSize(): int32 =
    return cheng_ptr_size()
fn elemSize[T](): int32 =
    return int32(sizeof T)

# Concrete fallback symbols for older stage0/self-link paths that still expect
# direct elemSize_* references instead of a generic instantiation.
fn elemSize_int32(): int32 =
    return int32(sizeof(int32))

fn elemSize_int64(): int32 =
    return int32(sizeof(int64))

fn elemSize_str(): int32 =
    return int32(sizeof(str))

fn elemSize_uint8(): int32 =
    return int32(sizeof(uint8))

fn elemSize_ptr(): int32 =
    return ptrSize()

