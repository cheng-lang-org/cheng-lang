fn echo(msg: cstring) =
    puts(msg)
importc fn exit(code: int32)
importc fn cheng_dump_backtrace_if_enabled()
fn panic(msg: str) =
    puts(cstring(msg))
    exit(1)
fn panicErr(err: result.ErrorInfo) =
    let msg: str =
        if len(err.msg) == 0:
            "error"
        else:
            err.msg
    puts(cstring(msg))
    exit(1)
fn assert(cond: bool, msg: str) =
    if ! cond:
        puts(cstring(msg))
        exit(1)
