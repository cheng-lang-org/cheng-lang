# C interop surface intentionally stays pointer-free at user source level.
# Raw pointer ABI helpers must live in compiler-generated shims or runtime internals.
type
    int32 = int
    int64 = int
@importc("puts")
fn puts(s: cstring): int32
@importc("exit")
fn exit(code: int32)
@importc("cheng_strlen")
fn strlen(s: cstring): int32
@importc("xor_0")
fn xor_0(a, b: int32): int32
@importc("bitnot_0")
fn bitnot_0(a: int32): int32
fn mul_0(a, b: int32): int32
