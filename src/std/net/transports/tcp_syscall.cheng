import std/strutils as strutil
# TCP syscall helpers (minimal loopback client/server transport).

import std/result
import std/rawbytes
import std/rawmem_support
import std/os as os
import std/strings
import std/net/transports/udp_syscall as udp

@importc("cheng_tcp_connect_host_port_bridge")
fn cheng_tcp_connect_host_port_bridge(hostText: str, port: int32): int32
@importc("cheng_fd_set_nonblocking_bridge")
fn cheng_fd_set_nonblocking_bridge(fd: int32, enabled: int32): int32
@importc("cheng_fd_wait_readable_bridge")
fn cheng_fd_wait_readable_bridge(fd: int32, timeoutMs: int32): int32
@importc("write")
fn tcpRawWrite(fd: int32, data: ptr, n: int64): int64
@importc("read")
fn tcpRawRead(fd: int32, data: ptr, n: int64): int64

const
    tcpAfInet = 2
    tcpAfInet6Linux = 10
    tcpAfInet6Bsd = 30
    tcpSockStream = 1
    tcpShutdownWr = 1
    tcpShutdownRdWr = 2

type
    TcpSockAddr = udp.UdpSockAddr

    TcpListenerHandle =
        fd: int32
        addr: TcpSockAddr

    TcpConnectionHandle =
        fd: int32
        localAddr: TcpSockAddr
        remoteAddr: TcpSockAddr
        open: bool

fn tcpErrno(): int32 =
    return os.UdpErrno()

fn tcpErrText(code: int32): str =
    let text: str = os.udpErrText(code)
    return text

fn tcpWouldBlock(code: int32): bool =
    return code == 11 || code == 35

fn tcpErrCodeText(errCode: int32): str =
    var out: str = tcpErrText(errCode)
    out = strutil.Join([out, " ("], "")
    out = strutil.Join([out, intToStr(errCode)], "")
    out = strutil.Join([out, ")"], "")
    return out

fn tcpErrMessage(prefix: str, errCode: int32): str =
    var out: str = prefix
    out = strutil.Join([out, tcpErrCodeText(errCode)], "")
    return out

fn tcpIpv6SocketErrMessage(errLinux: int32, errBsd: int32): str =
    if errLinux == errBsd:
        return tcpErrMessage("tcp syscall: ipv6 socket failed: ", errBsd)
    var out: str = "tcp syscall: ipv6 socket failed: "
    out = strutil.Join([out, tcpErrCodeText(errLinux)], "")
    out = strutil.Join([out, " | "], "")
    out = strutil.Join([out, tcpErrCodeText(errBsd)], "")
    return out

fn tcpSocketOpenStream(isV6: bool): Result[int32] =
    if !isV6:
        let fd: int32 = os.UdpOpenSocket(tcpAfInet, tcpSockStream, 0)
        if fd < 0:
            let errCode: int32 = tcpErrno()
            return Err[int32](tcpErrMessage("tcp syscall: socket failed: ", errCode))
        return Ok[int32](fd)

    let fdLinux: int32 = os.UdpOpenSocket(tcpAfInet6Linux, tcpSockStream, 0)
    if fdLinux >= 0:
        return Ok[int32](fdLinux)
    let errLinux: int32 = tcpErrno()

    let fdBsd: int32 = os.UdpOpenSocket(tcpAfInet6Bsd, tcpSockStream, 0)
    if fdBsd >= 0:
        return Ok[int32](fdBsd)
    let errBsd: int32 = tcpErrno()

    return Err[int32](tcpIpv6SocketErrMessage(errLinux, errBsd))

fn tcpSockAddrFromHostPort(host: str, port: int32, out: var TcpSockAddr, isV6: bool = false): Result[bool] =
    return udp.udpSockAddrFromHostPort(host, port, isV6, 0, false, out)

fn tcpSockAddrDecode(raw: Bytes, rawLen: int32, out: var TcpSockAddr): Result[bool] =
    return udp.udpSockAddrDecode(raw, rawLen, out)

fn tcpSockAddrCanonical(addr: TcpSockAddr): str =
    if addr.isV6:
        return strutil.Join(["tcp://[", addr.host, "]:", intToStr(addr.port)], "")
    return strutil.Join(["tcp://", addr.host, ":", intToStr(addr.port)], "")

fn tcpGetSockName(fd: int32, out: var TcpSockAddr): Result[bool] =
    if fd < 0:
        return Err[bool]("tcp syscall: invalid socket")
    let rawAddr: Bytes = bytesAlloc(128)
    var rawLen: int32 = bytesLen(rawAddr)
    let rc: int32 = os.udpGetSockNameFd(fd, rawAddr, rawLen)
    if rc != 0:
        let errCode: int32 = tcpErrno()
        return Err[bool](tcpErrMessage("tcp syscall: getsockname failed: ", errCode))
    if rawLen <= 0:
        return Err[bool]("tcp syscall: getsockname empty address")
    if rawLen > bytesLen(rawAddr):
        rawLen = bytesLen(rawAddr)
    return tcpSockAddrDecode(rawAddr, rawLen, out)

fn tcpListen(host: str, port: int32, isV6: bool = false): Result[TcpListenerHandle] =
    let openRes: Result[int32] = tcpSocketOpenStream(isV6)
    if IsErr(openRes):
        return Err[TcpListenerHandle](Error(openRes))
    let fd: int32 = Value(openRes)
    var addr: TcpSockAddr
    let addrRes: Result[bool] = tcpSockAddrFromHostPort(host, port, addr, isV6)
    if IsErr(addrRes):
        let _ = os.UdpCloseFd(fd)
        return Err[TcpListenerHandle](Error(addrRes))
    let bindRes: int32 = os.udpBindFd(fd, addr.data, addr.len)
    if bindRes != 0:
        let errCode: int32 = tcpErrno()
        let _ = os.UdpCloseFd(fd)
        return Err[TcpListenerHandle](tcpErrMessage("tcp syscall: bind failed: ", errCode))
    let listenRes: int32 = os.TcpListenFd(fd, 16)
    if listenRes != 0:
        let errCode: int32 = tcpErrno()
        let _ = os.UdpCloseFd(fd)
        return Err[TcpListenerHandle](tcpErrMessage("tcp syscall: listen failed: ", errCode))
    var localAddr: TcpSockAddr
    let localRes: Result[bool] = tcpGetSockName(fd, localAddr)
    if IsErr(localRes):
        let _ = os.UdpCloseFd(fd)
        return Err[TcpListenerHandle](Error(localRes))
    return Ok[TcpListenerHandle](TcpListenerHandle(fd: fd, addr: localAddr))

fn tcpListenFill(host: str,
                 port: int32,
                 out: var TcpListenerHandle,
                 isV6: bool = false): Result[bool] =
    out.fd = -1
    let openRes: Result[int32] = tcpSocketOpenStream(isV6)
    if IsErr(openRes):
        return Err[bool](Error(openRes))
    let fd: int32 = Value(openRes)
    var addr: TcpSockAddr
    let addrRes: Result[bool] = tcpSockAddrFromHostPort(host, port, addr, isV6)
    if IsErr(addrRes):
        let _ = os.UdpCloseFd(fd)
        return Err[bool](Error(addrRes))
    let bindRes: int32 = os.udpBindFd(fd, addr.data, addr.len)
    if bindRes != 0:
        let errCode: int32 = tcpErrno()
        let _ = os.UdpCloseFd(fd)
        return Err[bool](tcpErrMessage("tcp syscall: bind failed: ", errCode))
    let listenRes: int32 = os.TcpListenFd(fd, 16)
    if listenRes != 0:
        let errCode: int32 = tcpErrno()
        let _ = os.UdpCloseFd(fd)
        return Err[bool](tcpErrMessage("tcp syscall: listen failed: ", errCode))
    var localAddr: TcpSockAddr
    let localRes: Result[bool] = tcpGetSockName(fd, localAddr)
    if IsErr(localRes):
        let _ = os.UdpCloseFd(fd)
        return Err[bool](Error(localRes))
    out.fd = fd
    out.addr = localAddr
    return Ok[bool](true)

fn tcpListenerClose(listener: var TcpListenerHandle) =
    if listener.fd >= 0:
        let _ = os.UdpCloseFd(listener.fd)
        listener.fd = -1

fn tcpListenerSetNonblocking(listener: TcpListenerHandle, enabled: bool): Result[bool] =
    if listener.fd < 0:
        return Err[bool]("tcp syscall: invalid listener")
    let enabledCode: int32 = if enabled: 1 else: 0
    let rc: int32 = cheng_fd_set_nonblocking_bridge(listener.fd, enabledCode)
    if rc != 0:
        let errCode: int32 = tcpErrno()
        return Err[bool](tcpErrMessage("tcp syscall: listener nonblocking failed: ", errCode))
    return Ok[bool](true)

fn tcpListenerWaitReadable(listener: TcpListenerHandle, timeoutMs: int32): Result[bool] =
    if listener.fd < 0:
        return Err[bool]("tcp syscall: invalid listener")
    let rc: int32 = cheng_fd_wait_readable_bridge(listener.fd, timeoutMs)
    if rc < 0:
        let errCode: int32 = 0 - rc
        if errCode > 0:
            return Err[bool](tcpErrMessage("tcp syscall: listener wait readable failed: ", errCode))
        return Err[bool]("tcp syscall: listener wait readable failed")
    return Ok[bool](rc != 0)

fn tcpAccept(listener: TcpListenerHandle): Result[TcpConnectionHandle] =
    if listener.fd < 0:
        return Err[TcpConnectionHandle]("tcp syscall: invalid listener")
    let rawAddr: Bytes = bytesAlloc(128)
    var rawLen: int32 = bytesLen(rawAddr)
    let fd: int32 = os.TcpAcceptFd(listener.fd, rawAddr, rawLen)
    if fd < 0:
        let errCode: int32 = tcpErrno()
        return Err[TcpConnectionHandle](tcpErrMessage("tcp syscall: accept failed: ", errCode))
    if rawLen > bytesLen(rawAddr):
        rawLen = bytesLen(rawAddr)
    var remoteAddr: TcpSockAddr
    let remoteRes: Result[bool] = tcpSockAddrDecode(rawAddr, rawLen, remoteAddr)
    if IsErr(remoteRes):
        let _ = os.UdpCloseFd(fd)
        return Err[TcpConnectionHandle](Error(remoteRes))
    var localAddr: TcpSockAddr
    let localRes: Result[bool] = tcpGetSockName(fd, localAddr)
    if IsErr(localRes):
        let _ = os.UdpCloseFd(fd)
        return Err[TcpConnectionHandle](Error(localRes))
    var out: TcpConnectionHandle
    out.fd = fd
    out.localAddr = localAddr
    out.remoteAddr = remoteAddr
    out.open = true
    return Ok[TcpConnectionHandle](out)

fn tcpAcceptNonblocking(listener: TcpListenerHandle): Result[TcpConnectionHandle] =
    if listener.fd < 0:
        return Err[TcpConnectionHandle]("tcp syscall: invalid listener")
    let rawAddr: Bytes = bytesAlloc(128)
    var rawLen: int32 = bytesLen(rawAddr)
    let fd: int32 = os.TcpAcceptFd(listener.fd, rawAddr, rawLen)
    if fd < 0:
        let errCode: int32 = tcpErrno()
        if tcpWouldBlock(errCode):
            return Err[TcpConnectionHandle]("tcp syscall: would block")
        return Err[TcpConnectionHandle](tcpErrMessage("tcp syscall: accept failed: ", errCode))
    if rawLen > bytesLen(rawAddr):
        rawLen = bytesLen(rawAddr)
    var remoteAddr: TcpSockAddr
    let remoteRes: Result[bool] = tcpSockAddrDecode(rawAddr, rawLen, remoteAddr)
    if IsErr(remoteRes):
        let _ = os.UdpCloseFd(fd)
        return Err[TcpConnectionHandle](Error(remoteRes))
    var localAddr: TcpSockAddr
    let localRes: Result[bool] = tcpGetSockName(fd, localAddr)
    if IsErr(localRes):
        let _ = os.UdpCloseFd(fd)
        return Err[TcpConnectionHandle](Error(localRes))
    var out: TcpConnectionHandle
    out.fd = fd
    out.localAddr = localAddr
    out.remoteAddr = remoteAddr
    out.open = true
    return Ok[TcpConnectionHandle](out)

fn tcpConnect(host: str, port: int32, isV6: bool = false): Result[TcpConnectionHandle] =
    let openRes: Result[int32] = tcpSocketOpenStream(isV6)
    if IsErr(openRes):
        return Err[TcpConnectionHandle](Error(openRes))
    let fd: int32 = Value(openRes)
    var remoteAddr: TcpSockAddr
    let remoteRes: Result[bool] = tcpSockAddrFromHostPort(host, port, remoteAddr, isV6)
    if IsErr(remoteRes):
        let _ = os.UdpCloseFd(fd)
        return tcpConnectResolved(host, port)
    let connectRes: int32 = os.TcpConnectFd(fd, remoteAddr.data, remoteAddr.len)
    if connectRes != 0:
        let errCode: int32 = tcpErrno()
        let _ = os.UdpCloseFd(fd)
        return Err[TcpConnectionHandle](tcpErrMessage("tcp syscall: connect failed: ", errCode))
    var localAddr: TcpSockAddr
    let localRes: Result[bool] = tcpGetSockName(fd, localAddr)
    if IsErr(localRes):
        let _ = os.UdpCloseFd(fd)
        return Err[TcpConnectionHandle](Error(localRes))
    return Ok[TcpConnectionHandle](
        TcpConnectionHandle(
            fd: fd,
            localAddr: localAddr,
            remoteAddr: remoteAddr,
            open: true
        )
    )

fn tcpConnectResolved(host: str, port: int32): Result[TcpConnectionHandle] =
    let fd: int32 = cheng_tcp_connect_host_port_bridge(host, port)
    if fd < 0:
        return Err[TcpConnectionHandle](strutil.Join(["tcp syscall: resolve connect failed: ", host, ":", intToStr(port)], ""))
    var localAddr: TcpSockAddr
    let localRes: Result[bool] = tcpGetSockName(fd, localAddr)
    if IsErr(localRes):
        let _ = os.UdpCloseFd(fd)
        return Err[TcpConnectionHandle](Error(localRes))
    var remoteAddr: TcpSockAddr
    let empty: Bytes = emptyBytes()
    remoteAddr.data = empty
    remoteAddr.len = 0
    remoteAddr.family = 0
    remoteAddr.isV6 = strings.StrContains(host, ":")
    remoteAddr.host = host
    remoteAddr.port = port
    return Ok[TcpConnectionHandle](
        TcpConnectionHandle(
            fd: fd,
            localAddr: localAddr,
            remoteAddr: remoteAddr,
            open: true
        )
    )

fn tcpSend(conn: var TcpConnectionHandle, data: Bytes): Result[int32] =
    if !conn.open:
        return Err[int32]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[int32]("tcp syscall: connection closed")
    let totalLen: int32 = bytesLen(data)
    if totalLen <= 0:
        return Ok[int32](0)
    var sentTotal: int32
    while sentTotal < totalLen:
        let chunk: Bytes = bytesSliceView(data, sentTotal, totalLen - sentTotal)
        let sent: int32 = int32(tcpRawWrite(conn.fd, chunk.data, int64(bytesLen(chunk))))
        if sent <= 0:
            let errCode: int32 = tcpErrno()
            return Err[int32](tcpErrMessage("tcp syscall: send failed: ", errCode))
        sentTotal = sentTotal + sent
    return Ok[int32](sentTotal)

fn tcpSendNonblocking(conn: var TcpConnectionHandle, data: Bytes): Result[int32] =
    if !conn.open:
        return Err[int32]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[int32]("tcp syscall: connection closed")
    let totalLen: int32 = bytesLen(data)
    if totalLen <= 0:
        return Ok[int32](0)
    let sent: int32 = int32(tcpRawWrite(conn.fd, data.data, int64(totalLen)))
    if sent < 0:
        let errCode: int32 = tcpErrno()
        if tcpWouldBlock(errCode):
            return Ok[int32](0)
        return Err[int32](tcpErrMessage("tcp syscall: send failed: ", errCode))
    return Ok[int32](sent)

fn tcpRecv(conn: var TcpConnectionHandle, maxBytes: int32): Result[Bytes] =
    if !conn.open:
        return Err[Bytes]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[Bytes]("tcp syscall: connection closed")
    if maxBytes <= 0:
        let empty: Bytes = emptyBytes()
        return Ok[Bytes](empty)
    let out: Bytes = bytesAlloc(maxBytes)
    let got: int32 = int32(tcpRawRead(conn.fd, out.data, int64(bytesLen(out))))
    if got < 0:
        let errCode: int32 = tcpErrno()
        return Err[Bytes](tcpErrMessage("tcp syscall: recv failed: ", errCode))
    if got == 0:
        let empty: Bytes = emptyBytes()
        return Ok[Bytes](empty)
    if got == bytesLen(out):
        return Ok[Bytes](out)
    return Ok[Bytes](bytesSlice(out, 0, got))

fn tcpRecvNonblocking(conn: var TcpConnectionHandle, maxBytes: int32): Result[Bytes] =
    if !conn.open:
        return Err[Bytes]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[Bytes]("tcp syscall: connection closed")
    if maxBytes <= 0:
        let empty: Bytes = emptyBytes()
        return Ok[Bytes](empty)
    let out: Bytes = bytesAlloc(maxBytes)
    let got: int32 = int32(tcpRawRead(conn.fd, out.data, int64(bytesLen(out))))
    if got < 0:
        let errCode: int32 = tcpErrno()
        if tcpWouldBlock(errCode):
            return Err[Bytes]("tcp syscall: would block")
        return Err[Bytes](tcpErrMessage("tcp syscall: recv failed: ", errCode))
    if got == 0:
        let empty: Bytes = emptyBytes()
        return Ok[Bytes](empty)
    if got == bytesLen(out):
        return Ok[Bytes](out)
    return Ok[Bytes](bytesSlice(out, 0, got))

fn tcpSendRaw(conn: var TcpConnectionHandle, data: ptr, dataLen: int32): Result[int32] =
    if !conn.open:
        return Err[int32]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[int32]("tcp syscall: connection closed")
    if data == nil || dataLen <= 0:
        return Ok[int32](0)
    var sentTotal: int32
    while sentTotal < dataLen:
        let chunkPtr: ptr = rawmem_support.RawmemPtrAdd(data, sentTotal)
        let wrote: int32 = int32(tcpRawWrite(conn.fd, chunkPtr, int64(dataLen - sentTotal)))
        if wrote <= 0:
            let errCode: int32 = tcpErrno()
            return Err[int32](tcpErrMessage("tcp syscall: send failed: ", errCode))
        sentTotal = sentTotal + wrote
    return Ok[int32](sentTotal)

fn tcpSendRawNonblocking(conn: var TcpConnectionHandle, data: ptr, dataLen: int32): Result[int32] =
    if !conn.open:
        return Err[int32]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[int32]("tcp syscall: connection closed")
    if data == nil || dataLen <= 0:
        return Ok[int32](0)
    let wrote: int32 = int32(tcpRawWrite(conn.fd, data, int64(dataLen)))
    if wrote < 0:
        let errCode: int32 = tcpErrno()
        if tcpWouldBlock(errCode):
            return Ok[int32](0)
        return Err[int32](tcpErrMessage("tcp syscall: send failed: ", errCode))
    return Ok[int32](wrote)

fn tcpRecvRaw(conn: var TcpConnectionHandle, out: ptr, outCap: int32): Result[int32] =
    if !conn.open:
        return Err[int32]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[int32]("tcp syscall: connection closed")
    if out == nil || outCap <= 0:
        return Ok[int32](0)
    let got: int32 = int32(tcpRawRead(conn.fd, out, int64(outCap)))
    if got < 0:
        let errCode: int32 = tcpErrno()
        return Err[int32](tcpErrMessage("tcp syscall: recv failed: ", errCode))
    return Ok[int32](got)

fn tcpRecvRawNonblocking(conn: var TcpConnectionHandle, out: ptr, outCap: int32): Result[int32] =
    if !conn.open:
        return Err[int32]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[int32]("tcp syscall: connection closed")
    if out == nil || outCap <= 0:
        return Ok[int32](0)
    let got: int32 = int32(tcpRawRead(conn.fd, out, int64(outCap)))
    if got < 0:
        let errCode: int32 = tcpErrno()
        if tcpWouldBlock(errCode):
            return Err[int32]("tcp syscall: would block")
        return Err[int32](tcpErrMessage("tcp syscall: recv failed: ", errCode))
    return Ok[int32](got)

fn tcpSetNonblocking(conn: TcpConnectionHandle, enabled: bool): Result[bool] =
    if conn.fd < 0:
        return Err[bool]("tcp syscall: invalid connection")
    let enabledCode: int32 = if enabled: 1 else: 0
    let rc: int32 = cheng_fd_set_nonblocking_bridge(conn.fd, enabledCode)
    if rc != 0:
        let errCode: int32 = tcpErrno()
        return Err[bool](tcpErrMessage("tcp syscall: connection nonblocking failed: ", errCode))
    return Ok[bool](true)

fn tcpShutdownWrite(conn: var TcpConnectionHandle): Result[bool] =
    if !conn.open:
        return Err[bool]("tcp syscall: connection closed")
    if conn.fd < 0:
        return Err[bool]("tcp syscall: connection closed")
    let rc: int32 = os.TcpShutdownFd(conn.fd, tcpShutdownWr)
    if rc != 0:
        let errCode: int32 = tcpErrno()
        return Err[bool](tcpErrMessage("tcp syscall: shutdown write failed: ", errCode))
    return Ok[bool](true)

fn tcpClose(conn: var TcpConnectionHandle) =
    if conn.fd >= 0:
        let closeRc: int32 = os.TcpShutdownFd(conn.fd, tcpShutdownRdWr)
        closeRc
        let _ = os.UdpCloseFd(conn.fd)
    conn.fd = -1
    conn.open = false

fn TcpConnect(host: str, port: int32, isV6: bool = false): Result[TcpConnectionHandle] =
    return tcpConnect(host, port, isV6)

fn TcpConnectResolved(host: str, port: int32): Result[TcpConnectionHandle] =
    return tcpConnectResolved(host, port)

fn TcpListen(host: str, port: int32, isV6: bool = false): Result[TcpListenerHandle] =
    return tcpListen(host, port, isV6)

fn TcpListenFill(host: str,
                 port: int32,
                 out: var TcpListenerHandle,
                 isV6: bool = false): Result[bool] =
    return tcpListenFill(host, port, out, isV6)

fn TcpListenerClose(listener: var TcpListenerHandle) =
    tcpListenerClose(listener)

fn TcpListenerSetNonblocking(listener: TcpListenerHandle, enabled: bool): Result[bool] =
    return tcpListenerSetNonblocking(listener, enabled)

fn TcpListenerWaitReadable(listener: TcpListenerHandle, timeoutMs: int32): Result[bool] =
    return tcpListenerWaitReadable(listener, timeoutMs)

fn TcpAccept(listener: TcpListenerHandle): Result[TcpConnectionHandle] =
    return tcpAccept(listener)

fn TcpAcceptNonblocking(listener: TcpListenerHandle): Result[TcpConnectionHandle] =
    return tcpAcceptNonblocking(listener)

fn TcpSetNonblocking(conn: TcpConnectionHandle, enabled: bool): Result[bool] =
    return tcpSetNonblocking(conn, enabled)

fn TcpSend(conn: var TcpConnectionHandle, data: Bytes): Result[int32] =
    return tcpSend(conn, data)

fn TcpSendNonblocking(conn: var TcpConnectionHandle, data: Bytes): Result[int32] =
    return tcpSendNonblocking(conn, data)

fn TcpSendRaw(conn: var TcpConnectionHandle, data: ptr, dataLen: int32): Result[int32] =
    return tcpSendRaw(conn, data, dataLen)

fn TcpSendRawNonblocking(conn: var TcpConnectionHandle, data: ptr, dataLen: int32): Result[int32] =
    return tcpSendRawNonblocking(conn, data, dataLen)

fn TcpRecv(conn: var TcpConnectionHandle, maxBytes: int32): Result[Bytes] =
    return tcpRecv(conn, maxBytes)

fn TcpRecvNonblocking(conn: var TcpConnectionHandle, maxBytes: int32): Result[Bytes] =
    return tcpRecvNonblocking(conn, maxBytes)

fn TcpRecvRaw(conn: var TcpConnectionHandle, out: ptr, outCap: int32): Result[int32] =
    return tcpRecvRaw(conn, out, outCap)

fn TcpRecvRawNonblocking(conn: var TcpConnectionHandle, out: ptr, outCap: int32): Result[int32] =
    return tcpRecvRawNonblocking(conn, out, outCap)

fn TcpClose(conn: var TcpConnectionHandle) =
    tcpClose(conn)

fn TcpShutdownWrite(conn: var TcpConnectionHandle): Result[bool] =
    return tcpShutdownWrite(conn)
