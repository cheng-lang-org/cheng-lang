# std/hrtnet_driver (driver-side init/bind)
import std/hrt_ring
import std/hrtnet

type
    HrtNetDriverHandle = void*
    HrtNetDriverMap =
        rxMeta: hrt_ring.HrtRingMeta*
        rxSlots: hrtnet.HrtNetSlot*
        txMeta: hrt_ring.HrtRingMeta*
        txSlots: hrtnet.HrtNetSlot*

@importc("cheng_hrt_netdev_open")
fn cheng_hrt_netdev_open(ifname: cstring, queue: int32, rxCap: int32, txCap: int32): HrtNetDriverHandle

@importc("cheng_hrt_netdev_close")
fn cheng_hrt_netdev_close(handle: HrtNetDriverHandle)

@importc("cheng_hrt_netdev_map")
fn cheng_hrt_netdev_map(handle: HrtNetDriverHandle, outMap: HrtNetDriverMap*): bool

@importc("cheng_hrt_netdev_poll_rx")
fn cheng_hrt_netdev_poll_rx(handle: HrtNetDriverHandle): bool

@importc("cheng_hrt_netdev_kick_tx")
fn cheng_hrt_netdev_kick_tx(handle: HrtNetDriverHandle): bool

@importc("cheng_hrt_netdev_stub_rx_push")
fn cheng_hrt_netdev_stub_rx_push(handle: HrtNetDriverHandle, len: int32, flags: int32): bool

fn hrtNetDriverOpen(ifname: cstring, queue: int32, rxCap: int32, txCap: int32): HrtNetDriverHandle =
    return cheng_hrt_netdev_open(ifname, queue, rxCap, txCap)

fn hrtNetDriverClose(handle: HrtNetDriverHandle) =
    cheng_hrt_netdev_close handle

fn hrtNetDriverMap(handle: HrtNetDriverHandle, outMap: HrtNetDriverMap*): bool =
    return cheng_hrt_netdev_map(handle, outMap)

fn hrtNetDriverPollRx(handle: HrtNetDriverHandle): bool =
    return cheng_hrt_netdev_poll_rx handle

fn hrtNetDriverKickTx(handle: HrtNetDriverHandle): bool =
    return cheng_hrt_netdev_kick_tx handle

fn hrtNetDriverStubRxPush(handle: HrtNetDriverHandle, len: int32, flags: int32): bool =
    return cheng_hrt_netdev_stub_rx_push(handle, len, flags)

fn hrtNetDriverOpenStr(ifname: str, queue: int32, rxCap: int32, txCap: int32): HrtNetDriverHandle =
    let name: cstring = cstring(ifname)
    return hrtNetDriverOpen(name, queue, rxCap, txCap)

fn hrtNetDriverBind(queue: hrtnet.HrtNetQueue*, map: HrtNetDriverMap*): bool =
    if map == nil:
        return false
    if hrtnet.hrtNetBindRx(queue, map->rxMeta, map->rxSlots) == false:
        return false
    if hrtnet.hrtNetBindTx(queue, map->txMeta, map->txSlots) == false:
        return false
    return true
