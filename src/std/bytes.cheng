# bytes.cheng - minimal binary buffer + reader helpers
import std/system as system
import std/rawmem_support

type
    File = ptr

type
    ByteBuffer =
        len: int32
        data: ptr

type
    ByteReader =
        buf: ByteBuffer
        pos: int32

@importc("cheng_jpeg_decode")
fn c_jpeg_decode(data: ptr, len: int32, out_w: ptr, out_h: ptr): ptr
@importc("cheng_jpeg_free")
fn c_jpeg_free(p: ptr)
@importc("cheng_fopen")
fn bytesChengFopen(filename, mode: cstring): File
@importc("fopen")
fn bytesLibcFopen(filename, mode: cstring): File
fn bytesFopen(filename, mode: cstring): File =
    let f: File = bytesChengFopen(filename, mode)
    if f != nil:
        return f
    return bytesLibcFopen(filename, mode)
@importc("cheng_fclose")
fn bytesFclose(f: File): int32
@importc("cheng_fread")
fn bytesFread(ptr: ptr, size, n: int64, stream: File): int32
@importc("cheng_fseek")
fn bytesFseek(stream: File, offset: int64, whence: int32): int32
@importc("driver_c_read_file_all")
fn bytesReadFileAllRaw(path: cstring): cstring
@importc("cheng_file_size")
fn bytesFileSize(path: cstring): int64
@importc("cheng_rawbytes_get_at")
fn bytesRawGetAt(base: ptr, idx: int32): int32
@importc("cheng_rawbytes_set_at")
fn bytesRawSetAt(base: ptr, idx: int32, value: int32)

fn bytesReadFileAll(path: cstring): str =
    return system.strFromCStringBorrow(bytesReadFileAllRaw(path))

fn emptyBytes(): ByteBuffer =
    var out: ByteBuffer
    out.len = 0
    out.data = nil
    return out

fn newByteBuffer(len: int32): ByteBuffer =
    if len <= 0:
        return emptyBytes()
    let p: ptr = alloc(len)
    var out: ByteBuffer
    out.len = len
    out.data = p
    return out

fn freeByteBuffer(buf: var ByteBuffer) =
    if buf.data != nil:
        free(buf.data)
    buf.data = nil
    buf.len = 0

fn fileExists(path: str): bool =
    let f: File = bytesFopen(path, "rb")
    if f == nil:
        return false
    let _ = bytesFclose(f)
    return true

fn readFileText(path: str): str =
    return bytesReadFileAll(system.strToCStringTemp(path))

fn readFileBytes(path: str): ByteBuffer =
    var out: ByteBuffer = emptyBytes()
    let f: File = bytesFopen(path, "rb")
    if f == nil:
        return out
    let size64: int64 = bytesFileSize(path)
    if size64 <= 0 || size64 > int64(2147483647):
        let _ = bytesFclose(f)
        return out
    let cap: int32 = int32(size64)
    let buf: ptr = alloc(cap)
    if buf == nil:
        let _ = bytesFclose(f)
        return out
    var lenRead: int32
    while lenRead < cap:
        let avail: int32 = cap - lenRead
        let dst: ptr = rawmem_support.RawmemPtrAdd(buf, lenRead)
        let got: int32 = bytesFread(dst, 1, avail, f)
        if got <= 0:
            break
        lenRead = lenRead + got
    let _ = bytesFclose(f)
    out.len = lenRead
    out.data = buf
    return out

fn readFileSlice(path: str, offset: int32, count: int32): ByteBuffer =
    var empty: ByteBuffer = emptyBytes()
    if offset < 0 || count <= 0:
        return empty
    let f: File = bytesFopen(path, "rb")
    if f == nil:
        return empty
    let size64: int64 = bytesFileSize(path)
    if size64 <= 0 || int64(offset) + int64(count) > size64:
        let _ = bytesFclose(f)
        return empty
    if bytesFseek(f, int64(offset), 0) != 0:
        let _ = bytesFclose(f)
        return empty
    var out: ByteBuffer = newByteBuffer(count)
    if out.data == nil:
        let _ = bytesFclose(f)
        return empty
    var lenRead: int32
    while lenRead < count:
        let avail: int32 = count - lenRead
        let dst: ptr = rawmem_support.RawmemPtrAdd(out.data, lenRead)
        let got: int32 = bytesFread(dst, 1, avail, f)
        if got <= 0:
            break
        lenRead = lenRead + got
    let _ = bytesFclose(f)
    if lenRead != count:
        freeByteBuffer(out)
        return empty
    return out

fn bufByteAt(buf: ByteBuffer, idx: int32): int32 =
    if idx < 0 || idx >= buf.len:
        return -1
    var v: int32 = bytesRawGetAt(buf.data, idx)
    if v < 0:
        v = v + 256
    return v

fn bufSetByte(buf: ByteBuffer, idx: int32, val: int32) =
    if idx < 0 || idx >= buf.len:
        return
    bytesRawSetAt(buf.data, idx, val)

fn writeU32LEAt(buf: ByteBuffer, idx: int32, val: int32) =
    if idx < 0 || idx + 4 > buf.len:
        return
    bufSetByte(buf, idx, val & 255)
    bufSetByte(buf, idx + 1,(val >> 8) & 255)
    bufSetByte(buf, idx + 2,(val >> 16) & 255)
    bufSetByte(buf, idx + 3,(val >> 24) & 255)

fn writeF32LEAt(buf: ByteBuffer, idx: int32, value: float64) =
    let bits: int32 = system.f32ToBits(value)
    writeU32LEAt(buf, idx, bits)

fn readU16LEAt(buf: ByteBuffer, idx: int32): int32 =
    if idx < 0 || idx + 2 > buf.len:
        return -1
    let b0: int32 = bufByteAt(buf, idx)
    let b1: int32 = bufByteAt(buf, idx + 1)
    return b0 +(b1 << 8)

fn readU32LEAt(buf: ByteBuffer, idx: int32): int32 =
    if idx < 0 || idx + 4 > buf.len:
        return -1
    let b0: int32 = bufByteAt(buf, idx)
    let b1: int32 = bufByteAt(buf, idx + 1)
    let b2: int32 = bufByteAt(buf, idx + 2)
    let b3: int32 = bufByteAt(buf, idx + 3)
    return b0 +(b1 << 8) +(b2 << 16) +(b3 << 24)

fn bufMatchFourCC(buf: ByteBuffer, idx: int32, b0, b1, b2, b3: int32): bool =
    if idx < 0 || idx + 4 > buf.len:
        return false
    return bufByteAt(buf, idx) == b0 && bufByteAt(buf, idx + 1) == b1 &&
        bufByteAt(buf, idx + 2) == b2 && bufByteAt(buf, idx + 3) == b3

fn readerFromBytes(buf: ByteBuffer): ByteReader =
    var out: ByteReader
    out.buf = buf
    out.pos = 0
    return out

fn canRead(r: var ByteReader, count: int32): bool =
    return r.pos + count <= r.buf.len

fn seek(r: var ByteReader, pos: int32) =
    if pos < 0:
        r.pos = 0
    elif pos > r.buf.len:
        r.pos = r.buf.len
    else:
        r.pos = pos

fn skip(r: var ByteReader, count: int32) =
    seek(r, r.pos + count)

fn readU8(r: var ByteReader): int32 =
    if !canRead(r, 1):
        return -1
    let v: int32 = bufByteAt(r.buf, r.pos)
    r.pos = r.pos + 1
    return v

fn readU16LE(r: var ByteReader): int32 =
    if !canRead(r, 2):
        return -1
    let b0: int32 = bufByteAt(r.buf, r.pos)
    let b1: int32 = bufByteAt(r.buf, r.pos + 1)
    r.pos = r.pos + 2
    return b0 +(b1 << 8)

fn readU32LE(r: var ByteReader): int32 =
    if !canRead(r, 4):
        return -1
    let b0: int32 = bufByteAt(r.buf, r.pos)
    let b1: int32 = bufByteAt(r.buf, r.pos + 1)
    let b2: int32 = bufByteAt(r.buf, r.pos + 2)
    let b3: int32 = bufByteAt(r.buf, r.pos + 3)
    r.pos = r.pos + 4
    return b0 +(b1 << 8) +(b2 << 16) +(b3 << 24)

fn readF32LE(r: var ByteReader): float64 =
    let bits: int32 = readU32LE(r)
    return system.bitsToF32(bits)

fn readF32LEAt(buf: ByteBuffer, idx: int32): float64 =
    let bits: int32 = readU32LEAt(buf, idx)
    return system.bitsToF32(bits)

fn decodeJpegRgba(data: ByteBuffer): ByteBuffer =
    if data.data == nil || data.len <= 0:
        return emptyBytes()
    let wPtr: ptr = alloc(4)
    let hPtr: ptr = alloc(4)
    var out: ByteBuffer = emptyBytes()
    let p: ptr = c_jpeg_decode(data.data, data.len, wPtr, hPtr)
    if p != nil:
        let w: int32 = load[int32] wPtr
        let h: int32 = load[int32] hPtr
        let size: int32 = w * h * 4
        if size > 0:
            out = newByteBuffer(size)
            rawmem_support.RawmemCopy(out.data, p, size)
    c_jpeg_free(p)
    free(wPtr)
    free(hPtr)
    return out

fn ReadFileBytes(path: str): ByteBuffer =
    return readFileBytes(path)

fn ReadFileSlice(path: str, offset: int32, count: int32): ByteBuffer =
    return readFileSlice(path, offset, count)

fn NewByteBuffer(len: int32): ByteBuffer =
    return newByteBuffer(len)

fn FreeByteBuffer(buf: var ByteBuffer) =
    freeByteBuffer(buf)

fn BufByteAt(buf: ByteBuffer, idx: int32): int32 =
    return bufByteAt(buf, idx)

fn BufSetByte(buf: ByteBuffer, idx: int32, val: int32) =
    bufSetByte(buf, idx, val)

fn ReadU16LEAt(buf: ByteBuffer, idx: int32): int32 =
    return readU16LEAt(buf, idx)

fn ReadU32LEAt(buf: ByteBuffer, idx: int32): int32 =
    return readU32LEAt(buf, idx)
