module hashsets
import std/hashmaps

type
    HashSetStr =
        map: hashmaps.HashMapStrInt

fn hashSetStrInit(cap0: int32 = 16): HashSetStr =
    var s: HashSetStr
    s.map = hashmaps.hashMapStrIntInit(cap0)
    return s

fn hashSetStrClear(s: HashSetStr*) =
    if s == nil:
        return
    hashmaps.hashMapStrIntClear(&s->map)

fn hashSetStrAdd(s: HashSetStr*, key: str) =
    if s == nil || key == nil:
        return
    hashmaps.hashMapStrIntPut(&s->map, key, 1)

fn hashSetStrHas(s: HashSetStr, key: str): bool =
    var found: bool = false
    hashmaps.hashMapStrIntGet(s.map, key, &found)
    return found
