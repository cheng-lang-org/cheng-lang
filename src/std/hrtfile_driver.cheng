# std/hrtfile_driver (driver-side init/bind)
import std/hrt_ring
import std/hrtfile

type
    HrtFileDriverHandle = void*
    HrtFileDriverMap =
        submitMeta: hrt_ring.HrtRingMeta*
        submitSlots: hrtfile.HrtFileReq*
        completeMeta: hrt_ring.HrtRingMeta*
        completeSlots: hrtfile.HrtFileCpl*

@importc("cheng_hrt_filedev_open")
fn cheng_hrt_filedev_open(path: cstring, submitCap: int32, completeCap: int32): HrtFileDriverHandle

@importc("cheng_hrt_filedev_close")
fn cheng_hrt_filedev_close(handle: HrtFileDriverHandle)

@importc("cheng_hrt_filedev_map")
fn cheng_hrt_filedev_map(handle: HrtFileDriverHandle, outMap: HrtFileDriverMap*): bool

@importc("cheng_hrt_filedev_poll")
fn cheng_hrt_filedev_poll(handle: HrtFileDriverHandle): int32

fn hrtFileDriverOpen(path: cstring, submitCap: int32, completeCap: int32): HrtFileDriverHandle =
    return cheng_hrt_filedev_open(path, submitCap, completeCap)

fn hrtFileDriverClose(handle: HrtFileDriverHandle) =
    cheng_hrt_filedev_close handle

fn hrtFileDriverMap(handle: HrtFileDriverHandle, outMap: HrtFileDriverMap*): bool =
    return cheng_hrt_filedev_map(handle, outMap)

fn hrtFileDriverPoll(handle: HrtFileDriverHandle): int32 =
    return cheng_hrt_filedev_poll handle

fn hrtFileDriverOpenStr(path: str, submitCap: int32, completeCap: int32): HrtFileDriverHandle =
    let name: cstring = cstring(path)
    return hrtFileDriverOpen(name, submitCap, completeCap)

fn hrtFileDriverBind(queue: var hrtfile.HrtFileQueue, map: HrtFileDriverMap): bool =
    if hrtfile.hrtFileBindSubmit(queue, map.submitMeta, map.submitSlots) == false:
        return false
    if hrtfile.hrtFileBindComplete(queue, map.completeMeta, map.completeSlots) == false:
        return false
    return true
