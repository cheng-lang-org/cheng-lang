module cmdline
# Command-line args (bootstrap minimal implementation):
# - Injected by calling `__cheng_setCmdLine(argc, argv)` in `main(argc, argv)`.
# - In bootstrap runtime, str == cstring(null-terminated); argv[i] can be used as str.
# - ptr_add uses byte offsets, so use 64-bit pointer size (8) here.

var __cheng_cmdCount: int32 = 0
var __cheng_cmdLine: void* = nil
const __cheng_cmdCountMax: int32 = 4096

fn __cheng_setCmdLine(argc: int32, argv: void*) =
    __cheng_cmdCount = argc
    __cheng_cmdLine = argv

fn paramCount(): int32 =
    if __cheng_cmdCount <= 0:
        return 0
    if __cheng_cmdLine == nil:
        return 0
    if __cheng_cmdCount > __cheng_cmdCountMax:
        return 0
    return __cheng_cmdCount - 1

fn paramStr(i: int32): str =
    if i < 0:
        return ""
    if __cheng_cmdLine == nil:
        return ""
    if __cheng_cmdCount > __cheng_cmdCountMax:
        return ""
    if i >= __cheng_cmdCount:
        return ""
    var idx64: int64 = int64(i)
    var off64: int64 = idx64 * 8
    var off32: int32 = int32(off64)
    let p: void* = ptr_add(__cheng_cmdLine, off32)
    return load[str] p
