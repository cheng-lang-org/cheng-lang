module hashmaps
import std/seqs
import std/strings
import std/system

type
    HashMapStrInt =
        keys: str[]
        vals: int32[]
        states: uint8[] # 0=empty, 1=used
        mask: uint64
        used: int32

    HashMapStrSeqInt =
        keys: str[]
        valStart: int32[]
        valLen: int32[]
        valCap: int32[]
        states: uint8[] # 0=empty, 1=used
        pool: int32[]
        mask: uint64
        used: int32

    HashMapPtrInt =
        keys: int64[]
        vals: int32[]
        states: uint8[] # 0=empty, 1=used
        mask: uint64
        used: int32

    # Concrete seq aliases keep old-builder object returns stable.
    hashMap_seq_int32 = int32[]
    hashMap_seq_int64 = int64[]
    hashMap_seq_str = str[]
    hashMap_seq_uint8 = uint8[]

fn hashMapReturnSeqInt32(out: int32[]): int32[] =
    return hashMap_seq_int32(len: out.len, cap: out.cap, buffer: out.buffer)

fn hashMapReturnSeqInt64(out: int64[]): int64[] =
    return hashMap_seq_int64(len: out.len, cap: out.cap, buffer: out.buffer)

fn hashMapReturnSeqStr(out: str[]): str[] =
    return hashMap_seq_str(len: out.len, cap: out.cap, buffer: out.buffer)

fn hashMapReturnSeqUint8(out: uint8[]): uint8[] =
    return hashMap_seq_uint8(len: out.len, cap: out.cap, buffer: out.buffer)

fn hashMapAppendInt32(seqInst: var int32[], value: int32) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = value

fn hashMapAppendStr(seqInst: var str[], value: str) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = value

fn hashMapNextPow2(n0: int32, minCap: int32 = 8): int32 =
    var n: int32 = n0
    if n < minCap:
        n = minCap
    var cap: int32 = 1
    while cap < n:
        cap = cap * 2
    return cap

fn hashMapAllocZeroSeq[T](cap0: int32): T[] =
    if cap0 <= 0:
        return []
    let bytes64: int64 = int64(cap0) * int64(elemSize[T]())
    if bytes64 <= 0 || bytes64 > int64(2147483647):
        panic("hashmaps: allocation overflow")
    var out: T[]
    reserve(out, cap0)
    setLen(out, cap0)
    return out

# Stage1/self-link fallback symbols for concrete seq alloc helpers.
fn hashMapAllocZeroSeq_int32(cap0: int32): int32[] =
    var out: int32[]
    if cap0 > 0:
        let bytes64: int64 = int64(cap0) * int64(elemSize[int32]())
        if bytes64 <= 0 || bytes64 > int64(2147483647):
            panic("hashmaps: allocation overflow")
        cheng__seqGrowToRaw(&out.buffer, &out.cap, cap0, elemSize[int32]())
        cheng__seqZeroTailRaw(out.buffer, out.cap, 0, cap0, elemSize[int32]())
        out.len = cap0
    return hashMapReturnSeqInt32(out)

fn hashMapAllocZeroSeq_int64(cap0: int32): int64[] =
    var out: int64[]
    if cap0 > 0:
        let bytes64: int64 = int64(cap0) * int64(elemSize[int64]())
        if bytes64 <= 0 || bytes64 > int64(2147483647):
            panic("hashmaps: allocation overflow")
        cheng__seqGrowToRaw(&out.buffer, &out.cap, cap0, elemSize[int64]())
        cheng__seqZeroTailRaw(out.buffer, out.cap, 0, cap0, elemSize[int64]())
        out.len = cap0
    return hashMapReturnSeqInt64(out)

fn hashMapAllocZeroSeq_str(cap0: int32): str[] =
    var out: str[]
    if cap0 > 0:
        let bytes64: int64 = int64(cap0) * int64(elemSize[str]())
        if bytes64 <= 0 || bytes64 > int64(2147483647):
            panic("hashmaps: allocation overflow")
        cheng__seqGrowToRaw(&out.buffer, &out.cap, cap0, elemSize[str]())
        cheng__seqZeroTailRaw(out.buffer, out.cap, 0, cap0, elemSize[str]())
        out.len = cap0
    return hashMapReturnSeqStr(out)

fn hashMapAllocZeroSeq_uint8(cap0: int32): uint8[] =
    var out: uint8[]
    if cap0 > 0:
        let bytes64: int64 = int64(cap0) * int64(elemSize[uint8]())
        if bytes64 <= 0 || bytes64 > int64(2147483647):
            panic("hashmaps: allocation overflow")
        cheng__seqGrowToRaw(&out.buffer, &out.cap, cap0, elemSize[uint8]())
        cheng__seqZeroTailRaw(out.buffer, out.cap, 0, cap0, elemSize[uint8]())
        out.len = cap0
    return hashMapReturnSeqUint8(out)

fn hashMapHash64StrMetaRaw(dataPtr0: ptr, n: int32): uint64 =
    var h: uint64 = (uint64(1469598103) * uint64(1000000000)) + uint64(934665603)
    if n <= 0:
        return h
    if dataPtr0 == nil:
        return h
    for i in 0..<n:
        let ch: uint64 = uint64(load(system_ptr_add(dataPtr0, i)))
        h = h ^ ch
        h = h * ((uint64(1099511628) * uint64(1000)) + uint64(211))
    return h

fn hashMapHash64StrMeta(s: str): uint64 =
    return hashMapHash64StrMetaRaw(strDataPtr(s), strLenFast(s))

fn hashMapHash64Str(s: str): uint64 =
    return hashMapHash64StrMeta(s)

fn hashMapHash64Ptr(p: int64): uint64 =
    if p == 0:
        return 0
    var h: uint64 = uint64(p)
    h = h ^ (h >> 33)
    h = h ^ (h >> 17)
    h = h ^ (h >> 9)
    return h

fn hashMapStrEq(cur: str, key: str): bool =
    return hashMapStrEq(cur, key, strLenFast(key), strDataPtr(key))

fn hashMapStrEq(cur: str, key: str, keyLen: int32, keyPtr: ptr): bool =
    if keyLen <= 0:
        return false
    let nCur: int32 = strLenFast(cur)
    if nCur != keyLen:
        return false
    let curPtr: ptr = strDataPtr(cur)
    if curPtr == keyPtr:
        return true
    if curPtr == nil || keyPtr == nil:
        return false
    return cmpMem(curPtr, keyPtr, int64(keyLen)) == 0

fn hashMapStrIntInit(cap0: int32 = 16): HashMapStrInt =
    var m: HashMapStrInt
    hashMapStrIntInitInPlace(m, cap0)
    return HashMapStrInt(keys: m.keys,
                         vals: m.vals,
                         states: m.states,
                         mask: m.mask,
                         used: m.used)

fn hashMapStrIntInitInPlace(m: var HashMapStrInt, cap0: int32 = 16) =
    let cap: int32 = hashMapNextPow2(cap0, 8)
    let keys: str[] = hashMapAllocZeroSeq_str(cap)
    let vals: int32[] = hashMapAllocZeroSeq_int32(cap)
    let states: uint8[] = hashMapAllocZeroSeq_uint8(cap)
    for i in 0..<cap:
        keys[i] = nil
        vals[i] = 0
        states[i] = uint8(0)
    m.keys = keys
    m.vals = vals
    m.states = states
    m.mask = uint64(cap - 1)
    m.used = 0

fn hashMapStrIntClear(m: var HashMapStrInt) =
    if m.keys.len <= 0:
        m.mask = 0
        m.used = 0
    else:
        for i in 0..<m.keys.len:
            m.keys[i] = nil
            m.vals[i] = 0
            m.states[i] = uint8(0)
        m.used = 0

fn hashMapStrIntFindSlot(m: HashMapStrInt, key: str, allowInsert: bool): int32 =
    let keyLen: int32 = strLenFast(key)
    if keyLen <= 0 || m.mask == 0:
        return -1
    let keyPtr: ptr = strDataPtr(key)
    let mask: int32 = int32(m.mask)
    let states: uint8[] = m.states
    let keys: str[] = m.keys
    var probe: int32 = int32(hashMapHash64StrMetaRaw(keyPtr, keyLen) & uint64(mask))
    var scanned: int32
    for scanned in scanned..mask:
        let st: uint8 = states[probe]
        if st == uint8(0):
            if allowInsert:
                return probe
            return -1
        let cur: str = keys[probe]
        if hashMapStrEq(cur, key, keyLen, keyPtr):
            return probe
        probe = (probe + 1) & mask
    return -1

fn hashMapStrIntFindSlotMut(m: var HashMapStrInt, key: str, allowInsert: bool): int32 =
    let keyLen: int32 = strLenFast(key)
    if keyLen <= 0 || m.mask == 0:
        return -1
    let keyPtr: ptr = strDataPtr(key)
    let mask: int32 = int32(m.mask)
    let states: uint8[] = m.states
    let keys: str[] = m.keys
    var probe: int32 = int32(hashMapHash64StrMetaRaw(keyPtr, keyLen) & uint64(mask))
    var scanned: int32
    for scanned in scanned..mask:
        let st: uint8 = states[probe]
        if st == uint8(0):
            if allowInsert:
                return probe
            return -1
        let cur: str = keys[probe]
        if hashMapStrEq(cur, key, keyLen, keyPtr):
            return probe
        probe = (probe + 1) & mask
    return -1

fn hashMapStrIntGrow(m: var HashMapStrInt) =
    let oldKeys: str[] = m.keys
    let oldVals: int32[] = m.vals
    let oldStates: uint8[] = m.states
    let oldCap: int32 = oldKeys.len

    var newCap: int32 = oldCap * 2
    if newCap <= 0:
        newCap = 16
    let nextCap: int32 = hashMapNextPow2(newCap, 8)
    var nextMap: HashMapStrInt = hashMapStrIntInit(nextCap)

    for i in 0..<oldCap:
        if oldStates[i] == uint8(1):
            let key: str = oldKeys[i]
            let val: int32 = oldVals[i]
            let slot: int32 = hashMapStrIntFindSlotMut(nextMap, key, true)
            if slot >= 0:
                nextMap.keys[slot] = key
                nextMap.vals[slot] = val
                nextMap.states[slot] = uint8(1)
                nextMap.used = nextMap.used + 1
    m = nextMap

fn hashMapStrIntPut(m: var HashMapStrInt, key: str, val: int32) =
    if len(key) > 0:
        if m.mask == 0:
            hashMapStrIntInitInPlace(m, 16)
        if (m.used + 1) * 10 >= m.keys.len * 7:
            hashMapStrIntGrow(m)
        let slot: int32 = hashMapStrIntFindSlotMut(m, key, true)
        if slot >= 0:
            if m.states[slot] == uint8(0):
                m.used = m.used + 1
                m.states[slot] = uint8(1)
            m.keys[slot] = key
            m.vals[slot] = val

fn hashMapStrIntGetEx(m: HashMapStrInt, key: str, found: var bool): int32 =
    if len(key) == 0 || m.mask == 0:
        found = false
        return 0
    let slot: int32 = hashMapStrIntFindSlot(m, key, false)
    if slot < 0:
        found = false
        return 0
    found = true
    return m.vals[slot]

fn hashMapStrIntGetEx(m: var HashMapStrInt, key: str, found: var bool): int32 =
    return hashMapStrIntGetMutEx(m, key, found)

fn hashMapStrIntGet(m: HashMapStrInt, key: str): int32 =
    var found: bool
    return hashMapStrIntGetEx(m, key, found)

fn hashMapStrIntGet(m: HashMapStrInt, key: str, found: var bool): int32 =
    if len(key) == 0 || m.mask == 0:
        found = false
        return 0
    let slot: int32 = hashMapStrIntFindSlot(m, key, false)
    if slot < 0:
        found = false
        return 0
    found = true
    return m.vals[slot]

fn hashMapStrIntGetMut(m: var HashMapStrInt, key: str): int32 =
    var found: bool
    return hashMapStrIntGetMutEx(m, key, found)

fn hashMapStrIntGetMutEx(m: var HashMapStrInt, key: str, found: var bool): int32 =
    if len(key) == 0 || m.mask == 0:
        found = false
        return 0
    let slot: int32 = hashMapStrIntFindSlotMut(m, key, false)
    if slot < 0:
        found = false
        return 0
    found = true
    return m.vals[slot]

fn hashMapStrIntGet(m: var HashMapStrInt, key: str): int32 =
    var found: bool
    return hashMapStrIntGetMutEx(m, key, found)

fn hashMapStrIntGet(m: var HashMapStrInt, key: str, found: var bool): int32 =
    return hashMapStrIntGetMutEx(m, key, found)

fn `[]`(m: HashMapStrInt, key: str): int32 =
    var found: bool
    return hashMapStrIntGetEx(m, key, found)

fn `[]=`(m: var HashMapStrInt, key: str, val: int32) =
    hashMapStrIntPut(m, key, val)

fn hashMapStrIntGetOrInsertExPtr(m: var HashMapStrInt, key: str, newVal: int32, foundPtr: ptr = nil): int32 =
    if len(key) == 0:
        if foundPtr != nil:
            var found0: bool
            memCopyCompat(foundPtr, &found0, int32(sizeof(bool)))
        return newVal
    if m.mask == 0:
        hashMapStrIntInitInPlace(m, 16)
    if (m.used + 1) * 10 >= m.keys.len * 7:
        hashMapStrIntGrow(m)
    let slot: int32 = hashMapStrIntFindSlotMut(m, key, true)
    if slot < 0:
        if foundPtr != nil:
            var found1: bool
            memCopyCompat(foundPtr, &found1, int32(sizeof(bool)))
        return newVal
    let existed: bool = (m.states[slot] == uint8(1))
    if !existed:
        m.used = m.used + 1
        m.states[slot] = uint8(1)
        m.keys[slot] = key
        m.vals[slot] = newVal
    if foundPtr != nil:
        var found2: bool = existed
        memCopyCompat(foundPtr, &found2, int32(sizeof(bool)))
    return m.vals[slot]

fn hashMapStrIntGetOrInsertEx(m: var HashMapStrInt, key: str, newVal: int32, foundPtr: ptr = nil): int32 =
    return hashMapStrIntGetOrInsertExPtr(m, key, newVal, foundPtr)

fn hashMapStrIntGetOrInsertEx(m: var HashMapStrInt, key: str, newVal: int32, found: var bool): int32 =
    return hashMapStrIntGetOrInsertExPtr(m, key, newVal, &found)

fn hashMapStrIntGetOrInsert(m: var HashMapStrInt, key: str, newVal: int32): int32 =
    return hashMapStrIntGetOrInsertExPtr(m, key, newVal, nil)

fn hashMapStrIntGetOrInsert(m: var HashMapStrInt, key: str, newVal: int32, found: var bool): int32 =
    return hashMapStrIntGetOrInsertExPtr(m, key, newVal, &found)

fn hashMapStrSeqIntInit(cap0: int32 = 16): HashMapStrSeqInt =
    let capHint: int32 = (cap0 < 64) ? 64 : cap0
    let cap: int32 = hashMapNextPow2(capHint, 8)
    let keys: str[] = hashMapAllocZeroSeq_str(cap)
    var valStart: int32[] = hashMapAllocZeroSeq_int32(cap)
    let valLen: int32[] = hashMapAllocZeroSeq_int32(cap)
    let valCap: int32[] = hashMapAllocZeroSeq_int32(cap)
    let states: uint8[] = hashMapAllocZeroSeq_uint8(cap)
    var pool: int32[]
    for i in 0..<cap:
        valStart[i] = -1
    return HashMapStrSeqInt(keys: keys,
                            valStart: valStart,
                            valLen: valLen,
                            valCap: valCap,
                            states: states,
                            pool: pool,
                            mask: uint64(cap - 1),
                            used: 0)

fn hashMapStrSeqIntClear(m: var HashMapStrSeqInt) =
    if m.keys.len <= 0:
        m.mask = 0
        m.used = 0
        m.pool.len = 0
    else:
        for i in 0..<m.keys.len:
            m.keys[i] = nil
            m.valStart[i] = -1
            m.valLen[i] = 0
            m.valCap[i] = 0
            m.states[i] = uint8(0)
        m.pool.len = 0
        m.used = 0

fn hashMapStrSeqIntFindSlot(m: HashMapStrSeqInt, key: str, allowInsert: bool): int32 =
    let keyLen: int32 = strLenFast(key)
    if keyLen <= 0 || m.mask == 0:
        return -1
    let keyPtr: ptr = strDataPtr(key)
    let mask: int32 = int32(m.mask)
    let states: uint8[] = m.states
    let keys: str[] = m.keys
    var probe: int32 = int32(hashMapHash64StrMetaRaw(keyPtr, keyLen) & uint64(mask))
    var scanned: int32
    for scanned in scanned..mask:
        let st: uint8 = states[probe]
        if st == uint8(0):
            if allowInsert:
                return probe
            return -1
        let cur: str = keys[probe]
        if hashMapStrEq(cur, key, keyLen, keyPtr):
            return probe
        probe = (probe + 1) & mask
    return -1

fn hashMapStrSeqIntFindSlotMut(m: var HashMapStrSeqInt, key: str, allowInsert: bool): int32 =
    let keyLen: int32 = strLenFast(key)
    if keyLen <= 0 || m.mask == 0:
        return -1
    let keyPtr: ptr = strDataPtr(key)
    let mask: int32 = int32(m.mask)
    let states: uint8[] = m.states
    let keys: str[] = m.keys
    var probe: int32 = int32(hashMapHash64StrMetaRaw(keyPtr, keyLen) & uint64(mask))
    var scanned: int32
    for scanned in scanned..mask:
        let st: uint8 = states[probe]
        if st == uint8(0):
            if allowInsert:
                return probe
            return -1
        let cur: str = keys[probe]
        if hashMapStrEq(cur, key, keyLen, keyPtr):
            return probe
        probe = (probe + 1) & mask
    return -1

fn hashMapStrSeqIntStoreSeqAt(m: var HashMapStrSeqInt, slot: int32, val: int32[]) =
    if slot >= 0 && slot < m.keys.len:
        if val.len <= 0:
            m.valStart[slot] = -1
            m.valLen[slot] = 0
            m.valCap[slot] = 0
        else:
            let oldStart: int32 = m.valStart[slot]
            let oldCap: int32 = m.valCap[slot]
            if oldStart >= 0 && oldCap >= val.len && oldStart + oldCap <= m.pool.len:
                m.valLen[slot] = val.len
                for i in 0..<val.len:
                    m.pool[oldStart + i] = val[i]
                return
            var newCap: int32 = hashMapStrSeqIntNextCap(val.len, oldCap)
            if oldStart >= 0 && oldCap > 0 && oldStart + oldCap == m.pool.len:
                let needLen: int32 = oldStart + newCap
                if m.pool.buffer == nil || m.pool.cap < needLen:
                    reserve(m.pool, needLen)
                setLen(m.pool, needLen)
                m.valStart[slot] = oldStart
                m.valLen[slot] = val.len
                m.valCap[slot] = newCap
                for i in 0..<val.len:
                    m.pool[oldStart + i] = val[i]
                return
            let start: int32 = hashMapStrSeqIntAllocTail(m, newCap)
            m.valStart[slot] = start
            m.valLen[slot] = val.len
            m.valCap[slot] = newCap
            for i in 0..<val.len:
                m.pool[start + i] = val[i]

fn hashMapStrSeqIntBuildSeq(m: HashMapStrSeqInt, slot: int32): int32[] =
    var out: int32[]
    if slot < 0 || slot >= m.keys.len:
        return hashMapReturnSeqInt32(out)
    let start: int32 = m.valStart[slot]
    let n: int32 = m.valLen[slot]
    if start < 0:
        return hashMapReturnSeqInt32(out)
    if n <= 0:
        return hashMapReturnSeqInt32(out)
    if start + n > m.pool.len:
        return hashMapReturnSeqInt32(out)
    setLen(out, n)
    for i in 0..<n:
        out[i] = m.pool[start + i]
    return hashMapReturnSeqInt32(out)

fn hashMapStrSeqIntGrow(m: var HashMapStrSeqInt) =
    let oldKeys: str[] = m.keys
    let oldValStart: int32[] = m.valStart
    let oldValLen: int32[] = m.valLen
    let oldValCap: int32[] = m.valCap
    let oldStates: uint8[] = m.states
    let oldPool: int32[] = m.pool
    let oldCap: int32 = oldKeys.len

    var newCap: int32 = (oldCap < 1024) ? (oldCap * 4) : (oldCap * 2)
    if newCap <= 0:
        newCap = 16
    let nextCap: int32 = hashMapNextPow2(newCap, 8)
    var nextMap: HashMapStrSeqInt = hashMapStrSeqIntInit(nextCap)

    for i in 0..<oldCap:
        if oldStates[i] == uint8(1):
            let key: str = oldKeys[i]
            let slot: int32 = hashMapStrSeqIntFindSlotMut(nextMap, key, true)
            if slot >= 0:
                nextMap.keys[slot] = key
                nextMap.states[slot] = uint8(1)
                nextMap.used = nextMap.used + 1
                let start: int32 = oldValStart[i]
                let n: int32 = oldValLen[i]
                if start >= 0 && n > 0:
                    let segCap: int32 = hashMapStrSeqIntNextCap(n, oldValCap[i])
                    let segStart: int32 = hashMapStrSeqIntAllocTail(nextMap, segCap)
                    nextMap.valStart[slot] = segStart
                    nextMap.valLen[slot] = n
                    nextMap.valCap[slot] = segCap
                    for vi in 0..<n:
                        nextMap.pool[segStart + vi] = oldPool[start + vi]
                else:
                    nextMap.valStart[slot] = -1
                    nextMap.valLen[slot] = 0
                    nextMap.valCap[slot] = 0
    m = nextMap

fn hashMapStrSeqIntPutSeq(m: var HashMapStrSeqInt, key: str, val: int32[]) =
    if len(key) > 0 && key != "":
        if m.mask == 0:
            m = hashMapStrSeqIntInit(16)
        let existingSlot: int32 = hashMapStrSeqIntFindSlotMut(m, key, false)
        if existingSlot >= 0:
            m.keys[existingSlot] = key
            hashMapStrSeqIntStoreSeqAt(m, existingSlot, val)
            return
        if (m.used + 1) * 10 >= m.keys.len * 7:
            hashMapStrSeqIntGrow(m)
        let slot: int32 = hashMapStrSeqIntFindSlotMut(m, key, true)
        if slot >= 0:
            if m.states[slot] == uint8(0):
                m.used = m.used + 1
                m.states[slot] = uint8(1)
            m.keys[slot] = key
            hashMapStrSeqIntStoreSeqAt(m, slot, val)

fn hashMapStrSeqIntAdd(m: var HashMapStrSeqInt, key: str, value: int32) =
    if len(key) > 0 && key != "":
        if m.mask == 0:
            m = hashMapStrSeqIntInit(16)
        let existingSlot: int32 = hashMapStrSeqIntFindSlotMut(m, key, false)
        if existingSlot >= 0:
            m.keys[existingSlot] = key
            let oldStart: int32 = m.valStart[existingSlot]
            let oldLen: int32 = m.valLen[existingSlot]
            let oldCap: int32 = m.valCap[existingSlot]
            if oldStart >= 0 && oldCap > oldLen && oldStart + oldCap <= m.pool.len:
                m.pool[oldStart + oldLen] = value
                m.valLen[existingSlot] = oldLen + 1
                return
            let newLen: int32 = oldLen + 1
            let newCap: int32 = hashMapStrSeqIntNextCap(newLen, oldCap)
            if oldStart >= 0 && oldCap > 0 && oldStart + oldCap == m.pool.len:
                let needLen: int32 = oldStart + newCap
                if m.pool.buffer == nil || m.pool.cap < needLen:
                    reserve(m.pool, needLen)
                setLen(m.pool, needLen)
                m.pool[oldStart + oldLen] = value
                m.valLen[existingSlot] = newLen
                m.valCap[existingSlot] = newCap
                return
            let newStart: int32 = hashMapStrSeqIntAllocTail(m, newCap)
            if oldStart >= 0 && oldLen > 0 && oldStart + oldLen <= m.pool.len:
                for i in 0..<oldLen:
                    m.pool[newStart + i] = m.pool[oldStart + i]
            m.pool[newStart + oldLen] = value
            m.valStart[existingSlot] = newStart
            m.valLen[existingSlot] = newLen
            m.valCap[existingSlot] = newCap
            return
        if (m.used + 1) * 10 >= m.keys.len * 7:
            hashMapStrSeqIntGrow(m)
        let slot: int32 = hashMapStrSeqIntFindSlotMut(m, key, true)
        if slot >= 0:
            if m.states[slot] == uint8(0):
                m.used = m.used + 1
                m.states[slot] = uint8(1)
                m.keys[slot] = key
                let start: int32 = hashMapStrSeqIntAllocTail(m, 4)
                m.valStart[slot] = start
                m.valLen[slot] = 1
                m.valCap[slot] = 4
                m.pool[start] = value

fn hashMapStrSeqIntGet(m: HashMapStrSeqInt, key: str): int32[] =
    var found: bool
    return hashMapStrSeqIntGetEx(m, key, found)

fn hashMapStrSeqIntGetEx(m: HashMapStrSeqInt, key: str, found: var bool): int32[] =
    if len(key) == 0 || key == "" || m.mask == 0:
        found = false
        return []
    let slot: int32 = hashMapStrSeqIntFindSlot(m, key, false)
    if slot < 0:
        found = false
        return []
    found = true
    return hashMapStrSeqIntBuildSeq(m, slot)

fn `[]`(m: HashMapStrSeqInt, key: str): int32[] =
    return hashMapStrSeqIntGet(m, key)

fn `[]=`(m: var HashMapStrSeqInt, key: str, val: int32[]) =
    hashMapStrSeqIntPutSeq(m, key, val)

fn hashMapStrSeqIntNextCap(needLen0: int32, curCap0: int32): int32 =
    if needLen0 <= 0:
        return 0
    var cap: int32 = curCap0
    if cap < 4:
        cap = 4
    while cap < needLen0:
        let nextCap: int32 = cap * 2
        if nextCap <= cap:
            return needLen0
        cap = nextCap
    return cap

fn hashMapStrSeqIntAllocTail(m: var HashMapStrSeqInt, capLen: int32): int32 =
    if capLen <= 0:
        return -1
    let start: int32 = m.pool.len
    let needLen: int32 = start + capLen
    if needLen < start:
        panic("hashmaps: seq-int pool overflow")
    if m.pool.buffer == nil || m.pool.cap < needLen:
        reserve(m.pool, needLen)
    setLen(m.pool, needLen)
    return start

fn hashMapPtrIntInit(cap0: int32 = 1024): HashMapPtrInt =
    var m: HashMapPtrInt
    hashMapPtrIntInitInPlace(m, cap0)
    return HashMapPtrInt(keys: m.keys,
                         vals: m.vals,
                         states: m.states,
                         mask: m.mask,
                         used: m.used)

fn hashMapPtrIntInitInPlace(m: var HashMapPtrInt, cap0: int32 = 1024) =
    let cap: int32 = hashMapNextPow2(cap0, 8)
    let keys: int64[] = hashMapAllocZeroSeq_int64(cap)
    let vals: int32[] = hashMapAllocZeroSeq_int32(cap)
    let states: uint8[] = hashMapAllocZeroSeq_uint8(cap)
    for i in 0..<cap:
        keys[i] = 0
        vals[i] = 0
        states[i] = uint8(0)
    m.keys = keys
    m.vals = vals
    m.states = states
    m.mask = uint64(cap - 1)
    m.used = 0

fn hashMapPtrIntClear(m: var HashMapPtrInt) =
    if m.keys.len <= 0:
        m.mask = 0
        m.used = 0
    else:
        for i in 0..<m.keys.len:
            m.keys[i] = 0
            m.vals[i] = 0
            m.states[i] = uint8(0)
        m.used = 0

fn hashMapPtrIntFindSlot(m: HashMapPtrInt, key: int64, allowInsert: bool): int32 =
    if key == 0 || m.mask == 0:
        return -1
    let mask: int32 = int32(m.mask)
    let states: uint8[] = m.states
    let keys: int64[] = m.keys
    var probe: int32 = int32(hashMapHash64Ptr(key) & uint64(mask))
    var scanned: int32
    for scanned in scanned..mask:
        let st: uint8 = states[probe]
        if st == uint8(0):
            if allowInsert:
                return probe
            return -1
        if keys[probe] == key:
            return probe
        probe = (probe + 1) & mask
    return -1

fn hashMapPtrIntFindSlotMut(m: var HashMapPtrInt, key: int64, allowInsert: bool): int32 =
    if key == 0 || m.mask == 0:
        return -1
    let mask: int32 = int32(m.mask)
    let states: uint8[] = m.states
    let keys: int64[] = m.keys
    var probe: int32 = int32(hashMapHash64Ptr(key) & uint64(mask))
    var scanned: int32
    for scanned in scanned..mask:
        let st: uint8 = states[probe]
        if st == uint8(0):
            if allowInsert:
                return probe
            return -1
        let cur: int64 = keys[probe]
        if cur == key:
            return probe
        probe = (probe + 1) & mask
    return -1

fn hashMapPtrIntGrow(m: var HashMapPtrInt) =
    let oldKeys: int64[] = m.keys
    let oldVals: int32[] = m.vals
    let oldStates: uint8[] = m.states
    let oldCap: int32 = oldKeys.len

    var newCap: int32 = oldCap * 2
    if newCap <= 0:
        newCap = 1024
    let nextCap: int32 = hashMapNextPow2(newCap, 8)
    var nextMap: HashMapPtrInt = hashMapPtrIntInit(nextCap)

    for i in 0..<oldCap:
        if oldStates[i] == uint8(1):
            let key: int64 = oldKeys[i]
            let val: int32 = oldVals[i]
            let slot: int32 = hashMapPtrIntFindSlotMut(nextMap, key, true)
            if slot >= 0:
                nextMap.keys[slot] = key
                nextMap.vals[slot] = val
                nextMap.states[slot] = uint8(1)
                nextMap.used = nextMap.used + 1
    m = nextMap

fn hashMapPtrIntPut(m: var HashMapPtrInt, key: int64, val: int32) =
    if key != 0:
        if m.mask == 0:
            hashMapPtrIntInitInPlace(m, 1024)
        if (m.used + 1) * 10 >= m.keys.len * 7:
            hashMapPtrIntGrow(m)
        let slot: int32 = hashMapPtrIntFindSlotMut(m, key, true)
        if slot >= 0:
            if m.states[slot] == uint8(0):
                m.used = m.used + 1
                m.states[slot] = uint8(1)
            m.keys[slot] = key
            m.vals[slot] = val

fn hashMapPtrIntGet(m: HashMapPtrInt, key: int64): int32 =
    var found: bool
    return hashMapPtrIntGetEx(m, key, found)

fn hashMapPtrIntGetEx(m: HashMapPtrInt, key: int64, found: var bool): int32 =
    if key == 0 || m.mask == 0:
        found = false
        return 0
    let slot: int32 = hashMapPtrIntFindSlot(m, key, false)
    if slot < 0:
        found = false
        return 0
    found = true
    return m.vals[slot]

fn `[]`(m: HashMapPtrInt, key: int64): int32 =
    return hashMapPtrIntGet(m, key)

fn `[]=`(m: var HashMapPtrInt, key: int64, val: int32) =
    hashMapPtrIntPut(m, key, val)

fn hashMapPtrIntHas(m: HashMapPtrInt, key: int64): bool =
    var ok: bool
    hashMapPtrIntGetEx(m, key, ok)
    return ok

fn hashCountStrOrdered(items: str[], countsOut: var HashMapStrInt) =
    var dummyOrder: str[]
    hashCountStrOrdered(items, dummyOrder, countsOut)

fn hashCountStrOrdered(items: str[], orderOut: var str[], countsOut: var HashMapStrInt) =
    if countsOut.mask == 0:
        var cap: int32 = items.len * 2
        if cap < 16:
            cap = 16
        hashMapStrIntInitInPlace(countsOut, cap)
    else:
        hashMapStrIntClear(countsOut)
    orderOut.len = 0
    for i in 0..<items.len:
        let key: str = items[i]
        if len(key) > 0 && key != "":
            var found: bool
            let cnt: int32 = hashMapStrIntGetMut(countsOut, key, found)
            if found:
                hashMapStrIntPut(countsOut, key, cnt + 1)
            else:
                hashMapStrIntPut(countsOut, key, 1)
                hashMapAppendStr(orderOut, key)

fn hashIndexStrFirst(items: str[], indexOut: var HashMapStrInt) =
    var needCap: int32 = items.len * 2
    if needCap < 16:
        needCap = 16
    let capPow2: int32 = hashMapNextPow2(needCap, 8)
    if indexOut.mask == 0 || indexOut.keys.len < capPow2:
        hashMapStrIntInitInPlace(indexOut, capPow2)
    else:
        hashMapStrIntClear(indexOut)
    for i in 0..<items.len:
        let key: str = items[i]
        if len(key) > 0 && key != "":
            var found: bool
            hashMapStrIntGetMut(indexOut, key, found)
            if !found:
                hashMapStrIntPut(indexOut, key, i)

fn HashMapNextPow2(n0: int32, minCap: int32 = 8): int32 =
    return hashMapNextPow2(n0, minCap)

fn HashMapHash64Str(s: str): uint64 =
    return hashMapHash64Str(s)

