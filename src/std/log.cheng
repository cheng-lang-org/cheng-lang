# std/log - Structured logging (minimal, pure Cheng)
import std/system
import std/strings
import std/strformat
import std/os
import std/times

type
    LogLevel = enum
        llDebug
        llInfo
        llWarn
        llError

type
    Logger =
        level: LogLevel
        name: str

fn loggerNew(name: str, level: LogLevel): Logger =
    var l: Logger
    l.name = name
    l.level = level
    return l

fn loggerDefault(): Logger =
    return loggerNew("app", llDebug)

fn logLevelName(level: LogLevel): str =
    if level == llDebug:
        return "DEBUG"
    if level == llInfo:
        return "INFO"
    if level == llWarn:
        return "WARN"
    if level == llError:
        return "ERROR"
    return "UNKNOWN"

fn logLevelFromName(name: str): LogLevel =
    if name == "DEBUG":
        return llDebug
    if name == "INFO":
        return llInfo
    if name == "WARN":
        return llWarn
    if name == "ERROR":
        return llError
    return llDebug

fn formatTimestamp(): str =
    let unixSecs: int32 = Int32(times.EpochTimeSeconds())
    return strings.IntToStr(unixSecs)

fn logMsg(logger: Logger, level: LogLevel, message: str) =
    if level < logger.level:
        return
    let ts: str = formatTimestamp()
    let lvl: str = logLevelName(level)
    let line: str = Fmt"[{ts}] {lvl} {logger.name}: {message}\n"
    os.Write(os.GetStderr(), line)

fn logDebug(logger: Logger, msg: str) =
    logMsg(logger, llDebug, msg)

fn logInfo(logger: Logger, msg: str) =
    logMsg(logger, llInfo, msg)

fn logWarn(logger: Logger, msg: str) =
    logMsg(logger, llWarn, msg)

fn logError(logger: Logger, msg: str) =
    logMsg(logger, llError, msg)

fn logFmt(logger: Logger, level: LogLevel, fmt: str, args: str[]) =
    var message: str = fmt
    for i in 0..<args.len:
        message = Fmt"{message} {args[i]}"
    logMsg(logger, level, message)

fn logSetLevel(logger: var Logger, level: LogLevel) =
    logger.level = level

# ---- Public exports ----

fn NewLogger(name: str, level: LogLevel): Logger =
    return loggerNew(name, level)

fn DefaultLogger(): Logger =
    return loggerDefault()

fn LogLevelName(level: LogLevel): str =
    return logLevelName(level)

fn LogLevelFromName(name: str): LogLevel =
    return logLevelFromName(name)

fn Debug(logger: Logger, msg: str) =
    logDebug(logger, msg)

fn Info(logger: Logger, msg: str) =
    logInfo(logger, msg)

fn Warn(logger: Logger, msg: str) =
    logWarn(logger, msg)

fn Error(logger: Logger, msg: str) =
    logError(logger, msg)

fn SetLevel(logger: var Logger, level: LogLevel) =
    logSetLevel(logger, level)

let
    LvlDebug: LogLevel = llDebug
    LvlInfo: LogLevel = llInfo
    LvlWarn: LogLevel = llWarn
    LvlError: LogLevel = llError
