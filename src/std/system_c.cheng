# system_c: minimal system subset for direct C backend
import std/result

type
    cstring = ptr
    str =
        data: ptr
        len: int32
        store_id: int32
        flags: int32
type
    int8 = int8
    int16 = int16
    int32 = int32
    int64 = int64
type
    uint8 = uint8
    uint16 = uint16
    uint32 = uint32
    uint64 = uint64

@importc("cheng_puts")
fn c_puts(text: cstring): int32
@importc("cheng_exit")
fn c_exit(code: int32)
@importc("driver_c_new_string")
fn system_c_new_string(size: int32): cstring

fn strToCStringTemp(s: str): cstring =
    if s.data == nil || s.len <= 0:
        return system_c_new_string(0)
    return cstring(s.data)

fn echo(text: str) =
    c_puts(strToCStringTemp(text))

fn panic(text: str) =
    echo text
    c_exit 1
fn panic(err: result.ErrorInfo) =
    panic result.ErrorFormat(err)

@importc("cheng_malloc")
fn heapNewLegacy(size: int32): ptr
@importc("cheng_free")
fn free(p: ptr)
@importc("cheng_realloc")
fn heapResizeLegacy(p: ptr, size: int32): ptr
@importc("cheng_seq_get")
fn cheng_seq_get(buffer: ptr, len: int32, idx: int32, elemSize: int32): ptr
@importc("cheng_memset")
fn c_memset(dest: ptr, val: int32, n: int64): ptr

@importc("cheng_malloc")
fn heapAllocLegacy(size: int32): ptr

@importc("cheng_free")
fn heapFreeLegacy(p: ptr)

fn memZeroLegacy(dest: ptr, size: int) =
    c_memset(dest, 0, int64(size))
