@importc("cheng_panic_cstring_and_exit")
fn atomicPanicRaw(text: ptr): void

type
    I32 = ref
        value: int32

fn NewI32(value: int32): I32 =
    var a: I32 = new(I32)
    if a != nil:
        a.value = value
    return a

fn LoadI32(a: I32): int32 =
    if a == nil:
        atomicPanicRaw("std_atomic_i32_load_nil")
        return 0
    return atomicLoadI32(&a.value)

fn StoreI32(a: I32, value: int32) =
    if a == nil:
        atomicPanicRaw("std_atomic_i32_store_nil")
        return
    atomicStoreI32(&a.value, value)

fn CasI32(a: I32,
          expect: int32,
          desired: int32): bool =
    if a == nil:
        atomicPanicRaw("std_atomic_i32_cas_nil")
        return false
    return atomicCasI32(&a.value, expect, desired) != 0

fn FetchAddI32(a: I32, delta: int32): int32 =
    if a == nil:
        atomicPanicRaw("std_atomic_i32_fetch_add_nil")
        return 0
    while true:
        let current = LoadI32(a)
        if CasI32(a, current, current + delta):
            return current

fn AddI32(a: I32, delta: int32): int32 =
    return FetchAddI32(a, delta) + delta
