# Strings module (minimal)
import std/system
import std/rawmem_support
import std/seqs

@importc("driver_c_i32_to_str")
fn driver_c_i32_to_cstring(value: int32): cstring
@importc("driver_c_i64_to_str")
fn driver_c_i64_to_cstring(value: int64): cstring
@importc("driver_c_u64_to_str")
fn driver_c_u64_to_cstring(value: uint64): cstring
@importc("__cheng_str_concat")
fn cheng_str_concat_runtime(a: cstring, b: cstring): cstring

fn len(s: str): int32 =
    return strLenFast(s)

fn streq(s1: str, s2: str): bool =
    let n: int32 = strLenFast(s1)
    if n != strLenFast(s2):
        return false
    if n <= 0:
        return true
    var i: int32 = 0
    while i < n:
        if s1[i] != s2[i]:
            return false
        i = i + 1
    return true

fn `==`(s1: str, s2: str): bool =
    return streq(s1, s2)

fn strIsEmpty(s: str): bool =
    return strLenFast(s) == 0

fn strNonEmpty(s: str): bool =
    return strLenFast(s) != 0

fn hasPrefix(s: str, prefix: str): bool =
    let n: int32 = strLenFast(s)
    let m: int32 = strLenFast(prefix)
    if m == 0:
        return true
    if m > n:
        return false
    var i: int32 = 0
    while i < m:
        if s[i] != prefix[i]:
            return false
        i = i + 1
    return true

fn hasSuffix(s: str, suffix: str): bool =
    let n: int32 = strLenFast(s)
    let m: int32 = strLenFast(suffix)
    if m == 0:
        return true
    if m > n:
        return false
    var i: int32 = 0
    let start: int32 = n - m
    while i < m:
        if s[start + i] != suffix[i]:
            return false
        i = i + 1
    return true

fn dropPrefix(s: str, prefix: str): str =
    if !hasPrefix(s, prefix):
        return s
    return strSubView(s, strLenFast(prefix), strLenFast(s) - strLenFast(prefix))

@importc("cheng_str_arc_retain")
fn arcRetainString(s: str)

@importc("cheng_str_arc_release")
fn arcReleaseString(s: str)

fn __cheng_str_from_bytes(data: uint8[], len: int32): str =
    if data.buffer == nil || len <= 0:
        return strEmpty()
    return strFromBytesCopy(data.buffer, len)

fn concatStr(s1: str, s2: str): str =
    let raw: cstring = cheng_str_concat_runtime(strToCStringTemp(s1), strToCStringTemp(s2))
    if raw == nil:
        return strEmpty()
    return strViewWithFlags(ptr(raw), c_strlen(raw), 0, chengStrFlagOwned)

fn charToStr(c: char): str =
    var buf: uint8[1]
    buf[0] = uint8(int32(c))
    return __cheng_str_from_bytes(buf, 1)

fn `[]`(s: str, i: int32): char =
    if i < 0 || i >= strLenFast(s) || strDataPtr(s) == nil:
        return char(0)
    let byteVal: uint8 = load(rawmemPtrAdd(strDataPtr(s), i))
    return char(byteVal)

fn `[]=`(s: str, i: int32, val: char) =
    if i < 0 || i >= strLenFast(s) || strDataPtr(s) == nil:
        return
    rawmemWriteChar(strDataPtr(s), i, val)

fn __cheng_slice_string(s: str, start: int32, stop: int32, exclusive: bool): str =
    let count: int32 = exclusive ? (stop - start) : (stop - start + 1)
    return strSubView(s, start, count)

fn __cheng_string_contains_char(s: str, c: char): bool =
    let n: int32 = strLenFast(s)
    var i: int32 = 0
    while i < n:
        if s[i] == c:
            return true
        i = i + 1
    return false

fn __cheng_string_contains_str(s: str, sub: str): bool =
    return strContains(s, sub)


fn sliceBytes(text: str, start: int32, count: int32): str =
    return strSubView(text, start, count)

fn strContains(text: str, sub: str): bool =
    let n: int32 = strLenFast(text)
    let m: int32 = strLenFast(sub)
    if m == 0:
        return true
    if m > n:
        return false
    var i: int32 = 0
    while i + m <= n:
        var matched: bool = true
        var j: int32 = 0
        while j < m:
            if text[i + j] != sub[j]:
                matched = false
                break
            j = j + 1
        if matched:
            return true
        i = i + 1
    return false
@importc("driver_c_i32_to_str")
fn intToStrRaw(i: int32): cstring

@importc("driver_c_u64_to_str")
fn uint64ToStrRaw(x: uint64): cstring

@importc("driver_c_i64_to_str")
fn int64ToStrRaw(i: int64): cstring

fn intToStr(i: int32): str =
    return strFromCStringBorrow(intToStrRaw(i))

fn uint64ToStr(x: uint64): str =
    return strFromCStringBorrow(uint64ToStrRaw(x))

fn int64ToStr(i: int64): str =
    return strFromCStringBorrow(int64ToStrRaw(i))

fn `$`(s: str): str =
    return newStringCopy(strDataPtr(s), strLenFast(s))

@importc("cheng_seq_string_repr_compat")
fn repr_seq_string(xs: str[]): cstring

@importc("cheng_seq_bool_repr_compat")
fn repr_seq_bool(xs: bool[]): cstring

@importc("cheng_seq_i32_repr_compat")
fn repr_seq_i32(xs: int32[]): cstring

@importc("cheng_seq_i64_repr_compat")
fn repr_seq_i64(xs: int64[]): cstring

fn `$`(xs: str[]): str =
    return strFromCStringBorrow(repr_seq_string(xs))

fn `$`(xs: bool[]): str =
    return strFromCStringBorrow(repr_seq_bool(xs))

fn `$`(xs: int32[]): str =
    return strFromCStringBorrow(repr_seq_i32(xs))

fn `$`(xs: int64[]): str =
    return strFromCStringBorrow(repr_seq_i64(xs))

fn Len(s: str): int32 =
    return len(s)

fn Streq(s1: str, s2: str): bool =
    return streq(s1, s2)

fn HasPrefix(s: str, prefix: str): bool =
    return hasPrefix(s, prefix)

fn HasSuffix(s: str, suffix: str): bool =
    return hasSuffix(s, suffix)

fn DropPrefix(s: str, prefix: str): str =
    return dropPrefix(s, prefix)

fn ConcatStr(s1: str, s2: str): str =
    return concatStr(s1, s2)

fn CharToStr(c: char): str =
    return charToStr(c)

fn SliceBytes(text: str, start: int32, count: int32): str =
    return sliceBytes(text, start, count)

fn StrContains(text: str, sub: str): bool =
    return strContains(text, sub)

fn IntToStr(i: int32): str =
    return intToStr(i)

fn Uint64ToStr(x: uint64): str =
    return uint64ToStr(x)

fn Int64ToStr(i: int64): str =
    return int64ToStr(i)
