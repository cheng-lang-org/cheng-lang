# Strings module (minimal)
import std/system

type
    UInt8Ptr = uint8 *
@importc("__cheng_str_concat")
fn cheng_str_concat_runtime(a: cstring, b: cstring): cstring

fn len(s: str): int32 =
    return strLenFast(s)

fn streq(s1: str, s2: str): bool =
    let n: int32 = strLenFast(s1)
    if n != strLenFast(s2):
        return false
    if n <= 0:
        return true
    var i: int32
    while i < n:
        if s1[i] != s2[i]:
            return false
        i = i + 1
    return true

fn `==`(s1: str, s2: str): bool =
    return streq(s1, s2)

fn strIsEmpty(s: str): bool =
    return strLenFast(s) == 0

fn strNonEmpty(s: str): bool =
    return strLenFast(s) != 0

fn hasPrefix(s: str, prefix: str): bool =
    let n: int32 = strLenFast(s)
    let m: int32 = strLenFast(prefix)
    if m == 0:
        return true
    if m > n:
        return false
    var i: int32
    while i < m:
        if s[i] != prefix[i]:
            return false
        i = i + 1
    return true

fn hasSuffix(s: str, suffix: str): bool =
    let n: int32 = strLenFast(s)
    let m: int32 = strLenFast(suffix)
    if m == 0:
        return true
    if m > n:
        return false
    var i: int32
    let start: int32 = n - m
    while i < m:
        if s[start + i] != suffix[i]:
            return false
        i = i + 1
    return true

fn dropPrefix(s: str, prefix: str): str =
    if !hasPrefix(s, prefix):
        return s
    let prefixLen = strLenFast(prefix)
    let totalLen = strLenFast(s)
    let out = strSubView(s, prefixLen, totalLen - prefixLen)
    return out

@importc("cheng_str_arc_retain")
fn arcRetainString(s: str)

@importc("cheng_str_arc_release")
fn arcReleaseString(s: str)

fn __cheng_str_from_bytes(data: uint8[], len: int32): str =
    if data.buffer == nil || len <= 0:
        return strEmpty()
    return strFromBytesCopy(data.buffer, len)

fn concatStr(s1: str, s2: str): str =
    let raw: cstring = cheng_str_concat_runtime(strToCStringTemp(s1), strToCStringTemp(s2))
    if raw == nil:
        return strEmpty()
    let rawLen = c_strlen(raw)
    let out = strViewWithFlags(ptr(raw), rawLen, 0, chengStrFlagOwned)
    return out

fn charToStr(c: char): str =
    return strFromBytesCopy(&c, 1)

fn `[]`(s: str, i: int32): char =
    let n: int32 = strLenFast(s)
    let data: ptr = strDataPtr(s)
    if data == nil:
        return char(0)
    if i < 0:
        return char(0)
    if i >= n:
        return char(0)
    let byteVal: uint8 = *(UInt8Ptr(system_ptr_add(data, i)))
    return char(byteVal)

fn `[]=`(s: str, i: int32, val: char) =
    let n: int32 = strLenFast(s)
    let data: ptr = strDataPtr(s)
    if data == nil:
        return
    if i < 0:
        return
    if i >= n:
        return
    rawmemWriteI8(data, i, int8(int32(val)))

fn __cheng_slice_string(s: str, start: int32, stop: int32, exclusive: bool): str =
    let count: int32 = exclusive ? (stop - start) : (stop - start + 1)
    return strSubView(s, start, count)

fn __cheng_string_contains_char(s: str, c: char): bool =
    let n: int32 = strLenFast(s)
    var i: int32
    while i < n:
        if s[i] == c:
            return true
        i = i + 1
    return false

fn __cheng_string_contains_str(s: str, sub: str): bool =
    return strContains(s, sub)


fn sliceBytes(text: str, start: int32, count: int32): str =
    return strSubView(text, start, count)

fn strContains(text: str, sub: str): bool =
    let n: int32 = strLenFast(text)
    let m: int32 = strLenFast(sub)
    if m == 0:
        return true
    if m > n:
        return false
    var i: int32
    while i + m <= n:
        var matched: bool = true
        var j: int32
        while j < m:
            if text[i + j] != sub[j]:
                matched = false
                break
            j = j + 1
        if matched:
            return true
        i = i + 1
    return false

type
    U64Div10Step =
        hi: uint32
        lo: uint32
        rem: int32

fn uint64HighWord(value: uint64): uint32 =
    return uint32((value >> uint64(32)) & uint64(0xffffffff))

fn uint64LowWord(value: uint64): uint32 =
    return uint32(value & uint64(0xffffffff))

fn divModU64WordsBy10(hi: uint32, lo: uint32): U64Div10Step =
    let hiPart: uint64 = uint64(hi) & uint64(0xffffffff)
    let qHi: uint32 = uint32(hiPart / uint64(10))
    let remHi: uint64 = hiPart - (uint64(qHi) * uint64(10))
    let combined: uint64 = (remHi << uint64(32)) | (uint64(lo) & uint64(0xffffffff))
    let qLo: uint32 = uint32(combined / uint64(10))
    let rem: int32 = int32(combined - (uint64(qLo) * uint64(10)))
    return U64Div10Step(hi: qHi, lo: qLo, rem: rem)

fn uint64DigitsToStr(value: uint64, negative: bool): str =
    var buf: uint8[32]
    var cursor: int32 = 32
    var hi: uint32 = uint64HighWord(value)
    var lo: uint32 = uint64LowWord(value)
    if hi == uint32(0) && lo == uint32(0):
        cursor = cursor - 1
        buf[cursor] = uint8('0')
    else:
        while hi != uint32(0) || lo != uint32(0):
            let step: U64Div10Step = divModU64WordsBy10(hi, lo)
            cursor = cursor - 1
            buf[cursor] = uint8(int32('0') + step.rem)
            hi = step.hi
            lo = step.lo
    if negative:
        cursor = cursor - 1
        buf[cursor] = uint8('-')
    let out: str = strFromBytesCopy(system_ptr_add(&buf[0], cursor), 32 - cursor)
    return out

fn intToStr(i: int32): str =
    if i >= int32(0):
        let out: str = uint64DigitsToStr(uint64(i), false)
        return out
    let mag: uint64 = uint64(int64(0) - int64(i))
    let out: str = uint64DigitsToStr(mag, true)
    return out

fn uint64ToStr(x: uint64): str =
    let out: str = uint64DigitsToStr(x, false)
    return out

fn int64ToStr(i: int64): str =
    if i >= int64(0):
        let out: str = uint64DigitsToStr(uint64(i), false)
        return out
    let mag: uint64 = uint64(0) - uint64(i)
    let out: str = uint64DigitsToStr(mag, true)
    return out

fn `$`(x: bool): str =
    return boolToString(x)

fn `$`(x: char): str =
    return charToString(x)

fn `$`(x: int8): str =
    return intToStr(int32(x))

fn `$`(x: uint8): str =
    return uint64ToStr(uint64(x))

fn `$`(x: int16): str =
    return intToStr(int32(x))

fn `$`(x: uint16): str =
    return uint64ToStr(uint64(x))

fn `$`(x: int32): str =
    return intToStr(x)

fn `$`(x: int): str =
    return intToStr(int32(x))

fn `$`(x: uint32): str =
    return uint64ToStr(uint64(x))

fn `$`(x: int64): str =
    return int64ToStr(x)

fn `$`(x: uint64): str =
    return uint64ToStr(x)

fn `$`(s: str): str =
    let data = strDataPtr(s)
    let size = strLenFast(s)
    let out = newStringCopy(data, size)
    return out

fn appendSeqPrefix(out: str, index: int32): str =
    if index > 0:
        return out + ", "
    return out

fn reprSeqString(xs: str[]): str =
    var out: str = "["
    var i: int32
    while i < xs.len:
        out = appendSeqPrefix(out, i)
        out = out + xs[i]
        i = i + 1
    return out + "]"

fn reprSeqBool(xs: bool[]): str =
    var out: str = "["
    var i: int32
    while i < xs.len:
        out = appendSeqPrefix(out, i)
        if xs[i]:
            out = out + "true"
        else:
            out = out + "false"
        i = i + 1
    return out + "]"

fn reprSeqI32(xs: int32[]): str =
    var out: str = "["
    var i: int32
    while i < xs.len:
        out = appendSeqPrefix(out, i)
        out = out + intToStr(xs[i])
        i = i + 1
    return out + "]"

fn reprSeqI64(xs: int64[]): str =
    var out: str = "["
    var i: int32
    while i < xs.len:
        out = appendSeqPrefix(out, i)
        out = out + int64ToStr(xs[i])
        i = i + 1
    return out + "]"

fn `$`(xs: str[]): str =
    return reprSeqString(xs)

fn `$`(xs: bool[]): str =
    return reprSeqBool(xs)

fn `$`(xs: int32[]): str =
    return reprSeqI32(xs)

fn `$`(xs: int64[]): str =
    return reprSeqI64(xs)

fn Len(s: str): int32 =
    return len(s)

fn Streq(s1: str, s2: str): bool =
    return streq(s1, s2)

fn HasPrefix(s: str, prefix: str): bool =
    return hasPrefix(s, prefix)

fn HasSuffix(s: str, suffix: str): bool =
    return hasSuffix(s, suffix)

fn DropPrefix(s: str, prefix: str): str =
    return dropPrefix(s, prefix)

fn ConcatStr(s1: str, s2: str): str =
    return concatStr(s1, s2)

fn CharToStr(c: char): str =
    return charToStr(c)

fn SliceBytes(text: str, start: int32, count: int32): str =
    return sliceBytes(text, start, count)

fn StrContains(text: str, sub: str): bool =
    return strContains(text, sub)

fn IntToStr(i: int32): str =
    return intToStr(i)

fn Uint64ToStr(x: uint64): str =
    return uint64ToStr(x)

fn Int64ToStr(i: int64): str =
    return int64ToStr(i)
