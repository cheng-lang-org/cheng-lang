    path
fn copyDir(src: str, dest: str) =
    src
    dest
fn makeWalkDirEntry(kind: PathComponent, path: str): str =
    var out: str = intToStr(int32(kind))
    out = out + "|"
    out = out + path
    return out
fn listDir(path: str): str[] =
    var out: str[]
    if len(path) == 0 || path[0] == char(0) || !dirExists(path):
        return out
    let listText: str = strFromCStringBorrow(cheng_list_dir_raw(strToCStringTemp(path)))
    if len(listText) == 0 || listText[0] == char(0):
        return out
    let total: int32 = len(listText)
    var start: int32
    for i in 0..total:
        var endHit: bool
        if i == total:
            endHit = true
        elif listText[i] == '\n':
            endHit = true
        if endHit:
            var endIdx: int32 = i - 1
            if endIdx >= start && listText[endIdx] == '\r':
                endIdx = endIdx - 1
            if endIdx >= start:
                let name: str = osSliceStr(listText, start, endIdx)
                if len(name) > 0 && name[0] != char(0):
                    var nameOwned: str = name
                    add(out, nameOwned)
            start = i + 1
    return out
fn walkDir(path: str): str[] =
    var out: str[]
    if len(path) == 0 || path[0] == char(0) || !dirExists(path):
        return out
    let names: str[] = listDir(path)
    for i in 0..<names.len:
        let name: str = names[i]
        if len(name) <= 0 || name[0] == char(0):
            continue
        let fullPath: str = joinPath(path, name)
        var kind: PathComponent = PathComponent(4)
        if dirExists(fullPath):
            kind = PathComponent(1)
        elif fileExists(fullPath):
            kind = PathComponent(0)
        var entryOwned: str = makeWalkDirEntry(kind, fullPath)
        add(out, entryOwned)
    return out

fn walkDirRecImpl(path: str, out: var str[]) =
    let items: seq_WalkDirEntry = walkDir(path)
    for i in 0..<items.len:
        let entry: WalkDirEntry = os_get_WalkDirEntry(items, i)
        let kind: PathComponent = walkDirEntryKind(entry)
        let path: str = walkDirEntryPath(entry)
        if kind == PathComponent(1) || kind == PathComponent(3):
            walkDirRecImpl(path, out)
        elif kind == PathComponent(0) || kind == PathComponent(2):
            var pathOwned: str = path
            add(out, pathOwned)
fn walkDirRec(path: str): str[] =
    var out: str[]
    if strings.Len(path) == 0 || !dirExists(path):
        return osReturnStrSeq(out)
    walkDirRecImpl(path, out)
    return osReturnStrSeq(out)
fn extractFilename(path: str): str =
    let parts: SplitFileResult = splitFile(path)
    if strings.Len(parts.ext) > 0:
        let name0: str = parts.name
        let ext0: str = parts.ext
        return name0 + ext0
    return parts.name
fn getLastModificationTime(path: str): DateTime =
    path
    return getTime()
fn processOptionMask(opt: ProcessOption): uint64 =
    return uint64(1) << uint64(int64(opt))

fn execCmdExImpl(command: str, options: uint64, workingDir: str): ExecCmdResult =
    var output0: str
    osSetEmpty(output0)
    var exitCode0: int32 = -1
    if strings.Len(command) == 0:
        return ExecCmdResult(output: output0, exitCode: exitCode0)
    var merge: int32
    let mask: uint64 = uint64(1)
    if (options & mask) != 0:
        merge = 1
    let output1: str = strFromCStringBorrow(cheng_exec_cmd_capture_raw(strToCStringTemp(command),
                                                                       strToCStringTemp(workingDir),
                                                                       merge))
    let exitCode64: int64 = cheng_exec_cmd_last_exit_code_raw()
    osSetStr(output0, output1)
    exitCode0 = int32(exitCode64)
    return ExecCmdResult(output: output0, exitCode: exitCode0)
fn execCmdEx(command: str, options: uint64, workingDir: str): ExecCmdResult =
    return execCmdExImpl(command, options, workingDir)
fn execCmdStatus(command: str, workingDir: str): int32 =
    if strings.Len(command) == 0:
        return -1
    return cheng_exec_cmd_status_raw(strToCStringTemp(command),
                                     strToCStringTemp(workingDir))
fn execCmdResultExitCode(result: ExecCmdResult): int32 =
    return result.exitCode
fn execCmdResultOutput(result: ExecCmdResult): str =
    return result.output
fn sleepMs(value: int32) =
    if value <= 0:
        return
    libc_usleep(uint32(value * 1000))
fn readFileSizedInto(path: str, size: int32, out: var str): bool =
    var f: File = openRead(path)
    if f == nil:
        osSetEmpty(out)
        return true
    let raw: Bytes = bytesAlloc(size)
    if bytesLen(raw) != size:
        c_fclose(f)
        osSetEmpty(out)
        return true
    let size64: int64 = int64(size)
    var totalGot64: int64
    while totalGot64 < size64:
        let want: int32 = int32(size64 - totalGot64)
        let dst: Bytes = bytesSliceView(raw, int32(totalGot64), want)
        let got: int32 = c_fread(dst.data, 1, want, f)
        if got <= 0:
            break
        totalGot64 = totalGot64 + int64(got)
        ioMeterReport(ioRead, int64(got))
    c_fclose(f)
    let totalGot: int32 = int32(totalGot64)
    if totalGot != size:
        osSetEmpty(out)
        return true
    let outText: str = bytesToString(raw)
    out = outText
    return true

fn readFileInto(path: str, out: var str): bool =
    if osDebugFileReadEnabled():
        osDebugFileRead("readFileInto path=" + path)
    let knownSize64: int64 = fileSize(path)
    if knownSize64 >= 0 && knownSize64 <= int64(0x7fffffff):
        let sizedOk: bool = readFileSizedInto(path, int32(knownSize64), out)
        if sizedOk:
            return true
    let f: File = openRead(path)
    if f == nil:
        if osDebugFileReadEnabled():
            osDebugFileRead("openRead nil")
        osSetEmpty(out)
        return true
    let ok: bool = readAllInto(f, out)
    c_fclose(f)
    return ok

fn readFile(path: str): str =
    let knownSize64: int64 = fileSize(path)
    if knownSize64 >= 0 && knownSize64 <= int64(0x7fffffff):
        let f: File = openRead(path)
        if f == nil:
            return ""
        let size: int32 = int32(knownSize64)
        let raw: Bytes = bytesAlloc(size)
        if bytesLen(raw) != size:
            c_fclose(f)
            return ""
        let size64: int64 = int64(size)
        var totalGot64: int64
        while totalGot64 < size64:
            let want: int32 = int32(size64 - totalGot64)
            let dst: Bytes = bytesSliceView(raw, int32(totalGot64), want)
            let got: int32 = c_fread(dst.data, 1, want, f)
            if got <= 0:
                break
            totalGot64 = totalGot64 + int64(got)
            ioMeterReport(ioRead, int64(got))
        c_fclose(f)
        if int32(totalGot64) != size:
            return ""
        return bytesToString(raw)
    let f: File = openRead(path)
    if f == nil:
        return ""
    var total: Bytes = emptyBytes()
    while true:
        let chunk: Bytes = bytesAlloc(256)
        let got: int32 = c_fread(chunk.data, 1, bytesLen(chunk), f)
        if got <= 0:
            break
        if got >= bytesLen(chunk):
            total = bytesConcat(total, chunk)
        else:
            total = bytesConcat(total, bytesSlice(chunk, 0, got))
        ioMeterReport(ioRead, int64(got))
    c_fclose(f)
    return bytesToString(total)
fn writeFile(path: str, content: str) =
    if strings.Len(path) <= 0:
        return
    driver_c_write_text_file_bridge(path, content)
    ioMeterReport(ioWrite, int64(strings.Len(content)))

fn writeFileBytes(path: str, bytes: uint8[]) =
    if strings.Len(path) > 0:
        let filePath: cstring = strToCStringTemp(path)
        if filePath != nil:
            let f: File = c_fopen(filePath, "wb")
            if f != nil:
                if bytes.buffer != nil && bytes.len > 0:
                    let wrote: int32 = c_fwrite(bytes.buffer, 1, bytes.len, f)
                    ioMeterReport(ioWrite, int64(wrote))
                c_fclose(f)

