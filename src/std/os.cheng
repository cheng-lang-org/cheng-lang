type
    seq_WalkDirEntry = WalkDirEntry[]
fn os_newSeq_WalkDirEntry(len: int32, cap: int32): seq_WalkDirEntry =
    var out: str[]
    if cap > 0:
        seqs.Reserve(out, cap)
    if len > 0:
        seqs.SetLen(out, len)
    return out
fn os_get_WalkDirEntry(seqInst: str[], i: int32): WalkDirEntry =
    return seqInst[i]
fn walkDirEntryKind(entry: str): PathComponent =
    if strings.Len(entry) <= 0:
        return PathComponent(4)
    let code: char = entry[0]
    if code == '0':
        return PathComponent(0)
    if code == '1':
        return PathComponent(1)
    if code == '2':
        return PathComponent(2)
    if code == '3':
        return PathComponent(3)
    return PathComponent(4)
fn walkDirEntryPath(entry: str): str =
    if strings.Len(entry) < 2:
        return ""
    if entry[1] != '|':
        return ""
    return strings.SliceBytes(entry, 2, strings.Len(entry) - 2)
fn pathComponentDir(): PathComponent =
    return PathComponent(1)
fn os_addPtr_WalkDirEntry(seqInst: var str[], val: WalkDirEntry) =
    add(seqInst, val)

fn fileExists(path: str): bool =
    return cheng_os_file_exists_bridge(path) != 0
fn dirExists(path: str): bool =
    return cheng_os_dir_exists_bridge(path) != 0
fn createDir(path: str) =
    cheng_mkdir1(strToCStringTemp(path))
fn bos_dirExists(path: str): bool =
    return dirExists(path)
fn makeDir(path: str): bool =
    return cheng_mkdir1(strToCStringTemp(path)) != 0
fn fileMtime(path: str): int64 =
    return cheng_file_mtime(strToCStringTemp(path))
fn fileSize(path: str): int64 =
    return cheng_os_file_size_bridge(path)
fn getCurrentDir(): str =
    return strFromCStringCopy(cheng_getcwd_raw())
fn removeFile(path: str): bool =
    c_remove(strToCStringTemp(path)) == 0
fn renameFile(oldPath: str, newPath: str): bool =
    c_rename(strToCStringTemp(oldPath), strToCStringTemp(newPath)) == 0
fn removeDir(path: str) =
    if strings.Len(path) > 0:
        let _ = c_rmdir(strToCStringTemp(path))
fn getEnvImpl(key: str, defaultValue: str): str =
    let v: cstring = c_getenv(strToCStringTemp(key))
    if v == nil || c_strlen(v) == 0:
        return defaultValue
    return strFromCStringBorrow(v)
fn getEnv(key: str): str =
    return getEnvImpl(key, "")
fn getEnvDefault(key: str, defaultValue: str): str =
    return getEnvImpl(key, defaultValue)
fn setEnv(key: str, value: str) =
    let ignoredRc: int32 = c_setenv(strToCStringTemp(key), strToCStringTemp(value), 1)
    ignoredRc
fn commandLineParams(): str[] =
    # cmdline module now loads argv from runtime bridge lazily.
    let count: int32 = cmdline.ParamCount()
    var out: str[]
    if count > 0:
        setLen(out, count)
        var i: int32 = 1
        while i <= count:
            out[i - 1] = cmdline.ParamStr(i)
            i = i + 1
    return osReturnStrSeq(out)
fn quoteShell(value: str): str =
    if len(value) == 0:
        return "''"
    var out: str = "'"
    for i in 0..<len(value):
        let part = strings.SliceBytes(value, i, 1)
        if part == "'":
            out = out + "'\"'\"'"
        else:
            out = out + part
    out = out + "'"
    return out

fn joinPath(a: str, b: str): str =
    if strings.Len(a) == 0:
        return b
    if a[0] == char(0):
        return b
    if strings.Len(b) == 0:
        return a
    if b[0] == char(0):
        return a
    let aLen: int32 = strings.Len(a)
    let last: char = a[aLen - 1]
    var hasSep: bool
    if last == '/':
        hasSep = true
    if last == '\\':
        hasSep = true
    let bLen: int32 = strings.Len(b)
    var outLen: int32 = aLen + bLen
    if !hasSep:
        outLen = outLen + 1
    let out: str = newStringAlloc(outLen)
    if outLen <= 0:
        return ""
    var writePos: int32
    var i: int32
    while i < aLen:
        out[writePos] = a[i]
        writePos = writePos + 1
        i = i + 1
    if !hasSep:
        out[writePos] = '/'
        writePos = writePos + 1
    i = 0
    while i < bLen:
        out[writePos] = b[i]
        writePos = writePos + 1
        i = i + 1
    return out
fn `/`(a: str, b: str): str =
    return joinPath(a, b)

fn osSliceStr(text: str, start: int32, stop: int32): str =
    if strings.Len(text) == 0:
        return ""
    var s: int32 = start
    var e: int32 = stop
    if s < 0:
        s = 0
    let n: int32 = strings.Len(text)
    if e < s || s >= n:
        return ""
    if e >= n:
        e = n - 1
    let count: int32 = e - s + 1
    return strings.SliceBytes(text, s, count)
fn absolutePath(path: str): str =
    if strings.Len(path) == 0 || path[0] == char(0):
        return getCurrentDir()
    let c0: char = path[0]
    if c0 == '/' || c0 == '\\':
        return path
    if path[1] == ':':
        return path
    return joinPath(getCurrentDir(), path)
fn isAbsolute(path: str): bool =
    if strings.Len(path) == 0 || path[0] == char(0):
        return false
    let c0: char = path[0]
    if c0 == '/' || c0 == '\\':
        return true
    if path[1] == ':':
        return true
    return false
fn parentDir(path: str): str =
    let parts: SplitFileResult = splitFile(path)
    return parts.dir
fn relativePath(path: str, base: str): str =
    if strings.Len(base) == 0 || base[0] == char(0):
        return path
    let baseLen: int32 = strings.Len(base)
    let pathLen: int32 = strings.Len(path)
    if pathLen >= baseLen && osSliceStr(path, 0, baseLen - 1) == base:
        var idx: int32 = baseLen
        if idx < pathLen && (path[idx] == '/' || path[idx] == '\\'):
            idx = idx + 1
        if idx <= pathLen:
            return osSliceStr(path, idx, pathLen - 1)
    return path
fn splitFile(path: str): SplitFileResult =
    let pathLen: int32 = strings.Len(path)
    if pathLen == 0:
        return SplitFileResult(dir: "", name: "", ext: "")
    var lastSep: int32 = -1
    for i in 0..<pathLen:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    var lastDot: int32 = -1
    let nameStart: int32 = lastSep + 1
    if nameStart < pathLen:
        let revStart: int32 = pathLen - 1
        for revOffset in 0..(revStart - nameStart):
            let idx: int32 = revStart - revOffset
            let ch: char = path[idx]
            if ch == '.':
                lastDot = idx
                break
    if lastDot > lastSep && lastDot >= 0:
        if lastSep >= 0:
            if lastSep <= 0:
                if lastDot - 1 >= nameStart:
                    return SplitFileResult(dir: "",
                                           name: osSliceStr(path, nameStart, lastDot - 1),
                                           ext: osSliceStr(path, lastDot, pathLen - 1))
                return SplitFileResult(dir: "",
                                       name: "",
                                       ext: osSliceStr(path, lastDot, pathLen - 1))
            if lastDot - 1 >= nameStart:
                return SplitFileResult(dir: osSliceStr(path, 0, lastSep - 1),
                                       name: osSliceStr(path, nameStart, lastDot - 1),
                                       ext: osSliceStr(path, lastDot, pathLen - 1))
            return SplitFileResult(dir: osSliceStr(path, 0, lastSep - 1),
                                   name: "",
                                   ext: osSliceStr(path, lastDot, pathLen - 1))
        if lastDot > 0:
            return SplitFileResult(dir: "",
                                   name: osSliceStr(path, 0, lastDot - 1),
                                   ext: osSliceStr(path, lastDot, pathLen - 1))
        return SplitFileResult(dir: "",
                               name: "",
                               ext: osSliceStr(path, lastDot, pathLen - 1))
    if lastSep >= 0:
        if lastSep <= 0:
            if nameStart >= pathLen:
                return SplitFileResult(dir: "", name: "", ext: "")
            return SplitFileResult(dir: "",
                                   name: osSliceStr(path, nameStart, pathLen - 1),
                                   ext: "")
        if nameStart >= pathLen:
            return SplitFileResult(dir: osSliceStr(path, 0, lastSep - 1),
                                   name: "",
                                   ext: "")
        return SplitFileResult(dir: osSliceStr(path, 0, lastSep - 1),
                               name: osSliceStr(path, nameStart, pathLen - 1),
                               ext: "")
    return SplitFileResult(dir: "", name: path, ext: "")
fn getFileSize(path: str): int64 =
    path
    return 0
