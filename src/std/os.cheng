fn udpErrno(): int32 =
    return cheng_errno()

fn udpErrText(errCode: int32): str =
    let textPtr: cstring = cheng_strerror(errCode)
    if textPtr == nil:
        return "unknown"
    return strFromCStringBorrow(textPtr)

fn udpCloseFd(fd: int32): int32 =
    return libc_close(fd)

fn udpOpenSocket(domain: int32, typ: int32, protocol: int32): int32 =
    return libc_socket(domain, typ, protocol)

fn udpFcntl(fd: int32, cmd: int32, arg: int32): int32 =
    return libc_fcntl(fd, cmd, arg)

fn udpInetPton(family: int32, src: str, dst: Bytes): int32 =
    if strings.Len(src) <= 0 || bytesLen(dst) <= 0:
        return 0
    return libc_inet_pton(family, strToCStringTemp(src), dst.data)

fn udpInetNtop(family: int32, src: Bytes): str =
    if bytesLen(src) <= 0:
        return ""
    let outBuf: Bytes = bytesAlloc(128)
    if bytesLen(outBuf) <= 0:
        return ""
    bytesSet(outBuf, 0, 0)
    let textPtr: cstring = libc_inet_ntop(family, src.data, cstring(outBuf.data), bytesLen(outBuf))
    if textPtr == nil:
        return ""
    return strFromCStringBorrow(textPtr)

fn udpBindFd(fd: int32, addr: Bytes, addrLen: int32): int32 =
    if fd < 0 || addrLen <= 0:
        return -1
    return libc_bind(fd, addr.data, addrLen)

fn tcpListenFd(fd: int32, backlog: int32): int32 =
    if fd < 0:
        return -1
    return libc_listen(fd, backlog)

fn tcpConnectFd(fd: int32, addr: Bytes, addrLen: int32): int32 =
    if fd < 0 || addrLen <= 0:
        return -1
    return libc_connect(fd, addr.data, addrLen)

fn tcpAcceptFd(fd: int32, addr: Bytes, addrLen: var int32): int32 =
    if fd < 0:
        addrLen = 0
        return -1
    if bytesLen(addr) <= 0:
        addrLen = 0
        return libc_accept(fd, nil, addrLen)
    addrLen = bytesLen(addr)
    return libc_accept(fd, addr.data, addrLen)

fn tcpSendFd(fd: int32, payload: Bytes, flags: int32): int32 =
    if fd < 0 || bytesLen(payload) <= 0:
        return -1
    return libc_send(fd, payload.data, bytesLen(payload), flags)

fn tcpRecvFd(fd: int32, payload: Bytes, flags: int32): int32 =
    if fd < 0 || bytesLen(payload) <= 0:
        return -1
    if flags == 0:
        return int32(libc_read(fd, payload.data, int64(bytesLen(payload))))
    return libc_recv(fd, payload.data, bytesLen(payload), flags)

fn tcpShutdownFd(fd: int32, how: int32): int32 =
    if fd < 0:
        return -1
    return libc_shutdown(fd, how)

fn udpSendToFd(fd: int32, payload: Bytes, flags: int32, addr: Bytes, addrLen: int32): int32 =
    if fd < 0 || addrLen <= 0 || bytesLen(payload) <= 0:
        return -1
    return libc_sendto(fd, payload.data, bytesLen(payload), flags, addr.data, addrLen)

fn udpRecvFromFd(fd: int32, payload: Bytes, flags: int32): int32 =
    if fd < 0 || bytesLen(payload) <= 0:
        return -1
    var rawLen: int32
    return libc_recvfrom(fd, payload.data, bytesLen(payload), flags, nil, rawLen)

fn udpRecvFromFdEx(fd: int32, payload: Bytes, flags: int32, outErr: var int32): int32 =
    outErr = 0
    if fd < 0 || bytesLen(payload) <= 0:
        return -1
    return cheng_recvfrom_fd_ex(fd, payload.data, bytesLen(payload), flags, nil, nil, outErr)

fn udpRecvFromFdAddrEx(fd: int32, payload: Bytes, flags: int32, outAddr: Bytes, outAddrLen: var int32, outErr: var int32): int32 =
    let payloadLen: int32 = bytesLen(payload)
    let addrCap: int32 = bytesLen(outAddr)
    outErr = 0
    if fd < 0 || payloadLen <= 0 || addrCap <= 0:
        outAddrLen = 0
        return -1
    outAddrLen = addrCap
    let payloadPtr: ptr = payload.data
    let addrPtr: ptr = outAddr.data
    return cheng_udp_recvfrom_addr_bridge(fd, payloadPtr, payloadLen, flags, addrPtr, addrCap, outAddrLen, outErr)

fn udpSetSockOptIntFd(fd: int32, level: int32, optName: int32, optBytes: Bytes): int32 =
    if fd < 0 || bytesLen(optBytes) <= 0:
        return -1
    return libc_setsockopt(fd, level, optName, optBytes.data, bytesLen(optBytes))

fn udpGetSockNameFd(fd: int32, addr: Bytes, addrLen: var int32): int32 =
    if fd < 0 || bytesLen(addr) <= 0:
        addrLen = 0
        return -1
    addrLen = bytesLen(addr)
    return libc_getsockname(fd, addr.data, addrLen)

fn udpBindHostPortBridge(host: str, port: int32, isV6: int32, outFd: var int32, outPort: var int32, outFamily: var int32, outUseLenField: var int32): int32 =
    return cheng_udp_bind_host_port_bridge(host, port, isV6, outFd, outPort, outFamily, outUseLenField)

fn udpBindFdBridge(host: str, port: int32, isV6: int32): int32 =
    return cheng_udp_bind_fd_bridge(host, port, isV6)

fn udpBoundPortBridge(fd: int32, isV6: int32): int32 =
    return cheng_udp_bound_port_bridge(fd, isV6)

fn udpPlatformUseLenFieldBridge(): int32 =
    return cheng_udp_platform_use_len_field_bridge()

fn udpPlatformMsgDontWaitBridge(): int32 =
    return cheng_udp_platform_msg_dontwait_bridge()

fn openImplRead(filename: str): File =
    let pathText: cstring = strToCStringTemp(filename)
    let modeRaw: str = newStringAlloc(2)
    if modeRaw.len == 2:
        modeRaw[0] = 'r'
        modeRaw[1] = 'b'
    let modeText: cstring = strToCStringTemp(modeRaw)
    return c_fopen(pathText, modeText)

fn openImplWrite(filename: str): File =
    let pathText: cstring = strToCStringTemp(filename)
    let modeRaw: str = newStringAlloc(2)
    if modeRaw.len == 2:
        modeRaw[0] = 'w'
        modeRaw[1] = 'b'
    let modeText: cstring = strToCStringTemp(modeRaw)
    return c_fopen(pathText, modeText)

fn openImplReadWrite(filename: str): File =
    let pathText: cstring = strToCStringTemp(filename)
    let modeRaw: str = newStringAlloc(3)
    if modeRaw.len == 3:
        modeRaw[0] = 'r'
        modeRaw[1] = 'b'
        modeRaw[2] = '+'
    let modeText: cstring = strToCStringTemp(modeRaw)
    return c_fopen(pathText, modeText)

fn setIoMeterHook(hook: IoMeterHook) =
    ioMeterHasHook = (hook != nil)
    ioMeterHook = hook

fn clearIoMeterHook() =
    ioMeterHasHook = false
    ioMeterHook = nil

fn ioMeterReport(op: IoMeterOp, bytes: int64) =
    if ioMeterHasHook && ioMeterHook != nil:
        c_iometer_call(ioMeterHook, op, bytes)

fn openImpl(filename: str, mode: FileMode): File =
    if mode == fmRead:
        return openImplRead(filename)
    if mode == fmWrite:
        return openImplWrite(filename)
    return openImplReadWrite(filename)

fn openRead(filename: str): File =
    return openImpl(filename, fmRead)

fn open(filename: str, mode: FileMode): File =
    return openImpl(filename, mode)

fn close(f: File): void =
    let _rc: int32 = c_fclose(f)

fn osDebugFileReadEnabled(): bool =
    return getEnvDefault("BACKEND_DEBUG_FILE_READ", "") == "1"

fn osDebugFileRead(msg: str): void =
    if osDebugFileReadEnabled():
        let f: File = get_stderr()
        write(f, "[os.Read] ")
        writeLine(f, msg)

fn osDebugFileReadKV(label: str, value: int32): void =
    if osDebugFileReadEnabled():
        let f: File = get_stderr()
        write(f, "[os.Read] ")
        write(f, label)
        write(f, "=")
        writeLine(f, intToStr(value))

fn readAllInto(f: File, out: var str): bool =
    if f == nil:
        osSetEmpty(out)
        return true
    var outBuf: buffer.ByteBuffer = buffer.NewByteBuffer()
    while true:
        let chunk: Bytes = bytesAlloc(256)
        let room: int32 = bytesLen(chunk)
        let got: int32 = c_fread(chunk.data, 1, room, f)
        osDebugFileReadKV("chunk.got", got)
        osDebugFileReadKV("chunk.room", room)
        osDebugFileReadKV("chunk.len_before", buffer.ByteBufferLen(outBuf))
        if got <= 0:
            break
        if got >= room:
            buffer.AppendBytes(outBuf, chunk)
        else:
            buffer.AppendBytes(outBuf, bytesSlice(chunk, 0, got))
        ioMeterReport(ioRead, int64(got))
    let outText: str = bytesToString(buffer.ToBytes(outBuf))
    let finalLen: int32 = strings.Len(outText)
    osDebugFileReadKV("final.lenRead", finalLen)
    osDebugFileReadKV("final.outLen", strings.Len(outText))
    out = outText
    return true

fn readAll(f: File): str =
    var out: str
    osSetEmpty(out)
    let _ok: bool = readAllInto(f, out)
    return out

fn write(f: File, s: str) =
    let wrote: int32 = c_fwrite(strDataPtr(s), 1, strings.Len(s), f)
    ioMeterReport(ioWrite, int64(wrote))

fn writeLine(f: File, s: str) =
    write(f, s)
    write(f, "\n")

