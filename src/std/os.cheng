    return tcpAcceptFd(fd, addr, addrLen)

fn TcpSendFd(fd: int32, payload: Bytes, flags: int32): int32 =
    return tcpSendFd(fd, payload, flags)

fn TcpRecvFd(fd: int32, payload: Bytes, flags: int32): int32 =
    return tcpRecvFd(fd, payload, flags)

fn TcpShutdownFd(fd: int32, how: int32): int32 =
    return tcpShutdownFd(fd, how)
