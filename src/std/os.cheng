    cheng_getcwd()
fn removeFile(path: str): bool =
    c_remove path == 0
fn renameFile(oldPath: str, newPath: str): bool =
    c_rename(oldPath, newPath) == 0
fn removeDir(path: str) =
    path
fn getEnvImpl(key: str, defaultValue: str): str =
    let v: str = c_getenv key
    let vPtr: void* = void*(v)
    if vPtr == nil:
        return defaultValue
    return v
fn getEnv(key: str): str =
    return getEnvImpl(key, "")
fn getEnvDefault(key: str, defaultValue: str): str =
    return getEnvImpl(key, defaultValue)
fn commandLineParams(): str[] =
    # cmdline module now loads argv from runtime bridge lazily.
    let count: int32 = cmdline.paramCount()
    var out: str[]
    if count > 0:
        setLen(out, count)
        var i: int32 = 1
        while i <= count:
            out[i - 1] = cmdline.paramStr(i)
            i = i + 1
    return osReturnStrSeq(out)
fn quoteShell(value: str): str =
    if len(value) == 0 || value[0] == char(0):
        return "''"
    return "'" + value + "'"

fn osJoinPathRaw(a: str, b: str, sep: char): str =
    let aLen: int32 = len(a)
    let bLen: int32 = len(b)
    let needSep: bool = sep != char(0)
    let totalLen: int32 = aLen + bLen + (needSep ? 1 : 0)
    let buf: void* = malloc(totalLen)
    if buf == nil:
        return a
    for i in 0..<aLen:
        let dst: char* = char*(ptr_add(buf, i))
        *dst = a[i]
    if needSep:
        let sepDst: char* = char*(ptr_add(buf, aLen))
        *sepDst = sep
    let bOff: int32 = aLen + (needSep ? 1 : 0)
    for i in 0..<bLen:
        let dst: char* = char*(ptr_add(buf, bOff + i))
        *dst = b[i]
    let out: str = newStringCopy(buf, totalLen)
    free(buf)
    return out

fn joinPath(a: str, b: str): str =
    if len(a) == 0 || a[0] == char(0):
        return b
    if len(b) == 0 || b[0] == char(0):
        return a
    let aLen: int32 = len a
    let last: char = a[aLen - 1]
    if last == '/' || last == '\\':
        return osJoinPathRaw(a, b, char(0))
    return osJoinPathRaw(a, b, '/')
fn `/`(a: str, b: str): str =
    return joinPath(a, b)

fn osSliceStr(text: str, start: int32, stop: int32): str =
    if len(text) == 0:
        return ""
    var s: int32 = start
    var e: int32 = stop
    if s < 0:
        s = 0
    let n: int32 = len text
    if e < s || s >= n:
        return ""
    if e >= n:
        e = n - 1
    let count: int32 = e - s + 1
    let src: void* = ptr_add(void*(text), s)
    return newStringCopy(src, count)
fn absolutePath(path: str): str =
    if len(path) == 0 || path[0] == char(0):
        return getCurrentDir()
    let c0: char = path[0]
    if c0 == '/' || c0 == '\\':
        return path
    if path[1] == ':':
        return path
    return joinPath(getCurrentDir(), path)
fn isAbsolute(path: str): bool =
    if len(path) == 0 || path[0] == char(0):
        return false
    let c0: char = path[0]
    if c0 == '/' || c0 == '\\':
        return true
    if path[1] == ':':
        return true
    return false
fn parentDir(path: str): str =
    let parts: SplitFileResult = splitFile path
    return parts.dir
fn relativePath(path: str, base: str): str =
    if len(base) == 0 || base[0] == char(0):
        return path
    let baseLen: int32 = len base
    let pathLen: int32 = len path
    if pathLen >= baseLen && osSliceStr(path, 0, baseLen - 1) == base:
        var idx: int32 = baseLen
        if idx < pathLen && (path[idx] == '/' || path[idx] == '\\'):
            idx = idx + 1
        if idx <= pathLen:
            return osSliceStr(path, idx, pathLen - 1)
    return path
fn splitFile(path: str): SplitFileResult =
    var dir0: str = ""
    var name0: str = ""
    var ext0: str = ""
    let pathLen: int32 = len path
    if pathLen == 0:
        return SplitFileResult(dir: dir0, name: name0, ext: ext0)
    var lastSep: int32 = -1
    for i in 0..<pathLen:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    var lastDot: int32 = -1
    i = pathLen - 1
    let __for_start_i_1 = i
    for __for_i_1 in 0..(__for_start_i_1 - ((lastSep) + (1))):
        i = __for_start_i_1 - __for_i_1
        let ch: char = path[i]
        if ch == '.':
            lastDot = i
            break
        i = i - 1
    let nameStart: int32 = lastSep + 1
    if lastSep >= 0:
        if lastSep <= 0:
            dir0 = ""
        else:
            dir0 = osSliceStr(path, 0, lastSep - 1)
        if nameStart >= pathLen:
            name0 = ""
        else:
            name0 = osSliceStr(path, nameStart, pathLen - 1)
    else:
        dir0 = ""
        name0 = path
    if lastDot > lastSep && lastDot >= 0:
        if lastDot - 1 >= nameStart:
            name0 = osSliceStr(path, nameStart, lastDot - 1)
        else:
            name0 = ""
        ext0 = osSliceStr(path, lastDot, pathLen - 1)
    return SplitFileResult(dir: dir0, name: name0, ext: ext0)
fn getFileSize(path: str): int64 =
    path
    return 0
fn getAppDir(): str =
    return getCurrentDir()
fn findExe(name: str): str =
    name
    return ""
fn setCurrentDir(path: str) =
    path
fn copyDir(src: str, dest: str) =
    src
    dest
fn makeWalkDirEntry(kind: PathComponent, path: str): str =
    return charToStr(char(48 + int32(kind))) + "|" + path
fn walkDir(path: str): seq_WalkDirEntry =
    var out: seq_WalkDirEntry = os_newSeq_WalkDirEntry(0, 0)
    if len(path) == 0 || path[0] == char(0) || ! dirExists path:
        return seq_WalkDirEntry(len: out.len, cap: out.cap, buffer: out.buffer)
    let listText: str = cheng_list_dir path
    if len(listText) == 0 || listText[0] == char(0):
        let listTextPtr: void* = void*(listText)
        if listTextPtr != nil:
            dealloc listTextPtr
        return seq_WalkDirEntry(len: out.len, cap: out.cap, buffer: out.buffer)
    let total: int32 = len listText
    var start: int32 = 0
    for i in 0..total:
        var endHit: bool = false
        if i == total:
            endHit = true
        elif listText[i] == '\n':
            endHit = true
        if endHit:
            var endIdx: int32 = i - 1
            if endIdx >= start && listText[endIdx] == '\r':
                endIdx = endIdx - 1
            if endIdx >= start:
                let name: str = osSliceStr(listText, start, endIdx)
                if len(name) > 0 && name[0] != char(0):
                    let fullPath: str = joinPath(path, name)
                    var kind: PathComponent = PathComponent(4)
                    if dirExists fullPath:
                        kind = PathComponent(1)
                    elif fileExists fullPath:
                        kind = PathComponent(0)
                    os_addPtr_WalkDirEntry(&out, makeWalkDirEntry(kind, fullPath))
            start = i + 1
    let listTextPtr: void* = void*(listText)
    dealloc listTextPtr
    return seq_WalkDirEntry(len: out.len, cap: out.cap, buffer: out.buffer)

fn walkDirRecImpl(path: str, out: str[]*) =
    let items: seq_WalkDirEntry = walkDir path
    for i in 0..<items.len:
        let entry: WalkDirEntry = os_get_WalkDirEntry(items, i)
        let kind: PathComponent = walkDirEntryKind(entry)
        let path: str = walkDirEntryPath(entry)
        if kind == PathComponent(1) || kind == PathComponent(3):
            walkDirRecImpl(path, out)
        elif kind == PathComponent(0) || kind == PathComponent(2):
            var pathOwned: str = path
            osAddStrArrayPtr(out, pathOwned)
fn walkDirRec(path: str): str[] =
    var out: str[]
    if len path == 0 || ! dirExists path:
        return osReturnStrSeq(out)
    walkDirRecImpl(path, &out)
    return osReturnStrSeq(out)
fn extractFilename(path: str): str =
    let parts: SplitFileResult = splitFile path
    if len parts.ext > 0:
        let name0: str = parts.name
        let ext0: str = parts.ext
        return name0 + ext0
    return parts.name
fn getLastModificationTime(path: str): DateTime =
    path
    return getTime()
fn processOptionMask(opt: ProcessOption): uint64 =
    return uint64(1) << uint64(int64(opt))

fn execCmdExImpl(command: str, options: uint64, workingDir: str): ExecCmdResult =
    var output0: str = ""
    var exitCode0: int32 = -1
    if len command == 0:
        return ExecCmdResult(output: output0, exitCode: exitCode0)
    var merge: int32 = 0
    let mask: uint64 = processOptionMask(poStdErrToStdOut)
    if (options & mask) != 0:
        merge = 1
    var exitCode64: int64 = -1
    let output1: str = cheng_exec_cmd_ex(command, workingDir, merge, &exitCode64)
    let outputPtr: void* = void*(output1)
    if outputPtr != nil:
        output0 = output1
    exitCode0 = int32(exitCode64)
    return ExecCmdResult(output: output0, exitCode: exitCode0)
fn execCmdEx(command: str, options: uint64, workingDir: str): ExecCmdResult =
    return execCmdExImpl(command, options, workingDir)
fn execCmdResultExitCode(result: ExecCmdResult): int32 =
    return result.exitCode
fn execCmdResultOutput(result: ExecCmdResult): str =
    return result.output
fn ptySupported(): bool =
    cheng_pty_is_supported() != 0
fn ptySpawn(command: str, workingDir: str, outMasterFd: int32*, outPid: int64*): bool =
    cheng_pty_spawn(command, workingDir, outMasterFd, outPid) != 0
fn pipeSpawn(command: str, workingDir: str, outReadFd: int32*, outWriteFd: int32*, outPid: int64*): bool =
    cheng_pipe_spawn(command, workingDir, outReadFd, outWriteFd, outPid) != 0
fn ptyRead(fd: int32, maxBytes: int32, outEof: int32*): str =
    return cheng_pty_read(fd, maxBytes, outEof)
fn fdRead(fd: int32, maxBytes: int32, outEof: int32*): str =
    return cheng_fd_read(fd, maxBytes, outEof)
fn fdReadWait(fd: int32, maxBytes: int32, timeoutMs: int32, outEof: int32*): str =
    return cheng_fd_read_wait(fd, maxBytes, timeoutMs, outEof)
fn ptyWrite(fd: int32, data: str): int32 =
    return cheng_pty_write(fd, data, len data)
fn ptyClose(fd: int32) =
    cheng_pty_close fd
fn ptyWait(pid: int64, outExitCode: int32*): int32 =
    return cheng_pty_wait(pid, outExitCode)
fn readFileSizedInto(path: str, size: int32, out: str* = nil): bool =
    let f: File = openRead(path)
    if f == nil:
        osStoreStrOut(out, "")
        return true
    let p: void* = alloc(size + 1)
    if p == nil:
        c_fclose f
        osStoreStrOut(out, "")
        return true
    let size64: int64 = int64(size)
    var totalGot64: int64 = 0
    while totalGot64 < size64:
        let dst: void* = ptr_add(p, int32(totalGot64))
        let want: int32 = int32(size64 - totalGot64)
        let got: int32 = c_fread(dst, 1, want, f)
        if got <= 0:
            break
        totalGot64 = totalGot64 + int64(got)
        ioMeterReport(ioRead, int64(got))
    c_fclose f
    let totalGot: int32 = int32(totalGot64)
    if totalGot != size:
        free p
        osStoreStrOut(out, "")
        return true
    let outText: str = newStringCopy(p, totalGot)
    free p
    if void*(outText) != nil && len(outText) > 0:
        memScopeEscape(void*(outText))
    osStoreStrOut(out, outText)
    return true

fn readFileInto(path: str, out: str* = nil): bool =
    if osDebugFileReadEnabled():
        osDebugFileRead("readFileInto path=" + path)
    let fastText: str = driver_c_read_file_all(cstring(path))
    if len(fastText) > 0:
        if void*(fastText) != nil:
            memScopeEscape(void*(fastText))
        osStoreStrOut(out, fastText)
        return true
    let f: File = openRead(path)
    if f == nil:
        if osDebugFileReadEnabled():
            osDebugFileRead("openRead nil")
        osStoreStrOut(out, "")
        return true
    let ok: bool = readAllInto(f, out)
    c_fclose f
    return ok

fn readFile(path: str): str =
    var out: str = ""
    let _ok: bool = readFileInto(path, &out)
    return out
fn writeFile(path: str, content: str) =
    if len(path) > 0:
        let flags: int32 = osOpenWriteOnly | osOpenCreate | osOpenTrunc
        let fd: int32 = libc_open(path, flags, osFileMode0644)
        if fd >= 0:
            if len(content) > 0:
                let wrote: int64 = libc_write(fd, void*(content), int64(len(content)))
                ioMeterReport(ioWrite, wrote)
            libc_close(fd)

fn writeFileBytes(path: str, bytes: uint8[]) =
    if len(path) > 0:
        let flags: int32 = osOpenWriteOnly | osOpenCreate | osOpenTrunc
        let fd: int32 = libc_open(path, flags, osFileMode0644)
        if fd >= 0:
            if bytes.buffer != nil && bytes.len > 0:
                let wrote: int64 = libc_write(fd, bytes.buffer, int64(bytes.len))
                ioMeterReport(ioWrite, wrote)
            libc_close(fd)
