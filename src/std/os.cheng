fn udpErrno(): int32 =
    return cheng_errno()

fn udpErrText(errCode: int32): str =
    let textPtr: cstring = cheng_strerror(errCode)
    if textPtr == nil:
        return "unknown"
    return str(textPtr)

fn udpCloseFd(fd: int32): int32 =
    return cheng_close_fd(fd)

fn udpFcntl(fd: int32, cmd: int32, arg: int32): int32 =
    return cheng_fcntl(fd, cmd, arg)

fn udpInetPton(family: int32, src: str, dst: Bytes): int32 =
    if len(src) <= 0 || bytesLen(dst) <= 0:
        return 0
    return cheng_inet_pton(family, cstring(src), dst.data)

fn udpInetNtop(family: int32, src: Bytes): str =
    if bytesLen(src) <= 0:
        return ""
    let outBuf: Bytes = bytesAlloc(128)
    if bytesLen(outBuf) <= 0:
        return ""
    bytesSet(outBuf, 0, 0)
    let textPtr: cstring = cheng_inet_ntop(family, src.data, cstring(outBuf.data), bytesLen(outBuf))
    if textPtr == nil:
        return ""
    return str(textPtr)

fn udpBindFd(fd: int32, addr: Bytes, addrLen: int32): int32 =
    if fd < 0 || addrLen <= 0:
        return -1
    return bind(fd, addr.data, addrLen)

fn udpSendToFd(fd: int32, payload: Bytes, flags: int32, addr: Bytes, addrLen: int32): int32 =
    if fd < 0 || addrLen <= 0 || bytesLen(payload) <= 0:
        return -1
    return sendto(fd, payload.data, bytesLen(payload), flags, addr.data, addrLen)

fn udpSetSockOptIntFd(fd: int32, level: int32, optName: int32, optBytes: Bytes): int32 =
    if fd < 0 || bytesLen(optBytes) <= 0:
        return -1
    return setsockopt(fd, level, optName, optBytes.data, bytesLen(optBytes))

fn setIoMeterHook(hook: IoMeterHook) =
    ioMeterHasHook = (hook != nil)
    ioMeterHook = hook

fn clearIoMeterHook() =
    ioMeterHasHook = false
    ioMeterHook = nil

fn ioMeterReport(op: IoMeterOp, bytes: int64) =
    if ioMeterHasHook && ioMeterHook != nil:
        c_iometer_call(ioMeterHook, op, bytes)

fn openImpl(filename: str, mode: FileMode): File =
    if mode == fmRead:
        return c_fopen(filename, "rb")
    if mode == fmWrite:
        return c_fopen(filename, "wb")
    return c_fopen(filename, "rb+")

fn openRead(filename: str): File =
    return openImpl(filename, fmRead)

fn open(filename: str, mode: FileMode): File =
    return openImpl(filename, mode)

fn close(f: File): void =
    c_fclose f

fn osStoreStrOut(out: str*, value: str): void =
    if out != nil:
        *out = value

fn osDebugFileReadEnabled(): bool =
    return getEnvDefault("BACKEND_DEBUG_FILE_READ", "") == "1"

fn osDebugFileRead(msg: str): void =
    if osDebugFileReadEnabled():
        let f: File = get_stderr()
        write(f, "[os.read] ")
        writeLine(f, msg)

fn osDebugFileReadKV(label: str, value: int32): void =
    if osDebugFileReadEnabled():
        let f: File = get_stderr()
        write(f, "[os.read] ")
        write(f, label)
        write(f, "=")
        writeLine(f, intToStr(value))

fn readAllInto(f: File, out: str* = nil): bool =
    if f == nil:
        osStoreStrOut(out, "")
        return true
    var cap64: int64 = 256
    var lenRead64: int64 = 0
    var p: void* = alloc int32(cap64)
    if p == nil:
        osStoreStrOut(out, "")
        return true
    while true:
        var room64: int64 = cap64 - lenRead64 - 1
        var room: int32 = int32(room64)
        if room <= 0:
            cap64 = cap64 * 2
            p = realloc(p, int32(cap64))
            if p == nil:
                osStoreStrOut(out, "")
                return true
            room64 = cap64 - lenRead64 - 1
            room = int32(room64)
            if room <= 0:
                break
        let dst: void* = ptr_add(p, int32(lenRead64))
        let got: int32 = c_fread(dst, 1, room, f)
        osDebugFileReadKV("chunk.got", got)
        osDebugFileReadKV("chunk.room", room)
        osDebugFileReadKV("chunk.len_before", int32(lenRead64))
        if got <= 0:
            break
        lenRead64 = lenRead64 + int64(got)
        ioMeterReport(ioRead, int64(got))
    let finalLen: int32 = int32(lenRead64)
    let outText: str = newStringCopy(p, finalLen)
    osDebugFileReadKV("final.lenRead", finalLen)
    osDebugFileReadKV("final.outLen", len(outText))
    if finalLen > 0:
        let src0: char* = char*(p)
        if src0 != nil:
            osDebugFileReadKV("final.src0", ord(*src0))
    if void*(outText) != nil:
        osDebugFileReadKV("final.out0", ord(outText[0]))
    free p
    if void*(outText) != nil && len(outText) > 0:
        memScopeEscape(void*(outText))
    osStoreStrOut(out, outText)
    return true

fn readAll(f: File): str =
    var out: str = ""
    let _ok: bool = readAllInto(f, &out)
    return out

fn write(f: File, s: str) =
    let wrote: int32 = c_fwrite(s, 1, len(s), f)
    ioMeterReport(ioWrite, int64(wrote))

fn writeLine(f: File, s: str) =
    write(f, s)
    write(f, "\n")

type
    SplitFileResult = object
        dir: str
        name: str
        ext: str
type
    PathComponent = enum
        pcFile, pcDir, pcLinkToFile, pcLinkToDir, pcOther
type
    WalkDirEntry = str
type
    ProcessOption = enum
        poStdErrToStdOut, poUsePath, poEvalCommand
type
    ExecCmdResult = object
        output: str
        exitCode: int
type
    seq_WalkDirEntry = object
        len: int32
        cap: int32
        buffer: void*
fn os_newSeq_WalkDirEntry(len: int32, cap: int32): seq_WalkDirEntry =
    var buffer0: void* = nil
    if cap > 0:
        var size64: int64 = int64(cap) * int64(ptrSize())
        var size32: int32 = int32(size64)
        buffer0 = alloc size32
    return seq_WalkDirEntry(len: len, cap: cap, buffer: buffer0)
fn os_get_WalkDirEntry(seqInst: seq_WalkDirEntry, i: int32): WalkDirEntry =
    var idx64: int64 = int64(i)
    var offset64: int64 = idx64 * int64(ptrSize())
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst.buffer, offset32)
    var pt: str* = str*(p)
    return *pt
fn walkDirEntryKind(entry: str): PathComponent =
    let entryPtr: void* = void*(entry)
    if entryPtr == nil || len(entry) <= 0:
        return PathComponent(4)
    let pCode: char* = char*(entryPtr)
    let code: char = *pCode
    if code == '0':
        return PathComponent(0)
    if code == '1':
        return PathComponent(1)
    if code == '2':
        return PathComponent(2)
    if code == '3':
        return PathComponent(3)
    return PathComponent(4)
fn walkDirEntryPath(entry: str): str =
    if len(entry) < 2:
        return ""
    let entryPtr: void* = void*(entry)
    if entryPtr == nil:
        return ""
    let pSep: char* = char*(ptr_add(entryPtr, 1))
    if *pSep != '|':
        return ""
    return strings.sliceBytes(entry, 2, len(entry) - 2)
fn pathComponentDir(): PathComponent =
    return PathComponent(1)
fn os_addPtr_WalkDirEntry(seqInst: seq_WalkDirEntry*, val: WalkDirEntry) =
    if seqInst->len >= seqInst->cap:
        var newCap: int32 = 4
        if seqInst->cap != 0:
            newCap = seqInst->cap * 2
        seqInst->cap = newCap
        var cap64: int64 = int64(newCap)
        var size64: int64 = int64(cap64) * int64(ptrSize())
        var size32: int32 = int32(size64)
        seqInst->buffer = realloc(seqInst->buffer, size32)
    var idx64: int64 = int64(seqInst->len)
    var offset64: int64 = int64(idx64) * int64(ptrSize())
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst->buffer, offset32)
    var pt: str* = str*(p)
    *pt = val
    seqInst->len = seqInst->len + 1

fn os_arcRetainSeq_WalkDirEntry(seqInst: seq_WalkDirEntry) =
    if seqInst.buffer != nil:
        memRetain seqInst.buffer
    for i in 0..<seqInst.len:
        let entry: WalkDirEntry = os_get_WalkDirEntry(seqInst, i)
        let entryPtr: void* = void*(entry)
        if entryPtr != nil:
            memRetain entryPtr

fn os_arcReleaseSeq_WalkDirEntry(seqInst: seq_WalkDirEntry) =
    for i in 0..<seqInst.len:
        let entry: WalkDirEntry = os_get_WalkDirEntry(seqInst, i)
        let entryPtr: void* = void*(entry)
        if entryPtr != nil:
            memRelease entryPtr
    if seqInst.buffer != nil:
        memRelease seqInst.buffer

