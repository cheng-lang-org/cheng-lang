type
    seq_WalkDirEntry = WalkDirEntry[]
fn os_newSeq_WalkDirEntry(len: int32, cap: int32): seq_WalkDirEntry =
    var out: str[]
    if cap > 0:
        seqs.Reserve(out, cap)
    if len > 0:
        seqs.SetLen(out, len)
    return out
fn os_get_WalkDirEntry(seqInst: str[], i: int32): WalkDirEntry =
    return seqInst[i]
fn walkDirEntryKind(entry: str): PathComponent =
    if strings.Len(entry) <= 0:
        return PathComponent(4)
    let code: char = entry[0]
    if code == '0':
        return PathComponent(0)
    if code == '1':
        return PathComponent(1)
    if code == '2':
        return PathComponent(2)
    if code == '3':
        return PathComponent(3)
    return PathComponent(4)
fn walkDirEntryPath(entry: str): str =
    if strings.Len(entry) < 2:
        return ""
    if entry[1] != '|':
        return ""
    return strings.SliceBytes(entry, 2, strings.Len(entry) - 2)

fn splitFileResult(dir: str, name: str, ext: str): SplitFileResult =
    var out: SplitFileResult
    out.dir = dir
    out.name = name
    out.ext = ext
    return out

fn pathComponentDir(): PathComponent =
    return PathComponent(1)
fn os_addPtr_WalkDirEntry(seqInst: var str[], val: WalkDirEntry) =
    add(seqInst, val)

fn fileExists(path: str): bool =
    return cheng_os_file_exists_bridge(path) != 0
fn dirExists(path: str): bool =
    return cheng_os_dir_exists_bridge(path) != 0
fn createDir(path: str) =
    cheng_mkdir1(strToCStringTemp(path))
fn bos_dirExists(path: str): bool =
    return dirExists(path)
fn makeDir(path: str): bool =
    return cheng_mkdir1(strToCStringTemp(path)) != 0
fn fileMtime(path: str): int64 =
    return cheng_file_mtime(strToCStringTemp(path))
fn fileSize(path: str): int64 =
    return cheng_os_file_size_bridge(path)
@importc("driver_c_get_current_dir_bridge")
fn getCurrentDir(): str
fn removeFile(path: str): bool =
    c_remove(strToCStringTemp(path)) == 0
fn renameFile(oldPath: str, newPath: str): bool =
    c_rename(strToCStringTemp(oldPath), strToCStringTemp(newPath)) == 0
fn removeDir(path: str) =
    if strings.Len(path) > 0:
        let _ = c_rmdir(strToCStringTemp(path))
fn setEnv(key: str, value: str) =
    let ignoredRc: int32 = c_setenv(strToCStringTemp(key), strToCStringTemp(value), 1)
    ignoredRc
fn commandLineParams(): str[] =
    # cmdline module now loads argv from runtime bridge lazily.
    let count: int32 = cmdline.ParamCount()
    var out: str[]
    if count > 0:
        setLen(out, count)
        for i in 1..count:
            out[i - 1] = cmdline.ParamStr(i)
    return osReturnStrSeq(out)
fn quoteShell(value: str): str =
    if Len(value) == 0:
        return "''"
    var out: str = "'"
    for i in 0..<Len(value):
        let part = strings.SliceBytes(value, i, 1)
        if part == "'":
            out = Fmt"{out}'\"'\"'"
        else:
            out = Fmt"{out}{part}"
    out = Fmt"{out}'"
    return out

fn joinPath(a: str, b: str): str =
    if strings.Len(a) == 0:
        return b
    if a[0] == Char(0):
        return b
    if strings.Len(b) == 0:
        return a
    if b[0] == Char(0):
        return a
    let aLen: int32 = strings.Len(a)
    let last: char = a[aLen - 1]
    var hasSep: bool
    if last == '/':
        hasSep = true
    if last == '\\':
        hasSep = true
    var result: str
    if !hasSep:
        result = Fmt"{a}/{b}"
    else:
        result = Fmt"{a}{b}"
    # Reject path traversal: "../" segments and trailing ".."
    if StrContains(result, "/../") || strings.HasSuffix(result, "/.."):
        return ""
    return result
fn `/`(a: str, b: str): str =
    return joinPath(a, b)

fn osSliceStr(text: str, start: int32, stop: int32): str =
    if strings.Len(text) == 0:
        return ""
    var s: int32 = start
    var e: int32 = stop
    if s < 0:
        s = 0
    let n: int32 = strings.Len(text)
    if e < s || s >= n:
        return ""
    if e >= n:
        e = n - 1
    let count: int32 = e - s + 1
    return NewStringCopy(SystemPtrAdd(StrDataPtr(text), s), count)
fn absolutePath(path: str): str =
    if strings.Len(path) == 0 || path[0] == Char(0):
        return getCurrentDir()
    let c0: char = path[0]
    if c0 == '/' || c0 == '\\':
        return path
    if strings.Len(path) > 1 && path[1] == ':':
        return path
    return joinPath(getCurrentDir(), path)
fn isAbsolute(path: str): bool =
    if strings.Len(path) == 0 || path[0] == Char(0):
        return false
    let c0: char = path[0]
    if c0 == '/' || c0 == '\\':
        return true
    if strings.Len(path) > 1 && path[1] == ':':
        return true
    return false
fn parentDir(path: str): str =
    let n: int32 = strings.Len(path)
    if n <= 0:
        return ""
    var lastSep: int32 = -1
    for i in 0..<n:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    if lastSep <= 0:
        return ""
    return osSliceStr(path, 0, lastSep - 1)
fn relativePath(path: str, base: str): str =
    if strings.Len(base) == 0 || base[0] == Char(0):
        return path
    let baseLen: int32 = strings.Len(base)
    let pathLen: int32 = strings.Len(path)
    if pathLen >= baseLen && osSliceStr(path, 0, baseLen - 1) == base:
        var idx: int32 = baseLen
        if idx < pathLen && (path[idx] == '/' || path[idx] == '\\'):
            idx = idx + 1
        if idx <= pathLen:
            return osSliceStr(path, idx, pathLen - 1)
    return path
fn splitFile(path: str): SplitFileResult =
    let pathLen: int32 = strings.Len(path)
    if pathLen == 0:
        return splitFileResult("", "", "")
    var lastSep: int32 = -1
    for i in 0..<pathLen:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    var lastDot: int32 = -1
    let nameStart: int32 = lastSep + 1
    if nameStart < pathLen:
        let revStart: int32 = pathLen - 1
        for revOffset in 0..(revStart - nameStart):
            let idx: int32 = revStart - revOffset
            let ch: char = path[idx]
            if ch == '.':
                lastDot = idx
                break
    if lastDot > lastSep && lastDot >= 0:
        if lastSep >= 0:
            if lastSep <= 0:
                if lastDot - 1 >= nameStart:
                    return splitFileResult("",
                                           osSliceStr(path, nameStart, lastDot - 1),
                                           osSliceStr(path, lastDot, pathLen - 1))
                return splitFileResult("",
                                       "",
                                       osSliceStr(path, lastDot, pathLen - 1))
            if lastDot - 1 >= nameStart:
                return splitFileResult(osSliceStr(path, 0, lastSep - 1),
                                       osSliceStr(path, nameStart, lastDot - 1),
                                       osSliceStr(path, lastDot, pathLen - 1))
            return splitFileResult(osSliceStr(path, 0, lastSep - 1),
                                   "",
                                   osSliceStr(path, lastDot, pathLen - 1))
        if lastDot > 0:
            return splitFileResult("",
                                   osSliceStr(path, 0, lastDot - 1),
                                   osSliceStr(path, lastDot, pathLen - 1))
        return splitFileResult("",
                               "",
                               osSliceStr(path, lastDot, pathLen - 1))
    if lastSep >= 0:
        if lastSep <= 0:
            if nameStart >= pathLen:
                return splitFileResult("", "", "")
            return splitFileResult("",
                                   osSliceStr(path, nameStart, pathLen - 1),
                                   "")
        if nameStart >= pathLen:
            return splitFileResult(osSliceStr(path, 0, lastSep - 1),
                                   "",
                                   "")
        return splitFileResult(osSliceStr(path, 0, lastSep - 1),
                               osSliceStr(path, nameStart, pathLen - 1),
                               "")
    return splitFileResult("", path, "")
fn getFileSize(path: str): int64 =
    path
    return 0
fn getAppDir(): str =
    return getCurrentDir()
fn findExe(name: str): str =
    name
    return ""
fn setCurrentDir(path: str) =
    path
fn copyDir(src: str, dest: str) =
    src
    dest
fn makeWalkDirEntry(kind: PathComponent, path: str): str =
    let kindText: str = strings.IntToStr(Int32(kind))
    return Fmt"{kindText}|{path}"
fn listDir(path: str): str[] =
    var out: str[]
    if Len(path) == 0 || path[0] == Char(0) || !dirExists(path):
        return out
    let pathRaw: cstring = strToCStringTemp(path)
    let listRaw: cstring = cheng_list_dir_raw(pathRaw)
    if path.flags == 0 && pathRaw != nil:
        Free(ptr(pathRaw))
    if listRaw == nil:
        return out
    let listText: str = strFromCStringBorrow(listRaw)
    if Len(listText) == 0 || listText[0] == Char(0):
        Free(ptr(listRaw))
        return out
    let total: int32 = Len(listText)
    var count: int32
    var start: int32
    for i in 0..total:
        var endHit: bool
        if i == total:
            endHit = true
        elif listText[i] == '\n':
            endHit = true
        if endHit:
            var endIdx: int32 = i - 1
            if endIdx >= start && listText[endIdx] == '\r':
                endIdx = endIdx - 1
            if endIdx >= start:
                count = count + 1
            start = i + 1
    if count <= 0:
        Free(ptr(listRaw))
        return out
    setLen(out, count)
    var outLen: int32
    start = 0
    for i in 0..total:
        var endHit: bool
        if i == total:
            endHit = true
        elif listText[i] == '\n':
            endHit = true
        if endHit:
            var endIdx: int32 = i - 1
            if endIdx >= start && listText[endIdx] == '\r':
                endIdx = endIdx - 1
            if endIdx >= start:
                var nameOwned: str = osSliceStr(listText, start, endIdx)
                if Len(nameOwned) > 0 && nameOwned[0] != Char(0):
                    osMoveStr(out[outLen], nameOwned)
                    outLen = outLen + 1
            start = i + 1
    Free(ptr(listRaw))
    return out
fn walkDir(path: str): str[] =
    var out: str[]
    if Len(path) == 0 || path[0] == Char(0) || !dirExists(path):
        return out
    let names: str[] = listDir(path)
    for i in 0..<names.len:
        let name: str = names[i]
        if Len(name) <= 0 || name[0] == Char(0):
            continue
        let fullPath: str = joinPath(path, name)
        var kind: PathComponent = PathComponent(4)
        if dirExists(fullPath):
            kind = PathComponent(1)
        elif fileExists(fullPath):
            kind = PathComponent(0)
        var entryOwned: str = makeWalkDirEntry(kind, fullPath)
        add(out, entryOwned)
    return out

fn walkDirRecImpl(path: str, out: var str[]) =
    let items: seq_WalkDirEntry = walkDir(path)
    for i in 0..<items.len:
        let entry: WalkDirEntry = os_get_WalkDirEntry(items, i)
        let kind: PathComponent = walkDirEntryKind(entry)
        let path: str = walkDirEntryPath(entry)
        if kind == PathComponent(1) || kind == PathComponent(3):
            walkDirRecImpl(path, out)
        elif kind == PathComponent(0) || kind == PathComponent(2):
            var pathOwned: str = path
            add(out, pathOwned)
fn walkDirRec(path: str): str[] =
    var out: str[]
    if strings.Len(path) == 0 || !dirExists(path):
        return osReturnStrSeq(out)
    walkDirRecImpl(path, out)
    return osReturnStrSeq(out)
fn extractFilename(path: str): str =
    let pathLen: int32 = strings.Len(path)
    if pathLen <= 0:
        return ""
    var lastSep: int32 = -1
    for i in 0..<pathLen:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    let nameStart: int32 = lastSep + 1
    if nameStart >= pathLen:
        return ""
    return osSliceStr(path, nameStart, pathLen - 1)
fn getLastModificationTime(path: str): DateTime =
    path
    return getTime()
fn processOptionMask(opt: ProcessOption): uint64 =
    return UInt64(1) << UInt64(Int64(opt))

fn execCommandHasEvalOption(options: uint64): bool =
    return (options & UInt64(4)) != UInt64(0)

fn execCommandWithEvalOption(options: uint64): uint64 =
    return options | UInt64(4)

fn execCmdExImpl(command: str, options: uint64, workingDir: str): ExecCmdResult =
    var output0: str
    osSetEmpty(output0)
    var exitCode0: int32 = -1
    if strings.Len(command) == 0:
        var emptyResult: ExecCmdResult
        emptyResult.output = output0
        emptyResult.exitCode = exitCode0
        return emptyResult
    var merge: int32
    let mask: uint64 = UInt64(1)
    if (options & mask) != 0:
        merge = 1
    let output1: str = strFromCStringBorrow(cheng_exec_cmd_capture_raw(strToCStringTemp(command),
                                                                       strToCStringTemp(workingDir),
                                                                       merge))
    let exitCode64: int64 = cheng_exec_cmd_last_exit_code_raw()
    osSetStr(output0, output1)
    exitCode0 = Int32(exitCode64)
    var out: ExecCmdResult
    out.output = output0
    out.exitCode = exitCode0
    return out
fn execCmdEx(command: str, options: uint64, workingDir: str): ExecCmdResult =
    if !execCommandHasEvalOption(options):
        panic("std/os ExecCmdEx requires PoEvalCommand; prefer std/os_host_process ExecFile* for argv-safe execution")
    return execCmdExImpl(command, options, workingDir)

fn execShellCmdEx(command: str, options: uint64, workingDir: str): ExecCmdResult =
    return execCmdExImpl(command, execCommandWithEvalOption(options), workingDir)

fn execCmdStatus(command: str, workingDir: str): int32 =
    panic("std/os ExecCmdStatus requires explicit shell eval; use ExecShellCmdStatus or std/os_host_process ExecFileStatus")
    return -1

fn execShellCmdStatus(command: str, workingDir: str): int32 =
    if strings.Len(command) == 0:
        return -1
    return cheng_exec_cmd_status_raw(strToCStringTemp(command),
                                     strToCStringTemp(workingDir))
fn execCmdResultExitCode(result: ExecCmdResult): int32 =
    return result.exitCode
fn execCmdResultOutput(result: ExecCmdResult): str =
    return result.output

const osResourceGuardRusageSelf: int32 = 0
const osResourceGuardMemoryExceeded: int32 = 125

var processResourceGuardConfiguredMaxRssBytesReady: bool
var processResourceGuardConfiguredMaxRssBytesCached: int64

fn processResourceGuardParseUnsignedInt64(raw: str): int64 =
    if Len(raw) <= 0:
        return Int64(-1)
    var value: int64
    var hadDigit = false
    var trailingSpace = false
    for i in 0..<Len(raw):
        let ch = raw[i]
        if ch >= '0' && ch <= '9':
            if trailingSpace:
                return Int64(-1)
            value = value * Int64(10) + Int64(Int32(ch) - Int32('0'))
            hadDigit = true
        elif ch == ' ' || ch == '\n' || ch == '\t' || ch == '\r':
            if hadDigit:
                trailingSpace = true
        else:
            return Int64(-1)
    if !hadDigit:
        return Int64(-1)
    return value
fn processResourceGuardDefaultMaxRssBytes(): int64 =
    return Int64(8589934592)
fn processResourceGuardConfiguredMaxRssBytes(): int64 =
    let parentGuardRaw = getEnv("CHENG_PARENT_RSS_GUARD")
    if Len(parentGuardRaw) > 0:
        return Int64(0)
    var raw = getEnv("CHENG_PROCESS_MAX_RSS_BYTES")
    if Len(raw) <= 0:
        raw = getEnv("CHENG_MAX_RSS_BYTES")
    if Len(raw) <= 0:
        return processResourceGuardDefaultMaxRssBytes()
    if raw == "8589934592":
        return processResourceGuardDefaultMaxRssBytes()
    let parsed = processResourceGuardParseUnsignedInt64(raw)
    if parsed <= Int64(0):
        return Int64(-1)
    return parsed
fn processResourceGuardConfiguredMaxRssBytesOnce(): int64 =
    if processResourceGuardConfiguredMaxRssBytesReady:
        return processResourceGuardConfiguredMaxRssBytesCached
    let value = processResourceGuardConfiguredMaxRssBytes()
    processResourceGuardConfiguredMaxRssBytesCached = value
    processResourceGuardConfiguredMaxRssBytesReady = true
    return value
fn processResourceGuardCurrentRssBytes(): int64 =
    var usage: OsRusage
    if os_getrusage_bridge(osResourceGuardRusageSelf, usage) != 0:
        return Int64(-1)
    if usage.ru_maxrss <= Int64(0):
        return Int64(-1)
    return usage.ru_maxrss
fn processResourceGuardMemoryLimitExceededLine(rssBytes: int64,
                                                maxRssBytes: int64): str =
    return Fmt"compile_progress phase=resource_guard status=rss_limit_exceeded rss_bytes={strings.Int64ToStr(rssBytes)} limit_bytes={strings.Int64ToStr(maxRssBytes)}"
fn processResourceGuardMemoryUnavailableLine(): str =
    return "compile_progress phase=resource_guard status=rss_unavailable"
fn processResourceGuardCheck() =
    let maxRssBytes = processResourceGuardConfiguredMaxRssBytesOnce()
    if maxRssBytes == Int64(0):
        return
    if maxRssBytes < Int64(0):
        writeLine(get_stderr(), "compile_progress phase=resource_guard status=invalid_max_rss")
        os_exit_bridge(2)
    let rssBytes = processResourceGuardCurrentRssBytes()
    if rssBytes <= Int64(0):
        writeLine(get_stderr(), processResourceGuardMemoryUnavailableLine())
        os_exit_bridge(2)
    if rssBytes > maxRssBytes:
        writeLine(get_stderr(), processResourceGuardMemoryLimitExceededLine(rssBytes, maxRssBytes))
        os_exit_bridge(osResourceGuardMemoryExceeded)
fn sleepMs(value: int32) =
    if value <= 0:
        return
    libc_usleep(UInt32(value * 1000))
fn readFileSizedInto(path: str, size: int32, out: var str): bool =
    var f: File = openRead(path)
    if f == nil:
        osSetEmpty(out)
        return true
    let raw: Bytes = BytesAlloc(size)
    if BytesLen(raw) != size:
        c_fclose(f)
        osSetEmpty(out)
        return true
    let size64: int64 = Int64(size)
    var totalGot64: int64
    while totalGot64 < size64:
        let want: int32 = Int32(size64 - totalGot64)
        let dst: Bytes = BytesSliceView(raw, Int32(totalGot64), want)
        let got: int32 = c_fread(dst.data, 1, want, f)
        if got <= 0:
            break
        totalGot64 = totalGot64 + Int64(got)
        ioMeterReport(ioRead, Int64(got))
    c_fclose(f)
    let totalGot: int32 = Int32(totalGot64)
    if totalGot != size:
        osSetEmpty(out)
        return true
    var outText: str = BytesToString(raw)
    osMoveStr(out, outText)
    return true

fn readFileInto(path: str, out: var str): bool =
    if osDebugFileReadEnabled():
        osDebugFileRead(Fmt"readFileInto path={path}")
    let knownSize64: int64 = fileSize(path)
    if knownSize64 >= 0 && knownSize64 <= Int64(0x7fffffff):
        let sizedOk: bool = readFileSizedInto(path, Int32(knownSize64), out)
        if sizedOk:
            return true
    let f: File = openRead(path)
    if f == nil:
        if osDebugFileReadEnabled():
            osDebugFileRead("openRead nil")
        osSetEmpty(out)
        return true
    let ok: bool = readAllInto(f, out)
    c_fclose(f)
    return ok

fn readFile(path: str): str =
    let knownSize64: int64 = fileSize(path)
    if knownSize64 >= 0 && knownSize64 <= Int64(0x7fffffff):
        let f: File = openRead(path)
        if f == nil:
            return ""
        let size: int32 = Int32(knownSize64)
        let raw: Bytes = BytesAlloc(size)
        if BytesLen(raw) != size:
            c_fclose(f)
            return ""
        let size64: int64 = Int64(size)
        var totalGot64: int64
        while totalGot64 < size64:
            let want: int32 = Int32(size64 - totalGot64)
            let dst: Bytes = BytesSliceView(raw, Int32(totalGot64), want)
            let got: int32 = c_fread(dst.data, 1, want, f)
            if got <= 0:
                break
            totalGot64 = totalGot64 + Int64(got)
            ioMeterReport(ioRead, Int64(got))
        c_fclose(f)
        if Int32(totalGot64) != size:
            return ""
        return BytesToString(raw)
    let f: File = openRead(path)
    if f == nil:
        return ""
    var total: Bytes = EmptyBytes()
    while true:
        let chunk: Bytes = BytesAlloc(256)
        let got: int32 = c_fread(chunk.data, 1, BytesLen(chunk), f)
        if got <= 0:
            break
        if got >= BytesLen(chunk):
            total = bytesConcat(total, chunk)
        else:
            total = bytesConcat(total, BytesSlice(chunk, 0, got))
        ioMeterReport(ioRead, Int64(got))
    c_fclose(f)
    return BytesToString(total)

fn osWriteAllRaw(f: File, data: ptr, total: int32, label: str) =
    if f == nil:
        panic("os write failed: nil file")
    if total < 0:
        panic("os write failed: negative length")
    if total == 0:
        return
    if data == nil:
        panic("os write failed: nil data")
    var written: int32
    while written < total:
        let chunk: int32 = c_fwrite(SystemPtrAdd(data, written), 1, total - written, f)
        if chunk <= 0:
            panic(label)
        written = written + chunk
    ioMeterReport(ioWrite, Int64(written))

fn osCloseWrittenFile(f: File) =
    if c_fflush(f) != 0:
        let _closeAfterFlushFailure: int32 = c_fclose(f)
        panic("os write failed: flush")
    if c_fclose(f) != 0:
        panic("os write failed: close")

fn writeFile(path: str, content: str) =
    if strings.Len(path) <= 0:
        panic("os writeFile: empty path")
    let filePath: cstring = strToCStringTemp(path)
    if filePath == nil:
        panic("os writeFile: invalid path")
    let f: File = c_fopen(filePath, "wb")
    if f == nil:
        panic("os writeFile: open")
    osWriteAllRaw(f, StrDataPtr(content), strings.Len(content), "os writeFile: write")
    osCloseWrittenFile(f)

fn writeFileBytes(path: str, bytes: uint8[]) =
    if strings.Len(path) <= 0:
        panic("os writeFileBytes: empty path")
    let filePath: cstring = strToCStringTemp(path)
    if filePath == nil:
        panic("os writeFileBytes: invalid path")
    let f: File = c_fopen(filePath, "wb")
    if f == nil:
        panic("os writeFileBytes: open")
    if bytes.len > 0:
        if bytes.buffer == nil:
            let _closeAfterNilBuffer: int32 = c_fclose(f)
            panic("os writeFileBytes: nil data")
        osWriteAllRaw(f, bytes.buffer, bytes.len, "os writeFileBytes: write")
    osCloseWrittenFile(f)

