fn add(dst: var str[], val: str) =
    let writeAt: int32 = dst.len
    let nextLen: int32 = writeAt + 1
    if dst.buffer == nil || writeAt >= dst.cap:
        cheng__seqGrowInst_string(&dst, nextLen)
    dst.len = nextLen
    dst[writeAt] = val

fn add(dst: str[]*, val: str) =
    osAddStrArrayPtr(dst, val)

fn osAddStrArrayPtr(dst: str[]*, val: str) =
    if dst != nil:
        let writeAt: int32 = dst->len
        let nextLen: int32 = writeAt + 1
        if dst->buffer == nil || writeAt >= dst->cap:
            cheng__seqGrowInst_string(dst, nextLen)
        let writePtr: str* = str*(ptr_add(dst->buffer, writeAt * ptrSize()))
        *writePtr = val
        dst->len = nextLen

fn osReturnStrSeq(out: str[]): str[] =
    return seq_string(len: out.len, cap: out.cap, buffer: out.buffer)

