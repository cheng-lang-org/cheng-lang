fn add(dst: var str[], val: str) =
    seqs.add(dst, val)

fn osReturnStrSeq(out: str[]): str[] =
    return out

type
    File = ptr

type
    FileMode = enum
        fmRead
        fmWrite
        fmReadWrite

type
    IoMeterOp = enum
        ioRead
        ioWrite

type
    IoMeterHook = fn (op: IoMeterOp, bytes: int64)

var
    ioMeterHasHook: bool = false
    ioMeterHook: IoMeterHook = nil

const osOpenWriteOnly: int32 = 0x0001
const osOpenReadOnly: int32 = 0
const osOpenCreate: int32 = 0x0200
const osOpenTrunc: int32 = 0x0400
const osFileMode0644: int32 = 420

@importc("cheng_fopen")
fn cheng_fopen(filename, mode: cstring): File
@importc("fopen")
fn libc_fopen(filename, mode: cstring): File
fn c_fopen(filename, mode: cstring): File =
    let f: File = cheng_fopen(filename, mode)
    if f != nil:
        return f
    return libc_fopen(filename, mode)
@importc("cheng_fclose")
