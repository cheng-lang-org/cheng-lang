@importc("cheng_mem_release")
fn os_mem_release(p: ptr)

fn add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn osReturnStrSeq(out: str[]): str[] =
    return out

fn osSetEmpty(out: var str) =
    out.data = nil
    out.len = 0
    out.store_id = 0
    out.flags = 0

fn osSetStr(out: var str, value: str) =
    out.data = value.data
    out.len = value.len
    out.store_id = value.store_id
    out.flags = value.flags

fn osReleaseStr(out: var str) =
    if out.flags == 1 && out.data != nil:
        os_mem_release(out.data)
    osSetEmpty(out)

fn osMoveStr(out: var str, value: var str) =
    if out.data != value.data:
        osReleaseStr(out)
    out.data = value.data
    out.len = value.len
    out.store_id = value.store_id
    out.flags = value.flags
    value.data = nil
    value.len = 0
    value.store_id = 0
    value.flags = 0

