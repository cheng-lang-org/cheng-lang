    let prevLen: int32 = seqInst.len
    if target > seqInst.cap || (target > 0 && seqInst.buffer == nil):
        cheng__seqGrowInst(&seqInst, target, elemBytes)
    if target > seqInst.len:
        cheng__seqZeroTailRaw(seqInst.buffer, seqInst.cap, seqInst.len, target, elemBytes)
    elif target < prevLen:
        cheng_seq_string_release_range_compat(seqInst.buffer, target, prevLen - target)
    seqInst.len = target

