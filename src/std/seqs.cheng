# Sequence module

type
    ChengSeqHeader =
        len: int32
        cap: int32
        buffer: void*

@importc("cheng_seq_delete_shift")
fn cheng_seq_delete_shift(buffer: void*, at: int32, len: int32, elemSize: int32)
@importc("cheng_seq_slice_alloc")
fn cheng_seq_slice_alloc(buffer: void*, len: int32, startPos: int32, stopPos: int32,
                         exclusive: int32, elemSize: int32, outLen: int32*, outCap: int32*): void*
@importc("cheng_mem_retain")
fn seqs_mem_retain(p: void*)
@importc("cheng_mem_release")
fn seqs_mem_release(p: void*)

fn cheng__seqNextCap(curCap: int32, needLen: int32): int32 =
    var cap: int32
    cap = curCap
    if cap < 4:
        cap = 4
    while true:
        if !(cap < needLen):
            break
        cap = cap * 2
        if cap <= 0:
            cap = needLen
            break
    return cap

fn cheng__seqGrowToRaw(pBuffer: void**, pCap: int32*, minCap: int32, typeSize: int32) =
    if minCap > 0:
        var cap: int32
        cap = *pCap
        var buffer: void*
        buffer = *pBuffer
        if buffer == nil || minCap > cap:
            var newCap: int32
            newCap = cap
            if newCap < minCap:
                newCap = cheng__seqNextCap(cap, minCap)
            if newCap <= 0:
                newCap = cheng__seqNextCap(0, minCap)
            let oldBytes: int32 = (buffer != nil) ? (cap * typeSize) : 0
            let newBytes: int32 = newCap * typeSize
            let newBuffer: void* = realloc(buffer, newBytes)
            if newBuffer == nil:
                panic "cheng: out of memory"
            *pBuffer = newBuffer
            *pCap = newCap
            if newBytes > oldBytes:
                zeroMem(ptr_add(newBuffer, oldBytes), newBytes - oldBytes)

fn cheng__seqGrowInst(seqPtr: T[]*, minCap: int32, typeSize: int32) =
    if seqPtr != nil && minCap > 0:
        let seqHdr: ChengSeqHeader* = ChengSeqHeader*(seqPtr)
        var cap: int32
        cap = seqHdr->cap
        var buffer: void*
        buffer = seqHdr->buffer
        if buffer == nil || minCap > cap:
            var newCap: int32
            newCap = cap
            if newCap < minCap:
                newCap = cheng__seqNextCap(cap, minCap)
            if newCap <= 0:
                newCap = cheng__seqNextCap(0, minCap)
            let oldBytes: int32 = (buffer != nil) ? (cap * typeSize) : 0
            let newBytes: int32 = newCap * typeSize
            let newBuffer: void* = realloc(buffer, newBytes)
            if newBuffer == nil:
                panic "cheng: out of memory"
            seqHdr->buffer = newBuffer
            seqHdr->cap = newCap
            if newBytes > oldBytes:
                zeroMem(ptr_add(newBuffer, oldBytes), newBytes - oldBytes)

fn cheng__seqZeroTailRaw(buffer: void*, cap: int32, len: int32, target: int32, typeSize: int32) =
    cap
    if buffer != nil:
        if target > len:
            let fromBytes: int32 = len * typeSize
            let toBytes: int32 = target * typeSize
            if toBytes > fromBytes:
                let zeroCount: int32 = toBytes - fromBytes
                let zeroBase: void* = ptr_add(buffer, fromBytes)
                var zeroI: int32 = 0
                while zeroI < zeroCount:
                    *(uint8*(ptr_add(zeroBase, zeroI))) = uint8(0)
                    zeroI = zeroI + 1

fn setLen(seqInst: var T[], newLen: int) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    var target: int32 = int32(newLen)
    if target < 0:
        target = 0
    if target > seqHdr->cap || (target > 0 && seqHdr->buffer == nil):
        cheng__seqGrowInst(&seqInst, target, elemSize[T]())
    if target > seqHdr->len:
        cheng__seqZeroTailRaw(seqHdr->buffer, seqHdr->cap, seqHdr->len, target, elemSize[T]())
    seqHdr->len = target

fn setLen(seqInst: var T[], newLen: int32) =
    setLen(seqInst, int(newLen))

fn setLen(seqInst: T[]*, newLen: int) =
    if seqInst != nil:
        let seqHdr: ChengSeqHeader* = ChengSeqHeader*(seqInst)
        var target: int32 = int32(newLen)
        if target < 0:
            target = 0
        if target > seqHdr->cap || (target > 0 && seqHdr->buffer == nil):
            cheng__seqGrowInst(seqInst, target, elemSize[T]())
        if target > seqHdr->len:
            cheng__seqZeroTailRaw(seqHdr->buffer, seqHdr->cap, seqHdr->len, target, elemSize[T]())
        seqHdr->len = target

fn setLen(seqInst: T[]*, newLen: int32) =
    setLen(seqInst, int(newLen))

fn setLenPtr(seqInst: var T[], newLen: int) =
    setLen(seqInst, newLen)

fn reserve(seqInst: var T[], newCap: int32) =
    if newCap >= 0:
        let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
        if newCap > seqHdr->cap || seqHdr->buffer == nil:
            cheng__seqGrowInst(&seqInst, newCap, elemSize[T]())

fn reserve(seqInst: var T[], newCap: int) =
    reserve(seqInst, int32(newCap))

fn reserve(seqInst: T[]*, newCap: int32) =
    if seqInst != nil && newCap >= 0:
        let seqHdr: ChengSeqHeader* = ChengSeqHeader*(seqInst)
        if newCap > seqHdr->cap || seqHdr->buffer == nil:
            cheng__seqGrowInst(seqInst, newCap, elemSize[T]())

fn reserve(seqInst: T[]*, newCap: int) =
    reserve(seqInst, int32(newCap))

fn reservePtr(seqInst: var T[], newCap: int32) =
    reserve(seqInst, newCap)

fn clear(seqInst: var T[]) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    seqHdr->len = 0

fn resize(seqInst: var T[], newLen: int, capHint: int32 = 0) =
    if capHint > 0:
        reserve(seqInst, capHint)
    setLen(seqInst, newLen)

fn len(seqInst: T[]): int32 =
    return seqInst.len

fn dataPtr(seqInst: T[]): void* =
    return seqInst.buffer

fn get(seqInst: T[], at: int32): T =
    return seqInst[at]

fn get(seqInst: T[]*, at: int32): T =
    if seqInst == nil:
        panic "seqs.get: nil seq pointer"
    return seqInst[at]

fn add(seqInst: var T[], val: T) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    let nextLen: int32 = seqHdr->len + 1
    if seqHdr->buffer == nil || seqHdr->len >= seqHdr->cap:
        cheng__seqGrowInst(&seqInst, nextLen, elemSize[T]())
    let elemBytes: int32 = seqHdr->len * elemSize[T]()
    let writePtr: T* = T*(ptr_add(seqHdr->buffer, elemBytes))
    *writePtr = val
    seqHdr->len = nextLen

fn seqAdd(seqInst: var T[], val: T) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    let nextLen: int32 = seqHdr->len + 1
    if seqHdr->buffer == nil || seqHdr->len >= seqHdr->cap:
        cheng__seqGrowInst(&seqInst, nextLen, elemSize[T]())
    let elemBytes: int32 = seqHdr->len * elemSize[T]()
    let writePtr: T* = T*(ptr_add(seqHdr->buffer, elemBytes))
    *writePtr = val
    seqHdr->len = nextLen

fn add(seqInst: T[]*, val: T) =
    if seqInst != nil:
        let seqHdr: ChengSeqHeader* = ChengSeqHeader*(seqInst)
        if seqHdr->buffer == nil || seqHdr->len >= seqHdr->cap:
            cheng__seqGrowInst(seqInst, seqHdr->len + 1, elemSize[T]())
        let elemBytes: int32 = seqHdr->len * elemSize[T]()
        let writePtr: T* = T*(ptr_add(seqHdr->buffer, elemBytes))
        *writePtr = val
        seqHdr->len = seqHdr->len + 1

fn findImpl(seqInst: T[], val: T, start: int32): int32 =
    var index: int32 = start
    if index < 0:
        index = 0
    let __for_guard_start_index_1 = index
    for __for_guard_index_1 in __for_guard_start_index_1..<seqInst.len:
        if ! (index < seqInst.len):
            break
        if seqInst[index] == val:
            return index
        index = index + 1
    return -1

fn find(seqInst: T[], val: T): int32 =
    var index: int32 = 0
    let __for_guard_start_index_2 = index
    for __for_guard_index_2 in __for_guard_start_index_2..<seqInst.len:
        if ! (index < seqInst.len):
            break
        if seqInst[index] == val:
            return index
        index = index + 1
    return -1

fn find(seqInst: T[], val: T, start: int32): int32 =
    var index: int32 = start
    if index < 0:
        index = 0
    let __for_guard_start_index_3 = index
    for __for_guard_index_3 in __for_guard_start_index_3..<seqInst.len:
        if ! (index < seqInst.len):
            break
        if seqInst[index] == val:
            return index
        index = index + 1
