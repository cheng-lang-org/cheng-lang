fn reset(seqInst: var T[]) =
    freeSeq(seqInst)

fn arcRetainSeq(seqInst: T[]) =
    if seqInst.buffer != nil:
        seqs_mem_retain(void*(seqInst.buffer))

fn arcReleaseSeq(seqInst: T[]) =
    if seqInst.buffer != nil:
        seqs_mem_release(void*(seqInst.buffer))

# Monomorphized legacy alias for str sequence (kept for bootstrap compatibility).
type
    seq_string = str[]

fn seqReturnString(out: str[]): str[] =
    return seq_string(len: out.len, cap: out.cap, buffer: out.buffer)

fn cheng__seqGrowInst_string(seqPtr: str[]*, minCap: int32) =
    if seqPtr != nil && minCap > 0:
        var cap: int32 = seqPtr->cap
        var buffer: void* = seqPtr->buffer
        if buffer == nil || minCap > cap:
            var newCap: int32 = cap
            if newCap < minCap:
                newCap = cheng__seqNextCap(cap, minCap)
            if newCap <= 0:
                newCap = cheng__seqNextCap(0, minCap)
            let oldBytes: int32 = (buffer != nil) ? (cap * ptrSize()) : 0
            let newBytes: int32 = newCap * ptrSize()
            let newBuffer: void* = realloc(buffer, newBytes)
            if newBuffer == nil:
                panic "cheng: out of memory"
            seqPtr->buffer = newBuffer
            seqPtr->cap = newCap
            if newBytes > oldBytes:
                zeroMem(ptr_add(newBuffer, oldBytes), newBytes - oldBytes)

fn newSeq_string(seqLen: int32, seqCap: int32): str[] =
    var out: str[]
    var needCap: int32 = seqCap
    if needCap < seqLen:
        needCap = seqLen
    if needCap > 0:
        cheng__seqGrowInst_string(&out, needCap)
    if seqLen > 0:
        cheng__seqZeroTailRaw(out.buffer, out.cap, 0, seqLen, ptrSize())
        out.len = seqLen
    return seqReturnString(out)

fn get_string(seqInst: seq_string, at: int32): str =
    return seqInst[at]

fn add_string(seqInst: var seq_string, val: str) =
    let writeAt: int32 = seqInst.len
    let nextLen: int32 = writeAt + 1
    if seqInst.buffer == nil || writeAt >= seqInst.cap:
        cheng__seqGrowInst_string(&seqInst, nextLen)
    seqInst.len = nextLen
    seqInst[writeAt] = val

fn arcRetainSeqString(seqInst: str[]) =
    arcRetainSeq(seqInst)
    var index: int32 = 0
    let count: int32 = seqInst.len
    while index < count:
        let value: str = seqInst[index]
        if void*(value) != nil:
            let valuePtr: void* = void*(value)
            seqs_mem_retain(valuePtr)
        index = index + 1

fn arcReleaseSeqString(seqInst: str[]) =
    var index: int32 = 0
    let count: int32 = seqInst.len
    while index < count:
        let value: str = seqInst[index]
        if void*(value) != nil:
            let valuePtr: void* = void*(value)
            seqs_mem_release(valuePtr)
        index = index + 1
    arcReleaseSeq(seqInst)

fn arcRetainSeq_string(seqInst: seq_string) =
    arcRetainSeqString(seqInst)

fn arcReleaseSeq_string(seqInst: seq_string) =
    arcReleaseSeqString(seqInst)

fn freeSeqPtr_string(seqInst: var seq_string) =
    if seqInst.buffer != nil:
        seqs_mem_release(void*(seqInst.buffer))
    seqInst.buffer = nil
    seqInst.len = 0
    seqInst.cap = 0

fn __cheng_vec_contains(seqInst: T[], val: T): bool =
    var index: int32 = 0
    let count: int32 = seqInst.len
    let __for_guard_start_index_7 = index
    for __for_guard_index_7 in __for_guard_start_index_7..<count:
        if ! (index < count):
            break
        let cur: T = seqInst[index]
        if cur == val:
            return true
        index = index + 1
    return false

fn __cheng_slice_vec(seqInst: T[], startPos: int32, stopPos: int32, exclusive: bool): T[] =
    if exclusive:
        var index: int32 = startPos
        if index < 0:
            index = 0
        var out: T[]
        let outHdr: ChengSeqHeader* = ChengSeqHeader*(&out)
        while index < seqInst.len:
            if index >= stopPos:
                break
            let nextLen: int32 = outHdr->len + 1
            if outHdr->buffer == nil || outHdr->len >= outHdr->cap:
                cheng__seqGrowInst(&out, nextLen, elemSize[T]())
            let elemBytes: int32 = outHdr->len * elemSize[T]()
            let writePtr: T* = T*(ptr_add(outHdr->buffer, elemBytes))
            *writePtr = seqInst[index]
            outHdr->len = nextLen
            index = index + 1
        return out
    var index: int32 = startPos
    if index < 0:
        index = 0
    var out: T[]
    let outHdr: ChengSeqHeader* = ChengSeqHeader*(&out)
    while index < seqInst.len:
        if index > stopPos:
            break
        let nextLen: int32 = outHdr->len + 1
        if outHdr->buffer == nil || outHdr->len >= outHdr->cap:
            cheng__seqGrowInst(&out, nextLen, elemSize[T]())
        let elemBytes: int32 = outHdr->len * elemSize[T]()
        let writePtr: T* = T*(ptr_add(outHdr->buffer, elemBytes))
        *writePtr = seqInst[index]
        outHdr->len = nextLen
        index = index + 1
    return out
