    let writeAt: int32 = seqInst.len
    cheng_seq_string_register_compat(&seqInst)
    let slot: ptr = cheng_seq_set_grow(&seqInst, writeAt, chengSeqStringElemBytesCompat())
    chengSeqStoreStrCompat(slot, val)

