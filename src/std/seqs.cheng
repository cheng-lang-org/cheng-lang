fn delete(seqInst: var T[], at: int32) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    if at >= 0 && at < seqHdr->len:
        cheng_seq_delete_shift(seqHdr->buffer, at, seqHdr->len, elemSize[T]())
        seqHdr->len = seqHdr->len - 1

fn delete(seqInst: T[]*, at: int32) =
    if seqInst != nil:
        let seqHdr: ChengSeqHeader* = ChengSeqHeader*(seqInst)
        if at >= 0 && at < seqHdr->len:
            cheng_seq_delete_shift(seqHdr->buffer, at, seqHdr->len, elemSize[T]())
            seqHdr->len = seqHdr->len - 1

fn freeSeqPtr(seqInst: var T[]) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    if seqHdr->buffer != nil:
        seqs_mem_release(seqHdr->buffer)
    seqHdr->buffer = nil
    seqHdr->len = 0
    seqHdr->cap = 0

fn freeSeqPtr(seqInst: T[]*) =
    if seqInst != nil:
        let seqHdr: ChengSeqHeader* = ChengSeqHeader*(seqInst)
        if seqHdr->buffer != nil:
            seqs_mem_release(seqHdr->buffer)
        seqHdr->buffer = nil
        seqHdr->len = 0
        seqHdr->cap = 0

fn freeSeq(seqInst: var T[]) =
    let seqHdr: ChengSeqHeader* = ChengSeqHeader*(&seqInst)
    if seqHdr->buffer != nil:
        seqs_mem_release(seqHdr->buffer)
    seqHdr->buffer = nil
    seqHdr->len = 0
    seqHdr->cap = 0

# Stage1/self-link fallback symbol for concrete str sequence free helper.
