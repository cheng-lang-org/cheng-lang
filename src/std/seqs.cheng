# Sequence module
# system is implicitly imported in Stage 0
type
    VoidPtr = void*
    seq[T] =
        len: int32
        cap: int32
        buffer: void*
    seq_fixed[T, N] =
        len: int32
        cap: int32
        buffer: void*
        storage: array[T, N]

fn seqFixedInit[T, N](seqInst: var seq[T, N]) =
    seqInst.len = 0
    var size64: int64 = sizeof seqInst.storage
    var elem64: int64 = sizeof T
    var cap64: int64 = 0
    if elem64 > 0:
        cap64 = size64 / elem64
    seqInst.cap = int32(cap64)
    seqInst.buffer = void*(&seqInst.storage)

fn newSeqFixed[T, N](): seq[T, N] =
    var seqInst: seq[T, N]
    seqFixedInit[T, N] seqInst
    return seqInst

fn seqFixedLen[T, N](seqInst: seq[T, N]): int32 =
    return seqInst.len

fn seqFixedCap[T, N](seqInst: seq[T, N]): int32 =
    return seqInst.cap

fn seqFixedClear[T, N](seqInst: var seq[T, N]) =
    seqInst.len = 0

fn seqFixedTryAdd[T, N](seqInst: var seq[T, N], val: T): bool =
    if seqInst.len >= seqInst.cap:
        return false
    var idx64: int64 = int64(seqInst.len)
    var offset64: int64 = idx64 * sizeof T
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst.buffer, offset32)
    var pt: T* = T*(p)
    *pt = val
    seqInst.len = seqInst.len + 1
    return true

fn seqFixedGet[T, N](seqInst: seq[T, N], i: int32): T =
    var idx64: int64 = int64(i)
    var offset64: int64 = idx64 * sizeof T
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst.buffer, offset32)
    var pt: T* = T*(p)
    return *pt

fn seqFixedSet[T, N](seqInst: var seq[T, N], i: int32, val: T) =
    var idx64: int64 = int64(i)
    var offset64: int64 = idx64 * sizeof T
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst.buffer, offset32)
    var pt: T* = T*(p)
    *pt = val

fn `[]`[T, N](seqInst: seq[T, N], i: int32): T =
    return seqFixedGet[T, N](seqInst, i)

fn `[]=`[T, N](seqInst: var seq[T, N], i: int32, val: T) =
    seqFixedSet[T, N](seqInst, i, val)
fn newSeqWithCap[T](len: int32, cap: int32): seq[T] =
    var seqInstance: seq[T]
    seqInstance.len = len
    seqInstance.cap = cap
    if cap > 0:
        # Use cast to convert int64(size) to int32(for) alloc
        var size64: int64 = int64(cap) * sizeof T
        var size32: int32 = int32(size64)
        seqInstance.buffer = alloc size32
        if seqInstance.buffer != nil:
            zeroMem(seqInstance.buffer, size32)
    else:
        seqInstance.buffer = nil
    return seqInstance
fn newSeqImpl[T](len: int): seq[T] =
    var count = len
    if count < 0:
        count = 0
    var cap32: int32 = int32(count)
    var seqInstance: seq[T] = newSeqWithCap[T](cap32, cap32)
    seqInstance.len = cap32
    return seqInstance
fn newSeq[T](len: int = 0): seq[T] =
    return newSeqImpl[T] len
fn newSeqOfCap[T](cap: int): seq[T] =
    var count = cap
    if count < 0:
        count = 0
    return newSeqWithCap[T](0, int32(count))
fn dataPtr[T](seqInst: seq[T]): void* =
    return seqInst.buffer
fn setLen[T](seqInst: var seq[T], newLen: int) =
    if newLen < 0:
        return
    var target: int32 = int32(newLen)
    if target > seqInst.cap:
        let oldCap: int32 = seqInst.cap
        var newCap: int32 = seqInst.cap
        if newCap == 0:
            newCap = 4
        while newCap < target:
            newCap = newCap * 2
        seqInst.cap = newCap
        var cap64: int64 = int64(newCap)
        var size64: int64 = int64(cap64) * sizeof T
        var size32: int32 = int32(size64)
        seqInst.buffer = realloc(seqInst.buffer, size32)
        if seqInst.buffer != nil && oldCap >= 0:
            var oldSize64: int64 = int64(oldCap) * sizeof T
            var oldSize32: int32 = int32(oldSize64)
            if size32 > oldSize32:
                zeroMem(ptr_add(seqInst.buffer, oldSize32), size32 - oldSize32)
    elif target > seqInst.len && seqInst.buffer != nil:
        var from64: int64 = int64(seqInst.len) * sizeof T
        var from32: int32 = int32(from64)
        var to64: int64 = int64(target) * sizeof T
        var to32: int32 = int32(to64)
        if to32 > from32:
            zeroMem(ptr_add(seqInst.buffer, from32), to32 - from32)
    seqInst.len = target
fn len[T](seqInst: seq[T]): int32 =
    return seqInst.len
fn addPtr[T](seqInst: seq[T]*, val: T) =
    if seqInst->len >= seqInst->cap:
        let oldCap: int32 = seqInst->cap
        var newCap: int32 = 4
        if seqInst->cap != 0:
            newCap = seqInst->cap * 2
        seqInst->cap = newCap
        var cap64: int64 = int64(newCap)
        var size64: int64 = int64(cap64) * sizeof T
        var size32: int32 = int32(size64)
        seqInst->buffer = realloc(seqInst->buffer, size32)
        if seqInst->buffer != nil && oldCap >= 0:
            var oldSize64: int64 = int64(oldCap) * sizeof T
            var oldSize32: int32 = int32(oldSize64)
            if size32 > oldSize32:
                zeroMem(ptr_add(seqInst->buffer, oldSize32), size32 - oldSize32)
    var idx64: int64 = int64(seqInst->len)
    var offset64: int64 = int64(idx64) * sizeof T
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst->buffer, offset32)
    var pt: T* = T*(p)
    *pt = val
    seqInst->len = seqInst->len + 1
fn add[T](seqInst: var seq[T], val: T) =
    # Ideally call addPtr(&seqInst, val) but + is tricky here.
    if seqInst.len >= seqInst.cap:
        var newCap: int32 = 4
        if seqInst.cap != 0:
            newCap = seqInst.cap * 2
        seqInst.cap = newCap
        var cap64: int64 = int64(newCap)
        var size64: int64 = int64(cap64) * sizeof T
        var size32: int32 = int32(size64)
        seqInst.buffer = realloc(seqInst.buffer, size32)
    var idx64: int64 = int64(seqInst.len)
    var offset64: int64 = int64(idx64) * sizeof T
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst.buffer, offset32)
    var pt: T* = T*(p)
    *pt = val
    seqInst.len = seqInst.len + 1
fn seqAdd[T](seqInst: var seq[T], val: T) =
    if seqInst.len >= seqInst.cap:
        var newCap: int32 = 4
        if seqInst.cap != 0:
            newCap = seqInst.cap * 2
        seqInst.cap = newCap
        var cap64: int64 = int64(newCap)
        var size64: int64 = int64(cap64) * sizeof T
        var size32: int32 = int32(size64)
        seqInst.buffer = realloc(seqInst.buffer, size32)
    var idx64: int64 = int64(seqInst.len)
    var offset64: int64 = int64(idx64) * sizeof T
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst.buffer, offset32)
    var pt: T* = T*(p)
    *pt = val
    seqInst.len = seqInst.len + 1
fn get[T](seqInst: seq[T], i: int32): T =
    var p: void* = cheng_seq_get(seqInst.buffer, seqInst.len, i, sizeof T)
    var pt: T* = T*(p)
    return *pt
fn findImpl[T](seqInst: seq[T], val: T, start: int32): int32 =
    var i = start
    if i < 0:
        i = 0
    while i < seqInst.len:
        if seqInst[i] == val:
            return i
        i = i + 1
    return -1
fn find[T](seqInst: seq[T], val: T): int32 =
    return findImpl[T](seqInst, val, 0)
fn find[T](seqInst: seq[T], val: T, start: int32): int32 =
    return findImpl[T](seqInst, val, start)
fn getPtr[T](seqInst: seq[T]*, i: int32): T =
    var p: void* = cheng_seq_get(seqInst->buffer, seqInst->len, i, sizeof T)
    var pt: T* = T*(p)
    return *pt
fn setPtr[T](seqInst: seq[T]*, i: int32, val: T) =
    var p: void* = cheng_seq_set(seqInst->buffer, seqInst->len, i, sizeof T)
    var pt: T* = T*(p)
    *pt = val

fn delete[T](seqInst: seq[T]*, idx: int32) =
    if idx < 0 || idx >= seqInst->len:
        return
    var j: int32 = idx
    while j + 1 < seqInst->len:
        setPtr[T](seqInst, j, getPtr[T](seqInst, j + 1))
        j = j + 1
    seqInst->len = seqInst->len - 1

fn freeSeqPtr[T](seqInst: seq[T]*) =
    if seqInst == nil:
        return
    if seqInst->buffer != nil:
        memRelease seqInst->buffer
    seqInst->buffer = nil
    seqInst->len = 0
    seqInst->cap = 0

fn freeSeq[T](seqInst: var seq[T]) =
    freeSeqPtr[T](&seqInst)

fn reset[T](seqInst: var seq[T]) =
    if seqInst.buffer != nil:
        memRelease seqInst.buffer
    seqInst.buffer = nil
    seqInst.len = 0
    seqInst.cap = 0

fn arcRetainSeq[T](seqInst: seq[T]) =
    if seqInst.buffer != nil:
        memRetain seqInst.buffer

fn arcReleaseSeq[T](seqInst: seq[T]) =
    if seqInst.buffer != nil:
        memRelease seqInst.buffer

# Monomorphized seq for str (bootstrap).
type
    seq_string =
        len: int32
        cap: int32
        buffer: void*
fn newSeq_string(len: int32, cap: int32): seq_string =
    var seqInstance: seq_string
    seqInstance.len = 0
    seqInstance.cap = cap
    if cap > 0:
        var size64: int64 = int64(cap) * sizeof cstring
        var size32: int32 = int32(size64)
        seqInstance.buffer = alloc size32
        if seqInstance.buffer != nil:
            zeroMem(seqInstance.buffer, size32)
    else:
        seqInstance.buffer = nil
    return seqInstance
fn get_string(seqInst: seq_string, i: int32): str =
    var idx64: int64 = int64(i)
    var offset64: int64 = idx64 * sizeof cstring
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst.buffer, offset32)
    var pt: str* = str*(p)
    return *pt
fn addPtr_string(seqInst: seq_string*, val: str) =
    if seqInst->len >= seqInst->cap:
        let oldCap: int32 = seqInst->cap
        var newCap: int32 = 4
        if seqInst->cap != 0:
            newCap = seqInst->cap * 2
        seqInst->cap = newCap
        var cap64: int64 = int64(newCap)
        var size64: int64 = int64(cap64) * sizeof cstring
        var size32: int32 = int32(size64)
        seqInst->buffer = realloc(seqInst->buffer, size32)
        if seqInst->buffer != nil && oldCap >= 0:
            var oldSize64: int64 = int64(oldCap) * sizeof cstring
            var oldSize32: int32 = int32(oldSize64)
            if size32 > oldSize32:
                zeroMem(ptr_add(seqInst->buffer, oldSize32), size32 - oldSize32)
    var idx64: int64 = int64(seqInst->len)
    var offset64: int64 = int64(idx64) * sizeof cstring
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst->buffer, offset32)
    var pt: str* = str*(p)
    *pt = val
    seqInst->len = seqInst->len + 1

fn arcRetainSeqString(seqInst: seq[str]) =
    if seqInst.buffer != nil:
        memRetain seqInst.buffer
    var i: int32 = 0
    while i < seqInst.len:
        let s: str = get[str](seqInst, i)
        if s != nil:
            memRetain void*(s)
        i = i + 1

fn arcReleaseSeqString(seqInst: seq[str]) =
    var i: int32 = 0
    while i < seqInst.len:
        let s: str = get[str](seqInst, i)
        if s != nil:
            memRelease void*(s)
        i = i + 1
    if seqInst.buffer != nil:
        memRelease seqInst.buffer

fn arcRetainSeq_string(seqInst: seq_string) =
    if seqInst.buffer != nil:
        memRetain seqInst.buffer
    var i: int32 = 0
    while i < seqInst.len:
        let s: str = get_string(seqInst, i)
        if s != nil:
            memRetain void*(s)
        i = i + 1

fn arcReleaseSeq_string(seqInst: seq_string) =
    var i: int32 = 0
    while i < seqInst.len:
        let s: str = get_string(seqInst, i)
        if s != nil:
            memRelease void*(s)
        i = i + 1
    if seqInst.buffer != nil:
        memRelease seqInst.buffer
# Minimal str(seq) helpers used by the IDE.
fn setStringAt(seqInst: seq_string*, i: int32, val: str) =
    var idx64: int64 = int64(i)
    var offset64: int64 = idx64 * sizeof cstring
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst->buffer, offset32)
    var pt: str* = str*(p)
    *pt = val
fn getStringAtPtr(seqInst: seq_string*, i: int32): str =
    if seqInst == nil || seqInst->buffer == nil:
        return nil
    var idx64: int64 = int64(i)
    var offset64: int64 = idx64 * sizeof cstring
    var offset32: int32 = int32(offset64)
    var p: void* = ptr_add(seqInst->buffer, offset32)
    var pt: str* = str*(p)
    return *pt
fn insert(seqInst: seq_string*, val: str, idx: int32) =
    var pos: int32 = idx
    if pos < 0:
        pos = 0
    if pos > seqInst->len:
        pos = seqInst->len
    var oldLen: int32 = seqInst->len
    addPtr_string(seqInst, val)
    var j: int32 = oldLen
    while j > pos:
        setStringAt(seqInst, j, getStringAtPtr(seqInst, j - 1))
        j = j - 1
    setStringAt(seqInst, pos, val)
fn delete(seqInst: seq_string*, idx: int32) =
    if idx < 0 || idx >= seqInst->len:
        return
    var j: int32 = idx
    while j + 1 < seqInst->len:
        setStringAt(seqInst, j, getStringAtPtr(seqInst, j + 1))
        j = j + 1
    seqInst->len = seqInst->len - 1

fn freeSeqPtr_string(seqInst: seq_string*) =
    if seqInst == nil:
        return
    if seqInst->buffer != nil:
        free seqInst->buffer
    seqInst->buffer = nil
    seqInst->len = 0
    seqInst->cap = 0
# Helper for generic pointer vector (for Node.kids)
fn getPointer(v: seq[void*], i: int32): void* =
    var p: void* = cheng_seq_get(v.buffer, v.len, i, sizeof VoidPtr)
    return load_ptr p
fn __cheng_vec_contains[T](seqInst: seq[T], val: T): bool =
    var i: int32 = 0
    while i < seqInst.len:
        if seqInst[i] == val:
            return true
        i = i + 1
    return false
fn __cheng_slice_vec[T](seqInst: seq[T], start: int32, stop: int32, exclusive: bool): seq[T] =
    var s: int32 = start
    var e: int32 = stop
    if exclusive:
        e = e - 1
    if s < 0:
        s = 0
    if e < s || seqInst.len <= 0:
        return newSeqWithCap[T](0, 0)
    if s >= seqInst.len:
        return newSeqWithCap[T](0, 0)
    if e >= seqInst.len:
        e = seqInst.len - 1
    let count: int32 = e - s + 1
    var out: seq[T] = newSeqWithCap[T](0, count)
    var i: int32 = s
    while i <= e:
        if out.len >= out.cap:
            var nextCap: int32 = 4
            if out.cap > 0:
                nextCap = out.cap * 2
            reserve[T](&out, nextCap)
        var srcIdx64: int64 = int64(i)
        var srcOff64: int64 = srcIdx64 * sizeof T
        var srcOff32: int32 = int32(srcOff64)
        var srcP: void* = ptr_add(seqInst.buffer, srcOff32)
        var srcT: T* = T*(srcP)
        var dstIdx64: int64 = int64(out.len)
        var dstOff64: int64 = dstIdx64 * sizeof T
        var dstOff32: int32 = int32(dstOff64)
        var dstP: void* = ptr_add(out.buffer, dstOff32)
        var dstT: T* = T*(dstP)
        *dstT = *srcT
        out.len = out.len + 1
        i = i + 1
    return out
