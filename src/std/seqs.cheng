        let slot: ptr = cheng_seq_set_grow(seqInst, writeAt, chengSeqStringElemBytesCompat())
        chengSeqStoreStrCompat(slot, val)

fn __cheng_vec_contains(seqInst: T[], val: T): bool =
    var index: int32
    let count: int32 = seqInst.len
    for index in index..<count:
        let cur: T = seqInst[index]
        if cur == val:
            return true
    return false

fn __cheng_slice_vec(seqInst: T[], startPos: int32, stopPos: int32, exclusive: bool): T[] =
    if exclusive:
        var index: int32 = startPos
        if index < 0:
            index = 0
        var out: T[]
        for index in index..<seqInst.len:
            if index >= stopPos:
                break
            let nextLen: int32 = out.len + 1
            if out.buffer == nil || out.len >= out.cap:
                cheng__seqGrowInst(&out, nextLen, elemSize[T]())
            out.len = nextLen
            out[nextLen - 1] = seqInst[index]
        return out
    var index: int32 = startPos
    if index < 0:
        index = 0
    var out: T[]
    for index in index..<seqInst.len:
        if index > stopPos:
            break
        let nextLen: int32 = out.len + 1
        if out.buffer == nil || out.len >= out.cap:
            cheng__seqGrowInst(&out, nextLen, elemSize[T]())
        out.len = nextLen
        out[nextLen - 1] = seqInst[index]
    return out

