fn p256GeneratorWindow4NegPoint(idx: int32): EcPointFixed =
    if idx == 0:
        return pointInfinityFixed()
    let point: EcPointFixed = p256GeneratorWindow4Point(idx)
    let yNeg: pfix.P256Fixed = p256FieldFixedSubCrash(p256FieldFixedZero(), point.y)
    return EcPointFixed(x: point.x, y: yNeg, inf: false)

