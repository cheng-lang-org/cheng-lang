fn p256ScalarFixedIsZero(a: pfix.P256Fixed): bool =
    var aa: pfix.P256Fixed = a
    return pfix.p256FixedIsZero(aa)

fn p256ScalarFixedIsOdd(a: pfix.P256Fixed): bool =
    return (pfix.p256FixedWordToBitsU64(a.limbs[0]) & uint64(1)) != uint64(0)

fn p256ScalarFixedLow5(a: pfix.P256Fixed): int32 =
    return int32(pfix.p256FixedWordToBitsU64(a.limbs[0]) & uint64(31))

fn p256ScalarFixedAddSmall(a: pfix.P256Fixed, delta: int32): pfix.P256Fixed =
    var out: pfix.P256Fixed = a
    var carry: uint64 = uint64(delta)
    var i: int32 = 0
    while carry != uint64(0) && i < pfix.p256FixedLimbCount:
        let av: uint64 = pfix.p256FixedWordToBitsU64(out.limbs[i])
        let sum: uint64 = av + carry
        out.limbs[i] = pfix.p256FixedWordFromBitsU64(sum)
        carry = sum >> uint64(pfix.p256FixedWordBits)
        i = i + 1
    return out

fn p256ScalarFixedSubSmall(a: pfix.P256Fixed, delta: int32): pfix.P256Fixed =
    var out: pfix.P256Fixed = a
    var borrow: uint64 = uint64(delta)
    var i: int32 = 0
    let wordBase: uint64 = uint64(1) << uint64(pfix.p256FixedWordBits)
    while borrow != uint64(0) && i < pfix.p256FixedLimbCount:
        let av: uint64 = pfix.p256FixedWordToBitsU64(out.limbs[i])
        if av >= borrow:
            out.limbs[i] = pfix.p256FixedWordFromBitsU64(av - borrow)
            borrow = uint64(0)
        else:
            out.limbs[i] = pfix.p256FixedWordFromBitsU64(wordBase + av - borrow)
            borrow = uint64(1)
        i = i + 1
    return out

fn p256ScalarFixedShiftRight1(a: pfix.P256Fixed): pfix.P256Fixed =
    var out: pfix.P256Fixed
    var carry: uint64 = uint64(0)
    let __for_start_i = pfix.p256FixedLimbCount - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        let limb: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[i])
        let shifted: uint64 = (limb >> uint64(1)) | (carry << uint64(pfix.p256FixedWordBits - 1))
        out.limbs[i] = pfix.p256FixedWordFromBitsU64(shifted)
        carry = limb & uint64(1)
    return out

fn p256ScalarFixedComb8Digit(a: pfix.P256Fixed, row: int32): int32 =
    var digit: int32 = 0
    var i: int32 = 0
    while i < 8:
        let bitIdx: int32 = row + (32 * i)
        digit = digit | (pfix.p256FixedGetBit(a, bitIdx) << i)
        i = i + 1
    return digit

fn p256ScalarFixedComb6Digit(a: pfix.P256Fixed, row: int32): int32 =
    let w0: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[0])
    let w1: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[1])
    let w2: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[2])
    let w3: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[3])
    let w4: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[4])
    let w5: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[5])
    let w6: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[6])
    let w7: uint64 = pfix.p256FixedWordToBitsU64(a.limbs[7])
    var digit: int32 = 0
    if row < 32:
        digit = digit | int32((w0 >> uint64(row)) & uint64(1))
    else:
        digit = digit | int32((w1 >> uint64(row - 32)) & uint64(1))
    if row < 21:
        digit = digit | (int32((w1 >> uint64(row + 11)) & uint64(1)) << 1)
    else:
        digit = digit | (int32((w2 >> uint64(row - 21)) & uint64(1)) << 1)
    if row < 10:
        digit = digit | (int32((w2 >> uint64(row + 22)) & uint64(1)) << 2)
    elif row < 42:
        digit = digit | (int32((w3 >> uint64(row - 10)) & uint64(1)) << 2)
    else:
        digit = digit | (int32(w4 & uint64(1)) << 2)
    if row < 31:
        digit = digit | (int32((w4 >> uint64(row + 1)) & uint64(1)) << 3)
    else:
        digit = digit | (int32((w5 >> uint64(row - 31)) & uint64(1)) << 3)
    if row < 20:
        digit = digit | (int32((w5 >> uint64(row + 12)) & uint64(1)) << 4)
    else:
        digit = digit | (int32((w6 >> uint64(row - 20)) & uint64(1)) << 4)
    if row < 9:
        digit = digit | (int32((w6 >> uint64(row + 23)) & uint64(1)) << 5)
    elif row < 41:
        digit = digit | (int32((w7 >> uint64(row - 9)) & uint64(1)) << 5)
    return digit

fn ecnistHexValue(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'f':
        return 10 + int32(c) - int32('a')
    if c >= 'A' && c <= 'F':
        return 10 + int32(c) - int32('A')
    return -1

fn hexDecode(text: str): Result[Bytes] =
    if len(text) % 2 != 0:
        return Err[Bytes]("ecdsa: hex length must be even")
    let out: Bytes = bytesAlloc(len(text) / 2)
    var i: int32 = 0
    while i < len(text):
        let hi: int32 = ecnistHexValue(text[i])
        let lo: int32 = ecnistHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("ecdsa: invalid hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn bytesFromByte(value: int32): Bytes =
    let out: Bytes = bytesAlloc(1)
    bytesSet(out, 0, value)
    return out

fn hmacSha256(key: Bytes, data: Bytes): Bytes =
    return hmacDigestSha256(key, data)

fn ecnistSha256DigestFn(data: Bytes): Bytes =
    return sha256Digest(data)

fn bigShiftRight1(a: BigInt): BigInt =
    return bigint.bigShiftRight1(a)

fn p256EnsureInit(): Result[bool] =
    if p256InitDone:
        return Ok[bool](true)
    let pConst: BigInt = p256ConstP()
    let nConst: BigInt = p256ConstN()
    let bConst: BigInt = p256ConstB()
    let gxConst: BigInt = p256ConstGx()
    let gyConst: BigInt = p256ConstGy()
    let three: BigInt = bigFromInt(3)
    let aRes: Result[BigInt] = bigSub(pConst, three)
    if IsErr(aRes):
        return Err[bool](Error(aRes))
    p256A = Value(aRes)
    let two: BigInt = bigFromInt(2)
    let pMinus2Res: Result[BigInt] = bigSub(pConst, two)
    if IsErr(pMinus2Res):
        return Err[bool](Error(pMinus2Res))
    let nMinus2Res: Result[BigInt] = bigSub(nConst, two)
    if IsErr(nMinus2Res):
        return Err[bool](Error(nMinus2Res))
    p256P = pConst
    p256N = nConst
    p256B = bConst
    p256G = EcPoint(x: gxConst, y: gyConst, inf: false)
    p256PMinus2 = Value(pMinus2Res)
    p256NMinus2 = Value(nMinus2Res)
    p256NHalf = bigShiftRight1(nConst)
    p256PCtxFixed = pfix.p256FieldMontgomeryContext()
    p256NCtxFixed = pfix.p256ScalarMontgomeryContext()
    var pMinus2Big: BigInt = p256PMinus2
    let pMinus2FixedRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(pMinus2Big)
    if IsErr(pMinus2FixedRes):
        return Err[bool](Error(pMinus2FixedRes))
    var nMinus2Big: BigInt = p256NMinus2
    let nMinus2FixedRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(nMinus2Big)
    if IsErr(nMinus2FixedRes):
        return Err[bool](Error(nMinus2FixedRes))
    var bBig: BigInt = p256B
    let bFixedRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(bBig)
    if IsErr(bFixedRes):
        return Err[bool](Error(bFixedRes))
    let bMontRes: Result[pfix.P256Fixed] = p256FieldFixedToMont(Value(bFixedRes))
    if IsErr(bMontRes):
        return Err[bool](Error(bMontRes))
    p256PMinus2Fixed = Value(pMinus2FixedRes)
    p256NMinus2Fixed = Value(nMinus2FixedRes)
    p256BFixed = Value(bMontRes)
    p256InitDone = true
    return Ok[bool](true)

fn bigModSub(a: BigInt, b: BigInt, m: BigInt): Result[BigInt] =
    if bigCmp(a, b) >= 0:
        return bigSub(a, b)
    let diffRes: Result[BigInt] = bigSub(m, b)
    if IsErr(diffRes):
        return Err[BigInt](Error(diffRes))
    let sumRes: Result[BigInt] = bigAdd(a, Value(diffRes))
    if IsErr(sumRes):
        return Err[BigInt](Error(sumRes))
    var sum: BigInt = Value(sumRes)
    if bigCmp(sum, m) >= 0:
        let subRes: Result[BigInt] = bigSub(sum, m)
        if IsErr(subRes):
            return Err[BigInt](Error(subRes))
        sum = Value(subRes)
    return Ok[BigInt](sum)

fn p256Mod(a: BigInt): Result[BigInt] =
    return bigMod(a, p256P)

fn p256FixedToBigResult(value: pfix.P256Fixed): Result[BigInt] =
    return Ok[BigInt](pfix.p256FixedToBigInt(value))

fn p256ModMul(a: BigInt, b: BigInt): Result[BigInt] =
    var aBig: BigInt = a
    let aFixedRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(aBig)
    if IsErr(aFixedRes):
        return Err[BigInt](Error(aFixedRes))
    var bBig: BigInt = b
    let bFixedRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(bBig)
    if IsErr(bFixedRes):
        return Err[BigInt](Error(bFixedRes))
    var aFixed: pfix.P256Fixed = Value(aFixedRes)
    var bFixed: pfix.P256Fixed = Value(bFixedRes)
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    let mul: pfix.P256Fixed = pfix.p256FixedModMulWithContextTrusted(aFixed, bFixed, ctx)
    return p256FixedToBigResult(mul)

fn p256ModAdd(a: BigInt, b: BigInt): Result[BigInt] =
    return bigModAdd(a, b, p256P)

fn p256ModSub(a: BigInt, b: BigInt): Result[BigInt] =
    return bigModSub(a, b, p256P)

fn p256FixedPrimeModInv(a: BigInt,
                        modulus: BigInt,
                        modulusMinus2: pfix.P256Fixed,
                        ctx: pfix.P256FixedMontgomeryContext): Result[BigInt] =
    let modRes: Result[BigInt] = bigMod(a, modulus)
    if IsErr(modRes):
        return Err[BigInt](Error(modRes))
    var reduced: BigInt = Value(modRes)
    if bigIsZero(reduced):
        return Err[BigInt]("ecdsa: inverse of zero")
    let fixedRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(reduced)
    if IsErr(fixedRes):
        return Err[BigInt](Error(fixedRes))
    var fixed: pfix.P256Fixed = Value(fixedRes)
    var exp: pfix.P256Fixed = modulusMinus2
    let invFixed: pfix.P256Fixed = pfix.p256FixedModExpWithContextTrusted(fixed, exp, ctx)
    return Ok[BigInt](pfix.p256FixedToBigInt(invFixed))

fn p256ModInv(a: BigInt): Result[BigInt] =
    return p256FixedPrimeModInv(a, p256P, p256PMinus2Fixed, p256PCtxFixed)

fn nMod(a: BigInt): Result[BigInt] =
    return bigMod(a, p256N)

fn nModMul(a: BigInt, b: BigInt): Result[BigInt] =
    var aBig: BigInt = a
    let aFixedRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(aBig)
    if IsErr(aFixedRes):
        return Err[BigInt](Error(aFixedRes))
    var bBig: BigInt = b
    let bFixedRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(bBig)
    if IsErr(bFixedRes):
        return Err[BigInt](Error(bFixedRes))
    var aFixed: pfix.P256Fixed = Value(aFixedRes)
    var bFixed: pfix.P256Fixed = Value(bFixedRes)
    var ctx: pfix.P256FixedMontgomeryContext = p256NCtxFixed
    let mul: pfix.P256Fixed = pfix.p256FixedModMulWithContextTrusted(aFixed, bFixed, ctx)
    return p256FixedToBigResult(mul)

fn nModAdd(a: BigInt, b: BigInt): Result[BigInt] =
    return bigModAdd(a, b, p256N)

fn nModInv(a: BigInt): Result[BigInt] =
    return p256FixedPrimeModInv(a, p256N, p256NMinus2Fixed, p256NCtxFixed)

fn p256FieldFixedZero(): pfix.P256Fixed =
    return pfix.p256FixedZero()

fn p256FieldFixedOne(): pfix.P256Fixed =
    return p256PCtxFixed.oneMont

fn p256FieldFixedToMont(a: pfix.P256Fixed): Result[pfix.P256Fixed] =
    var aa: pfix.P256Fixed = a
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    var r2: pfix.P256Fixed = ctx.r2
    return pfix.p256FixedMontgomeryMulCore(aa, r2, ctx)

fn p256FieldFixedFromMont(a: pfix.P256Fixed): Result[pfix.P256Fixed] =
    var aa: pfix.P256Fixed = a
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    var one: pfix.P256Fixed = pfix.p256FixedOne()
    return pfix.p256FixedMontgomeryMulCore(aa, one, ctx)

fn p256FieldFixedAdd(a: pfix.P256Fixed, b: pfix.P256Fixed): Result[pfix.P256Fixed] =
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    var aa: pfix.P256Fixed = a
    var bb: pfix.P256Fixed = b
    var modulus: pfix.P256Fixed = ctx.modulus
    return pfix.p256FixedModAdd(aa, bb, modulus)

fn p256FieldFixedSub(a: pfix.P256Fixed, b: pfix.P256Fixed): Result[pfix.P256Fixed] =
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    var aa: pfix.P256Fixed = a
    var bb: pfix.P256Fixed = b
    var modulus: pfix.P256Fixed = ctx.modulus
    return pfix.p256FixedModSub(aa, bb, modulus)

fn p256FieldFixedMul(a: pfix.P256Fixed, b: pfix.P256Fixed): Result[pfix.P256Fixed] =
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    var aa: pfix.P256Fixed = a
    var bb: pfix.P256Fixed = b
    return pfix.p256FixedMontgomeryMulCore(aa, bb, ctx)

fn p256FieldFixedSquare(a: pfix.P256Fixed): Result[pfix.P256Fixed] =
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    var aa: pfix.P256Fixed = a
    return pfix.p256FixedMontgomerySquareCore(aa, ctx)

fn p256FieldFixedInv(a: pfix.P256Fixed): Result[pfix.P256Fixed] =
    if pfix.p256FixedIsZero(a):
        return Err[pfix.P256Fixed]("ecdsa: inverse of zero")
    let aNormRes: Result[pfix.P256Fixed] = p256FieldFixedFromMont(a)
    if IsErr(aNormRes):
        return Err[pfix.P256Fixed](Error(aNormRes))
    var aa: pfix.P256Fixed = Value(aNormRes)
    var exp: pfix.P256Fixed = p256PMinus2Fixed
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    let invNorm: pfix.P256Fixed = pfix.p256FixedModExpWithContextTrusted(aa, exp, ctx)
    return p256FieldFixedToMont(invNorm)

fn p256FieldFixedDouble(a: pfix.P256Fixed): Result[pfix.P256Fixed] =
    return p256FieldFixedAdd(a, a)

fn p256FieldFixedTriple(a: pfix.P256Fixed): Result[pfix.P256Fixed] =
    let dblRes: Result[pfix.P256Fixed] = p256FieldFixedDouble(a)
    if IsErr(dblRes):
        return Err[pfix.P256Fixed](Error(dblRes))
    return p256FieldFixedAdd(Value(dblRes), a)

fn p256FieldFixedQuad(a: pfix.P256Fixed): Result[pfix.P256Fixed] =
    let dblRes: Result[pfix.P256Fixed] = p256FieldFixedDouble(a)
    if IsErr(dblRes):
        return Err[pfix.P256Fixed](Error(dblRes))
    return p256FieldFixedDouble(Value(dblRes))

fn p256FieldFixedEight(a: pfix.P256Fixed): Result[pfix.P256Fixed] =
    let quadRes: Result[pfix.P256Fixed] = p256FieldFixedQuad(a)
    if IsErr(quadRes):
        return Err[pfix.P256Fixed](Error(quadRes))
    return p256FieldFixedDouble(Value(quadRes))

fn p256FieldFixedIsOne(a: pfix.P256Fixed): bool =
    var aa: pfix.P256Fixed = a
    var one: pfix.P256Fixed = p256FieldFixedOne()
    return pfix.p256FixedCmp(aa, one) == 0

fn p256FieldFixedAddCrash(a: pfix.P256Fixed, b: pfix.P256Fixed): pfix.P256Fixed =
    let res: Result[pfix.P256Fixed] = p256FieldFixedAdd(a, b)
    assert(!IsErr(res), "ecdsa: fixed add failed")
    return Value(res)

fn p256FieldFixedSubCrash(a: pfix.P256Fixed, b: pfix.P256Fixed): pfix.P256Fixed =
    let res: Result[pfix.P256Fixed] = p256FieldFixedSub(a, b)
    assert(!IsErr(res), "ecdsa: fixed sub failed")
    return Value(res)

fn p256FieldFixedMulCrash(a: pfix.P256Fixed, b: pfix.P256Fixed): pfix.P256Fixed =
    let res: Result[pfix.P256Fixed] = p256FieldFixedMul(a, b)
    assert(!IsErr(res), "ecdsa: fixed mul failed")
    return Value(res)

fn p256FieldFixedSquareCrash(a: pfix.P256Fixed): pfix.P256Fixed =
    let res: Result[pfix.P256Fixed] = p256FieldFixedSquare(a)
    assert(!IsErr(res), "ecdsa: fixed square failed")
    return Value(res)

fn p256FieldFixedDoubleCrash(a: pfix.P256Fixed): pfix.P256Fixed =
    return p256FieldFixedAddCrash(a, a)

fn p256FieldFixedTripleCrash(a: pfix.P256Fixed): pfix.P256Fixed =
    return p256FieldFixedAddCrash(p256FieldFixedDoubleCrash(a), a)

fn p256FieldFixedQuadCrash(a: pfix.P256Fixed): pfix.P256Fixed =
    return p256FieldFixedDoubleCrash(p256FieldFixedDoubleCrash(a))

fn p256FieldFixedEightCrash(a: pfix.P256Fixed): pfix.P256Fixed =
    return p256FieldFixedDoubleCrash(p256FieldFixedQuadCrash(a))

fn pointInfinityFixed(): EcPointFixed =
    EcPointFixed(x: p256FieldFixedZero(), y: p256FieldFixedZero(), inf: true)

fn pointJacobianInfinityFixed(): EcPointJacobianFixed =
    EcPointJacobianFixed(x: p256FieldFixedZero(), y: p256FieldFixedZero(), z: p256FieldFixedZero(), inf: true)

fn pointJacobianSetInfinityFixed(p: var EcPointJacobianFixed) =
    p.x = p256FieldFixedZero()
    p.y = p256FieldFixedZero()
    p.z = p256FieldFixedZero()
    p.inf = true

fn pointJacobianSetFromAffineFixed(p: var EcPointJacobianFixed, q: EcPointFixed) =
    if q.inf:
        pointJacobianSetInfinityFixed(p)
        return
    p.x = q.x
    p.y = q.y
    p.z = p256FieldFixedOne()
    p.inf = false

fn pointFixedFromBig(p: EcPoint): Result[EcPointFixed] =
    if p.inf:
        let outInf: EcPointFixed = pointInfinityFixed()
        return Ok[EcPointFixed](outInf)
    var xBig: BigInt = p.x
    let xRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(xBig)
    if IsErr(xRes):
        return Err[EcPointFixed](Error(xRes))
    var yBig: BigInt = p.y
    let yRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(yBig)
    if IsErr(yRes):
        return Err[EcPointFixed](Error(yRes))
    let xMontRes: Result[pfix.P256Fixed] = p256FieldFixedToMont(Value(xRes))
    if IsErr(xMontRes):
        return Err[EcPointFixed](Error(xMontRes))
    let yMontRes: Result[pfix.P256Fixed] = p256FieldFixedToMont(Value(yRes))
    if IsErr(yMontRes):
        return Err[EcPointFixed](Error(yMontRes))
    let out: EcPointFixed = EcPointFixed(x: Value(xMontRes), y: Value(yMontRes), inf: false)
    return Ok[EcPointFixed](out)

fn pointBigFromFixedInto(out: var EcPoint, p: EcPointFixed) =
    if p.inf:
        pointSetInfinityInto(out)
        return
    let xNormRes: Result[pfix.P256Fixed] = p256FieldFixedFromMont(p.x)
    if IsErr(xNormRes):
        panic("ecdsa: pointBigFromFixed x fromMont failed")
    let yNormRes: Result[pfix.P256Fixed] = p256FieldFixedFromMont(p.y)
    if IsErr(yNormRes):
        panic("ecdsa: pointBigFromFixed y fromMont failed")
    var x: pfix.P256Fixed = Value(xNormRes)
    var y: pfix.P256Fixed = Value(yNormRes)
    let xBig: BigInt = pfix.p256FixedToBigInt(x)
    let yBig: BigInt = pfix.p256FixedToBigInt(y)
    out.x = xBig
    out.y = yBig
    out.inf = false

fn pointBigFromFixed(p: EcPointFixed): EcPoint =
    var out: EcPoint
    pointBigFromFixedInto(out, p)
    return out

fn pointJacobianFromAffineFixed(p: EcPointFixed): EcPointJacobianFixed =
    if p.inf:
        return pointJacobianInfinityFixed()
    return EcPointJacobianFixed(x: p.x, y: p.y, z: p256FieldFixedOne(), inf: false)

fn pointJacobianCopyFixed(p: EcPointJacobianFixed): EcPointJacobianFixed =
    var out: EcPointJacobianFixed
    out.x = p.x
    out.y = p.y
    out.z = p.z
    out.inf = p.inf
    return out

fn pointJacobianToAffineFixed(p: EcPointJacobianFixed): Result[EcPointFixed] =
    if p.inf || pfix.p256FixedIsZero(p.z):
        let outInf: EcPointFixed = pointInfinityFixed()
        return Ok[EcPointFixed](outInf)
    if p256FieldFixedIsOne(p.z):
        let outOne: EcPointFixed = EcPointFixed(x: p.x, y: p.y, inf: false)
        return Ok[EcPointFixed](outOne)
    let zInvRes: Result[pfix.P256Fixed] = p256FieldFixedInv(p.z)
    if IsErr(zInvRes):
        return Err[EcPointFixed](Error(zInvRes))
    let zInv: pfix.P256Fixed = Value(zInvRes)
    let zInv2: pfix.P256Fixed = p256FieldFixedSquareCrash(zInv)
    let zInv3: pfix.P256Fixed = p256FieldFixedMulCrash(zInv2, zInv)
    let x: pfix.P256Fixed = p256FieldFixedMulCrash(p.x, zInv2)
    let y: pfix.P256Fixed = p256FieldFixedMulCrash(p.y, zInv3)
    let out: EcPointFixed = EcPointFixed(x: x, y: y, inf: false)
    return Ok[EcPointFixed](out)

fn pointJacobianXToScalarBigInt(p: EcPointJacobianFixed): Result[BigInt] =
    var reduced: pfix.P256Fixed = pointJacobianXToScalarFixedCrash(p)
    return Ok[BigInt](pfix.p256FixedToBigInt(reduced))

fn pointJacobianXToScalarFixedCrash(p: EcPointJacobianFixed): pfix.P256Fixed =
    assert(!(p.inf || pfix.p256FixedIsZero(p.z)), "ecdsa: jacobian point at infinity")
    var xNorm: pfix.P256Fixed
    if p256FieldFixedIsOne(p.z):
        let xNormRes: Result[pfix.P256Fixed] = p256FieldFixedFromMont(p.x)
        assert(!IsErr(xNormRes), "ecdsa: x fromMont failed")
        xNorm = Value(xNormRes)
    else:
        let zInvRes: Result[pfix.P256Fixed] = p256FieldFixedInv(p.z)
        assert(!IsErr(zInvRes), "ecdsa: z inverse failed")
        let zInv2: pfix.P256Fixed = p256FieldFixedSquareCrash(Value(zInvRes))
        let xMont: pfix.P256Fixed = p256FieldFixedMulCrash(p.x, zInv2)
        let xNormRes: Result[pfix.P256Fixed] = p256FieldFixedFromMont(xMont)
        assert(!IsErr(xNormRes), "ecdsa: x normalize failed")
        xNorm = Value(xNormRes)
    return p256FieldFixedXReduceToScalarFixed(xNorm)

fn p256FieldFixedXReduceToScalarBigInt(xNorm: pfix.P256Fixed): BigInt =
    var reduced: pfix.P256Fixed = p256FieldFixedXReduceToScalarFixed(xNorm)
    return pfix.p256FixedToBigInt(reduced)

fn p256FieldFixedXReduceToScalarFixed(xNorm: pfix.P256Fixed): pfix.P256Fixed =
    var reduced: pfix.P256Fixed = xNorm
    var nModulus: pfix.P256Fixed = p256NCtxFixed.modulus
    if pfix.p256FixedCmp(reduced, nModulus) >= 0:
        reduced = pfix.p256FixedModSubTrusted(reduced, nModulus, nModulus)
    return reduced

fn pointJacobianDoubleFixed(p: EcPointJacobianFixed): EcPointJacobianFixed =
    if p.inf || pfix.p256FixedIsZero(p.y):
        return pointJacobianInfinityFixed()
    let delta: pfix.P256Fixed = p256FieldFixedSquareCrash(p.z)
    let gamma: pfix.P256Fixed = p256FieldFixedSquareCrash(p.y)
    let beta: pfix.P256Fixed = p256FieldFixedMulCrash(p.x, gamma)
    let xMinusDelta: pfix.P256Fixed = p256FieldFixedSubCrash(p.x, delta)
    let xPlusDelta: pfix.P256Fixed = p256FieldFixedAddCrash(p.x, delta)
    let alphaBase: pfix.P256Fixed = p256FieldFixedMulCrash(xMinusDelta, xPlusDelta)
    let alpha: pfix.P256Fixed = p256FieldFixedTripleCrash(alphaBase)
    let alpha2: pfix.P256Fixed = p256FieldFixedSquareCrash(alpha)
    let beta4: pfix.P256Fixed = p256FieldFixedQuadCrash(beta)
    let beta8: pfix.P256Fixed = p256FieldFixedDoubleCrash(beta4)
    let x3: pfix.P256Fixed = p256FieldFixedSubCrash(alpha2, beta8)
    let yPlusZ: pfix.P256Fixed = p256FieldFixedAddCrash(p.y, p.z)
    let yPlusZ2: pfix.P256Fixed = p256FieldFixedSquareCrash(yPlusZ)
    let z3a: pfix.P256Fixed = p256FieldFixedSubCrash(yPlusZ2, gamma)
    let z3: pfix.P256Fixed = p256FieldFixedSubCrash(z3a, delta)
    let gamma2: pfix.P256Fixed = p256FieldFixedSquareCrash(gamma)
    let gamma8: pfix.P256Fixed = p256FieldFixedEightCrash(gamma2)
    let beta4MinusX3: pfix.P256Fixed = p256FieldFixedSubCrash(beta4, x3)
    let y3a: pfix.P256Fixed = p256FieldFixedMulCrash(alpha, beta4MinusX3)
    let y3: pfix.P256Fixed = p256FieldFixedSubCrash(y3a, gamma8)
    return EcPointJacobianFixed(x: x3, y: y3, z: z3, inf: false)

fn pointJacobianDoubleFixedInPlace(p: var EcPointJacobianFixed) =
    if p.inf || pfix.p256FixedIsZero(p.y):
        pointJacobianSetInfinityFixed(p)
        return
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    var modulus: pfix.P256Fixed = ctx.modulus
    var scratch: pfix.P256FixedMontgomeryScratch
    var delta: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(delta, p.z, ctx, scratch)
    var gamma: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(gamma, p.y, ctx, scratch)
    var beta: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(beta, p.x, gamma, ctx, scratch)
    var xMinusDelta: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(xMinusDelta, p.x, delta, modulus)
    var xPlusDelta: pfix.P256Fixed
    pfix.p256FixedModAddTrustedInto(xPlusDelta, p.x, delta, modulus)
    var alphaBase: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(alphaBase, xMinusDelta, xPlusDelta, ctx, scratch)
    let alpha: pfix.P256Fixed = p256FieldFixedTripleCrash(alphaBase)
    var alpha2: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(alpha2, alpha, ctx, scratch)
    let beta4: pfix.P256Fixed = p256FieldFixedQuadCrash(beta)
    let beta8: pfix.P256Fixed = p256FieldFixedDoubleCrash(beta4)
    var x3: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(x3, alpha2, beta8, modulus)
    var yPlusZ: pfix.P256Fixed
    pfix.p256FixedModAddTrustedInto(yPlusZ, p.y, p.z, modulus)
    var yPlusZ2: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(yPlusZ2, yPlusZ, ctx, scratch)
    var z3a: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(z3a, yPlusZ2, gamma, modulus)
    var z3: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(z3, z3a, delta, modulus)
    var gamma2: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(gamma2, gamma, ctx, scratch)
    let gamma8: pfix.P256Fixed = p256FieldFixedEightCrash(gamma2)
    var beta4MinusX3: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(beta4MinusX3, beta4, x3, modulus)
    var y3a: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(y3a, alpha, beta4MinusX3, ctx, scratch)
    var y3: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(y3, y3a, gamma8, modulus)
    p.x = x3
    p.y = y3
    p.z = z3
    p.inf = false

fn pointJacobianAddFixed(p1: EcPointJacobianFixed, p2: EcPointJacobianFixed): EcPointJacobianFixed =
    if p1.inf || pfix.p256FixedIsZero(p1.z):
        return p2
    if p2.inf || pfix.p256FixedIsZero(p2.z):
        return p1
    let z1z1: pfix.P256Fixed = p256FieldFixedSquareCrash(p1.z)
    let z2z2: pfix.P256Fixed = p256FieldFixedSquareCrash(p2.z)
    let u1: pfix.P256Fixed = p256FieldFixedMulCrash(p1.x, z2z2)
    let u2: pfix.P256Fixed = p256FieldFixedMulCrash(p2.x, z1z1)
    let z1Cubed: pfix.P256Fixed = p256FieldFixedMulCrash(p1.z, z1z1)
    let z2Cubed: pfix.P256Fixed = p256FieldFixedMulCrash(p2.z, z2z2)
    let s1: pfix.P256Fixed = p256FieldFixedMulCrash(p1.y, z2Cubed)
    let s2: pfix.P256Fixed = p256FieldFixedMulCrash(p2.y, z1Cubed)
    if pfix.p256FixedCmp(u1, u2) == 0:
        if pfix.p256FixedCmp(s1, s2) != 0:
            return pointJacobianInfinityFixed()
        return pointJacobianDoubleFixed(p1)
    let h: pfix.P256Fixed = p256FieldFixedSubCrash(u2, u1)
    let twoH: pfix.P256Fixed = p256FieldFixedDoubleCrash(h)
    let i: pfix.P256Fixed = p256FieldFixedSquareCrash(twoH)
    let j: pfix.P256Fixed = p256FieldFixedMulCrash(h, i)
    let sDiff: pfix.P256Fixed = p256FieldFixedSubCrash(s2, s1)
    let r: pfix.P256Fixed = p256FieldFixedDoubleCrash(sDiff)
    let v: pfix.P256Fixed = p256FieldFixedMulCrash(u1, i)
    let r2: pfix.P256Fixed = p256FieldFixedSquareCrash(r)
    let twoV: pfix.P256Fixed = p256FieldFixedDoubleCrash(v)
    let x3a: pfix.P256Fixed = p256FieldFixedSubCrash(r2, j)
    let x3: pfix.P256Fixed = p256FieldFixedSubCrash(x3a, twoV)
    let vMinusX3: pfix.P256Fixed = p256FieldFixedSubCrash(v, x3)
    let s1j: pfix.P256Fixed = p256FieldFixedMulCrash(s1, j)
    let twoS1J: pfix.P256Fixed = p256FieldFixedDoubleCrash(s1j)
    let y3a: pfix.P256Fixed = p256FieldFixedMulCrash(r, vMinusX3)
    let y3: pfix.P256Fixed = p256FieldFixedSubCrash(y3a, twoS1J)
    let z1PlusZ2: pfix.P256Fixed = p256FieldFixedAddCrash(p1.z, p2.z)
    let z1PlusZ2Sq: pfix.P256Fixed = p256FieldFixedSquareCrash(z1PlusZ2)
    let z3a: pfix.P256Fixed = p256FieldFixedSubCrash(z1PlusZ2Sq, z1z1)
    let z3b: pfix.P256Fixed = p256FieldFixedSubCrash(z3a, z2z2)
    let z3: pfix.P256Fixed = p256FieldFixedMulCrash(z3b, h)
    return EcPointJacobianFixed(x: x3, y: y3, z: z3, inf: false)

fn pointJacobianAddAffineFixed(p1: EcPointJacobianFixed, p2: EcPointFixed): EcPointJacobianFixed =
    if p2.inf:
        return p1
    if p1.inf || pfix.p256FixedIsZero(p1.z):
        return pointJacobianFromAffineFixed(p2)
    let z1z1: pfix.P256Fixed = p256FieldFixedSquareCrash(p1.z)
    let u2: pfix.P256Fixed = p256FieldFixedMulCrash(p2.x, z1z1)
    let z1Cubed: pfix.P256Fixed = p256FieldFixedMulCrash(p1.z, z1z1)
    let s2: pfix.P256Fixed = p256FieldFixedMulCrash(p2.y, z1Cubed)
    if pfix.p256FixedCmp(p1.x, u2) == 0:
        if pfix.p256FixedCmp(p1.y, s2) != 0:
            return pointJacobianInfinityFixed()
        return pointJacobianDoubleFixed(p1)
    let h: pfix.P256Fixed = p256FieldFixedSubCrash(u2, p1.x)
    let hh: pfix.P256Fixed = p256FieldFixedSquareCrash(h)
    let i: pfix.P256Fixed = p256FieldFixedQuadCrash(hh)
    let j: pfix.P256Fixed = p256FieldFixedMulCrash(h, i)
    let yDiff: pfix.P256Fixed = p256FieldFixedSubCrash(s2, p1.y)
    let r: pfix.P256Fixed = p256FieldFixedDoubleCrash(yDiff)
    let v: pfix.P256Fixed = p256FieldFixedMulCrash(p1.x, i)
    let r2: pfix.P256Fixed = p256FieldFixedSquareCrash(r)
    let twoV: pfix.P256Fixed = p256FieldFixedDoubleCrash(v)
    let x3a: pfix.P256Fixed = p256FieldFixedSubCrash(r2, j)
    let x3: pfix.P256Fixed = p256FieldFixedSubCrash(x3a, twoV)
    let vMinusX3: pfix.P256Fixed = p256FieldFixedSubCrash(v, x3)
    let y1j: pfix.P256Fixed = p256FieldFixedMulCrash(p1.y, j)
    let twoY1J: pfix.P256Fixed = p256FieldFixedDoubleCrash(y1j)
    let y3a: pfix.P256Fixed = p256FieldFixedMulCrash(r, vMinusX3)
    let y3: pfix.P256Fixed = p256FieldFixedSubCrash(y3a, twoY1J)
    let z1PlusH: pfix.P256Fixed = p256FieldFixedAddCrash(p1.z, h)
    let z1PlusHSq: pfix.P256Fixed = p256FieldFixedSquareCrash(z1PlusH)
    let z3a: pfix.P256Fixed = p256FieldFixedSubCrash(z1PlusHSq, z1z1)
    let z3: pfix.P256Fixed = p256FieldFixedSubCrash(z3a, hh)
    return EcPointJacobianFixed(x: x3, y: y3, z: z3, inf: false)

fn pointJacobianAddAffineFixedInPlace(p1: var EcPointJacobianFixed, p2: EcPointFixed) =
    if p2.inf:
        return
    if p1.inf || pfix.p256FixedIsZero(p1.z):
        pointJacobianSetFromAffineFixed(p1, p2)
        return
    var ctx: pfix.P256FixedMontgomeryContext = p256PCtxFixed
    var modulus: pfix.P256Fixed = ctx.modulus
    var scratch: pfix.P256FixedMontgomeryScratch
    var z1z1: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(z1z1, p1.z, ctx, scratch)
    var u2: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(u2, p2.x, z1z1, ctx, scratch)
    var z1Cubed: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(z1Cubed, p1.z, z1z1, ctx, scratch)
    var s2: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(s2, p2.y, z1Cubed, ctx, scratch)
    if pfix.p256FixedCmp(p1.x, u2) == 0:
        if pfix.p256FixedCmp(p1.y, s2) != 0:
            pointJacobianSetInfinityFixed(p1)
            return
        pointJacobianDoubleFixedInPlace(p1)
        return
    var h: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(h, u2, p1.x, modulus)
    var hh: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(hh, h, ctx, scratch)
    let i: pfix.P256Fixed = p256FieldFixedQuadCrash(hh)
    var j: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(j, h, i, ctx, scratch)
    let yDiff: pfix.P256Fixed = p256FieldFixedSubCrash(s2, p1.y)
    let r: pfix.P256Fixed = p256FieldFixedDoubleCrash(yDiff)
    var v: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(v, p1.x, i, ctx, scratch)
    var r2: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(r2, r, ctx, scratch)
    let twoV: pfix.P256Fixed = p256FieldFixedDoubleCrash(v)
    var x3a: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(x3a, r2, j, modulus)
    var x3: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(x3, x3a, twoV, modulus)
    var vMinusX3: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(vMinusX3, v, x3, modulus)
    var y1j: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(y1j, p1.y, j, ctx, scratch)
    let twoY1J: pfix.P256Fixed = p256FieldFixedDoubleCrash(y1j)
    var y3a: pfix.P256Fixed
    pfix.p256FixedMontgomeryMulCoreTrustedScratchInto(y3a, r, vMinusX3, ctx, scratch)
    var y3: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(y3, y3a, twoY1J, modulus)
    var z1PlusH: pfix.P256Fixed
    pfix.p256FixedModAddTrustedInto(z1PlusH, p1.z, h, modulus)
    var z1PlusHSq: pfix.P256Fixed
    pfix.p256FixedMontgomerySquareCoreTrustedScratchInto(z1PlusHSq, z1PlusH, ctx, scratch)
    var z3a: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(z3a, z1PlusHSq, z1z1, modulus)
    var z3: pfix.P256Fixed
    pfix.p256FixedModSubTrustedInto(z3, z3a, hh, modulus)
    p1.x = x3
    p1.y = y3
    p1.z = z3
    p1.inf = false

fn p256FixedWindowNibble(scalar: pfix.P256Fixed, baseBit: int32): int32 =
    var out: int32 = 0
    var shift: int32 = 0
    while shift < 4:
        out = out | (pfix.p256FixedGetBit(scalar, baseBit + shift) << shift)
        shift = shift + 1
    return out

fn pointJacobianBatchToAffineWindow16Into(table: EcPointJacobianFixed[16],
                                         outTable: var EcPointFixed[16]): Result[bool] =
    outTable[0] = pointInfinityFixed()
    var i: int32 = 1
    while i < 16:
        if table[i].inf:
            outTable[i] = pointInfinityFixed()
            i = i + 1
            continue
        let ziInvRes: Result[pfix.P256Fixed] = p256FieldFixedInv(table[i].z)
        if IsErr(ziInvRes):
            return Err[bool](Error(ziInvRes))
        let ziInv: pfix.P256Fixed = Value(ziInvRes)
        let ziInv2Res: Result[pfix.P256Fixed] = p256FieldFixedSquare(ziInv)
        if IsErr(ziInv2Res):
            return Err[bool](Error(ziInv2Res))
        let ziInv2: pfix.P256Fixed = Value(ziInv2Res)
        let ziInv3Res: Result[pfix.P256Fixed] = p256FieldFixedMul(ziInv2, ziInv)
        if IsErr(ziInv3Res):
            return Err[bool](Error(ziInv3Res))
        let ziInv3: pfix.P256Fixed = Value(ziInv3Res)
        let xRes: Result[pfix.P256Fixed] = p256FieldFixedMul(table[i].x, ziInv2)
        if IsErr(xRes):
            return Err[bool](Error(xRes))
        let yRes: Result[pfix.P256Fixed] = p256FieldFixedMul(table[i].y, ziInv3)
        if IsErr(yRes):
            return Err[bool](Error(yRes))
        outTable[i] = EcPointFixed(x: Value(xRes), y: Value(yRes), inf: false)
        i = i + 1
    while i < 16:
        outTable[i] = pointInfinityFixed()
        i = i + 1
    return Ok[bool](true)

fn pointMulFixedWindowed(scalar: pfix.P256Fixed, p: EcPointFixed): Result[EcPointFixed] =
    var windowBase: int32 = (8 * 32) - 1
    var result: EcPointJacobianFixed
    pointJacobianSetInfinityFixed(result)
    while windowBase >= 0:
        pointJacobianDoubleFixedInPlace(result)
        if pfix.p256FixedGetBit(scalar, windowBase) != 0:
            pointJacobianAddAffineFixedInPlace(result, p)
        windowBase = windowBase - 1
    return pointJacobianToAffineFixed(result)

fn pointMulGeneratorAndFixedShamir(u1: pfix.P256Fixed, u2: pfix.P256Fixed, p: EcPointFixed): Result[EcPointJacobianFixed] =
    var result: EcPointJacobianFixed
    pointMulGeneratorJacobianComb6FixedInto(result, u1)
    let fixedRes: Result[EcPointFixed] = pointMulFixedWindowed(u2, p)
    if IsErr(fixedRes):
        return Err[EcPointJacobianFixed](Error(fixedRes))
    pointJacobianAddAffineFixedInPlace(result, Value(fixedRes))
    return Ok[EcPointJacobianFixed](result)

fn pointAffineNegateFixed(p: EcPointFixed): Result[EcPointFixed] =
    if p.inf:
        let outInf: EcPointFixed = p
        return Ok[EcPointFixed](outInf)
    let yNegRes: Result[pfix.P256Fixed] = p256FieldFixedSub(p256FieldFixedZero(), p.y)
    if IsErr(yNegRes):
        return Err[EcPointFixed](Error(yNegRes))
    let out: EcPointFixed = EcPointFixed(x: p.x, y: Value(yNegRes), inf: false)
    return Ok[EcPointFixed](out)

fn pointMulGeneratorWnaf(k: BigInt): Result[EcPointFixed] =
    var scalarBig: BigInt = k
    let scalarRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(scalarBig)
    if IsErr(scalarRes):
        return Err[EcPointFixed](Error(scalarRes))
    return pointMulGeneratorWnafFixed(Value(scalarRes))

fn pointMulGeneratorJacobianWnafFixed(k: pfix.P256Fixed): EcPointJacobianFixed =
    var digits: int32[260]
    var digitCount: int32 = 0
    var work: pfix.P256Fixed = k
    while ! p256ScalarFixedIsZero(work):
        var digit: int32 = 0
        if p256ScalarFixedIsOdd(work):
            digit = p256ScalarFixedLow5(work)
            if digit > 16:
                digit = digit - 32
            if digit > 0:
                work = p256ScalarFixedSubSmall(work, digit)
            else:
                work = p256ScalarFixedAddSmall(work, -digit)
        digits[digitCount] = digit
        digitCount = digitCount + 1
        work = p256ScalarFixedShiftRight1(work)
    var result: EcPointJacobianFixed = pointJacobianInfinityFixed()
    let __for_start_i = digitCount - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        pointJacobianDoubleFixedInPlace(result)
        let digit: int32 = digits[i]
        if digit > 0:
            pointJacobianAddAffineFixedInPlace(result, p256GeneratorWindow4Point(digit))
        elif digit < 0:
            pointJacobianAddAffineFixedInPlace(result, p256GeneratorWindow4NegPoint(-digit))
    return result

fn pointMulGeneratorJacobianComb6FixedInto(result: var EcPointJacobianFixed, k: pfix.P256Fixed) =
    pointJacobianSetInfinityFixed(result)
    var started: bool = false
    let __for_start_row = p256GeneratorComb6Depth - 1
    for __for_rev_row in 0..(__for_start_row - (0)):
        let row = __for_start_row - __for_rev_row
        let digit: int32 = p256ScalarFixedComb6Digit(k, row)
        if ! started:
            if digit == 0:
                continue
            pointJacobianSetFromAffineFixed(result, p256GeneratorComb6Point(digit))
            started = true
            continue
        pointJacobianDoubleFixedInPlace(result)
        if digit != 0:
            pointJacobianAddAffineFixedInPlace(result, p256GeneratorComb6Point(digit))

fn pointMulGeneratorWnafFixed(k: pfix.P256Fixed): Result[EcPointFixed] =
    let result: EcPointJacobianFixed = pointMulGeneratorJacobianWnafFixed(k)
    let affineRes: Result[EcPointFixed] = pointJacobianToAffineFixed(result)
    if IsErr(affineRes):
        return Err[EcPointFixed](Error(affineRes))
    let affine: EcPointFixed = Value(affineRes)
    return Ok[EcPointFixed](affine)

fn pointMulGeneratorR(k: BigInt): Result[BigInt] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[BigInt](Error(initRes))
    var scalarBig: BigInt = k
    let scalarRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(scalarBig)
    if IsErr(scalarRes):
        return Err[BigInt](Error(scalarRes))
    let rFixed: pfix.P256Fixed = pointMulGeneratorRFixedCrash(Value(scalarRes))
    return Ok[BigInt](pfix.p256FixedToBigInt(rFixed))

fn pointMulGeneratorRFixedCrash(k: pfix.P256Fixed): pfix.P256Fixed =
    var result: EcPointJacobianFixed
    pointMulGeneratorJacobianComb6FixedInto(result, k)
    return pointJacobianXToScalarFixedCrash(result)

fn isInfinity(p: EcPoint): bool =
    return p.inf

fn pointInfinity(): EcPoint =
    EcPoint(x: bigZero(), y: bigZero(), inf: true)

fn pointJacobianInfinity(): EcPointJacobian =
    EcPointJacobian(x: bigZero(), y: bigZero(), z: bigZero(), inf: true)

fn pointJacobianSetInfinityInto(out: var EcPointJacobian) =
    out.x.count = 0
    for i in 0..<maxBigIntLimbs:
        out.x.limbs[i] = 0
    out.y.count = 0
    for i in 0..<maxBigIntLimbs:
        out.y.limbs[i] = 0
    out.z.count = 0
    for i in 0..<maxBigIntLimbs:
        out.z.limbs[i] = 0
    out.inf = true

fn pointJacobianSetInto(out: var EcPointJacobian, src: var EcPointJacobian) =
    out.x.count = src.x.count
    for i in 0..<maxBigIntLimbs:
        out.x.limbs[i] = 0
    for i in 0..<src.x.count:
        out.x.limbs[i] = src.x.limbs[i]
    out.y.count = src.y.count
    for i in 0..<maxBigIntLimbs:
        out.y.limbs[i] = 0
    for i in 0..<src.y.count:
        out.y.limbs[i] = src.y.limbs[i]
    out.z.count = src.z.count
    for i in 0..<maxBigIntLimbs:
        out.z.limbs[i] = 0
    for i in 0..<src.z.count:
        out.z.limbs[i] = src.z.limbs[i]
    out.inf = src.inf

fn pointJacobianSetCoordsInto(out: var EcPointJacobian, x: BigInt, y: BigInt, z: BigInt) =
    out.x.count = x.count
    for i in 0..<maxBigIntLimbs:
        out.x.limbs[i] = 0
    for i in 0..<x.count:
        out.x.limbs[i] = x.limbs[i]
    out.y.count = y.count
    for i in 0..<maxBigIntLimbs:
        out.y.limbs[i] = 0
    for i in 0..<y.count:
        out.y.limbs[i] = y.limbs[i]
    out.z.count = z.count
    for i in 0..<maxBigIntLimbs:
        out.z.limbs[i] = 0
    for i in 0..<z.count:
        out.z.limbs[i] = z.limbs[i]
    out.inf = false

fn pointJacobianFromAffine(p: EcPoint): EcPointJacobian =
    if p.inf:
        return pointJacobianInfinity()
    return EcPointJacobian(x: p.x, y: p.y, z: bigFromInt(1), inf: false)

fn pointJacobianToAffineInto(out: var EcPoint, p: EcPointJacobian): Result[bool] =
    if p.inf || bigIsZero(p.z):
        pointSetInfinityInto(out)
        return Ok[bool](true)
    let zInvRes: Result[BigInt] = p256ModInv(p.z)
    if IsErr(zInvRes):
        return Err[bool](Error(zInvRes))
    let zInv: BigInt = Value(zInvRes)
    let zInv2Res: Result[BigInt] = p256ModMul(zInv, zInv)
    if IsErr(zInv2Res):
        return Err[bool](Error(zInv2Res))
    let zInv3Res: Result[BigInt] = p256ModMul(Value(zInv2Res), zInv)
    if IsErr(zInv3Res):
        return Err[bool](Error(zInv3Res))
    let xRes: Result[BigInt] = p256ModMul(p.x, Value(zInv2Res))
    if IsErr(xRes):
        return Err[bool](Error(xRes))
    let yRes: Result[BigInt] = p256ModMul(p.y, Value(zInv3Res))
    if IsErr(yRes):
        return Err[bool](Error(yRes))
    let x: BigInt = Value(xRes)
    let y: BigInt = Value(yRes)
    pointSetCoordsInto(out, x, y)
    return Ok[bool](true)

fn pointJacobianToAffine(p: EcPointJacobian): Result[EcPoint] =
    if p.inf || bigIsZero(p.z):
        return Ok[EcPoint](pointInfinity())
    let zInvRes: Result[BigInt] = p256ModInv(p.z)
    if IsErr(zInvRes):
        return Err[EcPoint](Error(zInvRes))
    let zInv: BigInt = Value(zInvRes)
    let zInv2Res: Result[BigInt] = p256ModMul(zInv, zInv)
    if IsErr(zInv2Res):
        return Err[EcPoint](Error(zInv2Res))
    let zInv3Res: Result[BigInt] = p256ModMul(Value(zInv2Res), zInv)
    if IsErr(zInv3Res):
        return Err[EcPoint](Error(zInv3Res))
    let xRes: Result[BigInt] = p256ModMul(p.x, Value(zInv2Res))
    if IsErr(xRes):
        return Err[EcPoint](Error(xRes))
    let yRes: Result[BigInt] = p256ModMul(p.y, Value(zInv3Res))
    if IsErr(yRes):
        return Err[EcPoint](Error(yRes))
    return Ok[EcPoint](EcPoint(x: Value(xRes), y: Value(yRes), inf: false))

fn pointJacobianDoubleInto(out: var EcPointJacobian, p: var EcPointJacobian): Result[bool] =
    if p.inf || bigIsZero(p.y):
        pointJacobianSetInfinityInto(out)
        return Ok[bool](true)
    let deltaRes: Result[BigInt] = p256ModMul(p.z, p.z)
    if IsErr(deltaRes):
        return Err[bool](Error(deltaRes))
    let gammaRes: Result[BigInt] = p256ModMul(p.y, p.y)
    if IsErr(gammaRes):
        return Err[bool](Error(gammaRes))
    let betaRes: Result[BigInt] = p256ModMul(p.x, Value(gammaRes))
    if IsErr(betaRes):
        return Err[bool](Error(betaRes))
    let xMinusDeltaRes: Result[BigInt] = p256ModSub(p.x, Value(deltaRes))
    if IsErr(xMinusDeltaRes):
        return Err[bool](Error(xMinusDeltaRes))
    let xPlusDeltaRes: Result[BigInt] = p256ModAdd(p.x, Value(deltaRes))
    if IsErr(xPlusDeltaRes):
        return Err[bool](Error(xPlusDeltaRes))
    let alphaBaseRes: Result[BigInt] = p256ModMul(Value(xMinusDeltaRes), Value(xPlusDeltaRes))
    if IsErr(alphaBaseRes):
        return Err[bool](Error(alphaBaseRes))
    let alphaRes: Result[BigInt] = p256ModTriple(Value(alphaBaseRes))
    if IsErr(alphaRes):
        return Err[bool](Error(alphaRes))
    let alpha2Res: Result[BigInt] = p256ModMul(Value(alphaRes), Value(alphaRes))
    if IsErr(alpha2Res):
        return Err[bool](Error(alpha2Res))
    let beta4Res: Result[BigInt] = p256ModQuad(Value(betaRes))
    if IsErr(beta4Res):
        return Err[bool](Error(beta4Res))
    let beta8Res: Result[BigInt] = p256ModDouble(Value(beta4Res))
    if IsErr(beta8Res):
        return Err[bool](Error(beta8Res))
    let x3Res: Result[BigInt] = p256ModSub(Value(alpha2Res), Value(beta8Res))
    if IsErr(x3Res):
        return Err[bool](Error(x3Res))
    let yPlusZRes: Result[BigInt] = p256ModAdd(p.y, p.z)
    if IsErr(yPlusZRes):
        return Err[bool](Error(yPlusZRes))
    let yPlusZ2Res: Result[BigInt] = p256ModMul(Value(yPlusZRes), Value(yPlusZRes))
    if IsErr(yPlusZ2Res):
        return Err[bool](Error(yPlusZ2Res))
    let z3aRes: Result[BigInt] = p256ModSub(Value(yPlusZ2Res), Value(gammaRes))
    if IsErr(z3aRes):
        return Err[bool](Error(z3aRes))
    let z3Res: Result[BigInt] = p256ModSub(Value(z3aRes), Value(deltaRes))
    if IsErr(z3Res):
        return Err[bool](Error(z3Res))
    let gamma2Res: Result[BigInt] = p256ModMul(Value(gammaRes), Value(gammaRes))
    if IsErr(gamma2Res):
        return Err[bool](Error(gamma2Res))
    let gamma8Res: Result[BigInt] = p256ModEight(Value(gamma2Res))
    if IsErr(gamma8Res):
        return Err[bool](Error(gamma8Res))
    let beta4MinusX3Res: Result[BigInt] = p256ModSub(Value(beta4Res), Value(x3Res))
    if IsErr(beta4MinusX3Res):
        return Err[bool](Error(beta4MinusX3Res))
    let y3aRes: Result[BigInt] = p256ModMul(Value(alphaRes), Value(beta4MinusX3Res))
    if IsErr(y3aRes):
        return Err[bool](Error(y3aRes))
    let y3Res: Result[BigInt] = p256ModSub(Value(y3aRes), Value(gamma8Res))
    if IsErr(y3Res):
        return Err[bool](Error(y3Res))
    let x3: BigInt = Value(x3Res)
    let y3: BigInt = Value(y3Res)
    let z3: BigInt = Value(z3Res)
    pointJacobianSetCoordsInto(out, x3, y3, z3)
    return Ok[bool](true)

fn pointJacobianAddInto(out: var EcPointJacobian, p1: var EcPointJacobian, p2: var EcPointJacobian): Result[bool] =
    if p1.inf || bigIsZero(p1.z):
        pointJacobianSetInto(out, p2)
        return Ok[bool](true)
    if p2.inf || bigIsZero(p2.z):
        pointJacobianSetInto(out, p1)
        return Ok[bool](true)
    let z1z1Res: Result[BigInt] = p256ModMul(p1.z, p1.z)
    if IsErr(z1z1Res):
        return Err[bool](Error(z1z1Res))
    let z2z2Res: Result[BigInt] = p256ModMul(p2.z, p2.z)
    if IsErr(z2z2Res):
        return Err[bool](Error(z2z2Res))
    let u1Res: Result[BigInt] = p256ModMul(p1.x, Value(z2z2Res))
    if IsErr(u1Res):
        return Err[bool](Error(u1Res))
    let u2Res: Result[BigInt] = p256ModMul(p2.x, Value(z1z1Res))
    if IsErr(u2Res):
        return Err[bool](Error(u2Res))
    let z1CubedRes: Result[BigInt] = p256ModMul(p1.z, Value(z1z1Res))
    if IsErr(z1CubedRes):
        return Err[bool](Error(z1CubedRes))
    let z2CubedRes: Result[BigInt] = p256ModMul(p2.z, Value(z2z2Res))
    if IsErr(z2CubedRes):
        return Err[bool](Error(z2CubedRes))
    let s1Res: Result[BigInt] = p256ModMul(p1.y, Value(z2CubedRes))
    if IsErr(s1Res):
        return Err[bool](Error(s1Res))
    let s2Res: Result[BigInt] = p256ModMul(p2.y, Value(z1CubedRes))
    if IsErr(s2Res):
        return Err[bool](Error(s2Res))
    if bigCmp(Value(u1Res), Value(u2Res)) == 0:
        if bigCmp(Value(s1Res), Value(s2Res)) != 0:
            pointJacobianSetInfinityInto(out)
            return Ok[bool](true)
        return pointJacobianDoubleInto(out, p1)
    let hRes: Result[BigInt] = p256ModSub(Value(u2Res), Value(u1Res))
    if IsErr(hRes):
        return Err[bool](Error(hRes))
    let twoHRes: Result[BigInt] = p256ModDouble(Value(hRes))
    if IsErr(twoHRes):
        return Err[bool](Error(twoHRes))
    let iRes: Result[BigInt] = p256ModMul(Value(twoHRes), Value(twoHRes))
    if IsErr(iRes):
        return Err[bool](Error(iRes))
    let jRes: Result[BigInt] = p256ModMul(Value(hRes), Value(iRes))
    if IsErr(jRes):
        return Err[bool](Error(jRes))
    let sDiffRes: Result[BigInt] = p256ModSub(Value(s2Res), Value(s1Res))
    if IsErr(sDiffRes):
        return Err[bool](Error(sDiffRes))
    let rRes: Result[BigInt] = p256ModDouble(Value(sDiffRes))
    if IsErr(rRes):
        return Err[bool](Error(rRes))
    let vRes: Result[BigInt] = p256ModMul(Value(u1Res), Value(iRes))
    if IsErr(vRes):
        return Err[bool](Error(vRes))
    let r2Res: Result[BigInt] = p256ModMul(Value(rRes), Value(rRes))
    if IsErr(r2Res):
        return Err[bool](Error(r2Res))
    let twoVRes: Result[BigInt] = p256ModDouble(Value(vRes))
    if IsErr(twoVRes):
        return Err[bool](Error(twoVRes))
    let x3aRes: Result[BigInt] = p256ModSub(Value(r2Res), Value(jRes))
    if IsErr(x3aRes):
        return Err[bool](Error(x3aRes))
    let x3Res: Result[BigInt] = p256ModSub(Value(x3aRes), Value(twoVRes))
    if IsErr(x3Res):
        return Err[bool](Error(x3Res))
    let vMinusX3Res: Result[BigInt] = p256ModSub(Value(vRes), Value(x3Res))
    if IsErr(vMinusX3Res):
        return Err[bool](Error(vMinusX3Res))
    let s1jRes: Result[BigInt] = p256ModMul(Value(s1Res), Value(jRes))
    if IsErr(s1jRes):
        return Err[bool](Error(s1jRes))
    let twoS1JRes: Result[BigInt] = p256ModDouble(Value(s1jRes))
    if IsErr(twoS1JRes):
        return Err[bool](Error(twoS1JRes))
    let y3aRes: Result[BigInt] = p256ModMul(Value(rRes), Value(vMinusX3Res))
    if IsErr(y3aRes):
        return Err[bool](Error(y3aRes))
    let y3Res: Result[BigInt] = p256ModSub(Value(y3aRes), Value(twoS1JRes))
    if IsErr(y3Res):
        return Err[bool](Error(y3Res))
    let z1PlusZ2Res: Result[BigInt] = p256ModAdd(p1.z, p2.z)
    if IsErr(z1PlusZ2Res):
        return Err[bool](Error(z1PlusZ2Res))
    let z1PlusZ2SqRes: Result[BigInt] = p256ModMul(Value(z1PlusZ2Res), Value(z1PlusZ2Res))
    if IsErr(z1PlusZ2SqRes):
        return Err[bool](Error(z1PlusZ2SqRes))
    let z3aRes: Result[BigInt] = p256ModSub(Value(z1PlusZ2SqRes), Value(z1z1Res))
    if IsErr(z3aRes):
        return Err[bool](Error(z3aRes))
    let z3bRes: Result[BigInt] = p256ModSub(Value(z3aRes), Value(z2z2Res))
    if IsErr(z3bRes):
        return Err[bool](Error(z3bRes))
    let z3Res: Result[BigInt] = p256ModMul(Value(z3bRes), Value(hRes))
    if IsErr(z3Res):
        return Err[bool](Error(z3Res))
    let x3: BigInt = Value(x3Res)
    let y3: BigInt = Value(y3Res)
    let z3: BigInt = Value(z3Res)
    pointJacobianSetCoordsInto(out, x3, y3, z3)
    return Ok[bool](true)

fn p256ModDouble(a: BigInt): Result[BigInt] =
    return p256ModAdd(a, a)

fn p256ModTriple(a: BigInt): Result[BigInt] =
    let dblRes: Result[BigInt] = p256ModDouble(a)
    if IsErr(dblRes):
        return Err[BigInt](Error(dblRes))
    return p256ModAdd(Value(dblRes), a)

fn p256ModQuad(a: BigInt): Result[BigInt] =
    let dblRes: Result[BigInt] = p256ModDouble(a)
    if IsErr(dblRes):
        return Err[BigInt](Error(dblRes))
    return p256ModDouble(Value(dblRes))

fn p256ModEight(a: BigInt): Result[BigInt] =
    let quadRes: Result[BigInt] = p256ModQuad(a)
    if IsErr(quadRes):
        return Err[BigInt](Error(quadRes))
    return p256ModDouble(Value(quadRes))

fn pointJacobianDouble(p: EcPointJacobian): Result[EcPointJacobian] =
    if p.inf || bigIsZero(p.y):
        return Ok[EcPointJacobian](pointJacobianInfinity())
    let deltaRes: Result[BigInt] = p256ModMul(p.z, p.z)
    if IsErr(deltaRes):
        return Err[EcPointJacobian](Error(deltaRes))
    let gammaRes: Result[BigInt] = p256ModMul(p.y, p.y)
    if IsErr(gammaRes):
        return Err[EcPointJacobian](Error(gammaRes))
    let betaRes: Result[BigInt] = p256ModMul(p.x, Value(gammaRes))
    if IsErr(betaRes):
        return Err[EcPointJacobian](Error(betaRes))
    let xMinusDeltaRes: Result[BigInt] = p256ModSub(p.x, Value(deltaRes))
    if IsErr(xMinusDeltaRes):
        return Err[EcPointJacobian](Error(xMinusDeltaRes))
    let xPlusDeltaRes: Result[BigInt] = p256ModAdd(p.x, Value(deltaRes))
    if IsErr(xPlusDeltaRes):
        return Err[EcPointJacobian](Error(xPlusDeltaRes))
    let alphaBaseRes: Result[BigInt] = p256ModMul(Value(xMinusDeltaRes), Value(xPlusDeltaRes))
    if IsErr(alphaBaseRes):
        return Err[EcPointJacobian](Error(alphaBaseRes))
    let alphaRes: Result[BigInt] = p256ModTriple(Value(alphaBaseRes))
    if IsErr(alphaRes):
        return Err[EcPointJacobian](Error(alphaRes))
    let alpha2Res: Result[BigInt] = p256ModMul(Value(alphaRes), Value(alphaRes))
    if IsErr(alpha2Res):
        return Err[EcPointJacobian](Error(alpha2Res))
    let beta4Res: Result[BigInt] = p256ModQuad(Value(betaRes))
    if IsErr(beta4Res):
        return Err[EcPointJacobian](Error(beta4Res))
    let beta8Res: Result[BigInt] = p256ModDouble(Value(beta4Res))
    if IsErr(beta8Res):
        return Err[EcPointJacobian](Error(beta8Res))
    let x3Res: Result[BigInt] = p256ModSub(Value(alpha2Res), Value(beta8Res))
    if IsErr(x3Res):
        return Err[EcPointJacobian](Error(x3Res))
    let yPlusZRes: Result[BigInt] = p256ModAdd(p.y, p.z)
    if IsErr(yPlusZRes):
        return Err[EcPointJacobian](Error(yPlusZRes))
    let yPlusZ2Res: Result[BigInt] = p256ModMul(Value(yPlusZRes), Value(yPlusZRes))
    if IsErr(yPlusZ2Res):
        return Err[EcPointJacobian](Error(yPlusZ2Res))
    let z3aRes: Result[BigInt] = p256ModSub(Value(yPlusZ2Res), Value(gammaRes))
    if IsErr(z3aRes):
        return Err[EcPointJacobian](Error(z3aRes))
    let z3Res: Result[BigInt] = p256ModSub(Value(z3aRes), Value(deltaRes))
    if IsErr(z3Res):
        return Err[EcPointJacobian](Error(z3Res))
    let gamma2Res: Result[BigInt] = p256ModMul(Value(gammaRes), Value(gammaRes))
    if IsErr(gamma2Res):
        return Err[EcPointJacobian](Error(gamma2Res))
    let gamma8Res: Result[BigInt] = p256ModEight(Value(gamma2Res))
    if IsErr(gamma8Res):
        return Err[EcPointJacobian](Error(gamma8Res))
    let beta4MinusX3Res: Result[BigInt] = p256ModSub(Value(beta4Res), Value(x3Res))
    if IsErr(beta4MinusX3Res):
        return Err[EcPointJacobian](Error(beta4MinusX3Res))
    let y3aRes: Result[BigInt] = p256ModMul(Value(alphaRes), Value(beta4MinusX3Res))
    if IsErr(y3aRes):
        return Err[EcPointJacobian](Error(y3aRes))
    let y3Res: Result[BigInt] = p256ModSub(Value(y3aRes), Value(gamma8Res))
    if IsErr(y3Res):
        return Err[EcPointJacobian](Error(y3Res))
    return Ok[EcPointJacobian](EcPointJacobian(x: Value(x3Res), y: Value(y3Res), z: Value(z3Res), inf: false))

fn pointJacobianAdd(p1: EcPointJacobian, p2: EcPointJacobian): Result[EcPointJacobian] =
    if p1.inf || bigIsZero(p1.z):
        return Ok[EcPointJacobian](p2)
    if p2.inf || bigIsZero(p2.z):
        return Ok[EcPointJacobian](p1)
    let z1z1Res: Result[BigInt] = p256ModMul(p1.z, p1.z)
    if IsErr(z1z1Res):
        return Err[EcPointJacobian](Error(z1z1Res))
    let z2z2Res: Result[BigInt] = p256ModMul(p2.z, p2.z)
    if IsErr(z2z2Res):
        return Err[EcPointJacobian](Error(z2z2Res))
    let u1Res: Result[BigInt] = p256ModMul(p1.x, Value(z2z2Res))
    if IsErr(u1Res):
        return Err[EcPointJacobian](Error(u1Res))
    let u2Res: Result[BigInt] = p256ModMul(p2.x, Value(z1z1Res))
    if IsErr(u2Res):
        return Err[EcPointJacobian](Error(u2Res))
    let z1CubedRes: Result[BigInt] = p256ModMul(p1.z, Value(z1z1Res))
    if IsErr(z1CubedRes):
        return Err[EcPointJacobian](Error(z1CubedRes))
    let z2CubedRes: Result[BigInt] = p256ModMul(p2.z, Value(z2z2Res))
    if IsErr(z2CubedRes):
        return Err[EcPointJacobian](Error(z2CubedRes))
    let s1Res: Result[BigInt] = p256ModMul(p1.y, Value(z2CubedRes))
    if IsErr(s1Res):
        return Err[EcPointJacobian](Error(s1Res))
    let s2Res: Result[BigInt] = p256ModMul(p2.y, Value(z1CubedRes))
    if IsErr(s2Res):
        return Err[EcPointJacobian](Error(s2Res))
    if bigCmp(Value(u1Res), Value(u2Res)) == 0:
        if bigCmp(Value(s1Res), Value(s2Res)) != 0:
            return Ok[EcPointJacobian](pointJacobianInfinity())
        return pointJacobianDouble(p1)
    let hRes: Result[BigInt] = p256ModSub(Value(u2Res), Value(u1Res))
    if IsErr(hRes):
        return Err[EcPointJacobian](Error(hRes))
    let twoHRes: Result[BigInt] = p256ModDouble(Value(hRes))
    if IsErr(twoHRes):
        return Err[EcPointJacobian](Error(twoHRes))
    let iRes: Result[BigInt] = p256ModMul(Value(twoHRes), Value(twoHRes))
    if IsErr(iRes):
        return Err[EcPointJacobian](Error(iRes))
    let jRes: Result[BigInt] = p256ModMul(Value(hRes), Value(iRes))
    if IsErr(jRes):
        return Err[EcPointJacobian](Error(jRes))
    let sDiffRes: Result[BigInt] = p256ModSub(Value(s2Res), Value(s1Res))
    if IsErr(sDiffRes):
        return Err[EcPointJacobian](Error(sDiffRes))
    let rRes: Result[BigInt] = p256ModDouble(Value(sDiffRes))
    if IsErr(rRes):
        return Err[EcPointJacobian](Error(rRes))
    let vRes: Result[BigInt] = p256ModMul(Value(u1Res), Value(iRes))
    if IsErr(vRes):
        return Err[EcPointJacobian](Error(vRes))
    let r2Res: Result[BigInt] = p256ModMul(Value(rRes), Value(rRes))
    if IsErr(r2Res):
        return Err[EcPointJacobian](Error(r2Res))
    let twoVRes: Result[BigInt] = p256ModDouble(Value(vRes))
    if IsErr(twoVRes):
        return Err[EcPointJacobian](Error(twoVRes))
    let x3aRes: Result[BigInt] = p256ModSub(Value(r2Res), Value(jRes))
    if IsErr(x3aRes):
        return Err[EcPointJacobian](Error(x3aRes))
    let x3Res: Result[BigInt] = p256ModSub(Value(x3aRes), Value(twoVRes))
    if IsErr(x3Res):
        return Err[EcPointJacobian](Error(x3Res))
    let vMinusX3Res: Result[BigInt] = p256ModSub(Value(vRes), Value(x3Res))
    if IsErr(vMinusX3Res):
        return Err[EcPointJacobian](Error(vMinusX3Res))
    let s1jRes: Result[BigInt] = p256ModMul(Value(s1Res), Value(jRes))
    if IsErr(s1jRes):
        return Err[EcPointJacobian](Error(s1jRes))
    let twoS1JRes: Result[BigInt] = p256ModDouble(Value(s1jRes))
    if IsErr(twoS1JRes):
        return Err[EcPointJacobian](Error(twoS1JRes))
    let y3aRes: Result[BigInt] = p256ModMul(Value(rRes), Value(vMinusX3Res))
    if IsErr(y3aRes):
        return Err[EcPointJacobian](Error(y3aRes))
    let y3Res: Result[BigInt] = p256ModSub(Value(y3aRes), Value(twoS1JRes))
    if IsErr(y3Res):
        return Err[EcPointJacobian](Error(y3Res))
    let z1PlusZ2Res: Result[BigInt] = p256ModAdd(p1.z, p2.z)
    if IsErr(z1PlusZ2Res):
        return Err[EcPointJacobian](Error(z1PlusZ2Res))
    let z1PlusZ2SqRes: Result[BigInt] = p256ModMul(Value(z1PlusZ2Res), Value(z1PlusZ2Res))
    if IsErr(z1PlusZ2SqRes):
        return Err[EcPointJacobian](Error(z1PlusZ2SqRes))
    let z3aRes: Result[BigInt] = p256ModSub(Value(z1PlusZ2SqRes), Value(z1z1Res))
    if IsErr(z3aRes):
        return Err[EcPointJacobian](Error(z3aRes))
    let z3bRes: Result[BigInt] = p256ModSub(Value(z3aRes), Value(z2z2Res))
    if IsErr(z3bRes):
        return Err[EcPointJacobian](Error(z3bRes))
    let z3Res: Result[BigInt] = p256ModMul(Value(z3bRes), Value(hRes))
    if IsErr(z3Res):
        return Err[EcPointJacobian](Error(z3Res))
    return Ok[EcPointJacobian](EcPointJacobian(x: Value(x3Res), y: Value(y3Res), z: Value(z3Res), inf: false))

fn pointIsOnCurve(p: EcPoint): Result[bool] =
    if p.inf:
        return Ok[bool](false)
    let xModRes: Result[BigInt] = p256Mod(p.x)
    if IsErr(xModRes):
        return Err[bool](Error(xModRes))
    let yModRes: Result[BigInt] = p256Mod(p.y)
    if IsErr(yModRes):
        return Err[bool](Error(yModRes))
    let x: BigInt = Value(xModRes)
    let y: BigInt = Value(yModRes)
    let y2Res: Result[BigInt] = p256ModMul(y, y)
    if IsErr(y2Res):
        return Err[bool](Error(y2Res))
    let x2Res: Result[BigInt] = p256ModMul(x, x)
    if IsErr(x2Res):
        return Err[bool](Error(x2Res))
    let x3Res: Result[BigInt] = p256ModMul(Value(x2Res), x)
    if IsErr(x3Res):
        return Err[bool](Error(x3Res))
    let axRes: Result[BigInt] = p256ModMul(p256A, x)
    if IsErr(axRes):
        return Err[bool](Error(axRes))
    let rhs1Res: Result[BigInt] = p256ModAdd(Value(x3Res), Value(axRes))
    if IsErr(rhs1Res):
        return Err[bool](Error(rhs1Res))
    let rhsRes: Result[BigInt] = p256ModAdd(Value(rhs1Res), p256B)
    if IsErr(rhsRes):
        return Err[bool](Error(rhsRes))
    return Ok[bool](bigCmp(Value(y2Res), Value(rhsRes)) == 0)

fn pointIsOnCurveFixed(p: EcPointFixed): Result[bool] =
    if p.inf:
        return Ok[bool](false)
    let y2Res: Result[pfix.P256Fixed] = p256FieldFixedSquare(p.y)
    if IsErr(y2Res):
        return Err[bool](Error(y2Res))
    let x2Res: Result[pfix.P256Fixed] = p256FieldFixedSquare(p.x)
    if IsErr(x2Res):
        return Err[bool](Error(x2Res))
    let x3Res: Result[pfix.P256Fixed] = p256FieldFixedMul(Value(x2Res), p.x)
    if IsErr(x3Res):
        return Err[bool](Error(x3Res))
    let threeXRes: Result[pfix.P256Fixed] = p256FieldFixedTriple(p.x)
    if IsErr(threeXRes):
        return Err[bool](Error(threeXRes))
    let rhsBaseRes: Result[pfix.P256Fixed] = p256FieldFixedSub(Value(x3Res), Value(threeXRes))
    if IsErr(rhsBaseRes):
        return Err[bool](Error(rhsBaseRes))
    let rhsRes: Result[pfix.P256Fixed] = p256FieldFixedAdd(Value(rhsBaseRes), p256BFixed)
    if IsErr(rhsRes):
        return Err[bool](Error(rhsRes))
    var lhs: pfix.P256Fixed = Value(y2Res)
    var rhs: pfix.P256Fixed = Value(rhsRes)
    let same: bool = pfix.p256FixedCmp(lhs, rhs) == 0
    var out: Result[bool] = Ok[bool](same)
    return out

fn ecdsaParsePublicKeyPointFixedBytes(data: Bytes,
                                      requireCurveCheck: bool,
                                      out: var EcPointFixed): Result[bool] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[bool](Error(initRes))
    if bytesLen(data) != p256PublicSize:
        return Err[bool]("ecdsa: invalid public key length")
    if bytesGet(data, 0) != 0x04:
        return Err[bool]("ecdsa: invalid public key prefix")
    let xNormRes: Result[pfix.P256Fixed] = pfix.p256FixedReadBytesBE32(data, 1)
    if IsErr(xNormRes):
        return Err[bool](Error(xNormRes))
    let yNormRes: Result[pfix.P256Fixed] = pfix.p256FixedReadBytesBE32(data, 1 + p256ScalarSize)
    if IsErr(yNormRes):
        return Err[bool](Error(yNormRes))
    var xNorm: pfix.P256Fixed = Value(xNormRes)
    var yNorm: pfix.P256Fixed = Value(yNormRes)
    var modulus: pfix.P256Fixed = pfix.p256FieldModulus()
    if pfix.p256FixedCmp(xNorm, modulus) >= 0 || pfix.p256FixedCmp(yNorm, modulus) >= 0:
        return Err[bool]("ecdsa: point out of range")
    let xMontRes: Result[pfix.P256Fixed] = p256FieldFixedToMont(xNorm)
    if IsErr(xMontRes):
        return Err[bool](Error(xMontRes))
    let yMontRes: Result[pfix.P256Fixed] = p256FieldFixedToMont(yNorm)
    if IsErr(yMontRes):
        return Err[bool](Error(yMontRes))
    out.x = Value(xMontRes)
    out.y = Value(yMontRes)
    out.inf = false
    if requireCurveCheck:
        let onCurveRes: Result[bool] = pointIsOnCurveFixed(out)
        if IsErr(onCurveRes) || ! Value(onCurveRes):
            return Err[bool]("ecdsa: point ! on curve")
    return Ok[bool](true)

fn pointSetInfinityInto(out: var EcPoint) =
    out.x = bigZero()
    out.y = bigZero()
    out.inf = true

fn pointSetInto(out: var EcPoint, src: var EcPoint) =
    out.x = src.x
    out.y = src.y
    out.inf = src.inf

fn pointSetCoordsInto(out: var EcPoint, x: BigInt, y: BigInt) =
    out.x = x
    out.y = y
    out.inf = false

fn pointDoubleInto(out: var EcPoint, p: var EcPoint): Result[bool] =
    if p.inf:
        pointSetInto(out, p)
        return Ok[bool](true)
    if bigIsZero(p.y):
        pointSetInfinityInto(out)
        return Ok[bool](true)
    let x2Res: Result[BigInt] = p256ModMul(p.x, p.x)
    if IsErr(x2Res):
        return Err[bool](Error(x2Res))
    let dblRes: Result[BigInt] = p256ModAdd(Value(x2Res), Value(x2Res))
    if IsErr(dblRes):
        return Err[bool](Error(dblRes))
    let tripleRes: Result[BigInt] = p256ModAdd(Value(dblRes), Value(x2Res))
    if IsErr(tripleRes):
        return Err[bool](Error(tripleRes))
    let numRes: Result[BigInt] = p256ModAdd(Value(tripleRes), p256A)
    if IsErr(numRes):
        return Err[bool](Error(numRes))
    let denomRes: Result[BigInt] = p256ModAdd(p.y, p.y)
    if IsErr(denomRes):
        return Err[bool](Error(denomRes))
    let invRes: Result[BigInt] = p256ModInv(Value(denomRes))
    if IsErr(invRes):
        return Err[bool](Error(invRes))
    let lambdaRes: Result[BigInt] = p256ModMul(Value(numRes), Value(invRes))
    if IsErr(lambdaRes):
        return Err[bool](Error(lambdaRes))
    let lambda: BigInt = Value(lambdaRes)
    let lambda2Res: Result[BigInt] = p256ModMul(lambda, lambda)
    if IsErr(lambda2Res):
        return Err[bool](Error(lambda2Res))
    let twoXRes: Result[BigInt] = p256ModAdd(p.x, p.x)
    if IsErr(twoXRes):
        return Err[bool](Error(twoXRes))
    let x3Res: Result[BigInt] = p256ModSub(Value(lambda2Res), Value(twoXRes))
    if IsErr(x3Res):
        return Err[bool](Error(x3Res))
    let x1MinusX3Res: Result[BigInt] = p256ModSub(p.x, Value(x3Res))
    if IsErr(x1MinusX3Res):
        return Err[bool](Error(x1MinusX3Res))
    let y3Res1: Result[BigInt] = p256ModMul(lambda, Value(x1MinusX3Res))
    if IsErr(y3Res1):
        return Err[bool](Error(y3Res1))
    let y3Res: Result[BigInt] = p256ModSub(Value(y3Res1), p.y)
    if IsErr(y3Res):
        return Err[bool](Error(y3Res))
    let x3: BigInt = Value(x3Res)
    let y3: BigInt = Value(y3Res)
    pointSetCoordsInto(out, x3, y3)
    return Ok[bool](true)

fn pointDouble(p: EcPoint): Result[EcPoint] =
    var src: EcPoint = p
    var out: EcPoint
    let outRes: Result[bool] = pointDoubleInto(out, src)
    if IsErr(outRes):
        return Err[EcPoint](Error(outRes))
    return Ok[EcPoint](out)

fn pointAddInto(out: var EcPoint, p1: var EcPoint, p2: var EcPoint): Result[bool] =
    if p1.inf:
        pointSetInto(out, p2)
        return Ok[bool](true)
    if p2.inf:
        pointSetInto(out, p1)
        return Ok[bool](true)
    if bigCmp(p1.x, p2.x) == 0:
        let sumRes: Result[BigInt] = p256ModAdd(p1.y, p2.y)
        if IsErr(sumRes):
            return Err[bool](Error(sumRes))
        if bigIsZero(Value(sumRes)):
            pointSetInfinityInto(out)
            return Ok[bool](true)
        return pointDoubleInto(out, p1)
    let dyRes: Result[BigInt] = p256ModSub(p2.y, p1.y)
    if IsErr(dyRes):
        return Err[bool](Error(dyRes))
    let dxRes: Result[BigInt] = p256ModSub(p2.x, p1.x)
    if IsErr(dxRes):
        return Err[bool](Error(dxRes))
    let invRes: Result[BigInt] = p256ModInv(Value(dxRes))
    if IsErr(invRes):
        return Err[bool](Error(invRes))
    let lambdaRes: Result[BigInt] = p256ModMul(Value(dyRes), Value(invRes))
    if IsErr(lambdaRes):
        return Err[bool](Error(lambdaRes))
    let lambda: BigInt = Value(lambdaRes)
    let lambda2Res: Result[BigInt] = p256ModMul(lambda, lambda)
    if IsErr(lambda2Res):
        return Err[bool](Error(lambda2Res))
    let x3Res1: Result[BigInt] = p256ModSub(Value(lambda2Res), p1.x)
    if IsErr(x3Res1):
        return Err[bool](Error(x3Res1))
    let x3Res: Result[BigInt] = p256ModSub(Value(x3Res1), p2.x)
    if IsErr(x3Res):
        return Err[bool](Error(x3Res))
    let x1MinusX3Res: Result[BigInt] = p256ModSub(p1.x, Value(x3Res))
    if IsErr(x1MinusX3Res):
        return Err[bool](Error(x1MinusX3Res))
    let y3Res1: Result[BigInt] = p256ModMul(lambda, Value(x1MinusX3Res))
    if IsErr(y3Res1):
        return Err[bool](Error(y3Res1))
    let y3Res: Result[BigInt] = p256ModSub(Value(y3Res1), p1.y)
    if IsErr(y3Res):
        return Err[bool](Error(y3Res))
    let x3: BigInt = Value(x3Res)
    let y3: BigInt = Value(y3Res)
    pointSetCoordsInto(out, x3, y3)
    return Ok[bool](true)

fn pointAdd(p1: EcPoint, p2: EcPoint): Result[EcPoint] =
    var left: EcPoint = p1
    var right: EcPoint = p2
    var out: EcPoint
    let outRes: Result[bool] = pointAddInto(out, left, right)
    if IsErr(outRes):
        return Err[EcPoint](Error(outRes))
    return Ok[EcPoint](out)

fn pointMulInto(out: var EcPoint, k: BigInt, p: var EcPoint): Result[bool] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[bool](Error(initRes))
    if p.inf:
        pointSetInto(out, p)
        return Ok[bool](true)
    if bigIsZero(k):
        pointSetInfinityInto(out)
        return Ok[bool](true)
    let bitLen: int32 = bigBitLen(k)
    var result: EcPoint = pointInfinity()
    var addend: EcPoint = p
    var bitIdx: int32 = 0
    while bitIdx < bitLen:
        if bigGetBit(k, bitIdx) != 0:
            var nextResult: EcPoint
            let addRes: Result[bool] = pointAddInto(nextResult, result, addend)
            if IsErr(addRes):
                return Err[bool](Error(addRes))
            result = nextResult
        if bitIdx + 1 < bitLen:
            var nextAddend: EcPoint
            let dblRes: Result[bool] = pointDoubleInto(nextAddend, addend)
            if IsErr(dblRes):
                return Err[bool](Error(dblRes))
            addend = nextAddend
        bitIdx = bitIdx + 1
    pointSetInto(out, result)
    return Ok[bool](true)

fn pointMulJacobianInto(out: var EcPoint, k: BigInt, p: var EcPoint): Result[bool] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[bool](Error(initRes))
    if p.inf:
        pointSetInto(out, p)
        return Ok[bool](true)
    if bigIsZero(k):
        pointSetInfinityInto(out)
        return Ok[bool](true)
    let bitLen: int32 = bigBitLen(k)
    var result: EcPointJacobian = pointJacobianInfinity()
    var addend: EcPointJacobian = pointJacobianFromAffine(p)
    var bitIdx: int32 = 0
    while bitIdx < bitLen:
        if bigGetBit(k, bitIdx) != 0:
            var nextResult: EcPointJacobian
            let addRes: Result[bool] = pointJacobianAddInto(nextResult, result, addend)
            if IsErr(addRes):
                return Err[bool](Error(addRes))
            result = nextResult
        if bitIdx + 1 < bitLen:
            var nextAddend: EcPointJacobian
            let dblRes: Result[bool] = pointJacobianDoubleInto(nextAddend, addend)
            if IsErr(dblRes):
                return Err[bool](Error(dblRes))
            addend = nextAddend
        bitIdx = bitIdx + 1
    return pointJacobianToAffineInto(out, result)

fn pointMul(k: BigInt, p: EcPoint): Result[EcPoint] =
    var base: EcPoint = p
    var out: EcPoint
    let outRes: Result[bool] = pointMulInto(out, k, base)
    if IsErr(outRes):
        return Err[EcPoint](Error(outRes))
    return Ok[EcPoint](out)

fn pointMulGenerator(k: BigInt): Result[EcPoint] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[EcPoint](Error(initRes))
    if bigIsZero(k):
        return Ok[EcPoint](pointInfinity())
    var base: EcPoint = p256G
    var out: EcPoint
    let outRes: Result[bool] = pointMulJacobianInto(out, k, base)
    if IsErr(outRes):
        return Err[EcPoint](Error(outRes))
    return Ok[EcPoint](out)

fn pointMulGeneratorFixed(k: BigInt): Result[EcPointFixed] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[EcPointFixed](Error(initRes))
    if bigIsZero(k):
        return Ok[EcPointFixed](pointInfinityFixed())
    var scalarBig: BigInt = k
    let scalarRes: Result[pfix.P256Fixed] = pfix.p256FixedFromBigInt(scalarBig)
    if IsErr(scalarRes):
        return Err[EcPointFixed](Error(scalarRes))
    var result: EcPointJacobianFixed
    pointMulGeneratorJacobianComb6FixedInto(result, Value(scalarRes))
    return pointJacobianToAffineFixed(result)

fn p256Hash(msg: Bytes): Result[BigInt] =
    let digest: Bytes = sha256Digest(msg)
    return bigFromBytes(digest)

fn p256DeterministicConcat4(a: Bytes, b: Bytes, c: Bytes, d: Bytes): Bytes =
    let total: int32 = bytesLen(a) + bytesLen(b) + bytesLen(c) + bytesLen(d)
    let out: Bytes = bytesAlloc(total)
    var offset: int32 = 0
    for i in 0..<bytesLen(a):
        bytesSet(out, offset + i, bytesGet(a, i))
    offset = offset + bytesLen(a)
    for i in 0..<bytesLen(b):
        bytesSet(out, offset + i, bytesGet(b, i))
    offset = offset + bytesLen(b)
    for i in 0..<bytesLen(c):
        bytesSet(out, offset + i, bytesGet(c, i))
    offset = offset + bytesLen(c)
    for i in 0..<bytesLen(d):
        bytesSet(out, offset + i, bytesGet(d, i))
    return out

fn p256DeterministicFilledBytes(fill: int32): Bytes =
    let out: Bytes = bytesAlloc(sha256Size)
    for i in 0..<sha256Size:
        bytesSet(out, i, fill)
    return out

fn p256DeterministicK(priv: BigInt, msg: Bytes): Result[BigInt] =
    let xBytes: Bytes = bigToBytes(priv, p256ScalarSize)
    let h1: Bytes = sha256Digest(msg)
    var v: Bytes = p256DeterministicFilledBytes(0x01)
    var k: Bytes = p256DeterministicFilledBytes(0x00)
    let zero: Bytes = bytesFromByte(0x00)
    let one: Bytes = bytesFromByte(0x01)
    let seed0: Bytes = p256DeterministicConcat4(v, zero, xBytes, h1)
    let k1: Bytes = hmacSha256(k, seed0)
    k = k1
    v = hmacSha256(k, v)
    let seed1: Bytes = p256DeterministicConcat4(v, one, xBytes, h1)
    k = hmacSha256(k, seed1)
    v = hmacSha256(k, v)
    for attempt in 0..<64:
        v = hmacSha256(k, v)
        let tRes: Result[BigInt] = bigFromBytes(v)
        if IsErr(tRes):
            return Err[BigInt](Error(tRes))
        let candidate: BigInt = Value(tRes)
        if ! bigIsZero(candidate) && bigCmp(candidate, p256N) < 0:
            return Ok[BigInt](candidate)
        let retrySeed: Bytes = bytesConcat(v, zero)
        k = hmacSha256(k, retrySeed)
        v = hmacSha256(k, v)
    return Err[BigInt]("ecdsa: failed to derive nonce")

fn publicKeyFromPrivateKey(priv: EcPrivateKey): Result[EcPublicKey] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[EcPublicKey](Error(initRes))
    let pointRes: Result[EcPointFixed] = pointMulGeneratorFixed(priv.d)
    if IsErr(pointRes):
        return Err[EcPublicKey](Error(pointRes))
    let pointFixed: EcPointFixed = Value(pointRes)
    if pointFixed.inf:
        return Err[EcPublicKey]("ecdsa: public key at infinity")
    return Ok[EcPublicKey](EcPublicKey(point: pointBigFromFixed(pointFixed)))

fn generateEcKeyPair(): Result[EcKeyPair] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[EcKeyPair](Error(initRes))
    var attempt: int32 = 0
    let __for_guard_start_attempt_1 = attempt
    for __for_guard_attempt_1 in __for_guard_start_attempt_1..<100:
        if ! (attempt < 100):
            break
        let privRes: Result[Bytes] = randomBytes(p256ScalarSize)
        if IsErr(privRes):
            return Err[EcKeyPair](Error(privRes))
        let dRes: Result[BigInt] = bigFromBytes(Value(privRes))
        if IsErr(dRes):
            return Err[EcKeyPair](Error(dRes))
        let d: BigInt = Value(dRes)
        if bigIsZero(d) || bigCmp(d, p256N) >= 0:
            attempt = attempt + 1
            continue
        let priv: EcPrivateKey = EcPrivateKey(d: d)
        let pubRes: Result[EcPublicKey] = publicKeyFromPrivateKey(priv)
        if IsErr(pubRes):
            return Err[EcKeyPair](Error(pubRes))
        return Ok[EcKeyPair](EcKeyPair(publicKey: Value(pubRes), privateKey: priv))
    return Err[EcKeyPair]("ecdsa: failed to generate key")

fn ecdsaSignScalarResult(d: BigInt, msg: Bytes): Result[EcSignature] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[EcSignature](Error(initRes))
    if bigIsZero(d) || bigCmp(d, p256N) >= 0:
        return Err[EcSignature]("ecdsa: invalid private key")
    let eRes: Result[BigInt] = p256Hash(msg)
    if IsErr(eRes):
        return Err[EcSignature](Error(eRes))
    let eModRes: Result[BigInt] = nMod(Value(eRes))
    if IsErr(eModRes):
        return Err[EcSignature](Error(eModRes))
    let kRes: Result[BigInt] = p256DeterministicK(d, msg)
    if IsErr(kRes):
        return Err[EcSignature](Error(kRes))
    let k: BigInt = Value(kRes)
    let rRes: Result[BigInt] = pointMulGeneratorR(k)
    if IsErr(rRes):
        return Err[EcSignature](Error(rRes))
    let r: BigInt = Value(rRes)
    if bigIsZero(r):
        return Err[EcSignature]("ecdsa: r is zero")
    let rdRes: Result[BigInt] = nModMul(r, d)
    if IsErr(rdRes):
        return Err[EcSignature](Error(rdRes))
    let sumRes: Result[BigInt] = nModAdd(Value(eModRes), Value(rdRes))
    if IsErr(sumRes):
        return Err[EcSignature](Error(sumRes))
    let kInvRes: Result[BigInt] = nModInv(k)
    if IsErr(kInvRes):
        return Err[EcSignature](Error(kInvRes))
    let sRes: Result[BigInt] = nModMul(Value(kInvRes), Value(sumRes))
    if IsErr(sRes):
        return Err[EcSignature](Error(sRes))
    var s: BigInt = Value(sRes)
    if bigIsZero(s):
        return Err[EcSignature]("ecdsa: s is zero")
    if bigCmp(s, p256NHalf) > 0:
        let subRes: Result[BigInt] = bigSub(p256N, s)
        if IsErr(subRes):
            return Err[EcSignature](Error(subRes))
        s = Value(subRes)
    return Ok[EcSignature](EcSignature(r: r, s: s))

fn ecdsaSignScalarCore(d: BigInt, msg: Bytes, rOut: var BigInt, sOut: var BigInt): Result[bool] =
    let sigRes: Result[EcSignature] = ecdsaSignScalarResult(d, msg)
    if IsErr(sigRes):
        return Err[bool](Error(sigRes))
    let sig: EcSignature = Value(sigRes)
    rOut = sig.r
    sOut = sig.s
    return Ok[bool](true)

fn ecdsaVerifyPointScalars(pubPoint: EcPoint,
                           requireCurveCheck: bool,
                           msg: Bytes,
                           r: BigInt,
                           s: BigInt): bool =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return false
    if bigIsZero(r) || bigIsZero(s):
        return false
    if bigCmp(r, p256N) >= 0 || bigCmp(s, p256N) >= 0:
        return false
    if requireCurveCheck:
        let onCurveRes: Result[bool] = pointIsOnCurve(pubPoint)
        if IsErr(onCurveRes) || ! Value(onCurveRes):
            return false
    let eRes: Result[BigInt] = p256Hash(msg)
    if IsErr(eRes):
        return false
    let eModRes: Result[BigInt] = nMod(Value(eRes))
    if IsErr(eModRes):
        return false
    let wRes: Result[BigInt] = nModInv(s)
    if IsErr(wRes):
        return false
    let u1Res: Result[BigInt] = nModMul(Value(eModRes), Value(wRes))
    if IsErr(u1Res):
        return false
    let u2Res: Result[BigInt] = nModMul(r, Value(wRes))
    if IsErr(u2Res):
        return false
    let u1FixedRes: Result[pfix.P256Fixed] = ecdsaScalarToFixed(Value(u1Res))
    if IsErr(u1FixedRes):
        return false
    let u2FixedRes: Result[pfix.P256Fixed] = ecdsaScalarToFixed(Value(u2Res))
    if IsErr(u2FixedRes):
        return false
    let rFixedRes: Result[pfix.P256Fixed] = ecdsaScalarToFixed(r)
    if IsErr(rFixedRes):
        return false
    let xFixedRes: Result[pfix.P256Fixed] = ecdsaVerifyShamirX(pubPoint,
                                                               Value(u1FixedRes),
                                                               Value(u2FixedRes))
    if IsErr(xFixedRes):
        return false
    var xFixed: pfix.P256Fixed = Value(xFixedRes)
    var rFixed: pfix.P256Fixed = Value(rFixedRes)
    return pfix.p256FixedCmp(xFixed, rFixed) == 0

fn ecdsaSign(priv: EcPrivateKey, msg: Bytes): Result[EcSignature] =
    return ecdsaSignScalarResult(priv.d, msg)

fn ecdsaScalarToFixed(a: BigInt): Result[pfix.P256Fixed] =
    var aBig: BigInt = a
    return pfix.p256FixedFromBigInt(aBig)

fn ecdsaVerifyShamirX(pubPoint: EcPoint,
                      u1: pfix.P256Fixed,
                      u2: pfix.P256Fixed): Result[pfix.P256Fixed] =
    let pubFixedRes: Result[EcPointFixed] = pointFixedFromBig(pubPoint)
    if IsErr(pubFixedRes):
        return Err[pfix.P256Fixed](Error(pubFixedRes))
    let sumRes: Result[EcPointJacobianFixed] = pointMulGeneratorAndFixedShamir(u1, u2, Value(pubFixedRes))
    if IsErr(sumRes):
        return Err[pfix.P256Fixed](Error(sumRes))
    let sumPoint: EcPointJacobianFixed = Value(sumRes)
    if sumPoint.inf || pfix.p256FixedIsZero(sumPoint.z):
        return Err[pfix.P256Fixed]("ecdsa: verify infinity")
    return Ok[pfix.P256Fixed](pointJacobianXToScalarFixedCrash(sumPoint))

fn ecdsaVerify(pub: EcPublicKey, msg: Bytes, sig: EcSignature): bool =
    return ecdsaVerifyPointScalars(pub.point, true, msg, sig.r, sig.s)

fn ecdsaVerifyTrustedPublicKey(pub: EcPublicKey, msg: Bytes, sig: EcSignature): bool =
    return ecdsaVerifyPointScalars(pub.point, false, msg, sig.r, sig.s)

fn ecdsaParsePublicKeyPointBytes(data: Bytes,
                                 requireCurveCheck: bool,
                                 out: var EcPoint): Result[bool] =
    var fixedPoint: EcPointFixed
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointFixedBytes(data, requireCurveCheck, fixedPoint)
    if IsErr(pointRes):
        return Err[bool](Error(pointRes))
    pointBigFromFixedInto(out, fixedPoint)
    return Ok[bool](true)

fn ecdsaParsePrivateScalarBytes(data: Bytes, out: var BigInt): Result[bool] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[bool](Error(initRes))
    if bytesLen(data) != p256ScalarSize:
        return Err[bool]("ecdsa: invalid private key length")
    let dRes: Result[BigInt] = bigFromBytes(data)
    if IsErr(dRes):
        return Err[bool](Error(dRes))
    out = Value(dRes)
    if bigIsZero(out) || bigCmp(out, p256N) >= 0:
        return Err[bool]("ecdsa: invalid private key value")
    return Ok[bool](true)

fn ecdsaParseSignatureScalarsBytes(data: Bytes, rOut: var BigInt, sOut: var BigInt): Result[bool] =
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[bool](Error(initRes))
    if bytesLen(data) != p256SignatureSize:
        return Err[bool]("ecdsa: invalid signature length")
    let rRes: Result[BigInt] = bigFromBytes(bytesSliceView(data, 0, p256ScalarSize))
    if IsErr(rRes):
        return Err[bool](Error(rRes))
    let sRes: Result[BigInt] = bigFromBytes(bytesSliceView(data, p256ScalarSize, p256ScalarSize))
    if IsErr(sRes):
        return Err[bool](Error(sRes))
    rOut = Value(rRes)
    sOut = Value(sRes)
    if bigIsZero(rOut) || bigIsZero(sOut):
        return Err[bool]("ecdsa: invalid signature value")
    if bigCmp(rOut, p256N) >= 0 || bigCmp(sOut, p256N) >= 0:
        return Err[bool]("ecdsa: signature out of range")
    return Ok[bool](true)

fn ecdsaPublicPointToBytes(point: EcPoint): Bytes =
    let out: Bytes = bytesAlloc(p256PublicSize)
    bytesSet(out, 0, 0x04)
    let xBytes: Bytes = bigToBytes(point.x, p256ScalarSize)
    let yBytes: Bytes = bigToBytes(point.y, p256ScalarSize)
    for i in 0..<p256ScalarSize:
        bytesSet(out, 1 + i, bytesGet(xBytes, i))
    for i in 0..<p256ScalarSize:
        bytesSet(out, 1 + p256ScalarSize + i, bytesGet(yBytes, i))
    return out

fn ecdsaPublicPointFixedToBytes(point: EcPointFixed): Bytes =
    assert(!point.inf, "ecdsa: invalid public point at infinity")
    let xNormRes: Result[pfix.P256Fixed] = p256FieldFixedFromMont(point.x)
    assert(!IsErr(xNormRes), "ecdsa: public x fromMont failed")
    let yNormRes: Result[pfix.P256Fixed] = p256FieldFixedFromMont(point.y)
    assert(!IsErr(yNormRes), "ecdsa: public y fromMont failed")
    var xNorm: pfix.P256Fixed = Value(xNormRes)
    var yNorm: pfix.P256Fixed = Value(yNormRes)
    let xBig: BigInt = pfix.p256FixedToBigInt(xNorm)
    let yBig: BigInt = pfix.p256FixedToBigInt(yNorm)
    let out: Bytes = bytesAlloc(p256PublicSize)
    bytesSet(out, 0, 0x04)
    let xBytes: Bytes = bigToBytes(xBig, p256ScalarSize)
    let yBytes: Bytes = bigToBytes(yBig, p256ScalarSize)
    for i in 0..<p256ScalarSize:
        bytesSet(out, 1 + i, bytesGet(xBytes, i))
    for i in 0..<p256ScalarSize:
        bytesSet(out, 1 + p256ScalarSize + i, bytesGet(yBytes, i))
    return out

fn ecdsaSignatureScalarsToBytes(r: BigInt, s: BigInt): Bytes =
    let out: Bytes = bytesAlloc(p256SignatureSize)
    let rBytes: Bytes = bigToBytes(r, p256ScalarSize)
    let sBytes: Bytes = bigToBytes(s, p256ScalarSize)
    for i in 0..<p256ScalarSize:
        bytesSet(out, i, bytesGet(rBytes, i))
    for i in 0..<p256ScalarSize:
        bytesSet(out, p256ScalarSize + i, bytesGet(sBytes, i))
    return out

fn ecdsaVerifyTrustedPublicKeyBytes(pubBytes: Bytes, msg: Bytes, sig: EcSignature): Result[bool] =
    var point: EcPoint
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointBytes(pubBytes, false, point)
    if IsErr(pointRes):
        return Err[bool](Error(pointRes))
    return Ok[bool](ecdsaVerifyPointScalars(point, false, msg, sig.r, sig.s))

fn ecdsaPublicKeyBytesValid(pubBytes: Bytes): bool =
    var point: EcPointFixed
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointFixedBytes(pubBytes, true, point)
    return IsOk(pointRes)

fn ecdsaPublicKeyToBytes(pub: EcPublicKey): Bytes =
    return ecdsaPublicPointToBytes(pub.point)

fn ecdsaPrivateKeyToBytes(priv: EcPrivateKey): Bytes =
    return bigToBytes(priv.d, p256ScalarSize)

fn ecdsaSignatureToBytes(sig: EcSignature): Bytes =
    return ecdsaSignatureScalarsToBytes(sig.r, sig.s)

fn ecdsaPublicKeyFromBytes(data: Bytes): Result[EcPublicKey] =
    var point: EcPointFixed
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointFixedBytes(data, true, point)
    if IsErr(pointRes):
        return Err[EcPublicKey](Error(pointRes))
    return Ok[EcPublicKey](EcPublicKey(point: pointBigFromFixed(point)))

fn ecdsaTrustedPublicKeyFromBytes(data: Bytes): Result[EcPublicKey] =
    var point: EcPointFixed
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointFixedBytes(data, false, point)
    if IsErr(pointRes):
        return Err[EcPublicKey](Error(pointRes))
    return Ok[EcPublicKey](EcPublicKey(point: pointBigFromFixed(point)))

fn ecdsaPrivateKeyFromBytes(data: Bytes): Result[EcPrivateKey] =
    var d: BigInt
    let dRes: Result[bool] = ecdsaParsePrivateScalarBytes(data, d)
    if IsErr(dRes):
        return Err[EcPrivateKey](Error(dRes))
    return Ok[EcPrivateKey](EcPrivateKey(d: d))

fn ecdsaSignatureFromBytes(data: Bytes): Result[EcSignature] =
    var r: BigInt
    var s: BigInt
    let sigRes: Result[bool] = ecdsaParseSignatureScalarsBytes(data, r, s)
    if IsErr(sigRes):
        return Err[EcSignature](Error(sigRes))
    return Ok[EcSignature](EcSignature(r: r, s: s))

fn validateEcdsaPublicKeyBytes(data: Bytes): bool =
    var point: EcPointFixed
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointFixedBytes(data, true, point)
    return IsOk(pointRes)

fn validateEcdsaTrustedPublicKeyBytes(data: Bytes): bool =
    var point: EcPointFixed
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointFixedBytes(data, false, point)
    return IsOk(pointRes)

fn validateEcdsaPrivateKeyBytes(data: Bytes): bool =
    var d: BigInt
    let dRes: Result[bool] = ecdsaParsePrivateScalarBytes(data, d)
    return IsOk(dRes)

fn validateEcdsaSignatureBytes(data: Bytes): bool =
    var r: BigInt
    var s: BigInt
    let sigRes: Result[bool] = ecdsaParseSignatureScalarsBytes(data, r, s)
    return IsOk(sigRes)

fn ecdsaSignBytes(privData: Bytes, msg: Bytes): Result[Bytes] =
    var d: BigInt
    let dRes: Result[bool] = ecdsaParsePrivateScalarBytes(privData, d)
    if IsErr(dRes):
        return Err[Bytes](Error(dRes))
    let sigRes: Result[EcSignature] = ecdsaSignScalarResult(d, msg)
    if IsErr(sigRes):
        return Err[Bytes](Error(sigRes))
    let sig: EcSignature = Value(sigRes)
    let sigBytes: Bytes = ecdsaSignatureScalarsToBytes(sig.r, sig.s)
    return Ok[Bytes](sigBytes)

fn ecdsaVerifyBytes(pubData: Bytes, msg: Bytes, sig: Bytes): bool =
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointBytes(pubBytes, true, point)
    var point: EcPoint
    let pointRes = ecdsaParsePublicKeyPointBytes(pubData, true, point)
    if IsErr(pointRes):
        return false
    var r: BigInt
    var s: BigInt
    let sigRes: Result[bool] = ecdsaParseSignatureScalarsBytes(sig, r, s)
    if IsErr(sigRes):
        return false
    return ecdsaVerifyPointScalars(point, false, msg, r, s)

fn ecdsaVerifyTrustedBytes(pubData: Bytes, msg: Bytes, sig: Bytes): bool =
    var point: EcPoint
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointBytes(pubData, false, point)
    if IsErr(pointRes):
        return false
    var r: BigInt
    var s: BigInt
    let sigRes: Result[bool] = ecdsaParseSignatureScalarsBytes(sig, r, s)
    if IsErr(sigRes):
        return false
    return ecdsaVerifyPointScalars(point, false, msg, r, s)

fn ecdsaPublicKeyFromPrivateBytes(privData: Bytes): Result[Bytes] =
    var d: BigInt
    let dRes: Result[bool] = ecdsaParsePrivateScalarBytes(privData, d)
    if IsErr(dRes):
        return Err[Bytes](Error(dRes))
    let initRes: Result[bool] = p256EnsureInit()
    if IsErr(initRes):
        return Err[Bytes](Error(initRes))
    let pointRes: Result[EcPointFixed] = pointMulGeneratorFixed(d)
    if IsErr(pointRes):
        return Err[Bytes](Error(pointRes))
    let pointFixed: EcPointFixed = Value(pointRes)
    if pointFixed.inf:
        return Err[Bytes]("ecdsa: public key at infinity")
    return Ok[Bytes](ecdsaPublicPointFixedToBytes(pointFixed))

fn ecdhP256SharedSecretBytes(privData: Bytes, peerPubData: Bytes): Result[Bytes] =
    var d: BigInt
    let dRes: Result[bool] = ecdsaParsePrivateScalarBytes(privData, d)
    if IsErr(dRes):
        return Err[Bytes](Error(dRes))
    var peerPoint: EcPoint
    let pointRes: Result[bool] = ecdsaParsePublicKeyPointBytes(peerPubData, true, peerPoint)
    if IsErr(pointRes):
        return Err[Bytes](Error(pointRes))
    var sharedPoint: EcPoint
    let mulRes: Result[bool] = pointMulInto(sharedPoint, d, peerPoint)
    if IsErr(mulRes):
        return Err[Bytes](Error(mulRes))
    if sharedPoint.inf:
        return Err[Bytes]("ecdsa: invalid ecdh point")
    let secret: Bytes = bigToBytes(sharedPoint.x, p256ScalarSize)
    return Ok[Bytes](secret)
