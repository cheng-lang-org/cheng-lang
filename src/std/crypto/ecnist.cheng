# ECDSA helpers(NIST P-256, pure Cheng).

import std/result
import std/rawbytes
import std/system
import std/crypto/rand
import std/crypto/sha256
import std/crypto/hkdf
import std/crypto/bigint
import std/crypto/p256_fixed as pfix
const
    p256ScalarSize: int32 = 32
    p256PublicSize: int32 = 65
    p256SignatureSize: int32 = 64
    p256GeneratorComb6Width: int32 = 6
    p256GeneratorComb6Depth: int32 = 43
    p256HexP = "ffffffff00000001000000000000000000000000ffffffffffffffffffffffff"
    p256HexN = "ffffffff00000000ffffffffffffffffbce6faada7179e84f3b9cac2fc632551"
    p256HexB = "5ac635d8aa3a93e7b3ebbd55769886bc651d06b0cc53b0f63bce3c3e27d2604b"
    p256HexGx = "6b17d1f2e12c4247f8bce6e563a440f277037d812deb33a0f4a13945d898c296"
    p256HexGy = "4fe342e2fe1a7f9b8ee7eb4a7c0f9e162bce33576b315ececbb6406837bf51f5"

type
    EcPoint =
        x: BigInt
        y: BigInt
        inf: bool

    EcPointJacobian =
        x: BigInt
        y: BigInt
        z: BigInt
        inf: bool

    EcPointFixed =
        x: pfix.P256Fixed
        y: pfix.P256Fixed
        inf: bool

    EcPointJacobianFixed =
        x: pfix.P256Fixed
        y: pfix.P256Fixed
        z: pfix.P256Fixed
        inf: bool


    EcPublicKey =
        point: EcPoint

    EcPrivateKey =
        d: BigInt

    EcKeyPair =
        publicKey: EcPublicKey
        privateKey: EcPrivateKey

    EcSignature =
        r: BigInt
        s: BigInt

var
    p256InitDone: bool = false
    p256P: BigInt
    p256N: BigInt
    p256A: BigInt
    p256B: BigInt
    p256G: EcPoint
    p256PMinus2: BigInt
    p256NMinus2: BigInt
    p256NHalf: BigInt
    p256PCtxFixed: pfix.P256FixedMontgomeryContext
    p256NCtxFixed: pfix.P256FixedMontgomeryContext
    p256PMinus2Fixed: pfix.P256Fixed
    p256NMinus2Fixed: pfix.P256Fixed
    p256BFixed: pfix.P256Fixed

fn p256ConstBig8(count: int32,
                 l0: int32,
                 l1: int32,
                 l2: int32,
                 l3: int32,
                 l4: int32,
                 l5: int32,
                 l6: int32,
                 l7: int32): BigInt =
    var out: BigInt
    out.count = count
    out.limbs[0] = l0
    out.limbs[1] = l1
    out.limbs[2] = l2
    out.limbs[3] = l3
    out.limbs[4] = l4
    out.limbs[5] = l5
    out.limbs[6] = l6
    out.limbs[7] = l7
    return out

fn p256ConstFixed8(l0: int32,
                   l1: int32,
                   l2: int32,
                   l3: int32,
                   l4: int32,
                   l5: int32,
                   l6: int32,
                   l7: int32): pfix.P256Fixed =
    var out: pfix.P256Fixed
    out.limbs[0] = l0
    out.limbs[1] = l1
    out.limbs[2] = l2
    out.limbs[3] = l3
    out.limbs[4] = l4
    out.limbs[5] = l5
    out.limbs[6] = l6
    out.limbs[7] = l7
    return out

fn p256ConstP(): BigInt =
    return p256ConstBig8(8, -1, -1, -1, 0, 0, 0, 1, -1)

fn p256ConstN(): BigInt =
    return p256ConstBig8(8, -60611247, -205927742, -1491624316, -1125713235, -1, -1, 0, -1)

fn p256ConstNHalf(): BigInt =
    return p256ConstBig8(8, 2117178024, 2044519777, -745812158, -562856618, -1, 2147483647, -2147483648, 2147483647)

fn p256ConstB(): BigInt =
    return p256ConstBig8(8, 668098635, 1003371582, -866930442, 1696401072, 1989707452, -1276396203, -1439001625, 1522939352)

fn p256ConstGx(): BigInt =
    return p256ConstBig8(8, -661077354, -190760635, 770388896, 1996717441, 1671708914, -121837851, -517193145, 1796723186)

fn p256ConstGy(): BigInt =
    return p256ConstBig8(8, 935285237, -877248408, 1798397646, 734933847, 2081398294, -1897403574, -31817829, 1340293858)

