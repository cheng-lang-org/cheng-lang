import std/strutils as strutil
# RSA helpers(minimal, small-int implementation).

import std/result
import std/rawbytes
import std/buffer
import std/strings
import std/crypto/rand
import std/crypto/sha256
import std/crypto/sha384
import std/crypto/minasn1
import std/crypto/bigint
const
    rsaDefaultPrimeBits = 30
    rsaMinPrimeBits = 8
    rsaMaxPrimeBits = 31
    rsaDefaultE = 65537
    rsaExponentCandidateCount = 5

type
    RsaPublicKey =
        n: int64
        e: int64

    RsaPrivateKey =
        n: int64
        e: int64
        d: int64
        p: int64
        q: int64

    RsaKeyPair =
        publicKey: RsaPublicKey
        privateKey: RsaPrivateKey

    RsaBigPublicKey =
        n: BigInt
        e: BigInt
        modBits: int32
        modLen: int32

    RsaBigPrivateKey =
        n: BigInt
        d: BigInt
        modBits: int32
        modLen: int32

fn rsaCopyBytes(dst: var Bytes, dstOffset: int32, src: Bytes, srcOffset: int32, count: int32) =
    if count <= 0:
        return
    for i in 0..<count:
        BytesSet(dst, dstOffset + i, BytesGet(src, srcOffset + i))

fn gcd(a: int64, b: int64): int64 =
    var x: int64 = if a < 0: -a else: a
    var y: int64 = if b < 0: -b else: b
    while y != 0:
        let t: int64 = x % y
        x = y
        y = t
    return x

fn modInv(a: int64, modv: int64): Result[int64] =
    var t: int64
    var newT: int64 = 1
    var r: int64 = modv
    var newR: int64 = a % modv
    while newR != 0:
        let q: int64 = r / newR
        let nextT: int64 = t - q * newT
        t = newT
        newT = nextT
        let nextR: int64 = r - q * newR
        r = newR
        newR = nextR
    if r != 1 && r != -1:
        return Err[int64]("rsa: inverse ! found")
    if t < 0:
        t = t + modv
    return Ok[int64](t)

fn mulMod(a: int64, b: int64, modv: int64): int64 =
    var res: int64
    var x: int64 = a % modv
    var y: int64 = b
    while y > 0:
        if (y & 1) != 0:
            res = (res + x) % modv
        x = (x << 1) % modv
        y = y >> 1
    return res

fn powMod(base: int64, exp: int64, modv: int64): int64 =
    var result: int64 = 1 % modv
    var b: int64 = base % modv
    var e: int64 = exp
    while e > 0:
        if (e & 1) != 0:
            result = mulMod(result, b, modv)
        b = mulMod(b, b, modv)
        e = e >> 1
    return result

fn isPrime(n: int64): bool =
    if n <= 1:
        return false
    if n <= 3:
        return true
    if (n & 1) == 0:
        return false
    var i: int64 = 3
    while i * i <= n:
        if n % i == 0:
            return false
        i = i + 2
    return true

fn randomInt(bits: int32): Result[int64] =
    if bits < 2:
        return Err[int64]("rsa: bits too small")
    if bits > 62:
        return Err[int64]("rsa: bits too large")
    let byteCount: int32 = (bits + 7) / 8
    let res: Result[Bytes] = randomBytes(byteCount)
    if IsErr(res):
        return Err[int64](Error(res))
    let data: Bytes = Value(res)
    var value: int64
    for i in 0..<BytesLen(data):
        value = (value << 8) | int64(BytesGet(data, i))
    let topBit: int64 = int64(1) << (bits - 1)
    let mask: int64 = (int64(1) << bits) - 1
    value = value & mask
    value = value | topBit
    value = value | 1
    return Ok[int64](value)

fn generatePrime(bits: int32): Result[int64] =
    for attempt in 0..<10000:
        let res: Result[int64] = randomInt(bits)
        if IsErr(res):
            return Err[int64](Error(res))
        let candidate: int64 = Value(res)
        if isPrime(candidate):
            return Ok[int64](candidate)
    return Err[int64]("rsa: failed to generate prime")

fn rsaExponentCandidate(idx: int32): int64 =
    if idx == 0:
        return rsaDefaultE
    if idx == 1:
        return 257
    if idx == 2:
        return 17
    if idx == 3:
        return 5
    return 3

fn pickPublicExponent(phi: int64): Result[int64] =
    for i in 0..<rsaExponentCandidateCount:
        let e: int64 = rsaExponentCandidate(i)
        if e > 1 && e < phi && gcd(e, phi) == 1:
            return Ok[int64](e)
    return Err[int64]("rsa: no valid public exponent")

fn generateRsaKeyPair(primeBits: int32): Result[RsaKeyPair] =
    if primeBits < rsaMinPrimeBits || primeBits > rsaMaxPrimeBits:
        return Err[RsaKeyPair]("rsa: prime bits out of range")
    let pRes: Result[int64] = generatePrime(primeBits)
    if IsErr(pRes):
        return Err[RsaKeyPair](Error(pRes))
    var p: int64 = Value(pRes)
    var q: int64
    for attempt in 0..<10000:
        let qRes: Result[int64] = generatePrime(primeBits)
        if IsErr(qRes):
            return Err[RsaKeyPair](Error(qRes))
        q = Value(qRes)
        if q != p:
            break
    if q == 0 || q == p:
        return Err[RsaKeyPair]("rsa: failed to generate q")
    let n: int64 = p * q
    let phi: int64 = (p - 1) * (q - 1)
    let eRes: Result[int64] = pickPublicExponent(phi)
    if IsErr(eRes):
        return Err[RsaKeyPair](Error(eRes))
    let e: int64 = Value(eRes)
    let dRes: Result[int64] = modInv(e, phi)
    if IsErr(dRes):
        return Err[RsaKeyPair](Error(dRes))
    let d: int64 = Value(dRes)
    let pub: RsaPublicKey = RsaPublicKey(n: n, e: e)
    let priv: RsaPrivateKey = RsaPrivateKey(n: n, e: e, d: d, p: p, q: q)
    return Ok[RsaKeyPair](RsaKeyPair(publicKey: pub, privateKey: priv))

fn generateRsaKeyPair(): Result[RsaKeyPair] =
    return generateRsaKeyPair(rsaDefaultPrimeBits)

fn rsaPublicKeyFromPrivate(priv: RsaPrivateKey): RsaPublicKey =
    return RsaPublicKey(n: priv.n, e: priv.e)

fn bytesToInt64Mod(data: Bytes, modv: int64): int64 =
    if modv <= 0:
        return 0
    var acc: int64
    for i in 0..<BytesLen(data):
        acc = (acc * 256 + int64(BytesGet(data, i))) % modv
    return acc

fn rsaHexValue(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'f':
        return 10 + int32(c) - int32('a')
    if c >= 'A' && c <= 'F':
        return 10 + int32(c) - int32('A')
    return -1

fn rsaHexDecode(text: str): Result[Bytes] =
    if len(text) % 2 != 0:
        return Err[Bytes]("rsa: hex length must be even")
    let out: Bytes = BytesAlloc(len(text) / 2)
    var i: int32
    for _ in range(len(text) / 2):
        let hi: int32 = rsaHexValue(text[i])
        let lo: int32 = rsaHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("rsa: invalid hex")
        BytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn rsaHashLenSha256(): int32 =
    return 32

fn rsaHashLenSha384(): int32 =
    return 48

fn rsaHashSha256(data: Bytes): Bytes =
    return sha256Digest(data)

fn rsaHashSha384(data: Bytes): Bytes =
    return sha384Digest(data)

fn rsaDigestInfoSha256(hash: Bytes): Result[Bytes] =
    let prefixRes: Result[Bytes] = rsaHexDecode("3031300d060960864801650304020105000420")
    if IsErr(prefixRes):
        return Err[Bytes](Error(prefixRes))
    return Ok[Bytes](BytesConcat(Value(prefixRes), hash))

fn rsaDigestInfoSha384(hash: Bytes): Result[Bytes] =
    let prefixRes: Result[Bytes] = rsaHexDecode("3041300d060960864801650304020205000430")
    if IsErr(prefixRes):
        return Err[Bytes](Error(prefixRes))
    return Ok[Bytes](BytesConcat(Value(prefixRes), hash))

fn rsaMgf1(seed: Bytes, length: int32, useSha384: bool): Bytes =
    if length <= 0:
        return EmptyBytes()
    var out: ByteBuffer = newByteBuffer()
    var counter: int32
    while byteBufferLen(out) < length:
        let ctr: Bytes = BytesAlloc(4)
        BytesSet(ctr, 0, int32((counter >> 24) & 255))
        BytesSet(ctr, 1, int32((counter >> 16) & 255))
        BytesSet(ctr, 2, int32((counter >> 8) & 255))
        BytesSet(ctr, 3, int32(counter & 255))
        let msg: Bytes = BytesConcat(seed, ctr)
        var digest: Bytes
        if useSha384:
            digest = rsaHashSha384(msg)
        else:
            digest = rsaHashSha256(msg)
        appendBytes(out, digest)
        counter = counter + 1
    let mask: Bytes = toBytes(out)
    if BytesLen(mask) <= length:
        return mask
    return BytesSlice(mask, 0, length)

fn rsaBytesXorExact(a: Bytes, b: Bytes): Bytes =
    let out: Bytes = BytesAlloc(BytesLen(a))
    for i in 0..<BytesLen(a):
        let av: int32 = BytesGet(a, i)
        let bv: int32 = BytesGet(b, i)
        BytesSet(out, i, av + bv - 2 * (av & bv))
    return out

fn rsaBytesXorLen(a: Bytes, b: Bytes, count: int32): Bytes =
    let out: Bytes = BytesAlloc(count)
    var i: int32
    for i in i..<count:
        let av: int32 = BytesGet(a, i)
        let bv: int32 = BytesGet(b, i)
        BytesSet(out, i, av + bv - 2 * (av & bv))
    return out

fn rsaBytesEqualLen(a: Bytes, b: Bytes, count: int32): bool =
    var i: int32
    for i in i..<count:
        if BytesGet(a, i) != BytesGet(b, i):
            return false
    return true

fn rsaBytesXor(a: Bytes, b: Bytes): Result[Bytes] =
    if BytesLen(a) != BytesLen(b):
        return Err[Bytes]("rsa: ^ length mismatch")
    return Ok[Bytes](rsaBytesXorExact(a, b))

fn rsaBigModMulSlow(a: BigInt, b: BigInt, m: BigInt): Result[BigInt] =
    let mulRes: Result[BigInt] = bigMul(a, b)
    if IsErr(mulRes):
        return Err[BigInt](Error(mulRes))
    return bigMod(Value(mulRes), m)

fn rsaBigModExpSlow(base: BigInt, exp: BigInt, m: BigInt): Result[BigInt] =
    if bigIsZero(m):
        return Err[BigInt]("rsa: modexp modulus zero")
    var result: BigInt = bigFromInt(1)
    let baseModRes: Result[BigInt] = bigMod(base, m)
    if IsErr(baseModRes):
        return Err[BigInt](Error(baseModRes))
    var pow: BigInt = Value(baseModRes)
    let bits: int32 = bigBitLen(exp)
    for i in 0..<bits:
        if bigGetBit(exp, i) != 0:
            let mulRes: Result[BigInt] = rsaBigModMulSlow(result, pow, m)
            if IsErr(mulRes):
                return Err[BigInt](Error(mulRes))
            result = Value(mulRes)
        let sqRes: Result[BigInt] = rsaBigModMulSlow(pow, pow, m)
        if IsErr(sqRes):
            return Err[BigInt](Error(sqRes))
        pow = Value(sqRes)
    return Ok[BigInt](result)

fn rsaBigPublicKeyFromBytes(data: Bytes): Result[RsaBigPublicKey] =
    let seqRes: Result[Asn1ValueNext] = asn1DecodeSequence(data, 0)
    if IsErr(seqRes):
        return Err[RsaBigPublicKey](Error(seqRes))
    var offset: int32
    let seqValue: Bytes = Value(seqRes).value
    let nRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, offset)
    if IsErr(nRes):
        return Err[RsaBigPublicKey](Error(nRes))
    offset = Value(nRes).next
    let eRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, offset)
    if IsErr(eRes):
        return Err[RsaBigPublicKey](Error(eRes))
    let nBytes: Bytes = Value(nRes).value
    let eBytes: Bytes = Value(eRes).value
    let nBigRes: Result[BigInt] = bigFromBytes(nBytes)
    if IsErr(nBigRes):
        return Err[RsaBigPublicKey](Error(nBigRes))
    let eBigRes: Result[BigInt] = bigFromBytes(eBytes)
    if IsErr(eBigRes):
        return Err[RsaBigPublicKey](Error(eBigRes))
    let nBig: BigInt = Value(nBigRes)
    let eBig: BigInt = Value(eBigRes)
    let modBits: int32 = bigBitLen(nBig)
    let modLen: int32 = (modBits + 7) / 8
    if modBits <= 0 || modLen <= 0:
        return Err[RsaBigPublicKey]("rsa: invalid modulus")
    let one: BigInt = bigFromInt(1)
    if bigCmp(eBig, one) <= 0 || bigGetBit(eBig, 0) == 0:
        return Err[RsaBigPublicKey]("rsa: invalid exponent")
    if bigCmp(eBig, nBig) >= 0:
        return Err[RsaBigPublicKey]("rsa: exponent out of range")
    return Ok[RsaBigPublicKey](RsaBigPublicKey(n: nBig, e: eBig, modBits: modBits, modLen: modLen))

fn rsaBigPublicKeyFromParts(nBytes: Bytes, eBytes: Bytes): Result[RsaBigPublicKey] =
    let nBigRes: Result[BigInt] = bigFromBytes(nBytes)
    if IsErr(nBigRes):
        return Err[RsaBigPublicKey](Error(nBigRes))
    let eBigRes: Result[BigInt] = bigFromBytes(eBytes)
    if IsErr(eBigRes):
        return Err[RsaBigPublicKey](Error(eBigRes))
    let nBig: BigInt = Value(nBigRes)
    let eBig: BigInt = Value(eBigRes)
    let modBits: int32 = bigBitLen(nBig)
    let modLen: int32 = (modBits + 7) / 8
    if modBits <= 0 || modLen <= 0:
        return Err[RsaBigPublicKey]("rsa: invalid modulus")
    let one: BigInt = bigFromInt(1)
    if bigCmp(eBig, one) <= 0 || bigGetBit(eBig, 0) == 0:
        return Err[RsaBigPublicKey]("rsa: invalid exponent")
    if bigCmp(eBig, nBig) >= 0:
        return Err[RsaBigPublicKey]("rsa: exponent out of range")
    return Ok[RsaBigPublicKey](RsaBigPublicKey(n: nBig, e: eBig, modBits: modBits, modLen: modLen))

fn rsaPublicKeyPartsValid(nBytes: Bytes, eBytes: Bytes): bool =
    let nBigRes: Result[BigInt] = bigFromBytes(nBytes)
    if IsErr(nBigRes):
        return false
    let eBigRes: Result[BigInt] = bigFromBytes(eBytes)
    if IsErr(eBigRes):
        return false
    let nBig: BigInt = Value(nBigRes)
    let eBig: BigInt = Value(eBigRes)
    let modBits: int32 = bigBitLen(nBig)
    let modLen: int32 = (modBits + 7) / 8
    if modBits <= 0 || modLen <= 0:
        return false
    let one: BigInt = bigFromInt(1)
    if bigCmp(eBig, one) <= 0 || bigGetBit(eBig, 0) == 0:
        return false
    if bigCmp(eBig, nBig) >= 0:
        return false
    return true

fn rsaIsRsaEncryptionOid(oidValue: Bytes): bool =
    let expectRes: Result[Bytes] = rsaHexDecode("2a864886f70d010101")
    if IsErr(expectRes):
        return false
    return BytesEqual(oidValue, Value(expectRes))

fn rsaBigPrivateKeyFromPkcs1ValueInto(
    seqValue: Bytes,
    outN: var BigInt,
    outD: var BigInt,
    outModBits: var int32,
    outModLen: var int32
): Result[bool] =
    var offset: int32
    let vRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, offset)
    if IsErr(vRes):
        return Err[bool](Error(vRes))
    let vDecoded: Asn1ValueNext = Value(vRes)
    let vValue: Bytes = vDecoded.value
    offset = vDecoded.next
    let nRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, offset)
    if IsErr(nRes):
        return Err[bool](Error(nRes))
    let nDecoded: Asn1ValueNext = Value(nRes)
    let nValue: Bytes = nDecoded.value
    offset = nDecoded.next
    let eRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, offset)
    if IsErr(eRes):
        return Err[bool](Error(eRes))
    let eDecoded: Asn1ValueNext = Value(eRes)
    let eValue: Bytes = eDecoded.value
    offset = eDecoded.next
    let dRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, offset)
    if IsErr(dRes):
        return Err[bool](Error(dRes))
    let dDecoded: Asn1ValueNext = Value(dRes)
    let dValue: Bytes = dDecoded.value
    let vIntRes: Result[int64] = bytesToInt64(vValue)
    if IsErr(vIntRes) || Value(vIntRes) != 0:
        return Err[bool]("rsa: invalid private key version")
    let nBigRes: Result[BigInt] = bigFromBytes(nValue)
    if IsErr(nBigRes):
        return Err[bool](Error(nBigRes))
    let eBigRes: Result[BigInt] = bigFromBytes(eValue)
    if IsErr(eBigRes):
        return Err[bool](Error(eBigRes))
    let dBigRes: Result[BigInt] = bigFromBytes(dValue)
    if IsErr(dBigRes):
        return Err[bool](Error(dBigRes))
    let nBig: BigInt = Value(nBigRes)
    let eBig: BigInt = Value(eBigRes)
    let dBig: BigInt = Value(dBigRes)
    let modBits: int32 = bigBitLen(nBig)
    let modLen: int32 = (modBits + 7) / 8
    if modBits <= 0 || modLen <= 0:
        return Err[bool]("rsa: invalid modulus")
    let one: BigInt = bigFromInt(1)
    if bigCmp(eBig, one) <= 0 || bigGetBit(eBig, 0) == 0:
        return Err[bool]("rsa: invalid exponent")
    if bigCmp(eBig, nBig) >= 0:
        return Err[bool]("rsa: exponent out of range")
    if bigCmp(dBig, one) <= 0:
        return Err[bool]("rsa: invalid private exponent")
    outN = nBig
    outD = dBig
    outModBits = modBits
    outModLen = modLen
    return Ok[bool](true)

fn rsaBigPrivateKeyFromPkcs1Value(seqValue: Bytes): Result[RsaBigPrivateKey] =
    var nBig: BigInt
    var dBig: BigInt
    var modBits: int32
    var modLen: int32
    let fillRes: Result[bool] = rsaBigPrivateKeyFromPkcs1ValueInto(seqValue, nBig, dBig, modBits, modLen)
    if IsErr(fillRes):
        return Err[RsaBigPrivateKey](Error(fillRes))
    var out: RsaBigPrivateKey
    out.n = nBig
    out.d = dBig
    out.modBits = modBits
    out.modLen = modLen
    return Ok[RsaBigPrivateKey](out)

fn rsaBigPrivateKeyFromPkcs8ValueInto(
    seqValue: Bytes,
    outN: var BigInt,
    outD: var BigInt,
    outModBits: var int32,
    outModLen: var int32
): Result[bool] =
    var offset: int32
    let vRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, offset)
    if IsErr(vRes):
        return Err[bool](Error(vRes))
    let vDecoded: Asn1ValueNext = Value(vRes)
    let vValue: Bytes = vDecoded.value
    let vIntRes: Result[int64] = bytesToInt64(vValue)
    if IsErr(vIntRes) || (Value(vIntRes) != 0 && Value(vIntRes) != 1):
        return Err[bool]("rsa: invalid pkcs8 version")
    offset = vDecoded.next
    let algRes: Result[Asn1ValueNext] = asn1DecodeSequence(seqValue, offset)
    if IsErr(algRes):
        return Err[bool](Error(algRes))
    let algDecoded: Asn1ValueNext = Value(algRes)
    let algValue: Bytes = algDecoded.value
    let oidTlvRes: Result[Asn1TagValueNext] = asn1DecodeTlv(algValue, 0)
    if IsErr(oidTlvRes):
        return Err[bool](Error(oidTlvRes))
    let oidDecoded: Asn1TagValueNext = Value(oidTlvRes)
    let oidTag: int32 = oidDecoded.tag
    let oidValue: Bytes = oidDecoded.value
    let oidNext: int32 = oidDecoded.next
    if oidTag != asn1TagOid || ! rsaIsRsaEncryptionOid(oidValue):
        return Err[bool]("rsa: unsupported pkcs8 algorithm")
    if oidNext < BytesLen(algValue):
        let paramRes: Result[Asn1TagValueNext] = asn1DecodeTlv(algValue, oidNext)
        if IsErr(paramRes):
            return Err[bool](Error(paramRes))
        let paramDecoded: Asn1TagValueNext = Value(paramRes)
        if paramDecoded.tag != asn1TagNull:
            return Err[bool]("rsa: unsupported pkcs8 params")
    offset = algDecoded.next
    let keyRes: Result[Asn1TagValueNext] = asn1DecodeTlv(seqValue, offset)
    if IsErr(keyRes):
        return Err[bool](Error(keyRes))
    let keyDecoded: Asn1TagValueNext = Value(keyRes)
    let keyTag: int32 = keyDecoded.tag
    let keyValue: Bytes = keyDecoded.value
    if keyTag != asn1TagOctetString:
        return Err[bool]("rsa: pkcs8 private key ! octet string")
    return rsaBigPrivateKeyFromBytesInto(keyValue, outN, outD, outModBits, outModLen)

fn rsaBigPrivateKeyFromPkcs8Value(seqValue: Bytes): Result[RsaBigPrivateKey] =
    var nBig: BigInt
    var dBig: BigInt
    var modBits: int32
    var modLen: int32
    let fillRes: Result[bool] = rsaBigPrivateKeyFromPkcs8ValueInto(seqValue, nBig, dBig, modBits, modLen)
    if IsErr(fillRes):
        return Err[RsaBigPrivateKey](Error(fillRes))
    var out: RsaBigPrivateKey
    out.n = nBig
    out.d = dBig
    out.modBits = modBits
    out.modLen = modLen
    return Ok[RsaBigPrivateKey](out)

fn rsaBigPrivateKeyFromBytesInto(
    data: Bytes,
    outN: var BigInt,
    outD: var BigInt,
    outModBits: var int32,
    outModLen: var int32
): Result[bool] =
    let seqRes: Result[Asn1ValueNext] = asn1DecodeSequence(data, 0)
    if IsErr(seqRes):
        return Err[bool](Error(seqRes))
    let seqDecoded: Asn1ValueNext = Value(seqRes)
    let seqValue: Bytes = seqDecoded.value
    let vRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, 0)
    if IsErr(vRes):
        return Err[bool](Error(vRes))
    let vDecoded: Asn1ValueNext = Value(vRes)
    let nextRes: Result[Asn1TagValueNext] = asn1DecodeTlv(seqValue, vDecoded.next)
    if IsErr(nextRes):
        return Err[bool](Error(nextRes))
    let nextDecoded: Asn1TagValueNext = Value(nextRes)
    let nextTag: int32 = nextDecoded.tag
    if nextTag == asn1TagInteger:
        return rsaBigPrivateKeyFromPkcs1ValueInto(seqValue, outN, outD, outModBits, outModLen)
    if nextTag == asn1TagSequence:
        return rsaBigPrivateKeyFromPkcs8ValueInto(seqValue, outN, outD, outModBits, outModLen)
    return Err[bool]("rsa: unsupported private key format")

fn rsaBigPrivateKeyFromBytes(data: Bytes): Result[RsaBigPrivateKey] =
    var nBig: BigInt
    var dBig: BigInt
    var modBits: int32
    var modLen: int32
    let fillRes: Result[bool] = rsaBigPrivateKeyFromBytesInto(data, nBig, dBig, modBits, modLen)
    if IsErr(fillRes):
        return Err[RsaBigPrivateKey](Error(fillRes))
    var out: RsaBigPrivateKey
    out.n = nBig
    out.d = dBig
    out.modBits = modBits
    out.modLen = modLen
    return Ok[RsaBigPrivateKey](out)

fn rsaBigDecrypt(pub: RsaBigPublicKey, sig: Bytes): Result[Bytes] =
    if BytesLen(sig) <= 0:
        return Err[Bytes]("rsa: empty signature")
    if BytesLen(sig) > pub.modLen:
        return Err[Bytes]("rsa: signature too long")
    let sigRes: Result[BigInt] = bigFromBytes(sig)
    if IsErr(sigRes):
        return Err[Bytes](Error(sigRes))
    let sigBig: BigInt = Value(sigRes)
    if bigIsZero(sigBig):
        return Err[Bytes]("rsa: signature zero")
    if bigCmp(sigBig, pub.n) >= 0:
        return Err[Bytes]("rsa: signature out of range")
    let mRes: Result[BigInt] = rsaBigModExpSlow(sigBig, pub.e, pub.n)
    if IsErr(mRes):
        return Err[Bytes](Error(mRes))
    let em: Bytes = bigToBytes(Value(mRes), pub.modLen)
    return Ok[Bytes](em)

fn rsaBigDecryptBytes(nBytes: Bytes, eBytes: Bytes, sig: Bytes): Result[Bytes] =
    let nBigRes: Result[BigInt] = bigFromBytes(nBytes)
    if IsErr(nBigRes):
        return Err[Bytes](Error(nBigRes))
    let eBigRes: Result[BigInt] = bigFromBytes(eBytes)
    if IsErr(eBigRes):
        return Err[Bytes](Error(eBigRes))
    let nBig: BigInt = Value(nBigRes)
    let eBig: BigInt = Value(eBigRes)
    let modBits: int32 = bigBitLen(nBig)
    let modLen: int32 = (modBits + 7) / 8
    if modBits <= 0 || modLen <= 0:
        return Err[Bytes]("rsa: invalid modulus")
    let one: BigInt = bigFromInt(1)
    if bigCmp(eBig, one) <= 0 || bigGetBit(eBig, 0) == 0:
        return Err[Bytes]("rsa: invalid exponent")
    if bigCmp(eBig, nBig) >= 0:
        return Err[Bytes]("rsa: exponent out of range")
    if BytesLen(sig) <= 0:
        return Err[Bytes]("rsa: empty signature")
    if BytesLen(sig) > modLen:
        return Err[Bytes]("rsa: signature too long")
    let sigRes: Result[BigInt] = bigFromBytes(sig)
    if IsErr(sigRes):
        return Err[Bytes](Error(sigRes))
    let sigBig: BigInt = Value(sigRes)
    if bigIsZero(sigBig):
        return Err[Bytes]("rsa: signature zero")
    if bigCmp(sigBig, nBig) >= 0:
        return Err[Bytes]("rsa: signature out of range")
    let mRes: Result[BigInt] = rsaBigModExpSlow(sigBig, eBig, nBig)
    if IsErr(mRes):
        return Err[Bytes](Error(mRes))
    let em: Bytes = bigToBytes(Value(mRes), modLen)
    return Ok[Bytes](em)

fn rsaBigSignEmParts(nBig: BigInt, dBig: BigInt, modLen: int32, em: Bytes): Result[Bytes] =
    if BytesLen(em) != modLen:
        return Err[Bytes]("rsa: encoded message length mismatch")
    let emRes: Result[BigInt] = bigFromBytes(em)
    if IsErr(emRes):
        return Err[Bytes](Error(emRes))
    let emBig: BigInt = Value(emRes)
    if bigCmp(emBig, nBig) >= 0:
        return Err[Bytes]("rsa: encoded message too large")
    let sigRes: Result[BigInt] = rsaBigModExpSlow(emBig, dBig, nBig)
    if IsErr(sigRes):
        return Err[Bytes](Error(sigRes))
    let sigBig: BigInt = Value(sigRes)
    let sigBytes: Bytes = bigToBytes(sigBig, modLen)
    return Ok[Bytes](sigBytes)

fn rsaBigSignEm(priv: RsaBigPrivateKey, em: Bytes): Result[Bytes] =
    return rsaBigSignEmParts(priv.n, priv.d, priv.modLen, em)

fn rsaBigSignPkcs1(priv: RsaBigPrivateKey, msg: Bytes, useSha384: bool): Result[Bytes] =
    var digest: Bytes
    if useSha384:
        digest = rsaHashSha384(msg)
    else:
        digest = rsaHashSha256(msg)
    var diRes: Result[Bytes]
    if useSha384:
        diRes = rsaDigestInfoSha384(digest)
    else:
        diRes = rsaDigestInfoSha256(digest)
    if IsErr(diRes):
        return Err[Bytes](Error(diRes))
    let t: Bytes = Value(diRes)
    let emLen: int32 = priv.modLen
    let tLen: int32 = BytesLen(t)
    if emLen < tLen + 11:
        return Err[Bytes]("rsa: pkcs1 em too short")
    let psLen: int32 = emLen - tLen - 3
    let em: Bytes = BytesAlloc(emLen)
    BytesSet(em, 0, 0x00)
    BytesSet(em, 1, 0x01)
    for i in 0..<psLen:
        BytesSet(em, 2 + i, 0xff)
    BytesSet(em, 2 + psLen, 0x00)
    rsaCopyBytes(em, 3 + psLen, t, 0, tLen)
    return rsaBigSignEm(priv, em)

fn rsaBigSignPkcs1Pkcs1Value(pkcs1Value: Bytes, msg: Bytes, useSha384: bool): Result[Bytes] =
    let vRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, 0)
    if IsErr(vRes):
        return Err[Bytes](Error(vRes))
    let vDecoded: Asn1ValueNext = Value(vRes)
    let vIntRes: Result[int64] = bytesToInt64(vDecoded.value)
    if IsErr(vIntRes) || Value(vIntRes) != 0:
        return Err[Bytes]("rsa: invalid private key version")
    let nRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, vDecoded.next)
    if IsErr(nRes):
        return Err[Bytes](Error(nRes))
    let nDecoded: Asn1ValueNext = Value(nRes)
    let eRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, nDecoded.next)
    if IsErr(eRes):
        return Err[Bytes](Error(eRes))
    let eDecoded: Asn1ValueNext = Value(eRes)
    let dRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, eDecoded.next)
    if IsErr(dRes):
        return Err[Bytes](Error(dRes))
    let dDecoded: Asn1ValueNext = Value(dRes)
    let nBigRes: Result[BigInt] = bigFromBytes(nDecoded.value)
    if IsErr(nBigRes):
        return Err[Bytes](Error(nBigRes))
    let eBigRes: Result[BigInt] = bigFromBytes(eDecoded.value)
    if IsErr(eBigRes):
        return Err[Bytes](Error(eBigRes))
    let dBigRes: Result[BigInt] = bigFromBytes(dDecoded.value)
    if IsErr(dBigRes):
        return Err[Bytes](Error(dBigRes))
    let nBig: BigInt = Value(nBigRes)
    let eBig: BigInt = Value(eBigRes)
    let dBig: BigInt = Value(dBigRes)
    let modBits: int32 = bigBitLen(nBig)
    let modLen: int32 = (modBits + 7) / 8
    if modBits <= 0 || modLen <= 0:
        return Err[Bytes]("rsa: invalid modulus")
    let one: BigInt = bigFromInt(1)
    if bigCmp(eBig, one) <= 0 || bigGetBit(eBig, 0) == 0:
        return Err[Bytes]("rsa: invalid exponent")
    if bigCmp(eBig, nBig) >= 0:
        return Err[Bytes]("rsa: exponent out of range")
    if bigCmp(dBig, one) <= 0:
        return Err[Bytes]("rsa: invalid private exponent")
    var digest: Bytes
    if useSha384:
        digest = rsaHashSha384(msg)
    else:
        digest = rsaHashSha256(msg)
    var diRes: Result[Bytes]
    if useSha384:
        diRes = rsaDigestInfoSha384(digest)
    else:
        diRes = rsaDigestInfoSha256(digest)
    if IsErr(diRes):
        return Err[Bytes](Error(diRes))
    let t: Bytes = Value(diRes)
    if modLen < BytesLen(t) + 11:
        return Err[Bytes]("rsa: pkcs1 em too short")
    let psLen: int32 = modLen - BytesLen(t) - 3
    let em: Bytes = BytesAlloc(modLen)
    BytesSet(em, 0, 0x00)
    BytesSet(em, 1, 0x01)
    for i in 0..<psLen:
        BytesSet(em, 2 + i, 0xff)
    BytesSet(em, 2 + psLen, 0x00)
    rsaCopyBytes(em, 3 + psLen, t, 0, BytesLen(t))
    return rsaBigSignEmParts(nBig, dBig, modLen, em)

fn rsaBuildPssEncodedMessage(
    msg: Bytes,
    salt: Bytes,
    modBits: int32,
    modLen: int32,
    useSha384: bool
): Result[Bytes] =
    let hLen: int32 = if useSha384: rsaHashLenSha384() else: rsaHashLenSha256()
    let sLen: int32 = hLen
    if BytesLen(salt) != sLen:
        return Err[Bytes]("rsa: pss salt length mismatch")
    let emLen: int32 = modLen
    if emLen < hLen + sLen + 2:
        return Err[Bytes]("rsa: pss em too short")
    var mHash: Bytes
    if useSha384:
        mHash = rsaHashSha384(msg)
    else:
        mHash = rsaHashSha256(msg)
    let prefix: Bytes = BytesAlloc(8)
    let hMsg: Bytes = BytesConcat3(prefix, mHash, salt)
    var h: Bytes
    if useSha384:
        h = rsaHashSha384(hMsg)
    else:
        h = rsaHashSha256(hMsg)
    let hMaskSeed: Bytes = BytesSlice(h, 0, BytesLen(h))
    let hOut: Bytes = BytesSlice(h, 0, BytesLen(h))
    let psLen: int32 = emLen - sLen - hLen - 2
    if psLen < 0:
        return Err[Bytes]("rsa: pss ps len invalid")
    let dbLen: int32 = psLen + 1 + sLen
    let db: Bytes = BytesAlloc(dbLen)
    BytesSet(db, psLen, 0x01)
    rsaCopyBytes(db, psLen + 1, salt, 0, sLen)
    let dbExpected: Bytes = BytesSlice(db, 0, dbLen)
    let dbMask: Bytes = rsaMgf1(hMaskSeed, dbLen, useSha384)
    let maskedDb: Bytes = rsaBytesXorLen(db, dbMask, dbLen)
    let emBits: int32 = modBits - 1
    let unusedBits: int32 = emLen * 8 - emBits
    if unusedBits > 0:
        let mask: int32 = 0xff >> unusedBits
        BytesSet(maskedDb, 0, BytesGet(maskedDb, 0) & mask)
    let roundTripDb: Bytes = rsaBytesXorLen(maskedDb, dbMask, dbLen)
    if unusedBits > 0:
        let topMask: int32 = 0xff >> unusedBits
        BytesSet(roundTripDb, 0, BytesGet(roundTripDb, 0) & topMask)
        BytesSet(dbExpected, 0, BytesGet(dbExpected, 0) & topMask)
    if ! rsaBytesEqualLen(roundTripDb, dbExpected, dbLen):
        var i: int32
        for i in i..<dbLen:
            let got: int32 = BytesGet(roundTripDb, i)
            let want: int32 = BytesGet(dbExpected, i)
            if got != want:
                return Err[Bytes](
                    strutil.Join(["rsa: pss xor roundtrip mismatch at ", int64ToStr(i), " got ", int64ToStr(got), " want ", int64ToStr(want)], "")
                )
        return Err[Bytes]("rsa: pss xor roundtrip mismatch")
    let em: Bytes = BytesAlloc(emLen)
    rsaCopyBytes(em, 0, maskedDb, 0, emLen - hLen - 1)
    rsaCopyBytes(em, emLen - hLen - 1, hOut, 0, hLen)
    BytesSet(em, emLen - 1, 0xbc)
    return Ok[Bytes](em)

fn rsaBigSignPss(priv: RsaBigPrivateKey, msg: Bytes, useSha384: bool): Result[Bytes] =
    let hLen: int32 = if useSha384: rsaHashLenSha384() else: rsaHashLenSha256()
    let modBits: int32 = priv.modBits
    let modLen: int32 = priv.modLen
    let saltRes: Result[Bytes] = randomBytes(hLen)
    if IsErr(saltRes):
        return Err[Bytes](Error(saltRes))
    let salt: Bytes = Value(saltRes)
    let emRes: Result[Bytes] = rsaBuildPssEncodedMessage(
        msg,
        salt,
        modBits,
        modLen,
        useSha384
    )
    if IsErr(emRes):
        return Err[Bytes](Error(emRes))
    let em: Bytes = Value(emRes)
    let sigRes: Result[Bytes] = rsaBigSignEm(priv, em)
    if IsErr(sigRes):
        return Err[Bytes](Error(sigRes))
    let sig: Bytes = Value(sigRes)
    return Ok[Bytes](sig)

fn rsaPkcs1ValueFromPkcs8OuterSeqInto(
    outerSeqValue: Bytes,
    outerVersionValue: Bytes,
    algValue: Bytes,
    nextOffset: int32,
    outValue: var Bytes
): Result[bool] =
    let outerVersionIntRes: Result[int64] = bytesToInt64(outerVersionValue)
    if IsErr(outerVersionIntRes) || (Value(outerVersionIntRes) != 0 && Value(outerVersionIntRes) != 1):
        return Err[bool]("rsa: invalid pkcs8 version")
    let oidTlvRes: Result[Asn1TagValueNext] = asn1DecodeTlv(algValue, 0)
    if IsErr(oidTlvRes):
        return Err[bool](Error(oidTlvRes))
    let oidDecoded: Asn1TagValueNext = Value(oidTlvRes)
    let oidTag: int32 = oidDecoded.tag
    let oidValue: Bytes = oidDecoded.value
    let oidNext: int32 = oidDecoded.next
    if oidTag != asn1TagOid || ! rsaIsRsaEncryptionOid(oidValue):
        return Err[bool]("rsa: unsupported pkcs8 algorithm")
    if oidNext < BytesLen(algValue):
        let paramRes: Result[Asn1TagValueNext] = asn1DecodeTlv(algValue, oidNext)
        if IsErr(paramRes):
            return Err[bool](Error(paramRes))
        let paramDecoded: Asn1TagValueNext = Value(paramRes)
        if paramDecoded.tag != asn1TagNull:
            return Err[bool]("rsa: unsupported pkcs8 params")
    let keyRes: Result[Asn1TagValueNext] = asn1DecodeTlv(outerSeqValue, nextOffset)
    if IsErr(keyRes):
        return Err[bool](Error(keyRes))
    let keyDecoded: Asn1TagValueNext = Value(keyRes)
    let keyTag: int32 = keyDecoded.tag
    let keyValue: Bytes = keyDecoded.value
    if keyTag != asn1TagOctetString:
        return Err[bool]("rsa: pkcs8 private key ! octet string")
    let innerSeqRes: Result[Asn1ValueNext] = asn1DecodeSequence(keyValue, 0)
    if IsErr(innerSeqRes):
        return Err[bool](Error(innerSeqRes))
    outValue = Value(innerSeqRes).value
    return Ok[bool](true)

fn rsaPkcs1ValueFromPrivateKeyBodyInto(
    outerSeqValue: Bytes,
    outerVersionValue: Bytes,
    nextTag: int32,
    nextValue: Bytes,
    nextOffset: int32,
    outValue: var Bytes
): Result[bool] =
    if nextTag == asn1TagInteger:
        outValue = outerSeqValue
        return Ok[bool](true)
    if nextTag == asn1TagSequence:
        return rsaPkcs1ValueFromPkcs8OuterSeqInto(outerSeqValue, outerVersionValue, nextValue, nextOffset, outValue)
    return Err[bool]("rsa: unsupported private key format")

fn rsaPkcs1ValueFromPrivateKeyBytes(privData: Bytes): Result[Bytes] =
    let outerSeqRes: Result[Asn1ValueNext] = asn1DecodeSequence(privData, 0)
    if IsErr(outerSeqRes):
        return Err[Bytes](Error(outerSeqRes))
    let outerSeqDecoded: Asn1ValueNext = Value(outerSeqRes)
    let outerSeqValue: Bytes = outerSeqDecoded.value
    let outerVersionRes: Result[Asn1ValueNext] = asn1DecodeInteger(outerSeqValue, 0)
    if IsErr(outerVersionRes):
        return Err[Bytes](Error(outerVersionRes))
    let outerVersionDecoded: Asn1ValueNext = Value(outerVersionRes)
    let nextRes: Result[Asn1TagValueNext] = asn1DecodeTlv(outerSeqValue, outerVersionDecoded.next)
    if IsErr(nextRes):
        return Err[Bytes](Error(nextRes))
    let nextDecoded: Asn1TagValueNext = Value(nextRes)
    let nextTag: int32 = nextDecoded.tag
    let nextValue: Bytes = nextDecoded.value
    let nextOffset: int32 = nextDecoded.next
    let outerVersionValue: Bytes = outerVersionDecoded.value
    var outValue: Bytes
    let fillRes: Result[bool] = rsaPkcs1ValueFromPrivateKeyBodyInto(
        outerSeqValue,
        outerVersionValue,
        nextTag,
        nextValue,
        nextOffset,
        outValue
    )
    if IsErr(fillRes):
        return Err[Bytes](Error(fillRes))
    return Ok[Bytes](outValue)

fn rsaBigSignPssPkcs1Value(pkcs1Value: Bytes, msg: Bytes, useSha384: bool): Result[Bytes] =
    let vRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, 0)
    if IsErr(vRes):
        return Err[Bytes](Error(vRes))
    let vDecoded: Asn1ValueNext = Value(vRes)
    let vIntRes: Result[int64] = bytesToInt64(vDecoded.value)
    if IsErr(vIntRes) || Value(vIntRes) != 0:
        return Err[Bytes]("rsa: invalid private key version")
    let nRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, vDecoded.next)
    if IsErr(nRes):
        return Err[Bytes](Error(nRes))
    let nDecoded: Asn1ValueNext = Value(nRes)
    let eRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, nDecoded.next)
    if IsErr(eRes):
        return Err[Bytes](Error(eRes))
    let eDecoded: Asn1ValueNext = Value(eRes)
    let dRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, eDecoded.next)
    if IsErr(dRes):
        return Err[Bytes](Error(dRes))
    let dDecoded: Asn1ValueNext = Value(dRes)
    let nBigRes: Result[BigInt] = bigFromBytes(nDecoded.value)
    if IsErr(nBigRes):
        return Err[Bytes](Error(nBigRes))
    let eBigRes: Result[BigInt] = bigFromBytes(eDecoded.value)
    if IsErr(eBigRes):
        return Err[Bytes](Error(eBigRes))
    let dBigRes: Result[BigInt] = bigFromBytes(dDecoded.value)
    if IsErr(dBigRes):
        return Err[Bytes](Error(dBigRes))
    let nBig: BigInt = Value(nBigRes)
    let eBig: BigInt = Value(eBigRes)
    let dBig: BigInt = Value(dBigRes)
    let modBits: int32 = bigBitLen(nBig)
    let modLen: int32 = (modBits + 7) / 8
    if modBits <= 0 || modLen <= 0:
        return Err[Bytes]("rsa: invalid modulus")
    let one: BigInt = bigFromInt(1)
    if bigCmp(eBig, one) <= 0 || bigGetBit(eBig, 0) == 0:
        return Err[Bytes]("rsa: invalid exponent")
    if bigCmp(eBig, nBig) >= 0:
        return Err[Bytes]("rsa: exponent out of range")
    if bigCmp(dBig, one) <= 0:
        return Err[Bytes]("rsa: invalid private exponent")
    let hLen: int32 = if useSha384: rsaHashLenSha384() else: rsaHashLenSha256()
    let saltRes: Result[Bytes] = randomBytes(hLen)
    if IsErr(saltRes):
        return Err[Bytes](Error(saltRes))
    let salt: Bytes = Value(saltRes)
    let emRes: Result[Bytes] = rsaBuildPssEncodedMessage(msg, salt, modBits, modLen, useSha384)
    if IsErr(emRes):
        return Err[Bytes](Error(emRes))
    let em: Bytes = Value(emRes)
    return rsaBigSignEmParts(nBig, dBig, modLen, em)

fn rsaBigSignPssBytes(privData: Bytes, msg: Bytes, useSha384: bool): Result[Bytes] =
    let pkcs1ValueRes: Result[Bytes] = rsaPkcs1ValueFromPrivateKeyBytes(privData)
    if IsErr(pkcs1ValueRes):
        return Err[Bytes](Error(pkcs1ValueRes))
    return rsaBigSignPssPkcs1Value(Value(pkcs1ValueRes), msg, useSha384)

fn rsaBigSignPkcs1Bytes(privData: Bytes, msg: Bytes, useSha384: bool): Result[Bytes] =
    let pkcs1ValueRes: Result[Bytes] = rsaPkcs1ValueFromPrivateKeyBytes(privData)
    if IsErr(pkcs1ValueRes):
        return Err[Bytes](Error(pkcs1ValueRes))
    return rsaBigSignPkcs1Pkcs1Value(Value(pkcs1ValueRes), msg, useSha384)

fn rsaVerifyPkcs1(pub: RsaBigPublicKey, msg: Bytes, sig: Bytes, useSha384: bool): bool =
    var digest: Bytes
    if useSha384:
        digest = rsaHashSha384(msg)
    else:
        digest = rsaHashSha256(msg)
    var diRes: Result[Bytes]
    if useSha384:
        diRes = rsaDigestInfoSha384(digest)
    else:
        diRes = rsaDigestInfoSha256(digest)
    if IsErr(diRes):
        return false
    let t: Bytes = Value(diRes)
    let emRes: Result[Bytes] = rsaBigDecrypt(pub, sig)
    if IsErr(emRes):
        return false
    let em: Bytes = Value(emRes)
    let emLen: int32 = BytesLen(em)
    let tLen: int32 = BytesLen(t)
    if emLen < tLen + 11:
        return false
    if BytesGet(em, 0) != 0x00 || BytesGet(em, 1) != 0x01:
        return false
    let psLen: int32 = emLen - tLen - 3
    for i in 0..<psLen:
        if BytesGet(em, 2 + i) != 0xff:
            return false
    if BytesGet(em, 2 + psLen) != 0x00:
        return false
    let tStart: int32 = 3 + psLen
    let tBytes: Bytes = BytesSlice(em, tStart, tLen)
    return BytesEqual(tBytes, t)

fn rsaVerifyPkcs1Diag(pub: RsaBigPublicKey, msg: Bytes, sig: Bytes, useSha384: bool): Result[bool] =
    var digest: Bytes
    if useSha384:
        digest = rsaHashSha384(msg)
    else:
        digest = rsaHashSha256(msg)
    var diRes: Result[Bytes]
    if useSha384:
        diRes = rsaDigestInfoSha384(digest)
    else:
        diRes = rsaDigestInfoSha256(digest)
    if IsErr(diRes):
        return Err[bool]("rsa: digestinfo build failed")
    let t: Bytes = Value(diRes)
    let emRes: Result[Bytes] = rsaBigDecrypt(pub, sig)
    if IsErr(emRes):
        return Err[bool](strutil.Join(["rsa: decrypt failed: ", Error(emRes)], ""))
    let em: Bytes = Value(emRes)
    let emLen: int32 = BytesLen(em)
    let tLen: int32 = BytesLen(t)
    if emLen < tLen + 11:
        return Err[bool]("rsa: pkcs1 em too short")
    if BytesGet(em, 0) != 0x00 || BytesGet(em, 1) != 0x01:
        return Err[bool]("rsa: pkcs1 em prefix mismatch")
    let psLen: int32 = emLen - tLen - 3
    for i in 0..<psLen:
        if BytesGet(em, 2 + i) != 0xff:
            return Err[bool]("rsa: pkcs1 padding mismatch")
    if BytesGet(em, 2 + psLen) != 0x00:
        return Err[bool]("rsa: pkcs1 delimiter mismatch")
    let tStart: int32 = 3 + psLen
    let tBytes: Bytes = BytesSlice(em, tStart, tLen)
    if ! BytesEqual(tBytes, t):
        return Err[bool]("rsa: pkcs1 digestinfo mismatch")
    return Ok[bool](true)

fn rsaVerifyPkcs1EmDiag(msg: Bytes, em: Bytes, useSha384: bool): Result[bool] =
    var digest: Bytes
    if useSha384:
        digest = rsaHashSha384(msg)
    else:
        digest = rsaHashSha256(msg)
    var diRes: Result[Bytes]
    if useSha384:
        diRes = rsaDigestInfoSha384(digest)
    else:
        diRes = rsaDigestInfoSha256(digest)
    if IsErr(diRes):
        return Err[bool]("rsa: digestinfo build failed")
    let t: Bytes = Value(diRes)
    let emLen: int32 = BytesLen(em)
    let tLen: int32 = BytesLen(t)
    if emLen < tLen + 11:
        return Err[bool]("rsa: pkcs1 em too short")
    if BytesGet(em, 0) != 0x00 || BytesGet(em, 1) != 0x01:
        return Err[bool]("rsa: pkcs1 em prefix mismatch")
    let psLen: int32 = emLen - tLen - 3
    for i in 0..<psLen:
        if BytesGet(em, 2 + i) != 0xff:
            return Err[bool]("rsa: pkcs1 padding mismatch")
    if BytesGet(em, 2 + psLen) != 0x00:
        return Err[bool]("rsa: pkcs1 delimiter mismatch")
    let tStart: int32 = 3 + psLen
    let tBytes: Bytes = BytesSlice(em, tStart, tLen)
    if ! BytesEqual(tBytes, t):
        return Err[bool]("rsa: pkcs1 digestinfo mismatch")
    return Ok[bool](true)

fn rsaVerifyPkcs1Bytes(nBytes: Bytes, eBytes: Bytes, msg: Bytes, sig: Bytes, useSha384: bool): Result[bool] =
    let emRes: Result[Bytes] = rsaBigDecryptBytes(nBytes, eBytes, sig)
    if IsErr(emRes):
        return Err[bool](Error(emRes))
    return rsaVerifyPkcs1EmDiag(msg, Value(emRes), useSha384)

fn rsaVerifyPkcs1DiagBytes(nBytes: Bytes, eBytes: Bytes, msg: Bytes, sig: Bytes, useSha384: bool): Result[bool] =
    let emRes: Result[Bytes] = rsaBigDecryptBytes(nBytes, eBytes, sig)
    if IsErr(emRes):
        return Err[bool](strutil.Join(["rsa: decrypt failed: ", Error(emRes)], ""))
    return rsaVerifyPkcs1EmDiag(msg, Value(emRes), useSha384)

fn rsaVerifyPssEncodedMessageDiag(
    em: Bytes,
    msg: Bytes,
    modBits: int32,
    useSha384: bool
): Result[bool] =
    let hLen: int32 = if useSha384: rsaHashLenSha384() else: rsaHashLenSha256()
    let sLen: int32 = hLen
    let emLen: int32 = BytesLen(em)
    if emLen < hLen + sLen + 2:
        return Err[bool]("rsa: pss em too short")
    if BytesGet(em, emLen - 1) != 0xbc:
        return Err[bool]("rsa: pss trailer mismatch")
    let dbLen: int32 = emLen - hLen - 1
    let maskedDb: Bytes = BytesSlice(em, 0, dbLen)
    let h: Bytes = BytesSlice(em, dbLen, hLen)
    let hSeed: Bytes = BytesSlice(h, 0, BytesLen(h))
    let dbMask: Bytes = rsaMgf1(hSeed, dbLen, useSha384)
    let db: Bytes = rsaBytesXorLen(maskedDb, dbMask, dbLen)
    let emBits: int32 = modBits - 1
    let unusedBits: int32 = emLen * 8 - emBits
    if unusedBits > 0:
        let mask: int32 = 0xff ^((1 << (8 - unusedBits)) - 1)
        if (BytesGet(maskedDb, 0) & mask) != 0:
            return Err[bool]("rsa: pss maskeddb high bits set")
        BytesSet(db, 0, BytesGet(db, 0) & (0xff >> unusedBits))
    let psLen: int32 = dbLen - sLen - 1
    if psLen < 0:
        return Err[bool]("rsa: pss ps len invalid")
    var i: int32
    for i in i..<psLen:
        if BytesGet(db, i) != 0x00:
            return Err[bool]("rsa: pss ps mismatch")
    if BytesGet(db, psLen) != 0x01:
        return Err[bool]("rsa: pss delimiter mismatch")
    let salt: Bytes = BytesSlice(db, psLen + 1, sLen)
    var mHash: Bytes
    if useSha384:
        mHash = rsaHashSha384(msg)
    else:
        mHash = rsaHashSha256(msg)
    let prefix: Bytes = BytesAlloc(8)
    let hMsg: Bytes = BytesConcat3(prefix, mHash, salt)
    var h2: Bytes
    if useSha384:
        h2 = rsaHashSha384(hMsg)
    else:
        h2 = rsaHashSha256(hMsg)
    if ! BytesEqual(h, h2):
        return Err[bool]("rsa: pss hash mismatch")
    return Ok[bool](true)

fn rsaVerifyPssDiag(pub: RsaBigPublicKey, msg: Bytes, sig: Bytes, useSha384: bool): Result[bool] =
    let emRes: Result[Bytes] = rsaBigDecrypt(pub, sig)
    if IsErr(emRes):
        return Err[bool](strutil.Join(["rsa: pss decrypt failed: ", Error(emRes)], ""))
    return rsaVerifyPssEncodedMessageDiag(Value(emRes), msg, pub.modBits, useSha384)

fn rsaVerifyPss(pub: RsaBigPublicKey, msg: Bytes, sig: Bytes, useSha384: bool): bool =
    let res: Result[bool] = rsaVerifyPssDiag(pub, msg, sig, useSha384)
    if IsErr(res):
        return false
    return Value(res)

fn rsaVerifyPssDiagBytes(nBytes: Bytes, eBytes: Bytes, msg: Bytes, sig: Bytes, useSha384: bool): Result[bool] =
    let nBigRes: Result[BigInt] = bigFromBytes(nBytes)
    if IsErr(nBigRes):
        return Err[bool](Error(nBigRes))
    let eBigRes: Result[BigInt] = bigFromBytes(eBytes)
    if IsErr(eBigRes):
        return Err[bool](Error(eBigRes))
    let nBig: BigInt = Value(nBigRes)
    let eBig: BigInt = Value(eBigRes)
    let modBits: int32 = bigBitLen(nBig)
    let modLen: int32 = (modBits + 7) / 8
    if modBits <= 0 || modLen <= 0:
        return Err[bool]("rsa: invalid modulus")
    let one: BigInt = bigFromInt(1)
    if bigCmp(eBig, one) <= 0 || bigGetBit(eBig, 0) == 0:
        return Err[bool]("rsa: invalid exponent")
    if bigCmp(eBig, nBig) >= 0:
        return Err[bool]("rsa: exponent out of range")
    let emRes: Result[Bytes] = rsaBigDecryptBytes(nBytes, eBytes, sig)
    if IsErr(emRes):
        return Err[bool](strutil.Join(["rsa: pss decrypt failed: ", Error(emRes)], ""))
    return rsaVerifyPssEncodedMessageDiag(Value(emRes), msg, modBits, useSha384)

fn rsaVerifyPssBytes(nBytes: Bytes, eBytes: Bytes, msg: Bytes, sig: Bytes, useSha384: bool): Result[bool] =
    return rsaVerifyPssDiagBytes(nBytes, eBytes, msg, sig, useSha384)

fn rsaSign(priv: RsaPrivateKey, msg: Bytes): Result[Bytes] =
    if priv.n <= 0 || priv.d <= 0:
        return Err[Bytes]("rsa: invalid private key")
    let digest: Bytes = sha256Digest(msg)
    let m: int64 = bytesToInt64Mod(digest, priv.n)
    let s: int64 = powMod(m, priv.d, priv.n)
    let sig: Bytes = int64ToBytes(s)
    return Ok[Bytes](sig)

fn rsaVerify(pub: RsaPublicKey, msg: Bytes, sig: Bytes): bool =
    if pub.n <= 0 || pub.e <= 0:
        return false
    let sigValRes: Result[int64] = bytesToInt64(sig)
    if IsErr(sigValRes):
        return false
    let s: int64 = Value(sigValRes)
    let digest: Bytes = sha256Digest(msg)
    let m: int64 = bytesToInt64Mod(digest, pub.n)
    let v: int64 = powMod(s, pub.e, pub.n)
    return v == m

fn rsaPublicKeyToBytes(pub: RsaPublicKey): Bytes =
    let nEnc: Bytes = asn1EncodeInt64(pub.n)
    let eEnc: Bytes = asn1EncodeInt64(pub.e)
    var seq: ByteBuffer = newByteBuffer()
    appendBytes(seq, nEnc)
    appendBytes(seq, eEnc)
    return asn1EncodeSequence(toBytes(seq))

fn rsaBigPublicKeyToBytes(pub: RsaBigPublicKey): Bytes =
    let nEnc: Bytes = asn1EncodeInteger(bigToBytes(pub.n, pub.modLen))
    let eLen: int32 = (bigBitLen(pub.e) + 7) / 8
    let eEnc: Bytes = asn1EncodeInteger(bigToBytes(pub.e, eLen))
    var seq: ByteBuffer = newByteBuffer()
    appendBytes(seq, nEnc)
    appendBytes(seq, eEnc)
    return asn1EncodeSequence(toBytes(seq))

fn rsaBigPublicKeyToBytesParts(nBytes: Bytes, eBytes: Bytes): Bytes =
    let nEnc: Bytes = asn1EncodeInteger(nBytes)
    let eEnc: Bytes = asn1EncodeInteger(eBytes)
    var seq: ByteBuffer = newByteBuffer()
    appendBytes(seq, nEnc)
    appendBytes(seq, eEnc)
    return asn1EncodeSequence(toBytes(seq))

fn rsaPrivateKeyToBytes(priv: RsaPrivateKey): Bytes =
    let vEnc: Bytes = asn1EncodeInt64(0)
    let nEnc: Bytes = asn1EncodeInt64(priv.n)
    let eEnc: Bytes = asn1EncodeInt64(priv.e)
    let dEnc: Bytes = asn1EncodeInt64(priv.d)
    let pEnc: Bytes = asn1EncodeInt64(priv.p)
    let qEnc: Bytes = asn1EncodeInt64(priv.q)
    var seq: ByteBuffer = newByteBuffer()
    appendBytes(seq, vEnc)
    appendBytes(seq, nEnc)
    appendBytes(seq, eEnc)
    appendBytes(seq, dEnc)
    appendBytes(seq, pEnc)
    appendBytes(seq, qEnc)
    return asn1EncodeSequence(toBytes(seq))

fn rsaPublicKeyFromBytes(data: Bytes): Result[RsaPublicKey] =
    let seqRes: Result[Asn1ValueNext] = asn1DecodeSequence(data, 0)
    if IsErr(seqRes):
        return Err[RsaPublicKey](Error(seqRes))
    var offset: int32
    let seqValue: Bytes = Value(seqRes).value
    let nRes: Result[Asn1Int64Next] = asn1DecodeInt64(seqValue, offset)
    if IsErr(nRes):
        return Err[RsaPublicKey](Error(nRes))
    offset = Value(nRes).next
    let eRes: Result[Asn1Int64Next] = asn1DecodeInt64(seqValue, offset)
    if IsErr(eRes):
        return Err[RsaPublicKey](Error(eRes))
    let n: int64 = Value(nRes).value
    let e: int64 = Value(eRes).value
    if n <= 0 || e <= 0:
        return Err[RsaPublicKey]("rsa: invalid public key")
    return Ok[RsaPublicKey](RsaPublicKey(n: n, e: e))

fn rsaBigPublicKeyBytesInto(data: Bytes, outNBytes: var Bytes, outEBytes: var Bytes): Result[bool] =
    let seqRes: Result[Asn1ValueNext] = asn1DecodeSequence(data, 0)
    if IsErr(seqRes):
        return Err[bool](Error(seqRes))
    let seqValue: Bytes = Value(seqRes).value
    let nRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, 0)
    if IsErr(nRes):
        return Err[bool](Error(nRes))
    let nDecoded: Asn1ValueNext = Value(nRes)
    let eRes: Result[Asn1ValueNext] = asn1DecodeInteger(seqValue, nDecoded.next)
    if IsErr(eRes):
        return Err[bool](Error(eRes))
    let eDecoded: Asn1ValueNext = Value(eRes)
    if !rsaPublicKeyPartsValid(nDecoded.value, eDecoded.value):
        return Err[bool]("rsa: invalid public key parts")
    outNBytes = nDecoded.value
    outEBytes = eDecoded.value
    return Ok[bool](true)

fn rsaPrivateKeyFromBytes(data: Bytes): Result[RsaPrivateKey] =
    let seqRes: Result[Asn1ValueNext] = asn1DecodeSequence(data, 0)
    if IsErr(seqRes):
        return Err[RsaPrivateKey](Error(seqRes))
    var offset: int32
    let seqValue: Bytes = Value(seqRes).value
    let vRes: Result[Asn1Int64Next] = asn1DecodeInt64(seqValue, offset)
    if IsErr(vRes):
        return Err[RsaPrivateKey](Error(vRes))
    offset = Value(vRes).next
    let nRes: Result[Asn1Int64Next] = asn1DecodeInt64(seqValue, offset)
    if IsErr(nRes):
        return Err[RsaPrivateKey](Error(nRes))
    offset = Value(nRes).next
    let eRes: Result[Asn1Int64Next] = asn1DecodeInt64(seqValue, offset)
    if IsErr(eRes):
        return Err[RsaPrivateKey](Error(eRes))
    offset = Value(eRes).next
    let dRes: Result[Asn1Int64Next] = asn1DecodeInt64(seqValue, offset)
    if IsErr(dRes):
        return Err[RsaPrivateKey](Error(dRes))
    offset = Value(dRes).next
    let pRes: Result[Asn1Int64Next] = asn1DecodeInt64(seqValue, offset)
    if IsErr(pRes):
        return Err[RsaPrivateKey](Error(pRes))
    offset = Value(pRes).next
    let qRes: Result[Asn1Int64Next] = asn1DecodeInt64(seqValue, offset)
    if IsErr(qRes):
        return Err[RsaPrivateKey](Error(qRes))
    let n: int64 = Value(nRes).value
    let e: int64 = Value(eRes).value
    let d: int64 = Value(dRes).value
    let p: int64 = Value(pRes).value
    let q: int64 = Value(qRes).value
    if n <= 0 || e <= 0 || d <= 0:
        return Err[RsaPrivateKey]("rsa: invalid private key")
    return Ok[RsaPrivateKey](RsaPrivateKey(n: n, e: e, d: d, p: p, q: q))

fn validateRsaPublicKeyBytes(data: Bytes): bool =
    var nBytes: Bytes
    var eBytes: Bytes
    let bigRes: Result[bool] = rsaBigPublicKeyBytesInto(data, nBytes, eBytes)
    if IsOk(bigRes):
        return true
    let res: Result[RsaPublicKey] = rsaPublicKeyFromBytes(data)
    return IsOk(res)

fn validateRsaPrivateKeyBytes(data: Bytes): bool =
    let bigRes: Result[RsaBigPrivateKey] = rsaBigPrivateKeyFromBytes(data)
    if IsOk(bigRes):
        return true
    let res: Result[RsaPrivateKey] = rsaPrivateKeyFromBytes(data)
    return IsOk(res)

fn validateRsaSignatureBytes(data: Bytes): bool =
    return BytesLen(data) > 0

fn rsaSignBytes(privData: Bytes, msg: Bytes): Result[Bytes] =
    let bigRes: Result[RsaBigPrivateKey] = rsaBigPrivateKeyFromBytes(privData)
    if IsOk(bigRes):
        let priv: RsaBigPrivateKey = Value(bigRes)
        let sigRes: Result[Bytes] = rsaBigSignPkcs1(priv, msg, false)
        if IsErr(sigRes):
            return Err[Bytes](Error(sigRes))
        return sigRes
    let privRes: Result[RsaPrivateKey] = rsaPrivateKeyFromBytes(privData)
    if IsErr(privRes):
        return Err[Bytes](Error(privRes))
    return rsaSign(Value(privRes), msg)

fn rsaVerifyBytes(pubData: Bytes, msg: Bytes, sig: Bytes): bool =
    var nBytes: Bytes
    var eBytes: Bytes
    let bigRes: Result[bool] = rsaBigPublicKeyBytesInto(pubData, nBytes, eBytes)
    if IsOk(bigRes):
        let pkcs1Sha256Res = rsaVerifyPkcs1Bytes(nBytes, eBytes, msg, sig, false)
        if IsOk(pkcs1Sha256Res) && Value(pkcs1Sha256Res):
            return true
        let pkcs1Sha384Res = rsaVerifyPkcs1Bytes(nBytes, eBytes, msg, sig, true)
        if IsOk(pkcs1Sha384Res) && Value(pkcs1Sha384Res):
            return true
        let pssSha256Res = rsaVerifyPssBytes(nBytes, eBytes, msg, sig, false)
        if IsOk(pssSha256Res) && Value(pssSha256Res):
            return true
        let pssSha384Res = rsaVerifyPssBytes(nBytes, eBytes, msg, sig, true)
        if IsOk(pssSha384Res) && Value(pssSha384Res):
            return true
    let pubRes: Result[RsaPublicKey] = rsaPublicKeyFromBytes(pubData)
    if IsErr(pubRes):
        return false
    return rsaVerify(Value(pubRes), msg, sig)

fn rsaPublicKeyFromPrivateBytes(privData: Bytes): Result[Bytes] =
    var bigOut: Bytes
    let bigRes: Result[bool] = rsaBigPublicKeyFromPrivateBytesInto(bigOut, privData)
    if IsOk(bigRes):
        return Ok[Bytes](bigOut)
    let privRes: Result[RsaPrivateKey] = rsaPrivateKeyFromBytes(privData)
    if IsErr(privRes):
        return Err[Bytes](Error(privRes))
    let pub: RsaPublicKey = rsaPublicKeyFromPrivate(Value(privRes))
    return Ok[Bytes](rsaPublicKeyToBytes(pub))

fn rsaBigPublicKeyFromPrivateBytesInto(out: var Bytes, privData: Bytes): Result[bool] =
    let pkcs1Res: Result[Bytes] = rsaPkcs1ValueFromPrivateKeyBytes(privData)
    if IsErr(pkcs1Res):
        return Err[bool](Error(pkcs1Res))
    let pkcs1Value: Bytes = Value(pkcs1Res)
    let vRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, 0)
    if IsErr(vRes):
        return Err[bool](Error(vRes))
    let vDecoded: Asn1ValueNext = Value(vRes)
    let vIntRes: Result[int64] = bytesToInt64(vDecoded.value)
    if IsErr(vIntRes) || Value(vIntRes) != 0:
        return Err[bool]("rsa: invalid private key version")
    let nRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, vDecoded.next)
    if IsErr(nRes):
        return Err[bool](Error(nRes))
    let nDecoded: Asn1ValueNext = Value(nRes)
    let eRes: Result[Asn1ValueNext] = asn1DecodeInteger(pkcs1Value, nDecoded.next)
    if IsErr(eRes):
        return Err[bool](Error(eRes))
    let nBytes: Bytes = nDecoded.value
    let eBytes: Bytes = Value(eRes).value
    if !rsaPublicKeyPartsValid(nBytes, eBytes):
        return Err[bool]("rsa: invalid public key parts")
    out = rsaBigPublicKeyToBytesParts(nBytes, eBytes)
    return Ok[bool](true)

fn rsaBigPublicKeyFromPrivateBytes(privData: Bytes): Result[Bytes] =
    var out: Bytes
    let fillRes: Result[bool] = rsaBigPublicKeyFromPrivateBytesInto(out, privData)
    if IsErr(fillRes):
        return Err[Bytes](Error(fillRes))
    return Ok[Bytes](out)
