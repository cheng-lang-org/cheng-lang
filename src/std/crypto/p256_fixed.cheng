import std/result
import std/rawbytes
import std/system
import std/strings
import std/crypto/bigint
import std/strutils as strutil

const
    p256FixedLimbCount: int32 = 8
    p256FixedWordBits: int32 = 32

type
    P256Fixed =
        limbs: int32[p256FixedLimbCount]

    P256FixedAddRawResult =
        value: P256Fixed
        carry: uint64

    P256FixedSubRawResult =
        value: P256Fixed
        borrow: uint64

    P256FixedMontgomeryContext =
        modulus: P256Fixed
        n0Inv: uint64
        r2: P256Fixed
        oneMont: P256Fixed

    P256FixedMontgomeryScratch =
        words: int32[17]

fn p256FixedScratchZero(scratch: var P256FixedMontgomeryScratch) =
    for i in 0..<17:
        scratch.words[i] = 0

fn p256FixedLowWordBitsU64(v: uint64): uint64 =
    return v - ((v >> uint64(p256FixedWordBits)) << uint64(p256FixedWordBits))

fn p256FixedSquareAccumulate(c0: var uint64,
                             c1: var uint64,
                             c2: var uint64,
                             loWord: uint64,
                             hiWord: uint64) =
    c0 = c0 + loWord
    c1 = c1 + hiWord + (c0 >> uint64(p256FixedWordBits))
    c0 = p256FixedLowWordBitsU64(c0)
    c2 = c2 + (c1 >> uint64(p256FixedWordBits))
    c1 = p256FixedLowWordBitsU64(c1)

fn p256FixedSquareBuildScratch(a: var P256Fixed): Result[P256FixedMontgomeryScratch] =
    var scratch: P256FixedMontgomeryScratch
    p256FixedScratchZero(scratch)
    var c0: uint64 = uint64(0)
    var c1: uint64 = uint64(0)
    var c2: uint64 = uint64(0)
    for k in 0..<(p256FixedLimbCount * 2):
        var iStart: int32
        if k >= p256FixedLimbCount:
            iStart = k - (p256FixedLimbCount - 1)
        var iEnd: int32 = k
        if iEnd >= p256FixedLimbCount:
            iEnd = p256FixedLimbCount - 1
        var i: int32 = iStart
        while i <= iEnd:
            let j: int32 = k - i
            if i > j:
                break
            let ai: uint64 = p256FixedWordToBitsU64(a.limbs[i])
            let aj: uint64 = p256FixedWordToBitsU64(a.limbs[j])
            let prod: uint64 = ai * aj
            if i == j:
                p256FixedSquareAccumulate(c0,
                                          c1,
                                          c2,
                                          p256FixedLowWordBitsU64(prod),
                                          prod >> uint64(p256FixedWordBits))
            else:
                let prodLo: uint64 = p256FixedLowWordBitsU64(prod)
                let prodHi: uint64 = prod >> uint64(p256FixedWordBits)
                let dblLo: uint64 = p256FixedLowWordBitsU64(prodLo << uint64(1))
                let dblHi: uint64 = (prodHi << uint64(1)) + (prodLo >> uint64(31))
                p256FixedSquareAccumulate(c0, c1, c2, dblLo, dblHi)
            i = i + 1
        scratch.words[k] = p256FixedWordFromBitsU64(c0)
        c0 = c1
        c1 = c2
        c2 = uint64(0)
    if c0 != uint64(0) || c1 != uint64(0):
        return Err[P256FixedMontgomeryScratch]("p256_fixed: square comba overflow")
    return Ok[P256FixedMontgomeryScratch](scratch)

fn p256FixedWordToBitsU64(w: int32): uint64 =
    if w >= 0:
        return uint64(w)
    let mag: int64 = int64(0) - int64(w)
    return (uint64(1) << uint64(p256FixedWordBits)) - uint64(mag)

fn p256FixedWordFromBitsU64(v: uint64): int32 =
    let low: uint64 = p256FixedLowWordBitsU64(v)
    let signCut: uint64 = uint64(1) << uint64(p256FixedWordBits - 1)
    if low < signCut:
        return int32(low)
    let gap: uint64 = (uint64(1) << uint64(p256FixedWordBits)) - low
    return 0 - int32(gap)

fn p256FixedOne(): P256Fixed =
    var out: P256Fixed
    out.limbs[0] = 1
    return out

fn p256FieldModulus(): P256Fixed =
    var out: P256Fixed
    out.limbs[0] = int32(uint32(0xffffffff))
    out.limbs[1] = int32(uint32(0xffffffff))
    out.limbs[2] = int32(uint32(0xffffffff))
    out.limbs[3] = 0
    out.limbs[4] = 0
    out.limbs[5] = 0
    out.limbs[6] = 1
    out.limbs[7] = int32(uint32(0xffffffff))
    return out

fn p256FieldR2(): P256Fixed =
    var out: P256Fixed
    out.limbs[0] = 3
    out.limbs[1] = 0
    out.limbs[2] = int32(uint32(0xffffffff))
    out.limbs[3] = int32(uint32(0xfffffffb))
    out.limbs[4] = int32(uint32(0xfffffffe))
    out.limbs[5] = int32(uint32(0xffffffff))
    out.limbs[6] = int32(uint32(0xfffffffd))
    out.limbs[7] = 4
    return out

fn p256FieldOneMont(): P256Fixed =
    var out: P256Fixed
    out.limbs[0] = 1
    out.limbs[1] = 0
    out.limbs[2] = 0
    out.limbs[3] = int32(uint32(0xffffffff))
    out.limbs[4] = int32(uint32(0xffffffff))
    out.limbs[5] = int32(uint32(0xffffffff))
    out.limbs[6] = int32(uint32(0xfffffffe))
    out.limbs[7] = 0
    return out

fn p256FieldMontgomeryContext(): P256FixedMontgomeryContext =
    var out: P256FixedMontgomeryContext
    out.modulus = p256FieldModulus()
    out.n0Inv = uint64(1)
    out.r2 = p256FieldR2()
    out.oneMont = p256FieldOneMont()
    return out

fn p256ScalarModulus(): P256Fixed =
    var out: P256Fixed
    out.limbs[0] = int32(uint32(0xfc632551))
    out.limbs[1] = int32(uint32(0xf3b9cac2))
    out.limbs[2] = int32(uint32(0xa7179e84))
    out.limbs[3] = int32(uint32(0xbce6faad))
    out.limbs[4] = int32(uint32(0xffffffff))
    out.limbs[5] = int32(uint32(0xffffffff))
    out.limbs[6] = 0
    out.limbs[7] = int32(uint32(0xffffffff))
    return out

fn p256ScalarR2(): P256Fixed =
    var out: P256Fixed
    out.limbs[0] = int32(uint32(0xbe79eea2))
    out.limbs[1] = int32(uint32(0x83244c95))
    out.limbs[2] = int32(uint32(0x49bd6fa6))
    out.limbs[3] = int32(uint32(0x4699799c))
    out.limbs[4] = int32(uint32(0x2b6bec59))
    out.limbs[5] = int32(uint32(0x2845b239))
    out.limbs[6] = int32(uint32(0xf3d95620))
    out.limbs[7] = int32(uint32(0x66e12d94))
    return out

fn p256ScalarOneMont(): P256Fixed =
    var out: P256Fixed
    out.limbs[0] = int32(uint32(0x039cdaaf))
    out.limbs[1] = int32(uint32(0x0c46353d))
    out.limbs[2] = int32(uint32(0x58e8617b))
    out.limbs[3] = int32(uint32(0x43190552))
    out.limbs[4] = 0
    out.limbs[5] = 0
    out.limbs[6] = int32(uint32(0xffffffff))
    out.limbs[7] = 0
    return out

fn p256ScalarMontgomeryContext(): P256FixedMontgomeryContext =
    var out: P256FixedMontgomeryContext
    out.modulus = p256ScalarModulus()
    out.n0Inv = uint64(0xee00bc4f)
    out.r2 = p256ScalarR2()
    out.oneMont = p256ScalarOneMont()
    return out

fn p256FixedIsZero(a: var P256Fixed): bool =
    for i in 0..<p256FixedLimbCount:
        if a.limbs[i] != 0:
            return false
    return true

fn p256FixedCmp(a: var P256Fixed, b: var P256Fixed): int32 =
    let __for_start_i = p256FixedLimbCount - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        let av: uint64 = p256FixedWordToBitsU64(a.limbs[i])
        let bv: uint64 = p256FixedWordToBitsU64(b.limbs[i])
        if av < bv:
            return -1
        if av > bv:
            return 1
    return 0

fn p256FixedReadBytesBE32(data: Bytes, offset: int32): Result[P256Fixed] =
    if offset < 0 || offset + 32 > bytesLen(data):
        return Err[P256Fixed]("p256_fixed: need 32 bytes")
    var out: P256Fixed
    var limb: int32
    while limb < p256FixedLimbCount:
        let base: int32 = offset + 28 - limb * 4
        let b0: int64 = int64(bytesGet(data, base))
        let b1: int64 = int64(bytesGet(data, base + 1))
        let b2: int64 = int64(bytesGet(data, base + 2))
        let b3: int64 = int64(bytesGet(data, base + 3))
        let word: int64 = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
        out.limbs[limb] = int32(uint32(word))
        limb = limb + 1
    return Ok[P256Fixed](out)

fn p256FixedFromBytesBE32(data: Bytes): Result[P256Fixed] =
    return p256FixedReadBytesBE32(data, 0)

fn p256FixedFromBigIntFill(out: var P256Fixed, value: var BigInt): Result[bool] =
    if value.count < 0 || value.count > p256FixedLimbCount:
        return Err[bool]("p256_fixed: bigint does not fit fixed-256")
    for i in 0..<p256FixedLimbCount:
        out.limbs[i] = 0
    for i in 0..<value.count:
        out.limbs[i] = value.limbs[i]
    return Ok[bool](true)

fn p256FixedFromBigInt(value: var BigInt): Result[P256Fixed] =
    var out: P256Fixed
    let fillRes = p256FixedFromBigIntFill(out, value)
    if IsErr(fillRes):
        return Err[P256Fixed](Error(fillRes))
    return Ok[P256Fixed](out)

fn p256FixedToBigInt(value: var P256Fixed): BigInt =
    var out: BigInt
    out.count = p256FixedLimbCount
    for i in 0..<p256FixedLimbCount:
        out.limbs[i] = value.limbs[i]
    bigNormalize(out)
    return out

fn p256FixedNormalizeInput(value: var P256Fixed, modulus: var P256Fixed): Result[P256Fixed] =
    if p256FixedCmp(value, modulus) < 0:
        return Ok[P256Fixed](value)
    let modRes: Result[BigInt] = bigMod(p256FixedToBigInt(value), p256FixedToBigInt(modulus))
    if IsErr(modRes):
        return Err[P256Fixed](Error(modRes))
    var modValue: BigInt = Value(modRes)
    return p256FixedFromBigInt(modValue)

fn p256FixedAddRaw(a: var P256Fixed, b: var P256Fixed): P256FixedAddRawResult =
    var out: P256FixedAddRawResult
    p256FixedAddRawInto(out.value, out.carry, a, b)
    return out

fn p256FixedSubRaw(a: var P256Fixed, b: var P256Fixed): P256FixedSubRawResult =
    var out: P256FixedSubRawResult
    p256FixedSubRawInto(out.value, out.borrow, a, b)
    return out

fn p256FixedAddRawStep(outWord: var int32,
                       carryOut: var int32,
                       av: uint64,
                       bv: uint64,
                       carryIn: int32) =
    let sum: uint64 = av + bv + uint64(carryIn)
    outWord = p256FixedWordFromBitsU64(sum)
    carryOut = int32(sum >> uint64(p256FixedWordBits))

fn p256FixedSubRawStep(outWord: var int32,
                       borrowOut: var int32,
                       av: uint64,
                       bv: uint64,
                       borrowIn: int32) =
    let wordBase: uint64 = uint64(1) << uint64(p256FixedWordBits)
    let subWord: uint64 = bv + uint64(borrowIn)
    if av >= subWord:
        outWord = p256FixedWordFromBitsU64(av - subWord)
        borrowOut = 0
    else:
        outWord = p256FixedWordFromBitsU64(wordBase + av - subWord)
        borrowOut = 1

fn p256FixedAddRawInto(out: var P256Fixed,
                       carry: var uint64,
                       a: var P256Fixed,
                       b: var P256Fixed) =
    var carry0 = 0
    var carry1 = 0
    var carry2 = 0
    var carry3 = 0
    var carry4 = 0
    var carry5 = 0
    var carry6 = 0
    var carry7 = 0
    var carry8 = 0
    p256FixedAddRawStep(out.limbs[0], carry1, p256FixedWordToBitsU64(a.limbs[0]), p256FixedWordToBitsU64(b.limbs[0]), carry0)
    p256FixedAddRawStep(out.limbs[1], carry2, p256FixedWordToBitsU64(a.limbs[1]), p256FixedWordToBitsU64(b.limbs[1]), carry1)
    p256FixedAddRawStep(out.limbs[2], carry3, p256FixedWordToBitsU64(a.limbs[2]), p256FixedWordToBitsU64(b.limbs[2]), carry2)
    p256FixedAddRawStep(out.limbs[3], carry4, p256FixedWordToBitsU64(a.limbs[3]), p256FixedWordToBitsU64(b.limbs[3]), carry3)
    p256FixedAddRawStep(out.limbs[4], carry5, p256FixedWordToBitsU64(a.limbs[4]), p256FixedWordToBitsU64(b.limbs[4]), carry4)
    p256FixedAddRawStep(out.limbs[5], carry6, p256FixedWordToBitsU64(a.limbs[5]), p256FixedWordToBitsU64(b.limbs[5]), carry5)
    p256FixedAddRawStep(out.limbs[6], carry7, p256FixedWordToBitsU64(a.limbs[6]), p256FixedWordToBitsU64(b.limbs[6]), carry6)
    p256FixedAddRawStep(out.limbs[7], carry8, p256FixedWordToBitsU64(a.limbs[7]), p256FixedWordToBitsU64(b.limbs[7]), carry7)
    carry = uint64(carry8)

fn p256FixedSubRawInto(out: var P256Fixed,
                       borrow: var uint64,
                       a: var P256Fixed,
                       b: var P256Fixed) =
    var borrow0 = 0
    var borrow1 = 0
    var borrow2 = 0
    var borrow3 = 0
    var borrow4 = 0
    var borrow5 = 0
    var borrow6 = 0
    var borrow7 = 0
    var borrow8 = 0
    p256FixedSubRawStep(out.limbs[0], borrow1, p256FixedWordToBitsU64(a.limbs[0]), p256FixedWordToBitsU64(b.limbs[0]), borrow0)
    p256FixedSubRawStep(out.limbs[1], borrow2, p256FixedWordToBitsU64(a.limbs[1]), p256FixedWordToBitsU64(b.limbs[1]), borrow1)
    p256FixedSubRawStep(out.limbs[2], borrow3, p256FixedWordToBitsU64(a.limbs[2]), p256FixedWordToBitsU64(b.limbs[2]), borrow2)
    p256FixedSubRawStep(out.limbs[3], borrow4, p256FixedWordToBitsU64(a.limbs[3]), p256FixedWordToBitsU64(b.limbs[3]), borrow3)
    p256FixedSubRawStep(out.limbs[4], borrow5, p256FixedWordToBitsU64(a.limbs[4]), p256FixedWordToBitsU64(b.limbs[4]), borrow4)
    p256FixedSubRawStep(out.limbs[5], borrow6, p256FixedWordToBitsU64(a.limbs[5]), p256FixedWordToBitsU64(b.limbs[5]), borrow5)
    p256FixedSubRawStep(out.limbs[6], borrow7, p256FixedWordToBitsU64(a.limbs[6]), p256FixedWordToBitsU64(b.limbs[6]), borrow6)
    p256FixedSubRawStep(out.limbs[7], borrow8, p256FixedWordToBitsU64(a.limbs[7]), p256FixedWordToBitsU64(b.limbs[7]), borrow7)
    borrow = uint64(borrow8)

fn p256FixedMontgomeryAddMulAt(scratch: var P256FixedMontgomeryScratch,
                               offset: int32,
                               mulWord: uint64,
                               multiplicand: var P256Fixed): Result[bool] =
    if mulWord == uint64(0):
        return Ok[bool](true)
    var carry: uint64 = uint64(0)
    for j in 0..<p256FixedLimbCount:
        let bv: uint64 = p256FixedWordToBitsU64(multiplicand.limbs[j])
        let cur: uint64 = p256FixedWordToBitsU64(scratch.words[offset + j])
        let prod: uint64 = mulWord * bv
        let prodLo: uint64 = p256FixedLowWordBitsU64(prod)
        let prodHi: uint64 = prod >> uint64(p256FixedWordBits)
        let sumLo: uint64 = cur + prodLo + carry
        scratch.words[offset + j] = p256FixedWordFromBitsU64(sumLo)
        carry = prodHi + (sumLo >> uint64(p256FixedWordBits))
    var carryIdx: int32 = offset + p256FixedLimbCount
    while carry != uint64(0):
        if carryIdx >= 17:
            return Err[bool](strutil.Join(["p256_fixed: montgomery carry overflow offset=", intToStr(offset), " idx=", intToStr(carryIdx)], ""))
        let cur: uint64 = p256FixedWordToBitsU64(scratch.words[carryIdx])
        let sum: uint64 = cur + carry
        scratch.words[carryIdx] = p256FixedWordFromBitsU64(sum)
        carry = sum >> uint64(p256FixedWordBits)
        carryIdx = carryIdx + 1
    return Ok[bool](true)

fn p256FixedMontgomeryAddMulAtTrusted(scratch: var P256FixedMontgomeryScratch,
                                      offset: int32,
                                      mulWord: uint64,
                                      multiplicand: var P256Fixed) =
    if mulWord == uint64(0):
        return
    var carry: uint64 = uint64(0)
    for j in 0..<p256FixedLimbCount:
        let bv: uint64 = p256FixedWordToBitsU64(multiplicand.limbs[j])
        let cur: uint64 = p256FixedWordToBitsU64(scratch.words[offset + j])
        let prod: uint64 = mulWord * bv
        let prodLo: uint64 = p256FixedLowWordBitsU64(prod)
        let prodHi: uint64 = prod >> uint64(p256FixedWordBits)
        let sumLo: uint64 = cur + prodLo + carry
        scratch.words[offset + j] = p256FixedWordFromBitsU64(sumLo)
        carry = prodHi + (sumLo >> uint64(p256FixedWordBits))
    var carryIdx: int32 = offset + p256FixedLimbCount
    while carry != uint64(0):
        assert(carryIdx < 17, "p256_fixed: montgomery carry overflow")
        let cur: uint64 = p256FixedWordToBitsU64(scratch.words[carryIdx])
        let sum: uint64 = cur + carry
        scratch.words[carryIdx] = p256FixedWordFromBitsU64(sum)
        carry = sum >> uint64(p256FixedWordBits)
        carryIdx = carryIdx + 1

fn p256FixedSubtractModulusWithHigh(value: var P256Fixed,
                                    highWord: uint64,
                                    modulus: var P256Fixed): Result[P256Fixed] =
    var out: P256Fixed = value
    var borrow: uint64 = uint64(0)
    let wordBase: uint64 = uint64(1) << uint64(p256FixedWordBits)
    for i in 0..<p256FixedLimbCount:
        let av: uint64 = p256FixedWordToBitsU64(out.limbs[i])
        let bv: uint64 = p256FixedWordToBitsU64(modulus.limbs[i])
        let subWord: uint64 = bv + borrow
        if av >= subWord:
            out.limbs[i] = p256FixedWordFromBitsU64(av - subWord)
            borrow = uint64(0)
        else:
            out.limbs[i] = p256FixedWordFromBitsU64(wordBase + av - subWord)
            borrow = uint64(1)
    if highWord < borrow:
        return Err[P256Fixed]("p256_fixed: montgomery high borrow underflow")
    let reducedHigh: uint64 = highWord - borrow
    if reducedHigh != uint64(0):
        return Err[P256Fixed](strutil.Join(["p256_fixed: montgomery reduced high overflow=", uint64ToStr(reducedHigh)], ""))
    return Ok[P256Fixed](out)

fn p256FixedSubtractModulusWithHighTrusted(value: var P256Fixed,
                                           highWord: uint64,
                                           modulus: var P256Fixed): P256Fixed =
    var out: P256Fixed = value
    var borrow: uint64 = uint64(0)
    let wordBase: uint64 = uint64(1) << uint64(p256FixedWordBits)
    for i in 0..<p256FixedLimbCount:
        let av: uint64 = p256FixedWordToBitsU64(out.limbs[i])
        let bv: uint64 = p256FixedWordToBitsU64(modulus.limbs[i])
        let subWord: uint64 = bv + borrow
        if av >= subWord:
            out.limbs[i] = p256FixedWordFromBitsU64(av - subWord)
            borrow = uint64(0)
        else:
            out.limbs[i] = p256FixedWordFromBitsU64(wordBase + av - subWord)
            borrow = uint64(1)
    if highWord < borrow:
        panic("p256_fixed: montgomery high borrow underflow")
    let reducedHigh: uint64 = highWord - borrow
    assert(reducedHigh == uint64(0), "p256_fixed: montgomery reduced high overflow")
    return out

fn p256FixedSubtractModulusWithHighTrustedInto(out: var P256Fixed,
                                               value: var P256Fixed,
                                               highWord: uint64,
                                               modulus: var P256Fixed) =
    var borrow: uint64 = uint64(0)
    let wordBase: uint64 = uint64(1) << uint64(p256FixedWordBits)
    for i in 0..<p256FixedLimbCount:
        let av: uint64 = p256FixedWordToBitsU64(value.limbs[i])
        let bv: uint64 = p256FixedWordToBitsU64(modulus.limbs[i])
        let subWord: uint64 = bv + borrow
        if av >= subWord:
            out.limbs[i] = p256FixedWordFromBitsU64(av - subWord)
            borrow = uint64(0)
        else:
            out.limbs[i] = p256FixedWordFromBitsU64(wordBase + av - subWord)
            borrow = uint64(1)
    if highWord < borrow:
        panic("p256_fixed: montgomery high borrow underflow")
    let reducedHigh: uint64 = highWord - borrow
    assert(reducedHigh == uint64(0), "p256_fixed: montgomery reduced high overflow")

fn p256FixedMontgomeryMulCore(a: var P256Fixed,
                              b: var P256Fixed,
                              ctx: var P256FixedMontgomeryContext): Result[P256Fixed] =
    var scratch: P256FixedMontgomeryScratch
    p256FixedScratchZero(scratch)
    var modulusLocal: P256Fixed = ctx.modulus
    for i in 0..<p256FixedLimbCount:
        let bi: uint64 = p256FixedWordToBitsU64(b.limbs[i])
        let addRes: Result[bool] = p256FixedMontgomeryAddMulAt(scratch, i, bi, a)
        if IsErr(addRes):
            return Err[P256Fixed](strutil.Join(["p256_fixed: mul ab i=", intToStr(i), " ", Error(addRes)], ""))
        let mWord: uint64 = p256FixedLowWordBitsU64(p256FixedWordToBitsU64(scratch.words[i]) * ctx.n0Inv)
        let modAddRes: Result[bool] = p256FixedMontgomeryAddMulAt(scratch, i, mWord, modulusLocal)
        if IsErr(modAddRes):
            return Err[P256Fixed](strutil.Join(["p256_fixed: mul reduce i=", intToStr(i), " ", Error(modAddRes)], ""))
    return p256FixedMontgomeryFinishScratch(scratch, modulusLocal)

fn p256FixedMontgomeryFinishScratch(scratch: var P256FixedMontgomeryScratch,
                                    modulus: var P256Fixed): Result[P256Fixed] =
    var out: P256Fixed
    for i in 0..<p256FixedLimbCount:
        out.limbs[i] = scratch.words[i + p256FixedLimbCount]
    let highWord0: uint64 = p256FixedWordToBitsU64(scratch.words[p256FixedLimbCount * 2])
    if highWord0 != uint64(0) || p256FixedCmp(out, modulus) >= 0:
        let reduceRes: Result[P256Fixed] = p256FixedSubtractModulusWithHigh(out, highWord0, modulus)
        if IsErr(reduceRes):
            return Err[P256Fixed](Error(reduceRes))
        return Ok[P256Fixed](Value(reduceRes))
    return Ok[P256Fixed](out)

fn p256FixedMontgomeryFinishScratchTrusted(scratch: var P256FixedMontgomeryScratch,
                                           modulus: var P256Fixed): P256Fixed =
    var out: P256Fixed
    for i in 0..<p256FixedLimbCount:
        out.limbs[i] = scratch.words[i + p256FixedLimbCount]
    let highWord0: uint64 = p256FixedWordToBitsU64(scratch.words[p256FixedLimbCount * 2])
    if highWord0 != uint64(0) || p256FixedCmp(out, modulus) >= 0:
        return p256FixedSubtractModulusWithHighTrusted(out, highWord0, modulus)
    return out

fn p256FixedMontgomeryFinishScratchTrustedInto(out: var P256Fixed,
                                               scratch: var P256FixedMontgomeryScratch,
                                               modulus: var P256Fixed) =
    for i in 0..<p256FixedLimbCount:
        out.limbs[i] = scratch.words[i + p256FixedLimbCount]
    let highWord0: uint64 = p256FixedWordToBitsU64(scratch.words[p256FixedLimbCount * 2])
    if highWord0 != uint64(0) || p256FixedCmp(out, modulus) >= 0:
        p256FixedSubtractModulusWithHighTrustedInto(out, out, highWord0, modulus)

fn p256FixedMontgomeryReduceScratch(scratch: var P256FixedMontgomeryScratch,
                                    ctx: var P256FixedMontgomeryContext): Result[P256Fixed] =
    var modulusLocal: P256Fixed = ctx.modulus
    for i in 0..<p256FixedLimbCount:
        let mWord: uint64 = p256FixedLowWordBitsU64(p256FixedWordToBitsU64(scratch.words[i]) * ctx.n0Inv)
        let modAddRes: Result[bool] = p256FixedMontgomeryAddMulAt(scratch, i, mWord, modulusLocal)
        if IsErr(modAddRes):
            return Err[P256Fixed](strutil.Join(["p256_fixed: square reduce i=", intToStr(i), " ", Error(modAddRes)], ""))
    return p256FixedMontgomeryFinishScratch(scratch, modulusLocal)

fn p256FixedMontgomeryReduceScratchTrusted(scratch: var P256FixedMontgomeryScratch,
                                           ctx: var P256FixedMontgomeryContext): P256Fixed =
    var modulusLocal: P256Fixed = ctx.modulus
    for i in 0..<p256FixedLimbCount:
        let mWord: uint64 = p256FixedLowWordBitsU64(p256FixedWordToBitsU64(scratch.words[i]) * ctx.n0Inv)
        p256FixedMontgomeryAddMulAtTrusted(scratch, i, mWord, modulusLocal)
    return p256FixedMontgomeryFinishScratchTrusted(scratch, modulusLocal)

fn p256FixedMontgomeryReduceScratchTrustedInto(out: var P256Fixed,
                                               scratch: var P256FixedMontgomeryScratch,
                                               ctx: var P256FixedMontgomeryContext) =
    var modulusLocal: P256Fixed = ctx.modulus
    for i in 0..<p256FixedLimbCount:
        let mWord: uint64 = p256FixedLowWordBitsU64(p256FixedWordToBitsU64(scratch.words[i]) * ctx.n0Inv)
        p256FixedMontgomeryAddMulAtTrusted(scratch, i, mWord, modulusLocal)
    p256FixedMontgomeryFinishScratchTrustedInto(out, scratch, modulusLocal)

fn p256FixedMontgomerySquareCore(a: var P256Fixed,
                                 ctx: var P256FixedMontgomeryContext): Result[P256Fixed] =
    let scratchRes: Result[P256FixedMontgomeryScratch] = p256FixedSquareBuildScratch(a)
    if IsErr(scratchRes):
        return Err[P256Fixed](Error(scratchRes))
    var scratch: P256FixedMontgomeryScratch = Value(scratchRes)
    return p256FixedMontgomeryReduceScratch(scratch, ctx)

fn p256FixedSquareBuildScratchTrusted(a: var P256Fixed): P256FixedMontgomeryScratch =
    var scratch: P256FixedMontgomeryScratch
    p256FixedSquareBuildScratchTrustedInto(scratch, a)
    return scratch

fn p256FixedSquareBuildScratchTrustedInto(scratch: var P256FixedMontgomeryScratch,
                                          a: var P256Fixed) =
    p256FixedScratchZero(scratch)
    var c0: uint64 = uint64(0)
    var c1: uint64 = uint64(0)
    var c2: uint64 = uint64(0)
    for k in 0..<(p256FixedLimbCount * 2):
        var iStart: int32
        if k >= p256FixedLimbCount:
            iStart = k - (p256FixedLimbCount - 1)
        var iEnd: int32 = k
        if iEnd >= p256FixedLimbCount:
            iEnd = p256FixedLimbCount - 1
        var i: int32 = iStart
        while i <= iEnd:
            let j: int32 = k - i
            if i > j:
                break
            let ai: uint64 = p256FixedWordToBitsU64(a.limbs[i])
            let aj: uint64 = p256FixedWordToBitsU64(a.limbs[j])
            let prod: uint64 = ai * aj
            if i == j:
                p256FixedSquareAccumulate(c0,
                                          c1,
                                          c2,
                                          p256FixedLowWordBitsU64(prod),
                                          prod >> uint64(p256FixedWordBits))
            else:
                let prodLo: uint64 = p256FixedLowWordBitsU64(prod)
                let prodHi: uint64 = prod >> uint64(p256FixedWordBits)
                let dblLo: uint64 = p256FixedLowWordBitsU64(prodLo << uint64(1))
                let dblHi: uint64 = (prodHi << uint64(1)) + (prodLo >> uint64(31))
                p256FixedSquareAccumulate(c0, c1, c2, dblLo, dblHi)
            i = i + 1
        scratch.words[k] = p256FixedWordFromBitsU64(c0)
        c0 = c1
        c1 = c2
        c2 = uint64(0)
    if c0 != uint64(0) || c1 != uint64(0):
        panic("p256_fixed: square comba overflow")

fn p256FixedMontgomeryMulCoreTrusted(a: var P256Fixed,
                                     b: var P256Fixed,
                                     ctx: var P256FixedMontgomeryContext): P256Fixed =
    var scratch: P256FixedMontgomeryScratch
    p256FixedScratchZero(scratch)
    var modulusLocal: P256Fixed = ctx.modulus
    for i in 0..<p256FixedLimbCount:
        let bi: uint64 = p256FixedWordToBitsU64(b.limbs[i])
        p256FixedMontgomeryAddMulAtTrusted(scratch, i, bi, a)
        let mWord: uint64 = p256FixedLowWordBitsU64(p256FixedWordToBitsU64(scratch.words[i]) * ctx.n0Inv)
        p256FixedMontgomeryAddMulAtTrusted(scratch, i, mWord, modulusLocal)
    return p256FixedMontgomeryFinishScratchTrusted(scratch, modulusLocal)

fn p256FixedMontgomeryMulCoreTrustedInto(out: var P256Fixed,
                                         a: var P256Fixed,
                                         b: var P256Fixed,
                                         ctx: var P256FixedMontgomeryContext) =
    var scratch: P256FixedMontgomeryScratch
    p256FixedScratchZero(scratch)
    var modulusLocal: P256Fixed = ctx.modulus
    for i in 0..<p256FixedLimbCount:
        let bi: uint64 = p256FixedWordToBitsU64(b.limbs[i])
        p256FixedMontgomeryAddMulAtTrusted(scratch, i, bi, a)
        let mWord: uint64 = p256FixedLowWordBitsU64(p256FixedWordToBitsU64(scratch.words[i]) * ctx.n0Inv)
        p256FixedMontgomeryAddMulAtTrusted(scratch, i, mWord, modulusLocal)
    p256FixedMontgomeryFinishScratchTrustedInto(out, scratch, modulusLocal)

fn p256FixedMontgomeryMulCoreTrustedScratchInto(out: var P256Fixed,
                                                a: var P256Fixed,
                                                b: var P256Fixed,
                                                ctx: var P256FixedMontgomeryContext,
                                                scratch: var P256FixedMontgomeryScratch) =
    p256FixedScratchZero(scratch)
    var modulusLocal: P256Fixed = ctx.modulus
    for i in 0..<p256FixedLimbCount:
        let bi: uint64 = p256FixedWordToBitsU64(b.limbs[i])
        p256FixedMontgomeryAddMulAtTrusted(scratch, i, bi, a)
        let mWord: uint64 = p256FixedLowWordBitsU64(p256FixedWordToBitsU64(scratch.words[i]) * ctx.n0Inv)
        p256FixedMontgomeryAddMulAtTrusted(scratch, i, mWord, modulusLocal)
    p256FixedMontgomeryFinishScratchTrustedInto(out, scratch, modulusLocal)

fn p256FixedMontgomerySquareCoreTrusted(a: var P256Fixed,
                                        ctx: var P256FixedMontgomeryContext): P256Fixed =
    var scratch: P256FixedMontgomeryScratch = p256FixedSquareBuildScratchTrusted(a)
    return p256FixedMontgomeryReduceScratchTrusted(scratch, ctx)

fn p256FixedMontgomerySquareCoreTrustedInto(out: var P256Fixed,
                                            a: var P256Fixed,
                                            ctx: var P256FixedMontgomeryContext) =
    var scratch: P256FixedMontgomeryScratch = p256FixedSquareBuildScratchTrusted(a)
    p256FixedMontgomeryReduceScratchTrustedInto(out, scratch, ctx)

fn p256FixedMontgomerySquareCoreTrustedScratchInto(out: var P256Fixed,
                                                   a: var P256Fixed,
                                                   ctx: var P256FixedMontgomeryContext,
                                                   scratch: var P256FixedMontgomeryScratch) =
    p256FixedSquareBuildScratchTrustedInto(scratch, a)
    p256FixedMontgomeryReduceScratchTrustedInto(out, scratch, ctx)

fn p256FixedBuildMontgomeryContext(modulus: BigInt): Result[P256FixedMontgomeryContext] =
    let ctxRes: Result[BigMontgomeryContext] = bigBuildMontgomeryContext(modulus)
    if IsErr(ctxRes):
        return Err[P256FixedMontgomeryContext](Error(ctxRes))
    let bigCtx: BigMontgomeryContext = Value(ctxRes)
    var modulusBig: BigInt = bigCtx.modulus
    let modulusRes: Result[P256Fixed] = p256FixedFromBigInt(modulusBig)
    if IsErr(modulusRes):
        return Err[P256FixedMontgomeryContext](Error(modulusRes))
    var r2Big: BigInt = bigCtx.r2
    let r2Res: Result[P256Fixed] = p256FixedFromBigInt(r2Big)
    if IsErr(r2Res):
        return Err[P256FixedMontgomeryContext](Error(r2Res))
    var oneMontBig: BigInt = bigCtx.oneMont
    let oneMontRes: Result[P256Fixed] = p256FixedFromBigInt(oneMontBig)
    if IsErr(oneMontRes):
        return Err[P256FixedMontgomeryContext](Error(oneMontRes))
    var out: P256FixedMontgomeryContext
    out.modulus = Value(modulusRes)
    out.n0Inv = bigCtx.n0Inv
    out.r2 = Value(r2Res)
    out.oneMont = Value(oneMontRes)
    return Ok[P256FixedMontgomeryContext](out)

fn p256FixedModAdd(a: var P256Fixed, b: var P256Fixed, modulus: var P256Fixed): Result[P256Fixed] =
    var out: P256Fixed
    p256FixedModAddTrustedInto(out, a, b, modulus)
    return Ok[P256Fixed](out)

fn p256FixedModAddTrusted(a: var P256Fixed, b: var P256Fixed, modulus: var P256Fixed): P256Fixed =
    var out: P256Fixed
    p256FixedModAddTrustedInto(out, a, b, modulus)
    return out

fn p256FixedModAddTrustedInto(out: var P256Fixed,
                              a: var P256Fixed,
                              b: var P256Fixed,
                              modulus: var P256Fixed) =
    var carry: uint64 = uint64(0)
    p256FixedAddRawInto(out, carry, a, b)
    if carry != uint64(0) || p256FixedCmp(out, modulus) >= 0:
        p256FixedSubtractModulusWithHighTrustedInto(out, out, carry, modulus)
        return

fn p256FixedModSub(a: var P256Fixed, b: var P256Fixed, modulus: var P256Fixed): Result[P256Fixed] =
    var out: P256Fixed
    p256FixedModSubTrustedInto(out, a, b, modulus)
    return Ok[P256Fixed](out)

fn p256FixedModSubTrusted(a: var P256Fixed, b: var P256Fixed, modulus: var P256Fixed): P256Fixed =
    var out: P256Fixed
    p256FixedModSubTrustedInto(out, a, b, modulus)
    return out

fn p256FixedModSubTrustedInto(out: var P256Fixed,
                              a: var P256Fixed,
                              b: var P256Fixed,
                              modulus: var P256Fixed) =
    var borrow: uint64 = uint64(0)
    p256FixedSubRawInto(out, borrow, a, b)
    if borrow == uint64(0):
        return
    var diff: P256Fixed
    var diffBorrow: uint64 = uint64(0)
    p256FixedSubRawInto(diff, diffBorrow, b, a)
    if diffBorrow != uint64(0):
        panic("p256_fixed: wrapped subtraction diff borrow")
    var reduceBorrow: uint64 = uint64(0)
    p256FixedSubRawInto(out, reduceBorrow, modulus, diff)
    if reduceBorrow != uint64(0):
        panic("p256_fixed: modulus subtraction borrow")

fn p256FixedGetBit(a: var P256Fixed, idx: int32): int32 =
    if idx < 0:
        return 0
    let limbIdx: int32 = idx / p256FixedWordBits
    if limbIdx < 0 || limbIdx >= p256FixedLimbCount:
        return 0
    let shift: int32 = idx % p256FixedWordBits
    return int32((p256FixedWordToBitsU64(a.limbs[limbIdx]) >> uint64(shift)) & uint64(1))

fn p256FixedAssertNormalizedTrusted(value: var P256Fixed, modulus: var P256Fixed) =
    if p256FixedCmp(value, modulus) >= 0:
        panic("p256_fixed: trusted path got non-normalized input")

fn p256FixedModMulWithContext(a: var P256Fixed,
                              b: var P256Fixed,
                              ctx: var P256FixedMontgomeryContext): Result[P256Fixed] =
    var modulusLocal: P256Fixed = ctx.modulus
    let aNormRes: Result[P256Fixed] = p256FixedNormalizeInput(a, modulusLocal)
    if IsErr(aNormRes):
        return Err[P256Fixed](Error(aNormRes))
    let bNormRes: Result[P256Fixed] = p256FixedNormalizeInput(b, modulusLocal)
    if IsErr(bNormRes):
        return Err[P256Fixed](Error(bNormRes))
    var aNorm: P256Fixed = Value(aNormRes)
    var bNorm: P256Fixed = Value(bNormRes)
    var r2LocalA: P256Fixed = ctx.r2
    let aMontRes: Result[P256Fixed] = p256FixedMontgomeryMulCore(aNorm, r2LocalA, ctx)
    if IsErr(aMontRes):
        return Err[P256Fixed](Error(aMontRes))
    var r2LocalB: P256Fixed = ctx.r2
    let bMontRes: Result[P256Fixed] = p256FixedMontgomeryMulCore(bNorm, r2LocalB, ctx)
    if IsErr(bMontRes):
        return Err[P256Fixed](Error(bMontRes))
    var aMont: P256Fixed = Value(aMontRes)
    var bMont: P256Fixed = Value(bMontRes)
    let prodMontRes: Result[P256Fixed] = p256FixedMontgomeryMulCore(aMont, bMont, ctx)
    if IsErr(prodMontRes):
        return Err[P256Fixed](Error(prodMontRes))
    var prodMont: P256Fixed = Value(prodMontRes)
    var oneLocal: P256Fixed = p256FixedOne()
    return p256FixedMontgomeryMulCore(prodMont, oneLocal, ctx)

fn p256FixedModMulWithContextTrusted(a: var P256Fixed,
                                     b: var P256Fixed,
                                     ctx: var P256FixedMontgomeryContext): P256Fixed =
    var modulusLocal: P256Fixed = ctx.modulus
    p256FixedAssertNormalizedTrusted(a, modulusLocal)
    p256FixedAssertNormalizedTrusted(b, modulusLocal)
    var r2LocalA: P256Fixed = ctx.r2
    let aMont: P256Fixed = p256FixedMontgomeryMulCoreTrusted(a, r2LocalA, ctx)
    var r2LocalB: P256Fixed = ctx.r2
    let bMont: P256Fixed = p256FixedMontgomeryMulCoreTrusted(b, r2LocalB, ctx)
    let prodMont: P256Fixed = p256FixedMontgomeryMulCoreTrusted(aMont, bMont, ctx)
    var oneLocal: P256Fixed = p256FixedOne()
    return p256FixedMontgomeryMulCoreTrusted(prodMont, oneLocal, ctx)

fn p256FixedModExpWithContext(base: var P256Fixed,
                              exp: var P256Fixed,
                              ctx: var P256FixedMontgomeryContext): Result[P256Fixed] =
    var modulusLocal: P256Fixed = ctx.modulus
    let baseNormRes: Result[P256Fixed] = p256FixedNormalizeInput(base, modulusLocal)
    if IsErr(baseNormRes):
        return Err[P256Fixed](Error(baseNormRes))
    var resultMont: P256Fixed = ctx.oneMont
    var baseNorm: P256Fixed = Value(baseNormRes)
    var r2Local: P256Fixed = ctx.r2
    let powMontRes: Result[P256Fixed] = p256FixedMontgomeryMulCore(baseNorm, r2Local, ctx)
    if IsErr(powMontRes):
        return Err[P256Fixed](Error(powMontRes))
    var powMont: P256Fixed = Value(powMontRes)
    for i in 0..<(p256FixedLimbCount * p256FixedWordBits):
        if p256FixedGetBit(exp, i) != 0:
            let mulRes: Result[P256Fixed] = p256FixedMontgomeryMulCore(resultMont, powMont, ctx)
        if IsErr(mulRes):
            return Err[P256Fixed](Error(mulRes))
        resultMont = Value(mulRes)
        let sqPowRes: Result[P256Fixed] = p256FixedMontgomerySquareCore(powMont, ctx)
        if IsErr(sqPowRes):
            return Err[P256Fixed](Error(sqPowRes))
        powMont = Value(sqPowRes)
    var oneLocal: P256Fixed = p256FixedOne()
    return p256FixedMontgomeryMulCore(resultMont, oneLocal, ctx)

fn p256FixedModExpWithContextTrusted(base: var P256Fixed,
                                     exp: var P256Fixed,
                                     ctx: var P256FixedMontgomeryContext): P256Fixed =
    var modulusLocal: P256Fixed = ctx.modulus
    p256FixedAssertNormalizedTrusted(base, modulusLocal)
    var resultMont: P256Fixed = ctx.oneMont
    var r2Local: P256Fixed = ctx.r2
    var powMont: P256Fixed = p256FixedMontgomeryMulCoreTrusted(base, r2Local, ctx)
    for i in 0..<(p256FixedLimbCount * p256FixedWordBits):
        if p256FixedGetBit(exp, i) != 0:
            resultMont = p256FixedMontgomeryMulCoreTrusted(resultMont, powMont, ctx)
        powMont = p256FixedMontgomerySquareCoreTrusted(powMont, ctx)
    var oneLocal: P256Fixed = p256FixedOne()
    return p256FixedMontgomeryMulCoreTrusted(resultMont, oneLocal, ctx)

fn P256FieldModulus(): P256Fixed =
    return p256FieldModulus()

fn P256FixedCmp(a: var P256Fixed, b: var P256Fixed): int32 =
    return p256FixedCmp(a, b)

fn P256FixedFromBigInt(value: var BigInt): Result[P256Fixed] =
    return p256FixedFromBigInt(value)

fn P256FixedFromBigIntFill(out: var P256Fixed, value: var BigInt): Result[bool] =
    return p256FixedFromBigIntFill(out, value)

fn P256FixedGetBit(a: var P256Fixed, idx: int32): int32 =
    return p256FixedGetBit(a, idx)

fn P256FixedIsZero(a: var P256Fixed): bool =
    return p256FixedIsZero(a)

fn P256FixedModAdd(a: var P256Fixed, b: var P256Fixed, modulus: var P256Fixed): Result[P256Fixed] =
    return p256FixedModAdd(a, b, modulus)

fn P256FixedModSubTrustedInto(out: var P256Fixed,
                              a: var P256Fixed,
                              b: var P256Fixed,
                              modulus: var P256Fixed) =
    p256FixedModSubTrustedInto(out, a, b, modulus)

fn P256FixedModSubTrusted(a: var P256Fixed, b: var P256Fixed, modulus: var P256Fixed): P256Fixed =
    return p256FixedModSubTrusted(a, b, modulus)

fn P256FixedOne(): P256Fixed =
    return p256FixedOne()

fn P256FixedSubRawInto(out: var P256Fixed,
                       borrow: var uint64,
                       a: var P256Fixed,
                       b: var P256Fixed) =
    p256FixedSubRawInto(out, borrow, a, b)

fn P256FixedWordToBitsU64(w: int32): uint64 =
    return p256FixedWordToBitsU64(w)

fn P256ScalarModulus(): P256Fixed =
    return p256ScalarModulus()

fn P256ScalarMontgomeryContext(): P256FixedMontgomeryContext =
    return p256ScalarMontgomeryContext()

fn P256ScalarMontgomeryContextInto(out: var P256FixedMontgomeryContext) =
    out.modulus = p256ScalarModulus()
    out.n0Inv = uint64(0xee00bc4f)
    out.r2 = p256ScalarR2()
    out.oneMont = p256ScalarOneMont()

fn P256FixedModMulWithContext(a: var P256Fixed,
                              b: var P256Fixed,
                              ctx: var P256FixedMontgomeryContext): Result[P256Fixed] =
    return p256FixedModMulWithContext(a, b, ctx)
