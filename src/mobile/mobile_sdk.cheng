import std/result
import cheng/libp2p/identity/did
import cheng/mobile/android_bridge as bridge

type
    MobileSdk =
        host: bridge.MobileHost

fn MobileSdkInit(seed: str): MobileSdk =
    var out: MobileSdk
    out.host = bridge.MobileHostInit(seed)
    return out

fn MobileSdkInitWithDid(identity: did.DidIdentity): MobileSdk =
    var out: MobileSdk
    out.host = bridge.MobileHostInitWithDid(identity)
    return out

fn MobileSdkInitWithDidStore(identityStorePath: str,
                               rootSeedHint: str,
                               deviceSeedHint: str,
                               deviceLabelHint: str,
                               epochSeconds: int64): Result[MobileSdk] =
    var out: MobileSdk
    let initRes = MobileSdkInitWithDidStoreFill(out,
                                                  identityStorePath,
                                                  rootSeedHint,
                                                  deviceSeedHint,
                                                  deviceLabelHint,
                                                  epochSeconds)
    if IsErr(initRes):
        return Err[MobileSdk](Error(initRes))
    return Ok[MobileSdk](out)

fn MobileSdkInitWithDidStoreFill(out: var MobileSdk,
                                   identityStorePath: str,
                                   rootSeedHint: str,
                                   deviceSeedHint: str,
                                   deviceLabelHint: str,
                                   epochSeconds: int64): Result[bool] =
    var hostValue = bridge.MobileHostInit("")
    let hostRes = bridge.MobileHostInitWithDidStoreFill(hostValue,
                                                          identityStorePath,
                                                          rootSeedHint,
                                                          deviceSeedHint,
                                                          deviceLabelHint,
                                                          epochSeconds)
    if IsErr(hostRes):
        return Err[bool](Error(hostRes))
    out.host = hostValue
    return Ok[bool](true)

fn MobileSdkStart(sdk: var MobileSdk) =
    var hostInst = sdk.host
    bridge.MobileHostStart(hostInst)
    sdk.host = hostInst

fn MobileSdkStop(sdk: var MobileSdk) =
    var hostInst = sdk.host
    bridge.MobileHostStop(hostInst)
    sdk.host = hostInst

fn MobileSdkStarted(sdk: MobileSdk): bool =
    return bridge.MobileHostIsStarted(sdk.host)

fn MobileSdkSelfPeerText(sdk: MobileSdk): str =
    return bridge.MobileHostPeerIdText(sdk.host)

fn MobileSdkDidText(sdk: MobileSdk): str =
    return bridge.MobileHostDidText(sdk.host)

fn MobileSdkSaveDidIdentity(identityStorePath: str,
                              sdk: MobileSdk): Result[bool] =
    return bridge.MobileHostSaveDidIdentity(identityStorePath, sdk.host)

fn MobileSdkSetMdns(sdk: var MobileSdk,
                      enabled: bool,
                      intervalSeconds: int32) =
    var hostInst = sdk.host
    bridge.MobileHostSetMdnsEnabled(hostInst, enabled)
    bridge.MobileHostSetMdnsInterval(hostInst, intervalSeconds)
    sdk.host = hostInst

fn MobileSdkMdnsEnabled(sdk: MobileSdk): bool =
    return bridge.MobileHostMdnsEnabled(sdk.host)

fn MobileSdkMdnsInterval(sdk: MobileSdk): int32 =
    return bridge.MobileHostMdnsInterval(sdk.host)

fn MobileSdkSetTrustedInfra(sdk: var MobileSdk,
                              trusted: bool) =
    var hostInst = sdk.host
    bridge.MobileHostSetTrustedInfra(hostInst, trusted)
    sdk.host = hostInst

fn MobileSdkTrustedInfra(sdk: MobileSdk): bool =
    return bridge.MobileHostTrustedInfra(sdk.host)

fn MobileSdkListen(sdk: var MobileSdk,
                     addrText: str): Result[bool] =
    var hostInst = sdk.host
    let res = bridge.MobileHostListenAddText(hostInst, addrText)
    sdk.host = hostInst
    return res

fn MobileSdkListenCount(sdk: MobileSdk): int32 =
    return bridge.MobileHostListenAddrCount(sdk.host)

fn MobileSdkListenDialableAddrTextAt(sdk: MobileSdk,
                                       index: int32): str =
    return bridge.MobileHostDialableAddrTextAt(sdk.host, index)

fn MobileSdkAddBootstrapPeer(sdk: var MobileSdk,
                               peerText: str,
                               addrText: str): Result[bool] =
    var hostInst = sdk.host
    let res = bridge.MobileHostRegisterPeerHintText(hostInst,
                                                      peerText,
                                                      addrText,
                                                      0,
                                                      true,
                                                      true)
    sdk.host = hostInst
    return res

fn MobileSdkConnectRegistered(sdk: var MobileSdk,
                                peerText: str): Result[bool] =
    var hostInst = sdk.host
    let res = bridge.MobileHostConnectRegisteredText(hostInst, peerText)
    sdk.host = hostInst
    return res

fn MobileSdkConnectPreferred(sdk: var MobileSdk,
                               peerText: str,
                               addrText: str): Result[bool] =
    var hostInst = sdk.host
    let res = bridge.MobileHostConnectPreferredText(hostInst, peerText, addrText)
    sdk.host = hostInst
    return res

fn MobileSdkDisconnectPeer(sdk: var MobileSdk,
                             peerText: str): bool =
    var hostInst = sdk.host
    let ok = bridge.MobileHostDisconnectText(hostInst, peerText)
    sdk.host = hostInst
    return ok

fn MobileSdkReconnectBootstrap(sdk: var MobileSdk): int32 =
    var hostInst = sdk.host
    let count = bridge.MobileHostReconnectBootstrap(hostInst)
    sdk.host = hostInst
    return count

fn MobileSdkPeerCount(sdk: MobileSdk): int32 =
    return bridge.MobileHostPeerCount(sdk.host)

fn MobileSdkConnectedPeerCount(sdk: MobileSdk): int32 =
    return bridge.MobileHostConnectedPeerCount(sdk.host)

fn MobileSdkBootstrapPeerCount(sdk: MobileSdk): int32 =
    return bridge.MobileHostBootstrapPeerCount(sdk.host)

fn MobileSdkPeerConnected(sdk: MobileSdk,
                            peerText: str): bool =
    return bridge.MobileHostIsPeerConnectedText(sdk.host, peerText)

fn MobileSdkPeerDialableAddrTextAt(sdk: MobileSdk,
                                     peerText: str,
                                     index: int32): str =
    return bridge.MobileHostPeerDialableAddrTextAt(sdk.host, peerText, index)
