    return mobileCapiBioDidDiagOkCString("recover")

fn mobileCapiBioDidCreateDiagIdentityCStringRaw(requestIdRaw: ptr,
                                                  feature32HexRaw: ptr,
                                                  deviceBindingSeedRaw: ptr,
                                                  deviceLabelRaw: ptr,
                                                  sensorIdRaw: ptr,
                                                  hardwareAttestationRaw: ptr): ptr =
    let requestId = bridge.InternalMobileBridgeCopyRawText(requestIdRaw)
    let feature32Hex = bridge.InternalMobileBridgeCopyRawText(feature32HexRaw)
    let deviceBindingSeed = bridge.InternalMobileBridgeCopyRawText(deviceBindingSeedRaw)
    let deviceLabel = bridge.InternalMobileBridgeCopyRawText(deviceLabelRaw)
    let sensorId = bridge.InternalMobileBridgeCopyRawText(sensorIdRaw)
    let hardwareAttestation = bridge.InternalMobileBridgeCopyRawText(hardwareAttestationRaw)
    let captureRes = MobileCapiBioDidCapture(requestId,
                                               feature32Hex,
                                               deviceBindingSeed,
                                               deviceLabel,
                                               sensorId,
                                               hardwareAttestation)
    if IsErr(captureRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(captureRes)))
    let capture = Value(captureRes)
    let attestationOk = bio_did.BioDidCaptureAttestationValidate(capture, "create")
    if IsErr(attestationOk):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(attestationOk)))
    let recordRes = bio.BioEnroll(capture.feature32)
    if IsErr(recordRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(recordRes)))
    let rootSecretRes = bio.BioRecoverRoot(capture.feature32, Value(recordRes).helper)
    if IsErr(rootSecretRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(rootSecretRes)))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = bio_did.BioDidRootSeedFromRootSecret(rootSecret)
    let deviceSeed = bio_did.BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let identity = did.DidIdentityMake(rootSeed, deviceSeed, capture.deviceLabel, times.EpochTimeSeconds())
    var document: did.DidDocument
    let documentRes = did.DidIdentityDocumentFill(document, identity)
    if IsErr(documentRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(documentRes)))
    return mobileCapiBioDidDiagOkCString("identity")

fn mobileCapiBioDidCreateDiagAssertionCStringRaw(requestIdRaw: ptr,
                                                   feature32HexRaw: ptr,
                                                   deviceBindingSeedRaw: ptr,
                                                   deviceLabelRaw: ptr,
                                                   sensorIdRaw: ptr,
                                                   hardwareAttestationRaw: ptr): ptr =
    let requestId = bridge.InternalMobileBridgeCopyRawText(requestIdRaw)
    let feature32Hex = bridge.InternalMobileBridgeCopyRawText(feature32HexRaw)
    let deviceBindingSeed = bridge.InternalMobileBridgeCopyRawText(deviceBindingSeedRaw)
    let deviceLabel = bridge.InternalMobileBridgeCopyRawText(deviceLabelRaw)
    let sensorId = bridge.InternalMobileBridgeCopyRawText(sensorIdRaw)
    let hardwareAttestation = bridge.InternalMobileBridgeCopyRawText(hardwareAttestationRaw)
    let captureRes = MobileCapiBioDidCapture(requestId,
                                               feature32Hex,
                                               deviceBindingSeed,
                                               deviceLabel,
                                               sensorId,
                                               hardwareAttestation)
    if IsErr(captureRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(captureRes)))
    let capture = Value(captureRes)
    let attestationOk = bio_did.BioDidCaptureAttestationValidate(capture, "create")
    if IsErr(attestationOk):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(attestationOk)))
    let recordRes = bio.BioEnroll(capture.feature32)
    if IsErr(recordRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(recordRes)))
    let record = Value(recordRes)
    let rootSecretRes = bio.BioRecoverRoot(capture.feature32, record.helper)
    if IsErr(rootSecretRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(rootSecretRes)))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = bio_did.BioDidRootSeedFromRootSecret(rootSecret)
    let deviceSeed = bio_did.BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let identity = did.DidIdentityMake(rootSeed, deviceSeed, capture.deviceLabel, times.EpochTimeSeconds())
    var document: did.DidDocument
    let documentRes = did.DidIdentityDocumentFill(document, identity)
    if IsErr(documentRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(documentRes)))
    let bundleSeq = 1
    let challengeNonce = bio_did.BioDidChallengeNonce("create",
                                                        document.did,
                                                        identity.selfDevice.devicePeerId,
                                                        document.version,
                                                        bundleSeq)
    let hardware = bio_did.BioDidHardwareAttestationMake(capture,
                                                           "create",
                                                           document.did,
                                                           identity.selfDevice.devicePeerId,
                                                           document.version,
                                                           bundleSeq,
                                                           challengeNonce,
                                                           times.EpochTimeSeconds())
    let assertionRes = bio.BioProve(capture.feature32, record, challengeNonce)
    if IsErr(assertionRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(assertionRes)))
    return mobileCapiBioDidDiagOkCString("assertion")

fn mobileCapiBioDidCreateDiagBundleCStringRaw(requestIdRaw: ptr,
                                                feature32HexRaw: ptr,
                                                deviceBindingSeedRaw: ptr,
                                                deviceLabelRaw: ptr,
                                                sensorIdRaw: ptr,
                                                hardwareAttestationRaw: ptr): ptr =
    let requestId = bridge.InternalMobileBridgeCopyRawText(requestIdRaw)
    let feature32Hex = bridge.InternalMobileBridgeCopyRawText(feature32HexRaw)
    let deviceBindingSeed = bridge.InternalMobileBridgeCopyRawText(deviceBindingSeedRaw)
    let deviceLabel = bridge.InternalMobileBridgeCopyRawText(deviceLabelRaw)
    let sensorId = bridge.InternalMobileBridgeCopyRawText(sensorIdRaw)
    let hardwareAttestation = bridge.InternalMobileBridgeCopyRawText(hardwareAttestationRaw)
    let captureRes = MobileCapiBioDidCapture(requestId,
                                               feature32Hex,
                                               deviceBindingSeed,
                                               deviceLabel,
                                               sensorId,
                                               hardwareAttestation)
    if IsErr(captureRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(captureRes)))
    let capture = Value(captureRes)
    let attestationOk = bio_did.BioDidCaptureAttestationValidate(capture, "create")
    if IsErr(attestationOk):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(attestationOk)))
    let recordRes = bio.BioEnroll(capture.feature32)
    if IsErr(recordRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(recordRes)))
    let record = Value(recordRes)
    let rootSecretRes = bio.BioRecoverRoot(capture.feature32, record.helper)
    if IsErr(rootSecretRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(rootSecretRes)))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = bio_did.BioDidRootSeedFromRootSecret(rootSecret)
    let deviceSeed = bio_did.BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let identity = did.DidIdentityMake(rootSeed, deviceSeed, capture.deviceLabel, times.EpochTimeSeconds())
    var document: did.DidDocument
    let documentRes = did.DidIdentityDocumentFill(document, identity)
    if IsErr(documentRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(documentRes)))
    let bundleSeq = 1
    let challengeNonce = bio_did.BioDidChallengeNonce("create",
                                                        document.did,
                                                        identity.selfDevice.devicePeerId,
                                                        document.version,
                                                        bundleSeq)
    let hardware = bio_did.BioDidHardwareAttestationMake(capture,
                                                           "create",
                                                           document.did,
                                                           identity.selfDevice.devicePeerId,
                                                           document.version,
                                                           bundleSeq,
                                                           challengeNonce,
                                                           times.EpochTimeSeconds())
    let assertionRes = bio.BioProve(capture.feature32, record, challengeNonce)
    if IsErr(assertionRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(assertionRes)))
    let bundleRes = bio_did.BioDidChainBundleMake("create",
                                                    bundleSeq,
                                                    document,
                                                    identity.selfDevice.devicePeerId,
                                                    record,
                                                    Value(assertionRes),
                                                    hardware)
    if IsErr(bundleRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiBioDidErrorJson(Error(bundleRes)))
    return mobileCapiBioDidDiagOkCString("bundle")

fn MobileCapiBioDidImport(latestBundleText: str,
                            requestId: str,
                            feature32Hex: str,
                            deviceBindingSeed: str,
                            deviceLabel: str,
                            sensorId: str,
                            hardwareAttestation: str): str =
    let latestBundleRes = bio_did.BioDidChainBundleParseText(latestBundleText)
    if IsErr(latestBundleRes):
        let errorText = MobileCapiBioDidErrorJson(Error(latestBundleRes))
        return errorText
    let captureRes = MobileCapiBioDidCapture(requestId,
                                               feature32Hex,
                                               deviceBindingSeed,
                                               deviceLabel,
                                               sensorId,
                                               hardwareAttestation)
    if IsErr(captureRes):
        let errorText = MobileCapiBioDidErrorJson(Error(captureRes))
        return errorText
    let importRes = bio_did.BioDidImportFromLatestBundleWithHardwareCapture(Value(latestBundleRes),
                                                                              Value(captureRes),
                                                                              times.EpochTimeSeconds())
    if IsErr(importRes):
        let errorText = MobileCapiBioDidErrorJson(Error(importRes))
        return errorText
    let outcome = Value(importRes)
    let devicePeerIdText = peer_id.Libp2pPeerIdText(outcome.bundle.devicePeerId)
    let bundleSeqText = strings.IntToStr(outcome.bundle.bundleSeq)
    let recordVersionText = strings.IntToStr(outcome.bundle.record.version)
    let recordHelperText = layout.FixedBytes32Hex(outcome.bundle.record.helper)
    let recordPubKeyText = layout.FixedBytes65Hex(outcome.bundle.record.pubKey)
    let recordCodeNText = strings.IntToStr(outcome.bundle.record.codeN)
    let recordCodeKText = strings.IntToStr(outcome.bundle.record.codeK)
    let recordMaxCorrectableText = strings.IntToStr(outcome.bundle.record.maxCorrectable)
    let recordCidText = layout.FixedBytes32Hex(outcome.bundle.record.recordCid)
    let challengeNonceText = layout.FixedBytes32Hex(outcome.bundle.assertion.challengeNonce)
    let assertionCommitAText = layout.FixedBytes65Hex(outcome.bundle.assertion.commitA)
    let assertionResponseZText = layout.FixedBytes32Hex(outcome.bundle.assertion.responseZ)
    let assertionProofCidText = layout.FixedBytes32Hex(outcome.bundle.assertion.proofCid)
    let hardwareVersionText = strings.IntToStr(outcome.bundle.hardware.version)
    let hardwareVerifiedAtText = did.DidStoreWord64Hex(outcome.bundle.hardware.verifiedAtEpochSeconds)
    let hardwareDeviceBindingSeedHashText = layout.FixedBytes32Hex(outcome.bundle.hardware.deviceBindingSeedHash)
    let hardwareAttestationCidText = layout.FixedBytes32Hex(outcome.bundle.hardware.attestationCid)
    let hardwareBindingCidText = layout.FixedBytes32Hex(outcome.bundle.hardware.bindingCid)
    var bundleText = ""
    bundleText = did.DidStoreAppendLine(bundleText, "cheng_bio_did_bundle_version", bio_did.BioDidBundleVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "action", outcome.bundle.action)
    bundleText = did.DidStoreAppendLine(bundleText, "bundle_seq", bundleSeqText)
    bundleText = did.DidStoreAppendLine(bundleText, "did", outcome.document.did)
    bundleText = did.DidStoreAppendLine(bundleText, "device_peer_id", devicePeerIdText)
    bundleText = did.DidStoreAppendLine(bundleText, "document_text", did.DidStoreEncodeText(outcome.bundle.documentText))
    bundleText = did.DidStoreAppendLine(bundleText, "record_version", recordVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_helper", recordHelperText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_pub_key", recordPubKeyText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_code_n", recordCodeNText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_code_k", recordCodeKText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_max_correctable", recordMaxCorrectableText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_cid", recordCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "challenge_nonce", challengeNonceText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_commit_a", assertionCommitAText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_response_z", assertionResponseZText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_proof_cid", assertionProofCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_version", hardwareVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_request_id", did.DidStoreEncodeText(outcome.bundle.hardware.requestId))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_sensor_id", did.DidStoreEncodeText(outcome.bundle.hardware.sensorId))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_verified_at", hardwareVerifiedAtText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_device_binding_seed_hash", hardwareDeviceBindingSeedHashText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_attestation_text", did.DidStoreEncodeText(outcome.bundle.hardware.attestationText))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_attestation_cid", hardwareAttestationCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_binding_cid", hardwareBindingCidText)
    let out = MobileCapiBioDidProvisionJson(outcome.document.did,
                                              outcome.identity.rootSeed,
                                              outcome.identity.deviceSeed,
                                              outcome.bundle.documentText,
                                              bundleText)
    return out

fn MobileCapiBioDidImportWire(requestWire: str): str =
    let latestBundleTextRes = MobileCapiWireDecodedValue(requestWire, "latest_bundle_text")
    if IsErr(latestBundleTextRes):
        let errorText = MobileCapiBioDidErrorJson(Error(latestBundleTextRes))
        return errorText
    let requestIdRes = MobileCapiWireDecodedValue(requestWire, "request_id")
    if IsErr(requestIdRes):
        let errorText = MobileCapiBioDidErrorJson(Error(requestIdRes))
        return errorText
    let feature32HexRes = MobileCapiWireFindValue(requestWire, "feature32_hex")
    if IsErr(feature32HexRes):
        let errorText = MobileCapiBioDidErrorJson(Error(feature32HexRes))
        return errorText
    let deviceBindingSeedRes = MobileCapiWireDecodedValue(requestWire, "device_binding_seed")
    if IsErr(deviceBindingSeedRes):
        let errorText = MobileCapiBioDidErrorJson(Error(deviceBindingSeedRes))
        return errorText
    let deviceLabelRes = MobileCapiWireDecodedValue(requestWire, "device_label")
    if IsErr(deviceLabelRes):
        let errorText = MobileCapiBioDidErrorJson(Error(deviceLabelRes))
        return errorText
    let sensorIdRes = MobileCapiWireDecodedValue(requestWire, "sensor_id")
    if IsErr(sensorIdRes):
        let errorText = MobileCapiBioDidErrorJson(Error(sensorIdRes))
        return errorText
    let hardwareAttestationRes = MobileCapiWireDecodedValue(requestWire, "hardware_attestation")
    if IsErr(hardwareAttestationRes):
        let errorText = MobileCapiBioDidErrorJson(Error(hardwareAttestationRes))
        return errorText
    let out = MobileCapiBioDidImport(Value(latestBundleTextRes),
                                       Value(requestIdRes),
                                       Value(feature32HexRes),
                                       Value(deviceBindingSeedRes),
                                       Value(deviceLabelRes),
                                       Value(sensorIdRes),
                                       Value(hardwareAttestationRes))
    return out

fn MobileCapiBioDidImportWireHandle(requestWire: str): uint64 =
    let out = MobileCapiBioDidImportWire(requestWire)
    let handle = MobileCapiTextBufferHandle(out)
    return handle

fn mobileCapiBioDidImportWireCString(requestWire: str): ptr =
    let out = MobileCapiBioDidImportWire(requestWire)
    let ctext = bridge.InternalMobileBridgeTextCString(out)
    return ctext

fn mobileCapiBioDidImportWireHandleRaw(requestWireRaw: ptr): uint64 =
    let requestWire = bridge.InternalMobileBridgeCopyRawText(requestWireRaw)
    let handle = MobileCapiBioDidImportWireHandle(requestWire)
    return handle

fn mobileCapiBioDidImportWireCStringRaw(requestWireRaw: ptr): ptr =
    let requestWire = bridge.InternalMobileBridgeCopyRawText(requestWireRaw)
    let ctext = mobileCapiBioDidImportWireCString(requestWire)
    return ctext

fn MobileCapiBioDidImportHandle(latestBundleText: str,
                                  requestId: str,
                                  feature32Hex: str,
                                  deviceBindingSeed: str,
                                  deviceLabel: str,
                                  sensorId: str,
                                  hardwareAttestation: str): uint64 =
    let out = MobileCapiBioDidImport(latestBundleText,
                                       requestId,
                                       feature32Hex,
                                       deviceBindingSeed,
                                       deviceLabel,
                                       sensorId,
                                       hardwareAttestation)
    let handle = MobileCapiTextBufferHandle(out)
    return handle

fn mobileCapiBioDidImportCString(latestBundleText: str,
                                   requestId: str,
                                   feature32Hex: str,
                                   deviceBindingSeed: str,
                                   deviceLabel: str,
                                   sensorId: str,
                                   hardwareAttestation: str): ptr =
    let out = MobileCapiBioDidImport(latestBundleText,
                                       requestId,
                                       feature32Hex,
                                       deviceBindingSeed,
                                       deviceLabel,
                                       sensorId,
                                       hardwareAttestation)
    let ctext = bridge.InternalMobileBridgeTextCString(out)
    return ctext

