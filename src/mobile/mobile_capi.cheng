fn mobileCapiBioDidCreateIdentityFieldsCStringRaw(requestIdRaw: ptr,
                                                    feature32HexRaw: ptr,
                                                    deviceBindingSeedRaw: ptr,
                                                    deviceLabelRaw: ptr,
                                                    sensorIdRaw: ptr,
                                                    hardwareAttestationRaw: ptr): ptr =
    let requestId = bridge.InternalMobileBridgeCopyRawText(requestIdRaw)
    let feature32Hex = bridge.InternalMobileBridgeCopyRawText(feature32HexRaw)
    let deviceBindingSeed = bridge.InternalMobileBridgeCopyRawText(deviceBindingSeedRaw)
    let deviceLabel = bridge.InternalMobileBridgeCopyRawText(deviceLabelRaw)
    let sensorId = bridge.InternalMobileBridgeCopyRawText(sensorIdRaw)
    let hardwareAttestation = bridge.InternalMobileBridgeCopyRawText(hardwareAttestationRaw)
    let captureRes = MobileCapiBioDidCapture(requestId,
                                               feature32Hex,
                                               deviceBindingSeed,
                                               deviceLabel,
                                               sensorId,
                                               hardwareAttestation)
    if IsErr(captureRes):
        return bridge.InternalMobileBridgeTextCString("")
    let createRes = bio_did.BioDidCreateBundleWithHardwareCapture(Value(captureRes),
                                                                    times.EpochTimeSeconds())
    if IsErr(createRes):
        return bridge.InternalMobileBridgeTextCString("")
    let outcome = Value(createRes)
    var out = ""
    out = did.DidStoreAppendLine(out, "did", outcome.document.did)
    out = did.DidStoreAppendLine(out, "rootSeed", outcome.identity.rootSeed)
    out = did.DidStoreAppendLine(out, "deviceSeed", outcome.identity.deviceSeed)
    return bridge.InternalMobileBridgeTextCString(out)

fn mobileCapiBioDidCreateBundleCStringRaw(requestIdRaw: ptr,
                                            feature32HexRaw: ptr,
                                            deviceBindingSeedRaw: ptr,
                                            deviceLabelRaw: ptr,
                                            sensorIdRaw: ptr,
                                            hardwareAttestationRaw: ptr): ptr =
    let requestId = bridge.InternalMobileBridgeCopyRawText(requestIdRaw)
