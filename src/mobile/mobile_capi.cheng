    let deviceLabel = bridge.InternalMobileBridgeCopyRawText(deviceLabelRaw)
    let sensorId = bridge.InternalMobileBridgeCopyRawText(sensorIdRaw)
    let hardwareAttestation = bridge.InternalMobileBridgeCopyRawText(hardwareAttestationRaw)
    let handle = MobileCapiBioDidImportHandle(latestBundleText,
                                                requestId,
                                                feature32Hex,
                                                deviceBindingSeed,
                                                deviceLabel,
                                                sensorId,
                                                hardwareAttestation)
    return handle

fn mobileCapiBioDidImportCStringRaw(latestBundleTextRaw: ptr,
                                      requestIdRaw: ptr,
                                      feature32HexRaw: ptr,
                                      deviceBindingSeedRaw: ptr,
                                      deviceLabelRaw: ptr,
                                      sensorIdRaw: ptr,
                                      hardwareAttestationRaw: ptr): ptr =
