    let buildWire = bridge.InternalMobileBridgeCopyRawTextLen(buildWireRaw, buildWireLen)
    let requestWire = bridge.InternalMobileBridgeCopyRawTextLen(requestWireRaw, requestWireLen)
    let outputDirRes = moq.MoqFountainWireFindValue(requestWire, "output_dir")
    if IsErr(outputDirRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(outputDirRes)))
    let fileNameStemRes = moq.MoqFountainWireFindValue(requestWire, "file_name_stem")
    if IsErr(fileNameStemRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(fileNameStemRes)))
    let persistRes = MobileCapiMoqPersistWire(buildWire, Value(outputDirRes), Value(fileNameStemRes))
    if IsErr(persistRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(persistRes)))
    return bridge.InternalMobileBridgeTextCString(Value(persistRes))

fn mobileCapiMoqFountainBuildPersistRequestHandleRaw(blobPtr: ptr,
                                                       blobLen: int32,
                                                       requestWireRaw: ptr,
                                                       requestWireLen: int32): uint64 =
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_enter")
    if blobPtr == nil || blobLen <= 0:
        return MobileCapiTextBufferHandle(MobileCapiMoqError("moq_fountain_empty_blob"))
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_before_copy_request_wire")
    let requestWire = bridge.InternalMobileBridgeCopyRawTextLen(requestWireRaw, requestWireLen)
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_copy_request_wire")
    let ownerPeerIdRes = moq.MoqFountainWireFindValue(requestWire, "owner_peer_id")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_owner_peer_id")
    if IsErr(ownerPeerIdRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(ownerPeerIdRes)))
    let remotePeersCsvRes = moq.MoqFountainWireFindValue(requestWire, "remote_peers_csv")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_remote_peers_csv")
    if IsErr(remotePeersCsvRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(remotePeersCsvRes)))
    let mimeTypeRes = moq.MoqFountainWireFindValue(requestWire, "mime_type")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_mime_type")
    if IsErr(mimeTypeRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(mimeTypeRes)))
    let objectTargetBytesRes = moq.MoqFountainParseInt32Wire(requestWire, "object_target_bytes")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_object_target_bytes")
    if IsErr(objectTargetBytesRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(objectTargetBytesRes)))
    let sourceBlockBytesRes = moq.MoqFountainParseInt32Wire(requestWire, "source_block_bytes")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_source_block_bytes")
    if IsErr(sourceBlockBytesRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(sourceBlockBytesRes)))
    let repairDropletCountRes = moq.MoqFountainParseInt32Wire(requestWire, "repair_droplet_count")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_repair_droplet_count")
    if IsErr(repairDropletCountRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(repairDropletCountRes)))
    let outputDirRes = moq.MoqFountainWireFindValue(requestWire, "output_dir")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_output_dir")
    if IsErr(outputDirRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(outputDirRes)))
    let fileNameStemRes = moq.MoqFountainWireFindValue(requestWire, "file_name_stem")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_file_name_stem")
    if IsErr(fileNameStemRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(fileNameStemRes)))
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_before_build_call")
    let persistRes = MobileCapiMoqBuildPersistDirect(bytesView(blobPtr, blobLen),
                                                       Value(ownerPeerIdRes),
                                                       Value(remotePeersCsvRes),
                                                       Value(mimeTypeRes),
                                                       Value(objectTargetBytesRes),
                                                       Value(sourceBlockBytesRes),
                                                       Value(repairDropletCountRes),
                                                       Value(outputDirRes),
                                                       Value(fileNameStemRes))
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_build_call")
    if IsErr(persistRes):
        return MobileCapiTextBufferHandle(MobileCapiMoqError(Error(persistRes)))
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_persist_wire")
    MobileCapiEmitLog("mobile_moq:build_persist_request_handle_before_result_handle")
    return MobileCapiTextBufferHandle(Value(persistRes))

