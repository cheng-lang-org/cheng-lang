fn mobileCapiMoqFountainBuildPersistFileCStringRaw(blobPathRaw: ptr,
                                                     requestWireRaw: ptr): ptr =
    if blobPathRaw == nil:
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError("moq_fountain_missing_blob_path"))
    if requestWireRaw == nil:
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError("moq_fountain_missing_request_wire"))
    let blobPath = bridge.InternalMobileBridgeCopyRawText(blobPathRaw)
    if len(blobPath) <= 0:
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError("moq_fountain_missing_blob_path"))
    let requestWire = bridge.InternalMobileBridgeCopyRawText(requestWireRaw)
    if len(requestWire) <= 0:
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError("moq_fountain_missing_request_wire"))
    let blobText = os.ReadFile(blobPath)
    let blobBytes = bytesFromString(blobText)
    if bytesLen(blobBytes) <= 0:
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError("moq_fountain_empty_blob"))
    let ownerPeerIdRes = moq.MoqFountainWireFindValue(requestWire, "owner_peer_id")
    if IsErr(ownerPeerIdRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(ownerPeerIdRes)))
    let remotePeersCsvRes = moq.MoqFountainWireFindValue(requestWire, "remote_peers_csv")
    if IsErr(remotePeersCsvRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(remotePeersCsvRes)))
    let mimeTypeRes = moq.MoqFountainWireFindValue(requestWire, "mime_type")
    if IsErr(mimeTypeRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(mimeTypeRes)))
    let objectTargetBytesRes = moq.MoqFountainParseInt32Wire(requestWire, "object_target_bytes")
    if IsErr(objectTargetBytesRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(objectTargetBytesRes)))
    let sourceBlockBytesRes = moq.MoqFountainParseInt32Wire(requestWire, "source_block_bytes")
    if IsErr(sourceBlockBytesRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(sourceBlockBytesRes)))
    let repairDropletCountRes = moq.MoqFountainParseInt32Wire(requestWire, "repair_droplet_count")
    if IsErr(repairDropletCountRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(repairDropletCountRes)))
    let outputDirRes = moq.MoqFountainWireFindValue(requestWire, "output_dir")
    if IsErr(outputDirRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(outputDirRes)))
    let fileNameStemRes = moq.MoqFountainWireFindValue(requestWire, "file_name_stem")
    if IsErr(fileNameStemRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(fileNameStemRes)))
    let persistRes = MobileCapiMoqBuildPersistDirect(blobBytes,
                                                       Value(ownerPeerIdRes),
                                                       Value(remotePeersCsvRes),
                                                       Value(mimeTypeRes),
                                                       Value(objectTargetBytesRes),
                                                       Value(sourceBlockBytesRes),
                                                       Value(repairDropletCountRes),
                                                       Value(outputDirRes),
                                                       Value(fileNameStemRes))
    if IsErr(persistRes):
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError(Error(persistRes)))
    return bridge.InternalMobileBridgeTextCString(Value(persistRes))

fn mobileCapiMoqFountainBuildPersistRequestFileCStringRaw(requestPathRaw: ptr): ptr =
    if requestPathRaw == nil:
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError("moq_fountain_missing_request_path"))
    let requestPath = bridge.InternalMobileBridgeCopyRawText(requestPathRaw)
    if len(requestPath) <= 0:
        return bridge.InternalMobileBridgeTextCString(MobileCapiMoqError("moq_fountain_missing_request_path"))
