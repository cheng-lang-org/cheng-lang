fn mobileCapiBioDidCreateDiagRecoverCStringRaw(requestIdRaw: ptr,
                                                 feature32HexRaw: ptr,
                                                 deviceBindingSeedRaw: ptr,
                                                 deviceLabelRaw: ptr,
                                                 sensorIdRaw: ptr,
                                                 hardwareAttestationRaw: ptr): ptr =
