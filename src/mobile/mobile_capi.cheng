fn MobileCapiEmitLog(message: str) =
    bridge.InternalMobileBridgeEmitLog(message)

@exportc("MobileCapiPeerIdFromSeed")
fn MobileCapiPeerIdFromSeed(seed: str): str =
    var peerValue: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(peerValue, seed)
    return peer_id.Libp2pPeerIdText(peerValue)

@exportc("MobileCapiDidFromRootSeed")
fn MobileCapiDidFromRootSeed(rootSeed: str): str =
    let out = did.DidFromRootSeed(rootSeed)
    return out

@exportc("MobileCapiDidDevicePeerIdFromSeed")
fn MobileCapiDidDevicePeerIdFromSeed(deviceSeed: str): str =
    let peerValue = did.DidDevicePeerIdFromSeed(deviceSeed)
    let out = peer_id.Libp2pPeerIdText(peerValue)
    return out

@exportc("MobileCapiPeerIdNormalize")
fn MobileCapiPeerIdNormalize(peerText: str): str =
    var peerValue: types.Libp2pPeerId
    let peerRes = peer_id.Libp2pPeerIdFillFromText(peerValue, peerText)
    if IsErr(peerRes):
        return ""
    return peer_id.Libp2pPeerIdText(peerValue)

@exportc("MobileCapiMultiaddrNormalize")
fn MobileCapiMultiaddrNormalize(addrText: str): str =
    var addr: types.Libp2pMultiaddr
    let addrRes = multiaddr.Libp2pMultiaddrFillFromText(addr, addrText)
    if IsErr(addrRes):
        return ""
    return multiaddr.Libp2pMultiaddrText(addr)

@exportc("MobileCapiDialableAddr")
fn MobileCapiDialableAddr(addrText: str, peerText: str): str =
    let base = MobileCapiMultiaddrNormalize(addrText)
    if len(base) <= 0:
        return ""
    let peer = MobileCapiPeerIdNormalize(peerText)
    if len(peer) <= 0:
        return ""
    if strings.StrContains(base, "/p2p/") || strings.StrContains(base, "/ipfs/"):
        return base
    return Fmt"{base}/p2p/{peer}"

fn MobileCapiBioDidCapture(requestId: str,
                             feature32Hex: str,
                             deviceBindingSeed: str,
                             deviceLabel: str,
                             sensorId: str,
                             hardwareAttestation: str): Result[bio_did.BioDidHardwareCapture] =
    let featureRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(feature32Hex)
    if IsErr(featureRes):
        return Err[bio_did.BioDidHardwareCapture](" mobile capi: invalid fingerprint feature32")
    var capture = bio_did.BioDidHardwareCapture()
    capture.verified = true
    capture.feature32 = Value(featureRes)
    capture.requestId = requestId
    capture.sensorId = sensorId
    capture.deviceBindingSeed = deviceBindingSeed
    capture.deviceLabel = deviceLabel
    capture.hardwareAttestation = hardwareAttestation
    let captureOk = bio_did.BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[bio_did.BioDidHardwareCapture](Error(captureOk))
    return Ok[bio_did.BioDidHardwareCapture](capture)

fn MobileCapiTextHex(value: str): str =
    let raw = bytesFromString(value)
    let out = bytesToHex(raw)
    return out

fn MobileCapiDecodeWireText(text: str): Result[str] =
    let bytesRes = did.DidStoreDecodeBytes(text)
    if IsErr(bytesRes):
        return Err[str](Error(bytesRes))
    let decoded = bytesToString(Value(bytesRes))
    return Ok[str](decoded)

fn MobileCapiWireFindValue(wire: str, key: str): Result[str] =
    let prefix = Fmt"{key}="
    var lineStart: int32
    let n = strings.Len(wire)
    while lineStart < n:
        var lineEnd = lineStart
        for lineEnd in range(n):

            if wire[lineEnd] == '\n':
                break

        var line = ""
        if lineEnd > lineStart:
            line = strutils.SliceStr(wire, lineStart, lineEnd - 1)
        if strutils.StartsWith(line, prefix):
            return Ok[str](strutils.SliceStr(line, strings.Len(prefix), strings.Len(line) - 1))
        lineStart = lineEnd + 1
    return Err[str](Fmt" mobile capi: missing wire field {key}")

fn MobileCapiWireDecodedValue(wire: str, key: str): Result[str] =
    let rawRes = MobileCapiWireFindValue(wire, key)
    if IsErr(rawRes):
        return Err[str](Error(rawRes))
    let decodedRes = MobileCapiDecodeWireText(Value(rawRes))
    return decodedRes

fn MobileCapiBioDidErrorJson(errorText: str): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "ok", "0")
    out = did.DidStoreAppendLine(out, "error", errorText)
    return out

fn MobileCapiTextBufferHandle(text: str): uint64 =
    let raw = bytesFromString(text)
    let textLen = bytesLen(raw)
    let rawData = raw.data
    if textLen <= 0 || rawData == nil:
        return uint64(0)
    MobileCapiEmitLog("mobile_moq:text_buffer_handle_before_bridge")
    let handle = bridge.InternalMobileBridgeBufferHandleCopy(rawData, textLen)
    MobileCapiEmitLog("mobile_moq:text_buffer_handle_after_bridge")
    return handle

fn MobileCapiBytesBufferHandle(payload: Bytes): uint64 =
    let payloadLen = bytesLen(payload)
    if payloadLen <= 0:
        return uint64(0)
    let payloadData = payload.data
    if payloadData == nil:
        return uint64(0)
    return bridge.InternalMobileBridgeBufferHandleCopy(payloadData, payloadLen)

type MobileMoqDroplet = object
    objectIndex: int32
    dropletIndex: int32
    kindCode: int32
    key: str
    peerId: str
    cid: str
    degree: int32
    blockIndexes: int32[]
    payload: Bytes

type MobileMoqObject = object
    objectIndex: int32
    groupId: str
    objectId: str
    priority: int32
    byteOffset: int32
    byteLength: int32
    objectCid: str
    sourceBlockBytes: int32
    sourceBlockCount: int32
    repairDropletCount: int32
    droplets: MobileMoqDroplet[]

type MobileMoqEquation = object
    coeffs: int32[]
    payload: Bytes

type MobileMoqBuildResult = object
    ownerPeerId: str
    mimeType: str
    bundleCid: str
    blobCid: str
    catalogKey: str
    catalogCid: str
    catalogSizeBytes: int32
    catalogPayloadText: str
    catalogPayload: Bytes
    rebuildTemplateKey: str
    rebuildTemplateCid: str
    rebuildTemplateSizeBytes: int32
    rebuildTemplatePayloadText: str
    rebuildTemplatePayload: Bytes
    blobByteLen: int32
    objectTargetBytes: int32
    sourceBlockBytes: int32
    objectCount: int32
    remoteAckPeerIds: str[]
    objects: MobileMoqObject[]
    droplets: MobileMoqDroplet[]

const MobileMoqCatalogMagic = "unimaker.moq.fountain.catalog.v1"
const MobileMoqTransport = "native_media_rpc"
const MobileMoqLayout = "lt_xor_v1"
const MobileMoqDropletKindSource = 1
const MobileMoqDropletKindRepair = 2

fn MobileCapiByteBufAppendText(buf: var layout.ByteBuf, text: str) =
    if len(text) <= 0:
        return
    layout.ByteBufAppendBytes(buf, bytesFromString(text))

fn mobileCapiWireBufAppendRaw(buf: var layout.ByteBuf, key: str, value: str) =
    MobileCapiByteBufAppendText(buf, key)
    layout.ByteBufAppendByte(buf, int32('='))
    MobileCapiByteBufAppendText(buf, value)
    layout.ByteBufAppendByte(buf, int32('\n'))

fn MobileCapiWireBufAppendInt(buf: var layout.ByteBuf, key: str, value: int32) =
    mobileCapiWireBufAppendRaw(buf, key, strings.IntToStr(value))

fn MobileCapiWireRow(key: str, value: str): str =
    var buf = layout.ByteBufInit(len(key) + len(value) + 1)
    MobileCapiByteBufAppendText(buf, key)
    layout.ByteBufAppendByte(buf, int32('='))
    MobileCapiByteBufAppendText(buf, value)
    return bytesToString(layout.ByteBufToBytes(buf))

fn MobileCapiWireRowInt(key: str, value: int32): str =
    return MobileCapiWireRow(key, strings.IntToStr(value))

fn MobileCapiWireRowUint64(key: str, value: uint64): str =
    return MobileCapiWireRow(key, strings.Uint64ToStr(value))

fn MobileCapiWireRowsText(rows: str[]): str =
    if rows.len <= 0:
        return ""
    var cap: int32
    var rowLen: int32
    for rowLen in rowLen..<rows.len:
        cap = cap + len(rows[rowLen]) + 1
    var buf = layout.ByteBufInit(cap)
    var row: int32
    for row in row..<rows.len:
        MobileCapiByteBufAppendText(buf, rows[row])
        layout.ByteBufAppendByte(buf, int32('\n'))
    return bytesToString(layout.ByteBufToBytes(buf))

fn MobileCapiWireRowsResult(rows: str[], errorText: str): Result[str] =
    let out = MobileCapiWireRowsText(rows)
    if len(out) <= 0:
        return Err[str](errorText)
    return Ok[str](out)

fn MobileCapiWireMergeRows(baseWire: str, extraRows: str[], errorText: str): Result[str] =
    let suffixRes = MobileCapiWireRowsResult(extraRows, errorText)
    if IsErr(suffixRes):
        return Err[str](Error(suffixRes))
    let suffix = Value(suffixRes)
    if len(baseWire) <= 0:
        return Ok[str](suffix)
    if baseWire[len(baseWire) - 1] == '\n':
        var buf = layout.ByteBufInit(len(baseWire) + len(suffix))
        MobileCapiByteBufAppendText(buf, baseWire)
        MobileCapiByteBufAppendText(buf, suffix)
        return Ok[str](bytesToString(layout.ByteBufToBytes(buf)))
    var buf = layout.ByteBufInit(len(baseWire) + len(suffix) + 1)
    MobileCapiByteBufAppendText(buf, baseWire)
    layout.ByteBufAppendByte(buf, int32('\n'))
    MobileCapiByteBufAppendText(buf, suffix)
    return Ok[str](bytesToString(layout.ByteBufToBytes(buf)))

fn MobileCapiMoqDropletKindText(kindCode: int32): str =
    if kindCode == MobileMoqDropletKindSource:
        return "source"
    if kindCode == MobileMoqDropletKindRepair:
        return "repair"
    return "unknown"

fn MobileCapiMoqError(errorText: str): str =
    var rows: str[]
    rows = []
    add(rows, MobileCapiWireRow("ok", "0"))
    add(rows, MobileCapiWireRow("error", errorText))
    return MobileCapiWireRowsText(rows)

fn MobileCapiPathJoin(dirPath: str, fileName: str): str =
    if len(dirPath) <= 0:
        return fileName
    let needSep = dirPath[len(dirPath) - 1] != '/'
    var buf = layout.ByteBufInit(len(dirPath) + len(fileName) + if needSep: 1 else: 0)
    MobileCapiByteBufAppendText(buf, dirPath)
    if needSep:
        layout.ByteBufAppendByte(buf, int32('/'))
    MobileCapiByteBufAppendText(buf, fileName)
    return bytesToString(layout.ByteBufToBytes(buf))

fn MobileCapiPathJoinStemSuffix(dirPath: str, fileNameStem: str, suffix: str): str =
    if len(dirPath) <= 0:
        var fileBuf = layout.ByteBufInit(len(fileNameStem) + len(suffix))
        MobileCapiByteBufAppendText(fileBuf, fileNameStem)
        MobileCapiByteBufAppendText(fileBuf, suffix)
        return bytesToString(layout.ByteBufToBytes(fileBuf))
    let needSep = dirPath[len(dirPath) - 1] != '/'
    var buf = layout.ByteBufInit(len(dirPath) + len(fileNameStem) + len(suffix) + if needSep: 1 else: 0)
    MobileCapiByteBufAppendText(buf, dirPath)
    if needSep:
        layout.ByteBufAppendByte(buf, int32('/'))
    MobileCapiByteBufAppendText(buf, fileNameStem)
    MobileCapiByteBufAppendText(buf, suffix)
    return bytesToString(layout.ByteBufToBytes(buf))

fn MobileCapiDropletFileSuffix(objectIndex: int32,
                                 dropletIndex: int32): str =
    let objectText = strings.IntToStr(objectIndex)
    let dropletText = strings.IntToStr(dropletIndex)
    let cap = len(objectText) + len(dropletText) + 10
    var buf = layout.ByteBufInit(cap)
    layout.ByteBufAppendByte(buf, int32('.'))
    MobileCapiByteBufAppendText(buf, objectText)
    layout.ByteBufAppendByte(buf, int32('.'))
    MobileCapiByteBufAppendText(buf, dropletText)
    MobileCapiByteBufAppendText(buf, ".droplet")
    return bytesToString(layout.ByteBufToBytes(buf))

fn MobileCapiDropletKindFileSuffix(objectIndex: int32,
                                     kindText: str,
                                     dropletIndex: int32): str =
    let objectText = strings.IntToStr(objectIndex)
    let dropletText = strings.IntToStr(dropletIndex)
    let cap = len(objectText) + len(kindText) + len(dropletText) + 11
    var buf = layout.ByteBufInit(cap)
    layout.ByteBufAppendByte(buf, int32('.'))
    MobileCapiByteBufAppendText(buf, objectText)
    layout.ByteBufAppendByte(buf, int32('.'))
    MobileCapiByteBufAppendText(buf, kindText)
    layout.ByteBufAppendByte(buf, int32('.'))
    MobileCapiByteBufAppendText(buf, dropletText)
    MobileCapiByteBufAppendText(buf, ".droplet")
    return bytesToString(layout.ByteBufToBytes(buf))

fn MobileCapiIndexedFieldKey(groupName: str,
                               itemIndex: int32,
                               fieldName: str): str =
    let indexText = strings.IntToStr(itemIndex)
    let cap = len(groupName) + len(indexText) + len(fieldName) + 2
    var buf = layout.ByteBufInit(cap)
    MobileCapiByteBufAppendText(buf, groupName)
    layout.ByteBufAppendByte(buf, int32('.'))
    MobileCapiByteBufAppendText(buf, indexText)
    layout.ByteBufAppendByte(buf, int32('.'))
    MobileCapiByteBufAppendText(buf, fieldName)
    return bytesToString(layout.ByteBufToBytes(buf))

fn MobileCapiWriteBytesFile(path: str, payload: Bytes): Result[bool] =
    return bridge.InternalMobileBridgeWriteBytesFile(path, payload)

fn MobileCapiAppendBytesFile(path: str, payload: Bytes): Result[bool] =
    return bridge.InternalMobileBridgeAppendBytesFile(path, payload)

fn MobileCapiWriteTraceLine(path: str, line: str): Result[bool] =
    MobileCapiAppendBytesFile(path, bytesFromString(Fmt"{line}\n"))

fn MobileCapiMaybeWriteTraceLine(path: str, line: str) =
    if len(path) <= 0:
        return
    let _trace = MobileCapiWriteTraceLine(path, line)

fn MobileCapiMoqBuildPersistWire(result: MobileMoqBuildResult,
                                   outputDir: str,
                                   fileNameStem: str): Result[str] =
    MobileCapiEmitLog("mobile_moq:build_persist_wire_enter")
    let catalogPath = MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".catalog.json")
    MobileCapiEmitLog("mobile_moq:build_persist_wire_after_catalog_path")
    let catalogPayloadForWrite = bytesFromString(result.catalogPayloadText)
    if bytesLen(catalogPayloadForWrite) <= 0:
        return Err[str]("moq_fountain_empty_catalog_payload")
    let catalogWriteRes = MobileCapiWriteBytesFile(catalogPath, catalogPayloadForWrite)
    if IsErr(catalogWriteRes):
        return Err[str](Error(catalogWriteRes))
    MobileCapiEmitLog("mobile_moq:build_persist_wire_after_catalog_write")
    let rebuildPath = MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".rebuild.txt")
    MobileCapiEmitLog("mobile_moq:build_persist_wire_after_rebuild_path")
    let rebuildPayloadForWrite = bytesFromString(result.rebuildTemplatePayloadText)
    if bytesLen(rebuildPayloadForWrite) <= 0:
        return Err[str]("moq_fountain_empty_rebuild_template")
    let rebuildWriteRes = MobileCapiWriteBytesFile(rebuildPath, rebuildPayloadForWrite)
    if IsErr(rebuildWriteRes):
        return Err[str](Error(rebuildWriteRes))
    MobileCapiEmitLog("mobile_moq:build_persist_wire_after_rebuild_write")
    var rows: str[]
    rows = []
    add(rows, MobileCapiWireRow("ok", "1"))
    add(rows, MobileCapiWireRow("owner_peer_id", result.ownerPeerId))
    add(rows, MobileCapiWireRow("mime_type", result.mimeType))
    add(rows, MobileCapiWireRow("bundle_cid", result.bundleCid))
    add(rows, MobileCapiWireRow("blob_cid", result.blobCid))
    add(rows, MobileCapiWireRow("catalog_key", result.catalogKey))
    add(rows, MobileCapiWireRow("catalog_cid", result.catalogCid))
    add(rows, MobileCapiWireRowInt("catalog_size_bytes", result.catalogSizeBytes))
    add(rows, MobileCapiWireRow("catalog_path", catalogPath))
    add(rows, MobileCapiWireRow("rebuild_template_key", result.rebuildTemplateKey))
    add(rows, MobileCapiWireRow("rebuild_template_cid", result.rebuildTemplateCid))
    add(rows, MobileCapiWireRowInt("rebuild_template_size_bytes", result.rebuildTemplateSizeBytes))
    add(rows, MobileCapiWireRow("rebuild_template_path", rebuildPath))
    add(rows, MobileCapiWireRowInt("blob_byte_len", result.blobByteLen))
    add(rows, MobileCapiWireRowInt("object_target_bytes", result.objectTargetBytes))
    add(rows, MobileCapiWireRowInt("source_block_bytes", result.sourceBlockBytes))
    add(rows, MobileCapiWireRowInt("object_count", result.objectCount))
    add(rows, MobileCapiWireRow("remote_ack_peer_ids", MobileCapiJoinCsv(result.remoteAckPeerIds)))
    MobileCapiEmitLog("mobile_moq:build_persist_wire_after_header_rows")
    var objectRow: int32
    for objectRow in objectRow..<result.objects.len:
        MobileCapiEmitLog("mobile_moq:build_persist_wire_object_row_begin")
        let objectIndexKey = MobileCapiIndexedFieldKey("object", objectRow, "object_index")
        MobileCapiEmitLog("mobile_moq:build_persist_wire_object_index_key_ready")
        add(rows,
            MobileCapiWireRowInt(objectIndexKey,
                                   result.objects[objectRow].objectIndex))
        MobileCapiEmitLog("mobile_moq:build_persist_wire_object_index_ready")
        let sourceBlockBytesKey = MobileCapiIndexedFieldKey("object", objectRow, "source_block_bytes")
        MobileCapiEmitLog("mobile_moq:build_persist_wire_object_block_key_ready")
        add(rows,
            MobileCapiWireRowInt(sourceBlockBytesKey,
                                   result.objects[objectRow].sourceBlockBytes))
        MobileCapiEmitLog("mobile_moq:build_persist_wire_object_block_ready")
        let repairDropletCountKey = MobileCapiIndexedFieldKey("object", objectRow, "repair_droplet_count")
        MobileCapiEmitLog("mobile_moq:build_persist_wire_object_repair_key_ready")
        add(rows,
            MobileCapiWireRowInt(repairDropletCountKey,
                                   result.objects[objectRow].repairDropletCount))
        MobileCapiEmitLog("mobile_moq:build_persist_wire_object_row_done")
    MobileCapiEmitLog("mobile_moq:build_persist_wire_after_object_rows")
    add(rows, MobileCapiWireRowInt("droplet_count", result.droplets.len))
    var dropletRow: int32
    for dropletRow in dropletRow..<result.droplets.len:
        MobileCapiEmitLog("mobile_moq:build_persist_wire_droplet_row_begin")
        let dropletPath = MobileCapiPathJoinStemSuffix(outputDir,
                                                         fileNameStem,
                                                         MobileCapiDropletFileSuffix(result.droplets[dropletRow].objectIndex,
                                                                                      result.droplets[dropletRow].dropletIndex))
        MobileCapiEmitLog("mobile_moq:build_persist_wire_droplet_path_ready")
        let dropletWriteRes = MobileCapiWriteBytesFile(dropletPath, result.droplets[dropletRow].payload)
        if IsErr(dropletWriteRes):
            return Err[str](Error(dropletWriteRes))
        MobileCapiEmitLog("mobile_moq:build_persist_wire_droplet_write_ready")
        add(rows,
            MobileCapiWireRowInt(MobileCapiIndexedFieldKey("droplet",
                                                               dropletRow,
                                                               "object_index"),
                                   result.droplets[dropletRow].objectIndex))
        add(rows,
            MobileCapiWireRowInt(MobileCapiIndexedFieldKey("droplet",
                                                               dropletRow,
                                                               "droplet_index"),
                                   result.droplets[dropletRow].dropletIndex))
        add(rows,
            MobileCapiWireRow(MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "key"),
                                result.droplets[dropletRow].key))
        add(rows,
            MobileCapiWireRow(MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "peer_id"),
                                result.droplets[dropletRow].peerId))
        add(rows,
            MobileCapiWireRow(MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "cid"),
                                result.droplets[dropletRow].cid))
        add(rows,
            MobileCapiWireRow(MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "block_indexes"),
                                MobileCapiJoinIntCsv(result.droplets[dropletRow].blockIndexes)))
        add(rows,
            MobileCapiWireRow(MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "path"),
                                dropletPath))
        MobileCapiEmitLog("mobile_moq:build_persist_wire_droplet_row_done")
    MobileCapiEmitLog("mobile_moq:build_persist_wire_after_droplet_rows")
    return MobileCapiWireRowsResult(rows, "moq_fountain_empty_persist_wire")

fn MobileCapiMoqBuildPersistWireCore(result: moq.MoqFountainBuildResult,
                                       outputDir: str,
                                       fileNameStem: str): Result[str] =
    let catalogPath = MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".catalog.json")
    let catalogWriteRes = MobileCapiWriteBytesFile(catalogPath, result.catalogPayload)
    if IsErr(catalogWriteRes):
        return Err[str](Error(catalogWriteRes))
    let rebuildPath = MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".rebuild.txt")
    let rebuildWriteRes = MobileCapiWriteBytesFile(rebuildPath, result.rebuildTemplatePayload)
    if IsErr(rebuildWriteRes):
        return Err[str](Error(rebuildWriteRes))
    var rows: str[]
    rows = []
    add(rows, MobileCapiWireRow("ok", "1"))
    add(rows, MobileCapiWireRow("owner_peer_id", result.ownerPeerId))
    add(rows, MobileCapiWireRow("mime_type", result.mimeType))
    add(rows, MobileCapiWireRow("bundle_cid", result.bundleCid))
    add(rows, MobileCapiWireRow("blob_cid", result.blobCid))
    add(rows, MobileCapiWireRow("catalog_key", result.catalogKey))
    add(rows, MobileCapiWireRow("catalog_cid", result.catalogCid))
    add(rows, MobileCapiWireRowInt("catalog_size_bytes", result.catalogSizeBytes))
    add(rows, MobileCapiWireRow("catalog_path", catalogPath))
    add(rows, MobileCapiWireRow("rebuild_template_key", result.rebuildTemplateKey))
    add(rows, MobileCapiWireRow("rebuild_template_cid", result.rebuildTemplateCid))
    add(rows, MobileCapiWireRowInt("rebuild_template_size_bytes", result.rebuildTemplateSizeBytes))
    add(rows, MobileCapiWireRow("rebuild_template_path", rebuildPath))
    add(rows, MobileCapiWireRowInt("blob_byte_len", result.blobByteLen))
    add(rows, MobileCapiWireRowInt("object_target_bytes", result.objectTargetBytes))
    add(rows, MobileCapiWireRowInt("source_block_bytes", result.sourceBlockBytes))
    add(rows, MobileCapiWireRowInt("object_count", result.objectCount))
    add(rows, MobileCapiWireRow("remote_ack_peer_ids", MobileCapiJoinCsv(result.remoteAckPeerIds)))
    var objectRow: int32
    for objectRow in objectRow..<result.objects.len:
        let item = result.objects[objectRow]
        let prefix = Fmt"object.{strings.IntToStr(objectRow)}."
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}object_index", item.objectIndex))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}source_block_bytes", item.sourceBlockBytes))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}repair_droplet_count", item.repairDropletCount))
    add(rows, MobileCapiWireRowInt("droplet_count", result.droplets.len))
    var dropletRow: int32
    for dropletRow in dropletRow..<result.droplets.len:
        let droplet = result.droplets[dropletRow]
        let prefix = Fmt"droplet.{strings.IntToStr(dropletRow)}."
        let dropletPath = MobileCapiPathJoinStemSuffix(outputDir,
                                                         fileNameStem,
                                                         MobileCapiDropletFileSuffix(droplet.objectIndex,
                                                                                      droplet.dropletIndex))
        let dropletWriteRes = MobileCapiWriteBytesFile(dropletPath, droplet.payload)
        if IsErr(dropletWriteRes):
            return Err[str](Error(dropletWriteRes))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}object_index", droplet.objectIndex))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}droplet_index", droplet.dropletIndex))
        add(rows, MobileCapiWireRow(Fmt"{prefix}key", droplet.key))
        add(rows, MobileCapiWireRow(Fmt"{prefix}peer_id", droplet.peerId))
        add(rows, MobileCapiWireRow(Fmt"{prefix}cid", droplet.cid))
        add(rows, MobileCapiWireRow(Fmt"{prefix}block_indexes", MobileCapiJoinIntCsv(droplet.blockIndexes)))
        add(rows, MobileCapiWireRow(Fmt"{prefix}path", dropletPath))
    return MobileCapiWireRowsResult(rows, "moq_fountain_empty_persist_wire_core")

fn MobileCapiMoqPersistWire(requestWire: str,
                              outputDir: str,
                              fileNameStem: str): Result[str] =
    if len(outputDir) <= 0:
        return Err[str]("moq_fountain_missing_output_dir")
    if len(fileNameStem) <= 0:
        return Err[str]("moq_fountain_missing_file_stem")
    let catalogPayloadHexRes = moq.MoqFountainWireFindValue(requestWire, "catalog_payload_hex")
    if IsErr(catalogPayloadHexRes):
        return Err[str](Error(catalogPayloadHexRes))
    let rebuildPayloadHexRes = moq.MoqFountainWireFindValue(requestWire, "rebuild_template_payload_hex")
    if IsErr(rebuildPayloadHexRes):
        return Err[str](Error(rebuildPayloadHexRes))
    let catalogPayloadRes = moq.MoqFountainBytesFromHex(Value(catalogPayloadHexRes))
    if IsErr(catalogPayloadRes):
        return Err[str](Error(catalogPayloadRes))
    let rebuildPayloadRes = moq.MoqFountainBytesFromHex(Value(rebuildPayloadHexRes))
    if IsErr(rebuildPayloadRes):
        return Err[str](Error(rebuildPayloadRes))
    let catalogPath = MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".catalog.json")
    let catalogWriteRes = MobileCapiWriteBytesFile(catalogPath, Value(catalogPayloadRes))
    if IsErr(catalogWriteRes):
        return Err[str](Error(catalogWriteRes))
    let rebuildPath = MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".rebuild.txt")
    let rebuildWriteRes = MobileCapiWriteBytesFile(rebuildPath, Value(rebuildPayloadRes))
    if IsErr(rebuildWriteRes):
        return Err[str](Error(rebuildWriteRes))
    let dropletCountRes = moq.MoqFountainParseInt32Wire(requestWire, "droplet_count")
    if IsErr(dropletCountRes):
        return Err[str](Error(dropletCountRes))
    let dropletCount = Value(dropletCountRes)
    var extraRows: str[]
    extraRows = []
    add(extraRows, MobileCapiWireRow("catalog_path", catalogPath))
    add(extraRows, MobileCapiWireRow("rebuild_template_path", rebuildPath))
    var dropletRow: int32
    for dropletRow in dropletRow..<dropletCount:
        let prefix = Fmt"droplet.{strings.IntToStr(dropletRow)}."
        let objectIndexRes = moq.MoqFountainParseInt32Wire(requestWire, Fmt"{prefix}object_index")
        if IsErr(objectIndexRes):
            return Err[str](Error(objectIndexRes))
        let dropletIndexRes = moq.MoqFountainParseInt32Wire(requestWire, Fmt"{prefix}droplet_index")
        if IsErr(dropletIndexRes):
            return Err[str](Error(dropletIndexRes))
        let kindRes = moq.MoqFountainWireFindValue(requestWire, Fmt"{prefix}kind")
        if IsErr(kindRes):
            return Err[str](Error(kindRes))
        let payloadHexRes = moq.MoqFountainWireFindValue(requestWire, Fmt"{prefix}payload_hex")
        if IsErr(payloadHexRes):
            return Err[str](Error(payloadHexRes))
        let payloadRes = moq.MoqFountainBytesFromHex(Value(payloadHexRes))
        if IsErr(payloadRes):
            return Err[str](Error(payloadRes))
        let dropletPath = MobileCapiPathJoinStemSuffix(outputDir,
                                                         fileNameStem,
                                                         MobileCapiDropletKindFileSuffix(Value(objectIndexRes),
                                                                                          Value(kindRes),
                                                                                          Value(dropletIndexRes)))
        let dropletWriteRes = MobileCapiWriteBytesFile(dropletPath, Value(payloadRes))
        if IsErr(dropletWriteRes):
            return Err[str](Error(dropletWriteRes))
        add(extraRows, MobileCapiWireRow(Fmt"{prefix}path", dropletPath))
    return MobileCapiWireMergeRows(requestWire, extraRows, "moq_fountain_empty_persist_wire")

fn MobileCapiMoqBuildHandleWire(result: var MobileMoqBuildResult): str =
    var rows: str[]
    rows = []
    add(rows, MobileCapiWireRow("ok", "1"))
    add(rows, MobileCapiWireRow("owner_peer_id", result.ownerPeerId))
    add(rows, MobileCapiWireRow("mime_type", result.mimeType))
    add(rows, MobileCapiWireRow("bundle_cid", result.bundleCid))
    add(rows, MobileCapiWireRow("blob_cid", result.blobCid))
    add(rows, MobileCapiWireRow("catalog_key", result.catalogKey))
    add(rows, MobileCapiWireRow("catalog_cid", result.catalogCid))
    add(rows, MobileCapiWireRowInt("catalog_size_bytes", result.catalogSizeBytes))
    let catalogHandle = MobileCapiTextBufferHandle(result.catalogPayloadText)
    if catalogHandle == uint64(0):
        return MobileCapiMoqError("moq_fountain_empty_catalog_payload")
    add(rows, MobileCapiWireRowUint64("catalog_handle", catalogHandle))
    add(rows, MobileCapiWireRow("rebuild_template_key", result.rebuildTemplateKey))
    add(rows, MobileCapiWireRow("rebuild_template_cid", result.rebuildTemplateCid))
    add(rows, MobileCapiWireRowInt("rebuild_template_size_bytes", result.rebuildTemplateSizeBytes))
    let rebuildTemplateHandle = MobileCapiTextBufferHandle(result.rebuildTemplatePayloadText)
    if rebuildTemplateHandle == uint64(0):
        return MobileCapiMoqError("moq_fountain_empty_rebuild_template")
    add(rows, MobileCapiWireRowUint64("rebuild_template_handle", rebuildTemplateHandle))
    add(rows, MobileCapiWireRowInt("blob_byte_len", result.blobByteLen))
    add(rows, MobileCapiWireRowInt("object_target_bytes", result.objectTargetBytes))
    add(rows, MobileCapiWireRowInt("source_block_bytes", result.sourceBlockBytes))
    add(rows, MobileCapiWireRowInt("object_count", result.objectCount))
    add(rows, MobileCapiWireRow("remote_ack_peer_ids", MobileCapiJoinCsv(result.remoteAckPeerIds)))
    var objectRow: int32
    for objectRow in objectRow..<result.objects.len:
        let item = result.objects[objectRow]
        let prefix = Fmt"object.{strings.IntToStr(objectRow)}."
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}object_index", item.objectIndex))
        add(rows, MobileCapiWireRow(Fmt"{prefix}group_id", item.groupId))
        add(rows, MobileCapiWireRow(Fmt"{prefix}object_id", item.objectId))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}priority", item.priority))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}byte_offset", item.byteOffset))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}byte_length", item.byteLength))
        add(rows, MobileCapiWireRow(Fmt"{prefix}object_cid", item.objectCid))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}source_block_bytes", item.sourceBlockBytes))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}source_block_count", item.sourceBlockCount))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}repair_droplet_count", item.repairDropletCount))
    add(rows, MobileCapiWireRowInt("droplet_count", result.droplets.len))
    var dropletRow: int32
    for dropletRow in dropletRow..<result.droplets.len:
        let droplet = result.droplets[dropletRow]
        let prefix = Fmt"droplet.{strings.IntToStr(dropletRow)}."
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}object_index", droplet.objectIndex))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}droplet_index", droplet.dropletIndex))
        add(rows, MobileCapiWireRow(Fmt"{prefix}kind", MobileCapiMoqDropletKindText(droplet.kindCode)))
        add(rows, MobileCapiWireRow(Fmt"{prefix}key", droplet.key))
        add(rows, MobileCapiWireRow(Fmt"{prefix}peer_id", droplet.peerId))
        add(rows, MobileCapiWireRow(Fmt"{prefix}cid", droplet.cid))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}degree", droplet.degree))
        add(rows, MobileCapiWireRow(Fmt"{prefix}block_indexes", MobileCapiJoinIntCsv(droplet.blockIndexes)))
        add(rows, MobileCapiWireRowUint64(Fmt"{prefix}handle", MobileCapiBytesBufferHandle(droplet.payload)))
    let outRes = MobileCapiWireRowsResult(rows, "moq_fountain_empty_build_handle_wire")
    if IsErr(outRes):
        return MobileCapiMoqError(Error(outRes))
    return Value(outRes)

fn MobileCapiMaxInt32(left: int32, right: int32): int32 =
    if left >= right:
        return left
    return right

fn MobileCapiMinInt32(left: int32, right: int32): int32 =
    if left <= right:
        return left
    return right

fn MobileCapiNormalizePositiveInt(value: int32, fallback: int32): int32 =
    var out = value
    if out <= 0:
        out = fallback
    if out <= 0:
        return 1
    return out

fn MobileCapiHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn MobileCapiBytesFromHex(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](emptyBytes())
    if (len(text) % 2) != 0:
        return Err[Bytes](" mobile capi: invalid hex length")
    var out = bytesAlloc(len(text) / 2)
    var i = 0
    for i in range(0, len(text), 2):

        let hi = MobileCapiHexValue(text[i])
        let lo = MobileCapiHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes](" mobile capi: invalid hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn MobileCapiSha256HexBytes(data: Bytes): str =
    let digest = hash256.sha256Fixed(layout.ByteSpanFromBytes(data))
    return layout.FixedBytes32Hex(digest)

fn MobileCapiSha256HexText(text: str): str =
    return MobileCapiSha256HexBytes(bytesFromString(text))

fn MobileCapiAsciiTrimLeft(text: str): int32 =
    var idx: int32
    for idx in range(len(text)):

        let ch = text[idx]
        let code = int32(ch)
        if code == 32:
            idx = idx + 1
            continue
        if code == 10:
            idx = idx + 1
            continue
        if code == 13:
            idx = idx + 1
            continue
        if code == 9:
            idx = idx + 1
            continue
        break
    return idx

fn MobileCapiAsciiTrimRight(text: str): int32 =
    var idx: int32 = len(text)
    while idx > 0:
        let ch = text[idx - 1]
        let code = int32(ch)
        if code == 32:
            idx = idx - 1
            continue
        if code == 10:
            idx = idx - 1
            continue
        if code == 13:
            idx = idx - 1
            continue
        if code == 9:

            continue
        break
    return idx

fn MobileCapiTrimAscii(text: str): str =
    let start = MobileCapiAsciiTrimLeft(text)
    let stop = MobileCapiAsciiTrimRight(text)
    if stop <= start:
        return ""
    return strings.SliceBytes(text, start, stop - start)

fn MobileCapiSplitCsv(text: str): str[] =
    var out: str[]
    out = []
    if len(text) <= 0:
        return out
    var start: int32
    var idx: int32
    for idx in idx..<= len(text):
        let atEnd = idx >= len(text)
        if atEnd || text[idx] == ',':
            var item = ""
            if idx > start:
                item = strings.SliceBytes(text, start, idx - start)
            add(out, item)
            start = idx + 1
    return out

fn MobileCapiNormalizePeerCsv(peerCsv: str): str[] =
    MobileCapiEmitLog("mobile_moq:normalize_peers_enter")
    let parts = MobileCapiSplitCsv(peerCsv)
    MobileCapiEmitLog("mobile_moq:normalize_peers_after_split")
    var out: str[]
    out = []
    var i: int32
    for i in range(parts.len):

        let part = parts[i]
        MobileCapiEmitLog("mobile_moq:normalize_peers_before_trim")
        let candidate = MobileCapiTrimAscii(part)
        MobileCapiEmitLog("mobile_moq:normalize_peers_after_trim")
        if len(candidate) <= 0:

            continue
        var exists = false
        var j: int32
        for j in j..<out.len:
            MobileCapiEmitLog("mobile_moq:normalize_peers_before_equals")
            if out[j] == candidate:
                exists = true
                break
        if !exists:
            add(out, candidate)

    MobileCapiEmitLog("mobile_moq:normalize_peers_ok")
    return out

fn MobileCapiJoinCsv(values: str[]): str =
    if values.len <= 0:
        return ""
    return strutils.Join(values, ",")

fn MobileCapiJoinIntCsv(values: int32[]): str =
    var rows: int32[]
    rows = []
    var i: int32
    for i in i..<values.len:
        add(rows, values[i])
    var texts: str[]
    texts = []
    i = 0
    for i in i..<rows.len:
        add(texts, strings.IntToStr(rows[i]))
    return strutils.Join(texts, ",")

fn MobileCapiEscapeJsonText(text: str): str =
    var out = ""
    for i in 0..<len(text):
        let ch = text[i]
        let code = int32(ch)
        if code == 92:
            out = Fmt"{out}\\\\"
        elif code == 34:
            out = Fmt"{out}\\\""
        elif code == 8:
            out = Fmt"{out}\\b"
        elif code == 12:
            out = Fmt"{out}\\f"
        elif code == 10:
            out = Fmt"{out}\\n"
        elif code == 13:
            out = Fmt"{out}\\r"
        elif code == 9:
            out = Fmt"{out}\\t"
        else:
            out = Fmt"{out}{strings.charToStr(ch)}"
    return out

fn MobileCapiQuoteJsonTextBridge(text: str): str =
    return Fmt"\"{MobileCapiEscapeJsonText(text)}\""

fn MobileCapiStrformatFmtBridge(parts: str[]): str =
    return strutils.Join(parts, "")

fn MobileCapiStrformatLinesBridge(parts: str[]): str =
    return strutils.Join(parts, "\n")

fn MobileCapiJsonEscape(text: str): str =
    let quoted = MobileCapiQuoteJsonTextBridge(text)
    if len(quoted) <= 2:
        return ""
    return strings.SliceBytes(quoted, 1, len(quoted) - 2)

fn MobileCapiJsonQuote(text: str): str =
    let quoted = MobileCapiQuoteJsonTextBridge(text)
    return quoted

fn MobileCapiJoinIntJson(values: int32[]): str =
    if values.len <= 0:
        return "[]"
    var rows: str[]
    rows = []
    for i in 0..<values.len:
        add(rows, strings.IntToStr(values[i]))
    return Fmt"[{strutils.Join(rows, ",")}]"

fn MobileCapiContainsInt(values: int32[], want: int32): bool =
    for i in 0..<values.len:
        if values[i] == want:
            return true
    return false

fn MobileCapiSortInts(values0: int32[]): int32[] =
    var values = values0
    for i in 0..<values.len:
        for j in i + 1..<values.len:
            if values[j] < values[i]:
                let tmp = values[i]
                values[i] = values[j]
                values[j] = tmp
    return values

fn MobileCapiHashSeed(text: str): int32 =
    let digestHex = bridge.InternalMobileBridgeSha256Hex(text)
    if len(digestHex) < 8:
        return 1
    var out: int32
    var i: int32
    for i in i..<8:
        let nibble = MobileCapiHexValue(digestHex[i])
        if nibble < 0:
            return 1
        out = (out << 4) | nibble
    if out == 0:
        return 1
    return out

fn MobileCapiMoqDropletJson(droplet: MobileMoqDroplet): str =
    let kindText = MobileCapiMoqDropletKindText(droplet.kindCode)
    var rows: str[]
    rows = []
    add(rows, Fmt"\"objectIndex\":{strings.IntToStr(droplet.objectIndex)}")
    add(rows, Fmt"\"dropletIndex\":{strings.IntToStr(droplet.dropletIndex)}")
    add(rows, Fmt"\"kind\":{MobileCapiJsonQuote(kindText)}")
    add(rows, Fmt"\"key\":{MobileCapiJsonQuote(droplet.key)}")
    add(rows, Fmt"\"peerId\":{MobileCapiJsonQuote(droplet.peerId)}")
    add(rows, Fmt"\"cid\":{MobileCapiJsonQuote(droplet.cid)}")
    add(rows, Fmt"\"degree\":{strings.IntToStr(droplet.degree)}")
    add(rows, Fmt"\"blockIndexes\":{MobileCapiJoinIntJson(droplet.blockIndexes)}")
    return Fmt"{{{strutils.Join(rows, ",")}}}"

fn MobileCapiMoqDropletsJson(droplets: MobileMoqDroplet[]): str =
    var rows: str[]
    rows = []
    var idx: int32
    for idx in idx..<droplets.len:
        add(rows, MobileCapiMoqDropletJson(droplets[idx]))
    return strutils.Join(rows, ",")

fn MobileCapiMoqObjectJson(item: MobileMoqObject): str =
    var rows: str[]
    rows = []
    add(rows, Fmt"\"objectIndex\":{strings.IntToStr(item.objectIndex)}")
    add(rows, Fmt"\"groupId\":{MobileCapiJsonQuote(item.groupId)}")
    add(rows, Fmt"\"objectId\":{MobileCapiJsonQuote(item.objectId)}")
    add(rows, Fmt"\"priority\":{strings.IntToStr(item.priority)}")
    add(rows, Fmt"\"byteOffset\":{strings.IntToStr(item.byteOffset)}")
    add(rows, Fmt"\"byteLength\":{strings.IntToStr(item.byteLength)}")
    add(rows, Fmt"\"objectCid\":{MobileCapiJsonQuote(item.objectCid)}")
    add(rows, Fmt"\"sourceBlockBytes\":{strings.IntToStr(item.sourceBlockBytes)}")
    add(rows, Fmt"\"sourceBlockCount\":{strings.IntToStr(item.sourceBlockCount)}")
    add(rows, Fmt"\"repairDropletCount\":{strings.IntToStr(item.repairDropletCount)}")
    add(rows, Fmt"\"droplets\":[{MobileCapiMoqDropletsJson(item.droplets)}]")
    return Fmt"{{{strutils.Join(rows, ",")}}}"

fn MobileCapiParseInt32Text(text: str): int32 =
    return int32(strutils.ParseInt(text))

fn MobileCapiParseInt32Wire(requestWire: str, key: str): Result[int32] =
    let rawRes = MobileCapiWireFindValue(requestWire, key)
    if IsErr(rawRes):
        return Err[int32](Error(rawRes))
    let rawText = Value(rawRes)
    return Ok[int32](MobileCapiParseInt32Text(rawText))

fn MobileCapiMoqAppendDroplets(out: var MobileMoqDroplet[],
                                 droplets: MobileMoqDroplet[]) =
    var idx: int32
    for idx in idx..<droplets.len:
        add(out, droplets[idx])

fn MobileCapiMoqBuildObject(objectBytes: Bytes,
                              objectIndex: int32,
                              byteOffset: int32,
                              peers: str[],
                              bundleCid: str,
                              sourceBlockBytes: int32,
                              repairDropletCount: int32): Result[MobileMoqObject] =
    MobileCapiEmitLog("mobile_moq:build_object_enter")
    let objectByteLen = bytesLen(objectBytes)
    MobileCapiEmitLog("mobile_moq:build_object_after_len")
    let objectCid = MobileCapiSha256HexBytes(objectBytes)
    MobileCapiEmitLog("mobile_moq:build_object_after_object_cid")
    let sourceBlockCount = (objectByteLen + sourceBlockBytes - 1) / sourceBlockBytes
    MobileCapiEmitLog("mobile_moq:build_object_after_block_count")
    var blocks: Bytes[]
    blocks = []
    var blockIndex: int32
    for blockIndex in blockIndex..<sourceBlockCount:
        let blockOffset = blockIndex * sourceBlockBytes
        let blockLen = MobileCapiMinInt32(sourceBlockBytes, objectByteLen - blockOffset)
        let blockBytes = bytesSlice(objectBytes, blockOffset, blockLen)
        add(blocks, MobileCapiPadBlock(blockBytes, sourceBlockBytes))
    MobileCapiEmitLog("mobile_moq:build_object_after_blocks")
    var objectDroplets: MobileMoqDroplet[]
    objectDroplets = []
    blockIndex = 0
    for blockIndex in blockIndex..<sourceBlockCount:
        var indexes: int32[]
        indexes = []
        add(indexes, blockIndex)
        let peerId = peers[(objectIndex + blockIndex) % peers.len]
        let payload = blocks[blockIndex]
        let key = Fmt"moqdrop-{bundleCid}-o{strings.IntToStr(objectIndex)}-s{strings.IntToStr(blockIndex)}"
        let droplet = MobileMoqDroplet(
            objectIndex: objectIndex,
            dropletIndex: blockIndex,
            kindCode: MobileMoqDropletKindSource,
            key: key,
            peerId: peerId,
            cid: MobileCapiSha256HexBytes(payload),
            degree: 1,
            blockIndexes: indexes,
            payload: payload
        )
        add(objectDroplets, droplet)
    MobileCapiEmitLog("mobile_moq:build_object_after_source_droplets")
    var repairIndex: int32
    while repairIndex < repairDropletCount:
        var degreeBase: int32 = 1
        if sourceBlockCount > 1:
            let seedText = Fmt"{bundleCid}|o{strings.IntToStr(objectIndex)}|r{strings.IntToStr(repairIndex)}"
            degreeBase = 2 + MobileCapiPositiveMod(MobileCapiHashSeed(seedText), sourceBlockCount - 1)
        let repairSeed = Fmt"{bundleCid}|repair|{strings.IntToStr(objectIndex)}|{strings.IntToStr(repairIndex)}"
        let blockIndexes = MobileCapiChooseUniqueBlockIndexes(
            sourceBlockCount,
            degreeBase,
            repairSeed
        )
        var payload = bytesAlloc(sourceBlockBytes)
        var blockPick: int32
        for blockPick in blockPick..<blockIndexes.len:
            let xorOk = MobileCapiXorInto(payload, blocks[blockIndexes[blockPick]])
            if IsErr(xorOk):
                return Err[MobileMoqObject](Error(xorOk))
        let dropletIndex = sourceBlockCount + repairIndex
        let peerId = peers[(objectIndex + dropletIndex) % peers.len]
        let key = Fmt"moqdrop-{bundleCid}-o{strings.IntToStr(objectIndex)}-r{strings.IntToStr(repairIndex)}"
        let droplet = MobileMoqDroplet(
            objectIndex: objectIndex,
            dropletIndex: dropletIndex,
            kindCode: MobileMoqDropletKindRepair,
            key: key,
            peerId: peerId,
            cid: MobileCapiSha256HexBytes(payload),
            degree: blockIndexes.len,
            blockIndexes: blockIndexes,
            payload: payload
        )
        add(objectDroplets, droplet)
        repairIndex = repairIndex + 1
    MobileCapiEmitLog("mobile_moq:build_object_after_repair_droplets")
    let objectOut = MobileMoqObject(
        objectIndex: objectIndex,
        groupId: bundleCid,
        objectId: Fmt"object-{strings.IntToStr(objectIndex)}",
        priority: objectIndex,
        byteOffset: byteOffset,
        byteLength: objectByteLen,
        objectCid: objectCid,
        sourceBlockBytes: sourceBlockBytes,
        sourceBlockCount: sourceBlockCount,
        repairDropletCount: repairDropletCount,
        droplets: objectDroplets
    )
    MobileCapiEmitLog("mobile_moq:build_object_ok")
    return Ok[MobileMoqObject](objectOut)

fn MobileCapiNextSeed(state0: int32): int32 =
    var state = state0
    if state == 0:
        state = 1
    state = state ^ (state << 13)
    state = state ^ (state >> 17)
    state = state ^ (state << 5)
    if state == 0:
        return 1
    return state

fn MobileCapiPositiveMod(value: int32, modBy: int32): int32 =
    if modBy <= 0:
        return 0
    let normalized = int64(value & 2147483647)
    return int32(normalized % int64(modBy))

fn MobileCapiChooseUniqueBlockIndexes(blockCount: int32, degree0: int32, seedText: str): int32[] =
    var out: int32[]
    out = []
    if blockCount <= 0:
        return out
    let degree = MobileCapiMinInt32(blockCount, MobileCapiMaxInt32(1, degree0))
    var seed = MobileCapiHashSeed(seedText)
    while out.len < degree:
        seed = MobileCapiNextSeed(seed)
        let candidate = MobileCapiPositiveMod(seed, blockCount)
        if !MobileCapiContainsInt(out, candidate):
            add(out, candidate)
    return MobileCapiSortInts(out)

fn MobileCapiPadBlock(data: Bytes, blockBytes: int32): Bytes =
    if bytesLen(data) == blockBytes:
        return bytesSlice(data, 0, bytesLen(data))
    var out = bytesAlloc(blockBytes)
    let copyLen = MobileCapiMinInt32(bytesLen(data), blockBytes)
    for i in 0..<copyLen:
        bytesSet(out, i, bytesGet(data, i))
    return out

fn MobileCapiXorInto(target: var Bytes, source: Bytes): Result[bool] =
    if bytesLen(target) != bytesLen(source):
        return Err[bool](" mobile capi: xor length mismatch")
    for i in 0..<bytesLen(target):
        bytesSet(target, i, bytesGet(target, i) ^ bytesGet(source, i))
    return Ok[bool](true)

fn MobileCapiXorBytes(left: Bytes, right: Bytes): Result[Bytes] =
    if bytesLen(left) != bytesLen(right):
        return Err[Bytes](" mobile capi: xor length mismatch")
    var out = bytesAlloc(bytesLen(left))
    for i in 0..<bytesLen(left):
        bytesSet(out, i, bytesGet(left, i) ^ bytesGet(right, i))
    return Ok[Bytes](out)

fn MobileCapiMoqBuildCatalogJson(ownerPeerId: str,
                                   mimeType: str,
                                   blobCid: str,
                                   blobByteLen: int32,
                                   bundleCid: str,
                                   objectTargetBytes: int32,
                                   sourceBlockBytes: int32,
                                   objects: MobileMoqObject[]): str =
    var objectRows: str[]
    objectRows = []
    var objectIndex: int32
    for objectIndex in objectIndex..<objects.len:
        add(objectRows, MobileCapiMoqObjectJson(objects[objectIndex]))
    var rows: str[]
    rows = []
    add(rows, "\"magic\":\"unimaker.moq.fountain.catalog.v1\"")
    add(rows, "\"version\":1")
    add(rows, "\"transport\":\"native_media_rpc\"")
    add(rows, "\"fountainLayout\":\"lt_xor_v1\"")
    add(rows, strutils.Join(["\"ownerPeerId\":", MobileCapiJsonQuote(ownerPeerId)], ""))
    add(rows, strutils.Join(["\"mimeType\":", MobileCapiJsonQuote(mimeType)], ""))
    add(rows, strutils.Join(["\"blobCid\":", MobileCapiJsonQuote(blobCid)], ""))
    add(rows, strutils.Join(["\"blobByteLen\":", strings.IntToStr(blobByteLen)], ""))
    add(rows, strutils.Join(["\"trackId\":", MobileCapiJsonQuote(Fmt"track:{bundleCid}")], ""))
    add(rows, strutils.Join(["\"bundleCid\":", MobileCapiJsonQuote(bundleCid)], ""))
    add(rows, strutils.Join(["\"objectTargetBytes\":", strings.IntToStr(objectTargetBytes)], ""))
    add(rows, strutils.Join(["\"sourceBlockBytes\":", strings.IntToStr(sourceBlockBytes)], ""))
    add(rows, strutils.Join(["\"objectCount\":", strings.IntToStr(objects.len)], ""))
    add(rows, strutils.Join(["\"objects\":[", strutils.Join(objectRows, ","), "]"], ""))
    return strutils.Join(["{", strutils.Join(rows, ","), "}"], "")

fn MobileCapiMoqBuildBundleSeed(ownerPeerId: str,
                                  blobCid: str,
                                  mimeType: str,
                                  peers: str[],
                                  objectTargetBytes: int32,
                                  sourceBlockBytes: int32,
                                  repairDropletCount: int32): str =
    return Fmt"{ownerPeerId}|{blobCid}|{mimeType}|{MobileCapiJoinCsv(peers)}|{strings.IntToStr(objectTargetBytes)}|{strings.IntToStr(sourceBlockBytes)}|{strings.IntToStr(repairDropletCount)}"

fn MobileCapiMoqRebuildTemplateWire(objects: MobileMoqObject[],
                                      droplets: MobileMoqDroplet[],
                                      blobCid: str,
                                      blobByteLen: int32): str =
    var rows: str[]
    rows = []
    add(rows, MobileCapiWireRow("blob_cid", blobCid))
    add(rows, MobileCapiWireRowInt("blob_byte_len", blobByteLen))
    add(rows, MobileCapiWireRowInt("object_count", objects.len))
    add(rows, MobileCapiWireRowInt("droplet_count", droplets.len))
    var objectRow: int32
    for objectRow in objectRow..<objects.len:
        let item = objects[objectRow]
        let prefix = Fmt"object.{strings.IntToStr(objectRow)}."
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}object_index", item.objectIndex))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}byte_length", item.byteLength))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}source_block_bytes", item.sourceBlockBytes))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}source_block_count", item.sourceBlockCount))
        add(rows, MobileCapiWireRow(Fmt"{prefix}object_cid", item.objectCid))
    var dropletRow: int32
    for dropletRow in dropletRow..<droplets.len:
        let item = droplets[dropletRow]
        let prefix = Fmt"droplet.{strings.IntToStr(dropletRow)}."
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}object_index", item.objectIndex))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}droplet_index", item.dropletIndex))
        add(rows, MobileCapiWireRow(Fmt"{prefix}key", item.key))
        add(rows, MobileCapiWireRow(Fmt"{prefix}peer_id", item.peerId))
        add(rows, MobileCapiWireRow(Fmt"{prefix}cid", item.cid))
        add(rows, MobileCapiWireRow(Fmt"{prefix}block_indexes", MobileCapiJoinIntCsv(item.blockIndexes)))
    return MobileCapiWireRowsText(rows)

fn MobileCapiMoqBuildResultToWire(result: MobileMoqBuildResult): str =
    var rows: str[]
    rows = []
    add(rows, MobileCapiWireRow("ok", "1"))
    add(rows, MobileCapiWireRow("owner_peer_id", result.ownerPeerId))
    add(rows, MobileCapiWireRow("mime_type", result.mimeType))
    add(rows, MobileCapiWireRow("bundle_cid", result.bundleCid))
    add(rows, MobileCapiWireRow("blob_cid", result.blobCid))
    add(rows, MobileCapiWireRow("catalog_key", result.catalogKey))
    add(rows, MobileCapiWireRow("catalog_cid", result.catalogCid))
    add(rows, MobileCapiWireRowInt("catalog_size_bytes", result.catalogSizeBytes))
    add(rows, MobileCapiWireRow("catalog_payload_hex", bytesToHex(bytesFromString(result.catalogPayloadText))))
    add(rows, MobileCapiWireRow("rebuild_template_key", result.rebuildTemplateKey))
    add(rows, MobileCapiWireRow("rebuild_template_cid", result.rebuildTemplateCid))
    add(rows, MobileCapiWireRowInt("rebuild_template_size_bytes", result.rebuildTemplateSizeBytes))
    add(rows, MobileCapiWireRow("rebuild_template_payload_hex", bytesToHex(bytesFromString(result.rebuildTemplatePayloadText))))
    add(rows, MobileCapiWireRowInt("blob_byte_len", result.blobByteLen))
    add(rows, MobileCapiWireRowInt("object_target_bytes", result.objectTargetBytes))
    add(rows, MobileCapiWireRowInt("source_block_bytes", result.sourceBlockBytes))
    add(rows, MobileCapiWireRowInt("object_count", result.objectCount))
    add(rows, MobileCapiWireRow("remote_ack_peer_ids", MobileCapiJoinCsv(result.remoteAckPeerIds)))
    var objectRow: int32
    for objectRow in objectRow..<result.objects.len:
        let item = result.objects[objectRow]
        let prefix = Fmt"object.{strings.IntToStr(objectRow)}."
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}object_index", item.objectIndex))
        add(rows, MobileCapiWireRow(Fmt"{prefix}group_id", item.groupId))
        add(rows, MobileCapiWireRow(Fmt"{prefix}object_id", item.objectId))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}priority", item.priority))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}byte_offset", item.byteOffset))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}byte_length", item.byteLength))
        add(rows, MobileCapiWireRow(Fmt"{prefix}object_cid", item.objectCid))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}source_block_bytes", item.sourceBlockBytes))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}source_block_count", item.sourceBlockCount))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}repair_droplet_count", item.repairDropletCount))
    add(rows, MobileCapiWireRowInt("droplet_count", result.droplets.len))
    var dropletRow: int32
    for dropletRow in dropletRow..<result.droplets.len:
        let item = result.droplets[dropletRow]
        let prefix = Fmt"droplet.{strings.IntToStr(dropletRow)}."
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}object_index", item.objectIndex))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}droplet_index", item.dropletIndex))
        add(rows, MobileCapiWireRow(Fmt"{prefix}kind", MobileCapiMoqDropletKindText(item.kindCode)))
        add(rows, MobileCapiWireRow(Fmt"{prefix}key", item.key))
        add(rows, MobileCapiWireRow(Fmt"{prefix}peer_id", item.peerId))
        add(rows, MobileCapiWireRow(Fmt"{prefix}cid", item.cid))
        add(rows, MobileCapiWireRowInt(Fmt"{prefix}degree", item.degree))
        add(rows, MobileCapiWireRow(Fmt"{prefix}block_indexes", MobileCapiJoinIntCsv(item.blockIndexes)))
        add(rows, MobileCapiWireRow(Fmt"{prefix}payload_hex", bytesToHex(item.payload)))
    return MobileCapiWireRowsText(rows)

fn MobileCapiMoqDropletFromCore(item: moq.MoqFountainDroplet): MobileMoqDroplet =
    return MobileMoqDroplet(
        objectIndex: item.objectIndex,
        dropletIndex: item.dropletIndex,
        kindCode: item.kindCode,
        key: item.key,
        peerId: item.peerId,
        cid: item.cid,
        degree: item.degree,
        blockIndexes: item.blockIndexes,
        payload: item.payload
    )

fn MobileCapiMoqObjectFromCore(item: moq.MoqFountainObject): MobileMoqObject =
    var objectDroplets: MobileMoqDroplet[]
    objectDroplets = []
    var idx: int32
    for idx in idx..<item.droplets.len:
        let droplet = item.droplets[idx]
        let converted = MobileMoqDroplet(
            objectIndex: droplet.objectIndex,
            dropletIndex: droplet.dropletIndex,
            kindCode: droplet.kindCode,
            key: droplet.key,
            peerId: droplet.peerId,
            cid: droplet.cid,
            degree: droplet.degree,
            blockIndexes: droplet.blockIndexes,
            payload: droplet.payload
        )
        add(objectDroplets, converted)
    return MobileMoqObject(
        objectIndex: item.objectIndex,
        groupId: item.groupId,
        objectId: item.objectId,
        priority: item.priority,
        byteOffset: item.byteOffset,
        byteLength: item.byteLength,
        objectCid: item.objectCid,
        sourceBlockBytes: item.sourceBlockBytes,
        sourceBlockCount: item.sourceBlockCount,
        repairDropletCount: item.repairDropletCount,
        droplets: objectDroplets
    )

fn MobileCapiMoqBuildResultFromCore(item: moq.MoqFountainBuildResult): MobileMoqBuildResult =
    var objects: MobileMoqObject[]
    objects = []
    var objectIdx: int32
    for objectIdx in range(item.objects.len):

        let objectItem = item.objects[objectIdx]
        var objectDroplets: MobileMoqDroplet[]
        objectDroplets = []
        var objectDropletIdx: int32
        for objectDropletIdx in objectDropletIdx..<objectItem.droplets.len:
            let objectDroplet = objectItem.droplets[objectDropletIdx]
            let convertedDroplet = MobileMoqDroplet(
                objectIndex: objectDroplet.objectIndex,
                dropletIndex: objectDroplet.dropletIndex,
                kindCode: objectDroplet.kindCode,
                key: objectDroplet.key,
                peerId: objectDroplet.peerId,
                cid: objectDroplet.cid,
                degree: objectDroplet.degree,
                blockIndexes: objectDroplet.blockIndexes,
                payload: objectDroplet.payload
            )
            add(objectDroplets, convertedDroplet)
        let convertedObject = MobileMoqObject(
            objectIndex: objectItem.objectIndex,
            groupId: objectItem.groupId,
            objectId: objectItem.objectId,
            priority: objectItem.priority,
            byteOffset: objectItem.byteOffset,
            byteLength: objectItem.byteLength,
            objectCid: objectItem.objectCid,
            sourceBlockBytes: objectItem.sourceBlockBytes,
            sourceBlockCount: objectItem.sourceBlockCount,
            repairDropletCount: objectItem.repairDropletCount,
            droplets: objectDroplets
        )
        add(objects, convertedObject)

    var droplets: MobileMoqDroplet[]
    droplets = []
    var dropletIdx: int32
    for dropletIdx in dropletIdx..<item.droplets.len:
        let droplet = item.droplets[dropletIdx]
        let converted = MobileMoqDroplet(
            objectIndex: droplet.objectIndex,
            dropletIndex: droplet.dropletIndex,
            kindCode: droplet.kindCode,
            key: droplet.key,
            peerId: droplet.peerId,
            cid: droplet.cid,
            degree: droplet.degree,
            blockIndexes: droplet.blockIndexes,
            payload: droplet.payload
        )
        add(droplets, converted)
    return MobileMoqBuildResult(
        ownerPeerId: item.ownerPeerId,
        mimeType: item.mimeType,
        bundleCid: item.bundleCid,
        blobCid: item.blobCid,
        catalogKey: item.catalogKey,
        catalogCid: item.catalogCid,
        catalogSizeBytes: item.catalogSizeBytes,
        catalogPayloadText: "",
        catalogPayload: item.catalogPayload,
        rebuildTemplateKey: item.rebuildTemplateKey,
        rebuildTemplateCid: item.rebuildTemplateCid,
        rebuildTemplateSizeBytes: item.rebuildTemplateSizeBytes,
        rebuildTemplatePayloadText: "",
        rebuildTemplatePayload: item.rebuildTemplatePayload,
        blobByteLen: item.blobByteLen,
        objectTargetBytes: item.objectTargetBytes,
        sourceBlockBytes: item.sourceBlockBytes,
        objectCount: item.objectCount,
        remoteAckPeerIds: item.remoteAckPeerIds,
        objects: objects,
        droplets: droplets
    )

fn MobileCapiMoqSourceDropletKey(bundleCid: str, objectIndex: int32, dropletIndex: int32): str =
    return strutils.Join(["moqdrop-",
                bundleCid,
                "-o",
                strings.IntToStr(objectIndex),
                "-s",
                strings.IntToStr(dropletIndex)], "")

fn MobileCapiMoqRepairDropletKey(bundleCid: str, objectIndex: int32, repairIndex: int32): str =
    return strutils.Join(["moqdrop-",
                bundleCid,
                "-o",
                strings.IntToStr(objectIndex),
                "-r",
                strings.IntToStr(repairIndex)], "")

fn MobileCapiMoqHydratedCoreResult(base: MobileMoqBuildResult,
                                     blobBytes: Bytes,
                                     ownerPeerId: str,
                                     remotePeersCsv: str,
                                     mimeType0: str,
                                     objectTargetBytes0: int32,
                                     sourceBlockBytes0: int32,
                                     repairDropletCount0: int32): Result[MobileMoqBuildResult] =
    let peers = MobileCapiNormalizePeerCsv(remotePeersCsv)
    if peers.len <= 0:
        return Err[MobileMoqBuildResult]("video_publish_insufficient_storage_peers")
    let mimeType = if len(mimeType0) > 0: mimeType0 else: "video/mp4"
    let objectTargetBytes = MobileCapiNormalizePositiveInt(objectTargetBytes0, 512 * 1024)
    let sourceBlockBytes = MobileCapiNormalizePositiveInt(sourceBlockBytes0, 128 * 1024)
    let repairDropletCount = MobileCapiNormalizePositiveInt(repairDropletCount0, 2)
    let blobCid = MobileCapiSha256HexBytes(blobBytes)
    let bundleSeed = MobileCapiMoqBuildBundleSeed(ownerPeerId,
                                                    blobCid,
                                                    mimeType,
                                                    peers,
                                                    objectTargetBytes,
                                                    sourceBlockBytes,
                                                    repairDropletCount)
    if len(bundleSeed) <= 0:
        return Err[MobileMoqBuildResult]("moq_fountain_empty_bundle_seed")
    let bundleCid = MobileCapiSha256HexText(bundleSeed)
    if len(bundleCid) <= 0:
        return Err[MobileMoqBuildResult]("moq_fountain_empty_bundle_cid")

    var out = base
    out.ownerPeerId = ownerPeerId
    out.mimeType = mimeType
    out.blobCid = blobCid
    out.bundleCid = bundleCid
    out.blobByteLen = bytesLen(blobBytes)
    out.objectTargetBytes = objectTargetBytes
    out.sourceBlockBytes = sourceBlockBytes
    out.objectCount = out.objects.len
    out.remoteAckPeerIds = peers

    var objectRow: int32
    for objectRow in objectRow..<out.objects.len:
        out.objects[objectRow].groupId = bundleCid
        out.objects[objectRow].objectId = strutils.Join(["object-", strings.IntToStr(out.objects[objectRow].objectIndex)], "")

    var dropletRow: int32
    for dropletRow in range(out.droplets.len):

        let objectIndex = out.droplets[dropletRow].objectIndex
        var sourceBlockCount: int32
        var peerId = ""
        var findIdx: int32
        for findIdx in findIdx..<out.objects.len:
            if out.objects[findIdx].objectIndex == objectIndex:
                sourceBlockCount = out.objects[findIdx].sourceBlockCount
                break
        let peerSlot = (objectIndex + out.droplets[dropletRow].dropletIndex) % peers.len
        peerId = peers[peerSlot]
        out.droplets[dropletRow].peerId = peerId
        out.droplets[dropletRow].cid = MobileCapiSha256HexBytes(out.droplets[dropletRow].payload)
        if out.droplets[dropletRow].kindCode == MobileMoqDropletKindSource:
            out.droplets[dropletRow].key = MobileCapiMoqSourceDropletKey(bundleCid,
                                                                            objectIndex,
                                                                            out.droplets[dropletRow].dropletIndex)
        else:
            let repairIndex = out.droplets[dropletRow].dropletIndex - sourceBlockCount
            out.droplets[dropletRow].key = MobileCapiMoqRepairDropletKey(bundleCid,
                                                                            objectIndex,
                                                                            repairIndex)


    let catalogText = MobileCapiMoqBuildCatalogJson(ownerPeerId,
                                                      mimeType,
                                                      blobCid,
                                                      bytesLen(blobBytes),
                                                      bundleCid,
                                                      objectTargetBytes,
                                                      sourceBlockBytes,
                                                      out.objects)
    let catalogPayload = bytesFromString(catalogText)
    if bytesLen(catalogPayload) <= 0:
        return Err[MobileMoqBuildResult]("moq_fountain_empty_catalog_payload")
    out.catalogKey = strutils.Join(["moqcatalog-", bundleCid], "")
    out.catalogCid = MobileCapiSha256HexBytes(catalogPayload)
    out.catalogSizeBytes = bytesLen(catalogPayload)
    out.catalogPayloadText = catalogText
    out.catalogPayload = catalogPayload

    let rebuildTemplateText = MobileCapiMoqRebuildTemplateWire(out.objects,
                                                                 out.droplets,
                                                                 blobCid,
                                                                 bytesLen(blobBytes))
    let rebuildTemplatePayload = bytesFromString(rebuildTemplateText)
    if bytesLen(rebuildTemplatePayload) <= 0:
        return Err[MobileMoqBuildResult]("moq_fountain_empty_rebuild_template")
    out.rebuildTemplateKey = strutils.Join(["moqrebuild-", bundleCid], "")
    out.rebuildTemplateCid = MobileCapiSha256HexBytes(rebuildTemplatePayload)
    out.rebuildTemplateSizeBytes = bytesLen(rebuildTemplatePayload)
    out.rebuildTemplatePayloadText = rebuildTemplateText
    out.rebuildTemplatePayload = rebuildTemplatePayload
    return Ok[MobileMoqBuildResult](out)

fn MobileCapiMoqBuildPersistDirect(blobBytes: Bytes,
                                     ownerPeerId: str,
                                     remotePeersCsv: str,
                                     mimeType0: str,
                                     objectTargetBytes0: int32,
                                     sourceBlockBytes0: int32,
                                     repairDropletCount0: int32,
                                     outputDir: str,
                                     fileNameStem: str): Result[str] =
    MobileCapiEmitLog("mobile_moq:persist_direct_enter")
    if bytesLen(blobBytes) <= 0:
        return Err[str]("moq_fountain_empty_blob")
    if len(outputDir) <= 0:
        return Err[str]("moq_fountain_missing_output_dir")
    if len(fileNameStem) <= 0:
        return Err[str]("moq_fountain_missing_file_stem")
    let buildResolvedRes = MobileCapiMoqBuildResolved(blobBytes,
                                                        ownerPeerId,
                                                        remotePeersCsv,
                                                        mimeType0,
                                                        objectTargetBytes0,
                                                        sourceBlockBytes0,
                                                        repairDropletCount0,
                                                        "")
    MobileCapiEmitLog("mobile_moq:persist_direct_after_resolved")
    if IsErr(buildResolvedRes):
        return Err[str](Error(buildResolvedRes))
    let wireRes = MobileCapiMoqBuildPersistWire(Value(buildResolvedRes), outputDir, fileNameStem)
    if IsErr(wireRes):
        return Err[str](Error(wireRes))
    MobileCapiEmitLog("mobile_moq:persist_direct_ok")
    return wireRes

fn MobileCapiMoqBuildResolved(blobBytes: Bytes,
                                ownerPeerId: str,
                                remotePeersCsv: str,
                                mimeType0: str,
                                objectTargetBytes0: int32,
                                sourceBlockBytes0: int32,
                                repairDropletCount0: int32,
                                tracePath: str): Result[MobileMoqBuildResult] =
    MobileCapiEmitLog("mobile_moq:build_enter")
    let traceEnabled = len(tracePath) > 0
    if traceEnabled:
        MobileCapiMaybeWriteTraceLine(tracePath, "build:enter")
        MobileCapiMaybeWriteTraceLine(tracePath, Fmt"build:blob_len={strings.IntToStr(bytesLen(blobBytes))}")
    if bytesLen(blobBytes) <= 0:
        if traceEnabled:
            MobileCapiMaybeWriteTraceLine(tracePath, "build:error=moq_fountain_empty_blob")
        return Err[MobileMoqBuildResult]("moq_fountain_empty_blob")
    MobileCapiEmitLog("mobile_moq:build_before_core")
    if traceEnabled:
        moq.MoqFountainSetTracePath(tracePath)
    let buildRes = moq.MoqFountainBuild(blobBytes,
                                        ownerPeerId,
                                        remotePeersCsv,
                                        mimeType0,
                                        objectTargetBytes0,
                                        sourceBlockBytes0,
                                        repairDropletCount0)
    if traceEnabled:
        moq.MoqFountainClearTracePath()
    MobileCapiEmitLog("mobile_moq:build_after_core")
    if IsErr(buildRes):
        if traceEnabled:
            MobileCapiMaybeWriteTraceLine(tracePath, Fmt"build:error={Error(buildRes)}")
        return Err[MobileMoqBuildResult](Error(buildRes))
    let coreBuild = Value(buildRes)
    var coreObjects: MobileMoqObject[]
    coreObjects = []
    var coreObjectIdx: int32
    for coreObjectIdx in range(coreBuild.objects.len):

        let objectItem = coreBuild.objects[coreObjectIdx]
        var objectDroplets: MobileMoqDroplet[]
        objectDroplets = []
        var objectDropletIdx: int32
        for objectDropletIdx in objectDropletIdx..<objectItem.droplets.len:
            let objectDroplet = objectItem.droplets[objectDropletIdx]
            let convertedDroplet = MobileMoqDroplet(
                objectIndex: objectDroplet.objectIndex,
                dropletIndex: objectDroplet.dropletIndex,
                kindCode: objectDroplet.kindCode,
                key: objectDroplet.key,
                peerId: objectDroplet.peerId,
                cid: objectDroplet.cid,
                degree: objectDroplet.degree,
                blockIndexes: objectDroplet.blockIndexes,
                payload: objectDroplet.payload
            )
            add(objectDroplets, convertedDroplet)
        let convertedObject = MobileMoqObject(
            objectIndex: objectItem.objectIndex,
            groupId: objectItem.groupId,
            objectId: objectItem.objectId,
            priority: objectItem.priority,
            byteOffset: objectItem.byteOffset,
            byteLength: objectItem.byteLength,
            objectCid: objectItem.objectCid,
            sourceBlockBytes: objectItem.sourceBlockBytes,
            sourceBlockCount: objectItem.sourceBlockCount,
            repairDropletCount: objectItem.repairDropletCount,
            droplets: objectDroplets
        )
        add(coreObjects, convertedObject)

    var coreDroplets: MobileMoqDroplet[]
    coreDroplets = []
    var coreDropletIdx: int32
    for coreDropletIdx in coreDropletIdx..<coreBuild.droplets.len:
        let coreDroplet = coreBuild.droplets[coreDropletIdx]
        let convertedDroplet = MobileMoqDroplet(
            objectIndex: coreDroplet.objectIndex,
            dropletIndex: coreDroplet.dropletIndex,
            kindCode: coreDroplet.kindCode,
            key: coreDroplet.key,
            peerId: coreDroplet.peerId,
            cid: coreDroplet.cid,
            degree: coreDroplet.degree,
            blockIndexes: coreDroplet.blockIndexes,
            payload: coreDroplet.payload
        )
        add(coreDroplets, convertedDroplet)
    let mobileBuild = MobileMoqBuildResult(
        ownerPeerId: coreBuild.ownerPeerId,
        mimeType: coreBuild.mimeType,
        bundleCid: coreBuild.bundleCid,
        blobCid: coreBuild.blobCid,
        catalogKey: coreBuild.catalogKey,
        catalogCid: coreBuild.catalogCid,
        catalogSizeBytes: coreBuild.catalogSizeBytes,
        catalogPayloadText: "",
        catalogPayload: coreBuild.catalogPayload,
        rebuildTemplateKey: coreBuild.rebuildTemplateKey,
        rebuildTemplateCid: coreBuild.rebuildTemplateCid,
        rebuildTemplateSizeBytes: coreBuild.rebuildTemplateSizeBytes,
        rebuildTemplatePayloadText: "",
        rebuildTemplatePayload: coreBuild.rebuildTemplatePayload,
        blobByteLen: coreBuild.blobByteLen,
        objectTargetBytes: coreBuild.objectTargetBytes,
        sourceBlockBytes: coreBuild.sourceBlockBytes,
        objectCount: coreBuild.objectCount,
        remoteAckPeerIds: coreBuild.remoteAckPeerIds,
        objects: coreObjects,
        droplets: coreDroplets
    )
    let hydrateRes = MobileCapiMoqHydratedCoreResult(mobileBuild,
                                                       blobBytes,
                                                       ownerPeerId,
                                                       remotePeersCsv,
                                                       mimeType0,
                                                       objectTargetBytes0,
                                                       sourceBlockBytes0,
                                                       repairDropletCount0)
    if IsErr(hydrateRes):
        if traceEnabled:
            MobileCapiMaybeWriteTraceLine(tracePath, Fmt"build:error={Error(hydrateRes)}")
        return Err[MobileMoqBuildResult](Error(hydrateRes))
    let out = Value(hydrateRes)
    MobileCapiEmitLog("mobile_moq:build_ok")
    if traceEnabled:
        MobileCapiMaybeWriteTraceLine(tracePath, Fmt"build:blob_cid={out.blobCid}")
        MobileCapiMaybeWriteTraceLine(tracePath, Fmt"build:bundle_cid={out.bundleCid}")
        MobileCapiMaybeWriteTraceLine(tracePath,
                                        Fmt"build:objects_done count={strings.IntToStr(out.objects.len)} droplets={strings.IntToStr(out.droplets.len)}")
        MobileCapiMaybeWriteTraceLine(tracePath, Fmt"build:catalog_bytes={strings.IntToStr(bytesLen(out.catalogPayload))}")
        MobileCapiMaybeWriteTraceLine(tracePath, Fmt"build:rebuild_template_bytes={strings.IntToStr(bytesLen(out.rebuildTemplatePayload))}")
        MobileCapiMaybeWriteTraceLine(tracePath, "build:ok")
    return Ok[MobileMoqBuildResult](out)

fn MobileCapiMoqBuildTraced(out: var MobileMoqBuildResult,
                              tracePath: str,
                              blobBytes: Bytes,
                              ownerPeerId: str,
                              remotePeersCsv: str,
                              mimeType0: str,
