fn MobileCapiMoqDecodeBlockIndexes(csv: str): int32[] =
    let parts = MobileCapiSplitCsv(csv)
    var out: int32[]
    out = []
    var i: int32
    for i in i..<parts.len:
        let part = parts[i]
        let item = MobileCapiTrimAscii(part)
        if len(item) <= 0:
            continue
        add(out, MobileCapiParseInt32Text(item))
    return out

fn MobileCapiMoqSolveObject(sourceBlockCount: int32,
                              blockBytes: int32,
                              equations0: MobileMoqEquation[]): Result[Bytes[]] =
    if sourceBlockCount <= 0:
        return Err[Bytes[]]("moq_fountain_invalid_object")
    var equations = equations0
    var pivotCols: int32[]
    pivotCols = []
    var pivotRow = 0
    for col in 0..<sourceBlockCount:
        var found = -1
        for row in pivotRow..<equations.len:
            if equations[row].coeffs[col] != 0:
                found = row
                break
        if found < 0:
            continue
        if found != pivotRow:
            let temp = equations[pivotRow]
            equations[pivotRow] = equations[found]
            equations[found] = temp
        for row in 0..<equations.len:
            if row == pivotRow || equations[row].coeffs[col] == 0:
                continue
            for coeffIndex in 0..<sourceBlockCount:
                equations[row].coeffs[coeffIndex] = equations[row].coeffs[coeffIndex] ^ equations[pivotRow].coeffs[coeffIndex]
            let xorOk = MobileCapiXorInto(equations[row].payload, equations[pivotRow].payload)
            if IsErr(xorOk):
                return Err[Bytes[]](Error(xorOk))
        add(pivotCols, col)
        pivotRow = pivotRow + 1
        if pivotRow >= sourceBlockCount:
            break
    if pivotCols.len < sourceBlockCount:
        return Err[Bytes[]]("moq_fountain_insufficient_droplets")
    var solved: Bytes[]
    solved = []
    for i in 0..<sourceBlockCount:
        add(solved, bytesAlloc(blockBytes))
    for row in 0..<sourceBlockCount:
        solved[pivotCols[row]] = equations[row].payload
    return Ok[Bytes[]](solved)

@exportc("MobileCapiMoqFountainRebuild")
fn MobileCapiMoqFountainRebuild(requestWire: str): str =
    let outputPathRes = MobileCapiWireDecodedValue(requestWire, "output_path")
    if IsErr(outputPathRes):
        return MobileCapiMoqError(Error(outputPathRes))
    let outputPath = Value(outputPathRes)
    let rebuiltRes = moq.MoqFountainRebuildFromWire(requestWire)
    if IsErr(rebuiltRes):
        return MobileCapiMoqError(Error(rebuiltRes))
    let rebuilt = Value(rebuiltRes)
    let rebuiltBlob = rebuilt.blob
    let writeRes = bridge.InternalMobileBridgeWriteBytesPath(outputPath, rebuiltBlob)
    if IsErr(writeRes):
        return MobileCapiMoqError(Error(writeRes))
    return moq.MoqFountainRebuildResultToWire(outputPath, rebuilt)

fn mobileCapiMoqFountainRebuildCStringRaw(requestWireRaw: ptr): ptr =
    let requestWire = bridge.InternalMobileBridgeCopyRawText(requestWireRaw)
    let out = MobileCapiMoqFountainRebuild(requestWire)
    return bridge.InternalMobileBridgeTextCString(out)

fn MobileCapiBioDidProvisionJson(didText: str,
                                   rootSeed: str,
                                   deviceSeed: str,
                                   documentText: str,
                                   bundleText: str): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "ok", "1")
    out = did.DidStoreAppendLine(out, "did", didText)
    out = did.DidStoreAppendLine(out, "rootSeed", rootSeed)
    out = did.DidStoreAppendLine(out, "deviceSeed", deviceSeed)
    out = did.DidStoreAppendLine(out, "documentTextHex", MobileCapiTextHex(documentText))
    out = did.DidStoreAppendLine(out, "bundleTextHex", MobileCapiTextHex(bundleText))
    return out

fn MobileCapiBioDidSetTrustedAttestorRoot(pubKeyHex: str,
                                            rootKeyId: str): str =
    let setRes = bio_did.BioDidSetTrustedAttestorRootHex(pubKeyHex, rootKeyId)
    if IsErr(setRes):
        let errorText = MobileCapiBioDidErrorJson(Error(setRes))
        return errorText
    let out = "ok=1\n"
    return out

fn MobileCapiBioDidCreateRequestWire(requestId: str,
                                       feature32Hex: str,
                                       deviceBindingSeed: str,
                                       deviceLabel: str,
                                       sensorId: str,
                                       hardwareAttestation: str): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "request_id", MobileCapiTextHex(requestId))
    out = did.DidStoreAppendLine(out, "feature32_hex", feature32Hex)
    out = did.DidStoreAppendLine(out, "device_binding_seed", MobileCapiTextHex(deviceBindingSeed))
    out = did.DidStoreAppendLine(out, "device_label", MobileCapiTextHex(deviceLabel))
    out = did.DidStoreAppendLine(out, "sensor_id", MobileCapiTextHex(sensorId))
    out = did.DidStoreAppendLine(out, "hardware_attestation", MobileCapiTextHex(hardwareAttestation))
    return out

fn MobileCapiBioDidImportRequestWire(latestBundleText: str,
                                       requestId: str,
                                       feature32Hex: str,
                                       deviceBindingSeed: str,
                                       deviceLabel: str,
                                       sensorId: str,
                                       hardwareAttestation: str): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "latest_bundle_text", MobileCapiTextHex(latestBundleText))
    let createWire = MobileCapiBioDidCreateRequestWire(requestId,
                                                         feature32Hex,
                                                         deviceBindingSeed,
                                                         deviceLabel,
                                                         sensorId,
                                                         hardwareAttestation)
    out = strutils.Join([out, createWire], "")
    return out

fn MobileCapiBioDidCreate(requestId: str,
                            feature32Hex: str,
                            deviceBindingSeed: str,
                            deviceLabel: str,
                            sensorId: str,
                            hardwareAttestation: str): str =
    let captureRes = MobileCapiBioDidCapture(requestId,
                                               feature32Hex,
                                               deviceBindingSeed,
                                               deviceLabel,
                                               sensorId,
                                               hardwareAttestation)
    if IsErr(captureRes):
        let errorText = MobileCapiBioDidErrorJson(Error(captureRes))
        return errorText
    let capture = Value(captureRes)
    let epochSeconds = times.EpochTimeSeconds()
    let captureOk = bio_did.BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        let errorText = MobileCapiBioDidErrorJson(Error(captureOk))
        return errorText
    let attestationOk = bio_did.BioDidCaptureAttestationValidate(capture, "create")
    if IsErr(attestationOk):
        let errorText = MobileCapiBioDidErrorJson(Error(attestationOk))
        return errorText
    let recordRes = bio.BioEnroll(capture.feature32)
    if IsErr(recordRes):
        let errorText = MobileCapiBioDidErrorJson(Error(recordRes))
        return errorText
    let record = Value(recordRes)
    let rootSecretRes = bio.BioRecoverRoot(capture.feature32, record.helper)
    if IsErr(rootSecretRes):
        let errorText = MobileCapiBioDidErrorJson(Error(rootSecretRes))
        return errorText
    let rootSecret = Value(rootSecretRes)
    let rootSeed = bio_did.BioDidRootSeedFromRootSecret(rootSecret)
    let deviceSeed = bio_did.BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let identity = did.DidIdentityMake(rootSeed, deviceSeed, capture.deviceLabel, epochSeconds)
    var document: did.DidDocument
    let documentRes = did.DidIdentityDocumentFill(document, identity)
    if IsErr(documentRes):
        let errorText = MobileCapiBioDidErrorJson(Error(documentRes))
        return errorText
    let bundleSeq = 1
    let challengeNonce = bio_did.BioDidChallengeNonce("create",
                                                        document.did,
                                                        identity.selfDevice.devicePeerId,
                                                        document.version,
                                                        bundleSeq)
    let hardware = bio_did.BioDidHardwareAttestationMake(capture,
                                                           "create",
                                                           document.did,
                                                           identity.selfDevice.devicePeerId,
                                                           document.version,
                                                           bundleSeq,
                                                           challengeNonce,
                                                           epochSeconds)
    let assertionRes = bio.BioProve(capture.feature32, record, challengeNonce)
    if IsErr(assertionRes):
        let errorText = MobileCapiBioDidErrorJson(Error(assertionRes))
        return errorText
    let assertion = Value(assertionRes)
    let bundleRes = bio_did.BioDidChainBundleMake("create",
                                                    bundleSeq,
                                                    document,
                                                    identity.selfDevice.devicePeerId,
                                                    record,
                                                    assertion,
                                                    hardware)
    if IsErr(bundleRes):
        let errorText = MobileCapiBioDidErrorJson(Error(bundleRes))
        return errorText
    let bundle = Value(bundleRes)
    let devicePeerIdText = peer_id.Libp2pPeerIdText(bundle.devicePeerId)
    let bundleSeqText = strings.IntToStr(bundle.bundleSeq)
    let recordVersionText = strings.IntToStr(bundle.record.version)
    let recordHelperText = layout.FixedBytes32Hex(bundle.record.helper)
    let recordPubKeyText = layout.FixedBytes65Hex(bundle.record.pubKey)
    let recordCodeNText = strings.IntToStr(bundle.record.codeN)
    let recordCodeKText = strings.IntToStr(bundle.record.codeK)
    let recordMaxCorrectableText = strings.IntToStr(bundle.record.maxCorrectable)
    let recordCidText = layout.FixedBytes32Hex(bundle.record.recordCid)
    let challengeNonceText = layout.FixedBytes32Hex(bundle.assertion.challengeNonce)
    let assertionCommitAText = layout.FixedBytes65Hex(bundle.assertion.commitA)
    let assertionResponseZText = layout.FixedBytes32Hex(bundle.assertion.responseZ)
    let assertionProofCidText = layout.FixedBytes32Hex(bundle.assertion.proofCid)
    let hardwareVersionText = strings.IntToStr(bundle.hardware.version)
    let hardwareVerifiedAtText = did.DidStoreWord64Hex(bundle.hardware.verifiedAtEpochSeconds)
    let hardwareDeviceBindingSeedHashText = layout.FixedBytes32Hex(bundle.hardware.deviceBindingSeedHash)
    let hardwareAttestationCidText = layout.FixedBytes32Hex(bundle.hardware.attestationCid)
    let hardwareBindingCidText = layout.FixedBytes32Hex(bundle.hardware.bindingCid)
    var bundleText = ""
    bundleText = did.DidStoreAppendLine(bundleText, "cheng_bio_did_bundle_version", bio_did.BioDidBundleVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "action", bundle.action)
    bundleText = did.DidStoreAppendLine(bundleText, "bundle_seq", bundleSeqText)
    bundleText = did.DidStoreAppendLine(bundleText, "did", document.did)
    bundleText = did.DidStoreAppendLine(bundleText, "device_peer_id", devicePeerIdText)
    bundleText = did.DidStoreAppendLine(bundleText, "document_text", did.DidStoreEncodeText(bundle.documentText))
    bundleText = did.DidStoreAppendLine(bundleText, "record_version", recordVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_helper", recordHelperText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_pub_key", recordPubKeyText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_code_n", recordCodeNText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_code_k", recordCodeKText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_max_correctable", recordMaxCorrectableText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_cid", recordCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "challenge_nonce", challengeNonceText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_commit_a", assertionCommitAText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_response_z", assertionResponseZText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_proof_cid", assertionProofCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_version", hardwareVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_request_id", did.DidStoreEncodeText(bundle.hardware.requestId))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_sensor_id", did.DidStoreEncodeText(bundle.hardware.sensorId))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_verified_at", hardwareVerifiedAtText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_device_binding_seed_hash", hardwareDeviceBindingSeedHashText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_attestation_text", did.DidStoreEncodeText(bundle.hardware.attestationText))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_attestation_cid", hardwareAttestationCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_binding_cid", hardwareBindingCidText)
    let out = MobileCapiBioDidProvisionJson(document.did,
                                              identity.rootSeed,
                                              identity.deviceSeed,
                                              bundle.documentText,
                                              bundleText)
    return out

fn MobileCapiBioDidCreateWire(requestWire: str): str =
    let requestIdRes = MobileCapiWireDecodedValue(requestWire, "request_id")
    if IsErr(requestIdRes):
        let errorText = MobileCapiBioDidErrorJson(Error(requestIdRes))
        return errorText
    let feature32HexRes = MobileCapiWireFindValue(requestWire, "feature32_hex")
    if IsErr(feature32HexRes):
        let errorText = MobileCapiBioDidErrorJson(Error(feature32HexRes))
        return errorText
    let deviceBindingSeedRes = MobileCapiWireDecodedValue(requestWire, "device_binding_seed")
    if IsErr(deviceBindingSeedRes):
        let errorText = MobileCapiBioDidErrorJson(Error(deviceBindingSeedRes))
        return errorText
    let deviceLabelRes = MobileCapiWireDecodedValue(requestWire, "device_label")
    if IsErr(deviceLabelRes):
        let errorText = MobileCapiBioDidErrorJson(Error(deviceLabelRes))
        return errorText
    let sensorIdRes = MobileCapiWireDecodedValue(requestWire, "sensor_id")
    if IsErr(sensorIdRes):
        let errorText = MobileCapiBioDidErrorJson(Error(sensorIdRes))
        return errorText
    let hardwareAttestationRes = MobileCapiWireDecodedValue(requestWire, "hardware_attestation")
    if IsErr(hardwareAttestationRes):
        let errorText = MobileCapiBioDidErrorJson(Error(hardwareAttestationRes))
        return errorText
    let out = MobileCapiBioDidCreate(Value(requestIdRes),
                                       Value(feature32HexRes),
                                       Value(deviceBindingSeedRes),
                                       Value(deviceLabelRes),
                                       Value(sensorIdRes),
                                       Value(hardwareAttestationRes))
    return out

fn MobileCapiBioDidCreateWireHandle(requestWire: str): uint64 =
    let out = MobileCapiBioDidCreateWire(requestWire)
    let handle = MobileCapiTextBufferHandle(out)
    return handle

fn mobileCapiBioDidCreateWireCString(requestWire: str): ptr =
    let out = MobileCapiBioDidCreateWire(requestWire)
    let ctext = bridge.InternalMobileBridgeTextCString(out)
    return ctext

fn mobileCapiBioDidCreateWireHandleRaw(requestWireRaw: ptr): uint64 =
    let requestWire = bridge.InternalMobileBridgeCopyRawText(requestWireRaw)
    let handle = MobileCapiBioDidCreateWireHandle(requestWire)
    return handle

fn mobileCapiBioDidCreateWireCStringRaw(requestWireRaw: ptr): ptr =
    let requestWire = bridge.InternalMobileBridgeCopyRawText(requestWireRaw)
    let ctext = mobileCapiBioDidCreateWireCString(requestWire)
    return ctext

