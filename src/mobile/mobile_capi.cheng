                                               feature32Hex,
                                               deviceBindingSeed,
                                               deviceLabel,
                                               sensorId,
                                               hardwareAttestation)
    if IsErr(captureRes):
        return bridge.InternalMobileBridgeTextCString("")
    let createRes = bio_did.BioDidCreateBundleWithHardwareCapture(Value(captureRes),
                                                                    times.EpochTimeSeconds())
    if IsErr(createRes):
        return bridge.InternalMobileBridgeTextCString("")
    let outcome = Value(createRes)
    let devicePeerIdText = peer_id.Libp2pPeerIdText(outcome.bundle.devicePeerId)
    let bundleSeqText = strings.IntToStr(outcome.bundle.bundleSeq)
    let recordVersionText = strings.IntToStr(outcome.bundle.record.version)
    let recordHelperText = layout.FixedBytes32Hex(outcome.bundle.record.helper)
    let recordPubKeyText = layout.FixedBytes65Hex(outcome.bundle.record.pubKey)
    let recordCodeNText = strings.IntToStr(outcome.bundle.record.codeN)
    let recordCodeKText = strings.IntToStr(outcome.bundle.record.codeK)
    let recordMaxCorrectableText = strings.IntToStr(outcome.bundle.record.maxCorrectable)
    let recordCidText = layout.FixedBytes32Hex(outcome.bundle.record.recordCid)
    let challengeNonceText = layout.FixedBytes32Hex(outcome.bundle.assertion.challengeNonce)
    let assertionCommitAText = layout.FixedBytes65Hex(outcome.bundle.assertion.commitA)
    let assertionResponseZText = layout.FixedBytes32Hex(outcome.bundle.assertion.responseZ)
    let assertionProofCidText = layout.FixedBytes32Hex(outcome.bundle.assertion.proofCid)
    let hardwareVersionText = strings.IntToStr(outcome.bundle.hardware.version)
    let hardwareVerifiedAtText = did.DidStoreWord64Hex(outcome.bundle.hardware.verifiedAtEpochSeconds)
    let hardwareDeviceBindingSeedHashText = layout.FixedBytes32Hex(outcome.bundle.hardware.deviceBindingSeedHash)
    let hardwareAttestationCidText = layout.FixedBytes32Hex(outcome.bundle.hardware.attestationCid)
    let hardwareBindingCidText = layout.FixedBytes32Hex(outcome.bundle.hardware.bindingCid)
    var bundleText = ""
    bundleText = did.DidStoreAppendLine(bundleText, "cheng_bio_did_bundle_version", bio_did.BioDidBundleVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "action", outcome.bundle.action)
    bundleText = did.DidStoreAppendLine(bundleText, "bundle_seq", bundleSeqText)
    bundleText = did.DidStoreAppendLine(bundleText, "did", outcome.document.did)
    bundleText = did.DidStoreAppendLine(bundleText, "device_peer_id", devicePeerIdText)
    bundleText = did.DidStoreAppendLine(bundleText, "document_text", did.DidStoreEncodeText(outcome.bundle.documentText))
    bundleText = did.DidStoreAppendLine(bundleText, "record_version", recordVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_helper", recordHelperText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_pub_key", recordPubKeyText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_code_n", recordCodeNText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_code_k", recordCodeKText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_max_correctable", recordMaxCorrectableText)
    bundleText = did.DidStoreAppendLine(bundleText, "record_cid", recordCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "challenge_nonce", challengeNonceText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_commit_a", assertionCommitAText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_response_z", assertionResponseZText)
    bundleText = did.DidStoreAppendLine(bundleText, "assert_proof_cid", assertionProofCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_version", hardwareVersionText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_request_id", did.DidStoreEncodeText(outcome.bundle.hardware.requestId))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_sensor_id", did.DidStoreEncodeText(outcome.bundle.hardware.sensorId))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_verified_at", hardwareVerifiedAtText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_device_binding_seed_hash", hardwareDeviceBindingSeedHashText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_attestation_text", did.DidStoreEncodeText(outcome.bundle.hardware.attestationText))
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_attestation_cid", hardwareAttestationCidText)
    bundleText = did.DidStoreAppendLine(bundleText, "hardware_binding_cid", hardwareBindingCidText)
    return bridge.InternalMobileBridgeTextCString(bundleText)

fn mobileCapiBioDidDiagOkCString(stage: str): ptr =
    var out = ""
    out = did.DidStoreAppendLine(out, "ok", "1")
    out = did.DidStoreAppendLine(out, "stage", stage)
    return bridge.InternalMobileBridgeTextCString(out)

