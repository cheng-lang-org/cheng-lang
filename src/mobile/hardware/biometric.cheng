import std/result
import std/rawbytes
import std/strings as strings
import std/strutils
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256
import cheng/libp2p/identity/did as did

importc fn cheng_mobile_biometric_fingerprint_authorize_bridge(requestWire: str): str

const
    BiometricModalityFingerprint: int32 = 1
    BiometricPurposeDidCreate: int32 = 1
    BiometricPurposeDidImport: int32 = 2
    BiometricHardwareAttestationVersion: int32 = 2
    BiometricPlatformScripted: int32 = 1
    BiometricPlatformIos: int32 = 2
    BiometricPlatformAndroid: int32 = 3
    BiometricPlatformHarmony: int32 = 4
    BiometricAttestationKindPlatformChain: int32 = 1
    BiometricScriptedRootKeyId: str = "cheng.scripted.root"

type
    BiometricFingerprintAuthorizeReq =
        requestId: str
        purpose: int32
        didText: str
        promptTitle: str
        promptReason: str
        deviceBindingSeedHint: str
        deviceLabelHint: str

    BiometricFingerprintAuthorizeResp =
        authorized: bool
        modality: int32
        feature32: layout.FixedBytes32
        deviceBindingSeed: str
        deviceLabel: str
        sensorId: str
        hardwareAttestation: str
        error: str

    BiometricFingerprintAttestationEnvelope =
        requestId: str
        purpose: int32
        sensorId: str
        platform: int32
        attestationKind: int32
        rootKeyId: str
        certChainCid: layout.FixedBytes32
        livenessCid: layout.FixedBytes32
        deviceBindingSeedHash: layout.FixedBytes32
        deviceLabel: str
        featureCommitment: layout.FixedBytes32
        attestorPubKey: layout.FixedBytes65

var BiometricScriptedFingerprintEnabled: bool
var BiometricScriptedFingerprintAuthorized: bool
var BiometricScriptedFingerprintFeature32: layout.FixedBytes32
var BiometricScriptedFingerprintDeviceBindingSeed: str
var BiometricScriptedFingerprintDeviceLabel: str
var BiometricScriptedFingerprintSensorId: str
var BiometricScriptedFingerprintHardwareAttestation: str
var BiometricScriptedFingerprintAttestorPrivateKeyHex: str
var BiometricScriptedFingerprintError: str

fn BiometricFingerprintPurposeValid(purpose: int32): bool =
    if purpose == BiometricPurposeDidCreate:
        return true
    if purpose == BiometricPurposeDidImport:
        return true
    return false

fn BiometricAttestationPlatformValid(platform: int32): bool =
    if platform == BiometricPlatformScripted:
        return true
    if platform == BiometricPlatformIos:
        return true
    if platform == BiometricPlatformAndroid:
        return true
    if platform == BiometricPlatformHarmony:
        return true
    return false

fn BiometricAttestationKindValid(attestationKind: int32): bool =
    return attestationKind == BiometricAttestationKindPlatformChain

fn BiometricScriptedFingerprintCertChainSource(sensorId: str): str =
    var out = "scripted-cert-chain|"
    out = did.DidTextAppend(out, sensorId)
    return out

fn BiometricScriptedFingerprintLivenessSource(sensorId: str,
                                                deviceLabel: str): str =
    var out = "scripted-liveness|"
    out = did.DidTextAppend(out, sensorId)
    out = did.DidTextAppend(out, "|")
    out = did.DidTextAppend(out, deviceLabel)
    return out

fn BiometricFingerprintAuthorizeReqValidate(req: BiometricFingerprintAuthorizeReq): Result[bool] =
    let requestId = req.requestId
    let requestIdLen = strings.Len(requestId)
    if requestIdLen <= 0:
        return Err[bool](" biometric: request id required")
    if !BiometricFingerprintPurposeValid(req.purpose):
        return Err[bool](" biometric: invalid purpose")
    let didText = req.didText
    let didTextLen = strings.Len(didText)
    if req.purpose == BiometricPurposeDidImport && didTextLen <= 0:
        return Err[bool](" biometric: did required for import")
    let promptTitle = req.promptTitle
    let promptTitleLen = strings.Len(promptTitle)
    if promptTitleLen <= 0:
        return Err[bool](" biometric: prompt title required")
    let promptReason = req.promptReason
    let promptReasonLen = strings.Len(promptReason)
    if promptReasonLen <= 0:
        return Err[bool](" biometric: prompt reason required")
    let deviceBindingSeedHint = req.deviceBindingSeedHint
    let deviceBindingSeedHintLen = strings.Len(deviceBindingSeedHint)
    if deviceBindingSeedHintLen <= 0:
        return Err[bool](" biometric: device binding seed hint required")
    let deviceLabelHint = req.deviceLabelHint
    let deviceLabelHintLen = strings.Len(deviceLabelHint)
    if deviceLabelHintLen <= 0:
        return Err[bool](" biometric: device label hint required")
    return Ok[bool](true)

fn BiometricFingerprintAuthorizeRespValidate(resp: BiometricFingerprintAuthorizeResp): Result[bool] =
    let errorText = resp.error
    let errorTextLen = strings.Len(errorText)
    if !resp.authorized:
        if errorTextLen > 0:
            return Err[bool](errorText)
        return Err[bool](" biometric: fingerprint not authorized")
    if resp.modality != BiometricModalityFingerprint:
        return Err[bool](" biometric: fingerprint modality required")
    let deviceBindingSeed = resp.deviceBindingSeed
    let deviceBindingSeedLen = strings.Len(deviceBindingSeed)
    if deviceBindingSeedLen <= 0:
        return Err[bool](" biometric: device binding seed missing")
    let deviceLabel = resp.deviceLabel
    let deviceLabelLen = strings.Len(deviceLabel)
    if deviceLabelLen <= 0:
        return Err[bool](" biometric: device label missing")
    let sensorId = resp.sensorId
    let sensorIdLen = strings.Len(sensorId)
    if sensorIdLen <= 0:
        return Err[bool](" biometric: sensor id missing")
    let hardwareAttestation = resp.hardwareAttestation
    let hardwareAttestationLen = strings.Len(hardwareAttestation)
    if hardwareAttestationLen <= 0:
        return Err[bool](" biometric: hardware attestation missing")
    return Ok[bool](true)

fn BiometricFingerprintAuthorizeRespDenied(error: str): BiometricFingerprintAuthorizeResp =
    var out = BiometricFingerprintAuthorizeResp()
    out.authorized = false
    out.modality = BiometricModalityFingerprint
    out.error = error
    return out

fn BiometricFingerprintAuthorizeRespAuthorized(feature32: layout.FixedBytes32,
                                                 deviceBindingSeed: str,
                                                 deviceLabel: str,
                                                 sensorId: str,
                                                 hardwareAttestation: str):
                                                 BiometricFingerprintAuthorizeResp =
    var out = BiometricFingerprintAuthorizeResp()
    out.authorized = true
    out.modality = BiometricModalityFingerprint
    out.feature32 = feature32
    out.deviceBindingSeed = deviceBindingSeed
    out.deviceLabel = deviceLabel
    out.sensorId = sensorId
    out.hardwareAttestation = hardwareAttestation
    return out

fn BiometricTextHex(text: str): str =
    return bytesToHex(bytesFromString(text))

fn BiometricFingerprintFeatureCommitment(feature32: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(96)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.biometric.feature.commitment"))
    layout.ByteBufAppendBytes(buf, layout.FixedBytes32ToBytes(feature32))
    return fixed256.sha256Fixed(layout.ByteBufView(buf))

fn BiometricFingerprintDeviceBindingSeedHash(deviceBindingSeed: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(96)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.biometric.device.binding.seed"))
    layout.ByteBufAppendBytes(buf, bytesFromString(deviceBindingSeed))
    return fixed256.sha256Fixed(layout.ByteBufView(buf))

fn BiometricPlatformCertChainCid(platform: int32,
                                   attestationKind: int32,
                                   rootKeyId: str,
                                   certChainText: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.biometric.platform.cert.chain"))
    layout.ByteBufAppendBytes(buf, bytesFromString(strings.IntToStr(platform)))
    layout.ByteBufAppendBytes(buf, bytesFromString("|"))
    layout.ByteBufAppendBytes(buf, bytesFromString(strings.IntToStr(attestationKind)))
    layout.ByteBufAppendBytes(buf, bytesFromString("|"))
    layout.ByteBufAppendBytes(buf, bytesFromString(rootKeyId))
    layout.ByteBufAppendBytes(buf, bytesFromString("|"))
    layout.ByteBufAppendBytes(buf, bytesFromString(certChainText))
    return fixed256.sha256Fixed(layout.ByteBufView(buf))

fn BiometricLivenessCid(livenessText: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(192)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.biometric.liveness"))
    layout.ByteBufAppendBytes(buf, bytesFromString(livenessText))
    return fixed256.sha256Fixed(layout.ByteBufView(buf))

fn BiometricFingerprintAttestationSignable(envelope: var BiometricFingerprintAttestationEnvelope): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "cheng_biometric_attestation_version", strings.IntToStr(BiometricHardwareAttestationVersion))
    out = did.DidStoreAppendLine(out, "request_id", BiometricTextHex(envelope.requestId))
    out = did.DidStoreAppendLine(out, "purpose", strings.IntToStr(envelope.purpose))
    out = did.DidStoreAppendLine(out, "sensor_id", BiometricTextHex(envelope.sensorId))
    out = did.DidStoreAppendLine(out, "platform", strings.IntToStr(envelope.platform))
    out = did.DidStoreAppendLine(out, "attestation_kind", strings.IntToStr(envelope.attestationKind))
    out = did.DidStoreAppendLine(out, "root_key_id", BiometricTextHex(envelope.rootKeyId))
    out = did.DidStoreAppendLine(out, "cert_chain_cid", layout.FixedBytes32Hex(envelope.certChainCid))
    out = did.DidStoreAppendLine(out, "liveness_cid", layout.FixedBytes32Hex(envelope.livenessCid))
    out = did.DidStoreAppendLine(out, "device_binding_seed_hash", layout.FixedBytes32Hex(envelope.deviceBindingSeedHash))
    out = did.DidStoreAppendLine(out, "device_label", BiometricTextHex(envelope.deviceLabel))
    out = did.DidStoreAppendLine(out, "feature_commitment", layout.FixedBytes32Hex(envelope.featureCommitment))
    out = did.DidStoreAppendLine(out, "attestor_pub_key", layout.FixedBytes65Hex(envelope.attestorPubKey))
    return out

fn BiometricFingerprintAttestationText(envelope: var BiometricFingerprintAttestationEnvelope,
                                         signature: layout.FixedBytes64): str =
    var out = BiometricFingerprintAttestationSignable(envelope)
    out = did.DidStoreAppendLine(out, "signature", layout.FixedBytes64Hex(signature))
    return out

fn BiometricFingerprintAuthorizeReqWire(req: BiometricFingerprintAuthorizeReq): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "request_id", BiometricTextHex(req.requestId))
    out = did.DidStoreAppendLine(out, "purpose", strings.IntToStr(req.purpose))
    out = did.DidStoreAppendLine(out, "did", BiometricTextHex(req.didText))
    out = did.DidStoreAppendLine(out, "prompt_title", BiometricTextHex(req.promptTitle))
    out = did.DidStoreAppendLine(out, "prompt_reason", BiometricTextHex(req.promptReason))
    out = did.DidStoreAppendLine(out, "device_binding_seed_hint", BiometricTextHex(req.deviceBindingSeedHint))
    out = did.DidStoreAppendLine(out, "device_label_hint", BiometricTextHex(req.deviceLabelHint))
    return out

fn BiometricDecodeWireText(text: str): Result[str] =
    let bytesRes = did.DidStoreDecodeBytes(text)
    if IsErr(bytesRes):
        return Err[str](Error(bytesRes))
    return Ok[str](bytesToString(Value(bytesRes)))

fn BiometricWireFindValue(wire: str, key: str): Result[str] =
    let prefix = strutils.Join([key, "="], "")
    var lineStart: int32
    let n = strings.Len(wire)
    while lineStart < n:
        var lineEnd = lineStart
        while lineEnd < n && wire[lineEnd] != '\n':
            lineEnd = lineEnd + 1
        let line = strutils.SliceStr(wire, lineStart, lineEnd - 1)
        if strutils.StartsWith(line, prefix):
            return Ok[str](strutils.SliceStr(line, strings.Len(prefix), strings.Len(line) - 1))
        lineStart = lineEnd + 1
    return Err[str](strutils.Join([" biometric: missing wire field ", key], ""))

fn BiometricFingerprintAuthorizeHostBridge(requestWire: str): str =
    return cheng_mobile_biometric_fingerprint_authorize_bridge(requestWire)

fn BiometricFingerprintAttestationBuildSigned(req: BiometricFingerprintAuthorizeReq,
                                                feature32: layout.FixedBytes32,
                                                deviceBindingSeed: str,
                                                deviceLabel: str,
                                                sensorId: str,
                                                attestorPrivateKeyHex: str): Result[str] =
    let platform = BiometricPlatformScripted
    let attestationKind = BiometricAttestationKindPlatformChain
    let rootKeyId = BiometricScriptedRootKeyId
    let certChainText = BiometricScriptedFingerprintCertChainSource(sensorId)
    let livenessText = BiometricScriptedFingerprintLivenessSource(sensorId, deviceLabel)
    if !BiometricAttestationPlatformValid(platform):
        return Err[str](" biometric: invalid attestation platform")
    if !BiometricAttestationKindValid(attestationKind):
        return Err[str](" biometric: invalid attestation kind")
    if strings.Len(rootKeyId) <= 0:
        return Err[str](" biometric: root key id required")
    if strings.Len(certChainText) <= 0:
        return Err[str](" biometric: cert chain text required")
    if strings.Len(livenessText) <= 0:
        return Err[str](" biometric: liveness text required")
    let privRes = fixed256.scalar256FromHex(attestorPrivateKeyHex)
    if IsErr(privRes):
        return Err[str](Error(privRes))
    let pubRes = fixed256.p256PublicKey65FromPrivateScalar(Value(privRes))
    if IsErr(pubRes):
        return Err[str](Error(pubRes))
    let deviceBindingSeedHash = BiometricFingerprintDeviceBindingSeedHash(deviceBindingSeed)
    let featureCommitment = BiometricFingerprintFeatureCommitment(feature32)
    let certChainCid = BiometricPlatformCertChainCid(platform,
                                                       attestationKind,
                                                       rootKeyId,
                                                       certChainText)
    let livenessCid = BiometricLivenessCid(livenessText)
    var envelope = BiometricFingerprintAttestationEnvelope()
    envelope.requestId = req.requestId
    envelope.purpose = req.purpose
    envelope.sensorId = sensorId
    envelope.platform = platform
    envelope.attestationKind = attestationKind
    envelope.rootKeyId = rootKeyId
    envelope.certChainCid = certChainCid
    envelope.livenessCid = livenessCid
    envelope.deviceBindingSeedHash = deviceBindingSeedHash
    envelope.deviceLabel = deviceLabel
    envelope.featureCommitment = featureCommitment
    envelope.attestorPubKey = Value(pubRes)
    let signable = BiometricFingerprintAttestationSignable(envelope)
    let sigRes = fixed256.p256SignMessageFixed64(Value(privRes), bytesFromString(signable))
    if IsErr(sigRes):
        return Err[str](Error(sigRes))
    return Ok[str](BiometricFingerprintAttestationText(envelope,
                                                         Value(sigRes)))

fn BiometricSetScriptedFingerprintAuthorized(feature32: layout.FixedBytes32,
                                               deviceBindingSeed: str,
                                               deviceLabel: str,
                                               sensorId: str,
                                               hardwareAttestation: str) =
    BiometricScriptedFingerprintEnabled = true
    BiometricScriptedFingerprintAuthorized = true
    BiometricScriptedFingerprintFeature32 = feature32
    BiometricScriptedFingerprintDeviceBindingSeed = deviceBindingSeed
    BiometricScriptedFingerprintDeviceLabel = deviceLabel
    BiometricScriptedFingerprintSensorId = sensorId
    BiometricScriptedFingerprintHardwareAttestation = hardwareAttestation
    BiometricScriptedFingerprintAttestorPrivateKeyHex = ""
    BiometricScriptedFingerprintError = ""

fn BiometricSetScriptedFingerprintAuthorizedSigned(feature32: layout.FixedBytes32,
                                                     deviceBindingSeed: str,
                                                     deviceLabel: str,
                                                     sensorId: str,
                                                     attestorPrivateKeyHex: str) =
    BiometricScriptedFingerprintEnabled = true
    BiometricScriptedFingerprintAuthorized = true
    BiometricScriptedFingerprintFeature32 = feature32
    BiometricScriptedFingerprintDeviceBindingSeed = deviceBindingSeed
    BiometricScriptedFingerprintDeviceLabel = deviceLabel
    BiometricScriptedFingerprintSensorId = sensorId
    BiometricScriptedFingerprintHardwareAttestation = ""
    BiometricScriptedFingerprintAttestorPrivateKeyHex = attestorPrivateKeyHex
    BiometricScriptedFingerprintError = ""

fn BiometricSetScriptedFingerprintDenied(error: str) =
    BiometricScriptedFingerprintEnabled = true
    BiometricScriptedFingerprintAuthorized = false
    BiometricScriptedFingerprintFeature32 = layout.FixedBytes32()
    BiometricScriptedFingerprintDeviceBindingSeed = ""
    BiometricScriptedFingerprintDeviceLabel = ""
    BiometricScriptedFingerprintSensorId = ""
    BiometricScriptedFingerprintHardwareAttestation = ""
    BiometricScriptedFingerprintAttestorPrivateKeyHex = ""
    BiometricScriptedFingerprintError = error

fn BiometricClearScriptedFingerprintAuthorize() =
    BiometricScriptedFingerprintEnabled = false
    BiometricScriptedFingerprintAuthorized = false
    BiometricScriptedFingerprintFeature32 = layout.FixedBytes32()
    BiometricScriptedFingerprintDeviceBindingSeed = ""
    BiometricScriptedFingerprintDeviceLabel = ""
    BiometricScriptedFingerprintSensorId = ""
    BiometricScriptedFingerprintHardwareAttestation = ""
    BiometricScriptedFingerprintAttestorPrivateKeyHex = ""
    BiometricScriptedFingerprintError = ""

fn BiometricFingerprintAuthorizeBlockingFill(out: var BiometricFingerprintAuthorizeResp,
                                                 requestId: str,
                                                 req: BiometricFingerprintAuthorizeReq): Result[bool] =
    let requestIdLen = strings.Len(requestId)
    if requestIdLen <= 0:
        return Err[bool](" biometric: request id required")
    var callReq = req
    callReq.requestId = requestId
    let reqOk = BiometricFingerprintAuthorizeReqValidate(callReq)
    if IsErr(reqOk):
        return Err[bool](Error(reqOk))
    out = BiometricFingerprintAuthorizeResp()
    out.modality = BiometricModalityFingerprint
    if BiometricScriptedFingerprintEnabled:
        out.authorized = BiometricScriptedFingerprintAuthorized
        out.feature32 = BiometricScriptedFingerprintFeature32
        out.deviceBindingSeed = BiometricScriptedFingerprintDeviceBindingSeed
        out.deviceLabel = BiometricScriptedFingerprintDeviceLabel
        out.sensorId = BiometricScriptedFingerprintSensorId
        let scriptedHardwareAttestation = BiometricScriptedFingerprintHardwareAttestation
        let scriptedHardwareAttestationLen = strings.Len(scriptedHardwareAttestation)
        let scriptedAttestorPrivateKeyHex = BiometricScriptedFingerprintAttestorPrivateKeyHex
        let scriptedAttestorPrivateKeyHexLen = strings.Len(scriptedAttestorPrivateKeyHex)
        if scriptedHardwareAttestationLen > 0:
            out.hardwareAttestation = scriptedHardwareAttestation
        elif scriptedAttestorPrivateKeyHexLen > 0:
            let attestationRes = BiometricFingerprintAttestationBuildSigned(callReq,
                                                                              out.feature32,
                                                                              out.deviceBindingSeed,
                                                                              out.deviceLabel,
                                                                              out.sensorId,
                                                                              scriptedAttestorPrivateKeyHex)
            if IsErr(attestationRes):
                return Err[bool](Error(attestationRes))
            out.hardwareAttestation = Value(attestationRes)
        out.error = BiometricScriptedFingerprintError
    else:
        let requestWire = BiometricFingerprintAuthorizeReqWire(callReq)
        let responseWire = BiometricFingerprintAuthorizeHostBridge(requestWire)
        let okWireRes = BiometricWireFindValue(responseWire, "ok")
        if IsErr(okWireRes):
            return Err[bool](Error(okWireRes))
        if Value(okWireRes) != "1":
            let errorWireRes = BiometricWireFindValue(responseWire, "error_hex")
            if IsErr(errorWireRes):
                return Err[bool](" biometric: fingerprint authorize impl missing")
            let errorTextRes = BiometricDecodeWireText(Value(errorWireRes))
            if IsErr(errorTextRes):
                return Err[bool](Error(errorTextRes))
            let errorText = Value(errorTextRes)
            let errorTextLen = strings.Len(errorText)
            if errorTextLen > 0:
                return Err[bool](errorText)
            return Err[bool](" biometric: fingerprint authorize impl missing")
        let feature32HexRes = BiometricWireFindValue(responseWire, "feature32_hex")
        if IsErr(feature32HexRes):
            return Err[bool](Error(feature32HexRes))
        let deviceBindingSeedWireRes = BiometricWireFindValue(responseWire, "device_binding_seed_hex")
        if IsErr(deviceBindingSeedWireRes):
            return Err[bool](Error(deviceBindingSeedWireRes))
        let deviceLabelWireRes = BiometricWireFindValue(responseWire, "device_label_hex")
        if IsErr(deviceLabelWireRes):
            return Err[bool](Error(deviceLabelWireRes))
        let sensorIdWireRes = BiometricWireFindValue(responseWire, "sensor_id_hex")
        if IsErr(sensorIdWireRes):
            return Err[bool](Error(sensorIdWireRes))
        let hardwareAttestationWireRes = BiometricWireFindValue(responseWire, "hardware_attestation_hex")
        if IsErr(hardwareAttestationWireRes):
            return Err[bool](Error(hardwareAttestationWireRes))
        let deviceBindingSeedRes = BiometricDecodeWireText(Value(deviceBindingSeedWireRes))
        if IsErr(deviceBindingSeedRes):
            return Err[bool](Error(deviceBindingSeedRes))
        let deviceLabelRes = BiometricDecodeWireText(Value(deviceLabelWireRes))
        if IsErr(deviceLabelRes):
            return Err[bool](Error(deviceLabelRes))
        let sensorIdRes = BiometricDecodeWireText(Value(sensorIdWireRes))
        if IsErr(sensorIdRes):
            return Err[bool](Error(sensorIdRes))
        let hardwareAttestationRes = BiometricDecodeWireText(Value(hardwareAttestationWireRes))
        if IsErr(hardwareAttestationRes):
            return Err[bool](Error(hardwareAttestationRes))
        let feature32Res: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(Value(feature32HexRes))
        if IsErr(feature32Res):
            return Err[bool](" biometric: invalid host feature32")
        out.authorized = true
        out.feature32 = Value(feature32Res)
        out.deviceBindingSeed = Value(deviceBindingSeedRes)
        out.deviceLabel = Value(deviceLabelRes)
        out.sensorId = Value(sensorIdRes)
        out.hardwareAttestation = Value(hardwareAttestationRes)
        out.error = ""

    let respOk = BiometricFingerprintAuthorizeRespValidate(out)
    if IsErr(respOk):
        return Err[bool](Error(respOk))
    return Ok[bool](true)
