import std/rawbytes
import std/result
import std/system
import std/strings
import std/strformat
import std/rawmem_support
import cheng/std/bytes_layout as layout
import std/strutils as strutil

importc fn cheng_sha256_hex_bridge(text: str): str
@importc("cheng_mobile_host_emit_log")
fn cheng_mobile_host_emit_log(message: str)
@importc("cheng_fopen")
fn cheng_fopen(filename, mode: cstring): ptr
@importc("cheng_fclose")
fn cheng_fclose(stream: ptr): int32
@importc("cheng_fwrite")
fn cheng_fwrite(buf: ptr, size: int64, n: int64, stream: ptr): int32
@importc("cheng_fwrite_i32")
fn cheng_fwrite_i32(buf: ptr, size: int32, n: int32, stream: ptr): int32

fn MoqFountainSetTracePath(path: str) =
    path

fn MoqFountainClearTracePath() =
    return

fn MoqFountainAppendTraceLine(stream: ptr, line: str): Result[bool] =
    stream
    line
    return Ok[bool](true)

fn MoqFountainEmitLog(message: str) =
    cheng_mobile_host_emit_log(message)

fn MoqFountainByteBufAppendText(buf: var layout.ByteBuf, text: str) =
    if len(text) <= 0:
        return
    layout.ByteBufAppendBytes(buf, bytesFromString(text))

fn MoqFountainByteBufBytes(buf: var layout.ByteBuf): Bytes =
    if buf.len <= 0:
        return emptyBytes()
    var out = bytesAlloc(buf.len)
    rawmem_support.RawmemCopy(out.data, buf.storage.data, buf.len)
    return out

fn MoqFountainCopyBytesRange(data: Bytes,
                             offset: int32,
                             count: int32): Bytes =
    if count <= 0:
        return emptyBytes()
    if offset < 0:
        return emptyBytes()
    if offset >= bytesLen(data):
        return emptyBytes()
    var take = count
    if offset + take > bytesLen(data):
        take = bytesLen(data) - offset
    if take <= 0:
        return emptyBytes()
    var out = bytesAlloc(take)
    rawmem_support.RawmemCopy(out.data,
                              rawmem_support.RawmemPtrAdd(data.data, offset),
                              take)
    return out

type MoqFountainDroplet = object
    objectIndex: int32
    dropletIndex: int32
    kindCode: int32
    key: str
    peerId: str
    cid: str
    degree: int32
    blockIndexes: int32[]
    payload: Bytes

type MoqFountainObject = object
    objectIndex: int32
    groupId: str
    objectId: str
    priority: int32
    byteOffset: int32
    byteLength: int32
    objectCid: str
    sourceBlockBytes: int32
    sourceBlockCount: int32
    repairDropletCount: int32
    droplets: MoqFountainDroplet[]

type MoqFountainEquation = object
    coeffs: int32[]
    payload: Bytes

type MoqFountainBuildResult = object
    ownerPeerId: str
    mimeType: str
    bundleCid: str
    blobCid: str
    catalogKey: str
    catalogCid: str
    catalogSizeBytes: int32
    catalogPayload: Bytes
    rebuildTemplateKey: str
    rebuildTemplateCid: str
    rebuildTemplateSizeBytes: int32
    rebuildTemplatePayload: Bytes
    blobByteLen: int32
    objectTargetBytes: int32
    sourceBlockBytes: int32
    objectCount: int32
    remoteAckPeerIds: str[]
    objects: MoqFountainObject[]
    droplets: MoqFountainDroplet[]

type MoqFountainRebuildResult = object
    blob: Bytes
    blobCid: str
    blobByteLen: int32

const MoqFountainCatalogMagic = "unimaker.moq.fountain.catalog.v1"
const MoqFountainTransport = "native_media_rpc"
const MoqFountainLayout = "lt_xor_v1"
const MoqFountainDropletKindSource = 1
const MoqFountainDropletKindRepair = 2

fn MoqFountainErrorWire(errorText: str): str =
    var rows: str[]
    rows = []
    add(rows, "ok=0")
    add(rows, MoqFountainFmt2("error=", errorText))
    return MoqFountainLinesWithNewline(rows)

fn MoqFountainMaxInt32(left: int32, right: int32): int32 =
    if left >= right:
        return left
    return right

fn MoqFountainMinInt32(left: int32, right: int32): int32 =
    if left <= right:
        return left
    return right

fn MoqFountainNormalizePositiveInt(value: int32, fallback: int32): int32 =
    var out = value
    if out <= 0:
        out = fallback
    if out <= 0:
        return 1
    return out

fn MoqFountainHexValue(ch: int32): int32 =
    if ch >= int32('0') && ch <= int32('9'):
        return ch - int32('0')
    if ch >= int32('a') && ch <= int32('f'):
        return 10 + ch - int32('a')
    if ch >= int32('A') && ch <= int32('F'):
        return 10 + ch - int32('A')
    return -1

fn MoqFountainBytesFromHex(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](bytesAlloc(0))
    if (len(text) % 2) != 0:
        return Err[Bytes]("moq_fountain_invalid_hex_length")
    let textBytes = bytesFromString(text)
    var out = bytesAlloc(len(text) / 2)
    var i: int32
    for i in range(0, len(text), 2):

        let hi = MoqFountainHexValue(bytesGet(textBytes, i))
        let lo = MoqFountainHexValue(bytesGet(textBytes, i + 1))
        if hi < 0 || lo < 0:
            return Err[Bytes]("moq_fountain_invalid_hex")
        bytesSet(out, i / 2, (hi << 4) | lo)

    return Ok[Bytes](out)

fn MoqFountainSha256HexBytes(data: Bytes): str =
    let text = bytesToString(data)
    let digest = cheng_sha256_hex_bridge(text)
    return digest

fn MoqFountainSha256HexText(text: str): str =
    return cheng_sha256_hex_bridge(text)

fn MoqFountainAsciiTrimLeft(text: str): int32 =
    let textBytes = bytesFromString(text)
    var idx: int32
    for idx in range(len(text)):

        let code = bytesGet(textBytes, idx)
        if code == 32 || code == 10 || code == 13 || code == 9:
            idx = idx + 1
            continue
        break
    return idx

fn MoqFountainAsciiTrimRight(text: str): int32 =
    let textBytes = bytesFromString(text)
    var idx: int32 = len(text)
    while idx > 0:
        let code = bytesGet(textBytes, idx - 1)
        if code == 32 || code == 10 || code == 13 || code == 9:

            continue
        break
    return idx

fn MoqFountainTrimAscii(text: str): str =
    let start = MoqFountainAsciiTrimLeft(text)
    let stop = MoqFountainAsciiTrimRight(text)
    var sliceStart: int32
    var sliceCount: int32
    if stop > start:
        sliceStart = start
        sliceCount = stop - start
    let out = strings.SliceBytes(text, sliceStart, sliceCount)
    return out

fn MoqFountainTextContains(haystack: str, needle: str): bool =
    let haystackLen = len(haystack)
    let needleLen = len(needle)
    if needleLen <= 0:
        return true
    if haystackLen < needleLen:
        return false
    let haystackBytes = bytesFromString(haystack)
    let needleBytes = bytesFromString(needle)
    var start: int32
    for start in range(= haystackLen - needleLen):

        var matched = true
        var idx: int32
        for idx in idx..<needleLen:
            if bytesGet(haystackBytes, start + idx) != bytesGet(needleBytes, idx):
                matched = false
                break
        if matched:
            return true

    return false

fn MoqFountainSplitCsv(text: str): str[] =
    var out: str[]
    out = []
    if len(text) <= 0:
        return out
    let textBytes = bytesFromString(text)
    var start: int32
    var idx: int32
    for idx in idx..<= len(text):
        let atEnd = idx >= len(text)
        var hitSplit = atEnd
        if !hitSplit:
            if bytesGet(textBytes, idx) == 44:
                hitSplit = true
        if hitSplit:
            var item = ""
            if idx > start:
                item = strings.SliceBytes(text, start, idx - start)
            add(out, item)
            start = idx + 1
    return out

fn MoqFountainNormalizePeerCsv(peerCsv: str): str[] =
    var out: str[]
    out = []
    if len(peerCsv) <= 0:
        return out
    let peerCsvBytes = bytesFromString(peerCsv)
    var seen = ","
    var start: int32
    var i: int32
    for i in i..<= len(peerCsv):
        let atEnd = i >= len(peerCsv)
        var hitSplit = atEnd
        if !hitSplit:
            if bytesGet(peerCsvBytes, i) == 44:
                hitSplit = true
        if !hitSplit:
            continue
        var raw = ""
        if i > start:
            raw = strings.SliceBytes(peerCsv, start, i - start)
        let candidate = MoqFountainTrimAscii(raw)
        if len(candidate) > 0:
            let marker = MoqFountainFmt3(",", candidate, ",")
            if !MoqFountainTextContains(seen, marker):
                add(out, candidate)
                seen = MoqFountainFmt2(seen, marker)
        start = i + 1
    return out

fn MoqFountainJoinTexts(parts: str[], sep: str): str =
    if parts.len <= 0:
        return ""
    let sepLen = len(sep)
    var totalLen: int32
    var idx: int32
    for idx in idx..<parts.len:
        totalLen = totalLen + len(parts[idx])
        if idx + 1 < parts.len:
            totalLen = totalLen + sepLen
    var buf = layout.ByteBufInit(totalLen)
    idx = 0
    for idx in idx..<parts.len:
        if idx > 0 && sepLen > 0:
            MoqFountainByteBufAppendText(buf, sep)
        MoqFountainByteBufAppendText(buf, parts[idx])
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainAppendRawLine(buf: var layout.ByteBuf, key: str, value: str) =
    MoqFountainByteBufAppendText(buf, key)
    layout.ByteBufAppendByte(buf, int32('='))
    MoqFountainByteBufAppendText(buf, value)
    layout.ByteBufAppendByte(buf, int32('\n'))

fn MoqFountainAppendIntLine(buf: var layout.ByteBuf, key: str, value: int32) =
    MoqFountainAppendRawLine(buf, key, strings.IntToStr(value))

fn MoqFountainJoinCsv(values: str[]): str =
    if values.len <= 0:
        return ""
    return MoqFountainJoinTexts(values, ",")

fn MoqFountainJoinIntCsv(values: int32[]): str =
    var rows: str[]
    rows = []
    var i: int32
    for i in i..<values.len:
        add(rows, strings.IntToStr(values[i]))
    return MoqFountainJoinTexts(rows, ",")

fn MoqFountainFmt2(left: str, right: str): str =
    MoqFountainEmitLog("moq_fmt2:start")
    var buf = layout.ByteBufInit(len(left) + len(right))
    MoqFountainEmitLog("moq_fmt2:add_left_begin")
    MoqFountainByteBufAppendText(buf, left)
    MoqFountainEmitLog("moq_fmt2:add_left_done")
    MoqFountainEmitLog("moq_fmt2:add_right_begin")
    MoqFountainByteBufAppendText(buf, right)
    MoqFountainEmitLog("moq_fmt2:add_right_done")
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainFmt3(first: str, second: str, third: str): str =
    MoqFountainEmitLog("moq_fmt3:start")
    var buf = layout.ByteBufInit(len(first) + len(second) + len(third))
    MoqFountainEmitLog("moq_fmt3:add_first_begin")
    MoqFountainByteBufAppendText(buf, first)
    MoqFountainEmitLog("moq_fmt3:add_first_done")
    MoqFountainEmitLog("moq_fmt3:add_second_begin")
    MoqFountainByteBufAppendText(buf, second)
    MoqFountainEmitLog("moq_fmt3:add_second_done")
    MoqFountainEmitLog("moq_fmt3:add_third_begin")
    MoqFountainByteBufAppendText(buf, third)
    MoqFountainEmitLog("moq_fmt3:add_third_done")
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainCatalogJson(ownerPeerId: str,
                          mimeType: str,
                          blobCid: str,
                          blobByteLen: int32,
                          bundleCid: str,
                          objectTargetBytes: int32,
                          sourceBlockBytes: int32,
                          objects: MoqFountainObject[]): str =
    MoqFountainEmitLog("moq_catalog_json:start")
    var catalogMagic = "\"unimaker.moq.fountain.catalog.v1\""
    var transportText = "\"moq\""
    var layoutText = "\"lt_fountain_v1\""
    var ownerPeerText = ""
    MoqFountainEmitLog("moq_catalog_json:owner_begin")
    ownerPeerText = MoqFountainJsonQuote(ownerPeerId)
    MoqFountainEmitLog("moq_catalog_json:owner_done")
    var mimeTypeText = ""
    MoqFountainEmitLog("moq_catalog_json:mime_begin")
    mimeTypeText = MoqFountainJsonQuote(mimeType)
    MoqFountainEmitLog("moq_catalog_json:mime_done")
    var blobCidText = ""
    MoqFountainEmitLog("moq_catalog_json:blob_cid_begin")
    blobCidText = MoqFountainJsonQuote(blobCid)
    MoqFountainEmitLog("moq_catalog_json:blob_cid_done")
    var trackIdRaw = ""
    MoqFountainEmitLog("moq_catalog_json:track_raw_begin")
    trackIdRaw = MoqFountainFmt2("track:", bundleCid)
    MoqFountainEmitLog("moq_catalog_json:track_raw_done")
    var trackIdText = ""
    MoqFountainEmitLog("moq_catalog_json:track_begin")
    trackIdText = MoqFountainJsonQuote(trackIdRaw)
    MoqFountainEmitLog("moq_catalog_json:track_done")
    var bundleCidText = ""
    MoqFountainEmitLog("moq_catalog_json:bundle_begin")
    bundleCidText = MoqFountainJsonQuote(bundleCid)
    MoqFountainEmitLog("moq_catalog_json:bundle_done")
    var blobByteLenText = ""
    blobByteLenText = strings.IntToStr(blobByteLen)
    var objectTargetBytesText = ""
    objectTargetBytesText = strings.IntToStr(objectTargetBytes)
    var sourceBlockBytesText = ""
    sourceBlockBytesText = strings.IntToStr(sourceBlockBytes)
    var objectCountText = ""
    objectCountText = strings.IntToStr(objects.len)
    var buf = layout.ByteBufInit(512)
    MoqFountainByteBufAppendText(buf, "{")
    MoqFountainByteBufAppendText(buf, "\"magic\":")
    MoqFountainByteBufAppendText(buf, catalogMagic)
    MoqFountainByteBufAppendText(buf, ",\"version\":1,")
    MoqFountainByteBufAppendText(buf, "\"transport\":")
    MoqFountainByteBufAppendText(buf, transportText)
    MoqFountainByteBufAppendText(buf, ",\"fountainLayout\":")
    MoqFountainByteBufAppendText(buf, layoutText)
    MoqFountainByteBufAppendText(buf, ",\"ownerPeerId\":")
    MoqFountainByteBufAppendText(buf, ownerPeerText)
    MoqFountainByteBufAppendText(buf, ",\"mimeType\":")
    MoqFountainByteBufAppendText(buf, mimeTypeText)
    MoqFountainByteBufAppendText(buf, ",\"blobCid\":")
    MoqFountainByteBufAppendText(buf, blobCidText)
    MoqFountainByteBufAppendText(buf, ",\"blobByteLen\":")
    MoqFountainByteBufAppendText(buf, blobByteLenText)
    MoqFountainByteBufAppendText(buf, ",\"trackId\":")
    MoqFountainByteBufAppendText(buf, trackIdText)
    MoqFountainByteBufAppendText(buf, ",\"bundleCid\":")
    MoqFountainByteBufAppendText(buf, bundleCidText)
    MoqFountainByteBufAppendText(buf, ",\"objectTargetBytes\":")
    MoqFountainByteBufAppendText(buf, objectTargetBytesText)
    MoqFountainByteBufAppendText(buf, ",\"sourceBlockBytes\":")
    MoqFountainByteBufAppendText(buf, sourceBlockBytesText)
    MoqFountainByteBufAppendText(buf, ",\"objectCount\":")
    MoqFountainByteBufAppendText(buf, objectCountText)
    MoqFountainByteBufAppendText(buf, ",\"objects\":[")
    MoqFountainEmitLog("moq_catalog_json:objects_begin")
    var objectIndex: int32
    for objectIndex in objectIndex..<objects.len:
        if objectIndex > 0:
            MoqFountainByteBufAppendText(buf, ",")
        MoqFountainEmitLog("moq_catalog_json:object_begin")
        var objectJson = ""
        objectJson = MoqFountainObjectJson(objects[objectIndex])
        MoqFountainEmitLog("moq_catalog_json:object_done")
        MoqFountainByteBufAppendText(buf, objectJson)
    MoqFountainByteBufAppendText(buf, "]}")
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainCatalogBytes(ownerPeerId: str,
                           mimeType: str,
                           blobCid: str,
                           blobByteLen: int32,
                           bundleCid: str,
                           objectTargetBytes: int32,
                           sourceBlockBytes: int32,
                           objects: MoqFountainObject[]): Bytes =
    return bytesFromString(MoqFountainCatalogJson(ownerPeerId,
                                                  mimeType,
                                                  blobCid,
                                                  blobByteLen,
                                                  bundleCid,
                                                  objectTargetBytes,
                                                  sourceBlockBytes,
                                                  objects))

fn MoqFountainConcatAssign(out: var str, part: str) =
    let prefix = out
    out = strutil.Join([prefix, part], "")

fn MoqFountainPrefixKey(prefix: str, key: str): str =
    return MoqFountainFmt2(prefix, key)

fn MoqFountainLinesWithNewline(rows: str[]): str =
    if rows.len <= 0:
        return "\n"
    var cap: int32 = 1
    var i: int32
    for i in i..<rows.len:
        cap = cap + len(rows[i]) + 1
    var buf = layout.ByteBufInit(cap)
    i = 0
    for i in i..<rows.len:
        MoqFountainByteBufAppendText(buf, rows[i])
        layout.ByteBufAppendByte(buf, int32('\n'))
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainBuildBundleSeed(ownerPeerId: str,
                              blobCid: str,
                              mimeType: str,
                              peers: str[],
                              objectTargetBytes: int32,
                              sourceBlockBytes: int32,
                              repairDropletCount: int32): str =
    MoqFountainEmitLog("moq_build_bundle_seed:join_begin")
    let peerCsv = MoqFountainJoinCsv(peers)
    MoqFountainEmitLog("moq_build_bundle_seed:join_done")
    let objectTargetBytesText = strings.IntToStr(objectTargetBytes)
    let sourceBlockBytesText = strings.IntToStr(sourceBlockBytes)
    let repairDropletCountText = strings.IntToStr(repairDropletCount)
    var buf = layout.ByteBufInit(len(ownerPeerId) + len(blobCid) + len(mimeType) + len(peerCsv) + len(objectTargetBytesText) + len(sourceBlockBytesText) + len(repairDropletCountText) + 6)
    MoqFountainByteBufAppendText(buf, ownerPeerId)
    MoqFountainByteBufAppendText(buf, "|")
    MoqFountainByteBufAppendText(buf, blobCid)
    MoqFountainByteBufAppendText(buf, "|")
    MoqFountainByteBufAppendText(buf, mimeType)
    MoqFountainByteBufAppendText(buf, "|")
    MoqFountainByteBufAppendText(buf, peerCsv)
    MoqFountainByteBufAppendText(buf, "|")
    MoqFountainByteBufAppendText(buf, objectTargetBytesText)
    MoqFountainByteBufAppendText(buf, "|")
    MoqFountainByteBufAppendText(buf, sourceBlockBytesText)
    MoqFountainByteBufAppendText(buf, "|")
    MoqFountainByteBufAppendText(buf, repairDropletCountText)
    let payload = MoqFountainByteBufBytes(buf)
    return bytesToString(payload)

fn MoqFountainSourceDropletKey(bundleCid: str,
                               objectIndex: int32,
                               sourceDropletIndex: int32): str =
    MoqFountainEmitLog("moq_source_key:enter")
    let objectIndexText = strings.IntToStr(objectIndex)
    MoqFountainEmitLog("moq_source_key:object_index_text")
    let sourceDropletIndexText = strings.IntToStr(sourceDropletIndex)
    MoqFountainEmitLog("moq_source_key:source_index_text")
    var buf = layout.ByteBufInit(len(bundleCid) + len(objectIndexText) + len(sourceDropletIndexText) + 11)
    MoqFountainByteBufAppendText(buf, "moqdrop-")
    MoqFountainByteBufAppendText(buf, bundleCid)
    MoqFountainByteBufAppendText(buf, "-o")
    MoqFountainByteBufAppendText(buf, objectIndexText)
    MoqFountainByteBufAppendText(buf, "-s")
    MoqFountainByteBufAppendText(buf, sourceDropletIndexText)
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainRepairDropletKey(bundleCid: str,
                               objectIndex: int32,
                               repairIndex: int32): str =
    MoqFountainEmitLog("moq_repair_key:enter")
    let objectIndexText = strings.IntToStr(objectIndex)
    MoqFountainEmitLog("moq_repair_key:object_index_text")
    let repairIndexText = strings.IntToStr(repairIndex)
    MoqFountainEmitLog("moq_repair_key:repair_index_text")
    var buf = layout.ByteBufInit(len(bundleCid) + len(objectIndexText) + len(repairIndexText) + 11)
    MoqFountainByteBufAppendText(buf, "moqdrop-")
    MoqFountainByteBufAppendText(buf, bundleCid)
    MoqFountainByteBufAppendText(buf, "-o")
    MoqFountainByteBufAppendText(buf, objectIndexText)
    MoqFountainByteBufAppendText(buf, "-r")
    MoqFountainByteBufAppendText(buf, repairIndexText)
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainRepairDegreeSeed(bundleCid: str,
                               objectIndex: int32,
                               repairIndex: int32): str =
    MoqFountainEmitLog("moq_repair_degree_seed:enter")
    let objectIndexText = strings.IntToStr(objectIndex)
    MoqFountainEmitLog("moq_repair_degree_seed:object_index_text")
    let repairIndexText = strings.IntToStr(repairIndex)
    MoqFountainEmitLog("moq_repair_degree_seed:repair_index_text")
    var buf = layout.ByteBufInit(len(bundleCid) + len(objectIndexText) + len(repairIndexText) + 4)
    MoqFountainByteBufAppendText(buf, bundleCid)
    MoqFountainByteBufAppendText(buf, "|o")
    MoqFountainByteBufAppendText(buf, objectIndexText)
    MoqFountainByteBufAppendText(buf, "|r")
    MoqFountainByteBufAppendText(buf, repairIndexText)
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainRepairSeed(bundleCid: str,
                         objectIndex: int32,
                         repairIndex: int32): str =
    MoqFountainEmitLog("moq_repair_seed:enter")
    let objectIndexText = strings.IntToStr(objectIndex)
    MoqFountainEmitLog("moq_repair_seed:object_index_text")
    let repairIndexText = strings.IntToStr(repairIndex)
    MoqFountainEmitLog("moq_repair_seed:repair_index_text")
    var buf = layout.ByteBufInit(len(bundleCid) + len(objectIndexText) + len(repairIndexText) + 9)
    MoqFountainByteBufAppendText(buf, bundleCid)
    MoqFountainByteBufAppendText(buf, "|repair|")
    MoqFountainByteBufAppendText(buf, objectIndexText)
    MoqFountainByteBufAppendText(buf, "|")
    MoqFountainByteBufAppendText(buf, repairIndexText)
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainObjectIdText(objectIndex: int32): str =
    MoqFountainEmitLog("moq_object_id:enter")
    let objectIndexText = strings.IntToStr(objectIndex)
    MoqFountainEmitLog("moq_object_id:object_index_text")
    var buf = layout.ByteBufInit(len(objectIndexText) + 7)
    MoqFountainByteBufAppendText(buf, "object-")
    MoqFountainByteBufAppendText(buf, objectIndexText)
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainHexDigitCode(value: int32): int32 =
    if value < 10:
        return int32('0') + value
    return int32('a') + value - 10

fn MoqFountainHex4(value: int32): str =
    var out = bytesAlloc(4)
    bytesSet(out, 0, MoqFountainHexDigitCode((value >> 12) & 15))
    bytesSet(out, 1, MoqFountainHexDigitCode((value >> 8) & 15))
    bytesSet(out, 2, MoqFountainHexDigitCode((value >> 4) & 15))
    bytesSet(out, 3, MoqFountainHexDigitCode(value & 15))
    return bytesToString(out)

fn MoqFountainJsonQuote(text: str): str =
    MoqFountainEmitLog("moq_json_quote:start")
    let textBytes = bytesFromString(text)
    var outLen: int32 = 2
    var idx: int32
    for idx in idx..<len(text):
        let code = bytesGet(textBytes, idx) & 255
        if code == 34:
            outLen = outLen + 2
        elif code == 92:
            outLen = outLen + 2
        elif code == 8:
            outLen = outLen + 2
        elif code == 12:
            outLen = outLen + 2
        elif code == 10:
            outLen = outLen + 2
        elif code == 13:
            outLen = outLen + 2
        elif code == 9:
            outLen = outLen + 2
        elif code < 32:
            outLen = outLen + 6
        else:
            outLen = outLen + 1
    MoqFountainEmitLog("moq_json_quote:scan_done")
    var out = bytesAlloc(outLen)
    var pos: int32
    bytesSet(out, pos, 34)
    pos = pos + 1
    idx = 0
    for idx in idx..<len(text):
        let code = bytesGet(textBytes, idx) & 255
        if code == 34:
            bytesSet(out, pos, 92)
            pos = pos + 1
            bytesSet(out, pos, 34)
            pos = pos + 1
        elif code == 92:
            bytesSet(out, pos, 92)
            pos = pos + 1
            bytesSet(out, pos, 92)
            pos = pos + 1
        elif code == 8:
            bytesSet(out, pos, 92)
            pos = pos + 1
            bytesSet(out, pos, int32('b'))
            pos = pos + 1
        elif code == 12:
            bytesSet(out, pos, 92)
            pos = pos + 1
            bytesSet(out, pos, int32('f'))
            pos = pos + 1
        elif code == 10:
            bytesSet(out, pos, 92)
            pos = pos + 1
            bytesSet(out, pos, int32('n'))
            pos = pos + 1
        elif code == 13:
            bytesSet(out, pos, 92)
            pos = pos + 1
            bytesSet(out, pos, int32('r'))
            pos = pos + 1
        elif code == 9:
            bytesSet(out, pos, 92)
            pos = pos + 1
            bytesSet(out, pos, int32('t'))
            pos = pos + 1
        elif code < 32:
            bytesSet(out, pos, 92)
            pos = pos + 1
            bytesSet(out, pos, int32('u'))
            pos = pos + 1
            let hexText = MoqFountainHex4(code)
            bytesSet(out, pos, int32(hexText[0]) & 255)
            pos = pos + 1
            bytesSet(out, pos, int32(hexText[1]) & 255)
            pos = pos + 1
            bytesSet(out, pos, int32(hexText[2]) & 255)
            pos = pos + 1
            bytesSet(out, pos, int32(hexText[3]) & 255)
            pos = pos + 1
        else:
            bytesSet(out, pos, code)
            pos = pos + 1
    bytesSet(out, pos, 34)
    MoqFountainEmitLog("moq_json_quote:done")
    return bytesToString(out)

fn MoqFountainJoinIntJson(values: int32[]): str =
    MoqFountainEmitLog("moq_join_int_json:start")
    if values.len <= 0:
        MoqFountainEmitLog("moq_join_int_json:empty")
        return "[]"
    var buf = layout.ByteBufInit(MoqFountainMaxInt32(2, values.len * 12))
    MoqFountainByteBufAppendText(buf, "[")
    var i: int32
    for i in i..<values.len:
        if i > 0:
            MoqFountainByteBufAppendText(buf, ",")
        MoqFountainEmitLog("moq_join_int_json:item_begin")
        var itemText = ""
        itemText = strings.IntToStr(values[i])
        MoqFountainEmitLog("moq_join_int_json:item_done")
        MoqFountainByteBufAppendText(buf, itemText)
    MoqFountainByteBufAppendText(buf, "]")
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainContainsInt(values: int32[], want: int32): bool =
    var i: int32
    for i in i..<values.len:
        if values[i] == want:
            return true
    return false

fn MoqFountainSortInts(values0: int32[]): int32[] =
    var values = values0
    var i: int32
    for i in range(values.len):

        for j in i + 1..<values.len:
            if values[j] < values[i]:
                let tmp = values[i]
                values[i] = values[j]
                values[j] = tmp

    return values

fn MoqFountainHashSeed(text: str): int32 =
    let digestHex = MoqFountainSha256HexText(text)
    if len(digestHex) < 8:
        return 1
    let digestHexBytes = bytesFromString(digestHex)
    var out: int32
    var i: int32
    for i in i..<8:
        let nibble = MoqFountainHexValue(bytesGet(digestHexBytes, i))
        if nibble < 0:
            return 1
        out = (out << 4) | nibble
    if out == 0:
        return 1
    return out

fn MoqFountainDropletKindText(kindCode: int32): str =
    if kindCode == MoqFountainDropletKindSource:
        return "source"
    if kindCode == MoqFountainDropletKindRepair:
        return "repair"
    return "unknown"

fn MoqFountainDropletIndexTextOf(droplet: MoqFountainDroplet): str =
    var out = ""
    out = strings.IntToStr(droplet.dropletIndex)
    return out

fn MoqFountainDropletKeyOf(droplet: MoqFountainDroplet): str =
    return droplet.key

fn MoqFountainDropletPeerIdOf(droplet: MoqFountainDroplet): str =
    return droplet.peerId

fn MoqFountainDropletCidOf(droplet: MoqFountainDroplet): str =
    return droplet.cid

fn MoqFountainDropletBlockIndexesTextOf(droplet: MoqFountainDroplet): str =
    return MoqFountainJoinIntCsv(droplet.blockIndexes)

fn MoqFountainDropletJson(droplet: MoqFountainDroplet): str =
    MoqFountainEmitLog("moq_droplet_json:start")
    var objectIndexText = ""
    objectIndexText = strings.IntToStr(droplet.objectIndex)
    var dropletIndexText = ""
    dropletIndexText = strings.IntToStr(droplet.dropletIndex)
    var kindRaw = ""
    kindRaw = MoqFountainDropletKindText(droplet.kindCode)
    var kindText = ""
    kindText = MoqFountainJsonQuote(kindRaw)
    var keyText = ""
    keyText = MoqFountainJsonQuote(droplet.key)
    var peerIdText = ""
    peerIdText = MoqFountainJsonQuote(droplet.peerId)
    var cidText = ""
    cidText = MoqFountainJsonQuote(droplet.cid)
    var degreeText = ""
    degreeText = strings.IntToStr(droplet.degree)
    var blockIndexesText = ""
    blockIndexesText = MoqFountainJoinIntJson(droplet.blockIndexes)
    var buf = layout.ByteBufInit(256)
    MoqFountainByteBufAppendText(buf, "{")
    MoqFountainByteBufAppendText(buf, "\"objectIndex\":")
    MoqFountainByteBufAppendText(buf, objectIndexText)
    MoqFountainByteBufAppendText(buf, ",\"dropletIndex\":")
    MoqFountainByteBufAppendText(buf, dropletIndexText)
    MoqFountainByteBufAppendText(buf, ",\"kind\":")
    MoqFountainByteBufAppendText(buf, kindText)
    MoqFountainByteBufAppendText(buf, ",\"key\":")
    MoqFountainByteBufAppendText(buf, keyText)
    MoqFountainByteBufAppendText(buf, ",\"peerId\":")
    MoqFountainByteBufAppendText(buf, peerIdText)
    MoqFountainByteBufAppendText(buf, ",\"cid\":")
    MoqFountainByteBufAppendText(buf, cidText)
    MoqFountainByteBufAppendText(buf, ",\"degree\":")
    MoqFountainByteBufAppendText(buf, degreeText)
    MoqFountainByteBufAppendText(buf, ",\"blockIndexes\":")
    MoqFountainByteBufAppendText(buf, blockIndexesText)
    MoqFountainByteBufAppendText(buf, "}")
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainDropletsJson(droplets: MoqFountainDroplet[]): str =
    MoqFountainEmitLog("moq_droplets_json:start")
    var buf = layout.ByteBufInit(MoqFountainMaxInt32(2, droplets.len * 256))
    var idx: int32
    for idx in idx..<droplets.len:
        if idx > 0:
            MoqFountainByteBufAppendText(buf, ",")
        var dropletJson = ""
        MoqFountainEmitLog("moq_droplets_json:item_begin")
        dropletJson = MoqFountainDropletJson(droplets[idx])
        MoqFountainEmitLog("moq_droplets_json:item_done")
        MoqFountainByteBufAppendText(buf, dropletJson)
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainObjectJson(item: MoqFountainObject): str =
    MoqFountainEmitLog("moq_object_json:start")
    var objectIndexText = ""
    objectIndexText = strings.IntToStr(item.objectIndex)
    var groupIdText = ""
    groupIdText = MoqFountainJsonQuote(item.groupId)
    var objectIdText = ""
    objectIdText = MoqFountainJsonQuote(item.objectId)
    var priorityText = ""
    priorityText = strings.IntToStr(item.priority)
    var byteOffsetText = ""
    byteOffsetText = strings.IntToStr(item.byteOffset)
    var byteLengthText = ""
    byteLengthText = strings.IntToStr(item.byteLength)
    var objectCidText = ""
    objectCidText = MoqFountainJsonQuote(item.objectCid)
    var sourceBlockBytesText = ""
    sourceBlockBytesText = strings.IntToStr(item.sourceBlockBytes)
    var sourceBlockCountText = ""
    sourceBlockCountText = strings.IntToStr(item.sourceBlockCount)
    var repairDropletCountText = ""
    repairDropletCountText = strings.IntToStr(item.repairDropletCount)
    var dropletsText = ""
    MoqFountainEmitLog("moq_object_json:droplets_begin")
    dropletsText = MoqFountainDropletsJson(item.droplets)
    MoqFountainEmitLog("moq_object_json:droplets_done")
    var buf = layout.ByteBufInit(512)
    MoqFountainByteBufAppendText(buf, "{")
    MoqFountainByteBufAppendText(buf, "\"objectIndex\":")
    MoqFountainByteBufAppendText(buf, objectIndexText)
    MoqFountainByteBufAppendText(buf, ",\"groupId\":")
    MoqFountainByteBufAppendText(buf, groupIdText)
    MoqFountainByteBufAppendText(buf, ",\"objectId\":")
    MoqFountainByteBufAppendText(buf, objectIdText)
    MoqFountainByteBufAppendText(buf, ",\"priority\":")
    MoqFountainByteBufAppendText(buf, priorityText)
    MoqFountainByteBufAppendText(buf, ",\"byteOffset\":")
    MoqFountainByteBufAppendText(buf, byteOffsetText)
    MoqFountainByteBufAppendText(buf, ",\"byteLength\":")
    MoqFountainByteBufAppendText(buf, byteLengthText)
    MoqFountainByteBufAppendText(buf, ",\"objectCid\":")
    MoqFountainByteBufAppendText(buf, objectCidText)
    MoqFountainByteBufAppendText(buf, ",\"sourceBlockBytes\":")
    MoqFountainByteBufAppendText(buf, sourceBlockBytesText)
    MoqFountainByteBufAppendText(buf, ",\"sourceBlockCount\":")
    MoqFountainByteBufAppendText(buf, sourceBlockCountText)
    MoqFountainByteBufAppendText(buf, ",\"repairDropletCount\":")
    MoqFountainByteBufAppendText(buf, repairDropletCountText)
    MoqFountainByteBufAppendText(buf, ",\"droplets\":[")
    MoqFountainByteBufAppendText(buf, dropletsText)
    MoqFountainByteBufAppendText(buf, "]}")
    return bytesToString(MoqFountainByteBufBytes(buf))

fn MoqFountainParseInt32Text(text: str): int32 =
    if strings.Len(text) <= 0:
        return 0
    let textBytes = bytesFromString(text)
    var i: int32
    var sign: int32 = 1
    let first = bytesGet(textBytes, 0)
    if first == 43:
        i = 1
    elif first == 45:
        sign = -1
        i = 1
    var value: int32
    var hadDigit = false
    let n = strings.Len(text)
    for i in i..<n:
        let ch = bytesGet(textBytes, i)
        if ch < 48 || ch > 57:
            break
        hadDigit = true
        value = value * 10 + (ch - 48)
    if !hadDigit:
        return 0
    return sign * value

fn MoqFountainParseInt32Wire(requestWire: str, key: str): Result[int32] =
    let rawRes = MoqFountainWireFindValue(requestWire, key)
    if IsErr(rawRes):
        let errorText = Error(rawRes)
        return Err[int32](errorText)
    let rawValue = Value(rawRes)
    let parsed = MoqFountainParseInt32Text(rawValue)
    return Ok[int32](parsed)

fn MoqFountainAppendDroplets(out: var MoqFountainDroplet[],
                             droplets: MoqFountainDroplet[]) =
    var idx: int32
    for idx in idx..<droplets.len:
        add(out, droplets[idx])

fn MoqFountainNextSeed(state0: int32): int32 =
    var state = state0
    if state == 0:
        state = 1
    state = state ^ (state << 13)
    state = state ^ (state >> 17)
    state = state ^ (state << 5)
    if state == 0:
        return 1
    return state

fn MoqFountainPositiveMod(value: int32, modBy: int32): int32 =
    if modBy <= 0:
        return 0
    let normalized = value & 2147483647
    return normalized % modBy

fn MoqFountainChooseUniqueBlockIndexesInto(out: var int32[],
                                           blockCount: int32,
                                           degree0: int32,
                                           seedText: str) =
    out = []
    if blockCount <= 0:
        return
    let degree = MoqFountainMinInt32(blockCount, MoqFountainMaxInt32(1, degree0))
    var candidates: int32[]
    candidates = []
    var fillIndex: int32
    for fillIndex in fillIndex..<blockCount:
        add(candidates, fillIndex)
    var seed = MoqFountainHashSeed(seedText)
    var remaining = blockCount
    while out.len < degree && remaining > 0:
        seed = MoqFountainNextSeed(seed)
        let slot = MoqFountainPositiveMod(seed, remaining)
        add(out, candidates[slot])
        candidates[slot] = candidates[remaining - 1]
        remaining = remaining - 1

fn MoqFountainPadBlock(data: Bytes, blockBytes: int32): Bytes =
    if bytesLen(data) == blockBytes:
        return bytesSlice(data, 0, bytesLen(data))
    var out = bytesAlloc(blockBytes)
    let copyLen = MoqFountainMinInt32(bytesLen(data), blockBytes)
    var i: int32
    for i in i..<copyLen:
        bytesSet(out, i, bytesGet(data, i))
    return out

fn MoqFountainXorInto(target: var Bytes, source: Bytes): Result[bool] =
    if bytesLen(target) != bytesLen(source):
        return Err[bool]("moq_fountain_xor_length_mismatch")
    var i: int32
    let n = bytesLen(target)
    for i in i..<n:
        bytesSet(target, i, bytesGet(target, i) ^ bytesGet(source, i))
    return Ok[bool](true)

fn MoqFountainXorBytes(left: Bytes, right: Bytes): Result[Bytes] =
    if bytesLen(left) != bytesLen(right):
        return Err[Bytes]("moq_fountain_xor_length_mismatch")
    var out = bytesAlloc(bytesLen(left))
    var i: int32
    let n = bytesLen(left)
    for i in i..<n:
        bytesSet(out, i, bytesGet(left, i) ^ bytesGet(right, i))
    return Ok[Bytes](out)

fn MoqFountainBuildObject(objectBytes: Bytes,
                          objectIndex: int32,
                          byteOffset: int32,
                          peers: str[],
                          bundleCid: str,
                          sourceBlockBytes: int32,
                          repairDropletCount: int32): Result[MoqFountainObject] =
    let objectByteLen = bytesLen(objectBytes)
    MoqFountainEmitLog("moq_build_object:start")
    let objectCid = MoqFountainSha256HexBytes(objectBytes)
    MoqFountainEmitLog("moq_build_object:object_cid")
    let sourceBlockCount = (objectByteLen + sourceBlockBytes - 1) / sourceBlockBytes
    MoqFountainEmitLog("moq_build_object:source_block_count")
    var blocks: Bytes[]
    blocks = []
    var blockIndex: int32
    for blockIndex in blockIndex..<sourceBlockCount:
        let blockOffset = blockIndex * sourceBlockBytes
        let blockLen = MoqFountainMinInt32(sourceBlockBytes, objectByteLen - blockOffset)
        let blockBytes = MoqFountainCopyBytesRange(objectBytes, blockOffset, blockLen)
        add(blocks, MoqFountainPadBlock(blockBytes, sourceBlockBytes))
    MoqFountainEmitLog("moq_build_object:blocks_ready")
    var objectDroplets: MoqFountainDroplet[]
    objectDroplets = []
    var sourceDropletIndex: int32
    for sourceDropletIndex in range(blocks.len):

        MoqFountainEmitLog("moq_build_object:source_loop_enter")
        let payload = blocks[sourceDropletIndex]
        MoqFountainEmitLog("moq_build_object:source_payload_ready")
        var indexes: int32[]
        indexes = []
        add(indexes, sourceDropletIndex)
        MoqFountainEmitLog("moq_build_object:source_indexes_ready")
        let peerSlot = (objectIndex + sourceDropletIndex) % peers.len
        var peerId = ""
        var peerIdx: int32
        for peerIdx in peerIdx..<peers.len:
            if peerIdx == peerSlot:
                peerId = peers[peerIdx]
                break
        MoqFountainEmitLog("moq_build_object:source_peer_ready")
        MoqFountainEmitLog("moq_build_object:source_key_begin")
        let key = MoqFountainSourceDropletKey(bundleCid, objectIndex, sourceDropletIndex)
        MoqFountainEmitLog("moq_build_object:source_key_done")
        MoqFountainEmitLog("moq_build_object:source_cid_begin")
        let cid = MoqFountainSha256HexBytes(payload)
        MoqFountainEmitLog("moq_build_object:source_cid_done")
        let droplet = MoqFountainDroplet(
            objectIndex: objectIndex,
            dropletIndex: sourceDropletIndex,
            kindCode: MoqFountainDropletKindSource,
            key: key,
            peerId: peerId,
            cid: cid,
            degree: 1,
            blockIndexes: indexes,
            payload: payload
        )
        MoqFountainEmitLog("moq_build_object:source_droplet_ready")
        add(objectDroplets, droplet)
        MoqFountainEmitLog("moq_build_object:source_droplet_added")

    MoqFountainEmitLog("moq_build_object:source_droplets_ready")
    var repairIndex: int32
    for repairIndex in range(repairDropletCount):

        MoqFountainEmitLog("moq_build_object:repair_loop_enter")
        var degreeBase: int32 = 1
        if sourceBlockCount > 1:
            MoqFountainEmitLog("moq_build_object:repair_degree_seed_begin")
            let seedText = MoqFountainRepairDegreeSeed(bundleCid, objectIndex, repairIndex)
            MoqFountainEmitLog("moq_build_object:repair_degree_seed_done")
            degreeBase = 2 + MoqFountainPositiveMod(MoqFountainHashSeed(seedText), sourceBlockCount - 1)
            MoqFountainEmitLog("moq_build_object:repair_degree_ready")
        MoqFountainEmitLog("moq_build_object:repair_seed_begin")
        let repairSeed = MoqFountainRepairSeed(bundleCid, objectIndex, repairIndex)
        MoqFountainEmitLog("moq_build_object:repair_seed_done")
        MoqFountainEmitLog("moq_build_object:repair_indexes_begin")
        var blockIndexes: int32[]
        blockIndexes = []
        MoqFountainChooseUniqueBlockIndexesInto(blockIndexes,
                                                sourceBlockCount,
                                                degreeBase,
                                                repairSeed)
        MoqFountainEmitLog("moq_build_object:repair_indexes_done")
        if blockIndexes.len <= 0:
            return Err[MoqFountainObject]("moq_fountain_empty_repair_block_set")
        let firstBlockIndex = blockIndexes[0]
        if firstBlockIndex < 0 || firstBlockIndex >= blocks.len:
            return Err[MoqFountainObject]("moq_fountain_block_index_out_of_range")
        MoqFountainEmitLog("moq_build_object:repair_payload_begin")
        var payload = MoqFountainCopyBytesRange(blocks[firstBlockIndex], 0, bytesLen(blocks[firstBlockIndex]))
        MoqFountainEmitLog("moq_build_object:repair_payload_ready")
        for blockPick in 1..<blockIndexes.len:
            let wantedIndex = blockIndexes[blockPick]
            if wantedIndex < 0 || wantedIndex >= blocks.len:
                return Err[MoqFountainObject]("moq_fountain_block_index_out_of_range")
            MoqFountainEmitLog("moq_build_object:repair_xor_begin")
            let xorOk = MoqFountainXorInto(payload, blocks[wantedIndex])
            if IsErr(xorOk):
                return Err[MoqFountainObject](Error(xorOk))
            MoqFountainEmitLog("moq_build_object:repair_xor_done")
        let dropletIndex = sourceBlockCount + repairIndex
        let peerSlot = (objectIndex + dropletIndex) % peers.len
        var peerId = ""
        var peerIdx: int32
        for peerIdx in peerIdx..<peers.len:
            if peerIdx == peerSlot:
                peerId = peers[peerIdx]
                break
        MoqFountainEmitLog("moq_build_object:repair_key_begin")
        let key = MoqFountainRepairDropletKey(bundleCid, objectIndex, repairIndex)
        MoqFountainEmitLog("moq_build_object:repair_key_done")
        MoqFountainEmitLog("moq_build_object:repair_cid_begin")
        let droplet = MoqFountainDroplet(
            objectIndex: objectIndex,
            dropletIndex: dropletIndex,
            kindCode: MoqFountainDropletKindRepair,
            key: key,
            peerId: peerId,
            cid: MoqFountainSha256HexBytes(payload),
            degree: blockIndexes.len,
            blockIndexes: blockIndexes,
            payload: payload
        )
        MoqFountainEmitLog("moq_build_object:repair_cid_done")
        add(objectDroplets, droplet)
        MoqFountainEmitLog("moq_build_object:repair_droplet_added")

    MoqFountainEmitLog("moq_build_object:repair_ready")
    MoqFountainEmitLog("moq_build_object:object_id_begin")
    let objectIdText = MoqFountainObjectIdText(objectIndex)
    MoqFountainEmitLog("moq_build_object:object_id_done")
    MoqFountainEmitLog("moq_build_object:object_out_begin")
    let objectOut = MoqFountainObject(
        objectIndex: objectIndex,
        groupId: bundleCid,
        objectId: objectIdText,
        priority: objectIndex,
        byteOffset: byteOffset,
        byteLength: objectByteLen,
        objectCid: objectCid,
        sourceBlockBytes: sourceBlockBytes,
        sourceBlockCount: sourceBlockCount,
        repairDropletCount: repairDropletCount,
        droplets: objectDroplets
    )
    MoqFountainEmitLog("moq_build_object:object_out_done")
    MoqFountainEmitLog("moq_build_object:done")
    return Ok[MoqFountainObject](objectOut)

fn MoqFountainBuildResultFillFromParts(out: var MoqFountainBuildResult,
                                       ownerPeerId: str,
                                       mimeType: str,
                                       bundleCid: str,
                                       blobCid: str,
                                       blobByteLen: int32,
                                       objectTargetBytes: int32,
                                       sourceBlockBytes: int32,
                                       remoteAckPeerIds: str[],
                                       objects: MoqFountainObject[],
                                       droplets: MoqFountainDroplet[]): Result[bool] =
    MoqFountainEmitLog("moq_build_fill:start")
    let catalogPayload = MoqFountainCatalogBytes(ownerPeerId,
                                                 mimeType,
                                                 blobCid,
                                                 blobByteLen,
                                                 bundleCid,
                                                 objectTargetBytes,
                                                 sourceBlockBytes,
                                                 objects)
    MoqFountainEmitLog("moq_build_fill:catalog_ready")
    if bytesLen(catalogPayload) <= 0:
        return Err[bool]("moq_fountain_empty_catalog_payload")
    var rebuildRows: str[]
    rebuildRows = []
    let blobByteLenText = strings.IntToStr(blobByteLen)
    let objectCountText = strings.IntToStr(objects.len)
    let dropletCountText = strings.IntToStr(droplets.len)
    let blobCidLine = MoqFountainFmt2("blob_cid=", blobCid)
    let blobByteLenLine = MoqFountainFmt2("blob_byte_len=", blobByteLenText)
    let objectCountLine = MoqFountainFmt2("object_count=", objectCountText)
    let dropletCountLine = MoqFountainFmt2("droplet_count=", dropletCountText)
    add(rebuildRows, blobCidLine)
    add(rebuildRows, blobByteLenLine)
    add(rebuildRows, objectCountLine)
    add(rebuildRows, dropletCountLine)
    var rebuildObjectRow: int32
    for rebuildObjectRow in rebuildObjectRow..<objects.len:
        MoqFountainEmitLog("moq_build_fill:object_row_begin")
        let item = objects[rebuildObjectRow]
        let objectRowText = strings.IntToStr(rebuildObjectRow)
        let objectIndexText = strings.IntToStr(item.objectIndex)
        let objectByteLengthText = strings.IntToStr(item.byteLength)
        let objectSourceBlockBytesText = strings.IntToStr(item.sourceBlockBytes)
        let objectSourceBlockCountText = strings.IntToStr(item.sourceBlockCount)
        let prefix = MoqFountainFmt3("object.", objectRowText, ".")
        MoqFountainEmitLog("moq_build_fill:object_row_prefix_ready")
        let objectIndexLine = MoqFountainFmt3(prefix, "object_index=", objectIndexText)
        MoqFountainEmitLog("moq_build_fill:object_row_index_ready")
        let objectByteLengthLine = MoqFountainFmt3(prefix, "byte_length=", objectByteLengthText)
        MoqFountainEmitLog("moq_build_fill:object_row_byte_length_ready")
        let objectSourceBlockBytesLine = MoqFountainFmt3(prefix, "source_block_bytes=", objectSourceBlockBytesText)
        MoqFountainEmitLog("moq_build_fill:object_row_block_bytes_ready")
        let objectSourceBlockCountLine = MoqFountainFmt3(prefix, "source_block_count=", objectSourceBlockCountText)
        MoqFountainEmitLog("moq_build_fill:object_row_block_count_ready")
        let objectCidKey = MoqFountainPrefixKey(prefix, "object_cid=")
        MoqFountainEmitLog("moq_build_fill:object_row_cid_key_ready")
        let objectCidLine = MoqFountainFmt2(objectCidKey, item.objectCid)
        MoqFountainEmitLog("moq_build_fill:object_row_cid_ready")
        add(rebuildRows, objectIndexLine)
        add(rebuildRows, objectByteLengthLine)
        add(rebuildRows, objectSourceBlockBytesLine)
        add(rebuildRows, objectSourceBlockCountLine)
        add(rebuildRows, objectCidLine)
        MoqFountainEmitLog("moq_build_fill:object_row_done")
    var rebuildDropletRow: int32
    for rebuildDropletRow in rebuildDropletRow..<droplets.len:
        MoqFountainEmitLog("moq_build_fill:droplet_row_begin")
        let item = droplets[rebuildDropletRow]
        var dropletRowText = ""
        dropletRowText = strings.IntToStr(rebuildDropletRow)
        var dropletObjectIndexText = ""
        dropletObjectIndexText = strings.IntToStr(item.objectIndex)
        var dropletIndexText = ""
        dropletIndexText = MoqFountainDropletIndexTextOf(item)
        var prefix = ""
        prefix = MoqFountainFmt3("droplet.", dropletRowText, ".")
        MoqFountainEmitLog("moq_build_fill:droplet_row_prefix_ready")
        var dropletObjectIndexLine = ""
        dropletObjectIndexLine = MoqFountainFmt3(prefix, "object_index=", dropletObjectIndexText)
        MoqFountainEmitLog("moq_build_fill:droplet_row_object_index_ready")
        var dropletIndexLine = ""
        dropletIndexLine = MoqFountainFmt3(prefix, "droplet_index=", dropletIndexText)
        MoqFountainEmitLog("moq_build_fill:droplet_row_droplet_index_ready")
        var dropletKeyKey = ""
        dropletKeyKey = MoqFountainPrefixKey(prefix, "key=")
        MoqFountainEmitLog("moq_build_fill:droplet_row_key_key_ready")
        var dropletKeyLine = ""
        dropletKeyLine = MoqFountainFmt2(dropletKeyKey, MoqFountainDropletKeyOf(item))
        MoqFountainEmitLog("moq_build_fill:droplet_row_key_ready")
        var dropletPeerIdKey = ""
        dropletPeerIdKey = MoqFountainPrefixKey(prefix, "peer_id=")
        MoqFountainEmitLog("moq_build_fill:droplet_row_peer_key_ready")
        var dropletPeerIdLine = ""
        dropletPeerIdLine = MoqFountainFmt2(dropletPeerIdKey, MoqFountainDropletPeerIdOf(item))
        MoqFountainEmitLog("moq_build_fill:droplet_row_peer_ready")
        var dropletCidKey = ""
        dropletCidKey = MoqFountainPrefixKey(prefix, "cid=")
        MoqFountainEmitLog("moq_build_fill:droplet_row_cid_key_ready")
        var dropletCidLine = ""
        dropletCidLine = MoqFountainFmt2(dropletCidKey, MoqFountainDropletCidOf(item))
        MoqFountainEmitLog("moq_build_fill:droplet_row_cid_ready")
        var dropletBlockIndexesText = ""
        dropletBlockIndexesText = MoqFountainDropletBlockIndexesTextOf(item)
        MoqFountainEmitLog("moq_build_fill:droplet_row_block_indexes_text_ready")
        var dropletBlockIndexesKey = ""
        dropletBlockIndexesKey = MoqFountainPrefixKey(prefix, "block_indexes=")
        MoqFountainEmitLog("moq_build_fill:droplet_row_block_indexes_key_ready")
        var dropletBlockIndexesLine = ""
        dropletBlockIndexesLine = MoqFountainFmt2(dropletBlockIndexesKey, dropletBlockIndexesText)
        MoqFountainEmitLog("moq_build_fill:droplet_row_block_indexes_ready")
        add(rebuildRows, dropletObjectIndexLine)
        add(rebuildRows, dropletIndexLine)
        add(rebuildRows, dropletKeyLine)
        add(rebuildRows, dropletPeerIdLine)
        add(rebuildRows, dropletCidLine)
        add(rebuildRows, dropletBlockIndexesLine)
        MoqFountainEmitLog("moq_build_fill:droplet_row_done")
    let rebuildTemplatePayload = bytesFromString(MoqFountainLinesWithNewline(rebuildRows))
    MoqFountainEmitLog("moq_build_fill:rebuild_template_ready")
    if bytesLen(rebuildTemplatePayload) <= 0:
        return Err[bool]("moq_fountain_empty_rebuild_template")
    out.ownerPeerId = ownerPeerId
    out.mimeType = mimeType
    out.bundleCid = bundleCid
    out.blobCid = blobCid
    out.catalogKey = MoqFountainFmt2("moqcatalog-", bundleCid)
    out.catalogCid = MoqFountainSha256HexBytes(catalogPayload)
    out.catalogSizeBytes = bytesLen(catalogPayload)
    out.catalogPayload = catalogPayload
    out.rebuildTemplateKey = MoqFountainFmt2("moqrebuild-", bundleCid)
    out.rebuildTemplateCid = MoqFountainSha256HexBytes(rebuildTemplatePayload)
    out.rebuildTemplateSizeBytes = bytesLen(rebuildTemplatePayload)
    out.rebuildTemplatePayload = rebuildTemplatePayload
    out.blobByteLen = blobByteLen
    out.objectTargetBytes = objectTargetBytes
    out.sourceBlockBytes = sourceBlockBytes
    out.objectCount = objects.len
    out.remoteAckPeerIds = remoteAckPeerIds
    out.objects = objects
    out.droplets = droplets
    MoqFountainEmitLog("moq_build_fill:done")
    return Ok[bool](true)

fn MoqFountainBuild(blobBytes: Bytes,
                    ownerPeerId: str,
                    remotePeersCsv: str,
                    mimeType0: str,
                    objectTargetBytes0: int32,
                    sourceBlockBytes0: int32,
                    repairDropletCount0: int32): Result[MoqFountainBuildResult] =
    MoqFountainEmitLog("moq_build:enter")
    if bytesLen(blobBytes) <= 0:
        return Err[MoqFountainBuildResult]("moq_fountain_empty_blob")
    let peers = MoqFountainNormalizePeerCsv(remotePeersCsv)
    MoqFountainEmitLog("moq_build:peers_ready")
    if peers.len <= 0:
        return Err[MoqFountainBuildResult]("video_publish_insufficient_storage_peers")
    let objectTargetBytes = MoqFountainNormalizePositiveInt(objectTargetBytes0, 512 * 1024)
    let sourceBlockBytes = MoqFountainNormalizePositiveInt(sourceBlockBytes0, 128 * 1024)
    let repairDropletCount = MoqFountainNormalizePositiveInt(repairDropletCount0, 2)
    let mimeType = if len(mimeType0) > 0: mimeType0 else: "video/mp4"
    MoqFountainEmitLog("moq_build:params_ready")
    MoqFountainEmitLog("moq_build:blob_cid_begin")
    let blobCid = MoqFountainSha256HexBytes(blobBytes)
    MoqFountainEmitLog("moq_build:blob_cid_done")
    MoqFountainEmitLog("moq_build:bundle_seed_begin")
    let bundleSeed = MoqFountainBuildBundleSeed(ownerPeerId,
                                                blobCid,
                                                mimeType,
                                                peers,
                                                objectTargetBytes,
                                                sourceBlockBytes,
                                                repairDropletCount)
    MoqFountainEmitLog("moq_build:bundle_seed_done")
    if len(bundleSeed) <= 0:
        return Err[MoqFountainBuildResult]("moq_fountain_empty_bundle_seed")
    MoqFountainEmitLog("moq_build:bundle_cid_begin")
    let bundleCid = MoqFountainSha256HexText(bundleSeed)
    MoqFountainEmitLog("moq_build:bundle_cid_done")
    if len(bundleCid) <= 0:
        return Err[MoqFountainBuildResult]("moq_fountain_empty_bundle_cid")
    var objects: MoqFountainObject[]
    objects = []
    var allDroplets: MoqFountainDroplet[]
    allDroplets = []
    var byteOffset: int32
    var objectIndex: int32
    MoqFountainEmitLog("moq_build:object_loop_begin")
    while byteOffset < bytesLen(blobBytes):
        let objectByteLen = MoqFountainMinInt32(objectTargetBytes, bytesLen(blobBytes) - byteOffset)
        MoqFountainEmitLog("moq_build:object_begin")
        let objectBytes = MoqFountainCopyBytesRange(blobBytes, byteOffset, objectByteLen)
        let objectRes = MoqFountainBuildObject(objectBytes,
                                               objectIndex,
                                               byteOffset,
                                               peers,
                                               bundleCid,
                                               sourceBlockBytes,
                                               repairDropletCount)
        if IsErr(objectRes):
            MoqFountainEmitLog("moq_build:object_error")
            return Err[MoqFountainBuildResult](Error(objectRes))
        let objectOut = Value(objectRes)
        add(objects, objectOut)
        MoqFountainAppendDroplets(allDroplets, objectOut.droplets)
        MoqFountainEmitLog("moq_build:object_done")
        byteOffset = byteOffset + objectByteLen
        objectIndex = objectIndex + 1
    var out: MoqFountainBuildResult
    MoqFountainEmitLog("moq_build:fill_begin")
    let fillOk = MoqFountainBuildResultFillFromParts(out,
                                                     ownerPeerId,
                                                     mimeType,
                                                     bundleCid,
                                                     blobCid,
                                                     bytesLen(blobBytes),
                                                     objectTargetBytes,
                                                     sourceBlockBytes,
                                                     peers,
                                                     objects,
                                                     allDroplets)
    if IsErr(fillOk):
        return Err[MoqFountainBuildResult](Error(fillOk))
    MoqFountainEmitLog("moq_build:fill_done")
    return Ok[MoqFountainBuildResult](out)

fn MoqFountainAppendWireLine(out: var str, line: str) =
    let lineText = MoqFountainFmt2(line, "\n")
    out = MoqFountainFmt2(out, lineText)

fn MoqFountainRebuildTemplateWireFromParts(blobCid: str,
                                            blobByteLen: int32,
                                            objects: MoqFountainObject[],
                                            droplets: MoqFountainDroplet[]): str =
    var rows: str[]
    rows = []
    add(rows, MoqFountainFmt2("blob_cid=", blobCid))
    add(rows, MoqFountainFmt2("blob_byte_len=", strings.IntToStr(blobByteLen)))
    add(rows, MoqFountainFmt2("object_count=", strings.IntToStr(objects.len)))
    add(rows, MoqFountainFmt2("droplet_count=", strings.IntToStr(droplets.len)))
    var objectRow: int32
    for objectRow in objectRow..<objects.len:
        let item = objects[objectRow]
        let objectRowText = strings.IntToStr(objectRow)
        let prefix = MoqFountainFmt3("object.", objectRowText, ".")
        let objectIndexText = strings.IntToStr(item.objectIndex)
        let objectByteLengthText = strings.IntToStr(item.byteLength)
        let objectSourceBlockBytesText = strings.IntToStr(item.sourceBlockBytes)
        let objectSourceBlockCountText = strings.IntToStr(item.sourceBlockCount)
        add(rows, MoqFountainFmt3(prefix, "object_index=", objectIndexText))
        add(rows, MoqFountainFmt3(prefix, "byte_length=", objectByteLengthText))
        add(rows, MoqFountainFmt3(prefix, "source_block_bytes=", objectSourceBlockBytesText))
        add(rows, MoqFountainFmt3(prefix, "source_block_count=", objectSourceBlockCountText))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "object_cid="), item.objectCid))
    var dropletRow: int32
    for dropletRow in dropletRow..<droplets.len:
        let item = droplets[dropletRow]
        let dropletRowText = strings.IntToStr(dropletRow)
        let prefix = MoqFountainFmt3("droplet.", dropletRowText, ".")
        let dropletObjectIndexText = strings.IntToStr(item.objectIndex)
        let dropletIndexText = MoqFountainDropletIndexTextOf(item)
        let dropletKey = MoqFountainDropletKeyOf(item)
        let dropletPeerId = MoqFountainDropletPeerIdOf(item)
        let dropletCid = MoqFountainDropletCidOf(item)
        let blockIndexesText = MoqFountainDropletBlockIndexesTextOf(item)
        add(rows, MoqFountainFmt3(prefix, "object_index=", dropletObjectIndexText))
        add(rows, MoqFountainFmt3(prefix, "droplet_index=", dropletIndexText))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "key="), dropletKey))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "peer_id="), dropletPeerId))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "cid="), dropletCid))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "block_indexes="), blockIndexesText))
    return MoqFountainLinesWithNewline(rows)

fn MoqFountainBuildWireFromParts(ownerPeerId: str,
                                 mimeType: str,
                                 bundleCid: str,
                                 blobCid: str,
                                 blobByteLen: int32,
                                 objectTargetBytes: int32,
                                 sourceBlockBytes: int32,
                                 remoteAckPeerIds: str[],
                                 objects: MoqFountainObject[],
                                 droplets: MoqFountainDroplet[]): str =
    let catalogPayload = MoqFountainCatalogBytes(ownerPeerId,
                                                 mimeType,
                                                 blobCid,
                                                 blobByteLen,
                                                 bundleCid,
                                                 objectTargetBytes,
                                                 sourceBlockBytes,
                                                 objects)
    let catalogCid = MoqFountainSha256HexBytes(catalogPayload)
    let rebuildTemplateText = MoqFountainRebuildTemplateWireFromParts(blobCid,
                                                                      blobByteLen,
                                                                      objects,
                                                                      droplets)
    let rebuildTemplatePayload = bytesFromString(rebuildTemplateText)
    let rebuildTemplateCid = MoqFountainSha256HexBytes(rebuildTemplatePayload)
    var rows: str[]
    rows = []
    add(rows, "ok=1")
    add(rows, MoqFountainFmt2("owner_peer_id=", ownerPeerId))
    add(rows, MoqFountainFmt2("mime_type=", mimeType))
    add(rows, MoqFountainFmt2("bundle_cid=", bundleCid))
    add(rows, MoqFountainFmt2("blob_cid=", blobCid))
    let catalogKey = MoqFountainFmt2("moqcatalog-", bundleCid)
    add(rows, MoqFountainFmt2("catalog_key=", catalogKey))
    add(rows, MoqFountainFmt2("catalog_cid=", catalogCid))
    add(rows, MoqFountainFmt2("catalog_size_bytes=", strings.IntToStr(bytesLen(catalogPayload))))
    add(rows, MoqFountainFmt2("catalog_payload_hex=", bytesToHex(catalogPayload)))
    let rebuildTemplateKey = MoqFountainFmt2("moqrebuild-", bundleCid)
    add(rows, MoqFountainFmt2("rebuild_template_key=", rebuildTemplateKey))
    add(rows, MoqFountainFmt2("rebuild_template_cid=", rebuildTemplateCid))
    add(rows, MoqFountainFmt2("rebuild_template_size_bytes=", strings.IntToStr(bytesLen(rebuildTemplatePayload))))
    add(rows, MoqFountainFmt2("rebuild_template_payload_hex=", bytesToHex(rebuildTemplatePayload)))
    add(rows, MoqFountainFmt2("blob_byte_len=", strings.IntToStr(blobByteLen)))
    add(rows, MoqFountainFmt2("object_target_bytes=", strings.IntToStr(objectTargetBytes)))
    add(rows, MoqFountainFmt2("source_block_bytes=", strings.IntToStr(sourceBlockBytes)))
    add(rows, MoqFountainFmt2("object_count=", strings.IntToStr(objects.len)))
    let remoteAckCsv = MoqFountainJoinCsv(remoteAckPeerIds)
    add(rows, MoqFountainFmt2("remote_ack_peer_ids=", remoteAckCsv))
    var objectRow: int32
    for objectRow in objectRow..<objects.len:
        let item = objects[objectRow]
        let objectRowText = strings.IntToStr(objectRow)
        let prefix = MoqFountainFmt3("object.", objectRowText, ".")
        let objectIndexText = strings.IntToStr(item.objectIndex)
        let objectPriorityText = strings.IntToStr(item.priority)
        let objectByteOffsetText = strings.IntToStr(item.byteOffset)
        let objectByteLengthText = strings.IntToStr(item.byteLength)
        let objectSourceBlockBytesText = strings.IntToStr(item.sourceBlockBytes)
        let objectSourceBlockCountText = strings.IntToStr(item.sourceBlockCount)
        let objectRepairDropletCountText = strings.IntToStr(item.repairDropletCount)
        add(rows, MoqFountainFmt3(prefix, "object_index=", objectIndexText))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "group_id="), item.groupId))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "object_id="), item.objectId))
        add(rows, MoqFountainFmt3(prefix, "priority=", objectPriorityText))
        add(rows, MoqFountainFmt3(prefix, "byte_offset=", objectByteOffsetText))
        add(rows, MoqFountainFmt3(prefix, "byte_length=", objectByteLengthText))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "object_cid="), item.objectCid))
        add(rows, MoqFountainFmt3(prefix, "source_block_bytes=", objectSourceBlockBytesText))
        add(rows, MoqFountainFmt3(prefix, "source_block_count=", objectSourceBlockCountText))
        add(rows, MoqFountainFmt3(prefix, "repair_droplet_count=", objectRepairDropletCountText))
    add(rows, MoqFountainFmt2("droplet_count=", strings.IntToStr(droplets.len)))
    var dropletRow: int32
    for dropletRow in dropletRow..<droplets.len:
        let droplet = droplets[dropletRow]
        let dropletRowText = strings.IntToStr(dropletRow)
        let prefix = MoqFountainFmt3("droplet.", dropletRowText, ".")
        let dropletObjectIndexText = strings.IntToStr(droplet.objectIndex)
        let dropletIndexText = MoqFountainDropletIndexTextOf(droplet)
        let dropletDegreeText = strings.IntToStr(droplet.degree)
        let dropletKindText = MoqFountainDropletKindText(droplet.kindCode)
        let dropletBlockIndexesText = MoqFountainDropletBlockIndexesTextOf(droplet)
        let dropletPayloadHex = bytesToHex(droplet.payload)
        add(rows, MoqFountainFmt3(prefix, "object_index=", dropletObjectIndexText))
        add(rows, MoqFountainFmt3(prefix, "droplet_index=", dropletIndexText))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "kind="), dropletKindText))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "key="), MoqFountainDropletKeyOf(droplet)))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "peer_id="), MoqFountainDropletPeerIdOf(droplet)))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "cid="), MoqFountainDropletCidOf(droplet)))
        add(rows, MoqFountainFmt3(prefix, "degree=", dropletDegreeText))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "block_indexes="), dropletBlockIndexesText))
        add(rows, MoqFountainFmt2(MoqFountainPrefixKey(prefix, "payload_hex="), dropletPayloadHex))
    return MoqFountainLinesWithNewline(rows)

fn MoqFountainBuildResultToWire(result: MoqFountainBuildResult): str =
    return MoqFountainBuildWireFromParts(result.ownerPeerId,
                                         result.mimeType,
                                         result.bundleCid,
                                         result.blobCid,
                                         result.blobByteLen,
                                         result.objectTargetBytes,
                                         result.sourceBlockBytes,
                                         result.remoteAckPeerIds,
                                         result.objects,
                                         result.droplets)

fn MoqFountainBuildToWire(blobBytes: Bytes,
                          ownerPeerId: str,
                          remotePeersCsv: str,
                          mimeType0: str,
                          objectTargetBytes0: int32,
                          sourceBlockBytes0: int32,
                          repairDropletCount0: int32): str =
    let buildRes = MoqFountainBuild(blobBytes,
                                    ownerPeerId,
                                    remotePeersCsv,
                                    mimeType0,
                                    objectTargetBytes0,
                                    sourceBlockBytes0,
                                    repairDropletCount0)
    if IsErr(buildRes):
        return MoqFountainErrorWire(Error(buildRes))
    return MoqFountainBuildResultToWire(Value(buildRes))

fn MoqFountainWireFindValue(wire: str, key: str): Result[str] =
    var lineStart: int32
    let n = strings.Len(wire)
    let keyLen = strings.Len(key)
    let wireBytes = bytesFromString(wire)
    let keyBytes = bytesFromString(key)
    while lineStart < n:
        var lineEnd: int32 = lineStart
        var eqPos: int32 = -1
        for lineEnd in range(n):

            if bytesGet(wireBytes, lineEnd) == 61 && eqPos < 0:
                eqPos = lineEnd
            if bytesGet(wireBytes, lineEnd) == 10:
                break

        if eqPos >= lineStart && (eqPos - lineStart) == keyLen:
            var matched = true
            var keyIdx: int32
            for keyIdx in keyIdx..<keyLen:
                if bytesGet(wireBytes, lineStart + keyIdx) != bytesGet(keyBytes, keyIdx):
                    matched = false
                    break
            if matched:
                let valueStart = eqPos + 1
                var valueLen: int32
                if lineEnd > valueStart:
                    valueLen = lineEnd - valueStart
                return Ok[str](strings.SliceBytes(wire, valueStart, valueLen))
        lineStart = lineEnd + 1
    return Err[str](MoqFountainFmt2("moq_fountain_missing_wire_field:", key))

fn MoqFountainDecodeBlockIndexes(csv: str): int32[] =
    let parts = MoqFountainSplitCsv(csv)
    var out: int32[]
    out = []
    var i: int32
    for i in i..<parts.len:
        let item = MoqFountainTrimAscii(parts[i])
        if len(item) <= 0:
            continue
        add(out, MoqFountainParseInt32Text(item))
    return out

fn MoqFountainCoeffOffset(row: int32, col: int32, colCount: int32): int32 =
    return row * colCount + col

fn MoqFountainCoeffGet(coeffData: int32[],
                       row: int32,
                       col: int32,
                       colCount: int32): int32 =
    return coeffData[MoqFountainCoeffOffset(row, col, colCount)]

fn MoqFountainCoeffSet(coeffData: var int32[],
                       row: int32,
                       col: int32,
                       colCount: int32,
                       value: int32) =
    coeffData[MoqFountainCoeffOffset(row, col, colCount)] = value

fn MoqFountainCoeffSwapRows(coeffData: var int32[],
                            leftRow: int32,
                            rightRow: int32,
                            colCount: int32) =
    var col: int32
    for col in col..<colCount:
        let leftValue = MoqFountainCoeffGet(coeffData, leftRow, col, colCount)
        let rightValue = MoqFountainCoeffGet(coeffData, rightRow, col, colCount)
        MoqFountainCoeffSet(coeffData, leftRow, col, colCount, rightValue)
        MoqFountainCoeffSet(coeffData, rightRow, col, colCount, leftValue)

fn MoqFountainCopyBlockIntoFlat(target: var Bytes,
                                blockBytes: int32,
                                blockIndex: int32,
                                source: Bytes): Result[bool] =
    if bytesLen(source) != blockBytes:
        return Err[bool]("moq_fountain_invalid_solved_block")
    let offset = blockIndex * blockBytes
    var idx: int32
    for idx in idx..<blockBytes:
        bytesSet(target, offset + idx, bytesGet(source, idx))
    return Ok[bool](true)

fn MoqFountainSolveObjectBytes(sourceBlockCount: int32,
                               blockBytes: int32,
                               byteLength: int32,
                               coeffData0: int32[],
                               payloadRows0: Bytes[]): Result[Bytes] =
    if sourceBlockCount <= 0:
        return Err[Bytes]("moq_fountain_invalid_object")
    let rowCount = payloadRows0.len
    if rowCount <= 0:
        return Err[Bytes]("moq_fountain_insufficient_droplets")
    if coeffData0.len != rowCount * sourceBlockCount:
        return Err[Bytes]("moq_fountain_invalid_coeff_matrix")
    var coeffData = coeffData0
    var payloadRows = payloadRows0
    let solvedFlatLen = sourceBlockCount * blockBytes
    var solvedFlat = bytesAlloc(solvedFlatLen)
    var solvedMask = bytesAlloc(sourceBlockCount)
    var solvedCount: int32
    var pivotRow: int32
    var col: int32
    while col < sourceBlockCount && pivotRow < rowCount:
        var found: int32 = -1
        var row: int32 = pivotRow
        for row in row..<rowCount:
            if MoqFountainCoeffGet(coeffData, row, col, sourceBlockCount) != 0:
                found = row
                break
        if found < 0:
            col = col + 1
            continue
        if found != pivotRow:
            MoqFountainCoeffSwapRows(coeffData, pivotRow, found, sourceBlockCount)
            let tempPayload = payloadRows[pivotRow]
            payloadRows[pivotRow] = payloadRows[found]
            payloadRows[found] = tempPayload
        row = 0
        for row in range(rowCount):

            if row == pivotRow:
                row = row + 1
                continue
            if MoqFountainCoeffGet(coeffData, row, col, sourceBlockCount) == 0:
                row = row + 1
                continue
            var coeffIndex: int32
            for coeffIndex in coeffIndex..<sourceBlockCount:
                let nextValue = MoqFountainCoeffGet(coeffData, row, coeffIndex, sourceBlockCount) ^
                                MoqFountainCoeffGet(coeffData, pivotRow, coeffIndex, sourceBlockCount)
                MoqFountainCoeffSet(coeffData, row, coeffIndex, sourceBlockCount, nextValue)
            let xorOk = MoqFountainXorInto(payloadRows[row], payloadRows[pivotRow])
            if IsErr(xorOk):
                return Err[Bytes](Error(xorOk))

        if bytesGet(solvedMask, col) == 0:
            solvedCount = solvedCount + 1
        bytesSet(solvedMask, col, 1)
        let copyOk = MoqFountainCopyBlockIntoFlat(solvedFlat, blockBytes, col, payloadRows[pivotRow])
        if IsErr(copyOk):
            return Err[Bytes](Error(copyOk))
        pivotRow = pivotRow + 1
        col = col + 1
    if solvedCount < sourceBlockCount:
        return Err[Bytes]("moq_fountain_insufficient_droplets")
    var i: int32
    for i in i..<sourceBlockCount:
        if bytesGet(solvedMask, i) == 0:
            return Err[Bytes]("moq_fountain_invalid_solved_block")
    var objectBytes = bytesAlloc(byteLength)
    var writeOffset: int32
    var blockIndex: int32
    for blockIndex in range(sourceBlockCount):

        if writeOffset >= byteLength:
            break
        let copyLen = MoqFountainMinInt32(blockBytes, byteLength - writeOffset)
        let blockOffset = blockIndex * blockBytes
        var copyIndex: int32
        for copyIndex in copyIndex..<copyLen:
            bytesSet(objectBytes, writeOffset + copyIndex, bytesGet(solvedFlat, blockOffset + copyIndex))
        writeOffset = writeOffset + copyLen

    return Ok[Bytes](objectBytes)

fn MoqFountainRebuildFromWire(requestWire: str): Result[MoqFountainRebuildResult] =
    let blobCidRes = MoqFountainWireFindValue(requestWire, "blob_cid")
    if IsErr(blobCidRes):
        return Err[MoqFountainRebuildResult](Error(blobCidRes))
    let blobByteLenRes = MoqFountainParseInt32Wire(requestWire, "blob_byte_len")
    if IsErr(blobByteLenRes):
        return Err[MoqFountainRebuildResult](Error(blobByteLenRes))
    let objectCountRes = MoqFountainParseInt32Wire(requestWire, "object_count")
    if IsErr(objectCountRes):
        return Err[MoqFountainRebuildResult](Error(objectCountRes))
    let dropletCountRes = MoqFountainParseInt32Wire(requestWire, "droplet_count")
    if IsErr(dropletCountRes):
        return Err[MoqFountainRebuildResult](Error(dropletCountRes))
    let blobCid = Value(blobCidRes)
    let blobByteLen = Value(blobByteLenRes)
    let objectCount = Value(objectCountRes)
    let dropletCount = Value(dropletCountRes)
    var objectBytesList: Bytes[]
    objectBytesList = []
    var objectIndex: int32
    for objectIndex in range(objectCount):

        let objectPrefix = MoqFountainFmt3("object.", strings.IntToStr(objectIndex), ".")
        let byteLengthRes = MoqFountainParseInt32Wire(requestWire, MoqFountainPrefixKey(objectPrefix, "byte_length"))
        if IsErr(byteLengthRes):
            return Err[MoqFountainRebuildResult](Error(byteLengthRes))
        let sourceBlockBytesRes = MoqFountainParseInt32Wire(requestWire, MoqFountainPrefixKey(objectPrefix, "source_block_bytes"))
        if IsErr(sourceBlockBytesRes):
            return Err[MoqFountainRebuildResult](Error(sourceBlockBytesRes))
        let sourceBlockCountRes = MoqFountainParseInt32Wire(requestWire, MoqFountainPrefixKey(objectPrefix, "source_block_count"))
        if IsErr(sourceBlockCountRes):
            return Err[MoqFountainRebuildResult](Error(sourceBlockCountRes))
        let objectCidRes = MoqFountainWireFindValue(requestWire, MoqFountainPrefixKey(objectPrefix, "object_cid"))
        if IsErr(objectCidRes):
            return Err[MoqFountainRebuildResult](Error(objectCidRes))
        let byteLength = Value(byteLengthRes)
        let sourceBlockBytes = Value(sourceBlockBytesRes)
        let sourceBlockCount = Value(sourceBlockCountRes)
        let objectCid = Value(objectCidRes)
        var coeffData: int32[]
        coeffData = []
        var payloadRows: Bytes[]
        payloadRows = []
        var dropletRow: int32
        for dropletRow in range(dropletCount):

            let prefix = MoqFountainFmt3("droplet.", strings.IntToStr(dropletRow), ".")
            let candidateObjectIndexRes = MoqFountainParseInt32Wire(requestWire, MoqFountainPrefixKey(prefix, "object_index"))
            if IsErr(candidateObjectIndexRes):
                return Err[MoqFountainRebuildResult](Error(candidateObjectIndexRes))
            let candidateObjectIndex = Value(candidateObjectIndexRes)
            if candidateObjectIndex != objectIndex:
                dropletRow = dropletRow + 1
                continue
            let payloadHexRes = MoqFountainWireFindValue(requestWire, MoqFountainPrefixKey(prefix, "payload_hex"))
            if IsErr(payloadHexRes):
                return Err[MoqFountainRebuildResult](Error(payloadHexRes))
            let payloadRes = MoqFountainBytesFromHex(Value(payloadHexRes))
            if IsErr(payloadRes):
                return Err[MoqFountainRebuildResult](Error(payloadRes))
            let payload = Value(payloadRes)
            if bytesLen(payload) != sourceBlockBytes:
                return Err[MoqFountainRebuildResult]("moq_fountain_payload_size_mismatch")
            let cidRes = MoqFountainWireFindValue(requestWire, MoqFountainPrefixKey(prefix, "cid"))
            if IsErr(cidRes):
                return Err[MoqFountainRebuildResult](Error(cidRes))
            let cid = Value(cidRes)
            if len(cid) > 0 && cid != MoqFountainSha256HexBytes(payload):
                return Err[MoqFountainRebuildResult]("moq_fountain_payload_cid_mismatch")
            let blockIndexesRes = MoqFountainWireFindValue(requestWire, MoqFountainPrefixKey(prefix, "block_indexes"))
            if IsErr(blockIndexesRes):
                return Err[MoqFountainRebuildResult](Error(blockIndexesRes))
            let blockIndexes = MoqFountainDecodeBlockIndexes(Value(blockIndexesRes))
            let rowIndex = payloadRows.len
            add(payloadRows, payload)
            var coeffIndex: int32
            for coeffIndex in coeffIndex..<sourceBlockCount:
                add(coeffData, 0)
            var blockIndex: int32
            for blockIndex in blockIndex..<blockIndexes.len:
                let idx = blockIndexes[blockIndex]
                if idx < 0 || idx >= sourceBlockCount:
                    return Err[MoqFountainRebuildResult]("moq_fountain_block_index_out_of_range")
                let nextValue = MoqFountainCoeffGet(coeffData, rowIndex, idx, sourceBlockCount) ^ 1
                MoqFountainCoeffSet(coeffData, rowIndex, idx, sourceBlockCount, nextValue)

        let solvedRes = MoqFountainSolveObjectBytes(sourceBlockCount,
                                                   sourceBlockBytes,
                                                   byteLength,
                                                   coeffData,
                                                   payloadRows)
        if IsErr(solvedRes):
            return Err[MoqFountainRebuildResult](Error(solvedRes))
        let objectBytes = Value(solvedRes)
        if objectCid != MoqFountainSha256HexBytes(objectBytes):
            return Err[MoqFountainRebuildResult]("moq_fountain_object_cid_mismatch")
        add(objectBytesList, objectBytes)
        objectIndex = objectIndex + 1
    var rebuilt = bytesAlloc(blobByteLen)
    var blobOffset: int32
    objectIndex = 0
    while objectIndex < objectBytesList.len:
        let objectBytes = objectBytesList[objectIndex]
        var copyIndex: int32
        for copyIndex in copyIndex..<bytesLen(objectBytes):
            if blobOffset + copyIndex >= blobByteLen:
                break
            bytesSet(rebuilt, blobOffset + copyIndex, bytesGet(objectBytes, copyIndex))
        blobOffset = blobOffset + bytesLen(objectBytes)

    if blobCid != MoqFountainSha256HexBytes(rebuilt):
        return Err[MoqFountainRebuildResult]("moq_fountain_blob_cid_mismatch")
    return Ok[MoqFountainRebuildResult](MoqFountainRebuildResult(
        blob: rebuilt,
        blobCid: blobCid,
        blobByteLen: blobByteLen
    ))

fn MoqFountainRebuildResultToWire(outputPath: str,
                                  result: MoqFountainRebuildResult): str =
    let rows = [
        "ok=1",
        MoqFountainFmt2("output_path=", outputPath),
        MoqFountainFmt2("blob_cid=", result.blobCid),
        MoqFountainFmt2("blob_byte_len=", strings.IntToStr(result.blobByteLen))
    ]
    return MoqFountainLinesWithNewline(rows)

fn MoqFountainBrowserRebuildResultToWire(result: MoqFountainRebuildResult): str =
    var rows: str[]
    rows = []
    add(rows, "ok=1")
    add(rows, MoqFountainFmt2("blob_cid=", result.blobCid))
    add(rows, MoqFountainFmt2("blob_byte_len=", strings.IntToStr(result.blobByteLen)))
    add(rows, MoqFountainFmt2("blob_hex=", bytesToHex(result.blob)))
    return MoqFountainLinesWithNewline(rows)

fn MoqFountainRebuildToWire(requestWire: str): str =
    let rebuiltRes = MoqFountainRebuildFromWire(requestWire)
    if IsErr(rebuiltRes):
        let errorText = Error(rebuiltRes)
        return MoqFountainErrorWire(errorText)
    let rebuilt = Value(rebuiltRes)
    return MoqFountainBrowserRebuildResultToWire(rebuilt)
