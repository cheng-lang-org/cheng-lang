import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256
import cheng/oracle/oracle_types as oracle_types
import cheng/oracle/oracle_plane as oracle_plane

fn oracleSmokePrivHex(slot: int32): str =
    if slot == 1:
        return "60d71049a0cafe01faa9948dc77ee5bc4bd5e05b8e328fdb9cc4c38237250a05"
    if slot == 2:
        return "d312c4a184302fdd5a3fe211c477d78b6de911f033b803268cb37b3e1e639852"
    if slot == 3:
        return "4e99df50f57f4981fe453e7950f429b72c3f8e68461f47c9da11243cf1c52191"
    if slot == 4:
        return "54cfcd44450dcf304643a1700974f43468b65a8ea761564c7517e1203693461d"
    if slot == 5:
        return "c56927477cc00396a71b36d41ba22c0b87d0d84c650de22300f12471ecafe5ae"
    if slot == 6:
        return "e6eac8fd7dd03ba114239e4be20d3a6c27aee673fc5c59a521b7a2ec1eaa3685"
    if slot == 7:
        return "4a99d2bfd7e8495c193dadc2f10ec7c2607e0479833cdc750d75312002e94bd7"
    panic("oracle smoke: missing private key")

fn oracleSmokePrivateScalar(slot: int32): fixed256.Scalar256 =
    let privRes = fixed256.scalar256FromHex(oracleSmokePrivHex(slot))
    assert(IsOk(privRes), "oracle smoke: private scalar")
    return Value(privRes)

fn oracleSmokePubKeyHex(slot: int32): str =
    if slot == 1:
        return "04963c1356849b8478030a6eb572581063ccedf53fda0bc7241247eba977e3b0666e4bf0c12caa47487c2927f83b17d6f9f332481cd2ab0c4885f91fc2a6c547d5"
    if slot == 2:
        return "04a07a1b4f54e85504185a40456e9020fcb7ae67bda04ac1fe5cd790e67035497a1be276d433dc5b772ca543cc6b96d6d443ff2da9e1ca1b3b847d1bab55ec0c2d"
    if slot == 3:
        return "04849d0a4d07c118a06e274519e743f23b327104b017e985ac50a7749f592120d865abc57511ef74ee12878e0583770e6457acb1abbe408a27ad220068936307ee"
    if slot == 4:
        return "0483898a50dd6df34f3fe95788b7f5bbd85e6372e82038e9ba16ea03054e4b31dca1e2f032a9d8ff5dd747dddc94e41626c65fb9f72f1a0829c357ad68c9bedb9c"
    if slot == 5:
        return "04a3435b80c5d1e5cdceaab69001870a89789de55226948d9fc17f2706db725e3e4398f1b4a3ba48be4454b6cdfae4522aace30bcc1a8bf1e37799a6b794418a71"
    if slot == 6:
        return "049f9d7d9707431e517488e9e82880a8c559acbae55b5ef20cf16d054d24c3bb37a5c688a96ced084282c77603e7447f018bc632949e23f8c5d3852272335beb5c"
    if slot == 7:
        return "0494ae32aab6e35ea0f4fa7667b845aa49b2a93a558f9a42e43221cc21ba2c049ed4ccb0b6b83cdf42a8cabce0437991bbefb6e991a896fed82a544d65ee7a9fb6"
    panic("oracle smoke: missing private key")

fn oracleSmokePubKey(slot: int32): layout.FixedBytes65 =
    let pubRes = layout.FixedBytes65FromHex(oracleSmokePubKeyHex(slot))
    assert(IsOk(pubRes), "oracle smoke: pubkey")
    return Value(pubRes)

fn oracleSmokeCommittee(): oracle_types.OracleCommitteeConfig =
    var pubKeys: layout.FixedBytes65[]
    pubKeys = []
    for slot in 1..<8:
        add(pubKeys, oracleSmokePubKey(slot))
    let committeeRes = oracle_types.OracleCommitteeConfigMake(1, pubKeys, oracle_types.OracleDefaultQuorum)
    assert(IsOk(committeeRes), "oracle smoke: committee")
    return Value(committeeRes)

fn oracleSmokePrice(roundId: int64, pairIndex: int32, reporterSlot: int32): int64 =
    return (roundId * int64(1000000000)) + int64((pairIndex + 1) * 1000) + int64(reporterSlot * 10) + int64(1)

fn oracleSmokePrices(roundId: int64, reporterSlot: int32): int64[] =
    var prices: int64[]
    prices = []
    for pairIndex in 0..<oracle_types.OraclePairCount:
        add(prices, oracleSmokePrice(roundId, pairIndex, reporterSlot))
    return prices

