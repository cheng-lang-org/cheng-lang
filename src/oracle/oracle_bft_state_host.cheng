import std/os
import std/result
import std/strings
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/oracle/oracle_types as oracle_types
import cheng/oracle/oracle_bft_state_machine as oracle_bft
import cheng/core/tooling/path as chengpath

const
    OracleBftStateMagic: str = "cheng.oracle.bft.state.v1"

fn OracleBftStateCurrentDir(): str =
    return os.GetCurrentDir()

fn OracleBftStateReadTextFile(pathRaw: str): str =
    let rootDir = OracleBftStateCurrentDir()
    let text = chengpath.ReadTextFile(rootDir, pathRaw)
    return text

fn OracleBftStateWriteTextFile(pathRaw: str, text: str): bool =
    let rootDir = OracleBftStateCurrentDir()
    let ok = chengpath.WriteTextFile(rootDir, pathRaw, text)
    return ok

fn OracleBftStateTextValue(text: str, key: str): str =
    let prefix = key + "="
    var start = 0
    while start < len(text):
        var end = start
        while end < len(text):
            if text[end] == '\n' || text[end] == '\r':
                break
            end = end + 1
        let line = chengpath.TextSlice(text, start, end - start)
        if chengpath.TextStartsWith(line, prefix):
            return chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
        start = end + 1
        while start < len(text):
            if text[start] != '\n' && text[start] != '\r':
                break
            start = start + 1
    return ""

fn OracleBftStateParseBool(key: str, raw: str): Result[bool] =
    let text = strutil.Strip(raw)
    if text == "1" || text == "true":
        return Ok[bool](true)
    if text == "0" || text == "false":
        return Ok[bool](false)
    return Err[bool](" oracle state: invalid bool " + key)

fn OracleBftStateParseInt64(key: str, raw: str): Result[int64] =
    let text = strutil.Strip(raw)
    if len(text) <= 0:
        return Err[int64](" oracle state: empty integer " + key)
    var sign = int64(1)
    var i = 0
    if text[0] == '+':
        i = 1
    elif text[0] == '-':
        sign = int64(-1)
        i = 1
    if i >= len(text):
        return Err[int64](" oracle state: invalid integer " + key)
    var value = int64(0)
    while i < len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int64](" oracle state: invalid integer " + key)
        value = value * int64(10) + int64(int32(ch) - int32('0'))
        i = i + 1
    return Ok[int64](value * sign)

fn OracleBftStateParseInt32(key: str, raw: str): Result[int32] =
    let valueRes = OracleBftStateParseInt64(key, raw)
    if IsErr(valueRes):
        return Err[int32](Error(valueRes))
    if Value(valueRes) < int64(-2147483648) || Value(valueRes) > int64(2147483647):
        return Err[int32](" oracle state: integer overflow " + key)
    return Ok[int32](int32(Value(valueRes)))

fn OracleBftStateHistoryStart(state: oracle_types.OraclePairState): int32 =
    let raw = state.historyHead - state.historyLen
    if raw >= 0:
        return raw
    return raw + oracle_types.OracleHistoryMax

fn OracleBftStatePushHistory(state: var oracle_types.OraclePairState,
                               roundId: int64,
                               priceE8: int64) =
    let writePos = state.historyHead
    state.historyRoundIds[writePos] = roundId
    state.historyPricesE8[writePos] = priceE8
    state.historyHead = (writePos + 1) % oracle_types.OracleHistoryMax
    if state.historyLen < oracle_types.OracleHistoryMax:
        state.historyLen = state.historyLen + 1
    state.available = true
    state.latestRoundId = roundId
    state.latestPriceE8 = priceE8

fn OracleBftStateHistoryText(state: oracle_types.OraclePairState): str =
    if state.historyLen <= 0:
        return ""
    let start = OracleBftStateHistoryStart(state)
    var out = ""
    var i = 0
    while i < state.historyLen:
        let idx = (start + i) % oracle_types.OracleHistoryMax
        if i > 0:
            out = out + ","
        out = out +
            strings.Int64ToStr(state.historyRoundIds[idx]) +
            ":" +
            strings.Int64ToStr(state.historyPricesE8[idx])
        i = i + 1
    return out

fn OracleBftStateParseHistoryItem(item: str,
                                    outRoundId: var int64,
                                    outPriceE8: var int64): Result[bool] =
    outRoundId = int64(0)
    outPriceE8 = int64(0)
    var colonPos = -1
    var i = 0
    while i < len(item):
        if item[i] == ':':
            colonPos = i
            break
        i = i + 1
    if colonPos <= 0 || colonPos >= len(item) - 1:
        return Err[bool](" oracle state: invalid history item")
    let roundText = strings.SliceBytes(item, 0, colonPos)
    let priceText = strings.SliceBytes(item, colonPos + 1, len(item) - colonPos - 1)
    let roundRes = OracleBftStateParseInt64("history_round", roundText)
    if IsErr(roundRes):
        return Err[bool](Error(roundRes))
    let priceRes = OracleBftStateParseInt64("history_price", priceText)
    if IsErr(priceRes):
        return Err[bool](Error(priceRes))
    outRoundId = Value(roundRes)
    outPriceE8 = Value(priceRes)
    return Ok[bool](true)

fn OracleBftStateParseHistory(raw: str,
                                outState: var oracle_types.OraclePairState): Result[bool] =
    outState = oracle_types.OraclePairState()
    let text = strutil.Strip(raw)
    if len(text) <= 0:
        return Ok[bool](true)
    var start = 0
    while start < len(text):
        var end = start
        while end < len(text):
            if text[end] == ',':
                break
            end = end + 1
        let item = strings.SliceBytes(text, start, end - start)
        if len(item) > 0:
            var roundId = int64(0)
            var priceE8 = int64(0)
            let itemRes = OracleBftStateParseHistoryItem(item, roundId, priceE8)
            if IsErr(itemRes):
                return Err[bool](Error(itemRes))
            OracleBftStatePushHistory(outState, roundId, priceE8)
        start = end + 1
    return Ok[bool](true)

fn OracleBftMachineHasPending(machine: oracle_bft.OracleBftStateMachine): bool =
    for i in 0..<oracle_types.OraclePendingRoundMax:
        if machine.pendingRounds[i].active:
            return true
    return false

fn OracleBftStateLineAppend(out: var str, key: str, value: str) =
    out = out + key + "=" + value + "\n"

fn OracleBftWriteState(pathRaw: str,
                         machine: oracle_bft.OracleBftStateMachine): Result[bool] =
    let hasPending = OracleBftMachineHasPending(machine)
    if hasPending:
        return Err[bool](" oracle state: pending rounds must be finalized before write")
    let appHash = oracle_bft.OracleBftStateMachineQueryAppHash(machine)
    let finalizedText = machine.hasFinalized ? "1" : "0"
    var out = ""
    OracleBftStateLineAppend(out, "magic", OracleBftStateMagic)
    OracleBftStateLineAppend(out, "app_id", machine.appId)
    OracleBftStateLineAppend(out, "committee_set_id", intToStr(machine.committee.committeeSetId))
    OracleBftStateLineAppend(out, "reporter_count", intToStr(machine.committee.reporterCount))
    OracleBftStateLineAppend(out, "quorum", intToStr(machine.committee.quorum))
    for i in 0..<machine.committee.reporterCount:
        OracleBftStateLineAppend(out,
                                   "reporter_pubkey_" + intToStr(i + 1),
                                   layout.FixedBytes65Hex(machine.committee.reporterPubKeys[i]))
    OracleBftStateLineAppend(out, "has_finalized", finalizedText)
    OracleBftStateLineAppend(out, "last_finalized_round_id", strings.Int64ToStr(machine.lastFinalizedRoundId))
    OracleBftStateLineAppend(out, "last_finalized_height", strings.Int64ToStr(machine.lastFinalizedHeight))
    OracleBftStateLineAppend(out, "last_commit_app_hash", layout.FixedBytes32Hex(appHash))
    for pairIndex in 0..<oracle_types.OraclePairCount:
        let pairState = machine.pairStates[pairIndex]
        let pairId = pairIndex + 1
        let prefix = "pair_" + intToStr(pairId) + "_"
        let availableText = pairState.available ? "1" : "0"
        OracleBftStateLineAppend(out, prefix + "available", availableText)
        OracleBftStateLineAppend(out, prefix + "latest_round_id", strings.Int64ToStr(pairState.latestRoundId))
        OracleBftStateLineAppend(out, prefix + "latest_price_e8", strings.Int64ToStr(pairState.latestPriceE8))
        OracleBftStateLineAppend(out, prefix + "history_len", intToStr(pairState.historyLen))
        OracleBftStateLineAppend(out, prefix + "history", OracleBftStateHistoryText(pairState))
    if !OracleBftStateWriteTextFile(pathRaw, out):
        return Err[bool](" oracle state: write failed")
    return Ok[bool](true)

fn OracleBftLoadState(pathRaw: str,
                        outMachine: var oracle_bft.OracleBftStateMachine): Result[bool] =
    let text = OracleBftStateReadTextFile(pathRaw)
    if len(text) <= 0:
        return Err[bool](" oracle state: missing state file")
    if OracleBftStateTextValue(text, "magic") != OracleBftStateMagic:
        return Err[bool](" oracle state: bad state magic")
    let appId = OracleBftStateTextValue(text, "app_id")
    if len(appId) <= 0:
        return Err[bool](" oracle state: missing app id")
    let committeeSetIdRes = OracleBftStateParseInt32("committee_set_id",
                                                       OracleBftStateTextValue(text, "committee_set_id"))
    if IsErr(committeeSetIdRes):
        return Err[bool](Error(committeeSetIdRes))
    let reporterCountRes = OracleBftStateParseInt32("reporter_count",
                                                      OracleBftStateTextValue(text, "reporter_count"))
    if IsErr(reporterCountRes):
        return Err[bool](Error(reporterCountRes))
    let quorumRes = OracleBftStateParseInt32("quorum",
                                               OracleBftStateTextValue(text, "quorum"))
    if IsErr(quorumRes):
        return Err[bool](Error(quorumRes))
    var pubKeys: layout.FixedBytes65[]
    pubKeys = []
    for i in 0..<Value(reporterCountRes):
        let pubRes = layout.FixedBytes65FromHex(OracleBftStateTextValue(text, "reporter_pubkey_" + intToStr(i + 1)))
        if IsErr(pubRes):
            return Err[bool](" oracle state: bad reporter pubkey")
        add(pubKeys, Value(pubRes))
    let committeeRes = oracle_types.OracleCommitteeConfigMake(Value(committeeSetIdRes), pubKeys, Value(quorumRes))
    if IsErr(committeeRes):
        return Err[bool](Error(committeeRes))
    outMachine = oracle_bft.OracleBftStateMachineInit(appId, Value(committeeRes))
    let hasFinalizedRes = OracleBftStateParseBool("has_finalized", OracleBftStateTextValue(text, "has_finalized"))
    if IsErr(hasFinalizedRes):
        return Err[bool](Error(hasFinalizedRes))
    let lastRoundRes = OracleBftStateParseInt64("last_finalized_round_id",
                                                  OracleBftStateTextValue(text, "last_finalized_round_id"))
    if IsErr(lastRoundRes):
        return Err[bool](Error(lastRoundRes))
    let lastHeightRes = OracleBftStateParseInt64("last_finalized_height",
                                                   OracleBftStateTextValue(text, "last_finalized_height"))
    if IsErr(lastHeightRes):
        return Err[bool](Error(lastHeightRes))
    let storedHashRes = layout.FixedBytes32FromHex(OracleBftStateTextValue(text, "last_commit_app_hash"))
    if IsErr(storedHashRes):
        return Err[bool](" oracle state: bad app hash")
    outMachine.hasFinalized = Value(hasFinalizedRes)
    outMachine.lastFinalizedRoundId = Value(lastRoundRes)
    outMachine.lastFinalizedHeight = Value(lastHeightRes)
    for pairIndex in 0..<oracle_types.OraclePairCount:
        let pairId = pairIndex + 1
        let prefix = "pair_" + intToStr(pairId) + "_"
        let availableRes = OracleBftStateParseBool(prefix + "available",
                                                     OracleBftStateTextValue(text, prefix + "available"))
        if IsErr(availableRes):
            return Err[bool](Error(availableRes))
        let latestRoundRes = OracleBftStateParseInt64(prefix + "latest_round_id",
                                                        OracleBftStateTextValue(text, prefix + "latest_round_id"))
        if IsErr(latestRoundRes):
            return Err[bool](Error(latestRoundRes))
        let latestPriceRes = OracleBftStateParseInt64(prefix + "latest_price_e8",
                                                        OracleBftStateTextValue(text, prefix + "latest_price_e8"))
        if IsErr(latestPriceRes):
            return Err[bool](Error(latestPriceRes))
        let historyLenRes = OracleBftStateParseInt32(prefix + "history_len",
                                                       OracleBftStateTextValue(text, prefix + "history_len"))
        if IsErr(historyLenRes):
            return Err[bool](Error(historyLenRes))
        var pairState = oracle_types.OraclePairState()
        let parseRes = OracleBftStateParseHistory(OracleBftStateTextValue(text, prefix + "history"), pairState)
        if IsErr(parseRes):
            return Err[bool](Error(parseRes))
        if pairState.historyLen != Value(historyLenRes):
            return Err[bool](" oracle state: history length mismatch")
        if Value(availableRes):
            if !pairState.available:
                return Err[bool](" oracle state: missing pair history")
            if pairState.latestRoundId != Value(latestRoundRes) || pairState.latestPriceE8 != Value(latestPriceRes):
                return Err[bool](" oracle state: latest pair mismatch")
        else:
            if pairState.historyLen != 0:
                return Err[bool](" oracle state: unexpected pair history")
            if Value(latestRoundRes) != int64(0) || Value(latestPriceRes) != int64(0):
                return Err[bool](" oracle state: unexpected pair latest")
        outMachine.pairStates[pairIndex] = pairState
    if outMachine.hasFinalized:
        if outMachine.lastFinalizedRoundId <= int64(0) || outMachine.lastFinalizedHeight <= int64(0):
            return Err[bool](" oracle state: bad finalized head")
        for pairIndex in 0..<oracle_types.OraclePairCount:
            let pairState = outMachine.pairStates[pairIndex]
            if !pairState.available || pairState.latestRoundId != outMachine.lastFinalizedRoundId:
                return Err[bool](" oracle state: finalized pair drift")
    else:
        if outMachine.lastFinalizedRoundId != int64(0) || outMachine.lastFinalizedHeight != int64(0):
            return Err[bool](" oracle state: unexpected empty head")
    let computedHash = oracle_bft.OracleBftStateMachineQueryAppHash(outMachine)
    if !layout.FixedBytes32Equal(computedHash, Value(storedHashRes)):
        return Err[bool](" oracle state: app hash drift")
    outMachine.lastCommitAppHash = computedHash
    return Ok[bool](true)
