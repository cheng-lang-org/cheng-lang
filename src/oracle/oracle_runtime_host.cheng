import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as binary
import cheng/chain/pubsub
import cheng/oracle/oracle_types as oracle_types
import cheng/oracle/oracle_plane as oracle_plane
import cheng/overlay/contracts as overlay
import cheng/overlay/libp2p_bridge as bridge
import cheng/libp2p/core/types as core
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/host/host as host_base

type
    OracleFastRuntime =
        committee: oracle_types.OracleCommitteeConfig
        batches: oracle_plane.OracleSignedBatch[]

    OracleFastQuote =
        available: bool
        pairId: oracle_types.OraclePairId
        roundId: int64
        priceE8: int64
        reportCount: int32

fn OracleFastRuntimeInit(committee: oracle_types.OracleCommitteeConfig): OracleFastRuntime =
    var out: OracleFastRuntime
    out.committee = committee
    out.batches = []
    return out

fn OracleRuntimeSelectSyncRequest(localHost: var host_base.Libp2pHost,
                                    remoteHost: var host_base.Libp2pHost,
                                    remotePeerId: core.Libp2pPeerId,
                                    query: overlay.StoreQuery,
                                    out: var overlay.IngressEnvelope[]): Result[bool] =
    var endpoint: ps.Libp2pPeerEndpoint
    let endpointRes = host_base.Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[bool](Error(endpointRes))
    if endpoint.addr.transport == core.Libp2pTransportQuic:
        return Err[bool](" oracle runtime host: quic sync requires pin_runtime_host_quic")
    return host_base.Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, out)

fn OracleRuntimeFindIngress(entries: overlay.IngressEnvelope[],
                              payloadCid: layout.FixedBytes32,
                              payloadKind: int32): Result[overlay.IngressEnvelope] =
    for i in 0..<entries.len:
        let ingress = entries[i]
        if !layout.fixedBytes32Equal(ingress.payloadCid, payloadCid):
            continue
        if ingress.payloadKind != payloadKind:
            continue
        return Ok[overlay.IngressEnvelope](ingress)
    return Err[overlay.IngressEnvelope](" oracle runtime host: ingress missing")

fn OracleSortI64(values: var int64[]) =
    for i in 1..<values.len:
        let key = values[i]
        var j = i - 1
        while j >= 0 && values[j] > key:
            values[j + 1] = values[j]
            j = j - 1
        values[j + 1] = key

fn OracleFastRuntimeMaxRound(runtime: OracleFastRuntime): int64 =
    if runtime.batches.len <= 0:
        return int64(-1)
    var out = runtime.batches[0].roundId
    for i in 1..<runtime.batches.len:
        if runtime.batches[i].roundId > out:
            out = runtime.batches[i].roundId
    return out

fn OracleFastRuntimeReportCount(runtime: OracleFastRuntime, roundId: int64): int32 =
    var count = 0
    for i in 0..<runtime.batches.len:
        if runtime.batches[i].roundId == roundId:
            count = count + 1
    return count

fn OracleFastRuntimeFindQuorumRound(runtime: OracleFastRuntime): int64 =
    var best = int64(-1)
    for i in 0..<runtime.batches.len:
        let roundId = runtime.batches[i].roundId
        if roundId <= best:
            continue
        if OracleFastRuntimeReportCount(runtime, roundId) < runtime.committee.quorum:
            continue
        best = roundId
    return best

fn OracleFastRuntimeStoreBatch(runtime: var OracleFastRuntime,
                                 batch: var oracle_plane.OracleSignedBatch): Result[bool] =
    let verifyRes = oracle_plane.OracleSignedBatchVerifyAgainstCommittee(batch, runtime.committee)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    for i in 0..<runtime.batches.len:
        let prev = runtime.batches[i]
        if prev.roundId != batch.roundId:
            continue
        if prev.reporterSlot != batch.reporterSlot:
            continue
        if layout.fixedBytes32Equal(prev.batchCid, batch.batchCid):
            return Ok[bool](false)
        return Err[bool](" oracle runtime host: conflicting reporter batch")
    add(runtime.batches, batch)
    let maxRound = OracleFastRuntimeMaxRound(runtime)
    let minRound = maxRound - int64(oracle_types.OraclePendingRoundMax - 1)
    var kept: oracle_plane.OracleSignedBatch[]
    kept = []
    for i in 0..<runtime.batches.len:
        if runtime.batches[i].roundId >= minRound:
            add(kept, runtime.batches[i])
    runtime.batches = kept
    return Ok[bool](true)

fn OracleFastRuntimeQueryFast(runtime: OracleFastRuntime,
                                pairId: oracle_types.OraclePairId): Result[OracleFastQuote] =
    if !oracle_types.OraclePairValid(pairId):
        return Err[OracleFastQuote](" oracle runtime host: bad pair id")
    let roundId = OracleFastRuntimeFindQuorumRound(runtime)
    if roundId < 0:
        return Err[OracleFastQuote](" oracle runtime host: fast quote unavailable")
    let pairIndex = oracle_types.OraclePairIndex(pairId)
    var values: int64[]
    values = []
    for i in 0..<runtime.batches.len:
        let batch = runtime.batches[i]
        if batch.roundId != roundId:
            continue
        add(values, batch.pricesE8[pairIndex])
    if values.len < runtime.committee.quorum:
        return Err[OracleFastQuote](" oracle runtime host: fast quorum missing")
    OracleSortI64(values)
    var out = OracleFastQuote()
    out.available = true
    out.pairId = pairId
    out.roundId = roundId
    out.priceE8 = values[values.len / 2]
    out.reportCount = values.len
    return Ok[OracleFastQuote](out)

fn OracleRuntimePublishBatch(hostState: var host_base.Libp2pHost,
                               scope: overlay.OverlayTopicScope,
                               address: binary.LsmrAddress,
                               batch: oracle_plane.OracleSignedBatch,
                               stampEpoch: int32,
                               stampGanzhi: int32): Result[bool] =
    let payload = oracle_plane.OracleSignedBatchEncode(batch)
    let payloadOk = oracle_plane.OracleSignedBatchValidatePayload(payload, batch.batchCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let ingress = bridge.Libp2pIngressMake(hostState.selfPeerId,
                                             scope,
                                             address,
                                             pubsub.PubSubPayloadKindOracleBatch,
                                             batch.batchCid,
                                             payload,
                                             stampEpoch,
                                             stampGanzhi)
    bridge.Libp2pRelayPublish(hostState, ingress)
    host_base.Libp2pKadProvide(hostState, batch.batchCid)
    return Ok[bool](true)

fn OracleRuntimeFetchBatch(localHost: var host_base.Libp2pHost,
                             remoteHost: var host_base.Libp2pHost,
                             remotePeerId: core.Libp2pPeerId,
                             scope: overlay.OverlayTopicScope,
                             address: binary.LsmrAddress,
                             batchCid: layout.FixedBytes32): Result[oracle_plane.OracleSignedBatch] =
    var query = overlay.StoreQuery()
    query.topicScope = scope
    query.address = address
    query.wantEventCid = batchCid
    var entries: overlay.IngressEnvelope[]
    let entriesRes = OracleRuntimeSelectSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[oracle_plane.OracleSignedBatch](Error(entriesRes))
    let ingressRes = OracleRuntimeFindIngress(entries,
                                                batchCid,
                                                pubsub.PubSubPayloadKindOracleBatch)
    if IsErr(ingressRes):
        return Err[oracle_plane.OracleSignedBatch](Error(ingressRes))
    let ingress = Value(ingressRes)
    let payloadOk = oracle_plane.OracleSignedBatchValidatePayload(ingress.payload, batchCid)
    if IsErr(payloadOk):
        return Err[oracle_plane.OracleSignedBatch](Error(payloadOk))
    return oracle_plane.OracleSignedBatchDecode(ingress.payload)
