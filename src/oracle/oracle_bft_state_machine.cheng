import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/oracle/oracle_types as oracle_types
import cheng/oracle/oracle_plane as oracle_plane

const
    OracleBftCodeOk: int32 = 0
    OracleBftCodeDecodeError: int32 = 1
    OracleBftCodeBadHeight: int32 = 2
    OracleBftCodeBadCommittee: int32 = 3
    OracleBftCodeBadReporter: int32 = 4
    OracleBftCodeBadSignature: int32 = 5
    OracleBftCodeBadRound: int32 = 6
    OracleBftCodeDuplicateReporter: int32 = 7
    OracleBftCodeNotFinalized: int32 = 8
    OracleBftCodeStale: int32 = 9
    OracleBftCodeBadPair: int32 = 10
    OracleBftCodeBadWindow: int32 = 11

type
    OracleBftBlockContext =
        height: int64
        txIndex: int32
        timeHint: int64
        proposerHint: layout.FixedBytes32

    OracleBftTxCheckResult =
        code: int32
        accepted: bool
        applied: bool
        batchCid: layout.FixedBytes32
        appHash: layout.FixedBytes32
        nextHeight: int64
        roundId: int64
        reporterSlot: int32

    OracleBftTxBatch =
        txs: oracle_plane.OracleSignedBatch[]

    OracleBftBlockSummary =
        height: int64
        txCount: int32
        acceptedCount: int32
        rejectedCount: int32
        finalizedRoundCount: int32
        lastFinalizedRoundId: int64
        appHash: layout.FixedBytes32

    OracleBftCommitResult =
        height: int64
        appHash: layout.FixedBytes32
        lastFinalizedRoundId: int64
        finalizedPairCount: int32

    OracleBftPendingRound =
        active: bool
        roundId: int64
        reportCount: int32
        reporterSeen: bool[oracle_types.OracleCommitteeMax]
        reporterBatchCids: layout.FixedBytes32[oracle_types.OracleCommitteeMax]
        reporterPricesE8: int64[oracle_types.OraclePendingPriceSlotCount]

    OracleBftStateMachine =
        appId: str
        committee: oracle_types.OracleCommitteeConfig
        pendingRounds: OracleBftPendingRound[oracle_types.OraclePendingRoundMax]
        pairStates: oracle_types.OraclePairState[oracle_types.OraclePairCount]
        hasFinalized: bool
        lastFinalizedRoundId: int64
        lastFinalizedHeight: int64
        lastCommitAppHash: layout.FixedBytes32

fn OracleBftBlockContextMake(height: int64,
                               txIndex: int32,
                               timeHint: int64,
                               proposerHint: layout.FixedBytes32): OracleBftBlockContext =
    var out = OracleBftBlockContext()
    out.height = height
    out.txIndex = txIndex
    out.timeHint = timeHint
    out.proposerHint = proposerHint
    return out

fn OracleBftTxBatchAdd(batch: var OracleBftTxBatch, tx: oracle_plane.OracleSignedBatch) =
    add(batch.txs, tx)

fn OracleBftTxBatchAddDecoded(batch: var OracleBftTxBatch, rawTx: Bytes): Result[bool] =
    let txRes = oracle_plane.OracleSignedBatchDecode(rawTx)
    if IsErr(txRes):
        return Err[bool](Error(txRes))
    add(batch.txs, Value(txRes))
    return Ok[bool](true)

fn OracleBftBlockSummaryZero(height: int64): OracleBftBlockSummary =
    var out: OracleBftBlockSummary
    out.height = height
    out.txCount = 0
    out.acceptedCount = 0
    out.rejectedCount = 0
    out.finalizedRoundCount = 0
    out.lastFinalizedRoundId = int64(0)
    out.appHash = layout.FixedBytes32()
    return out

fn OracleBftStateMachineInit(appId: str,
                               committee: oracle_types.OracleCommitteeConfig): OracleBftStateMachine =
    var out: OracleBftStateMachine
    out.appId = appId
    out.committee = committee
    for i in 0..<oracle_types.OraclePendingRoundMax:
        out.pendingRounds[i] = OracleBftPendingRound()
    for i in 0..<oracle_types.OraclePairCount:
        out.pairStates[i] = oracle_types.OraclePairState()
    out.hasFinalized = false
    out.lastFinalizedRoundId = int64(0)
    out.lastFinalizedHeight = int64(0)
    out.lastCommitAppHash = layout.FixedBytes32()
    return out

fn OracleBftAppendU32BE(buf: var layout.ByteBuf, value: int64) =
    lt.AppendU32BE(buf, value)

fn OracleBftAppendI64BE(buf: var layout.ByteBuf, value: int64) =
    OracleBftAppendU32BE(buf, int32(value >> 32))
    OracleBftAppendU32BE(buf, int32(value & int64(0xffffffff)))

fn OracleBftAppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(value))

fn OracleBftAppendFixed65(buf: var layout.ByteBuf, value: layout.FixedBytes65) =
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(value))

fn OracleBftStateMachineAppHash(machine: OracleBftStateMachine): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(8192)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.oracle.bft.apphash"))
    layout.byteBufAppendBytes(buf, bytesFromString(machine.appId))
    OracleBftAppendU32BE(buf, machine.committee.committeeSetId)
    OracleBftAppendU32BE(buf, machine.committee.reporterCount)
    OracleBftAppendU32BE(buf, machine.committee.quorum)
    for i in 0..<oracle_types.OracleCommitteeMax:
        OracleBftAppendFixed65(buf, machine.committee.reporterPubKeys[i])
    if machine.hasFinalized:
        OracleBftAppendU32BE(buf, 1)
    else:
        OracleBftAppendU32BE(buf, 0)
    OracleBftAppendI64BE(buf, machine.lastFinalizedRoundId)
    OracleBftAppendI64BE(buf, machine.lastFinalizedHeight)
    for i in 0..<oracle_types.OraclePairCount:
        let pairState = machine.pairStates[i]
        if pairState.available:
            OracleBftAppendU32BE(buf, 1)
        else:
            OracleBftAppendU32BE(buf, 0)
        OracleBftAppendI64BE(buf, pairState.latestRoundId)
        OracleBftAppendI64BE(buf, pairState.latestPriceE8)
        OracleBftAppendU32BE(buf, pairState.historyLen)
        OracleBftAppendU32BE(buf, pairState.historyHead)
        for j in 0..<oracle_types.OracleHistoryMax:
            OracleBftAppendI64BE(buf, pairState.historyRoundIds[j])
            OracleBftAppendI64BE(buf, pairState.historyPricesE8[j])
    for i in 0..<oracle_types.OraclePendingRoundMax:
        let pending = machine.pendingRounds[i]
        if pending.active:
            OracleBftAppendU32BE(buf, 1)
        else:
            OracleBftAppendU32BE(buf, 0)
        OracleBftAppendI64BE(buf, pending.roundId)
        OracleBftAppendU32BE(buf, pending.reportCount)
        for j in 0..<oracle_types.OracleCommitteeMax:
            if pending.reporterSeen[j]:
                OracleBftAppendU32BE(buf, 1)
            else:
                OracleBftAppendU32BE(buf, 0)
            OracleBftAppendFixed32(buf, pending.reporterBatchCids[j])
        for j in 0..<oracle_types.OraclePendingPriceSlotCount:
            OracleBftAppendI64BE(buf, pending.reporterPricesE8[j])
    return lt.FixedCidFromBuf(buf)

fn OracleBftHeightOk(height: int64): bool =
    if height <= int64(0):
        return false
    if height > int64(2147483647):
        return false
    return true

fn OracleBftFindPendingRound(machine: OracleBftStateMachine, roundId: int64): int32 =
    for i in 0..<oracle_types.OraclePendingRoundMax:
        if !machine.pendingRounds[i].active:
            continue
        if machine.pendingRounds[i].roundId == roundId:
            return i
    return -1

fn OracleBftFindFreePendingSlot(machine: OracleBftStateMachine): int32 =
    for i in 0..<oracle_types.OraclePendingRoundMax:
        if !machine.pendingRounds[i].active:
            return i
    return -1

fn OracleBftFindMinPendingRound(machine: OracleBftStateMachine): int64 =
    var found = false
    var out = int64(0)
    for i in 0..<oracle_types.OraclePendingRoundMax:
        if !machine.pendingRounds[i].active:
            continue
        if !found || machine.pendingRounds[i].roundId < out:
            out = machine.pendingRounds[i].roundId
            found = true
    if !found:
        return int64(-1)
    return out

fn OracleBftNextFinalizeRound(machine: OracleBftStateMachine): int64 =
    if machine.hasFinalized:
        return machine.lastFinalizedRoundId + int64(1)
    return OracleBftFindMinPendingRound(machine)

fn OracleBftPendingReporterOffset(slotIndex: int32, pairIndex: int32): int32 =
    return (slotIndex * oracle_types.OraclePairCount) + pairIndex

fn OracleBftCheckCode(machine: OracleBftStateMachine,
                        context: OracleBftBlockContext,
                        batch: oracle_plane.OracleSignedBatch): int32 =
    if !OracleBftHeightOk(context.height):
        return OracleBftCodeBadHeight
    if context.height <= machine.lastFinalizedHeight:
        return OracleBftCodeBadHeight
    let shapeRes = oracle_plane.OracleSignedBatchStructuralValidate(batch)
    if IsErr(shapeRes):
        return OracleBftCodeBadRound
    if batch.committeeSetId != machine.committee.committeeSetId:
        return OracleBftCodeBadCommittee
    if batch.reporterSlot <= 0 || batch.reporterSlot > machine.committee.reporterCount:
        return OracleBftCodeBadReporter
    let pubBytes = layout.fixedBytes65ToBytes(machine.committee.reporterPubKeys[batch.reporterSlot - 1])
    let verifyRes = oracle_plane.OracleSignedBatchVerify(batch, pubBytes)
    if IsErr(verifyRes):
        return OracleBftCodeBadSignature
    let currentRound = oracle_types.OracleRoundIdFromObservedAtMs(context.timeHint)
    if currentRound < 0:
        return OracleBftCodeBadRound
    if batch.roundId > currentRound:
        return OracleBftCodeBadRound
    let minRound = currentRound - int64(oracle_types.OraclePendingRoundMax - 1)
    if batch.roundId < minRound:
        return OracleBftCodeBadRound
    if machine.hasFinalized && batch.roundId <= machine.lastFinalizedRoundId:
        return OracleBftCodeBadRound
    let pendingPos = OracleBftFindPendingRound(machine, batch.roundId)
    if pendingPos >= 0:
        if machine.pendingRounds[pendingPos].reporterSeen[batch.reporterSlot - 1]:
            return OracleBftCodeDuplicateReporter
    return OracleBftCodeOk

fn OracleBftStateMachineCheckTxWithContext(machine: OracleBftStateMachine,
                                             context: OracleBftBlockContext,
                                             tx: oracle_plane.OracleSignedBatch): OracleBftTxCheckResult =
    var out = OracleBftTxCheckResult()
    out.batchCid = tx.batchCid
    out.roundId = tx.roundId
    out.reporterSlot = tx.reporterSlot
    out.nextHeight = machine.lastFinalizedHeight + int64(1)
    out.appHash = OracleBftStateMachineAppHash(machine)
    out.code = OracleBftCheckCode(machine, context, tx)
    out.accepted = out.code == OracleBftCodeOk
    return out

fn OracleBftStateMachineCheckTx(machine: OracleBftStateMachine,
                                  tx: oracle_plane.OracleSignedBatch): OracleBftTxCheckResult =
    let context = OracleBftBlockContextMake(machine.lastFinalizedHeight + int64(1),
                                              0,
                                              tx.observedAtMs,
                                              layout.FixedBytes32())
    return OracleBftStateMachineCheckTxWithContext(machine, context, tx)

fn OracleBftStateMachineCheckTxBytesWithContext(machine: OracleBftStateMachine,
                                                  context: OracleBftBlockContext,
                                                  txBytes: Bytes): OracleBftTxCheckResult =
    let txRes = oracle_plane.OracleSignedBatchDecode(txBytes)
    if IsErr(txRes):
        var out = OracleBftTxCheckResult()
        out.code = OracleBftCodeDecodeError
        out.appHash = OracleBftStateMachineAppHash(machine)
        out.nextHeight = machine.lastFinalizedHeight + int64(1)
        return out
    return OracleBftStateMachineCheckTxWithContext(machine, context, Value(txRes))

fn OracleBftStateMachineCheckTxBytes(machine: OracleBftStateMachine,
                                       txBytes: Bytes): OracleBftTxCheckResult =
    let context = OracleBftBlockContextMake(machine.lastFinalizedHeight + int64(1),
                                              0,
                                              int64(0),
                                              layout.FixedBytes32())
    return OracleBftStateMachineCheckTxBytesWithContext(machine, context, txBytes)

fn OracleBftEnsurePendingRound(machine: var OracleBftStateMachine,
                                 roundId: int64): int32 =
    let pos = OracleBftFindPendingRound(machine, roundId)
    if pos >= 0:
        return pos
    let freePos = OracleBftFindFreePendingSlot(machine)
    if freePos < 0:
        return -1
    machine.pendingRounds[freePos] = OracleBftPendingRound()
    machine.pendingRounds[freePos].active = true
    machine.pendingRounds[freePos].roundId = roundId
    return freePos

fn OracleBftApplyBatch(machine: var OracleBftStateMachine,
                         batch: oracle_plane.OracleSignedBatch): int32 =
    let pendingPos = OracleBftEnsurePendingRound(machine, batch.roundId)
    if pendingPos < 0:
        return OracleBftCodeBadRound
    if machine.pendingRounds[pendingPos].reporterSeen[batch.reporterSlot - 1]:
        return OracleBftCodeDuplicateReporter
    machine.pendingRounds[pendingPos].reporterSeen[batch.reporterSlot - 1] = true
    machine.pendingRounds[pendingPos].reporterBatchCids[batch.reporterSlot - 1] = batch.batchCid
    machine.pendingRounds[pendingPos].reportCount = machine.pendingRounds[pendingPos].reportCount + 1
    let reporterIndex = batch.reporterSlot - 1
    for pairIndex in 0..<oracle_types.OraclePairCount:
        let offset = OracleBftPendingReporterOffset(reporterIndex, pairIndex)
        machine.pendingRounds[pendingPos].reporterPricesE8[offset] = batch.pricesE8[pairIndex]
    return OracleBftCodeOk

fn OracleBftSortI64(values: var int64[]) =
    for i in 1..<values.len:
        let key = values[i]
        var j = i - 1
        while j >= 0 && values[j] > key:
            values[j + 1] = values[j]
            j = j - 1
        values[j + 1] = key

fn OracleBftPairStatePush(state: var oracle_types.OraclePairState,
                            roundId: int64,
                            priceE8: int64) =
    let writePos = state.historyHead
    state.historyRoundIds[writePos] = roundId
    state.historyPricesE8[writePos] = priceE8
    state.historyHead = (writePos + 1) % oracle_types.OracleHistoryMax
    if state.historyLen < oracle_types.OracleHistoryMax:
        state.historyLen = state.historyLen + 1
    state.available = true
    state.latestRoundId = roundId
    state.latestPriceE8 = priceE8

fn OracleBftClearPendingRound(machine: var OracleBftStateMachine, pos: int32) =
    machine.pendingRounds[pos] = OracleBftPendingRound()

fn OracleBftFinalizeReadyRounds(machine: var OracleBftStateMachine,
                                  timeHint: int64): int32 =
    var finalized = 0
    while true:
        let roundId = OracleBftNextFinalizeRound(machine)
        if roundId < 0:
            break
        if timeHint < oracle_types.OracleRoundEndMs(roundId):
            break
        let pendingPos = OracleBftFindPendingRound(machine, roundId)
        if pendingPos < 0:
            break
        let pending = machine.pendingRounds[pendingPos]
        if pending.reportCount < machine.committee.quorum:
            break
        for pairIndex in 0..<oracle_types.OraclePairCount:
            var values: int64[]
            values = []
            for reporterIndex in 0..<machine.committee.reporterCount:
                if !pending.reporterSeen[reporterIndex]:
                    continue
                let offset = OracleBftPendingReporterOffset(reporterIndex, pairIndex)
                add(values, pending.reporterPricesE8[offset])
            if values.len < machine.committee.quorum:
                return finalized
            OracleBftSortI64(values)
            let median = values[values.len / 2]
            OracleBftPairStatePush(machine.pairStates[pairIndex], roundId, median)
        machine.hasFinalized = true
        machine.lastFinalizedRoundId = roundId
        OracleBftClearPendingRound(machine, pendingPos)
        finalized = finalized + 1
    return finalized

fn OracleBftStateMachineFinalizeBatchSummaryWithContext(machine: var OracleBftStateMachine,
                                                          context: OracleBftBlockContext,
                                                          batch: var OracleBftTxBatch,
                                                          out: var OracleBftBlockSummary) =
    out = OracleBftBlockSummaryZero(context.height)
    out.txCount = batch.txs.len
    if !OracleBftHeightOk(context.height) || context.height <= machine.lastFinalizedHeight:
        out.rejectedCount = out.txCount
        out.lastFinalizedRoundId = machine.lastFinalizedRoundId
        out.appHash = OracleBftStateMachineAppHash(machine)
        return
    for i in 0..<batch.txs.len:
        var txContext = context
        txContext.txIndex = i
        let tx = batch.txs[i]
        let check = OracleBftStateMachineCheckTxWithContext(machine, txContext, tx)
        if check.code != OracleBftCodeOk:
            out.rejectedCount = out.rejectedCount + 1
            continue
        let applyCode = OracleBftApplyBatch(machine, tx)
        if applyCode == OracleBftCodeOk:
            out.acceptedCount = out.acceptedCount + 1
        else:
            out.rejectedCount = out.rejectedCount + 1
    out.finalizedRoundCount = OracleBftFinalizeReadyRounds(machine, context.timeHint)
    machine.lastFinalizedHeight = context.height
    out.lastFinalizedRoundId = machine.lastFinalizedRoundId
    out.appHash = OracleBftStateMachineAppHash(machine)

fn OracleBftStateMachineFinalizeBatchSummary(machine: var OracleBftStateMachine,
                                               height: int64,
                                               batch: var OracleBftTxBatch,
                                               out: var OracleBftBlockSummary) =
    let context = OracleBftBlockContextMake(height,
                                              0,
                                              height * oracle_types.OracleRoundMs,
                                              layout.FixedBytes32())
    OracleBftStateMachineFinalizeBatchSummaryWithContext(machine, context, batch, out)

fn OracleBftStateMachineFinalizeBlockSummaryWithContext(machine: var OracleBftStateMachine,
                                                          context: OracleBftBlockContext,
                                                          txs: oracle_plane.OracleSignedBatch[],
                                                          out: var OracleBftBlockSummary) =
    var batch = OracleBftTxBatch()
    for i in 0..<txs.len:
        OracleBftTxBatchAdd(batch, txs[i])
    OracleBftStateMachineFinalizeBatchSummaryWithContext(machine, context, batch, out)

fn OracleBftStateMachineFinalizeBlockSummary(machine: var OracleBftStateMachine,
                                               height: int64,
                                               txs: oracle_plane.OracleSignedBatch[],
                                               out: var OracleBftBlockSummary) =
    let context = OracleBftBlockContextMake(height,
                                              0,
                                              height * oracle_types.OracleRoundMs,
                                              layout.FixedBytes32())
    OracleBftStateMachineFinalizeBlockSummaryWithContext(machine, context, txs, out)

fn OracleBftStateMachineFinalizeBlockBytesSummaryWithContext(machine: var OracleBftStateMachine,
                                                               context: OracleBftBlockContext,
                                                               txBytes: Bytes[],
                                                               out: var OracleBftBlockSummary) =
    var batch = OracleBftTxBatch()
    for i in 0..<txBytes.len:
        let addRes = OracleBftTxBatchAddDecoded(batch, txBytes[i])
        if IsErr(addRes):
            out = OracleBftBlockSummaryZero(context.height)
            out.txCount = txBytes.len
            out.rejectedCount = txBytes.len
            out.lastFinalizedRoundId = machine.lastFinalizedRoundId
            out.appHash = OracleBftStateMachineAppHash(machine)
            return
    OracleBftStateMachineFinalizeBatchSummaryWithContext(machine, context, batch, out)

fn OracleBftStateMachineFinalizeBlockBytesSummary(machine: var OracleBftStateMachine,
                                                    height: int64,
                                                    txBytes: Bytes[],
                                                    out: var OracleBftBlockSummary) =
    let context = OracleBftBlockContextMake(height,
                                              0,
                                              height * oracle_types.OracleRoundMs,
                                              layout.FixedBytes32())
    OracleBftStateMachineFinalizeBlockBytesSummaryWithContext(machine, context, txBytes, out)

fn OracleBftStateMachineCommit(machine: var OracleBftStateMachine): OracleBftCommitResult =
    var out = OracleBftCommitResult()
    out.height = machine.lastFinalizedHeight
    out.appHash = OracleBftStateMachineAppHash(machine)
    out.lastFinalizedRoundId = machine.lastFinalizedRoundId
    if machine.hasFinalized:
        out.finalizedPairCount = oracle_types.OraclePairCount
    else:
        out.finalizedPairCount = 0
    machine.lastCommitAppHash = out.appHash
    return out

fn OracleBftStateMachineQueryAppHash(machine: OracleBftStateMachine): layout.FixedBytes32 =
    return OracleBftStateMachineAppHash(machine)

fn OracleBftLatestState(machine: OracleBftStateMachine,
                          pairId: oracle_types.OraclePairId): Result[oracle_types.OraclePairState] =
    if !oracle_types.OraclePairValid(pairId):
        return Err[oracle_types.OraclePairState](" oracle bft: bad pair id")
    let pairState = machine.pairStates[oracle_types.OraclePairIndex(pairId)]
    if !pairState.available:
        return Err[oracle_types.OraclePairState](" oracle bft: no finalized price")
    return Ok[oracle_types.OraclePairState](pairState)

fn OracleBftStateMachineQueryLatest(machine: OracleBftStateMachine,
                                      pairId: oracle_types.OraclePairId,
                                      nowMs: int64): oracle_types.OracleLatestQueryResult =
    var out = oracle_types.OracleLatestQueryResult()
    out.pairId = pairId
    out.height = machine.lastFinalizedHeight
    out.appHash = OracleBftStateMachineAppHash(machine)
    if !oracle_types.OraclePairValid(pairId):
        out.code = OracleBftCodeBadPair
        return out
    let stateRes = OracleBftLatestState(machine, pairId)
    if IsErr(stateRes):
        out.code = OracleBftCodeNotFinalized
        return out
    let pairState = Value(stateRes)
    let currentRound = oracle_types.OracleRoundIdFromObservedAtMs(nowMs)
    if currentRound - pairState.latestRoundId >= oracle_types.OracleStaleRoundThreshold:
        out.code = OracleBftCodeStale
        out.stale = true
        return out
    out.code = OracleBftCodeOk
    out.available = true
    out.roundId = pairState.latestRoundId
    out.priceE8 = pairState.latestPriceE8
    out.reporterCount = machine.committee.quorum
    return out

fn OracleBftHistoryRead(state: oracle_types.OraclePairState, back: int32): int32 =
    let raw = state.historyHead - 1 - back
    if raw >= 0:
        return raw
    return raw + oracle_types.OracleHistoryMax

fn OracleBftStateMachineQueryTwap(machine: OracleBftStateMachine,
                                    pairId: oracle_types.OraclePairId,
                                    windowRounds: int32,
                                    nowMs: int64): oracle_types.OracleTwapQueryResult =
    var out = oracle_types.OracleTwapQueryResult()
    out.pairId = pairId
    out.windowRounds = windowRounds
    out.height = machine.lastFinalizedHeight
    out.appHash = OracleBftStateMachineAppHash(machine)
    if !oracle_types.OraclePairValid(pairId):
        out.code = OracleBftCodeBadPair
        return out
    if windowRounds <= 0 || windowRounds > oracle_types.OracleHistoryMax:
        out.code = OracleBftCodeBadWindow
        return out
    let latestRes = OracleBftStateMachineQueryLatest(machine, pairId, nowMs)
    if latestRes.code == OracleBftCodeStale:
        out.code = OracleBftCodeStale
        out.stale = true
        return out
    if latestRes.code != OracleBftCodeOk:
        out.code = latestRes.code
        return out
    let state = machine.pairStates[oracle_types.OraclePairIndex(pairId)]
    if state.historyLen < windowRounds:
        out.code = OracleBftCodeNotFinalized
        return out
    var sum: int64 = int64(0)
    var expectedRound = int64(-1)
    for back in 0..<windowRounds:
        let idx = OracleBftHistoryRead(state, back)
        let roundId = state.historyRoundIds[idx]
        let priceE8 = state.historyPricesE8[idx]
        if back == 0:
            expectedRound = roundId
        else:
            if roundId != expectedRound - int64(1):
                out.code = OracleBftCodeNotFinalized
                return out
            expectedRound = roundId
        if priceE8 <= int64(0):
            out.code = OracleBftCodeNotFinalized
            return out
        sum = sum + priceE8
    out.code = OracleBftCodeOk
    out.available = true
    out.roundId = state.latestRoundId
    out.priceE8 = sum / int64(windowRounds)
    return out
