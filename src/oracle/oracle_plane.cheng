import std/result
import std/system
import std/rawbytes
import std/crypto/ecnist
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256
import cheng/chain/lsmr_types as lt
import cheng/oracle/oracle_types as oracle_types

const
    OracleBatchMagic: str = "cheng.oracle.batch"
    OracleBatchMagicSize: int32 = 18
    OracleSignedBatchWireSize: int32 = 398
    OracleFixedBytes32Size: int32 = 32
    OracleFixedBytes64Size: int32 = 64

type
    OracleSignedBatch =
        version: int32
        committeeSetId: int32
        reporterSlot: int32
        roundId: int64
        observedAtMs: int64
        pricesE8: int64[]
        sig: layout.FixedBytes64
        batchCid: layout.FixedBytes32

fn OracleAppendU32BE(buf: var layout.ByteBuf, value: int64) =
    lt.AppendU32BE(buf, value)

fn OracleAppendI64BE(buf: var layout.ByteBuf, value: int64) =
    OracleAppendU32BE(buf, int32(value >> 32))
    OracleAppendU32BE(buf, int32(value & int64(0xffffffff)))

fn OracleReadU32BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    if offset < 0 || offset + 4 > layout.ByteSpanLen(span):
        return Err[int64](" oracle plane: short u32")
    let b0: int64 = int64(layout.ByteSpanAt(span, offset))
    let b1: int64 = int64(layout.ByteSpanAt(span, offset + 1))
    let b2: int64 = int64(layout.ByteSpanAt(span, offset + 2))
    let b3: int64 = int64(layout.ByteSpanAt(span, offset + 3))
    return Ok[int64]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn OracleReadI64BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    let hiRes = OracleReadU32BE(span, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = OracleReadU32BE(span, offset + 4)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    let hi = Value(hiRes)
    let lo = Value(loRes)
    return Ok[int64]((hi << 32) | (lo & int64(0xffffffff)))

fn OracleReadFixed32(span: layout.ByteSpan, offset: int32): Result[layout.FixedBytes32] =
    if offset < 0 || offset + OracleFixedBytes32Size > layout.ByteSpanLen(span):
        return Err[layout.FixedBytes32](" oracle plane: short fixed32")
    return layout.FixedBytes32FromBytes(layout.ByteSpanToBytes(layout.ByteSpanSlice(span,
                                                                                    offset,
                                                                                    OracleFixedBytes32Size)))

fn OracleReadFixed64(span: layout.ByteSpan, offset: int32): Result[layout.FixedBytes64] =
    if offset < 0 || offset + OracleFixedBytes64Size > layout.ByteSpanLen(span):
        return Err[layout.FixedBytes64](" oracle plane: short fixed64")
    return layout.FixedBytes64FromBytes(layout.ByteSpanToBytes(layout.ByteSpanSlice(span,
                                                                                    offset,
                                                                                    OracleFixedBytes64Size)))

fn OracleSignedBatchShapeValidate(batch: var OracleSignedBatch): Result[bool] =
    if batch.version != oracle_types.OracleVersion:
        return Err[bool](" oracle plane: bad version")
    if batch.committeeSetId <= 0:
        return Err[bool](" oracle plane: bad committee set id")
    if batch.reporterSlot <= 0 || batch.reporterSlot > oracle_types.OracleCommitteeMax:
        return Err[bool](" oracle plane: bad reporter slot")
    if batch.observedAtMs < 0:
        return Err[bool](" oracle plane: bad observed time")
    let expectedRound = oracle_types.OracleRoundIdFromObservedAtMs(batch.observedAtMs)
    if batch.roundId != expectedRound:
        return Err[bool](" oracle plane: bad round id")
    if batch.pricesE8.len != oracle_types.OraclePairCount:
        return Err[bool](" oracle plane: bad pair count")
    for i in 0..<batch.pricesE8.len:
        if batch.pricesE8[i] <= int64(0):
            return Err[bool](" oracle plane: bad price")
    return Ok[bool](true)

fn OracleSignedBatchSignableBytes(batch: var OracleSignedBatch): Result[Bytes] =
    let shapeRes = OracleSignedBatchShapeValidate(batch)
    if IsErr(shapeRes):
        return Err[Bytes](Error(shapeRes))
    var buf: layout.ByteBuf = layout.ByteBufInit(320)
    layout.ByteBufAppendBytes(buf, bytesFromString(OracleBatchMagic))
    OracleAppendU32BE(buf, batch.version)
    OracleAppendU32BE(buf, batch.committeeSetId)
    OracleAppendU32BE(buf, batch.reporterSlot)
    OracleAppendI64BE(buf, batch.roundId)
    OracleAppendI64BE(buf, batch.observedAtMs)
    for i in 0..<oracle_types.OraclePairCount:
        OracleAppendI64BE(buf, batch.pricesE8[i])
    return Ok[Bytes](layout.ByteBufToBytes(buf))

fn OracleSignedBatchCid(batch: var OracleSignedBatch): Result[layout.FixedBytes32] =
    let signableRes = OracleSignedBatchSignableBytes(batch)
    if IsErr(signableRes):
        return Err[layout.FixedBytes32](Error(signableRes))
    var buf: layout.ByteBuf = layout.ByteBufInit(384)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.oracle.batch.cid"))
    layout.ByteBufAppendBytes(buf, Value(signableRes))
    layout.ByteBufAppendBytes(buf, layout.FixedBytes64ToBytes(batch.sig))
    return Ok[layout.FixedBytes32](lt.FixedCidFromBuf(buf))

fn OracleSignedBatchStructuralValidate(batch: var OracleSignedBatch): Result[bool] =
    let shapeRes = OracleSignedBatchShapeValidate(batch)
    if IsErr(shapeRes):
        return Err[bool](Error(shapeRes))
    let cidRes = OracleSignedBatchCid(batch)
    if IsErr(cidRes):
        return Err[bool](Error(cidRes))
    if !layout.FixedBytes32Equal(Value(cidRes), batch.batchCid):
        return Err[bool](" oracle plane: bad batch cid")
    return Ok[bool](true)

fn OracleSignedBatchVerify(batch: var OracleSignedBatch,
                             pubBytes: Bytes): Result[bool] =
    let okRes = OracleSignedBatchStructuralValidate(batch)
    if IsErr(okRes):
        return Err[bool](Error(okRes))
    let signableRes = OracleSignedBatchSignableBytes(batch)
    if IsErr(signableRes):
        return Err[bool](Error(signableRes))
    let sigBytes = layout.FixedBytes64ToBytes(batch.sig)
    let verifyOk = ecnist.ecdsaVerifyTrustedBytes(pubBytes, Value(signableRes), sigBytes)
    if !verifyOk:
        return Err[bool](" oracle plane: bad signature")
    return Ok[bool](true)

fn OracleSignedBatchVerifyAgainstCommittee(batch: var OracleSignedBatch,
                                             committee: var oracle_types.OracleCommitteeConfig): Result[bool] =
    if committee.committeeSetId != batch.committeeSetId:
        return Err[bool](" oracle plane: wrong committee set")
    if batch.reporterSlot <= 0 || batch.reporterSlot > committee.reporterCount:
        return Err[bool](" oracle plane: reporter outside committee")
    let pubBytes = layout.FixedBytes65ToBytes(committee.reporterPubKeys[batch.reporterSlot - 1])
    return OracleSignedBatchVerify(batch, pubBytes)

fn OracleSignedBatchMake(priv: fixed256.Scalar256,
                           committeeSetId: int32,
                           reporterSlot: int32,
                           observedAtMs: int64,
                           pricesE8: int64[]): Result[OracleSignedBatch] =
    var out = OracleSignedBatch()
    out.version = oracle_types.OracleVersion
    out.committeeSetId = committeeSetId
    out.reporterSlot = reporterSlot
    out.roundId = oracle_types.OracleRoundIdFromObservedAtMs(observedAtMs)
    out.observedAtMs = observedAtMs
    out.pricesE8 = []
    for i in 0..<pricesE8.len:
        add(out.pricesE8, pricesE8[i])
    let signableRes = OracleSignedBatchSignableBytes(out)
    if IsErr(signableRes):
        return Err[OracleSignedBatch](Error(signableRes))
    let sigRes = fixed256.p256SignMessageFixed64(priv, Value(signableRes))
    if IsErr(sigRes):
        return Err[OracleSignedBatch](Error(sigRes))
    out.sig = Value(sigRes)
    let cidRes = OracleSignedBatchCid(out)
    if IsErr(cidRes):
        return Err[OracleSignedBatch](Error(cidRes))
    out.batchCid = Value(cidRes)
    let okRes = OracleSignedBatchStructuralValidate(out)
    if IsErr(okRes):
        return Err[OracleSignedBatch](Error(okRes))
    return Ok[OracleSignedBatch](out)

fn OracleSignedBatchEncode(batch: var OracleSignedBatch): Bytes =
    let okRes = OracleSignedBatchStructuralValidate(batch)
    if IsErr(okRes):
        system.panic(Error(okRes))
    var buf: layout.ByteBuf = layout.ByteBufInit(OracleSignedBatchWireSize)
    layout.ByteBufAppendBytes(buf, bytesFromString(OracleBatchMagic))
    OracleAppendU32BE(buf, batch.version)
    OracleAppendU32BE(buf, batch.committeeSetId)
    OracleAppendU32BE(buf, batch.reporterSlot)
    OracleAppendI64BE(buf, batch.roundId)
    OracleAppendI64BE(buf, batch.observedAtMs)
    for i in 0..<oracle_types.OraclePairCount:
        OracleAppendI64BE(buf, batch.pricesE8[i])
    layout.ByteBufAppendBytes(buf, layout.FixedBytes64ToBytes(batch.sig))
    layout.ByteBufAppendBytes(buf, layout.FixedBytes32ToBytes(batch.batchCid))
    return layout.ByteBufToBytes(buf)

fn OracleSignedBatchDecode(payload: Bytes): Result[OracleSignedBatch] =
    let span = layout.ByteSpanFromBytes(payload)
    if layout.ByteSpanLen(span) != OracleSignedBatchWireSize:
        return Err[OracleSignedBatch](" oracle plane: bad payload size")
    let magic = layout.ByteSpanToBytes(layout.ByteSpanSlice(span, 0, OracleBatchMagicSize))
    if bytesLen(magic) != OracleBatchMagicSize:
        return Err[OracleSignedBatch](" oracle plane: short magic")
    for i in 0..<OracleBatchMagicSize:
        if bytesGet(magic, i) != bytesGet(bytesFromString(OracleBatchMagic), i):
            return Err[OracleSignedBatch](" oracle plane: bad magic")
    var offset = OracleBatchMagicSize
    let versionRes = OracleReadU32BE(span, offset)
    if IsErr(versionRes):
        return Err[OracleSignedBatch](Error(versionRes))
    offset = offset + 4
    let committeeRes = OracleReadU32BE(span, offset)
    if IsErr(committeeRes):
        return Err[OracleSignedBatch](Error(committeeRes))
    offset = offset + 4
    let slotRes = OracleReadU32BE(span, offset)
    if IsErr(slotRes):
        return Err[OracleSignedBatch](Error(slotRes))
    offset = offset + 4
    let roundRes = OracleReadI64BE(span, offset)
    if IsErr(roundRes):
        return Err[OracleSignedBatch](Error(roundRes))
    offset = offset + 8
    let observedRes = OracleReadI64BE(span, offset)
    if IsErr(observedRes):
        return Err[OracleSignedBatch](Error(observedRes))
    offset = offset + 8
    var pricesE8: int64[]
    pricesE8 = []
    for i in 0..<oracle_types.OraclePairCount:
        let priceRes = OracleReadI64BE(span, offset)
        if IsErr(priceRes):
            return Err[OracleSignedBatch](Error(priceRes))
        add(pricesE8, Value(priceRes))
        offset = offset + 8
    let sigRes = OracleReadFixed64(span, offset)
    if IsErr(sigRes):
        return Err[OracleSignedBatch](Error(sigRes))
    offset = offset + OracleFixedBytes64Size
    let cidRes = OracleReadFixed32(span, offset)
    if IsErr(cidRes):
        return Err[OracleSignedBatch](Error(cidRes))
    var out = OracleSignedBatch()
    out.version = int32(Value(versionRes))
    out.committeeSetId = int32(Value(committeeRes))
    out.reporterSlot = int32(Value(slotRes))
    out.roundId = Value(roundRes)
    out.observedAtMs = Value(observedRes)
    out.pricesE8 = pricesE8
    out.sig = Value(sigRes)
    out.batchCid = Value(cidRes)
    let okRes = OracleSignedBatchStructuralValidate(out)
    if IsErr(okRes):
        return Err[OracleSignedBatch](Error(okRes))
    return Ok[OracleSignedBatch](out)

fn OracleSignedBatchValidatePayload(payload: Bytes,
                                      expectedCid: layout.FixedBytes32): Result[bool] =
    let batchRes = OracleSignedBatchDecode(payload)
    if IsErr(batchRes):
        return Err[bool](Error(batchRes))
    let batch = Value(batchRes)
    if !layout.FixedBytes32Equal(batch.batchCid, expectedCid):
        return Err[bool](" oracle plane: payload cid mismatch")
    return Ok[bool](true)
