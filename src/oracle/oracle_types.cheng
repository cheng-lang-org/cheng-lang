import std/result
import cheng/std/bytes_layout as layout

const
    OracleVersion: int32 = 1

    OracleAssetBtc: int32 = 1
    OracleAssetEth: int32 = 2
    OracleAssetSol: int32 = 3
    OracleAssetBnb: int32 = 4
    OracleAssetXau: int32 = 5
    OracleAssetXag: int32 = 6
    OracleAssetXpt: int32 = 7
    OracleAssetXpd: int32 = 8
    OracleAssetCount: int32 = 8

    OracleQuoteUsd: int32 = 1
    OracleQuoteCny: int32 = 2
    OracleQuoteEur: int32 = 3
    OracleQuoteHkd: int32 = 4
    OracleQuoteCount: int32 = 4

    OraclePairCount: int32 = 32

    OracleCommitteeMax: int32 = 16
    OracleDefaultReporterCount: int32 = 7
    OracleDefaultQuorum: int32 = 5

    OraclePendingRoundMax: int32 = 8
    OracleHistoryMax: int32 = 60
    OraclePendingPriceSlotCount: int32 = 512

    OracleRoundMs: int64 = 60000
    OracleStaleRoundThreshold: int64 = 2

type
    OracleAssetId = int32
    OracleQuoteId = int32
    OraclePairId = int32

    OracleCommitteeConfig =
        committeeSetId: int32
        reporterCount: int32
        quorum: int32
        reporterPubKeys: layout.FixedBytes65[OracleCommitteeMax]

    OraclePairState =
        available: bool
        latestRoundId: int64
        latestPriceE8: int64
        historyLen: int32
        historyHead: int32
        historyRoundIds: int64[OracleHistoryMax]
        historyPricesE8: int64[OracleHistoryMax]

    OracleLatestQueryResult =
        code: int32
        available: bool
        stale: bool
        pairId: OraclePairId
        roundId: int64
        priceE8: int64
        reporterCount: int32
        height: int64
        appHash: layout.FixedBytes32

    OracleTwapQueryResult =
        code: int32
        available: bool
        stale: bool
        pairId: OraclePairId
        windowRounds: int32
        roundId: int64
        priceE8: int64
        height: int64
        appHash: layout.FixedBytes32

fn OracleAssetValid(assetId: OracleAssetId): bool =
    if assetId < OracleAssetBtc:
        return false
    if assetId > OracleAssetXpd:
        return false
    return true

fn OracleQuoteValid(quoteId: OracleQuoteId): bool =
    if quoteId < OracleQuoteUsd:
        return false
    if quoteId > OracleQuoteHkd:
        return false
    return true

fn OraclePairValid(pairId: OraclePairId): bool =
    if pairId <= 0:
        return false
    if pairId > OraclePairCount:
        return false
    return true

fn OraclePairIdFromAssetQuote(assetId: OracleAssetId,
                                quoteId: OracleQuoteId): Result[OraclePairId] =
    if !OracleAssetValid(assetId):
        return Err[OraclePairId](" oracle: invalid asset id")
    if !OracleQuoteValid(quoteId):
        return Err[OraclePairId](" oracle: invalid quote id")
    return Ok[OraclePairId](((assetId - 1) * OracleQuoteCount) + quoteId)

fn OraclePairIndex(pairId: OraclePairId): int32 =
    return pairId - 1

fn OracleRoundIdFromObservedAtMs(observedAtMs: int64): int64 =
    if observedAtMs < 0:
        return int64(-1)
    return observedAtMs / OracleRoundMs

fn OracleRoundStartMs(roundId: int64): int64 =
    return roundId * OracleRoundMs

fn OracleRoundEndMs(roundId: int64): int64 =
    return (roundId + int64(1)) * OracleRoundMs

fn OracleCommitteeConfigMake(committeeSetId: int32,
                               reporterPubKeys: layout.FixedBytes65[],
                               quorum: int32): Result[OracleCommitteeConfig] =
    if committeeSetId <= 0:
        return Err[OracleCommitteeConfig](" oracle: invalid committee set id")
    if reporterPubKeys.len <= 0:
        return Err[OracleCommitteeConfig](" oracle: empty committee")
    if reporterPubKeys.len > OracleCommitteeMax:
        return Err[OracleCommitteeConfig](" oracle: committee overflow")
    if quorum <= 0:
        return Err[OracleCommitteeConfig](" oracle: invalid quorum")
    if quorum > reporterPubKeys.len:
        return Err[OracleCommitteeConfig](" oracle: quorum overflow")
    var out = OracleCommitteeConfig()
    out.committeeSetId = committeeSetId
    out.reporterCount = reporterPubKeys.len
    out.quorum = quorum
    for i in 0..<reporterPubKeys.len:
        out.reporterPubKeys[i] = reporterPubKeys[i]
    return Ok[OracleCommitteeConfig](out)
