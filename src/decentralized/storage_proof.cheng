import std/times
import std/strings

type
    StorageProof =
        proofId: str
        providerId: str
        packageId: str
        cidText: str
        bytes: int64
        status: str
        proofHash: str
        epoch: int32
        note: str
        ts: str

fn storageProofTs(): str =
    return int64ToStr(times.EpochTimeSeconds())

fn normalizeStatus(text: str): str =
    if len(text) == 0:
        return "ok"
    if text == "ok" || text == "missing":
        return text
    return text

fn buildStorageProofId(ev: StorageProof): str =
    let payload = ev.providerId + "|" + ev.packageId + "|" + ev.cidText + "|" +
        ev.status + "|" + intToStr(ev.epoch) + "|" + ev.ts
    return "proof-" + intToStr(int32(len(payload)))

fn normalizeStorageProof(ev: StorageProof): StorageProof =
    var out = ev
    out.status = normalizeStatus(out.status)
    if len(out.ts) == 0:
        out.ts = storageProofTs()
    if len(out.proofId) == 0:
        out.proofId = buildStorageProofId(out)
    return out

fn StorageProofTs(): str =
    return storageProofTs()

fn NormalizeStatus(text: str): str =
    return normalizeStatus(text)

fn BuildStorageProofId(ev: StorageProof): str =
    return buildStorageProofId(ev)

fn NormalizeStorageProof(ev: StorageProof): StorageProof =
    return normalizeStorageProof(ev)

fn NormalizeStorageProofId(providerId: str,
                           packageId: str,
                           cidText: str,
                           epoch: int32): str =
    var ev: StorageProof
    ev.providerId = providerId
    ev.packageId = packageId
    ev.cidText = cidText
    ev.epoch = epoch
    ev.status = normalizeStatus(ev.status)
    if len(ev.ts) == 0:
        ev.ts = storageProofTs()
    if len(ev.proofId) == 0:
        ev.proofId = buildStorageProofId(ev)
    return ev.proofId
