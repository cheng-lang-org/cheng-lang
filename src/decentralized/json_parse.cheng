import runtime/json_ast as json
import std/strings

type
    JsonParser =
        text: str
        pos: int32
        length: int32
        error: str

    ParseResult =
        ok: bool
        value: json.JsonNode
        error: str

const
    jsonByteQuote = 34
    jsonByteComma = 44
    jsonBytePlus = 43
    jsonByteMinus = 45
    jsonByteDot = 46
    jsonByteZero = 48
    jsonByteNine = 57
    jsonByteColon = 58
    jsonByteOpenBracket = 91
    jsonByteBackslash = 92
    jsonByteCloseBracket = 93
    jsonByteUpperE = 69
    jsonByteOpenBrace = 123
    jsonByteCloseBrace = 125
    jsonByteSpace = 32
    jsonByteTab = 9
    jsonByteLf = 10
    jsonByteCr = 13
    jsonByteLowerE = 101
    jsonByteLowerN = 110
    jsonByteLowerR = 114
    jsonByteLowerT = 116

fn parserInit(text: str): JsonParser =
    var out: JsonParser
    out.text = text
    out.length = len(text)
    return out

fn parserFail(p: var JsonParser, msg: str) =
    if len(p.error) <= 0:
        p.error = msg

fn parserPeekByte(p: JsonParser): int32 =
    if p.pos >= p.length:
        return 0
    return int32(p.text[p.pos])

fn parserNextByte(p: var JsonParser): int32 =
    if p.pos >= p.length:
        return 0
    let out: int32 = int32(p.text[p.pos])
    p.pos = p.pos + 1
    return out

fn parserByteText(p: JsonParser, pos: int32): str =
    if pos < 0:
        return ""
    if pos >= p.length:
        return ""
    return strings.SliceBytes(p.text, pos, 1)

fn skipWhitespace(p: var JsonParser) =
    while p.pos < p.length:
        let b: int32 = parserPeekByte(p)
        if b == jsonByteSpace:
            p.pos = p.pos + 1
        else:
            if b == jsonByteLf:
                p.pos = p.pos + 1
            else:
                if b == jsonByteCr:
                    p.pos = p.pos + 1
                else:
                    if b == jsonByteTab:
                        p.pos = p.pos + 1
                    else:
                        return

fn isDigitByte(b: int32): bool =
    if b < jsonByteZero:
        return false
    if b > jsonByteNine:
        return false
    return true

fn parseValue(p: var JsonParser): json.JsonNode

fn parseString(p: var JsonParser): str =
    if parserPeekByte(p) != jsonByteQuote:
        parserFail(p, "expected string")
        return ""
    let _open: int32 = parserNextByte(p)
    _open
    var out: str
    while p.pos < p.length:
        let chPos: int32 = p.pos
        let b: int32 = parserNextByte(p)
        if b == jsonByteQuote:
            return out
        if b == jsonByteBackslash:
            if p.pos >= p.length:
                parserFail(p, "unterminated string escape")
                return out
            let esc: int32 = parserNextByte(p)
            if esc == jsonByteQuote:
                out = out + "\""
            else:
                if esc == jsonByteBackslash:
                    out = out + "\\"
                else:
                    if esc == jsonByteLowerN:
                        out = out + "\n"
                    else:
                        if esc == jsonByteLowerR:
                            out = out + "\r"
                        else:
                            if esc == jsonByteLowerT:
                                out = out + "\t"
                            else:
                                out = out + parserByteText(p, p.pos - 1)
        else:
            out = out + parserByteText(p, chPos)
    parserFail(p, "unterminated string")
    return out

fn parseNumber(p: var JsonParser): json.JsonNode =
    var negative: bool
    if parserPeekByte(p) == jsonByteMinus:
        negative = true
        let _minus: int32 = parserNextByte(p)
        _minus

    var intPart: int64
    var intDigits: int32
    while true:
        let b: int32 = parserPeekByte(p)
        if !isDigitByte(b):
            break
        let _digit: int32 = parserNextByte(p)
        _digit
        intPart = intPart * int64(10) + int64(b - jsonByteZero)
        intDigits = intDigits + 1

    var hasFrac: bool
    var fracPart: int64
    var fracDiv: int64 = 1
    var fracDigits: int32
    if parserPeekByte(p) == jsonByteDot:
        hasFrac = true
        let _dot: int32 = parserNextByte(p)
        _dot
        while true:
            let b: int32 = parserPeekByte(p)
            if !isDigitByte(b):
                break
            let _digit: int32 = parserNextByte(p)
            _digit
            fracPart = fracPart * int64(10) + int64(b - jsonByteZero)
            fracDiv = fracDiv * int64(10)
            fracDigits = fracDigits + 1
        if fracDigits <= 0:
            parserFail(p, "invalid fraction")
            return json.NewJInt(0)

    if intDigits <= 0 && fracDigits <= 0:
        parserFail(p, "invalid number")
        return json.NewJInt(0)

    var hasExp: bool
    var expNegative: bool
    var expValue: int32
    if parserPeekByte(p) == jsonByteLowerE || parserPeekByte(p) == jsonByteUpperE:
        hasExp = true
        let _exp: int32 = parserNextByte(p)
        _exp
        if parserPeekByte(p) == jsonBytePlus:
            let _plus: int32 = parserNextByte(p)
            _plus
        else:
            if parserPeekByte(p) == jsonByteMinus:
                expNegative = true
                let _minus: int32 = parserNextByte(p)
                _minus
        var expDigits: int32
        while true:
            let b: int32 = parserPeekByte(p)
            if !isDigitByte(b):
                break
            let _digit: int32 = parserNextByte(p)
            _digit
            expValue = expValue * 10 + int32(b - jsonByteZero)
            expDigits = expDigits + 1
        if expDigits <= 0:
            parserFail(p, "invalid exponent")
            return json.NewJInt(0)

    if !hasFrac && !hasExp:
        if negative:
            return json.NewJInt(0 - intPart)
        return json.NewJInt(intPart)

    var value: float64 = float64(intPart)
    if fracDiv > 1:
        value = value + float64(fracPart) / float64(fracDiv)
    if hasExp:
        var remaining: int32 = expValue
        if expNegative:
            while remaining > 0:
                value = value / float64(int32(10))
                remaining = remaining - 1
        else:
            while remaining > 0:
                value = value * float64(int32(10))
                remaining = remaining - 1
    if negative:
        value = float64(int32(0)) - value
    return json.NewJFloat(value)

fn consumeLiteral(p: var JsonParser, lit: str): bool =
    var i: int32
    while i < len(lit):
        if parserPeekByte(p) != int32(lit[i]):
            return false
        let _b: int32 = parserNextByte(p)
        _b
        i = i + 1
    return true

fn parseArray(p: var JsonParser): json.JsonNode =
    if parserPeekByte(p) != jsonByteOpenBracket:
        parserFail(p, "expected '['")
        return json.NewJArray()
    let _open: int32 = parserNextByte(p)
    _open
    var out: json.JsonNode = json.NewJArray()
    skipWhitespace(p)
    if parserPeekByte(p) == jsonByteCloseBracket:
        let _close: int32 = parserNextByte(p)
        _close
        return out
    var done: bool
    while !done:
        let item: json.JsonNode = parseValue(p)
        add(out.a, item)
        skipWhitespace(p)
        let b: int32 = parserPeekByte(p)
        if b == jsonByteComma:
            let _comma: int32 = parserNextByte(p)
            _comma
            skipWhitespace(p)
        else:
            if b == jsonByteCloseBracket:
                let _close: int32 = parserNextByte(p)
                _close
                done = true
            else:
                parserFail(p, "expected ',' or ']'")
                return out
    return out

fn parseObject(p: var JsonParser): json.JsonNode =
    if parserPeekByte(p) != jsonByteOpenBrace:
        parserFail(p, "expected '{'")
        return json.NewJObject()
    let _open: int32 = parserNextByte(p)
    _open
    var out: json.JsonNode = json.NewJObject()
    skipWhitespace(p)
    if parserPeekByte(p) == jsonByteCloseBrace:
        let _close: int32 = parserNextByte(p)
        _close
        return out
    var done: bool
    while !done:
        skipWhitespace(p)
        let key: str = parseString(p)
        skipWhitespace(p)
        if parserPeekByte(p) != jsonByteColon:
            parserFail(p, "expected ':'")
            return out
        let _colon: int32 = parserNextByte(p)
        _colon
        skipWhitespace(p)
        let value: json.JsonNode = parseValue(p)
        json.JsonSetField(out, key, value)
        skipWhitespace(p)
        let b: int32 = parserPeekByte(p)
        if b == jsonByteComma:
            let _comma: int32 = parserNextByte(p)
            _comma
            skipWhitespace(p)
        else:
            if b == jsonByteCloseBrace:
                let _close: int32 = parserNextByte(p)
                _close
                done = true
            else:
                parserFail(p, "expected ',' or '}'")
                return out
    return out

fn parseValue(p: var JsonParser): json.JsonNode =
    skipWhitespace(p)
    let b: int32 = parserPeekByte(p)
    if b == jsonByteQuote:
        return json.NewJString(parseString(p))
    if b == jsonByteOpenBrace:
        return parseObject(p)
    if b == jsonByteOpenBracket:
        return parseArray(p)
    if b == jsonByteMinus:
        return parseNumber(p)
    if isDigitByte(b):
        return parseNumber(p)
    if consumeLiteral(p, "true"):
        return json.NewJBool(true)
    if consumeLiteral(p, "false"):
        return json.NewJBool(false)
    if consumeLiteral(p, "null"):
        return json.NewJNull()
    parserFail(p, "unexpected token")
    return json.NewJNull()

fn parseJsonSafe(content: str): ParseResult =
    var res: ParseResult
    if len(content) == 0:
        res.ok = false
        res.error = "empty input"
        return res
    var p: JsonParser = parserInit(content)
    let node: json.JsonNode = parseValue(p)
    skipWhitespace(p)
    if p.pos < p.length:
        parserFail(p, "trailing data")
    if len(p.error) > 0:
        res.ok = false
        res.error = p.error
        return res
    res.ok = true
    res.value = node
    return res

fn hasField(node: json.JsonNode, key: str): bool =
    return json.HasKey(node, key)

fn getStringField(node: json.JsonNode, key: str, fallback: str): str =
    if !json.HasKey(node, key):
        return fallback
    let value: json.JsonNode = json.JsonGetField(node, key)
    if value.kind == json.JString:
        let text: str = json.GetStr(value)
        if len(text) == 0:
            return text
        return "" + text
    return fallback

fn getFloatField(node: json.JsonNode, key: str, fallback: float64): float64 =
    if !json.HasKey(node, key):
        return fallback
    let value: json.JsonNode = json.JsonGetField(node, key)
    if value.kind == json.JFloat:
        return json.GetFloat(value)
    if value.kind == json.JInt:
        return float64(json.GetInt(value))
    return fallback

fn getIntField(node: json.JsonNode, key: str, fallback: int64): int64 =
    if !json.HasKey(node, key):
        return fallback
    let value: json.JsonNode = json.JsonGetField(node, key)
    if value.kind == json.JInt:
        return json.GetInt(value)
    if value.kind == json.JFloat:
        return int64(json.GetFloat(value))
    return fallback

fn getBoolField(node: json.JsonNode, key: str, fallback: bool): bool =
    if !json.HasKey(node, key):
        return fallback
    let value: json.JsonNode = json.JsonGetField(node, key)
    if value.kind == json.JBool:
        return json.GetBool(value)
    return fallback

fn HasField(node: json.JsonNode, key: str): bool =
    return hasField(node, key)

fn GetStringField(node: json.JsonNode, key: str, fallback: str): str =
    return getStringField(node, key, fallback)

fn GetFloatField(node: json.JsonNode, key: str, fallback: float64): float64 =
    return getFloatField(node, key, fallback)

fn GetIntField(node: json.JsonNode, key: str, fallback: int64): int64 =
    return getIntField(node, key, fallback)

fn GetBoolField(node: json.JsonNode, key: str, fallback: bool): bool =
    return getBoolField(node, key, fallback)

fn ParseJsonSafe(content: str): ParseResult =
    return parseJsonSafe(content)
