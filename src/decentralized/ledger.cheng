    node["author_id"] = json.NewJString(usage.authorId)
    node["executor_id"] = json.NewJString(usage.executorId)
    node["cpu_ms"] = json.NewJInt(usage.cpuMs)
    node["mem_bytes"] = json.NewJInt(usage.memBytes)
