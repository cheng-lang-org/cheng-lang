import std/buffer
import std/result
import std/rawbytes
import cheng/qpack/min as qpack
import cheng/quic/core/quic_varint as qvarint

type
    Http3Frame =
        kind: int64
        payload: Bytes

    Http3FrameDecoded =
        frame: Http3Frame
        next: int32

    Http3Setting =
        id: int64
        value: int64

    Http3Preamble =
        control: Bytes
        qpackEncoder: Bytes
        qpackDecoder: Bytes

const
    Http3FrameData = 0
    Http3FrameHeaders = 1
    Http3FrameCancelPush = 3
    Http3FrameSettings = 4
    Http3FramePushPromise = 5
    Http3FrameGoaway = 7
    Http3FrameMaxPushId = 13
    Http3UniStreamControl = 0
    Http3UniStreamPush = 1
    Http3UniStreamQpackEncoder = 2
    Http3UniStreamQpackDecoder = 3
    Http3SettingQpackMaxTableCapacity = 1
    Http3SettingMaxFieldSectionSize = 6
    Http3SettingQpackBlockedStreams = 7

fn Http3MakeFrame(kind: int64, payload: Bytes): Http3Frame =
    var out: Http3Frame
    out.kind = kind
    out.payload = payload
    return out

fn Http3EncodeFrame(frame: Http3Frame): Result[Bytes] =
    var out = buffer.newByteBuffer()
    let kindRes: Result[Bytes] = qvarint.quicVarIntEncode(frame.kind)
    if IsErr(kindRes):
        return Err[Bytes](ErrorText(kindRes))
    let lenRes: Result[Bytes] = qvarint.quicVarIntEncode(int64(bytesLen(frame.payload)))
    if IsErr(lenRes):
        return Err[Bytes](ErrorText(lenRes))
    buffer.appendBytes(out, Value(kindRes))
    buffer.appendBytes(out, Value(lenRes))
    if bytesLen(frame.payload) > 0:
        buffer.appendBytes(out, frame.payload)
    return Ok[Bytes](buffer.toBytes(out))

fn Http3DecodeFrame(data: Bytes, offset: int32): Result[Http3FrameDecoded] =
    let kindRes: Result[qvarint.QuicVarIntDecoded] = qvarint.quicVarIntDecode(data, offset)
    if IsErr(kindRes):
        return Err[Http3FrameDecoded](ErrorText(kindRes))
    let lenRes: Result[qvarint.QuicVarIntDecoded] = qvarint.quicVarIntDecode(data, Value(kindRes).next)
    if IsErr(lenRes):
        return Err[Http3FrameDecoded](ErrorText(lenRes))
    let payloadLen: int32 = int32(Value(lenRes).value)
    if payloadLen < 0 || Value(lenRes).next + payloadLen > bytesLen(data):
        return Err[Http3FrameDecoded]("http3: frame truncated")
    let payload: Bytes = bytesSlice(data, Value(lenRes).next, payloadLen)
    var out: Http3FrameDecoded
    out.frame = Http3MakeFrame(Value(kindRes).value, payload)
    out.next = Value(lenRes).next + payloadLen
    return Ok[Http3FrameDecoded](out)

fn Http3EncodeSettingsPayload(entries: Http3Setting[]): Result[Bytes] =
    var out = buffer.newByteBuffer()
    for i in 0..<entries.len:
        let idRes: Result[Bytes] = qvarint.quicVarIntEncode(entries[i].id)
        if IsErr(idRes):
            return Err[Bytes](ErrorText(idRes))
        let valueRes: Result[Bytes] = qvarint.quicVarIntEncode(entries[i].value)
        if IsErr(valueRes):
            return Err[Bytes](ErrorText(valueRes))
        buffer.appendBytes(out, Value(idRes))
        buffer.appendBytes(out, Value(valueRes))
    return Ok[Bytes](buffer.toBytes(out))

fn Http3DecodeSettingsPayload(data: Bytes): Result[Http3Setting[]] =
    var out: Http3Setting[]
    var idx: int32
    while idx < bytesLen(data):
        let idRes: Result[qvarint.QuicVarIntDecoded] = qvarint.quicVarIntDecode(data, idx)
        if IsErr(idRes):
            return Err[Http3Setting[]](ErrorText(idRes))
        let valueRes: Result[qvarint.QuicVarIntDecoded] = qvarint.quicVarIntDecode(data, Value(idRes).next)
        if IsErr(valueRes):
            return Err[Http3Setting[]](ErrorText(valueRes))
        add(out, Http3Setting(id: Value(idRes).value, value: Value(valueRes).value))
        idx = Value(valueRes).next
    return Ok[Http3Setting[]](out)

fn Http3EncodeSettingsFrame(entries: Http3Setting[]): Result[Bytes] =
    let payloadRes: Result[Bytes] = Http3EncodeSettingsPayload(entries)
    if IsErr(payloadRes):
        return Err[Bytes](ErrorText(payloadRes))
    return Http3EncodeFrame(Http3MakeFrame(Http3FrameSettings, Value(payloadRes)))

fn Http3DecodeSettingsFramePayload(payload: Bytes): Result[Http3Setting[]] =
    return Http3DecodeSettingsPayload(payload)

fn Http3EncodeHeadersFrame(fields: qpack.QpackHeaderField[]): Result[Bytes] =
    let blockRes: Result[Bytes] = qpack.QpackEncodeLiteralFieldSection(fields)
    if IsErr(blockRes):
        return Err[Bytes](ErrorText(blockRes))
    return Http3EncodeFrame(Http3MakeFrame(Http3FrameHeaders, Value(blockRes)))

fn Http3DecodeHeadersFramePayload(payload: Bytes): Result[qpack.QpackFieldSection] =
    return qpack.QpackDecodeLiteralFieldSection(payload)

fn Http3EncodeUnidirectionalStream(streamType: int64, payload: Bytes): Result[Bytes] =
    let typeRes: Result[Bytes] = qvarint.quicVarIntEncode(streamType)
    if IsErr(typeRes):
        return Err[Bytes](ErrorText(typeRes))
    var out = buffer.newByteBuffer()
    buffer.appendBytes(out, Value(typeRes))
    if bytesLen(payload) > 0:
        buffer.appendBytes(out, payload)
    return Ok[Bytes](buffer.toBytes(out))

fn Http3EncodeClientPreamble(settings: Http3Setting[]): Result[Http3Preamble] =
    let controlFrameRes: Result[Bytes] = Http3EncodeSettingsFrame(settings)
    if IsErr(controlFrameRes):
        return Err[Http3Preamble](ErrorText(controlFrameRes))
    let controlRes: Result[Bytes] = Http3EncodeUnidirectionalStream(Http3UniStreamControl, Value(controlFrameRes))
    if IsErr(controlRes):
        return Err[Http3Preamble](ErrorText(controlRes))
    let encoderRes: Result[Bytes] = Http3EncodeUnidirectionalStream(Http3UniStreamQpackEncoder, emptyBytes())
    if IsErr(encoderRes):
        return Err[Http3Preamble](ErrorText(encoderRes))
    let decoderRes: Result[Bytes] = Http3EncodeUnidirectionalStream(Http3UniStreamQpackDecoder, emptyBytes())
    if IsErr(decoderRes):
        return Err[Http3Preamble](ErrorText(decoderRes))
    var out: Http3Preamble
    out.control = Value(controlRes)
    out.qpackEncoder = Value(encoderRes)
    out.qpackDecoder = Value(decoderRes)
    return Ok[Http3Preamble](out)

fn Http3MakeSetting(id: int64, value: int64): Http3Setting =
    return Http3Setting(id: id, value: value)
