import tooling/cheng_tooling_selfhost_bootstrap_args as tselfboot
import tooling/cheng_tooling_selfhost_types as tselftypes

fn toolingSelfhostExecBoolText(v: bool): str =
    if v:
        return "1"
    return "0"

fn toolingSelfhostBootstrapVerifyUsageLines(): str[] =
    return tselfboot.toolingSelfhostBootstrapVerifyUsageLines()

fn toolingSelfhostStrictInmemWitnessUsageLines(): str[] =
    return tselfboot.toolingSelfhostStrictInmemWitnessUsageLines()

fn toolingSelfhostInnerLoopUsageLines(): str[] =
    return tselfboot.toolingSelfhostInnerLoopUsageLines()

fn toolingSelfhostStrictInmemWitnessSuccessLines(res: tselftypes.ToolingSelfhostResult): str[] =
    var out: str[] = []
    add(out, "selfhost_inmem_witness_mode=" + res.mode)
    add(out, "selfhost_inmem_witness_stage0=" + res.stage0Path)
    add(out, "selfhost_inmem_witness_stage0_driver_kind=" + res.stage0DriverKind)
    add(out, "selfhost_inmem_witness_stage1=" + res.stage1Path)
    add(out, "selfhost_inmem_witness_stage1_status=" + res.stage1Status)
    add(out, "selfhost_inmem_witness_total_ms=" + intToStr(int32(res.totalMs)))
    return out

fn toolingSelfhostInnerLoopReportLines(res: tselftypes.ToolingSelfhostInnerLoopResult): str[] =
    var out: str[] = []
    let inmemRes: tselftypes.ToolingSelfhostResult = res.inmemRes
    let strictRes: tselftypes.ToolingSelfhostResult = res.strictRes
    add(out, "selfhost_inner_loop_out_dir=" + res.outDir)
    add(out, "selfhost_inner_loop_timing=" + res.timingPath)
    add(out, "selfhost_inner_loop_summary=" + res.summaryPath)
    add(out, "selfhost_inner_loop_build_driver=" + res.buildDriverPath)
    add(out, "selfhost_inner_loop_build_driver_ms=" + intToStr(int32(res.buildMs)))
    add(out, "selfhost_inner_loop_build_driver_rc=" + intToStr(res.buildRc))
    add(out, "selfhost_inner_loop_inmem_requested=" + toolingSelfhostExecBoolText(res.inmemRequested))
    if inmemRes != nil:
        add(out, "selfhost_inner_loop_inmem_stage1=" + inmemRes.stage1Path)
        add(out, "selfhost_inner_loop_inmem_total_ms=" + intToStr(int32(inmemRes.totalMs)))
    add(out, "selfhost_inner_loop_strict_requested=" + toolingSelfhostExecBoolText(res.strictRequested))
    if strictRes != nil:
        add(out, "selfhost_inner_loop_strict_stage2=" + strictRes.stage2Path)
        add(out, "selfhost_inner_loop_strict_stage3=" + strictRes.stage3Path)
        add(out, "selfhost_inner_loop_strict_total_ms=" + intToStr(int32(strictRes.totalMs)))
        add(out, "selfhost_inner_loop_strict_fixed_point_ok=" + toolingSelfhostExecBoolText(strictRes.fixedPointOk))
    add(out, "selfhost_inner_loop_closure_requested=" + toolingSelfhostExecBoolText(res.closureRequested))
    add(out, "selfhost_inner_loop_closure_rc=" + intToStr(res.closureRc))
    add(out, "selfhost_inner_loop_total_ms=" + intToStr(int32(res.totalMs)))
    if !res.ok:
        add(out, "selfhost_inner_loop_ok=0")
        add(out, "selfhost_inner_loop_failed_step=" + res.failedStep)
        return out
    add(out, "selfhost_inner_loop_ok=1")
    return out

fn toolingSelfhostBootstrapWitnessPreludeLines(res: tselftypes.ToolingSelfhostResult): str[] =
    var out: str[] = []
    add(out, "selfhost_strict_inmem_witness_ok=1")
    add(out, "selfhost_strict_inmem_witness_stage1=" + res.stage1Path)
    add(out, "selfhost_strict_inmem_witness_total_ms=" + intToStr(int32(res.totalMs)))
    return out

fn toolingSelfhostBootstrapVerifySuccessLines(mode: str, res: tselftypes.ToolingSelfhostResult): str[] =
    var out: str[] = []
    add(out, "selfhost_bootstrap_mode=" + mode)
    add(out, "selfhost_bootstrap_stage1=" + res.stage1Path)
    add(out, "selfhost_bootstrap_stage2=" + res.stage2Path)
    add(out, "selfhost_bootstrap_stage0=" + res.stage0Path)
    add(out, "selfhost_bootstrap_stage0_driver_kind=" + res.stage0DriverKind)
    add(out, "selfhost_bootstrap_stage1_status=" + res.stage1Status)
    add(out, "selfhost_bootstrap_stage1_compile_mode=" + res.stage1CompileMode)
    add(out, "selfhost_bootstrap_stage1_rebuild_ok=" + toolingSelfhostExecBoolText(res.stage1RebuildOk))
    add(out, "selfhost_bootstrap_fallback_used=" + toolingSelfhostExecBoolText(res.fallbackUsed))
    add(out, "selfhost_bootstrap_quarantine_cleaned=" + intToStr(res.quarantineCleaned))
    add(out, "selfhost_bootstrap_lock_wait_ms=" + intToStr(res.lockWaitMs))
    add(out, "selfhost_bootstrap_strict_rebuild_ok=" + toolingSelfhostExecBoolText(res.strictRebuildOk))
    if mode == "strict":
        add(out, "selfhost_bootstrap_stage3=" + res.stage3Path)
        add(out, "selfhost_bootstrap_stage2_sha256=" + res.stage2Sha256)
        add(out, "selfhost_bootstrap_stage3_sha256=" + res.stage3Sha256)
        add(out, "selfhost_bootstrap_fixed_point_ok=" + toolingSelfhostExecBoolText(res.fixedPointOk))
        add(out, "selfhost_bootstrap_strict_mismatch_report=" + res.strictMismatchReport)
        add(out, "stage2_sha256=" + res.stage2Sha256)
        add(out, "stage3_sha256=" + res.stage3Sha256)
        add(out, "fixed_point_ok=" + toolingSelfhostExecBoolText(res.fixedPointOk))
    add(out, "selfhost_bootstrap_total_ms=" + intToStr(int32(res.totalMs)))
    return out

fn toolingSelfhostBootstrapVerifyStrictFailureLines(res: tselftypes.ToolingSelfhostResult): str[] =
    var out: str[] = []
    if len(res.stage2Sha256) > 0:
        add(out, "cheng_tooling: stage2_sha256=" + res.stage2Sha256)
    if len(res.stage3Sha256) > 0:
        add(out, "cheng_tooling: stage3_sha256=" + res.stage3Sha256)
    if len(res.strictMismatchReport) > 0:
        add(out, "cheng_tooling: strict_mismatch_report=" + res.strictMismatchReport)
    return out
