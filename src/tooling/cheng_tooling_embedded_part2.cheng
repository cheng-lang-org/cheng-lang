# Auto-generated split embedded tooling command payload map part.
import std/seqs
import std/strutils as strutil

fn toolingEmbeddedJoinChunks(chunks: str[]): str =
    return strutil.join(chunks, "")

fn toolingEmbeddedScriptIdsPart2(): str[] =
    var out: str[] = []
    add(out, "cheng_rwad_bridge")
    add(out, "cheng_tooling")
    add(out, "chengb")
    add(out, "chengc")
    add(out, "chengc_daemon")
    add(out, "cleanup_backend_obj_like_artifacts")
