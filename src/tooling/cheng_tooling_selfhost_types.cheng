type
    ToolingSelfhostResult = ref
        ok: bool
        message: str
        totalMs: int64
        mode: str
        stage1Path: str
        stage2Path: str
        stage3Path: str
        stage0Path: str
        stage0DriverKind: str
        stage1Status: str
        stage1CompileMode: str
        stage1RebuildOk: bool
        fallbackUsed: bool
        quarantineCleaned: int32
        lockWaitMs: int32
        strictRebuildOk: bool
        stage2Sha256: str
        stage3Sha256: str
        fixedPointOk: bool
        strictMismatchReport: str
        stage1CompileMs: int64
        stage1SanityMs: int64
        stage1CompileAttempts: int32
        stage1CompileSegfaults: int32

    ToolingSelfhostInnerLoopResult = ref
        ok: bool
        message: str
        totalMs: int64
        outDir: str
        summaryPath: str
        timingPath: str
        buildDriverPath: str
        buildMs: int64
        buildRc: int32
        inmemRequested: bool
        inmemMs: int64
        inmemRes: ToolingSelfhostResult
        strictRequested: bool
        strictMs: int64
        strictRes: ToolingSelfhostResult
        closureRequested: bool
        closureMs: int64
        closureRc: int32
        failedStep: str

fn toolingNewSelfhostResult(): ToolingSelfhostResult =
    var result: ToolingSelfhostResult = new(ToolingSelfhostResult)
    return result

fn toolingNewSelfhostInnerLoopResult(): ToolingSelfhostInnerLoopResult =
    var result: ToolingSelfhostInnerLoopResult = new(ToolingSelfhostInnerLoopResult)
    return result
