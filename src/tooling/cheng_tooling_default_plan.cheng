import std/os
import std/strutils as strutil

type
    ToolingVerifyDefaultPlan = ref
        steps: str[]
        runNoRootBuildArtifacts: bool
        runBackendClosedloop: bool
        runBackendProdClosure: bool

fn toolingDefaultPlanIsTrue(raw: str): bool =
    let text: str = strutil.toLowerAscii(strutil.strip(raw))
    return text == "1" || text == "true" || text == "yes" || text == "on"

fn toolingBuildBackendBaselineIds(): str[] =
    var ids: str[] = []
    add(ids, "build_backend_rawptr_contract")
    add(ids, "build_backend_mem_contract")
    add(ids, "build_backend_dod_contract")
    add(ids, "build_backend_string_abi_contract")
    add(ids, "build_backend_dot_lowering_contract")
    add(ids, "build_backend_determinism_contract")
    add(ids, "build_backend_profile_schema")
    add(ids, "build_backend_profile_baseline")
    return ids

fn toolingVerifyDefaultPlan(): ToolingVerifyDefaultPlan =
    var out: ToolingVerifyDefaultPlan = nil
    new(out)
    out.steps = []
    add(out.steps, "verify_cheng_skill_consistency")
    add(out.steps, "verify_tooling_cmdline")
    add(out.steps, "verify_backend_stage1_fixed0_envs")
    add(out.steps, "verify_backend_string_literal_regression")
    add(out.steps, "verify_std_strformat")
    add(out.steps, "verify_backend_default_output_safety")
    add(out.steps, "verify_new_expr_surface")
    add(out.steps, "verify_backend_selfhost_currentsrc_proof")
    add(out.steps, "verify_stage1_seed_layout")
    add(out.steps, "verify_no_legacy_net_multiformats_imports")
    add(out.steps, "verify_backend_string_abi_contract")
    add(out.steps, "verify_backend_dot_lowering_contract")
    out.runNoRootBuildArtifacts = toolingDefaultPlanIsTrue(
        os.getEnvDefault("VERIFY_NO_ROOT_BUILD_ARTIFACTS", "1"))
    out.runBackendClosedloop = toolingDefaultPlanIsTrue(
        os.getEnvDefault("BACKEND_CLOSEDLOOP", "0"))
    out.runBackendProdClosure = toolingDefaultPlanIsTrue(
        os.getEnvDefault("BACKEND_PROD_CLOSURE", "1"))
    return out
