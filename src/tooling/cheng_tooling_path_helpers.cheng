import std/os
import std/strutils as strutil
import std/strings

fn toolingPathHelpersStrNonEmpty(text: str): bool =
    return len(text) > 0

fn toolingPathHelpersIsAsciiSpace(ch: char): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn toolingPathHelpersTrimAsciiSpace(raw: str): str =
    if !toolingPathHelpersStrNonEmpty(raw):
        return ""
    let n: int32 = len(raw)
    if n <= 0:
        return ""
    var start: int32 = 0
    while start < n && toolingPathHelpersIsAsciiSpace(raw[start]):
        start = start + 1
    if start >= n:
        return ""
    var stop: int32 = n - 1
    while stop >= start && toolingPathHelpersIsAsciiSpace(raw[stop]):
        stop = stop - 1
    if start == 0 && stop == n - 1:
        return raw
    return strings.sliceBytes(raw, start, stop - start + 1)

fn toolingPathHelpersShellQuote(raw: str): str =
    if len(raw) == 0:
        return "\"\""
    return "\"" + strutil.replace(
        strutil.replace(
            strutil.replace(
                strutil.replace(raw, "\\", "\\\\"),
                "$",
                "\\$"
            ),
            "`",
            "\\`"
        ),
        "\"",
        "\\\""
    ) + "\""

fn toolingJoinPathSimpleNormalized(base: str, rel: str): str =
    if !toolingPathHelpersStrNonEmpty(base):
        return rel
    if !toolingPathHelpersStrNonEmpty(rel):
        return base
    if strutil.startsWith(rel, "/") || strutil.startsWith(rel, "\\"):
        return base + rel
    let n: int32 = len(base)
    if n > 0:
        let tail: char = base[n - 1]
        if tail == '/' || tail == '\\':
            return base + rel
    return base + "/" + rel

fn toolingJoinPathSimple(baseRaw: str, relRaw: str): str =
    return toolingJoinPathSimpleNormalized(
        toolingPathHelpersTrimAsciiSpace(baseRaw),
        toolingPathHelpersTrimAsciiSpace(relRaw)
    )

fn toolingPathAbsoluteFromText(root: str, text: str): str =
    if !toolingPathHelpersStrNonEmpty(text):
        return ""
    if os.isAbsolute(text):
        return text
    if strutil.startsWith(text, "./") || strutil.startsWith(text, "../"):
        return os.absolutePath(text)
    return toolingJoinPathSimple(root, text)

fn toolingPathAbsolute(root: str, raw: str): str =
    return toolingPathAbsoluteFromText(root, toolingPathHelpersTrimAsciiSpace(raw))

fn toolingPathExists(path: str): bool =
    if !toolingPathHelpersStrNonEmpty(path):
        return false
    if os.fileExists(path):
        return true
    if os.dirExists(path):
        return true
    return false

fn toolingFileExistsNonEmpty(pathRaw: str): bool =
    if !toolingPathHelpersStrNonEmpty(toolingPathHelpersTrimAsciiSpace(pathRaw)) ||
       !os.fileExists(toolingPathHelpersTrimAsciiSpace(pathRaw)):
        return false
    return os.fileSize(toolingPathHelpersTrimAsciiSpace(pathRaw)) > int64(0)

fn toolingFileIsNewerAbs(root: str, lhs: str, rhs: str): bool =
    if !toolingPathHelpersStrNonEmpty(lhs) || !toolingPathHelpersStrNonEmpty(rhs):
        return false
    if !os.fileExists(lhs) || !os.fileExists(rhs):
        return false
    let opts: uint64 = uint64(7)
    let res: os.ExecCmdResult =
        os.execCmdEx("[ " + toolingPathHelpersShellQuote(lhs) + " -nt " + toolingPathHelpersShellQuote(rhs) + " ]", opts, root)
    return os.execCmdResultExitCode(res) == 0

fn toolingFileIsNewer(root: str, lhsRaw: str, rhsRaw: str): bool =
    return toolingFileIsNewerAbs(
        root,
        toolingPathAbsolute(root, lhsRaw),
        toolingPathAbsolute(root, rhsRaw)
    )

fn toolingScriptShellFromLowerProbe(lower: str): str =
    if strutil.startsWith(lower, "#!/usr/bin/env bash") || strutil.startsWith(lower, "#!/bin/bash"):
        return "bash"
    return "sh"

fn toolingScriptShellForPath(path: str): str =
    if !toolingPathHelpersStrNonEmpty(path) || !os.fileExists(path):
        return "sh"
    return toolingScriptShellFromText(os.readFile(path))

fn toolingScriptShell(root: str, scriptPath: str): str =
    return toolingScriptShellForPath(toolingPathAbsolute(root, scriptPath))

fn toolingScriptShellFromText(scriptText: str): str =
    if !toolingPathHelpersStrNonEmpty(scriptText):
        return "sh"
    var probeLen: int32 = len(scriptText)
    if probeLen > 160:
        probeLen = 160
    return toolingScriptShellFromLowerProbe(
        strutil.toLowerAscii(strutil.strip(strings.sliceBytes(scriptText, 0, probeLen)))
    )

fn toolingProgramBaseNameTrimmed(raw: str): str =
    if !toolingPathHelpersStrNonEmpty(raw):
        return "cheng_tooling"
    let parts: os.SplitFileResult = os.splitFile(raw)
    if toolingPathHelpersStrNonEmpty(parts.name):
        return parts.name
    return raw

fn toolingProgramBaseName(raw0: str): str =
    return toolingProgramBaseNameTrimmed(toolingPathHelpersTrimAsciiSpace(raw0))

fn toolingFileNameTrimmed(path: str): str =
    if !toolingPathHelpersStrNonEmpty(path):
        return ""
    let parts: os.SplitFileResult = os.splitFile(path)
    if toolingPathHelpersStrNonEmpty(parts.name):
        return parts.name + parts.ext
    return path

fn toolingFileName(pathRaw: str): str =
    return toolingFileNameTrimmed(toolingPathHelpersTrimAsciiSpace(pathRaw))
