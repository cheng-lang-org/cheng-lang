fn toolingEmbeddedPatchDodSoa(): str[] =
    var lines: str[] = []
    add(lines, "#!/usr/bin/env sh")
    add(lines, ":")
    add(lines, "set -eu")
    add(lines, "(set -o pipefail) 2>/dev/null && set -o pipefail")
    add(lines, "")
    add(lines, "root=\"${TOOLING_ROOT:-}\"")
    add(lines, "if [ \"$root\" = \"\" ]; then")
    add(lines, "  root=\"$(pwd)\"")
    add(lines, "fi")
    add(lines, "cd \"$root\"")
    add(lines, "")
    add(lines, "if ! command -v rg >/dev/null 2>&1; then")
    add(lines, "  echo \"[verify_backend_dod_soa] rg is required\" >&2")
    add(lines, "  exit 2")
    add(lines, "fi")
    add(lines, "")
    add(lines, "out_dir=\"artifacts/backend_dod_soa\"")
    add(lines, "mkdir -p \"$out_dir\"")
    add(lines, "report_file=\"$out_dir/backend_dod_soa.report.txt\"")
    add(lines, "snapshot_file=\"$out_dir/backend_dod_soa.snapshot.env\"")
    add(lines, "missing_file=\"$out_dir/backend_dod_soa.missing_markers.txt\"")
    add(lines, ": >\"$missing_file\"")
    add(lines, "")
    add(lines, "check_marker() {")
    add(lines, "  file=\"$1\"")
    add(lines, "  pattern=\"$2\"")
    add(lines, "  name=\"$3\"")
    add(lines, "  if ! rg -q \"$pattern\" \"$file\"; then")
    add(lines, "    printf '%s\\t%s\\t%s\\n' \"$file\" \"$name\" \"$pattern\" >>\"$missing_file\"")
    add(lines, "  fi")
    add(lines, "}")
    add(lines, "")
    add(lines, "check_marker \"src/stage1/ast.cheng\" 'astKindByNode: NodeKind\\[\\]' 'stage1_ast_kind_by_node'")
    add(lines, "check_marker \"src/stage1/ast.cheng\" 'nodeArenaEnabled: bool = true' 'stage1_node_arena_enabled'")
    add(lines, "check_marker \"src/backend/uir/uir_internal/uir_core_types.cheng\" 'localIndex: int32' 'uir_local_index_int32'")
    add(lines, "check_marker \"src/backend/uir/uir_internal/uir_core_types.cheng\" 'slot: int32' 'uir_slot_index_int32'")
    add(lines, "check_marker \"src/backend/uir/uir_internal/uir_core_types.cheng\" 'frameOff: int32' 'uir_frame_offset_int32'")
    add(lines, "check_marker \"src/backend/uir/uir_internal/uir_core_ssa.cheng\" 'rpoIndex: int32\\[\\]' 'uir_ssa_rpo_index_int32'")
    add(lines, "")
    add(lines, "status=\"ok\"")
    add(lines, "if [ -s \"$missing_file\" ]; then")
    add(lines, "  status=\"drift\"")
    add(lines, "fi")
    add(lines, "")
    add(lines, "{")
    add(lines, "  echo \"verify_backend_dod_soa report\"")
    add(lines, "  echo \"status=$status\"")
    add(lines, "  echo \"mode=source_contract\"")
    add(lines, "  echo \"missing_markers=$missing_file\"")
    add(lines, "} >\"$report_file\"")
    add(lines, "")
    add(lines, "{")
    add(lines, "  echo \"backend_dod_soa_status=$status\"")
    add(lines, "  echo \"backend_dod_soa_mode=source_contract\"")
    add(lines, "  echo \"backend_dod_soa_missing_markers=$missing_file\"")
    add(lines, "  echo \"backend_dod_soa_report=$report_file\"")
    add(lines, "} >\"$snapshot_file\"")
    add(lines, "")
    add(lines, "if [ \"$status\" != \"ok\" ]; then")
    add(lines, "  echo \"[verify_backend_dod_soa] missing required markers; see $missing_file\" >&2")
    add(lines, "  exit 1")
    add(lines, "fi")
    add(lines, "")
    add(lines, "echo \"verify_backend_dod_soa ok\"")
    return lines
