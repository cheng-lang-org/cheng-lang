import std/strutils as strutil
import std/strings

fn toolingVerifyContractScriptsStrNonEmpty(text: str): bool =
    return len(text) > 0

fn toolingVerifyContractScriptsStrEq(a: str, b: str): bool =
    if a == b:
        return true
    if len(a) == 0 || len(b) == 0:
        return false
    return strings.streq(a, b)

fn toolingVerifyContractScriptsShellQuote(raw: str): str =
    if len(raw) == 0:
        return "\"\""
    var escaped: str = strutil.replace(raw, "\\", "\\\\")
    escaped = strutil.replace(escaped, "$", "\\$")
    escaped = strutil.replace(escaped, "`", "\\`")
    escaped = strutil.replace(escaped, "\"", "\\\"")
    return "\"" + escaped + "\""

fn toolingVerifyContractScriptsJoin(parts: str[]): str =
    return strutil.join(parts, "")

fn toolingContractDotCStringSmokeSnippetScript(): str =
    var parts: str[] = []
    add(parts, "smoke_fixture=\"tests/cheng/backend/fixtures/dot_cstring_contract.cheng\"; ")
    add(parts, "smoke_ok=\"1\"; ")
    add(parts, "smoke_driver=\"${BACKEND_DRIVER:-}\"; ")
    add(parts, "if [ \"$smoke_driver\" = \"\" ] && [ -x \"artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2.proof\" ]; then smoke_driver=\"artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2.proof\"; fi; ")
    add(parts, "if [ \"$smoke_driver\" = \"\" ]; then smoke_driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r' || true)\"; fi; ")
    add(parts, "smoke_target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; ")
    add(parts, "smoke_dev_exe=\"$out_dir/dot_cstring_contract.dev\"; ")
    add(parts, "smoke_release_exe=\"$out_dir/dot_cstring_contract.release\"; ")
    add(parts, "smoke_dev_log=\"$out_dir/dot_cstring_contract.dev.log\"; ")
    add(parts, "smoke_release_log=\"$out_dir/dot_cstring_contract.release.log\"; ")
    add(parts, "smoke_dev_run_log=\"$out_dir/dot_cstring_contract.dev.run.log\"; ")
    add(parts, "smoke_release_run_log=\"$out_dir/dot_cstring_contract.release.run.log\"; ")
    add(parts, "if [ ! -f \"$smoke_fixture\" ] || [ \"$smoke_driver\" = \"\" ] || [ ! -x \"$smoke_driver\" ]; then smoke_ok=\"0\"; status=\"drift\"; else ")
    add(parts, "rm -f \"$smoke_dev_exe\" \"$smoke_release_exe\" \"$smoke_dev_log\" \"$smoke_release_log\" \"$smoke_dev_run_log\" \"$smoke_release_run_log\"; ")
    add(parts, "if ! env MM=orc BACKEND_BUILD_TRACK=dev BACKEND_STAGE1_PARSE_MODE=outline BACKEND_FN_SCHED=ws BACKEND_DIRECT_EXE=1 BACKEND_LINKERLESS_INMEM=1 BACKEND_FAST_DEV_PROFILE=1 BACKEND_LINKER=self BACKEND_INPUT=\"$smoke_fixture\" BACKEND_OUTPUT=\"$smoke_dev_exe\" \"$smoke_driver\" >\"$smoke_dev_log\" 2>&1; then smoke_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if [ \"$smoke_ok\" = \"1\" ] && ! \"$smoke_dev_exe\" >\"$smoke_dev_run_log\" 2>&1; then smoke_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if [ \"$smoke_ok\" = \"1\" ] && ! env MM=orc BACKEND_BUILD_TRACK=release BACKEND_STAGE1_PARSE_MODE=full BACKEND_FN_SCHED=ws BACKEND_DIRECT_EXE=0 BACKEND_LINKERLESS_INMEM=0 BACKEND_LINKER=system BACKEND_NO_RUNTIME_C=0 BACKEND_INPUT=\"$smoke_fixture\" BACKEND_OUTPUT=\"$smoke_release_exe\" \"$smoke_driver\" >\"$smoke_release_log\" 2>&1; then smoke_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if [ \"$smoke_ok\" = \"1\" ] && ! \"$smoke_release_exe\" >\"$smoke_release_run_log\" 2>&1; then smoke_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "fi; ")
    return toolingVerifyContractScriptsJoin(parts)

fn toolingVerifyBackendStringAbiContractScript(toolBin: str, baselineFile: str, doc: str, formalDoc: str,
                                               toolingDoc: str, matrixDoc: str): str =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then echo \"[verify_backend_string_abi_contract] rg is required\" >&2; exit 2; fi; ")
    add(parts, "hash_file() { file=\"$1\"; if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; cksum \"$file\" | awk '{print $1}'; }; ")
    add(parts, "tool=")
    add(parts, toolingVerifyContractScriptsShellQuote(toolBin))
    add(parts, "; baseline=")
    add(parts, toolingVerifyContractScriptsShellQuote(baselineFile))
    add(parts, "; doc=")
    add(parts, toolingVerifyContractScriptsShellQuote(doc))
    add(parts, "; formal_doc=")
    add(parts, toolingVerifyContractScriptsShellQuote(formalDoc))
    add(parts, "; tooling_doc=")
    add(parts, toolingVerifyContractScriptsShellQuote(toolingDoc))
    add(parts, "; matrix_doc=")
    add(parts, toolingVerifyContractScriptsShellQuote(matrixDoc))
    add(parts, "; ")
    add(parts, "machine_types=\"src/backend/machine/machine_types.cheng\"; isel_shared=\"src/backend/machine/select_internal/isel_parallel_shared.cheng\"; coff_writer=\"src/backend/obj/coff_writer_x86_64.cheng\"; elf_writer=\"src/backend/obj/elf_writer.cheng\"; uir_codegen=\"src/backend/uir/uir_codegen.cheng\"; tooling_file=\"src/tooling/cheng_tooling.cheng\"; default_plan_file=\"src/tooling/cheng_tooling_default_plan.cheng\"; embedded_file=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; ")
    add(parts, "for required in \"$tool\" \"$baseline\" \"$doc\" \"$formal_doc\" \"$tooling_doc\" \"$matrix_doc\" \"$machine_types\" \"$isel_shared\" \"$coff_writer\" \"$elf_writer\" \"$uir_codegen\" \"$tooling_file\" \"$default_plan_file\" \"$embedded_file\"; do if [ ! -f \"$required\" ]; then echo \"[verify_backend_string_abi_contract] missing file: $required\" >&2; exit 2; fi; done; ")
    add(parts, "out_dir=\"artifacts/backend_string_abi_contract\"; rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; generated=\"$out_dir/backend_string_abi_contract.generated.env\"; report=\"$out_dir/backend_string_abi_contract.report.txt\"; snapshot=\"$out_dir/backend_string_abi_contract.snapshot.env\"; diff_file=\"$out_dir/backend_string_abi_contract.diff.txt\"; ")
    add(parts, "\"$tool\" build_backend_string_abi_contract --doc:\"$doc\" --formal-doc:\"$formal_doc\" --tooling-doc:\"$tooling_doc\" --matrix-doc:\"$matrix_doc\" --out:\"$generated\" >/dev/null; ")
    add(parts, "status=\"ok\"; if ! cmp -s \"$baseline\" \"$generated\"; then status=\"drift\"; if ! diff -u \"$baseline\" \"$generated\" >\"$diff_file\" 2>/dev/null; then diff \"$baseline\" \"$generated\" >\"$diff_file\" 2>/dev/null || true; fi; else : >\"$diff_file\"; fi; ")
    add(parts, "default_verify_ok=\"1\"; if ! rg -q 'add\\((steps|out\\.steps), \"verify_backend_string_abi_contract\"\\)' \"$tooling_file\" \"$default_plan_file\"; then default_verify_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "prod_closure_required_ok=\"1\"; if ! rg -q 'tooling_cmdBackendProdRunGate\\(root, toolBin, \"backend\\.string_abi_contract\"' \"$tooling_file\"; then prod_closure_required_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "source_markers_ok=\"1\"; ")
    add(parts, "if ! rg -q 'selector cstring lowering is always enabled on the production machine surface' \"$machine_types\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'selector-owned cstring lowering materializes MachineCString payloads before object writers' \"$isel_shared\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'Selector owns cstring materialization' \"$coff_writer\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'ELF writer consumes selector-owned cstring materialization' \"$elf_writer\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'selector_missing cstring payloads is a hard error' \"$uir_codegen\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, toolingContractDotCStringSmokeSnippetScript())
    add(parts, "baseline_sha=\"$(hash_file \"$baseline\")\"; generated_sha=\"$(hash_file \"$generated\")\"; ")
    add(parts, "{ echo \"status=$status\"; echo \"baseline=$baseline\"; echo \"generated=$generated\"; echo \"default_verify_ok=$default_verify_ok\"; echo \"prod_closure_required_ok=$prod_closure_required_ok\"; echo \"source_markers_ok=$source_markers_ok\"; echo \"smoke_ok=$smoke_ok\"; echo \"baseline_sha256=$baseline_sha\"; echo \"generated_sha256=$generated_sha\"; echo \"diff=$diff_file\"; echo \"smoke_fixture=$smoke_fixture\"; echo \"smoke_driver=$smoke_driver\"; echo \"smoke_target=$smoke_target\"; echo \"smoke_dev_log=$smoke_dev_log\"; echo \"smoke_release_log=$smoke_release_log\"; echo \"smoke_dev_run_log=$smoke_dev_run_log\"; echo \"smoke_release_run_log=$smoke_release_run_log\"; } >\"$report\"; ")
    add(parts, "{ echo \"backend_string_abi_contract_status=$status\"; echo \"backend_string_abi_contract_default_verify_ok=$default_verify_ok\"; echo \"backend_string_abi_contract_prod_closure_required_ok=$prod_closure_required_ok\"; echo \"backend_string_abi_contract_source_markers_ok=$source_markers_ok\"; echo \"backend_string_abi_contract_smoke_ok=$smoke_ok\"; echo \"backend_string_abi_contract_report=$report\"; echo \"backend_string_abi_contract_diff=$diff_file\"; } >\"$snapshot\"; ")
    add(parts, "if [ \"$status\" != \"ok\" ]; then echo \"[verify_backend_string_abi_contract] string ABI contract drift detected\" >&2; echo \"  baseline: $baseline\" >&2; echo \"  generated: $generated\" >&2; if [ -s \"$diff_file\" ]; then sed -n '1,160p' \"$diff_file\" >&2 || true; fi; if [ \"$default_verify_ok\" != \"1\" ]; then echo \"  reason: default verify wiring missing verify_backend_string_abi_contract\" >&2; fi; if [ \"$prod_closure_required_ok\" != \"1\" ]; then echo \"  reason: backend_prod_closure missing required string ABI contract gate\" >&2; fi; if [ \"$source_markers_ok\" != \"1\" ]; then echo \"  reason: selector/backfill source markers drifted\" >&2; fi; if [ \"$smoke_ok\" != \"1\" ]; then echo \"  reason: dot_cstring_contract smoke failed\" >&2; for log in \"$smoke_dev_log\" \"$smoke_dev_run_log\" \"$smoke_release_log\" \"$smoke_release_run_log\"; do if [ -s \"$log\" ]; then echo \"  log: $log\" >&2; sed -n '1,120p' \"$log\" >&2 || true; fi; done; fi; echo \"  fix: $tool build_backend_string_abi_contract --doc:$doc --formal-doc:$formal_doc --tooling-doc:$tooling_doc --matrix-doc:$matrix_doc --out:$baseline\" >&2; exit 1; fi; ")
    add(parts, "echo \"verify_backend_string_abi_contract ok\"")
    return toolingVerifyContractScriptsJoin(parts)

fn toolingVerifyBackendDotLoweringContractScript(toolBin: str, baselineFile: str, doc: str, uirDoc: str,
                                                 toolingDoc: str, matrixDoc: str): str =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then echo \"[verify_backend_dot_lowering_contract] rg is required\" >&2; exit 2; fi; ")
    add(parts, "hash_file() { file=\"$1\"; if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; cksum \"$file\" | awk '{print $1}'; }; ")
    add(parts, "tool=")
    add(parts, toolingVerifyContractScriptsShellQuote(toolBin))
    add(parts, "; baseline=")
    add(parts, toolingVerifyContractScriptsShellQuote(baselineFile))
    add(parts, "; doc=")
    add(parts, toolingVerifyContractScriptsShellQuote(doc))
    add(parts, "; uir_doc=")
    add(parts, toolingVerifyContractScriptsShellQuote(uirDoc))
    add(parts, "; tooling_doc=")
    add(parts, toolingVerifyContractScriptsShellQuote(toolingDoc))
    add(parts, "; matrix_doc=")
    add(parts, toolingVerifyContractScriptsShellQuote(matrixDoc))
    add(parts, "; ")
    add(parts, "uir_builder=\"src/backend/uir/uir_internal/uir_core_builder.cheng\"; machine_types=\"src/backend/machine/machine_types.cheng\"; isel_shared=\"src/backend/machine/select_internal/isel_parallel_shared.cheng\"; coff_writer=\"src/backend/obj/coff_writer_x86_64.cheng\"; elf_writer=\"src/backend/obj/elf_writer.cheng\"; uir_codegen=\"src/backend/uir/uir_codegen.cheng\"; tooling_file=\"src/tooling/cheng_tooling.cheng\"; default_plan_file=\"src/tooling/cheng_tooling_default_plan.cheng\"; embedded_file=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; ")
    add(parts, "for required in \"$tool\" \"$baseline\" \"$doc\" \"$uir_doc\" \"$tooling_doc\" \"$matrix_doc\" \"$uir_builder\" \"$machine_types\" \"$isel_shared\" \"$coff_writer\" \"$elf_writer\" \"$uir_codegen\" \"$tooling_file\" \"$default_plan_file\" \"$embedded_file\"; do if [ ! -f \"$required\" ]; then echo \"[verify_backend_dot_lowering_contract] missing file: $required\" >&2; exit 2; fi; done; ")
    add(parts, "out_dir=\"artifacts/backend_dot_lowering_contract\"; rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; generated=\"$out_dir/backend_dot_lowering_contract.generated.env\"; report=\"$out_dir/backend_dot_lowering_contract.report.txt\"; snapshot=\"$out_dir/backend_dot_lowering_contract.snapshot.env\"; diff_file=\"$out_dir/backend_dot_lowering_contract.diff.txt\"; ")
    add(parts, "\"$tool\" build_backend_dot_lowering_contract --doc:\"$doc\" --uir-doc:\"$uir_doc\" --tooling-doc:\"$tooling_doc\" --matrix-doc:\"$matrix_doc\" --out:\"$generated\" >/dev/null; ")
    add(parts, "status=\"ok\"; if ! cmp -s \"$baseline\" \"$generated\"; then status=\"drift\"; if ! diff -u \"$baseline\" \"$generated\" >\"$diff_file\" 2>/dev/null; then diff \"$baseline\" \"$generated\" >\"$diff_file\" 2>/dev/null || true; fi; else : >\"$diff_file\"; fi; ")
    add(parts, "default_verify_ok=\"1\"; if ! rg -q 'add\\((steps|out\\.steps), \"verify_backend_dot_lowering_contract\"\\)' \"$tooling_file\" \"$default_plan_file\"; then default_verify_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "prod_closure_required_ok=\"1\"; if ! rg -q 'tooling_cmdBackendProdRunGate\\(root, toolBin, \"backend\\.dot_lowering_contract\"' \"$tooling_file\"; then prod_closure_required_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "source_markers_ok=\"1\"; ")
    add(parts, "if ! rg -q 'debugDot' \"$uir_builder\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'globalObjProbe' \"$uir_builder\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'call-dot' \"$uir_builder\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'bracket-dot' \"$uir_builder\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'field access' \"$uir_builder\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'selector cstring lowering is always enabled on the production machine surface' \"$machine_types\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'selector-owned cstring lowering materializes MachineCString payloads before object writers' \"$isel_shared\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'Selector owns cstring materialization' \"$coff_writer\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'ELF writer consumes selector-owned cstring materialization' \"$elf_writer\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, "if ! rg -q 'selector_missing cstring payloads is a hard error' \"$uir_codegen\"; then source_markers_ok=\"0\"; status=\"drift\"; fi; ")
    add(parts, toolingContractDotCStringSmokeSnippetScript())
    add(parts, "baseline_sha=\"$(hash_file \"$baseline\")\"; generated_sha=\"$(hash_file \"$generated\")\"; ")
    add(parts, "{ echo \"status=$status\"; echo \"baseline=$baseline\"; echo \"generated=$generated\"; echo \"default_verify_ok=$default_verify_ok\"; echo \"prod_closure_required_ok=$prod_closure_required_ok\"; echo \"source_markers_ok=$source_markers_ok\"; echo \"smoke_ok=$smoke_ok\"; echo \"baseline_sha256=$baseline_sha\"; echo \"generated_sha256=$generated_sha\"; echo \"diff=$diff_file\"; echo \"smoke_fixture=$smoke_fixture\"; echo \"smoke_driver=$smoke_driver\"; echo \"smoke_target=$smoke_target\"; echo \"smoke_dev_log=$smoke_dev_log\"; echo \"smoke_release_log=$smoke_release_log\"; echo \"smoke_dev_run_log=$smoke_dev_run_log\"; echo \"smoke_release_run_log=$smoke_release_run_log\"; } >\"$report\"; ")
    add(parts, "{ echo \"backend_dot_lowering_contract_status=$status\"; echo \"backend_dot_lowering_contract_default_verify_ok=$default_verify_ok\"; echo \"backend_dot_lowering_contract_prod_closure_required_ok=$prod_closure_required_ok\"; echo \"backend_dot_lowering_contract_source_markers_ok=$source_markers_ok\"; echo \"backend_dot_lowering_contract_smoke_ok=$smoke_ok\"; echo \"backend_dot_lowering_contract_report=$report\"; echo \"backend_dot_lowering_contract_diff=$diff_file\"; } >\"$snapshot\"; ")
    add(parts, "if [ \"$status\" != \"ok\" ]; then echo \"[verify_backend_dot_lowering_contract] dot-lowering contract drift detected\" >&2; echo \"  baseline: $baseline\" >&2; echo \"  generated: $generated\" >&2; if [ -s \"$diff_file\" ]; then sed -n '1,160p' \"$diff_file\" >&2 || true; fi; if [ \"$default_verify_ok\" != \"1\" ]; then echo \"  reason: default verify wiring missing verify_backend_dot_lowering_contract\" >&2; fi; if [ \"$prod_closure_required_ok\" != \"1\" ]; then echo \"  reason: backend_prod_closure missing required dot-lowering contract gate\" >&2; fi; if [ \"$source_markers_ok\" != \"1\" ]; then echo \"  reason: semantic dot / selector cstring source markers drifted\" >&2; fi; if [ \"$smoke_ok\" != \"1\" ]; then echo \"  reason: dot_cstring_contract smoke failed\" >&2; for log in \"$smoke_dev_log\" \"$smoke_dev_run_log\" \"$smoke_release_log\" \"$smoke_release_run_log\"; do if [ -s \"$log\" ]; then echo \"  log: $log\" >&2; sed -n '1,120p' \"$log\" >&2 || true; fi; done; fi; echo \"  fix: $tool build_backend_dot_lowering_contract --doc:$doc --uir-doc:$uir_doc --tooling-doc:$tooling_doc --matrix-doc:$matrix_doc --out:$baseline\" >&2; exit 1; fi; ")
    add(parts, "echo \"verify_backend_dot_lowering_contract ok\"")
    return toolingVerifyContractScriptsJoin(parts)
