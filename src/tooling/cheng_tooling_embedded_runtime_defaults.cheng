import std/strutils as strutil

fn toolingEmbeddedPatchRuntimeDefaults(scriptId: str, scriptText: str): str =
    if scriptText == "":
        return scriptText
    var out: str = scriptText
    out = strutil.replace(out, "FRONTIER_SKIP_SEM=\"0\"", "FRONTIER_SKIP_SEM=\"0\"")
    out = strutil.replace(out, "FRONTIER_SKIP_SEM=\"${FRONTIER_SKIP_SEM:-0}\"", "FRONTIER_SKIP_SEM=\"0\"")
    out = strutil.replace(out, "FRONTIER_SKIP_OWNERSHIP=\"0\"", "FRONTIER_SKIP_OWNERSHIP=\"0\"")
    out = strutil.replace(out, "FRONTIER_SKIP_OWNERSHIP=\"${FRONTIER_SKIP_OWNERSHIP:-0}\"", "FRONTIER_SKIP_OWNERSHIP=\"0\"")
    out = strutil.replace(out, "FRONTIER_SKIP_SEM=<0|1>      Stage1 skip semantics (default: 1)",
                          "FRONTIER_SKIP_SEM=<removed>  fixed=0 (removed config)")
    out = strutil.replace(out, "FRONTIER_SKIP_OWNERSHIP=<0|1> Stage1 skip ownership (default: 1)",
                          "FRONTIER_SKIP_OWNERSHIP=<removed> fixed=0 (removed config)")
    out = strutil.replace(out, "FULLCHAIN_TOOL_SKIP_SEM=\"0\"", "FULLCHAIN_TOOL_SKIP_SEM=\"0\"")
    out = strutil.replace(out, "FULLCHAIN_TOOL_SKIP_SEM=\"${FULLCHAIN_TOOL_SKIP_SEM:-0}\"", "FULLCHAIN_TOOL_SKIP_SEM=\"0\"")
    out = strutil.replace(out, "FULLCHAIN_TOOL_SKIP_OWNERSHIP=\"0\"", "FULLCHAIN_TOOL_SKIP_OWNERSHIP=\"0\"")
    out = strutil.replace(out, "FULLCHAIN_TOOL_SKIP_OWNERSHIP=\"${FULLCHAIN_TOOL_SKIP_OWNERSHIP:-0}\"", "FULLCHAIN_TOOL_SKIP_OWNERSHIP=\"0\"")
    out = strutil.replace(out, "STAGE1_SEM_FIXED_0=\"0\"", "STAGE1_SEM_FIXED_0=\"0\"")
    out = strutil.replace(out, "STAGE1_SEM_FIXED_0=\"${FULLCHAIN_TOOL_SKIP_SEM:-0}\"", "STAGE1_SEM_FIXED_0=\"0\"")
    out = strutil.replace(out, "STAGE1_OWNERSHIP_FIXED_0=\"0\"", "STAGE1_OWNERSHIP_FIXED_0=\"0\"")
    out = strutil.replace(out, "STAGE1_OWNERSHIP_FIXED_0=\"${FULLCHAIN_TOOL_SKIP_OWNERSHIP:-0}\"", "STAGE1_OWNERSHIP_FIXED_0=\"0\"")
    out = strutil.replace(out,
                          "artifacts/tooling_cmd/cheng_tooling_global",
                          "artifacts/tooling_cmd/cheng_tooling")
    if scriptId == "backend_prod_closure" || scriptId == "verify_backend_closedloop":
        out = strutil.replace(out,
                              "mm_gate_driver=\"${BACKEND_DRIVER:-}\"",
                              "mm_gate_driver=\"${BACKEND_MM_DRIVER:-}\"")
    if scriptId == "verify_backend_closedloop":
        out = strutil.replace(out, "export BACKEND_DRIVER=\"$driver\"\n", "")
        out = strutil.replace(out,
                              "run_step \"backend.linkerless_dev\" env BACKEND_LINKER=self BACKEND_BUILD_TRACK=dev BACKEND_DRIVER=\"$linkerless_gate_driver\" ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_linkerless_dev\n",
                              "run_step \"backend.linkerless_dev\" env BACKEND_LINKER=self BACKEND_BUILD_TRACK=dev BACKEND_LINKERLESS_DRIVER=\"$linkerless_gate_driver\" ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_linkerless_dev\n")
        out = strutil.replace(out, "fullspec_skip_sem=\"${BACKEND_FULLSPEC_SKIP_SEM:-1}\"", "fullspec_skip_sem=\"0\"")
        out = strutil.replace(out, "fullspec_skip_sem=\"${BACKEND_FULLSPEC_SKIP_SEM:-$stage1_skip_sem}\"", "fullspec_skip_sem=\"0\"")
        out = strutil.replace(out,
                              "fullspec_skip_ownership=\"${BACKEND_FULLSPEC_SKIP_OWNERSHIP:-$stage1_skip_ownership}\"",
                              "fullspec_skip_ownership=\"0\"")
    if scriptId == "verify_backend_linker_abi_core":
        out = strutil.replace(out,
                              "allow_selfhost_fallback=\"${BACKEND_LINKER_ABI_CORE_ALLOW_SELFHOST:-0}\"",
                              "allow_selfhost_fallback=\"0\"")
        out = strutil.replace(
            out,
            "for cand in \\\n    \"artifacts/backend_driver/cheng\" \\\n    \"artifacts/backend_selfhost_self_obj/cheng.stage2\" \\\n    \"dist/releases/current/cheng\"; do")
        out = strutil.replace(out,
                              "  echo \"  hint: set BACKEND_LINKER_ABI_CORE_DRIVER=<path>\" >&2\n",
                              "  echo \"  hint: build canonical driver first: artifacts/tooling_cmd/cheng_tooling build-backend-driver\" >&2\n")
    return out
