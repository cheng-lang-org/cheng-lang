import std/os

fn toolingUsagePrintOut(text: str) =
    os.write(os.get_stdout(), text + "\n")

fn toolingPrintUsage() =
    toolingUsagePrintOut("usage: cheng_tooling <command> [args]")
    toolingUsagePrintOut("")
    toolingUsagePrintOut("commands:")
    toolingUsagePrintOut("  toolchain-root")
    toolingUsagePrintOut("      print canonical toolchain root resolved from executable path")
    toolingUsagePrintOut("  driver-path [--path-only]")
    toolingUsagePrintOut("      print canonical driver metadata (or only path with --path-only)")
    toolingUsagePrintOut("  build-backend-driver [--out:<path>] [--target:<triple>] [--require-rebuild] [--debug-rebuild]")
    toolingUsagePrintOut("      build artifacts/backend_driver/cheng via native fast host path (zero-script)")
    toolingUsagePrintOut("  cleanup-backend-driver-history [--dry-run]")
    toolingUsagePrintOut("      remove historical artifacts/backend_driver/cheng* variants, keep canonical driver")
    toolingUsagePrintOut("  verify [--help]")
    toolingUsagePrintOut("      run default repository verification gates")
    toolingUsagePrintOut("  build-backend-baselines")
    toolingUsagePrintOut("      rebuild all backend contract/profile baselines in one call")
    toolingUsagePrintOut("  build_backend_rawptr_contract [--out:<path>] [--doc:<path>] [--formal-doc:<path>] [--tooling-doc:<path>]")
    toolingUsagePrintOut("      build RPSPAR raw-pointer contract baseline env")
    toolingUsagePrintOut("  build_backend_mem_contract [--out:<path>] [--doc:<path>]")
    toolingUsagePrintOut("      build PAR memory/hotpatch contract baseline env")
    toolingUsagePrintOut("  build_backend_dod_contract [--out:<path>] [--doc:<path>]")
    toolingUsagePrintOut("      build DOD contract baseline env")
    toolingUsagePrintOut("  build_backend_string_abi_contract [--out:<path>] [--doc:<path>] [--formal-doc:<path>] [--tooling-doc:<path>] [--matrix-doc:<path>]")
    toolingUsagePrintOut("      build string ABI / cstring contract baseline env")
    toolingUsagePrintOut("  build_backend_dot_lowering_contract [--out:<path>] [--doc:<path>] [--uir-doc:<path>] [--tooling-doc:<path>] [--matrix-doc:<path>]")
    toolingUsagePrintOut("      build dot-lowering contract baseline env")
    toolingUsagePrintOut("  build_backend_determinism_contract [--out:<path>] [--doc:<path>]")
    toolingUsagePrintOut("      build determinism-state closure baseline env")
    toolingUsagePrintOut("  build_backend_profile_schema [--out:<path>]")
    toolingUsagePrintOut("      build backend profile schema env")
    toolingUsagePrintOut("  build_backend_profile_baseline [--out:<path>] [--schema:<path>]")
    toolingUsagePrintOut("      build backend profile baseline env")
    toolingUsagePrintOut("  selfhost-bootstrap-fast-host [--compile-stage1|--no-compile-stage1] [--out-dir:<path>] [--timing-out:<path>]")
    toolingUsagePrintOut("      host-only fast selfhost bootstrap without shell script orchestration")
    toolingUsagePrintOut("  verify_backend_selfhost_bootstrap_self_obj [--mode:fast|strict] [--compile-stage1|--no-compile-stage1] [--out-dir:<path>] [--timing-out:<path>]")
    toolingUsagePrintOut("      native selfhost bootstrap verifier (strict enforces SHA256(stage2)==SHA256(stage3))")
    toolingUsagePrintOut("  verify_backend_selfhost_bootstrap_inmem_witness [--out-dir:<path>] [--timing-out:<path>]")
    toolingUsagePrintOut("      strict full-parse in-memory direct-exe witness for backend_driver selfhost compile")
    toolingUsagePrintOut("  verify_backend_selfhost_inner_loop [--out-dir:<path>] [--timing-out:<path>] [--closure]")
    toolingUsagePrintOut("      native inner loop: canonical rebuild -> inmem witness -> strict host (-> optional closure)")
    toolingUsagePrintOut("  selfhost-100ms-host [--iters:<N>] [--p95-ms:<ms>] [--p99-ms:<ms>] [--host-only:<tag>] [--report:<path>] [--enforce:0|1]")
    toolingUsagePrintOut("      host-only 100ms gate using native selfhost bootstrap path")
    toolingUsagePrintOut("  verify_backend_cdrop_emergency")
    toolingUsagePrintOut("      emergency C-Drop gate (manifest hash + clang seed + strict selfhost)")
    toolingUsagePrintOut("  verify_backend_opt2_impl_surface")
    toolingUsagePrintOut("      verify opt2 implementation surface (no placeholder return false + NJVL/SSU defaults)")
    toolingUsagePrintOut("  verify_backend_driver_unified_global")
    toolingUsagePrintOut("      verify single canonical driver policy across cheng-lang and ecosystem repos")
    toolingUsagePrintOut("  verify_backend_compile_name_canonical")
    toolingUsagePrintOut("      verify canonical compile command naming (cheng only) across selected repos")
    toolingUsagePrintOut("  verify_backend_dev_track_only")
    toolingUsagePrintOut("      verify cheng is dev-only, compile/chengc are removed, and backend_prod_closure excludes release tail")
    toolingUsagePrintOut("  verify_backend_loop_runtime")
    toolingUsagePrintOut("      verify while/for loop fixtures keep runtime behavior under opt2")
    toolingUsagePrintOut("  verify_backend_symbol_closure")
    toolingUsagePrintOut("      verify dev runtime symbol closure (_alloc/_c_strlen/_zeroMem) via runnable fixtures")
    toolingUsagePrintOut("  verify_backend_new_expr_ref_stability")
    toolingUsagePrintOut("      verify new(Box[T]) generic ref expr fixture remains compile+run stable")
    toolingUsagePrintOut("  verify_backend_release_compile_stability")
    toolingUsagePrintOut("      verify release-compile stability on new(ref) fixture (default 3x, no rc=139)")
    toolingUsagePrintOut("  verify_backend_determinism_contract")
    toolingUsagePrintOut("      verify determinism contract baseline markers and required gate wiring")
    toolingUsagePrintOut("  verify_backend_determinism_strict")
    toolingUsagePrintOut("      verify strict release exe determinism via 3 stable release-compile builds")
    toolingUsagePrintOut("  verify_backend_exe_determinism_strict")
    toolingUsagePrintOut("      verify strict release exe determinism via 3 stable release-compile builds")
    toolingUsagePrintOut("  verify_backend_ue_no_growth")
    toolingUsagePrintOut("      verify relevant UE process set has zero growth during gate execution")
    toolingUsagePrintOut("  verify_backend_seed_uir_import")
    toolingUsagePrintOut("      verify recovery seed compiler can emit backend_driver_uir_import obj fixture")
    toolingUsagePrintOut("  verify_backend_sidecar_cheng_seed")
    toolingUsagePrintOut("      verify recovery seed compiler builds emergency_c sidecar bundle and compile+runs return_add/new(Box[T])/new ref seq fixtures")
    toolingUsagePrintOut("  verify_backend_sidecar_cheng_fresh")
    toolingUsagePrintOut("      verify current Cheng compiler builds fresh cheng sidecar bundle and compile+runs return_add/new(Box[T])/new ref seq fixtures")
    toolingUsagePrintOut("  verify_backend_zero_script_residual")
    toolingUsagePrintOut("      verify tooling required path has no legacy CHENG_* reads and no shell residual in src/tooling")
    toolingUsagePrintOut("  verify_backend_opt2")
    toolingUsagePrintOut("      native opt2 fixture runtime gate (strict no compile-only fallback)")
    toolingUsagePrintOut("  verify_backend_opt3")
    toolingUsagePrintOut("      native opt3 fixture runtime gate (strict no compile-only fallback)")
    toolingUsagePrintOut("  verify_backend_opt3_extended")
    toolingUsagePrintOut("      extended opt3 fixture gate with crash diagnostics (blocking by default; override via UIR_OPT3_EXTENDED_ENFORCE=0)")
    toolingUsagePrintOut("  verify_backend_simd")
    toolingUsagePrintOut("      native SIMD gate (loop+SLP reports, determinism, scalar/SIMD runtime equivalence)")
    toolingUsagePrintOut("  verify_backend_rawptr_surface_forbid")
    toolingUsagePrintOut("      verify ZRPC no-pointer diagnostics and cmdline raw-pointer surface removal")
    toolingUsagePrintOut("  verify_backend_pure_cheng_surface")
    toolingUsagePrintOut("      report hard-cut drift for legacy new local-var syntax, implementation raw pointers, and repo-tracked C/H build surfaces")
    toolingUsagePrintOut("  verify_stage1_ast_soa_surface")
    toolingUsagePrintOut("      verify stage1 AST hard-cut SoA surface snapshot (Node=ref/nil/rawptr usage)")
    toolingUsagePrintOut("  verify_backend_rawptr_migration")
    toolingUsagePrintOut("      verify raw-pointer migration gate is wired via native subcommands")
    toolingUsagePrintOut("  verify_backend_uir_soa_surface")
    toolingUsagePrintOut("      verify SoA surface + runtime contract (double-run determinism + self-link probe)")
    toolingUsagePrintOut("  verify_backend_uir_soa_self_probe")
    toolingUsagePrintOut("      verify SoA self-link runtime probe (hard-fail, no fallback)")
    toolingUsagePrintOut("  verify_backend_string_abi_contract")
    toolingUsagePrintOut("      verify string ABI / cstring contract baseline, docs, default verify wiring, and report-only closure status")
    toolingUsagePrintOut("  verify_backend_dot_lowering_contract")
    toolingUsagePrintOut("      verify dot-lowering contract baseline, docs, default verify wiring, and report-only closure status")
    toolingUsagePrintOut("  verify_backend_string_literal_regression")
    toolingUsagePrintOut("      verify canonical backend_driver string literal runtime path (4 fixtures, timeout+sample report)")
    toolingUsagePrintOut("  verify_new_expr_surface")
    toolingUsagePrintOut("      verify real Cheng sources only use expression-style new(T) and bare current-source proof stage2 compiles+runs a minimal new(T) fixture")
    toolingUsagePrintOut("  verify_backend_selfhost_currentsrc_proof")
    toolingUsagePrintOut("      verify current-source selfhost proof surface publish + bare/proof return_i64 direct-compile smoke")
    toolingUsagePrintOut("  verify_mobile_crash_free")
    toolingUsagePrintOut("      mobile crash-free stress gate (serial 50 + parallel 4x20)")
    toolingUsagePrintOut("  verify_backend_closedloop")
    toolingUsagePrintOut("      verify closedloop runtime (minimal mode uses native path)")
    toolingUsagePrintOut("  verify_backend_linker_abi_core_cross [--enforce:0|1] [--targets:<csv|@file>]")
    toolingUsagePrintOut("      cross-target self-link ABI probe (enforce by default, use --report-only for diagnostics)")
    toolingUsagePrintOut("  backend_prod_closure [options]")
    toolingUsagePrintOut("      native production closure gate runner (default BACKEND_PROD_INMEM_ONLY=1; release stability default 3x)")
    toolingUsagePrintOut("  backend-prod-publish [--dst:<dir>] [--manifest:<path>] [--bundle:<path>] [--name:<name>] [--driver:<path>]")
    toolingUsagePrintOut("      native publish entry (dev closure + release required gates + manifest/bundle/sign/verify/publish)")
    toolingUsagePrintOut("  infant-speak [--text:<text>] [--out-wav:<path>] [--out-json:<path>] [--sample-rate:<hz>] [--syllable-ms:<ms>] [--pause-ms:<ms>]")
    toolingUsagePrintOut("      compile+run cheng-ai infant speech entry directly (supports alias: `infant speak`)")
    toolingUsagePrintOut("  cheng --in:<file.cheng> [--out:<path>|--name:<name>] [--target:<triple>] [--run|--run:host|--run:file]")
    toolingUsagePrintOut("      canonical zero-script compiler entrypoint (dev-only, emit=exe, frontend=stage1)")
    toolingUsagePrintOut("  compile|chengc [same args as `cheng`]")
    toolingUsagePrintOut("      removed aliases (return rc=2); use `cheng`")
    toolingUsagePrintOut("  release-compile --in:<file.cheng> [--out:<path>|--name:<name>] [--emit:exe|shared|static] [--target:<triple>] [--run|--run:file]")
    toolingUsagePrintOut("      explicit release compiler entrypoint (system-link; shared/static use object-first packaging)")
    toolingUsagePrintOut("  stage0-ue-status [--limit:<N>|--all]")
    toolingUsagePrintOut("      inspect current stuck/orphan UE process set relevant to stage0/tooling")
    toolingUsagePrintOut("  stage0-ue-clean [--context:<name>] [--rechecks:<N>] [--strict:0|1] [--dry-run] [--global]")
    toolingUsagePrintOut("      attempt to clean stuck/orphan UE process set before running heavy commands")
    toolingUsagePrintOut("  cheng <file.cheng> [compile args]")
    toolingUsagePrintOut("      positional shorthand for `cheng --in:<file.cheng>`")
    toolingUsagePrintOut("  bootstrap-pure [--mode:fast|strict] [--compile-stage1|--no-compile-stage1] [--fullspec]")
    toolingUsagePrintOut("      zero-script pure selfhost bootstrap path")
    toolingUsagePrintOut("  bootstrap")
    toolingUsagePrintOut("      alias of bootstrap-pure")
    toolingUsagePrintOut("  list")
    toolingUsagePrintOut("      list all runnable tooling command IDs embedded in cheng_tooling")
    toolingUsagePrintOut("  embedded-ids")
    toolingUsagePrintOut("      alias of list (internal/native embed introspection)")
    toolingUsagePrintOut("  embedded-text --id:<script> | embedded-text <script>")
    toolingUsagePrintOut("      print embedded script payload text (internal/native embed introspection)")
    toolingUsagePrintOut("  embedded-map-rewrite [--out:<path>] [map_path] [out_path]")
    toolingUsagePrintOut("      rewrite embedded map as canonical Cheng source (native, no python)")
    toolingUsagePrintOut("  run <script> [args...]")
    toolingUsagePrintOut("      run script by name, for example: run backend_prod_closure --help")
    toolingUsagePrintOut("  install --dir:<path> [--bin:<path>] [--manifest:<path>] [--mode:symlink|hardlink|copy] [--force] [--only:<script>] [--exclude:<script>]")
    toolingUsagePrintOut("      install multicall links (one global binary drives all tooling script IDs)")
    toolingUsagePrintOut("  build-global [--out:<path>] [--linker:self] [--driver:<path>]")
    toolingUsagePrintOut("      build cheng_tooling as global native binary (dev-only self-link/in-memory mode)")
    toolingUsagePrintOut("  bundle [--out-dir:<path>] [--profile:full]... [--mode:symlink|hardlink|copy] [--linker:self] [--driver:<path>] [--force]")
    toolingUsagePrintOut("      build and install one or more global binaries by profile")
    toolingUsagePrintOut("  <script> [args...]")
    toolingUsagePrintOut("      shorthand for `run <script> [args...]`")
    toolingUsagePrintOut("")
    toolingUsagePrintOut("notes:")
    toolingUsagePrintOut("  - script can be `name` (or legacy `name.sh`, normalized to `name`).")
    toolingUsagePrintOut("  - all args after script are passed through as-is.")
    toolingUsagePrintOut("  - install filter flags are repeatable; --only narrows selection and --exclude removes from it.")
    toolingUsagePrintOut("  - multicall mode: if argv0 is a script ID (for example backend_prod_closure),")
    toolingUsagePrintOut("    cheng_tooling will dispatch to native command first, then embedded payload when needed.")
    toolingUsagePrintOut("  - recommended global install:")
    toolingUsagePrintOut("      cheng_tooling build-global --out:artifacts/tooling_cmd/cheng_tooling --linker:self")
    toolingUsagePrintOut("      artifacts/tooling_cmd/cheng_tooling install --dir:artifacts/tooling_cmd/bin --bin:artifacts/tooling_cmd/cheng_tooling --force")
    toolingUsagePrintOut("  - bundle profiles:")
    toolingUsagePrintOut("      full: all embedded tooling command IDs")

fn toolingPrintBackendProdClosureHelpFast() =
    toolingUsagePrintOut("Usage:")
    toolingUsagePrintOut("  cheng_tooling backend_prod_closure [--no-validate] [--debug] [--no-debug]")
    toolingUsagePrintOut("                                    [--selfhost|--no-selfhost]")
    toolingUsagePrintOut("                                    [--selfhost-fast|--selfhost-strict]")
    toolingUsagePrintOut("                                    [--self-linker-gates|--no-self-linker-gates]")
    toolingUsagePrintOut("                                    [--opt3-stable|--no-opt3-stable]")
    toolingUsagePrintOut("                                    [--opt3-extended|--no-opt3-extended]")
    toolingUsagePrintOut("                                    [--opt3-extended-enforce:0|1]")
    toolingUsagePrintOut("                                    [--linker-abi-core-cross|--no-linker-abi-core-cross]")
    toolingUsagePrintOut("                                    [--linker-abi-core-cross-report-only]")
    toolingUsagePrintOut("                                    [--linker-abi-core-cross-enforce:0|1]")
    toolingUsagePrintOut("                                    [--linker-abi-core-cross-targets:<csv|@file>]")
    toolingUsagePrintOut("                                    [--fullchain|--no-fullchain]")
    toolingUsagePrintOut("                                    [--no-publish] [--strict]")
    toolingUsagePrintOut("")
    toolingUsagePrintOut("Notes:")
    toolingUsagePrintOut("  - Runs self-hosted backend production closure required gates.")
    toolingUsagePrintOut("  - Uses native gate runner by default (no giant embedded payload load).")
    toolingUsagePrintOut("  - Default BACKEND_PROD_INMEM_ONLY=1; set BACKEND_PROD_INMEM_ONLY=0 only when running obj/fullchain gates.")
    toolingUsagePrintOut("  - Default required selfhost gate is strict fixed-point (stage2 SHA == stage3 SHA).")
    toolingUsagePrintOut("  - This command is dev-only closure; use `backend-prod-publish` for release/publish.")
