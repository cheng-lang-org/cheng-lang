import std/os
import std/seqs
import std/strutils as strutil
import std/strings
import tooling/cheng_tooling_embedded_inline
import tooling/cheng_tooling_embedded_normalize as tembednorm
import tooling/cheng_tooling_embedded_patch_closure_group as tembedclosure
import tooling/cheng_tooling_embedded_patch_dod_soa as tembeddodsoa
import tooling/cheng_tooling_embedded_patch_mm_hotpatch as tembedmm
import tooling/cheng_tooling_embedded_patch_preflight_group as tembedpreflight
import tooling/cheng_tooling_embedded_patch_proof_opt as tembedproof
import tooling/cheng_tooling_embedded_patch_runtime_group as tembedruntime
import tooling/cheng_tooling_embedded_patch_special_group as tembedspecial
import tooling/cheng_tooling_embedded_patch_targets as tembedtargets
import tooling/cheng_tooling_embedded_route_map as tembedroute

fn toolingEmbeddedDispatchStrNonEmpty(text: str): bool =
    return len(text) > 0

fn toolingEmbeddedDispatchIsSafeScriptName(name: str): bool =
    if !toolingEmbeddedDispatchStrNonEmpty(name):
        return false
    for i in 0..<len(name):
        let ch: char = name[i]
        if ch >= 'a' && ch <= 'z':
            continue
        if ch >= 'A' && ch <= 'Z':
            continue
        if ch >= '0' && ch <= '9':
            continue
        if ch == '_' || ch == '-' || ch == '.':
            continue
        return false
    return true

fn toolingEmbeddedDispatchRenderRawLines(lines: str[], trailingNewline: bool): str =
    let joined: str = strutil.join(lines, "\n")
    if trailingNewline:
        return joined + "\n"
    return joined

fn toolingEmbeddedDispatchNativeForwardScript(subcmd: str): str =
    var lines: str[] = []
    add(lines, "#!/usr/bin/env sh")
    add(lines, ":")
    add(lines, "set -eu")
    add(lines, "(set -o pipefail) 2>/dev/null && set -o pipefail")
    add(lines, "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"")
    add(lines, "exec \"$tool\" " + subcmd + " \"$@\"")
    return toolingEmbeddedDispatchRenderRawLines(lines, true)

fn toolingEmbeddedDispatchNormalizeScriptText(id: str, raw: str): str =
    return tembednorm.toolingNormalizeEmbeddedScriptText(id, raw)

fn toolingEmbeddedDispatchReadTextFile(root: str, pathRaw: str): str =
    var path: str = strutil.strip(pathRaw)
    if !toolingEmbeddedDispatchStrNonEmpty(path):
        return ""
    if !os.isAbsolute(path):
        path = os.joinPath(root, path)
    if !toolingEmbeddedDispatchStrNonEmpty(path) || !os.fileExists(path):
        return ""
    return os.readFile(path)

fn toolingEmbeddedScriptText(root: str, id: str): str =
    if !toolingEmbeddedDispatchIsSafeScriptName(id):
        return ""
    let nativeForwardSubcmd: str = tembedroute.toolingEmbeddedNativeForwardCommand(id)
    if toolingEmbeddedDispatchStrNonEmpty(nativeForwardSubcmd):
        return toolingEmbeddedDispatchNativeForwardScript(nativeForwardSubcmd)
    let repoScriptPath: str = tembedroute.toolingEmbeddedRepoScriptPath(id)
    if toolingEmbeddedDispatchStrNonEmpty(repoScriptPath):
        return toolingEmbeddedDispatchReadTextFile(root, repoScriptPath)
    if id == "verify_backend_coff_lld_link" ||
       id == "verify_backend_float" ||
       id == "verify_backend_multi_lto" ||
       id == "verify_backend_ffi_outptr_tuple":
        let rawSpecialGroup: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !toolingEmbeddedDispatchStrNonEmpty(rawSpecialGroup):
            return ""
        let patchedSpecialGroup: str = tembedspecial.toolingEmbeddedPatchSpecialGroup(id, rawSpecialGroup)
        if toolingEmbeddedDispatchStrNonEmpty(patchedSpecialGroup):
            return patchedSpecialGroup
        return rawSpecialGroup
    if id == "verify_backend_mm" ||
       id == "verify_backend_mem_exe_emit" ||
       id == "verify_backend_hotpatch" ||
       id == "verify_backend_hotpatch_meta" ||
       id == "verify_backend_mem_patch_regression":
        let rawFamily: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !toolingEmbeddedDispatchStrNonEmpty(rawFamily):
            return ""
        let patchedFamily: str = tembedmm.toolingEmbeddedPatchMmHotpatchFamily(id, rawFamily)
        if toolingEmbeddedDispatchStrNonEmpty(patchedFamily):
            return patchedFamily
        return rawFamily
    if id == "verify_backend_closedloop" ||
       id == "verify_stage1_fullspec" ||
       id == "verify_fullchain_bootstrap" ||
       id == "verify_backend_driver_selfbuild_smoke":
        let rawClosureGroup: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !toolingEmbeddedDispatchStrNonEmpty(rawClosureGroup):
            return ""
        let patchedClosureGroup: str = tembedclosure.toolingEmbeddedPatchClosureGroup(id, rawClosureGroup)
        if toolingEmbeddedDispatchStrNonEmpty(patchedClosureGroup):
            if id == "verify_backend_closedloop":
                return toolingEmbeddedDispatchNormalizeScriptText(id, patchedClosureGroup)
            return patchedClosureGroup
        return rawClosureGroup
    if id == "verify_backend_opt2":
        return toolingEmbeddedDispatchNativeForwardScript("verify_backend_opt2")
    if id == "verify_backend_opt3":
        return toolingEmbeddedDispatchNativeForwardScript("verify_backend_opt3")
    if id == "verify_backend_simd":
        return toolingEmbeddedDispatchNativeForwardScript("verify_backend_simd")
    if id == "verify_backend_ffi_slice_shim" ||
       id == "verify_cheng_skill_consistency" ||
       id == "verify_backend_x86_64_linux" ||
       id == "verify_backend_android" ||
       id == "verify_backend_targets" ||
       id == "verify_libp2p_frontier" ||
       id == "verify_backend_x86_64_darwin" ||
       id == "verify_backend_spawn_api_gate":
        let rawTargetsFamily: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !toolingEmbeddedDispatchStrNonEmpty(rawTargetsFamily):
            return ""
        let patchedTargetsFamily: str = tembedtargets.toolingEmbeddedPatchTargetsFamily(id, rawTargetsFamily)
        if toolingEmbeddedDispatchStrNonEmpty(patchedTargetsFamily):
            return patchedTargetsFamily
        return rawTargetsFamily
    if id == "verify_backend_targets_matrix":
        return toolingEmbeddedDispatchNativeForwardScript("verify_backend_targets")
    if id == "verify_backend_mir_borrow" ||
       id == "verify_backend_noalias_opt" ||
       id == "verify_backend_egraph_cost" ||
       id == "verify_backend_dod_opt_regression":
        let rawProofFamily: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !toolingEmbeddedDispatchStrNonEmpty(rawProofFamily):
            return ""
        let patchedProofFamily: str = tembedproof.toolingEmbeddedPatchProofOptFamily(id, rawProofFamily)
        if toolingEmbeddedDispatchStrNonEmpty(patchedProofFamily):
            return patchedProofFamily
        return rawProofFamily
    if id == "verify_backend_plugin_system" ||
       id == "verify_backend_metering_stream" ||
       id == "verify_backend_multi" ||
       id == "verify_backend_determinism" ||
       id == "verify_backend_uir_stability":
        let rawRuntimeGroup: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !toolingEmbeddedDispatchStrNonEmpty(rawRuntimeGroup):
            return ""
        let patchedRuntimeGroup: str = tembedruntime.toolingEmbeddedPatchRuntimeGroup(id, rawRuntimeGroup)
        if toolingEmbeddedDispatchStrNonEmpty(patchedRuntimeGroup):
            return patchedRuntimeGroup
        return rawRuntimeGroup
    if id == "verify_backend_dod_soa":
        return toolingEmbeddedDispatchRenderRawLines(tembeddodsoa.toolingEmbeddedPatchDodSoa(), true)
    if id == "verify_backend_abi_v2_noptr":
        return toolingEmbeddedDispatchNativeForwardScript("verify_backend_noptr_default_cli")
    if id == "verify_backend_noptr_default_cli" ||
       id == "verify_backend_stage0_no_compat" ||
       id == "verify_tooling_cmdline" ||
       id == "verify_backend_selfhost_strict_noreuse_probe" ||
       id == "verify_backend_nolibc_linux_aarch64":
        let rawPreflightGroup: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !toolingEmbeddedDispatchStrNonEmpty(rawPreflightGroup):
            return ""
        let patchedPreflightGroup: str = tembedpreflight.toolingEmbeddedPatchPreflightGroup(id, rawPreflightGroup)
        if toolingEmbeddedDispatchStrNonEmpty(patchedPreflightGroup):
            return patchedPreflightGroup
        return rawPreflightGroup
    if id == "verify_backend_selfhost_bootstrap_self_obj":
        return tooling_embedded_inline.toolingEmbeddedScriptBody(id)
    if id == "verify":
        return tooling_embedded_inline.toolingEmbeddedScriptBody(id)
    if id == "backend_prod_closure":
        return tooling_embedded_inline.toolingEmbeddedScriptBody(id)
    let raw: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
    if !toolingEmbeddedDispatchStrNonEmpty(raw):
        return ""
    if os.getEnvDefault("TOOLING_EMBEDDED_RUNTIME_NORMALIZE", "0") == "1":
        return toolingEmbeddedDispatchNormalizeScriptText(id, raw)
    return raw
