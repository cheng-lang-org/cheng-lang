# Selfhost bootstrap performance baseline (seconds).
# Environment variables with the same names can still override these defaults.

CHENG_SELFHOST_PERF_MAX_LOCK_WAIT="${CHENG_SELFHOST_PERF_MAX_LOCK_WAIT:-10}"
CHENG_SELFHOST_PERF_MAX_STAGE1="${CHENG_SELFHOST_PERF_MAX_STAGE1:-30}"
CHENG_SELFHOST_PERF_MAX_STAGE2="${CHENG_SELFHOST_PERF_MAX_STAGE2:-30}"
CHENG_SELFHOST_PERF_MAX_SMOKE_STAGE1="${CHENG_SELFHOST_PERF_MAX_SMOKE_STAGE1:-20}"
CHENG_SELFHOST_PERF_MAX_SMOKE_STAGE2="${CHENG_SELFHOST_PERF_MAX_SMOKE_STAGE2:-20}"
CHENG_SELFHOST_PERF_MAX_TOTAL="${CHENG_SELFHOST_PERF_MAX_TOTAL:-60}"
