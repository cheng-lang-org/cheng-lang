import std/os
import std/strutils as strutil

fn toolingInstallStrNonEmpty(text: str): bool =
    return len(text) > 0

fn toolingInstallShellQuote(raw: str): str =
    if len(raw) == 0:
        return "\"\""
    return "\"" + strutil.replace(
        strutil.replace(
            strutil.replace(
                strutil.replace(raw, "\\", "\\\\"),
                "$",
                "\\$"
            ),
            "`",
            "\\`"
        ),
        "\"",
        "\\\""
    ) + "\""

fn toolingInstallStartsWith(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true

fn toolingInstallPathAbsoluteText(root: str, text: str): str =
    if !toolingInstallStrNonEmpty(text):
        return ""
    if os.isAbsolute(text):
        return text
    if toolingInstallStartsWith(text, "./") || toolingInstallStartsWith(text, "../"):
        return os.absolutePath(text)
    if !toolingInstallStrNonEmpty(root):
        return text
    let n: int32 = len(root)
    if n > 0:
        let tail: char = root[n - 1]
        if tail == '/' || tail == '\\':
            return root + text
    return root + "/" + text

fn toolingInstallPathAbsolute(root: str, raw: str): str =
    return toolingInstallPathAbsoluteText(root, strutil.strip(raw))

fn toolingInstallPathExists(path: str): bool =
    if !toolingInstallStrNonEmpty(path):
        return false
    if os.fileExists(path):
        return true
    if os.dirExists(path):
        return true
    return false

fn toolingInstallExec(root: str, command: str): os.ExecCmdResult =
    let opts: uint64 = uint64(7)
    return os.execCmdEx(command, opts, root)

fn toolingInstallPrintExecOutput(result: os.ExecCmdResult) =
    if toolingInstallStrNonEmpty(os.execCmdResultOutput(result)):
        os.write(os.get_stdout(), os.execCmdResultOutput(result))

fn toolingInstallMkdirP(root: str, path: str): bool =
    let result: os.ExecCmdResult = toolingInstallExec(root, "mkdir -p " + toolingInstallShellQuote(path))
    toolingInstallPrintExecOutput(result)
    return os.execCmdResultExitCode(result) == 0

fn toolingInstallIdsContains(ids: str[], id: str): bool =
    for i in 0..<ids.len:
        if ids[i] == id:
            return true
    return false

fn toolingInstallSelectorContains(selector: str, id: str): bool =
    if !toolingInstallStrNonEmpty(selector) || !toolingInstallStrNonEmpty(id):
        return false
    return strutil.contains(selector, "," + id + ",")

fn toolingInstallNormalizeLinkModeText(text: str): str =
    if text == "symlink" || text == "hardlink" || text == "copy":
        return text
    return ""

fn toolingInstallNormalizeLinkMode(raw: str): str =
    return toolingInstallNormalizeLinkModeText(strutil.toLowerAscii(strutil.strip(raw)))

fn toolingInstallLinkPath(outDir: str, name: str): str =
    return os.joinPath(outDir, name)

fn toolingInstallLinkCommand(mode: str, force: bool, binPath: str, linkPath: str): str =
    if mode == "copy":
        if force:
            return "cp -f " + toolingInstallShellQuote(binPath) + " " + toolingInstallShellQuote(linkPath)
        return "cp " + toolingInstallShellQuote(binPath) + " " + toolingInstallShellQuote(linkPath)
    if mode == "hardlink":
        if force:
            return "ln -f " + toolingInstallShellQuote(binPath) + " " + toolingInstallShellQuote(linkPath)
        return "ln " + toolingInstallShellQuote(binPath) + " " + toolingInstallShellQuote(linkPath)
    if force:
        return "ln -sf " + toolingInstallShellQuote(binPath) + " " + toolingInstallShellQuote(linkPath)
    return "ln -s " + toolingInstallShellQuote(binPath) + " " + toolingInstallShellQuote(linkPath)

fn toolingInstallWriteManifest(root: str, manifestRaw: str, manifestRows: str[]) =
    if !toolingInstallStrNonEmpty(toolingInstallPathAbsolute(root, manifestRaw)):
        return
    os.writeFile(toolingInstallPathAbsolute(root, manifestRaw), strutil.join(manifestRows, "\n") + "\n")
    os.write(os.get_stdout(), "install_manifest=" + toolingInstallPathAbsolute(root, manifestRaw) + "\n")

fn toolingInstallLinksCore(root: str, idsRaw: str[], binPath: str, outDir: str, manifestRaw: str,
                           force: bool, onlySelector: str, excludeSelector: str, mode: str): int32 =
    if !toolingInstallStrNonEmpty(outDir):
        os.write(os.get_stderr(), "cheng_tooling: install requires --dir:<path>\n")
        return 1
    if !toolingInstallStrNonEmpty(binPath):
        os.write(os.get_stderr(), "cheng_tooling: install requires --bin:<path> (or runnable absolute program name)\n")
        return 1
    if !toolingInstallPathExists(binPath):
        os.write(os.get_stderr(), "cheng_tooling: install binary not found: " + binPath + "\n")
        return 1
    if !toolingInstallStrNonEmpty(mode):
        os.write(os.get_stderr(), "cheng_tooling: invalid --mode (expected symlink|hardlink|copy)\n")
        return 1
    if !toolingInstallMkdirP(root, outDir):
        os.write(os.get_stderr(), "cheng_tooling: failed to create install dir: " + outDir + "\n")
        return 1

    var ids: str[] = idsRaw
    if ids.len == 0:
        os.write(os.get_stderr(), "cheng_tooling: no scripts found under src/tooling\n")
        return 1
    if !toolingInstallIdsContains(ids, "cheng_tooling"):
        add(ids, "cheng_tooling")

    var manifestRows: str[] = ["name\tlink"]
    var selectedCount: int32 = 0
    var failCount: int32 = 0
    for i in 0..<ids.len:
        if toolingInstallStrNonEmpty(onlySelector) && !toolingInstallSelectorContains(onlySelector, ids[i]):
            continue
        if toolingInstallSelectorContains(excludeSelector, ids[i]):
            continue
        selectedCount = selectedCount + 1
        if !force && toolingInstallPathExists(toolingInstallLinkPath(outDir, ids[i])):
            add(manifestRows, ids[i] + "\t" + toolingInstallLinkPath(outDir, ids[i]))
            continue
        let result: os.ExecCmdResult =
            toolingInstallExec(root, toolingInstallLinkCommand(mode, force, binPath, toolingInstallLinkPath(outDir, ids[i])))
        let rc: int32 = os.execCmdResultExitCode(result)
        if rc == 0:
            add(manifestRows, ids[i] + "\t" + toolingInstallLinkPath(outDir, ids[i]))
            continue
        failCount = failCount + 1
        os.write(
            os.get_stderr(),
            "cheng_tooling: link failed: " + ids[i] + " -> " + toolingInstallLinkPath(outDir, ids[i]) + "\n"
        )
        toolingInstallPrintExecOutput(result)
    if selectedCount <= 0:
        os.write(os.get_stderr(), "cheng_tooling: install selection is empty (adjust --only/--exclude)\n")
        return 1
    if toolingInstallStrNonEmpty(manifestRaw):
        toolingInstallWriteManifest(root, manifestRaw, manifestRows)
    os.write(os.get_stdout(), "install_dir=" + outDir + "\n")
    os.write(os.get_stdout(), "install_bin=" + binPath + "\n")
    os.write(os.get_stdout(), "install_mode=" + mode + "\n")
    if failCount > 0:
        return 1
    return 0

fn toolingInstallLinks(root: str, idsRaw: str[], binPathRaw: str, dirRaw: str, manifestRaw: str,
                       force: bool, onlySelector: str, excludeSelector: str, modeRaw: str): int32 =
    return toolingInstallLinksCore(
        root,
        idsRaw,
        toolingInstallPathAbsolute(root, binPathRaw),
        toolingInstallPathAbsolute(root, dirRaw),
        manifestRaw,
        force,
        onlySelector,
        excludeSelector,
        toolingInstallNormalizeLinkMode(modeRaw)
    )
