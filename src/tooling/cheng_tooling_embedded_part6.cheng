oid_obj\" | awk 'index($0, \" T main\") { found = 1 } END { exit found ? 0 : 1 }'\n  elif nm \"$android_obj\" >/dev/null 2>&1; then\n    nm_has_symbol \"$android_obj\" \" T main\"\n  fi\nfi\n\necho \"verify_backend_targets ok\"\n"
