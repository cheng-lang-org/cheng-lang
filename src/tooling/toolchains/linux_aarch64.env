# Linux aarch64 toolchain template
export ASM_TARGET="aarch64-unknown-linux-gnu"
export ASM_ABI="elf"
# Optional sysroot:
# export ASM_SYSROOT="/path/to/sysroot"
# Optional compiler override:
# export ASM_CC="clang"
# Optional linker override:
# export ASM_LD="ld.lld"
# Optional prebuilt no-libc runtime object:
# export ASM_RUNTIME_OBJ="/path/to/system_helpers_backend_nolibc_linux_aarch64.o"
