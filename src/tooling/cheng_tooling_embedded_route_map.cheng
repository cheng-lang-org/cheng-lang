fn toolingEmbeddedRepoScriptPath(id: str): str =
    if id == "verify_backend_stage1_fixed0_envs":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_backend_stage1_fixed0_envs.sh"
    if id == "verify_backend_string_literal_regression":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_backend_string_literal_regression.sh"
    if id == "verify_new_expr_surface":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_new_expr_surface.sh"
    if id == "verify_backend_selfhost_currentsrc_proof":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_backend_selfhost_currentsrc_proof.sh"
    if id == "verify_backend_mir_borrow":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_backend_mir_borrow.sh"
    if id == "verify_backend_noalias_opt":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_backend_noalias_opt.sh"
    if id == "verify_backend_egraph_cost":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_backend_egraph_cost.sh"
    if id == "verify_backend_dod_opt_regression":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_backend_dod_opt_regression.sh"
    if id == "verify_tooling_cmdline":
        return "src/tooling/cheng_tooling_embedded_scripts/verify_tooling_cmdline.sh"
    if id == "verify_backend_rawptr_contract" || id == "verify_backend_rawptr_contract_shell":
        return "src/tooling/verify_backend_rawptr_contract_native.sh"
    return ""
