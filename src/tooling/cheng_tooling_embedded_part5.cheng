    if id == "verify_backend_selfhost_100ms_host":
        var chunks: str[] = []
        add(chunks, "#!/usr/bin/env sh\n")
        add(chunks, ":\n")
        add(chunks, "set -eu\n")
        add(chunks, "(set -o pipefail) 2>/dev/null && set -o pipefail\n")
        add(chunks, "\n")
        add(chunks, "usage() {\n")
        add(chunks, "  cat <<'EOF'\n")
        add(chunks, "Usage:\n")
        add(chunks, "  ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_selfhost_100ms_host [--help]\n")
        add(chunks, "\n")
        add(chunks, "Env:\n")
        add(chunks, "  SELFHOST_100MS_BASELINE=<path>          default: src/tooling/selfhost_perf_100ms_host.env\n")
        add(chunks, "  SELFHOST_100MS_HOST_ONLY=<tag>          default: darwin_arm64\n")
        add(chunks, "  SELFHOST_100MS_TRACK=quick|full          default: quick\n")
        add(chunks, "  SELFHOST_100MS_ITERS=<N>                default: 5 (quick) or SELFHOST_100MS_QUICK_ITERS (quick track)\n")
        add(chunks, "  SELFHOST_100MS_P95_MS=<ms>              default: 100 (quick) or SELFHOST_100MS_QUICK_P95_MS (quick track)\n")
        add(chunks, "  SELFHOST_100MS_P99_MS=<ms>              default: 120 (quick) or SELFHOST_100MS_QUICK_P99_MS (quick track)\n")
        add(chunks, "  SELFHOST_100MS_ENFORCE_ON_HOST=<0|1>    default: 1\n")
        add(chunks, "  SELFHOST_100MS_QUICK_ITERS=<N>          quick default: 3\n")
        add(chunks, "  SELFHOST_100MS_QUICK_P95_MS=<ms>        quick default: 30000\n")
        add(chunks, "  SELFHOST_100MS_QUICK_P99_MS=<ms>        quick default: 40000\n")
        add(chunks, "  SELFHOST_100MS_QUICK_ENFORCE_ON_HOST=<0|1> default: 0\n")
        add(chunks, "  SELFHOST_100MS_QUICK_REUSE=<0|1>        quick default: 1\n")
        add(chunks, "  SELFHOST_100MS_QUICK_TIMEOUT=<seconds>   quick compile timeout default: 60\n")
        add(chunks, "  SELFHOST_100MS_FULL_ITERS=<N>           full default: 3\n")
        add(chunks, "  SELFHOST_100MS_FULL_P95_MS=<ms>         full default: 100\n")
        add(chunks, "  SELFHOST_100MS_FULL_P99_MS=<ms>         full default: 120\n")
        add(chunks, "  SELFHOST_100MS_FULL_ENFORCE_ON_HOST=<0|1> default: 1\n")
        add(chunks, "  SELFHOST_100MS_FULL_REUSE=<0|1>         full default: 0\n")
        add(chunks, "  SELFHOST_100MS_FULL_TIMEOUT=<seconds>    full compile timeout default: 60\n")
        add(chunks, "  SELFHOST_100MS_REPORT=<path>            default: artifacts/backend_selfhost_100ms_host/report.tsv\n")
        add(chunks, "  SELFHOST_STRICT_REBUILD=<0|1>           override default by track\n")
        add(chunks, "  SELFHOST_STAGE1_FULL_REBUILD=<0|1>      override default by track\n")
        add(chunks, "  SELFHOST_STAGE1_REQUIRE_REBUILD=<0|1>   override default by track\n")
        add(chunks, "\n")
        add(chunks, "Notes:\n")
        add(chunks, "  - This gate is host-only and intended for dedicated perf runners.\n")
        add(chunks, "  - Non-target hosts are report-only (exit 0).\n")
        add(chunks, "EOF\n")
        add(chunks, "}\n")
        add(chunks, "\n")
        add(chunks, "for arg in \"$@\"; do\n")
        add(chunks, "  case \"$arg\" in\n")
        add(chunks, "    --help|-h)\n")
        add(chunks, "      usage\n")
        add(chunks, "      exit 0\n")
        add(chunks, "      ;;\n")
        add(chunks, "  esac\n")
        add(chunks, "done\n")
        add(chunks, "\n")
        add(chunks, "root=\"$(CDPATH= cd -- \"$(dirname -- \"$0\")/../..\" && pwd)\"\n")
        add(chunks, "cd \"$root\"\n")
        add(chunks, "\n")
        add(chunks, "baseline_file=\"${SELFHOST_100MS_BASELINE:-src/tooling/selfhost_perf_100ms_host.env}\"\n")
        add(chunks, "if [ ! -f \"$baseline_file\" ]; then\n")
        add(chunks, "  echo \"[selfhost_100ms] baseline file not found: $baseline_file\" >&2\n")
        add(chunks, "  exit 1\n")
        add(chunks, "fi\n")
        add(chunks, "# shellcheck disable=SC1090\n")
        add(chunks, ". \"$baseline_file\"\n")
        add(chunks, "\n")
        add(chunks, "host_os=\"$(uname -s 2>/dev/null | tr 'A-Z' 'a-z')\"\n")
        add(chunks, "host_arch=\"$(uname -m 2>/dev/null | tr 'A-Z' 'a-z')\"\n")
        add(chunks, "host_tag=\"${host_os}_${host_arch}\"\n")
        add(chunks, "if [ \"$host_os\" = \"darwin\" ] && [ \"$host_arch\" = \"arm64\" ]; then\n")
        add(chunks, "  host_tag=\"darwin_arm64\"\n")
        add(chunks, "fi\n")
        add(chunks, "\n")
        add(chunks, "host_only=\"${SELFHOST_100MS_HOST_ONLY:-darwin_arm64}\"\n")
        add(chunks, "track=\"${SELFHOST_100MS_TRACK:-${SELFHOST_100MS_FAST_TRACK:-quick}}\"\n")
        add(chunks, "case \"$track\" in\n")
        add(chunks, "  full)\n")
        add(chunks, "    ;;\n")
        add(chunks, "  quick)\n")
        add(chunks, "    ;;\n")
        add(chunks, "  *)\n")
        add(chunks, "    track=\"quick\"\n")
        add(chunks, "    ;;\n")
        add(chunks, "esac\n")
        add(chunks, "if [ \"$track\" = \"full\" ]; then\n")
        add(chunks, "  enforce=\"${SELFHOST_100MS_FULL_ENFORCE_ON_HOST:-${SELFHOST_100MS_ENFORCE_ON_HOST:-1}}\"\n")
        add(chunks, "  iters=\"${SELFHOST_100MS_FULL_ITERS:-${SELFHOST_100MS_ITERS:-3}}\"\n")
        add(chunks, "  p95_limit=\"${SELFHOST_100MS_FULL_P95_MS:-${SELFHOST_100MS_P95_MS:-100}}\"\n")
        add(chunks, "  p99_limit=\"${SELFHOST_100MS_FULL_P99_MS:-${SELFHOST_100MS_P99_MS:-120}}\"\n")
        add(chunks, "  bootstrap_reuse=\"${SELFHOST_100MS_FULL_REUSE:-0}\"\n")
        add(chunks, "  bootstrap_timeout=\"${SELFHOST_100MS_FULL_TIMEOUT:-60}\"\n")
        add(chunks, "  strict_rebuild_default=\"1\"\n")
        add(chunks, "  stage1_full_rebuild_default=\"1\"\n")
        add(chunks, "  stage1_require_rebuild_default=\"1\"\n")
        add(chunks, "else\n")
        add(chunks, "  enforce=\"${SELFHOST_100MS_QUICK_ENFORCE_ON_HOST:-${SELFHOST_100MS_ENFORCE_ON_HOST:-0}}\"\n")
        add(chunks, "  iters=\"${SELFHOST_100MS_QUICK_ITERS:-${SELFHOST_100MS_ITERS:-3}}\"\n")
        add(chunks, "  p95_limit=\"${SELFHOST_100MS_QUICK_P95_MS:-${SELFHOST_100MS_P95_MS:-30000}}\"\n")
        add(chunks, "  p99_limit=\"${SELFHOST_100MS_QUICK_P99_MS:-${SELFHOST_100MS_P99_MS:-40000}}\"\n")
        add(chunks, "  bootstrap_reuse=\"${SELFHOST_100MS_QUICK_REUSE:-1}\"\n")
        add(chunks, "  bootstrap_timeout=\"${SELFHOST_100MS_QUICK_TIMEOUT:-60}\"\n")
        add(chunks, "  strict_rebuild_default=\"0\"\n")
        add(chunks, "  stage1_full_rebuild_default=\"0\"\n")
        add(chunks, "  stage1_require_rebuild_default=\"0\"\n")
        add(chunks, "fi\n")
        add(chunks, "\n")
        add(chunks, "if [ \"${SELFHOST_100MS_ENFORCE_ON_HOST+x}\" != \"\" ]; then\n")
        add(chunks, "  enforce=\"$SELFHOST_100MS_ENFORCE_ON_HOST\"\n")
        add(chunks, "fi\n")
        add(chunks, "if [ \"${SELF_OBJ_BOOTSTRAP_REUSE+x}\" != \"\" ]; then\n")
        add(chunks, "  bootstrap_reuse=\"$SELF_OBJ_BOOTSTRAP_REUSE\"\n")
        add(chunks, "fi\n")
        add(chunks, "if [ \"${SELF_OBJ_BOOTSTRAP_TIMEOUT+x}\" != \"\" ]; then\n")
        add(chunks, "  bootstrap_timeout=\"$SELF_OBJ_BOOTSTRAP_TIMEOUT\"\n")
        add(chunks, "fi\n")
        add(chunks, "strict_rebuild=\"${SELFHOST_STRICT_REBUILD:-$strict_rebuild_default}\"\n")
        add(chunks, "stage1_full_rebuild=\"${SELFHOST_STAGE1_FULL_REBUILD:-$stage1_full_rebuild_default}\"\n")
        add(chunks, "stage1_require_rebuild=\"${SELFHOST_STAGE1_REQUIRE_REBUILD:-$stage1_require_rebuild_default}\"\n")
        add(chunks, "\n")
        add(chunks, "case \"$iters\" in\n")
        add(chunks, "  ''|*[!0-9]*|0) iters=5 ;;\n")
        add(chunks, "esac\n")
        add(chunks, "case \"$p95_limit\" in\n")
        add(chunks, "  ''|*[!0-9]*) p95_limit=100 ;;\n")
        add(chunks, "esac\n")
        add(chunks, "case \"$p99_limit\" in\n")
        add(chunks, "  ''|*[!0-9]*) p99_limit=120 ;;\n")
        add(chunks, "esac\n")
        add(chunks, "case \"$enforce\" in\n")
        add(chunks, "  0|1) ;;\n")
        add(chunks, "  *) enforce=1 ;;\n")
        add(chunks, "esac\n")
        add(chunks, "\n")
        add(chunks, "out_dir=\"artifacts/backend_selfhost_100ms_host\"\n")
        add(chunks, "mkdir -p \"$out_dir\"\n")
        add(chunks, "report=\"${SELFHOST_100MS_REPORT:-$out_dir/report.tsv}\"\n")
        add(chunks, "values_file=\"$out_dir/totals_ms.tsv\"\n")
        add(chunks, "sorted_file=\"$out_dir/totals_ms.sorted.tsv\"\n")
        add(chunks, ": >\"$values_file\"\n")
        add(chunks, "\n")
        add(chunks, "if [ \"$host_only\" != \"\" ] && [ \"$host_tag\" != \"$host_only\" ]; then\n")
        add(chunks, "  {\n")
        add(chunks, "    printf 'host=%s\\n' \"$host_tag\"\n")
        add(chunks, "    printf 'host_only=%s\\n' \"$host_only\"\n")
        add(chunks, "    printf 'status=skip_non_target_host\\n'\n")
        add(chunks, "  } >\"$report\"\n")
        add(chunks, "  echo \"[selfhost_100ms] skip on non-target host: host=$host_tag target=$host_only\"\n")
        add(chunks, "  exit 0\n")
        add(chunks, "fi\n")
        add(chunks, "\n")
        add(chunks, "run_id=\"selfhost100ms.$$\"\n")
        add(chunks, "i=1\n")
        add(chunks, "while [ \"$i\" -le \"$iters\" ]; do\n")
        add(chunks, "  session=\"$run_id.$i\"\n")
        add(chunks, "  timing_file=\"$out_dir/selfhost_timing_${session}.tsv\"\n")
        add(chunks, "  rm -f \"$timing_file\"\n")
        add(chunks, "  echo \"[selfhost_100ms] run $i/$iters session=$session\"\n")
        add(chunks, "  env \\\n")
        add(chunks, "    SELF_OBJ_BOOTSTRAP_MODE=fast \\\n")
        add(chunks, "    SELF_OBJ_BOOTSTRAP_REUSE=\"$bootstrap_reuse\" \\\n")
        add(chunks, "    SELF_OBJ_BOOTSTRAP_TIMEOUT=\"$bootstrap_timeout\" \\\n")
        add(chunks, "    SELFHOST_STRICT_REBUILD=\"$strict_rebuild\" \\\n")
        add(chunks, "    SELFHOST_STAGE1_FULL_REBUILD=\"$stage1_full_rebuild\" \\\n")
        add(chunks, "    SELFHOST_STAGE1_REQUIRE_REBUILD=\"$stage1_require_rebuild\" \\\n")
        add(chunks, "    SELF_OBJ_BOOTSTRAP_SESSION=\"$session\" \\\n")
        add(chunks, "    SELF_OBJ_BOOTSTRAP_TIMING_OUT=\"$timing_file\" \\\n")
        add(chunks, "    ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_selfhost_bootstrap_fast >/dev/null\n")
        add(chunks, "  if [ ! -s \"$timing_file\" ]; then\n")
        add(chunks, "    echo \"[selfhost_100ms] missing timing file: $timing_file\" >&2\n")
        add(chunks, "    exit 1\n")
        add(chunks, "  fi\n")
        add(chunks, "  total_s=\"$(awk -F '\\t' '$1==\"total\"{print $3; exit}' \"$timing_file\")\"\n")
        add(chunks, "  if [ \"$total_s\" = \"\" ]; then\n")
        add(chunks, "    echo \"[selfhost_100ms] missing total stage in timing file: $timing_file\" >&2\n")
        add(chunks, "    exit 1\n")
        add(chunks, "  fi\n")
        add(chunks, "  total_ms=\"$(awk -v s=\"$total_s\" 'BEGIN{ printf(\"%.0f\", s*1000.0) }')\"\n")
        add(chunks, "  printf '%s\\n' \"$total_ms\" >>\"$values_file\"\n")
        add(chunks, "  i=$((i + 1))\n")
        add(chunks, "done\n")
        add(chunks, "\n")
        add(chunks, "sort -n \"$values_file\" >\"$sorted_file\"\n")
        add(chunks, "\n")
        add(chunks, "pick_percentile() {\n")
        add(chunks, "  pct=\"$1\"\n")
        add(chunks, "  awk -v p=\"$pct\" '\n")
        add(chunks, "    { a[++n] = $1 }\n")
        add(chunks, "    END {\n")
        add(chunks, "      if (n <= 0) {\n")
        add(chunks, "        print -1\n")
        add(chunks, "        exit\n")
        add(chunks, "      }\n")
        add(chunks, "      k = int((p * n + 99) / 100)\n")
        add(chunks, "      if (k < 1) k = 1\n")
        add(chunks, "      if (k > n) k = n\n")
        add(chunks, "      print a[k]\n")
        add(chunks, "    }\n")
        add(chunks, "  ' \"$sorted_file\"\n")
        add(chunks, "}\n")
        add(chunks, "\n")
        add(chunks, "p95_ms=\"$(pick_percentile 95)\"\n")
        add(chunks, "p99_ms=\"$(pick_percentile 99)\"\n")
        add(chunks, "max_ms=\"$(awk 'BEGIN{m=0} { if ($1>m) m=$1 } END{ print m+0 }' \"$sorted_file\")\"\n")
        add(chunks, "\n")
        add(chunks, "status=\"ok\"\n")
        add(chunks, "if [ \"$p95_ms\" -gt \"$p95_limit\" ] || [ \"$p99_ms\" -gt \"$p99_limit\" ]; then\n")
        add(chunks, "  status=\"regression\"\n")
        add(chunks, "fi\n")
        add(chunks, "\n")
        add(chunks, "{\n")
        add(chunks, "  printf 'host=%s\\n' \"$host_tag\"\n")
        add(chunks, "  printf 'iters=%s\\n' \"$iters\"\n")
        add(chunks, "  printf 'p95_ms=%s\\n' \"$p95_ms\"\n")
        add(chunks, "  printf 'p99_ms=%s\\n' \"$p99_ms\"\n")
        add(chunks, "  printf 'max_ms=%s\\n' \"$max_ms\"\n")
        add(chunks, "  printf 'limit_p95_ms=%s\\n' \"$p95_limit\"\n")
        add(chunks, "  printf 'limit_p99_ms=%s\\n' \"$p99_limit\"\n")
        add(chunks, "  printf 'status=%s\\n' \"$status\"\n")
        add(chunks, "} >\"$report\"\n")
        add(chunks, "\n")
        add(chunks, "echo \"[selfhost_100ms] host=$host_tag p95=${p95_ms}ms p99=${p99_ms}ms max=${max_ms}ms status=$status\"\n")
        add(chunks, "\n")
        add(chunks, "if [ \"$status\" != \"ok\" ] && [ \"$enforce\" = \"1\" ]; then\n")
        add(chunks, "  echo \"[selfhost_100ms] regression: p95>${p95_limit}ms or p99>${p99_limit}ms\" >&2\n")
        add(chunks, "  exit 1\n")
        add(chunks, "fi\n")
        add(chunks, "\n")
        add(chunks, "exit 0\n")
        return toolingEmbeddedJoinChunks(chunks)
    if id == "verify_backend_selfhost_100ms_host_legacy":
        var chunks: str[] = []
        add(chunks, "#!/usr/bin/env sh\n:\nset -eu\n(set -o pipefail) 2>/dev/null && set -o pipefail\n\nusage() {\n  cat <<'EOF'\nUsage:\n  ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_selfhost_100ms_host [--help]\n\nEnv:\n  SELFHOST_100MS_BASELINE=<path>          default: src/tooling/selfhost_perf_100ms_host.env\n  SELFHOST_100MS_HOST_ONLY=<tag>          default: darwin_arm64\n  SELFHOST_100MS_ITERS=<N>                default: 5\n  SELFHOST_100MS_P95_MS=<ms>              default: 100\n  SELFHOST_100MS_P99_MS=<ms>              default: 120\n  SELFHOST_100MS_ENFORCE_ON_HOST=<0|1>    default: 1\n  SELFHOST_100MS_REPORT=<path>            default: artifacts/backend_selfhost_100ms_host/report.tsv\n\nNotes:\n  - This gate is host-only and intended for dedicated perf runners.\n  - Non-target hosts are report-only (exit 0).\nEOF\n}\n\nfor arg in \"$@\"; do\n  case \"$arg\" in\n    --help|-h)\n      usage\n      exit 0\n      ;;\n  esac\ndone\n\nroot=\"$(CDPATH= cd -- \"$(dirname -- \"$0\")/../..\" && pwd)\"\ncd \"$root\"\n\nbaseline_file=\"${SELFHOST_100MS_BASELINE:-src/tooling/selfhost_perf_100ms_host.env}\"\nif [ ! -f \"$baseline_file\" ]; then\n  echo \"[selfhost_100ms] baseline file not found: $baseline_file\" >&2\n  exit 1\nfi\n# shellcheck disable=SC1090\n. \"$baseline_file\"\n\nhost_os=\"$(uname -s 2>/dev/null | tr 'A-Z' 'a-z')\"\nhost_arch=\"$(uname -m 2>/dev/null | tr 'A-Z' 'a-z')\"\nhost_tag=\"${host_os}_${host_arch}\"\nif [ \"$host_os\" = \"darwin\" ] && [ \"$host_arch\" = \"arm64\" ]; then\n  host_tag=\"darwin_arm64\"\nfi\n\nhost_only=\"${SELFHOST_100MS_HOST_ONLY:-darwin_arm64}\"\nenforce=\"${SELFHOST_100MS_ENFORCE_ON_HOST:-1}\"\niters=\"${SELFHOST_100MS_ITERS:-5}\"\np95_limit=\"${SELFHOST_100MS_P95_MS:-100}\"\np99_limit=\"${SELFHOST_100MS_P99_MS:-120}\"\n\nca")
        add(chunks, "se \"$iters\" in\n  ''|*[!0-9]*|0) iters=5 ;;\nesac\ncase \"$p95_limit\" in\n  ''|*[!0-9]*) p95_limit=100 ;;\nesac\ncase \"$p99_limit\" in\n  ''|*[!0-9]*) p99_limit=120 ;;\nesac\ncase \"$enforce\" in\n  0|1) ;;\n  *) enforce=1 ;;\nesac\n\nout_dir=\"artifacts/backend_selfhost_100ms_host\"\nmkdir -p \"$out_dir\"\nreport=\"${SELFHOST_100MS_REPORT:-$out_dir/report.tsv}\"\nvalues_file=\"$out_dir/totals_ms.tsv\"\nsorted_file=\"$out_dir/totals_ms.sorted.tsv\"\n: >\"$values_file\"\n\nif [ \"$host_only\" != \"\" ] && [ \"$host_tag\" != \"$host_only\" ]; then\n  {\n    printf 'host=%s\\n' \"$host_tag\"\n    printf 'host_only=%s\\n' \"$host_only\"\n    printf 'status=skip_non_target_host\\n'\n  } >\"$report\"\n  echo \"[selfhost_100ms] skip on non-target host: host=$host_tag target=$host_only\"\n  exit 0\nfi\n\nrun_id=\"selfhost100ms.$$\"\ni=1\nwhile [ \"$i\" -le \"$iters\" ]; do\n  session=\"$run_id.$i\"\n  timing_file=\"$out_dir/selfhost_timing_${session}.tsv\"\n  rm -f \"$timing_file\"\n  echo \"[selfhost_100ms] run $i/$iters session=$session\"\n  env \\\n    SELF_OBJ_BOOTSTRAP_MODE=fast \\\n    SELF_OBJ_BOOTSTRAP_REUSE=0 \\\n    SELF_OBJ_BOOTSTRAP_SESSION=\"$session\" \\\n    SELF_OBJ_BOOTSTRAP_TIMING_OUT=\"$timing_file\" \\\n    ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_selfhost_bootstrap_fast >/dev/null\n  if [ ! -s \"$timing_file\" ]; then\n    echo \"[selfhost_100ms] missing timing file: $timing_file\" >&2\n    exit 1\n  fi\n  total_s=\"$(awk -F '\\t' '$1==\"total\"{print $3; exit}' \"$timing_file\")\"\n  if [ \"$total_s\" = \"\" ]; then\n    echo \"[selfhost_100ms] missing total stage in timing file: $timing_file\" >&2\n    exit 1\n  fi\n  total_ms=\"$(awk -v s=\"$total_s\" 'BEGIN{ printf(\"%.0f\", s*1000.0) }')\"\n  printf '%s\\n' \"$total_m")
        add(chunks, "s\" >>\"$values_file\"\n  i=$((i + 1))\ndone\n\nsort -n \"$values_file\" >\"$sorted_file\"\n\npick_percentile() {\n  pct=\"$1\"\n  awk -v p=\"$pct\" '\n    { a[++n] = $1 }\n    END {\n      if (n <= 0) {\n        print -1\n        exit\n      }\n      k = int((p * n + 99) / 100)\n      if (k < 1) k = 1\n      if (k > n) k = n\n      print a[k]\n    }\n  ' \"$sorted_file\"\n}\n\np95_ms=\"$(pick_percentile 95)\"\np99_ms=\"$(pick_percentile 99)\"\nmax_ms=\"$(awk 'BEGIN{m=0} { if ($1>m) m=$1 } END{ print m+0 }' \"$sorted_file\")\"\n\nstatus=\"ok\"\nif [ \"$p95_ms\" -gt \"$p95_limit\" ] || [ \"$p99_ms\" -gt \"$p99_limit\" ]; then\n  status=\"regression\"\nfi\n\n{\n  printf 'host=%s\\n' \"$host_tag\"\n  printf 'iters=%s\\n' \"$iters\"\n  printf 'p95_ms=%s\\n' \"$p95_ms\"\n  printf 'p99_ms=%s\\n' \"$p99_ms\"\n  printf 'max_ms=%s\\n' \"$max_ms\"\n  printf 'limit_p95_ms=%s\\n' \"$p95_limit\"\n  printf 'limit_p99_ms=%s\\n' \"$p99_limit\"\n  printf 'status=%s\\n' \"$status\"\n} >\"$report\"\n\necho \"[selfhost_100ms] host=$host_tag p95=${p95_ms}ms p99=${p99_ms}ms max=${max_ms}ms status=$status\"\n\nif [ \"$status\" != \"ok\" ] && [ \"$enforce\" = \"1\" ]; then\n  echo \"[selfhost_100ms] regression: p95>${p95_limit}ms or p99>${p99_limit}ms\" >&2\n  exit 1\nfi\n\nexit 0\n")
        return toolingEmbeddedJoinChunks(chunks)
    if id == "verify_backend_selfhost_bootstrap":
        return "#!/usr/bin/env sh\n:\nset -eu\n(set -o pipefail) 2>/dev/null && set -o pipefail\n\nroot=\"$(CDPATH= cd -- \"$(dirname -- \"$0\")/../..\" && pwd)\"\ncd \"$root\"\n\n# NOTE: asm backend removed. This script keeps a stable entrypoint name and\n# delegates to the self-obj bootstrap verifier.\n\nset +e\n${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_selfhost_bootstrap_self_obj\nrc=\"$?\"\nset -e\nif [ \"$rc\" -ne 0 ]; then\n  exit \"$rc\"\nfi\n\nstage2_src=\"artifacts/backend_selfhost_self_obj/cheng.stage2\"\n[ -x \"$stage2_src\" ]\n\necho \"verify_backend_selfhost_bootstrap ok\"\n"
