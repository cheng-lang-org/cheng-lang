# Host-only 100ms bootstrap gate baseline (Darwin arm64 dedicated perf runner).
# Environment variables with the same names can override these defaults.
# Two-track policy:
#   - QUICK track: compile-stage1 quick rebuild (report-only by default)
#   - FULL  track: compile-stage1 full rebuild (blocking by default)
# Last refreshed: 2026-02-24

# Two-track policy: quick (default) and full.
SELFHOST_100MS_HOST_ONLY="${SELFHOST_100MS_HOST_ONLY:-darwin_arm64}"
SELFHOST_100MS_TRACK="${SELFHOST_100MS_TRACK:-quick}"
SELFHOST_100MS_ITERS="${SELFHOST_100MS_ITERS:-5}"
SELFHOST_100MS_P95_MS="${SELFHOST_100MS_P95_MS:-100}"
SELFHOST_100MS_P99_MS="${SELFHOST_100MS_P99_MS:-120}"
SELFHOST_100MS_ENFORCE_ON_HOST="${SELFHOST_100MS_ENFORCE_ON_HOST:-1}"

SELFHOST_100MS_QUICK_ITERS="${SELFHOST_100MS_QUICK_ITERS:-3}"
SELFHOST_100MS_QUICK_P95_MS="${SELFHOST_100MS_QUICK_P95_MS:-30000}"
SELFHOST_100MS_QUICK_P99_MS="${SELFHOST_100MS_QUICK_P99_MS:-40000}"
SELFHOST_100MS_QUICK_ENFORCE_ON_HOST="${SELFHOST_100MS_QUICK_ENFORCE_ON_HOST:-0}"
SELFHOST_100MS_QUICK_REUSE="${SELFHOST_100MS_QUICK_REUSE:-1}"
SELFHOST_100MS_QUICK_TIMEOUT="${SELFHOST_100MS_QUICK_TIMEOUT:-60}"

SELFHOST_100MS_FULL_ITERS="${SELFHOST_100MS_FULL_ITERS:-3}"
SELFHOST_100MS_FULL_P95_MS="${SELFHOST_100MS_FULL_P95_MS:-100}"
SELFHOST_100MS_FULL_P99_MS="${SELFHOST_100MS_FULL_P99_MS:-120}"
SELFHOST_100MS_FULL_ENFORCE_ON_HOST="${SELFHOST_100MS_FULL_ENFORCE_ON_HOST:-1}"
SELFHOST_100MS_FULL_ENFORCE_WITH_COMPILE_STAGE1="${SELFHOST_100MS_FULL_ENFORCE_WITH_COMPILE_STAGE1:-1}"
SELFHOST_100MS_FULL_REUSE="${SELFHOST_100MS_FULL_REUSE:-0}"
SELFHOST_100MS_FULL_TIMEOUT="${SELFHOST_100MS_FULL_TIMEOUT:-60}"

# Optional track-level rebuild overrides.
SELFHOST_STRICT_REBUILD="${SELFHOST_STRICT_REBUILD:-0}"
SELFHOST_STAGE1_FULL_REBUILD="${SELFHOST_STAGE1_FULL_REBUILD:-0}"
SELFHOST_STAGE1_REQUIRE_REBUILD="${SELFHOST_STAGE1_REQUIRE_REBUILD:-0}"
