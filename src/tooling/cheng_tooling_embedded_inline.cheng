fn toolingEmbeddedAppendIds(out: str[]*, values: str[]) =
    if out == nil:
        return
    for i in 0..<values.len:
        add(*out, values[i])

fn toolingEmbeddedScriptIds(): str[] =
    var out: str[] = []
    toolingEmbeddedAppendIds(&out, part1.toolingEmbeddedScriptIdsPart1())
    toolingEmbeddedAppendIds(&out, part2.toolingEmbeddedScriptIdsPart2())
    toolingEmbeddedAppendIds(&out, part3.toolingEmbeddedScriptIdsPart3())
    toolingEmbeddedAppendIds(&out, part4.toolingEmbeddedScriptIdsPart4())
    toolingEmbeddedAppendIds(&out, part5.toolingEmbeddedScriptIdsPart5())
    toolingEmbeddedAppendIds(&out, part6.toolingEmbeddedScriptIdsPart6())
    return out

fn toolingEmbeddedScriptBody(id: str): str =
    let part1Body: str = part1.toolingEmbeddedScriptBodyPart1(id)
    if len(part1Body) > 0:
        return part1Body
    let part2Body: str = part2.toolingEmbeddedScriptBodyPart2(id)
    if len(part2Body) > 0:
        return part2Body
    let part3Body: str = part3.toolingEmbeddedScriptBodyPart3(id)
    if len(part3Body) > 0:
        return part3Body
    let part4Body: str = part4.toolingEmbeddedScriptBodyPart4(id)
    if len(part4Body) > 0:
        return part4Body
    let part5Body: str = part5.toolingEmbeddedScriptBodyPart5(id)
    if len(part5Body) > 0:
        return part5Body
    let part6Body: str = part6.toolingEmbeddedScriptBodyPart6(id)
    if len(part6Body) > 0:
        return part6Body
    return ""
