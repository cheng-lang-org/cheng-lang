fn tooling_cmdBuildBackendStringAbiContract(root: str, outFile: str, doc: str, formalDoc: str,
                                            toolingDoc: str, matrixDoc: str): int32 =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then echo \"[build_backend_string_abi_contract] rg is required\" >&2; exit 2; fi; ")
    add(parts, "hash_file() { file=\"$1\"; if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; cksum \"$file\" | awk '{print $1}'; }; ")
    add(parts, "read_marker_value() { file=\"$1\"; marker_regex=\"$2\"; rg -o \"${marker_regex}=[A-Za-z0-9_]+\" \"$file\" | head -n 1 | cut -d= -f2 || true; }; ")
    add(parts, "require_marker_value() { file=\"$1\"; marker_regex=\"$2\"; marker_name=\"$3\"; expected=\"$4\"; value=\"$(read_marker_value \"$file\" \"$marker_regex\")\"; if [ \"$value\" != \"$expected\" ]; then echo \"[build_backend_string_abi_contract] ${marker_name} must be ${expected} in: $file\" >&2; exit 2; fi; printf '%s\\n' \"$value\"; }; ")
    add(parts, "out=")
    add(parts, tooling_shellQuote(outFile))
    add(parts, "; doc=")
    add(parts, tooling_shellQuote(doc))
    add(parts, "; formal_doc=")
    add(parts, tooling_shellQuote(formalDoc))
    add(parts, "; tooling_doc=")
    add(parts, tooling_shellQuote(toolingDoc))
    add(parts, "; matrix_doc=")
    add(parts, tooling_shellQuote(matrixDoc))
    add(parts, "; ")
    add(parts, "machine_types=\"src/backend/machine/machine_types.cheng\"; isel_shared=\"src/backend/machine/select_internal/isel_parallel_shared.cheng\"; coff_writer=\"src/backend/obj/coff_writer_x86_64.cheng\"; elf_writer=\"src/backend/obj/elf_writer.cheng\"; uir_codegen=\"src/backend/uir/uir_codegen.cheng\"; tooling_file=\"src/tooling/cheng_tooling.cheng\"; ")
    add(parts, "for required in \"$doc\" \"$formal_doc\" \"$tooling_doc\" \"$matrix_doc\" \"$machine_types\" \"$isel_shared\" \"$coff_writer\" \"$elf_writer\" \"$uir_codegen\" \"$tooling_file\"; do if [ ! -f \"$required\" ]; then echo \"[build_backend_string_abi_contract] missing file: $required\" >&2; exit 2; fi; done; ")
    add(parts, "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_string_abi_contract_markers.XXXXXX\")\"; tmp_source_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_string_abi_contract_sources.XXXXXX\")\"; ")
    add(parts, "cleanup() { rm -f \"$tmp_markers\" \"$tmp_source_markers\"; }; trap cleanup EXIT; ")
    add(parts, "{ rg -o 'string_abi_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$doc\" || true; rg -o 'string_abi_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$formal_doc\" || true; rg -o 'string_abi_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$tooling_doc\" || true; rg -o 'string_abi_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$matrix_doc\" || true; } | LC_ALL=C sort -u >\"$tmp_markers\"; ")
    add(parts, "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; if [ \"$marker_count\" -eq 0 ]; then echo \"[build_backend_string_abi_contract] no contract markers found\" >&2; exit 2; fi; ")
    add(parts, "contract_version=\"$(read_marker_value \"$doc\" 'string_abi_contract\\.version')\"; if [ \"$contract_version\" = \"\" ]; then echo \"[build_backend_string_abi_contract] missing string_abi_contract.version marker in: $doc\" >&2; exit 2; fi; ")
    add(parts, "doc_scheme_id=\"$(require_marker_value \"$doc\" 'string_abi_contract\\.scheme\\.id' 'string_abi_contract.scheme.id' 'SABI')\"; ")
    add(parts, "doc_scheme_name=\"$(require_marker_value \"$doc\" 'string_abi_contract\\.scheme\\.name' 'string_abi_contract.scheme.name' 'backend_string_abi_contract')\"; ")
    add(parts, "doc_scheme_normative=\"$(require_marker_value \"$doc\" 'string_abi_contract\\.scheme\\.normative' 'string_abi_contract.scheme.normative' '1')\"; ")
    add(parts, "doc_enforce_mode=\"$(require_marker_value \"$doc\" 'string_abi_contract\\.enforce\\.mode' 'string_abi_contract.enforce.mode' 'default_verify')\"; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.language\\.str' 'string_abi_contract.language.str' 'value_semantics' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.abi\\.cstring' 'string_abi_contract.abi.cstring' 'ffi_boundary' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.nil_compare\\.cstring_only' 'string_abi_contract.nil_compare.cstring_only' '1' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.selector_cstring_lowering\\.user_abi' 'string_abi_contract.selector_cstring_lowering.user_abi' '0' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.closure' 'string_abi_contract.closure' 'required' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'string_abi_contract\\.scheme\\.id' 'string_abi_contract.scheme.id' 'SABI' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'string_abi_contract\\.scheme\\.name' 'string_abi_contract.scheme.name' 'backend_string_abi_contract' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'string_abi_contract\\.scheme\\.normative' 'string_abi_contract.scheme.normative' '1' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'string_abi_contract\\.enforce\\.mode' 'string_abi_contract.enforce.mode' 'default_verify' >/dev/null; ")
    add(parts, "if ! rg -q 'string_abi_contract\\.formal_spec\\.synced=1' \"$formal_doc\"; then echo \"[build_backend_string_abi_contract] missing formal spec sync marker: $formal_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'string_abi_contract\\.tooling_readme\\.synced=1' \"$tooling_doc\"; then echo \"[build_backend_string_abi_contract] missing tooling README sync marker: $tooling_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'string_abi_contract\\.matrix\\.synced=1' \"$matrix_doc\"; then echo \"[build_backend_string_abi_contract] missing matrix sync marker: $matrix_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'string_abi_contract\\.selector_cstring_lowering\\.user_abi=0' \"$tooling_doc\"; then echo \"[build_backend_string_abi_contract] missing tooling README selector/user ABI marker\" >&2; exit 2; fi; ")
    add(parts, "{ rg -o 'selector cstring lowering is always enabled on the production machine surface' \"$machine_types\" || true; rg -o 'selector-owned cstring lowering materializes MachineCString payloads before object writers' \"$isel_shared\" || true; rg -o 'Selector owns cstring materialization' \"$coff_writer\" || true; rg -o 'ELF writer consumes selector-owned cstring materialization' \"$elf_writer\" || true; rg -o 'selector_missing cstring payloads is a hard error' \"$uir_codegen\" || true; } | LC_ALL=C sort -u >\"$tmp_source_markers\"; ")
    add(parts, "selector_marker_count=\"$(wc -l < \"$tmp_source_markers\" | tr -d ' ')\"; if [ \"$selector_marker_count\" -lt 5 ]; then echo \"[build_backend_string_abi_contract] missing selector-owned source markers\" >&2; exit 2; fi; ")
    add(parts, "doc_sha=\"$(hash_file \"$doc\")\"; formal_doc_sha=\"$(hash_file \"$formal_doc\")\"; tooling_doc_sha=\"$(hash_file \"$tooling_doc\")\"; matrix_doc_sha=\"$(hash_file \"$matrix_doc\")\"; tooling_sha=\"$(hash_file \"$tooling_file\")\"; marker_sha=\"$(hash_file \"$tmp_markers\")\"; source_marker_sha=\"$(hash_file \"$tmp_source_markers\")\"; ")
    add(parts, "out_dir=\"$(dirname \"$out\")\"; if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; ")
    add(parts, "{ ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_BASELINE_VERSION=1\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_DOC=$doc\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_FORMAL_DOC=$formal_doc\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_TOOLING_DOC=$tooling_doc\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_MATRIX_DOC=$matrix_doc\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_DOC_SHA256=$doc_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_FORMAL_DOC_SHA256=$formal_doc_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_TOOLING_DOC_SHA256=$tooling_doc_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_MATRIX_DOC_SHA256=$matrix_doc_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_TOOLING_SHA256=$tooling_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_VERSION=$contract_version\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SCHEME_ID=$doc_scheme_id\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SCHEME_NAME=$doc_scheme_name\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SCHEME_NORMATIVE=$doc_scheme_normative\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_ENFORCE_MODE=$doc_enforce_mode\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_MARKER_COUNT=$marker_count\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_MARKER_SHA256=$marker_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SOURCE_MARKER_SHA256=$source_marker_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SELECTOR_MARKER_COUNT=$selector_marker_count\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_DEFAULT_VERIFY_GATES=verify_backend_string_abi_contract\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_CLOSURE_TIER=required\"; ")
    add(parts, "} >\"$out\"; ")
    add(parts, "echo \"backend string ABI contract baseline generated: $out\"")
    let cmd: str = tooling_joinFragments(parts)
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdBuildBackendStringAbiContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var outFile: str = "src/tooling/backend_string_abi_contract.env"
    var doc: str = "docs/backend-string-abi-contract.md"
    var formalDoc: str = "docs/cheng-formal-spec.md"
    var toolingDoc: str = "src/tooling/README.md"
    var matrixDoc: str = "docs/backend-techdebt-matrix.md"
