        "singleton_compile_log=" + os.joinPath(ctx.finalOutDir, "std_strformat_singleton.compile.log"),
        "singleton_run_log=" + os.joinPath(ctx.finalOutDir, "std_strformat_singleton.run.txt"),
        "concat_compile_log=" + os.joinPath(ctx.finalOutDir, "std_strformat_concat.compile.log"),
        "concat_run_log=" + os.joinPath(ctx.finalOutDir, "std_strformat_concat.run.txt"),
        "lines_compile_log=" + os.joinPath(ctx.finalOutDir, "std_strformat_lines.compile.log"),
        "lines_run_log=" + os.joinPath(ctx.finalOutDir, "std_strformat_lines.run.txt")
    ]
    if !tooling_stdWriteReportAndPublish(
        root,
        ctx,
        tooling_renderRawLines(reportLines, true)):
