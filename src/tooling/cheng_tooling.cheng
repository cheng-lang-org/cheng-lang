fn tooling_verifyBackendSeedUirImportEnv(root: str, stage0Exec: str, target: str,
                                         fixturePath: str, tempOut: str): str[] =
    var envOverrides: str[] = []
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "dev", "outline", "system", target, fixturePath, tempOut,
        "obj", "1", "1", "0", "0", "0", "0", "1", "1")
    tooling_envAssignCollect(envOverrides, "DYLD_INSERT_LIBRARIES", "")
    tooling_envAssignCollect(envOverrides, "DYLD_FORCE_FLAT_NAMESPACE", "")
    compileOpts.optLevelText = "0"
    compileOpts.optText = "0"
    compileOpts.opt2Text = "0"
    compileOpts.uirSimdText = "0"
    compileOpts.disableDupScanText = "0"
    compileOpts.skipFixupsText = "0"
    compileOpts.skipNormalizeText = "0"
    compileOpts.noRuntimeCText = "0"
    compileOpts.internalAllowEmitObjText = "1"
    tooling_compileCollectEnvOverrides(root, stage0Exec, compileOpts, envOverrides)
    return envOverrides

fn tooling_verifyBackendSidecarChengCompileEnv(root: str, outerDriver: str, sidecarMode: str,
                                               compilerPath: str, builtBundle: str,
                                               target: str, fixturePath: str,
                                               cacheExePath: str): str[] =
    var compileEnv: str[] = []
    let compileJobsText: str = tooling_compileParallelJobsText(root)
    let compileFnJobsText: str = tooling_compileParallelFnJobsText(root, compileJobsText)
    let compileMultiText: str = tooling_compileParallelMultiText(root)
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "dev", "outline", "system", target, fixturePath, cacheExePath,
        "exe", "0", "1", "0", "0", compileMultiText, "0",
        compileJobsText, compileFnJobsText)
    compileOpts.noRuntimeCText = "0"
    compileOpts.sidecarModeText = sidecarMode
    compileOpts.sidecarPreferText = "1"
    compileOpts.sidecarForceText = "1"
    compileOpts.sidecarBundlePath = builtBundle
    compileOpts.sidecarCompilerPath = compilerPath
    compileOpts.sidecarChildModeText = tooling_backendDriverSidecarCompilerChildMode(root, compilerPath)
    compileOpts.sidecarOuterCompilerPath = tooling_backendDriverSidecarCompilerOuterCompanion(root, compilerPath)
    tooling_compileCollectEnvOverrides(root, outerDriver, compileOpts, compileEnv)
    if !tooling_strNonEmpty(compilerPath):
        tooling_envAssignCollect(compileEnv, "BACKEND_UIR_SIDECAR_COMPILER", "")
        tooling_envAssignCollect(compileEnv, "BACKEND_UIR_SIDECAR_CHILD_MODE", "")
        tooling_envAssignCollect(compileEnv, "BACKEND_UIR_SIDECAR_OUTER_COMPILER", "")
    return compileEnv

fn tooling_verifyBackendSeedUirImportArgs(fixturePath: str, tempOut: str, target: str): str[] =
    var argv: str[] = []
    add(argv, "--input:" + fixturePath)
    add(argv, "--output:" + tempOut)
    add(argv, "--target:" + target)
    add(argv, "--linker:system")
    return argv

fn tooling_verifyBackendSeedUirImportTempOut(outPath: str, index: int32): str =
    return outPath + ".candidate." + intToStr(index)

fn tooling_cmdVerifyBackendSeedUirImport(root: str): int32 =
    let fixturePath: str = tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/seed_uir_import_min.cheng")
    if !os.fileExists(fixturePath):
        tooling_printErr("cheng_tooling: missing seed UIR import fixture: " + fixturePath)
        return 1
    let target: str = tooling_detectHostTarget(root)
    let outPath: str = tooling_pathAbsolute(root, "artifacts/backend_seed_uir_import/seed_uir_import_min.o")
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        tooling_tryMkdirP(root, outDir)
    if os.fileExists(outPath):
        os.removeFile(outPath)
    var candidates: str[] = []
    let currentSourceProof: str = tooling_pathAbsolute(
        root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2")
    if tooling_isExecutable(root, currentSourceProof):
        add(candidates, currentSourceProof)
    let recoverySeed: str = tooling_resolveRecoverySeedCompiler(root, false)
    if tooling_isExecutable(root, recoverySeed) && !tooling_seqContainsStr(candidates, recoverySeed):
        add(candidates, recoverySeed)
    let canonicalDriver: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if tooling_isExecutable(root, canonicalDriver) && !tooling_seqContainsStr(candidates, canonicalDriver):
        add(candidates, canonicalDriver)
    let selfhostStage2: str = tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/cheng.stage2")
    if tooling_isExecutable(root, selfhostStage2) && !tooling_seqContainsStr(candidates, selfhostStage2):
        add(candidates, selfhostStage2)
    if candidates.len <= 0:
        tooling_printErr("cheng_tooling: missing seed UIR import compiler candidates")
        return 1
    var lastRc: int32 = 1
    for i in 0..<candidates.len:
        let tempOut: str = tooling_verifyBackendSeedUirImportTempOut(outPath, i)
        if os.fileExists(tempOut):
            os.removeFile(tempOut)
        let envOverrides: str[] = tooling_verifyBackendSeedUirImportEnv(
            root, candidates[i], target, fixturePath, tempOut)
        let argv: str[] = tooling_verifyBackendSeedUirImportArgs(fixturePath, tempOut, target)
        let res: os.ExecCmdResult =
            tooling_execFileDirect(candidates[i], argv, envOverrides, root, 0, true)
        let rc: int32 = os.execCmdResultExitCode(res)
        if rc == 0 && tooling_fileExistsNonEmpty(tempOut):
            if os.fileExists(outPath):
                os.removeFile(outPath)
            os.rename(tempOut, outPath)
            tooling_printOut("verify_backend_seed_uir_import_compiler=" + candidates[i])
            tooling_printOut("verify_backend_seed_uir_import ok")
            return 0
        lastRc = rc
        if os.fileExists(tempOut):
            os.removeFile(tempOut)
        tooling_printErr("cheng_tooling: seed UIR import candidate failed rc=" + intToStr(rc) +
                         " kind=" + tooling_exitKind(rc) + " compiler=" + candidates[i])
        let rows: str[] = tooling_splitLines(os.execCmdResultOutput(res))
        var shown: int32 = 0
        for j in 0..<rows.len:
            if shown >= 6:
                break
            let row: str = strutil.strip(rows[j])
            if tooling_strNonEmpty(row):
                tooling_printErr("cheng_tooling: seed UIR import log: " + row)
                shown = shown + 1
    if lastRc != 0:
        tooling_printErr("cheng_tooling: verify_backend_seed_uir_import failed rc=" + intToStr(lastRc))
        return lastRc
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_printErr("cheng_tooling: verify_backend_seed_uir_import missing output: " + outPath)
        return 1
    return 0

fn tooling_resolveReturnAddFixture(root: str): str =
    let fixturePath: str = tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/return_add.cheng")
    if tooling_fileExistsNonEmpty(fixturePath):
        return fixturePath
    let fallbackPath: str = tooling_pathAbsolute(root, "return_add.cheng")
    if tooling_fileExistsNonEmpty(fallbackPath):
        return fallbackPath
    return fixturePath

fn tooling_verifyBackendSidecarChengCommon(root: str, gateName: str, snapshotPrefix: str, sidecarMode: str,
                                           compilerPath: str, target: str, builtObj: str, builtBundle: str,
                                           outDir: str): int32 =
    let outerDriver: str = tooling_prepareBackendDriverSidecarOuterDriver(root, target)
    if !tooling_isExecutable(root, outerDriver):
        tooling_printErr("cheng_tooling: " + gateName + " missing native outer driver")
        return 1
    tooling_tryMkdirP(root, outDir)
    let reportPath: str = os.joinPath(outDir, gateName + ".report.txt")
    let snapshotPath: str = os.joinPath(outDir, gateName + ".snapshot.env")
    let childMode: str = tooling_backendDriverSidecarCompilerChildMode(root, compilerPath)
    if !tooling_backendDriverUirSidecarChildModeValid(childMode):
        tooling_printErr("cheng_tooling: " + gateName +
                         " missing sidecar child-mode contract for compiler: " + compilerPath)
        return 1
    var outerCompanion: str = ""
    if tooling_strEq(childMode, "outer_cli"):
        outerCompanion = tooling_backendDriverSidecarCompilerOuterCompanion(root, compilerPath)
        if !tooling_isExecutable(root, outerCompanion):
            tooling_printErr("cheng_tooling: " + gateName +
                             " missing outer companion contract for compiler: " + compilerPath)
            return 1
    else:
        outerCompanion = compilerPath
    let realDriver: str = tooling_backendDriverSidecarCompilerRealDriver(root, compilerPath)
    if !tooling_isExecutable(root, realDriver):
        tooling_printErr("cheng_tooling: " + gateName +
                         " missing sidecar real-driver contract for compiler: " + compilerPath)
        return 1
    if !tooling_backendDriverSidecarCompilerMetaWrite(root, compilerPath, childMode, outerCompanion,
                                                      realDriver):
        tooling_printErr("cheng_tooling: " + gateName +
                         " failed to write sidecar compiler contract: " + compilerPath)
        return 1
    var fixtures: str[] = []
    add(fixtures, tooling_resolveReturnAddFixture(root))
    add(fixtures, os.joinPath(root, "tests/cheng/backend/fixtures/return_new_expr_generic_box.cheng"))
    add(fixtures, os.joinPath(root, "tests/cheng/backend/fixtures/return_new_ref_seq_growth.cheng"))
    var fixtureReports: str[] = []
    for i in 0..<fixtures.len:
        let fixturePath: str = fixtures[i]
        if !tooling_fileExistsNonEmpty(fixturePath):
            tooling_printErr("cheng_tooling: " + gateName + " missing fixture: " + fixturePath)
            return 1
        let name: str = os.extractFilename(fixturePath)
        let exePath: str = os.joinPath(outDir, name + ".sidecar")
        let cacheExePath: str = os.joinPath(root,
            "chengcache/backend_driver_sidecar/" + gateName + "." + intToStr(i) + ".sidecar")
        let compileLog: str = os.joinPath(outDir, name + ".compile.log")
        let runLog: str = os.joinPath(outDir, name + ".run.log")
        if os.fileExists(exePath):
            os.removeFile(exePath)
        if os.fileExists(cacheExePath):
            os.removeFile(cacheExePath)
        if os.fileExists(compileLog):
            os.removeFile(compileLog)
        if os.fileExists(runLog):
            os.removeFile(runLog)
        let compileEnv: str[] = tooling_verifyBackendSidecarChengCompileEnv(
            root, outerDriver, sidecarMode, compilerPath, builtBundle, target, fixturePath, cacheExePath)
        var outerArgs: str[] = []
        let compileRes: os.ExecCmdResult =
            tooling_execFileDirect(outerDriver, outerArgs, compileEnv, root, 60, true)
        os.writeFile(compileLog, os.execCmdResultOutput(compileRes))
        let compileRc: int32 = os.execCmdResultExitCode(compileRes)
        if compileRc != 0 || !tooling_fileExistsNonEmpty(cacheExePath):
            tooling_printErr("cheng_tooling: " + gateName + " compile failed fixture=" +
                             fixturePath + " rc=" + intToStr(compileRc))
            return 1
        if !tooling_copyExecutablePreserveBytes(root, cacheExePath, exePath):
            tooling_printErr("cheng_tooling: " + gateName + " failed to install fixture output: " + exePath)
            return 1
        var runArgs: str[] = []
        var runEnv: str[] = []
        let runRes: os.ExecCmdResult =
            tooling_execFileDirect(exePath, runArgs, runEnv, root, 10, true)
        os.writeFile(runLog, os.execCmdResultOutput(runRes))
        let runRc: int32 = os.execCmdResultExitCode(runRes)
        if runRc != 0:
            tooling_printErr("cheng_tooling: " + gateName + " run failed fixture=" +
                             fixturePath + " rc=" + intToStr(runRc))
            return 1
        add(fixtureReports, name + ":ok")
    os.writeFile(
        reportPath,
        "status=ok\n" +
        "gate=" + gateName + "\n" +
        "sidecar_mode=" + sidecarMode + "\n" +
        "compiler=" + compilerPath + "\n" +
        "compiler_real_driver=" + realDriver + "\n" +
        "driver=" + outerDriver + "\n" +
        "driver_mode=native_sidecar_outer\n" +
        "target=" + target + "\n" +
        "object=" + builtObj + "\n" +
        "bundle=" + builtBundle + "\n" +
        "child_mode=" + childMode + "\n" +
        "outer_companion=" + outerCompanion + "\n" +
        "fixtures=" + strutil.join(fixtureReports, ",") + "\n"
    )
    os.writeFile(
        snapshotPath,
        snapshotPrefix + "_status=ok\n" +
        snapshotPrefix + "_compiler=" + compilerPath + "\n" +
        snapshotPrefix + "_real_driver=" + realDriver + "\n" +
        snapshotPrefix + "_child_mode=" + childMode + "\n" +
        snapshotPrefix + "_outer_companion=" + outerCompanion + "\n" +
        snapshotPrefix + "_driver=" + outerDriver + "\n" +
        snapshotPrefix + "_driver_mode=native_sidecar_outer\n" +
        snapshotPrefix + "_target=" + target + "\n" +
        snapshotPrefix + "_mode=" + sidecarMode + "\n" +
        snapshotPrefix + "_bundle=" + builtBundle + "\n" +
        snapshotPrefix + "_report=" + reportPath + "\n" +
        snapshotPrefix + "_fixtures=" + strutil.join(fixtureReports, ",") + "\n"
    )
    tooling_printOut(gateName + " ok")
    return 0

fn tooling_cmdVerifyBackendSidecarChengSeed(root: str): int32 =
    tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_seed removed; pure Cheng sidecar requires verify_backend_sidecar_cheng_fresh")
    return 2

fn tooling_cmdVerifyBackendSidecarChengFresh(root: str): int32 =
    let target: str = tooling_detectHostTarget(root)
    let outerDriver: str = tooling_prepareBackendDriverSidecarOuterDriver(root, target)
    if !tooling_isExecutable(root, outerDriver):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh missing native outer driver")
        return 1
    var compilerPath: str = tooling_pathAbsolute(
        root, strutil.strip(os.getEnvDefault("BACKEND_UIR_SIDECAR_COMPILER", "")))
    let explicitCompiler: bool = tooling_strNonEmpty(compilerPath)
    if !explicitCompiler:
        compilerPath = tooling_prepareBackendDriverCurrentsrcSidecarCompiler(root, target)
    if !tooling_isExecutable(root, compilerPath):
        tooling_printErr("cheng_tooling: missing fresh sidecar compiler; set BACKEND_UIR_SIDECAR_COMPILER=<compiler contract>")
        return 1
    let explicitBootstrapRealDriver: str = tooling_pathAbsolute(
        root, strutil.strip(os.getEnvDefault("BACKEND_UIR_SIDECAR_BOOTSTRAP_DRIVER", "")))
    let bootstrapRealDriver: str = tooling_backendDriverSidecarBootstrapDriverPath(root, compilerPath, target)
    if !tooling_isExecutable(root, bootstrapRealDriver):
        if tooling_strNonEmpty(explicitBootstrapRealDriver):
            tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh explicit bootstrap sidecar driver failed wrapper-source compile probe: " +
                             explicitBootstrapRealDriver)
        else:
            tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh missing usable strict bootstrap sidecar driver")
        return 1
    var realDriver: str = tooling_pathAbsolute(
        root, strutil.strip(os.getEnvDefault("BACKEND_UIR_SIDECAR_REAL_DRIVER", "")))
    if !tooling_strNonEmpty(realDriver):
        let publishedRealDriver: str = tooling_backendDriverCurrentsrcProofPublishedStage2Path(root)
        if tooling_backendDriverCurrentsrcProofRuntimeSurfaceOk(root, publishedRealDriver):
            realDriver = publishedRealDriver
        else:
            realDriver = tooling_backendDriverCurrentsrcProofRealDriverPath(root)
    if tooling_strEq(realDriver, tooling_backendDriverSidecarDistRealDriverPath(root)):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh strict-fresh rejects dist current real driver: " +
                         realDriver)
        return 1
    if !tooling_backendDriverUirSidecarStrictRealDriverPathOk(root, realDriver):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh missing current-source real driver: " +
                         realDriver)
        return 1
    if !tooling_backendDriverCurrentsrcProofRuntimeStage0Path(root, realDriver):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh strict real sidecar driver must be a current-source proof surface: " +
                         realDriver)
        return 1
    if !tooling_backendDriverCurrentsrcProofRuntimeSurfaceOk(root, realDriver):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh strict real sidecar driver missing contract: " +
                         realDriver)
        return 1
    var childMode: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("BACKEND_UIR_SIDECAR_CHILD_MODE", "")))
    if !tooling_strNonEmpty(childMode):
        if explicitCompiler:
            childMode = tooling_backendDriverSidecarCompilerChildMode(root, compilerPath)
        else:
            childMode = "cli"
    if !tooling_backendDriverUirSidecarChildModeValid(childMode):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh missing sidecar child-mode contract")
        return 1
    var outerCompanion: str = tooling_pathAbsolute(
        root, strutil.strip(os.getEnvDefault("BACKEND_UIR_SIDECAR_OUTER_COMPILER", "")))
    if tooling_strEq(childMode, "outer_cli"):
        if !tooling_strNonEmpty(outerCompanion):
            if explicitCompiler:
                outerCompanion = tooling_backendDriverSidecarCompilerOuterCompanion(root, compilerPath)
        if !tooling_isExecutable(root, outerCompanion):
            tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh missing outer companion contract")
            return 1
        if tooling_strEq(tooling_pathAbsolute(root, compilerPath),
                         tooling_pathAbsolute(root, outerCompanion)):
            tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh invalid outer companion self-cycle: " +
                             compilerPath)
            return 1
    else:
        outerCompanion = compilerPath
    if !tooling_backendDriverSidecarCompilerMetaWrite(root, compilerPath, childMode, outerCompanion,
                                                      bootstrapRealDriver):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh failed to write compiler contract: " +
                         compilerPath)
        return 1
    let objPath: str = tooling_backendDriverUirSidecarObjPath(root, target)
    let bundlePath: str = tooling_backendDriverUirSidecarBundlePath(root, target)
    let helperObjPath: str = tooling_backendDriverUirSidecarHelperObjPath(root, target)
    if os.fileExists(objPath):
        os.removeFile(objPath)
    if os.fileExists(helperObjPath):
        os.removeFile(helperObjPath)
    if os.fileExists(bundlePath):
        os.removeFile(bundlePath)
    let builtObj: str = tooling_prepareBackendDriverUirSidecarChengObj(root, compilerPath, target)
    if !tooling_fileExistsNonEmpty(builtObj):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh missing object output")
        return 1
    let builtBundle: str = tooling_prepareBackendDriverUirSidecarBundle(root, target, builtObj, "cheng")
    if !tooling_fileExistsNonEmpty(builtBundle):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh missing bundle output")
        return 1
    if !tooling_backendDriverSidecarCompilerMetaWrite(root, compilerPath, childMode, outerCompanion,
                                                      realDriver):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_fresh failed to write runtime compiler contract: " +
                         compilerPath)
        return 1
    let outDir: str = os.joinPath(root, "artifacts/backend_sidecar_cheng_fresh")
    return tooling_verifyBackendSidecarChengCommon(root,
                                                   "verify_backend_sidecar_cheng_fresh",
                                                   "backend_sidecar_cheng_fresh",
                                                   "cheng",
                                                   compilerPath,
                                                   target,
                                                   builtObj,
                                                   builtBundle,
                                                   outDir)

fn tooling_printVerifyBackendSidecarChengFreshUsage() =
    tooling_printOut("verify_backend_sidecar_cheng_fresh options:")
    tooling_printOut("  --help    show this message")

fn tooling_cmdVerifyBackendSidecarChengFreshFromArgs(root: str, firstArgIndex: int32,
                                                     count: int32): int32 =
    let args: str[] = tooling_argsRange(firstArgIndex, count)
    for i in 0..<args.len:
        let arg: str = args[i]
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printVerifyBackendSidecarChengFreshUsage()
            return 0
        tooling_printErr("cheng_tooling: unknown verify_backend_sidecar_cheng_fresh arg: " + arg)
        return 2
    return tooling_cmdVerifyBackendSidecarChengFresh(root)

fn tooling_cmdBuildBackendMemContract(root: str, outFile: str, doc: str): int32 =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then echo \"[build_backend_mem_contract] rg is required\" >&2; exit 2; fi; ")
    add(parts, "hash_file() { file=\"$1\"; if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; cksum \"$file\" | awk '{print $1}'; }; ")
    add(parts, "out=")
    add(parts, tooling_shellQuote(outFile))
    add(parts, "; doc=")
    add(parts, tooling_shellQuote(doc))
    add(parts, "; ")
    add(parts, "for required in \"$doc\" \"src/tooling/cheng_tooling_embedded_inline.cheng\" \"src/tooling/cheng_tooling_embedded_inline.cheng\" \"src/tooling/cheng_tooling_embedded_inline.cheng\"; do ")
    add(parts, "if [ ! -f \"$required\" ]; then echo \"[build_backend_mem_contract] missing file: $required\" >&2; exit 2; fi; ")
    add(parts, "done; ")
    add(parts, "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_mem_contract_markers.XXXXXX\")\"; ")
    add(parts, "cleanup() { rm -f \"$tmp_markers\"; }; trap cleanup EXIT; ")
    add(parts, "rg -o 'mem_contract\\.version=[0-9]+|mem_image\\.schema\\.version=[0-9]+|patch_meta\\.schema\\.version=[0-9]+|mem_image\\.field\\.[A-Za-z0-9_]+|patch_meta\\.field\\.[A-Za-z0-9_]+|mem_image\\.invariant\\.[A-Za-z0-9_]+|patch_meta\\.invariant\\.[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u >\"$tmp_markers\"; ")
    add(parts, "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; ")
    add(parts, "if [ \"$marker_count\" -eq 0 ]; then echo \"[build_backend_mem_contract] no contract markers found in: $doc\" >&2; exit 2; fi; ")
    add(parts, "contract_version=\"$(rg -o 'mem_contract\\.version=[0-9]+' \"$doc\" | head -n 1 | cut -d= -f2 || true)\"; ")
    add(parts, "mem_schema_version=\"$(rg -o 'mem_image\\.schema\\.version=[0-9]+' \"$doc\" | head -n 1 | cut -d= -f2 || true)\"; ")
    add(parts, "patch_schema_version=\"$(rg -o 'patch_meta\\.schema\\.version=[0-9]+' \"$doc\" | head -n 1 | cut -d= -f2 || true)\"; ")
    add(parts, "if [ \"$contract_version\" = \"\" ] || [ \"$mem_schema_version\" = \"\" ] || [ \"$patch_schema_version\" = \"\" ]; then echo \"[build_backend_mem_contract] missing version markers in: $doc\" >&2; exit 2; fi; ")
    add(parts, "mem_field_count=\"$(rg -o 'mem_image\\.field\\.[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; ")
    add(parts, "patch_field_count=\"$(rg -o 'patch_meta\\.field\\.[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; ")
    add(parts, "mem_invariant_count=\"$(rg -o 'mem_image\\.invariant\\.[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; ")
    add(parts, "patch_invariant_count=\"$(rg -o 'patch_meta\\.invariant\\.[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; ")
    add(parts, "marker_sha=\"$(hash_file \"$tmp_markers\")\"; doc_sha=\"$(hash_file \"$doc\")\"; ")
    add(parts, "verify_sha=\"$(hash_file src/tooling/cheng_tooling_embedded_inline.cheng)\"; ")
    add(parts, "closedloop_sha=\"$(hash_file src/tooling/cheng_tooling_embedded_inline.cheng)\"; ")
    add(parts, "prod_closure_sha=\"$(hash_file src/tooling/cheng_tooling_embedded_inline.cheng)\"; ")
    add(parts, "out_dir=\"$(dirname \"$out\")\"; if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; ")
    add(parts, "{ ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_BASELINE_VERSION=1\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_DOC=$doc\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_DOC_SHA256=$doc_sha\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_VERSION=$contract_version\"; ")
    add(parts, "echo \"BACKEND_MEM_IMAGE_SCHEMA_VERSION=$mem_schema_version\"; ")
    add(parts, "echo \"BACKEND_PATCH_META_SCHEMA_VERSION=$patch_schema_version\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_MARKER_COUNT=$marker_count\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_MARKER_SHA256=$marker_sha\"; ")
    add(parts, "echo \"BACKEND_MEM_IMAGE_FIELD_COUNT=$mem_field_count\"; ")
    add(parts, "echo \"BACKEND_PATCH_META_FIELD_COUNT=$patch_field_count\"; ")
    add(parts, "echo \"BACKEND_MEM_IMAGE_INVARIANT_COUNT=$mem_invariant_count\"; ")
    add(parts, "echo \"BACKEND_PATCH_META_INVARIANT_COUNT=$patch_invariant_count\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_VERIFY_SCRIPT_SHA256=$verify_sha\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_CLOSEDLOOP_SHA256=$closedloop_sha\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_PROD_CLOSURE_SHA256=$prod_closure_sha\"; ")
    add(parts, "echo \"BACKEND_MEM_CONTRACT_REQUIRED_GATES=backend.mem_contract\"; ")
    add(parts, "} >\"$out\"; ")
    add(parts, "echo \"backend mem contract baseline generated: $out\"")
    let cmd: str = tooling_joinFragments(parts)
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdBuildBackendMemContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let args: str[] = tooling_argsRange(firstArgIndex, count)
    for i in 0..<args.len:
        let arg: str = args[i]
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build_backend_mem_contract options:")
            tooling_printOut("  --out:<path>   output baseline env")
            tooling_printOut("  --doc:<path>   source contract doc")
            return 0
        if strutil.startsWith(arg, "--out:") || strutil.startsWith(arg, "--doc:"):
            continue
        tooling_printErr("cheng_tooling: unknown build_backend_mem_contract arg: " + arg)
        return 2
    return tooling_cmdBuildBackendMemContract(
        root,
        tooling_argsReadPrefixedValue(args, "--out:", "src/tooling/backend_mem_contract.env"),
        tooling_argsReadPrefixedValue(args, "--doc:", "docs/backend-mem-hotpatch-contract.md")
    )

fn tooling_cmdBuildBackendDodContract(root: str, outFile: str, doc: str): int32 =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then echo \"[build_backend_dod_contract] rg is required\" >&2; exit 2; fi; ")
    add(parts, "hash_file() { file=\"$1\"; if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; cksum \"$file\" | awk '{print $1}'; }; ")
    add(parts, "out=")
    add(parts, tooling_shellQuote(outFile))
    add(parts, "; doc=")
    add(parts, tooling_shellQuote(doc))
    add(parts, "; ")
    add(parts, "stage1_ast=\"src/stage1/ast.cheng\"; uir_types=\"src/backend/uir/uir_internal/uir_core_types.cheng\"; uir_ssa=\"src/backend/uir/uir_internal/uir_core_ssa.cheng\"; ")
    add(parts, "verify_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; verify_dod_soa=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; closedloop_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; prod_closure_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; ")
    add(parts, "for required in \"$doc\" \"$stage1_ast\" \"$uir_types\" \"$uir_ssa\" \"$verify_script\" \"$verify_dod_soa\" \"$closedloop_script\" \"$prod_closure_script\"; do ")
    add(parts, "if [ ! -f \"$required\" ]; then echo \"[build_backend_dod_contract] missing file: $required\" >&2; exit 2; fi; ")
    add(parts, "done; ")
    add(parts, "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_dod_contract_markers.XXXXXX\")\"; ")
    add(parts, "cleanup() { rm -f \"$tmp_markers\"; }; trap cleanup EXIT; ")
    add(parts, "{ ")
    add(parts, "rg -o 'DOD-ATOM-0[1-5]|DOPAR-0[1-2]|backend\\.dod_contract|backend\\.dod_soa|SoA|Arena|No-Alias|E-Graph' \"$doc\" || true; ")
    add(parts, "rg -o 'nodeArena: Node\\[\\]|nodeArenaEnabled: bool = true' \"$stage1_ast\" || true; ")
    add(parts, "rg -o 'localIndex: int32|slot: int32|frameOff: int32' \"$uir_types\" || true; ")
    add(parts, "rg -o 'rpoIndex: int32\\[\\]' \"$uir_ssa\" || true; ")
    add(parts, "} | LC_ALL=C sort -u >\"$tmp_markers\"; ")
    add(parts, "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; ")
    add(parts, "if [ \"$marker_count\" -eq 0 ]; then echo \"[build_backend_dod_contract] no DOD contract markers found\" >&2; exit 2; fi; ")
    add(parts, "stage1_arena_count=\"$(rg -o 'nodeArena: Node\\[\\]|nodeArenaEnabled: bool = true' \"$stage1_ast\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; ")
    add(parts, "uir_index_count=\"$(rg -o 'localIndex: int32|slot: int32|frameOff: int32|rpoIndex: int32\\[\\]' \"$uir_types\" \"$uir_ssa\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; ")
    add(parts, "doc_sha=\"$(hash_file \"$doc\")\"; marker_sha=\"$(hash_file \"$tmp_markers\")\"; ")
    add(parts, "verify_sha=\"$(hash_file \"$verify_script\")\"; verify_dod_soa_sha=\"$(hash_file \"$verify_dod_soa\")\"; closedloop_sha=\"$(hash_file \"$closedloop_script\")\"; prod_closure_sha=\"$(hash_file \"$prod_closure_script\")\"; ")
    add(parts, "out_dir=\"$(dirname \"$out\")\"; if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; ")
    add(parts, "{ ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_BASELINE_VERSION=1\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_DOC=$doc\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_DOC_SHA256=$doc_sha\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_MARKER_COUNT=$marker_count\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_MARKER_SHA256=$marker_sha\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_STAGE1_ARENA_MARKER_COUNT=$stage1_arena_count\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_UIR_INDEX_MARKER_COUNT=$uir_index_count\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_VERIFY_SCRIPT_SHA256=$verify_sha\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_VERIFY_DOD_SOA_SHA256=$verify_dod_soa_sha\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_CLOSEDLOOP_SHA256=$closedloop_sha\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_PROD_CLOSURE_SHA256=$prod_closure_sha\"; ")
    add(parts, "echo \"BACKEND_DOD_CONTRACT_REQUIRED_GATES=backend.dod_contract,backend.dod_soa\"; ")
    add(parts, "} >\"$out\"; ")
    add(parts, "echo \"backend dod contract baseline generated: $out\"")
    let res: os.ExecCmdResult = tooling_exec(root, tooling_joinFragments(parts))
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdBuildBackendDodContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let args: str[] = tooling_argsRange(firstArgIndex, count)
    for i in 0..<args.len:
        let arg: str = args[i]
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build_backend_dod_contract options:")
            tooling_printOut("  --out:<path>   output baseline env")
            tooling_printOut("  --doc:<path>   source plan doc")
            return 0
        if strutil.startsWith(arg, "--out:") || strutil.startsWith(arg, "--doc:"):
            continue
        tooling_printErr("cheng_tooling: unknown build_backend_dod_contract arg: " + arg)
        return 2
    return tooling_cmdBuildBackendDodContract(
        root,
        tooling_argsReadPrefixedValue(args, "--out:", "src/tooling/backend_dod_contract.env"),
        tooling_argsReadPrefixedValue(args, "--doc:", "docs/cheng-plan-full.md")
    )

fn tooling_cmdBuildBackendStringAbiContract(root: str, outFile: str, doc: str, formalDoc: str,
                                            toolingDoc: str, matrixDoc: str): int32 =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then echo \"[build_backend_string_abi_contract] rg is required\" >&2; exit 2; fi; ")
    add(parts, "hash_file() { file=\"$1\"; if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; cksum \"$file\" | awk '{print $1}'; }; ")
    add(parts, "read_marker_value() { file=\"$1\"; marker_regex=\"$2\"; rg -o \"${marker_regex}=[A-Za-z0-9_]+\" \"$file\" | head -n 1 | cut -d= -f2 || true; }; ")
    add(parts, "require_marker_value() { file=\"$1\"; marker_regex=\"$2\"; marker_name=\"$3\"; expected=\"$4\"; value=\"$(read_marker_value \"$file\" \"$marker_regex\")\"; if [ \"$value\" != \"$expected\" ]; then echo \"[build_backend_string_abi_contract] ${marker_name} must be ${expected} in: $file\" >&2; exit 2; fi; printf '%s\\n' \"$value\"; }; ")
    add(parts, "out=")
    add(parts, tooling_shellQuote(outFile))
    add(parts, "; doc=")
    add(parts, tooling_shellQuote(doc))
    add(parts, "; formal_doc=")
    add(parts, tooling_shellQuote(formalDoc))
    add(parts, "; tooling_doc=")
    add(parts, tooling_shellQuote(toolingDoc))
    add(parts, "; matrix_doc=")
    add(parts, tooling_shellQuote(matrixDoc))
    add(parts, "; ")
    add(parts, "machine_types=\"src/backend/machine/machine_types.cheng\"; isel_shared=\"src/backend/machine/select_internal/isel_parallel_shared.cheng\"; coff_writer=\"src/backend/obj/coff_writer_x86_64.cheng\"; elf_writer=\"src/backend/obj/elf_writer.cheng\"; uir_codegen=\"src/backend/uir/uir_codegen.cheng\"; tooling_file=\"src/tooling/cheng_tooling.cheng\"; ")
    add(parts, "for required in \"$doc\" \"$formal_doc\" \"$tooling_doc\" \"$matrix_doc\" \"$machine_types\" \"$isel_shared\" \"$coff_writer\" \"$elf_writer\" \"$uir_codegen\" \"$tooling_file\"; do if [ ! -f \"$required\" ]; then echo \"[build_backend_string_abi_contract] missing file: $required\" >&2; exit 2; fi; done; ")
    add(parts, "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_string_abi_contract_markers.XXXXXX\")\"; tmp_source_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_string_abi_contract_sources.XXXXXX\")\"; ")
    add(parts, "cleanup() { rm -f \"$tmp_markers\" \"$tmp_source_markers\"; }; trap cleanup EXIT; ")
    add(parts, "{ rg -o 'string_abi_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$doc\" || true; rg -o 'string_abi_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$formal_doc\" || true; rg -o 'string_abi_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$tooling_doc\" || true; rg -o 'string_abi_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$matrix_doc\" || true; } | LC_ALL=C sort -u >\"$tmp_markers\"; ")
    add(parts, "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; if [ \"$marker_count\" -eq 0 ]; then echo \"[build_backend_string_abi_contract] no contract markers found\" >&2; exit 2; fi; ")
    add(parts, "contract_version=\"$(read_marker_value \"$doc\" 'string_abi_contract\\.version')\"; if [ \"$contract_version\" = \"\" ]; then echo \"[build_backend_string_abi_contract] missing string_abi_contract.version marker in: $doc\" >&2; exit 2; fi; ")
    add(parts, "doc_scheme_id=\"$(require_marker_value \"$doc\" 'string_abi_contract\\.scheme\\.id' 'string_abi_contract.scheme.id' 'SABI')\"; ")
    add(parts, "doc_scheme_name=\"$(require_marker_value \"$doc\" 'string_abi_contract\\.scheme\\.name' 'string_abi_contract.scheme.name' 'backend_string_abi_contract')\"; ")
    add(parts, "doc_scheme_normative=\"$(require_marker_value \"$doc\" 'string_abi_contract\\.scheme\\.normative' 'string_abi_contract.scheme.normative' '1')\"; ")
    add(parts, "doc_enforce_mode=\"$(require_marker_value \"$doc\" 'string_abi_contract\\.enforce\\.mode' 'string_abi_contract.enforce.mode' 'default_verify')\"; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.language\\.str' 'string_abi_contract.language.str' 'value_semantics' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.abi\\.cstring' 'string_abi_contract.abi.cstring' 'ffi_boundary' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.nil_compare\\.cstring_only' 'string_abi_contract.nil_compare.cstring_only' '1' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.selector_cstring_lowering\\.user_abi' 'string_abi_contract.selector_cstring_lowering.user_abi' '0' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'string_abi_contract\\.closure' 'string_abi_contract.closure' 'required' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'string_abi_contract\\.scheme\\.id' 'string_abi_contract.scheme.id' 'SABI' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'string_abi_contract\\.scheme\\.name' 'string_abi_contract.scheme.name' 'backend_string_abi_contract' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'string_abi_contract\\.scheme\\.normative' 'string_abi_contract.scheme.normative' '1' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'string_abi_contract\\.enforce\\.mode' 'string_abi_contract.enforce.mode' 'default_verify' >/dev/null; ")
    add(parts, "if ! rg -q 'string_abi_contract\\.formal_spec\\.synced=1' \"$formal_doc\"; then echo \"[build_backend_string_abi_contract] missing formal spec sync marker: $formal_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'string_abi_contract\\.tooling_readme\\.synced=1' \"$tooling_doc\"; then echo \"[build_backend_string_abi_contract] missing tooling README sync marker: $tooling_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'string_abi_contract\\.matrix\\.synced=1' \"$matrix_doc\"; then echo \"[build_backend_string_abi_contract] missing matrix sync marker: $matrix_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'string_abi_contract\\.selector_cstring_lowering\\.user_abi=0' \"$tooling_doc\"; then echo \"[build_backend_string_abi_contract] missing tooling README selector/user ABI marker\" >&2; exit 2; fi; ")
    add(parts, "{ rg -o 'selector cstring lowering is always enabled on the production machine surface' \"$machine_types\" || true; rg -o 'selector-owned cstring lowering materializes MachineCString payloads before object writers' \"$isel_shared\" || true; rg -o 'Selector owns cstring materialization' \"$coff_writer\" || true; rg -o 'ELF writer consumes selector-owned cstring materialization' \"$elf_writer\" || true; rg -o 'selector_missing cstring payloads is a hard error' \"$uir_codegen\" || true; } | LC_ALL=C sort -u >\"$tmp_source_markers\"; ")
    add(parts, "selector_marker_count=\"$(wc -l < \"$tmp_source_markers\" | tr -d ' ')\"; if [ \"$selector_marker_count\" -lt 5 ]; then echo \"[build_backend_string_abi_contract] missing selector-owned source markers\" >&2; exit 2; fi; ")
    add(parts, "doc_sha=\"$(hash_file \"$doc\")\"; formal_doc_sha=\"$(hash_file \"$formal_doc\")\"; tooling_doc_sha=\"$(hash_file \"$tooling_doc\")\"; matrix_doc_sha=\"$(hash_file \"$matrix_doc\")\"; tooling_sha=\"$(hash_file \"$tooling_file\")\"; marker_sha=\"$(hash_file \"$tmp_markers\")\"; source_marker_sha=\"$(hash_file \"$tmp_source_markers\")\"; ")
    add(parts, "out_dir=\"$(dirname \"$out\")\"; if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; ")
    add(parts, "{ ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_BASELINE_VERSION=1\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_DOC=$doc\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_FORMAL_DOC=$formal_doc\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_TOOLING_DOC=$tooling_doc\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_MATRIX_DOC=$matrix_doc\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_DOC_SHA256=$doc_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_FORMAL_DOC_SHA256=$formal_doc_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_TOOLING_DOC_SHA256=$tooling_doc_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_MATRIX_DOC_SHA256=$matrix_doc_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_TOOLING_SHA256=$tooling_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_VERSION=$contract_version\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SCHEME_ID=$doc_scheme_id\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SCHEME_NAME=$doc_scheme_name\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SCHEME_NORMATIVE=$doc_scheme_normative\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_ENFORCE_MODE=$doc_enforce_mode\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_MARKER_COUNT=$marker_count\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_MARKER_SHA256=$marker_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SOURCE_MARKER_SHA256=$source_marker_sha\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_SELECTOR_MARKER_COUNT=$selector_marker_count\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_DEFAULT_VERIFY_GATES=verify_backend_string_abi_contract\"; ")
    add(parts, "echo \"BACKEND_STRING_ABI_CONTRACT_CLOSURE_TIER=required\"; ")
    add(parts, "} >\"$out\"; ")
    add(parts, "echo \"backend string ABI contract baseline generated: $out\"")
    let res: os.ExecCmdResult = tooling_exec(root, tooling_joinFragments(parts))
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdBuildBackendStringAbiContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let args: str[] = tooling_argsRange(firstArgIndex, count)
    for i in 0..<args.len:
        let arg: str = args[i]
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build_backend_string_abi_contract options:")
            tooling_printOut("  --out:<path>         output baseline env")
            tooling_printOut("  --doc:<path>         string ABI contract doc")
            tooling_printOut("  --formal-doc:<path>  formal spec doc")
            tooling_printOut("  --tooling-doc:<path> tooling README")
            tooling_printOut("  --matrix-doc:<path>  backend techdebt matrix doc")
            return 0
        if strutil.startsWith(arg, "--out:") ||
           strutil.startsWith(arg, "--doc:") ||
           strutil.startsWith(arg, "--formal-doc:") ||
           strutil.startsWith(arg, "--tooling-doc:") ||
           strutil.startsWith(arg, "--matrix-doc:"):
            continue
        tooling_printErr("cheng_tooling: unknown build_backend_string_abi_contract arg: " + arg)
        return 2
    return tooling_cmdBuildBackendStringAbiContract(
        root,
        tooling_argsReadPrefixedValue(args, "--out:", "src/tooling/backend_string_abi_contract.env"),
        tooling_argsReadPrefixedValue(args, "--doc:", "docs/backend-string-abi-contract.md"),
        tooling_argsReadPrefixedValue(args, "--formal-doc:", "docs/cheng-formal-spec.md"),
        tooling_argsReadPrefixedValue(args, "--tooling-doc:", "src/tooling/README.md"),
        tooling_argsReadPrefixedValue(args, "--matrix-doc:", "docs/backend-techdebt-matrix.md")
    )

