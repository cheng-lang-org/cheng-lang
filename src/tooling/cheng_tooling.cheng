fn tooling_cmdVerifyBackendSeedUirImport(root: str): int32 =
    let fixturePath: str = tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/seed_uir_import_min.cheng")
    if !os.fileExists(fixturePath):
        tooling_printErr("cheng_tooling: missing seed UIR import fixture: " + fixturePath)
        return 1
    let target: str = tooling_detectHostTarget(root)
    let outPath: str = tooling_pathAbsolute(root, "artifacts/backend_seed_uir_import/seed_uir_import_min.o")
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        tooling_tryMkdirP(root, outDir)
    if os.fileExists(outPath):
        os.removeFile(outPath)
    var candidates: str[] = []
    let currentSourceProof: str = tooling_pathAbsolute(
        root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2")
    if tooling_isExecutable(root, currentSourceProof):
        add(candidates, currentSourceProof)
    let recoverySeed: str = tooling_resolveRecoverySeedCompiler(root, false)
    if tooling_isExecutable(root, recoverySeed) && !tooling_seqContainsStr(candidates, recoverySeed):
        add(candidates, recoverySeed)
    let canonicalDriver: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if tooling_isExecutable(root, canonicalDriver) && !tooling_seqContainsStr(candidates, canonicalDriver):
        add(candidates, canonicalDriver)
    let selfhostStage2: str = tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/cheng.stage2")
    if tooling_isExecutable(root, selfhostStage2) && !tooling_seqContainsStr(candidates, selfhostStage2):
        add(candidates, selfhostStage2)
    if candidates.len <= 0:
        tooling_printErr("cheng_tooling: missing seed UIR import compiler candidates")
        return 1
    var chosenCompiler: str = ""
    var chosenRc: int32 = 1
    for i in 0..<candidates.len:
        let compilerPath: str = candidates[i]
        let tempOut: str = outPath + ".candidate." + intToStr(i)
        if os.fileExists(tempOut):
            os.removeFile(tempOut)
        var cmd: str = ""
        cmd = cmd + tooling_envAssignCompat("DYLD_INSERT_LIBRARIES", "")
        cmd = cmd + tooling_envAssignCompat("DYLD_FORCE_FLAT_NAMESPACE", "")
        cmd = cmd + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS_STRICT", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "0")
        cmd = cmd + tooling_envAssignCompat("MM", "orc")
        cmd = cmd + tooling_envAssignCompat("CACHE", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_AUTO_SYSTEM", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_BUILD_TRACK", "dev")
        cmd = cmd + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
        cmd = cmd + tooling_envAssignCompat("WHOLE_PROGRAM", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_WHOLE_PROGRAM", "1")
        cmd = cmd + tooling_envAssignCompat("whole_program", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_STAGE1_PARSE_MODE", "outline")
        cmd = cmd + tooling_envAssignCompat("BACKEND_FN_SCHED", "ws")
        cmd = cmd + tooling_envAssignCompat("BACKEND_DIRECT_EXE", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_LINKERLESS_INMEM", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_FAST_FALLBACK_ALLOW", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_MULTI", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_MULTI_FORCE", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_MULTI_MODULE_CACHE", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_MODULE_CACHE", "")
        cmd = cmd + tooling_envAssignCompat("BACKEND_MODULE_CACHE_UNSTABLE_ALLOW", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_INCREMENTAL", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_JOBS", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_FN_JOBS", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_VALIDATE", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_OPT_LEVEL", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_OPT", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_OPT2", "0")
        cmd = cmd + tooling_envAssignCompat("UIR_SIMD", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_SKIP_CPROFILE", "1")
        cmd = cmd + tooling_envAssignCompat("STAGE1_PROFILE", "0")
        cmd = cmd + tooling_envAssignCompat("GENERIC_MODE", "dict")
        cmd = cmd + tooling_envAssignCompat("GENERIC_SPEC_BUDGET", "0")
        cmd = cmd + tooling_envAssignCompat("GENERIC_LOWERING", "mir_dict")
        cmd = cmd + tooling_envAssignCompat("BACKEND_STAGE1_DISABLE_DUP_SCAN", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_STAGE1_BUILDER", "stage1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_SKIP_GLOBAL_INIT", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_SKIP_UIR_FIXUPS", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_SKIP_UIR_NORMALIZE", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_LINKER", "system")
        cmd = cmd + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_INTERNAL_ALLOW_EMIT_OBJ", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_ALLOW_NO_MAIN", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_EMIT", "obj")
        cmd = cmd + tooling_envAssignCompat("BACKEND_TARGET", target)
        cmd = cmd + tooling_shellQuote(compilerPath)
        cmd = cmd + " " + tooling_shellQuote("--input:" + fixturePath)
        cmd = cmd + " " + tooling_shellQuote("--output:" + tempOut)
        cmd = cmd + " " + tooling_shellQuote("--target:" + target)
        cmd = cmd + " " + tooling_shellQuote("--linker:system")
        let res: os.ExecCmdResult = tooling_exec(root, cmd)
        let rc: int32 = os.execCmdResultExitCode(res)
        if rc == 0 && tooling_fileExistsNonEmpty(tempOut):
            if os.fileExists(outPath):
                os.removeFile(outPath)
            os.rename(tempOut, outPath)
            chosenCompiler = compilerPath
            chosenRc = 0
            break
        chosenRc = rc
        if os.fileExists(tempOut):
            os.removeFile(tempOut)
        tooling_printErr("cheng_tooling: seed UIR import candidate failed rc=" + intToStr(rc) +
                         " kind=" + tooling_exitKind(rc) + " compiler=" + compilerPath)
        let rows: str[] = tooling_splitLines(os.execCmdResultOutput(res))
        var shown: int32 = 0
        for j in 0..<rows.len:
            if shown >= 6:
                break
            let row: str = strutil.strip(rows[j])
            if tooling_strNonEmpty(row):
                tooling_printErr("cheng_tooling: seed UIR import log: " + row)
                shown = shown + 1
    if chosenRc != 0:
        tooling_printErr("cheng_tooling: verify_backend_seed_uir_import failed rc=" + intToStr(chosenRc))
        return chosenRc
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_printErr("cheng_tooling: verify_backend_seed_uir_import missing output: " + outPath)
        return 1
    tooling_printOut("verify_backend_seed_uir_import_compiler=" + chosenCompiler)
    tooling_printOut("verify_backend_seed_uir_import ok")
    return 0

fn tooling_resolveReturnAddFixture(root: str): str =
    let fixturePath: str = tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/return_add.cheng")
    if tooling_fileExistsNonEmpty(fixturePath):
        return fixturePath
    let fallbackPath: str = tooling_pathAbsolute(root, "return_add.cheng")
    if tooling_fileExistsNonEmpty(fallbackPath):
        return fallbackPath
    return fixturePath

fn tooling_verifyBackendSidecarChengCommon(root: str, gateName: str, snapshotPrefix: str, sidecarMode: str,
                                           compilerPath: str, target: str, builtObj: str, builtBundle: str,
                                           outDir: str): int32 =
    let outerDriver: str = tooling_prepareBackendDriverSidecarOuterDriver(root, target)
    if !tooling_isExecutable(root, outerDriver):
        tooling_printErr("cheng_tooling: " + gateName + " missing native outer driver")
        return 1
    tooling_tryMkdirP(root, outDir)
    let reportPath: str = os.joinPath(outDir, gateName + ".report.txt")
    let snapshotPath: str = os.joinPath(outDir, gateName + ".snapshot.env")
    var fixtures: str[] = []
    add(fixtures, tooling_resolveReturnAddFixture(root))
    add(fixtures, os.joinPath(root, "tests/cheng/backend/fixtures/return_new_expr_generic_box.cheng"))
    add(fixtures, os.joinPath(root, "tests/cheng/backend/fixtures/return_new_ref_seq_growth.cheng"))
    var fixtureReports: str[] = []
    for i in 0..<fixtures.len:
        let fixturePath: str = fixtures[i]
        if !tooling_fileExistsNonEmpty(fixturePath):
            tooling_printErr("cheng_tooling: " + gateName + " missing fixture: " + fixturePath)
            return 1
        let name: str = os.splitFile(fixturePath).name
        let exePath: str = os.joinPath(outDir, name + ".sidecar")
        let cacheExePath: str = os.joinPath(root,
            "chengcache/backend_driver_sidecar/" + gateName + "." + intToStr(i) + ".sidecar")
        let compileLog: str = os.joinPath(outDir, name + ".compile.log")
        let runLog: str = os.joinPath(outDir, name + ".run.log")
        if os.fileExists(exePath):
            os.removeFile(exePath)
        if os.fileExists(cacheExePath):
            os.removeFile(cacheExePath)
        if os.fileExists(compileLog):
            os.removeFile(compileLog)
        if os.fileExists(runLog):
            os.removeFile(runLog)
        var compileEnv: str[] = []
        tooling_envAssignCollect(compileEnv, "BACKEND_UIR_SIDECAR_MODE", sidecarMode)
        tooling_envAssignCollect(compileEnv, "BACKEND_UIR_SIDECAR_BUNDLE", builtBundle)
        tooling_envAssignCollect(compileEnv, "BACKEND_UIR_SIDECAR_COMPILER", compilerPath)
        tooling_envAssignCollect(compileEnv, "BACKEND_TARGET", target)
        tooling_envAssignCollect(compileEnv, "BACKEND_INPUT", fixturePath)
        tooling_envAssignCollect(compileEnv, "BACKEND_OUTPUT", cacheExePath)
        var outerArgs: str[] = []
        let compileRes: os.ExecCmdResult =
            tooling_execFileDirect(outerDriver, outerArgs, compileEnv, root, 60, true)
        os.writeFile(compileLog, os.execCmdResultOutput(compileRes))
        let compileRc: int32 = os.execCmdResultExitCode(compileRes)
        if compileRc != 0 || !tooling_fileExistsNonEmpty(cacheExePath):
            tooling_printErr("cheng_tooling: " + gateName + " compile failed fixture=" +
                             fixturePath + " rc=" + intToStr(compileRc))
            return 1
        if !tooling_copyExecutablePreserveBytes(root, cacheExePath, exePath):
            tooling_printErr("cheng_tooling: " + gateName + " failed to install fixture output: " + exePath)
            return 1
        var runArgs: str[] = []
        var runEnv: str[] = []
        let runRes: os.ExecCmdResult =
            tooling_execFileDirect(exePath, runArgs, runEnv, root, 10, true)
        os.writeFile(runLog, os.execCmdResultOutput(runRes))
        let runRc: int32 = os.execCmdResultExitCode(runRes)
        if runRc != 0:
            tooling_printErr("cheng_tooling: " + gateName + " run failed fixture=" +
                             fixturePath + " rc=" + intToStr(runRc))
            return 1
        add(fixtureReports, name + ":ok")
    var reportText: str = ""
    reportText = reportText + "status=ok\n"
    reportText = reportText + "gate=" + gateName + "\n"
    reportText = reportText + "sidecar_mode=" + sidecarMode + "\n"
    reportText = reportText + "compiler=" + compilerPath + "\n"
    reportText = reportText + "driver=" + outerDriver + "\n"
    reportText = reportText + "driver_mode=native_sidecar_outer\n"
    reportText = reportText + "target=" + target + "\n"
    reportText = reportText + "object=" + builtObj + "\n"
    reportText = reportText + "bundle=" + builtBundle + "\n"
    reportText = reportText + "fixtures=" + strutil.join(fixtureReports, ",") + "\n"
    os.writeFile(reportPath, reportText)
    var snapshotText: str = ""
    snapshotText = snapshotText + snapshotPrefix + "_status=ok\n"
    snapshotText = snapshotText + snapshotPrefix + "_compiler=" + compilerPath + "\n"
    snapshotText = snapshotText + snapshotPrefix + "_driver=" + outerDriver + "\n"
    snapshotText = snapshotText + snapshotPrefix + "_driver_mode=native_sidecar_outer\n"
    snapshotText = snapshotText + snapshotPrefix + "_target=" + target + "\n"
    snapshotText = snapshotText + snapshotPrefix + "_mode=" + sidecarMode + "\n"
    snapshotText = snapshotText + snapshotPrefix + "_bundle=" + builtBundle + "\n"
    snapshotText = snapshotText + snapshotPrefix + "_report=" + reportPath + "\n"
    snapshotText = snapshotText + snapshotPrefix + "_fixtures=" +
                   strutil.join(fixtureReports, ",") + "\n"
    os.writeFile(snapshotPath, snapshotText)
    tooling_printOut(gateName + " ok")
    return 0

fn tooling_cmdVerifyBackendSidecarChengSeed(root: str): int32 =
    let compilerPath: str = tooling_resolveBackendSidecarCompiler(root)
    if !tooling_fileExistsNonEmpty(compilerPath):
        tooling_printErr("cheng_tooling: missing recovery seed compiler: " + compilerPath)
        return 1
    let target: str = tooling_detectHostTarget(root)
    let objPath: str = tooling_backendDriverUirSidecarObjPath(root, target)
    let bundlePath: str = tooling_backendDriverUirSidecarBundlePath(root, target)
    if os.fileExists(objPath):
        os.removeFile(objPath)
    if os.fileExists(bundlePath):
        os.removeFile(bundlePath)
    let builtObj: str = tooling_prepareBackendDriverUirSidecarEmergencyObj(root, target)
    if !tooling_fileExistsNonEmpty(builtObj):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_seed missing object output")
        return 1
    let builtBundle: str = tooling_prepareBackendDriverUirSidecarEmergencyBundle(root, target, builtObj)
    if !tooling_fileExistsNonEmpty(builtBundle):
        tooling_printErr("cheng_tooling: verify_backend_sidecar_cheng_seed missing bundle output")
        return 1
    let outDir: str = os.joinPath(root, "artifacts/backend_sidecar_cheng_seed")
    return tooling_verifyBackendSidecarChengCommon(root,
                                                   "verify_backend_sidecar_cheng_seed",
                                                   "backend_sidecar_cheng_seed",
                                                   "emergency_c",
                                                   compilerPath,
                                                   target,
                                                   builtObj,
                                                   builtBundle,
                                                   outDir)

fn tooling_cmdVerifyBackendSidecarChengFresh(root: str): int32 =
    let compilerPath: str = tooling_resolveBackendSidecarCompiler(root)
    if !tooling_fileExistsNonEmpty(compilerPath):
        tooling_printErr("cheng_tooling: missing fresh sidecar compiler: " + compilerPath)
