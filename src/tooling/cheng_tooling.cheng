fn tooling_runtimeObjPath(root: str, target: str): str =
    let candidate0: str = os.joinPath(root, "chengcache/runtime_selflink/system_helpers.backend.combined." + target + ".o")
    if os.fileExists(candidate0) && tooling_runtimeObjHasRequiredSymbols(root, candidate0):
        return candidate0
    let candidate1: str = os.joinPath(root, "artifacts/backend_mm/system_helpers.backend.combined." + target + ".o")
    if os.fileExists(candidate1) && tooling_runtimeObjHasRequiredSymbols(root, candidate1):
        return candidate1
    let candidate2: str = os.joinPath(root, "artifacts/backend_selfhost_self_obj/stage1.native.runtime.dedup.o")
    if os.fileExists(candidate2) && tooling_runtimeObjHasRequiredSymbols(root, candidate2):
        return candidate2
    let candidate3: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng." + target + ".o")
    if os.fileExists(candidate3) && tooling_runtimeObjHasRequiredSymbols(root, candidate3):
        return candidate3
    let candidate4: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng.o")
    if os.fileExists(candidate4) && tooling_runtimeObjHasRequiredSymbols(root, candidate4):
        return candidate4
    return ""

fn tooling_runtimeLdArch(target: str): str =
    if strutil.startsWith(target, "arm64") || strutil.startsWith(target, "aarch64"):
        return "arm64"
    if strutil.startsWith(target, "x86_64"):
        return "x86_64"
    if strutil.startsWith(target, "riscv64"):
        return "riscv64"
    return ""

fn tooling_prepareRuntimeObjForTarget(root: str, compilerPath: str, target: str): str =
    let fallbackPath: str = tooling_runtimeObjPath(root, target)
    let fallbackOk: bool = tooling_runtimeObjHasRequiredSymbols(root, fallbackPath)
    if !tooling_isExecutable(root, compilerPath):
        return fallbackPath
    let refreshEnabled: bool =
        tooling_isTrue(os.getEnvDefault("BACKEND_RUNTIME_OBJ_REFRESH", "0")) ||
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_RUNTIME_OBJ_REFRESH", "0")) ||
        tooling_isTrue(os.getEnvDefault("BACKEND_SELFHOST_RUNTIME_OBJ_REFRESH", "0"))
    if !refreshEnabled && fallbackOk:
        return fallbackPath
    let arch: str = tooling_runtimeLdArch(target)
    if !tooling_strNonEmpty(arch):
        return fallbackPath
    let runtimeSrc: str = os.joinPath(root, "src/std/system_helpers_backend.cheng")
    let shimSrc: str = os.joinPath(root, "src/runtime/native/system_helpers_selflink_shim.c")
    let fdWriteBridgeSrc: str = os.joinPath(root, "src/runtime/native/system_helpers_fd_write_bridge.c")
    let epochTimeBridgeSrc: str = os.joinPath(root, "src/runtime/native/system_helpers_epoch_time_bridge.c")
    let openCloseBridgeSrc: str = os.joinPath(root, "src/runtime/native/system_helpers_open_close_bridge.c")
    let bridgeSrc: str = os.joinPath(root, "src/backend/tooling/backend_driver_symbol_bridge.c")
    let baseObj: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng." + target + ".o")
    let runtimeDir: str = os.joinPath(root, "chengcache/runtime_selflink")
    let shimObj: str = os.joinPath(runtimeDir, "system_helpers_selflink_shim." + target + ".o")
    let fdWriteBridgeObj: str = os.joinPath(runtimeDir, "system_helpers_fd_write_bridge." + target + ".o")
    let epochTimeBridgeObj: str = os.joinPath(runtimeDir, "system_helpers_epoch_time_bridge." + target + ".o")
    let openCloseBridgeObj: str = os.joinPath(runtimeDir, "system_helpers_open_close_bridge." + target + ".o")
    let bridgeObj: str = os.joinPath(runtimeDir, "backend_driver_symbol_bridge." + target + ".o")
    let combinedObj: str = os.joinPath(runtimeDir, "system_helpers.backend.combined." + target + ".o")
    let combinedTmp: str = combinedObj + ".tmp"
    let mmCombinedObj: str = os.joinPath(root, "artifacts/backend_mm/system_helpers.backend.combined." + target + ".o")
    let mmCodexFullObj: str = os.joinPath(runtimeDir, "system_helpers.backend.combined." + target + ".codex_full.o")
    let baseObjDir: str = os.parentDir(baseObj)
    if tooling_strNonEmpty(baseObjDir):
        tooling_tryMkdirP(root, baseObjDir)
    tooling_tryMkdirP(root, runtimeDir)
    var timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("BACKEND_RUNTIME_OBJ_REFRESH_TIMEOUT", ""), 60)
    if timeoutSec < 1:
        timeoutSec = 60
    let refreshCompiler: str = compilerPath
    var prepRcFinal: int32 = 1
    var prepOutFinal: str = ""
    if !tooling_isExecutable(root, refreshCompiler):
        prepRcFinal = 127
    else:
        var prepared: bool = false
        var mmSourceObj: str = mmCombinedObj
        if os.fileExists(mmCodexFullObj):
            mmSourceObj = mmCodexFullObj
        if os.fileExists(mmSourceObj) && os.fileExists(fdWriteBridgeSrc) &&
           os.fileExists(epochTimeBridgeSrc) && os.fileExists(openCloseBridgeSrc):
            var prepMmCmd: str = "cc -std=c11 -O2 -mmacosx-version-min=11.0 -c " +
                                 tooling_shellQuote(fdWriteBridgeSrc) + " -o " + tooling_shellQuote(fdWriteBridgeObj) +
                                 " && cc -std=c11 -O2 -mmacosx-version-min=11.0 -c " +
                                 tooling_shellQuote(epochTimeBridgeSrc) + " -o " + tooling_shellQuote(epochTimeBridgeObj) +
                                 " && cc -std=c11 -O2 -mmacosx-version-min=11.0 -c " +
                                 tooling_shellQuote(openCloseBridgeSrc) + " -o " + tooling_shellQuote(openCloseBridgeObj) +
                                 " && cc -std=c11 -O2 -mmacosx-version-min=11.0 -c " +
                                 tooling_shellQuote(bridgeSrc) + " -o " + tooling_shellQuote(bridgeObj) +
                                 " && ld -r -arch " + arch + " -o " + tooling_shellQuote(combinedTmp) + " " +
                                 tooling_shellQuote(mmSourceObj) + " " + tooling_shellQuote(fdWriteBridgeObj) + " " +
                                 tooling_shellQuote(epochTimeBridgeObj) + " " +
                                 tooling_shellQuote(openCloseBridgeObj) + " " +
                                 tooling_shellQuote(bridgeObj) +
                                 " && mv " + tooling_shellQuote(combinedTmp) + " " + tooling_shellQuote(combinedObj)
            prepMmCmd = tooling_prefixUnsetLegacyFrontendEnv(prepMmCmd)
            prepMmCmd = tooling_wrapStage0LockTimeout(root, timeoutSec, prepMmCmd, "runtime_obj_refresh")
            let prepMmRes: os.ExecCmdResult = tooling_exec(root, prepMmCmd)
            prepRcFinal = os.execCmdResultExitCode(prepMmRes)
            prepOutFinal = os.execCmdResultOutput(prepMmRes)
            if prepRcFinal == 0 && os.fileExists(combinedObj) &&
               tooling_runtimeObjHasRequiredSymbols(root, combinedObj):
                return combinedObj
            prepared = prepRcFinal == 0 && os.fileExists(combinedObj) &&
                       tooling_runtimeObjHasRequiredSymbols(root, combinedObj)
        if !prepared:
            if !os.fileExists(runtimeSrc) || !os.fileExists(shimSrc) || !os.fileExists(bridgeSrc) ||
               !os.fileExists(epochTimeBridgeSrc) || !os.fileExists(openCloseBridgeSrc):
                return fallbackPath
            var prepCmd: str = "BACKEND_BUILD_DRIVER_STAGE0= BACKEND_STAGE0= "
            prepCmd = prepCmd +
                tooling_envAssignCompat("BACKEND_STAGE1_BUILDER", "stage1") +
                tooling_envAssignCompat("MM", "orc") +
                tooling_envAssignCompat("CACHE", "0") +
                tooling_envAssignCompat("BACKEND_INTERNAL_ALLOW_EMIT_OBJ", "1") +
                tooling_envAssignCompat("BACKEND_ALLOW_NO_MAIN", "1") +
                tooling_envAssignCompat("BACKEND_EMIT", "obj") +
                tooling_envAssignCompat("BACKEND_TARGET", target) +
                tooling_envAssignCompat("BACKEND_INPUT", runtimeSrc) +
                tooling_envAssignCompat("BACKEND_OUTPUT", baseObj) +
                tooling_stage0LegacyCStringCompatPrefix(root, refreshCompiler) +
                tooling_shellQuote(refreshCompiler) +
                " && cc -std=c11 -O2 -mmacosx-version-min=11.0 -c " + tooling_shellQuote(shimSrc) + " -o " + tooling_shellQuote(shimObj) +
                " && cc -std=c11 -O2 -mmacosx-version-min=11.0 -c " + tooling_shellQuote(epochTimeBridgeSrc) + " -o " + tooling_shellQuote(epochTimeBridgeObj) +
                " && cc -std=c11 -O2 -mmacosx-version-min=11.0 -c " + tooling_shellQuote(openCloseBridgeSrc) + " -o " + tooling_shellQuote(openCloseBridgeObj) +
                " && cc -std=c11 -O2 -mmacosx-version-min=11.0 -c " + tooling_shellQuote(bridgeSrc) + " -o " + tooling_shellQuote(bridgeObj) +
                " && ld -r -arch " + arch + " -o " + tooling_shellQuote(combinedTmp) + " " +
                tooling_shellQuote(baseObj) + " " + tooling_shellQuote(shimObj) + " " + tooling_shellQuote(epochTimeBridgeObj) + " " +
                tooling_shellQuote(openCloseBridgeObj) + " " +
                tooling_shellQuote(bridgeObj) +
                " && mv " + tooling_shellQuote(combinedTmp) + " " + tooling_shellQuote(combinedObj)
            prepCmd = tooling_prefixUnsetLegacyFrontendEnv(prepCmd)
            prepCmd = tooling_wrapStage0LockTimeout(root, timeoutSec, prepCmd, "runtime_obj_refresh")
            let prepRes: os.ExecCmdResult = tooling_exec(root, prepCmd)
            prepRcFinal = os.execCmdResultExitCode(prepRes)
            prepOutFinal = os.execCmdResultOutput(prepRes)
            if prepRcFinal == 0 && os.fileExists(combinedObj) &&
               tooling_runtimeObjHasRequiredSymbols(root, combinedObj):
                return combinedObj
    let strictRefresh: bool = tooling_isTrue(os.getEnvDefault("BACKEND_RUNTIME_OBJ_REFRESH_STRICT", "0"))
    if !strictRefresh && fallbackOk:
        return fallbackPath
    tooling_printErr("cheng_tooling: runtime object refresh failed for target=" + target +
                     " rc=" + intToStr(prepRcFinal) + " kind=" + tooling_exitKind(prepRcFinal))
    let refreshDebug: bool = strictRefresh || tooling_isTrue(os.getEnvDefault("BACKEND_RUNTIME_OBJ_REFRESH_DEBUG", "0"))
    if refreshDebug && tooling_strNonEmpty(prepOutFinal):
        let rows: str[] = tooling_splitLines(prepOutFinal)
        var shown: int32 = 0
        for i in 0..<rows.len:
            if shown >= 80:
                break
            tooling_printErr("cheng_tooling: runtime refresh log: " + rows[i])
            shown = shown + 1
    if strictRefresh:
        return ""
    return fallbackOk ? fallbackPath : ""

fn tooling_printBackendResolveSelflinkRuntimeObjUsage() =
    tooling_printOut("backend_resolve_selflink_runtime_obj options:")
    tooling_printOut("  --target:<triple>            backend target triple (default BACKEND_TARGET or host)")
    tooling_printOut("  --prepare:0|1                refresh runtime object when missing/incomplete (default 1)")
    tooling_printOut("  --strict:0|1                 fail when unresolved (default 1)")
    tooling_printOut("  --help|-h")

fn tooling_cmdBackendResolveSelflinkRuntimeObjFromArgs(root: str, argStart: int32, count: int32): int32 =
    var targetRaw: str = ""
    var prepare: bool = true
    var strict: bool = true
    var i: int32 = argStart
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printBackendResolveSelflinkRuntimeObjUsage()
            return 0
        if strutil.startsWith(arg, "--target:"):
            targetRaw = strings.dropPrefix(arg, "--target:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--prepare:"):
            prepare = tooling_isTrue(strings.dropPrefix(arg, "--prepare:"))
            i = i + 1
            continue
        if strutil.startsWith(arg, "--strict:"):
            strict = tooling_isTrue(strings.dropPrefix(arg, "--strict:"))
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown backend_resolve_selflink_runtime_obj arg: " + arg)
        return 1
    if !tooling_strNonEmpty(strutil.strip(targetRaw)):
        targetRaw = strutil.strip(os.getEnvDefault("BACKEND_TARGET", ""))
    let target: str = tooling_normalizeTargetAlias(root, targetRaw)
    if !tooling_strNonEmpty(target) || tooling_strEq(target, "auto"):
        tooling_printErr("cheng_tooling: unable to resolve backend target; pass --target:<triple> or set BACKEND_TARGET")
        return 1
    var runtimeObj: str = tooling_runtimeObjPath(root, target)
    if prepare && (!os.fileExists(runtimeObj) || !tooling_runtimeObjHasRequiredSymbols(root, runtimeObj)):
        let stage0: str = tooling_resolveStage0Driver(root, "")
        if tooling_isExecutable(root, stage0):
            runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0, target)
    let ok: bool = tooling_strNonEmpty(runtimeObj) &&
                   os.fileExists(runtimeObj) &&
                   tooling_runtimeObjHasRequiredSymbols(root, runtimeObj)
    tooling_printOut("backend_runtime_obj_target=" + target)
    tooling_printOut("backend_runtime_obj_path=" + runtimeObj)
    tooling_printOut("backend_runtime_obj_ok=" + tooling_boolText(ok))
    if ok:
        return 0
    tooling_printErr("cheng_tooling: missing valid self-link runtime object for target=" + target)
    return strict ? 1 : 0

fn tooling_outputLooksExecutable(root: str, outPath: str): bool =
    if !tooling_strNonEmpty(outPath) || !os.fileExists(outPath):
        return false
    let probeFile: os.ExecCmdResult = tooling_exec(root, "command -v file >/dev/null 2>&1")
    if os.execCmdResultExitCode(probeFile) != 0:
        return true
    let res: os.ExecCmdResult = tooling_exec(root, "file -b " + tooling_shellQuote(outPath))
    if os.execCmdResultExitCode(res) != 0:
        return true
    let desc: str = strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res)))
    if !tooling_strNonEmpty(desc):
        return true
    return tooling_strContains(desc, "executable")

fn tooling_driverNativeContractProbeOk(root: str, stage0Exec: str, timeoutSec: int32): bool =
    let probeEnabled: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_PROBE_NATIVE_CONTRACT", "0"))
    if !probeEnabled:
        return true
    let fixtureRel: str = strutil.strip(
        os.getEnvDefault("TOOLING_STAGE0_PROBE_NATIVE_CONTRACT_FIXTURE",
                         "tests/cheng/backend/fixtures/return_i64.cheng"))
    if !tooling_strNonEmpty(fixtureRel):
        return true
    let fixturePath: str = os.joinPath(root, fixtureRel)
    if !os.fileExists(fixturePath):
        return true
    let probeOut: str = os.joinPath(root, "chengcache/tooling_stage0_probe.native_contract." +
                                    tooling_nowNonceText() + ".o")
    let probeOutDir: str = os.parentDir(probeOut)
    if tooling_strNonEmpty(probeOutDir):
        tooling_tryMkdirP(root, probeOutDir)
    if os.fileExists(probeOut):
        os.removeFile(probeOut)
    var probeCmd: str = ""
    probeCmd = probeCmd + tooling_envAssignCompat("MM", "orc")
    probeCmd = probeCmd + tooling_envAssignCompat("CACHE", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("STAGE1_SKIP_CPROFILE", "1")
    probeCmd = probeCmd + tooling_envAssignCompat("STAGE1_PROFILE", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_ENABLE_CLI", "1")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_NATIVE_CONTRACT", "1")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_LINKER", "self")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "1")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_VALIDATE", "1")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_ELF_PROFILE", "nolibc")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_INTERNAL_ALLOW_EMIT_OBJ", "1")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_EMIT", "obj")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_TARGET", "linux-aarch64")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_INPUT", fixturePath)
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_OUTPUT", probeOut)
    probeCmd = probeCmd + tooling_stage0LegacyCStringCompatPrefix(root, stage0Exec)
    probeCmd = probeCmd + tooling_shellQuote(stage0Exec)
    probeCmd = tooling_wrapStage0LockTimeout(root, timeoutSec, probeCmd, "stage0_native_contract_probe")
    let probeRes: os.ExecCmdResult = tooling_exec(root, probeCmd)
    let probeRc: int32 = os.execCmdResultExitCode(probeRes)
    let probeOutText: str = strutil.strip(os.execCmdResultOutput(probeRes))
    if probeRc != 0:
        tooling_printErr("cheng_tooling: stage0 native_contract probe failed rc=" + intToStr(probeRc) +
                         " kind=" + tooling_exitKind(probeRc))
        if tooling_strNonEmpty(probeOutText):
            let rows: str[] = tooling_splitLines(probeOutText)
            var shown: int32 = 0
            for i in 0..<rows.len:
                if shown >= 6:
                    break
                tooling_printErr("cheng_tooling: stage0 native_contract probe log: " + rows[i])
                shown = shown + 1
        if os.fileExists(probeOut):
            os.removeFile(probeOut)
        return false
    let sizeProbe: os.ExecCmdResult = tooling_exec(root, "test -s " + tooling_shellQuote(probeOut))
    if os.execCmdResultExitCode(sizeProbe) != 0:
        tooling_printErr("cheng_tooling: stage0 native_contract probe produced no object output")
        if os.fileExists(probeOut):
            os.removeFile(probeOut)
        return false
    if os.fileExists(probeOut):
        os.removeFile(probeOut)
    return true

fn tooling_driverCompileProbeOk(root: str, binPath: str): bool =
    if !tooling_isExecutable(root, binPath):
        return false
    var probeInputRel: str = strutil.strip(os.getEnvDefault("TOOLING_STAGE0_PROBE_FIXTURE", ""))
    if !tooling_strNonEmpty(probeInputRel):
        # Use a minimal runtime fixture by default; this catches stage0 driver
        # regressions that can pass import-heavy probes but still segfault on
        # small end-to-end compile paths.
        probeInputRel = "tests/cheng/backend/fixtures/return_add.cheng"
    let probeInput: str = os.joinPath(root, probeInputRel)
    if !os.fileExists(probeInput):
        return true
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        return true
    let runtimeObj: str = tooling_runtimeObjPath(root, target)
    if !os.fileExists(runtimeObj):
        return true
    let stage0Exec: str = tooling_prepareStage0Exec(root, binPath, "probe")
    if !tooling_strNonEmpty(stage0Exec):
        return false
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    var timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_PROBE_TIMEOUT", ""), 60)
    if timeoutSec <= 0:
        timeoutSec = 60
    let probeOut: str = os.joinPath(root, "chengcache/tooling_stage0_probe." + tooling_nowNonceText() + ".bin")
    let probeOutDir: str = os.parentDir(probeOut)
    if tooling_strNonEmpty(probeOutDir):
        tooling_tryMkdirP(root, probeOutDir)
    if os.fileExists(probeOut):
        os.removeFile(probeOut)
    var probeCmd: str = ""
    probeCmd = probeCmd + tooling_envAssignCompat("MM", "orc")
    probeCmd = probeCmd + tooling_envAssignCompat("CACHE", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("STAGE1_AUTO_SYSTEM", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("GENERIC_MODE", "dict")
    probeCmd = probeCmd + tooling_envAssignCompat("GENERIC_SPEC_BUDGET", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("GENERIC_LOWERING", "mir_dict")
    probeCmd = probeCmd + tooling_envAssignCompat("STAGE1_SKIP_CPROFILE", "1")
    # Do not inherit caller semantic profiler; known stage0 profiler chain can segfault.
    probeCmd = probeCmd + tooling_envAssignCompat("STAGE1_PROFILE", "0")
    # Stage0 output sanity probe must prefer the most compatible path.
    # Some stage0 candidates can build valid binaries only through system-link
    # release profile (dev in-memory path can be unavailable during bootstrap).
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_BUILD_TRACK", "release")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_FAST_DEV_PROFILE", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_STAGE1_PARSE_MODE", "full")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_STAGE1_BUILDER", "stage1")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_FN_SCHED", "serial")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_DIRECT_EXE", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_LINKERLESS_INMEM", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_FAST_FALLBACK_ALLOW", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_SKIP_GLOBAL_INIT", os.getEnvDefault("BACKEND_STAGE0_PROBE_SKIP_GLOBAL_INIT", "0"))
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_IR", "uir")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_MULTI", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_MULTI_FORCE", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_INCREMENTAL", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_VALIDATE", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_ALLOW_NO_MAIN", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_LINKER", "system")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "0")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_EMIT", "exe")
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_TARGET", target)
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_INPUT", probeInput)
    probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_OUTPUT", probeOut)
    probeCmd = probeCmd + tooling_shellQuote(stage0Exec)
    probeCmd = tooling_prefixUnsetLegacyFrontendEnv(probeCmd)
    probeCmd = tooling_wrapStage0LockTimeout(root, timeoutSec, probeCmd, "stage0_compile_probe")
    let probeRes: os.ExecCmdResult = tooling_exec(root, probeCmd)
    var probeRc: int32 = os.execCmdResultExitCode(probeRes)
    var probeOutText: str = strutil.strip(os.execCmdResultOutput(probeRes))
    var sizeProbe: os.ExecCmdResult = tooling_exec(root, "test -s " + tooling_shellQuote(probeOut))
    var hasOut: bool = os.execCmdResultExitCode(sizeProbe) == 0
    var executableOut: bool = false
    if hasOut:
        executableOut = tooling_outputLooksExecutable(root, probeOut)
        if probeRc == 0 && !executableOut:
            tooling_printErr("cheng_tooling: stage0 compile probe output is not executable: " + probeOut)
    if probeRc != 0:
        tooling_printErr("cheng_tooling: stage0 compile probe failed rc=" + intToStr(probeRc) +
                         " kind=" + tooling_exitKind(probeRc))
        if tooling_strNonEmpty(probeOutText):
            let rows: str[] = tooling_splitLines(probeOutText)
            var shown: int32 = 0
            for i in 0..<rows.len:
                if shown >= 6:
                    break
                tooling_printErr("cheng_tooling: stage0 probe log: " + rows[i])
                shown = shown + 1
        if os.fileExists(probeOut):
            os.removeFile(probeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    if !hasOut || !executableOut:
        tooling_printErr("cheng_tooling: stage0 compile probe produced no output binary")
        if os.fileExists(probeOut):
            os.removeFile(probeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    let requireRun: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_PROBE_REQUIRE_RUN", "1"))
    if requireRun:
        var runTimeoutSec: int32 = tooling_parseInt32Default(
            os.getEnvDefault("TOOLING_STAGE0_PROBE_RUN_TIMEOUT", ""), 15)
        if runTimeoutSec < 1:
            runTimeoutSec = 15
        var runCmd: str = tooling_shellQuote(probeOut) + " >/dev/null 2>&1"
        runCmd = tooling_wrapCommandWithTimeout(root, runTimeoutSec, runCmd)
        let runRes: os.ExecCmdResult = tooling_exec(root, runCmd)
        let runRc: int32 = os.execCmdResultExitCode(runRes)
        if runRc != 0:
            tooling_printErr("cheng_tooling: stage0 compile probe binary run failed rc=" + intToStr(runRc) +
                             " kind=" + tooling_exitKind(runRc))
            if os.fileExists(probeOut):
                os.removeFile(probeOut)
            tooling_cleanupStage0Exec(binPath, stage0Exec)
            return false
    if !tooling_driverNativeContractProbeOk(root, stage0Exec, timeoutSec):
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    if os.fileExists(probeOut):
        os.removeFile(probeOut)
    tooling_cleanupStage0Exec(binPath, stage0Exec)
    return true

fn tooling_driverCompileSmokeDevInmemOk(root: str, binPath: str): bool =
    if !tooling_isExecutable(root, binPath):
        return false
    var fixturePath: str = tooling_trimAsciiSpace(
        os.getEnvDefault("TOOLING_STAGE0_SMOKE_FIXTURE", "tests/cheng/backend/fixtures/return_add.cheng"))
    fixturePath = tooling_pathAbsolute(root, fixturePath)
    if !os.fileExists(fixturePath):
        fixturePath = os.joinPath(root, "tests/cheng/backend/fixtures/return_add.cheng")
    if !os.fileExists(fixturePath):
        fixturePath = os.joinPath(root, "tests/cheng/backend/fixtures/return_new_ref_seq_growth.cheng")
    if !os.fileExists(fixturePath):
        return true
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        return true
    let stage0Exec: str = tooling_prepareStage0Exec(root, binPath, "probe_dev_inmem")
    if !tooling_strNonEmpty(stage0Exec):
        return false
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    var runtimeObj: str = tooling_runtimeObjPath(root, target)
    if !os.fileExists(runtimeObj):
        runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
    if !os.fileExists(runtimeObj):
        tooling_printErr("cheng_tooling: stage0 dev-inmem smoke missing runtime object: " + runtimeObj)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    var timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_SMOKE_TIMEOUT", ""), 60)
    if timeoutSec <= 0:
        timeoutSec = 60
    let smokeOut: str = os.joinPath(root, "chengcache/tooling_stage0_smoke." + tooling_nowNonceText() + ".bin")
    let smokeOutDir: str = os.parentDir(smokeOut)
    if tooling_strNonEmpty(smokeOutDir):
        tooling_tryMkdirP(root, smokeOutDir)
    if os.fileExists(smokeOut):
        os.removeFile(smokeOut)
    var smokeCmd: str = ""
    smokeCmd = smokeCmd + tooling_envAssignCompat("MM", "orc")
    smokeCmd = smokeCmd + tooling_envAssignCompat("CACHE", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("STAGE1_AUTO_SYSTEM", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("STAGE1_SKIP_CPROFILE", "1")
    smokeCmd = smokeCmd + tooling_envAssignCompat("STAGE1_PROFILE", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_BUILD_TRACK", "dev")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_LINKER", "self")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_FAST_DEV_PROFILE", "1")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_STAGE1_PARSE_MODE", "outline")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_STAGE1_BUILDER", "stage1")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_FN_SCHED", "ws")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_DIRECT_EXE", "1")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_LINKERLESS_INMEM", "1")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_FAST_FALLBACK_ALLOW", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_INCREMENTAL", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_SKIP_GLOBAL_INIT", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_IR", "uir")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_MULTI", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_MULTI_FORCE", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_VALIDATE", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_ALLOW_NO_MAIN", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_EMIT", "exe")
    smokeCmd = smokeCmd + tooling_envAssignCompat("GENERIC_MODE", "dict")
    smokeCmd = smokeCmd + tooling_envAssignCompat("GENERIC_SPEC_BUDGET", "0")
    smokeCmd = smokeCmd + tooling_envAssignCompat("GENERIC_LOWERING", "mir_dict")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_TARGET", target)
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_INPUT", fixturePath)
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_OUTPUT", smokeOut)
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "1")
    smokeCmd = smokeCmd + tooling_envAssignCompat("BACKEND_RUNTIME_OBJ", runtimeObj)
    smokeCmd = smokeCmd + tooling_stage0LegacyCStringCompatPrefix(root, stage0Exec)
    smokeCmd = smokeCmd + tooling_shellQuote(stage0Exec)
    smokeCmd = tooling_prefixUnsetLegacyFrontendEnv(smokeCmd)
    smokeCmd = tooling_wrapStage0LockTimeout(root, timeoutSec, smokeCmd, "stage0_compile_smoke")
    let smokeRes: os.ExecCmdResult = tooling_exec(root, smokeCmd)
    let smokeRc: int32 = os.execCmdResultExitCode(smokeRes)
    let smokeOutText: str = strutil.strip(os.execCmdResultOutput(smokeRes))
    if smokeRc != 0:
        tooling_printErr("cheng_tooling: stage0 dev-inmem smoke compile failed rc=" + intToStr(smokeRc) +
                         " kind=" + tooling_exitKind(smokeRc))
        if tooling_strNonEmpty(smokeOutText):
            let rows: str[] = tooling_splitLines(smokeOutText)
            var shown: int32 = 0
            for i in 0..<rows.len:
                if shown >= 6:
                    break
                tooling_printErr("cheng_tooling: stage0 dev-inmem smoke log: " + rows[i])
                shown = shown + 1
        if os.fileExists(smokeOut):
            os.removeFile(smokeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    let sizeProbe: os.ExecCmdResult = tooling_exec(root, "test -s " + tooling_shellQuote(smokeOut))
    if os.execCmdResultExitCode(sizeProbe) != 0 || !tooling_outputLooksExecutable(root, smokeOut):
        tooling_printErr("cheng_tooling: stage0 dev-inmem smoke produced invalid binary")
        let keepFailedSmoke: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_SMOKE_KEEP_FAIL", "0"))
        if os.fileExists(smokeOut):
            let sizeCmd: str = "wc -c < " + tooling_shellQuote(smokeOut)
            let sizeRes: os.ExecCmdResult = tooling_exec(root, sizeCmd)
            let sizeText: str = tooling_trimAsciiSpace(os.execCmdResultOutput(sizeRes))
            if tooling_strNonEmpty(sizeText):
                tooling_printErr("cheng_tooling: stage0 dev-inmem smoke invalid size_bytes=" + sizeText)
            let magicCmd: str = "xxd -l 8 " + tooling_shellQuote(smokeOut) + " 2>/dev/null | head -n 1"
            let magicRes: os.ExecCmdResult = tooling_exec(root, magicCmd)
            let magicText: str = tooling_trimAsciiSpace(os.execCmdResultOutput(magicRes))
            if tooling_strNonEmpty(magicText):
                tooling_printErr("cheng_tooling: stage0 dev-inmem smoke invalid magic=" + magicText)
            if keepFailedSmoke:
                tooling_printErr("cheng_tooling: stage0 dev-inmem smoke keep failed output: " + smokeOut)
            else:
                os.removeFile(smokeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    var runTimeoutSec: int32 = tooling_parseInt32Default(
        os.getEnvDefault("TOOLING_STAGE0_SMOKE_RUN_TIMEOUT", ""), 15)
    if runTimeoutSec < 1:
        runTimeoutSec = 15
    var runCmd: str = tooling_shellQuote(smokeOut) + " >/dev/null 2>&1"
    runCmd = tooling_wrapCommandWithTimeout(root, runTimeoutSec, runCmd)
    let runRes: os.ExecCmdResult = tooling_exec(root, runCmd)
    let runRc: int32 = os.execCmdResultExitCode(runRes)
    if runRc != 0:
        tooling_printErr("cheng_tooling: stage0 dev-inmem smoke run failed rc=" + intToStr(runRc) +
                         " kind=" + tooling_exitKind(runRc))
        if os.fileExists(smokeOut):
            os.removeFile(smokeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    if os.fileExists(smokeOut):
        os.removeFile(smokeOut)
    tooling_cleanupStage0Exec(binPath, stage0Exec)
    return true

