    if smokeMachoCStringOverlap:
        tooling_printErr("[std_string_json] Mach-O cstring overlap warning in compile log: " +
                         smokeCompileLog)
        tooling_printCommandLogTail(root, smokeCompileLog, ctx.gateName, 120)
        rc = 1
    if rc == 0 && !tooling_stdRunCompiledBinary(root, ctx, smokeOut, smokeRunLog, noEnv):
        rc = 1
    let reportLines: str[] = [
        "result=" + tooling_stdResultStatus(rc),
        "driver=" + ctx.driverPath,
        "core_import_src=" + importSrc,
        "core_import_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(importCompileLog)),
        "core_import_run_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(importRunLog)),
        "bytes_import_src=" + bytesImportSrc,
        "bytes_import_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(bytesImportCompileLog)),
        "bytes_import_run_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(bytesImportRunLog)),
        "smoke_src=" + smokeSrc,
        "smoke_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(smokeCompileLog)),
        "smoke_run_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(smokeRunLog))
    ]
    if !tooling_stdWriteReportAndPublish(
        root,
        ctx,
        tooling_renderRawLines(reportLines, true)):
        return 1
    if rc == 0:
        tooling_printOut("verify_std_foundation ok")
    return rc

