fn tooling_cmdVerifyStdBaseline(root: str): int32 =
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_baseline", true)
    if ctx == nil:
        return 1
    let toolBin: str = tooling_stdToolBinary(root)
    if !tooling_isExecutable(root, toolBin):
        tooling_printErr("[std_baseline] missing tooling binary: " + toolBin)
        return 1
    let gateIds: str[] = [
        "verify_std_layout_sync",
        "verify_std_foundation",
        "verify_std_string_json",
        "verify_std_file_io",
        "verify_std_net_io"
    ]
    var rc: int32 = 0
    for i in 0..<gateIds.len:
        if rc != 0:
            break
        let gateId: str = gateIds[i]
        let logPath: str = os.joinPath(ctx.workDir, gateId + ".log")
        let subRes: os.ExecCmdResult = tooling_stdRunToolingSubcommandLogged(root, toolBin, gateId, 0, logPath)
        if !tooling_stdEnsureCommandOk(root, ctx, toolBin + " " + gateId, logPath, subRes):
            rc = 1
    let reportLines: str[] = [
        "result=" + tooling_stdResultStatus(rc),
        "driver=" + ctx.driverPath,
        "layout_log=" + os.joinPath(ctx.finalOutDir, "verify_std_layout_sync.log"),
        "foundation_log=" + os.joinPath(ctx.finalOutDir, "verify_std_foundation.log"),
        "string_json_log=" + os.joinPath(ctx.finalOutDir, "verify_std_string_json.log"),
        "file_io_log=" + os.joinPath(ctx.finalOutDir, "verify_std_file_io.log"),
        "net_io_log=" + os.joinPath(ctx.finalOutDir, "verify_std_net_io.log")
    ]
    if !tooling_stdWriteReportAndPublish(
        root,
        ctx,
        tooling_renderRawLines(reportLines, true)):
        return 1
    if rc == 0:
        tooling_printOut("verify_std_baseline ok")
    return rc

fn tooling_cmdVerifyStdDocsExamples(root: str): int32 =
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_docs_examples", true)
    if ctx == nil:
        return 1
    let docsList: str[] = [
        "docs/stdlib/foundation.md",
        "docs/stdlib/string-json.md",
        "docs/stdlib/file-io.md",
        "docs/stdlib/net-io.md"
    ]
    var rc: int32 = 0
    var docsCount: int32 = 0
    for i in 0..<docsList.len:
        if rc != 0:
            break
        let docRel: str = docsList[i]
        let docPath: str = tooling_pathAbsolute(root, docRel)
        if !tooling_stdRequireFile(ctx.gateName, docPath):
            rc = 1
            break
        let docText: str = tooling_readTextFile(root, docPath)
        if !tooling_strNonEmpty(tooling_stdDocFieldValue(docText, "Modules:")):
            tooling_printErr("[std_docs_examples] doc missing Modules: " + docRel)
            rc = 1
            break
        if !tooling_strNonEmpty(tooling_stdDocFieldValue(docText, "Key APIs:")):
            tooling_printErr("[std_docs_examples] doc missing Key APIs: " + docRel)
            rc = 1
            break
        let exampleRel: str = strutil.replace(tooling_stdDocFieldValue(docText, "Example:"), "`", "")
        if !tooling_strNonEmpty(exampleRel):
            tooling_printErr("[std_docs_examples] doc missing Example: " + docRel)
            rc = 1
            break
        let exampleSrc: str = tooling_pathAbsolute(root, exampleRel)
        let exampleDir: str = os.parentDir(exampleSrc)
        let exampleName: str = tooling_stripSuffix(os.extractFilename(exampleSrc), ".cheng")
        let expectedPath: str = os.joinPath(exampleDir, exampleName + ".expected.txt")
        if !tooling_stdRequireFile(ctx.gateName, exampleSrc) || !tooling_stdRequireFile(ctx.gateName, expectedPath):
            rc = 1
            break
        let outPath: str = os.joinPath(ctx.workDir, exampleName)
        let compileLog: str = os.joinPath(ctx.workDir, exampleName + ".compile.log")
        let runLog: str = os.joinPath(ctx.workDir, exampleName + ".run.log")
        if !tooling_stdCompileSource(root, ctx, exampleSrc, outPath, compileLog):
            rc = 1
            break
        var envOverrides: str[] = []
        if tooling_strEq(exampleName, "file_io"):
            let runtimeDir: str = os.joinPath(ctx.workDir, "example_runtime_" + exampleName)
            tooling_envAssignCollect(envOverrides, "EXAMPLE_STD_TMPDIR", runtimeDir)
        if !tooling_stdRunCompiledBinary(root, ctx, outPath, runLog, envOverrides):
            rc = 1
            break
        if !tooling_stdFilesEqual(root, expectedPath, runLog):
            tooling_printErr("[std_docs_examples] example output mismatch: " + exampleRel +
                             " (expected=" + expectedPath + " actual=" + runLog + ")")
            rc = 1
            break
        docsCount = docsCount + 1
    let reportLines: str[] = [
        "result=" + tooling_stdResultStatus(rc),
        "driver=" + ctx.driverPath,
        "docs_count=" + intToStr(docsCount),
        "foundation_doc=docs/stdlib/foundation.md",
        "string_json_doc=docs/stdlib/string-json.md",
        "file_io_doc=docs/stdlib/file-io.md",
        "net_io_doc=docs/stdlib/net-io.md"
    ]
    if !tooling_stdWriteReportAndPublish(
        root,
        ctx,
        tooling_renderRawLines(reportLines, true)):
        return 1
    if rc == 0:
        tooling_printOut("verify_std_docs_examples ok")
    return rc

fn tooling_cmdVerifyStdStability(root: str): int32 =
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_stability", true)
    if ctx == nil:
        return 1
    let rounds: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_STABILITY_ROUNDS", ""), 3)
    let timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_STABILITY_TIMEOUT", ""), 180)
    let requireStability: bool = tooling_isTrue(os.getEnvDefault("STD_STABILITY_REQUIRE", "0"))
    let toolBin: str = tooling_stdToolBinary(root)
    if !tooling_isExecutable(root, toolBin):
        tooling_printErr("[std_stability] missing tooling binary: " + toolBin)
        return 1
    let gateIds: str[] = ["verify_std_baseline", "verify_std_docs_examples"]
    var refRcs: str[] = []
    var refHashes: str[] = []
    setLen(refRcs, gateIds.len)
    setLen(refHashes, gateIds.len)
    var statusCode: int32 = 0
    var summaryLines: str[] = []
    add(summaryLines, "gate_id\tround\trc\thash")
    var round: int32 = 1
    while round <= rounds:
        for i in 0..<gateIds.len:
            let gateId: str = gateIds[i]
            let logPath: str = os.joinPath(ctx.workDir, gateId + ".round" + intToStr(round) + ".log")
            let runRes: os.ExecCmdResult = tooling_stdRunToolingSubcommandLogged(root, toolBin, gateId, timeoutSec, logPath)
            let childRc: int32 = os.execCmdResultExitCode(runRes)
            let rcText: str = intToStr(childRc)
            let hash: str = tooling_stdStableHashFileIfExists(root, logPath)
            add(summaryLines, gateId + "\t" + intToStr(round) + "\t" + rcText + "\t" + hash)
            if round == 1:
                refRcs[i] = rcText
                refHashes[i] = hash
            elif (rcText != refRcs[i] || hash != refHashes[i]) && statusCode == 0:
                statusCode = 1
            if childRc != 0:
                statusCode = 2
        round = round + 1
    let summaryPath: str = os.joinPath(ctx.workDir, "summary.tsv")
    if !tooling_stdWriteTextFile(root, summaryPath, tooling_renderRawLines(summaryLines, true)):
        tooling_printErr("[std_stability] failed to write summary: " + summaryPath)
        return 1
    let status: str = tooling_stdStabilityStatusText(statusCode)
    let reportLines: str[] = [
        "result=" + status,
        "rounds=" + intToStr(rounds),
        "timeout_s=" + intToStr(timeoutSec),
        "require=" + tooling_boolText(requireStability),
        "summary=" + os.joinPath(ctx.finalOutDir, "summary.tsv")
    ]
    if !tooling_stdWriteReportAndPublish(
        root,
        ctx,
        tooling_renderRawLines(reportLines, true)):
        return 1
    if !tooling_strEq(status, "ok") && requireStability:
        tooling_printErr("[verify_std_stability] fail: status=" + status +
                         " (report=" + os.joinPath(ctx.finalOutDir, "std_stability.report.txt") + ")")
        return 1
    if !tooling_strEq(status, "ok"):
        tooling_printErr("[verify_std_stability] soft fail: status=" + status +
                         " (report=" + os.joinPath(ctx.finalOutDir, "std_stability.report.txt") + ")")
    tooling_printOut("verify_std_stability ok")
    return 0

fn tooling_cmdBuildStdPerfBaselineFromArgs(root: str, argStart: int32, count: int32): int32 =
    let args: str[] = tooling_argsRange(argStart, count)
    for i in 0..<args.len:
        let arg: str = args[i]
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("Usage:")
            tooling_printOut("  " + tooling_stdToolBinary(root) + " build_std_perf_baseline [--out:<path>]")
            tooling_printOut("")
            tooling_printOut("Notes:")
            tooling_printOut("  - Builds a report-only stdlib perf baseline.")
            tooling_printOut("  - Default output: src/tooling/std_perf_baseline.env")
            return 0
        if !strutil.startsWith(arg, "--out:"):
            tooling_printErr("[build_std_perf_baseline] unknown arg: " + arg)
            return 2
    let outRaw: str = tooling_argsReadPrefixedValue(args, "--out:", "src/tooling/std_perf_baseline.env")
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_perf_build", true)
    if ctx == nil:
        return 1
    let warmups: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_WARMUPS", ""), 2)
    let measureRuns: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MEASURE_RUNS", ""), 5)
    let timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_TIMEOUT", ""), 30)
    let memoryIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MEMORY_ITERS", ""), 400)
    let fileIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_FILE_ITERS", ""), 80)
    let udpIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_UDP_ITERS", ""), 16)
    let maxSlowdownPct: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MAX_SLOWDOWN_PERCENT", ""), 10)
    let memoryCases: str[] = ["strings", "strformat", "rawbytes", "seqs", "json", "hashmaps"]
    let memorySrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_memory_bench.cheng")
    let fileSrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_file_io_bench.cheng")
    let udpSrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_udp_witness.cheng")
    if !tooling_stdRequireFile(ctx.gateName, memorySrc) || !tooling_stdRequireFile(ctx.gateName, fileSrc) ||
       !tooling_stdRequireFile(ctx.gateName, udpSrc):
        return 1
    let memoryBin: str = os.joinPath(ctx.workDir, "std_perf_memory_bench")
    let memoryCompileLog: str = os.joinPath(ctx.workDir, "std_perf_memory_bench.compile.log")
    let fileBin: str = os.joinPath(ctx.workDir, "std_perf_file_io_bench")
    let fileCompileLog: str = os.joinPath(ctx.workDir, "std_perf_file_io_bench.compile.log")
    let udpBin: str = os.joinPath(ctx.workDir, "std_perf_udp_witness")
    let udpCompileLog: str = os.joinPath(ctx.workDir, "std_perf_udp_witness.compile.log")
    var rc: int32 = 0
    if rc == 0 && !tooling_stdCompileSource(root, ctx, memorySrc, memoryBin, memoryCompileLog):
        rc = 1
    if rc == 0 && !tooling_stdCompileSource(root, ctx, fileSrc, fileBin, fileCompileLog):
        rc = 1
    let udpCompileRc: int32 = tooling_stdCompileSourceResult(root, ctx, udpSrc, udpBin, udpCompileLog)
    let udpBinReady: bool = udpCompileRc == 0
    var baselineLines: str[] = []
    add(baselineLines, "STD_PERF_BASELINE_VERSION=1")
    add(baselineLines, "STD_PERF_DRIVER=" + ctx.driverPath)
    add(baselineLines, "STD_PERF_WARMUPS=" + intToStr(warmups))
    add(baselineLines, "STD_PERF_MEASURE_RUNS=" + intToStr(measureRuns))
    add(baselineLines, "STD_PERF_MAX_SLOWDOWN_PERCENT=" + intToStr(maxSlowdownPct))
    add(baselineLines, "STD_PERF_MEMORY_CASES=strings,strformat,rawbytes,seqs,json,hashmaps")
    add(baselineLines, "STD_PERF_SKIPPED_CASES=tables")
    add(baselineLines, "STD_PERF_WITNESS_CASES=file_io,udp_loopback")
    if rc == 0:
        for i in 0..<memoryCases.len:
            let caseId: str = memoryCases[i]
            let caseRes: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
                root, ctx.workDir, memoryBin, caseId, memoryIters, warmups, measureRuns, timeoutSec, false)
            if !tooling_strEq(caseRes.status, "ok"):
                tooling_printErr("[build_std_perf_baseline] perf case failed: " + caseId +
                                 " status=" + caseRes.status + " note=" + caseRes.note)
                rc = 1
                break
            tooling_stdPerfAppendEnv(baselineLines, caseId, caseRes)
        if rc == 0:
            let fileRes: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
                root, ctx.workDir, fileBin, "file_io", fileIters, warmups, measureRuns, timeoutSec, false)
            if !tooling_strEq(fileRes.status, "ok"):
                tooling_printErr("[build_std_perf_baseline] perf case failed: file_io status=" +
                                 fileRes.status + " note=" + fileRes.note)
                rc = 1
            else:
                tooling_stdPerfAppendEnv(baselineLines, "file_io", fileRes)
    let tablesRes: ToolingStdPerfCaseResult = tooling_stdPerfCaseResult("skipped", 0, "", "table_symbols_unavailable")
    tooling_stdPerfAppendEnv(baselineLines, "tables", tablesRes)
    if udpBinReady:
        let udpRes: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
            root, ctx.workDir, udpBin, "udp_loopback", udpIters, warmups, measureRuns, timeoutSec, true)
        tooling_stdPerfAppendEnv(baselineLines, "udp_loopback", udpRes)
    else:
        let udpRes: ToolingStdPerfCaseResult = tooling_stdPerfCaseResult("skipped", 0, "", "compile_failed")
        tooling_stdPerfAppendEnv(baselineLines, "udp_loopback", udpRes)
    let outPath: str = tooling_pathAbsolute(root, outRaw)
    let outDir: str = os.parentDir(outPath)
    if rc == 0 && tooling_strNonEmpty(outDir) && !tooling_stdMkdirPNative(root, outDir):
        tooling_printErr("[build_std_perf_baseline] failed to create output dir: " + outDir)
        rc = 1
    if rc == 0 && !tooling_stdWriteTextFile(root, outPath, tooling_renderRawLines(baselineLines, true)):
        tooling_printErr("[build_std_perf_baseline] failed to write baseline: " + outPath)
        rc = 1
    let reportLines: str[] = [
        "result=" + tooling_stdResultStatus(rc),
        "baseline_out=" + outPath,
        "driver=" + ctx.driverPath,
        "memory_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(memoryCompileLog)),
        "file_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(fileCompileLog)),
        "udp_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(udpCompileLog))
    ]
    if !tooling_stdWriteReportAndPublish(
        root,
        ctx,
        tooling_renderRawLines(reportLines, true)):
        return 1
    if rc == 0:
        tooling_printOut("build_std_perf_baseline ok")
    return rc

fn tooling_cmdVerifyStdPerfBaselineFromArgs(root: str, argStart: int32, count: int32): int32 =
    var i: int32 = argStart
    for _ in argStart..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("Usage:")
            tooling_printOut("  " + tooling_stdToolBinary(root) + " verify_std_perf_baseline [--help]")
            tooling_printOut("")
            tooling_printOut("Env:")
            tooling_printOut("  STD_PERF_BASELINE=<path>      Baseline env file (default: src/tooling/std_perf_baseline.env)")
            tooling_printOut("  STD_PERF_REQUIRE=<0|1>        Fail on regression/drift when set to 1 (default: 0)")
            tooling_printOut("")
            tooling_printOut("Notes:")
            tooling_printOut("  - This command is report-only by default.")
            tooling_printOut("  - Deterministic memory cases use a 10% slowdown threshold from the baseline.")
            tooling_printOut("  - File and UDP cases are witness-only and do not gate by default.")
            return 0
        tooling_printErr("[verify_std_perf_baseline] unknown arg: " + arg)
        return 2
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_perf", true)
    if ctx == nil:
        return 1
    let baselineFile: str = tooling_pathAbsolute(root, os.getEnvDefault("STD_PERF_BASELINE", "src/tooling/std_perf_baseline.env"))
    if !tooling_stdRequireFile(ctx.gateName, baselineFile):
        return 1
    let baselineText: str = tooling_readTextFile(root, baselineFile)
    let warmups: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_WARMUPS", ""), 2)
    let measureRuns: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MEASURE_RUNS", ""), 5)
    let timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_TIMEOUT", ""), 30)
    let memoryIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MEMORY_ITERS", ""), 400)
    let fileIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_FILE_ITERS", ""), 80)
    let udpIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_UDP_ITERS", ""), 16)
    let maxSlowdownPct: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MAX_SLOWDOWN_PERCENT", ""), 10)
    let requirePerf: bool = tooling_isTrue(os.getEnvDefault("STD_PERF_REQUIRE", "0"))
    let memoryCases: str[] = tooling_stdCsvList(tooling_kvGet(baselineText, "STD_PERF_MEMORY_CASES"))
    let skippedCases: str[] = tooling_stdCsvList(tooling_kvGet(baselineText, "STD_PERF_SKIPPED_CASES"))
    let memorySrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_memory_bench.cheng")
    let fileSrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_file_io_bench.cheng")
    let udpSrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_udp_witness.cheng")
    if !tooling_stdRequireFile(ctx.gateName, memorySrc) || !tooling_stdRequireFile(ctx.gateName, fileSrc) ||
       !tooling_stdRequireFile(ctx.gateName, udpSrc):
        return 1
    let memoryBin: str = os.joinPath(ctx.workDir, "std_perf_memory_bench")
    let memoryCompileLog: str = os.joinPath(ctx.workDir, "std_perf_memory_bench.compile.log")
    let fileBin: str = os.joinPath(ctx.workDir, "std_perf_file_io_bench")
    let fileCompileLog: str = os.joinPath(ctx.workDir, "std_perf_file_io_bench.compile.log")
    let udpBin: str = os.joinPath(ctx.workDir, "std_perf_udp_witness")
    let udpCompileLog: str = os.joinPath(ctx.workDir, "std_perf_udp_witness.compile.log")
    var statusRef: str[] = []
    if !tooling_stdCompileSource(root, ctx, memorySrc, memoryBin, memoryCompileLog):
        add(statusRef, "failed")
    if tooling_strEq(tooling_stdStatusOrOk(statusRef), "ok") &&
       !tooling_stdCompileSource(root, ctx, fileSrc, fileBin, fileCompileLog):
        add(statusRef, "failed")
    let udpCompileRc: int32 = tooling_stdCompileSourceResult(root, ctx, udpSrc, udpBin, udpCompileLog)
    let udpBinReady: bool = udpCompileRc == 0
    var summaryLines: str[] = []
    add(summaryLines, "case\tkind\tstatus\tbaseline_ms\tcurrent_ms\tbaseline_checksum\tcurrent_checksum\tnote")
    if tooling_strEq(tooling_stdStatusOrOk(statusRef), "ok"):
        for i in 0..<memoryCases.len:
            let caseId: str = memoryCases[i]
            let caseKey: str = tooling_stdPerfCaseKey(caseId)
            let baseMs: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_MS")
            let baseChecksum: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_CHECKSUM")
            let runRes: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
                root, ctx.workDir, memoryBin, caseId, memoryIters, warmups, measureRuns, timeoutSec, false)
            let caseStatus: str = tooling_stdPerfCaseStatus(runRes, baseChecksum, baseMs, maxSlowdownPct)
            let note: str = tooling_stdPerfCaseNote(runRes, baseChecksum, baseMs, maxSlowdownPct)
            if !tooling_strEq(caseStatus, "ok") && !tooling_strNonEmpty(tooling_seqValueAtOrEmpty(statusRef, 0)):
                add(statusRef, caseStatus)
            add(summaryLines, tooling_stdPerfSummaryRow(
                caseId, "memory", caseStatus, baseMs, runRes.medianMs, baseChecksum, runRes.checksum, note))
        for i in 0..<skippedCases.len:
            let caseId: str = skippedCases[i]
            let caseKey: str = tooling_stdPerfCaseKey(caseId)
            let baseMs: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_MS")
            let baseChecksum: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_CHECKSUM")
            let note: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_NOTE")
            add(summaryLines, tooling_stdPerfSummaryRow(
                caseId, "memory", "skipped", baseMs, 0, baseChecksum, "", note))
        let fileBaseMs: str = tooling_kvGet(baselineText, "STD_PERF_FILE_IO_MS")
        let fileBaseChecksum: str = tooling_kvGet(baselineText, "STD_PERF_FILE_IO_CHECKSUM")
        let fileRun: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
            root, ctx.workDir, fileBin, "file_io", fileIters, warmups, measureRuns, timeoutSec, true)
        add(summaryLines, tooling_stdPerfSummaryRow(
            "file_io", "witness", fileRun.status, fileBaseMs, fileRun.medianMs,
            fileBaseChecksum, fileRun.checksum, fileRun.note))
        let udpBaseMs: str = tooling_kvGet(baselineText, "STD_PERF_UDP_LOOPBACK_MS")
        let udpBaseChecksum: str = tooling_kvGet(baselineText, "STD_PERF_UDP_LOOPBACK_CHECKSUM")
        if udpBinReady:
            let udpRun: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
                root, ctx.workDir, udpBin, "udp_loopback", udpIters, warmups, measureRuns, timeoutSec, true)
            add(summaryLines, tooling_stdPerfSummaryRow(
                "udp_loopback", "witness", udpRun.status, udpBaseMs, udpRun.medianMs,
                udpBaseChecksum, udpRun.checksum, udpRun.note))
        else:
            let udpRun: ToolingStdPerfCaseResult = tooling_stdPerfCaseResult("skipped", 0, "", "compile_failed")
            add(summaryLines, tooling_stdPerfSummaryRow(
                "udp_loopback", "witness", udpRun.status, udpBaseMs, udpRun.medianMs,
                udpBaseChecksum, udpRun.checksum, udpRun.note))
    let summaryPath: str = os.joinPath(ctx.workDir, "std_perf_summary.tsv")
    if !tooling_stdWriteTextFile(root, summaryPath, tooling_renderRawLines(summaryLines, true)):
        tooling_printErr("[std_perf] failed to write summary: " + summaryPath)
        return 1
    let status: str = tooling_stdStatusOrOk(statusRef)
    let reportLines: str[] = [
        "result=" + status,
        "baseline_file=" + baselineFile,
        "driver=" + ctx.driverPath,
        "summary=" + os.joinPath(ctx.finalOutDir, "std_perf_summary.tsv"),
        "memory_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(memoryCompileLog)),
        "file_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(fileCompileLog)),
        "udp_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(udpCompileLog))
    ]
    if !tooling_stdWriteReportAndPublish(
        root,
        ctx,
        tooling_renderRawLines(reportLines, true)):
        return 1
    if !tooling_strEq(status, "ok") && requirePerf:
        tooling_printErr("[verify_std_perf_baseline] fail: status=" + status +
                         " (report=" + os.joinPath(ctx.finalOutDir, "std_perf.report.txt") + ")")
        return 1
    if !tooling_strEq(status, "ok"):
        tooling_printErr("[verify_std_perf_baseline] soft fail: status=" + status +
                         " (report=" + os.joinPath(ctx.finalOutDir, "std_perf.report.txt") + ")")
    tooling_printOut("verify_std_perf_baseline ok")
    return 0

fn tooling_dispatchVerifyRoute(root: str, route: str, argStart: int32, count: int32): int32 =
    if tooling_strEq(route, "verify"):
        return tooling_cmdVerifyDefaultFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_ffi_slice_shim"):
        return tooling_cmdVerifyBackendFfiSliceShimFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_ffi_outptr_tuple"):
        return tooling_cmdVerifyBackendFfiOutptrTupleFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_selfhost_parallel_perf"):
        return tooling_cmdVerifyBackendSelfhostParallelPerfFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_tooling_cmdline"):
        return tooling_cmdVerifyToolingCmdline(root)
    if tooling_strEq(route, "verify_std_layout_sync"):
        return tooling_cmdVerifyStdLayoutSync(root)
    if tooling_strEq(route, "verify_std_strformat"):
        return tooling_cmdVerifyStdStrformat(root)
    if tooling_strEq(route, "verify_std_foundation"):
        return tooling_cmdVerifyStdFoundation(root)
    if tooling_strEq(route, "verify_std_string_json"):
        return tooling_cmdVerifyStdStringJson(root)
    if tooling_strEq(route, "verify_std_file_io"):
        return tooling_cmdVerifyStdFileIo(root)
    if tooling_strEq(route, "verify_std_net_io"):
        return tooling_cmdVerifyStdNetIo(root)
    if tooling_strEq(route, "verify_std_baseline"):
        return tooling_cmdVerifyStdBaseline(root)
    if tooling_strEq(route, "verify_std_docs_examples"):
        return tooling_cmdVerifyStdDocsExamples(root)
    if tooling_strEq(route, "verify_std_stability"):
        return tooling_cmdVerifyStdStability(root)
    if tooling_strEq(route, "verify_std_perf_baseline"):
        return tooling_cmdVerifyStdPerfBaselineFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_string_literal_regression"):
        return tooling_cmdVerifyBackendStringLiteralRegression(root)
    if tooling_strEq(route, "verify_backend_stage1_fixed0_envs"):
        return tooling_cmdVerifyBackendStage1Fixed0EnvsFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_mir_borrow"):
        return tooling_cmdVerifyBackendMirBorrowFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_loop_runtime"):
        return tooling_cmdVerifyBackendLoopRuntime(root)
    if tooling_strEq(route, "verify_backend_selfhost_bootstrap_self_obj"):
        return tooling_cmdSelfhostBootstrapVerifyFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_selfhost_bootstrap_inmem_witness"):
        return tooling_cmdSelfhostStrictInmemWitnessFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_selfhost_strict_noreuse_probe"):
        return tooling_cmdVerifyBackendSelfhostStrictNoreuseProbeFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_selfhost_inner_loop"):
        return tooling_cmdSelfhostInnerLoopFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_selfhost_100ms_host"):
        return tooling_cmdSelfhost100msHostFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_cdrop_emergency"):
        return tooling_cmdVerifyBackendCdropEmergencyFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_determinism_contract"):
        return tooling_cmdVerifyBackendDeterminismContract(root)
    if tooling_strEq(route, "verify_backend_determinism_strict"):
        return tooling_cmdVerifyBackendDeterminismStrictFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_exe_determinism_strict"):
        return tooling_cmdVerifyBackendExeDeterminismStrictFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_ue_no_growth"):
        return tooling_cmdVerifyBackendUeNoGrowth(root)
    if tooling_strEq(route, "verify_backend_opt2_impl_surface"):
        return tooling_cmdVerifyBackendOpt2ImplSurface(root)
    if tooling_strEq(route, "verify_backend_driver_unified_global"):
        return tooling_cmdVerifyBackendDriverUnifiedGlobal(root)
    if tooling_strEq(route, "verify_backend_compile_name_canonical"):
        return tooling_cmdVerifyBackendCompileNameCanonical(root)
    if tooling_strEq(route, "verify_backend_dev_track_only"):
        return tooling_cmdVerifyBackendDevTrackOnly(root)
    if tooling_strEq(route, "verify_backend_symbol_closure"):
        return tooling_cmdVerifyBackendSymbolClosure(root)
    if tooling_strEq(route, "verify_backend_new_expr_ref_stability"):
        return tooling_cmdVerifyBackendNewExprRefStability(root)
    if tooling_strEq(route, "verify_backend_release_compile_stability"):
        return tooling_cmdVerifyBackendReleaseCompileStability(root)
    if tooling_strEq(route, "verify_backend_zero_script_residual"):
        return tooling_cmdVerifyBackendZeroScriptResidual(root)
    if tooling_strEq(route, "verify_backend_opt2"):
        return tooling_cmdVerifyBackendOpt2(root)
    if tooling_strEq(route, "verify_backend_opt3"):
        return tooling_cmdVerifyBackendOpt3(root)
    if tooling_strEq(route, "verify_backend_opt3_extended"):
        return tooling_cmdVerifyBackendOpt3Extended(root)
    if tooling_strEq(route, "verify_backend_simd"):
        return tooling_cmdVerifyBackendSimd(root)
    if tooling_strEq(route, "verify_backend_spawn_api_gate"):
        return tooling_cmdVerifyBackendSpawnApiGateFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_noalias_opt"):
        return tooling_cmdVerifyBackendNoaliasOpt(root)
    if tooling_strEq(route, "verify_backend_egraph_cost"):
        return tooling_cmdVerifyBackendEgraphCost(root)
    if tooling_strEq(route, "verify_backend_dod_opt_regression"):
        return tooling_cmdVerifyBackendDodOptRegression(root)
    if tooling_strEq(route, "verify_backend_noptr_exemption_scope"):
        return tooling_cmdVerifyBackendNoptrExemptionScopeFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_linker_abi_core"):
        return tooling_cmdVerifyBackendLinkerAbiCore(root)
    if tooling_strEq(route, "verify_backend_linker_abi_core_cross"):
        return tooling_cmdVerifyBackendLinkerAbiCoreCrossFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_zero_script_closure"):
        return tooling_cmdVerifyBackendZeroScriptClosure(root)
    if tooling_strEq(route, "verify_backend_closedloop"):
        return tooling_cmdVerifyBackendClosedloopMinimalFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_rawptr_contract"):
        return tooling_cmdVerifyBackendRawptrContract(root, argStart, count)
    if tooling_strEq(route, "verify_backend_rawptr_surface_forbid"):
        return tooling_cmdVerifyBackendRawptrSurfaceForbid(root)
    if tooling_strEq(route, "verify_backend_pure_cheng_surface"):
        return tooling_cmdVerifyBackendPureChengSurfaceFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_seed_uir_import"):
        return tooling_cmdVerifyBackendSeedUirImport(root)
    if tooling_strEq(route, "verify_backend_sidecar_cheng_seed"):
        return tooling_cmdVerifyBackendSidecarChengSeed(root)
    if tooling_strEq(route, "verify_backend_sidecar_cheng_fresh"):
        return tooling_cmdVerifyBackendSidecarChengFreshFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_stage1_ast_soa_surface"):
        return tooling_cmdVerifyStage1AstSoaSurface(root)
    if tooling_strEq(route, "verify_backend_rawptr_migration"):
        return tooling_cmdVerifyBackendRawptrMigrationFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_uir_soa_surface"):
        return tooling_cmdVerifyBackendUirSoaSurface(root)
    if tooling_strEq(route, "verify_backend_uir_soa_self_probe"):
        return tooling_cmdVerifyBackendUirSoaSelfProbe(root)
    if tooling_strEq(route, "verify_backend_emit_obj_contract"):
        return tooling_cmdVerifyBackendEmitObjContract(root)
    if tooling_strEq(route, "verify_backend_string_abi_contract"):
        return tooling_cmdVerifyBackendStringAbiContractFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_dot_lowering_contract"):
        return tooling_cmdVerifyBackendDotLoweringContractFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_new_expr_surface"):
        return tooling_cmdVerifyNewExprSurfaceFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_backend_selfhost_currentsrc_proof"):
        return tooling_cmdVerifyBackendSelfhostCurrentsrcProofFromArgs(root, argStart, count)
    if tooling_strEq(route, "verify_mobile_crash_free"):
        return tooling_cmdVerifyMobileCrashFreeFromArgs(root, argStart, count)
    return tooling_routeMiss()

fn tooling_dispatchNativeScriptRoute(root: str, scriptIdRaw: str, argStart: int32, count: int32): int32 =
    let scriptId: str = troute.toolingNormalizeRouteAlias(tinv.toolingNormalizeScriptId(scriptIdRaw))
    let verifyRc: int32 = tooling_dispatchVerifyRoute(root, scriptId, argStart, count)
    if verifyRc != tooling_routeMiss():
        return verifyRc
    if tooling_strEq(scriptId, "backend_prod_closure"):
        return tooling_cmdBackendProdClosureFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "backend_prod_publish") || tooling_strEq(scriptId, "backend-prod-publish"):
        return tooling_cmdBackendProdPublishFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_rawptr_contract") || tooling_strEq(scriptId, "build-backend-rawptr-contract"):
        return tooling_cmdBuildBackendRawptrContractFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_mem_contract") || tooling_strEq(scriptId, "build-backend-mem-contract"):
        return tooling_cmdBuildBackendMemContractFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_dod_contract") || tooling_strEq(scriptId, "build-backend-dod-contract"):
        return tooling_cmdBuildBackendDodContractFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_string_abi_contract") || tooling_strEq(scriptId, "build-backend-string-abi-contract"):
        return tooling_cmdBuildBackendStringAbiContractFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_dot_lowering_contract") || tooling_strEq(scriptId, "build-backend-dot-lowering-contract"):
        return tooling_cmdBuildBackendDotLoweringContractFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_determinism_contract") || tooling_strEq(scriptId, "build-backend-determinism-contract"):
        return tooling_cmdBuildBackendDeterminismContractFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_profile_schema") || tooling_strEq(scriptId, "build-backend-profile-schema"):
        return tooling_cmdBuildBackendProfileSchemaFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_profile_baseline") || tooling_strEq(scriptId, "build-backend-profile-baseline"):
        return tooling_cmdBuildBackendProfileBaselineFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_baselines"):
        return tooling_cmdBuildBackendBaselines(root)
    if tooling_strEq(scriptId, "build_std_perf_baseline"):
        return tooling_cmdBuildStdPerfBaselineFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "build_backend_driver"):
        return tooling_cmdBuildBackendDriverFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "backend_resolve_selflink_runtime_obj") || tooling_strEq(scriptId, "backend-resolve-selflink-runtime-obj"):
        return tooling_cmdBackendResolveSelflinkRuntimeObjFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "backend_link_env") || tooling_strEq(scriptId, "backend-link-env"):
        return tooling_cmdBackendLinkEnvFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "cleanup_backend_driver_history"):
        return tooling_cmdCleanupBackendDriverHistoryFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "toolchain_root") || tooling_strEq(scriptId, "toolchain-root"):
        return tooling_cmdToolchainRoot(root)
    if tooling_strEq(scriptId, "backend_driver_path"):
        return tooling_cmdDriverPath(root, true)
    if tooling_strEq(scriptId, "driver_path"):
        return tooling_cmdDriverPathFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "bootstrap_pure") || tooling_strEq(scriptId, "bootstrap"):
        return tooling_cmdBootstrapPureFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "release_compile") || tooling_strEq(scriptId, "release-compile"):
        return tooling_cmdReleaseCompileFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "cheng"):
        return tooling_cmdCompileFromArgsNamed(root, argStart, count, "cheng")
    if tooling_strEq(scriptId, "compile"):
        return tooling_cmdCompileFromArgsNamed(root, argStart, count, "compile")
    if tooling_strEq(scriptId, "chengc"):
        return tooling_cmdCompileFromArgsNamed(root, argStart, count, "chengc")
    return tooling_routeMiss()

fn tooling_cmdRunEmbeddedScriptNoCleanup(root: str, scriptId: str, argStart: int32, count: int32): int32 =
    let cacheDir: str = os.joinPath(root, "chengcache/embedded_scripts")
    if !tooling_mkdirP(root, cacheDir):
        tooling_printErr("cheng_tooling: failed to create embedded script cache: " + cacheDir)
        return 1
    let tempScript: str = os.joinPath(cacheDir, scriptId + "." + tooling_nowNonceText() + ".native.run.sh")
    let scriptText: str = tooling_embeddedTextPatchedScript(root, scriptId)
    if !tooling_strNonEmpty(scriptText):
        tooling_printErr("cheng_tooling: missing embedded script payload: " + scriptId)
        return 1
    let shellBin: str = tooling_scriptShellFromText(scriptText)
    if !tooling_writeTextFileViaShell(root, tempScript, scriptText):
        tooling_printErr("cheng_tooling: failed to write temp embedded script: " + tempScript)
        return 1
    let chmodRes: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(tempScript))
    if os.execCmdResultExitCode(chmodRes) != 0:
        tooling_printErr("cheng_tooling: chmod failed for temp embedded script: " + tempScript)
        tooling_printExecOutput(chmodRes)
        let _cleanupChmodFail: os.ExecCmdResult = tooling_exec(root, "rm -f " + tooling_shellQuote(tempScript))
        return 1
    let selfExe: str = tooling_selfExecPath(root)
    let command: str = tooling_runScriptCommandWithArgs(
        tooling_runEmbeddedBaseCommandNoCleanup(root, selfExe, shellBin, tempScript), argStart, count)
    let result: os.ExecCmdResult = os.execCmdEx(command, uint64(7), root)
    let output: str = os.execCmdResultOutput(result)
    if tooling_strNonEmpty(output):
        os.write(os.get_stdout(), output)
    let _cleanupRes: os.ExecCmdResult = tooling_exec(root, "rm -f " + tooling_shellQuote(tempScript))
    return os.execCmdResultExitCode(result)

fn tooling_runScript(root: str, scriptPath: str, argStart: int32): int32 =
    let scriptId: str = tooling_scriptIdFromResolvedPath(scriptPath)
    let selfExe: str = tooling_selfExecPath(root)
    if tooling_runScriptNeedsUeBlock(scriptId):
        if tooling_stage0BlockOnQuarantineUe(root, "TOOLING_RUN_SCRIPT_BLOCK_ON_UE", "run_script:" + scriptId):
            return 1
    let count: int32 = tooling_paramCount()
    if tooling_strEq(scriptId, "backend_prod_closure") && tooling_onlyHelpArgs(argStart, count):
        tooling_printBackendProdClosureHelpFast()
        return 0
    if tooling_strNonEmpty(scriptId):
        let nativeRc: int32 = tooling_dispatchNativeScriptRoute(root, scriptId, argStart, count)
        if nativeRc != tooling_routeMiss():
            return nativeRc
        if tooling_strEq(scriptId, "backend_resolve_selflink_runtime_obj") ||
           tooling_strEq(scriptId, "backend-resolve-selflink-runtime-obj"):
            tooling_printErr("cheng_tooling: backend_resolve_selflink_runtime_obj requires native route; embedded fallback disabled")
            return 2
        if tooling_strEq(scriptId, tooling_legacyReleaseDriverScriptUnderscore()) ||
           tooling_strEq(scriptId, tooling_legacyReleaseDriverScriptDash()):
            tooling_printErr("cheng_tooling: legacy release-driver command has been removed; single canonical driver only")
            return 2
        return tooling_runScriptEmbeddedExec(root, scriptId, selfExe, argStart, count)
    return tooling_runScriptDirectExec(root, scriptId, scriptPath, selfExe, argStart, count)

fn tooling_routeMiss(): int32 =
    return -2147483000

fn tooling_strEq2(value: str, a: str, b: str): bool =
    if tooling_strEq(value, a):
        return true
    return tooling_strEq(value, b)

fn tooling_strEq3(value: str, a: str, b: str, c: str): bool =
    if tooling_strEq2(value, a, b):
        return true
    return tooling_strEq(value, c)

fn tooling_strEq4(value: str, a: str, b: str, c: str, d: str): bool =
    if tooling_strEq2(value, a, b):
        return true
    if tooling_strEq(value, c):
        return true
    return tooling_strEq(value, d)

fn tooling_cmdBuildGlobalFromArgsSlim(root: str, firstArgIndex: int32, count: int32): int32 =
    let args: str[] = tooling_argsRange(firstArgIndex, count)
    for i in 0..<args.len:
        let arg: str = args[i]
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build-global options:")
            tooling_printOut("  --out:<path>                 output executable path")
            tooling_printOut("  --target:<triple>            backend target triple (default host target)")
            tooling_printOut("  --linker:self                linker mode (fixed self)")
            tooling_printOut("  --driver:<path>              explicit stage0 driver")
            tooling_printOut("  note: default canonical out=artifacts/tooling_cmd/cheng_tooling syncs wrapper/launchers")
            tooling_printOut("        use --out:artifacts/tooling_bundle/core/cheng_tooling_global for core Mach-O rebuild")
            tooling_printOut("  env: TOOLING_BUILD_GLOBAL_BLOCK_ON_UE=1|0 (default 1)")
            tooling_printOut("  env: TOOLING_BUILD_GLOBAL_TIMEOUT=60 (default/cap)")
            tooling_printOut("       TOOLING_BUILD_GLOBAL_CRASH_RETRY_SAFE=1|0 (default 0)")
            tooling_printOut("       TOOLING_BUILD_GLOBAL_EAGER_REBUILD=1|0 (default 0; 0=fast reuse existing healthy tooling)")
            tooling_printOut("       TOOLING_BUILD_GLOBAL_BACKEND_OPT=0|1 (default 0)")
            tooling_printOut("       TOOLING_BUILD_GLOBAL_BACKEND_OPT2=0|1 (default 0)")
            tooling_printOut("       TOOLING_BUILD_GLOBAL_OPT_LEVEL=0..3 (default 0)")
            return 0
        if !strutil.startsWith(arg, "--out:") &&
           !strutil.startsWith(arg, "--target:") &&
           !strutil.startsWith(arg, "--linker:") &&
           !strutil.startsWith(arg, "--driver:"):
            tooling_printErr("cheng_tooling: unknown build-global arg: " + arg)
            return 1
    let linker: str = tooling_argsReadPrefixedValue(args, "--linker:", "self")
    if !tooling_strEq(strutil.toLowerAscii(tooling_trimAsciiSpace(linker)), "self"):
        tooling_printErr("cheng_tooling: build-global only supports --linker:self")
        return 2
    return tooling_buildGlobal(
        root,
        tooling_argsReadPrefixedValue(args, "--out:", os.joinPath(root, "artifacts/tooling_cmd/cheng_tooling")),
        tooling_argsReadPrefixedValue(args, "--target:", ""),
        linker,
        tooling_argsReadPrefixedValue(args, "--driver:", ""))

fn tooling_cmdBundleFromArgsSlim(root: str, firstArgIndex: int32, count: int32): int32 =
    var bundleArgs: str[] = []
    var i: int32 = firstArgIndex
    for _ in firstArgIndex..count:
        if i > count:
            break
        add(bundleArgs, tooling_paramStr(i))
        i = i + 1
    let spec: tbundle.ToolingBundleArgs = tbundle.toolingBundleParseArgs(root, bundleArgs)
    return tooling_bundle(root, spec)

fn tooling_cmdInstallFromArgsSlim(root: str, firstArgIndex: int32, count: int32): int32 =
    let args: str[] = tooling_argsRange(firstArgIndex, count)
    var onlyIds: str[] = []
    var excludeIds: str[] = []
    var force: bool = false
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.startsWith(arg, "--dir:"):
            continue
        if strutil.startsWith(arg, "--bin:"):
            continue
        if strutil.startsWith(arg, "--manifest:"):
            continue
        if strutil.startsWith(arg, "--mode:"):
            continue
        if strutil.startsWith(arg, "--only:"):
            let id: str = tinv.toolingNormalizeScriptId(strings.dropPrefix(arg, "--only:"))
            if !tooling_strNonEmpty(id):
                tooling_printErr("cheng_tooling: invalid --only script id: " + arg)
                return 1
            if !tooling_idsContains(onlyIds, id):
                add(onlyIds, id)
            continue
        if strutil.startsWith(arg, "--exclude:"):
            let id: str = tinv.toolingNormalizeScriptId(strings.dropPrefix(arg, "--exclude:"))
            if !tooling_strNonEmpty(id):
                tooling_printErr("cheng_tooling: invalid --exclude script id: " + arg)
                return 1
            if !tooling_idsContains(excludeIds, id):
                add(excludeIds, id)
            continue
        if tooling_strEq(arg, "--force"):
            force = true
            continue
        if strutil.startsWith(arg, "--force:"):
            force = tooling_isTrue(strings.dropPrefix(arg, "--force:"))
            continue
        tooling_printErr("cheng_tooling: unknown install arg: " + arg)
        return 1
    let installIds: str[] = tinv.toolingCollectScripts(root)
    return tinstall.toolingInstallLinks(
        root,
        installIds,
        tooling_argsReadPrefixedValue(args, "--bin:", tooling_paramStr(0)),
        tooling_argsReadPrefixedValue(args, "--dir:", os.joinPath(root, "artifacts/tooling_cmd/bin")),
        tooling_argsReadPrefixedValue(args, "--manifest:", ""),
        force,
        tooling_installSelectorFromIds(onlyIds),
        tooling_installSelectorFromIds(excludeIds),
        tooling_argsReadPrefixedValue(args, "--mode:", "hardlink"))

fn tooling_dispatchBuiltinFirstSlim(root: str, count: int32, first: str): int32 =
    let routeFirst: str = troute.toolingNormalizeRouteAlias(first)
    if tooling_strEq3(first, "help", "--help", "-h"):
        tooling_printUsage()
        return 0
    if tooling_strEq2(first, "toolchain-root", "toolchain_root"):
        return tooling_cmdToolchainRoot(root)
    if tooling_strEq2(first, "detect_host_target", "detect-host-target"):
        return tooling_cmdDetectHostTarget(root)
    if tooling_strEq(first, "backend_driver_path"):
        return tooling_cmdDriverPath(root, true)
    if tooling_strEq2(first, "backend_link_env", "backend-link-env"):
        return tooling_cmdBackendLinkEnvFromArgs(root, 2, count)
    if tooling_strEq(first, "driver-path"):
        return tooling_cmdDriverPathFromArgs(root, 2, count)
    if tooling_strEq2(first, "build-backend-driver", "build_backend_driver"):
        return tooling_cmdBuildBackendDriverFromArgs(root, 2, count)
    if tooling_strEq2(first, "cleanup-backend-driver-history", "cleanup_backend_driver_history"):
        return tooling_cmdCleanupBackendDriverHistoryFromArgs(root, 2, count)
    if tooling_strEq(routeFirst, "stage0_ue_status"):
        return tooling_cmdStage0UeStatusFromArgs(root, 2, count)
    if tooling_strEq(routeFirst, "stage0_ue_clean"):
        return tooling_cmdStage0UeCleanFromArgs(root, 2, count)
    if tooling_strEq3(first, "bootstrap-pure", "bootstrap_pure", "bootstrap"):
        return tooling_cmdBootstrapPureFromArgs(root, 2, count)
    if tooling_strEq(first, "cheng"):
        return tooling_cmdCompileFromArgsNamed(root, 2, count, "cheng")
    if tooling_strEq(first, "compile"):
        return tooling_cmdCompileFromArgsNamed(root, 2, count, "compile")
    if tooling_strEq(first, "chengc"):
        return tooling_cmdCompileFromArgsNamed(root, 2, count, "chengc")
    if tooling_strEq2(first, "release-compile", "release_compile"):
        return tooling_cmdReleaseCompileFromArgs(root, 2, count)
    if tooling_strEq3(first, "list", "embedded-ids", "embedded_ids"):
        return tooling_list(root)
    let verifyRc: int32 = tooling_dispatchVerifyRoute(root, routeFirst, 2, count)
    if verifyRc != tooling_routeMiss():
        return verifyRc
    if tooling_strEq2(first, "embedded-text", "embedded_text"):
        return tooling_embeddedTextCommand(root, 2, count)
    if tooling_strEq4(first, "embedded-map-rewrite", "embedded_map_rewrite", "rewrite-map", "rewrite_map"):
        return tooling_embeddedMapRewriteCommand(root, 2, count)
    if tooling_strEq(first, "build-global"):
        return tooling_cmdBuildGlobalFromArgsSlim(root, 2, count)
    if tooling_strEq(first, "bundle"):
        return tooling_cmdBundleFromArgsSlim(root, 2, count)
    if tooling_strEq(first, "install"):
        return tooling_cmdInstallFromArgsSlim(root, 2, count)
    if tooling_strEq(first, "backend_prod_closure"):
        return tooling_cmdBackendProdClosureFromArgs(root, 2, count)
    if tooling_strEq(routeFirst, "backend_prod_publish"):
        return tooling_cmdBackendProdPublishFromArgs(root, 2, count)
    return tooling_routeMiss()

fn tooling_dispatchBuiltinSelfSlim(root: str, selfName: str, count: int32): int32 =
    let routeSelf: str = troute.toolingNormalizeRouteAlias(selfName)
    if tooling_strEq(selfName, "cheng"):
        return tooling_cmdCompileFromArgsNamed(root, 1, count, "cheng")
    if tooling_strEq(selfName, "compile"):
        return tooling_cmdCompileFromArgsNamed(root, 1, count, "compile")
    if tooling_strEq(selfName, "chengc"):
        return tooling_cmdCompileFromArgsNamed(root, 1, count, "chengc")
    if tooling_strEq2(selfName, "release_compile", "release-compile"):
        return tooling_cmdReleaseCompileFromArgs(root, 1, count)
    if tooling_strEq3(selfName, "bootstrap", "bootstrap_pure", "bootstrap-pure"):
        return tooling_cmdBootstrapPureFromArgs(root, 1, count)
    if tooling_strEq2(selfName, "toolchain_root", "toolchain-root"):
        return tooling_cmdToolchainRoot(root)
    if tooling_strEq2(selfName, "detect_host_target", "detect-host-target"):
        return tooling_cmdDetectHostTarget(root)
    if tooling_strEq(selfName, "backend_driver_path"):
        return tooling_cmdDriverPath(root, true)
    if tooling_strEq2(selfName, "backend_link_env", "backend-link-env"):
        return tooling_cmdBackendLinkEnvFromArgs(root, 1, count)
    if tooling_strEq(selfName, "driver-path"):
        return tooling_cmdDriverPathFromArgs(root, 1, count)
    if tooling_strEq2(selfName, "build_backend_driver", "build-backend-driver"):
        return tooling_cmdBuildBackendDriverFromArgs(root, 1, count)
    if tooling_strEq2(selfName, "cleanup_backend_driver_history", "cleanup-backend-driver-history"):
        return tooling_cmdCleanupBackendDriverHistoryFromArgs(root, 1, count)
    if tooling_strEq(routeSelf, "stage0_ue_status"):
        return tooling_cmdStage0UeStatusFromArgs(root, 1, count)
    if tooling_strEq(routeSelf, "stage0_ue_clean"):
        return tooling_cmdStage0UeCleanFromArgs(root, 1, count)
    let verifyRc: int32 = tooling_dispatchVerifyRoute(root, routeSelf, 1, count)
    if verifyRc != tooling_routeMiss():
        return verifyRc
    if tooling_strEq(selfName, "backend_prod_closure"):
        return tooling_cmdBackendProdClosureFromArgs(root, 1, count)
    if tooling_strEq(routeSelf, "backend_prod_publish"):
        return tooling_cmdBackendProdPublishFromArgs(root, 1, count)
    return tooling_routeMiss()

fn tooling_dispatchScriptSlim(root: str, count: int32, first: str): int32 =
    if tooling_strEq(first, "run"):
        if count < 2:
            tooling_printErr("cheng_tooling: missing script name for `run`")
            tooling_printUsage()
            return 1
    let scriptArg: str = tooling_dispatchScriptArg(first)
    let argStart: int32 = tooling_dispatchScriptArgStart(first)
    let normalizedScriptArg: str = troute.toolingNormalizeRouteAlias(tinv.toolingNormalizeScriptId(scriptArg))
    tooling_debugDispatchField("first", first)
    tooling_debugDispatchField("script_arg", scriptArg)
    tooling_debugDispatchField("normalized", normalizedScriptArg)
    if tooling_strEq(normalizedScriptArg, "backend_prod_closure"):
        return tooling_cmdBackendProdClosureFromArgs(root, argStart, count)
    if tooling_strEq(normalizedScriptArg, "backend_prod_publish"):
        return tooling_cmdBackendProdPublishFromArgs(root, argStart, count)
    let nativeRc: int32 = tooling_dispatchNativeScriptRoute(root, normalizedScriptArg, argStart, count)
    tooling_debugDispatchField("native_rc", intToStr(nativeRc))
    tooling_debugDispatchField("route_miss", intToStr(tooling_routeMiss()))
    if nativeRc != tooling_routeMiss():
        return nativeRc
    let scriptPath: str = tinv.toolingResolveScriptPath(root, scriptArg)
    tooling_debugDispatchField("script_path", scriptPath)
    if !tooling_strNonEmpty(scriptPath):
        tooling_printErr("cheng_tooling: unknown tooling script: " + scriptArg)
        tooling_printErr("cheng_tooling: run `cheng_tooling list` to inspect available script IDs")
        return 1
    return tooling_runScript(root, scriptPath, argStart)

fn tooling_dispatchFirstAfterBuiltinSlim(root: str, count: int32, first: str, builtinRc: int32): int32 =
    if builtinRc != tooling_routeMiss():
        return builtinRc
    return tooling_dispatchScriptSlim(root, count, first)

fn tooling_dispatchSelfAfterBuiltinSlim(root: str, selfName: str, count: int32, selfRc: int32): int32 =
    if selfRc != tooling_routeMiss():
        return selfRc
    tooling_printUsage()
    return 1

fn tooling_mainDispatchSlim(root: str, selfName: str, count: int32): int32 =
    if count > 0:
        return tooling_dispatchFirstAfterBuiltinSlim(
            root, count, tooling_paramStr(1),
            tooling_dispatchBuiltinFirstSlim(root, count, tooling_paramStr(1)))
    return tooling_dispatchSelfAfterBuiltinSlim(
        root, selfName, count,
        tooling_dispatchBuiltinSelfSlim(root, selfName, count))

fn tooling_mainDispatchLegacy(root: str, selfName: str, count: int32): int32 =
    return tooling_mainDispatchSlim(root, selfName, count)

fn toolingMainWithCount(count: int32): int32 =
    return tooling_mainDispatchSlim(tooling_root(), tooling_programBaseName(), count)

fn tooling_countFromMainArgc(argc: int32): int32 =
    if argc <= 1 || argc > 4096:
        return 0
    return argc - 1

fn main(argc: int32, argv: str*): int32 =
    return toolingMainWithCount(tooling_countFromMainArgc(argc))
