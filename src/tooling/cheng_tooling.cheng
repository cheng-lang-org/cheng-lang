    tooling_printOut("usage: cheng_tooling <command> [args]")
    tooling_printOut("")
    tooling_printOut("commands:")
    tooling_printOut("  toolchain-root")
    tooling_printOut("      print canonical toolchain root resolved from executable path")
    tooling_printOut("  driver-path [--path-only]")
