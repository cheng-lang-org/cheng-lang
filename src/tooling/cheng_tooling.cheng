    return -1

fn tooling_runScript(root: str, scriptPath: str, argStart: int32): int32 =
    var command: str = ""
    var shellBin: str = "sh"
    let scriptId: str = tooling_scriptIdFromResolvedPath(scriptPath)
    if tooling_runScriptNeedsUeBlock(scriptId):
        if tooling_stage0BlockOnQuarantineUe(root, "TOOLING_RUN_SCRIPT_BLOCK_ON_UE", "run_script:" + scriptId):
            return 1
    let count: int32 = tooling_paramCount()
    if tooling_strEq(scriptId, "backend_prod_closure") && tooling_onlyHelpArgs(argStart, count):
        tooling_printBackendProdClosureHelpFast()
        return 0
    if tooling_strNonEmpty(scriptId):
        let nativeRc: int32 = tooling_dispatchNativeScriptRoute(root, scriptId, argStart, count)
        if nativeRc != -1:
            return nativeRc
        if tooling_strEq(scriptId, "backend_resolve_selflink_runtime_obj") ||
           tooling_strEq(scriptId, "backend-resolve-selflink-runtime-obj"):
            tooling_printErr("cheng_tooling: backend_resolve_selflink_runtime_obj requires native route; embedded fallback disabled")
            return 2
        let removedReleaseScriptUnderscore: str = "build_" + "release_driver"
        let removedReleaseScriptDash: str = "build" + "-release-driver"
        if tooling_strEq(scriptId, removedReleaseScriptUnderscore) || tooling_strEq(scriptId, removedReleaseScriptDash):
            tooling_printErr("cheng_tooling: legacy release-driver command has been removed; single canonical driver only")
            return 2
        let cacheDir: str = os.joinPath(root, "chengcache/embedded_scripts")
        if !tooling_mkdirP(root, cacheDir):
            tooling_printErr("cheng_tooling: failed to create embedded script cache: " + cacheDir)
            return 1
        let tempScript: str = os.joinPath(cacheDir, scriptId + "." + tooling_nowNonceText() + ".run.sh")
        var scriptText: str = tooling_embeddedScriptText(root, scriptId)
        scriptText = tooling_patchEmbeddedRuntimeDefaults(scriptId, scriptText)
        if !tooling_strNonEmpty(scriptText):
            tooling_printErr("cheng_tooling: missing embedded script payload: " + scriptId)
            return 1
        shellBin = tooling_scriptShellFromText(scriptText)
        if !tooling_writeTextFileViaShell(root, tempScript, scriptText):
            tooling_printErr("cheng_tooling: failed to write temp embedded script: " + tempScript)
            return 1
        let chmodRes: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(tempScript))
        if os.execCmdResultExitCode(chmodRes) != 0:
            tooling_printErr("cheng_tooling: chmod failed for temp embedded script: " + tempScript)
            tooling_printExecOutput(chmodRes)
            let _cleanupChmodFail: os.ExecCmdResult = tooling_exec(root, "rm -f " + tooling_shellQuote(tempScript))
            return 1
        command = tooling_shellQuote(shellBin) + " " + tooling_shellQuote(tempScript)
        if argStart <= count:
            for i in argStart..count:
                command = command + " " + tooling_shellQuote(tooling_paramStr(i))
        let opts0: uint64 = uint64(7)
        let crashRetryMax: int32 = 0
        var runAttempt: int32 = 0
        var rc0: int32 = 1
        while true:
            let result0: os.ExecCmdResult = os.execCmdEx(command, opts0, root)
            let output0: str = os.execCmdResultOutput(result0)
            if tooling_strNonEmpty(output0):
                os.write(os.get_stdout(), output0)
            rc0 = os.execCmdResultExitCode(result0)
            if tooling_strEq(scriptId, "build_mobile_export") && tooling_isCompileCrashExitCode(rc0):
                let reportPath: str = tooling_writeCompileCrashReport(
                    root,
                    "run_script_" + scriptId,
                    rc0,
                    runAttempt + 1,
                    crashRetryMax + 1,
                    command,
                    output0
                )
                if tooling_strNonEmpty(reportPath):
                    tooling_printErr("cheng_tooling: embedded script crash report: " + reportPath)
                if runAttempt < crashRetryMax:
                    tooling_printErr("cheng_tooling: embedded script `" + scriptId + "` crashed rc=" + intToStr(rc0) +
                                     "; retrying attempt " + intToStr(runAttempt + 1) + "/" + intToStr(crashRetryMax))
                    runAttempt = runAttempt + 1
                    continue
            break
        let _cleanupRes: os.ExecCmdResult = tooling_exec(root, "rm -f " + tooling_shellQuote(tempScript))
        return rc0
    else:
        if !os.fileExists(scriptPath):
            tooling_printErr("cheng_tooling: script not found: " + scriptPath)
            return 1
        shellBin = tooling_scriptShell(root, scriptPath)
        command = tooling_shellQuote(shellBin) + " " + tooling_shellQuote(scriptPath)
    if argStart <= count:
        for i in argStart..count:
            command = command + " " + tooling_shellQuote(tooling_paramStr(i))
    let opts: uint64 = uint64(7)
    let result: os.ExecCmdResult = os.execCmdEx(command, opts, root)
    let output: str = os.execCmdResultOutput(result)
    if tooling_strNonEmpty(output):
        os.write(os.get_stdout(), output)
    return os.execCmdResultExitCode(result)

fn main(argc: int32, argv: str*): int32 =
    tooling_setCmdLine(argc, argv)
    let root: str = tooling_root()
    if tooling_rejectRemovedRiskyEnvs():
        return 2
    let selfName: str = tooling_programBaseName()
    let count: int32 = tooling_paramCount()
    if tooling_strEq(selfName, "cheng"):
        return tooling_cmdCompileFromArgsNamed(root, 1, count, "cheng")
    if tooling_strEq(selfName, "compile"):
        return tooling_cmdCompileFromArgsNamed(root, 1, count, "compile")
    if tooling_strEq(selfName, "chengc"):
        return tooling_cmdCompileFromArgsNamed(root, 1, count, "chengc")
    if tooling_strEq(selfName, "release_compile") || tooling_strEq(selfName, "release-compile"):
        return tooling_cmdReleaseCompileFromArgs(root, 1, count)
    if tooling_strEq(selfName, "chengb"):
        tooling_printErr("cheng_tooling: chengb has been removed; use `cheng`")
        return 2
    if tooling_strEq(selfName, "bootstrap") || tooling_strEq(selfName, "bootstrap_pure") || tooling_strEq(selfName, "bootstrap-pure"):
        return tooling_cmdBootstrapPureFromArgs(root, 1, count)
    if tooling_strEq(selfName, "toolchain_root") || tooling_strEq(selfName, "toolchain-root"):
        return tooling_cmdToolchainRoot(root)
    if tooling_strEq(selfName, "backend_driver_path"):
        return tooling_cmdDriverPath(root, true)
    if tooling_strEq(selfName, "driver-path"):
        return tooling_cmdDriverPathFromArgs(root, 1, count)
    if tooling_strEq(selfName, "build_backend_driver") || tooling_strEq(selfName, "build-backend-driver"):
        return tooling_cmdBuildBackendDriverFromArgs(root, 1, count)
    if tooling_strEq(selfName, "cleanup_backend_driver_history") || tooling_strEq(selfName, "cleanup-backend-driver-history"):
        return tooling_cmdCleanupBackendDriverHistoryFromArgs(root, 1, count)
    if tooling_strEq(selfName, "build_backend_baselines") || tooling_strEq(selfName, "build-backend-baselines"):
        return tooling_cmdBuildBackendBaselines(root)
    if tooling_strEq(selfName, "build_backend_rawptr_contract") || tooling_strEq(selfName, "build-backend-rawptr-contract"):
        return tooling_cmdBuildBackendRawptrContractFromArgs(root, 1, count)
    if tooling_strEq(selfName, "build_backend_mem_contract") || tooling_strEq(selfName, "build-backend-mem-contract"):
        return tooling_cmdBuildBackendMemContractFromArgs(root, 1, count)
    if tooling_strEq(selfName, "build_backend_dod_contract") || tooling_strEq(selfName, "build-backend-dod-contract"):
        return tooling_cmdBuildBackendDodContractFromArgs(root, 1, count)
    if tooling_strEq(selfName, "build_backend_native_contract") || tooling_strEq(selfName, "build-backend-native-contract"):
        return tooling_cmdBuildBackendNativeContractFromArgs(root, 1, count)
    if tooling_strEq(selfName, "build_backend_profile_schema") || tooling_strEq(selfName, "build-backend-profile-schema"):
        return tooling_cmdBuildBackendProfileSchemaFromArgs(root, 1, count)
    if tooling_strEq(selfName, "build_backend_profile_baseline") || tooling_strEq(selfName, "build-backend-profile-baseline"):
        return tooling_cmdBuildBackendProfileBaselineFromArgs(root, 1, count)
    if tooling_strEq(selfName, "sync_global") || tooling_strEq(selfName, "sync-global"):
        return tooling_cmdSyncGlobalDeprecated()
    if tooling_strEq(selfName, "verify_backend_selfhost_bootstrap_self_obj"):
        return tooling_cmdSelfhostBootstrapVerifyFromArgs(root, 1, count)
    if tooling_strEq(selfName, "verify_backend_selfhost_100ms_host"):
        return tooling_cmdSelfhost100msHostFromArgs(root, 1, count)
    if tooling_strEq(selfName, "verify_backend_cdrop_emergency"):
        return tooling_cmdVerifyBackendCdropEmergencyFromArgs(root, 1, count)
    if tooling_strEq(selfName, "verify_backend_native_contract"):
        return tooling_cmdVerifyBackendNativeContract(root)
    if tooling_strEq(selfName, "verify_backend_native_contract_autosystem"):
        return tooling_cmdVerifyBackendNativeContractAutosystem(root)
    if tooling_strEq(selfName, "verify_backend_opt2_impl_surface"):
