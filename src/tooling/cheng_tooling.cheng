fn tooling_stage0CapabilityDetectedUirBuilderSources(): str[] =
    let scanRes: os.ExecCmdResult = tooling_exec(
        os.getCurrentDir(),
        "if ! command -v rg >/dev/null 2>&1; then exit 0; fi; " +
        "rg --files src/backend/uir/uir_internal 2>/dev/null | " +
        "rg '(^|/)uir_core_builder[^/]*\\.cheng$' | sort || true")
    if os.execCmdResultExitCode(scanRes) != 0:
        return []
    return tooling_splitLines(os.execCmdResultOutput(scanRes))

fn tooling_stage0CapabilitySourceList(): str[] =
    var out: str[] = []
    add(out, "src/std/cmdline.cheng")
    add(out, "src/std/rawmem_support.cheng")
    add(out, "src/stage1/ast.cheng")
    add(out, "src/stage1/token.cheng")
    add(out, "src/stage1/lexer.cheng")
    add(out, "src/stage1/parser.cheng")
    add(out, "src/stage1/frontend_lib.cheng")
    add(out, "src/stage1/diagnostics.cheng")
    add(out, "src/stage1/semantics.cheng")
    add(out, "src/stage1/ownership.cheng")
    add(out, "src/stage1/monomorphize.cheng")
    add(out, "src/stage1/type_syntax_lowering.cheng")
    add(out, "src/stage1/c_profile_lowering.cheng")
    add(out, "src/backend/uir/uir_internal/uir_core_types.cheng")
    let detectedBuilderSources: str[] = tooling_stage0CapabilityDetectedUirBuilderSources()
    if detectedBuilderSources.len > 0:
        for i in 0..<detectedBuilderSources.len:
            tooling_stage0CapabilityAdd(&out, detectedBuilderSources[i])
    else:
        tooling_stage0CapabilityAppendUirBuilderSources(&out)
    add(out, "src/backend/uir/uir_codegen.cheng")
    add(out, "src/backend/machine/machine_internal/machine_core_types.cheng")
    add(out, "src/backend/obj/macho_writer.cheng")
    add(out, "src/backend/machine/select_internal/aarch64_select.cheng")
    add(out, "src/backend/machine/select_internal/x86_64_select.cheng")
    add(out, "src/backend/tooling/backend_driver.cheng")
    add(out, "src/backend/obj/linker_shared_core.cheng")
    add(out, "src/backend/obj/macho_linker.cheng")
    add(out, "src/backend/obj/macho_linker_x86_64.cheng")
    add(out, "src/backend/obj/elf_linker.cheng")
    add(out, "src/backend/obj/elf_linker_riscv64.cheng")
    add(out, "src/backend/obj/coff_linker.cheng")
    return out

