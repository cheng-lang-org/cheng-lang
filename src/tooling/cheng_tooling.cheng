    if tooling_strEq(selfName, "verify_backend_driver_unified_global"):
        return tooling_cmdVerifyBackendDriverUnifiedGlobal(root)
    if tooling_strEq(selfName, "verify_backend_compile_name_canonical"):
        return tooling_cmdVerifyBackendCompileNameCanonical(root)
    if tooling_strEq(selfName, "verify_backend_dev_track_only"):
        return tooling_cmdVerifyBackendDevTrackOnly(root)
    if tooling_strEq(selfName, "verify_backend_symbol_closure"):
