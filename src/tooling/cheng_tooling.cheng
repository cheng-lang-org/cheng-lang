        return ""
    let envOverrides: str[] = tooling_backendDriverUirSidecarCompileEnv(root, compilerPath, sourcePath, outPath, target)
    var compilerArgs: str[] = []
    let res: os.ExecCmdResult = tooling_execFileDirect(compilerPath, compilerArgs, envOverrides, root, 60, true)
    tooling_printExecOutput(res)
