        tcontracts.toolingVerifyBackendDotLoweringContractScript(toolBin, baselineFile, doc, uirDoc, toolingDoc, matrixDoc)
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

