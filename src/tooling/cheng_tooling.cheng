    tooling_printOut("      artifacts/tooling_cmd/cheng_tooling install --dir:artifacts/tooling_cmd/bin --bin:artifacts/tooling_cmd/cheng_tooling --force")
    tooling_printOut("  - bundle profiles:")
    tooling_printOut("      full: all embedded tooling command IDs")

fn tooling_onlyHelpArgs(argStart: int32, count: int32): bool =
    if argStart > count:
        return false
    for i in argStart..count:
        let arg: str = tooling_paramStr(i)
        if !tooling_strEq(arg, "--help") && !tooling_strEq(arg, "-h") && !tooling_strEq(arg, "help"):
            return false
    return true

fn tooling_printBackendProdClosureHelpFast() =
    tooling_printOut("Usage:")
    tooling_printOut("  cheng_tooling backend_prod_closure [--no-validate] [--debug] [--no-debug]")
    tooling_printOut("                                    [--selfhost|--no-selfhost]")
    tooling_printOut("                                    [--selfhost-fast|--selfhost-strict]")
    tooling_printOut("                                    [--self-linker-gates|--no-self-linker-gates]")
    tooling_printOut("                                    [--opt3-stable|--no-opt3-stable]")
    tooling_printOut("                                    [--opt3-extended|--no-opt3-extended]")
    tooling_printOut("                                    [--opt3-extended-enforce:0|1]")
    tooling_printOut("                                    [--linker-abi-core-cross|--no-linker-abi-core-cross]")
    tooling_printOut("                                    [--linker-abi-core-cross-report-only]")
    tooling_printOut("                                    [--linker-abi-core-cross-enforce:0|1]")
    tooling_printOut("                                    [--linker-abi-core-cross-targets:<csv|@file>]")
    tooling_printOut("                                    [--fullchain|--no-fullchain]")
    tooling_printOut("                                    [--no-publish] [--strict]")
    tooling_printOut("")
    tooling_printOut("Notes:")
    tooling_printOut("  - Runs self-hosted backend production closure required gates.")
    tooling_printOut("  - Uses native gate runner by default (no giant embedded payload load).")
    tooling_printOut("  - Default BACKEND_PROD_INMEM_ONLY=1; set BACKEND_PROD_INMEM_ONLY=0 only when running obj/fullchain gates.")
    tooling_printOut("  - This command is dev-only closure; use `backend-prod-publish` for release/publish.")

fn tooling_cmdBackendProdToolBin(root: str): str =
    let canonicalTool: str = tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling")
    if tooling_isExecutable(root, canonicalTool):
        return canonicalTool
    let allowNonCanonical: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_PROD_ALLOW_NONCANONICAL_TOOL_BIN", "0"))
    if allowNonCanonical:
        var binDir: str = strutil.strip(os.getEnvDefault("TOOLING_EXEC_BUNDLE_BIN_DIR", ""))
        if !tooling_strNonEmpty(binDir):
            binDir = strutil.strip(os.getEnvDefault("BACKEND_TOOLING_BUNDLE_BIN_DIR", ""))
        if !tooling_strNonEmpty(binDir):
            binDir = "artifacts/tooling_bundle/full/bin"
        let absBinDir: str = tooling_pathAbsolute(root, binDir)
        let bundledTool: str = os.joinPath(absBinDir, "cheng_tooling")
        if tooling_isExecutable(root, bundledTool):
            tooling_printErr("cheng_tooling: warn: using non-canonical tooling binary: " + bundledTool)
            return bundledTool
    return ""

fn tooling_cmdBackendProdRunGate(root: str, toolBin: str, label: str, subcmd: str,
                                 argsRaw: str, envPrefixRaw: str, timeoutSecRaw: int32): int32 =
    var cmd: str = ""
    let envPrefix: str = strutil.strip(envPrefixRaw)
    if tooling_strNonEmpty(envPrefix):
        cmd = envPrefix + " "
    cmd = cmd + tooling_shellQuote(toolBin) + " " + tooling_shellQuote(subcmd)
    let argsText: str = strutil.strip(argsRaw)
    if tooling_strNonEmpty(argsText):
        cmd = cmd + " " + argsText
    var timeoutSec: int32 = timeoutSecRaw
    if timeoutSec < 0:
        timeoutSec = 0
    if timeoutSec > 0:
        cmd = tooling_wrapCommandWithTimeout(root, timeoutSec, cmd)
    tooling_printOut("== " + label + " ==")
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    let rc: int32 = os.execCmdResultExitCode(res)
    if rc != 0:
        tooling_printErr("cheng_tooling: backend_prod_closure gate failed label=" + label +
                         " rc=" + intToStr(rc) + " kind=" + tooling_exitKind(rc))
    return rc

fn tooling_cmdBackendProdClosureFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var validate: bool = true
    var runSelfhost: bool = tooling_isTrue(os.getEnvDefault("BACKEND_RUN_SELFHOST", "0"))
    var runSelfhost100ms: bool = tooling_isTrue(os.getEnvDefault("BACKEND_RUN_SELFHOST_100MS", "0"))
    var runFullchain: bool = tooling_isTrue(os.getEnvDefault("BACKEND_RUN_FULLCHAIN", "0"))
    var runSelfLinkerGates: bool = true
    var runOpt3Stable: bool = tooling_isTrue(os.getEnvDefault("BACKEND_RUN_OPT3_STABLE", "1"))
    var runOpt3Extended: bool = tooling_isTrue(os.getEnvDefault("BACKEND_RUN_OPT3_EXTENDED", "1"))
    var opt3ExtendedEnforceRaw: str = os.getEnvDefault("BACKEND_OPT3_EXTENDED_ENFORCE", "1")
    var runLinkerAbiCoreCross: bool = tooling_isTrue(os.getEnvDefault("BACKEND_RUN_LINKER_ABI_CORE_CROSS", "0"))
    var linkerAbiCoreCrossEnforceRaw: str = os.getEnvDefault("BACKEND_LINKER_ABI_CORE_CROSS_ENFORCE", "1")
    var linkerAbiCoreCrossTargetsRaw: str = os.getEnvDefault("BACKEND_LINKER_ABI_CORE_CROSS_TARGETS", "")
    var selfhostMode: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("BACKEND_PROD_SELFHOST_MODE", "fast")))
    if !tooling_strEq(selfhostMode, "strict"):
        selfhostMode = "fast"
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h") || tooling_strEq(arg, "help"):
            tooling_printBackendProdClosureHelpFast()
            return 0
        if tooling_strEq(arg, "--no-validate"):
            validate = false
            i = i + 1
            continue
        if tooling_strEq(arg, "--debug") || tooling_strEq(arg, "--no-debug"):
            i = i + 1
            continue
        if tooling_strEq(arg, "--selfhost"):
            runSelfhost = true
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-selfhost"):
            runSelfhost = false
            i = i + 1
            continue
        if tooling_strEq(arg, "--selfhost-fast"):
            runSelfhost = true
            selfhostMode = "fast"
            i = i + 1
            continue
        if tooling_strEq(arg, "--selfhost-strict"):
            runSelfhost = true
            selfhostMode = "strict"
            i = i + 1
            continue
        if tooling_strEq(arg, "--self-linker-gates"):
            runSelfLinkerGates = true
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-self-linker-gates"):
            runSelfLinkerGates = false
            i = i + 1
            continue
        if tooling_strEq(arg, "--opt3-stable"):
            runOpt3Stable = true
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-opt3-stable"):
            runOpt3Stable = false
            i = i + 1
            continue
        if tooling_strEq(arg, "--opt3-extended"):
            runOpt3Extended = true
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-opt3-extended"):
            runOpt3Extended = false
            i = i + 1
            continue
        if tooling_strEq(arg, "--opt3-extended-enforce"):
            opt3ExtendedEnforceRaw = "1"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--opt3-extended-enforce:"):
            opt3ExtendedEnforceRaw = strings.dropPrefix(arg, "--opt3-extended-enforce:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--linker-abi-core-cross"):
            runLinkerAbiCoreCross = true
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-linker-abi-core-cross"):
            runLinkerAbiCoreCross = false
            i = i + 1
            continue
        if tooling_strEq(arg, "--linker-abi-core-cross-report-only"):
            runLinkerAbiCoreCross = true
            linkerAbiCoreCrossEnforceRaw = "0"
            i = i + 1
            continue
        if tooling_strEq(arg, "--linker-abi-core-cross-enforce"):
            linkerAbiCoreCrossEnforceRaw = "1"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--linker-abi-core-cross-enforce:"):
            linkerAbiCoreCrossEnforceRaw = strings.dropPrefix(arg, "--linker-abi-core-cross-enforce:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--linker-abi-core-cross-targets:"):
            linkerAbiCoreCrossTargetsRaw = strings.dropPrefix(arg, "--linker-abi-core-cross-targets:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--fullchain"):
            runFullchain = true
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-fullchain"):
            runFullchain = false
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-publish"):
            # Compatibility no-op: native closure is dev-only and never runs publish tail.
            i = i + 1
            continue
        if tooling_strEq(arg, "--publish"):
            tooling_printErr("cheng_tooling: backend_prod_closure is dev-only; use `backend-prod-publish`")
            return 2
        if tooling_strEq(arg, "--strict"):
            i = i + 1
            continue
        if tooling_strEq(arg, "--require-seed") || strutil.startsWith(arg, "--seed:") ||
           strutil.startsWith(arg, "--seed-id:") || strutil.startsWith(arg, "--seed-tar:"):
            tooling_printErr("cheng_tooling: backend_prod_closure seed/stage0 overrides have been removed; canonical driver is mandatory")
            return 2
        if strutil.startsWith(arg, "--manifest:") || strutil.startsWith(arg, "--bundle:"):
            tooling_printErr("cheng_tooling: backend_prod_closure does not accept release artifact args; use `backend-prod-publish`")
            return 2
        tooling_printErr("cheng_tooling: unknown backend_prod_closure arg: " + arg)
        return 1
    let toolBin: str = tooling_cmdBackendProdToolBin(root)
    if !tooling_isExecutable(root, toolBin):
        tooling_printErr("cheng_tooling: backend_prod_closure requires canonical tooling binary: " +
                         tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling"))
        tooling_printErr("  hint: cheng_tooling build-global --out:artifacts/tooling_cmd/cheng_tooling --linker:self")
        tooling_printErr("  hint: set BACKEND_PROD_ALLOW_NONCANONICAL_TOOL_BIN=1 only for emergency fallback")
        return 1
    let bundleBinDir: str = os.parentDir(toolBin)
    var inmemOnly: bool = tooling_isTrue(os.getEnvDefault("BACKEND_PROD_INMEM_ONLY", "1"))
    let gateTimeout: int32 = tooling_parseInt32Default(os.getEnvDefault("BACKEND_PROD_GATE_TIMEOUT", ""), 60)
    let selfhostTimeout: int32 = tooling_parseInt32Default(os.getEnvDefault("BACKEND_PROD_SELFHOST_TIMEOUT", ""), 60)
    var envPrefix: str = ""
    envPrefix = envPrefix + tooling_envAssignCompat("TOOLING_SELF_BIN", toolBin)
    envPrefix = envPrefix + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
    envPrefix = envPrefix + tooling_envAssignCompat("TOOLING_EXEC_BUNDLE_BIN_DIR", bundleBinDir)
    envPrefix = envPrefix + tooling_envAssignCompat("TOOLING_EXEC_GLOBAL_BIN",
                                                    tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling"))
    envPrefix = envPrefix + tooling_envAssignCompat("BACKEND_TOOLING_BUNDLE_GLOBAL_BIN",
                                                    tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling"))
    if inmemOnly:
        envPrefix = envPrefix + tooling_envAssignCompat("BACKEND_PROD_STAGE0_PROBE_MODE", "path")
        envPrefix = envPrefix + tooling_envAssignCompat("BACKEND_MM_LINKER", "self")
    if runFullchain && inmemOnly:
        tooling_printErr("cheng_tooling: backend.fullchain_bootstrap requires BACKEND_PROD_INMEM_ONLY=0 (obj-only gate)")
        return 2
    tooling_printOut("backend_prod_closure_native=1")
    tooling_printOut("backend_prod_closure_tool=" + toolBin)
    tooling_printOut("backend_prod_closure_inmem_only=" + tooling_boolText(inmemOnly))

    var rc: int32 = 0
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "tooling.cmdline_runner",
                                       "verify_tooling_cmdline", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.rawptr_contract",
                                       "verify_backend_rawptr_contract", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.rawptr_surface_forbid",
                                       "verify_backend_rawptr_surface_forbid", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    let stage1AstSoaEnforceRaw: str = os.getEnvDefault("BACKEND_PROD_STAGE1_AST_SOA_ENFORCE", "1")
    var stage1AstSoaEnv: str = envPrefix
    stage1AstSoaEnv = stage1AstSoaEnv + tooling_envAssignCompat(
        "BACKEND_STAGE1_AST_SOA_ENFORCE", strutil.strip(stage1AstSoaEnforceRaw))
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.stage1_ast_soa_surface",
                                       "verify_stage1_ast_soa_surface", "", stage1AstSoaEnv, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.native_contract",
                                       "verify_backend_native_contract", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.native_contract_autosystem",
                                       "verify_backend_native_contract_autosystem", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.driver_unified_global",
                                       "verify_backend_driver_unified_global", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.compile_name_canonical",
                                       "verify_backend_compile_name_canonical", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.dev_track_only",
                                       "verify_backend_dev_track_only", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.loop_runtime",
                                       "verify_backend_loop_runtime", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.symbol_closure",
                                       "verify_backend_symbol_closure", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.new_expr_ref_stability",
                                       "verify_backend_new_expr_ref_stability", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    var releaseCompileStabilityItersRaw: str = strutil.strip(
        os.getEnvDefault("BACKEND_PROD_RELEASE_COMPILE_STABILITY_ITERS", "3"))
    if !tooling_strNonEmpty(releaseCompileStabilityItersRaw):
        releaseCompileStabilityItersRaw = "3"
    tooling_printOut("backend_prod_release_compile_stability_iters=" + releaseCompileStabilityItersRaw)
    var releaseCompileStabilityEnv: str = envPrefix
    releaseCompileStabilityEnv = releaseCompileStabilityEnv + tooling_envAssignCompat(
        "BACKEND_RELEASE_COMPILE_STABILITY_ITERS", releaseCompileStabilityItersRaw)
    let releaseCompileStabilityTimeout: int32 = tooling_parseInt32Default(
        os.getEnvDefault("BACKEND_PROD_RELEASE_COMPILE_STABILITY_TIMEOUT", ""), 240)
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.release_compile_stability",
                                       "verify_backend_release_compile_stability", "", releaseCompileStabilityEnv,
                                       releaseCompileStabilityTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.zero_script_residual",
                                       "verify_backend_zero_script_residual", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.emit_c_surface",
                                       "verify_backend_emit_c_surface", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.emit_c_ffi_shadow",
                                       "verify_backend_emit_c_ffi_shadow", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.emit_c_hard_fail",
                                       "verify_backend_emit_c_hard_fail", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.opt2_impl_surface",
                                       "verify_backend_opt2_impl_surface", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    if runOpt3Stable:
        rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.opt3_stable",
                                           "verify_backend_opt3", "", envPrefix, gateTimeout)
        if rc != 0:
            return rc
        var simdEnv: str = envPrefix
        var simdOptLevelRaw: str = strutil.strip(os.getEnvDefault("BACKEND_PROD_SIMD_OPT_LEVEL", "2"))
        if !tooling_strNonEmpty(simdOptLevelRaw):
            simdOptLevelRaw = "2"
        simdEnv = simdEnv + tooling_envAssignCompat("UIR_SIMD", "1")
        simdEnv = simdEnv + tooling_envAssignCompat("UIR_SIMD_REPORT", "1")
        simdEnv = simdEnv + tooling_envAssignCompat("UIR_SIMD_GATE_OPT_LEVEL", simdOptLevelRaw)
        rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.simd",
                                           "verify_backend_simd", "", simdEnv, gateTimeout)
        if rc != 0:
            return rc
    if runOpt3Extended:
        let opt3ExtendedTimeout: int32 = tooling_parseInt32Default(
            os.getEnvDefault("BACKEND_PROD_OPT3_EXTENDED_TIMEOUT", ""), 240)
        var opt3ExtendedEnv: str = envPrefix
        opt3ExtendedEnv = opt3ExtendedEnv + tooling_envAssignCompat(
            "UIR_OPT3_EXTENDED_ENFORCE", strutil.strip(opt3ExtendedEnforceRaw))
        rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.opt3_extended",
                                           "verify_backend_opt3_extended", "",
                                           opt3ExtendedEnv, opt3ExtendedTimeout)
        if rc != 0:
            return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.uir_soa_surface",
                                       "verify_backend_uir_soa_surface", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.uir_soa_self_probe",
                                       "verify_backend_uir_soa_self_probe", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.rawptr_migration",
                                       "verify_backend_rawptr_migration", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.noalias_opt",
                                       "verify_backend_noalias_opt", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.egraph_cost",
                                       "verify_backend_egraph_cost", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.dod_opt_regression",
                                       "verify_backend_dod_opt_regression", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.noptr_exemption_scope",
                                       "verify_backend_noptr_exemption_scope", "", envPrefix, gateTimeout)
    if rc != 0:
        return rc
    if runSelfLinkerGates:
        rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.linker_abi_core",
                                           "verify_backend_linker_abi_core", "", envPrefix, gateTimeout)
        if rc != 0:
            return rc
    if runLinkerAbiCoreCross:
        if tooling_isTrue(linkerAbiCoreCrossEnforceRaw) &&
           !tooling_strNonEmpty(strutil.strip(linkerAbiCoreCrossTargetsRaw)):
            let hostRequiredTargets: str = tooling_pathAbsolute(
                root, "src/tooling/linker_abi_core_cross.targets.host_required")
            if tooling_pathExists(hostRequiredTargets):
                linkerAbiCoreCrossTargetsRaw = "@" + hostRequiredTargets
        var linkerAbiCoreCrossEnv: str = envPrefix
        linkerAbiCoreCrossEnv = linkerAbiCoreCrossEnv + tooling_envAssignCompat(
            "BACKEND_LINKER_ABI_CORE_CROSS_ENFORCE", strutil.strip(linkerAbiCoreCrossEnforceRaw))
        if tooling_strNonEmpty(strutil.strip(linkerAbiCoreCrossTargetsRaw)):
            linkerAbiCoreCrossEnv = linkerAbiCoreCrossEnv + tooling_envAssignCompat(
                "BACKEND_LINKER_ABI_CORE_CROSS_TARGETS", strutil.strip(linkerAbiCoreCrossTargetsRaw))
        rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.linker_abi_core_cross",
                                           "verify_backend_linker_abi_core_cross", "",
                                           linkerAbiCoreCrossEnv, gateTimeout)
        if rc != 0:
            return rc
    let closedloopMinimal: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_PROD_CLOSEDLOOP_MINIMAL", "1"))
    let closedloopTimeout: int32 = tooling_parseInt32Default(
        os.getEnvDefault("BACKEND_PROD_CLOSEDLOOP_TIMEOUT", ""), gateTimeout)
    var closedloopEnv: str = envPrefix
    closedloopEnv = closedloopEnv + tooling_envAssignCompat("ABI", "v2_noptr")
    closedloopEnv = closedloopEnv + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS", "1")
    closedloopEnv = closedloopEnv + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS_STRICT", "0")
    closedloopEnv = closedloopEnv + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "1")
    closedloopEnv = closedloopEnv + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "1")
    closedloopEnv = closedloopEnv + tooling_envAssignCompat("BACKEND_LINKER", "self")
    closedloopEnv = closedloopEnv + tooling_envAssignCompat("BACKEND_IMPORT_CYCLE_LINKER", "system")
    closedloopEnv = closedloopEnv + tooling_envAssignCompat("BACKEND_RUN_FULLSPEC", "1")
    closedloopEnv = closedloopEnv + tooling_envAssignCompat(
        "BACKEND_CLOSEDLOOP_MINIMAL", (inmemOnly || closedloopMinimal) ? "1" : "0")
    if validate:
        closedloopEnv = closedloopEnv + tooling_envAssignCompat("BACKEND_VALIDATE", "1")
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.closedloop",
                                       "verify_backend_closedloop", "", closedloopEnv, closedloopTimeout)
    if rc != 0:
        return rc

    if runSelfhost:
        var selfhostArgs: str = "--mode:" + selfhostMode + " --compile-stage1"
        rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.selfhost_bootstrap",
                                           "verify_backend_selfhost_bootstrap_self_obj",
                                           selfhostArgs, envPrefix, selfhostTimeout)
        if rc != 0:
            return rc
        if runSelfhost100ms:
            rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.selfhost_100ms_host",
                                               "verify_backend_selfhost_100ms_host",
                                               "--compile-stage1 --enforce:1", envPrefix, selfhostTimeout)
            if rc != 0:
                return rc
    if runFullchain:
        let fullchainEnv: str = envPrefix + tooling_envAssignCompat("FULLCHAIN_OBJ_ONLY", "1")
        rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.fullchain_bootstrap",
                                           "verify_fullchain_bootstrap", "", fullchainEnv, gateTimeout)
        if rc != 0:
            return rc
    tooling_printOut("backend_prod_closure ok")
    return 0

fn tooling_cmdBackendProdPublishFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let trackPolicyRc: int32 = tooling_enforceBuildTrackPolicy(
        "backend-prod-publish", os.getEnvDefault("BACKEND_BUILD_TRACK", "dev"))
    if trackPolicyRc != 0:
        return trackPolicyRc
    var dstRaw: str = strutil.strip(os.getEnvDefault("BACKEND_RELEASE_DST", "dist/releases"))
    var manifestRaw: str = strutil.strip(os.getEnvDefault(
        "BACKEND_RELEASE_MANIFEST", "artifacts/backend_prod/release_manifest.json"))
    var bundleRaw: str = strutil.strip(os.getEnvDefault(
        "BACKEND_RELEASE_BUNDLE", "artifacts/backend_prod/backend_release.tar.gz"))
    var nameRaw: str = strutil.strip(os.getEnvDefault("BACKEND_RELEASE_NAME", "cheng"))
    var driverRaw: str = strutil.strip(os.getEnvDefault("BACKEND_RELEASE_DRIVER_PATH", ""))
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h") || tooling_strEq(arg, "help"):
            tooling_printOut("backend-prod-publish options:")
            tooling_printOut("  --dst:<dir>                  publish destination root (default dist/releases)")
            tooling_printOut("  --manifest:<path>            release manifest output path")
            tooling_printOut("  --bundle:<path>              release bundle output path")
            tooling_printOut("  --name:<name>                release binary name (default cheng)")
            tooling_printOut("  --driver:<path>              release manifest/bundle driver (default canonical driver)")
            tooling_printOut("  note: always runs dev closure first, then release required gates + publish tail")
            return 0
        if strutil.startsWith(arg, "--dst:"):
            dstRaw = strings.dropPrefix(arg, "--dst:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--manifest:"):
            manifestRaw = strings.dropPrefix(arg, "--manifest:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--bundle:"):
            bundleRaw = strings.dropPrefix(arg, "--bundle:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--name:"):
            nameRaw = strings.dropPrefix(arg, "--name:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--driver:"):
            driverRaw = strings.dropPrefix(arg, "--driver:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown backend-prod-publish arg: " + arg)
        return 1
    let toolBin: str = tooling_cmdBackendProdToolBin(root)
    if !tooling_isExecutable(root, toolBin):
        tooling_printErr("cheng_tooling: backend-prod-publish requires canonical tooling binary: " +
                         tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling"))
        tooling_printErr("  hint: cheng_tooling build-global --out:artifacts/tooling_cmd/cheng_tooling --linker:self")
        tooling_printErr("  hint: set BACKEND_PROD_ALLOW_NONCANONICAL_TOOL_BIN=1 only for emergency fallback")
        return 1
    let bundleBinDir: str = os.parentDir(toolBin)
    let manifestPath: str = tooling_pathAbsolute(root, manifestRaw)
    let bundlePath: str = tooling_pathAbsolute(root, bundleRaw)
    let dstPath: str = tooling_pathAbsolute(root, dstRaw)
    var driverPath: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if tooling_strNonEmpty(strutil.strip(driverRaw)):
        driverPath = tooling_pathAbsolute(root, driverRaw)
    if !tooling_isExecutable(root, driverPath):
        tooling_printErr("cheng_tooling: backend-prod-publish driver is not executable: " + driverPath)
        return 1
    let manifestDir: str = os.parentDir(manifestPath)
    if tooling_strNonEmpty(manifestDir):
        if !tooling_mkdirP(root, manifestDir):
            tooling_printErr("cheng_tooling: failed to create manifest dir: " + manifestDir)
            return 1
    let bundleDir: str = os.parentDir(bundlePath)
    if tooling_strNonEmpty(bundleDir):
        if !tooling_mkdirP(root, bundleDir):
            tooling_printErr("cheng_tooling: failed to create bundle dir: " + bundleDir)
            return 1
    if !tooling_mkdirP(root, dstPath):
        tooling_printErr("cheng_tooling: failed to create publish dst dir: " + dstPath)
        return 1
    let gateTimeout: int32 = tooling_parseInt32Default(os.getEnvDefault("BACKEND_PROD_GATE_TIMEOUT", ""), 60)
    var envPrefixCommon: str = ""
    envPrefixCommon = envPrefixCommon + tooling_envAssignCompat("TOOLING_SELF_BIN", toolBin)
    envPrefixCommon = envPrefixCommon + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
    envPrefixCommon = envPrefixCommon + tooling_envAssignCompat("TOOLING_EXEC_BUNDLE_BIN_DIR", bundleBinDir)
    envPrefixCommon = envPrefixCommon + tooling_envAssignCompat("TOOLING_EXEC_GLOBAL_BIN",
                                                                tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling"))
    envPrefixCommon = envPrefixCommon + tooling_envAssignCompat("BACKEND_TOOLING_BUNDLE_GLOBAL_BIN",
                                                                tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling"))
    var publishClosureItersRaw: str = strutil.strip(
        os.getEnvDefault("BACKEND_PROD_PUBLISH_RELEASE_COMPILE_STABILITY_ITERS", "3"))
    if !tooling_strNonEmpty(publishClosureItersRaw):
        publishClosureItersRaw = "3"
    tooling_printOut("backend_prod_publish_release_compile_stability_iters=" + publishClosureItersRaw)
    let devEnv: str = envPrefixCommon +
                      tooling_envAssignCompat("BACKEND_BUILD_TRACK", "dev") +
                      tooling_envAssignCompat("BACKEND_PROD_RELEASE_COMPILE_STABILITY_ITERS",
                                              publishClosureItersRaw)
    let releaseEnv: str = envPrefixCommon +
                          tooling_envAssignCompat("BACKEND_BUILD_TRACK", "release") +
                          tooling_envAssignCompat("BACKEND_LINKER", "system") +
                          tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "0")
    var rc: int32 = 0
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.dev_closure",
                                       "backend_prod_closure", "", devEnv, gateTimeout)
    if rc != 0:
        return rc
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.release_system_link",
                                       "verify_backend_release_c_o3_lto", "", releaseEnv, gateTimeout)
    if rc != 0:
        return rc
    let releaseName: str = tooling_strNonEmpty(nameRaw) ? nameRaw : "cheng"
    let manifestArgs: str = "--out:" + tooling_shellQuote(manifestPath) +
                            " --name:" + tooling_shellQuote(releaseName) +
                            " --driver:" + tooling_shellQuote(driverPath)
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.release_manifest",
                                       "backend_release_manifest", manifestArgs, releaseEnv, gateTimeout)
    if rc != 0:
        return rc
    let bundleArgs: str = "--out:" + tooling_shellQuote(bundlePath) +
                          " --name:" + tooling_shellQuote(releaseName) +
                          " --manifest:" + tooling_shellQuote(manifestPath) +
                          " --driver:" + tooling_shellQuote(driverPath)
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.release_bundle",
                                       "backend_release_bundle", bundleArgs, releaseEnv, gateTimeout)
    if rc != 0:
        return rc
    let signArgs: str = "--manifest:" + tooling_shellQuote(manifestPath) +
                        " --bundle:" + tooling_shellQuote(bundlePath)
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.release_sign",
                                       "backend_release_sign", signArgs, releaseEnv, gateTimeout)
    if rc != 0:
        return rc
    let verifyArgs: str = "--manifest:" + tooling_shellQuote(manifestPath) +
                          " --bundle:" + tooling_shellQuote(bundlePath)
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.release_verify",
                                       "backend_release_verify", verifyArgs, releaseEnv, gateTimeout)
    if rc != 0:
        return rc
    let publishArgs: str = "--manifest:" + tooling_shellQuote(manifestPath) +
                           " --bundle:" + tooling_shellQuote(bundlePath) +
                           " --dst:" + tooling_shellQuote(dstPath)
    rc = tooling_cmdBackendProdRunGate(root, toolBin, "backend.release_publish",
                                       "backend_release_publish", publishArgs, releaseEnv, gateTimeout)
    if rc != 0:
        return rc
    tooling_printOut("backend_prod_publish_manifest=" + manifestPath)
    tooling_printOut("backend_prod_publish_bundle=" + bundlePath)
    tooling_printOut("backend_prod_publish_dst=" + dstPath)
    tooling_printOut("backend_prod_publish_driver=" + driverPath)
    tooling_printOut("backend_prod_publish ok")
    return 0

fn tooling_list(root: str): int32 =
    let out: str[] = tooling_collectScripts(root)
    if out.len == 0:
        tooling_printErr("cheng_tooling: no embedded tooling scripts registered")
        return 1
    for i in 0..<out.len:
        tooling_printOut(out[i])
    return 0

fn tooling_embeddedTextCommand(root: str, argStart: int32, count: int32): int32 =
    var scriptId: str = ""
    var i: int32 = argStart
    for _ in argStart..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("usage: cheng_tooling embedded-text --id:<script-id>")
            tooling_printOut("   or: cheng_tooling embedded-text <script-id>")
            return 0
        if strutil.startsWith(arg, "--id:"):
            scriptId = strings.dropPrefix(arg, "--id:")
            i = i + 1
            continue
        if !tooling_strNonEmpty(scriptId):
            scriptId = arg
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown embedded-text arg: " + arg)
        return 1
    let normalizedId: str = tooling_normalizeScriptId(scriptId)
    if !tooling_strNonEmpty(normalizedId):
        tooling_printErr("cheng_tooling: embedded-text requires --id:<script-id>")
        return 1
    if tooling_strEq(normalizedId, "chengb"):
        tooling_printErr("cheng_tooling: chengb has been removed; use `cheng`")
        return 2
    var scriptText: str = tooling_embeddedScriptText(root, normalizedId)
    scriptText = tooling_patchEmbeddedRuntimeDefaults(normalizedId, scriptText)
    if !tooling_strNonEmpty(scriptText):
        tooling_printErr("cheng_tooling: embedded-text script not found: " + normalizedId)
        return 1
    os.write(os.get_stdout(), scriptText)
    return 0

fn tooling_embeddedMapRewriteCommand(root: str, argStart: int32, count: int32): int32 =
    var outPath: str = os.joinPath(root, "src/tooling/cheng_tooling_embedded_inline.cheng")
    var outFromFlag: str = ""
    var positionalA: str = ""
    var positionalB: str = ""
    var i: int32 = argStart
    for _ in argStart..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("usage: cheng_tooling embedded-map-rewrite [--out:<path>] [map_path] [out_path]")
            tooling_printOut("   or: cheng_tooling rewrite-map [map_path] [out_path]")
            return 0
        if strutil.startsWith(arg, "--out:"):
            outFromFlag = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "-"):
            tooling_printErr("cheng_tooling: unknown embedded-map-rewrite arg: " + arg)
            return 1
        if !tooling_strNonEmpty(positionalA):
            positionalA = arg
            i = i + 1
            continue
        if !tooling_strNonEmpty(positionalB):
            positionalB = arg
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: too many positional args for embedded-map-rewrite")
        return 1
    if tooling_strNonEmpty(outFromFlag):
        outPath = tooling_pathAbsolute(root, outFromFlag)
    elif tooling_strNonEmpty(positionalB):
        # Compatibility with old `rewrite-map <map_path> <out_path>` CLI.
        outPath = tooling_pathAbsolute(root, positionalB)
    elif tooling_strNonEmpty(positionalA):
        # Compatibility with old `rewrite-map <map_path>` in-place rewrite.
        outPath = tooling_pathAbsolute(root, positionalA)
    else:
        outPath = tooling_pathAbsolute(root, outPath)
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        if !tooling_mkdirP(root, outDir):
            tooling_printErr("cheng_tooling: failed to create output dir: " + outDir)
            return 1
    let rendered: str = tooling_renderEmbeddedMapText(root)
    os.writeFile(outPath, rendered)
    let renderedIds: str[] = tooling_collectScripts(root)
    tooling_printOut("embedded_map_rewrite_out=" + outPath)
    tooling_printOut("embedded_map_rewrite_count=" + intToStr(renderedIds.len))
    return 0

fn tooling_cmdVerifyBackendCdropEmergency(root: str): int32 =
    let cdropDir: str = tooling_pathAbsolute(root, "bootstrap/cdrop")
    let bootCPath: str = os.joinPath(cdropDir, "cheng_boot.c")
    let manifestPath: str = os.joinPath(cdropDir, "manifest.toml")
    if !os.fileExists(bootCPath):
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency missing file: " + bootCPath)
        return 1
    if !os.fileExists(manifestPath):
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency missing file: " + manifestPath)
        return 1

    let parseCmd: str =
        "awk -F '=' '/^[[:space:]]*sha256[[:space:]]*=/{v=$2; gsub(/[[:space:]\\\"\\047]/,\"\",v); print v; exit}' " +
        tooling_shellQuote(manifestPath)
    let parseRes: os.ExecCmdResult = tooling_exec(root, parseCmd)
    if os.execCmdResultExitCode(parseRes) != 0:
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency failed to parse manifest sha256")
        tooling_printExecOutput(parseRes)
        return 1
    let manifestShaExpected: str = strutil.strip(os.execCmdResultOutput(parseRes))
    if !tooling_strNonEmpty(manifestShaExpected):
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency missing manifest sha256 key")
        return 1
    let manifestShaActual: str = tooling_sha256File(root, bootCPath)
    if !tooling_strNonEmpty(manifestShaActual):
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency requires SHA-256 tool (shasum or sha256sum)")
        return 1
    tooling_printOut("cdrop_manifest_sha256_expected=" + manifestShaExpected)
    tooling_printOut("cdrop_manifest_sha256_actual=" + manifestShaActual)
    if !tooling_strEq(manifestShaExpected, manifestShaActual):
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency manifest hash mismatch")
        tooling_printErr("cheng_tooling: expected=" + manifestShaExpected + " actual=" + manifestShaActual)
        return 1

    let hasClang: os.ExecCmdResult = tooling_exec(root, "command -v clang >/dev/null 2>&1")
    if os.execCmdResultExitCode(hasClang) != 0:
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency requires clang")
        return 1
    let outDir: str = tooling_pathAbsolute(root, "artifacts/backend_cdrop_emergency")
    tooling_tryMkdirP(root, outDir)
    let seedPath: str = os.joinPath(outDir, "cheng.cdrop.seed")
    let runtimeDir: str = os.joinPath(root, "src/runtime/native")
    var compileCmd: str = "clang -O3 " + tooling_shellQuote(bootCPath) + " " +
                          tooling_shellQuote(runtimeDir) + "/*.c -o " + tooling_shellQuote(seedPath)
    var compileTimeoutSec: int32 = tooling_parseInt32Default(
        os.getEnvDefault("CDROP_EMERGENCY_COMPILE_TIMEOUT", ""), 60)
    if compileTimeoutSec < 1:
        compileTimeoutSec = 60
    compileCmd = tooling_wrapCommandWithTimeout(root, compileTimeoutSec, compileCmd)
    var compileRes: os.ExecCmdResult = tooling_exec(root, compileCmd)
    tooling_printExecOutput(compileRes)
    var compileRc: int32 = os.execCmdResultExitCode(compileRes)
    if compileRc != 0:
        let allowRuntimeless: bool = tooling_isTrue(
            os.getEnvDefault("CDROP_EMERGENCY_ALLOW_RUNTIMELESS_COMPILE", "1"))
        if !allowRuntimeless:
            tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency clang compile failed rc=" + intToStr(compileRc))
            return compileRc
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency runtime-full compile failed rc=" + intToStr(compileRc) +
                         ", retrying minimal bootstrap compile")
        var fallbackCompileCmd: str = "clang -O3 " + tooling_shellQuote(bootCPath) + " -o " + tooling_shellQuote(seedPath)
        fallbackCompileCmd = tooling_wrapCommandWithTimeout(root, compileTimeoutSec, fallbackCompileCmd)
        compileRes = tooling_exec(root, fallbackCompileCmd)
        tooling_printExecOutput(compileRes)
        compileRc = os.execCmdResultExitCode(compileRes)
        if compileRc != 0:
            tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency minimal clang compile failed rc=" + intToStr(compileRc))
            return compileRc
        tooling_printOut("cdrop_seed_compile_mode=minimal")
    else:
        tooling_printOut("cdrop_seed_compile_mode=runtime_full")
    tooling_printOut("cdrop_seed_bin=" + seedPath)

    if !tooling_binaryHelpProbeOk(root, seedPath, true):
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency seed --help probe failed: " + seedPath)
        return 1
    tooling_printOut("cdrop_seed_help_probe_ok=1")

    let canonicalDriver: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    let backupDriver: str = os.joinPath(outDir, "cheng.canonical.backup")
    var hasBackup: bool = false
    if tooling_isExecutable(root, canonicalDriver):
        if tooling_copyExecutable(root, canonicalDriver, backupDriver):
            hasBackup = true
    if !tooling_installExecutableAtomic(root, seedPath, canonicalDriver):
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency failed to install seed as canonical driver")
        return 1
    tooling_printOut("cdrop_seed_installed_canonical=1")

    let strictOutDir: str = os.joinPath(outDir, "selfhost")
    let strictTimingOut: str = os.joinPath(strictOutDir, "selfhost_timing_native.tsv")
    let strictRes: ToolingSelfhostResult = tooling_selfhostBootstrapStrictHost(root, strictOutDir, strictTimingOut, "")
    if !strictRes.ok:
        if hasBackup:
            if tooling_installExecutableAtomic(root, backupDriver, canonicalDriver):
                tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency restored previous canonical driver after strict failure")
        var strictMsg: str = strictRes.message
        if !tooling_strNonEmpty(strictMsg):
            strictMsg = "unknown failure"
        if tooling_strNonEmpty(strictRes.stage2Sha256):
            tooling_printErr("cheng_tooling: cdrop strict stage2_sha256=" + strictRes.stage2Sha256)
        if tooling_strNonEmpty(strictRes.stage3Sha256):
            tooling_printErr("cheng_tooling: cdrop strict stage3_sha256=" + strictRes.stage3Sha256)
        tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency strict selfhost failed: " + strictMsg)
        return 1
    if tooling_strNonEmpty(strictRes.stage3Path) && tooling_isExecutable(root, strictRes.stage3Path):
        if !tooling_installExecutableAtomic(root, strictRes.stage3Path, canonicalDriver):
            tooling_printErr("cheng_tooling: verify_backend_cdrop_emergency failed to promote strict stage3 as canonical driver")
            return 1
        tooling_printOut("cdrop_stage3_promoted_canonical=1")
    tooling_printOut("cdrop_selfhost_stage2=" + strictRes.stage2Path)
    tooling_printOut("cdrop_selfhost_stage3=" + strictRes.stage3Path)
    tooling_printOut("cdrop_selfhost_stage2_sha256=" + strictRes.stage2Sha256)
    tooling_printOut("cdrop_selfhost_stage3_sha256=" + strictRes.stage3Sha256)
    tooling_printOut("cdrop_selfhost_fixed_point_ok=" + tooling_boolText(strictRes.fixedPointOk))
    tooling_printOut("verify_backend_cdrop_emergency ok")
    return 0

fn tooling_cmdVerifyBackendCdropEmergencyFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("verify_backend_cdrop_emergency options:")
            tooling_printOut("  (no flags)")
            tooling_printOut("  env: BACKEND_RUN_CDROP_EMERGENCY=0|1 (integration gate toggle, default 0)")
            tooling_printOut("  env: CDROP_EMERGENCY_ALLOW_RUNTIMELESS_COMPILE=0|1 (default 1)")
            return 0
        tooling_printErr("cheng_tooling: unknown verify_backend_cdrop_emergency arg: " + arg)
        return 1
    return tooling_cmdVerifyBackendCdropEmergency(root)

fn tooling_cmdVerifyBackendNativeContract(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "usage() { " +
          "echo \"Usage: ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_native_contract [--baseline:<path>] [--doc:<path>]\"; " +
        "}; " +
        "hash_file() { " +
          "file=\"$1\"; " +
          "if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; " +
          "if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; " +
          "cksum \"$file\" | awk '{print $1}'; " +
        "}; " +
        "baseline=\"src/tooling/backend_native_contract.env\"; " +
        "doc=\"docs/cheng-native-contract.md\"; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "while [ \"${1:-}\" != \"\" ]; do " +
          "case \"$1\" in " +
            "--baseline:*) baseline=\"${1#--baseline:}\" ;; " +
            "--doc:*) doc=\"${1#--doc:}\" ;; " +
            "--help|-h) usage; exit 0 ;; " +
            "*) echo \"[Error] unknown arg: $1\" >&2; usage; exit 2 ;; " +
          "esac; " +
          "shift || true; " +
        "done; " +
        "if [ ! -f \"$baseline\" ]; then echo \"[verify_backend_native_contract] missing baseline file: $baseline\" >&2; exit 2; fi; " +
        "if [ ! -f \"$doc\" ]; then echo \"[verify_backend_native_contract] missing doc file: $doc\" >&2; exit 2; fi; " +
        "if ! command -v rg >/dev/null 2>&1; then echo \"[verify_backend_native_contract] rg is required\" >&2; exit 2; fi; " +
        "out_dir=\"artifacts/backend_native_contract\"; " +
        "mkdir -p \"$out_dir\"; " +
        "generated=\"$out_dir/backend_native_contract.generated.env\"; " +
        "report=\"$out_dir/backend_native_contract.report.txt\"; " +
        "snapshot=\"$out_dir/backend_native_contract.snapshot.env\"; " +
        "diff_file=\"$out_dir/backend_native_contract.diff.txt\"; " +
        "\"$tool\" build_backend_native_contract --doc:\"$doc\" --out:\"$generated\" >/dev/null; " +
        "status=\"ok\"; " +
        "if ! cmp -s \"$baseline\" \"$generated\"; then " +
          "status=\"drift\"; " +
          "if ! diff -u \"$baseline\" \"$generated\" >\"$diff_file\" 2>/dev/null; then diff \"$baseline\" \"$generated\" >\"$diff_file\" 2>/dev/null || true; fi; " +
        "else : >\"$diff_file\"; fi; " +
        "closedloop_gate_ok=1; prod_closure_gate_ok=1; " +
        "if ! rg -q 'backend\\.native_contract' src/tooling/cheng_tooling.cheng; then closedloop_gate_ok=0; fi; " +
        "if ! rg -q 'verify_backend_native_contract' src/tooling/cheng_tooling.cheng; then prod_closure_gate_ok=0; fi; " +
        "if [ \"$closedloop_gate_ok\" != \"1\" ] || [ \"$prod_closure_gate_ok\" != \"1\" ]; then status=\"drift\"; fi; " +
        "driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r' || true)\"; " +
        "if [ \"$driver\" = \"\" ] || [ ! -x \"$driver\" ]; then " +
          "echo \"[verify_backend_native_contract] missing canonical backend driver; run: $tool build-backend-driver\" >&2; " +
          "exit 2; " +
        "fi; " +
        "run_driver_once() { " +
          "log_file=\"$1\"; shift; timeout_sec=\"${NATIVE_CONTRACT_DRIVER_TIMEOUT_SEC:-20}\"; " +
          "case \"$timeout_sec\" in ''|*[!0-9]*) timeout_sec=20 ;; esac; " +
          "if [ \"$timeout_sec\" -lt 1 ]; then \"$@\" >\"$log_file\" 2>&1; return \"$?\"; fi; " +
          "\"$@\" >\"$log_file\" 2>&1 & pid=\"$!\"; elapsed=0; " +
          "while kill -0 \"$pid\" >/dev/null 2>&1; do " +
            "if [ \"$elapsed\" -ge \"$timeout_sec\" ]; then kill -TERM \"$pid\" >/dev/null 2>&1 || true; sleep 0.2; kill -KILL \"$pid\" >/dev/null 2>&1 || true; return 124; fi; " +
            "sleep 1; elapsed=$((elapsed + 1)); " +
          "done; " +
          "wait \"$pid\"; return \"$?\"; " +
        "}; " +
        "run_driver_retry() { " +
          "log_file=\"$1\"; shift; attempts=\"${NATIVE_CONTRACT_DRIVER_RETRIES:-2}\"; " +
          "case \"$attempts\" in ''|*[!0-9]*) attempts=2 ;; esac; " +
          "if [ \"$attempts\" -lt 1 ]; then attempts=1; fi; " +
          "try=1; rc=139; " +
          "while [ \"$try\" -le \"$attempts\" ]; do " +
            "run_driver_once \"$log_file\" \"$@\"; rc=\"$?\"; " +
            "if [ \"$rc\" -ne 139 ] && [ \"$rc\" -ne 138 ]; then break; fi; " +
            "if [ \"$try\" -lt \"$attempts\" ]; then echo \"[verify_backend_native_contract] retry driver after crash rc=$rc attempt=$try/$attempts\" >&2; fi; " +
            "try=$((try + 1)); " +
          "done; " +
          "return \"$rc\"; " +
        "}; " +
        "ok_fixture=\"${NATIVE_CONTRACT_OK_FIXTURE:-tests/cheng/backend/fixtures/return_i64.cheng}\"; " +
        "float_fixture=\"tests/cheng/backend/fixtures/native_contract_float_fail.cheng\"; " +
        "syscall_fixture=\"tests/cheng/backend/fixtures/native_contract_syscall_fail.cheng\"; " +
        "for fixture in \"$ok_fixture\" \"$float_fixture\" \"$syscall_fixture\"; do " +
          "if [ ! -f \"$fixture\" ]; then echo \"[verify_backend_native_contract] missing fixture: $fixture\" >&2; exit 2; fi; " +
        "done; " +
        "ok_out=\"$out_dir/native_contract_ok.bin\"; ok_stamp=\"$out_dir/native_contract_ok.compile_stamp.txt\"; ok_err=\"$out_dir/native_contract_ok.stderr.txt\"; " +
        "rm -f \"$ok_out\" \"$ok_stamp\" \"$ok_err\"; " +
        "native_contract_stamp_missing=0; " +
        "set +e; " +
        "run_driver_retry \"$ok_err\" env -u STAGE1_AUTO_SYSTEM BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_ENABLE_CLI=1 BACKEND_NATIVE_CONTRACT=1 BACKEND_LINKER=self BACKEND_NO_RUNTIME_C=1 BACKEND_VALIDATE=1 BACKEND_ELF_PROFILE=nolibc BACKEND_INTERNAL_ALLOW_EMIT_OBJ=1 BACKEND_EMIT=obj BACKEND_TARGET=linux-aarch64 MM=orc BACKEND_CACHE=0 STAGE1_AUTO_SYSTEM=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 BACKEND_BUILD_TRACK=dev BACKEND_TOOLING_ENTRY=1 BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_ALLOW_NO_MAIN=0 BACKEND_STAGE1_PARSE_MODE=outline BACKEND_FN_SCHED=ws BACKEND_DIRECT_EXE=1 BACKEND_LINKERLESS_INMEM=1 BACKEND_FAST_DEV_PROFILE=1 BACKEND_FAST_FALLBACK_ALLOW=0 BACKEND_INCREMENTAL=1 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict BACKEND_INPUT=\"$ok_fixture\" BACKEND_OUTPUT=\"$ok_out\" BACKEND_COMPILE_STAMP_OUT=\"$ok_stamp\" \"$driver\"; " +
        "ok_rc=\"$?\"; " +
        "set -e; " +
        "native_smoke_ok=1; " +
        "if [ \"$ok_rc\" -ne 0 ]; then " +
          "if [ -s \"$ok_err\" ]; then sed -n '1,120p' \"$ok_err\" >&2 || true; fi; " +
          "native_smoke_ok=0; status=\"drift\"; " +
        "elif ! rg -q '^native_contract=1$' \"$ok_stamp\"; then " +
          "echo \"[verify_backend_native_contract] warn: compile stamp missing native_contract=1 marker (compat driver); continue\" >&2; " +
          "native_contract_stamp_missing=1; " +
        "fi; " +
        "if [ \"$native_smoke_ok\" = \"1\" ] && command -v nm >/dev/null 2>&1; then " +
          "if ! nm \"$ok_out\" 2>/dev/null | rg -q 'cheng_contract_charge_block|cheng_contract_gas_used'; then " +
            "if [ \"$native_contract_stamp_missing\" = \"1\" ]; then " +
              "echo \"[verify_backend_native_contract] warn: compat driver output missing charge symbols\" >&2; " +
            "else " +
              "echo \"[verify_backend_native_contract] native contract output missing charge symbols\" >&2; " +
              "native_smoke_ok=0; status=\"drift\"; " +
            "fi; " +
          "fi; " +
        "fi; " +
        "enforce_float_fail=\"${NATIVE_CONTRACT_ENFORCE_FLOAT_FAIL:-0}\"; " +
        "expect_fail() { " +
          "label=\"$1\"; fixture=\"$2\"; out_bin=\"$out_dir/${label}.bin\"; err_file=\"$out_dir/${label}.stderr.txt\"; " +
          "rm -f \"$out_bin\" \"$err_file\"; " +
          "set +e; " +
          "run_driver_retry \"$err_file\" env -u STAGE1_AUTO_SYSTEM BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_ENABLE_CLI=1 BACKEND_NATIVE_CONTRACT=1 BACKEND_LINKER=self BACKEND_NO_RUNTIME_C=1 BACKEND_VALIDATE=1 BACKEND_ELF_PROFILE=nolibc BACKEND_INTERNAL_ALLOW_EMIT_OBJ=1 BACKEND_EMIT=obj BACKEND_TARGET=linux-aarch64 MM=orc BACKEND_CACHE=0 STAGE1_AUTO_SYSTEM=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 BACKEND_BUILD_TRACK=dev BACKEND_TOOLING_ENTRY=1 BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_ALLOW_NO_MAIN=0 BACKEND_STAGE1_PARSE_MODE=outline BACKEND_FN_SCHED=ws BACKEND_DIRECT_EXE=1 BACKEND_LINKERLESS_INMEM=1 BACKEND_FAST_DEV_PROFILE=1 BACKEND_FAST_FALLBACK_ALLOW=0 BACKEND_INCREMENTAL=1 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$out_bin\" \"$driver\"; " +
          "rc=\"$?\"; " +
          "set -e; " +
          "if [ \"$rc\" -eq 0 ]; then echo \"[verify_backend_native_contract] expected failure but succeeded: $label\" >&2; status=\"drift\"; return; fi; " +
          "case \"$label\" in " +
            "float) if ! rg -q 'native_contract hard-fail|forbid float' \"$err_file\"; then echo \"[verify_backend_native_contract] missing float hard-fail diagnostics\" >&2; status=\"drift\"; fi ;; " +
            "syscall) if ! rg -q 'native_contract hard-fail|forbid syscall|linux syscall builtin|cheng_linux_syscall' \"$err_file\"; then " +
              "if [ -s \"$err_file\" ]; then " +
                "echo \"[verify_backend_native_contract] missing syscall hard-fail diagnostics\" >&2; status=\"drift\"; " +
              "else " +
                "echo \"[verify_backend_native_contract] warn: syscall negative fixture returned non-zero without stderr diagnostics\" >&2; " +
              "fi; " +
            "fi ;; " +
          "esac; " +
        "}; " +
        "if [ \"$enforce_float_fail\" = \"1\" ]; then " +
          "expect_fail float \"$float_fixture\"; " +
        "else " +
          "echo \"[verify_backend_native_contract] float hard-fail check disabled (set NATIVE_CONTRACT_ENFORCE_FLOAT_FAIL=1 to enforce)\" >&2; " +
        "fi; " +
        "expect_fail syscall \"$syscall_fixture\"; " +
        "baseline_sha=\"$(hash_file \"$baseline\")\"; generated_sha=\"$(hash_file \"$generated\")\"; " +
        "{ " +
          "echo \"verify_backend_native_contract report\"; " +
          "echo \"status=$status\"; " +
          "echo \"doc=$doc\"; " +
          "echo \"baseline=$baseline\"; " +
          "echo \"generated=$generated\"; " +
          "echo \"baseline_sha256=$baseline_sha\"; " +
          "echo \"generated_sha256=$generated_sha\"; " +
          "echo \"closedloop_gate_ok=$closedloop_gate_ok\"; " +
          "echo \"prod_closure_gate_ok=$prod_closure_gate_ok\"; " +
          "echo \"native_smoke_ok=$native_smoke_ok\"; " +
          "echo \"native_contract_stamp_missing=$native_contract_stamp_missing\"; " +
          "echo \"enforce_float_fail=$enforce_float_fail\"; " +
          "echo \"diff=$diff_file\"; " +
        "} >\"$report\"; " +
        "{ " +
          "echo \"backend_native_contract_status=$status\"; " +
          "echo \"backend_native_contract_baseline_sha256=$baseline_sha\"; " +
          "echo \"backend_native_contract_generated_sha256=$generated_sha\"; " +
          "echo \"backend_native_contract_closedloop_gate_ok=$closedloop_gate_ok\"; " +
          "echo \"backend_native_contract_prod_closure_gate_ok=$prod_closure_gate_ok\"; " +
          "echo \"backend_native_contract_native_smoke_ok=$native_smoke_ok\"; " +
          "echo \"backend_native_contract_stamp_missing=$native_contract_stamp_missing\"; " +
          "echo \"backend_native_contract_enforce_float_fail=$enforce_float_fail\"; " +
          "echo \"backend_native_contract_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$status\" != \"ok\" ]; then " +
          "echo \"[verify_backend_native_contract] native contract baseline/implementation drift detected\" >&2; " +
          "echo \"  baseline: $baseline\" >&2; " +
          "echo \"  generated: $generated\" >&2; " +
          "if [ -s \"$diff_file\" ]; then sed -n '1,120p' \"$diff_file\" >&2 || true; fi; " +
          "echo \"  fix: ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} build_backend_native_contract --doc:$doc --out:$baseline\" >&2; " +
          "exit 1; " +
        "fi; " +
        "echo \"verify_backend_native_contract ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendNativeContractAutosystem(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_native_contract_autosystem] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_native_contract_autosystem] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_native_contract_autosystem\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_native_contract_autosystem.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_native_contract_autosystem.snapshot.env\"; " +
        "fixture=\"${NATIVE_CONTRACT_OK_FIXTURE:-tests/cheng/backend/fixtures/return_i64.cheng}\"; " +
        "if [ ! -f \"$fixture\" ]; then " +
            "echo \"[verify_backend_native_contract_autosystem] missing fixture: $fixture\" >&2; exit 2; " +
        "fi; " +
        "driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r' || true)\"; " +
        "if [ \"$driver\" = \"\" ] || [ ! -x \"$driver\" ]; then " +
            "echo \"[verify_backend_native_contract_autosystem] missing canonical driver; run: $tool build-backend-driver\" >&2; exit 1; " +
        "fi; " +
        "target=\"${BACKEND_TARGET:-linux-aarch64}\"; " +
        "stage1_parse_mode=\"${NATIVE_CONTRACT_AUTOSYSTEM_STAGE1_PARSE_MODE:-full}\"; " +
        "if [ \"$stage1_parse_mode\" != \"full\" ] && [ \"$stage1_parse_mode\" != \"outline\" ]; then stage1_parse_mode=\"full\"; fi; " +
        "attempts=\"${NATIVE_CONTRACT_AUTOSYSTEM_RETRIES:-${NATIVE_CONTRACT_DRIVER_RETRIES:-10}}\"; " +
        "case \"$attempts\" in ''|*[!0-9]*) attempts=10 ;; esac; " +
        "if [ \"$attempts\" -lt 1 ]; then attempts=1; fi; " +
        "run_case() { " +
          "name=\"$1\"; mode=\"$2\"; out_bin=\"$out_dir/$name.bin\"; stamp=\"$out_dir/$name.stamp.txt\"; log=\"$out_dir/$name.log\"; " +
          "rm -f \"$out_bin\" \"$stamp\" \"$log\"; " +
          "try=1; rc=139; " +
          "while [ \"$try\" -le \"$attempts\" ]; do " +
            "set +e; " +
            "if [ \"$mode\" = \"unset\" ]; then " +
              "env -u STAGE1_AUTO_SYSTEM BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_ENABLE_CLI=1 BACKEND_NATIVE_CONTRACT=1 BACKEND_LINKER=self BACKEND_NO_RUNTIME_C=1 BACKEND_VALIDATE=1 BACKEND_ELF_PROFILE=nolibc BACKEND_INTERNAL_ALLOW_EMIT_OBJ=1 BACKEND_EMIT=obj BACKEND_TARGET=\"$target\" MM=orc BACKEND_CACHE=0 STAGE1_AUTO_SYSTEM=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 BACKEND_BUILD_TRACK=dev BACKEND_TOOLING_ENTRY=1 BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_ALLOW_NO_MAIN=0 BACKEND_STAGE1_PARSE_MODE=\"$stage1_parse_mode\" BACKEND_FN_SCHED=ws BACKEND_DIRECT_EXE=1 BACKEND_LINKERLESS_INMEM=1 BACKEND_FAST_DEV_PROFILE=1 BACKEND_FAST_FALLBACK_ALLOW=0 BACKEND_INCREMENTAL=1 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$out_bin\" BACKEND_COMPILE_STAMP_OUT=\"$stamp\" \"$driver\" >\"$log\" 2>&1; " +
            "else " +
              "env STAGE1_AUTO_SYSTEM=1 BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_ENABLE_CLI=1 BACKEND_NATIVE_CONTRACT=1 BACKEND_LINKER=self BACKEND_NO_RUNTIME_C=1 BACKEND_VALIDATE=1 BACKEND_ELF_PROFILE=nolibc BACKEND_INTERNAL_ALLOW_EMIT_OBJ=1 BACKEND_EMIT=obj BACKEND_TARGET=\"$target\" MM=orc BACKEND_CACHE=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 BACKEND_BUILD_TRACK=dev BACKEND_TOOLING_ENTRY=1 BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_ALLOW_NO_MAIN=0 BACKEND_STAGE1_PARSE_MODE=\"$stage1_parse_mode\" BACKEND_FN_SCHED=ws BACKEND_DIRECT_EXE=1 BACKEND_LINKERLESS_INMEM=1 BACKEND_FAST_DEV_PROFILE=1 BACKEND_FAST_FALLBACK_ALLOW=0 BACKEND_INCREMENTAL=1 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$out_bin\" BACKEND_COMPILE_STAMP_OUT=\"$stamp\" \"$driver\" >\"$log\" 2>&1; " +
            "fi; " +
            "rc=\"$?\"; set -e; " +
            "if [ \"$rc\" -ne 139 ] && [ \"$rc\" -ne 138 ]; then break; fi; " +
            "if [ \"$try\" -lt \"$attempts\" ]; then " +
              "echo \"[verify_backend_native_contract_autosystem] retry after crash rc=$rc case=$name attempt=$try/$attempts\" >&2; " +
            "fi; " +
            "try=$((try + 1)); " +
          "done; " +
          "printf '%s\\n' \"$rc\" >\"$out_dir/$name.rc\"; " +
          "if [ \"$rc\" -ne 0 ] || [ ! -s \"$out_bin\" ] || [ ! -s \"$stamp\" ]; then " +
            "echo \"[verify_backend_native_contract_autosystem] compile failed case=$name rc=$rc\" >&2; " +
            "sed -n '1,120p' \"$log\" >&2 || true; " +
            "return 1; " +
          "fi; " +
          "if ! rg -q '^native_contract=1$' \"$stamp\"; then " +
            "echo \"[verify_backend_native_contract_autosystem] missing native_contract marker case=$name\" >&2; " +
            "sed -n '1,80p' \"$stamp\" >&2 || true; " +
            "return 1; " +
          "fi; " +
          "return 0; " +
        "}; " +
        "run_case unset_case unset; " +
        "run_case force_on_case force_on; " +
        "unset_rc=\"$(cat \"$out_dir/unset_case.rc\" 2>/dev/null || echo 1)\"; " +
        "force_on_rc=\"$(cat \"$out_dir/force_on_case.rc\" 2>/dev/null || echo 1)\"; " +
        "{ " +
            "echo \"verify_backend_native_contract_autosystem report\"; " +
            "echo \"status=ok\"; " +
            "echo \"driver=$driver\"; " +
            "echo \"target=$target\"; " +
            "echo \"fixture=$fixture\"; " +
            "echo \"stage1_parse_mode=$stage1_parse_mode\"; " +
            "echo \"unset_case_rc=$unset_rc\"; " +
            "echo \"force_on_case_rc=$force_on_rc\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_native_contract_autosystem_status=ok\"; " +
            "echo \"backend_native_contract_autosystem_driver=$driver\"; " +
            "echo \"backend_native_contract_autosystem_target=$target\"; " +
            "echo \"backend_native_contract_autosystem_fixture=$fixture\"; " +
            "echo \"backend_native_contract_autosystem_stage1_parse_mode=$stage1_parse_mode\"; " +
            "echo \"backend_native_contract_autosystem_unset_case_rc=$unset_rc\"; " +
            "echo \"backend_native_contract_autosystem_force_on_case_rc=$force_on_rc\"; " +
            "echo \"backend_native_contract_autosystem_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_native_contract_autosystem ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendOpt2ImplSurface(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_opt2_impl_surface] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_opt2_impl_surface\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "opt2_file=\"src/backend/uir/uir_internal/uir_core_opt2.cheng\"; " +
        "ssu_file=\"src/backend/uir/uir_internal/uir_core_ssu.cheng\"; " +
        "noalias_file=\"src/backend/uir/uir_noalias_pass.cheng\"; " +
        "placeholder_hits=\"$out_dir/opt2.placeholder_hits.txt\"; " +
        "report=\"$out_dir/verify_backend_opt2_impl_surface.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_opt2_impl_surface.snapshot.env\"; " +
        "status=\"ok\"; " +
        "rg -n -U -P \"(?s)^fn\\\\s+(uirCore(?:OptimizeModule|Func)[A-Za-z0-9_]+)\\\\([^\\\\n]*\\\\):\\\\s*bool\\\\s*=\\\\n\\\\s*return false\" \"$opt2_file\" >\"$placeholder_hits\" || true; " +
        "placeholder_count=0; " +
        "if [ -s \"$placeholder_hits\" ]; then " +
            "placeholder_count=\"$(wc -l <\"$placeholder_hits\" | tr -d '[:space:]')\"; " +
            "status=\"drift\"; " +
        "fi; " +
        "ssu_default_ok=1; " +
        "if ! rg -q 'UIR_SSU\", true' \"$ssu_file\"; then ssu_default_ok=0; status=\"drift\"; fi; " +
        "njvl_default_ok=1; " +
        "if ! rg -q 'UIR_NOALIAS_NJVL_LITE\", true' \"$noalias_file\"; then njvl_default_ok=0; status=\"drift\"; fi; " +
        "noalias_fields_ok=1; " +
        "for key in unknown_slot_clobbers unknown_global_clobbers kill_events; do " +
            "if ! rg -q \"$key\" \"$noalias_file\"; then noalias_fields_ok=0; status=\"drift\"; fi; " +
        "done; " +
        "{ " +
            "echo \"verify_backend_opt2_impl_surface report\"; " +
            "echo \"status=$status\"; " +
            "echo \"placeholder_hits=$placeholder_hits\"; " +
            "echo \"placeholder_count=$placeholder_count\"; " +
            "echo \"ssu_default_ok=$ssu_default_ok\"; " +
            "echo \"njvl_default_ok=$njvl_default_ok\"; " +
            "echo \"noalias_fields_ok=$noalias_fields_ok\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_opt2_impl_surface_status=$status\"; " +
            "echo \"backend_opt2_impl_surface_placeholder_count=$placeholder_count\"; " +
            "echo \"backend_opt2_impl_surface_ssu_default_ok=$ssu_default_ok\"; " +
            "echo \"backend_opt2_impl_surface_njvl_default_ok=$njvl_default_ok\"; " +
            "echo \"backend_opt2_impl_surface_noalias_fields_ok=$noalias_fields_ok\"; " +
            "echo \"backend_opt2_impl_surface_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$status\" != \"ok\" ]; then " +
            "echo \"[verify_backend_opt2_impl_surface] drift detected\" >&2; " +
            "echo \"  report: $report\" >&2; " +
            "if [ -s \"$placeholder_hits\" ]; then " +
                "echo \"  placeholder functions (top):\" >&2; " +
                "sed -n '1,80p' \"$placeholder_hits\" >&2 || true; " +
            "fi; " +
            "exit 1; " +
        "fi; " +
        "echo \"verify_backend_opt2_impl_surface ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendDriverUnifiedGlobal(root: str): int32 =
    let outDir: str = tooling_pathAbsolute(root, "artifacts/backend_driver_unify")
    if !tooling_mkdirP(root, outDir):
        tooling_printErr("cheng_tooling: failed to create output dir: " + outDir)
        return 1
    let baselineDir: str = os.joinPath(outDir, "baseline")
    if !tooling_mkdirP(root, baselineDir):
        tooling_printErr("cheng_tooling: failed to create baseline dir: " + baselineDir)
        return 1
    let baselinePsBefore: str = os.joinPath(baselineDir, "ue_orphan_before.txt")
    let baselinePsAfter: str = os.joinPath(baselineDir, "ue_orphan_after.txt")
    let baselineRefs: str = os.joinPath(baselineDir, "driver_refs.txt")
    let psCmd: str = "ps -Ao pid,ppid,state,command | awk '$3 ~ /^U/ {print}'"
    let psBeforeRes: os.ExecCmdResult = tooling_exec(root, psCmd)
    os.writeFile(baselinePsBefore, os.execCmdResultOutput(psBeforeRes))
    let beforeCount: int32 = tooling_stage0QuarantineUeCount(root)
    let cleanedCount: int32 = tooling_stage0QuarantineSweepUe(root, "verify_backend_driver_unified_global")
    let afterCount: int32 = tooling_stage0QuarantineUeCount(root)
    let psAfterRes: os.ExecCmdResult = tooling_exec(root, psCmd)
    os.writeFile(baselinePsAfter, os.execCmdResultOutput(psAfterRes))
    let reportPath: str = os.joinPath(outDir, "verify_backend_driver_unified_global.report.txt")
    let snapshotPath: str = os.joinPath(outDir, "verify_backend_driver_unified_global.snapshot.env")
    var userHome: str = strutil.strip(os.getEnvDefault("HOME", ""))
    if !tooling_strNonEmpty(userHome):
        userHome = os.parentDir(root)
    let codexMain: str = os.joinPath(userHome, ".cheng-packages/cheng-codex/src/main.cheng")
    let guiNativeC: str = os.joinPath(userHome, ".cheng-packages/cheng-gui/src/tools/native_r2c_compile_react_project.c")
    let libp2pBuild: str = os.joinPath(userHome, ".cheng-packages/cheng-libp2p/scripts/backend_build.sh")
    let quicBuild: str = os.joinPath(userHome, ".cheng-packages/cheng-quic/scripts/backend_build.sh")
    let vpnVerify: str = os.joinPath(userHome, ".cheng-packages/cheng-vpn/scripts/verify.sh")
    let pebbleClosure: str = os.joinPath(userHome, ".cheng-packages/cheng-pebble/scripts/production_closure.sh")
    let rwadSmoke: str = os.joinPath(userHome, ".cheng-packages/RWAD-blockchain/tools/run_smoke_tests.sh")
    let rwadKeygen: str = os.joinPath(userHome, ".cheng-packages/RWAD-blockchain/tools/rwad_keygen.sh")
    let wordBackendDriver: str = "\\bBACKEND_DRIVER\\b"
    let wordChengBackendDriver: str = "\\bCHENG_BACKEND_DRIVER\\b"
    let badLegacyReleasePath: str = "backend_" + "release_driver"
    let badLegacyReleaseFn: str = "tooling_" + "releaseDriver"
    let badLegacyCrossWorkspaceToggle: str = "TOOLING_STAGE0_ORPHAN_" + "CROSS_WORKSPACE"
    let checks: str[] = [
        codexMain + "::" + wordBackendDriver + "|" + wordChengBackendDriver + "|artifacts/backend_driver/cheng|dist/releases/current/cheng|artifacts/backend_seed/",
        guiNativeC + "::" + wordBackendDriver + "|artifacts/backend_driver/cheng",
        libp2pBuild + "::" + wordBackendDriver + "|" + wordChengBackendDriver + "|artifacts/backend_driver/cheng|dist/releases/current/cheng|artifacts/backend_seed/",
        quicBuild + "::" + wordBackendDriver + "|" + wordChengBackendDriver + "|artifacts/backend_driver/cheng|dist/releases/current/cheng|artifacts/backend_seed/",
        vpnVerify + "::" + wordBackendDriver + "|" + wordChengBackendDriver + "|artifacts/backend_driver/cheng|dist/releases/current/cheng|artifacts/backend_seed/",
        pebbleClosure + "::" + wordBackendDriver + "|" + wordChengBackendDriver + "|artifacts/backend_driver/cheng|dist/releases/current/cheng|artifacts/backend_seed/",
        rwadSmoke + "::" + wordBackendDriver + "|" + wordChengBackendDriver + "|artifacts/backend_driver/cheng|dist/releases/current/cheng|artifacts/backend_seed/",
        rwadKeygen + "::" + wordBackendDriver + "|" + wordChengBackendDriver + "|artifacts/backend_driver/cheng|dist/releases/current/cheng|artifacts/backend_seed/",
    ]
    let internalTokenChecks: str[] = [
        badLegacyReleasePath,
        badLegacyReleaseFn,
        badLegacyCrossWorkspaceToggle,
    ]
    var failCount: int32 = 0
    var report: str = "verify_backend_driver_unified_global report\n"
    report = report + "toolchain_root=" + os.absolutePath(root) + "\n"
    report = report + "ue_before=" + intToStr(beforeCount) + "\n"
    report = report + "ue_cleaned=" + intToStr(cleanedCount) + "\n"
    report = report + "ue_after=" + intToStr(afterCount) + "\n"
    var refsText: str = "# external refs (file::pattern)\n"
    for i in 0..<checks.len:
        refsText = refsText + checks[i] + "\n"
    refsText = refsText + "# internal forbidden tokens (src/tooling/cheng_tooling.cheng)\n"
    for i in 0..<internalTokenChecks.len:
        refsText = refsText + "src/tooling/cheng_tooling.cheng::" + internalTokenChecks[i] + "\n"
    os.writeFile(baselineRefs, refsText)
    for i in 0..<internalTokenChecks.len:
        let tok: str = internalTokenChecks[i]
        let cmdTok: str = "rg -n -- " + tooling_shellQuote(tok) + " src/tooling/cheng_tooling.cheng"
        let resTok: os.ExecCmdResult = tooling_exec(root, cmdTok)
        if os.execCmdResultExitCode(resTok) == 0:
            failCount = failCount + 1
            report = report + "fail_pattern=src/tooling/cheng_tooling.cheng :: " + tok + "\n"
            let outTok: str = os.execCmdResultOutput(resTok)
            if tooling_strNonEmpty(outTok):
                report = report + outTok
        else:
            report = report + "ok_pattern=src/tooling/cheng_tooling.cheng :: " + tok + "\n"
    for i in 0..<checks.len:
        let row: str = checks[i]
        var sepIdx: int32 = -1
        if len(row) >= 2:
            for j in 0..<(len(row) - 1):
                if row[j] == ':' && row[j + 1] == ':':
                    sepIdx = j
                    break
        if sepIdx <= 0:
            continue
        let filePath: str = strings.sliceBytes(row, 0, sepIdx)
        let pattern: str = strings.sliceBytes(row, sepIdx + 2, len(row) - (sepIdx + 2))
        if !os.fileExists(filePath):
            report = report + "skip_missing=" + filePath + "\n"
            continue
        let cmd: str = "rg -n -- " + tooling_shellQuote(pattern) + " " + tooling_shellQuote(filePath)
        let res: os.ExecCmdResult = tooling_exec(root, cmd)
        if os.execCmdResultExitCode(res) == 0:
            failCount = failCount + 1
            report = report + "fail_pattern=" + filePath + " :: " + pattern + "\n"
            let out: str = os.execCmdResultOutput(res)
            if tooling_strNonEmpty(out):
                report = report + out
        else:
            report = report + "ok_pattern=" + filePath + "\n"
    let canonicalDriver: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    let driverSha: str = tooling_sha256File(root, canonicalDriver)
    let snapshot: str =
        "toolchain_root=" + os.absolutePath(root) + "\n" +
        "driver_path=" + canonicalDriver + "\n" +
        "driver_sha256=" + driverSha + "\n" +
        "ue_before=" + intToStr(beforeCount) + "\n" +
        "ue_cleaned=" + intToStr(cleanedCount) + "\n" +
        "ue_after=" + intToStr(afterCount) + "\n" +
        "fail_count=" + intToStr(failCount) + "\n"
    os.writeFile(reportPath, report)
    os.writeFile(snapshotPath, snapshot)
    tooling_printOut("backend_driver_unified_global_report=" + reportPath)
    tooling_printOut("backend_driver_unified_global_snapshot=" + snapshotPath)
    tooling_printOut("backend_driver_unified_global_baseline_refs=" + baselineRefs)
    tooling_printOut("backend_driver_unified_global_baseline_ue_before=" + baselinePsBefore)
    tooling_printOut("backend_driver_unified_global_baseline_ue_after=" + baselinePsAfter)
    tooling_printOut("backend_driver_unified_global_fail_count=" + intToStr(failCount))
    tooling_printOut("backend_driver_unified_global_ue_before=" + intToStr(beforeCount))
    tooling_printOut("backend_driver_unified_global_ue_after=" + intToStr(afterCount))
    if afterCount > 0:
        return 1
    if failCount > 0:
        return 1
    tooling_printOut("verify_backend_driver_unified_global ok")
    return 0

fn tooling_cmdVerifyBackendCompileNameCanonical(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_compile_name_canonical] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_compile_name_canonical\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_compile_name_canonical.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_compile_name_canonical.snapshot.env\"; " +
        "hits=\"$out_dir/hits.txt\"; : >\"$hits\"; " +
        "fail=0; " +
        "forbid_pat() { " +
          "file=\"$1\"; pat=\"$2\"; tag=\"$3\"; " +
          "if [ ! -e \"$file\" ]; then " +
            "echo \"skip_missing=$file\" >>\"$report\"; " +
            "return 0; " +
          "fi; " +
          "if rg -n \"$pat\" \"$file\" >\"$out_dir/.tmp.hit\" 2>/dev/null; then " +
            "echo \"fail=$tag file=$file pattern=$pat\" >>\"$report\"; " +
            "cat \"$out_dir/.tmp.hit\" >>\"$hits\"; " +
            "fail=$((fail+1)); " +
          "else " +
            "echo \"ok=$tag file=$file\" >>\"$report\"; " +
          "fi; " +
        "}; " +
        "require_pat() { " +
          "file=\"$1\"; pat=\"$2\"; tag=\"$3\"; " +
          "if [ ! -e \"$file\" ]; then " +
            "echo \"skip_missing=$file\" >>\"$report\"; " +
            "return 0; " +
          "fi; " +
          "if rg -n \"$pat\" \"$file\" >\"$out_dir/.tmp.hit\" 2>/dev/null; then " +
            "echo \"ok=$tag file=$file\" >>\"$report\"; " +
          "else " +
            "echo \"fail=$tag file=$file pattern=$pat\" >>\"$report\"; " +
            "fail=$((fail+1)); " +
          "fi; " +
        "}; " +
        "require_pat \"src/tooling/cheng_tooling.cheng\" '`compile` has been removed; use `cheng`' 'alias_compile_removed_marker'; " +
        "require_pat \"src/tooling/cheng_tooling.cheng\" '`chengc` has been removed; use `cheng`' 'alias_chengc_removed_marker'; " +
        "require_pat \"src/tooling/cheng_tooling.cheng\" 'tooling_strEq\\(first, \"cheng\"\\)' 'canonical_route_first'; " +
        "require_pat \"src/tooling/cheng_tooling.cheng\" 'tooling_strEq\\(selfName, \"cheng\"\\)' 'canonical_route_argv0'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/cheng-codex/src/main.cheng\" '\" compile --' 'codex_main_compile_token'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/cheng-codex/build.sh\" 'cheng_tooling[[:space:]]+compile|[[:space:]]\\\"\\$TOOLING\\\"[[:space:]]+compile' 'codex_build_compile_cmd'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/cheng-codex/README.md\" 'cheng_tooling[[:space:]]+compile|\\$TOOLING[[:space:]]+compile' 'codex_readme_compile_cmd'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/cheng-codex/docs/closed-loop.md\" 'cheng_tooling[[:space:]]+compile|\\$TOOLING[[:space:]]+compile' 'codex_closedloop_compile_cmd'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/cheng-gui/src/tools/native_r2c_compile_react_project.c\" '\"compile\",' 'gui_native_compile_cmd'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/cheng-libp2p/scripts/backend_build.sh\" 'compile_args=\\(compile\\b' 'libp2p_backend_build_compile_cmd'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/cheng-quic/scripts/backend_build.sh\" 'compile_args=\\(compile\\b' 'quic_backend_build_compile_cmd'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/cheng-pebble/scripts/production_closure.sh\" '\\\"\\$tooling_bin\\\"[[:space:]]+compile\\b' 'pebble_production_compile_cmd'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/RWAD-blockchain/tools/run_smoke_tests.sh\" '\\\"\\$tooling_bin\\\"[[:space:]]+compile\\b' 'rwad_smoke_compile_cmd'; " +
        "forbid_pat \"/Users/lbcheng/.cheng-packages/RWAD-blockchain/tools/rwad_keygen.sh\" '\\\"\\$\\{tooling_bin\\}\\\"[[:space:]]+compile\\b' 'rwad_keygen_compile_cmd'; " +
        "{ " +
          "echo \"verify_backend_compile_name_canonical report\"; " +
          "echo \"fail_count=$fail\"; " +
          "echo \"hits=$hits\"; " +
        "} >>\"$report\"; " +
        "{ " +
          "echo \"backend_compile_name_canonical_fail_count=$fail\"; " +
          "echo \"backend_compile_name_canonical_report=$report\"; " +
          "echo \"backend_compile_name_canonical_hits=$hits\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$fail\" -ne 0 ]; then " +
          "echo \"[verify_backend_compile_name_canonical] found non-canonical compile command tokens\" >&2; " +
          "sed -n '1,200p' \"$hits\" >&2 || true; " +
          "exit 1; " +
        "fi; " +
        "echo \"verify_backend_compile_name_canonical ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendDevTrackOnly(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_dev_track_only] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_dev_track_only\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_dev_track_only.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_dev_track_only.snapshot.env\"; " +
        "tool=\"artifacts/tooling_cmd/cheng_tooling\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_dev_track_only] missing canonical tooling binary: $tool\" >&2; " +
            "echo \"hint: cheng_tooling build-global --out:artifacts/tooling_cmd/cheng_tooling --linker:self\" >&2; " +
            "exit 1; " +
        "fi; " +
        "fixture=\"tests/cheng/backend/fixtures/return_i64.cheng\"; " +
        "if [ ! -f \"$fixture\" ]; then fixture=\"tests/cheng/backend/fixtures/return_add.cheng\"; fi; " +
        "if [ ! -f \"$fixture\" ]; then " +
            "echo \"[verify_backend_dev_track_only] missing fixture\" >&2; exit 2; " +
        "fi; " +
        "set +e; " +
        "\"$tool\" cheng --release --in:\"$fixture\" >\"$out_dir/cheng_release.log\" 2>&1; rc_cheng_release=\"$?\"; " +
        "BACKEND_BUILD_TRACK=release \"$tool\" cheng --in:\"$fixture\" >\"$out_dir/cheng_env_release.log\" 2>&1; rc_cheng_env_release=\"$?\"; " +
        "BACKEND_LINKER=self \"$tool\" cheng --in:\"$fixture\" >\"$out_dir/cheng_env_linker.log\" 2>&1; rc_cheng_env_linker=\"$?\"; " +
        "BACKEND_LINKER=system \"$tool\" release-compile --in:\"$fixture\" >\"$out_dir/release_env_linker.log\" 2>&1; rc_release_env_linker=\"$?\"; " +
        "\"$tool\" compile --in:\"$fixture\" >\"$out_dir/compile_alias.log\" 2>&1; rc_compile_alias=\"$?\"; " +
        "\"$tool\" chengc --in:\"$fixture\" >\"$out_dir/chengc_alias.log\" 2>&1; rc_chengc_alias=\"$?\"; " +
        "set -e; " +
        "if [ \"$rc_cheng_release\" -ne 2 ]; then " +
            "echo \"[verify_backend_dev_track_only] cheng --release should fail rc=2, got rc=$rc_cheng_release\" >&2; " +
            "tail -n 80 \"$out_dir/cheng_release.log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$rc_cheng_env_release\" -ne 2 ]; then " +
            "echo \"[verify_backend_dev_track_only] env BACKEND_BUILD_TRACK=release cheng should fail rc=2, got rc=$rc_cheng_env_release\" >&2; " +
            "tail -n 80 \"$out_dir/cheng_env_release.log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$rc_cheng_env_linker\" -ne 2 ]; then " +
            "echo \"[verify_backend_dev_track_only] env BACKEND_LINKER=self cheng should fail rc=2, got rc=$rc_cheng_env_linker\" >&2; " +
            "tail -n 80 \"$out_dir/cheng_env_linker.log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$rc_release_env_linker\" -ne 2 ]; then " +
            "echo \"[verify_backend_dev_track_only] env BACKEND_LINKER=system release-compile should fail rc=2, got rc=$rc_release_env_linker\" >&2; " +
            "tail -n 80 \"$out_dir/release_env_linker.log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$rc_compile_alias\" -ne 2 ]; then " +
            "echo \"[verify_backend_dev_track_only] compile alias should fail rc=2, got rc=$rc_compile_alias\" >&2; " +
            "tail -n 80 \"$out_dir/compile_alias.log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$rc_chengc_alias\" -ne 2 ]; then " +
            "echo \"[verify_backend_dev_track_only] chengc alias should fail rc=2, got rc=$rc_chengc_alias\" >&2; " +
            "tail -n 80 \"$out_dir/chengc_alias.log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "closure_fn=\"$out_dir/backend_prod_closure.func.txt\"; " +
        "awk '/^fn tooling_cmdBackendProdClosureFromArgs\\(/{f=1} f{print} /^fn tooling_cmdBackendProdPublishFromArgs\\(/{if(f){exit}}' " +
            "src/tooling/cheng_tooling.cheng >\"$closure_fn\"; " +
        "if [ ! -s \"$closure_fn\" ]; then " +
            "echo \"[verify_backend_dev_track_only] failed to extract backend_prod_closure function body\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if rg -q 'verify_backend_release_c_o3_lto|backend_release_manifest|backend_release_bundle|backend_release_sign|backend_release_verify|backend_release_publish' \"$closure_fn\"; then " +
            "echo \"[verify_backend_dev_track_only] backend_prod_closure must not include release/publish tail\" >&2; " +
            "exit 1; " +
        "fi; " +
        "toolbin_fn=\"$out_dir/backend_prod_toolbin.func.txt\"; " +
        "awk '/^fn tooling_cmdBackendProdToolBin\\(/{f=1} f{print} /^fn tooling_cmdBackendProdRunGate\\(/{if(f){exit}}' " +
            "src/tooling/cheng_tooling.cheng >\"$toolbin_fn\"; " +
        "if [ ! -s \"$toolbin_fn\" ]; then " +
            "echo \"[verify_backend_dev_track_only] failed to extract tooling_cmdBackendProdToolBin function body\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if ! rg -q 'artifacts/tooling_cmd/cheng_tooling' \"$toolbin_fn\"; then " +
            "echo \"[verify_backend_dev_track_only] backend_prod tool path must be canonical artifacts/tooling_cmd/cheng_tooling\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if ! rg -q 'BACKEND_PROD_ALLOW_NONCANONICAL_TOOL_BIN' \"$toolbin_fn\"; then " +
            "echo \"[verify_backend_dev_track_only] missing explicit emergency fallback toggle BACKEND_PROD_ALLOW_NONCANONICAL_TOOL_BIN\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if ! rg -q '\"0\"' \"$toolbin_fn\"; then " +
            "echo \"[verify_backend_dev_track_only] emergency fallback toggle must default to 0\" >&2; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"verify_backend_dev_track_only report\"; " +
            "echo \"status=ok\"; " +
            "echo \"tool=$tool\"; " +
            "echo \"cheng_release_rc=$rc_cheng_release\"; " +
            "echo \"cheng_env_release_rc=$rc_cheng_env_release\"; " +
            "echo \"cheng_env_linker_rc=$rc_cheng_env_linker\"; " +
            "echo \"release_env_linker_rc=$rc_release_env_linker\"; " +
            "echo \"compile_alias_rc=$rc_compile_alias\"; " +
            "echo \"chengc_alias_rc=$rc_chengc_alias\"; " +
            "echo \"closure_fn=$closure_fn\"; " +
            "echo \"toolbin_fn=$toolbin_fn\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_dev_track_only_status=ok\"; " +
            "echo \"backend_dev_track_only_report=$report\"; " +
            "echo \"backend_dev_track_only_cheng_env_linker_rc=$rc_cheng_env_linker\"; " +
            "echo \"backend_dev_track_only_release_env_linker_rc=$rc_release_env_linker\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_dev_track_only ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendLoopRuntime(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_loop_runtime] rg is required\" >&2; exit 2; " +
        "fi; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_loop_runtime] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "driver=\"${BACKEND_DRIVER:-}\"; " +
        "if [ \"$driver\" = \"\" ]; then driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r')\"; fi; " +
        "if [ ! -x \"$driver\" ]; then " +
            "echo \"[verify_backend_loop_runtime] backend driver not executable: $driver\" >&2; exit 1; " +
        "fi; " +
        "out_dir=\"artifacts/backend_loop_runtime\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_loop_runtime.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_loop_runtime.snapshot.env\"; " +
        "matrix=\"$out_dir/loop_runtime.matrix.tsv\"; " +
        ": >\"$matrix\"; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "fixtures=\"${BACKEND_LOOP_RUNTIME_FIXTURES:-tests/cheng/backend/fixtures/return_while_sum.cheng tests/cheng/backend/fixtures/return_for_sum.cheng}\"; " +
        "if [ \"$fixtures\" = \"\" ]; then " +
            "echo \"[verify_backend_loop_runtime] empty fixture list\" >&2; exit 2; " +
        "fi; " +
        "for fixture in $fixtures; do " +
            "if [ ! -f \"$fixture\" ]; then " +
                "echo \"[verify_backend_loop_runtime] missing fixture: $fixture\" >&2; exit 2; " +
            "fi; " +
            "name=\"$(basename \"$fixture\" .cheng)\"; " +
            "base_bin=\"$out_dir/${name}.opt0\"; " +
            "opt_bin=\"$out_dir/${name}.opt1\"; " +
            "base_log=\"$out_dir/${name}.opt0.compile.log\"; " +
            "opt_log=\"$out_dir/${name}.opt1.compile.log\"; " +
            "set +e; " +
            "env BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_TARGET=\"$target\" BACKEND_BUILD_TRACK=dev BACKEND_OPT=1 BACKEND_OPT_LEVEL=0 BACKEND_OPT2=0 BACKEND_VALIDATE=0 BACKEND_EMIT=exe BACKEND_LINKER=self BACKEND_DIRECT_EXE=1 BACKEND_LINKERLESS_INMEM=1 BACKEND_NO_RUNTIME_C=1 BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_ALLOW_NO_MAIN=0 BACKEND_INCREMENTAL=0 MM=orc BACKEND_CACHE=0 STAGE1_AUTO_SYSTEM=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict UIR_EGRAPH_ITERS=0 BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$base_bin\" " +
                "\"$driver\" >\"$base_log\" 2>&1; " +
            "rc_compile_base=\"$?\"; " +
            "set -e; " +
            "if [ \"$rc_compile_base\" -ne 0 ] || [ ! -x \"$base_bin\" ]; then " +
                "echo \"[verify_backend_loop_runtime] opt0 compile failed: $fixture\" >&2; " +
                "tail -n 120 \"$base_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "set +e; \"$base_bin\" >/dev/null 2>&1; rc_base=\"$?\"; set -e; " +
            "set +e; " +
            "env BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_TARGET=\"$target\" BACKEND_BUILD_TRACK=dev BACKEND_OPT=1 BACKEND_OPT_LEVEL=1 BACKEND_OPT2=0 BACKEND_VALIDATE=0 BACKEND_EMIT=exe BACKEND_LINKER=self BACKEND_DIRECT_EXE=1 BACKEND_LINKERLESS_INMEM=1 BACKEND_NO_RUNTIME_C=1 BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_ALLOW_NO_MAIN=0 BACKEND_INCREMENTAL=0 MM=orc BACKEND_CACHE=0 STAGE1_AUTO_SYSTEM=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict UIR_EGRAPH_ITERS=0 BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$opt_bin\" " +
                "\"$driver\" >\"$opt_log\" 2>&1; " +
            "rc_compile_opt=\"$?\"; " +
            "set -e; " +
            "if [ \"$rc_compile_opt\" -ne 0 ] || [ ! -x \"$opt_bin\" ]; then " +
                "echo \"[verify_backend_loop_runtime] opt1 compile failed: $fixture\" >&2; " +
                "tail -n 120 \"$opt_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "set +e; \"$opt_bin\" >/dev/null 2>&1; rc_opt=\"$?\"; set -e; " +
            "printf '%s\\t%s\\t%s\\n' \"$name\" \"$rc_base\" \"$rc_opt\" >>\"$matrix\"; " +
            "if [ \"$rc_base\" -ne \"$rc_opt\" ]; then " +
                "echo \"[verify_backend_loop_runtime] runtime mismatch fixture=$fixture opt0_rc=$rc_base opt1_rc=$rc_opt\" >&2; " +
                "exit 1; " +
            "fi; " +
        "done; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"target=$target\"; " +
            "echo \"comparison=opt0_vs_opt1\"; " +
            "echo \"fixtures=$fixtures\"; " +
            "echo \"matrix=$matrix\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_loop_runtime_status=ok\"; " +
            "echo \"backend_loop_runtime_target=$target\"; " +
            "echo \"backend_loop_runtime_matrix=$matrix\"; " +
            "echo \"backend_loop_runtime_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_loop_runtime ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendSymbolClosure(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_symbol_closure] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "out_dir=\"artifacts/backend_symbol_closure\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_symbol_closure.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_symbol_closure.snapshot.env\"; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "fixtures=\"tests/cheng/backend/fixtures/return_add.cheng tests/cheng/backend/fixtures/return_new_ref_seq_growth.cheng\"; " +
        "if [ \"${BACKEND_SYMBOL_CLOSURE_INCLUDE_NEW_EXPR:-0}\" = \"1\" ]; then " +
            "fixtures=\"$fixtures tests/cheng/backend/fixtures/return_new_expr_generic_box.cheng\"; " +
        "fi; " +
        "runtime_non_symbol_fail_count=0; " +
        "for fixture in $fixtures; do " +
            "if [ ! -f \"$fixture\" ]; then " +
                "echo \"[verify_backend_symbol_closure] missing fixture: $fixture\" >&2; exit 2; " +
            "fi; " +
            "name=\"$(basename \"$fixture\" .cheng)\"; " +
            "exe=\"$out_dir/${name}.dev\"; " +
            "compile_log=\"$out_dir/${name}.compile.log\"; " +
            "run_log=\"$out_dir/${name}.run.log\"; " +
            "nm_log=\"$out_dir/${name}.nm.log\"; " +
            "set +e; " +
            "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER \"$tool\" cheng --target:\"$target\" --in:\"$fixture\" --out:\"$exe\" >\"$compile_log\" 2>&1; " +
            "compile_rc=\"$?\"; " +
            "set -e; " +
            "if [ \"$compile_rc\" -ne 0 ] || [ ! -x \"$exe\" ]; then " +
                "echo \"[verify_backend_symbol_closure] compile failed: $fixture\" >&2; " +
                "tail -n 120 \"$compile_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "if command -v nm >/dev/null 2>&1; then " +
                "nm \"$exe\" >\"$nm_log\" 2>/dev/null || true; " +
                "if rg -q -e '[[:space:]][Uu][[:space:]]+_?(alloc|c_strlen|zeroMem|cheng_realloc)(@.*)?$' \"$nm_log\"; then " +
                    "echo \"[verify_backend_symbol_closure] unresolved runtime symbol in binary: $fixture\" >&2; " +
                    "sed -n '1,120p' \"$nm_log\" >&2 || true; " +
                    "exit 1; " +
                "fi; " +
            "fi; " +
            "set +e; \"$exe\" >\"$run_log\" 2>&1; run_rc=\"$?\"; set -e; " +
            "if [ \"$run_rc\" -ne 0 ]; then " +
                "if rg -n \"Symbol not found: _?(alloc|c_strlen|zeroMem|cheng_realloc)\" \"$run_log\" >/dev/null 2>&1; then " +
                    "echo \"[verify_backend_symbol_closure] unresolved runtime symbol in run log: $fixture\" >&2; " +
                    "cat \"$run_log\" >&2 || true; " +
                    "exit 1; " +
                "fi; " +
                "runtime_non_symbol_fail_count=$((runtime_non_symbol_fail_count + 1)); " +
            "fi; " +
            "if rg -n \"Symbol not found: _?(alloc|c_strlen|zeroMem|cheng_realloc)\" \"$run_log\" >/dev/null 2>&1; then " +
                "echo \"[verify_backend_symbol_closure] unresolved runtime symbol in run log: $fixture\" >&2; " +
                "cat \"$run_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
        "done; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"target=$target\"; " +
            "echo \"runtime_non_symbol_fail_count=$runtime_non_symbol_fail_count\"; " +
            "echo \"report=$report\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_symbol_closure_status=ok\"; " +
            "echo \"backend_symbol_closure_target=$target\"; " +
            "echo \"backend_symbol_closure_runtime_non_symbol_fail_count=$runtime_non_symbol_fail_count\"; " +
            "echo \"backend_symbol_closure_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_symbol_closure ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendNewExprRefStability(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_new_expr_ref_stability] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "fixture=\"tests/cheng/backend/fixtures/return_new_expr_generic_box.cheng\"; " +
        "if [ ! -f \"$fixture\" ]; then " +
            "echo \"[verify_backend_new_expr_ref_stability] missing fixture: $fixture\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_new_expr_ref_stability\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_new_expr_ref_stability.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_new_expr_ref_stability.snapshot.env\"; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "exe=\"$out_dir/return_new_expr_generic_box.rel\"; " +
        "compile_log=\"$out_dir/return_new_expr_generic_box.compile.log\"; " +
        "run_log=\"$out_dir/return_new_expr_generic_box.run.log\"; " +
        "set +e; " +
        "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER \"$tool\" release-compile --target:\"$target\" --in:\"$fixture\" --out:\"$exe\" >\"$compile_log\" 2>&1; " +
        "compile_rc=\"$?\"; " +
        "set -e; " +
        "if [ \"$compile_rc\" -ne 0 ] || [ ! -x \"$exe\" ]; then " +
            "echo \"[verify_backend_new_expr_ref_stability] compile failed rc=$compile_rc\" >&2; " +
            "tail -n 120 \"$compile_log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "set +e; \"$exe\" >\"$run_log\" 2>&1; run_rc=\"$?\"; set -e; " +
        "if [ \"$run_rc\" -ne 0 ]; then " +
            "echo \"[verify_backend_new_expr_ref_stability] run failed rc=$run_rc\" >&2; " +
            "tail -n 120 \"$run_log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"fixture=$fixture\"; " +
            "echo \"target=$target\"; " +
            "echo \"track=release\"; " +
            "echo \"report=$report\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_new_expr_ref_stability_status=ok\"; " +
            "echo \"backend_new_expr_ref_stability_fixture=$fixture\"; " +
            "echo \"backend_new_expr_ref_stability_target=$target\"; " +
            "echo \"backend_new_expr_ref_stability_track=release\"; " +
            "echo \"backend_new_expr_ref_stability_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_new_expr_ref_stability ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendReleaseCompileStability(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_release_compile_stability] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "repo_root=\"$(pwd)\"; " +
        "fixture_rel=\"${BACKEND_RELEASE_COMPILE_STABILITY_FIXTURE:-tests/cheng/backend/fixtures/return_new_ref_seq_growth.cheng}\"; " +
        "fixture=\"$repo_root/$fixture_rel\"; " +
        "if [ ! -f \"$fixture\" ]; then " +
            "fallback_rel=\"tests/cheng/backend/fixtures/return_add.cheng\"; " +
            "fixture=\"$repo_root/$fallback_rel\"; " +
            "if [ ! -f \"$fixture\" ]; then " +
                "echo \"[verify_backend_release_compile_stability] missing fixture: $repo_root/$fixture_rel (fallback also missing: $fixture)\" >&2; exit 2; " +
            "fi; " +
        "fi; " +
        "iters_default=\"${BACKEND_RELEASE_COMPILE_STABILITY_ITERS_DEFAULT:-3}\"; " +
        "case \"$iters_default\" in ''|*[!0-9]*) iters_default=3 ;; esac; " +
        "iters=\"${BACKEND_RELEASE_COMPILE_STABILITY_ITERS:-$iters_default}\"; " +
        "case \"$iters\" in ''|*[!0-9]*) iters=$iters_default ;; esac; " +
        "if [ \"$iters\" -lt 1 ]; then iters=1; fi; " +
        "out_dir=\"$repo_root/artifacts/backend_release_compile_stability\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_release_compile_stability.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_release_compile_stability.snapshot.env\"; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "ok_count=0; fail_count=0; segfault_count=0; " +
        "i=1; " +
        "while [ \"$i\" -le \"$iters\" ]; do " +
            "exe=\"$out_dir/new_ref.rel.$i\"; " +
            "compile_log=\"$out_dir/new_ref.rel.$i.compile.log\"; " +
            "run_log=\"$out_dir/new_ref.rel.$i.run.log\"; " +
            "compile_cmd=\"env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER \\\"$tool\\\" release-compile --target:\\\"$target\\\" --in:\\\"$fixture\\\" --out:\\\"$exe\\\"\"; " +
            "set +e; " +
            "sh -c \"$compile_cmd\" >\"$compile_log\" 2>&1; " +
            "compile_rc=\"$?\"; " +
            "if [ \"$compile_rc\" -eq 124 ] || [ \"$compile_rc\" -eq 137 ] || [ \"$compile_rc\" -eq 143 ] || [ \"$compile_rc\" -eq 138 ] || [ \"$compile_rc\" -eq 139 ]; then " +
                "sh -c \"$compile_cmd\" >>\"$compile_log\" 2>&1; " +
                "compile_rc=\"$?\"; " +
            "fi; " +
            "set -e; " +
            "if [ \"$compile_rc\" -ne 0 ] || [ ! -x \"$exe\" ]; then " +
                "fail_count=$((fail_count + 1)); " +
                "if [ \"$compile_rc\" -eq 139 ] || [ \"$compile_rc\" -eq 138 ]; then segfault_count=$((segfault_count + 1)); fi; " +
                "echo \"[verify_backend_release_compile_stability] compile failed iter=$i rc=$compile_rc\" >&2; " +
                "tail -n 80 \"$compile_log\" >&2 || true; " +
                "i=$((i + 1)); " +
                "continue; " +
            "fi; " +
            "set +e; \"$exe\" >\"$run_log\" 2>&1; run_rc=\"$?\"; set -e; " +
            "if [ \"$run_rc\" -ne 0 ]; then " +
                "fail_count=$((fail_count + 1)); " +
                "echo \"[verify_backend_release_compile_stability] run failed iter=$i rc=$run_rc\" >&2; " +
                "tail -n 80 \"$run_log\" >&2 || true; " +
            "else " +
                "ok_count=$((ok_count + 1)); " +
            "fi; " +
            "i=$((i + 1)); " +
        "done; " +
        "status=\"ok\"; " +
        "if [ \"$fail_count\" -ne 0 ] || [ \"$segfault_count\" -ne 0 ] || [ \"$ok_count\" -ne \"$iters\" ]; then status=\"failed\"; fi; " +
        "{ " +
            "echo \"status=$status\"; " +
            "echo \"iters=$iters\"; " +
            "echo \"ok_count=$ok_count\"; " +
            "echo \"fail_count=$fail_count\"; " +
            "echo \"segfault_count=$segfault_count\"; " +
            "echo \"target=$target\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_release_compile_stability_status=$status\"; " +
            "echo \"backend_release_compile_stability_iters=$iters\"; " +
            "echo \"backend_release_compile_stability_ok_count=$ok_count\"; " +
            "echo \"backend_release_compile_stability_fail_count=$fail_count\"; " +
            "echo \"backend_release_compile_stability_segfault_count=$segfault_count\"; " +
            "echo \"backend_release_compile_stability_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$status\" != \"ok\" ]; then " +
            "echo \"[verify_backend_release_compile_stability] failed\" >&2; " +
            "exit 1; " +
        "fi; " +
        "echo \"verify_backend_release_compile_stability ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyToolingCmdline(root: str): int32 =
    let outDir: str = tooling_pathAbsolute(root, "artifacts/tooling_cmdline")
    let listOut: str = os.joinPath(outDir, "tooling_cmdline.list.txt")
    let helpOut: str = os.joinPath(outDir, "tooling_cmdline.backend_prod_closure.help.txt")
    let helpOutMulticall: str = os.joinPath(outDir, "tooling_cmdline.backend_prod_closure.multicall.help.txt")
    let installDir: str = os.joinPath(outDir, "bin")
    let installManifest: str = os.joinPath(outDir, "tooling_cmdline.install_manifest.tsv")
    let installStdout: str = os.joinPath(outDir, "tooling_cmdline.install.stdout.txt")
    let reportPath: str = os.joinPath(outDir, "tooling_cmdline.report.txt")
    if tooling_pathExists(outDir):
        let rmRes: os.ExecCmdResult = tooling_exec(root, "rm -rf " + tooling_shellQuote(outDir))
        if os.execCmdResultExitCode(rmRes) != 0:
            tooling_printErr("[verify_tooling_cmdline] failed to cleanup output dir: " + outDir)
            tooling_printExecOutput(rmRes)
            return 1
    if !tooling_mkdirP(root, outDir):
        tooling_printErr("[verify_tooling_cmdline] failed to create output dir: " + outDir)
        return 1

    let tool: str = tooling_pathAbsolute(root, os.getEnvDefault("TOOLING_SELF_BIN", "artifacts/tooling_cmd/cheng_tooling"))
    if !tooling_isExecutable(root, tool):
        tooling_printErr("[verify_tooling_cmdline] missing tooling binary: " + tool)
        return 1

    var globalBin: str = tooling_pathAbsolute(root, os.getEnvDefault("TOOLING_GLOBAL_BIN", "artifacts/tooling_cmd/cheng_tooling"))
    if !tooling_isExecutable(root, globalBin):
        globalBin = tool
    if !tooling_isExecutable(root, globalBin):
        tooling_printErr("[verify_tooling_cmdline] missing runnable global tool binary: " + globalBin)
        return 1

    let listCmd: str =
        "set -eu; " +
        "TOOLING_FORCE_BUILD=1 TOOLING_LINKER=system " + tooling_shellQuote(tool) +
        " list >" + tooling_shellQuote(listOut) + "; " +
        "for id in backend_prod_closure verify_backend_closedloop chengc verify_tooling_cmdline; do " +
            "if ! rg -qx \"$id\" " + tooling_shellQuote(listOut) + "; then " +
                "echo \"[verify_tooling_cmdline] missing id in list output: $id\" >&2; exit 1; " +
            "fi; " +
        "done"
    let listRes: os.ExecCmdResult = tooling_exec(root, listCmd)
    tooling_printExecOutput(listRes)
    if os.execCmdResultExitCode(listRes) != 0:
        return 1

    let helpCmd: str =
        "set -eu; " +
        "TOOLING_LINKER=system " + tooling_shellQuote(tool) +
        " backend_prod_closure --help >" + tooling_shellQuote(helpOut) + "; " +
        "if ! rg -q 'Usage:' " + tooling_shellQuote(helpOut) + "; then " +
            "echo \"[verify_tooling_cmdline] backend_prod_closure help text missing\" >&2; exit 1; " +
        "fi"
    let helpRes: os.ExecCmdResult = tooling_exec(root, helpCmd)
    tooling_printExecOutput(helpRes)
    if os.execCmdResultExitCode(helpRes) != 0:
        return 1

    let installCmd: str =
        "set -eu; " +
        tooling_shellQuote(globalBin) +
        " list >/dev/null; " +
        tooling_shellQuote(globalBin) + " install --dir:" + tooling_shellQuote(installDir) +
        " --bin:" + tooling_shellQuote(globalBin) +
        " --manifest:" + tooling_shellQuote(installManifest) +
        " --force >" + tooling_shellQuote(installStdout) + "; " +
        "if [ ! -s " + tooling_shellQuote(installManifest) + " ]; then " +
            "printf 'name\\tlink\\n' >" + tooling_shellQuote(installManifest) + "; " +
            "for p in " + tooling_shellQuote(installDir) + "/*; do " +
                "[ -x \"$p\" ] || continue; " +
                "name=\"$(basename \"$p\")\"; " +
                "printf '%s\\t%s\\n' \"$name\" \"$p\" >>" + tooling_shellQuote(installManifest) + "; " +
            "done; " +
        "fi; " +
        "for link in backend_prod_closure verify_backend_closedloop cheng_tooling; do " +
            "if [ ! -x " + tooling_shellQuote(installDir) + "/$link ]; then " +
                "echo \"[verify_tooling_cmdline] missing multicall link: " + installDir + "/$link\" >&2; exit 1; " +
            "fi; " +
        "done; " +
        "if ! rg -q '^backend_prod_closure\\t' " + tooling_shellQuote(installManifest) + "; then " +
            "echo \"[verify_tooling_cmdline] install manifest missing backend_prod_closure entry\" >&2; exit 1; " +
        "fi"
    let installRes: os.ExecCmdResult = tooling_exec(root, installCmd)
    tooling_printExecOutput(installRes)
    if os.execCmdResultExitCode(installRes) != 0:
        return 1

    let multicallHelpCmd: str =
        "set -eu; " +
        tooling_shellQuote(os.joinPath(installDir, "backend_prod_closure")) +
        " --help >" + tooling_shellQuote(helpOutMulticall) + "; " +
        "if ! rg -q 'Usage:' " + tooling_shellQuote(helpOutMulticall) + "; then " +
            "echo \"[verify_tooling_cmdline] multicall backend_prod_closure help text missing\" >&2; exit 1; " +
        "fi"
    let multicallHelpRes: os.ExecCmdResult = tooling_exec(root, multicallHelpCmd)
    tooling_printExecOutput(multicallHelpRes)
    if os.execCmdResultExitCode(multicallHelpRes) != 0:
        return 1

    os.writeFile(reportPath,
                 "tooling_cmdline_runner=ok\n" +
                 "list_output=" + listOut + "\n" +
                 "help_output=" + helpOut + "\n" +
                 "help_output_multicall=" + helpOutMulticall + "\n" +
                 "global_bin=" + globalBin + "\n" +
                 "install_dir=" + installDir + "\n" +
                 "install_manifest=" + installManifest + "\n" +
                 "install_stdout=" + installStdout + "\n")
    tooling_printOut("verify_tooling_cmdline ok")
    return 0

fn tooling_cmdVerifyBackendZeroScriptResidual(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_zero_script_residual] rg is required\" >&2; exit 2; " +
        "fi; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_zero_script_residual] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "out_dir=\"artifacts/backend_zero_script_residual\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_zero_script_residual.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_zero_script_residual.snapshot.env\"; " +
        "sh_count=\"$(rg --files src/tooling | rg '\\\\.sh$' | wc -l | tr -d ' ')\"; " +
        "if [ \"$sh_count\" != \"0\" ]; then " +
            "echo \"[verify_backend_zero_script_residual] unexpected shell files under src/tooling\" >&2; " +
            "rg --files src/tooling | rg '\\\\.sh$' >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "legacy_read_count=\"$(rg -n 'getEnvDefault\\(\"CHENG_|getEnv\\(\"CHENG_' src/tooling/cheng_tooling.cheng src/backend/tooling/backend_driver.cheng | wc -l | tr -d ' ')\"; " +
        "if [ \"$legacy_read_count\" != \"0\" ]; then " +
            "echo \"[verify_backend_zero_script_residual] legacy CHENG_* env reads still present\" >&2; " +
            "rg -n 'getEnvDefault\\(\"CHENG_|getEnv\\(\"CHENG_' src/tooling/cheng_tooling.cheng src/backend/tooling/backend_driver.cheng >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "if ! \"$tool\" backend_prod_closure --help | rg -q 'native gate runner'; then " +
            "echo \"[verify_backend_zero_script_residual] backend_prod_closure help no longer declares native gate runner\" >&2; " +
            "exit 1; " +
        "fi; " +
        "closure_fn=\"$out_dir/backend_prod_closure.func.txt\"; " +
        "awk '/^fn tooling_cmdBackendProdClosureFromArgs\\(/{f=1} f{print} /^fn tooling_cmdBackendProdPublishFromArgs\\(/{if(f){exit}}' " +
            "src/tooling/cheng_tooling.cheng >\"$closure_fn\"; " +
        "if [ ! -s \"$closure_fn\" ]; then " +
            "echo \"[verify_backend_zero_script_residual] failed to extract backend_prod_closure function\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if rg -n 'compile-only|status=skip| skip:' \"$closure_fn\" >/dev/null 2>&1; then " +
            "echo \"[verify_backend_zero_script_residual] required closure path still contains compile-only/skip semantics\" >&2; " +
            "rg -n 'compile-only|status=skip| skip:' \"$closure_fn\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "if rg -n 'tooling_embedded|embedded_inline' \"$closure_fn\" >/dev/null 2>&1; then " +
            "echo \"[verify_backend_zero_script_residual] required closure path still references embedded inline payload\" >&2; " +
            "rg -n 'tooling_embedded|embedded_inline' \"$closure_fn\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "required_ids=\"verify_backend_mem_exe_emit verify_backend_hotpatch verify_backend_hotpatch_meta verify_backend_mem_patch_regression verify_backend_incr_patch_fastpath verify_backend_hotpatch_inplace\"; " +
        "required_embedded_checked=0; required_embedded_fail_count=0; " +
        "required_embedded_fail_list=\"$out_dir/required_embedded_failures.txt\"; : >\"$required_embedded_fail_list\"; " +
        "for required_id in $required_ids; do " +
            "required_embedded_checked=$((required_embedded_checked + 1)); " +
            "required_body=\"$out_dir/${required_id}.embedded.sh\"; " +
            "if ! \"$tool\" embedded-text --id:\"$required_id\" >\"$required_body\"; then " +
                "echo \"id=$required_id check=embedded_text status=missing\" >>\"$required_embedded_fail_list\"; " +
                "required_embedded_fail_count=$((required_embedded_fail_count + 1)); " +
                "continue; " +
            "fi; " +
            "chengc_hits=\"$out_dir/${required_id}.forbid_chengc.hits\"; " +
            "if rg -n '\\\\bchengc\\\\b' \"$required_body\" >\"$chengc_hits\" 2>/dev/null; then " +
                "echo \"id=$required_id check=forbid_chengc hits=$chengc_hits\" >>\"$required_embedded_fail_list\"; " +
                "required_embedded_fail_count=$((required_embedded_fail_count + 1)); " +
            "fi; " +
            "backend_driver_hits=\"$out_dir/${required_id}.forbid_backend_driver_env.hits\"; " +
            "if rg -n 'BACKEND_DRIVER=' \"$required_body\" >\"$backend_driver_hits\" 2>/dev/null; then " +
                "echo \"id=$required_id check=forbid_backend_driver_env hits=$backend_driver_hits\" >>\"$required_embedded_fail_list\"; " +
                "required_embedded_fail_count=$((required_embedded_fail_count + 1)); " +
            "fi; " +
        "done; " +
        "if [ \"$required_embedded_fail_count\" != \"0\" ]; then " +
            "echo \"[verify_backend_zero_script_residual] required embedded payload residual detected\" >&2; " +
            "cat \"$required_embedded_fail_list\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"sh_count=$sh_count\"; " +
            "echo \"legacy_read_count=$legacy_read_count\"; " +
            "echo \"closure_fn=$closure_fn\"; " +
            "echo \"required_embedded_checked=$required_embedded_checked\"; " +
            "echo \"required_embedded_fail_count=$required_embedded_fail_count\"; " +
            "echo \"required_embedded_fail_list=$required_embedded_fail_list\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_zero_script_residual_status=ok\"; " +
            "echo \"backend_zero_script_residual_sh_count=$sh_count\"; " +
            "echo \"backend_zero_script_residual_legacy_read_count=$legacy_read_count\"; " +
            "echo \"backend_zero_script_residual_closure_fn=$closure_fn\"; " +
            "echo \"backend_zero_script_residual_required_embedded_checked=$required_embedded_checked\"; " +
            "echo \"backend_zero_script_residual_required_embedded_fail_count=$required_embedded_fail_count\"; " +
            "echo \"backend_zero_script_residual_required_embedded_fail_list=$required_embedded_fail_list\"; " +
            "echo \"backend_zero_script_residual_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_zero_script_residual ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendEmitCSurface(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_emit_c_surface] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "fixture=\"tests/cheng/backend/fixtures/ffi_importc_slice_seq_i32.cheng\"; " +
        "if [ ! -f \"$fixture\" ]; then " +
            "echo \"[verify_backend_emit_c_surface] missing fixture: $fixture\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_emit_c_surface\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_emit_c_surface.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_emit_c_surface.snapshot.env\"; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "out_c=\"$out_dir/ffi_slice.c\"; " +
        "log=\"$out_dir/ffi_slice.compile.log\"; " +
        "mode=\"runtime\"; " +
        "set +e; " +
        "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER \"$tool\" cheng --emit:c --target:\"$target\" --in:\"$fixture\" --out:\"$out_c\" >\"$log\" 2>&1; " +
        "rc=\"$?\"; " +
        "set -e; " +
        "if [ \"$rc\" -ne 0 ] || [ ! -s \"$out_c\" ]; then " +
            "if rg -q 'invalid emit mode .*: c' \"$log\"; then " +
                "if [ \"${BACKEND_EMIT_C_STRICT_RUNTIME_REPORT:-0}\" = \"1\" ]; then " +
                    "echo \"[verify_backend_emit_c_surface] emit:c runtime report required but driver lacks emit:c\" >&2; " +
                    "tail -n 120 \"$log\" >&2 || true; " +
                    "exit 1; " +
                "fi; " +
                "mode=\"source_fallback\"; " +
                "echo \"[verify_backend_emit_c_surface] warn: runtime emit:c unsupported, fallback to source-surface proof\" >&2; " +
                "if ! rg -q 'invalid emit mode \\(expected exe\\|c\\):' src/backend/tooling/backend_driver.cheng; then " +
                    "echo \"[verify_backend_emit_c_surface] missing emit:c driver surface marker\" >&2; " +
                    "exit 1; " +
                "fi; " +
                "if ! rg -qF '#include <stdint.h>' src/backend/c/c_emitter_main.cheng; then " +
                    "echo \"[verify_backend_emit_c_surface] missing stdint marker in emitter source\" >&2; " +
                    "exit 1; " +
                "fi; " +
                "if ! rg -q 'extern ' src/backend/c/c_emitter_func.cheng; then " +
                    "echo \"[verify_backend_emit_c_surface] missing extern marker in emitter source\" >&2; " +
                    "exit 1; " +
                "fi; " +
                "if ! rg -q '@importc\\(\"cheng_abi_sum_seq_i32\"\\)' \"$fixture\"; then " +
                    "echo \"[verify_backend_emit_c_surface] missing fixture importc marker\" >&2; " +
                    "exit 1; " +
                "fi; " +
                "out_c=\"\"; " +
            "else " +
                "echo \"[verify_backend_emit_c_surface] emit:c compile failed rc=$rc\" >&2; " +
                "tail -n 120 \"$log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
        "fi; " +
        "if [ \"$mode\" = \"runtime\" ]; then " +
            "if ! rg -q '^#include <stdint.h>' \"$out_c\"; then " +
                "echo \"[verify_backend_emit_c_surface] missing stdint include in C output\" >&2; " +
                "exit 1; " +
            "fi; " +
            "if ! rg -q 'extern .*cheng_abi_sum_seq_i32' \"$out_c\"; then " +
                "echo \"[verify_backend_emit_c_surface] missing importc extern declaration\" >&2; " +
                "exit 1; " +
            "fi; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"mode=$mode\"; " +
            "echo \"fixture=$fixture\"; " +
            "echo \"target=$target\"; " +
            "echo \"out_c=$out_c\"; " +
            "echo \"log=$log\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_emit_c_surface_status=ok\"; " +
            "echo \"backend_emit_c_surface_mode=$mode\"; " +
            "echo \"backend_emit_c_surface_target=$target\"; " +
            "echo \"backend_emit_c_surface_out=$out_c\"; " +
            "echo \"backend_emit_c_surface_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_emit_c_surface ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendEmitCFfiShadow(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v cc >/dev/null 2>&1; then " +
            "echo \"[verify_backend_emit_c_ffi_shadow] missing C compiler: cc\" >&2; exit 2; " +
        "fi; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_emit_c_ffi_shadow] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "runtime_c=\"src/runtime/native/system_helpers.c\"; " +
        "if [ ! -f \"$runtime_c\" ]; then " +
            "echo \"[verify_backend_emit_c_ffi_shadow] missing runtime C file: $runtime_c\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_emit_c_ffi_shadow\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_emit_c_ffi_shadow.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_emit_c_ffi_shadow.snapshot.env\"; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "extra_ldflags=\"\"; " +
        "case \"$(uname -s 2>/dev/null || echo unknown)\" in Linux) extra_ldflags=\"-ldl\";; esac; " +
        "fixtures=\"ffi_importc_slice_seq_i32 ffi_outptr_tuple_importc_pair_i32 ffi_importc_handle_sandbox_i32 ffi_importc_borrow_mut_pair_i32\"; " +
        "mode=\"runtime\"; " +
        "for base in $fixtures; do " +
            "fixture=\"tests/cheng/backend/fixtures/${base}.cheng\"; " +
            "if [ ! -f \"$fixture\" ]; then " +
                "echo \"[verify_backend_emit_c_ffi_shadow] missing fixture: $fixture\" >&2; exit 2; " +
            "fi; " +
            "out_c=\"$out_dir/${base}.c\"; " +
            "emit_log=\"$out_dir/${base}.emit.log\"; " +
            "bin=\"$out_dir/${base}.bin\"; " +
            "cc_log=\"$out_dir/${base}.cc.log\"; " +
            "run_log=\"$out_dir/${base}.run.log\"; " +
            "set +e; " +
            "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER \"$tool\" cheng --emit:c --target:\"$target\" --in:\"$fixture\" --out:\"$out_c\" >\"$emit_log\" 2>&1; " +
            "emit_rc=\"$?\"; " +
            "set -e; " +
            "if [ \"$emit_rc\" -ne 0 ] || [ ! -s \"$out_c\" ]; then " +
                "if rg -q 'invalid emit mode .*: c' \"$emit_log\"; then " +
                    "if [ \"${BACKEND_EMIT_C_STRICT_RUNTIME_REPORT:-0}\" = \"1\" ]; then " +
                        "echo \"[verify_backend_emit_c_ffi_shadow] emit:c runtime report required but driver lacks emit:c\" >&2; " +
                        "tail -n 120 \"$emit_log\" >&2 || true; " +
                        "exit 1; " +
                    "fi; " +
                    "mode=\"source_fallback\"; " +
                    "echo \"[verify_backend_emit_c_ffi_shadow] warn: runtime emit:c unsupported, fallback to source-surface proof\" >&2; " +
                    "break; " +
                "fi; " +
                "echo \"[verify_backend_emit_c_ffi_shadow] emit:c failed base=$base rc=$emit_rc\" >&2; " +
                "tail -n 120 \"$emit_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "if [ \"$mode\" = \"source_fallback\" ]; then break; fi; " +
            "set +e; " +
            "cc -std=c11 -O2 -I src/runtime/native \"$runtime_c\" \"$out_c\" -o \"$bin\" $extra_ldflags >\"$cc_log\" 2>&1; " +
            "cc_rc=\"$?\"; " +
            "set -e; " +
            "if [ \"$cc_rc\" -ne 0 ] || [ ! -x \"$bin\" ]; then " +
                "echo \"[verify_backend_emit_c_ffi_shadow] cc failed base=$base rc=$cc_rc\" >&2; " +
                "tail -n 120 \"$cc_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "set +e; \"$bin\" >\"$run_log\" 2>&1; run_rc=\"$?\"; set -e; " +
            "if [ \"$run_rc\" -ne 0 ]; then " +
                "echo \"[verify_backend_emit_c_ffi_shadow] run failed base=$base rc=$run_rc\" >&2; " +
                "tail -n 120 \"$run_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
        "done; " +
        "if [ \"$mode\" = \"source_fallback\" ]; then " +
            "if ! rg -q 'invalid emit mode \\(expected exe\\|c\\):' src/backend/tooling/backend_driver.cheng; then " +
                "echo \"[verify_backend_emit_c_ffi_shadow] missing emit:c driver surface marker\" >&2; " +
                "exit 1; " +
            "fi; " +
            "if ! rg -qF '#include <stdint.h>' src/backend/c/c_emitter_main.cheng; then " +
                "echo \"[verify_backend_emit_c_ffi_shadow] missing stdint marker in emitter source\" >&2; " +
                "exit 1; " +
            "fi; " +
            "if ! rg -q 'extern ' src/backend/c/c_emitter_func.cheng; then " +
                "echo \"[verify_backend_emit_c_ffi_shadow] missing extern marker in emitter source\" >&2; " +
                "exit 1; " +
            "fi; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"mode=$mode\"; " +
            "echo \"target=$target\"; " +
            "echo \"fixtures=$fixtures\"; " +
            "echo \"out_dir=$out_dir\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_emit_c_ffi_shadow_status=ok\"; " +
            "echo \"backend_emit_c_ffi_shadow_mode=$mode\"; " +
            "echo \"backend_emit_c_ffi_shadow_target=$target\"; " +
            "echo \"backend_emit_c_ffi_shadow_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_emit_c_ffi_shadow ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendEmitCHardFail(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then " +
            "echo \"[verify_backend_emit_c_hard_fail] missing tooling binary: $tool\" >&2; exit 1; " +
        "fi; " +
        "fixture=\"tests/cheng/backend/fixtures/hello_importc_puts.cheng\"; " +
        "if [ ! -f \"$fixture\" ]; then " +
            "echo \"[verify_backend_emit_c_hard_fail] missing fixture: $fixture\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_emit_c_hard_fail\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_emit_c_hard_fail.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_emit_c_hard_fail.snapshot.env\"; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "out_c=\"$out_dir/hello_importc_puts.c\"; " +
        "log=\"$out_dir/hello_importc_puts.emit.log\"; " +
        "mode=\"runtime\"; " +
        "set +e; " +
        "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER \"$tool\" cheng --emit:c --target:\"$target\" --in:\"$fixture\" --out:\"$out_c\" >\"$log\" 2>&1; " +
        "rc=\"$?\"; " +
        "set -e; " +
        "if [ \"$rc\" -eq 0 ]; then " +
            "echo \"[verify_backend_emit_c_hard_fail] expected failure but command succeeded\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if rg -q 'emit-c not-mapped' \"$log\"; then " +
            "mode=\"runtime\"; " +
        "elif rg -q 'invalid emit mode .*: c' \"$log\"; then " +
            "if [ \"${BACKEND_EMIT_C_STRICT_RUNTIME_REPORT:-0}\" = \"1\" ]; then " +
                "echo \"[verify_backend_emit_c_hard_fail] runtime emit-c not-mapped diagnostic required\" >&2; " +
                "tail -n 160 \"$log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "mode=\"source_fallback\"; " +
            "echo \"[verify_backend_emit_c_hard_fail] warn: runtime emit:c unsupported, fallback to source-surface proof\" >&2; " +
            "if ! rg -q 'emit-c not-mapped:' src/backend/c/c_emitter_expr.cheng; then " +
                "echo \"[verify_backend_emit_c_hard_fail] missing emit-c not-mapped marker in expr emitter\" >&2; " +
                "exit 1; " +
            "fi; " +
            "if ! rg -q 'emit-c not-mapped:' src/backend/c/c_emitter_stmt.cheng; then " +
                "echo \"[verify_backend_emit_c_hard_fail] missing emit-c not-mapped marker in stmt emitter\" >&2; " +
                "exit 1; " +
            "fi; " +
            "if ! rg -q 'emit-c not-mapped:' src/backend/c/c_emitter_main.cheng; then " +
                "echo \"[verify_backend_emit_c_hard_fail] missing emit-c not-mapped marker in main emitter\" >&2; " +
                "exit 1; " +
            "fi; " +
        "else " +
            "echo \"[verify_backend_emit_c_hard_fail] missing emit-c not-mapped diagnostic\" >&2; " +
            "tail -n 160 \"$log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"mode=$mode\"; " +
            "echo \"target=$target\"; " +
            "echo \"fixture=$fixture\"; " +
            "echo \"rc=$rc\"; " +
            "echo \"log=$log\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_emit_c_hard_fail_status=ok\"; " +
            "echo \"backend_emit_c_hard_fail_mode=$mode\"; " +
            "echo \"backend_emit_c_hard_fail_target=$target\"; " +
            "echo \"backend_emit_c_hard_fail_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_emit_c_hard_fail ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendOpt2(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "(set -o pipefail) 2>/dev/null && set -o pipefail; " +
        "normalize_int() { " +
            "n=\"$1\"; default=\"$2\"; minv=\"$3\"; maxv=\"$4\"; " +
            "case \"$n\" in ''|*[!0-9]*) printf '%s\\n' \"$default\"; return 0 ;; esac; " +
            "if [ \"$n\" -lt \"$minv\" ]; then printf '%s\\n' \"$minv\"; return 0; fi; " +
            "if [ \"$n\" -gt \"$maxv\" ]; then printf '%s\\n' \"$maxv\"; return 0; fi; " +
            "printf '%s\\n' \"$n\"; " +
        "}; " +
        "normalize_fixture_lines() { printf '%s\\n' \"$1\" | tr ';' '\\n' | tr '\\r' '\\n' | sed -e '/^[[:space:]]*$/d'; }; " +
        "is_known_runtime_symbol_log() { " +
            "log_file=\"$1\"; " +
            "if [ ! -f \"$log_file\" ]; then return 1; fi; " +
            "if grep -q \"Symbol not found: _cheng_\" \"$log_file\"; then return 0; fi; " +
            "if grep -q \"_cheng_f32_bits_to_i64\" \"$log_file\"; then return 0; fi; " +
            "if grep -q \"_cheng_memcpy\" \"$log_file\"; then return 0; fi; " +
            "return 1; " +
        "}; " +
        "run_fixture() { " +
            "fixture=\"$1\"; " +
            "if [ ! -f \"$fixture\" ]; then echo \"[verify_backend_opt2] missing fixture: $fixture\" 1>&2; exit 2; fi; " +
            "name=\"$(basename \"$fixture\")\"; name=\"${name%.cheng}\"; exe_path=\"$out_dir/$name.opt2\"; " +
            "env $link_env $stable_env " +
                "BACKEND_OPT2=1 " +
                "BACKEND_MULTI=0 " +
                "BACKEND_MULTI_FORCE=0 " +
                "UIR_OPT2_ITERS=\"$uir_opt2_iters\" " +
                "UIR_INLINE_ITERS=\"$uir_inline_iters\" " +
                "UIR_CFG_CANON_ITERS=\"$uir_cfg_canon_iters\" " +
                "UIR_PROFILE=\"$uir_profile\" " +
                "UIR_SIMD=\"$uir_simd\" " +
                "UIR_SIMD_MAX_WIDTH=\"$uir_simd_max_width\" " +
                "UIR_SIMD_POLICY=\"$uir_simd_policy\" " +
                "BACKEND_EMIT=exe " +
                "BACKEND_TARGET=\"$target\" " +
                "BACKEND_INPUT=\"$fixture\" " +
                "BACKEND_OUTPUT=\"$exe_path\" " +
                "\"$driver\"; " +
            "if [ ! -x \"$exe_path\" ]; then echo \"[verify_backend_opt2] failed to produce executable: $exe_path\" 1>&2; exit 1; fi; " +
            "run_log=\"$out_dir/$name.opt2.run.log\"; " +
            "set +e; \"$exe_path\" >\"$run_log\" 2>&1; run_status=\"$?\"; set -e; " +
            "if [ \"$run_status\" -ne 0 ]; then " +
                "if is_known_runtime_symbol_log \"$run_log\"; then " +
                    "echo \"[verify_backend_opt2] known runtime-symbol instability (strict-no-fallback): $fixture\" 1>&2; " +
                    "cat \"$run_log\" 1>&2 || true; " +
                    "exit \"$run_status\"; " +
                "fi; " +
                "cat \"$run_log\" 1>&2 || true; " +
                "exit \"$run_status\"; " +
            "fi; " +
        "}; " +
        "if [ \"${CLEAN_CHENG_LOCAL:-1}\" = \"1\" ] && [ \"${TOOLING_CLEANUP_DEPTH:-0}\" = \"0\" ]; then " +
            "export TOOLING_CLEANUP_DEPTH=1; " +
            "cleanup_backend_driver_on_exit() { " +
                "status=$?; set +e; ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} cleanup-backend-driver-history >/dev/null 2>&1 || true; exit \"$status\"; " +
            "}; " +
            "trap cleanup_backend_driver_on_exit EXIT; " +
        "fi; " +
        "uir_opt2_iters=\"$(normalize_int \"${UIR_OPT2_ITERS:-5}\" 5 1 32)\"; " +
        "uir_inline_iters=\"$(normalize_int \"${UIR_INLINE_ITERS:-4}\" 4 1 16)\"; " +
        "uir_cfg_canon_iters=\"$(normalize_int \"${UIR_CFG_CANON_ITERS:-1}\" 1 1 16)\"; " +
        "uir_profile=\"${UIR_PROFILE:-0}\"; " +
        "uir_simd=\"${UIR_SIMD:-0}\"; " +
        "uir_simd_max_width=\"${UIR_SIMD_MAX_WIDTH:-0}\"; " +
        "uir_simd_policy=\"${UIR_SIMD_POLICY:-autovec}\"; " +
        "if [ \"$uir_simd_policy\" = \"\" ]; then uir_simd_policy=\"autovec\"; fi; " +
        "fixture_list=\"${UIR_OPT2_FIXTURES:-tests/cheng/backend/fixtures/return_opt2_inline_dce.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cse.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_sroa_deref.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_licm_while_cond.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_algebraic.cse.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_noop_dse.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_merge_jumps.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_forward_subst.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_boolret.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_const_cmp_fold.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_fold_jump_to_ret_slot.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_same_ret_expr.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_same_ret_expr_chain.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_constfold.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_mergeable.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_merge_identical_ret_blocks.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_merge_equiv_blocks.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_zero_cmp.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_same_target.cheng}\"; " +
        "driver=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_driver_path)\"; " +
        "target=\"${BACKEND_TARGET:-$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "link_env=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_link_env --driver:\"$driver\" --target:\"$target\" --linker:\"${BACKEND_LINKER:-self}\")\"; " +
        "stable_env=\"BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_TOOLING_ENTRY=1 MM=orc BACKEND_CACHE=0 STAGE1_AUTO_SYSTEM=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 BACKEND_BUILD_TRACK=release BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_ALLOW_NO_MAIN=0 BACKEND_DIRECT_EXE=0 BACKEND_LINKERLESS_INMEM=0 BACKEND_FAST_DEV_PROFILE=0 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict\"; " +
        "out_dir=\"artifacts/backend_opt2\"; mkdir -p \"$out_dir\"; " +
        "fixture_lines=\"$(normalize_fixture_lines \"$fixture_list\")\"; " +
        "while IFS= read -r fixture; do run_fixture \"$fixture\"; done <<EOF\n" +
        "$fixture_lines\n" +
        "EOF\n" +
        "echo \"verify_backend_opt2 ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendOpt3(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "(set -o pipefail) 2>/dev/null && set -o pipefail; " +
        "normalize_int() { " +
            "n=\"$1\"; default=\"$2\"; minv=\"$3\"; maxv=\"$4\"; " +
            "case \"$n\" in ''|*[!0-9]*) printf '%s\\n' \"$default\"; return 0 ;; esac; " +
            "if [ \"$n\" -lt \"$minv\" ]; then printf '%s\\n' \"$minv\"; return 0; fi; " +
            "if [ \"$n\" -gt \"$maxv\" ]; then printf '%s\\n' \"$maxv\"; return 0; fi; " +
            "printf '%s\\n' \"$n\"; " +
        "}; " +
        "normalize_fixture_lines() { printf '%s\\n' \"$1\" | tr ';' '\\n' | tr '\\r' '\\n' | sed -e '/^[[:space:]]*$/d'; }; " +
        "is_known_runtime_symbol_log() { " +
            "log_file=\"$1\"; " +
            "if [ ! -f \"$log_file\" ]; then return 1; fi; " +
            "if grep -q \"Symbol not found: _cheng_\" \"$log_file\"; then return 0; fi; " +
            "if grep -q \"_cheng_f32_bits_to_i64\" \"$log_file\"; then return 0; fi; " +
            "if grep -q \"_cheng_memcpy\" \"$log_file\"; then return 0; fi; " +
            "return 1; " +
        "}; " +
        "run_fixture() { " +
            "fixture=\"$1\"; out_name=\"$2\"; out_path=\"$out_dir/$out_name\"; " +
            "if [ \"$opt3_aggressive\" = \"1\" ]; then out_path=\"$out_dir/$(printf '%s.aggressive' \"$out_name\")\"; fi; " +
            "build_log=\"$out_path.build.log\"; " +
            "set +e; " +
            "env $link_env $stable_env $uir_aggressive_env " +
                "BACKEND_MULTI=0 " +
                "BACKEND_MULTI_FORCE=0 " +
                "BACKEND_INCREMENTAL=0 " +
                "UIR_PROFILE=\"$uir_profile\" " +
                "UIR_OPT3_ITERS=\"$uir_opt3_iters\" " +
                "UIR_OPT3_CLEANUP_ITERS=\"$uir_opt3_cleanup_iters\" " +
                "UIR_INLINE_ITERS=\"$uir_inline_iters\" " +
                "UIR_CFG_CANON_ITERS=\"$uir_cfg_canon_iters\" " +
                "UIR_SIMD=\"$uir_simd\" " +
                "UIR_SIMD_MAX_WIDTH=\"$uir_simd_max_width\" " +
                "UIR_SIMD_POLICY=\"$uir_simd_policy\" " +
                "BACKEND_OPT_LEVEL=3 " +
                "BACKEND_EMIT=exe " +
                "BACKEND_TARGET=\"$target\" " +
                "BACKEND_INPUT=\"$fixture\" " +
                "BACKEND_OUTPUT=\"$out_path\" " +
                "\"$driver\" >\"$build_log\" 2>&1; " +
            "build_status=\"$?\"; " +
            "set -e; " +
            "if [ \"$build_status\" -ne 0 ] && { [ \"$build_status\" -eq 138 ] || [ \"$build_status\" -eq 139 ]; }; then " +
                "echo \"[verify_backend_opt3] compiler crashed (rc=$build_status), retry once: $fixture\" 1>&2; " +
                "set +e; " +
                "env $link_env $stable_env $uir_aggressive_env " +
                    "BACKEND_MULTI=0 " +
                    "BACKEND_MULTI_FORCE=0 " +
                    "BACKEND_INCREMENTAL=0 " +
                    "BACKEND_JOBS=1 " +
                    "UIR_PROFILE=\"$uir_profile\" " +
                    "UIR_OPT3_ITERS=\"$uir_opt3_iters\" " +
                    "UIR_OPT3_CLEANUP_ITERS=\"$uir_opt3_cleanup_iters\" " +
                    "UIR_INLINE_ITERS=\"$uir_inline_iters\" " +
                    "UIR_CFG_CANON_ITERS=\"$uir_cfg_canon_iters\" " +
                    "UIR_SIMD=\"$uir_simd\" " +
                    "UIR_SIMD_MAX_WIDTH=\"$uir_simd_max_width\" " +
                    "UIR_SIMD_POLICY=\"$uir_simd_policy\" " +
                    "BACKEND_OPT_LEVEL=3 " +
                    "BACKEND_EMIT=exe " +
                    "BACKEND_TARGET=\"$target\" " +
                    "BACKEND_INPUT=\"$fixture\" " +
                    "BACKEND_OUTPUT=\"$out_path\" " +
                    "\"$driver\" >>\"$build_log\" 2>&1; " +
                "build_status=\"$?\"; " +
                "set -e; " +
            "fi; " +
            "if [ \"$build_status\" -ne 0 ]; then tail -n 200 \"$build_log\" 1>&2 || true; exit \"$build_status\"; fi; " +
            "if [ ! -x \"$out_path\" ]; then echo \"[Error] verify_backend_opt3: missing executable: $out_path\" 1>&2; exit 1; fi; " +
            "run_log=\"$out_path.run.log\"; set +e; \"$out_path\" >\"$run_log\" 2>&1; run_status=\"$?\"; set -e; " +
            "if [ \"$run_status\" -ne 0 ]; then " +
                "if is_known_runtime_symbol_log \"$run_log\"; then " +
                    "echo \"[verify_backend_opt3] known runtime-symbol instability (strict-no-fallback): $fixture\" 1>&2; " +
                    "cat \"$run_log\" 1>&2 || true; " +
                    "exit \"$run_status\"; " +
                "fi; " +
                "cat \"$run_log\" 1>&2 || true; " +
                "exit \"$run_status\"; " +
            "fi; " +
        "}; " +
        "run_fixture_wrapper() { " +
            "fixture=\"$1\"; " +
            "if [ ! -f \"$fixture\" ]; then echo \"[verify_backend_opt3] missing fixture: $fixture\" 1>&2; exit 2; fi; " +
            "out_name=\"$(basename \"$fixture\")\"; out_name=\"${out_name%.cheng}\"; out_name=\"${out_name}.opt3\"; " +
            "run_fixture \"$fixture\" \"$out_name\"; " +
        "}; " +
        "if [ \"${CLEAN_CHENG_LOCAL:-1}\" = \"1\" ] && [ \"${TOOLING_CLEANUP_DEPTH:-0}\" = \"0\" ]; then " +
            "export TOOLING_CLEANUP_DEPTH=1; " +
            "cleanup_backend_driver_on_exit() { " +
                "status=$?; set +e; ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} cleanup-backend-driver-history >/dev/null 2>&1 || true; exit \"$status\"; " +
            "}; " +
            "trap cleanup_backend_driver_on_exit EXIT; " +
        "fi; " +
        "driver=\"${BACKEND_DRIVER:-}\"; " +
        "if [ \"$driver\" = \"\" ]; then driver=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_driver_path)\"; fi; " +
        "target=\"${BACKEND_TARGET:-$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "link_env=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_link_env --driver:\"$driver\" --target:\"$target\" --linker:\"${BACKEND_LINKER:-self}\")\"; " +
        "stable_env=\"BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_TOOLING_ENTRY=1 MM=orc BACKEND_CACHE=0 STAGE1_AUTO_SYSTEM=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 BACKEND_BUILD_TRACK=release BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_ALLOW_NO_MAIN=0 BACKEND_DIRECT_EXE=0 BACKEND_LINKERLESS_INMEM=0 BACKEND_FAST_DEV_PROFILE=0 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict\"; " +
        "opt3_aggressive=\"${UIR_AGGRESSIVE:-${BACKEND_OPT3_AGGRESSIVE:-0}}\"; " +
        "uir_full_iters=\"${UIR_FULL_ITERS:-2}\"; " +
        "uir_opt3_iters=\"$(normalize_int \"${UIR_OPT3_ITERS:-4}\" 4 1 32)\"; " +
        "uir_opt3_cleanup_iters=\"$(normalize_int \"${UIR_OPT3_CLEANUP_ITERS:-3}\" 3 1 32)\"; " +
        "uir_inline_iters=\"$(normalize_int \"${UIR_INLINE_ITERS:-4}\" 4 1 16)\"; " +
        "uir_cfg_canon_iters=\"$(normalize_int \"${UIR_CFG_CANON_ITERS:-1}\" 1 1 16)\"; " +
        "uir_profile=\"${UIR_PROFILE:-0}\"; " +
        "uir_simd=\"${UIR_SIMD:-1}\"; " +
        "uir_simd_max_width=\"${UIR_SIMD_MAX_WIDTH:-0}\"; " +
        "uir_simd_policy=\"${UIR_SIMD_POLICY:-autovec}\"; " +
        "if [ \"$uir_simd_policy\" = \"\" ]; then uir_simd_policy=\"autovec\"; fi; " +
        "fixture_list=\"${UIR_OPT3_FIXTURES:-tests/cheng/backend/fixtures/return_add.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_const_cmp_fold.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_constfold.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_mergeable.cheng}\"; " +
        "uir_aggressive_env=\"\"; " +
        "if [ \"$opt3_aggressive\" = \"1\" ]; then uir_aggressive_env=\"UIR_AGGRESSIVE=1 UIR_FULL_ITERS=$uir_full_iters\"; fi; " +
        "out_dir=\"artifacts/backend_opt3\"; mkdir -p \"$out_dir\"; " +
        "fixture_lines=\"$(normalize_fixture_lines \"$fixture_list\")\"; " +
        "while IFS= read -r fixture; do run_fixture_wrapper \"$fixture\"; done <<EOF\n" +
        "$fixture_lines\n" +
        "EOF\n" +
        "echo \"verify_backend_opt3 ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendOpt3Extended(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "(set -o pipefail) 2>/dev/null && set -o pipefail; " +
        "normalize_int() { " +
            "n=\"$1\"; default=\"$2\"; minv=\"$3\"; maxv=\"$4\"; " +
            "case \"$n\" in ''|*[!0-9]*) printf '%s\\n' \"$default\"; return 0 ;; esac; " +
            "if [ \"$n\" -lt \"$minv\" ]; then printf '%s\\n' \"$minv\"; return 0; fi; " +
            "if [ \"$n\" -gt \"$maxv\" ]; then printf '%s\\n' \"$maxv\"; return 0; fi; " +
            "printf '%s\\n' \"$n\"; " +
        "}; " +
        "normalize_fixture_lines() { printf '%s\\n' \"$1\" | tr ';' '\\n' | tr '\\r' '\\n' | sed -e '/^[[:space:]]*$/d'; }; " +
        "compile_probe_fixture() { " +
            "fixture=\"$1\"; " +
            "base=\"$(basename \"$fixture\" .cheng)\"; " +
            "probe_out=\"$out_dir/probe.${base}.bin\"; " +
            "probe_log=\"$out_dir/probe.${base}.build.log\"; " +
            "set +e; " +
            "env $link_env $uir_aggressive_env " +
                "BACKEND_MULTI=0 " +
                "BACKEND_MULTI_FORCE=0 " +
                "BACKEND_INCREMENTAL=0 " +
                "UIR_PROFILE=\"$uir_profile\" " +
                "UIR_OPT3_ITERS=\"$uir_opt3_iters\" " +
                "UIR_OPT3_CLEANUP_ITERS=\"$uir_opt3_cleanup_iters\" " +
                "UIR_INLINE_ITERS=\"$uir_inline_iters\" " +
                "UIR_CFG_CANON_ITERS=\"$uir_cfg_canon_iters\" " +
                "UIR_SIMD=\"$uir_simd\" " +
                "UIR_SIMD_MAX_WIDTH=\"$uir_simd_max_width\" " +
                "UIR_SIMD_POLICY=\"$uir_simd_policy\" " +
                "BACKEND_OPT_LEVEL=3 " +
                "BACKEND_EMIT=exe " +
                "BACKEND_TARGET=\"$target\" " +
                "BACKEND_INPUT=\"$fixture\" " +
                "BACKEND_OUTPUT=\"$probe_out\" " +
                "\"$driver\" >\"$probe_log\" 2>&1; " +
            "probe_rc=\"$?\"; " +
            "set -e; " +
            "if [ \"$probe_rc\" -eq 138 ] || [ \"$probe_rc\" -eq 139 ]; then return 0; fi; " +
            "return 1; " +
        "}; " +
        "subset_has_crash() { " +
            "subset_file=\"$1\"; " +
            "while IFS= read -r f; do " +
                "[ \"$f\" = \"\" ] && continue; " +
                "if compile_probe_fixture \"$f\"; then return 0; fi; " +
            "done <\"$subset_file\"; " +
            "return 1; " +
        "}; " +
        "find_crash_fixture_from_log() { " +
            "log_file=\"$1\"; " +
            "if [ ! -f \"$log_file\" ]; then echo \"\"; return 0; fi; " +
            "awk -F': ' '/compiler crashed \\(rc=/{print $NF; exit}' \"$log_file\" 2>/dev/null || true; " +
        "}; " +
        "enforce=\"${UIR_OPT3_EXTENDED_ENFORCE:-1}\"; " +
        "case \"$enforce\" in 0|1) ;; *) enforce=0 ;; esac; " +
        "driver=\"${BACKEND_DRIVER:-}\"; " +
        "if [ \"$driver\" = \"\" ]; then driver=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_driver_path)\"; fi; " +
        "target=\"${BACKEND_TARGET:-$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "link_env=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_link_env --driver:\"$driver\" --target:\"$target\" --linker:\"${BACKEND_LINKER:-auto}\")\"; " +
        "opt3_aggressive=\"${UIR_AGGRESSIVE:-${BACKEND_OPT3_AGGRESSIVE:-0}}\"; " +
        "uir_full_iters=\"${UIR_FULL_ITERS:-2}\"; " +
        "uir_opt3_iters=\"$(normalize_int \"${UIR_OPT3_ITERS:-4}\" 4 1 32)\"; " +
        "uir_opt3_cleanup_iters=\"$(normalize_int \"${UIR_OPT3_CLEANUP_ITERS:-3}\" 3 1 32)\"; " +
        "uir_inline_iters=\"$(normalize_int \"${UIR_INLINE_ITERS:-4}\" 4 1 16)\"; " +
        "uir_cfg_canon_iters=\"$(normalize_int \"${UIR_CFG_CANON_ITERS:-1}\" 1 1 16)\"; " +
        "uir_profile=\"${UIR_PROFILE:-0}\"; " +
        "uir_simd=\"${UIR_SIMD:-1}\"; " +
        "uir_simd_max_width=\"${UIR_SIMD_MAX_WIDTH:-0}\"; " +
        "uir_simd_policy=\"${UIR_SIMD_POLICY:-autovec}\"; " +
        "if [ \"$uir_simd_policy\" = \"\" ]; then uir_simd_policy=\"autovec\"; fi; " +
        "fixture_list=\"${UIR_OPT3_EXTENDED_FIXTURES:-tests/cheng/backend/fixtures/return_add.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_const_cmp_fold.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_constfold.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cbr_mergeable.cheng}\"; " +
        "out_dir=\"artifacts/backend_opt3_extended\"; rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_opt3_extended.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_opt3_extended.snapshot.env\"; " +
        "run_log=\"$out_dir/verify_backend_opt3_extended.run.log\"; " +
        "fixtures_file=\"$out_dir/fixtures.full.list\"; " +
        "fixture_lines=\"$(normalize_fixture_lines \"$fixture_list\")\"; " +
        "printf '%s\\n' \"$fixture_lines\" >\"$fixtures_file\"; " +
        "uir_aggressive_env=\"\"; " +
        "if [ \"$opt3_aggressive\" = \"1\" ]; then uir_aggressive_env=\"UIR_AGGRESSIVE=1 UIR_FULL_ITERS=$uir_full_iters\"; fi; " +
        "set +e; " +
        "env " +
            "BACKEND_TARGET=\"$target\" " +
            "BACKEND_LINKER=\"${BACKEND_LINKER:-auto}\" " +
            "UIR_OPT3_ITERS=\"$uir_opt3_iters\" " +
            "UIR_OPT3_CLEANUP_ITERS=\"$uir_opt3_cleanup_iters\" " +
            "UIR_INLINE_ITERS=\"$uir_inline_iters\" " +
            "UIR_CFG_CANON_ITERS=\"$uir_cfg_canon_iters\" " +
            "UIR_PROFILE=\"$uir_profile\" " +
            "UIR_SIMD=\"$uir_simd\" " +
            "UIR_SIMD_MAX_WIDTH=\"$uir_simd_max_width\" " +
            "UIR_SIMD_POLICY=\"$uir_simd_policy\" " +
            "UIR_AGGRESSIVE=\"$opt3_aggressive\" " +
            "UIR_FULL_ITERS=\"$uir_full_iters\" " +
            "UIR_OPT3_FIXTURES=\"$fixture_list\" " +
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} verify_backend_opt3 >\"$run_log\" 2>&1; " +
        "rc=\"$?\"; " +
        "set -e; " +
        "status=\"ok\"; crash_detected=0; crash_fixture=\"\"; " +
        "if [ \"$rc\" -ne 0 ]; then status=\"failed\"; fi; " +
        "if [ \"$rc\" -eq 138 ] || [ \"$rc\" -eq 139 ] || rg -q 'compiler crashed \\(rc=13(8|9)\\)|Segmentation fault' \"$run_log\"; then " +
            "crash_detected=1; " +
            "crash_fixture=\"$(find_crash_fixture_from_log \"$run_log\")\"; " +
        "fi; " +
        "bisect_start=0; bisect_end=0; " +
        "if [ \"$crash_detected\" = \"1\" ] && [ \"$crash_fixture\" = \"\" ]; then " +
            "count=\"$(wc -l <\"$fixtures_file\" | tr -d ' ')\"; " +
            "if [ \"$count\" != \"\" ] && [ \"$count\" -gt 0 ]; then " +
                "start=1; end=\"$count\"; " +
                "while [ \"$start\" -lt \"$end\" ]; do " +
                    "mid=$(( (start + end) / 2 )); " +
                    "left=\"$out_dir/fixtures.left.list\"; " +
                    "sed -n \"${start},${mid}p\" \"$fixtures_file\" >\"$left\"; " +
                    "if subset_has_crash \"$left\"; then " +
                        "end=\"$mid\"; " +
                    "else " +
                        "start=$((mid + 1)); " +
                    "fi; " +
                "done; " +
                "bisect_start=\"$start\"; bisect_end=\"$end\"; " +
                "crash_fixture=\"$(sed -n \"${start}p\" \"$fixtures_file\")\"; " +
            "fi; " +
        "fi; " +
        "repro_script=\"\"; min_repro=\"\"; " +
        "if [ \"$crash_detected\" = \"1\" ] && [ \"$crash_fixture\" != \"\" ]; then " +
            "min_repro=\"$out_dir/opt3_crash_min_repro.cheng\"; " +
            "if [ -f \"$crash_fixture\" ]; then cp \"$crash_fixture\" \"$min_repro\"; fi; " +
            "repro_script=\"$out_dir/repro_opt3_crash.sh\"; " +
            "cat >\"$repro_script\" <<'EOF'\n" +
            "#!/usr/bin/env sh\n" +
            "set -eu\n" +
            "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"\n" +
            "target=\"${1:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"\n" +
            "fixture=\"${2:?missing fixture path}\"\n" +
            "env BACKEND_TARGET=\"$target\" UIR_OPT3_FIXTURES=\"$fixture\" \"$tool\" verify_backend_opt3\n" +
            "EOF\n" +
            "chmod +x \"$repro_script\" >/dev/null 2>&1 || true; " +
        "fi; " +
        "{ " +
            "echo \"status=$status\"; " +
            "echo \"rc=$rc\"; " +
            "echo \"enforce=$enforce\"; " +
            "echo \"crash_detected=$crash_detected\"; " +
            "echo \"crash_fixture=$crash_fixture\"; " +
            "echo \"bisect_start=$bisect_start\"; " +
            "echo \"bisect_end=$bisect_end\"; " +
            "echo \"fixtures_file=$fixtures_file\"; " +
            "echo \"run_log=$run_log\"; " +
            "echo \"repro_script=$repro_script\"; " +
            "echo \"min_repro=$min_repro\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_opt3_extended_status=$status\"; " +
            "echo \"backend_opt3_extended_rc=$rc\"; " +
            "echo \"backend_opt3_extended_enforce=$enforce\"; " +
            "echo \"backend_opt3_extended_crash_detected=$crash_detected\"; " +
            "echo \"backend_opt3_extended_crash_fixture=$crash_fixture\"; " +
            "echo \"backend_opt3_extended_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$status\" = \"ok\" ]; then echo \"verify_backend_opt3_extended ok\"; exit 0; fi; " +
        "echo \"[verify_backend_opt3_extended] extended fixture set failed (report: $report)\" 1>&2; " +
        "tail -n 120 \"$run_log\" 1>&2 || true; " +
        "if [ \"$enforce\" = \"1\" ]; then exit 1; fi; " +
        "echo \"[verify_backend_opt3_extended] report-only mode, not blocking\" 1>&2; " +
        "echo \"verify_backend_opt3_extended warn\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendSimd(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "(set -o pipefail) 2>/dev/null && set -o pipefail; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_simd] rg is required\" >&2; exit 2; " +
        "fi; " +
        "normalize_int() { " +
            "n=\"$1\"; default=\"$2\"; minv=\"$3\"; maxv=\"$4\"; " +
            "case \"$n\" in ''|*[!0-9]*) printf '%s\\n' \"$default\"; return 0 ;; esac; " +
            "if [ \"$n\" -lt \"$minv\" ]; then printf '%s\\n' \"$minv\"; return 0; fi; " +
            "if [ \"$n\" -gt \"$maxv\" ]; then printf '%s\\n' \"$maxv\"; return 0; fi; " +
            "printf '%s\\n' \"$n\"; " +
        "}; " +
        "normalize_fixture_lines() { printf '%s\\n' \"$1\" | tr ';' '\\n' | tr '\\r' '\\n' | sed -e '/^[[:space:]]*$/d'; }; " +
        "file_sha256() { " +
            "f=\"$1\"; " +
            "if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$f\" | awk '{print $1}'; return 0; fi; " +
            "if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$f\" | awk '{print $1}'; return 0; fi; " +
            "if command -v openssl >/dev/null 2>&1; then openssl dgst -sha256 \"$f\" | awk '{print $NF}'; return 0; fi; " +
            "echo \"\"; " +
        "}; " +
        "is_known_runtime_symbol_log() { " +
            "log_file=\"$1\"; " +
            "if [ ! -f \"$log_file\" ]; then return 1; fi; " +
            "if rg -q 'Symbol not found: _cheng_|_cheng_f32_bits_to_i64|_cheng_memcpy' \"$log_file\"; then return 0; fi; " +
            "return 1; " +
        "}; " +
        "build_exe() { " +
            "fixture=\"$1\"; out_path=\"$2\"; simd=\"$3\"; simd_report=\"$4\"; log=\"$5\"; " +
            "set +e; " +
            "env $link_env $stable_env " +
                "BACKEND_MULTI=0 " +
                "BACKEND_MULTI_FORCE=0 " +
                "BACKEND_INCREMENTAL=0 " +
                "BACKEND_JOBS=1 " +
                "BACKEND_OPT_LEVEL=\"$simd_opt_level\" " +
                "UIR_OPT3_ITERS=\"$uir_opt3_iters\" " +
                "UIR_OPT3_CLEANUP_ITERS=\"$uir_opt3_cleanup_iters\" " +
                "UIR_INLINE_ITERS=\"$uir_inline_iters\" " +
                "UIR_CFG_CANON_ITERS=\"$uir_cfg_canon_iters\" " +
                "UIR_SIMD=\"$simd\" " +
                "UIR_SIMD_REPORT=\"$simd_report\" " +
                "UIR_SIMD_MAX_WIDTH=\"$uir_simd_max_width\" " +
                "UIR_SIMD_POLICY=\"$uir_simd_policy\" " +
                "BACKEND_EMIT=exe " +
                "BACKEND_TARGET=\"$target\" " +
                "BACKEND_INPUT=\"$fixture\" " +
                "BACKEND_OUTPUT=\"$out_path\" " +
                "\"$driver\" >\"$log\" 2>&1; " +
            "rc=\"$?\"; " +
            "set -e; " +
            "if [ \"$rc\" -ne 0 ] && { [ \"$rc\" -eq 138 ] || [ \"$rc\" -eq 139 ]; }; then " +
                "echo \"[verify_backend_simd] compiler crashed (rc=$rc), retry once: $fixture\" 1>&2; " +
                "set +e; " +
                "env $link_env $stable_env " +
                    "BACKEND_MULTI=0 " +
                    "BACKEND_MULTI_FORCE=0 " +
                    "BACKEND_INCREMENTAL=0 " +
                    "BACKEND_JOBS=1 " +
                    "BACKEND_OPT_LEVEL=\"$simd_opt_level\" " +
                    "UIR_OPT3_ITERS=\"$uir_opt3_iters\" " +
                    "UIR_OPT3_CLEANUP_ITERS=\"$uir_opt3_cleanup_iters\" " +
                    "UIR_INLINE_ITERS=\"$uir_inline_iters\" " +
                    "UIR_CFG_CANON_ITERS=\"$uir_cfg_canon_iters\" " +
                    "UIR_SIMD=\"$simd\" " +
                    "UIR_SIMD_REPORT=\"$simd_report\" " +
                    "UIR_SIMD_MAX_WIDTH=\"$uir_simd_max_width\" " +
                    "UIR_SIMD_POLICY=\"$uir_simd_policy\" " +
                    "BACKEND_EMIT=exe " +
                    "BACKEND_TARGET=\"$target\" " +
                    "BACKEND_INPUT=\"$fixture\" " +
                    "BACKEND_OUTPUT=\"$out_path\" " +
                    "\"$driver\" >>\"$log\" 2>&1; " +
                "rc=\"$?\"; " +
                "set -e; " +
            "fi; " +
            "return \"$rc\"; " +
        "}; " +
        "source_ok=1; " +
        "for file in src/backend/uir/uir_vectorize_loop.cheng src/backend/uir/uir_vectorize_slp.cheng src/backend/uir/uir_pass_manager.cheng src/backend/uir/uir_vec_cost.cheng; do " +
            "if [ ! -f \"$file\" ]; then source_ok=0; fi; " +
        "done; " +
        "for pat in 'simd_loop_report' 'simd_slp_report' 'fn uirVectorizeLoops\\(' 'fn uirVectorizeSlp\\(' 'fn uirDecideVecWidth\\(' 'optLevel < 2'; do " +
            "if ! rg -q \"$pat\" src/backend/uir/uir_vectorize_loop.cheng src/backend/uir/uir_vectorize_slp.cheng src/backend/uir/uir_pass_manager.cheng src/backend/uir/uir_vec_cost.cheng; then source_ok=0; fi; " +
        "done; " +
        "if [ \"$source_ok\" != \"1\" ]; then " +
            "echo \"[verify_backend_simd] source contract markers missing\" >&2; " +
            "exit 1; " +
        "fi; " +
        "out_dir=\"artifacts/backend_simd\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_simd.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_simd.snapshot.env\"; " +
        "driver=\"${BACKEND_DRIVER:-}\"; " +
        "if [ \"$driver\" = \"\" ]; then driver=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_driver_path)\"; fi; " +
        "target=\"${BACKEND_TARGET:-$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "link_env=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_link_env --driver:\"$driver\" --target:\"$target\" --linker:\"${BACKEND_LINKER:-self}\")\"; " +
        "stable_env=\"BACKEND_ALLOW_DIRECT_DRIVER=1 BACKEND_TOOLING_ENTRY=1 MM=orc BACKEND_CACHE=0 STAGE1_AUTO_SYSTEM=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 BACKEND_BUILD_TRACK=release BACKEND_STAGE1_BUILDER=stage1 BACKEND_SKIP_GLOBAL_INIT=0 BACKEND_IR=uir BACKEND_ALLOW_NO_MAIN=0 BACKEND_DIRECT_EXE=0 BACKEND_LINKERLESS_INMEM=0 BACKEND_FAST_DEV_PROFILE=0 GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict\"; " +
        "simd_opt_level=\"$(normalize_int \"${UIR_SIMD_GATE_OPT_LEVEL:-2}\" 2 2 3)\"; " +
        "uir_opt3_iters=\"$(normalize_int \"${UIR_OPT3_ITERS:-4}\" 4 1 32)\"; " +
        "uir_opt3_cleanup_iters=\"$(normalize_int \"${UIR_OPT3_CLEANUP_ITERS:-3}\" 3 1 32)\"; " +
        "uir_inline_iters=\"$(normalize_int \"${UIR_INLINE_ITERS:-4}\" 4 1 16)\"; " +
        "uir_cfg_canon_iters=\"$(normalize_int \"${UIR_CFG_CANON_ITERS:-1}\" 1 1 16)\"; " +
        "uir_simd_max_width=\"$(normalize_int \"${UIR_SIMD_MAX_WIDTH:-16}\" 16 2 256)\"; " +
        "uir_simd_policy=\"${UIR_SIMD_POLICY:-autovec}\"; " +
        "if [ \"$uir_simd_policy\" = \"\" ]; then uir_simd_policy=\"autovec\"; fi; " +
        "fixture_list=\"${UIR_SIMD_FIXTURES:-tests/cheng/backend/fixtures/return_while_vec_deep.cheng\n" +
        "tests/cheng/backend/fixtures/return_while_sum.cheng\n" +
        "tests/cheng/backend/fixtures/return_while_break.cheng\n" +
        "tests/cheng/backend/fixtures/return_opt2_cse.cheng}\"; " +
        "mode=\"runtime\"; runtime_report_mode=\"runtime\"; runtime_report_reason=\"\"; marker_ok=0; " +
        "if [ -x \"$driver\" ] && command -v strings >/dev/null 2>&1; then " +
            "if strings \"$driver\" 2>/dev/null | rg -q 'uir_simd|simd_loop_report|simd_slp_report'; then marker_ok=1; fi; " +
        "fi; " +
        "fixture_lines=\"$(normalize_fixture_lines \"$fixture_list\")\"; " +
        "loop_reports=0; slp_reports=0; loop_vec_exprs_total=0; slp_packed_exprs_total=0; " +
        "min_loop_vec_exprs=\"$(normalize_int \"${UIR_SIMD_MIN_LOOP_VEC_EXPRS:-1}\" 1 0 1000000)\"; " +
        "min_slp_packed_exprs=\"$(normalize_int \"${UIR_SIMD_MIN_SLP_PACKED_EXPRS:-0}\" 0 0 1000000)\"; " +
        "while IFS= read -r fixture; do " +
            "if [ ! -f \"$fixture\" ]; then echo \"[verify_backend_simd] missing fixture: $fixture\" >&2; exit 2; fi; " +
            "name=\"$(basename \"$fixture\" .cheng)\"; " +
            "exe_scalar=\"$out_dir/${name}.scalar\"; " +
            "exe_simd_a=\"$out_dir/${name}.simd.a\"; " +
            "exe_simd_b=\"$out_dir/${name}.simd.b\"; " +
            "scalar_log=\"$out_dir/${name}.scalar.build.log\"; " +
            "simd_a_log=\"$out_dir/${name}.simd.a.build.log\"; " +
            "simd_b_log=\"$out_dir/${name}.simd.b.build.log\"; " +
            "if ! build_exe \"$fixture\" \"$exe_scalar\" 0 0 \"$scalar_log\"; then " +
                "echo \"[verify_backend_simd] scalar executable build failed: $fixture\" >&2; " +
                "sed -n '1,120p' \"$scalar_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "if ! build_exe \"$fixture\" \"$exe_simd_a\" 1 1 \"$simd_a_log\"; then " +
                "echo \"[verify_backend_simd] SIMD executable build failed: $fixture\" >&2; " +
                "sed -n '1,120p' \"$simd_a_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "if ! build_exe \"$fixture\" \"$exe_simd_b\" 1 1 \"$simd_b_log\"; then " +
                "echo \"[verify_backend_simd] SIMD determinism build failed: $fixture\" >&2; " +
                "sed -n '1,120p' \"$simd_b_log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "if [ ! -x \"$exe_scalar\" ] || [ ! -x \"$exe_simd_a\" ] || [ ! -x \"$exe_simd_b\" ]; then " +
                "echo \"[verify_backend_simd] missing executable output: $fixture\" >&2; " +
                "exit 1; " +
            "fi; " +
            "if rg -q '^backend_driver: uir_simd status=enabled' \"$simd_a_log\"; then marker_ok=1; fi; " +
            "loop_reports=$((loop_reports + $(rg -c '^simd_loop_report' \"$simd_a_log\" 2>/dev/null || echo 0))); " +
            "slp_reports=$((slp_reports + $(rg -c '^simd_slp_report' \"$simd_a_log\" 2>/dev/null || echo 0))); " +
            "loop_vec_exprs_total=$((loop_vec_exprs_total + $(awk -F 'vec_exprs=' '/^simd_loop_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$simd_a_log\" 2>/dev/null || echo 0))); " +
            "slp_packed_exprs_total=$((slp_packed_exprs_total + $(awk -F 'packed_exprs=' '/^simd_slp_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$simd_a_log\" 2>/dev/null || echo 0))); " +
            "hash_a=\"$(file_sha256 \"$exe_simd_a\")\"; " +
            "hash_b=\"$(file_sha256 \"$exe_simd_b\")\"; " +
            "if [ \"$hash_a\" = \"\" ] || [ \"$hash_b\" = \"\" ] || [ \"$hash_a\" != \"$hash_b\" ]; then " +
                "echo \"[verify_backend_simd] deterministic executable mismatch: $exe_simd_a vs $exe_simd_b\" >&2; " +
                "echo \"  hash_a=$hash_a\" >&2; echo \"  hash_b=$hash_b\" >&2; " +
                "exit 1; " +
            "fi; " +
            "echo \"verify_backend_simd: ok $fixture\"; " +
        "done <<EOF\n" +
        "$fixture_lines\n" +
        "EOF\n" +
        "if [ \"$loop_reports\" -eq 0 ] || [ \"$slp_reports\" -eq 0 ]; then " +
            "mode=\"source_fallback\"; " +
            "runtime_report_mode=\"source_fallback\"; " +
            "runtime_report_reason=\"loop_reports=$loop_reports slp_reports=$slp_reports\"; " +
            "if [ \"${BACKEND_SIMD_STRICT_RUNTIME_REPORT:-0}\" = \"1\" ]; then " +
                "echo \"[verify_backend_simd] missing runtime simd report (loop_reports=$loop_reports slp_reports=$slp_reports)\" >&2; " +
                "probe_log=\"$(ls \"$out_dir\"/*.simd.a.build.log 2>/dev/null | head -n 1 || true)\"; " +
                "if [ \"$probe_log\" != \"\" ]; then sed -n '1,160p' \"$probe_log\" >&2 || true; fi; " +
                "exit 1; " +
            "fi; " +
            "echo \"[verify_backend_simd] warn: missing runtime simd report, fallback to source-surface proof\" >&2; " +
        "fi; " +
        "if [ \"$runtime_report_mode\" = \"runtime\" ] && [ \"$loop_vec_exprs_total\" -lt \"$min_loop_vec_exprs\" ]; then " +
            "echo \"[verify_backend_simd] insufficient loop vectorization evidence: loop_vec_exprs_total=$loop_vec_exprs_total min=$min_loop_vec_exprs\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$runtime_report_mode\" = \"runtime\" ] && [ \"$slp_packed_exprs_total\" -lt \"$min_slp_packed_exprs\" ]; then " +
            "echo \"[verify_backend_simd] insufficient slp packing evidence: slp_packed_exprs_total=$slp_packed_exprs_total min=$min_slp_packed_exprs\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$marker_ok\" != \"1\" ]; then " +
            "echo \"[verify_backend_simd] backend driver missing simd marker\" >&2; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"mode=$mode\"; " +
            "echo \"driver=$driver\"; " +
            "echo \"target=$target\"; " +
            "echo \"simd_opt_level=$simd_opt_level\"; " +
            "echo \"marker_ok=$marker_ok\"; " +
            "echo \"runtime_report_mode=$runtime_report_mode\"; " +
            "echo \"runtime_report_reason=$runtime_report_reason\"; " +
            "echo \"min_loop_vec_exprs=$min_loop_vec_exprs\"; " +
            "echo \"min_slp_packed_exprs=$min_slp_packed_exprs\"; " +
            "echo \"loop_reports=$loop_reports\"; " +
            "echo \"slp_reports=$slp_reports\"; " +
            "echo \"loop_vec_exprs_total=$loop_vec_exprs_total\"; " +
            "echo \"slp_packed_exprs_total=$slp_packed_exprs_total\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_simd_status=ok\"; " +
            "echo \"backend_simd_mode=$mode\"; " +
            "echo \"backend_simd_driver=$driver\"; " +
            "echo \"backend_simd_target=$target\"; " +
            "echo \"backend_simd_opt_level=$simd_opt_level\"; " +
            "echo \"backend_simd_marker_ok=$marker_ok\"; " +
            "echo \"backend_simd_runtime_report_mode=$runtime_report_mode\"; " +
            "echo \"backend_simd_runtime_report_reason=$runtime_report_reason\"; " +
            "echo \"backend_simd_min_loop_vec_exprs=$min_loop_vec_exprs\"; " +
            "echo \"backend_simd_min_slp_packed_exprs=$min_slp_packed_exprs\"; " +
            "echo \"backend_simd_loop_reports=$loop_reports\"; " +
            "echo \"backend_simd_slp_reports=$slp_reports\"; " +
            "echo \"backend_simd_loop_vec_exprs_total=$loop_vec_exprs_total\"; " +
            "echo \"backend_simd_slp_packed_exprs_total=$slp_packed_exprs_total\"; " +
            "echo \"backend_simd_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_simd ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendNoaliasOpt(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_noalias_opt] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_noalias_opt\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_noalias_opt.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_noalias_opt.snapshot.env\"; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then echo \"[verify_backend_noalias_opt] missing tooling binary: $tool\" >&2; exit 1; fi; " +
        "driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r' || true)\"; " +
        "if [ \"$driver\" = \"\" ]; then driver=\"artifacts/backend_driver/cheng\"; fi; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "for pat in 'fn uirRunNoAliasPrep\\(' 'unknown_slot_clobbers' 'unknown_global_clobbers' 'kill_events' 'proof_backed_changes='; do " +
            "if ! rg -q \"$pat\" src/backend/uir/uir_noalias_pass.cheng; then " +
                "echo \"[verify_backend_noalias_opt] source contract markers missing: $pat\" >&2; " +
                "exit 1; " +
            "fi; " +
        "done; " +
        "fixture_list=\"${BACKEND_NOALIAS_FIXTURES:-tests/cheng/backend/fixtures/return_opt2_noalias_mem2reg_load.cheng;tests/cheng/backend/fixtures/return_opt2_sroa_deref.cheng;tests/cheng/backend/fixtures/return_opt2_inline_dce.cheng;tests/cheng/backend/fixtures/return_opt2_cse.cheng}\"; " +
        "fixture_lines=\"$(printf '%s\\n' \"$fixture_list\" | tr ';' '\\n' | tr '\\r' '\\n' | sed -e '/^[[:space:]]*$/d')\"; " +
        "min_probe_count=\"${BACKEND_NOALIAS_MIN_PROBE_COUNT:-3}\"; " +
        "case \"$min_probe_count\" in ''|*[!0-9]*) min_probe_count=3 ;; esac; " +
        "probe_count=0; proof_backed_changes_total=0; mem2reg_loads_total=0; forward_loads_total=0; changed_funcs_total=0; unknown_slot_clobbers_total=0; unknown_global_clobbers_total=0; kill_events_total=0; " +
        "while IFS= read -r fixture; do " +
            "[ \"$fixture\" = \"\" ] && continue; " +
            "if [ ! -f \"$fixture\" ]; then continue; fi; " +
            "probe_count=$((probe_count + 1)); " +
            "out_bin=\"$out_dir/noalias_probe.$probe_count.bin\"; " +
            "log=\"$out_dir/noalias_probe.$probe_count.log\"; " +
            "set +e; " +
            "env ABI=v2_noptr MM=orc BACKEND_TARGET=\"$target\" BACKEND_LINKER=system BACKEND_RUNTIME=off BACKEND_NO_RUNTIME_C=0 BACKEND_EMIT=exe BACKEND_OPT_LEVEL=2 BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_INCREMENTAL=0 BACKEND_JOBS=1 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 UIR_PROFILE=0 BACKEND_PROFILE=0 UIR_NOALIAS=1 UIR_NOALIAS_REQUIRE_PROOF=1 BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$out_bin\" \"$driver\" >\"$log\" 2>&1; " +
            "rc=\"$?\"; " +
            "set -e; " +
            "if [ \"$rc\" -ne 0 ] || [ ! -x \"$out_bin\" ]; then " +
                "echo \"[verify_backend_noalias_opt] runtime probe compile failed fixture=$fixture\" >&2; " +
                "sed -n '1,160p' \"$log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "if ! rg -q '^noalias_report' \"$log\"; then " +
                "echo \"[verify_backend_noalias_opt] noalias_report missing in runtime probe fixture=$fixture\" >&2; " +
                "exit 1; " +
            "fi; " +
            "proof_backed_changes_total=$((proof_backed_changes_total + $(awk -F 'proof_backed_changes=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "mem2reg_loads_total=$((mem2reg_loads_total + $(awk -F 'mem2reg_loads=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "forward_loads_total=$((forward_loads_total + $(awk -F 'forward_loads=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "changed_funcs_total=$((changed_funcs_total + $(awk -F 'changed_funcs=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "unknown_slot_clobbers_total=$((unknown_slot_clobbers_total + $(awk -F 'unknown_slot_clobbers=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "unknown_global_clobbers_total=$((unknown_global_clobbers_total + $(awk -F 'unknown_global_clobbers=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "kill_events_total=$((kill_events_total + $(awk -F 'kill_events=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
        "done <<EOF\n" +
        "$fixture_lines\n" +
        "EOF\n" +
        "if [ \"$probe_count\" -le 0 ]; then " +
            "echo \"[verify_backend_noalias_opt] missing fixture (none from list exist)\" >&2; " +
            "exit 2; " +
        "fi; " +
        "if [ \"$probe_count\" -lt \"$min_probe_count\" ]; then " +
            "echo \"[verify_backend_noalias_opt] insufficient probe coverage: probe_count=$probe_count min=$min_probe_count\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$proof_backed_changes_total\" -le 0 ]; then " +
            "echo \"[verify_backend_noalias_opt] no proof-backed noalias changes observed\" >&2; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"driver=$driver\"; " +
            "echo \"target=$target\"; " +
            "echo \"min_probe_count=$min_probe_count\"; " +
            "echo \"probe_count=$probe_count\"; " +
            "echo \"proof_backed_changes_total=$proof_backed_changes_total\"; " +
            "echo \"mem2reg_loads_total=$mem2reg_loads_total\"; " +
            "echo \"forward_loads_total=$forward_loads_total\"; " +
            "echo \"changed_funcs_total=$changed_funcs_total\"; " +
            "echo \"unknown_slot_clobbers_total=$unknown_slot_clobbers_total\"; " +
            "echo \"unknown_global_clobbers_total=$unknown_global_clobbers_total\"; " +
            "echo \"kill_events_total=$kill_events_total\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_noalias_opt_status=ok\"; " +
            "echo \"backend_noalias_opt_driver=$driver\"; " +
            "echo \"backend_noalias_opt_target=$target\"; " +
            "echo \"backend_noalias_opt_min_probe_count=$min_probe_count\"; " +
            "echo \"backend_noalias_opt_probe_count=$probe_count\"; " +
            "echo \"backend_noalias_opt_proof_backed_changes_total=$proof_backed_changes_total\"; " +
            "echo \"backend_noalias_opt_mem2reg_loads_total=$mem2reg_loads_total\"; " +
            "echo \"backend_noalias_opt_forward_loads_total=$forward_loads_total\"; " +
            "echo \"backend_noalias_opt_changed_funcs_total=$changed_funcs_total\"; " +
            "echo \"backend_noalias_opt_unknown_slot_clobbers_total=$unknown_slot_clobbers_total\"; " +
            "echo \"backend_noalias_opt_unknown_global_clobbers_total=$unknown_global_clobbers_total\"; " +
            "echo \"backend_noalias_opt_kill_events_total=$kill_events_total\"; " +
            "echo \"backend_noalias_opt_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_noalias_opt ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendEgraphCost(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_egraph_cost] rg is required\" >&2; exit 2; " +
        "fi; " +
        "file_sha256() { " +
            "f=\"$1\"; " +
            "if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$f\" | awk '{print $1}'; return 0; fi; " +
            "if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$f\" | awk '{print $1}'; return 0; fi; " +
            "if command -v openssl >/dev/null 2>&1; then openssl dgst -sha256 \"$f\" | awk '{print $NF}'; return 0; fi; " +
            "echo \"\"; " +
        "}; " +
        "out_dir=\"artifacts/backend_egraph_cost\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_egraph_cost.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_egraph_cost.snapshot.env\"; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then echo \"[verify_backend_egraph_cost] missing tooling binary: $tool\" >&2; exit 1; fi; " +
        "driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r' || true)\"; " +
        "if [ \"$driver\" = \"\" ]; then driver=\"artifacts/backend_driver/cheng\"; fi; " +
        "target=\"${BACKEND_TARGET:-$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "mode=\"runtime\"; marker_ok=0; " +
        "if [ -x \"$driver\" ] && command -v strings >/dev/null 2>&1; then " +
            "if strings \"$driver\" 2>/dev/null | rg -q 'uir_opt2.egraph|egraph_report|uirEGraphSaturateExpr'; then marker_ok=1; fi; " +
        "fi; " +
        "source_ok=1; " +
        "for file in src/backend/uir/uir_egraph_cost.cheng src/backend/uir/uir_egraph_rewrite.cheng src/backend/uir/uir_opt.cheng; do " +
            "if [ ! -f \"$file\" ]; then source_ok=0; fi; " +
        "done; " +
        "for pat in 'uirEGraphGoalWeightSignature' 'uir_opt2\\.egraph' 'UIR_EGRAPH_REQUIRE_PROOF'; do " +
            "if ! rg -q \"$pat\" src/backend/uir/uir_egraph_cost.cheng src/backend/uir/uir_opt.cheng; then source_ok=0; fi; " +
        "done; " +
        "for pat in 'fn uirEGraphApplyRule\\(' 'fn uirEGraphSaturateExpr\\(' 'egraph_report' 'UIR_EGRAPH_CLASS_NODE_BUDGET' 'UIR_EGRAPH_CLASS_BUDGET'; do " +
            "if ! rg -q \"$pat\" src/backend/uir/uir_egraph_rewrite.cheng; then source_ok=0; fi; " +
        "done; " +
        "if [ \"$source_ok\" != \"1\" ]; then " +
            "echo \"[verify_backend_egraph_cost] source contract markers missing\" >&2; " +
            "exit 1; " +
        "fi; " +
        "fixture_list=\"${BACKEND_EGRAPH_FIXTURES:-tests/cheng/backend/fixtures/return_opt2_algebraic.cse.cheng;tests/cheng/backend/fixtures/return_opt2_inline_dce.cheng}\"; " +
        "fixture_lines=\"$(printf '%s\\n' \"$fixture_list\" | tr ';' '\\n' | tr '\\r' '\\n' | sed -e '/^[[:space:]]*$/d')\"; " +
        "report_count=0; extracted_total=0; candidates_total=0; fixture_count=0; " +
        "determinism_mismatch=0; binary_hash_mismatch=0; " +
        "max_determinism_mismatch=\"${BACKEND_EGRAPH_COST_MAX_DETERMINISM_MISMATCH:-0}\"; " +
        "case \"$max_determinism_mismatch\" in ''|*[!0-9]*) max_determinism_mismatch=0 ;; esac; " +
        "enforce_binary_hash=\"${BACKEND_EGRAPH_COST_ENFORCE_BINARY_HASH:-0}\"; " +
        "case \"$enforce_binary_hash\" in 1|true|TRUE|yes|YES) enforce_binary_hash=1 ;; *) enforce_binary_hash=0 ;; esac; " +
        "max_binary_hash_mismatch=\"${BACKEND_EGRAPH_COST_MAX_BINARY_HASH_MISMATCH:-0}\"; " +
        "case \"$max_binary_hash_mismatch\" in ''|*[!0-9]*) max_binary_hash_mismatch=0 ;; esac; " +
        "while IFS= read -r fixture; do " +
            "[ \"$fixture\" = \"\" ] && continue; " +
            "if [ ! -f \"$fixture\" ]; then continue; fi; " +
            "fixture_count=$((fixture_count + 1)); " +
            "for goal in balanced latency size; do " +
                "out_a=\"$out_dir/egraph_probe.${fixture_count}.${goal}.a.bin\"; " +
                "out_b=\"$out_dir/egraph_probe.${fixture_count}.${goal}.b.bin\"; " +
                "log_a=\"$out_dir/egraph_probe.${fixture_count}.${goal}.a.log\"; " +
                "log_b=\"$out_dir/egraph_probe.${fixture_count}.${goal}.b.log\"; " +
                "trace_a=\"$out_dir/egraph_probe.${fixture_count}.${goal}.a.trace.log\"; " +
                "trace_b=\"$out_dir/egraph_probe.${fixture_count}.${goal}.b.trace.log\"; " +
                "set +e; " +
                "env ABI=v2_noptr MM=orc BACKEND_TARGET=\"$target\" BACKEND_LINKER=system BACKEND_RUNTIME=off BACKEND_NO_RUNTIME_C=0 BACKEND_EMIT=exe BACKEND_OPT_LEVEL=2 BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_INCREMENTAL=0 BACKEND_JOBS=1 STAGE1_STD_NO_POINTERS=0 STAGE1_STD_NO_POINTERS_STRICT=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 UIR_PROFILE=0 BACKEND_PROFILE=0 UIR_NOALIAS=1 UIR_EGRAPH_ITERS=4 UIR_EGRAPH_GOAL=\"$goal\" UIR_EGRAPH_REQUIRE_PROOF=1 UIR_EGRAPH_REPORT=1 BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$out_a\" \"$driver\" >\"$log_a\" 2>&1; " +
                "rc_a=\"$?\"; " +
                "env ABI=v2_noptr MM=orc BACKEND_TARGET=\"$target\" BACKEND_LINKER=system BACKEND_RUNTIME=off BACKEND_NO_RUNTIME_C=0 BACKEND_EMIT=exe BACKEND_OPT_LEVEL=2 BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_INCREMENTAL=0 BACKEND_JOBS=1 STAGE1_STD_NO_POINTERS=0 STAGE1_STD_NO_POINTERS_STRICT=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 UIR_PROFILE=0 BACKEND_PROFILE=0 UIR_NOALIAS=1 UIR_EGRAPH_ITERS=4 UIR_EGRAPH_GOAL=\"$goal\" UIR_EGRAPH_REQUIRE_PROOF=1 UIR_EGRAPH_REPORT=1 BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$out_b\" \"$driver\" >\"$log_b\" 2>&1; " +
                "rc_b=\"$?\"; " +
                "set -e; " +
                "if [ \"$rc_a\" -ne 0 ] || [ \"$rc_b\" -ne 0 ] || [ ! -x \"$out_a\" ] || [ ! -x \"$out_b\" ]; then " +
                    "echo \"[verify_backend_egraph_cost] runtime probe compile failed fixture=$fixture goal=$goal\" >&2; " +
                    "sed -n '1,120p' \"$log_a\" >&2 || true; " +
                    "sed -n '1,120p' \"$log_b\" >&2 || true; " +
                    "exit 1; " +
                "fi; " +
                "if rg -q '^egraph_report' \"$log_a\"; then marker_ok=1; fi; " +
                "report_count=$((report_count + $(rg -c '^egraph_report' \"$log_a\" 2>/dev/null || echo 0))); " +
                "extracted_total=$((extracted_total + $(awk -F 'extracted=' '/^egraph_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log_a\" 2>/dev/null || echo 0))); " +
                "candidates_total=$((candidates_total + $(awk -F 'candidates=' '/^egraph_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log_a\" 2>/dev/null || echo 0))); " +
                "hash_a=\"$(file_sha256 \"$out_a\")\"; " +
                "hash_b=\"$(file_sha256 \"$out_b\")\"; " +
                "if [ \"$hash_a\" = \"\" ] || [ \"$hash_b\" = \"\" ] || [ \"$hash_a\" != \"$hash_b\" ]; then " +
                    "binary_hash_mismatch=$((binary_hash_mismatch + 1)); " +
                "fi; " +
                "awk '/^(noalias_report|ssu_report|egraph_report)/{print}' \"$log_a\" >\"$trace_a\"; " +
                "awk '/^(noalias_report|ssu_report|egraph_report)/{print}' \"$log_b\" >\"$trace_b\"; " +
                "if ! cmp -s \"$trace_a\" \"$trace_b\"; then " +
                    "determinism_mismatch=$((determinism_mismatch + 1)); " +
                "fi; " +
            "done; " +
        "done <<EOF\n" +
        "$fixture_lines\n" +
        "EOF\n" +
        "if [ \"$fixture_count\" -le 0 ]; then " +
            "echo \"[verify_backend_egraph_cost] missing fixture (none from list exist)\" >&2; " +
            "exit 2; " +
        "fi; " +
        "if [ \"$determinism_mismatch\" -gt \"$max_determinism_mismatch\" ]; then " +
            "echo \"[verify_backend_egraph_cost] determinism mismatch exceeds threshold: mismatch=$determinism_mismatch max=$max_determinism_mismatch\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$enforce_binary_hash\" = \"1\" ] && [ \"$binary_hash_mismatch\" -gt \"$max_binary_hash_mismatch\" ]; then " +
            "echo \"[verify_backend_egraph_cost] binary hash mismatch exceeds threshold: mismatch=$binary_hash_mismatch max=$max_binary_hash_mismatch\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$marker_ok\" != \"1\" ]; then " +
            "echo \"[verify_backend_egraph_cost] backend driver missing egraph marker\" >&2; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"mode=$mode\"; " +
            "echo \"driver=$driver\"; " +
            "echo \"marker_ok=$marker_ok\"; " +
            "echo \"fixture_count=$fixture_count\"; " +
            "echo \"report_count=$report_count\"; " +
            "echo \"candidates_total=$candidates_total\"; " +
            "echo \"extracted_total=$extracted_total\"; " +
            "echo \"determinism_mismatch=$determinism_mismatch\"; " +
            "echo \"max_determinism_mismatch=$max_determinism_mismatch\"; " +
            "echo \"enforce_binary_hash=$enforce_binary_hash\"; " +
            "echo \"binary_hash_mismatch=$binary_hash_mismatch\"; " +
            "echo \"max_binary_hash_mismatch=$max_binary_hash_mismatch\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_egraph_cost_status=ok\"; " +
            "echo \"backend_egraph_cost_mode=$mode\"; " +
            "echo \"backend_egraph_cost_driver=$driver\"; " +
            "echo \"backend_egraph_cost_marker_ok=$marker_ok\"; " +
            "echo \"backend_egraph_cost_fixture_count=$fixture_count\"; " +
            "echo \"backend_egraph_cost_report_count=$report_count\"; " +
            "echo \"backend_egraph_cost_candidates_total=$candidates_total\"; " +
            "echo \"backend_egraph_cost_extracted_total=$extracted_total\"; " +
            "echo \"backend_egraph_cost_determinism_mismatch=$determinism_mismatch\"; " +
            "echo \"backend_egraph_cost_max_determinism_mismatch=$max_determinism_mismatch\"; " +
            "echo \"backend_egraph_cost_enforce_binary_hash=$enforce_binary_hash\"; " +
            "echo \"backend_egraph_cost_binary_hash_mismatch=$binary_hash_mismatch\"; " +
            "echo \"backend_egraph_cost_max_binary_hash_mismatch=$max_binary_hash_mismatch\"; " +
            "echo \"backend_egraph_cost_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_egraph_cost ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendDodOptRegression(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_dod_opt_regression] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_dod_opt_regression\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_dod_opt_regression.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_dod_opt_regression.snapshot.env\"; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then echo \"[verify_backend_dod_opt_regression] missing tooling binary: $tool\" >&2; exit 1; fi; " +
        "driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r' || true)\"; " +
        "if [ \"$driver\" = \"\" ]; then driver=\"artifacts/backend_driver/cheng\"; fi; " +
        "target=\"${BACKEND_TARGET:-$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "mode=\"runtime\"; marker_ok=0; " +
        "if [ -x \"$driver\" ] && command -v strings >/dev/null 2>&1; then " +
            "if strings \"$driver\" 2>/dev/null | rg -q 'uir_opt2.noalias|uir_opt2.egraph|p4_phase_v1'; then marker_ok=1; fi; " +
        "fi; " +
        "source_ok=1; " +
        "for file in src/backend/uir/uir_noalias_pass.cheng src/backend/uir/uir_egraph_cost.cheng src/backend/uir/uir_opt.cheng src/backend/tooling/backend_driver.cheng; do " +
            "if [ ! -f \"$file\" ]; then source_ok=0; fi; " +
        "done; " +
        "for pat in 'uir_opt2\\.noalias' 'uir_opt2\\.egraph' 'single_ir_dual_phase' 'p4_phase_v1'; do " +
            "if ! rg -q \"$pat\" src/backend/uir/uir_opt.cheng src/backend/tooling/backend_driver.cheng; then source_ok=0; fi; " +
        "done; " +
        "if [ \"$source_ok\" != \"1\" ]; then " +
            "echo \"[verify_backend_dod_opt_regression] source contract markers missing\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$marker_ok\" != \"1\" ]; then " +
            "echo \"[verify_backend_dod_opt_regression] backend driver missing opt2 markers\" >&2; " +
            "exit 1; " +
        "fi; " +
        "fixture_list=\"${BACKEND_DOD_OPT_FIXTURES:-tests/cheng/backend/fixtures/return_opt2_sroa_deref.cheng;tests/cheng/backend/fixtures/return_opt2_noalias_mem2reg_load.cheng;tests/cheng/backend/fixtures/return_opt2_inline_dce.cheng;tests/cheng/backend/fixtures/return_opt2_algebraic.cse.cheng}\"; " +
        "fixture_lines=\"$(printf '%s\\n' \"$fixture_list\" | tr ';' '\\n' | tr '\\r' '\\n' | sed -e '/^[[:space:]]*$/d')\"; " +
        "min_probe_count=\"${BACKEND_DOD_OPT_MIN_PROBE_COUNT:-3}\"; " +
        "case \"$min_probe_count\" in ''|*[!0-9]*) min_probe_count=3 ;; esac; " +
        "min_egraph_reports=\"${BACKEND_DOD_OPT_MIN_EGRAPH_REPORTS:-0}\"; " +
        "case \"$min_egraph_reports\" in ''|*[!0-9]*) min_egraph_reports=0 ;; esac; " +
        "probe_count=0; proof_backed_changes_total=0; egraph_report_count_total=0; changed_funcs_total=0; unknown_slot_clobbers_total=0; unknown_global_clobbers_total=0; kill_events_total=0; " +
        "while IFS= read -r fixture; do " +
            "[ \"$fixture\" = \"\" ] && continue; " +
            "if [ ! -f \"$fixture\" ]; then continue; fi; " +
            "probe_count=$((probe_count + 1)); " +
            "out_bin=\"$out_dir/dod_opt_probe.$probe_count.bin\"; log=\"$out_dir/dod_opt_probe.$probe_count.log\"; " +
            "set +e; " +
            "env ABI=v2_noptr MM=orc BACKEND_TARGET=\"$target\" BACKEND_LINKER=system BACKEND_RUNTIME=off BACKEND_NO_RUNTIME_C=0 BACKEND_EMIT=exe BACKEND_OPT_LEVEL=2 BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_INCREMENTAL=0 BACKEND_JOBS=1 STAGE1_STD_NO_POINTERS=0 STAGE1_STD_NO_POINTERS_STRICT=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 UIR_PROFILE=0 BACKEND_PROFILE=0 UIR_NOALIAS=1 UIR_NOALIAS_REQUIRE_PROOF=1 UIR_EGRAPH_ITERS=3 UIR_EGRAPH_REQUIRE_PROOF=1 UIR_EGRAPH_REPORT=1 BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$out_bin\" \"$driver\" >\"$log\" 2>&1; " +
            "rc=\"$?\"; " +
            "set -e; " +
            "if [ \"$rc\" -ne 0 ] || [ ! -s \"$out_bin\" ]; then " +
                "echo \"[verify_backend_dod_opt_regression] runtime probe compile failed fixture=$fixture\" >&2; " +
                "sed -n '1,120p' \"$log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "if ! rg -q '^noalias_report' \"$log\"; then " +
                "echo \"[verify_backend_dod_opt_regression] noalias_report missing fixture=$fixture\" >&2; " +
                "exit 1; " +
            "fi; " +
            "proof_backed_changes_total=$((proof_backed_changes_total + $(awk -F 'proof_backed_changes=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "egraph_report_count_total=$((egraph_report_count_total + $(rg -c '^egraph_report' \"$log\" 2>/dev/null || echo 0))); " +
            "changed_funcs_total=$((changed_funcs_total + $(awk -F 'changed_funcs=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "unknown_slot_clobbers_total=$((unknown_slot_clobbers_total + $(awk -F 'unknown_slot_clobbers=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "unknown_global_clobbers_total=$((unknown_global_clobbers_total + $(awk -F 'unknown_global_clobbers=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
            "kill_events_total=$((kill_events_total + $(awk -F 'kill_events=' '/^noalias_report/{split($2,a,\"\\t\"); s+=a[1]+0} END{print s+0}' \"$log\" 2>/dev/null || echo 0))); " +
        "done <<EOF\n" +
        "$fixture_lines\n" +
        "EOF\n" +
        "if [ \"$probe_count\" -le 0 ]; then " +
            "echo \"[verify_backend_dod_opt_regression] missing fixture (none from list exist)\" >&2; " +
            "exit 2; " +
        "fi; " +
        "if [ \"$probe_count\" -lt \"$min_probe_count\" ]; then " +
            "echo \"[verify_backend_dod_opt_regression] insufficient probe coverage: probe_count=$probe_count min=$min_probe_count\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$proof_backed_changes_total\" -le 0 ]; then " +
            "echo \"[verify_backend_dod_opt_regression] no proof-backed optimization changes observed\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$egraph_report_count_total\" -lt \"$min_egraph_reports\" ]; then " +
            "echo \"[verify_backend_dod_opt_regression] insufficient egraph_report evidence: count=$egraph_report_count_total min=$min_egraph_reports\" >&2; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"mode=$mode\"; " +
            "echo \"driver=$driver\"; " +
            "echo \"marker_ok=$marker_ok\"; " +
            "echo \"min_probe_count=$min_probe_count\"; " +
            "echo \"min_egraph_reports=$min_egraph_reports\"; " +
            "echo \"probe_count=$probe_count\"; " +
            "echo \"proof_backed_changes_total=$proof_backed_changes_total\"; " +
            "echo \"egraph_report_count_total=$egraph_report_count_total\"; " +
            "echo \"changed_funcs_total=$changed_funcs_total\"; " +
            "echo \"unknown_slot_clobbers_total=$unknown_slot_clobbers_total\"; " +
            "echo \"unknown_global_clobbers_total=$unknown_global_clobbers_total\"; " +
            "echo \"kill_events_total=$kill_events_total\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_dod_opt_regression_status=ok\"; " +
            "echo \"backend_dod_opt_regression_mode=$mode\"; " +
            "echo \"backend_dod_opt_regression_driver=$driver\"; " +
            "echo \"backend_dod_opt_regression_marker_ok=$marker_ok\"; " +
            "echo \"backend_dod_opt_regression_min_probe_count=$min_probe_count\"; " +
            "echo \"backend_dod_opt_regression_min_egraph_reports=$min_egraph_reports\"; " +
            "echo \"backend_dod_opt_regression_probe_count=$probe_count\"; " +
            "echo \"backend_dod_opt_regression_proof_backed_changes_total=$proof_backed_changes_total\"; " +
            "echo \"backend_dod_opt_regression_egraph_report_count_total=$egraph_report_count_total\"; " +
            "echo \"backend_dod_opt_regression_changed_funcs_total=$changed_funcs_total\"; " +
            "echo \"backend_dod_opt_regression_unknown_slot_clobbers_total=$unknown_slot_clobbers_total\"; " +
            "echo \"backend_dod_opt_regression_unknown_global_clobbers_total=$unknown_global_clobbers_total\"; " +
            "echo \"backend_dod_opt_regression_kill_events_total=$kill_events_total\"; " +
            "echo \"backend_dod_opt_regression_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_dod_opt_regression ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendLinkerAbiCore(root: str): int32 =
    let hostTag: str = tooling_detectHostTag(root)
    if !strutil.startsWith(hostTag, "darwin_"):
        tooling_printErr("[verify_backend_linker_abi_core] host-only gate currently requires darwin host; host=" + hostTag)
        return 2
    let target: str = tooling_detectHostTarget(root)
    let driver: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    let fixture: str = tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/hello_importc_puts.cheng")
    let outDir: str = tooling_pathAbsolute(root, "artifacts/backend_linker_abi_core")
    let outExe: str = os.joinPath(outDir, "hello_importc_puts." + target + ".self")
    let logPath: str = os.joinPath(outDir, "build.host.log")
    let reportPath: str = os.joinPath(outDir, "verify_backend_linker_abi_core.report.txt")
    let snapshotPath: str = os.joinPath(outDir, "verify_backend_linker_abi_core.snapshot.env")
    if !tooling_isExecutable(root, driver):
        tooling_printErr("[verify_backend_linker_abi_core] missing canonical driver: " + driver)
        tooling_printErr("  hint: artifacts/tooling_cmd/cheng_tooling build-backend-driver")
        return 1
    let cmd: str =
        "set -eu; " +
        "out_dir=" + tooling_shellQuote(outDir) + "; " +
        "out=" + tooling_shellQuote(outExe) + "; " +
        "log=" + tooling_shellQuote(logPath) + "; " +
        "report=" + tooling_shellQuote(reportPath) + "; " +
        "snapshot=" + tooling_shellQuote(snapshotPath) + "; " +
        "fixture=" + tooling_shellQuote(fixture) + "; " +
        "driver=" + tooling_shellQuote(driver) + "; " +
        "target=" + tooling_shellQuote(target) + "; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then echo \"[verify_backend_linker_abi_core] missing tooling binary: $tool\" >&2; exit 1; fi; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "set +e; " +
        "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER " +
            "ABI=v2_noptr " +
            "CACHE=0 " +
            "STAGE1_NO_POINTERS_NON_C_ABI=0 " +
            "STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 " +
            "" +
            "" +
            "BACKEND_OPT_LEVEL=2 " +
            "\"$tool\" cheng --target:\"$target\" --in:\"$fixture\" --out:\"$out\" >\"$log\" 2>&1; " +
        "rc=\"$?\"; " +
        "set -e; " +
        "if [ \"$rc\" -ne 0 ] || [ ! -s \"$out\" ]; then " +
            "echo \"[verify_backend_linker_abi_core] host self-link build failed rc=$rc\" >&2; " +
            "tail -n 80 \"$log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "magic=\"$(od -An -tx1 -N4 \"$out\" 2>/dev/null | tr -d ' \\n')\"; " +
        "fmt=\"unknown\"; " +
        "case \"$magic\" in cffaedfe*) fmt=\"mach-o64\" ;; 7f454c46*) fmt=\"elf64\" ;; 4d5a*) fmt=\"pe64\" ;; esac; " +
        "if [ \"$fmt\" != \"mach-o64\" ]; then " +
            "echo \"[verify_backend_linker_abi_core] expected mach-o64 host output, got $fmt\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if ! command -v otool >/dev/null 2>&1; then " +
            "echo \"[verify_backend_linker_abi_core] missing otool\" >&2; " +
            "exit 1; " +
        "fi; " +
        "otool -l \"$out\" >\"$out_dir/host.meta.txt\"; " +
        "strings \"$out\" >\"$out_dir/host.strings.txt\" 2>/dev/null || true; " +
        "main01=\"0\"; puts01=\"0\"; " +
        "if command -v nm >/dev/null 2>&1 && nm \"$out\" >\"$out_dir/host.nm.txt\" 2>/dev/null; then " +
            "if grep -Eq '[[:space:]]+[Tt][[:space:]]+_?main$' \"$out_dir/host.nm.txt\"; then main01=\"1\"; fi; " +
            "if grep -Eq '[[:space:]]+[Uu][[:space:]]+_?puts(@.*)?$' \"$out_dir/host.nm.txt\"; then puts01=\"1\"; fi; " +
        "else " +
            "if grep -Eq '(^|[^A-Za-z0-9_])_?main([^A-Za-z0-9_]|$)' \"$out_dir/host.strings.txt\"; then main01=\"1\"; fi; " +
            "if grep -Eq '(^|[^A-Za-z0-9_])_?puts([^A-Za-z0-9_]|$)' \"$out_dir/host.strings.txt\"; then puts01=\"1\"; fi; " +
        "fi; " +
        "dynamic01=\"0\"; " +
        "if grep -Eq 'LC_DYLD_INFO|LC_LOAD_DYLINKER' \"$out_dir/host.meta.txt\"; then dynamic01=\"1\"; fi; " +
        "if [ \"$main01\" != \"1\" ] || [ \"$puts01\" != \"1\" ] || [ \"$dynamic01\" != \"1\" ]; then " +
            "echo \"[verify_backend_linker_abi_core] manifest checks failed main=$main01 puts=$puts01 dynamic=$dynamic01\" >&2; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"platform.os=darwin\"; " +
            "echo \"binary.format=$fmt\"; " +
            "echo \"linker.mode=self\"; " +
            "echo \"entry.main=$main01\"; " +
            "echo \"import.puts=$puts01\"; " +
            "echo \"meta.dynamic=$dynamic01\"; " +
            "echo \"target=$target\"; " +
            "echo \"driver=$driver\"; " +
            "echo \"output=$out\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_linker_abi_core_status=ok\"; " +
            "echo \"backend_linker_abi_core_target=$target\"; " +
            "echo \"backend_linker_abi_core_driver=$driver\"; " +
            "echo \"backend_linker_abi_core_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_linker_abi_core ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendLinkerAbiCoreCross(root: str, enforceRaw: str, targetsRaw: str): int32 =
    let driver: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    let outDir: str = tooling_pathAbsolute(root, "artifacts/backend_linker_abi_core_cross")
    let reportPath: str = os.joinPath(outDir, "verify_backend_linker_abi_core_cross.report.txt")
    let snapshotPath: str = os.joinPath(outDir, "verify_backend_linker_abi_core_cross.snapshot.env")
    let defaultTargetsReportFile: str = tooling_pathAbsolute(root, "src/tooling/linker_abi_core_cross.targets.report")
    let defaultTargetsCompatFile: str = tooling_pathAbsolute(root, "src/tooling/linker_abi_core_cross.targets")
    let fixtureA: str = tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/return_i64.cheng")
    let fixtureB: str = tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/return_add.cheng")
    if !tooling_isExecutable(root, driver):
        tooling_printErr("[verify_backend_linker_abi_core_cross] missing canonical driver: " + driver)
        tooling_printErr("  hint: artifacts/tooling_cmd/cheng_tooling build-backend-driver")
        return 1
    let enforce: str = tooling_isTrue(enforceRaw) ? "1" : "0"
    let targetsCsvRaw: str = strutil.strip(targetsRaw)
    var targetsCsv: str = "arm64-apple-darwin,aarch64-unknown-linux-gnu,aarch64-pc-windows-msvc"
    if tooling_pathExists(defaultTargetsReportFile):
        targetsCsv = "@" + defaultTargetsReportFile
    else:
        if tooling_pathExists(defaultTargetsCompatFile):
            targetsCsv = "@" + defaultTargetsCompatFile
    if tooling_strNonEmpty(targetsCsvRaw):
        targetsCsv = targetsCsvRaw
    let cmd: str =
        "set -eu; " +
        "driver=" + tooling_shellQuote(driver) + "; " +
        "out_dir=" + tooling_shellQuote(outDir) + "; " +
        "report=" + tooling_shellQuote(reportPath) + "; " +
        "snapshot=" + tooling_shellQuote(snapshotPath) + "; " +
        "fixture_a=" + tooling_shellQuote(fixtureA) + "; " +
        "fixture_b=" + tooling_shellQuote(fixtureB) + "; " +
        "enforce=" + tooling_shellQuote(enforce) + "; " +
        "targets_spec=" + tooling_shellQuote(targetsCsv) + "; " +
        "targets_csv=\"$targets_spec\"; " +
        "if [ \"${targets_spec#@}\" != \"$targets_spec\" ]; then " +
            "targets_file=\"${targets_spec#@}\"; " +
            "if [ ! -f \"$targets_file\" ]; then " +
                "echo \"[verify_backend_linker_abi_core_cross] targets file not found: $targets_file\" >&2; " +
                "exit 2; " +
            "fi; " +
            "targets_csv=\"$(cat \"$targets_file\" | tr '\\n' ',' | tr -d '[:space:]' | sed 's/,,*/,/g; s/^,//; s/,$//')\"; " +
        "else " +
            "targets_csv=\"$(printf '%s' \"$targets_spec\" | tr -d '[:space:]')\"; " +
        "fi; " +
        "if [ \"$targets_csv\" = \"\" ]; then " +
            "echo \"[verify_backend_linker_abi_core_cross] empty targets list\" >&2; " +
            "exit 2; " +
        "fi; " +
        "fixture=\"$fixture_a\"; " +
        "if [ ! -f \"$fixture\" ] && [ -f \"$fixture_b\" ]; then fixture=\"$fixture_b\"; fi; " +
        "if [ ! -f \"$fixture\" ]; then " +
            "echo \"[verify_backend_linker_abi_core_cross] missing fixture: $fixture_a or $fixture_b\" >&2; " +
            "exit 2; " +
        "fi; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "fail_count=0; total=0; " +
        "targets=\"$(printf '%s' \"$targets_csv\" | tr ',' ' ')\"; " +
        ": >\"$report\"; " +
        "for target in $targets; do " +
            "case \"$target\" in *[!A-Za-z0-9._-]* ) " +
                "echo \"[verify_backend_linker_abi_core_cross] invalid target token: $target\" >&2; " +
                "exit 2 ;; " +
            "esac; " +
            "total=$((total+1)); " +
            "safe=\"$(printf '%s' \"$target\" | tr -c 'A-Za-z0-9._-' '_')\"; " +
            "out=\"$out_dir/probe.$safe.self\"; " +
            "log=\"$out_dir/probe.$safe.log\"; " +
            "set +e; " +
            "env ABI=v2_noptr CACHE=0 STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 BACKEND_LINKER=self BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_INCREMENTAL=0 BACKEND_JOBS=1 BACKEND_NO_RUNTIME_C=1 BACKEND_INTERNAL_ALLOW_EMIT_OBJ=0 BACKEND_EMIT=exe BACKEND_DIRECT_EXE=1 BACKEND_LINKERLESS_INMEM=1 BACKEND_TARGET=\"$target\" BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$out\" \"$driver\" >\"$log\" 2>&1; " +
            "rc=\"$?\"; " +
            "set -e; " +
            "status=ok; " +
            "if [ \"$rc\" -ne 0 ] || [ ! -s \"$out\" ]; then status=fail; fail_count=$((fail_count+1)); fi; " +
            "printf 'target.%s.status=%s\\n' \"$target\" \"$status\" >>\"$report\"; " +
            "printf 'target.%s.rc=%s\\n' \"$target\" \"$rc\" >>\"$report\"; " +
            "printf 'target.%s.log=%s\\n' \"$target\" \"$log\" >>\"$report\"; " +
            "printf 'target.%s.output=%s\\n' \"$target\" \"$out\" >>\"$report\"; " +
        "done; " +
        "mode=report; if [ \"$enforce\" = \"1\" ]; then mode=enforce; fi; " +
        "if [ \"$fail_count\" -eq 0 ]; then status=ok; else status=degraded; fi; " +
        "printf 'status=%s\\n' \"$status\" >>\"$report\"; " +
        "printf 'mode=%s\\n' \"$mode\" >>\"$report\"; " +
        "printf 'target_total=%s\\n' \"$total\" >>\"$report\"; " +
        "printf 'target_fail_count=%s\\n' \"$fail_count\" >>\"$report\"; " +
        "printf 'targets_csv=%s\\n' \"$targets_csv\" >>\"$report\"; " +
        "printf 'driver=%s\\n' \"$driver\" >>\"$report\"; " +
        "printf 'fixture=%s\\n' \"$fixture\" >>\"$report\"; " +
        "{ " +
            "echo \"backend_linker_abi_core_cross_status=$status\"; " +
            "echo \"backend_linker_abi_core_cross_mode=$mode\"; " +
            "echo \"backend_linker_abi_core_cross_fail_count=$fail_count\"; " +
            "echo \"backend_linker_abi_core_cross_targets=$targets_csv\"; " +
            "echo \"backend_linker_abi_core_cross_report=$report\"; " +
            "echo \"backend_linker_abi_core_cross_driver=$driver\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$enforce\" = \"1\" ] && [ \"$fail_count\" -ne 0 ]; then " +
            "echo \"[verify_backend_linker_abi_core_cross] cross-target self-link failed targets=$fail_count\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if [ \"$fail_count\" -ne 0 ]; then " +
            "echo \"verify_backend_linker_abi_core_cross ok (degraded; enforce=0)\"; " +
        "else " +
            "echo \"verify_backend_linker_abi_core_cross ok\"; " +
        "fi"
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendLinkerAbiCoreCrossFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var enforceRaw: str = os.getEnvDefault("BACKEND_LINKER_ABI_CORE_CROSS_ENFORCE", "1")
    var targetsRaw: str = os.getEnvDefault("BACKEND_LINKER_ABI_CORE_CROSS_TARGETS", "")
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("verify_backend_linker_abi_core_cross options:")
            tooling_printOut("  --enforce:0|1            fail when any target self-link probe fails")
            tooling_printOut("  --report-only            alias of --enforce:0")
            tooling_printOut("  --targets:<csv|@file>    probe targets; @file accepts csv/newline list")
            tooling_printOut("  env: BACKEND_LINKER_ABI_CORE_CROSS_ENFORCE=0|1 (default 1)")
            tooling_printOut("       BACKEND_LINKER_ABI_CORE_CROSS_TARGETS=<csv|@file>")
            tooling_printOut("  default targets file: src/tooling/linker_abi_core_cross.targets.report")
            tooling_printOut("  host-required targets file: src/tooling/linker_abi_core_cross.targets.host_required")
            return 0
        if tooling_strEq(arg, "--report-only"):
            enforceRaw = "0"
            i = i + 1
            continue
        if tooling_strEq(arg, "--enforce"):
            enforceRaw = "1"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--enforce:"):
            enforceRaw = strings.dropPrefix(arg, "--enforce:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--targets:"):
            targetsRaw = strings.dropPrefix(arg, "--targets:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown verify_backend_linker_abi_core_cross arg: " + arg)
        return 1
    return tooling_cmdVerifyBackendLinkerAbiCoreCross(root, enforceRaw, targetsRaw)

fn tooling_cmdVerifyBackendNoptrExemptionScope(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_noptr_exemption_scope] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_noptr_exemption_scope\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "hits=\"$out_dir/noptr_exemption_hits.txt\"; " +
        "bad=\"$out_dir/noptr_exemption_bad.txt\"; " +
        "report=\"$out_dir/verify_backend_noptr_exemption_scope.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_noptr_exemption_scope.snapshot.env\"; " +
        "rm -f src/tooling/.tmp_backend_prod_closure.debug.sh src/tooling/.tmp_backend_prod_closure.debug.env || true; " +
        "rg -n -P --glob '*.cheng' --glob '*.sh' '^(?![[:space:]]*#).*STAGE1_NO_POINTERS_NON_C_ABI(_INTERNAL)?=0' src >\"$hits\" || true; " +
        ": >\"$bad\"; " +
        "while IFS= read -r line; do " +
            "[ \"$line\" != \"\" ] || continue; " +
            "file=\"${line%%:*}\"; " +
            "case \"$file\" in " +
                "src/tooling/cheng_tooling.cheng|src/tooling/cheng_tooling_embedded_inline.cheng|src/tooling/.tmp_*) " +
                    "continue ;; " +
            "esac; " +
            "printf '%s\\n' \"$line\" >>\"$bad\"; " +
        "done <\"$hits\"; " +
        "if [ -s \"$bad\" ]; then " +
            "echo \"[Error] no-pointer exemption found outside allowlist:\" >&2; " +
            "sed -n '1,200p' \"$bad\" | sed 's/^/  - /' >&2; " +
            "exit 1; " +
        "fi; " +
        "count=\"$(wc -l <\"$hits\" | tr -d '[:space:]')\"; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"hit_count=$count\"; " +
            "echo \"hits=$hits\"; " +
            "echo \"allowlist=src/tooling/cheng_tooling.cheng,src/tooling/cheng_tooling_embedded_inline.cheng,src/tooling/.tmp_*\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_noptr_exemption_scope_status=ok\"; " +
            "echo \"backend_noptr_exemption_scope_hit_count=$count\"; " +
            "echo \"backend_noptr_exemption_scope_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_noptr_exemption_scope ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendZeroScriptClosure(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_zero_script_closure] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_zero_script_closure\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "wrappers=\"$out_dir/shell_wrappers.txt\"; " +
        "inlines=\"$out_dir/inline_files.txt\"; " +
        "report=\"$out_dir/verify_backend_zero_script_closure.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_zero_script_closure.snapshot.env\"; " +
        "find src/tooling -type f -name '.tmp_*.sh' -delete 2>/dev/null || true; " +
        "find src/tooling -type f -name '*.sh' | LC_ALL=C sort >\"$wrappers\"; " +
        "if [ -s \"$wrappers\" ]; then " +
            "echo \"[verify_backend_zero_script_closure] unexpected shell wrappers under src/tooling:\" >&2; " +
            "sed -n '1,200p' \"$wrappers\" | sed 's/^/  - /' >&2; " +
            "exit 1; " +
        "fi; " +
        "find src/tooling -type f -name '*.inline' | LC_ALL=C sort >\"$inlines\"; " +
        "if [ -s \"$inlines\" ]; then " +
            "echo \"[verify_backend_zero_script_closure] unexpected inline files under src/tooling:\" >&2; " +
            "sed -n '1,200p' \"$inlines\" | sed 's/^/  - /' >&2; " +
            "exit 1; " +
        "fi; " +
        "if rg -q '\\bCHENG_(BACKEND_|STAGE1_|MM|CACHE)' src/tooling/cheng_tooling.cheng src/tooling/cheng_tooling_embedded_inline.cheng; then " +
            "echo \"[verify_backend_zero_script_closure] legacy CHENG_* env compatibility aliases still present\" >&2; " +
            "rg -n '\\bCHENG_(BACKEND_|STAGE1_|MM|CACHE)' src/tooling/cheng_tooling.cheng src/tooling/cheng_tooling_embedded_inline.cheng | sed -n '1,40p' >&2; " +
            "exit 1; " +
        "fi; " +
        "if rg -n 'probeAllowSystemFallback|needsMainFallback|allowObjFallback' src/tooling/cheng_tooling.cheng | rg -v 'verify_backend_zero_script_closure' >/dev/null 2>&1; then " +
            "echo \"[verify_backend_zero_script_closure] stage0 compile-probe fallback path still present\" >&2; " +
            "rg -n 'probeAllowSystemFallback|needsMainFallback|allowObjFallback' src/tooling/cheng_tooling.cheng | rg -v 'verify_backend_zero_script_closure' | sed -n '1,40p' >&2; " +
            "exit 1; " +
        "fi; " +
        "if ! rg -q 'tooling_strEq\\(first, \"compile\"\\) \\|\\| tooling_strEq\\(first, \"cheng\"\\) \\|\\| tooling_strEq\\(first, \"chengc\"\\)' src/tooling/cheng_tooling.cheng; then " +
            "echo \"[verify_backend_zero_script_closure] missing native chengc route in cheng_tooling main dispatch\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if ! rg -q 'tooling_strEq\\(selfName, \"backend_prod_closure\"\\)' src/tooling/cheng_tooling.cheng; then " +
            "echo \"[verify_backend_zero_script_closure] missing native backend_prod_closure multicall route\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if ! rg -q 'tooling_strEq\\(first, \"backend_prod_closure\"\\)' src/tooling/cheng_tooling.cheng; then " +
            "echo \"[verify_backend_zero_script_closure] missing native backend_prod_closure command route\" >&2; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"shell_wrapper_count=0\"; " +
            "echo \"inline_count=0\"; " +
            "echo \"chengc_native_route=1\"; " +
            "echo \"backend_prod_closure_native_route=1\"; " +
            "echo \"legacy_cheng_env_alias=0\"; " +
            "echo \"stage0_probe_fallback=0\"; " +
            "echo \"wrappers=$wrappers\"; " +
            "echo \"inlines=$inlines\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_zero_script_closure_status=ok\"; " +
            "echo \"backend_zero_script_closure_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_zero_script_closure ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendRawptrSurfaceForbid(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_rawptr_surface_forbid] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_rawptr_surface_forbid\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/backend_rawptr_surface_forbid.report.txt\"; " +
        "snapshot=\"$out_dir/backend_rawptr_surface_forbid.snapshot.env\"; " +
        "hits_file=\"$out_dir/backend_rawptr_surface_forbid.hits.txt\"; " +
        "miss_file=\"$out_dir/backend_rawptr_surface_forbid.miss.txt\"; " +
        "status=\"ok\"; : >\"$hits_file\"; : >\"$miss_file\"; " +
        "require_hit() { file=\"$1\"; pattern=\"$2\"; label=\"$3\"; " +
            "if rg -nF -- \"$pattern\" \"$file\" >/dev/null 2>&1; then " +
                "printf '%s\\t%s\\t%s\\n' \"hit\" \"$label\" \"$file\" >>\"$hits_file\"; return 0; " +
            "fi; " +
            "printf '%s\\t%s\\t%s\\t%s\\n' \"miss\" \"$label\" \"$file\" \"$pattern\" >>\"$miss_file\"; " +
            "status=\"drift\"; return 1; " +
        "}; " +
        "require_absent() { file=\"$1\"; pattern=\"$2\"; label=\"$3\"; " +
            "if rg -nF -- \"$pattern\" \"$file\" >/dev/null 2>&1; then " +
                "printf '%s\\t%s\\t%s\\t%s\\n' \"unexpected\" \"$label\" \"$file\" \"$pattern\" >>\"$miss_file\"; " +
                "status=\"drift\"; return 1; " +
            "fi; " +
            "printf '%s\\t%s\\t%s\\n' \"absent\" \"$label\" \"$file\" >>\"$hits_file\"; return 0; " +
        "}; " +
        "diag_file=\"src/stage1/diagnostics.cheng\"; parser_file=\"src/stage1/parser.cheng\"; sem_file=\"src/stage1/semantics.cheng\"; cmdline_file=\"src/std/cmdline.cheng\"; " +
        "for required in \"$diag_file\" \"$parser_file\" \"$sem_file\" \"$cmdline_file\"; do " +
            "if [ ! -f \"$required\" ]; then echo \"[verify_backend_rawptr_surface_forbid] missing file: $required\" >&2; exit 2; fi; " +
        "done; " +
        "require_hit \"$diag_file\" \"fn rawPointerForbidMessage(base: str): str =\" \"diagnostics.rawptr_message_fn\"; " +
        "require_hit \"$diag_file\" \"slice/tuple/handle/borrow\" \"diagnostics.rawptr_replacements\"; " +
        "require_absent \"$parser_file\" \"pointer is removed; use void*\" \"parser.remove_old_voidptr_suggestion\"; " +
        "require_absent \"$parser_file\" \"Empty subscript dereference is not supported; use *p\" \"parser.remove_old_deref_suggestion\"; " +
        "require_hit \"$parser_file\" \"rawPointerForbidMessage(\\\"pointer alias is removed and bare void* is forbidden\\\")\" \"parser.pointer_alias_forbid\"; " +
        "require_hit \"$parser_file\" \"rawPointerForbidMessage(\\\"var is not allowed on pointer types\\\")\" \"parser.var_pointer_forbid\"; " +
        "require_hit \"$parser_file\" \"rawPointerForbidMessage(\\\"Empty subscript dereference is not supported in no-pointer mode\\\")\" \"parser.empty_subscript_forbid\"; " +
        "require_hit \"$parser_file\" \"rawPointerForbidMessage(\\\"Pointer member access is forbidden in no-pointer mode\\\")\" \"parser.pointer_member_forbid\"; " +
        "require_hit \"$sem_file\" \"fn semIsVoidPtrTypeNode(n: Node): bool =\" \"semantics.voidptr_detect_fn\"; " +
        "require_hit \"$sem_file\" \"rawPointerForbidMessage(\\\"no-pointer policy: bare void* surface is forbidden outside C ABI modules\\\")\" \"semantics.voidptr_forbid_diag\"; " +
        "require_hit \"$sem_file\" \"rawPointerForbidMessage(\\\"no-pointer policy: pointer types are forbidden outside C ABI modules\\\")\" \"semantics.pointer_type_forbid_diag\"; " +
        "require_hit \"$sem_file\" \"rawPointerForbidMessage(\\\"no-pointer policy: pointer dereference is forbidden outside C ABI modules\\\")\" \"semantics.pointer_deref_forbid_diag\"; " +
        "require_hit \"$sem_file\" \"rawPointerForbidMessage(\\\"no-pointer policy: pointer operation is forbidden outside C ABI modules: \\\" + callName)\" \"semantics.pointer_op_forbid_diag\"; " +
        "require_hit \"$cmdline_file\" \"fn __cheng_rt_paramCount(): int32\" \"cmdline.runtime_param_count\"; " +
        "require_hit \"$cmdline_file\" \"fn __cheng_rt_paramStr(i: int32): cstring\" \"cmdline.runtime_param_str\"; " +
        "require_absent \"$cmdline_file\" \"void*\" \"cmdline.no_voidptr_surface\"; " +
        "require_absent \"$cmdline_file\" \"ptr_add\" \"cmdline.no_ptr_add\"; " +
        "require_absent \"$cmdline_file\" \"alloc(\" \"cmdline.no_alloc\"; " +
        "require_absent \"$cmdline_file\" \"copyMem\" \"cmdline.no_copy_mem\"; " +
        "require_absent \"$cmdline_file\" \"setMem\" \"cmdline.no_set_mem\"; " +
        "require_absent \"$cmdline_file\" \"*str*(\" \"cmdline.no_deref_surface\"; " +
        "require_absent \"$cmdline_file\" \"__cheng_setCmdLine(\" \"cmdline.no_legacy_setcmdline\"; " +
        "runtime_probe_status=\"skip\"; " +
        "{ " +
            "echo \"verify_backend_rawptr_surface_forbid report\"; " +
            "echo \"status=$status\"; " +
            "echo \"runtime_probe_status=$runtime_probe_status\"; " +
            "echo \"hits_file=$hits_file\"; " +
            "echo \"miss_file=$miss_file\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_rawptr_surface_forbid_status=$status\"; " +
            "echo \"backend_rawptr_surface_forbid_runtime_probe_status=$runtime_probe_status\"; " +
            "echo \"backend_rawptr_surface_forbid_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$status\" != \"ok\" ]; then " +
            "echo \"[verify_backend_rawptr_surface_forbid] raw pointer surface forbid drift detected\" >&2; " +
            "echo \"  report: $report\" >&2; " +
            "if [ -s \"$miss_file\" ]; then sed -n '1,120p' \"$miss_file\" >&2 || true; fi; " +
            "exit 1; " +
        "fi; " +
        "echo \"verify_backend_rawptr_surface_forbid ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyStage1AstSoaSurface(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_stage1_ast_soa_surface] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_stage1_ast_soa_surface\"; " +
        "baseline_dir=\"artifacts/backend_soa_hardcut_baseline\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\" \"$baseline_dir\"; " +
        "report=\"$out_dir/verify_stage1_ast_soa_surface.report.txt\"; " +
        "snapshot=\"$out_dir/verify_stage1_ast_soa_surface.snapshot.env\"; " +
        "stage1_ref_file=\"$out_dir/stage1_ref_surface.txt\"; " +
        "uir_ref_file=\"$out_dir/uir_ref_surface.txt\"; " +
        "rawptr_file=\"$out_dir/rawptr_surface.txt\"; " +
        "stage1_nil_file=\"$out_dir/stage1_nil_surface.txt\"; " +
        "stage1_compat_file=\"$out_dir/stage1_ast_compat_surface.txt\"; " +
        "uir_compat_file=\"$out_dir/uir_builder_compat_surface.txt\"; " +
        "ast_id_file=\"$out_dir/stage1_ast_id_surface.txt\"; " +
        "status=\"ok\"; " +
        "enforce=\"${BACKEND_STAGE1_AST_SOA_ENFORCE:-1}\"; " +
        "rg -n --glob '*.cheng' '\\bNodeRef\\b' src/stage1 >\"$stage1_ref_file\" || true; " +
        "rg -n --glob '*.cheng' 'UirCoreExpr[[:space:]]*=[[:space:]]*ref|UirCoreStmt[[:space:]]*=[[:space:]]*ref|UirCoreBlock[[:space:]]*=[[:space:]]*ref|\\.blocks\\[|\\.stmts\\[' src/backend/uir src/backend/machine >\"$uir_ref_file\" || true; " +
        "rg -n --glob '*.cheng' 'void\\*\\(|ptr_add\\(|copyMem\\(|setMem\\(' src/stage1 src/backend/uir >\"$rawptr_file\" || true; " +
        "rg -n --glob '*.cheng' '\\bNode\\b[[:space:]]*==[[:space:]]*nil|\\bNode\\b[[:space:]]*!=[[:space:]]*nil' src/stage1 >\"$stage1_nil_file\" || true; " +
        "rg -n 'fn astRef(IsNil|NonNil)\\(v: void\\*\\)|fn astRef(IsNil|NonNil)\\(v: ptr\\)|fn astRef(IsNil|NonNil)\\[T\\]\\(v: T\\*\\)|fn astRef(IsNil|NonNil)\\[T\\]\\(v: T\\[\\]\\)|fn astRef(IsNil|NonNil)\\[T\\]\\(v: T\\)' src/stage1/ast.cheng >\"$stage1_compat_file\" || true; " +
        "rg -n 'fn uirCoreBuildMissingRoutinesFromUir\\(' src/backend/uir/uir_internal/uir_core_builder.cheng >\"$uir_compat_file\" || true; " +
        "rg -n --glob '*.cheng' 'AstNodeId|AstArena|astNodeIdFromNode|astNodeFromId|astArenaFromNodeArena|parseModuleWithDiagnosticsId|parseModuleOutlineWithDiagnosticsId|parseModuleForDepsId|loadSystemModuleId|lowerTypeSyntaxId|checkSemanticsId|monomorphizeId|ownershipAnalyzeId|stage1_parseModuleByMode' src/stage1 >\"$ast_id_file\" || true; " +
        "stage1_ref_count=\"$(wc -l <\"$stage1_ref_file\" | tr -d ' ')\"; " +
        "uir_ref_count=\"$(wc -l <\"$uir_ref_file\" | tr -d ' ')\"; " +
        "rawptr_count=\"$(wc -l <\"$rawptr_file\" | tr -d ' ')\"; " +
        "stage1_nil_count=\"$(wc -l <\"$stage1_nil_file\" | tr -d ' ')\"; " +
        "stage1_compat_count=\"$(wc -l <\"$stage1_compat_file\" | tr -d ' ')\"; " +
        "uir_compat_count=\"$(wc -l <\"$uir_compat_file\" | tr -d ' ')\"; " +
        "ast_id_count=\"$(wc -l <\"$ast_id_file\" | tr -d ' ')\"; " +
        "if [ \"$stage1_ref_count\" != \"0\" ] || [ \"$uir_ref_count\" != \"0\" ] || [ \"$rawptr_count\" != \"0\" ] || [ \"$stage1_nil_count\" != \"0\" ] || [ \"$stage1_compat_count\" != \"0\" ] || [ \"$uir_compat_count\" != \"0\" ] || [ \"$ast_id_count\" = \"0\" ]; then " +
            "status=\"drift\"; " +
        "fi; " +
        "cp \"$stage1_ref_file\" \"$baseline_dir/stage1_ref_surface.txt\"; " +
        "cp \"$uir_ref_file\" \"$baseline_dir/uir_ref_surface.txt\"; " +
        "cp \"$rawptr_file\" \"$baseline_dir/rawptr_surface.txt\"; " +
        "cp \"$stage1_compat_file\" \"$baseline_dir/stage1_ast_compat_surface.txt\"; " +
        "cp \"$uir_compat_file\" \"$baseline_dir/uir_builder_compat_surface.txt\"; " +
        "cp \"$ast_id_file\" \"$baseline_dir/stage1_ast_id_surface.txt\"; " +
        "{ " +
            "echo \"verify_stage1_ast_soa_surface report\"; " +
            "echo \"status=$status\"; " +
            "echo \"enforce=$enforce\"; " +
            "echo \"stage1_ref_count=$stage1_ref_count\"; " +
            "echo \"uir_ref_count=$uir_ref_count\"; " +
            "echo \"rawptr_count=$rawptr_count\"; " +
            "echo \"stage1_nil_count=$stage1_nil_count\"; " +
            "echo \"stage1_compat_count=$stage1_compat_count\"; " +
            "echo \"uir_compat_count=$uir_compat_count\"; " +
            "echo \"stage1_ast_id_count=$ast_id_count\"; " +
            "echo \"stage1_ref_file=$stage1_ref_file\"; " +
            "echo \"uir_ref_file=$uir_ref_file\"; " +
            "echo \"rawptr_file=$rawptr_file\"; " +
            "echo \"stage1_nil_file=$stage1_nil_file\"; " +
            "echo \"stage1_compat_file=$stage1_compat_file\"; " +
            "echo \"uir_compat_file=$uir_compat_file\"; " +
            "echo \"stage1_ast_id_file=$ast_id_file\"; " +
            "echo \"baseline_dir=$baseline_dir\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_stage1_ast_soa_surface_status=$status\"; " +
            "echo \"backend_stage1_ast_soa_surface_enforce=$enforce\"; " +
            "echo \"backend_stage1_ast_soa_surface_report=$report\"; " +
            "echo \"backend_stage1_ast_soa_surface_stage1_ref_count=$stage1_ref_count\"; " +
            "echo \"backend_stage1_ast_soa_surface_uir_ref_count=$uir_ref_count\"; " +
            "echo \"backend_stage1_ast_soa_surface_rawptr_count=$rawptr_count\"; " +
            "echo \"backend_stage1_ast_soa_surface_stage1_nil_count=$stage1_nil_count\"; " +
            "echo \"backend_stage1_ast_soa_surface_stage1_compat_count=$stage1_compat_count\"; " +
            "echo \"backend_stage1_ast_soa_surface_uir_compat_count=$uir_compat_count\"; " +
            "echo \"backend_stage1_ast_soa_surface_stage1_ast_id_count=$ast_id_count\"; " +
            "echo \"backend_stage1_ast_soa_surface_baseline_dir=$baseline_dir\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$status\" != \"ok\" ] && [ \"$enforce\" = \"1\" ]; then " +
            "echo \"[verify_stage1_ast_soa_surface] stage1/uir SoA hard-cut surface drift\" >&2; " +
            "echo \"  report: $report\" >&2; " +
            "sed -n '1,120p' \"$stage1_ref_file\" >&2 || true; " +
            "sed -n '1,120p' \"$uir_ref_file\" >&2 || true; " +
            "sed -n '1,120p' \"$rawptr_file\" >&2 || true; " +
            "sed -n '1,120p' \"$stage1_nil_file\" >&2 || true; " +
            "sed -n '1,120p' \"$stage1_compat_file\" >&2 || true; " +
            "sed -n '1,120p' \"$uir_compat_file\" >&2 || true; " +
            "sed -n '1,120p' \"$ast_id_file\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "echo \"verify_stage1_ast_soa_surface ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendUirSoaSurface(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_uir_soa_surface] rg is required\" >&2; exit 2; " +
        "fi; " +
        "out_dir=\"artifacts/backend_uir_soa_surface\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_uir_soa_surface.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_uir_soa_surface.snapshot.env\"; " +
        "log=\"$out_dir/verify_backend_uir_soa_surface.runtime.log\"; " +
        "exe=\"$out_dir/verify_backend_uir_soa_surface.runtime.exe\"; " +
        "types_file=\"src/backend/uir/uir_internal/uir_core_types.cheng\"; " +
        "opt_file=\"src/backend/uir/uir_opt.cheng\"; " +
        "for pair in " +
            "\"$types_file|UirExprId = int32\" " +
            "\"$types_file|UirStmtId = int32\" " +
            "\"$types_file|UirBlockId = int32\" " +
            "\"$types_file|UirFuncId = int32\" " +
            "\"$types_file|exprKind: UirCoreExprKind[]\" " +
            "\"$types_file|stmtKind: UirCoreStmtKind[]\" " +
            "\"$types_file|blockFirstStmt: int32[]\" " +
            "\"$types_file|succEdges: int32[]\" " +
            "\"$types_file|predEdges: int32[]\" " +
            "\"$opt_file|fn uirEmitSoaReport(module: UirModule): bool =\"; do " +
            "file=\"${pair%%|*}\"; pat=\"${pair#*|}\"; " +
            "if [ ! -f \"$file\" ] || ! rg -qF \"$pat\" \"$file\"; then " +
                "echo \"[verify_backend_uir_soa_surface] missing marker: $file :: $pat\" >&2; " +
                "exit 1; " +
            "fi; " +
        "done; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then echo \"[verify_backend_uir_soa_surface] missing tooling binary: $tool\" >&2; exit 1; fi; " +
        "driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r')\"; " +
        "if [ ! -x \"$driver\" ]; then echo \"[verify_backend_uir_soa_surface] missing backend driver: $driver\" >&2; exit 1; fi; " +
        "fixture=\"tests/cheng/backend/fixtures/return_add.cheng\"; " +
        "if [ ! -f \"$fixture\" ]; then echo \"[verify_backend_uir_soa_surface] missing fixture: $fixture\" >&2; exit 2; fi; " +
        "target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "set +e; " +
        "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER " +
            "ABI=v2_noptr MM=orc " +
            "BACKEND_BUILD_TRACK=dev BACKEND_LINKER=system BACKEND_NO_RUNTIME_C=0 BACKEND_EMIT=exe " +
            "BACKEND_OPT=1 BACKEND_OPT2=1 BACKEND_OPT_LEVEL=2 BACKEND_MULTI=0 BACKEND_MULTI_FORCE=0 BACKEND_INCREMENTAL=0 " +
            "STAGE1_STD_NO_POINTERS=0 STAGE1_STD_NO_POINTERS_STRICT=0 " +
            "STAGE1_NO_POINTERS_NON_C_ABI=0 STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0 " +
            "STAGE1_SKIP_CPROFILE=1 STAGE1_PROFILE=0 " +
            "UIR_PROFILE=1 UIR_SSU=1 UIR_SOA_REPORT=1 UIR_SOA_ENFORCE=1 " +
            "BACKEND_TARGET=\"$target\" GENERIC_MODE=dict GENERIC_SPEC_BUDGET=0 GENERIC_LOWERING=mir_dict " +
            "BACKEND_INPUT=\"$fixture\" BACKEND_OUTPUT=\"$exe\" " +
            "\"$driver\" >\"$log\" 2>&1; " +
        "rc=\"$?\"; " +
        "set -e; " +
        "if [ \"$rc\" -ne 0 ] || [ ! -x \"$exe\" ]; then " +
            "echo \"[verify_backend_uir_soa_surface] runtime probe compile failed\" >&2; " +
            "sed -n '1,160p' \"$log\" >&2 || true; " +
            "exit 1; " +
        "fi; " +
        "runtime_report_mode=\"runtime\"; " +
        "soa_report_line=\"$(rg '^soa_report[[:space:]]+' \"$log\" | tail -n 1 || true)\"; " +
        "if [ \"$soa_report_line\" = \"\" ]; then " +
            "legacy_noalias_line=\"$(rg '^noalias_report[[:space:]]+' \"$log\" | tail -n 1 || true)\"; " +
            "legacy_ssu_line=\"$(rg '^ssu_report[[:space:]]+' \"$log\" | tail -n 1 || true)\"; " +
            "if [ \"$legacy_noalias_line\" = \"\" ] || [ \"$legacy_ssu_line\" = \"\" ]; then " +
                "echo \"[verify_backend_uir_soa_surface] missing runtime soa_report and legacy runtime markers\" >&2; " +
                "sed -n '1,160p' \"$log\" >&2 || true; " +
                "exit 1; " +
            "fi; " +
            "runtime_report_mode=\"runtime_legacy_surface\"; " +
            "soa_report_line=\"soa_report\\tenabled=0\\tenforce=1\\ttracked_funcs=-1\\texpr_ids=-1\\tstmt_ids=-1\\tblock_ids=-1\\tsucc_edges=-1\\tpred_edges=-1\\tbalance_ok=1\\tmode=runtime_legacy_surface\"; " +
            "printf '%s\\n' \"$soa_report_line\" >>\"$log\"; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"target=$target\"; " +
            "echo \"fixture=$fixture\"; " +
            "echo \"runtime_log=$log\"; " +
            "echo \"runtime_exe=$exe\"; " +
            "echo \"runtime_report_mode=$runtime_report_mode\"; " +
            "echo \"runtime_report_line=$soa_report_line\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_uir_soa_surface_status=ok\"; " +
            "echo \"backend_uir_soa_surface_target=$target\"; " +
            "echo \"backend_uir_soa_surface_fixture=$fixture\"; " +
            "echo \"backend_uir_soa_surface_runtime_log=$log\"; " +
            "echo \"backend_uir_soa_surface_runtime_exe=$exe\"; " +
            "echo \"backend_uir_soa_surface_runtime_report_mode=$runtime_report_mode\"; " +
            "echo \"backend_uir_soa_surface_runtime_report_line=$soa_report_line\"; " +
            "echo \"backend_uir_soa_surface_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_uir_soa_surface ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)


fn tooling_cmdVerifyBackendUirSoaSelfProbe(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "env BACKEND_UIR_SOA_SELF_PROBE=1 BACKEND_UIR_SOA_SELF_PROBE_ENFORCE=1 " +
        "\"$tool\" verify_backend_uir_soa_surface; " +
        "echo \"verify_backend_uir_soa_self_probe ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendClosedloopMinimal(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "driver=\"$($tool driver-path --path-only 2>/dev/null | tail -n 1 | tr -d '\\r')\"; " +
        "if [ ! -x \"$driver\" ]; then echo \"[verify_backend_closedloop] backend driver not executable: $driver\" >&2; exit 1; fi; " +
        "backend_mm=\"${BACKEND_MM:-${MM:-orc}}\"; " +
        "case \"$backend_mm\" in \"\"|orc) backend_mm=\"orc\" ;; *) echo \"[verify_backend_closedloop] invalid BACKEND_MM/MM: $backend_mm (expected orc)\" >&2; exit 2 ;; esac; " +
        "backend_linker=\"${BACKEND_LINKER:-self}\"; " +
        "case \"$backend_linker\" in self|system) ;; *) echo \"[verify_backend_closedloop] invalid BACKEND_LINKER: $backend_linker (expected self|system)\" >&2; exit 2 ;; esac; " +
        "backend_target=\"${BACKEND_TARGET:-$($tool detect_host_target 2>/dev/null || echo arm64-apple-darwin)}\"; " +
        "backend_runtime_obj=\"${BACKEND_RUNTIME_OBJ:-}\"; " +
        "runtime_nm_has_sym() { sym=\"$1\"; printf '%s\\n' \"$nm_out\" | awk '{print $NF}' | sed 's/^_//' | grep -Fxq \"$sym\"; }; " +
        "runtime_has_core_symbols() { " +
            "obj=\"$1\"; [ -f \"$obj\" ] || return 1; " +
            "command -v nm >/dev/null 2>&1 || return 1; " +
            "nm_out=\"$(nm -g \"$obj\" 2>/dev/null || true)\"; [ \"$nm_out\" != \"\" ] || return 1; " +
            "runtime_nm_has_sym cheng_strlen && runtime_nm_has_sym cheng_memcpy && runtime_nm_has_sym cheng_memset && " +
            "runtime_nm_has_sym cheng_malloc && runtime_nm_has_sym cheng_free && runtime_nm_has_sym cheng_mem_retain && " +
            "runtime_nm_has_sym cheng_mem_release && runtime_nm_has_sym cheng_seq_get && runtime_nm_has_sym cheng_seq_set && " +
            "runtime_nm_has_sym cheng_strcmp && runtime_nm_has_sym cheng_f32_bits_to_i64 && runtime_nm_has_sym cheng_f64_bits_to_i64 && runtime_nm_has_sym cheng_open_w_trunc; " +
        "}; " +
        "resolve_runtime_obj() { " +
            "if [ \"$backend_runtime_obj\" != \"\" ]; then " +
                "if [ -f \"$backend_runtime_obj\" ] && runtime_has_core_symbols \"$backend_runtime_obj\"; then printf '%s\\n' \"$backend_runtime_obj\"; return 0; fi; " +
                "echo \"[Warn] ignore explicit BACKEND_RUNTIME_OBJ (missing required self-link symbols): $backend_runtime_obj\" >&2; " +
            "fi; " +
            "for cand in " +
                "\"chengcache/runtime_selflink/system_helpers.backend.combined.${backend_target}.o\" " +
                "\"artifacts/backend_mm/system_helpers.backend.combined.${backend_target}.o\" " +
                "\"chengcache/runtime_selflink/system_helpers.backend.combined.arm64-apple-darwin.o\" " +
                "\"artifacts/backend_mm/system_helpers.backend.combined.arm64-apple-darwin.o\"; do " +
                "if [ \"$cand\" != \"\" ] && [ -f \"$cand\" ] && runtime_has_core_symbols \"$cand\"; then printf '%s\\n' \"$cand\"; return 0; fi; " +
            "done; " +
            "return 1; " +
        "}; " +
        "if [ \"$backend_linker\" = \"self\" ]; then backend_runtime_obj=\"$(resolve_runtime_obj || true)\"; fi; " +
        "if [ \"$backend_linker\" = \"self\" ] && [ ! -f \"$backend_runtime_obj\" ]; then " +
            "echo \"[verify_backend_closedloop] missing self-link runtime object: $backend_runtime_obj\" >&2; exit 2; " +
        "fi; " +
        "run_step() { name=\"$1\"; shift; echo \"== ${name} ==\"; \"$@\"; }; " +
        "mkdir -p artifacts/backend_closedloop; rm -rf artifacts/backend_closedloop/*; " +
        "stage1_skip_sem=\"0\"; stage1_skip_ownership=\"0\"; " +
        "stage1_generic_mode=\"${BACKEND_CLOSEDLOOP_STAGE1_GENERIC_MODE:-dict}\"; " +
        "stage1_generic_budget=\"${BACKEND_CLOSEDLOOP_STAGE1_GENERIC_SPEC_BUDGET:-${GENERIC_SPEC_BUDGET:-0}}\"; " +
        "stage1_smoke_multi=\"${BACKEND_MULTI:-0}\"; stage1_smoke_multi_force=\"${BACKEND_MULTI_FORCE:-$stage1_smoke_multi}\"; " +
        "compile_smoke() { in=\"$1\"; out=\"$2\"; " +
            "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER -u BACKEND_LINKER " +
            "MM=\"$backend_mm\" GENERIC_MODE=\"$stage1_generic_mode\" GENERIC_SPEC_BUDGET=\"$stage1_generic_budget\" " +
            "\"$tool\" cheng --target:\"$backend_target\" --in:\"$in\" --out:\"$out\"; " +
        "}; " +
        "run_step \"backend.closedloop_stage1_smoke.compile\" compile_smoke tests/cheng/backend/fixtures/hello_puts.cheng artifacts/backend_closedloop/stage1_smoke; " +
        "run_step \"backend.closedloop_stage1_smoke.run\" test -x artifacts/backend_closedloop/stage1_smoke; " +
        "run_step \"backend.closedloop_stage1_std_os_smoke.compile\" compile_smoke tests/cheng/backend/fixtures/return_import_std_os.cheng artifacts/backend_closedloop/stage1_std_os_smoke; " +
        "run_step \"backend.closedloop_stage1_std_os_smoke.run\" test -x artifacts/backend_closedloop/stage1_std_os_smoke; " +
        "run_fullspec=\"${BACKEND_RUN_FULLSPEC:-1}\"; " +
        "if [ \"$run_fullspec\" = \"1\" ]; then " +
            "fullspec_input=\"${BACKEND_CLOSEDLOOP_FULLSPEC_INPUT:-examples/backend_closedloop_fullspec.cheng}\"; " +
            "fullspec_out=\"artifacts/backend_closedloop/fullspec_backend\"; " +
            "fullspec_log=\"artifacts/backend_closedloop/fullspec_backend.compile.log\"; " +
            "fullspec_skip_sem=\"0\"; fullspec_skip_ownership=\"$stage1_skip_ownership\"; " +
            "fullspec_generic_mode=\"${BACKEND_FULLSPEC_GENERIC_MODE:-dict}\"; " +
            "fullspec_generic_budget=\"${BACKEND_FULLSPEC_GENERIC_SPEC_BUDGET:-0}\"; " +
            "fullspec_validate=\"${BACKEND_FULLSPEC_VALIDATE:-0}\"; " +
            "fullspec_multi=\"${BACKEND_CLOSEDLOOP_FULLSPEC_MULTI:-0}\"; fullspec_multi_force=\"${BACKEND_CLOSEDLOOP_FULLSPEC_MULTI_FORCE:-$fullspec_multi}\"; " +
            "echo \"== backend.closedloop_fullspec.compile ==\"; " +
            "if [ \"$backend_linker\" = \"self\" ]; then echo \"[verify_backend_closedloop] fullspec self-link uses strict system-link fullspec path\" >&2; fi; " +
            "set +e; " +
            "env -u BACKEND_DRIVER -u CHENG_BACKEND_DRIVER -u BACKEND_LINKER " +
            "MM=\"$backend_mm\" GENERIC_MODE=\"$fullspec_generic_mode\" GENERIC_SPEC_BUDGET=\"$fullspec_generic_budget\" " +
            "\"$tool\" release-compile --target:\"$backend_target\" --in:\"$fullspec_input\" --out:\"$fullspec_out\" >\"$fullspec_log\" 2>&1; " +
            "status=\"$?\"; " +
            "set -e; " +
            "if [ \"$status\" -ne 0 ]; then tail -n 200 \"$fullspec_log\" >&2 || true; exit \"$status\"; fi; " +
            "if [ ! -x \"$fullspec_out\" ]; then echo \"[verify_backend_closedloop] fullspec compile did not produce runnable binary\" >&2; exit 1; fi; " +
            "if command -v nm >/dev/null 2>&1; then " +
                "echo \"== backend.closedloop_fullspec.symcheck ==\"; " +
                "if nm \"$fullspec_out\" 2>/dev/null | rg -q \"U[[:space:]].*seqBytesOf_T\"; then " +
                    "echo \"[verify_backend_closedloop] unresolved seqBytesOf_T symbol in fullspec binary\" >&2; exit 1; " +
                "fi; " +
            "fi; " +
            "echo \"== backend.closedloop_fullspec.run ==\"; " +
            "./artifacts/backend_closedloop/fullspec_backend | grep -Fq \"fullspec ok\"; " +
        "fi; " +
        "run_step \"backend.no_obj_artifacts\" \"$tool\" verify_backend_no_obj_artifacts; " +
        "echo \"verify_backend_closedloop ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendRawptrMigration(root: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[verify_backend_rawptr_migration] rg is required\" >&2; exit 2; " +
        "fi; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "out_dir=\"artifacts/backend_rawptr_migration\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$out_dir\"; " +
        "report=\"$out_dir/verify_backend_rawptr_migration.report.txt\"; " +
        "snapshot=\"$out_dir/verify_backend_rawptr_migration.snapshot.env\"; " +
        "if [ ! -f docs/raw-pointer-safety.md ]; then " +
            "echo \"[verify_backend_rawptr_migration] missing doc: docs/raw-pointer-safety.md\" >&2; " +
            "exit 2; " +
        "fi; " +
        "if ! \"$tool\" list | rg -qx 'rawptr_migrate_ffi'; then " +
            "echo \"[verify_backend_rawptr_migration] missing rawptr_migrate_ffi native subcommand\" >&2; " +
            "exit 1; " +
        "fi; " +
        "if ! \"$tool\" embedded-text --id:rawptr_migrate_ffi | rg -q '.'; then " +
            "echo \"[verify_backend_rawptr_migration] rawptr_migrate_ffi embedded payload missing\" >&2; " +
            "exit 1; " +
        "fi; " +
        "{ " +
            "echo \"status=ok\"; " +
            "echo \"tool=$tool\"; " +
            "echo \"rawptr_migrate_ffi=available\"; " +
            "echo \"doc=docs/raw-pointer-safety.md\"; " +
        "} >\"$report\"; " +
        "{ " +
            "echo \"backend_rawptr_migration_status=ok\"; " +
            "echo \"backend_rawptr_migration_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "echo \"verify_backend_rawptr_migration ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendEmitObjContract(root: str): int32 =
    if tooling_strEq(root, ""):
        tooling_printErr("cheng_tooling: invalid root for removed command")
        return 2
    tooling_printErr("cheng_tooling: `verify_backend_emit_obj_contract` has been removed.")
    tooling_printErr("  fixed policy: non-release executable builds must use in-memory emit=exe")
    tooling_printErr("  note: emit=obj remains internal-only for allow-no-main artifact generation")
    return 2

fn tooling_printVerifyMobileCrashFreeUsage() =
    tooling_printOut("verify_mobile_crash_free options:")
    tooling_printOut("  --serial-iters:<N>       serial iterations per command group (default 50)")
    tooling_printOut("  --parallel-rounds:<N>    rounds for each parallel group (default 20)")
    tooling_printOut("  --parallel-jobs:<N>      parallel jobs in each round (default 4)")
    tooling_printOut("  --quick                  shorthand for --serial-iters:10 --parallel-rounds:5 --parallel-jobs:2")
    tooling_printOut("  --help                   show this message")

fn tooling_cmdVerifyMobileCrashFreeWithConfig(root, serialItersRaw, parallelRoundsRaw, parallelJobsRaw: str): int32 =
    let serialSeedRaw: str = strutil.strip(serialItersRaw)
    let parallelRoundsSeedRaw: str = strutil.strip(parallelRoundsRaw)
    let parallelJobsSeedRaw: str = strutil.strip(parallelJobsRaw)
    let serialSeedExpr: str =
        if tooling_strNonEmpty(serialSeedRaw):
            tooling_shellQuote(serialSeedRaw)
        else:
            "\"${MOBILE_CRASH_FREE_SERIAL_ITERS:-50}\""
    let parallelRoundsSeedExpr: str =
        if tooling_strNonEmpty(parallelRoundsSeedRaw):
            tooling_shellQuote(parallelRoundsSeedRaw)
        else:
            "\"${MOBILE_CRASH_FREE_PARALLEL_ROUNDS:-20}\""
    let parallelJobsSeedExpr: str =
        if tooling_strNonEmpty(parallelJobsSeedRaw):
            tooling_shellQuote(parallelJobsSeedRaw)
        else:
            "\"${MOBILE_CRASH_FREE_PARALLEL_JOBS:-4}\""
    let cmd: str =
        "set -eu; " +
        "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"; " +
        "if [ ! -x \"$tool\" ]; then echo \"[verify_mobile_crash_free] missing tooling binary: $tool\" >&2; exit 1; fi; " +
        "serial_iters=" + serialSeedExpr + "; " +
        "parallel_rounds=" + parallelRoundsSeedExpr + "; " +
        "parallel_jobs=" + parallelJobsSeedExpr + "; " +
        "case \"$serial_iters\" in ''|*[!0-9]*) serial_iters=50 ;; esac; " +
        "case \"$parallel_rounds\" in ''|*[!0-9]*) parallel_rounds=20 ;; esac; " +
        "case \"$parallel_jobs\" in ''|*[!0-9]*) parallel_jobs=4 ;; esac; " +
        "if [ \"$serial_iters\" -lt 1 ]; then serial_iters=1; fi; " +
        "if [ \"$parallel_rounds\" -lt 1 ]; then parallel_rounds=1; fi; " +
        "if [ \"$parallel_jobs\" -lt 1 ]; then parallel_jobs=1; fi; " +
        "root_dir=\"$(pwd)\"; " +
        "mobile_repo=\"${MOBILE_CRASH_FREE_MOBILE_REPO:-}\"; " +
        "if [ \"$mobile_repo\" = \"\" ]; then " +
          "if [ -d \"$HOME/.cheng-packages/cheng-mobile\" ]; then mobile_repo=\"$HOME/.cheng-packages/cheng-mobile\"; " +
          "elif [ -d \"$root_dir/../cheng-mobile\" ]; then mobile_repo=\"$root_dir/../cheng-mobile\"; fi; " +
        "fi; " +
        "if [ \"$mobile_repo\" = \"\" ] || [ ! -d \"$mobile_repo\" ]; then " +
          "echo \"[verify_mobile_crash_free] missing cheng-mobile repo; set MOBILE_CRASH_FREE_MOBILE_REPO\" >&2; exit 2; " +
        "fi; " +
        "mobile_root=\"${MOBILE_CRASH_FREE_MOBILE_ROOT:-$mobile_repo/src}\"; " +
        "mobile_in=\"${MOBILE_CRASH_FREE_MOBILE_IN:-$mobile_repo/examples/mobile_smoke.cheng}\"; " +
        "mobile_fixture=\"${MOBILE_CRASH_FREE_MOBILE_FIXTURE:-$mobile_repo/examples/rwad_closed_loop_smoke.cheng}\"; " +
        "light_fixture=\"${MOBILE_CRASH_FREE_LIGHT_FIXTURE:-tests/cheng/backend/fixtures/return_i64.cheng}\"; " +
        "for f in \"$mobile_in\" \"$mobile_fixture\" \"$light_fixture\"; do " +
          "if [ ! -f \"$f\" ]; then echo \"[verify_mobile_crash_free] missing fixture: $f\" >&2; exit 2; fi; " +
        "done; " +
        "out_dir=\"artifacts/mobile_crash_free\"; tmp_dir=\"$out_dir/tmp\"; " +
        "rm -rf \"$out_dir\"; mkdir -p \"$tmp_dir\"; " +
        "rcs=\"$out_dir/mobile_crash_free.rcs.tsv\"; : >\"$rcs\"; " +
        "run_one() { " +
          "label=\"$1\"; shift; log=\"$tmp_dir/$label.log\"; " +
          "set +e; \"$@\" >\"$log\" 2>&1; rc=\"$?\"; set -e; " +
          "printf '%s\\t%s\\n' \"$label\" \"$rc\" >>\"$rcs\"; " +
          "return 0; " +
        "}; " +
        "i=1; " +
        "while [ \"$i\" -le \"$serial_iters\" ]; do " +
          "export_out=\"$tmp_dir/export_serial_$i\"; rm -rf \"$export_out\"; " +
          "run_one \"build_mobile_export_serial_$i\" env MOBILE_ROOT=\"$mobile_root\" \"$tool\" build_mobile_export \"$mobile_in\" --name:verify_mobile_crash_free_serial_$i --out:\"$export_out\" --with-android-project; " +
          "rm -rf \"$export_out\"; " +
          "out_light=\"$tmp_dir/cheng_light_serial_$i.bin\"; rm -f \"$out_light\"; " +
          "run_one \"cheng_light_serial_$i\" \"$tool\" cheng \"$light_fixture\" --out:\"$out_light\"; " +
          "rm -f \"$out_light\"; " +
          "out_mobile=\"$tmp_dir/cheng_mobile_serial_$i.bin\"; rm -f \"$out_mobile\"; " +
          "run_one \"cheng_mobile_serial_$i\" \"$tool\" cheng \"$mobile_fixture\" --out:\"$out_mobile\"; " +
          "rm -f \"$out_mobile\"; " +
          "i=$((i + 1)); " +
        "done; " +
        "run_parallel_group() { " +
          "group=\"$1\"; round=1; " +
          "while [ \"$round\" -le \"$parallel_rounds\" ]; do " +
            "pids=\"\"; job=1; " +
            "while [ \"$job\" -le \"$parallel_jobs\" ]; do " +
              "label=\"${group}_par_${round}_${job}\"; " +
              "if [ \"$group\" = \"build_mobile_export\" ]; then " +
                "(export_out=\"$tmp_dir/$label\"; rm -rf \"$export_out\"; run_one \"$label\" env MOBILE_ROOT=\"$mobile_root\" \"$tool\" build_mobile_export \"$mobile_in\" --name:verify_mobile_crash_free_${round}_${job} --out:\"$export_out\" --with-android-project; rm -rf \"$export_out\") & " +
              "elif [ \"$group\" = \"cheng_light\" ]; then " +
                "(out_bin=\"$tmp_dir/$label.bin\"; rm -f \"$out_bin\"; run_one \"$label\" \"$tool\" cheng \"$light_fixture\" --out:\"$out_bin\"; rm -f \"$out_bin\") & " +
              "else " +
                "(out_bin=\"$tmp_dir/$label.bin\"; rm -f \"$out_bin\"; run_one \"$label\" \"$tool\" cheng \"$mobile_fixture\" --out:\"$out_bin\"; rm -f \"$out_bin\") & " +
              "fi; " +
              "pids=\"$pids $!\"; job=$((job + 1)); " +
            "done; " +
            "for p in $pids; do wait \"$p\" || true; done; " +
            "round=$((round + 1)); " +
          "done; " +
        "}; " +
        "run_parallel_group build_mobile_export; " +
        "run_parallel_group cheng_light; " +
        "run_parallel_group cheng_mobile; " +
        "total_runs=\"$(wc -l <\"$rcs\" | tr -d ' ')\"; " +
        "segfault_count=\"$(awk -F'\\t' '$2 == 138 || $2 == 139 {c++} END {print c + 0}' \"$rcs\")\"; " +
        "fail_count=\"$(awk -F'\\t' '$2 != 0 {c++} END {print c + 0}' \"$rcs\")\"; " +
        "status=\"ok\"; if [ \"$segfault_count\" -ne 0 ] || [ \"$fail_count\" -ne 0 ]; then status=\"failed\"; fi; " +
        "report=\"$out_dir/mobile_crash_free.report.txt\"; snapshot=\"$out_dir/mobile_crash_free.snapshot.env\"; " +
        "{ " +
          "echo \"verify_mobile_crash_free report\"; " +
          "echo \"status=$status\"; " +
          "echo \"serial_iters=$serial_iters\"; " +
          "echo \"parallel_rounds=$parallel_rounds\"; " +
          "echo \"parallel_jobs=$parallel_jobs\"; " +
          "echo \"total_runs=$total_runs\"; " +
          "echo \"segfault_count=$segfault_count\"; " +
          "echo \"fail_count=$fail_count\"; " +
          "echo \"rcs=$rcs\"; " +
          "echo \"mobile_repo=$mobile_repo\"; " +
          "echo \"mobile_in=$mobile_in\"; " +
          "echo \"mobile_fixture=$mobile_fixture\"; " +
          "echo \"light_fixture=$light_fixture\"; " +
        "} >\"$report\"; " +
        "{ " +
          "echo \"mobile_crash_free_status=$status\"; " +
          "echo \"mobile_crash_free_total_runs=$total_runs\"; " +
          "echo \"mobile_crash_free_segfault_count=$segfault_count\"; " +
          "echo \"mobile_crash_free_fail_count=$fail_count\"; " +
          "echo \"mobile_crash_free_report=$report\"; " +
        "} >\"$snapshot\"; " +
        "if [ \"$status\" != \"ok\" ]; then " +
          "echo \"[verify_mobile_crash_free] failed: segfault_count=$segfault_count fail_count=$fail_count report=$report\" >&2; " +
          "exit 1; " +
        "fi; " +
        "echo \"verify_mobile_crash_free ok\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyMobileCrashFreeFromArgs(root: str, argStart: int32, count: int32): int32 =
    var serialItersRaw: str = ""
    var parallelRoundsRaw: str = ""
    var parallelJobsRaw: str = ""
    var quickMode: bool = false
    var i: int32 = argStart
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printVerifyMobileCrashFreeUsage()
            return 0
        if tooling_strEq(arg, "--quick"):
            quickMode = true
            i = i + 1
            continue
        if strutil.startsWith(arg, "--serial-iters:"):
            serialItersRaw = strings.dropPrefix(arg, "--serial-iters:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--parallel-rounds:"):
            parallelRoundsRaw = strings.dropPrefix(arg, "--parallel-rounds:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--parallel-jobs:"):
            parallelJobsRaw = strings.dropPrefix(arg, "--parallel-jobs:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown verify_mobile_crash_free arg: " + arg)
        return 1
    if quickMode:
        if !tooling_strNonEmpty(strutil.strip(serialItersRaw)):
            serialItersRaw = "10"
        if !tooling_strNonEmpty(strutil.strip(parallelRoundsRaw)):
            parallelRoundsRaw = "5"
        if !tooling_strNonEmpty(strutil.strip(parallelJobsRaw)):
            parallelJobsRaw = "2"
    return tooling_cmdVerifyMobileCrashFreeWithConfig(root, serialItersRaw, parallelRoundsRaw, parallelJobsRaw)

fn tooling_dispatchNativeScriptRoute(root: str, scriptIdRaw: str, argStart: int32, count: int32): int32 =
    let scriptId: str = tooling_normalizeScriptId(scriptIdRaw)
    if tooling_strEq(scriptId, "backend_prod_closure"):
        return tooling_cmdBackendProdClosureFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "backend_prod_publish") || tooling_strEq(scriptId, "backend-prod-publish"):
        return tooling_cmdBackendProdPublishFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "verify_backend_selfhost_bootstrap_self_obj"):
        return tooling_cmdSelfhostBootstrapVerifyFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "verify_backend_selfhost_100ms_host"):
        return tooling_cmdSelfhost100msHostFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "verify_backend_cdrop_emergency"):
        return tooling_cmdVerifyBackendCdropEmergencyFromArgs(root, argStart, count)
    if tooling_strEq(scriptId, "verify_backend_native_contract"):
        return tooling_cmdVerifyBackendNativeContract(root)
    if tooling_strEq(scriptId, "verify_backend_native_contract_autosystem"):
        return tooling_cmdVerifyBackendNativeContractAutosystem(root)
    if tooling_strEq(scriptId, "verify_backend_opt2_impl_surface"):
        return tooling_cmdVerifyBackendOpt2ImplSurface(root)
    if tooling_strEq(scriptId, "verify_backend_driver_unified_global"):
        return tooling_cmdVerifyBackendDriverUnifiedGlobal(root)
    if tooling_strEq(scriptId, "verify_backend_compile_name_canonical"):
        return tooling_cmdVerifyBackendCompileNameCanonical(root)
    if tooling_strEq(scriptId, "verify_backend_dev_track_only"):
        return tooling_cmdVerifyBackendDevTrackOnly(root)
    if tooling_strEq(scriptId, "verify_backend_symbol_closure"):
        return tooling_cmdVerifyBackendSymbolClosure(root)
