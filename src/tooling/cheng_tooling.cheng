    tooling_envAssignCollect(envOverrides, "BACKEND_INPUT", sourcePath)
    tooling_envAssignCollect(envOverrides, "BACKEND_OUTPUT", outPath)
    tooling_stage0LegacyCStringCompatCollect(root, compilerPath, envOverrides)
    return envOverrides

fn tooling_prepareBackendDriverUirSidecarObj(root: str, compilerPath: str, target: str): str =
    let sourcePath: str = tooling_backendDriverUirSidecarSourcePath(root)
    let outPath: str = tooling_backendDriverUirSidecarObjPath(root, target)
    if !os.fileExists(sourcePath):
        return ""
    if tooling_fileExistsNonEmpty(outPath) && !tooling_backendDriverUirSidecarNeedsRebuild(root, outPath):
        return outPath
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        tooling_tryMkdirP(root, outDir)
    if os.fileExists(outPath):
        os.removeFile(outPath)
    if tooling_strEq(tooling_backendDriverUirSidecarMode(root), "emergency_c"):
        var ccmd: str = ""
        ccmd = ccmd + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_MODE", "emergency_c")
        ccmd = ccmd + "cc -fPIC -c "
        ccmd = ccmd + tooling_shellQuote(sourcePath)
        ccmd = ccmd + " -o " + tooling_shellQuote(outPath)
        let cres: os.ExecCmdResult = tooling_exec(root, ccmd)
        tooling_printExecOutput(cres)
        if os.execCmdResultExitCode(cres) != 0:
            tooling_printErr("cheng_tooling: backend_driver sidecar compile failed rc=" +
                             intToStr(os.execCmdResultExitCode(cres)))
            return ""
        if !tooling_fileExistsNonEmpty(outPath):
            tooling_printErr("cheng_tooling: backend_driver sidecar missing output: " + outPath)
            return ""
        return outPath
    if !tooling_strNonEmpty(compilerPath):
        tooling_printErr("cheng_tooling: backend_driver cheng sidecar compiler not found")
        return ""
    let envOverrides: str[] = tooling_backendDriverUirSidecarCompileEnv(root, compilerPath, sourcePath, outPath, target)
    var compilerArgs: str[] = []
    let res: os.ExecCmdResult = tooling_execFileDirect(compilerPath, compilerArgs, envOverrides, root, 60, true)
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("cheng_tooling: backend_driver sidecar compile failed rc=" +
                         intToStr(os.execCmdResultExitCode(res)))
        return ""
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_printErr("cheng_tooling: backend_driver sidecar missing output: " + outPath)
        return ""
    return outPath

