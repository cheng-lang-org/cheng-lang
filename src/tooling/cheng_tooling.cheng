fn tooling_cmdBuildBackendProfileSchema(root: str, outFile: str): int32 =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then echo \"[build_backend_profile_schema] rg is required\" >&2; exit 2; fi; ")
    add(parts, "hash_file() { file=\"$1\"; if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; cksum \"$file\" | awk '{print $1}'; }; ")
    add(parts, "out=")
    add(parts, tooling_shellQuote(outFile))
    add(parts, "; ")
    add(parts, "driver_file=\"src/backend/tooling/backend_driver.cheng\"; uir_builder_file=\"src/backend/uir/uir_internal/uir_core_builder.cheng\"; stage1_file=\"src/stage1/frontend_lib.cheng\"; ")
    add(parts, "for required in \"$driver_file\" \"$uir_builder_file\" \"$stage1_file\"; do if [ ! -f \"$required\" ]; then echo \"[build_backend_profile_schema] missing source file: $required\" >&2; exit 2; fi; done; ")
    add(parts, "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_profile_schema_markers.XXXXXX\")\"; ")
    add(parts, "cleanup() { rm -f \"$tmp_markers\"; }; trap cleanup EXIT; ")
    add(parts, "marker_regex='backend_profile|uir_profile|generics_report|\\[stage1\\] profile'; ")
    add(parts, "rg --no-filename --no-line-number -o \"$marker_regex\" \"$driver_file\" \"$uir_builder_file\" \"$stage1_file\" | LC_ALL=C sort >\"$tmp_markers\"; ")
    add(parts, "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; marker_sha=\"$(hash_file \"$tmp_markers\")\"; ")
    add(parts, "out_dir=\"$(dirname \"$out\")\"; if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; ")
    add(parts, "{ ")
    add(parts, "echo \"BACKEND_PROFILE_SCHEMA_VERSION=1\"; ")
    add(parts, "echo \"BACKEND_PROFILE_SCHEMA_PREFIXES=backend_profile,uir_profile,stage1_profile,generics_report\"; ")
    add(parts, "echo \"BACKEND_PROFILE_GENERICS_FIELDS=ir,mode,spec_budget,borrow_ir,generic_lowering\"; ")
    add(parts, "echo \"BACKEND_PROFILE_SCHEMA_MARKER_REGEX=backend_profile|uir_profile|generics_report|\\\\[stage1\\\\]\\\\ profile\"; ")
    add(parts, "echo \"BACKEND_PROFILE_SCHEMA_MARKER_COUNT=$marker_count\"; ")
    add(parts, "echo \"BACKEND_PROFILE_SCHEMA_MARKER_SHA256=$marker_sha\"; ")
    add(parts, "echo \"BACKEND_PROFILE_SCHEMA_SOURCES=$driver_file,$uir_builder_file,$stage1_file\"; ")
    add(parts, "} >\"$out\"; ")
    add(parts, "echo \"backend profile schema generated: $out\"")
    let res: os.ExecCmdResult = tooling_exec(root, tooling_joinFragments(parts))
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

