    tooling_printOut("       TOOLING_COMPILE_BLOCK_ON_UE=1|0 (default 1; hard-block follows TOOLING_STAGE0_HARD_BLOCK_ON_UE)")
    tooling_printOut("       TOOLING_COMPILE_CRASH_REPORT_DIR=artifacts/tooling_compile_crash")
    tooling_printOut("  note: --emit:shared|static use object-first release packaging (no --run)")
    tooling_printOut("  note: TOOLING_COMPILE_STAGE0_AUTO_REBUILD_ON_PREFLIGHT_FAIL is removed (fixed=0)")
    tooling_printOut("  note: TOOLING_COMPILE_CRASH_RETRY_MAX is removed (fixed=0)")

fn tooling_commandAllowsReleaseTrack(commandIdRaw: str): bool =
    let commandId: str = strutil.toLowerAscii(strutil.strip(commandIdRaw))
    if tooling_strEq(commandId, "release-compile") || tooling_strEq(commandId, "backend-prod-publish"):
        return true
    return false

fn tooling_normalizeBuildTrackRaw(raw: str): str =
    let track: str = strutil.toLowerAscii(strutil.strip(raw))
    if tooling_strEq(track, "release"):
        return "release"
    return "dev"

fn tooling_enforceBuildTrackPolicy(commandIdRaw: str, requestedTrackRaw: str): int32 =
    let commandId: str = strutil.toLowerAscii(strutil.strip(commandIdRaw))
    let track: str = tooling_normalizeBuildTrackRaw(requestedTrackRaw)
    if tooling_strEq(track, "release") && !tooling_commandAllowsReleaseTrack(commandId):
        tooling_printErr("cheng_tooling: " + commandId + " is dev-only; release track is only allowed for `release-compile` and `backend-prod-publish`")
        return 2
    return 0

fn tooling_compileDevModeParsed(raw: str): str =
    let mode: str = strutil.toLowerAscii(strutil.strip(raw))
    if tooling_strEq(mode, "strict"):
        return "strict"
    if tooling_strEq(mode, "fast"):
        return "fast"
    return ""

fn tooling_compileDevModeNormalized(raw: str): str =
    let parsed: str = tooling_compileDevModeParsed(raw)
    if tooling_strNonEmpty(parsed):
        return parsed
    return "fast"

fn tooling_compileProfileEnv01(name: str, fallback: str = "0"): str =
    var out: str = tooling_bool01Normalized(os.getEnvDefault(name, ""))
    if !tooling_strNonEmpty(out):
        out = fallback
    if !tooling_strNonEmpty(out):
        return "0"
    return out

fn tooling_compileTarget(root: str, targetRaw: str): str =
    return tooling_nonEmptyDefault(tooling_normalizeTargetAlias(root, targetRaw), "auto")

fn tooling_compileTrackLabel(releaseBuild: bool): str =
    if releaseBuild:
        return "release-compile"
    return "cheng"

fn tooling_compileLinkerMode(releaseBuild: bool): str =
    if releaseBuild:
        return "system"
    return "self"

fn tooling_compileDevModeForTrack(releaseBuild: bool, devModeRaw: str): str =
    if releaseBuild:
        return "release"
    return tooling_compileDevModeNormalized(devModeRaw)

fn tooling_compileParseExpected(releaseBuild: bool): str =
    if releaseBuild:
        return "full"
    return "outline"

fn tooling_compileDirectExpected(releaseBuild: bool): str =
    if releaseBuild:
        return "0"
    return "1"

fn tooling_compileInmemExpected(releaseBuild: bool): str =
    if releaseBuild:
        return "0"
    return "1"

fn tooling_compileRunEphemeralOut(runAfter: bool, emitMode: str, runMode: str,
                                  releaseBuild: bool, explicitOut: bool): bool =
    return runAfter &&
           tooling_strEq(emitMode, "exe") &&
           tooling_strEq(runMode, "host") &&
           !releaseBuild &&
           !explicitOut

fn tooling_compileRunTempBase(inPath: str): str =
    return tooling_nonEmptyDefault(
        tooling_stripSuffix(os.extractFilename(inPath), ".cheng"),
        "cheng_run")

fn tooling_compileOutPath(root: str, inPath: str, outRaw: str, nameRaw: str,
                          emitMode: str, runEphemeralOut: bool): str =
    if runEphemeralOut:
        return os.joinPath(
            root,
            "chengcache/compile_run/" + tooling_compileRunTempBase(inPath) + "." + tooling_nowNonceText())
    return tooling_defaultCompileOut(root, inPath, outRaw, nameRaw, emitMode)

fn tooling_compileBackendOutPath(outPath: str, atomicExePublish: bool, libraryEmit: bool): str =
    if atomicExePublish:
        return outPath + ".compile." + tooling_nowNonceText() + ".tmp"
    if libraryEmit:
        return outPath + ".objtmp." + tooling_nowNonceText() + ".o"
    return outPath

fn tooling_compileTmpLinkObjPath(backendOutPath: str): str =
    return backendOutPath + ".tmp.linkobj"

fn tooling_compileObjPath(backendOutPath: str): str =
    return backendOutPath + ".o"

fn tooling_compileLogPath(backendOutPath: str): str =
    return backendOutPath + ".compile.log"

fn tooling_compileBuildTrack(releaseBuild: bool): str =
    if releaseBuild:
        return "release"
    return "dev"

fn tooling_compileBackendEmitMode(libraryEmit: bool, emitMode: str): str =
    if libraryEmit:
        return "obj"
    return emitMode

fn tooling_compileReleaseCflagsRaw(releaseBuild: bool): str =
    if !releaseBuild:
        return ""
    return tooling_trimAsciiSpace(os.getEnvDefault("BACKEND_RELEASE_CFLAGS", "-O2"))

fn tooling_compileReleaseLdflagsRaw(releaseBuild: bool, target: str,
                                    releaseCflagsRaw: str): str =
    if !releaseBuild:
        return ""
    return tooling_releaseLdflagsForTarget(
        os.getEnvDefault("BACKEND_RELEASE_LDFLAGS", releaseCflagsRaw), target)

fn tooling_compileExplicitOptions(buildTrack: str, parseMode: str, linker: str,
                                  target: str, inputPath: str, outputPath: str,
                                  emitModeText: str, allowNoMainText: str,
                                  wholeProgramText: str, directExeText: str,
                                  linkerlessInmemText: str, multiText: str,
                                  incrementalText: str, jobsText: str,
                                  fnJobsText: str): ToolingCompileOptions =
    var opts: ToolingCompileOptions = nil
    new(opts)
    opts.stdNoptr = ""
    opts.stdNoptrStrict = ""
    opts.noptrNonCAbi = ""
    opts.noptrNonCAbiInternal = ""
    opts.stage1ProfileText = "0"
    opts.backendProfileText = "0"
    opts.uirProfileText = "0"
    opts.buildTrack = buildTrack
    opts.parseMode = parseMode
    opts.stage1BuilderText = "stage1"
    opts.skipGlobalInitText = "0"
    opts.allowNoMainText = allowNoMainText
    opts.fastDevProfileText = "0"
    opts.wholeProgramText = wholeProgramText
    opts.directExeText = directExeText
    opts.linkerlessInmemText = linkerlessInmemText
    opts.multiText = multiText
    opts.incrementalText = incrementalText
    opts.jobsText = jobsText
    opts.fnJobsText = fnJobsText
    opts.optText = ""
    opts.opt2Text = ""
    opts.optLevelText = ""
    opts.cflagsRaw = ""
    opts.ldflagsRaw = ""
    opts.enableCliText = ""
    opts.abiText = ""
    opts.emitModeText = emitModeText
    opts.genericModeText = "dict"
    opts.genericSpecBudgetText = "0"
    opts.genericLoweringText = "mir_dict"
    opts.linkerText = linker
    opts.targetText = target
    opts.inputPath = inputPath
    opts.outputPath = outputPath
    opts.noRuntimeCText = ""
    opts.runtimeObjPath = ""
    opts.runtimeObjAssigned = false
    opts.internalAllowEmitObjText = ""
    opts.sidecarModeText = ""
    opts.sidecarDisableText = ""
    opts.sidecarObjPath = ""
    opts.sidecarBundlePath = ""
    opts.sidecarCompilerPath = ""
    opts.sidecarChildModeText = ""
    opts.sidecarOuterCompilerPath = ""
    opts.sidecarPreferText = ""
    opts.sidecarForceText = ""
    opts.uirSimdText = ""
    opts.disableDupScanText = ""
    opts.skipFixupsText = ""
    opts.skipNormalizeText = ""
    return opts

fn tooling_compileSemanticOptions(root: str, buildTrack: str, parseMode: str,
                                  linkerText: str, wholeProgramText: str,
                                  directExeText: str, linkerlessInmemText: str,
                                  multiText: str, incrementalText: str): ToolingCompileOptions =
    let jobsText: str = tooling_compileParallelJobsText(root)
    let fnJobsText: str = tooling_compileParallelFnJobsText(root, jobsText)
    return tooling_compileExplicitOptions(
        buildTrack, parseMode, linkerText, "", "", "", "", "", wholeProgramText,
        directExeText, linkerlessInmemText, multiText, incrementalText,
        jobsText, fnJobsText)

fn tooling_compileResolvedOptions(root: str, releaseBuild: bool, devStrict: bool,
                                  libraryEmit: bool, emitMode: str, linker: str,
                                  target: str, inPath: str,
                                  backendOutPath: str, wholeProgramRaw: str,
                                  optRaw: str, opt2Raw: str, optLevelRaw: str,
                                  noRuntimeCRaw: str, runtimeObjRaw: str,
                                  sidecarModeRaw: str, sidecarBundleRaw: str,
                                  sidecarCompilerRaw: str,
                                  sidecarChildModeRaw: str,
                                  sidecarOuterCompilerRaw: str,
                                  genericModeRaw: str, genericSpecBudgetRaw: str,
                                  genericLoweringRaw: str,
                                  jobsRaw: str, fnJobsRaw: str, multiRaw: str,
                                  incrementalRaw: str): ToolingCompileOptions =
    let buildTrack: str = tooling_compileBuildTrack(releaseBuild)
    let trackLabel: str = tooling_compileTrackLabel(releaseBuild)
    let parseMode: str = releaseBuild ? "full" : "outline"
    let allowNoMainText: str = libraryEmit ? "1" : "0"
    let directExeText: str = tooling_compileDirectExpected(releaseBuild)
    let linkerlessInmemText: str = tooling_compileInmemExpected(releaseBuild)
    let wholeProgramText: str = tooling_optionalBoolTextResolved(
        wholeProgramRaw, "", "--whole-program", trackLabel)
    if tooling_strNonEmpty(strutil.strip(wholeProgramRaw)) && !tooling_strNonEmpty(wholeProgramText):
        return nil
    let optDefaultText: str = releaseBuild ? "0" : ""
    let optText: str = tooling_optionalBoolTextResolved(
        optRaw, optDefaultText, "--opt", trackLabel)
    if tooling_strNonEmpty(strutil.strip(optRaw)) && !tooling_strNonEmpty(optText):
        return nil
    let opt2DefaultText: str = releaseBuild ? "0" : ""
    let opt2Text: str = tooling_optionalBoolTextResolved(
        opt2Raw, opt2DefaultText, "--opt2", trackLabel)
    if tooling_strNonEmpty(strutil.strip(opt2Raw)) && !tooling_strNonEmpty(opt2Text):
        return nil
    let optLevelDefaultText: str = releaseBuild ? "0" : ""
    let optLevelText: str = tooling_compileOptLevelTextResolved(
        optLevelRaw, optLevelDefaultText, "--opt-level", trackLabel)
    if tooling_strNonEmpty(strutil.strip(optLevelRaw)) && !tooling_strNonEmpty(optLevelText):
        return nil
    var noRuntimeCText: str = tooling_optionalBoolTextResolved(
        noRuntimeCRaw, "", "--no-runtime-c", trackLabel)
    if tooling_strNonEmpty(strutil.strip(noRuntimeCRaw)) && !tooling_strNonEmpty(noRuntimeCText):
        return nil
    let runtimeObjAssigned: bool = tooling_strNonEmpty(strutil.strip(runtimeObjRaw))
    let runtimeObjPath: str = tooling_compileRuntimeObjPathResolved(
        root, runtimeObjRaw, "--runtime-obj", trackLabel)
    if runtimeObjAssigned && !tooling_strNonEmpty(runtimeObjPath):
        return nil
    if runtimeObjAssigned && tooling_strEq(noRuntimeCText, "0"):
        tooling_printErr("cheng_tooling: " + trackLabel +
                         " --runtime-obj requires --no-runtime-c:1")
        return nil
    if runtimeObjAssigned && !tooling_strNonEmpty(noRuntimeCText):
        noRuntimeCText = "1"
    let sidecarModeText: str = tooling_compileSidecarModeTextResolved(
        sidecarModeRaw, "", "--sidecar-mode", trackLabel)
    if tooling_strNonEmpty(strutil.strip(sidecarModeRaw)) && !tooling_strNonEmpty(sidecarModeText):
        return nil
    let sidecarBundlePath: str = tooling_compileSidecarBundlePathResolved(
        root, sidecarBundleRaw, "--sidecar-bundle", trackLabel)
    if tooling_strNonEmpty(strutil.strip(sidecarBundleRaw)) &&
       !tooling_strNonEmpty(sidecarBundlePath):
        return nil
    let sidecarCompilerPath: str = tooling_compileSidecarCompilerPathResolved(
        root, sidecarCompilerRaw, "--sidecar-compiler", trackLabel)
    if tooling_strNonEmpty(strutil.strip(sidecarCompilerRaw)) &&
       !tooling_strNonEmpty(sidecarCompilerPath):
        return nil
    let sidecarChildModeText: str = tooling_compileSidecarChildModeTextResolved(
        sidecarChildModeRaw, "", "--sidecar-child-mode", trackLabel)
    if tooling_strNonEmpty(strutil.strip(sidecarChildModeRaw)) &&
       !tooling_strNonEmpty(sidecarChildModeText):
        return nil
    let sidecarOuterCompilerPath: str = tooling_compileSidecarOuterCompilerPathResolved(
        root, sidecarOuterCompilerRaw, "--sidecar-outer-compiler", trackLabel)
    if tooling_strNonEmpty(strutil.strip(sidecarOuterCompilerRaw)) &&
       !tooling_strNonEmpty(sidecarOuterCompilerPath):
        return nil
    let genericModeText: str = tooling_compileGenericModeTextResolved(
        genericModeRaw, "dict", "--generic-mode", trackLabel)
    if !tooling_strNonEmpty(genericModeText):
        return nil
    let genericSpecBudgetText: str = tooling_compileGenericSpecBudgetTextResolved(
        genericSpecBudgetRaw, "0", "--generic-spec-budget", trackLabel)
    if !tooling_strNonEmpty(genericSpecBudgetText):
        return nil
    let genericLoweringText: str = tooling_compileGenericLoweringTextResolved(
        genericLoweringRaw, "mir_dict", "--generic-lowering", trackLabel)
    if !tooling_strNonEmpty(genericLoweringText):
        return nil
    let jobsDefaultText: str = tooling_compileDefaultJobs(root)
    let jobsText: str = tooling_compileJobsTextResolved(
        jobsRaw, jobsDefaultText, "--jobs", trackLabel)
    if !tooling_strNonEmpty(jobsText):
        return nil
    let fnJobsText: str = tooling_compileJobsTextResolved(
        fnJobsRaw, jobsText, "--fn-jobs", trackLabel)
    if !tooling_strNonEmpty(fnJobsText):
        return nil
    var multiDefaultText: str = tooling_compileDefaultMulti(root)
    if !releaseBuild:
        multiDefaultText = tooling_compileDevMultiDefault(root, devStrict)
    let multiText: str = tooling_boolTextResolved(
        multiRaw, multiDefaultText, "--multi", trackLabel)
    if !tooling_strNonEmpty(multiText):
        return nil
    var incrementalDefaultText: str = "0"
    if !releaseBuild:
        incrementalDefaultText = tooling_compileDevFastText(devStrict)
    let incrementalText: str = tooling_boolTextResolved(
        incrementalRaw, incrementalDefaultText, "--incremental", trackLabel)
    if !tooling_strNonEmpty(incrementalText):
        return nil
    let opts: ToolingCompileOptions = tooling_compileExplicitOptions(
        buildTrack, parseMode, linker, target, inPath, backendOutPath,
        tooling_compileBackendEmitMode(libraryEmit, emitMode), allowNoMainText, wholeProgramText,
        directExeText, linkerlessInmemText, multiText, incrementalText,
        jobsText, fnJobsText)
    opts.targetText = target
    opts.inputPath = inPath
    opts.outputPath = backendOutPath
    opts.stage1ProfileText = tooling_compileProfileEnv01("STAGE1_PROFILE", "0")
    opts.backendProfileText = tooling_compileProfileEnv01("BACKEND_PROFILE", "0")
    opts.uirProfileText = tooling_compileProfileEnv01("UIR_PROFILE", "0")
    opts.fastDevProfileText = releaseBuild ? "0" : tooling_compileDevFastText(devStrict)
    opts.cflagsRaw = tooling_compileReleaseCflagsRaw(releaseBuild)
    opts.ldflagsRaw = tooling_compileReleaseLdflagsRaw(releaseBuild, target, opts.cflagsRaw)
    opts.enableCliText = "1"
    opts.optText = optText
    opts.opt2Text = opt2Text
    opts.optLevelText = optLevelText
    opts.noRuntimeCText = noRuntimeCText
    opts.runtimeObjPath = runtimeObjPath
    opts.runtimeObjAssigned = runtimeObjAssigned
    if !tooling_compileApplyStrictSidecarContract(
            root, trackLabel, "", sidecarBundlePath, sidecarCompilerPath, opts):
        return nil
    if tooling_strNonEmpty(sidecarChildModeText):
        opts.sidecarChildModeText = sidecarChildModeText
        if !tooling_strEq(sidecarChildModeText, "outer_cli"):
            opts.sidecarOuterCompilerPath = ""
    if tooling_strNonEmpty(sidecarOuterCompilerPath):
        opts.sidecarOuterCompilerPath = sidecarOuterCompilerPath
    if tooling_strEq(opts.sidecarChildModeText, "outer_cli"):
        if !tooling_isExecutable(root, opts.sidecarOuterCompilerPath):
            tooling_printErr("cheng_tooling: " + trackLabel +
                             " --sidecar-child-mode:outer_cli requires --sidecar-outer-compiler:<path>")
            return nil
    elif tooling_strNonEmpty(opts.sidecarOuterCompilerPath):
        tooling_printErr("cheng_tooling: " + trackLabel +
                         " --sidecar-outer-compiler requires --sidecar-child-mode:outer_cli")
        return nil
    opts.genericModeText = genericModeText
    opts.genericSpecBudgetText = genericSpecBudgetText
    opts.genericLoweringText = genericLoweringText
    opts.internalAllowEmitObjText = libraryEmit ? "1" : ""
    return opts

fn tooling_compileCollectEnvOverridesInternal(root: str, stage0Exec: str,
                                              opts: ToolingCompileOptions,
                                              includeConcreteCompileEnv: bool,
                                              envOverrides: var str[]) =
    tooling_backendCompileModuleCacheDisabledCollect(envOverrides)
    tooling_backendCompileCompatCollect(
        envOverrides, opts.stdNoptr, opts.stdNoptrStrict, opts.noptrNonCAbi,
        opts.noptrNonCAbiInternal, opts.stage1ProfileText)
    tooling_envAssignCollect(envOverrides, "BACKEND_PROFILE", opts.backendProfileText)
    tooling_envAssignCollect(envOverrides, "UIR_PROFILE", opts.uirProfileText)
    if tooling_strNonEmpty(opts.enableCliText):
        tooling_envAssignCollect(envOverrides, "BACKEND_ENABLE_CLI", opts.enableCliText)
    tooling_envAssignCollect(envOverrides, "BACKEND_LINKER", opts.linkerText)
    tooling_backendCompileBaseCollect(
        envOverrides, opts.buildTrack, opts.parseMode, opts.stage1BuilderText,
        opts.skipGlobalInitText, opts.allowNoMainText)
    tooling_envAssignCollect(envOverrides, "BACKEND_FAST_DEV_PROFILE", opts.fastDevProfileText)
    tooling_backendCompileExecutionCollect(
        envOverrides, opts.wholeProgramText, opts.directExeText, opts.linkerlessInmemText,
        opts.multiText, opts.incrementalText, opts.jobsText, opts.fnJobsText)
    if tooling_strNonEmpty(opts.optText):
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT", opts.optText)
    if tooling_strNonEmpty(opts.opt2Text):
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT2", opts.opt2Text)
    if tooling_strNonEmpty(opts.optLevelText):
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT_LEVEL", opts.optLevelText)
    if tooling_strNonEmpty(opts.cflagsRaw):
        tooling_envAssignCollect(envOverrides, "BACKEND_CFLAGS", opts.cflagsRaw)
    if tooling_strNonEmpty(opts.ldflagsRaw):
        tooling_envAssignCollect(envOverrides, "BACKEND_LDFLAGS", opts.ldflagsRaw)
    if tooling_strNonEmpty(opts.abiText):
        tooling_envAssignCollect(envOverrides, "ABI", opts.abiText)
    tooling_backendCompileGenericCollect(
        envOverrides, opts.genericModeText, opts.genericSpecBudgetText, opts.genericLoweringText)
    if tooling_strNonEmpty(opts.uirSimdText):
        tooling_envAssignCollect(envOverrides, "UIR_SIMD", opts.uirSimdText)
    if tooling_strNonEmpty(opts.disableDupScanText):
        tooling_envAssignCollect(envOverrides, "BACKEND_STAGE1_DISABLE_DUP_SCAN",
                                 opts.disableDupScanText)
    if tooling_strNonEmpty(opts.skipFixupsText):
        tooling_envAssignCollect(envOverrides, "BACKEND_SKIP_UIR_FIXUPS",
                                 opts.skipFixupsText)
    if tooling_strNonEmpty(opts.skipNormalizeText):
        tooling_envAssignCollect(envOverrides, "BACKEND_SKIP_UIR_NORMALIZE",
                                 opts.skipNormalizeText)
    if includeConcreteCompileEnv:
        tooling_envAssignCollect(envOverrides, "BACKEND_TARGET", opts.targetText)
        tooling_envAssignCollect(envOverrides, "BACKEND_INPUT", opts.inputPath)
        tooling_envAssignCollect(envOverrides, "BACKEND_OUTPUT", opts.outputPath)
        tooling_envAssignCollect(envOverrides, "BACKEND_EMIT", opts.emitModeText)
        if tooling_strNonEmpty(opts.internalAllowEmitObjText):
            tooling_envAssignCollect(envOverrides, "BACKEND_INTERNAL_ALLOW_EMIT_OBJ",
                                     opts.internalAllowEmitObjText)
    if tooling_strNonEmpty(opts.noRuntimeCText):
        tooling_envAssignCollect(envOverrides, "BACKEND_NO_RUNTIME_C", opts.noRuntimeCText)
    if opts.runtimeObjAssigned || tooling_strNonEmpty(opts.runtimeObjPath):
        tooling_envAssignCollect(envOverrides, "BACKEND_RUNTIME_OBJ", opts.runtimeObjPath)
    if tooling_strNonEmpty(opts.sidecarModeText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_MODE", opts.sidecarModeText)
    if tooling_strNonEmpty(opts.sidecarDisableText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_DISABLE",
                                 opts.sidecarDisableText)
    if tooling_strNonEmpty(opts.sidecarObjPath):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_OBJ",
                                 opts.sidecarObjPath)
    if tooling_strNonEmpty(opts.sidecarBundlePath):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_BUNDLE",
                                 opts.sidecarBundlePath)
    if tooling_strNonEmpty(opts.sidecarCompilerPath):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_COMPILER",
                                 opts.sidecarCompilerPath)
        let sidecarRealDriver: str = tooling_backendDriverSidecarCompilerRealDriver(
            root, opts.sidecarCompilerPath)
        if tooling_strNonEmpty(sidecarRealDriver):
            tooling_envAssignCollect(
                envOverrides,
                "TOOLING_BUILD_GLOBAL_CURRENTSOURCE_REAL_DRIVER",
                sidecarRealDriver)
    if tooling_strNonEmpty(opts.sidecarChildModeText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_CHILD_MODE",
                                 opts.sidecarChildModeText)
    if tooling_strNonEmpty(opts.sidecarOuterCompilerPath):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_OUTER_COMPILER",
                                 opts.sidecarOuterCompilerPath)
    if tooling_strNonEmpty(opts.sidecarPreferText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_PREFER_SIDECAR",
                                 opts.sidecarPreferText)
    if tooling_strNonEmpty(opts.sidecarForceText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_FORCE_SIDECAR",
                                 opts.sidecarForceText)
    tooling_stage0LegacyCStringCompatCollect(root, stage0Exec, envOverrides)

fn tooling_compileCollectEnvOverrides(root: str, stage0Exec: str, opts: ToolingCompileOptions,
                                      envOverrides: var str[]) =
    tooling_compileCollectEnvOverridesInternal(root, stage0Exec, opts, true, envOverrides)

fn tooling_compileCollectSemanticEnvOverrides(root: str, stage0Exec: str,
                                              opts: ToolingCompileOptions,
                                              envOverrides: var str[]) =
    tooling_compileCollectEnvOverridesInternal(root, stage0Exec, opts, false, envOverrides)

fn tooling_compileOptionsEnvText(root: str, stage0Exec: str,
                                 opts: ToolingCompileOptions): str =
    var envOverrides: str[] = []
    tooling_compileCollectEnvOverrides(root, stage0Exec, opts, envOverrides)
    return tooling_envOverridesShellPrefix(envOverrides)

fn tooling_compileSemanticEnvText(root: str, stage0Exec: str,
                                  opts: ToolingCompileOptions): str =
    var envOverrides: str[] = []
    tooling_compileCollectSemanticEnvOverrides(root, stage0Exec, opts, envOverrides)
    return tooling_envOverridesShellPrefix(envOverrides)

fn tooling_compileCommandEnvOverrides(opts: ToolingCompileOptions, includeBuildTrack: bool,
                                      envOverrides: var str[]) =
    tooling_backendCompileCompatCollect(
        envOverrides, opts.stdNoptr, opts.stdNoptrStrict, opts.noptrNonCAbi,
        opts.noptrNonCAbiInternal, opts.stage1ProfileText)
    if tooling_strNonEmpty(opts.backendProfileText):
        tooling_envAssignCollect(envOverrides, "BACKEND_PROFILE", opts.backendProfileText)
    if tooling_strNonEmpty(opts.uirProfileText):
        tooling_envAssignCollect(envOverrides, "UIR_PROFILE", opts.uirProfileText)
    if includeBuildTrack && tooling_strNonEmpty(opts.buildTrack):
        tooling_envAssignCollect(envOverrides, "BACKEND_BUILD_TRACK", opts.buildTrack)
    if tooling_strNonEmpty(opts.stage1BuilderText):
        tooling_envAssignCollect(envOverrides, "BACKEND_STAGE1_BUILDER", opts.stage1BuilderText)
    if tooling_strNonEmpty(opts.skipGlobalInitText):
        tooling_envAssignCollect(envOverrides, "BACKEND_SKIP_GLOBAL_INIT", opts.skipGlobalInitText)
    tooling_envAssignCollect(envOverrides, "BACKEND_IR", "uir")
    if tooling_strNonEmpty(opts.allowNoMainText):
        tooling_envAssignCollect(envOverrides, "BACKEND_ALLOW_NO_MAIN", opts.allowNoMainText)
    if tooling_strNonEmpty(opts.fastDevProfileText):
        tooling_envAssignCollect(envOverrides, "BACKEND_FAST_DEV_PROFILE", opts.fastDevProfileText)
    if tooling_strNonEmpty(opts.linkerText):
        tooling_envAssignCollect(envOverrides, "BACKEND_LINKER", opts.linkerText)
    if tooling_strNonEmpty(opts.wholeProgramText):
        tooling_envAssignCollect(envOverrides, "BACKEND_WHOLE_PROGRAM", opts.wholeProgramText)
    if tooling_strNonEmpty(opts.directExeText):
        tooling_envAssignCollect(envOverrides, "BACKEND_DIRECT_EXE", opts.directExeText)
    if tooling_strNonEmpty(opts.linkerlessInmemText):
        tooling_envAssignCollect(envOverrides, "BACKEND_LINKERLESS_INMEM",
                                 opts.linkerlessInmemText)
    if tooling_strNonEmpty(opts.multiText):
        tooling_envAssignCollect(envOverrides, "BACKEND_MULTI", opts.multiText)
    if tooling_strNonEmpty(opts.incrementalText):
        tooling_envAssignCollect(envOverrides, "BACKEND_INCREMENTAL", opts.incrementalText)
    if tooling_strNonEmpty(opts.jobsText):
        tooling_envAssignCollect(envOverrides, "BACKEND_JOBS", opts.jobsText)
    if tooling_strNonEmpty(opts.fnJobsText):
        tooling_envAssignCollect(envOverrides, "BACKEND_FN_JOBS", opts.fnJobsText)
    if tooling_strNonEmpty(opts.optText):
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT", opts.optText)
    if tooling_strNonEmpty(opts.opt2Text):
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT2", opts.opt2Text)
    if tooling_strNonEmpty(opts.optLevelText):
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT_LEVEL", opts.optLevelText)
    if tooling_strNonEmpty(opts.cflagsRaw):
        tooling_envAssignCollect(envOverrides, "BACKEND_CFLAGS", opts.cflagsRaw)
    if tooling_strNonEmpty(opts.ldflagsRaw):
        tooling_envAssignCollect(envOverrides, "BACKEND_LDFLAGS", opts.ldflagsRaw)
    if tooling_strNonEmpty(opts.abiText):
        tooling_envAssignCollect(envOverrides, "ABI", opts.abiText)
    tooling_backendCompileGenericCollect(
        envOverrides, opts.genericModeText, opts.genericSpecBudgetText, opts.genericLoweringText)
    if tooling_strNonEmpty(opts.uirSimdText):
        tooling_envAssignCollect(envOverrides, "UIR_SIMD", opts.uirSimdText)
    if tooling_strNonEmpty(opts.disableDupScanText):
        tooling_envAssignCollect(envOverrides, "BACKEND_STAGE1_DISABLE_DUP_SCAN",
                                 opts.disableDupScanText)
    if tooling_strNonEmpty(opts.skipFixupsText):
        tooling_envAssignCollect(envOverrides, "BACKEND_SKIP_UIR_FIXUPS",
                                 opts.skipFixupsText)
    if tooling_strNonEmpty(opts.skipNormalizeText):
        tooling_envAssignCollect(envOverrides, "BACKEND_SKIP_UIR_NORMALIZE",
                                 opts.skipNormalizeText)
    if tooling_strNonEmpty(opts.noRuntimeCText):
        tooling_envAssignCollect(envOverrides, "BACKEND_NO_RUNTIME_C", opts.noRuntimeCText)
    if opts.runtimeObjAssigned || tooling_strNonEmpty(opts.runtimeObjPath):
        tooling_envAssignCollect(envOverrides, "BACKEND_RUNTIME_OBJ", opts.runtimeObjPath)
    if tooling_strNonEmpty(opts.sidecarModeText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_MODE", opts.sidecarModeText)
    if tooling_strNonEmpty(opts.sidecarDisableText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_DISABLE",
                                 opts.sidecarDisableText)
    if tooling_strNonEmpty(opts.sidecarObjPath):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_OBJ",
                                 opts.sidecarObjPath)
    if tooling_strNonEmpty(opts.sidecarBundlePath):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_BUNDLE",
                                 opts.sidecarBundlePath)
    if tooling_strNonEmpty(opts.sidecarCompilerPath):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_COMPILER",
                                 opts.sidecarCompilerPath)
    if tooling_strNonEmpty(opts.sidecarChildModeText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_CHILD_MODE",
                                 opts.sidecarChildModeText)
    if tooling_strNonEmpty(opts.sidecarOuterCompilerPath):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_OUTER_COMPILER",
                                 opts.sidecarOuterCompilerPath)
    if tooling_strNonEmpty(opts.sidecarPreferText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_PREFER_SIDECAR",
                                 opts.sidecarPreferText)
    if tooling_strNonEmpty(opts.sidecarForceText):
        tooling_envAssignCollect(envOverrides, "BACKEND_UIR_FORCE_SIDECAR",
                                 opts.sidecarForceText)

fn tooling_compileCommandEnvText(opts: ToolingCompileOptions,
                                 includeBuildTrack: bool): str =
    var envOverrides: str[] = []
    tooling_compileCommandEnvOverrides(opts, includeBuildTrack, envOverrides)
    return tooling_envOverridesShellPrefix(envOverrides)

fn tooling_compileCommandTargetLinkerExprEnvText(targetExpr: str, linkerExpr: str): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "", "", "", targetExpr, "", "", "", "", "", "", "", "", "", "", "")
    return tooling_compileExprEnvText(
        compileOpts, tooling_envAssignExpr("BACKEND_LINKER", linkerExpr), true)

fn tooling_verifyBackendLoopRuntimeCompileEnvText(targetExpr: str, inputExpr: str,
                                                  outputExpr: str,
                                                  optLevelExpr: str): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "", "", "self", targetExpr, inputExpr, outputExpr, "exe", "", "", "1", "1", "0",
        "0", "", "")
    compileOpts.optText = "1"
    compileOpts.opt2Text = "0"
    compileOpts.optLevelText = optLevelExpr
    compileOpts.noRuntimeCText = "1"
    return tooling_compileExprEnvText(
        compileOpts,
        tooling_envAssignExpr("BACKEND_VALIDATE", "0") +
            tooling_envAssignExpr("UIR_EGRAPH_ITERS", "0"),
        true)

fn tooling_verifyBackendOpt2CompileEnvText(targetExpr: str, inputExpr: str, outputExpr: str,
                                           opt2ItersExpr: str, inlineItersExpr: str,
                                           cfgCanonItersExpr: str,
                                           uirProfileExpr: str, uirSimdExpr: str,
                                           uirSimdMaxWidthExpr: str,
                                           uirSimdPolicyExpr: str): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "", "", "", targetExpr, inputExpr, outputExpr, "exe", "", "", "", "", "0",
        "", "", "")
    compileOpts.opt2Text = "1"
    return tooling_compileExprEnvText(
        compileOpts,
        tooling_envAssignExpr("UIR_OPT2_ITERS", opt2ItersExpr) +
            tooling_envAssignExpr("UIR_INLINE_ITERS", inlineItersExpr) +
            tooling_envAssignExpr("UIR_CFG_CANON_ITERS", cfgCanonItersExpr) +
            tooling_envAssignExpr("UIR_PROFILE", uirProfileExpr) +
            tooling_envAssignExpr("UIR_SIMD", uirSimdExpr) +
            tooling_envAssignExpr("UIR_SIMD_MAX_WIDTH", uirSimdMaxWidthExpr) +
            tooling_envAssignExpr("UIR_SIMD_POLICY", uirSimdPolicyExpr),
        true)

fn tooling_verifyBackendLinkerAbiCoreCrossCompileEnvText(targetExpr: str, inputExpr: str,
                                                         outputExpr: str): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "", "", "self", targetExpr, inputExpr, outputExpr, "exe", "", "", "1", "1", "0",
        "0", "1", "")
    compileOpts.abiText = "v2_noptr"
    compileOpts.noptrNonCAbi = "0"
    compileOpts.noptrNonCAbiInternal = "0"
    compileOpts.noRuntimeCText = "1"
    compileOpts.internalAllowEmitObjText = "0"
    return tooling_compileExprEnvText(
        compileOpts, tooling_envAssignExpr("CACHE", "0"), true)

fn tooling_verifyBackendUirSoaSurfaceCompileEnvText(targetExpr: str, inputExpr: str,
                                                    outputExpr: str): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "dev", "", "system", targetExpr, inputExpr, outputExpr, "exe", "", "", "", "", "0",
        "0", "", "")
    compileOpts.optText = "1"
    compileOpts.opt2Text = "1"
    compileOpts.optLevelText = "2"
    compileOpts.noRuntimeCText = "0"
    compileOpts.stdNoptr = "0"
    compileOpts.stdNoptrStrict = "0"
    compileOpts.noptrNonCAbi = "0"
    compileOpts.noptrNonCAbiInternal = "0"
    compileOpts.stage1ProfileText = "0"
    compileOpts.uirProfileText = "1"
    return tooling_compileExprEnvText(
        compileOpts,
        tooling_envAssignExpr("MM", "orc") +
            tooling_envAssignExpr("STAGE1_SKIP_CPROFILE", "1") +
            tooling_envAssignExpr("UIR_SSU", "1") +
            tooling_envAssignExpr("UIR_SOA_REPORT", "1") +
            tooling_envAssignExpr("UIR_SOA_ENFORCE", "1"),
        true)

fn tooling_verifyBackendLinkerAbiCoreCompileEnvText(): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "", "", "", "", "", "", "", "", "", "", "", "", "", "", "")
    compileOpts.abiText = "v2_noptr"
    compileOpts.noptrNonCAbi = "0"
    compileOpts.noptrNonCAbiInternal = "0"
    compileOpts.optLevelText = "2"
    return tooling_envAssignCompat("CACHE", "0") + tooling_compileCommandEnvText(compileOpts, false)

fn tooling_compileDevFastText(devStrict: bool): str =
    return tooling_boolText(!devStrict)

fn tooling_compileDevMultiDefault(root: str, devStrict: bool): str =
    if devStrict:
        return "0"
    return tooling_compileDefaultMulti(root)

fn tooling_compileProfileLib(emitMode: str): str =
    if tooling_strEq(emitMode, "shared"):
        return "release_system_link_shared_obj_packaged"
    return "release_system_link_static_obj_packaged"

fn tooling_compileProfile(releaseBuild: bool, linker: str, devStrict: bool): str =
    if releaseBuild:
        return "release_system_link_canonical_driver"
    if tooling_strEq(linker, "self"):
        if devStrict:
            return "dev_strict_mem_exe"
        return "dev_fast_mem_exe"
    return "dev_system_link_stable"

fn tooling_compileRunModeText(runMode: str): str =
    return tooling_nonEmptyDefault(runMode, "none")

fn tooling_compileDirectSpawnCmd(stage0Exec: str): str =
    return tooling_shellQuote(stage0Exec) + " [direct_spawn]"

fn tooling_compileShellExecCmd(root: str, stage0Exec: str, envOverrides: str[],
                               inPath: str, backendOutPath: str, target: str,
                               linker: str, timeoutSec: int32): str =
    var shellCmdParts: str[] = []
    add(shellCmdParts, tooling_envOverridesShellPrefix(envOverrides))
    add(shellCmdParts, tooling_shellQuote(stage0Exec))
    add(shellCmdParts, " ")
    add(shellCmdParts, tooling_shellQuote("--input:" + inPath))
    add(shellCmdParts, " ")
    add(shellCmdParts, tooling_shellQuote("--output:" + backendOutPath))
    add(shellCmdParts, " ")
    add(shellCmdParts, tooling_shellQuote("--target:" + target))
    add(shellCmdParts, " ")
    add(shellCmdParts, tooling_shellQuote("--linker:" + linker))
    return tooling_wrapStage0LockTimeout(
        root, timeoutSec, tooling_joinFragments(shellCmdParts), "compile_exe")

fn tooling_compileExecCmd(root: str, directExecAllowed: bool, stage0Exec: str,
                          envOverrides: str[], inPath: str, backendOutPath: str,
                          target: str, linker: str, timeoutSec: int32): str =
    if directExecAllowed:
        return tooling_compileDirectSpawnCmd(stage0Exec)
    return tooling_compileShellExecCmd(
        root, stage0Exec, envOverrides, inPath, backendOutPath, target, linker, timeoutSec)

fn tooling_compileRunHostCmd(root: str, outPath: str): str =
    let selfExe: str = tooling_selfExecPath(root)
    if !tooling_strNonEmpty(selfExe):
        return ""
    let stateDirRaw: str = strutil.strip(os.getEnvDefault("BACKEND_HOSTRUNNER_STATE_DIR", ""))
    if tooling_strNonEmpty(stateDirRaw):
        let stateAbs: str = tooling_pathAbsolute(root, stateDirRaw)
        return tooling_envAssignCompat("TOOLING_SELF_BIN", selfExe) +
               tooling_shellQuote(selfExe) + " run backend_host_runner run-host " +
               tooling_shellQuote("--exe:" + outPath) +
               " " + tooling_shellQuote("--state:" + stateAbs)
    return tooling_envAssignCompat("TOOLING_SELF_BIN", selfExe) +
           tooling_shellQuote(selfExe) + " run backend_host_runner run-host " +
           tooling_shellQuote("--exe:" + outPath)

fn tooling_compileRunAfterCmd(root: str, outPath: str, runMode: str): str =
    if tooling_strEq(runMode, "host"):
        return tooling_compileRunHostCmd(root, outPath)
    return tooling_shellQuote(outPath)

fn tooling_cmdCompileExe(root: str, inRaw: str, outRaw: str, nameRaw: str, targetRaw: str,
                         releaseBuild: bool,
                         devModeRaw: str,
                         emitModeRaw: str,
                         wholeProgramRaw: str, optRaw: str, opt2Raw: str, optLevelRaw: str,
                         noRuntimeCRaw: str, runtimeObjRaw: str,
                         sidecarModeRaw: str, sidecarBundleRaw: str,
                         sidecarCompilerRaw: str, sidecarChildModeRaw: str,
                         sidecarOuterCompilerRaw: str,
                         genericModeRaw: str, genericSpecBudgetRaw: str,
                         genericLoweringRaw: str,
                         jobsRaw: str, fnJobsRaw: str, multiRaw: str, incrementalRaw: str,
                         runAfter: bool, runModeRaw: str): int32 =
    let compileStartMs: int64 = tooling_nowMs()
    var stage0ResolveMs: int64 = int64(0)
    var stage0PrepareMs: int64 = int64(0)
    var stage0PreflightMs: int64 = int64(0)
    var runtimeResolveMs: int64 = int64(0)
    var commandBuildMs: int64 = int64(0)
    var compileExecMs: int64 = int64(0)
    var publishMs: int64 = int64(0)
    let inPath: str = tooling_pathAbsolute(root, inRaw)
    if !tooling_strNonEmpty(inPath) || !os.fileExists(inPath):
        tooling_printErr("cheng_tooling: compile input not found: " + inRaw + " (resolved: " + inPath + ")")
        return 1
    let emitMode: str = strutil.toLowerAscii(strutil.strip(emitModeRaw))
    let libraryEmit: bool = tooling_emitModeIsLibrary(emitMode)
    if !tooling_strEq(emitMode, "exe") && !libraryEmit:
        tooling_printErr("cheng_tooling: compile only supports --emit:exe|shared|static")
        return 2
    if libraryEmit && !releaseBuild:
        tooling_printErr("cheng_tooling: --emit:shared|static is release-compile only")
        return 2
    if runAfter && libraryEmit:
        tooling_printErr("cheng_tooling: --emit:shared/static does not support --run/--run:*")
        return 2
    let target: str = tooling_compileTarget(root, targetRaw)
    let linker: str = tooling_compileLinkerMode(releaseBuild)
    if tooling_strEq(emitMode, "exe") && !releaseBuild && !tooling_targetSupportsSelfLinker(target):
        tooling_printErr("cheng_tooling: cheng requires self-link/direct-exe target support: " + target)
        return 2
    if !tooling_stage0QuarantineEnabled() &&
       tooling_stage0BlockOnQuarantineUe(root, "TOOLING_COMPILE_BLOCK_ON_UE", "compile_exe"):
        return 1
    let stage0ResolveStartMs: int64 = tooling_nowMs()
    let stage0ProbeEnabled: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_COMPILE_PROBE", "0"))
    let stage0: str = tooling_resolveStage0DriverForCompile(root, stage0ProbeEnabled)
    stage0ResolveMs = tooling_nowMs() - stage0ResolveStartMs
    if !tooling_strNonEmpty(stage0):
        tooling_printErr("cheng_tooling: stage0 driver not found")
        return 1
    let stage0PrepareStartMs: int64 = tooling_nowMs()
    let stage0Exec: str = tooling_prepareStage0Exec(root, stage0, "compile")
    stage0PrepareMs = tooling_nowMs() - stage0PrepareStartMs
    if !tooling_strNonEmpty(stage0Exec):
        tooling_printErr("cheng_tooling: stage0 prepare failed")
        return 1
    let stage0PreflightStartMs: int64 = tooling_nowMs()
    if !tooling_stage0PreflightOk(root, stage0Exec):
        stage0PreflightMs = tooling_nowMs() - stage0PreflightStartMs
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: stage0 preflight failed: " + stage0)
        return 1
    stage0PreflightMs = tooling_nowMs() - stage0PreflightStartMs
    let trackLabel: str = tooling_compileTrackLabel(releaseBuild)
    let devMode: str = tooling_compileDevModeForTrack(releaseBuild, devModeRaw)
    let devStrict: bool = !releaseBuild && tooling_strEq(devMode, "strict")
    let explicitNoRuntimeC: bool = tooling_strNonEmpty(strutil.strip(noRuntimeCRaw))
    let explicitRuntimeObj: bool = tooling_strNonEmpty(strutil.strip(runtimeObjRaw))
    if tooling_failRemovedEnvPresent("CHENGC_DEV_MODE", "--dev:fast|strict"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_DEV_MODE", "--dev:fast|strict"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if releaseBuild && explicitNoRuntimeC:
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: release-compile does not accept --no-runtime-c")
        return 2
    if releaseBuild && explicitRuntimeObj:
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: release-compile does not accept --runtime-obj")
        return 2
    if tooling_failFixedTrackEnv(
        "BACKEND_STAGE1_PARSE_MODE", tooling_compileParseExpected(releaseBuild), trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failFixedTrackEnv("BACKEND_FN_SCHED", "ws", trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failFixedTrackEnv(
        "BACKEND_DIRECT_EXE", tooling_compileDirectExpected(releaseBuild), trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failFixedTrackEnv(
        "BACKEND_LINKERLESS_INMEM", tooling_compileInmemExpected(releaseBuild), trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failFixedTrackEnv(
        "BACKEND_LINKER", tooling_compileLinkerMode(releaseBuild), trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_WHOLE_PROGRAM", "--whole-program:0|1"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_OPT", "--opt:0|1"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_OPT2", "--opt2:0|1"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_OPT_LEVEL", "--opt-level:0|1|2|3"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_RELEASE_BACKEND_OPT", "--opt:0|1"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_RELEASE_BACKEND_OPT2", "--opt2:0|1"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_RELEASE_OPT_LEVEL", "--opt-level:0|1|2|3"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("GENERIC_MODE", "--generic-mode:dict"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("GENERIC_SPEC_BUDGET", "--generic-spec-budget:0"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("GENERIC_LOWERING", "--generic-lowering:mir_dict"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_NO_RUNTIME_C", "--no-runtime-c:0|1"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_RUNTIME_OBJ", "--runtime-obj:<path>"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_SIDECAR_MODE",
                                     "--sidecar-mode:cheng"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_SIDECAR_BUNDLE",
                                     "--sidecar-bundle:<path>"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_SIDECAR_COMPILER",
                                     "--sidecar-compiler:<path>"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_SIDECAR_CHILD_MODE",
                                     "--sidecar-child-mode:<cli|outer_cli>"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_SIDECAR_OUTER_COMPILER",
                                     "--sidecar-outer-compiler:<path>"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_SIDECAR_DISABLE", ""):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_SIDECAR_OBJ", ""):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_PREFER_SIDECAR", ""):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failRemovedEnvPresent("BACKEND_UIR_FORCE_SIDECAR", ""):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    let runMode: str = tooling_compileRunModeNormalized(runAfter, runModeRaw, releaseBuild)
    let explicitOut: bool = tooling_strNonEmpty(strutil.strip(outRaw)) || tooling_strNonEmpty(strutil.strip(nameRaw))
    let runEphemeralOut: bool = tooling_compileRunEphemeralOut(
        runAfter, emitMode, runMode, releaseBuild, explicitOut)
    let outPath: str = tooling_compileOutPath(
        root, inPath, outRaw, nameRaw, emitMode, runEphemeralOut)
    let exeEmit: bool = tooling_strEq(emitMode, "exe")
    let atomicExePublish: bool = exeEmit && tooling_compileNeedsAtomicExePublish(root, outPath)
    let directExeOutput: bool = exeEmit && !atomicExePublish
    let backendOutPath: str = tooling_compileBackendOutPath(outPath, atomicExePublish, libraryEmit)
    if (atomicExePublish || libraryEmit) && os.fileExists(backendOutPath):
        os.removeFile(backendOutPath)
    let backendOutTmpLinkObj: str = tooling_compileTmpLinkObjPath(backendOutPath)
    let backendOutObj: str = tooling_compileObjPath(backendOutPath)
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        if !tooling_mkdirP(root, outDir):
            tooling_printErr("cheng_tooling: failed to create output dir: " + outDir)
            return 1
    let compileLog: str = tooling_compileLogPath(backendOutPath)
    if os.fileExists(compileLog):
        os.removeFile(compileLog)
    let commandBuildStartMs: int64 = tooling_nowMs()
    let compileOpts: ToolingCompileOptions = tooling_compileResolvedOptions(
        root, releaseBuild, devStrict, libraryEmit, emitMode, linker, target, inPath,
        backendOutPath, wholeProgramRaw, optRaw, opt2Raw, optLevelRaw,
        noRuntimeCRaw, runtimeObjRaw,
        sidecarModeRaw, sidecarBundleRaw, sidecarCompilerRaw,
        sidecarChildModeRaw, sidecarOuterCompilerRaw,
        genericModeRaw, genericSpecBudgetRaw, genericLoweringRaw,
        jobsRaw, fnJobsRaw, multiRaw, incrementalRaw)
    if compileOpts == nil:
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    var envOverrides: str[] = []
    if tooling_strEq(linker, "self") && tooling_strEq(emitMode, "exe"):
        let runtimeResolveStartMs: int64 = tooling_nowMs()
        var runtimeObj: str = tooling_textLiteral("")
        runtimeResolveMs = tooling_nowMs() - runtimeResolveStartMs
        if compileOpts.runtimeObjAssigned:
            runtimeObj = compileOpts.runtimeObjPath
            runtimeResolveMs = tooling_nowMs() - runtimeResolveStartMs
            if !tooling_compileRuntimeObjSupportsInput(root, inPath, runtimeObj):
                tooling_printErr("cheng_tooling: explicit --runtime-obj missing required self-link symbols: " + runtimeObj)
                tooling_cleanupStage0Exec(stage0, stage0Exec)
                return 1
            compileOpts.noRuntimeCText = "1"
            compileOpts.runtimeObjPath = runtimeObj
        elif tooling_strEq(compileOpts.noRuntimeCText, "1"):
            runtimeObj = tooling_compileExplicitNoRuntimeRuntimeObjPath(
                root, stage0Exec, target, inPath)
            runtimeResolveMs = tooling_nowMs() - runtimeResolveStartMs
            if !tooling_compileRuntimeObjSupportsInput(root, inPath, runtimeObj):
                tooling_printErr("cheng_tooling: missing valid runtime object for --no-runtime-c:1: " + runtimeObj)
                tooling_cleanupStage0Exec(stage0, stage0Exec)
                return 1
            compileOpts.runtimeObjPath = runtimeObj
        elif tooling_strEq(compileOpts.noRuntimeCText, "0"):
            compileOpts.runtimeObjPath = ""
        else:
            let compileNeedsCombinedRuntimeObj: bool =
                tooling_compileInputNeedsCombinedRuntimeObj(inPath)
            if compileNeedsCombinedRuntimeObj:
                runtimeObj = tooling_runtimeObjPath(root, target)
                if !os.fileExists(runtimeObj) || !tooling_runtimeObjHasRequiredSymbols(root, runtimeObj):
                    runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
                runtimeResolveMs = tooling_nowMs() - runtimeResolveStartMs
                if !os.fileExists(runtimeObj) || !tooling_runtimeObjHasRequiredSymbols(root, runtimeObj):
                    tooling_printErr("cheng_tooling: missing valid runtime object for self-link: " + runtimeObj)
                    tooling_cleanupStage0Exec(stage0, stage0Exec)
                    return 1
                compileOpts.noRuntimeCText = "1"
                compileOpts.runtimeObjPath = runtimeObj
            else:
                runtimeObj = tooling_runtimeObjBasePath(root, target)
                runtimeResolveMs = tooling_nowMs() - runtimeResolveStartMs
                if tooling_runtimeObjHasFastExeSymbols(root, runtimeObj):
                    compileOpts.noRuntimeCText = "1"
                    compileOpts.runtimeObjPath = runtimeObj
                else:
                    compileOpts.noRuntimeCText = "0"
    elif libraryEmit:
        compileOpts.noRuntimeCText = "1"
    else:
        compileOpts.noRuntimeCText = "0"
    tooling_compileCollectEnvOverrides(root, stage0Exec, compileOpts, envOverrides)
    var stage0Args: str[] = []
    add(stage0Args, "--input:" + inPath)
    add(stage0Args, "--output:" + backendOutPath)
    add(stage0Args, "--target:" + target)
    add(stage0Args, "--linker:" + linker)
    commandBuildMs = tooling_nowMs() - commandBuildStartMs
    var timeoutSec: int32 = tooling_clampCompileTimeoutSec(
        tooling_parseInt32Default(os.getEnvDefault("TOOLING_COMPILE_TIMEOUT", ""), 60))
    let compileExecStartMs: int64 = tooling_nowMs()
    let directCapturePreferred: bool =
        tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_DIRECT_CAPTURE", "0"))
    let directExecAllowed: bool =
        !releaseBuild &&
        !libraryEmit &&
        !devStrict &&
        tooling_strEq(linker, "self") &&
        !tooling_stage0LockContextEnabled("compile_exe") &&
        !tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_FORCE_SHELL", "0")) &&
        !tooling_isTrue(os.getEnvDefault("TOOLING_TIMEOUT_DIAG", "0"))
    let runCmd: str = tooling_compileExecCmd(
        root, directExecAllowed, stage0Exec, envOverrides, inPath, backendOutPath,
        target, linker, timeoutSec)
    var res: os.ExecCmdResult
    if directExecAllowed:
        if directCapturePreferred:
            res = hostos.execFileCapture(stage0Exec, stage0Args, envOverrides, root, true, timeoutSec)
        else:
            let directRc: int32 = hostos.execFileStatus(stage0Exec, stage0Args, envOverrides, root, timeoutSec)
            if directRc == 0:
                res = os.ExecCmdResult(output: "", exitCode: 0)
            elif directRc == 124:
                res = os.ExecCmdResult(output: "", exitCode: directRc)
            else:
                res = hostos.execFileCapture(stage0Exec, stage0Args, envOverrides, root, true, timeoutSec)
    else:
        res = tooling_exec(root, runCmd)
    compileExecMs = tooling_nowMs() - compileExecStartMs
    let compileOutput: str = os.execCmdResultOutput(res)
    let rc: int32 = os.execCmdResultExitCode(res)
    if rc != 0 && tooling_isCompileCrashExitCode(rc):
        let reportPath: str = tooling_writeCompileCrashReport(
            root,
            "compile_exe",
            rc,
            1,
            1,
            runCmd,
            compileOutput
        )
        if tooling_strNonEmpty(reportPath):
            tooling_printErr("cheng_tooling: compile crash report: " + reportPath)
    if rc != 0:
        if tooling_strNonEmpty(compileOutput):
            let _logWriteOk: bool = tooling_writeTextFileViaShell(root, compileLog, compileOutput)
            if !_logWriteOk:
                os.writeFile(compileLog, compileOutput)
        tooling_printErr("cheng_tooling: compile failed rc=" + intToStr(rc) +
                         " kind=" + tooling_exitKind(rc) + " stage0=" + stage0 +
                         "; log=" + compileLog)
        if tooling_strNonEmpty(tooling_exitHint(rc)):
            tooling_printErr("cheng_tooling: compile hint=" + tooling_exitHint(rc))
        if rc == 124:
            tooling_printErr("compile timeout reached " + intToStr(timeoutSec) + "s")
        if tooling_fileExistsNonEmpty(compileLog):
            tooling_printCommandLogTail(root, compileLog, "compile_exe", 260)
        if exeEmit:
            tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj,
                                             atomicExePublish || directExeOutput)
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return rc
    if !tooling_fileExistsNonEmpty(backendOutPath):
        if exeEmit:
            tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj,
                                             atomicExePublish || directExeOutput)
        tooling_stage0MarkBlocked(root, stage0Exec, rc, "compile_exe_missing_output", "missing_output")
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: compile returned success but produced no output: " + backendOutPath)
        tooling_printErr("cheng_tooling: stage0 quarantined to prevent repeated false-success compiles: " + stage0)
        return 1
    if libraryEmit:
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        let linkRc: int32 = tooling_linkReleaseLibrary(
            root, emitMode, target, outPath, backendOutPath, compileOpts.ldflagsRaw)
        if os.fileExists(backendOutPath):
            os.removeFile(backendOutPath)
        if os.fileExists(backendOutTmpLinkObj):
            os.removeFile(backendOutTmpLinkObj)
        if os.fileExists(backendOutObj):
            os.removeFile(backendOutObj)
        if linkRc != 0:
            return linkRc
        if tooling_compilePrintOutEnabled():
            tooling_printOut("compile_out=" + outPath)
        if tooling_compileSuccessMetaVerboseEnabled():
            tooling_printOut("compile_driver=" + stage0)
            tooling_printOut("compile_driver_track=canonical")
            tooling_printOut("compile_target=" + target)
            tooling_printOut("compile_linker=" + linker)
            tooling_printOut("compile_track=" + compileOpts.buildTrack)
            tooling_printOut("compile_dev_mode=" + devMode)
            tooling_printOut("compile_emit=" + emitMode)
            tooling_printOut("compile_profile=" + tooling_compileProfileLib(emitMode))
            tooling_printOut("compile_run_mode=none")
        return 0
    if tooling_strEq(emitMode, "exe"):
        let publishStartMs: int64 = tooling_nowMs()
        let chmodRes: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(backendOutPath))
        tooling_printExecOutput(chmodRes)
        if os.execCmdResultExitCode(chmodRes) != 0:
            tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj,
                                             atomicExePublish || directExeOutput)
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            tooling_printErr("cheng_tooling: chmod failed: " + backendOutPath)
            return 1
        if atomicExePublish && !tooling_strEq(backendOutPath, outPath):
            if !tooling_publishExecutableAtomicInPlace(root, backendOutPath, outPath):
                tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj, true)
                tooling_cleanupStage0Exec(stage0, stage0Exec)
                tooling_printErr("cheng_tooling: compile publish failed: " + outPath)
                return 1
        publishMs = tooling_nowMs() - publishStartMs
        tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj, false)
        if atomicExePublish && os.fileExists(backendOutPath):
            os.removeFile(backendOutPath)
    tooling_cleanupStage0Exec(stage0, stage0Exec)
    if tooling_compilePrintOutEnabled():
        tooling_printOut("compile_out=" + outPath)
    if tooling_compileSuccessMetaVerboseEnabled():
        tooling_printOut("compile_driver=" + stage0)
        tooling_printOut("compile_driver_track=canonical")
        tooling_printOut("compile_target=" + target)
        tooling_printOut("compile_linker=" + linker)
        tooling_printOut("compile_track=" + compileOpts.buildTrack)
        tooling_printOut("compile_dev_mode=" + devMode)
        tooling_printOut("compile_emit=" + emitMode)
        tooling_printOut("compile_profile=" + tooling_compileProfile(releaseBuild, linker, devStrict))
        tooling_printOut("compile_run_mode=" + tooling_compileRunModeText(runMode))
    tooling_printCompilePhaseTiming("stage0_resolve", stage0ResolveMs)
    tooling_printCompilePhaseTiming("stage0_prepare", stage0PrepareMs)
    tooling_printCompilePhaseTiming("stage0_preflight", stage0PreflightMs)
    tooling_printCompilePhaseTiming("runtime_obj", runtimeResolveMs)
    tooling_printCompilePhaseTiming("command_build", commandBuildMs)
    tooling_printCompilePhaseTiming("compile_exec", compileExecMs)
    tooling_printCompilePhaseTiming("publish", publishMs)
    tooling_printCompilePhaseTiming("total", tooling_nowMs() - compileStartMs)
    if runAfter:
        let runCmd: str = tooling_compileRunAfterCmd(root, outPath, runMode)
        if tooling_strEq(runMode, "host") && !tooling_strNonEmpty(runCmd):
            tooling_printErr("cheng_tooling: cannot resolve tooling executable for host runner reentry")
            if runEphemeralOut && os.fileExists(outPath):
                os.removeFile(outPath)
            return 1
        let runRes: os.ExecCmdResult = tooling_exec(root, runCmd)
        tooling_printExecOutput(runRes)
        let runRc: int32 = os.execCmdResultExitCode(runRes)
        if runEphemeralOut:
            if os.fileExists(outPath):
                os.removeFile(outPath)
            let tmpLinkObj: str = tooling_compileTmpLinkObjPath(outPath)
            if os.fileExists(tmpLinkObj):
                os.removeFile(tmpLinkObj)
        return runRc
    return 0

fn tooling_cmdCompileFromArgsMode(root: str, firstArgIndex: int32, count: int32,
                                  commandIdRaw: str, forceRelease: bool): int32 =
    let commandId: str = strutil.toLowerAscii(strutil.strip(commandIdRaw))
    var args: ToolingCompileArgsState = nil
    new(args)
    args.inPath = tooling_textLiteral("")
    args.outPath = tooling_textLiteral("")
    args.outName = tooling_textLiteral("")
    args.target = tooling_textLiteral("")
    args.wholeProgramRaw = tooling_textLiteral("")
    args.optRaw = tooling_textLiteral("")
    args.opt2Raw = tooling_textLiteral("")
    args.optLevelRaw = tooling_textLiteral("")
    args.noRuntimeCRaw = tooling_textLiteral("")
    args.runtimeObjRaw = tooling_textLiteral("")
    args.sidecarModeRaw = tooling_textLiteral("")
    args.sidecarBundleRaw = tooling_textLiteral("")
    args.sidecarCompilerRaw = tooling_textLiteral("")
    args.sidecarChildModeRaw = tooling_textLiteral("")
    args.sidecarOuterCompilerRaw = tooling_textLiteral("")
    args.genericModeRaw = tooling_textLiteral("")
    args.genericSpecBudgetRaw = tooling_textLiteral("")
    args.genericLoweringRaw = tooling_textLiteral("")
    args.jobsRaw = tooling_textLiteral("")
    args.fnJobsRaw = tooling_textLiteral("")
    args.multiRaw = tooling_textLiteral("")
    args.incrementalRaw = tooling_textLiteral("")
    let linkerEnvRaw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_LINKER", "")))
    let expectedLinker: str = tooling_compileLinkerMode(forceRelease)
    if tooling_strNonEmpty(linkerEnvRaw) && !tooling_strEq(linkerEnvRaw, "auto"):
        tooling_printErr("cheng_tooling: " + commandId + " does not accept BACKEND_LINKER (fixed: " + expectedLinker + "); unset BACKEND_LINKER")
        return 2
    let buildTrackEnvRaw: str = os.getEnvDefault("BACKEND_BUILD_TRACK", "dev")
    let trackPolicyRc: int32 = tooling_enforceBuildTrackPolicy(commandId, buildTrackEnvRaw)
    if trackPolicyRc != 0:
        return trackPolicyRc
    args.releaseBuild = forceRelease
    args.devMode = tooling_textLiteral("fast")
    args.emitMode = tooling_textLiteral("exe")
    args.runAfter = false
    args.runMode = tooling_textLiteral("")
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            if forceRelease:
                tooling_printReleaseCompileUsage()
            else:
                tooling_printCompileUsage()
            return 0
        if strutil.startsWith(arg, "--in:"):
            args.inPath = strings.dropPrefix(arg, "--in:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--out:"):
            args.outPath = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--name:"):
            args.outName = strings.dropPrefix(arg, "--name:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--target:"):
            args.target = strings.dropPrefix(arg, "--target:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--stage0:"):
            tooling_printErr("cheng_tooling: --stage0 has been removed; canonical driver is mandatory")
            return 2
        if strutil.startsWith(arg, "--linker:"):
            if forceRelease:
                tooling_printErr("cheng_tooling: release-compile no longer accepts --linker (fixed: system-link)")
            else:
                tooling_printErr("cheng_tooling: " + commandId + " no longer accepts --linker (fixed: self-link)")
            return 2
        if tooling_strEq(arg, "--release"):
            if forceRelease:
                i = i + 1
                continue
            tooling_printErr("cheng_tooling: " + commandId + " no longer accepts --release; use `release-compile`")
            return 2
        if tooling_strEq(arg, "--dev"):
            if forceRelease:
                tooling_printErr("cheng_tooling: release-compile does not accept --dev")
                return 2
            args.devMode = tooling_textLiteral("fast")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--dev:"):
            if forceRelease:
                tooling_printErr("cheng_tooling: release-compile does not accept --dev:*")
                return 2
            let modeRaw: str = strings.dropPrefix(arg, "--dev:")
            let modeNorm: str = tooling_compileDevModeParsed(modeRaw)
            if !tooling_strNonEmpty(modeNorm):
                tooling_printErr("cheng_tooling: invalid --dev mode (expected fast|strict): " + modeRaw)
                return 2
            args.devMode = modeNorm
            i = i + 1
            continue
        if tooling_strEq(arg, "--run"):
            args.runAfter = true
            if !tooling_strNonEmpty(args.runMode):
                args.runMode = tooling_textLiteral("host")
            i = i + 1
            continue
        if tooling_strEq(arg, "--run:host"):
            args.runAfter = true
            args.runMode = tooling_textLiteral("host")
            i = i + 1
            continue
        if tooling_strEq(arg, "--run:file"):
            args.runAfter = true
            args.runMode = tooling_textLiteral("file")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--emit:"):
            let emit: str = strutil.toLowerAscii(strutil.strip(strings.dropPrefix(arg, "--emit:")))
            if tooling_strEq(emit, "shared") || tooling_strEq(emit, "static"):
                if !forceRelease:
                    tooling_printErr("cheng_tooling: `cheng` only supports --emit:exe (library emit is release-compile only)")
                    return 2
            elif !tooling_strEq(emit, "exe"):
                if forceRelease:
                    tooling_printErr("cheng_tooling: release-compile supports --emit:exe|shared|static")
                else:
                    tooling_printErr("cheng_tooling: compile only supports --emit:exe")
                return 2
            args.emitMode = emit
            i = i + 1
            continue
        if strutil.startsWith(arg, "--frontend:"):
            let frontend: str = strings.dropPrefix(arg, "--frontend:")
            if !tooling_strEq(frontend, "stage1"):
                tooling_printErr("cheng_tooling: compile only supports --frontend:stage1")
                return 1
            i = i + 1
            continue
        if tooling_strEq(arg, "--whole-program"):
            args.wholeProgramRaw = "1"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--whole-program:"):
            args.wholeProgramRaw = strings.dropPrefix(arg, "--whole-program:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--opt"):
            args.optRaw = "1"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--opt:"):
            args.optRaw = strings.dropPrefix(arg, "--opt:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--opt2"):
            args.opt2Raw = "1"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--opt2:"):
            args.opt2Raw = strings.dropPrefix(arg, "--opt2:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--opt-level:"):
            args.optLevelRaw = strings.dropPrefix(arg, "--opt-level:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-runtime-c"):
            args.noRuntimeCRaw = "1"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--no-runtime-c:"):
            args.noRuntimeCRaw = strings.dropPrefix(arg, "--no-runtime-c:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--runtime-obj:"):
            args.runtimeObjRaw = strings.dropPrefix(arg, "--runtime-obj:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--sidecar-mode:"):
            args.sidecarModeRaw = strings.dropPrefix(arg, "--sidecar-mode:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--sidecar-bundle:"):
            args.sidecarBundleRaw = strings.dropPrefix(arg, "--sidecar-bundle:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--sidecar-compiler:"):
            args.sidecarCompilerRaw = strings.dropPrefix(arg, "--sidecar-compiler:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--sidecar-child-mode:"):
            args.sidecarChildModeRaw = strings.dropPrefix(arg, "--sidecar-child-mode:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--sidecar-outer-compiler:"):
            args.sidecarOuterCompilerRaw = strings.dropPrefix(arg, "--sidecar-outer-compiler:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--generic-mode:"):
            args.genericModeRaw = strings.dropPrefix(arg, "--generic-mode:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--generic-spec-budget:"):
            args.genericSpecBudgetRaw = strings.dropPrefix(arg, "--generic-spec-budget:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--generic-lowering:"):
            args.genericLoweringRaw = strings.dropPrefix(arg, "--generic-lowering:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--jobs:"):
            args.jobsRaw = strings.dropPrefix(arg, "--jobs:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--fn-jobs:"):
            args.fnJobsRaw = strings.dropPrefix(arg, "--fn-jobs:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--multi"):
            args.multiRaw = "1"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--multi:"):
            args.multiRaw = strings.dropPrefix(arg, "--multi:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--incremental:"):
            args.incrementalRaw = strings.dropPrefix(arg, "--incremental:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--orc") || strutil.startsWith(arg, "--mm:"):
            i = i + 1
            continue
        if strutil.startsWith(arg, "--manifest:") || strutil.startsWith(arg, "--lock:") ||
           strutil.startsWith(arg, "--registry:") || strutil.startsWith(arg, "--package:") ||
           strutil.startsWith(arg, "--channel:") || strutil.startsWith(arg, "--lock-format:") ||
           strutil.startsWith(arg, "--meta-out:") || strutil.startsWith(arg, "--buildmeta:") ||
           strutil.startsWith(arg, "--pkg-cache:") || strutil.startsWith(arg, "--ledger:") ||
           strutil.startsWith(arg, "--source-listen:") || strutil.startsWith(arg, "--source-peer:") ||
           strutil.startsWith(arg, "--pkg-roots:") || tooling_strEq(arg, "--skip-pkg") ||
           tooling_strEq(arg, "--verify"):
            i = i + 1
            continue
        if strutil.startsWith(arg, "-"):
            tooling_printErr("cheng_tooling: unknown compile arg: " + arg)
            return 1
        if !tooling_strNonEmpty(args.inPath):
            args.inPath = arg
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unexpected positional arg: " + arg)
        return 1
    if !tooling_strNonEmpty(args.inPath):
        tooling_printErr("cheng_tooling: " + commandId + " requires input file (use --in:<file.cheng>)")
        if forceRelease:
            tooling_printReleaseCompileUsage()
        else:
            tooling_printCompileUsage()
        return 1
    if forceRelease:
        args.releaseBuild = true
    else:
        args.releaseBuild = false
    if args.runAfter && tooling_emitModeIsLibrary(args.emitMode):
        tooling_printErr("cheng_tooling: --emit:shared/static does not support --run/--run:*")
        return 2
    return tooling_cmdCompileExe(
        root, args.inPath, args.outPath, args.outName, args.target,
        args.releaseBuild, args.devMode, args.emitMode,
        args.wholeProgramRaw, args.optRaw, args.opt2Raw, args.optLevelRaw,
        args.noRuntimeCRaw, args.runtimeObjRaw,
        args.sidecarModeRaw, args.sidecarBundleRaw, args.sidecarCompilerRaw,
        args.sidecarChildModeRaw, args.sidecarOuterCompilerRaw,
        args.genericModeRaw, args.genericSpecBudgetRaw, args.genericLoweringRaw,
        args.jobsRaw, args.fnJobsRaw, args.multiRaw, args.incrementalRaw,
        args.runAfter, args.runMode)

fn tooling_cmdCompileFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    return tooling_cmdCompileFromArgsMode(root, firstArgIndex, count, "cheng", false)

fn tooling_cmdCompileFromArgsNamed(root: str, firstArgIndex: int32, count: int32,
                                   commandIdRaw: str): int32 =
    let commandId: str = strutil.toLowerAscii(strutil.strip(commandIdRaw))
    if tooling_strEq(commandId, "compile") || tooling_strEq(commandId, "chengc"):
        tooling_printErr("cheng_tooling: `" + commandId + "` has been removed; use `cheng`")
        return 2
    return tooling_cmdCompileFromArgsMode(root, firstArgIndex, count, commandId, false)

fn tooling_cmdReleaseCompileFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    return tooling_cmdCompileFromArgsMode(root, firstArgIndex, count, "release-compile", true)

fn tooling_printBootstrapPureUsage() =
    tooling_printLines(tselfboot.toolingBootstrapPureUsageLines())

fn tooling_cmdBootstrapPureFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingBootstrapPureArgs =
        tselfboot.toolingBootstrapPureParseArgs(tooling_argsRange(firstArgIndex, count))
    if tselfboot.toolingBootstrapPureArgsHelpRequested(parsed):
        tooling_printBootstrapPureUsage()
        return 0
    if !tselfboot.toolingBootstrapPureArgsOk(parsed):
        tooling_printErr(tselfboot.toolingBootstrapPureArgsError(parsed))
        return tselfboot.toolingBootstrapPureArgsExitCode(parsed)
    let mode: str = tselfboot.toolingBootstrapPureArgsMode(parsed)
    var compileStage1: bool = tselfboot.toolingBootstrapPureArgsCompileStage1(parsed)
    let outDir: str = tselfboot.toolingBootstrapPureArgsOutDir(parsed)
    let timingOut: str = tselfboot.toolingBootstrapPureArgsTimingOut(parsed)
    let fullspec: bool = tselfboot.toolingBootstrapPureArgsFullspec(parsed)
    if !tooling_strNonEmpty(mode):
        tooling_printErr("cheng_tooling: invalid bootstrap-pure mode")
        return 1
    var res: ToolingSelfhostResult
    let allowBootstrapCapabilityRefresh: bool = tooling_isTrue(
        os.getEnvDefault("BOOTSTRAP_UPDATE_SEED", "0"))
    if tooling_strEq(mode, "strict"):
        compileStage1 = true
        res = tooling_selfhostBootstrapStrictHost(root, outDir, timingOut,
                                                  allowBootstrapCapabilityRefresh)
    else:
        res = tooling_selfhostBootstrapFastHost(root, compileStage1, outDir, timingOut,
                                                allowBootstrapCapabilityRefresh)
    if !res.ok:
        tooling_printErr("cheng_tooling: bootstrap-pure failed: " + tooling_messageOrUnknown(res.message))
        if tooling_strEq(mode, "strict"):
            if tooling_strNonEmpty(res.stage2Sha256):
                tooling_printErr("cheng_tooling: bootstrap-pure strict stage2_sha256=" + res.stage2Sha256)
            if tooling_strNonEmpty(res.stage3Sha256):
                tooling_printErr("cheng_tooling: bootstrap-pure strict stage3_sha256=" + res.stage3Sha256)
            if tooling_strNonEmpty(res.strictMismatchReport):
                tooling_printErr("cheng_tooling: bootstrap-pure strict mismatch_report=" + res.strictMismatchReport)
        return 1
    tooling_printOut("bootstrap_pure_mode=" + mode)
    tooling_printOut("bootstrap_pure_stage1=" + res.stage1Path)
    tooling_printOut("bootstrap_pure_stage2=" + res.stage2Path)
    tooling_printOut("bootstrap_pure_stage1_status=" + res.stage1Status)
    tooling_printOut("bootstrap_pure_stage1_compile_mode=" + res.stage1CompileMode)
    tooling_printOut("bootstrap_pure_stage1_rebuild_ok=" + tooling_boolText(res.stage1RebuildOk))
    if tooling_strEq(mode, "strict"):
        tooling_printOut("bootstrap_pure_stage3=" + res.stage3Path)
        tooling_printOut("bootstrap_pure_stage2_sha256=" + res.stage2Sha256)
        tooling_printOut("bootstrap_pure_stage3_sha256=" + res.stage3Sha256)
        tooling_printOut("bootstrap_pure_fixed_point_ok=" + tooling_boolText(res.fixedPointOk))
        tooling_printOut("bootstrap_pure_strict_mismatch_report=" + res.strictMismatchReport)
    tooling_printOut("bootstrap_pure_total_ms=" + intToStr(int32(res.totalMs)))
    if fullspec:
        let fullspecScriptPath: str = tinv.toolingResolveScriptPath(root, "verify_fullchain_bootstrap")
        if !tooling_strNonEmpty(fullspecScriptPath):
            tooling_printErr("cheng_tooling: bootstrap-pure --fullspec missing verify_fullchain_bootstrap entry")
            return 1
        tooling_printOut("bootstrap_pure_fullspec=1")
        let fullspecRc: int32 = tooling_runScript(root, fullspecScriptPath, count + 1)
        if fullspecRc != 0:
            tooling_printErr("cheng_tooling: bootstrap-pure --fullspec failed rc=" + intToStr(fullspecRc))
            return fullspecRc
        tooling_printOut("bootstrap_pure_fullspec_ok=1")
    if tooling_isTrue(os.getEnvDefault("BOOTSTRAP_UPDATE_SEED", "0")):
        let seedOut: str = tooling_pathAbsolute(root, "artifacts/backend_seed/cheng.stage2")
        if !tooling_copyExecutable(root, res.stage2Path, seedOut):
            tooling_printErr("cheng_tooling: bootstrap-pure seed update failed: " + seedOut)
            return 1
        tooling_printOut("bootstrap_pure_seed_updated=" + seedOut)
    return 0

fn tooling_cmdDriverPathFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var pathOnly: bool = false
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("driver-path options:")
            tooling_printOut("  --path-only                  print only canonical driver path")
            return 0
        if tooling_strEq(arg, "--path-only"):
            pathOnly = true
            i = i + 1
            continue
        if strutil.startsWith(arg, "--stage0:"):
            tooling_printErr("cheng_tooling: --stage0 has been removed; canonical driver is mandatory")
            return 2
        tooling_printErr("cheng_tooling: unknown driver-path arg: " + arg)
        return 1
    return tooling_cmdDriverPath(root, pathOnly)

fn tooling_cmdBuildBackendDriverFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var args: ToolingBuildDriverArgsState = nil
    new(args)
    args.outPath = os.getEnvDefault("BACKEND_LOCAL_DRIVER_REL", "artifacts/backend_driver/cheng")
    args.stage0 = tooling_textLiteral("")
    args.target = tooling_textLiteral("")
    args.requireRebuild = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_REQUIRE_REBUILD", "0"))
    args.debugRebuild = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_DEBUG_REBUILD", "0"))
    args.modeRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_MODE", "")
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build-backend-driver options:")
            tooling_printOut("  --out:<path>                 output path")
            tooling_printOut("  --name:<path>                legacy alias of --out")
            tooling_printOut("  --target:<triple>            explicit backend target")
            tooling_printOut("  --fast                       dev-fast rebuild (quick/system-link by default)")
            tooling_printOut("  --seal                       strict seal rebuild (full/system-link by default)")
            tooling_printOut("  --mode:auto|fast|seal       explicit build mode")
            tooling_printOut("  --source:<path>              explicit backend driver source")
            tooling_printOut("  --jobs:<N>                   explicit compile jobs for selected mode")
            tooling_printOut("  --parse:outline|full         explicit parse mode for selected mode")
            tooling_printOut("  --incremental:0|1            explicit incremental mode for selected mode")
            tooling_printOut("  --multi:0|1                  explicit function-parallel mode for selected mode")
            tooling_printOut("  --multi-force:0|1            explicit multi_force for selected mode")
            tooling_printOut("  --generic-mode:dict          explicit generic mode for selected mode")
            tooling_printOut("  --generic-spec-budget:<N>    explicit generic specialization budget")
            tooling_printOut("  --generic-lowering:mir_dict  explicit generic lowering for selected mode")
            tooling_printOut("  --disable-dup-scan:0|1       explicit duplicate-scan mode for selected mode")
            tooling_printOut("  --skip-fixups:0|1            explicit UIR fixups mode for selected mode")
            tooling_printOut("  --skip-normalize:0|1         explicit UIR normalize mode for selected mode")
            tooling_printOut("  --require-rebuild            fail if stage0 reuse happens")
            tooling_printOut("  --require-rebuild:0|1        explicit require-rebuild toggle")
            tooling_printOut("  --debug-rebuild              keep attempt artifacts and skip canonical install")
            tooling_printOut("  --debug-rebuild:0|1          explicit debug-rebuild toggle")
            tooling_printOut("  --full-rebuild[[:0|1]]       alias of --seal / --mode:seal")
            tooling_printOut("  compat env: BACKEND_BUILD_DRIVER_SOURCE / *_JOBS / *_PARSE_MODE / *_INCREMENTAL / *_MULTI / *_GENERIC_*")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_AUTO_CLEAN_HISTORY=1|0 (default 1)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_MODE=auto|fast|seal (default auto; fast unless require-rebuild/debug)")
            tooling_printOut("       BUILD_DRIVER_STRICT_NATIVE=1|0 (default 1; seal path)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_FAST_STRICT_NATIVE=1|0 (default 1; fast path, set 0 for experimental self-link)")
            tooling_printOut("  env: BUILD_DRIVER_ALLOW_FALLBACK (removed; fallback path hard-disabled)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_REBUILD_CRASH_RETRY_SAFE=1|0 (default 0)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_CRASH_RETRY_MAX=0..2 (default 1 when retry enabled)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_REBUILD_TIMEOUT=60 (full-only, hard cap)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_SKIP_GLOBAL_INIT=1|0 (fixed required: 0)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_REQUIRE_REBUILD=1|0 (default 0)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_EAGER_REBUILD=1|0 (default 0; only effective when require-rebuild=0 and strict-native=0)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_FAST_REUSE=1|0 (default 1; allow direct reuse only when final output stamp matches current source/capability)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_FAST_CANONICAL_SMOKE=1|0 (default 1; require dev/release smoke + proof sidecar before fast canonical install/reuse)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=1|0 (default 1)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=1|0 (default 1; share quick cache across different --out paths)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_QUICK_STAMP_HIT_FAST_SANITY=1|0 (default 1)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_QUICK_LIGHT_SANITY=1|0 (default 1)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_PROFILE_MODE=backend|safe|stage1_uir|full (default backend)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_PROFILE_FAIL_OPEN=1|0 (default 0; auto-disable profile flags on segfault)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_STAMP_CACHE=1|0 (default 1; full-only)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_STAMP_IGNORE_STAGE0_SHA=1|0 (tight profile default 1)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_CRASH_TRACE=1|0 (default 1; write stage1 trace log on rc=138/139)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_CRASH_TRACE_TIMEOUT=<sec> (default 25)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_DEBUG_REBUILD=1|0 (default 0; diagnostic mode)")
            tooling_printOut("       TOOLING_STAGE0_ALLOW_MAIN_ONLY=1|0 (default 0; reject main-only stage0 binaries)")
            tooling_printOut("  env: TOOLING_STAGE0_HARD_BLOCK_ON_UE=1|0 (default 1)")
            tooling_printOut("       TOOLING_STAGE0_GENERATION_GUARD=1|0 (default 1; ignore UE older than current driver generation)")
            tooling_printOut("       TOOLING_STAGE0_INODE_GUARD=1|0 (default 1; ignore UE mapped to an older driver inode)")
            tooling_printOut("       TOOLING_STAGE0_GENERATION_MARGIN_SEC=<sec> (default 3)")
            tooling_printOut("       TOOLING_STAGE0_BLOCK_SHA256=<sha[,sha...]> (hard-block known bad driver digests)")
            tooling_printOut("       SELFHOST_STAGE1_STAMP_HIT_FAST_SANITY=1|0 (default 1; selfhost compile-stage1 only)")
            return 0
        if strutil.startsWith(arg, "--out:"):
            args.outPath = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--name:"):
            args.outPath = strings.dropPrefix(arg, "--name:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--stage0:"):
            tooling_printErr("cheng_tooling: build-backend-driver no longer accepts --stage0; strict stage0 selection is mandatory")
            return 2
        if strutil.startsWith(arg, "--target:"):
            args.target = strings.dropPrefix(arg, "--target:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--source:"):
            args.sourcePath = strings.dropPrefix(arg, "--source:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--jobs:"):
            args.jobsRaw = strings.dropPrefix(arg, "--jobs:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--parse:"):
            args.parseModeRaw = strings.dropPrefix(arg, "--parse:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--incremental:"):
            args.incrementalRaw = strings.dropPrefix(arg, "--incremental:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--multi:"):
            args.multiRaw = strings.dropPrefix(arg, "--multi:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--multi-force:"):
            args.multiForceRaw = strings.dropPrefix(arg, "--multi-force:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--generic-mode:"):
            args.genericModeRaw = strings.dropPrefix(arg, "--generic-mode:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--generic-spec-budget:"):
            args.genericSpecBudgetRaw = strings.dropPrefix(arg, "--generic-spec-budget:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--generic-lowering:"):
            args.genericLoweringRaw = strings.dropPrefix(arg, "--generic-lowering:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--disable-dup-scan:"):
            args.disableDupScanRaw = strings.dropPrefix(arg, "--disable-dup-scan:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--skip-fixups:"):
            args.skipFixupsRaw = strings.dropPrefix(arg, "--skip-fixups:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--skip-normalize:"):
            args.skipNormalizeRaw = strings.dropPrefix(arg, "--skip-normalize:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--fast"):
            args.modeRaw = tooling_textLiteral("fast")
            i = i + 1
            continue
        if tooling_strEq(arg, "--seal"):
            args.modeRaw = tooling_textLiteral("seal")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--mode:"):
            args.modeRaw = strings.dropPrefix(arg, "--mode:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--require-rebuild"):
            args.requireRebuild = true
            i = i + 1
            continue
        if strutil.startsWith(arg, "--require-rebuild:"):
            args.requireRebuild = tooling_isTrue(strings.dropPrefix(arg, "--require-rebuild:"))
            i = i + 1
            continue
        if tooling_strEq(arg, "--debug-rebuild"):
            args.debugRebuild = true
            i = i + 1
            continue
        if strutil.startsWith(arg, "--debug-rebuild:"):
            args.debugRebuild = tooling_isTrue(strings.dropPrefix(arg, "--debug-rebuild:"))
            i = i + 1
            continue
        if tooling_strEq(arg, "--full-rebuild"):
            args.modeRaw = tooling_textLiteral("seal")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--full-rebuild:"):
            if tooling_isTrue(strings.dropPrefix(arg, "--full-rebuild:")):
                args.modeRaw = tooling_textLiteral("seal")
            else:
                args.modeRaw = tooling_textLiteral("fast")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown build-backend-driver arg: " + arg)
        return 1
    return tooling_cmdBuildBackendDriverWithCompatArgs(root, args)

fn tooling_cmdSelfhostBootstrapFastHostFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingSelfhostBootstrapFastHostArgs =
        tselfboot.toolingSelfhostBootstrapFastHostParseArgs(tooling_argsRange(firstArgIndex, count))
    if tselfboot.toolingSelfhostBootstrapFastHostArgsHelpRequested(parsed):
        tooling_printLines(tselfboot.toolingSelfhostBootstrapFastHostUsageLines())
        return 0
    if !tselfboot.toolingSelfhostBootstrapFastHostArgsOk(parsed):
        tooling_printErr(tselfboot.toolingSelfhostBootstrapFastHostArgsError(parsed))
        return tselfboot.toolingSelfhostBootstrapFastHostArgsExitCode(parsed)
    return tooling_cmdSelfhostBootstrapFastHost(
        root,
        tselfboot.toolingSelfhostBootstrapFastHostArgsCompileStage1(parsed),
        tselfboot.toolingSelfhostBootstrapFastHostArgsOutDir(parsed),
        tselfboot.toolingSelfhostBootstrapFastHostArgsTimingOut(parsed))

fn tooling_cmdSelfhostStrictInmemWitnessFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingSelfhostStrictInmemWitnessArgs =
        tselfboot.toolingSelfhostStrictInmemWitnessParseArgs(tooling_argsRange(firstArgIndex, count))
    if tselfboot.toolingSelfhostStrictInmemWitnessArgsHelpRequested(parsed):
        tooling_printLines(tselfboot.toolingSelfhostStrictInmemWitnessUsageLines())
        return 0
    if !tselfboot.toolingSelfhostStrictInmemWitnessArgsOk(parsed):
        tooling_printErr(tselfboot.toolingSelfhostStrictInmemWitnessArgsError(parsed))
        return tselfboot.toolingSelfhostStrictInmemWitnessArgsExitCode(parsed)
    let res: ToolingSelfhostResult =
        tooling_selfhostStrictInmemWitnessHost(
            root,
            tselfboot.toolingSelfhostStrictInmemWitnessArgsOutDir(parsed),
            tselfboot.toolingSelfhostStrictInmemWitnessArgsTimingOut(parsed),
            false)
    if !res.ok:
        tooling_printErr("cheng_tooling: verify_backend_selfhost_bootstrap_inmem_witness failed: " +
                         tooling_messageOrUnknown(res.message))
        return 1
    tooling_printOut("selfhost_inmem_witness_mode=" + res.mode)
    tooling_printOut("selfhost_inmem_witness_stage0=" + res.stage0Path)
    tooling_printOut("selfhost_inmem_witness_stage0_driver_kind=" + res.stage0DriverKind)
    tooling_printOut("selfhost_inmem_witness_stage1=" + res.stage1Path)
    tooling_printOut("selfhost_inmem_witness_stage1_status=" + res.stage1Status)
    tooling_printOut("selfhost_inmem_witness_total_ms=" + intToStr(int32(res.totalMs)))
    return 0

fn tooling_cmdSelfhostInnerLoopFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingSelfhostInnerLoopArgs =
        tselfboot.toolingSelfhostInnerLoopParseArgs(tooling_argsRange(firstArgIndex, count))
    if tselfboot.toolingSelfhostInnerLoopArgsHelpRequested(parsed):
        tooling_printLines(tselfboot.toolingSelfhostInnerLoopUsageLines())
        return 0
    if !tselfboot.toolingSelfhostInnerLoopArgsOk(parsed):
        tooling_printErr(tselfboot.toolingSelfhostInnerLoopArgsError(parsed))
        return tselfboot.toolingSelfhostInnerLoopArgsExitCode(parsed)
    let res: ToolingSelfhostInnerLoopResult =
        tooling_selfhostInnerLoop(
            root,
            tselfboot.toolingSelfhostInnerLoopArgsOutDir(parsed),
            tselfboot.toolingSelfhostInnerLoopArgsTimingOut(parsed),
            tselfboot.toolingSelfhostInnerLoopArgsRunInmemWitness(parsed),
            tselfboot.toolingSelfhostInnerLoopArgsRunStrict(parsed),
            tselfboot.toolingSelfhostInnerLoopArgsRunClosure(parsed))
    let inmemRes: ToolingSelfhostResult = res.inmemRes
    let strictRes: ToolingSelfhostResult = res.strictRes
    tooling_printOut("selfhost_inner_loop_out_dir=" + res.outDir)
    tooling_printOut("selfhost_inner_loop_timing=" + res.timingPath)
    tooling_printOut("selfhost_inner_loop_summary=" + res.summaryPath)
    tooling_printOut("selfhost_inner_loop_build_driver=" + res.buildDriverPath)
    tooling_printOut("selfhost_inner_loop_build_driver_ms=" + intToStr(int32(res.buildMs)))
    tooling_printOut("selfhost_inner_loop_build_driver_rc=" + intToStr(res.buildRc))
    tooling_printOut("selfhost_inner_loop_inmem_requested=" + tooling_boolText(res.inmemRequested))
    if inmemRes != nil:
        tooling_printOut("selfhost_inner_loop_inmem_stage1=" + inmemRes.stage1Path)
        tooling_printOut("selfhost_inner_loop_inmem_total_ms=" + intToStr(int32(inmemRes.totalMs)))
    tooling_printOut("selfhost_inner_loop_strict_requested=" + tooling_boolText(res.strictRequested))
    if strictRes != nil:
        tooling_printOut("selfhost_inner_loop_strict_stage2=" + strictRes.stage2Path)
        tooling_printOut("selfhost_inner_loop_strict_stage3=" + strictRes.stage3Path)
        tooling_printOut("selfhost_inner_loop_strict_total_ms=" + intToStr(int32(strictRes.totalMs)))
        tooling_printOut("selfhost_inner_loop_strict_fixed_point_ok=" + tooling_boolText(strictRes.fixedPointOk))
    tooling_printOut("selfhost_inner_loop_closure_requested=" + tooling_boolText(res.closureRequested))
    tooling_printOut("selfhost_inner_loop_closure_rc=" + intToStr(res.closureRc))
    tooling_printOut("selfhost_inner_loop_total_ms=" + intToStr(int32(res.totalMs)))
    if !res.ok:
        tooling_printOut("selfhost_inner_loop_ok=0")
        tooling_printOut("selfhost_inner_loop_failed_step=" + res.failedStep)
    else:
        tooling_printOut("selfhost_inner_loop_ok=1")
    if !res.ok:
        tooling_printErr("cheng_tooling: verify_backend_selfhost_inner_loop failed step=" + res.failedStep +
                         " message=" + tooling_summaryOneLine(tooling_messageOrUnknown(res.message)))
        return 1
    return 0

fn tooling_cmdSelfhostBootstrapVerifyFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingSelfhostBootstrapVerifyArgs =
        tselfboot.toolingSelfhostBootstrapVerifyParseArgs(tooling_argsRange(firstArgIndex, count))
    if tselfboot.toolingSelfhostBootstrapVerifyArgsHelpRequested(parsed):
        tooling_printLines(tselfboot.toolingSelfhostBootstrapVerifyUsageLines())
        return 0
    if !tselfboot.toolingSelfhostBootstrapVerifyArgsOk(parsed):
        tooling_printErr(tselfboot.toolingSelfhostBootstrapVerifyArgsError(parsed))
        return tselfboot.toolingSelfhostBootstrapVerifyArgsExitCode(parsed)
    let mode: str = tselfboot.toolingSelfhostBootstrapVerifyArgsMode(parsed)
    var compileStage1: bool = tselfboot.toolingSelfhostBootstrapVerifyArgsCompileStage1(parsed)
    let outDir: str = tselfboot.toolingSelfhostBootstrapVerifyArgsOutDir(parsed)
    let timingOut: str = tselfboot.toolingSelfhostBootstrapVerifyArgsTimingOut(parsed)
    let strictInmemWitness: bool =
        tselfboot.toolingSelfhostBootstrapVerifyArgsStrictInmemWitness(parsed)
    if !tooling_strNonEmpty(mode):
        tooling_printErr("cheng_tooling: invalid verify_backend_selfhost_bootstrap_self_obj mode")
        return 1
    var res: ToolingSelfhostResult
    if tooling_strEq(mode, "strict"):
        compileStage1 = true
        if strictInmemWitness:
            let witnessRes: ToolingSelfhostResult =
                tooling_selfhostStrictInmemWitnessHost(root, outDir, timingOut, false)
            if !witnessRes.ok:
                tooling_printErr("cheng_tooling: strict inmem witness failed before strict host fixed-point: " +
                                 tooling_messageOrUnknown(witnessRes.message))
                return 1
            tooling_printOut("selfhost_strict_inmem_witness_ok=1")
            tooling_printOut("selfhost_strict_inmem_witness_stage1=" + witnessRes.stage1Path)
            tooling_printOut("selfhost_strict_inmem_witness_total_ms=" + intToStr(int32(witnessRes.totalMs)))
        res = tooling_selfhostBootstrapStrictHost(root, outDir, timingOut, false)
    else:
        res = tooling_selfhostBootstrapFastHost(root, compileStage1, outDir, timingOut, false)
    if !res.ok:
        tooling_printErr("cheng_tooling: verify_backend_selfhost_bootstrap_self_obj failed: " +
                         tooling_messageOrUnknown(res.message))
        if tooling_strEq(mode, "strict"):
            if tooling_strNonEmpty(res.stage2Sha256):
                tooling_printErr("cheng_tooling: stage2_sha256=" + res.stage2Sha256)
            if tooling_strNonEmpty(res.stage3Sha256):
                tooling_printErr("cheng_tooling: stage3_sha256=" + res.stage3Sha256)
            if tooling_strNonEmpty(res.strictMismatchReport):
                tooling_printErr("cheng_tooling: strict_mismatch_report=" + res.strictMismatchReport)
        return 1
    tooling_printOut("selfhost_bootstrap_mode=" + mode)
    tooling_printOut("selfhost_bootstrap_stage1=" + res.stage1Path)
    tooling_printOut("selfhost_bootstrap_stage2=" + res.stage2Path)
    tooling_printOut("selfhost_bootstrap_stage0=" + res.stage0Path)
    tooling_printOut("selfhost_bootstrap_stage0_driver_kind=" + res.stage0DriverKind)
    tooling_printOut("selfhost_bootstrap_stage1_status=" + res.stage1Status)
    tooling_printOut("selfhost_bootstrap_stage1_compile_mode=" + res.stage1CompileMode)
    tooling_printOut("selfhost_bootstrap_stage1_rebuild_ok=" + tooling_boolText(res.stage1RebuildOk))
    tooling_printOut("selfhost_bootstrap_fallback_used=" + tooling_boolText(res.fallbackUsed))
    tooling_printOut("selfhost_bootstrap_quarantine_cleaned=" + intToStr(res.quarantineCleaned))
    tooling_printOut("selfhost_bootstrap_lock_wait_ms=" + intToStr(res.lockWaitMs))
    tooling_printOut("selfhost_bootstrap_strict_rebuild_ok=" + tooling_boolText(res.strictRebuildOk))
    if tooling_strEq(mode, "strict"):
        tooling_printOut("selfhost_bootstrap_stage3=" + res.stage3Path)
        tooling_printOut("selfhost_bootstrap_stage2_sha256=" + res.stage2Sha256)
        tooling_printOut("selfhost_bootstrap_stage3_sha256=" + res.stage3Sha256)
        tooling_printOut("selfhost_bootstrap_fixed_point_ok=" + tooling_boolText(res.fixedPointOk))
        tooling_printOut("selfhost_bootstrap_strict_mismatch_report=" + res.strictMismatchReport)
        tooling_printOut("stage2_sha256=" + res.stage2Sha256)
        tooling_printOut("stage3_sha256=" + res.stage3Sha256)
        tooling_printOut("fixed_point_ok=" + tooling_boolText(res.fixedPointOk))
    tooling_printOut("selfhost_bootstrap_total_ms=" + intToStr(int32(res.totalMs)))
    return 0

fn tooling_cmdSelfhost100msHostFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var hostOnly: str = os.getEnvDefault("SELFHOST_100MS_HOST_ONLY", "darwin_arm64")
    var itersRaw: str = os.getEnvDefault("SELFHOST_100MS_ITERS", "1")
    var p95Raw: str = os.getEnvDefault("SELFHOST_100MS_P95_MS", "100")
    var p99Raw: str = os.getEnvDefault("SELFHOST_100MS_P99_MS", "120")
    var enforceRaw: str = os.getEnvDefault("SELFHOST_100MS_ENFORCE_ON_HOST", "1")
    var reportRaw: str = os.getEnvDefault("SELFHOST_100MS_REPORT", "artifacts/backend_selfhost_100ms_host/report.tsv")
    var compileStage1: bool = tooling_isTrue(os.getEnvDefault("SELFHOST_NATIVE_COMPILE_STAGE1", "1"))
    var outDir: str = os.getEnvDefault("SELFHOST_100MS_OUT_DIR", "artifacts/backend_selfhost_100ms_host")
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("selfhost-100ms-host options:")
            tooling_printOut("  --iters:<N> --p95-ms:<ms> --p99-ms:<ms>")
            tooling_printOut("  --host-only:<tag> --report:<path> --enforce:0|1")
            tooling_printOut("  --compile-stage1|--no-compile-stage1 --out-dir:<path>")
            tooling_printOut("  env: SELFHOST_STAGE1_FULL_REBUILD=1|0 (strict default 1)")
            tooling_printOut("       SELFHOST_STRICT_REBUILD=1|0 (default 1)")
            tooling_printOut("       SELFHOST_100MS_REQUIRE_COMPILE_STAGE1=1|0 (default 1)")
            tooling_printOut("       SELFHOST_100MS_ENFORCE_WITH_COMPILE_STAGE1=1|0 (default 1)")
            tooling_printOut("       SELFHOST_100MS_PREWARM_STAGE1=1|0 (default 1 when --compile-stage1 && iters>1)")
            return 0
        if strutil.startsWith(arg, "--host-only:"):
            hostOnly = strings.dropPrefix(arg, "--host-only:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--iters:"):
            itersRaw = strings.dropPrefix(arg, "--iters:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--p95-ms:"):
            p95Raw = strings.dropPrefix(arg, "--p95-ms:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--p99-ms:"):
            p99Raw = strings.dropPrefix(arg, "--p99-ms:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--enforce:"):
            enforceRaw = strings.dropPrefix(arg, "--enforce:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--report:"):
            reportRaw = strings.dropPrefix(arg, "--report:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--compile-stage1"):
            compileStage1 = true
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-compile-stage1"):
            compileStage1 = false
            i = i + 1
            continue
        if strutil.startsWith(arg, "--out-dir:"):
            outDir = strings.dropPrefix(arg, "--out-dir:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--stage0:"):
            tooling_printErr("cheng_tooling: selfhost-100ms-host no longer accepts --stage0; canonical driver is mandatory")
            return 2
        tooling_printErr("cheng_tooling: unknown selfhost-100ms-host arg: " + arg)
        return 1
    let requireCompileStage1: bool = tooling_isTrue(
        os.getEnvDefault("SELFHOST_100MS_REQUIRE_COMPILE_STAGE1", "1"))
    if requireCompileStage1 && !compileStage1:
        tooling_printErr("cheng_tooling: selfhost-100ms-host requires --compile-stage1 in strict mode")
        tooling_printErr("  hint: set SELFHOST_100MS_REQUIRE_COMPILE_STAGE1=0 only for emergency diagnostics")
        return 2
    return tooling_cmdSelfhost100msHost(root, hostOnly, itersRaw, p95Raw, p99Raw, enforceRaw, reportRaw,
                                        compileStage1, outDir)

fn tooling_cmdVerifyBackendFfiOutptrTupleFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let allowRunFail: bool = tooling_isTrue(os.getEnvDefault("BACKEND_FFI_OUTPTR_TUPLE_ALLOW_RUN_FAIL", "0"))
    let outDir: str = tooling_pathAbsolute(root, "artifacts/backend_ffi_outptr_tuple")
    let fixtureRun: str = tooling_verifyBackendFfiOutptrTupleFixtureRun(root)
    let fixtureStatus: str = tooling_verifyBackendFfiOutptrTupleFixtureStatus(root)
    let fixtureFail: str = tooling_verifyBackendFfiOutptrTupleFixtureFail(root)
    let tool: str = tooling_verifyToolingBinaryPath(root)
    if !tooling_isExecutable(root, tool):
        tooling_printErr("cheng_tooling: missing tooling binary: " + tool)
        return 1
    if !tooling_verifyRgAvailable(root, "verify_backend_ffi_outptr_tuple"):
        return 2

    var i: int32 = firstArgIndex
    var targetRaw: str = ""
    var linkerRaw: str = ""
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("verify_backend_ffi_outptr_tuple options:")
            tooling_printOut("  --target:<triple>            explicit backend target (default host target)")
            tooling_printOut("  --linker:self|system|auto   explicit linker mode (default auto)")
            return 0
        if strutil.startsWith(arg, "--target:"):
            targetRaw = strings.dropPrefix(arg, "--target:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--linker:"):
            linkerRaw = strings.dropPrefix(arg, "--linker:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown verify_backend_ffi_outptr_tuple arg: " + arg)
        return 1
        i = i + 1

    let info: ToolingBackendDriverExecInfo =
        tooling_verifyBackendDriverExecInfo(root, tool, "verify_backend_ffi_outptr_tuple", targetRaw)
    if info == nil:
        return 1

    let requestedLinker: str = tooling_verifyBackendRequestedLinkerMode(
        linkerRaw, "auto", true, "verify_backend_ffi_outptr_tuple")
    if !tooling_strNonEmpty(requestedLinker):
        return 1
    let linkEnv: str = tooling_verifyBackendLinkEnvResolved(
        root, tool, info.driver, info.target, requestedLinker, "verify_backend_ffi_outptr_tuple")
    if !tooling_strNonEmpty(linkEnv):
        return 1

    if !tooling_fileExistsNonEmpty(fixtureRun) ||
       !tooling_fileExistsNonEmpty(fixtureStatus) ||
       !tooling_fileExistsNonEmpty(fixtureFail):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] missing fixture file")
        return 1

    if !tooling_mkdirP(root, outDir):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] failed to create output dir: " + outDir)
        return 1

    let safeTarget: str = tooling_verifySafeTarget(root, info.target)
    let exePath: str = tooling_verifyTargetExePath(
        outDir, "ffi_outptr_tuple_importc_pair_i32", safeTarget, info.target)
    let objPath: str = os.joinPath(outDir, "ffi_outptr_tuple_status_i32_objonly." + safeTarget + ".bin")

    let buildRunLog: str = os.joinPath(outDir, "ffi_outptr_tuple." + safeTarget + ".build_run.log")
    let runLog: str = os.joinPath(outDir, "ffi_outptr_tuple." + safeTarget + ".run.log")
    let buildObjLog: str = os.joinPath(outDir, "ffi_outptr_tuple." + safeTarget + ".build_obj.log")
    let buildFailLog: str = os.joinPath(outDir, "ffi_outptr_tuple." + safeTarget + ".build_fail.log")
    let report: str = os.joinPath(outDir, "backend_ffi_outptr_tuple." + safeTarget + ".report.txt")
    let snapshot: str = os.joinPath(outDir, "backend_ffi_outptr_tuple." + safeTarget + ".snapshot.env")
    var cleanupCmdParts: str[] = []
    add(cleanupCmdParts, "rm -f ")
    add(cleanupCmdParts, tooling_shellQuote(buildRunLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(runLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(buildObjLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(buildFailLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(exePath))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(objPath))
    let cleanup: os.ExecCmdResult = tooling_exec(root, tooling_joinFragments(cleanupCmdParts))
    let _ = tooling_exec(root, tooling_shellQuote("/bin/true"))

    let runCompileOpts: ToolingCompileOptions = tooling_verifyBackendCompileOptions(
        root, requestedLinker, info.target, fixtureRun, exePath)
    tooling_compileOptionsApplyLinkEnv(runCompileOpts, linkEnv, requestedLinker)
    let runCompileEnv: str = tooling_verifyBackendDriverCompileEnvText(
        root, info.driverExec, info.driverRealEnv, runCompileOpts)
    var runCompileCmdParts: str[] = []
    add(runCompileCmdParts, "env ")
    add(runCompileCmdParts, runCompileEnv)
    add(runCompileCmdParts, tooling_shellQuote(info.driverExec))
    add(runCompileCmdParts, " >")
    add(runCompileCmdParts, tooling_shellQuote(buildRunLog))
    add(runCompileCmdParts, " 2>&1")
    let runCompileRes: os.ExecCmdResult = tooling_exec(
        root,
        tooling_joinFragments(runCompileCmdParts))
    let runCompileRc: int32 = os.execCmdResultExitCode(runCompileRes)
    if runCompileRc != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] runtime fixture build failed (status=" + intToStr(runCompileRc) + ")")
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,200p' " + tooling_shellQuote(buildRunLog)))
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(exePath) + " ]")) != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] missing executable output: " + exePath)
        return 1

    let runFixtureRes: os.ExecCmdResult = tooling_exec(
        root, tooling_shellQuote(exePath) + " >" + tooling_shellQuote(runLog) + " 2>&1")
    var runStatus: int32 = os.execCmdResultExitCode(runFixtureRes)
    var runtimeSymbolMissingSkip: bool = false
    if runStatus != 0:
        if allowRunFail ||
           os.execCmdResultExitCode(tooling_exec(root,
               "rg -q 'Symbol not found: _cheng_memcpy' " + tooling_shellQuote(runLog) + " >/dev/null 2>&1")) == 0:
            runtimeSymbolMissingSkip = true
            runStatus = 0
        else:
            tooling_printErr("[verify_backend_ffi_outptr_tuple] runtime fixture run failed (status=" + intToStr(runStatus) + ")")
            tooling_printExecOutput(tooling_exec(root, "sed -n '1,120p' " + tooling_shellQuote(runLog)))
            return 1

    let statusCompileOpts: ToolingCompileOptions = tooling_verifyBackendCompileOptions(
        root, "self", info.target, fixtureStatus, objPath)
    statusCompileOpts.noRuntimeCText = "0"
    let statusCompileEnv: str = tooling_verifyBackendDriverCompileEnvText(
        root, info.driverExec, info.driverRealEnv, statusCompileOpts)
    var statusCompileCmdParts: str[] = []
    add(statusCompileCmdParts, "env ")
    add(statusCompileCmdParts, statusCompileEnv)
    add(statusCompileCmdParts, tooling_shellQuote(info.driverExec))
    add(statusCompileCmdParts, " >")
    add(statusCompileCmdParts, tooling_shellQuote(buildObjLog))
    add(statusCompileCmdParts, " 2>&1")
    if os.execCmdResultExitCode(tooling_exec(
        root,
        tooling_joinFragments(statusCompileCmdParts))) != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] status fixture exe build failed")
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,120p' " + tooling_shellQuote(buildObjLog)))
        return 1
    if !tooling_fileExistsNonEmpty(objPath):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] missing executable output: " + objPath)
        return 1

    let failOutput: str = os.joinPath(outDir, "compile_fail_ffi_outptr_tuple_arity_mismatch." + safeTarget)
    let failCompileOpts: ToolingCompileOptions = tooling_verifyBackendCompileOptions(
        root, requestedLinker, info.target, fixtureFail, failOutput)
    tooling_compileOptionsApplyLinkEnv(failCompileOpts, linkEnv, requestedLinker)
    let failCompileEnv: str = tooling_verifyBackendDriverCompileEnvText(
        root, info.driverExec, info.driverRealEnv, failCompileOpts)
    var failCompileCmdParts: str[] = []
    add(failCompileCmdParts, "env ")
    add(failCompileCmdParts, failCompileEnv)
    add(failCompileCmdParts, tooling_shellQuote(info.driverExec))
    add(failCompileCmdParts, " >")
    add(failCompileCmdParts, tooling_shellQuote(buildFailLog))
    add(failCompileCmdParts, " 2>&1")
    let failCompileRes: os.ExecCmdResult = tooling_exec(
        root,
        tooling_joinFragments(failCompileCmdParts))
    let failCompileRc: int32 = os.execCmdResultExitCode(failCompileRes)
    if failCompileRc == 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] negative fixture unexpectedly compiled")
        return 1

    let diagOk: bool = os.execCmdResultExitCode(tooling_exec(
        root,
        "rg -q --fixed-strings '" + "ffi_out_ptrs tuple arity mismatch" + "' " +
            tooling_shellQuote(buildFailLog) + " >/dev/null 2>&1")) == 0
    if !diagOk:
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,220p' " + tooling_shellQuote(buildFailLog)))
        tooling_printErr("[verify_backend_ffi_outptr_tuple] missing expected ffi_out_ptrs diagnostic in negative fixture log")
        return 1

    var reportLines: str[] = []
    add(reportLines, "verify_backend_ffi_outptr_tuple report")
    add(reportLines, "target=" + info.target)
    add(reportLines, "driver=" + info.driver)
    add(reportLines, "driver_exec=" + info.driverExec)
    add(reportLines, "fixture_run=" + fixtureRun)
    add(reportLines, "fixture_status_obj=" + fixtureStatus)
    add(reportLines, "fixture_fail=" + fixtureFail)
    add(reportLines, "build_run_status=" + intToStr(runCompileRc))
    add(reportLines, "run_status=" + intToStr(runStatus))
    add(reportLines, "run_mode=" + tooling_verifyBackendFfiOutptrTupleRunMode(runtimeSymbolMissingSkip))
    add(reportLines, "build_obj_status=0")
    add(reportLines, "build_fail_status=" + intToStr(failCompileRc))
    add(reportLines, "diag_pattern=ffi_out_ptrs tuple arity mismatch")
    add(reportLines, "diag_ok=" + tooling_boolText(diagOk))
    add(reportLines, "build_run_log=" + buildRunLog)
    add(reportLines, "run_log=" + runLog)
    add(reportLines, "build_obj_log=" + buildObjLog)
    add(reportLines, "build_fail_log=" + buildFailLog)
    if !tooling_writeTextFileViaShell(
        root,
        report,
        tooling_renderRawLines(reportLines, true)):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] failed to write report: " + report)
        return 1
    var snapshotLines: str[] = []
    add(snapshotLines, "backend_ffi_outptr_tuple_target=" + info.target)
    add(snapshotLines, "backend_ffi_outptr_tuple_diag_ok=" + tooling_boolText(diagOk))
    add(snapshotLines, "backend_ffi_outptr_tuple_report=" + report)
    if !tooling_writeTextFileViaShell(
        root,
        snapshot,
        tooling_renderRawLines(snapshotLines, true)):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] failed to write snapshot: " + snapshot)
        return 1

    tooling_printOut("verify_backend_ffi_outptr_tuple ok")
    return 0

fn tooling_cmdVerifyBackendFfiSliceShimFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let timeoutSec: int32 = 60
    let tool: str = tooling_verifyToolingBinaryPath(root)
    if !tooling_isExecutable(root, tool):
        tooling_printErr("[verify_backend_ffi_slice_shim] missing tooling binary: " + tool)
        return 1
    if !tooling_verifyRgAvailable(root, "verify_backend_ffi_slice_shim"):
        return 2

    var i: int32 = firstArgIndex
    var targetRaw: str = ""
    var linkerRaw: str = ""
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("verify_backend_ffi_slice_shim options:")
            tooling_printOut("  --target:<triple>            explicit backend target (default host target)")
            tooling_printOut("  --linker:self|system         explicit linker mode (default system)")
            tooling_printOut("  env BACKEND_FFI_SLICE_SHIM_RUN=1")
            tooling_printOut("      enable direct executable run for positive fixture")
            return 0
        if strutil.startsWith(arg, "--target:"):
            targetRaw = strings.dropPrefix(arg, "--target:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--linker:"):
            linkerRaw = strings.dropPrefix(arg, "--linker:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown verify_backend_ffi_slice_shim arg: " + arg)
        return 1

    let info: ToolingBackendDriverExecInfo =
        tooling_verifyBackendDriverExecInfo(root, tool, "verify_backend_ffi_slice_shim", targetRaw)
    if info == nil:
        return 1

    let backendLinkerMode: str = tooling_verifyBackendRequestedLinkerMode(
        linkerRaw, "system", false, "verify_backend_ffi_slice_shim")
    if !tooling_strNonEmpty(backendLinkerMode):
        return 1
    let linkEnv: str = tooling_verifyBackendLinkEnvResolved(
        root, tool, info.driver, info.target, backendLinkerMode, "verify_backend_ffi_slice_shim")
    if !tooling_strNonEmpty(linkEnv):
        return 1
    let runPositiveRaw: str = strutil.strip(os.getEnvDefault("BACKEND_FFI_SLICE_SHIM_RUN", "0"))
    let runPositive: bool = tooling_isTrue(runPositiveRaw)

    let outDir: str = tooling_pathAbsolute(root, "artifacts/backend_ffi_slice_shim")
    let fixtureOk: str = tooling_verifyBackendFfiSliceShimFixtureOk(root)
    let fixtureFailLegacy: str = tooling_verifyBackendFfiSliceShimFixtureFailLegacy(root)
    let fixtureFailSurface: str = tooling_verifyBackendFfiSliceShimFixtureFailSurface(root)
    let importcSymbol: str = tooling_verifyBackendFfiSliceShimImportcSymbol()
    let surfacePattern: str = tooling_verifyBackendFfiSliceShimSurfacePattern()
    let legacyDiagPattern: str = tooling_verifyBackendFfiSliceShimLegacyDiagPattern()
    let surfaceDiagPattern: str = tooling_verifyBackendFfiSliceShimSurfaceDiagPattern()

    if !tooling_fileExistsNonEmpty(fixtureOk) ||
       !tooling_fileExistsNonEmpty(fixtureFailLegacy) ||
       !tooling_fileExistsNonEmpty(fixtureFailSurface):
        tooling_printErr("[verify_backend_ffi_slice_shim] missing fixture file")
        return 1

    if !tooling_mkdirP(root, outDir):
        tooling_printErr("[verify_backend_ffi_slice_shim] failed to create output dir: " + outDir)
        return 1

    let safeTarget: str = tooling_verifySafeTarget(root, info.target)
    let exePath: str = tooling_verifyTargetExePath(outDir, "ffi_importc_slice_seq_i32", safeTarget, info.target)

    let runLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".run.log")
    let buildOkLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".build_ok.log")
    let buildFailLegacyLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".build_fail_legacy.log")
    let buildFailSurfaceLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".build_fail_surface.log")
    let surfaceScanLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".surface_scan.log")
    let report: str = os.joinPath(outDir, "backend_ffi_slice_shim." + safeTarget + ".report.txt")
    let snapshot: str = os.joinPath(outDir, "backend_ffi_slice_shim." + safeTarget + ".snapshot.env")
    let failLegacyOutput: str = os.joinPath(
        outDir,
        "compile_fail_ffi_importc_slice_openarray_i32." + safeTarget)
    let failSurfaceOutput: str = os.joinPath(
        outDir,
        "compile_fail_ffi_slice_user_raw_ptr_surface." + safeTarget)

    var cleanupCmdParts: str[] = []
    add(cleanupCmdParts, "rm -f ")
    add(cleanupCmdParts, tooling_shellQuote(exePath + ".o"))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(buildOkLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(runLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(buildFailLegacyLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(buildFailSurfaceLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(surfaceScanLog))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(report))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(snapshot))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(failLegacyOutput))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(failSurfaceOutput))
    add(cleanupCmdParts, " ; rm -rf ")
    add(cleanupCmdParts, tooling_shellQuote(exePath + ".objs"))
    add(cleanupCmdParts, " ")
    add(cleanupCmdParts, tooling_shellQuote(exePath + ".objs.lock"))
    let _ = tooling_exec(root, tooling_joinFragments(cleanupCmdParts))

    let surfaceOk: bool = tooling_verifyBackendFfiSliceShimSurfaceOk(
        root, fixtureOk, surfacePattern, surfaceScanLog)
    if !surfaceOk:
        tooling_printErr("[verify_backend_ffi_slice_shim] positive fixture leaks raw pointer surface (see " +
                        surfaceScanLog + ")")
        return 1

    let commonCompileEnv: str = tooling_verifyBackendFfiSliceShimCommonCompileEnv(
        root, info.driverExec, info.driverRealEnv, linkEnv, backendLinkerMode,
        info.target, fixtureOk, exePath)

    var compileOkCmdParts: str[] = []
    add(compileOkCmdParts, "env ")
    add(compileOkCmdParts, commonCompileEnv)
    add(compileOkCmdParts, " ")
    add(compileOkCmdParts, tooling_shellQuote(info.driverExec))
    add(compileOkCmdParts, " >")
    add(compileOkCmdParts, tooling_shellQuote(buildOkLog))
    add(compileOkCmdParts, " 2>&1")
    let compileOkCommand: str = tooling_wrapCommandWithTimeout(
        root,
        timeoutSec,
        tooling_joinFragments(compileOkCmdParts))
    let compileOkRes: os.ExecCmdResult = tooling_exec(root, compileOkCommand)
    let compileOkRc: int32 = os.execCmdResultExitCode(compileOkRes)
    if compileOkRc != 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] positive fixture build failed (status=" + intToStr(compileOkRc) + ")")
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,200p' " + tooling_shellQuote(buildOkLog)))
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(exePath) + " ]")) != 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] missing executable output: " + exePath)
        return 1

    let symbolCheck: str = tooling_verifyBackendFfiSliceShimSymbolCheck(root, exePath, importcSymbol)
    if tooling_strEq(symbolCheck, "0"):
        tooling_printErr("[verify_backend_ffi_slice_shim] missing expected importc symbol in positive artifact: " +
                         importcSymbol)
        return 1

    var runStatus: int32 = 0
    let runMode: str = tooling_verifyBackendFfiSliceShimRunMode(runPositive)
    if runPositive:
        var runCmdParts: str[] = []
        add(runCmdParts, tooling_shellQuote(exePath))
        add(runCmdParts, " >")
        add(runCmdParts, tooling_shellQuote(runLog))
        add(runCmdParts, " 2>&1")
        let runCommand: str = tooling_wrapCommandWithTimeout(
            root,
            timeoutSec,
            tooling_joinFragments(runCmdParts))
        let runRes: os.ExecCmdResult = tooling_exec(root, runCommand)
        runStatus = os.execCmdResultExitCode(runRes)
        if runStatus != 0:
            tooling_printErr("[verify_backend_ffi_slice_shim] positive fixture run failed (status=" + intToStr(runStatus) + ")")
            tooling_printExecOutput(tooling_exec(root, "sed -n '1,120p' " + tooling_shellQuote(runLog)))
            return 1

    var compileLegacyCmdParts: str[] = []
    add(compileLegacyCmdParts, "env ")
    add(compileLegacyCmdParts, tooling_verifyBackendFfiSliceShimCommonCompileEnv(
        root, info.driverExec, info.driverRealEnv, linkEnv, backendLinkerMode,
        info.target, fixtureFailLegacy, failLegacyOutput))
    add(compileLegacyCmdParts, " ")
    add(compileLegacyCmdParts, tooling_shellQuote(info.driverExec))
    add(compileLegacyCmdParts, " >")
    add(compileLegacyCmdParts, tooling_shellQuote(buildFailLegacyLog))
    add(compileLegacyCmdParts, " 2>&1")
    let compileLegacyCommand: str = tooling_wrapCommandWithTimeout(
        root,
        timeoutSec,
        tooling_joinFragments(compileLegacyCmdParts))
    let compileLegacyRes: os.ExecCmdResult = tooling_exec(root, compileLegacyCommand)
    let compileLegacyRc: int32 = os.execCmdResultExitCode(compileLegacyRes)
    if compileLegacyRc == 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] legacy openArray negative fixture unexpectedly compiled")
        return 1

    let legacyDiagOk: bool = tooling_verifyBackendFfiSliceShimDiagOk(root, legacyDiagPattern, buildFailLegacyLog)
    if !legacyDiagOk:
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,200p' " + tooling_shellQuote(buildFailLegacyLog)))
        tooling_printErr("[verify_backend_ffi_slice_shim] missing expected legacy openArray diagnostic")
        return 1

    let compileSurfaceEnv: str = tooling_verifyBackendFfiSliceShimSurfaceCompileEnv(
        root, info.driverExec, info.driverRealEnv, linkEnv, backendLinkerMode,
        info.target, fixtureFailSurface, failSurfaceOutput)
    var compileSurfaceCmdParts: str[] = []
    add(compileSurfaceCmdParts, "env ")
    add(compileSurfaceCmdParts, compileSurfaceEnv)
    add(compileSurfaceCmdParts, " ")
    add(compileSurfaceCmdParts, tooling_shellQuote(info.driverExec))
    add(compileSurfaceCmdParts, " >")
    add(compileSurfaceCmdParts, tooling_shellQuote(buildFailSurfaceLog))
    add(compileSurfaceCmdParts, " 2>&1")
    let compileSurfaceCommand: str = tooling_wrapCommandWithTimeout(
        root,
        timeoutSec,
        tooling_joinFragments(compileSurfaceCmdParts))
    let compileSurfaceRes: os.ExecCmdResult = tooling_exec(root, compileSurfaceCommand)
    let compileSurfaceRc: int32 = os.execCmdResultExitCode(compileSurfaceRes)
    if compileSurfaceRc == 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] raw pointer surface negative fixture unexpectedly compiled")
        return 1

    let surfaceDiagOk: bool = tooling_verifyBackendFfiSliceShimDiagOk(root, surfaceDiagPattern, buildFailSurfaceLog)
    if !surfaceDiagOk:
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,200p' " + tooling_shellQuote(buildFailSurfaceLog)))
        tooling_printErr("[verify_backend_ffi_slice_shim] missing expected no-pointer policy diagnostic")
        return 1

    var reportLines: str[] = []
    add(reportLines, "verify_backend_ffi_slice_shim report")
    add(reportLines, "target=" + info.target)
    add(reportLines, "driver=" + info.driver)
    add(reportLines, "fixture_ok=" + fixtureOk)
    add(reportLines, "fixture_fail_legacy=" + fixtureFailLegacy)
    add(reportLines, "fixture_fail_surface=" + fixtureFailSurface)
    add(reportLines, "build_ok_status=" + intToStr(compileOkRc))
    add(reportLines, "importc_symbol=" + importcSymbol)
    add(reportLines, "symbol_check=" + symbolCheck)
    add(reportLines, "run_status=" + intToStr(runStatus))
    add(reportLines, "run_mode=" + runMode)
    add(reportLines, "run_positive=" + tooling_boolText(runPositive))
    add(reportLines, "runtime_symbol_blocked=0")
    add(reportLines, "build_fail_legacy_status=" + intToStr(compileLegacyRc))
    add(reportLines, "build_fail_surface_status=" + intToStr(compileSurfaceRc))
    add(reportLines, "surface_pattern=" + surfacePattern)
    add(reportLines, "surface_ok=" + tooling_boolText(surfaceOk))
    add(reportLines, "legacy_diag_pattern=" + legacyDiagPattern)
    add(reportLines, "legacy_diag_ok=" + tooling_boolText(legacyDiagOk))
    add(reportLines, "surface_diag_pattern=" + surfaceDiagPattern)
    add(reportLines, "surface_diag_ok=" + tooling_boolText(surfaceDiagOk))
    add(reportLines, "build_ok_log=" + buildOkLog)
    add(reportLines, "run_log=" + runLog)
    add(reportLines, "build_fail_legacy_log=" + buildFailLegacyLog)
    add(reportLines, "build_fail_surface_log=" + buildFailSurfaceLog)
    add(reportLines, "surface_scan_log=" + surfaceScanLog)
    if !tooling_writeTextFileViaShell(
        root,
        report,
        tooling_renderRawLines(reportLines, true)):
        tooling_printErr("[verify_backend_ffi_slice_shim] failed to write report: " + report)
        return 1
    var snapshotLines: str[] = []
    add(snapshotLines, "backend_ffi_slice_shim_target=" + info.target)
    add(snapshotLines, "backend_ffi_slice_shim_surface_ok=" + tooling_boolText(surfaceOk))
    add(snapshotLines, "backend_ffi_slice_shim_symbol_check=" + symbolCheck)
    add(snapshotLines, "backend_ffi_slice_shim_run_mode=" + runMode)
    add(snapshotLines, "backend_ffi_slice_shim_run_positive=" + tooling_boolText(runPositive))
    add(snapshotLines, "backend_ffi_slice_shim_runtime_symbol_blocked=0")
    add(snapshotLines, "backend_ffi_slice_shim_legacy_diag_ok=" + tooling_boolText(legacyDiagOk))
    add(snapshotLines, "backend_ffi_slice_shim_surface_diag_ok=" + tooling_boolText(surfaceDiagOk))
    add(snapshotLines, "backend_ffi_slice_shim_report=" + report)
    if !tooling_writeTextFileViaShell(
        root,
        snapshot,
        tooling_renderRawLines(snapshotLines, true)):
        tooling_printErr("[verify_backend_ffi_slice_shim] failed to write snapshot: " + snapshot)
        return 1

    tooling_printOut("verify_backend_ffi_slice_shim ok")
    return 0

fn tooling_cmdRunSelfhostParallelPerfProbe(
    root: str,
    tool: str,
    timeoutRaw: str,
    session: str,
    skipSemRaw: str,
    skipOwnRaw: str,
    skipCProfileRaw: str,
    genericModeRaw: str,
    genericBudgetRaw: str,
    validateRaw: str,
    skipSmokeRaw: str,
    requireRunnableRaw: str,
    allowRetryRaw: str,
    multiRaw: str,
    multiForceRaw: str,
    jobsRaw: str,
    timingPath: str): int32 =
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "env " +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SESSION", session) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_TIMEOUT", timeoutRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_REQUIRE", "1") +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_REUSE", "0") +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_STRICT_ALLOW_FAST_REUSE", "0") +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SKIP_SEM", skipSemRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SKIP_OWNERSHIP", skipOwnRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SKIP_CPROFILE", skipCProfileRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_GENERIC_MODE", genericModeRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_GENERIC_SPEC_BUDGET", genericBudgetRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_VALIDATE", validateRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SKIP_SMOKE", skipSmokeRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_REQUIRE_RUNNABLE", requireRunnableRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_ALLOW_RETRY", allowRetryRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_MULTI", multiRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_MULTI_FORCE", multiForceRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_JOBS", jobsRaw) +
            tooling_envAssignCompat("SELFHOST_STRICT_PROBE_TIMING", timingPath) +
            tooling_shellQuote(tool) + " verify_backend_selfhost_strict_noreuse_probe")
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendSelfhostParallelPerfFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let timeoutRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_TIMEOUT", "60")
    let baseSessionRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_BASE_SESSION", "perf.parallel")
    let hostOnlyRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_HOST_ONLY", "")
    let enforceRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_ENFORCE_ON_HOST", "0")
    let jobsRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_JOBS", "0")
    let maxSlowdownRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_MAX_SLOWDOWN_SEC", "2")
    let skipSmokeRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_SKIP_SMOKE", "1")
    let requireRunnableRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_REQUIRE_RUNNABLE", "1")
    let validateRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_VALIDATE", "0")
    let skipSemRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_SKIP_SEM", "1")
    let skipOwnRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_SKIP_OWNERSHIP", "1")
    let skipCProfileRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_SKIP_CPROFILE", "1")
    let allowRetryRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_ALLOW_RETRY", "1")
    let genericModeRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_GENERIC_MODE", "dict")
    let genericBudgetRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_GENERIC_SPEC_BUDGET", "0")
    let reportRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_REPORT", "")

    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("Usage:")
            tooling_printOut("  src/tooling/verify_backend_selfhost_parallel_perf.sh [--help]")
            tooling_printOut("")
            tooling_printOut("Env:")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_TIMEOUT=<seconds>          default: 60")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_BASE_SESSION=<name>        default: perf.parallel")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_HOST_ONLY=<tag>            optional dedicated-host tag")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_ENFORCE_ON_HOST=<0|1>      default: 0")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_JOBS=<N>                   default: 0 (auto)")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_MAX_SLOWDOWN_SEC=<N>       default: 2")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_SKIP_SMOKE=<0|1>           default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_REQUIRE_RUNNABLE=<0|1>     default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_VALIDATE=<0|1>             default: 0")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_SKIP_SEM=<0|1>             default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_SKIP_OWNERSHIP=<0|1>       default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_SKIP_CPROFILE=<0|1>        default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_ALLOW_RETRY=<0|1>          default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_GENERIC_MODE=<mode>        default: dict")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_GENERIC_SPEC_BUDGET=<N>    default: 0")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_REPORT=<path>              optional report path")
            return 0
        tooling_printErr("cheng_tooling: unknown verify_backend_selfhost_parallel_perf arg: " + arg)
        return 2

    let tool: str = tooling_verifyToolingBinaryPath(root)
    if !tooling_isExecutable(root, tool):
        tooling_printErr("[selfhost_parallel_perf] missing tooling binary: " + tool)
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(tool) + " ]")) != 0:
        tooling_printErr("[selfhost_parallel_perf] missing tooling binary: " + tool)
        return 1

    let stage0: str = tooling_selfhostParallelPerfStage0(root, tool)
    if !tooling_strNonEmpty(stage0):
        tooling_printErr("[selfhost_parallel_perf] missing stage0")
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(stage0) + " ]")) != 0:
        tooling_printErr("[selfhost_parallel_perf] stage0 is not executable: " + stage0)
        return 1

    let hostTag: str = tooling_detectHostTag(root)
    let hostOnly: str = strutil.strip(hostOnlyRaw)
    let enforce: bool = tooling_isTrue(enforceRaw)
    let baseSession: str = tooling_nonEmptyDefault(baseSessionRaw, "perf.parallel")
    let safeBaseSession: str = tooling_selfhostParallelPerfSafeSession(root, baseSession, "perf_parallel")
    let report: str = tooling_selfhostParallelPerfReport(root, reportRaw, safeBaseSession)

    let reportDir: str = os.parentDir(report)
    if tooling_strNonEmpty(reportDir):
        if !tooling_mkdirP(root, reportDir):
            tooling_printErr("[selfhost_parallel_perf] failed to create report dir: " + reportDir)
            return 1
    if tooling_strNonEmpty(hostOnly) && !tooling_strEq(hostTag, hostOnly):
        let skipReport: str =
            "mode\tstatus\ttotal_sec\tstage1_sec\ttiming_file\n" +
            "meta\tskip_non_target_host\thost=" + hostTag +
                "\thost_only=" + hostOnly + "\treport_only=1\n" +
            "summary\tskip_non_target_host\t-1\t-1\thost=" + hostTag +
                " host_only=" + hostOnly + " dedicated_host_verified=0\n"
        if !tooling_writeTextFileViaShell(root, report, skipReport):
            tooling_printErr("[selfhost_parallel_perf] failed to write report: " + report)
            return 1
        tooling_printOut("[selfhost_parallel_perf] report-only on non-target host: host=" + hostTag + " target=" + hostOnly)
        return 0

    let serialSession: str = tooling_selfhostParallelPerfSession(baseSession, ".serial")
    let serialSessionSafe: str =
        tooling_selfhostParallelPerfSafeSession(root, serialSession, "perf_parallel_serial")
    let serialTiming: str = os.joinPath("artifacts/backend_selfhost_self_obj", "selfhost_timing_" + serialSessionSafe + ".tsv")

    let parallelSession: str = tooling_selfhostParallelPerfSession(baseSession, ".parallel")
    let parallelSessionSafe: str =
        tooling_selfhostParallelPerfSafeSession(root, parallelSession, "perf_parallel_parallel")
    let parallelTiming: str = os.joinPath("artifacts/backend_selfhost_self_obj", "selfhost_timing_" + parallelSessionSafe + ".tsv")

    let _ = tooling_exec(root, "rm -f " + tooling_shellQuote(serialTiming) + " " + tooling_shellQuote(parallelTiming))

    tooling_printOut("== backend.selfhost_parallel_perf.serial ==")
    let serialRc: int32 = tooling_cmdRunSelfhostParallelPerfProbe(
        root, tool, timeoutRaw, serialSession, skipSemRaw, skipOwnRaw,
        skipCProfileRaw, genericModeRaw, genericBudgetRaw, validateRaw,
        skipSmokeRaw, requireRunnableRaw, allowRetryRaw, "0", "0", jobsRaw, serialTiming)

    let serialStatusRaw: str = tooling_parseTimingRowField(root, serialTiming, "total", 2)
    let serialStatus: str = tooling_nonEmptyDefault(serialStatusRaw, "unknown")
    let serialTotalRaw: str = tooling_parseTimingRowField(root, serialTiming, "total", 3)
    let serialTotal: str = tooling_nonEmptyDefault(serialTotalRaw, "-1")
    let serialStage1Raw: str = tooling_parseTimingRowField(root, serialTiming, "stage1", 3)
    let serialStage1: str = tooling_nonEmptyDefault(serialStage1Raw, "-1")

    let _ = tooling_exec(root, "rm -f " + tooling_shellQuote(parallelTiming))
    tooling_printOut("== backend.selfhost_parallel_perf.parallel ==")
    let parallelRc: int32 = tooling_cmdRunSelfhostParallelPerfProbe(
        root, tool, timeoutRaw, parallelSession, skipSemRaw, skipOwnRaw,
        skipCProfileRaw, genericModeRaw, genericBudgetRaw, validateRaw,
        skipSmokeRaw, requireRunnableRaw, allowRetryRaw, "1", "0", jobsRaw, parallelTiming)

    let parallelStatusRaw: str = tooling_parseTimingRowField(root, parallelTiming, "total", 2)
    let parallelStatus: str = tooling_nonEmptyDefault(parallelStatusRaw, "unknown")
    let parallelTotalRaw: str = tooling_parseTimingRowField(root, parallelTiming, "total", 3)
    let parallelTotal: str = tooling_nonEmptyDefault(parallelTotalRaw, "-1")
    let parallelStage1Raw: str = tooling_parseTimingRowField(root, parallelTiming, "stage1", 3)
    let parallelStage1: str = tooling_nonEmptyDefault(parallelStage1Raw, "-1")

    tooling_printOut("[selfhost_parallel_perf] serial=" + serialTotal + "s status=" + serialStatus)
    tooling_printOut("[selfhost_parallel_perf] parallel=" + parallelTotal + "s status=" + parallelStatus)

    var summaryLine: str = ""
    if !tooling_strEq(serialStatus, "ok") || !tooling_strEq(parallelStatus, "ok"):
        summaryLine =
            "summary\tprobe_failed\t" + serialTotal + "\t" + parallelTotal +
                "\thost=" + hostTag + " dedicated_host_verified=0\n"
        if !tooling_writeTextFileViaShell(
            root,
            report,
            "mode\tstatus\ttotal_sec\tstage1_sec\ttiming_file\n" +
                "meta\thost=" + hostTag +
                    "\tenforce=" + tooling_boolText(enforce) +
                    "\tmax_slowdown=" + maxSlowdownRaw +
                    "\tstage0=" + stage0 + "\n" +
                "serial\t" + serialStatus + "\t" + serialTotal + "\t" + serialStage1 + "\t" + serialTiming + "\n" +
                "parallel\t" + parallelStatus + "\t" + parallelTotal + "\t" + parallelStage1 + "\t" + parallelTiming + "\n" +
                summaryLine):
            tooling_printErr("[selfhost_parallel_perf] failed to write report: " + report)
            return 1
        tooling_printErr("[selfhost_parallel_perf] fail: probe status is not ok (report=" + report + ")")
        return 1

    if !tooling_isDigitsColonDash(serialTotal + ":" + parallelTotal + ":" + maxSlowdownRaw):
        if !tooling_writeTextFileViaShell(
            root,
            report,
            "mode\tstatus\ttotal_sec\tstage1_sec\timing_file\n" +
                "meta\thost=" + hostTag +
                    "\tenforce=" + tooling_boolText(enforce) +
                    "\tmax_slowdown=" + maxSlowdownRaw +
                    "\tstage0=" + stage0 + "\n" +
                "serial\t" + serialStatus + "\t" + serialTotal + "\t" + serialStage1 + "\t" + serialTiming + "\n" +
                "parallel\t" + parallelStatus + "\t" + parallelTotal + "\t" + parallelStage1 + "\t" + parallelTiming + "\n"):
            tooling_printErr("[selfhost_parallel_perf] failed to write report: " + report)
            return 1
        tooling_printErr("[selfhost_parallel_perf] fail: non-numeric totals (report=" + report + ")")
        return 1

    let serialTotalInt: int32 = tooling_parseInt32Default(serialTotal, -1)
    let parallelTotalInt: int32 = tooling_parseInt32Default(parallelTotal, -1)
    let maxSlowdownInt: int32 = tooling_parseInt32Default(maxSlowdownRaw, -1)
    if serialTotalInt < 0 || parallelTotalInt < 0 || maxSlowdownInt < 0:
        if !tooling_writeTextFileViaShell(
            root,
            report,
            "mode\tstatus\ttotal_sec\tstage1_sec\timing_file\n" +
                "meta\thost=" + hostTag +
                    "\tenforce=" + tooling_boolText(enforce) +
                    "\tmax_slowdown=" + maxSlowdownRaw +
                    "\tstage0=" + stage0 + "\n" +
                "serial\t" + serialStatus + "\t" + serialTotal + "\t" + serialStage1 + "\t" + serialTiming + "\n" +
                "parallel\t" + parallelStatus + "\t" + parallelTotal + "\t" + parallelStage1 + "\t" + parallelTiming + "\n"):
            tooling_printErr("[selfhost_parallel_perf] failed to write report: " + report)
            return 1
        tooling_printErr("[selfhost_parallel_perf] fail: non-numeric totals (report=" + report + ")")
        return 1

    let limit: int32 = serialTotalInt + maxSlowdownInt
    if parallelTotalInt > limit:
        if enforce:
            summaryLine =
                "summary\tdedicated_host_failed\t" + serialTotal + "\t" + parallelTotal +
                    "\thost=" + hostTag + " limit=" + intToStr(limit) + " dedicated_host_verified=0\n"
            if !tooling_writeTextFileViaShell(
                root,
                report,
                "mode\tstatus\ttotal_sec\tstage1_sec\timing_file\n" +
                    "meta\thost=" + hostTag +
                        "\tenforce=" + tooling_boolText(enforce) +
                        "\tmax_slowdown=" + maxSlowdownRaw +
                        "\tstage0=" + stage0 + "\n" +
                    "serial\t" + serialStatus + "\t" + serialTotal + "\t" + serialStage1 + "\t" + serialTiming + "\n" +
                    "parallel\t" + parallelStatus + "\t" + parallelTotal + "\t" + parallelStage1 + "\t" + parallelTiming + "\n" +
                    summaryLine):
                tooling_printErr("[selfhost_parallel_perf] failed to write report: " + report)
                return 1
            tooling_printErr("[selfhost_parallel_perf] fail: parallel slower than budget (parallel=" + parallelTotal + "s > serial=" + serialTotal + "s + " + maxSlowdownRaw + "s, report=" + report + ")")
            return 1
        summaryLine =
            "summary\treport_only_slow\t" + serialTotal + "\t" + parallelTotal +
                "\thost=" + hostTag + " limit=" + intToStr(limit) + " dedicated_host_verified=0\n"
        if !tooling_writeTextFileViaShell(
            root,
            report,
            "mode\tstatus\ttotal_sec\tstage1_sec\timing_file\n" +
                "meta\thost=" + hostTag +
                    "\tenforce=" + tooling_boolText(enforce) +
                    "\tmax_slowdown=" + maxSlowdownRaw +
                    "\tstage0=" + stage0 + "\n" +
                "serial\t" + serialStatus + "\t" + serialTotal + "\t" + serialStage1 + "\t" + serialTiming + "\n" +
                "parallel\t" + parallelStatus + "\t" + parallelTotal + "\t" + parallelStage1 + "\t" + parallelTiming + "\n" +
                summaryLine):
            tooling_printErr("[selfhost_parallel_perf] failed to write report: " + report)
            return 1
        tooling_printOut("[selfhost_parallel_perf] report-only: parallel slower than budget (parallel=" + parallelTotal + "s > serial=" + serialTotal + "s + " + maxSlowdownRaw + "s, report=" + report + ")")
        return 0

    let summaryStatus: str = enforce ? "dedicated_host_verified" : "dedicated_host_pending"
    let dedicatedVerified: str = enforce ? "1" : "0"
    summaryLine =
        "summary\t" + summaryStatus + "\t" + serialTotal + "\t" + parallelTotal +
            "\thost=" + hostTag + " limit=" + intToStr(limit) +
            " dedicated_host_verified=" + dedicatedVerified + "\n"
    if !tooling_writeTextFileViaShell(
        root,
        report,
        "mode\tstatus\ttotal_sec\tstage1_sec\timing_file\n" +
            "meta\thost=" + hostTag +
                "\tenforce=" + tooling_boolText(enforce) +
                "\tmax_slowdown=" + maxSlowdownRaw +
                "\tstage0=" + stage0 + "\n" +
            "serial\t" + serialStatus + "\t" + serialTotal + "\t" + serialStage1 + "\t" + serialTiming + "\n" +
            "parallel\t" + parallelStatus + "\t" + parallelTotal + "\t" + parallelStage1 + "\t" + parallelTiming + "\n" +
            summaryLine):
        tooling_printErr("[selfhost_parallel_perf] failed to write report: " + report)
        return 1
    tooling_printOut("[selfhost_parallel_perf] ok (report=" + report + ")")
    if serialRc != 0 || parallelRc != 0:
        return 1
    return 0

fn tooling_cmdSyncGlobalDeprecated(): int32 =
    tooling_printErr("cheng_tooling: sync-global removed; use `build-global --out:artifacts/tooling_cmd/cheng_tooling`")
    return 2

fn tooling_idsContains(ids: str[], id: str): bool =
    for i in 0..<ids.len:
        if tooling_strEq(ids[i], id):
            return true
    return false

fn tooling_bundle(root: str, spec: tbundle.ToolingBundleArgs): int32 =
    if spec == nil:
        tooling_printErr("cheng_tooling: internal bundle parse failure")
        return 1
    if !tbundle.toolingBundleArgsOk(spec):
        tooling_printErr(tbundle.toolingBundleArgsError(spec))
        return tbundle.toolingBundleArgsExitCode(spec)
    var profileSelector: str = tbundle.toolingBundleArgsProfileSelector(spec)
    if !tooling_strNonEmpty(profileSelector):
        profileSelector = tinv.toolingSelectorAppend(profileSelector, "full")
    let mode: str = tinv.toolingNormalizeLinkMode(tbundle.toolingBundleArgsMode(spec))
    if !tooling_strNonEmpty(mode):
        tooling_printErr("cheng_tooling: invalid bundle --mode (expected symlink|hardlink|copy): " +
                         tbundle.toolingBundleArgsMode(spec))
        return 1
    if !tinv.toolingSelectorContains(profileSelector, "full"):
        tooling_printErr("cheng_tooling: bundle profile set is empty (allowed: full)")
        return 1
    let outDir: str = tbundle.toolingBundlePathAbsolute(root, tbundle.toolingBundleArgsOutDir(spec))
    if !tooling_strNonEmpty(outDir):
        tooling_printErr("cheng_tooling: bundle requires --out-dir:<path>")
        return 1
    if !tooling_mkdirP(root, outDir):
        tooling_printErr("cheng_tooling: failed to create bundle out dir: " + outDir)
        return 1
    let profileDir: str = os.joinPath(outDir, "full")
    let binPath: str = os.joinPath(profileDir, "cheng_tooling")
    let linksDir: str = os.joinPath(profileDir, "bin")
    let manifestPath: str = os.joinPath(profileDir, "manifest.tsv")
    let buildRc: int32 = tooling_buildGlobal(
        root, binPath, "", tbundle.toolingBundleArgsLinker(spec), tbundle.toolingBundleArgsDriver(spec))
    if buildRc != 0:
        return buildRc
    let installIds: str[] = tinv.toolingCollectScripts(root)
    let installRc: int32 = tinstall.toolingInstallLinks(
        root, installIds, binPath, linksDir, manifestPath, tbundle.toolingBundleArgsForce(spec), "", "", mode)
    if installRc != 0:
        return installRc
    tooling_printOut("bundle_profile=full")
    tooling_printOut("bundle_profile_bin=" + binPath)
    tooling_printOut("bundle_profile_links=" + linksDir)
    tooling_printOut("bundle_profile_manifest=" + manifestPath)
    return 0

fn tooling_resolveBuildDriver(root: str, driverRaw: str): str =
    let explicitRaw: str = strutil.strip(driverRaw)
    if tooling_strNonEmpty(explicitRaw):
        return tooling_resolveStage0DriverStrict(root, explicitRaw)
    return tooling_resolveStage0DriverStrict(root, "")

fn tooling_buildGlobalPreferredDriver(root: str, targetRaw: str): str =
    let target: str = tooling_normalizeTargetAlias(root, targetRaw)
    let canonicalDriver: str = tooling_resolveBuildDriver(root, "")
    let preferCurrentsrcProof: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_PREFER_CURRENTSRC_PROOF", "0"))
    if tooling_strNonEmpty(canonicalDriver) &&
       tooling_stage0CandidateHealthy(root, canonicalDriver, false, "build_global_canonical_driver") &&
       !preferCurrentsrcProof:
        return canonicalDriver
    if tooling_strEq(target, "arm64-apple-darwin"):
        let currentsrcStage2: str =
            tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2")
        if tooling_stage0CandidateHealthy(root, currentsrcStage2, false, "build_global_currentsrc_proof"):
            return currentsrcStage2
    return canonicalDriver

fn tooling_buildGlobalDriverSurface(root: str, driverPathRaw: str): str =
    let driverPath: str = tooling_pathAbsolute(root, driverPathRaw)
    if !tooling_strNonEmpty(driverPath):
        return ""
    let currentsrcStage2: str =
        tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2")
    let canonicalDriver: str =
        tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if tooling_strEq(driverPath, currentsrcStage2):
        return "probe_currentsrc_proof"
    if tooling_strEq(driverPath, canonicalDriver):
        return "canonical_backend_driver"
    return "explicit_or_other"

fn tooling_buildGlobalStage0Route(root: str, driverPathRaw: str, driverRaw: str): str =
    let routeRaw: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_STAGE0_ROUTE", "")))
    if tooling_strEq(routeRaw, "sidecar"):
        return "sidecar"
    if tooling_strEq(routeRaw, "direct"):
        return "direct"
    let driverSurface: str = tooling_buildGlobalDriverSurface(root, driverPathRaw)
    if tooling_strNonEmpty(strutil.strip(driverRaw)):
        return "direct"
    if tooling_strEq(driverSurface, "probe_currentsrc_proof") ||
       tooling_strEq(driverSurface, "explicit_or_other"):
        return "direct"
    return "default"

fn tooling_binaryHelpProbeOk(root: str, binPathRaw: str, acceptRc1: bool): bool =
    let binPath: str = tooling_pathAbsolute(root, binPathRaw)
    if !tooling_isExecutable(root, binPath):
        return false
    if !tooling_binaryExecPolicyPreflightOk(root, binPath, "binary_help_probe"):
        return false
    let runProbe: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BINARY_HELP_PROBE_RUN", "0"))
    if !runProbe:
        return true
    var timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_BINARY_HELP_TIMEOUT", ""), 12)
    if timeoutSec <= 0:
        timeoutSec = 12
    let res: os.ExecCmdResult = tooling_exec(
        root,
        tooling_wrapCommandWithTimeout(root, timeoutSec, tooling_binaryHelpProbeCommand(binPath)))
    let rc: int32 = os.execCmdResultExitCode(res)
    if rc == 0:
        return true
    if acceptRc1 && rc == 1:
        return true
    return false

fn tooling_verifyBuiltToolingBinarySurface(root: str, binPathRaw: str): bool =
    let binPath: str = tooling_pathAbsolute(root, binPathRaw)
    if !tooling_isExecutable(root, binPath):
        return false
    if !tooling_binaryExecPolicyPreflightOk(root, binPath, "tooling_surface_verify"):
        return false
    let isScriptShim: bool = tooling_driverIsScriptShim(root, binPath)
    var timeoutSec: int32 = tooling_parseInt32Default(
        os.getEnvDefault("TOOLING_BINARY_SURFACE_HELP_TIMEOUT", ""), 8)
    if timeoutSec <= 0:
        timeoutSec = 8
    if isScriptShim:
        let listRes: os.ExecCmdResult = tooling_exec(
            root,
            tooling_wrapCommandWithTimeout(root, timeoutSec, tooling_binaryListProbeCommand(binPath)))
        if os.execCmdResultExitCode(listRes) != 0:
            return false
        let helpShimRes: os.ExecCmdResult = tooling_exec(
            root,
            tooling_wrapCommandWithTimeout(root, timeoutSec, tooling_binaryHelpProbeCommand(binPath)))
        return os.execCmdResultExitCode(helpShimRes) == 0
    # Guard against silently corrupted self-link output (for example zeroed
    # __TEXT,__cstring) that exits with rc=1 and no diagnostics.
    let res: os.ExecCmdResult = tooling_exec(root, tooling_binarySurfaceStringsProbeCommand(binPath))
    if os.execCmdResultExitCode(res) != 0:
        return false
    let helpRes: os.ExecCmdResult = tooling_exec(
        root,
        tooling_wrapCommandWithTimeout(root, timeoutSec, tooling_binaryHelpProbeCommand(binPath)))
    if os.execCmdResultExitCode(helpRes) != 0:
        return false
    return true

fn tooling_buildGlobalReleaseFallbackTry(root: str, stage0Exec: str, src: str, outPath: str,
                                         target: str, timeoutSec: int32,
                                         releaseCflagsRaw: str, releaseLdflagsRaw: str,
                                         stage0RouteRaw: str): bool =
    if !tooling_isExecutable(root, stage0Exec):
        return false
    if os.fileExists(outPath):
        os.removeFile(outPath)
    let cmdLog: str = tooling_buildGlobalReleaseFallbackCmdLog(outPath)
    if os.fileExists(cmdLog):
        os.removeFile(cmdLog)
    let optLevel: str = tooling_buildGlobalReleaseFallbackOptLevel()
    let opt: str = tooling_buildGlobalReleaseFallbackOpt()
    let opt2: str = tooling_buildGlobalReleaseFallbackOpt2()
    let effectiveReleaseCflags: str =
        tooling_buildGlobalReleaseFallbackEffectiveCflags(releaseCflagsRaw)
    let compileMultiText: str = tooling_compileParallelMultiText(root)
    let compileJobsText: str = tooling_compileParallelJobsText(root)
    let compileFnJobsText: str = tooling_compileParallelFnJobsText(root, compileJobsText)
    let stage0Route: str = tooling_buildGlobalReleaseFallbackStage0Route(stage0RouteRaw)
    let res: os.ExecCmdResult = tooling_exec(
        root,
        tooling_buildGlobalReleaseFallbackCommand(
            root, stage0Exec, src, outPath, target, timeoutSec, effectiveReleaseCflags,
            releaseLdflagsRaw, stage0Route, optLevel, opt, opt2, compileMultiText,
            compileJobsText, compileFnJobsText, cmdLog))
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("cheng_tooling: build-global release fallback attempt failed, dumping log: " + cmdLog)
        if os.execCmdResultExitCode(res) == 124:
            tooling_printErr("build_global release fallback timeout reached " + intToStr(timeoutSec) + "s")
        tooling_printCommandLogTail(root, cmdLog, "build_global_release_fallback", 220)
    else:
        tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) != 0:
        return false
    return tooling_verifyBuiltToolingBinarySurface(root, outPath)

fn tooling_buildGlobal(root: str, outRaw: str, targetRaw: str, linkerRaw: str,
                       driverRaw: str): int32 =
    let src: str = os.joinPath(root, "src/tooling/cheng_tooling.cheng")
    if !os.fileExists(src):
        tooling_printErr("cheng_tooling: source not found: " + src)
        return 1
    let embeddedSources: str[] = tooling_embeddedToolingSourceList(root)
    for i in 0..<embeddedSources.len:
        if !os.fileExists(embeddedSources[i]):
            tooling_printErr("cheng_tooling: embedded tooling source not found: " + embeddedSources[i])
            return 1
    let outPath: str = tooling_pathAbsolute(root, outRaw)
    if !tooling_strNonEmpty(outPath):
        tooling_printErr("cheng_tooling: build-global requires --out:<path>")
        return 1
    if bgsync.toolingBuildGlobalIsCanonicalWrapperTarget(root, outPath):
        let changed: bool = bgsync.toolingBuildGlobalCanonicalWrapperChanged(root, outPath)
        tooling_printOut("build_global_mode=canonical_wrapper_sync")
        tooling_printOut("build_global_out=" + outPath)
        tooling_printOut("build_global_release_fallback=0")
        tooling_printOut("build_global_release_fallback_allowed=0")
        if !bgsync.toolingBuildGlobalSyncCanonicalWrappers(root, outPath):
            tooling_printErr("cheng_tooling: build-global failed to sync canonical wrapper surface")
            tooling_printOut("build_global_rebuilt=0")
            tooling_printOut("build_global_binary_surface_ok=0")
            tooling_printOut("build_global_status=failed")
            tooling_printOut("build_global_rc=1")
            return 1
        if !tooling_verifyBuiltToolingBinarySurface(root, outPath):
            tooling_printErr("cheng_tooling: build-global synced canonical wrapper surface is unhealthy")
            tooling_printOut("build_global_rebuilt=0")
            tooling_printOut("build_global_binary_surface_ok=0")
            tooling_printOut("build_global_status=failed")
            tooling_printOut("build_global_rc=1")
            return 1
        tooling_printOut("build_global_rebuilt=" + tooling_boolText(changed))
        tooling_printOut("build_global_binary_surface_ok=1")
        tooling_printOut("build_global_status=ok")
        tooling_printOut("build_global_rc=0")
        return 0
    let eagerRebuild: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_GLOBAL_EAGER_REBUILD", "0"))
    var state: ToolingBuildGlobalState = nil
    new(state)
    state.target = tooling_buildGlobalResolvedTarget(root, targetRaw)
    let releaseFallbackDefault: str = tooling_buildGlobalReleaseFallbackDefault(state.target)
    let releaseFallbackAllowedRaw: str = os.getEnvDefault(
        "TOOLING_BUILD_GLOBAL_RELEASE_FALLBACK", releaseFallbackDefault)
    let releaseFallbackAllowed: bool = tooling_isTrue(releaseFallbackAllowedRaw)
    let outHealthy: bool = tooling_verifyBuiltToolingBinarySurface(root, outPath)
    let sourceNewerThanOut: bool =
        tooling_fileIsNewer(root, src, outPath) ||
        tooling_anyFileNewerThan(root, embeddedSources, outPath)
    if !eagerRebuild && outHealthy && !sourceNewerThanOut:
        tooling_printOut("build_global_rebuilt=0")
        tooling_printOut("build_global_fast_path=reuse_existing")
        tooling_printOut("build_global_binary_surface_ok=1")
        tooling_printOut("build_global_release_fallback=0")
        tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
        tooling_printOut("build_global_out=" + outPath)
        return 0
    if !eagerRebuild && outHealthy && sourceNewerThanOut:
        tooling_printErr("cheng_tooling: build-global sources newer than existing binary; forcing rebuild")
    if !tooling_stage0QuarantineEnabled() &&
       tooling_stage0BlockOnQuarantineUe(root, "TOOLING_BUILD_GLOBAL_BLOCK_ON_UE", "build_global"):
        return 1
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        if !tooling_mkdirP(root, outDir):
            tooling_printErr("cheng_tooling: failed to create output dir: " + outDir)
            return 1
    let buildOutPath: str = os.joinPath(root, "chengcache/tooling_cmd/cheng_tooling.build_global." + tooling_nowNonceText() + ".tmp")
    let buildOutDir: str = os.parentDir(buildOutPath)
    if tooling_strNonEmpty(buildOutDir):
        if !tooling_mkdirP(root, buildOutDir):
            tooling_printErr("cheng_tooling: failed to create build-global temp dir: " + buildOutDir)
            return 1
    if os.fileExists(buildOutPath):
        os.removeFile(buildOutPath)
    let linker: str = tooling_trimAsciiSpace(linkerRaw)
    if !tooling_strEq(linker, "self"):
        tooling_printErr("cheng_tooling: build-global only supports --linker:self in dev in-memory mode")
        return 1
    state.driverPath = tooling_buildGlobalResolvedDriverPath(root, state.target, driverRaw)
    if !tooling_strNonEmpty(state.driverPath):
        if tooling_strNonEmpty(driverRaw):
            tooling_printErr("cheng_tooling: --driver not found: " + driverRaw)
        else:
            tooling_printErr("cheng_tooling: failed to resolve build driver (set --driver:<path>)")
        return 1
    let stage0Exec: str = tooling_prepareStage0Exec(root, state.driverPath, "build_global")
    if !tooling_strNonEmpty(stage0Exec):
        tooling_printErr("cheng_tooling: build-global stage0 prepare failed: " + state.driverPath)
        return 1
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(state.driverPath, stage0Exec)
        tooling_printErr("cheng_tooling: build-global stage0 preflight failed: " + state.driverPath)
        return 1
    let stage0Route: str = tooling_buildGlobalStage0Route(root, state.driverPath, driverRaw)
    let releaseCflagsRaw: str = strutil.strip(os.getEnvDefault("BACKEND_RELEASE_CFLAGS", "-O0"))
    let releaseLdflagsRaw: str = tooling_releaseLdflagsForTarget(
        os.getEnvDefault("BACKEND_RELEASE_LDFLAGS", releaseCflagsRaw), state.target)
    let crashMemoEnabled: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_GLOBAL_CRASH_MEMO", "1"))
    let safeFirstDefault: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_GLOBAL_SAFE_FIRST", "1"))
    let crashMemoPath: str = tooling_buildGlobalCrashMemoPath(root)
    let driverPathSha: str = tooling_sha256File(root, state.driverPath)
    let srcSha: str = tooling_sha256File(root, src)
    var safeFirstFromMemo: bool = safeFirstDefault
    if crashMemoEnabled:
        safeFirstFromMemo = safeFirstFromMemo ||
            tooling_buildGlobalSafeFromMemo(
                root, crashMemoPath, state.driverPath, src, state.target, linker, driverPathSha, srcSha)
    state.runtimeObj = tooling_runtimeObjPath(root, state.target)
    if !os.fileExists(state.runtimeObj):
        state.runtimeObj = tooling_prepareRuntimeObjForTargetWithRoute(root, stage0Exec, state.target, stage0Route)
    if !os.fileExists(state.runtimeObj):
        tooling_cleanupStage0Exec(state.driverPath, stage0Exec)
        tooling_printErr("cheng_tooling: build-global missing runtime object for self-link: " + state.runtimeObj)
        return 1
    let timeoutDefault: int32 = 60
    var timeoutSec: int32 =
        tooling_clampCompileTimeoutSec(
            tooling_parseInt32Default(os.getEnvDefault("TOOLING_BUILD_GLOBAL_TIMEOUT", ""), timeoutDefault))
    let crashRetrySafe: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_GLOBAL_CRASH_RETRY_SAFE", "0"))
    var retryUsed: bool = false
    state.compileOptLevel = tooling_buildGlobalCompileOptLevelDefault()
    state.compileBackendOpt = tooling_buildGlobalCompileBackendOptDefault()
    state.compileBackendOpt2 = tooling_buildGlobalCompileBackendOpt2Default()
    state.compileCflagsRaw = ""
    state.compileLdflagsRaw = ""
    let compileMultiDefault: str = tooling_compileDefaultMulti(root)
    let compileMultiText: str = tooling_compileParallelMultiText(root, compileMultiDefault)
    let compileJobsText: str = tooling_compileParallelJobsText(root)
    let compileFnJobsText: str = tooling_compileParallelFnJobsText(root, compileJobsText)
    var finalRc: int32 = 1
    tooling_printOut("build_global_driver=" + state.driverPath)
    tooling_printOut("build_global_driver_surface=" + tooling_buildGlobalDriverSurface(root, state.driverPath))
    tooling_printOut("build_global_stage0_route=" + stage0Route)
    tooling_printOut("build_global_driver_exec=" + stage0Exec)
    tooling_printOut("build_global_linker=" + linker)
    tooling_printOut("build_global_out=" + outPath)
    tooling_printOut("build_global_temp_out=" + buildOutPath)
    tooling_printOut("build_global_timeout_sec=" + intToStr(timeoutSec))
    tooling_printOut("build_global_release_fallback=0")
    tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
    tooling_printOut("build_global_status=building")
    if safeFirstFromMemo:
        state.compileOptLevel = tooling_buildGlobalCompileOptLevelRetry()
        state.compileBackendOpt = tooling_buildGlobalCompileBackendOptRetry()
        state.compileBackendOpt2 = tooling_buildGlobalCompileBackendOpt2Retry()
        state.compileCflagsRaw = tooling_buildGlobalCompileCflagsRetry()
        state.compileLdflagsRaw = tooling_buildGlobalCompileLdflagsRetry(state.target, state.compileCflagsRaw)
        tooling_printOut("build_global_safe_first=1")
    for attempt in 0..<2:
        if attempt > 0 && (safeFirstFromMemo || !crashRetrySafe || !retryUsed):
            break
        let attemptLog: str = tooling_buildGlobalAttemptLog(buildOutPath, attempt)
        if os.fileExists(attemptLog):
            os.removeFile(attemptLog)
        if os.fileExists(buildOutPath):
            os.removeFile(buildOutPath)
        let result: os.ExecCmdResult = tooling_exec(
            root,
            tooling_buildGlobalAttemptCommand(
                root, stage0Exec, src, buildOutPath, state.target, stage0Route, state.runtimeObj,
                state.compileOptLevel, state.compileBackendOpt, state.compileBackendOpt2,
                state.compileCflagsRaw, state.compileLdflagsRaw, compileMultiText,
                compileJobsText, compileFnJobsText, attemptLog,
                timeoutSec, attempt))
        finalRc = os.execCmdResultExitCode(result)
        if finalRc != 0:
            tooling_printErr("cheng_tooling: build-global attempt " + intToStr(attempt) +
                             " failed rc=" + intToStr(finalRc) +
                             " kind=" + tooling_exitKind(finalRc) +
                             "; log=" + attemptLog)
            if finalRc == 124:
                tooling_printErr("build_global timeout reached " + intToStr(timeoutSec) + "s; capture tail diagnostic")
            tooling_printCommandLogTail(root, attemptLog, "build_global_attempt_" + intToStr(attempt), 220)
        elif os.execCmdResultExitCode(result) == 0:
            tooling_printExecOutput(result)
        if finalRc == 0:
            break
        if !crashRetrySafe || retryUsed || !tooling_isCrashExitCode(finalRc):
            break
        retryUsed = true
        state.compileOptLevel = tooling_buildGlobalCompileOptLevelRetry()
        state.compileBackendOpt = tooling_buildGlobalCompileBackendOptRetry()
        state.compileBackendOpt2 = tooling_buildGlobalCompileBackendOpt2Retry()
        state.compileCflagsRaw = tooling_buildGlobalCompileCflagsRetry()
        state.compileLdflagsRaw = tooling_buildGlobalCompileLdflagsRetry(state.target, state.compileCflagsRaw)
        tooling_printErr("cheng_tooling: build-global crashed rc=" + intToStr(finalRc) +
                         " kind=" + tooling_exitKind(finalRc) +
                         "; retry safe profile opt=" + state.compileBackendOpt +
                         " opt2=" + state.compileBackendOpt2 +
                         " opt_level=" + state.compileOptLevel)
    tooling_cleanupStage0Exec(state.driverPath, stage0Exec)
    if crashMemoEnabled && tooling_strNonEmpty(driverPathSha) && tooling_strNonEmpty(srcSha):
        if finalRc == 0:
            tooling_buildGlobalWriteCrashMemo(
                root, crashMemoPath, state.driverPath, src, state.target, linker, driverPathSha, srcSha,
                retryUsed || safeFirstFromMemo)
        elif retryUsed:
            tooling_buildGlobalWriteCrashMemo(
                root, crashMemoPath, state.driverPath, src, state.target, linker, driverPathSha, srcSha, true)
    if retryUsed:
        tooling_printOut("build_global_retry=1")
    if finalRc != 0:
        if tooling_verifyBuiltToolingBinarySurface(root, buildOutPath):
            tooling_printErr("cheng_tooling: build-global recovered healthy output despite rc=" +
                             intToStr(finalRc) + " kind=" + tooling_exitKind(finalRc) +
                             "; accepting built artifact")
            if tooling_installExecutableAtomic(root, buildOutPath, outPath):
                if os.fileExists(buildOutPath):
                    os.removeFile(buildOutPath)
                tooling_printOut("build_global_rebuilt=1")
                tooling_printOut("build_global_binary_surface_ok=1")
                tooling_printOut("build_global_release_fallback=0")
                tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
                tooling_printOut("build_global_status=ok")
                tooling_printOut("build_global_rc=0")
                return 0
            tooling_printErr("cheng_tooling: build-global recovered healthy output but install failed: " + outPath)
        if releaseFallbackAllowed:
            let fallbackOutOnFail: str = tooling_buildGlobalReleaseFallbackOut(buildOutPath)
            tooling_printErr("cheng_tooling: build-global self-link failed; attempting release-system fallback rebuild")
            if tooling_buildGlobalReleaseFallbackTry(root, stage0Exec, src, fallbackOutOnFail, state.target, timeoutSec,
                                                     releaseCflagsRaw, releaseLdflagsRaw, stage0Route):
                if tooling_installExecutableAtomic(root, fallbackOutOnFail, outPath):
                    if os.fileExists(buildOutPath):
                        os.removeFile(buildOutPath)
                    if os.fileExists(fallbackOutOnFail):
                        os.removeFile(fallbackOutOnFail)
                    tooling_printOut("build_global_release_fallback=1")
                    tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
                    tooling_printOut("build_global_rebuilt=1")
                    tooling_printOut("build_global_binary_surface_ok=1")
                    return 0
                tooling_printErr("cheng_tooling: release fallback built healthy binary but install failed: " + outPath)
            if os.fileExists(fallbackOutOnFail):
                os.removeFile(fallbackOutOnFail)
        else:
            tooling_printErr("cheng_tooling: build-global release-system fallback disabled for target=" + state.target)
        if tooling_verifyBuiltToolingBinarySurface(root, outPath):
            tooling_printErr("cheng_tooling: build-global rebuild failed rc=" + intToStr(finalRc) +
                             " kind=" + tooling_exitKind(finalRc) +
                             "; keep existing healthy tooling binary")
            if os.fileExists(buildOutPath):
                os.removeFile(buildOutPath)
            tooling_printOut("build_global_rebuilt=0")
            tooling_printOut("build_global_fast_path=keep_existing_after_fail")
            tooling_printOut("build_global_binary_surface_ok=1")
            tooling_printOut("build_global_release_fallback=0")
            tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
            tooling_printOut("build_global_status=kept_existing_after_fail")
            tooling_printOut("build_global_rc=" + intToStr(finalRc))
            tooling_printOut("build_global_out=" + outPath)
            return 0
        if os.fileExists(buildOutPath):
            os.removeFile(buildOutPath)
        tooling_printOut("build_global_rebuilt=0")
        tooling_printOut("build_global_binary_surface_ok=0")
        tooling_printOut("build_global_status=failed")
        tooling_printOut("build_global_rc=" + intToStr(finalRc))
        return finalRc
    if !tooling_verifyBuiltToolingBinarySurface(root, buildOutPath):
        tooling_printErr("cheng_tooling: build-global produced unhealthy tooling binary: " + buildOutPath)
        tooling_printErr("  hint: inspect self-link output (__TEXT,__cstring) and keep canonical seed binary for execution")
        if releaseFallbackAllowed:
            let fallbackOut: str = tooling_buildGlobalReleaseFallbackOut(buildOutPath)
            tooling_printErr("cheng_tooling: attempting release-system fallback rebuild for build-global")
            if tooling_buildGlobalReleaseFallbackTry(root, stage0Exec, src, fallbackOut, state.target, timeoutSec,
                                                     releaseCflagsRaw, releaseLdflagsRaw, stage0Route):
                if tooling_installExecutableAtomic(root, fallbackOut, outPath):
                    if os.fileExists(buildOutPath):
                        os.removeFile(buildOutPath)
                    if os.fileExists(fallbackOut):
                        os.removeFile(fallbackOut)
                    tooling_printOut("build_global_release_fallback=1")
                    tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
                    tooling_printOut("build_global_rebuilt=1")
                    tooling_printOut("build_global_binary_surface_ok=1")
                    return 0
                tooling_printErr("cheng_tooling: release fallback built healthy binary but install failed: " + outPath)
            if os.fileExists(fallbackOut):
                os.removeFile(fallbackOut)
            tooling_printErr("cheng_tooling: release-system fallback rebuild failed")
        else:
            tooling_printErr("cheng_tooling: build-global release-system fallback disabled for target=" + state.target)
        if tooling_verifyBuiltToolingBinarySurface(root, outPath):
            tooling_printErr("cheng_tooling: keep existing healthy tooling binary: " + outPath)
            if os.fileExists(buildOutPath):
                os.removeFile(buildOutPath)
            tooling_printOut("build_global_rebuilt=0")
            tooling_printOut("build_global_fast_path=keep_existing_unhealthy_build")
            tooling_printOut("build_global_binary_surface_ok=1")
            tooling_printOut("build_global_release_fallback=0")
            tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
            tooling_printOut("build_global_status=kept_existing_after_unhealthy_build")
            tooling_printOut("build_global_rc=1")
            tooling_printOut("build_global_out=" + outPath)
            return 0
        if os.fileExists(buildOutPath):
            os.removeFile(buildOutPath)
        tooling_printOut("build_global_rebuilt=0")
        tooling_printOut("build_global_binary_surface_ok=0")
        tooling_printOut("build_global_status=unhealthy_build")
        tooling_printOut("build_global_rc=1")
        return 1
    if !tooling_installExecutableAtomic(root, buildOutPath, outPath):
        tooling_printErr("cheng_tooling: build-global failed to install healthy tooling binary to: " + outPath)
        if os.fileExists(buildOutPath):
            os.removeFile(buildOutPath)
        return 1
    if os.fileExists(buildOutPath):
        os.removeFile(buildOutPath)
    tooling_printOut("build_global_rebuilt=1")
    tooling_printOut("build_global_binary_surface_ok=1")
    tooling_printOut("build_global_release_fallback=0")
    tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
    tooling_printOut("build_global_status=ok")
    tooling_printOut("build_global_rc=0")
    let embeddedCacheDir: str = os.joinPath(root, "chengcache/embedded_scripts")
    if os.dirExists(embeddedCacheDir):
        let purgeRes: os.ExecCmdResult = tooling_exec(
            root, tooling_buildGlobalPurgeEmbeddedCacheCommand(embeddedCacheDir))
        tooling_printExecOutput(purgeRes)
        if os.execCmdResultExitCode(purgeRes) == 0:
            tooling_printOut("build_global_embedded_cache_purged=1")
        else:
            tooling_printErr("cheng_tooling: warn: failed to purge embedded cache under " +
                             embeddedCacheDir)
    return 0

fn tooling_cmdBuildBackendRawptrContract(root: str, outFile: str, doc: str, formalDoc: str, toolingDoc: str): int32 =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then ")
    add(parts, "echo \"[build_backend_rawptr_contract] rg is required\" >&2; exit 2; ")
    add(parts, "fi; ")
    add(parts, "hash_file() { ")
    add(parts, "file=\"$1\"; ")
    add(parts, "if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; ")
    add(parts, "if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; ")
    add(parts, "cksum \"$file\" | awk '{print $1}'; ")
    add(parts, "}; ")
    add(parts, "read_marker_value() { file=\"$1\"; marker_regex=\"$2\"; rg -o \"${marker_regex}=[A-Za-z0-9_]+\" \"$file\" | head -n 1 | cut -d= -f2 || true; }; ")
    add(parts, "require_marker_value() { ")
    add(parts, "file=\"$1\"; marker_regex=\"$2\"; marker_name=\"$3\"; expected=\"$4\"; ")
    add(parts, "value=\"$(read_marker_value \"$file\" \"$marker_regex\")\"; ")
    add(parts, "if [ \"$value\" != \"$expected\" ]; then echo \"[build_backend_rawptr_contract] ${marker_name} must be ${expected} in: $file\" >&2; exit 2; fi; ")
    add(parts, "printf '%s\\n' \"$value\"; ")
    add(parts, "}; ")
    add(parts, "out=")
    add(parts, tooling_shellQuote(outFile))
    add(parts, "; ")
    add(parts, "doc=")
    add(parts, tooling_shellQuote(doc))
    add(parts, "; ")
    add(parts, "formal_doc=")
    add(parts, tooling_shellQuote(formalDoc))
    add(parts, "; ")
    add(parts, "tooling_doc=")
    add(parts, tooling_shellQuote(toolingDoc))
    add(parts, "; ")
    add(parts, "verify_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; ")
    add(parts, "closedloop_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; ")
    add(parts, "prod_closure_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; ")
    add(parts, "for required in \"$doc\" \"$formal_doc\" \"$tooling_doc\" \"$verify_script\" \"$closedloop_script\" \"$prod_closure_script\"; do ")
    add(parts, "if [ ! -f \"$required\" ]; then echo \"[build_backend_rawptr_contract] missing file: $required\" >&2; exit 2; fi; ")
    add(parts, "done; ")
    add(parts, "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_rawptr_contract_markers.XXXXXX\")\"; ")
    add(parts, "tmp_required_gates=\"$(mktemp \"${TMPDIR:-/tmp}/backend_rawptr_contract_required.XXXXXX\")\"; ")
    add(parts, "cleanup() { rm -f \"$tmp_markers\" \"$tmp_required_gates\"; }; ")
    add(parts, "trap cleanup EXIT; ")
    add(parts, "{ ")
    add(parts, "rg -o 'rawptr_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$doc\" || true; ")
    add(parts, "rg -o 'rawptr_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$formal_doc\" || true; ")
    add(parts, "rg -o 'rawptr_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$tooling_doc\" || true; ")
    add(parts, "} | LC_ALL=C sort -u >\"$tmp_markers\"; ")
    add(parts, "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; ")
    add(parts, "if [ \"$marker_count\" -eq 0 ]; then echo \"[build_backend_rawptr_contract] no rawptr contract markers found\" >&2; exit 2; fi; ")
    add(parts, "contract_version=\"$(read_marker_value \"$doc\" 'rawptr_contract\\.version')\"; ")
    add(parts, "if [ \"$contract_version\" = \"\" ]; then echo \"[build_backend_rawptr_contract] missing rawptr_contract.version marker in: $doc\" >&2; exit 2; fi; ")
    add(parts, "doc_scheme_id=\"$(require_marker_value \"$doc\" 'rawptr_contract\\.scheme\\.id' 'rawptr_contract.scheme.id' 'ZRPC')\"; ")
    add(parts, "doc_scheme_name=\"$(require_marker_value \"$doc\" 'rawptr_contract\\.scheme\\.name' 'rawptr_contract.scheme.name' 'zero_rawptr_production_closure')\"; ")
    add(parts, "doc_scheme_normative=\"$(require_marker_value \"$doc\" 'rawptr_contract\\.scheme\\.normative' 'rawptr_contract.scheme.normative' '1')\"; ")
    add(parts, "doc_enforce_mode=\"$(require_marker_value \"$doc\" 'rawptr_contract\\.enforce\\.mode' 'rawptr_contract.enforce.mode' 'hard_fail')\"; ")
    add(parts, "require_marker_value \"$formal_doc\" 'rawptr_contract\\.scheme\\.id' 'rawptr_contract.scheme.id' 'ZRPC' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'rawptr_contract\\.scheme\\.name' 'rawptr_contract.scheme.name' 'zero_rawptr_production_closure' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'rawptr_contract\\.scheme\\.normative' 'rawptr_contract.scheme.normative' '1' >/dev/null; ")
    add(parts, "require_marker_value \"$formal_doc\" 'rawptr_contract\\.enforce\\.mode' 'rawptr_contract.enforce.mode' 'hard_fail' >/dev/null; ")
    add(parts, "if ! rg -q 'rawptr_contract\\.formal_spec\\.synced=1' \"$formal_doc\"; then echo \"[build_backend_rawptr_contract] missing formal spec sync marker: $formal_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'rawptr_contract\\.tooling_readme\\.synced=1' \"$tooling_doc\"; then echo \"[build_backend_rawptr_contract] missing tooling README sync marker: $tooling_doc\" >&2; exit 2; fi; ")
    add(parts, "annotation_count=\"$(rg -o 'rawptr_contract\\.annotation\\.[a-z0-9_]+=[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; ")
    add(parts, "forbid_count=\"$(rg -o 'rawptr_contract\\.forbid\\.[a-z0-9_]+=[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; ")
    add(parts, "rg -o 'rawptr_contract\\.required_gate\\.[a-z0-9_.]+=1' \"$doc\" | sed -E 's/^rawptr_contract\\.required_gate\\.([a-z0-9_.]+)=1$/\\1/' | LC_ALL=C sort -u >\"$tmp_required_gates\"; ")
    add(parts, "required_gate_count=\"$(wc -l < \"$tmp_required_gates\" | tr -d ' ')\"; ")
    add(parts, "if [ \"$required_gate_count\" -eq 0 ]; then echo \"[build_backend_rawptr_contract] no required rawptr gates found in: $doc\" >&2; exit 2; fi; ")
    add(parts, "required_gates_csv=\"$(tr '\\n' ',' <\"$tmp_required_gates\" | sed -E 's/,+$//')\"; ")
    add(parts, "if [ \"$required_gates_csv\" = \"\" ]; then echo \"[build_backend_rawptr_contract] failed to compute required gate CSV\" >&2; exit 2; fi; ")
    add(parts, "marker_sha=\"$(hash_file \"$tmp_markers\")\"; ")
    add(parts, "doc_sha=\"$(hash_file \"$doc\")\"; ")
    add(parts, "formal_doc_sha=\"$(hash_file \"$formal_doc\")\"; ")
    add(parts, "tooling_doc_sha=\"$(hash_file \"$tooling_doc\")\"; ")
    add(parts, "verify_sha=\"$(hash_file \"$verify_script\")\"; ")
    add(parts, "closedloop_sha=\"$(hash_file \"$closedloop_script\")\"; ")
    add(parts, "prod_closure_sha=\"$(hash_file \"$prod_closure_script\")\"; ")
    add(parts, "out_dir=\"$(dirname \"$out\")\"; ")
    add(parts, "if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; ")
    add(parts, "{ ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_BASELINE_VERSION=1\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_DOC=$doc\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_FORMAL_DOC=$formal_doc\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_TOOLING_DOC=$tooling_doc\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_DOC_SHA256=$doc_sha\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_FORMAL_DOC_SHA256=$formal_doc_sha\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_TOOLING_DOC_SHA256=$tooling_doc_sha\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_VERSION=$contract_version\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_SCHEME_ID=$doc_scheme_id\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_SCHEME_NAME=$doc_scheme_name\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_SCHEME_NORMATIVE=$doc_scheme_normative\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_ENFORCE_MODE=$doc_enforce_mode\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_MARKER_COUNT=$marker_count\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_MARKER_SHA256=$marker_sha\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_ANNOTATION_COUNT=$annotation_count\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_FORBID_COUNT=$forbid_count\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_REQUIRED_GATE_COUNT=$required_gate_count\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_VERIFY_SCRIPT_SHA256=$verify_sha\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_CLOSEDLOOP_SHA256=$closedloop_sha\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_PROD_CLOSURE_SHA256=$prod_closure_sha\"; ")
    add(parts, "echo \"BACKEND_RAWPTR_CONTRACT_REQUIRED_GATES=$required_gates_csv\"; ")
    add(parts, "} >\"$out\"; ")
    add(parts, "echo \"backend rawptr contract baseline generated: $out\"")
    let cmd: str = tooling_joinFragments(parts)
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdBuildBackendRawptrContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let args: str[] = tooling_argsRange(firstArgIndex, count)
    for i in 0..<args.len:
        let arg: str = args[i]
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build_backend_rawptr_contract options:")
            tooling_printOut("  --out:<path>         output baseline env")
            tooling_printOut("  --doc:<path>         raw-pointer contract doc")
            tooling_printOut("  --formal-doc:<path>  formal spec doc")
            tooling_printOut("  --tooling-doc:<path> tooling README")
            return 0
        if strutil.startsWith(arg, "--out:") ||
           strutil.startsWith(arg, "--doc:") ||
           strutil.startsWith(arg, "--formal-doc:") ||
           strutil.startsWith(arg, "--tooling-doc:"):
            continue
        tooling_printErr("cheng_tooling: unknown build_backend_rawptr_contract arg: " + arg)
        return 2
    return tooling_cmdBuildBackendRawptrContract(
        root,
        tooling_argsReadPrefixedValue(args, "--out:", "src/tooling/backend_rawptr_contract.env"),
        tooling_argsReadPrefixedValue(args, "--doc:", "docs/raw-pointer-safety.md"),
        tooling_argsReadPrefixedValue(args, "--formal-doc:", "docs/cheng-formal-spec.md"),
        tooling_argsReadPrefixedValue(args, "--tooling-doc:", "src/tooling/README.md")
    )

fn tooling_cmdVerifyBackendRawptrContract(root: str, firstArgIndex: int32, count: int32): int32 =
    let scriptPath: str = tooling_pathAbsolute(root, "src/tooling/verify_backend_rawptr_contract_native.sh")
    if !tooling_strNonEmpty(scriptPath) || !os.fileExists(scriptPath):
        tooling_printErr("cheng_tooling: missing rawptr contract script: " + scriptPath)
        return 1
    let _count: int32 = count
    return tooling_runScript(root, scriptPath, firstArgIndex)

fn tooling_cmdRunRepoVerifyScriptFromArgs(root: str, scriptName: str, firstArgIndex: int32, count: int32): int32 =
    let scriptPath: str = tooling_pathAbsolute(root, "src/tooling/cheng_tooling_embedded_scripts/" + scriptName)
    if !tooling_strNonEmpty(scriptPath) || !os.fileExists(scriptPath):
        tooling_printErr("cheng_tooling: missing repo verify script: " + scriptPath)
        return 1
    let _count: int32 = count
    return tooling_runScript(root, scriptPath, firstArgIndex)

fn tooling_cmdVerifyBackendStage1Fixed0EnvsFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    return tooling_cmdRunRepoVerifyScriptFromArgs(
        root, "verify_backend_stage1_fixed0_envs.sh", firstArgIndex, count)

