        return 2
    let fnSchedOverrideRaw0: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_FN_SCHED", "")))
    if tooling_strNonEmpty(fnSchedOverrideRaw0) && !tooling_strEq(fnSchedOverrideRaw0, "ws"):
        tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_FN_SCHED=ws")
        return 2
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_DIRECT_EXE", ""))):
        tooling_printErr("cheng_tooling: build-backend-driver removed env BACKEND_BUILD_DRIVER_DIRECT_EXE (fixed=1)")
        return 2
    var parseMode: str = tooling_strNonEmpty(parseModeOverrideRaw0) ? parseModeOverrideRaw0 : "outline"
    var fnSchedText: str = "ws"
    var directExeText: str = "0"
    var incrementalText: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_INCREMENTAL", "0")
    var multiText: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_MULTI", tooling_buildDriverDefaultMulti(root))
    var multiForceText: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_MULTI_FORCE", tooling_buildDriverDefaultMulti(root))
    var stage1BuilderText: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_STAGE1_BUILDER", "stage1")
    var skipGlobalInitText: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_SKIP_GLOBAL_INIT", "0")
    var disableDupScanText: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_DISABLE_DUP_SCAN", "0")
    var skipFixupsText: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_SKIP_FIXUPS", "0")
    var skipNormalizeText: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_SKIP_NORMALIZE", "0")
    var genericModeText: str = "dict"
    var genericSpecBudgetText: str = "0"
    var genericLoweringText: str = "mir_dict"
    if fullRebuild:
        timeoutEnv = "BACKEND_BUILD_DRIVER_REBUILD_TIMEOUT"
        timeoutDefault = 60
        timeoutHintRaw = os.getEnvDefault(timeoutEnv, "")
        timeoutHintSec = tooling_clampCompileTimeoutSec(
            tooling_parseInt32Default(timeoutHintRaw, timeoutDefault))
        fullRebuildTightTimeoutProfile = timeoutHintSec <= 60 &&
            tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_TIGHT_TIMEOUT_PROFILE", "0"))
        let rebuildParseModeOverrideRaw: str = strutil.toLowerAscii(strutil.strip(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_PARSE_MODE", "")))
        if tooling_strNonEmpty(rebuildParseModeOverrideRaw) &&
           !tooling_strEq(rebuildParseModeOverrideRaw, "outline") &&
           !tooling_strEq(rebuildParseModeOverrideRaw, "full"):
            tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_REBUILD_PARSE_MODE=outline|full")
            return 2
        let rebuildFnSchedOverrideRaw: str = strutil.toLowerAscii(strutil.strip(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_FN_SCHED", "")))
        if tooling_strNonEmpty(rebuildFnSchedOverrideRaw) && !tooling_strEq(rebuildFnSchedOverrideRaw, "ws"):
            tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_REBUILD_FN_SCHED=ws")
            return 2
        if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_DIRECT_EXE", ""))):
            tooling_printErr("cheng_tooling: build-backend-driver removed env BACKEND_BUILD_DRIVER_REBUILD_DIRECT_EXE (fixed=1)")
            return 2
        parseMode = tooling_strNonEmpty(rebuildParseModeOverrideRaw) ? rebuildParseModeOverrideRaw : "full"
        fnSchedText = "ws"
        directExeText = "0"
        incrementalText = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_INCREMENTAL", "0")
        # Reference host full rebuild uses the proven parallel profile by
        # default; callers can still override via env for diagnostics.
        multiText = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_MULTI", tooling_buildDriverDefaultMulti(root))
        multiForceText = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_MULTI_FORCE", tooling_buildDriverDefaultMulti(root))
        # Full rebuild is hard-pinned to stage1 builder.
        stage1BuilderText = "stage1"
        skipGlobalInitText = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_SKIP_GLOBAL_INIT", skipGlobalInitText)
        disableDupScanText = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_DISABLE_DUP_SCAN", disableDupScanText)
        genericModeText = "dict"
        genericSpecBudgetText = "0"
        genericLoweringText = "mir_dict"
        # Full rebuild defaults to semantic-complete UIR passes for runtime safety.
        skipFixupsText = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_SKIP_FIXUPS", "0")
        # Full rebuild defaults to semantic-complete UIR passes for runtime safety.
        skipNormalizeText = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_SKIP_NORMALIZE", "0")
    if !fullRebuild:
        parseMode = tooling_strNonEmpty(parseModeOverrideRaw0) ? parseModeOverrideRaw0 : "outline"
    fnSchedText = "ws"
    let directExePolicyVar: str = fullRebuild ? "BACKEND_BUILD_DRIVER_REBUILD_DIRECT_EXE" : "BACKEND_BUILD_DRIVER_DIRECT_EXE"
    directExeText = tooling_bool01Normalized(directExeText)
    if tooling_strEq(linkerMode, "self"):
        if !tooling_strEq(directExeText, "1"):
            tooling_printErr("cheng_tooling: build-backend-driver requires " + directExePolicyVar + "=1 when BACKEND_BUILD_DRIVER_LINKER=self")
            return 2
    else:
        if !tooling_strEq(directExeText, "0"):
            directExeText = "0"
    if !tooling_strNonEmpty(incrementalText):
        incrementalText = fullRebuild ? "0" : "1"
    if !tooling_strNonEmpty(multiText):
        multiText = tooling_buildDriverDefaultMulti(root)
    if !tooling_strNonEmpty(multiForceText):
        multiForceText = tooling_buildDriverDefaultMulti(root)
    if !tooling_strNonEmpty(stage1BuilderText):
        stage1BuilderText = "stage1"
    if !tooling_strNonEmpty(skipGlobalInitText):
        skipGlobalInitText = "0"
    skipGlobalInitText = tooling_bool01Normalized(skipGlobalInitText)
    if !tooling_strEq(skipGlobalInitText, "0"):
        tooling_printErr("cheng_tooling: build-backend-driver requires BACKEND_BUILD_DRIVER_SKIP_GLOBAL_INIT=0 " +
                         "(and BACKEND_BUILD_DRIVER_REBUILD_SKIP_GLOBAL_INIT=0) for runtime-safe output")
        return 2
    if !tooling_strNonEmpty(disableDupScanText):
        disableDupScanText = "0"
    disableDupScanText = tooling_bool01Normalized(disableDupScanText)
    if !tooling_strNonEmpty(skipFixupsText):
        skipFixupsText = "0"
    skipFixupsText = tooling_bool01Normalized(skipFixupsText)
    if !tooling_strNonEmpty(skipNormalizeText):
        skipNormalizeText = "0"
    skipNormalizeText = tooling_bool01Normalized(skipNormalizeText)
    if fullRebuild && !tooling_strEq(strutil.toLowerAscii(strutil.strip(stage1BuilderText)), "stage1"):
        stage1BuilderText = "stage1"
    if !tooling_strNonEmpty(genericModeText):
        genericModeText = "dict"
    if !tooling_strNonEmpty(genericSpecBudgetText):
        genericSpecBudgetText = "0"
    if !tooling_strNonEmpty(genericLoweringText):
        genericLoweringText = "mir_dict"
    let genericModeOverrideRaw0: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(genericModeOverrideRaw0):
        tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_GENERIC_MODE=dict")
        return 2
    let genericModeOverrideRaw: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(genericModeOverrideRaw):
        tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_REBUILD_GENERIC_MODE=dict")
        return 2
    let genericLoweringOverrideRaw0: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_GENERIC_LOWERING", "")
    if !tooling_genericLoweringIsDictOnly(genericLoweringOverrideRaw0):
        tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_GENERIC_LOWERING=mir_dict")
        return 2
    let genericLoweringOverrideRaw: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_GENERIC_LOWERING", "")
    if !tooling_genericLoweringIsDictOnly(genericLoweringOverrideRaw):
        tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_REBUILD_GENERIC_LOWERING=mir_dict")
        return 2
    var timeoutText: str = os.getEnvDefault(timeoutEnv, "")
    if !tooling_strNonEmpty(timeoutText):
        timeoutText = os.getEnvDefault("SELF_OBJ_BOOTSTRAP_TIMEOUT", "")
    var timeoutSec: int32 = tooling_parseInt32Default(timeoutText, timeoutDefault)
    if timeoutSec < 1:
        timeoutSec = timeoutDefault
    if fullRebuild && fullRebuildTightTimeoutProfile:
        if !tooling_strNonEmpty(rebuildJobsRaw) && !tooling_strNonEmpty(jobsText):
            jobs = tooling_parseInt32Default(
                os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_DEFAULT_JOBS",
                                 intToStr(tooling_buildDriverDefaultJobs(root))),
                tooling_buildDriverDefaultJobs(root))
        let logEveryCall: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_DRIVER_TIGHT_PROFILE_LOG_EVERY_CALL", "0"))
        if !tooling_buildDriverTightProfileLogShown || logEveryCall:
            tooling_printErr("cheng_tooling: full rebuild using tight-timeout profile (parse=" + parseMode +
                             ", fn_sched=" + fnSchedText + ", skip_sem=0, skip_ownership=0, skip_fixups=" +
                             skipFixupsText + ", skip_normalize=" + skipNormalizeText +
                             ", skip_global_init=" + skipGlobalInitText +
                             ", disable_dup_scan=" + disableDupScanText + ")")
            tooling_printErr("cheng_tooling: full rebuild tight-timeout jobs=" + intToStr(jobs))
            tooling_buildDriverTightProfileLogShown = true
    let compileModeText: str = fullRebuild ? "full" : "quick"
    let profileEnabledFromEnv: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE", "0"))
    let profileOutRaw: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_OUT", "")
    var profileOutPath: str = ""
    if tooling_strNonEmpty(profileOutRaw):
        profileOutPath = tooling_pathAbsolute(root, profileOutRaw)
    let profileEnabled: bool = profileEnabledFromEnv || tooling_strNonEmpty(profileOutPath)
    let profileMode: str = tooling_buildDriverProfileMode()
    let profileFailOpen: bool = profileEnabled &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_FAIL_OPEN", "0"))
    var stampIgnoreStage0ShaEnv: str = ""
    if fullRebuild:
        let rebuildStampIgnoreDefault: str = fullRebuildTightTimeoutProfile ? "1" : "0"
