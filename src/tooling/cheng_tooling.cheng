fn tooling_cmdBuildBackendNativeContract(root: str, outFile: str, doc: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
            "echo \"[build_backend_native_contract] rg is required\" >&2; exit 2; " +
        "fi; " +
        "hash_file() { " +
          "file=\"$1\"; " +
          "if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; " +
          "if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; " +
          "cksum \"$file\" | awk '{print $1}'; " +
        "}; " +
        "doc=" + tooling_shellQuote(doc) + "; " +
        "out_file=" + tooling_shellQuote(outFile) + "; " +
        "driver_file=\"src/backend/tooling/backend_driver.cheng\"; " +
        "builder_file=\"src/backend/uir/uir_internal/uir_core_builder.cheng\"; " +
        "tooling_file=\"src/tooling/cheng_tooling.cheng\"; " +
        "for required in \"$doc\" \"$driver_file\" \"$builder_file\" \"$tooling_file\"; do " +
          "if [ ! -f \"$required\" ]; then " +
            "echo \"[build_backend_native_contract] missing file: $required\" >&2; exit 2; " +
          "fi; " +
        "done; " +
        "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_native_contract_markers.XXXXXX\")\"; " +
        "tmp_required=\"$(mktemp \"${TMPDIR:-/tmp}/backend_native_contract_required.XXXXXX\")\"; " +
        "cleanup() { rm -f \"$tmp_markers\" \"$tmp_required\"; }; " +
        "trap cleanup EXIT; " +
        "rg -o 'native_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u >\"$tmp_markers\"; " +
        "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; " +
        "if [ \"$marker_count\" -eq 0 ]; then " +
          "echo \"[build_backend_native_contract] no native contract markers found in: $doc\" >&2; exit 2; " +
        "fi; " +
        "contract_version=\"$(rg -o 'native_contract\\.version=[0-9]+' \"$doc\" | head -n 1 | cut -d= -f2 || true)\"; " +
        "scheme_id=\"$(rg -o 'native_contract\\.scheme\\.id=[A-Za-z0-9_]+' \"$doc\" | head -n 1 | cut -d= -f2 || true)\"; " +
        "scheme_name=\"$(rg -o 'native_contract\\.scheme\\.name=[A-Za-z0-9_]+' \"$doc\" | head -n 1 | cut -d= -f2 || true)\"; " +
        "scheme_normative=\"$(rg -o 'native_contract\\.scheme\\.normative=[0-9]+' \"$doc\" | head -n 1 | cut -d= -f2 || true)\"; " +
        "enforce_mode=\"$(rg -o 'native_contract\\.enforce\\.mode=[A-Za-z0-9_]+' \"$doc\" | head -n 1 | cut -d= -f2 || true)\"; " +
        "if [ \"$contract_version\" = \"\" ] || [ \"$scheme_id\" = \"\" ] || [ \"$scheme_name\" = \"\" ] || [ \"$scheme_normative\" = \"\" ] || [ \"$enforce_mode\" = \"\" ]; then " +
          "echo \"[build_backend_native_contract] missing required contract markers in: $doc\" >&2; exit 2; " +
        "fi; " +
        "if [ \"$scheme_id\" != \"CNC\" ] || [ \"$scheme_name\" != \"cheng_native_contract\" ] || [ \"$scheme_normative\" != \"1\" ] || [ \"$enforce_mode\" != \"hard_fail\" ]; then " +
          "echo \"[build_backend_native_contract] CNC normative markers must be CNC/cheng_native_contract/normative=1/hard_fail\" >&2; exit 2; " +
        "fi; " +
        "pillar_count=\"$(rg -o 'native_contract\\.pillar\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; " +
        "rg -o 'native_contract\\.required_gate\\.[a-z0-9_.]+=1' \"$doc\" | sed -E 's/^native_contract\\.required_gate\\.([a-z0-9_.]+)=1$/\\1/' | LC_ALL=C sort -u >\"$tmp_required\"; " +
        "required_gate_count=\"$(wc -l < \"$tmp_required\" | tr -d ' ')\"; " +
        "if [ \"$required_gate_count\" -eq 0 ]; then " +
          "echo \"[build_backend_native_contract] no required gates found in: $doc\" >&2; exit 2; " +
        "fi; " +
        "required_gates_csv=\"$(tr '\\n' ',' <\"$tmp_required\" | sed -E 's/,+$//')\"; " +
        "if [ \"$required_gates_csv\" = \"\" ]; then " +
          "echo \"[build_backend_native_contract] failed to compute required gate list\" >&2; exit 2; " +
        "fi; " +
        "doc_sha=\"$(hash_file \"$doc\")\"; " +
        "marker_sha=\"$(hash_file \"$tmp_markers\")\"; " +
        "tooling_sha=\"$(hash_file \"$tooling_file\")\"; " +
        "driver_sha=\"$(hash_file \"$driver_file\")\"; " +
        "builder_sha=\"$(hash_file \"$builder_file\")\"; " +
        "out_dir=\"$(dirname \"$out_file\")\"; " +
        "if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; " +
        "{ " +
          "echo \"BACKEND_NATIVE_CONTRACT_BASELINE_VERSION=1\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_DOC=$doc\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_DOC_SHA256=$doc_sha\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_VERSION=$contract_version\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_SCHEME_ID=$scheme_id\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_SCHEME_NAME=$scheme_name\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_SCHEME_NORMATIVE=$scheme_normative\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_ENFORCE_MODE=$enforce_mode\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_MARKER_COUNT=$marker_count\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_MARKER_SHA256=$marker_sha\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_PILLAR_COUNT=$pillar_count\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_REQUIRED_GATE_COUNT=$required_gate_count\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_VERIFY_SCRIPT_SHA256=$tooling_sha\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_CLOSEDLOOP_SHA256=$tooling_sha\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_PROD_CLOSURE_SHA256=$tooling_sha\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_DRIVER_SHA256=$driver_sha\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_UIR_BUILDER_SHA256=$builder_sha\"; " +
          "echo \"BACKEND_NATIVE_CONTRACT_REQUIRED_GATES=$required_gates_csv\"; " +
        "} >\"$out_file\"; " +
        "echo \"backend native contract baseline generated: $out_file\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdBuildBackendNativeContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var outFile: str = "src/tooling/backend_native_contract.env"
    var doc: str = "docs/cheng-native-contract.md"
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build_backend_native_contract options:")
            tooling_printOut("  --out:<path>   output baseline env (default src/tooling/backend_native_contract.env)")
            tooling_printOut("  --doc:<path>   source contract doc (default docs/cheng-native-contract.md)")
            return 0
        if strutil.startsWith(arg, "--out:"):
            outFile = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--doc:"):
            doc = strings.dropPrefix(arg, "--doc:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown build_backend_native_contract arg: " + arg)
        return 2
    return tooling_cmdBuildBackendNativeContract(root, outFile, doc)

fn tooling_cmdBuildBackendBaselines(root: str): int32 =
    let ids: str[] = [
        "build_backend_rawptr_contract",
        "build_backend_mem_contract",
        "build_backend_dod_contract",
        "build_backend_native_contract",
        "build_backend_profile_schema",
        "build_backend_profile_baseline",
    ]
    let argStart: int32 = tooling_paramCount() + 1
    for i in 0..<ids.len:
        let id: str = ids[i]
        let scriptPath: str = tooling_resolveScriptPath(root, id)
        if !tooling_strNonEmpty(scriptPath):
            tooling_printErr("cheng_tooling: missing embedded baseline builder: " + id)
            return 1
        tooling_printOut("build_backend_baselines_step=" + id)
        let rc: int32 = tooling_runScript(root, scriptPath, argStart)
        if rc != 0:
            tooling_printErr("cheng_tooling: baseline step failed id=" + id +
                             " rc=" + intToStr(rc) +
                             " kind=" + tooling_exitKind(rc))
            return rc
    tooling_printOut("build_backend_baselines ok")
    return 0

fn tooling_cmdInfantSpeakResolveAiRoot(): str =
    let envRoot: str = strutil.strip(os.getEnvDefault("AI_ROOT", ""))
    if tooling_strNonEmpty(envRoot):
        return envRoot
    let home: str = strutil.strip(os.getEnvDefault("HOME", ""))
    if !tooling_strNonEmpty(home):
        return ""
    return os.joinPath(home, ".cheng-packages/cheng-ai")

fn tooling_cmdInfantSpeakFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var argStart: int32 = firstArgIndex
    if argStart < 1:
        argStart = 1
    for i in argStart..count:
        let a: str = tooling_paramStr(i)
        if tooling_strEq(a, "--help") || tooling_strEq(a, "-h") || tooling_strEq(a, "help"):
            tooling_printOut("infant-speak options:")
            tooling_printOut("  --text:<text>           input text (default: 爸爸，妈妈)")
            tooling_printOut("  --out-wav:<path>        output wav path (default: state.infant_speak.wav)")
            tooling_printOut("  --out-json:<path>       output report path (default: state.infant_speak_report.json)")
            tooling_printOut("  --sample-rate:<hz>      8000|16000|22050 (default 16000)")
            tooling_printOut("  --syllable-ms:<ms>      syllable duration in ms (default 170)")
            tooling_printOut("  --pause-ms:<ms>         pause duration in ms (default 70)")
            tooling_printOut("  env: AI_ROOT=<cheng-ai-repo-path>")
            return 0

    let aiRoot: str = tooling_cmdInfantSpeakResolveAiRoot()
    if !tooling_strNonEmpty(aiRoot):
        tooling_printErr("cheng_tooling: infant-speak cannot resolve AI_ROOT")
        return 1
    let entryPath: str = os.joinPath(aiRoot, "src/wxl_tool_infant_speak_main.cheng")
    if !tooling_pathExists(entryPath):
        tooling_printErr("cheng_tooling: infant-speak entry not found: " + entryPath)
        tooling_printErr("  hint: set AI_ROOT to your cheng-ai repository path")
        return 1

    let outDir: str = tooling_pathAbsolute(root, "artifacts/tooling_tmp/infant_speak")
    os.createDir(outDir)
    let outBin: str = os.joinPath(outDir, "cheng_ai_infant_speak")

    var toolBin: str = strutil.strip(tooling_paramStr(0))
    if !tooling_strNonEmpty(toolBin) || !tooling_pathExists(toolBin):
        let canonicalTool: str = tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling")
        if tooling_isExecutable(root, canonicalTool):
            toolBin = canonicalTool
    if !tooling_strNonEmpty(toolBin):
        toolBin = "cheng_tooling"

    let compileCmd: str =
        tooling_shellQuote(toolBin) +
        " cheng --in:" + tooling_shellQuote(entryPath) +
        " --out:" + tooling_shellQuote(outBin)
    let compileRes: os.ExecCmdResult = tooling_exec(root, compileCmd)
    tooling_printExecOutput(compileRes)
    let compileRc: int32 = os.execCmdResultExitCode(compileRes)
    if compileRc != 0:
        tooling_printErr("cheng_tooling: infant-speak compile failed rc=" + intToStr(compileRc))
        return compileRc

    var runCmd: str = tooling_shellQuote(outBin)
    for i in argStart..count:
        runCmd = runCmd + " " + tooling_shellQuote(tooling_paramStr(i))
    let runRes: os.ExecCmdResult = tooling_exec(root, runCmd)
    tooling_printExecOutput(runRes)
    return os.execCmdResultExitCode(runRes)

