fn tooling_cmdVerifyStdBaseline(root: str): int32 =
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_baseline", true)
    if ctx == nil:
        return 1
    let toolBin: str = tooling_stdToolBinary(root)
    if !tooling_isExecutable(root, toolBin):
        tooling_printErr("[std_baseline] missing tooling binary: " + toolBin)
        return 1
    let gateIds: str[] = [
        "verify_std_layout_sync",
        "verify_std_foundation",
        "verify_std_string_json",
        "verify_std_file_io",
        "verify_std_net_io"
    ]
    var rc: int32 = 0
    for i in 0..<gateIds.len:
        if rc != 0:
            break
        let gateId: str = gateIds[i]
        let logPath: str = os.joinPath(ctx.workDir, gateId + ".log")
        let subRes: os.ExecCmdResult = tooling_stdRunToolingSubcommandLogged(root, toolBin, gateId, 0, logPath)
        if !tooling_stdEnsureCommandOk(root, ctx, toolBin + " " + gateId, logPath, subRes):
            rc = 1
    var status: str = "ok"
    if rc != 0:
        status = "failed"
    var reportText: str = ""
    reportText = reportText + "result=" + status + "\n"
    reportText = reportText + "driver=" + ctx.driverPath + "\n"
    reportText = reportText + "layout_log=" + os.joinPath(ctx.finalOutDir, "verify_std_layout_sync.log") + "\n"
    reportText = reportText + "foundation_log=" + os.joinPath(ctx.finalOutDir, "verify_std_foundation.log") + "\n"
    reportText = reportText + "string_json_log=" + os.joinPath(ctx.finalOutDir, "verify_std_string_json.log") + "\n"
    reportText = reportText + "file_io_log=" + os.joinPath(ctx.finalOutDir, "verify_std_file_io.log") + "\n"
    reportText = reportText + "net_io_log=" + os.joinPath(ctx.finalOutDir, "verify_std_net_io.log") + "\n"
    if !tooling_stdWriteReportAndPublish(root, ctx, reportText):
        return 1
    if rc == 0:
        tooling_printOut("verify_std_baseline ok")
    return rc

fn tooling_cmdVerifyStdDocsExamples(root: str): int32 =
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_docs_examples", true)
    if ctx == nil:
        return 1
    let docsList: str[] = [
        "docs/stdlib/foundation.md",
        "docs/stdlib/string-json.md",
        "docs/stdlib/file-io.md",
        "docs/stdlib/net-io.md"
    ]
    var rc: int32 = 0
    var docsCount: int32 = 0
    for i in 0..<docsList.len:
        if rc != 0:
            break
        let docRel: str = docsList[i]
        let docPath: str = tooling_pathAbsolute(root, docRel)
        if !tooling_stdRequireFile(ctx.gateName, docPath):
            rc = 1
            break
        let docText: str = tooling_readTextFile(root, docPath)
        if !tooling_strNonEmpty(tooling_stdDocFieldValue(docText, "Modules:")):
            tooling_printErr("[std_docs_examples] doc missing Modules: " + docRel)
            rc = 1
            break
        if !tooling_strNonEmpty(tooling_stdDocFieldValue(docText, "Key APIs:")):
            tooling_printErr("[std_docs_examples] doc missing Key APIs: " + docRel)
            rc = 1
            break
        var exampleRel: str = tooling_stdDocFieldValue(docText, "Example:")
        exampleRel = strutil.replace(exampleRel, "`", "")
        if !tooling_strNonEmpty(exampleRel):
            tooling_printErr("[std_docs_examples] doc missing Example: " + docRel)
            rc = 1
            break
        let exampleSrc: str = tooling_pathAbsolute(root, exampleRel)
        let split: os.SplitFileResult = os.splitFile(exampleSrc)
        let expectedPath: str = os.joinPath(split.dir, split.name + ".expected.txt")
        if !tooling_stdRequireFile(ctx.gateName, exampleSrc) || !tooling_stdRequireFile(ctx.gateName, expectedPath):
            rc = 1
            break
        let exampleName: str = split.name
        let outPath: str = os.joinPath(ctx.workDir, exampleName)
        let compileLog: str = os.joinPath(ctx.workDir, exampleName + ".compile.log")
        let runLog: str = os.joinPath(ctx.workDir, exampleName + ".run.log")
        if !tooling_stdCompileSource(root, ctx, exampleSrc, outPath, compileLog):
            rc = 1
            break
        var envOverrides: str[] = []
        if tooling_strEq(exampleName, "file_io"):
            let runtimeDir: str = os.joinPath(ctx.workDir, "example_runtime_" + exampleName)
            tooling_envAssignCollect(envOverrides, "EXAMPLE_STD_TMPDIR", runtimeDir)
        if !tooling_stdRunCompiledBinary(root, ctx, outPath, runLog, envOverrides):
            rc = 1
            break
        if !tooling_stdFilesEqual(root, expectedPath, runLog):
            tooling_printErr("[std_docs_examples] example output mismatch: " + exampleRel +
                             " (expected=" + expectedPath + " actual=" + runLog + ")")
            rc = 1
            break
        docsCount = docsCount + 1
    var status: str = "ok"
    if rc != 0:
        status = "failed"
    var reportText: str = ""
    reportText = reportText + "result=" + status + "\n"
    reportText = reportText + "driver=" + ctx.driverPath + "\n"
    reportText = reportText + "docs_count=" + intToStr(docsCount) + "\n"
    reportText = reportText + "foundation_doc=docs/stdlib/foundation.md\n"
    reportText = reportText + "string_json_doc=docs/stdlib/string-json.md\n"
    reportText = reportText + "file_io_doc=docs/stdlib/file-io.md\n"
    reportText = reportText + "net_io_doc=docs/stdlib/net-io.md\n"
    if !tooling_stdWriteReportAndPublish(root, ctx, reportText):
        return 1
    if rc == 0:
        tooling_printOut("verify_std_docs_examples ok")
    return rc

fn tooling_cmdVerifyStdStability(root: str): int32 =
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_stability", true)
    if ctx == nil:
        return 1
    let rounds: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_STABILITY_ROUNDS", ""), 3)
    let timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_STABILITY_TIMEOUT", ""), 180)
    let requireStability: bool = tooling_isTrue(os.getEnvDefault("STD_STABILITY_REQUIRE", "0"))
    let toolBin: str = tooling_stdToolBinary(root)
    if !tooling_isExecutable(root, toolBin):
        tooling_printErr("[std_stability] missing tooling binary: " + toolBin)
        return 1
    let gateIds: str[] = ["verify_std_baseline", "verify_std_docs_examples"]
    var refRcs: str[] = []
    var refHashes: str[] = []
    setLen(refRcs, gateIds.len)
    setLen(refHashes, gateIds.len)
    var status: str = "ok"
    var summaryText: str = "gate_id\tround\trc\thash\n"
    var round: int32 = 1
    while round <= rounds:
        for i in 0..<gateIds.len:
            let gateId: str = gateIds[i]
            let logPath: str = os.joinPath(ctx.workDir, gateId + ".round" + intToStr(round) + ".log")
            let runRes: os.ExecCmdResult = tooling_stdRunToolingSubcommandLogged(root, toolBin, gateId, timeoutSec, logPath)
            let childRc: int32 = os.execCmdResultExitCode(runRes)
            let rcText: str = intToStr(childRc)
            var hash: str = ""
            if os.fileExists(logPath):
                hash = tooling_stdStableHashFile(root, logPath)
            summaryText = summaryText + gateId + "\t" + intToStr(round) + "\t" + rcText + "\t" + hash + "\n"
            if round == 1:
                refRcs[i] = rcText
                refHashes[i] = hash
            elif (rcText != refRcs[i] || hash != refHashes[i]) && tooling_strEq(status, "ok"):
                status = "drift"
            if childRc != 0:
                status = "failed"
        round = round + 1
    let summaryPath: str = os.joinPath(ctx.workDir, "summary.tsv")
    if !tooling_stdWriteTextFile(root, summaryPath, summaryText):
        tooling_printErr("[std_stability] failed to write summary: " + summaryPath)
        return 1
    var reportText: str = ""
    reportText = reportText + "result=" + status + "\n"
    reportText = reportText + "rounds=" + intToStr(rounds) + "\n"
    reportText = reportText + "timeout_s=" + intToStr(timeoutSec) + "\n"
    reportText = reportText + "require=" + (requireStability ? "1" : "0") + "\n"
    reportText = reportText + "summary=" + os.joinPath(ctx.finalOutDir, "summary.tsv") + "\n"
    if !tooling_stdWriteReportAndPublish(root, ctx, reportText):
        return 1
    if !tooling_strEq(status, "ok") && requireStability:
        tooling_printErr("[verify_std_stability] fail: status=" + status +
                         " (report=" + os.joinPath(ctx.finalOutDir, "std_stability.report.txt") + ")")
        return 1
    if !tooling_strEq(status, "ok"):
        tooling_printErr("[verify_std_stability] soft fail: status=" + status +
                         " (report=" + os.joinPath(ctx.finalOutDir, "std_stability.report.txt") + ")")
    tooling_printOut("verify_std_stability ok")
    return 0

fn tooling_cmdBuildStdPerfBaselineFromArgs(root: str, argStart: int32, count: int32): int32 =
    var outRaw: str = "src/tooling/std_perf_baseline.env"
    var i: int32 = argStart
    for _ in argStart..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("Usage:")
            tooling_printOut("  " + tooling_stdToolBinary(root) + " build_std_perf_baseline [--out:<path>]")
            tooling_printOut("")
            tooling_printOut("Notes:")
            tooling_printOut("  - Builds a report-only stdlib perf baseline.")
            tooling_printOut("  - Default output: src/tooling/std_perf_baseline.env")
            return 0
        if strutil.startsWith(arg, "--out:"):
            outRaw = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        tooling_printErr("[build_std_perf_baseline] unknown arg: " + arg)
        return 2
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_perf_build", true)
    if ctx == nil:
        return 1
    let warmups: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_WARMUPS", ""), 2)
    let measureRuns: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MEASURE_RUNS", ""), 5)
    let timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_TIMEOUT", ""), 30)
    let memoryIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MEMORY_ITERS", ""), 400)
    let fileIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_FILE_ITERS", ""), 80)
    let udpIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_UDP_ITERS", ""), 16)
    let maxSlowdownPct: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MAX_SLOWDOWN_PERCENT", ""), 10)
    let memoryCases: str[] = ["strings", "strformat", "rawbytes", "seqs", "json", "hashmaps"]
    let memorySrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_memory_bench.cheng")
    let fileSrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_file_io_bench.cheng")
    let udpSrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_udp_witness.cheng")
    if !tooling_stdRequireFile(ctx.gateName, memorySrc) || !tooling_stdRequireFile(ctx.gateName, fileSrc) ||
       !tooling_stdRequireFile(ctx.gateName, udpSrc):
        return 1
    let memoryBin: str = os.joinPath(ctx.workDir, "std_perf_memory_bench")
    let memoryCompileLog: str = os.joinPath(ctx.workDir, "std_perf_memory_bench.compile.log")
    let fileBin: str = os.joinPath(ctx.workDir, "std_perf_file_io_bench")
    let fileCompileLog: str = os.joinPath(ctx.workDir, "std_perf_file_io_bench.compile.log")
    let udpBin: str = os.joinPath(ctx.workDir, "std_perf_udp_witness")
    let udpCompileLog: str = os.joinPath(ctx.workDir, "std_perf_udp_witness.compile.log")
    var rc: int32 = 0
    if rc == 0 && !tooling_stdCompileSource(root, ctx, memorySrc, memoryBin, memoryCompileLog):
        rc = 1
    if rc == 0 && !tooling_stdCompileSource(root, ctx, fileSrc, fileBin, fileCompileLog):
        rc = 1
    let udpCompileRc: int32 = tooling_stdCompileSourceResult(root, ctx, udpSrc, udpBin, udpCompileLog)
    let udpBinReady: bool = udpCompileRc == 0
    var baselineText: str = ""
    baselineText = baselineText + "STD_PERF_BASELINE_VERSION=1\n"
    baselineText = baselineText + "STD_PERF_DRIVER=" + ctx.driverPath + "\n"
    baselineText = baselineText + "STD_PERF_WARMUPS=" + intToStr(warmups) + "\n"
    baselineText = baselineText + "STD_PERF_MEASURE_RUNS=" + intToStr(measureRuns) + "\n"
    baselineText = baselineText + "STD_PERF_MAX_SLOWDOWN_PERCENT=" + intToStr(maxSlowdownPct) + "\n"
    baselineText = baselineText + "STD_PERF_MEMORY_CASES=strings,strformat,rawbytes,seqs,json,hashmaps\n"
    baselineText = baselineText + "STD_PERF_SKIPPED_CASES=tables\n"
    baselineText = baselineText + "STD_PERF_WITNESS_CASES=file_io,udp_loopback\n"
    if rc == 0:
        for i in 0..<memoryCases.len:
            let caseId: str = memoryCases[i]
            let caseRes: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
                root, ctx.workDir, memoryBin, caseId, memoryIters, warmups, measureRuns, timeoutSec, false)
            if !tooling_strEq(caseRes.status, "ok"):
                tooling_printErr("[build_std_perf_baseline] perf case failed: " + caseId +
                                 " status=" + caseRes.status + " note=" + caseRes.note)
                rc = 1
                break
            tooling_stdPerfAppendEnv(baselineText, caseId, caseRes)
        if rc == 0:
            let fileRes: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
                root, ctx.workDir, fileBin, "file_io", fileIters, warmups, measureRuns, timeoutSec, false)
            if !tooling_strEq(fileRes.status, "ok"):
                tooling_printErr("[build_std_perf_baseline] perf case failed: file_io status=" +
                                 fileRes.status + " note=" + fileRes.note)
                rc = 1
            else:
                tooling_stdPerfAppendEnv(baselineText, "file_io", fileRes)
    let tablesRes: ToolingStdPerfCaseResult = tooling_stdPerfCaseResult("skipped", 0, "", "table_symbols_unavailable")
    tooling_stdPerfAppendEnv(baselineText, "tables", tablesRes)
    if udpBinReady:
        let udpRes: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
            root, ctx.workDir, udpBin, "udp_loopback", udpIters, warmups, measureRuns, timeoutSec, true)
        tooling_stdPerfAppendEnv(baselineText, "udp_loopback", udpRes)
    else:
        let udpRes: ToolingStdPerfCaseResult = tooling_stdPerfCaseResult("skipped", 0, "", "compile_failed")
        tooling_stdPerfAppendEnv(baselineText, "udp_loopback", udpRes)
    let outPath: str = tooling_pathAbsolute(root, outRaw)
    let outDir: str = os.parentDir(outPath)
    if rc == 0 && tooling_strNonEmpty(outDir) && !tooling_stdMkdirPNative(root, outDir):
        tooling_printErr("[build_std_perf_baseline] failed to create output dir: " + outDir)
        rc = 1
    if rc == 0 && !tooling_stdWriteTextFile(root, outPath, baselineText):
        tooling_printErr("[build_std_perf_baseline] failed to write baseline: " + outPath)
        rc = 1
    var status: str = "ok"
    if rc != 0:
        status = "failed"
    var reportText: str = ""
    reportText = reportText + "result=" + status + "\n"
    reportText = reportText + "baseline_out=" + outPath + "\n"
    reportText = reportText + "driver=" + ctx.driverPath + "\n"
    reportText = reportText + "memory_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(memoryCompileLog)) + "\n"
    reportText = reportText + "file_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(fileCompileLog)) + "\n"
    reportText = reportText + "udp_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(udpCompileLog)) + "\n"
    if !tooling_stdWriteReportAndPublish(root, ctx, reportText):
        return 1
    if rc == 0:
        tooling_printOut("build_std_perf_baseline ok")
    return rc

fn tooling_cmdVerifyStdPerfBaselineFromArgs(root: str, argStart: int32, count: int32): int32 =
    var i: int32 = argStart
    for _ in argStart..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("Usage:")
            tooling_printOut("  " + tooling_stdToolBinary(root) + " verify_std_perf_baseline [--help]")
            tooling_printOut("")
            tooling_printOut("Env:")
            tooling_printOut("  STD_PERF_BASELINE=<path>      Baseline env file (default: src/tooling/std_perf_baseline.env)")
            tooling_printOut("  STD_PERF_REQUIRE=<0|1>        Fail on regression/drift when set to 1 (default: 0)")
            tooling_printOut("")
            tooling_printOut("Notes:")
            tooling_printOut("  - This command is report-only by default.")
            tooling_printOut("  - Deterministic memory cases use a 10% slowdown threshold from the baseline.")
            tooling_printOut("  - File and UDP cases are witness-only and do not gate by default.")
            return 0
        tooling_printErr("[verify_std_perf_baseline] unknown arg: " + arg)
        return 2
    let ctx: ToolingStdGateContext = tooling_stdInitGate(root, "std_perf", true)
    if ctx == nil:
        return 1
    let baselineFile: str = tooling_pathAbsolute(root, os.getEnvDefault("STD_PERF_BASELINE", "src/tooling/std_perf_baseline.env"))
    if !tooling_stdRequireFile(ctx.gateName, baselineFile):
        return 1
    let baselineText: str = tooling_readTextFile(root, baselineFile)
    let warmups: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_WARMUPS", ""), 2)
    let measureRuns: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MEASURE_RUNS", ""), 5)
    let timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_TIMEOUT", ""), 30)
    let memoryIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MEMORY_ITERS", ""), 400)
    let fileIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_FILE_ITERS", ""), 80)
    let udpIters: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_UDP_ITERS", ""), 16)
    let maxSlowdownPct: int32 = tooling_parseInt32Default(os.getEnvDefault("STD_PERF_MAX_SLOWDOWN_PERCENT", ""), 10)
    let requirePerf: bool = tooling_isTrue(os.getEnvDefault("STD_PERF_REQUIRE", "0"))
    let memoryCases: str[] = tooling_stdCsvList(tooling_kvGet(baselineText, "STD_PERF_MEMORY_CASES"))
    let skippedCases: str[] = tooling_stdCsvList(tooling_kvGet(baselineText, "STD_PERF_SKIPPED_CASES"))
    let memorySrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_memory_bench.cheng")
    let fileSrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_file_io_bench.cheng")
    let udpSrc: str = tooling_pathAbsolute(root, "src/tests/std_perf_udp_witness.cheng")
    if !tooling_stdRequireFile(ctx.gateName, memorySrc) || !tooling_stdRequireFile(ctx.gateName, fileSrc) ||
       !tooling_stdRequireFile(ctx.gateName, udpSrc):
        return 1
    let memoryBin: str = os.joinPath(ctx.workDir, "std_perf_memory_bench")
    let memoryCompileLog: str = os.joinPath(ctx.workDir, "std_perf_memory_bench.compile.log")
    let fileBin: str = os.joinPath(ctx.workDir, "std_perf_file_io_bench")
    let fileCompileLog: str = os.joinPath(ctx.workDir, "std_perf_file_io_bench.compile.log")
    let udpBin: str = os.joinPath(ctx.workDir, "std_perf_udp_witness")
    let udpCompileLog: str = os.joinPath(ctx.workDir, "std_perf_udp_witness.compile.log")
    var status: str = "ok"
    if !tooling_stdCompileSource(root, ctx, memorySrc, memoryBin, memoryCompileLog):
        status = "failed"
    if tooling_strEq(status, "ok") && !tooling_stdCompileSource(root, ctx, fileSrc, fileBin, fileCompileLog):
        status = "failed"
    let udpCompileRc: int32 = tooling_stdCompileSourceResult(root, ctx, udpSrc, udpBin, udpCompileLog)
    let udpBinReady: bool = udpCompileRc == 0
    var summaryText: str = "case\tkind\tstatus\tbaseline_ms\tcurrent_ms\tbaseline_checksum\tcurrent_checksum\tnote\n"
    if tooling_strEq(status, "ok"):
        for i in 0..<memoryCases.len:
            let caseId: str = memoryCases[i]
            let caseKey: str = tooling_stdPerfCaseKey(caseId)
            let baseMs: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_MS")
            let baseChecksum: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_CHECKSUM")
            let runRes: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
                root, ctx.workDir, memoryBin, caseId, memoryIters, warmups, measureRuns, timeoutSec, false)
            var caseStatus: str = runRes.status
            var note: str = runRes.note
            if tooling_strEq(caseStatus, "ok") && tooling_strNonEmpty(baseChecksum) && runRes.checksum != baseChecksum:
                caseStatus = "drift"
                note = "checksum_mismatch"
            if tooling_strEq(caseStatus, "ok") && tooling_strNonEmpty(baseMs):
                let baseMsInt: int32 = tooling_parseInt32Default(baseMs, 0)
                let limitMs: int32 = (baseMsInt * (100 + maxSlowdownPct)) / 100
                if runRes.medianMs > limitMs:
                    caseStatus = "regression"
                    note = "slowdown_gt_" + intToStr(maxSlowdownPct) + "pct"
            if !tooling_strEq(caseStatus, "ok") && tooling_strEq(status, "ok"):
                status = caseStatus
            summaryText = summaryText + caseId + "\tmemory\t" + caseStatus + "\t" + baseMs + "\t" +
                          intToStr(runRes.medianMs) + "\t" + baseChecksum + "\t" + runRes.checksum + "\t" + note + "\n"
        for i in 0..<skippedCases.len:
            let caseId: str = skippedCases[i]
            let caseKey: str = tooling_stdPerfCaseKey(caseId)
            let baseMs: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_MS")
            let baseChecksum: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_CHECKSUM")
            let note: str = tooling_kvGet(baselineText, "STD_PERF_" + caseKey + "_NOTE")
            summaryText = summaryText + caseId + "\tmemory\tskipped\t" + baseMs + "\t0\t" +
                          baseChecksum + "\t\t" + note + "\n"
        let fileBaseMs: str = tooling_kvGet(baselineText, "STD_PERF_FILE_IO_MS")
        let fileBaseChecksum: str = tooling_kvGet(baselineText, "STD_PERF_FILE_IO_CHECKSUM")
        let fileRun: ToolingStdPerfCaseResult = tooling_stdPerfRunCase(
            root, ctx.workDir, fileBin, "file_io", fileIters, warmups, measureRuns, timeoutSec, true)
        summaryText = summaryText + "file_io\twitness\t" + fileRun.status + "\t" + fileBaseMs + "\t" +
                      intToStr(fileRun.medianMs) + "\t" + fileBaseChecksum + "\t" + fileRun.checksum + "\t" +
                      fileRun.note + "\n"
        let udpBaseMs: str = tooling_kvGet(baselineText, "STD_PERF_UDP_LOOPBACK_MS")
        let udpBaseChecksum: str = tooling_kvGet(baselineText, "STD_PERF_UDP_LOOPBACK_CHECKSUM")
        var udpRun: ToolingStdPerfCaseResult = tooling_stdPerfCaseResult("skipped", 0, "", "compile_failed")
        if udpBinReady:
            udpRun = tooling_stdPerfRunCase(
                root, ctx.workDir, udpBin, "udp_loopback", udpIters, warmups, measureRuns, timeoutSec, true)
        summaryText = summaryText + "udp_loopback\twitness\t" + udpRun.status + "\t" + udpBaseMs + "\t" +
                      intToStr(udpRun.medianMs) + "\t" + udpBaseChecksum + "\t" + udpRun.checksum + "\t" +
                      udpRun.note + "\n"
    let summaryPath: str = os.joinPath(ctx.workDir, "std_perf_summary.tsv")
    if !tooling_stdWriteTextFile(root, summaryPath, summaryText):
        tooling_printErr("[std_perf] failed to write summary: " + summaryPath)
        return 1
    var reportText: str = ""
    reportText = reportText + "result=" + status + "\n"
    reportText = reportText + "baseline_file=" + baselineFile + "\n"
    reportText = reportText + "driver=" + ctx.driverPath + "\n"
    reportText = reportText + "summary=" + os.joinPath(ctx.finalOutDir, "std_perf_summary.tsv") + "\n"
    reportText = reportText + "memory_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(memoryCompileLog)) + "\n"
    reportText = reportText + "file_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(fileCompileLog)) + "\n"
    reportText = reportText + "udp_compile_log=" + os.joinPath(ctx.finalOutDir, tooling_fileName(udpCompileLog)) + "\n"
    if !tooling_stdWriteReportAndPublish(root, ctx, reportText):
        return 1
    if !tooling_strEq(status, "ok") && requirePerf:
        tooling_printErr("[verify_std_perf_baseline] fail: status=" + status +
                         " (report=" + os.joinPath(ctx.finalOutDir, "std_perf.report.txt") + ")")
        return 1
    if !tooling_strEq(status, "ok"):
        tooling_printErr("[verify_std_perf_baseline] soft fail: status=" + status +
                         " (report=" + os.joinPath(ctx.finalOutDir, "std_perf.report.txt") + ")")
    tooling_printOut("verify_std_perf_baseline ok")
    return 0

