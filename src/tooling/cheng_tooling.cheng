        return tooling_cmdVerifyBackendZeroScriptResidual(root)
    if tooling_strEq(selfName, "verify_backend_emit_c_surface"):
        return tooling_cmdVerifyBackendEmitCSurface(root)
    if tooling_strEq(selfName, "verify_backend_emit_c_ffi_shadow"):
        return tooling_cmdVerifyBackendEmitCFfiShadow(root)
    if tooling_strEq(selfName, "verify_backend_emit_c_hard_fail"):
        return tooling_cmdVerifyBackendEmitCHardFail(root)
    if tooling_strEq(selfName, "verify_backend_opt2"):
        return tooling_cmdVerifyBackendOpt2(root)
    if tooling_strEq(selfName, "verify_backend_opt3"):
        return tooling_cmdVerifyBackendOpt3(root)
    if tooling_strEq(selfName, "verify_backend_opt3_extended"):
        return tooling_cmdVerifyBackendOpt3Extended(root)
    if tooling_strEq(selfName, "verify_backend_simd"):
        return tooling_cmdVerifyBackendSimd(root)
    if tooling_strEq(selfName, "verify_backend_loop_runtime"):
        return tooling_cmdVerifyBackendLoopRuntime(root)
