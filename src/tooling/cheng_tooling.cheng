    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build_backend_string_abi_contract options:")
            tooling_printOut("  --out:<path>         output baseline env")
            tooling_printOut("  --doc:<path>         string ABI contract doc")
            tooling_printOut("  --formal-doc:<path>  formal spec doc")
            tooling_printOut("  --tooling-doc:<path> tooling README")
            tooling_printOut("  --matrix-doc:<path>  backend techdebt matrix doc")
            return 0
        if strutil.startsWith(arg, "--out:"):
            outFile = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--doc:"):
            doc = strings.dropPrefix(arg, "--doc:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--formal-doc:"):
            formalDoc = strings.dropPrefix(arg, "--formal-doc:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--tooling-doc:"):
            toolingDoc = strings.dropPrefix(arg, "--tooling-doc:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--matrix-doc:"):
            matrixDoc = strings.dropPrefix(arg, "--matrix-doc:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown build_backend_string_abi_contract arg: " + arg)
        return 2
    return tooling_cmdBuildBackendStringAbiContract(root, outFile, doc, formalDoc, toolingDoc, matrixDoc)

fn tooling_cmdVerifyBackendStringAbiContract(root: str, baselineFile: str, doc: str, formalDoc: str,
                                             toolingDoc: str, matrixDoc: str): int32 =
    var toolBin: str = tooling_selfExecPath(root)
    if !tooling_strNonEmpty(toolBin):
        toolBin = "artifacts/tooling_cmd/cheng_tooling"
    let cmd: str =
        tcontracts.toolingVerifyBackendStringAbiContractScript(toolBin, baselineFile, doc, formalDoc, toolingDoc, matrixDoc)
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendStringAbiContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var baselineFile: str = "src/tooling/backend_string_abi_contract.env"
    var doc: str = "docs/backend-string-abi-contract.md"
    var formalDoc: str = "docs/cheng-formal-spec.md"
    var toolingDoc: str = "src/tooling/README.md"
    var matrixDoc: str = "docs/backend-techdebt-matrix.md"
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("verify_backend_string_abi_contract options:")
            tooling_printOut("  --baseline:<path>    baseline env")
            tooling_printOut("  --doc:<path>         string ABI contract doc")
            tooling_printOut("  --formal-doc:<path>  formal spec doc")
            tooling_printOut("  --tooling-doc:<path> tooling README")
            tooling_printOut("  --matrix-doc:<path>  backend techdebt matrix doc")
            return 0
        if strutil.startsWith(arg, "--baseline:"):
            baselineFile = strings.dropPrefix(arg, "--baseline:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--doc:"):
            doc = strings.dropPrefix(arg, "--doc:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--formal-doc:"):
            formalDoc = strings.dropPrefix(arg, "--formal-doc:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--tooling-doc:"):
            toolingDoc = strings.dropPrefix(arg, "--tooling-doc:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--matrix-doc:"):
            matrixDoc = strings.dropPrefix(arg, "--matrix-doc:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown verify_backend_string_abi_contract arg: " + arg)
        return 2
    return tooling_cmdVerifyBackendStringAbiContract(root, baselineFile, doc, formalDoc, toolingDoc, matrixDoc)

fn tooling_cmdBuildBackendDotLoweringContract(root: str, outFile: str, doc: str, uirDoc: str,
                                              toolingDoc: str, matrixDoc: str): int32 =
    var parts: str[] = []
    add(parts, "set -eu; ")
    add(parts, "if ! command -v rg >/dev/null 2>&1; then echo \"[build_backend_dot_lowering_contract] rg is required\" >&2; exit 2; fi; ")
    add(parts, "hash_file() { file=\"$1\"; if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; cksum \"$file\" | awk '{print $1}'; }; ")
    add(parts, "read_marker_value() { file=\"$1\"; marker_regex=\"$2\"; rg -o \"${marker_regex}=[A-Za-z0-9_]+\" \"$file\" | head -n 1 | cut -d= -f2 || true; }; ")
    add(parts, "require_marker_value() { file=\"$1\"; marker_regex=\"$2\"; marker_name=\"$3\"; expected=\"$4\"; value=\"$(read_marker_value \"$file\" \"$marker_regex\")\"; if [ \"$value\" != \"$expected\" ]; then echo \"[build_backend_dot_lowering_contract] ${marker_name} must be ${expected} in: $file\" >&2; exit 2; fi; printf '%s\\n' \"$value\"; }; ")
    add(parts, "out=")
    add(parts, tooling_shellQuote(outFile))
    add(parts, "; doc=")
    add(parts, tooling_shellQuote(doc))
    add(parts, "; uir_doc=")
    add(parts, tooling_shellQuote(uirDoc))
    add(parts, "; tooling_doc=")
    add(parts, tooling_shellQuote(toolingDoc))
    add(parts, "; matrix_doc=")
    add(parts, tooling_shellQuote(matrixDoc))
    add(parts, "; ")
    add(parts, "uir_builder=\"src/backend/uir/uir_internal/uir_core_builder.cheng\"; machine_types=\"src/backend/machine/machine_types.cheng\"; isel_shared=\"src/backend/machine/select_internal/isel_parallel_shared.cheng\"; coff_writer=\"src/backend/obj/coff_writer_x86_64.cheng\"; elf_writer=\"src/backend/obj/elf_writer.cheng\"; uir_codegen=\"src/backend/uir/uir_codegen.cheng\"; tooling_file=\"src/tooling/cheng_tooling.cheng\"; ")
    add(parts, "for required in \"$doc\" \"$uir_doc\" \"$tooling_doc\" \"$matrix_doc\" \"$uir_builder\" \"$machine_types\" \"$isel_shared\" \"$coff_writer\" \"$elf_writer\" \"$uir_codegen\" \"$tooling_file\"; do if [ ! -f \"$required\" ]; then echo \"[build_backend_dot_lowering_contract] missing file: $required\" >&2; exit 2; fi; done; ")
    add(parts, "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_dot_lowering_contract_markers.XXXXXX\")\"; tmp_source_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_dot_lowering_contract_sources.XXXXXX\")\"; ")
    add(parts, "cleanup() { rm -f \"$tmp_markers\" \"$tmp_source_markers\"; }; trap cleanup EXIT; ")
    add(parts, "{ rg -o 'dot_lowering_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$doc\" || true; rg -o 'dot_lowering_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$uir_doc\" || true; rg -o 'dot_lowering_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$tooling_doc\" || true; rg -o 'dot_lowering_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$matrix_doc\" || true; } | LC_ALL=C sort -u >\"$tmp_markers\"; ")
    add(parts, "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; if [ \"$marker_count\" -eq 0 ]; then echo \"[build_backend_dot_lowering_contract] no contract markers found\" >&2; exit 2; fi; ")
    add(parts, "contract_version=\"$(read_marker_value \"$doc\" 'dot_lowering_contract\\.version')\"; if [ \"$contract_version\" = \"\" ]; then echo \"[build_backend_dot_lowering_contract] missing dot_lowering_contract.version marker in: $doc\" >&2; exit 2; fi; ")
    add(parts, "doc_scheme_id=\"$(require_marker_value \"$doc\" 'dot_lowering_contract\\.scheme\\.id' 'dot_lowering_contract.scheme.id' 'DOTLOW')\"; ")
    add(parts, "doc_scheme_name=\"$(require_marker_value \"$doc\" 'dot_lowering_contract\\.scheme\\.name' 'dot_lowering_contract.scheme.name' 'backend_dot_lowering_contract')\"; ")
    add(parts, "doc_scheme_normative=\"$(require_marker_value \"$doc\" 'dot_lowering_contract\\.scheme\\.normative' 'dot_lowering_contract.scheme.normative' '1')\"; ")
    add(parts, "doc_enforce_mode=\"$(require_marker_value \"$doc\" 'dot_lowering_contract\\.enforce\\.mode' 'dot_lowering_contract.enforce.mode' 'default_verify')\"; ")
    add(parts, "require_marker_value \"$doc\" 'dot_lowering_contract\\.subdebt\\.semantic_dot' 'dot_lowering_contract.subdebt.semantic_dot' '1' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'dot_lowering_contract\\.subdebt\\.selector_cstring' 'dot_lowering_contract.subdebt.selector_cstring' '1' >/dev/null; ")
    add(parts, "require_marker_value \"$doc\" 'dot_lowering_contract\\.closure' 'dot_lowering_contract.closure' 'required' >/dev/null; ")
    add(parts, "if ! rg -q 'dot_lowering_contract\\.uiR_doc\\.synced=1' \"$uir_doc\"; then echo \"[build_backend_dot_lowering_contract] missing UIR doc sync marker: $uir_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'dot_lowering_contract\\.tooling_readme\\.synced=1' \"$tooling_doc\"; then echo \"[build_backend_dot_lowering_contract] missing tooling README sync marker: $tooling_doc\" >&2; exit 2; fi; ")
    add(parts, "if ! rg -q 'dot_lowering_contract\\.matrix\\.synced=1' \"$matrix_doc\"; then echo \"[build_backend_dot_lowering_contract] missing matrix sync marker: $matrix_doc\" >&2; exit 2; fi; ")
    add(parts, "{ rg -o 'debugDot' \"$uir_builder\" || true; rg -o 'globalObjProbe' \"$uir_builder\" || true; rg -o 'call-dot' \"$uir_builder\" || true; rg -o 'bracket-dot' \"$uir_builder\" || true; rg -o 'field access' \"$uir_builder\" || true; rg -o 'selector cstring lowering is always enabled on the production machine surface' \"$machine_types\" || true; rg -o 'selector-owned cstring lowering materializes MachineCString payloads before object writers' \"$isel_shared\" || true; rg -o 'Selector owns cstring materialization' \"$coff_writer\" || true; rg -o 'ELF writer consumes selector-owned cstring materialization' \"$elf_writer\" || true; rg -o 'selector_missing cstring payloads is a hard error' \"$uir_codegen\" || true; } | LC_ALL=C sort -u >\"$tmp_source_markers\"; ")
    add(parts, "source_marker_count=\"$(wc -l < \"$tmp_source_markers\" | tr -d ' ')\"; if [ \"$source_marker_count\" -lt 9 ]; then echo \"[build_backend_dot_lowering_contract] missing source markers for semantic dot / selector cstring debt split\" >&2; exit 2; fi; ")
    add(parts, "doc_sha=\"$(hash_file \"$doc\")\"; uir_doc_sha=\"$(hash_file \"$uir_doc\")\"; tooling_doc_sha=\"$(hash_file \"$tooling_doc\")\"; matrix_doc_sha=\"$(hash_file \"$matrix_doc\")\"; tooling_sha=\"$(hash_file \"$tooling_file\")\"; marker_sha=\"$(hash_file \"$tmp_markers\")\"; source_marker_sha=\"$(hash_file \"$tmp_source_markers\")\"; ")
    add(parts, "out_dir=\"$(dirname \"$out\")\"; if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; ")
    add(parts, "{ ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_BASELINE_VERSION=1\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_DOC=$doc\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_UIR_DOC=$uir_doc\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_TOOLING_DOC=$tooling_doc\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_MATRIX_DOC=$matrix_doc\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_DOC_SHA256=$doc_sha\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_UIR_DOC_SHA256=$uir_doc_sha\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_TOOLING_DOC_SHA256=$tooling_doc_sha\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_MATRIX_DOC_SHA256=$matrix_doc_sha\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_TOOLING_SHA256=$tooling_sha\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_VERSION=$contract_version\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_SCHEME_ID=$doc_scheme_id\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_SCHEME_NAME=$doc_scheme_name\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_SCHEME_NORMATIVE=$doc_scheme_normative\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_ENFORCE_MODE=$doc_enforce_mode\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_MARKER_COUNT=$marker_count\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_MARKER_SHA256=$marker_sha\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_SOURCE_MARKER_COUNT=$source_marker_count\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_SOURCE_MARKER_SHA256=$source_marker_sha\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_DEFAULT_VERIFY_GATES=verify_backend_dot_lowering_contract\"; ")
    add(parts, "echo \"BACKEND_DOT_LOWERING_CONTRACT_CLOSURE_TIER=required\"; ")
    add(parts, "} >\"$out\"; ")
    add(parts, "echo \"backend dot lowering contract baseline generated: $out\"")
    let cmd: str = tooling_joinFragments(parts)
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdBuildBackendDotLoweringContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var outFile: str = "src/tooling/backend_dot_lowering_contract.env"
