                        tooling_printErr("cheng_tooling: warning: failed to write build-backend-driver stamp: " +
                                         stampPath)
                let capPath: str = tooling_stage0CapabilityFilePath(outPath)
                if !os.fileExists(capPath):
                    let _capWrittenOnSharedHit: bool = tooling_stage0CapabilityWriteForOutput(root, outPath)
                tooling_cleanupStage0Exec(stage0, stage0Exec)
                return 0
    stage0Exec = tooling_prepareStage0Exec(root, stage0, stage0Purpose)
    if !tooling_strNonEmpty(stage0Exec):
        return 1
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 1
    var uirSidecarObj: str = ""
    var uirSidecarBundle: str = ""
    if useUirSidecar:
        uirSidecarObj = tooling_prepareBackendDriverUirSidecarObj(root, stage0Exec, target)
        if !tooling_fileExistsNonEmpty(uirSidecarObj):
            tooling_printErr("cheng_tooling: missing backend driver UIR sidecar object: " +
                             tooling_backendDriverUirSidecarObjPath(root, target))
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            return 1
        uirSidecarBundle = tooling_prepareBackendDriverUirSidecarBundle(root, target, uirSidecarObj)
        if !tooling_fileExistsNonEmpty(uirSidecarBundle):
            tooling_printErr("cheng_tooling: missing backend driver UIR sidecar bundle: " +
                             tooling_backendDriverUirSidecarBundlePath(root, target))
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            return 1
    if tooling_strEq(linkerMode, "self"):
        let refreshRuntimeObj: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_RUNTIME_OBJ_REFRESH", "0"))
        if refreshRuntimeObj:
            runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
        else:
            runtimeObj = tooling_runtimeObjPath(root, target)
            if !os.fileExists(runtimeObj):
                runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
        let preferSeedBaseRuntimeObj: bool = tooling_isTrue(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_SEED_BASE_RUNTIME_OBJ", "1"))
        let stage0LowerRaw: str = strutil.toLowerAscii(strutil.strip(stage0))
        let seedLikeStage0: bool =
            tooling_strContains(stage0LowerRaw, "/artifacts/backend_selfhost_self_obj/cheng.stage2") ||
            tooling_strContains(stage0LowerRaw, "/artifacts/backend_selfhost_self_obj/cheng.stage1")
        if preferSeedBaseRuntimeObj && seedLikeStage0:
            let baseRuntimeObj: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng." + target + ".o")
            if os.fileExists(baseRuntimeObj):
                runtimeObj = baseRuntimeObj
        if !os.fileExists(runtimeObj):
            tooling_printErr("cheng_tooling: missing runtime object: " + runtimeObj)
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            return 1
    let crashRetrySafe: bool = fullRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_CRASH_RETRY_SAFE", "1"))
    var crashRetryMax: int32 = 0
    if crashRetrySafe:
        crashRetryMax = tooling_parseInt32Default(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_CRASH_RETRY_MAX", ""), 1)
    if crashRetryMax < 0:
        crashRetryMax = 0
    if crashRetryMax > 2:
        crashRetryMax = 2
    let compileAttemptLimit: int32 = crashRetryMax + 1
    var segfaultRetryCount: int32 = 0
    var finalRes: os.ExecCmdResult = tooling_exec(root, "true")
    var finalRc: int32 = 1
    var lastCompileCmdBase: str = ""
    var lastAttemptTimeoutSec: int32 = timeoutSec
    let distStage0FailFast: bool = fullRebuild &&
        tooling_strContains(stage0Exec, "/dist/releases/current/cheng") &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_DIST_FAIL_FAST", "1"))
    var profileDisabledByCrash: bool = false
    let crashTraceEnabled: bool = fullRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_CRASH_TRACE", "1"))
    let crashTraceTimeoutMax: int32 = tooling_parseInt32Default(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_CRASH_TRACE_TIMEOUT", "25"), 25)
    for attempt in 0..<compileAttemptLimit:
        var compileCmdBase: str = ""
        var attemptTimeoutSec: int32 = timeoutSec
        if tooling_strContains(stage0Exec, "/dist/releases/current/cheng"):
            let distRecoveryTimeout: int32 = tooling_clampCompileTimeoutSec(
                tooling_parseInt32Default(
                    os.getEnvDefault("TOOLING_BUILD_DRIVER_DIST_RECOVERY_TIMEOUT", "60"), 60))
            if distRecoveryTimeout > attemptTimeoutSec:
                attemptTimeoutSec = distRecoveryTimeout
        lastAttemptTimeoutSec = attemptTimeoutSec
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS_STRICT", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("MM", "orc")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("CACHE", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_AUTO_SYSTEM", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_BUILD_TRACK", "dev")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
        # Stage0 compatibility: some older seed drivers still gate whole-program
        # closure behind legacy knobs. Keep all legacy spellings pinned to 1.
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("WHOLE_PROGRAM", "1")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_WHOLE_PROGRAM", "1")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("whole_program", "1")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_STAGE1_PARSE_MODE", parseMode)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_FN_SCHED", fnSchedText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_DIRECT_EXE", directExeText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_LINKERLESS_INMEM", directExeText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_FAST_FALLBACK_ALLOW", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MULTI", multiText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MULTI_FORCE", multiForceText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MULTI_MODULE_CACHE", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MODULE_CACHE", "")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MODULE_CACHE_UNSTABLE_ALLOW", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_INCREMENTAL", incrementalText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_JOBS", intToStr(jobs))
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_FN_JOBS", intToStr(jobs))
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_VALIDATE", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_OPT_LEVEL", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_OPT", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_OPT2", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("UIR_SIMD", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_SKIP_CPROFILE", "1")
        # Stage0 semantic profiler path is unstable (known semProfRecordKind crash chain).
        # Keep full-rebuild deterministic by forcing stage1 semantic profiling off.
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_PROFILE", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("GENERIC_MODE", genericModeText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("GENERIC_SPEC_BUDGET", genericSpecBudgetText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("GENERIC_LOWERING", genericLoweringText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_STAGE1_DISABLE_DUP_SCAN", disableDupScanText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_STAGE1_BUILDER", stage1BuilderText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_SKIP_GLOBAL_INIT", skipGlobalInitText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_SKIP_UIR_FIXUPS", skipFixupsText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_SKIP_UIR_NORMALIZE", skipNormalizeText)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_LINKER", linkerMode)
        if tooling_strEq(linkerMode, "self"):
            compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "1")
            compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_RUNTIME_OBJ", runtimeObj)
        else:
            compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "0")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_EMIT", "exe")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_TARGET", target)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_INPUT", sourcePath)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_OUTPUT", outPath)
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("TOOLING_TIMEOUT_DIAG", "1")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("TOOLING_TIMEOUT_DIAG_DIR",
            os.joinPath(root, "chengcache/backend_timeout_diag"))
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("TOOLING_TIMEOUT_DIAG_SECONDS",
            intToStr(attemptTimeoutSec))
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("TOOLING_TIMEOUT_DIAG_SUMMARY", "1")
        compileCmdBase = compileCmdBase + tooling_envAssignCompat("TOOLING_TIMEOUT_DIAG_SUMMARY_TOP", "12")
        if tooling_fileExistsNonEmpty(uirSidecarBundle):
            compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_BUNDLE", uirSidecarBundle)
            let sidecarCompilerPath: str = tooling_backendDriverUirSidecarCompilerPath(root, stage0Exec)
            compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_COMPILER", sidecarCompilerPath)
        if tooling_strEq(os.extractFilename(sourcePath), "backend_driver.cheng"):
            compileCmdBase = compileCmdBase + tooling_envAssignCompat(
                "BACKEND_CFLAGS", "-DCHENG_BACKEND_DRIVER_ENTRY_SHIM=1")
        compileCmdBase = compileCmdBase + tooling_buildBackendDriverLegacyStage0Prefix(
            "dev", sourcePath, outPath, target, linkerMode, parseMode, fnSchedText,
            multiText, multiForceText, incrementalText, jobs, skipGlobalInitText,
            skipFixupsText, skipNormalizeText, genericModeText, genericSpecBudgetText,
            genericLoweringText, runtimeObj)
        compileCmdBase = compileCmdBase + tooling_stage0LegacyCStringCompatPrefix(root, stage0Exec)
        compileCmdBase = compileCmdBase + tooling_shellQuote(stage0Exec)
        compileCmdBase = compileCmdBase + " " + tooling_shellQuote("--input:" + sourcePath)
        compileCmdBase = compileCmdBase + " " + tooling_shellQuote("--output:" + outPath)
        compileCmdBase = compileCmdBase + " " + tooling_shellQuote("--target:" + target)
        compileCmdBase = compileCmdBase + " " + tooling_shellQuote("--linker:" + linkerMode)
        compileCmdBase = tooling_prefixUnsetLegacyFrontendEnv(compileCmdBase)
        lastCompileCmdBase = compileCmdBase
        var compileCmd: str = compileCmdBase
        let profileAttemptEnabled: bool = profileEnabled && !profileDisabledByCrash
        if profileAttemptEnabled:
            compileCmd = tooling_prefixBuildDriverProfile(compileCmd, profileMode)
        compileCmd = tooling_wrapStage0LockTimeout(root, attemptTimeoutSec, compileCmd,
                                                   "build_backend_driver_compile")
        var res: os.ExecCmdResult = tooling_exec(root, compileCmd)
        tooling_printExecOutput(res)
        finalRes = res
        finalRc = os.execCmdResultExitCode(res)
        if profileAttemptEnabled && profileFailOpen && finalRc == 139:
            tooling_printErr("cheng_tooling: profile-enabled full rebuild segfaulted; retrying same attempt without profile flags")
            profileDisabledByCrash = true
            var noProfileCmd: str = compileCmdBase
            noProfileCmd = tooling_wrapStage0LockTimeout(root, attemptTimeoutSec, noProfileCmd,
                                                         "build_backend_driver_compile")
            res = tooling_exec(root, noProfileCmd)
            tooling_printExecOutput(res)
            finalRes = res
            finalRc = os.execCmdResultExitCode(res)
        let finalKindAttempt: str = tooling_exitKind(finalRc)
        if distStage0FailFast &&
           (tooling_strEq(finalKindAttempt, "timeout") || finalRc == 138 || finalRc == 139):
            tooling_printErr("cheng_tooling: dist stage0 rebuild fail-fast hit rc=" +
                             intToStr(finalRc) + " kind=" + finalKindAttempt)
            break
        if crashTraceEnabled && (finalRc == 138 || finalRc == 139):
            var traceTimeoutSec: int32 = attemptTimeoutSec
            if traceTimeoutSec < 8:
                traceTimeoutSec = 8
            if crashTraceTimeoutMax > 0 && traceTimeoutSec > crashTraceTimeoutMax:
                traceTimeoutSec = crashTraceTimeoutMax
            let traceLogDir: str = tooling_driverBuildTempDir(root)
            tooling_tryMkdirP(root, traceLogDir)
            let traceLogPath: str = os.joinPath(traceLogDir, "backend_driver_crash_trace.attempt." +
                                                intToStr(attempt + 1) + ".log")
            var traceCmd: str = ""
            traceCmd = traceCmd + tooling_envAssignCompat("STAGE1_TRACE", "1")
            traceCmd = traceCmd + tooling_envAssignCompat("STAGE1_TRACE_FLUSH", "1")
            traceCmd = traceCmd + tooling_envAssignCompat("STAGE1_TOKEN_CACHE", "0")
            traceCmd = traceCmd + compileCmdBase
            traceCmd = tooling_wrapCommandWithTimeout(root, traceTimeoutSec, traceCmd)
            let traceRes: os.ExecCmdResult = tooling_exec(root, traceCmd)
            let traceOut: str = os.execCmdResultOutput(traceRes)
            if !tooling_writeTextFileViaShell(root, traceLogPath, traceOut):
                tooling_printErr("cheng_tooling: failed to write crash trace log: " + traceLogPath)
            tooling_printOut("build_backend_driver_crash_trace_log=" + traceLogPath)
            tooling_printOut("build_backend_driver_crash_trace_rc=" + intToStr(os.execCmdResultExitCode(traceRes)))
            let traceSawFixupsStart: bool = tooling_strContains(traceOut, "backend: uir fixups start")
            let traceSawFixupsDone: bool = tooling_strContains(traceOut, "backend: uir fixups done")
            tooling_printOut("build_backend_driver_crash_trace_fixups_start=" + (traceSawFixupsStart ? "1" : "0"))
            tooling_printOut("build_backend_driver_crash_trace_fixups_done=" + (traceSawFixupsDone ? "1" : "0"))
        if finalRc != 139 || (attempt + 1) >= compileAttemptLimit:
            break
        segfaultRetryCount = segfaultRetryCount + 1
        tooling_printErr("cheng_tooling: full rebuild crashed with segfault; retrying safe stage1 builder profile (" +
                         intToStr(segfaultRetryCount) + "/" + intToStr(crashRetryMax) + ")")
        jobs = 1
        multiText = "0"
        multiForceText = "0"
        incrementalText = "0"
        parseMode = "outline"
        fnSchedText = "ws"
        directExeText = tooling_strEq(linkerMode, "self") ? "1" : "0"
        stage1BuilderText = "stage1"
    let finalOutTrim: str = strutil.strip(os.execCmdResultOutput(finalRes))
    let diagOnEmptyFailDefault: str = fullRebuildTightTimeoutProfile ? "0" : "1"
    let diagOnEmptyFail: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_EMPTY_FAIL_DIAG", diagOnEmptyFailDefault))
    let finalKind: str = tooling_exitKind(finalRc)
    if fullRebuild && finalRc != 0 && finalRc != 139 && !tooling_strEq(finalKind, "timeout") &&
       !tooling_strNonEmpty(finalOutTrim) &&
       diagOnEmptyFail && tooling_strNonEmpty(lastCompileCmdBase):
        var diagCmd: str = ""
        if profileEnabled && !profileDisabledByCrash:
            diagCmd = tooling_prefixBuildDriverProfile(diagCmd, profileMode)
        diagCmd = diagCmd + tooling_envAssignCompat("BACKEND_DEBUG_STAGE1_PIPE", "1")
        diagCmd = diagCmd + lastCompileCmdBase
        diagCmd = tooling_wrapCommandWithTimeout(root, lastAttemptTimeoutSec, diagCmd)
        let diagRes: os.ExecCmdResult = tooling_exec(root, diagCmd)
        let diagOut: str = os.execCmdResultOutput(diagRes)
        tooling_printErr("cheng_tooling: full rebuild failed with empty output; printing inline diagnostics")
        if tooling_strNonEmpty(strutil.strip(diagOut)):
            let rows: str[] = tooling_splitLines(diagOut)
            var maxLines: int32 = 24
            if rows.len < maxLines:
                maxLines = rows.len
            for i in 0..<maxLines:
                tooling_printErr("cheng_tooling: full rebuild diag: " + rows[i])
        else:
            tooling_printErr("cheng_tooling: full rebuild diag produced empty output")
    elif fullRebuild && finalRc != 0 && tooling_strEq(finalKind, "timeout") && !diagOnEmptyFail:
        tooling_printErr("cheng_tooling: skip empty-output diag on timeout (tight-timeout profile)")
    if tooling_strNonEmpty(profileOutPath):
        if finalRc == 0 && profileEnabled && !profileDisabledByCrash:
            let profileOutDir: str = os.parentDir(profileOutPath)
            if tooling_strNonEmpty(profileOutDir):
                tooling_tryMkdirP(root, profileOutDir)
            os.writeFile(profileOutPath, os.execCmdResultOutput(finalRes))
            tooling_printOut("build_backend_driver_profile_log=" + profileOutPath)
        elif finalRc == 0 && profileDisabledByCrash:
            tooling_printErr("cheng_tooling: profile log disabled after segfault fail-open; build succeeded without profile flags")
        else:
            tooling_printErr("cheng_tooling: skip profile log write for failed full rebuild rc=" + intToStr(finalRc))
    if fullRebuild && (finalRc == 138 || finalRc == 139):
        let finalOutRaw: str = os.execCmdResultOutput(finalRes)
        let sawFixupsStart: bool = tooling_strContains(finalOutRaw, "backend: uir fixups start")
        let sawFixupsDone: bool = tooling_strContains(finalOutRaw, "backend: uir fixups done")
        if sawFixupsStart && !sawFixupsDone:
            tooling_printErr("cheng_tooling: detected stage0 crash window in uir fixups (start seen, done missing)")
            tooling_printErr("cheng_tooling: action: refresh seed/canonical stage0 before require-rebuild (tick/tock bootstrap)")
        if tooling_strContains(finalOutRaw, "unknown local/global: pcOther"):
            tooling_printErr("cheng_tooling: detected stale stage0 enum resolution failure for PathComponent.pcOther")
            tooling_printErr("cheng_tooling: action: keep PathComponent returns explicit (PathComponent(<int>)) and refresh stage0")
    if fullRebuild && finalRc != 0 && tooling_strNonEmpty(lastCompileCmdBase):
        let attemptsUsed: int32 = segfaultRetryCount + 1
        let reportPath: str = tooling_writeCompileCrashReport(
            root, "build_backend_driver_rebuild", finalRc, attemptsUsed, compileAttemptLimit,
            lastCompileCmdBase, os.execCmdResultOutput(finalRes))
        if tooling_strNonEmpty(reportPath):
            tooling_printOut("build_backend_driver_rebuild_report=" + reportPath)
    if finalRc != 0:
        # Legacy relink fallback has been removed.
        let _strictNativeUnused: bool = strictNative
        let _allowFallbackUnused: bool = allowFallback
        let _targetUnused: str = target
    if finalRc != 0:
        tooling_stage0MarkCrash(root, stage0Exec, finalRc, "build_backend_driver_compile")
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return finalRc
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_stage0MarkBlocked(root, stage0Exec, finalRc,
                                  "build_backend_driver_missing_output", "missing_output")
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: build-backend-driver returned success but produced no output: " + outPath)
        return 1
    let chmodRes: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(outPath))
    tooling_printExecOutput(chmodRes)
    let chmodRc: int32 = os.execCmdResultExitCode(chmodRes)
    if chmodRc == 0:
        if !tooling_stage0CapabilityWriteForOutput(root, outPath):
            tooling_printErr("cheng_tooling: warning: stage0 capability sidecar write failed for " + outPath)
    if chmodRc == 0 && stampCacheEnabled:
        if !tooling_strNonEmpty(sourceSha):
            sourceSha = tooling_sha256File(root, sourcePath)
        if !tooling_strNonEmpty(stage0IdentitySha):
            stage0IdentitySha = tooling_sha256File(root, stage0IdentityPath)
        if !tooling_strNonEmpty(sourceCapabilitySignature):
            sourceCapabilitySignature = tooling_stage0CapabilitySignature(root)
        if !tooling_strNonEmpty(stampText):
            stampText = tooling_buildDriverStampText(
                compileModeText, target, linkerMode, stage0IdentityPath, stage0IdentitySha,
                sourcePath, sourceSha, sourceCapabilitySignature,
                parseMode, fnSchedText, directExeText, incrementalText,
                multiText, multiForceText, stage1BuilderText, skipGlobalInitText,
                disableDupScanText, skipFixupsText, skipNormalizeText, genericModeText,
                genericSpecBudgetText, genericLoweringText, jobs)
        if tooling_writeTextFileViaShell(root, stampPath, stampText):
            tooling_printOut("build_backend_driver_stamp_cache_write=1")
        else:
            tooling_printErr("cheng_tooling: failed to write build-backend-driver stamp: " + stampPath)
        if quickSharedCacheEnabled && tooling_strNonEmpty(quickSharedCachePath):
            if tooling_installExecutableAtomic(root, outPath, quickSharedCachePath):
                let _sharedCapWritten: bool = tooling_stage0CapabilityWriteForOutput(root, quickSharedCachePath)
                if tooling_writeTextFileViaShell(root, quickSharedStampPath, stampText):
                    tooling_printOut("build_backend_driver_shared_cache_write=1")
                else:
                    tooling_printErr("cheng_tooling: warning: failed to write build-backend-driver shared stamp: " +
                                     quickSharedStampPath)
            else:
                tooling_printErr("cheng_tooling: warning: failed to publish build-backend-driver shared cache: " +
                                 quickSharedCachePath)
    tooling_cleanupStage0Exec(stage0, stage0Exec)
    return chmodRc

fn tooling_compileBackendDriverFastHost(root: str, stage0: str, target: str, outPath: str, fullRebuild: bool): int32 =
    return tooling_compileBackendDriverFastHostWithRebuildPolicy(root, stage0, target, outPath, fullRebuild, "", "",
                                                                 false)

fn tooling_selfhostBootstrapFastHost(root: str, compileStage1: bool, outDirRaw: str, timingOutRaw: str,
                                     stage0Raw: str, allowBootstrapCapabilityRefresh: bool): ToolingSelfhostResult =
    var result: ToolingSelfhostResult = new(ToolingSelfhostResult)
    result.ok = false
    result.message = ""
    result.totalMs = int64(0)
    result.mode = "fast"
    result.stage1Path = ""
    result.stage2Path = ""
    result.stage3Path = ""
    result.stage0Path = ""
    result.stage0DriverKind = "unknown"
    result.stage1Status = "init"
    result.stage1CompileMode = "alias"
    result.stage1RebuildOk = false
    result.fallbackUsed = false
    result.quarantineCleaned = 0
    result.lockWaitMs = 0
    result.strictRebuildOk = false
    result.stage2Sha256 = ""
    result.stage3Sha256 = ""
    result.fixedPointOk = false
    result.strictMismatchReport = ""
    result.stage1CompileMs = int64(0)
    result.stage1SanityMs = int64(0)
    result.stage1CompileAttempts = 0
    result.stage1CompileSegfaults = 0

    let hostTag: str = tooling_detectHostTag(root)
    if !tooling_strEq(hostTag, "darwin_arm64"):
        result.message = "selfhost_fast_host unsupported host: " + hostTag
        return result
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        result.message = "selfhost_fast_host failed to resolve host target"
        return result
    result.quarantineCleaned = tooling_stage0QuarantineSweepUe(root, "selfhost_fast_host")
    if tooling_stage0BlockOnQuarantineUe(root, "TOOLING_SELFHOST_BLOCK_ON_UE", "selfhost_fast_host"):
        result.message = "selfhost_fast_host blocked by quarantine stuck/orphan processes"
        return result

    let explicitStage0Raw: str = strutil.strip(stage0Raw)
    var stage0: str = tooling_resolveStage0DriverStrict(root, stage0Raw)
    if !tooling_strNonEmpty(stage0) && tooling_strNonEmpty(explicitStage0Raw):
        result.message = "selfhost_fast_host explicit stage0 failed strict probe: " + explicitStage0Raw
        return result
    if !tooling_strNonEmpty(stage0):
        result.message = "selfhost_fast_host missing stage0 driver"
        return result
    result.stage0Path = stage0
    result.stage0DriverKind = tooling_stage0DriverKind(root, stage0)

    var outDir: str = outDirRaw
    if !tooling_strNonEmpty(outDir):
        outDir = "artifacts/backend_selfhost_self_obj"
    outDir = tooling_pathAbsolute(root, outDir)
    if !tooling_mkdirP(root, outDir):
        result.message = "selfhost_fast_host failed to create out dir: " + outDir
        return result
    let stage1Path: str = os.joinPath(outDir, "cheng.stage1")
    let stage2Path: str = os.joinPath(outDir, "cheng.stage2")
    result.stage1Path = stage1Path
    result.stage2Path = stage2Path

    let startedMs: int64 = tooling_nowMs()
    let stage1StartedMs: int64 = tooling_nowMs()
    var stage1Status: str = "alias"
    var stage1CompileMode: str = "alias"
    let strictRebuild: bool = tooling_selfhostStrictRebuildEnabled()
    let requireStage1Rebuild: bool = compileStage1 &&
        (strictRebuild || tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_REQUIRE_REBUILD", "0")))
    let stage1FullRebuild: bool = compileStage1 &&
        (strictRebuild || tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_FULL_REBUILD", "0")))
    let stage1ForceProbeOnFull: bool = compileStage1 &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_FORCE_PROBE_ON_FULL", "0"))
    let stage1AutoFullOnRequire: bool = compileStage1 && !stage1FullRebuild && requireStage1Rebuild &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_AUTO_FULL_ON_REQUIRE", "1"))
    let stage1QuickLightSanity: bool = compileStage1 && !stage1FullRebuild &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_QUICK_LIGHT_SANITY", "1"))
    let stage1StampHitFastSanity: bool = compileStage1 && stage1FullRebuild &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_STAMP_HIT_FAST_SANITY", "1"))
    var compileStage1TextBase: str = "0"
    if compileStage1:
        compileStage1TextBase = "1"
        if stage1FullRebuild:
            stage1CompileMode = "full"
        else:
            stage1CompileMode = "quick"
    result.stage1CompileMode = stage1CompileMode
    var stage1CompileMsTotal: int64 = int64(0)
    var stage1SanityMsTotal: int64 = int64(0)
    var stage1CompileAttempts: int32 = 0
    var stage1CompileSegfaults: int32 = 0
    let stageRebuildLinkerMode: str = tooling_buildDriverEffectiveLinkerMode(
        tooling_buildDriverEffectiveStrictNativeForRebuild(stage1FullRebuild))
    if compileStage1:
        let compileStarted0: int64 = tooling_nowMs()
        var rcBuild: int32 = tooling_compileBackendDriverFastHostWithRebuildPolicy(
            root, stage0, target, stage1Path, stage1FullRebuild, "", "",
            allowBootstrapCapabilityRefresh)
        stage1CompileMsTotal = stage1CompileMsTotal + (tooling_nowMs() - compileStarted0)
        stage1CompileAttempts = stage1CompileAttempts + 1
        if rcBuild != 0 && tooling_strEq(tooling_exitKind(rcBuild), "segfault"):
            stage1CompileSegfaults = stage1CompileSegfaults + 1
        var stage1BuildOk: bool = false
        if rcBuild == 0:
            let sanityStarted0: int64 = tooling_nowMs()
            if stage1StampHitFastSanity && tooling_buildDriverLastStampHit:
                stage1BuildOk = tooling_driverMinimalSanityOk(root, stage1Path)
            else:
                stage1BuildOk = tooling_driverBuildOutputOk(root, stage1Path, stage1CompileMode, stage1QuickLightSanity,
                                                            stage1ForceProbeOnFull, stageRebuildLinkerMode)
            stage1SanityMsTotal = stage1SanityMsTotal + (tooling_nowMs() - sanityStarted0)
        if stage1AutoFullOnRequire && (!stage1BuildOk || rcBuild != 0):
            tooling_printErr("cheng_tooling: selfhost fast stage1 quick rebuild failed or not runnable; retrying full-rebuild because require-rebuild is enabled")
            stage1CompileMode = "full"
            let compileStarted1: int64 = tooling_nowMs()
            rcBuild = tooling_compileBackendDriverFastHostWithRebuildPolicy(
                root, stage0, target, stage1Path, true, "", "",
                allowBootstrapCapabilityRefresh)
            stage1CompileMsTotal = stage1CompileMsTotal + (tooling_nowMs() - compileStarted1)
            stage1CompileAttempts = stage1CompileAttempts + 1
            if rcBuild != 0 && tooling_strEq(tooling_exitKind(rcBuild), "segfault"):
                stage1CompileSegfaults = stage1CompileSegfaults + 1
            if rcBuild == 0:
                let sanityStarted1: int64 = tooling_nowMs()
                if stage1StampHitFastSanity && tooling_buildDriverLastStampHit:
                    stage1BuildOk = tooling_driverMinimalSanityOk(root, stage1Path)
                else:
                    stage1BuildOk = tooling_driverBuildOutputOk(root, stage1Path, stage1CompileMode, stage1QuickLightSanity,
                                                                stage1ForceProbeOnFull, stageRebuildLinkerMode)
                stage1SanityMsTotal = stage1SanityMsTotal + (tooling_nowMs() - sanityStarted1)
            else:
                stage1BuildOk = false
        if stage1BuildOk:
            stage1Status = "rebuild"
            result.stage1RebuildOk = true
            result.fallbackUsed = false
        else:
            result.stage1CompileMs = stage1CompileMsTotal
            result.stage1SanityMs = stage1SanityMsTotal
            result.stage1CompileAttempts = stage1CompileAttempts
            result.stage1CompileSegfaults = stage1CompileSegfaults
            if rcBuild != 0:
                result.message = "selfhost_fast_host stage1 compile failed rc=" + intToStr(rcBuild) +
                                 " kind=" + tooling_exitKind(rcBuild)
            else:
                result.message = "selfhost_fast_host stage1 compile output sanity failed"
            return result
    else:
        if !tooling_copyExecutable(root, stage0, stage1Path):
            result.message = "selfhost_fast_host stage1 alias copy failed"
            return result
        stage1Status = "alias"
        result.stage1RebuildOk = false
        # Alias mode is the intentional default fast path, not a fallback.
        result.fallbackUsed = false
    result.stage1CompileMs = stage1CompileMsTotal
    result.stage1SanityMs = stage1SanityMsTotal
    result.stage1CompileAttempts = stage1CompileAttempts
    result.stage1CompileSegfaults = stage1CompileSegfaults
    let stage1Ms: int64 = tooling_nowMs() - stage1StartedMs
    result.stage1Status = stage1Status
    result.stage1CompileMode = stage1CompileMode
    result.strictRebuildOk = !compileStage1 || !strictRebuild || result.stage1RebuildOk

    let stage2StartedMs: int64 = tooling_nowMs()
    if !tooling_copyExecutable(root, stage1Path, stage2Path):
        result.message = "selfhost_fast_host stage2 alias copy failed"
        return result
    let stage2Ms: int64 = tooling_nowMs() - stage2StartedMs

    let totalMs: int64 = tooling_nowMs() - startedMs
    result.totalMs = totalMs
    result.ok = true
    result.message = "ok"

    var timingOut: str = timingOutRaw
    if !tooling_strNonEmpty(timingOut):
        timingOut = os.joinPath(outDir, "selfhost_timing_native.tsv")
    timingOut = tooling_pathAbsolute(root, timingOut)
    let timingDir: str = os.parentDir(timingOut)
    tooling_tryMkdirP(root, timingDir)
    let timingText: str =
        "stage1\t" + stage1Status + "\t" + tooling_msToSecondsText(stage1Ms) + "\n" +
        "stage2\talias\t" + tooling_msToSecondsText(stage2Ms) + "\n" +
        "total\tok\t" + tooling_msToSecondsText(totalMs) + "\n"
    let _timingWriteOk: bool = tooling_writeTextFileViaShell(root, timingOut, timingText)
    result.lockWaitMs = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_LOCK_WAIT_MS", ""), 0)
    return result

fn tooling_selfhostWriteTiming(root: str, outDirRaw: str, timingOutRaw: str, stage1Status: str, stage1Ms: int64,
                               stage2Status: str, stage2Ms: int64, stage3Status: str, stage3Ms: int64,
                               hashStatus: str, hashMs: int64, totalStatus: str, totalMs: int64) =
    var outDir: str = outDirRaw
    if !tooling_strNonEmpty(outDir):
        outDir = "artifacts/backend_selfhost_self_obj"
    outDir = tooling_pathAbsolute(root, outDir)
    var timingOut: str = timingOutRaw
    if !tooling_strNonEmpty(timingOut):
        timingOut = os.joinPath(outDir, "selfhost_timing_native.tsv")
    timingOut = tooling_pathAbsolute(root, timingOut)
    let timingDir: str = os.parentDir(timingOut)
    tooling_tryMkdirP(root, timingDir)
    let timingText: str =
        "stage1\t" + stage1Status + "\t" + tooling_msToSecondsText(stage1Ms) + "\n" +
        "stage2\t" + stage2Status + "\t" + tooling_msToSecondsText(stage2Ms) + "\n" +
        "stage3\t" + stage3Status + "\t" + tooling_msToSecondsText(stage3Ms) + "\n" +
        "hash_check\t" + hashStatus + "\t" + tooling_msToSecondsText(hashMs) + "\n" +
        "total\t" + totalStatus + "\t" + tooling_msToSecondsText(totalMs) + "\n"
    let _timingWriteOk: bool = tooling_writeTextFileViaShell(root, timingOut, timingText)

fn tooling_summaryOneLine(raw: str): str =
    if !tooling_strNonEmpty(raw):
        return ""
    var out: str = raw
    out = strutil.replace(out, "\r", " ")
    out = strutil.replace(out, "\n", " ")
    out = strutil.replace(out, "\t", " ")
    return out

fn tooling_selfhostInnerLoopWriteTiming(root: str, outDirRaw: str, timingOutRaw: str,
                                        buildStatus: str, buildMs: int64,
                                        inmemStatus: str, inmemMs: int64,
                                        strictStatus: str, strictMs: int64,
                                        closureStatus: str, closureMs: int64,
                                        totalStatus: str, totalMs: int64) =
    var outDir: str = outDirRaw
    if !tooling_strNonEmpty(outDir):
        outDir = "artifacts/backend_selfhost_inner_loop"
    outDir = tooling_pathAbsolute(root, outDir)
    var timingOut: str = timingOutRaw
    if !tooling_strNonEmpty(timingOut):
        timingOut = os.joinPath(outDir, "selfhost_inner_loop_timing.tsv")
    timingOut = tooling_pathAbsolute(root, timingOut)
    let timingDir: str = os.parentDir(timingOut)
    tooling_tryMkdirP(root, timingDir)
    let timingText: str =
        "build_driver\t" + buildStatus + "\t" + tooling_msToSecondsText(buildMs) + "\n" +
        "inmem_witness\t" + inmemStatus + "\t" + tooling_msToSecondsText(inmemMs) + "\n" +
        "strict_host\t" + strictStatus + "\t" + tooling_msToSecondsText(strictMs) + "\n" +
        "closure\t" + closureStatus + "\t" + tooling_msToSecondsText(closureMs) + "\n" +
        "total\t" + totalStatus + "\t" + tooling_msToSecondsText(totalMs) + "\n"
    let _timingWriteOk: bool = tooling_writeTextFileViaShell(root, timingOut, timingText)

fn tooling_selfhostInnerLoopWriteSummary(root: str, res: ToolingSelfhostInnerLoopResult): str =
    var outDir: str = res.outDir
    if !tooling_strNonEmpty(outDir):
        outDir = "artifacts/backend_selfhost_inner_loop"
    outDir = tooling_pathAbsolute(root, outDir)
    var summaryPath: str = res.summaryPath
    if !tooling_strNonEmpty(summaryPath):
        summaryPath = os.joinPath(outDir, "selfhost_inner_loop.summary.env")
    summaryPath = tooling_pathAbsolute(root, summaryPath)
    let summaryDir: str = os.parentDir(summaryPath)
    tooling_tryMkdirP(root, summaryDir)
    let inmemRes: ToolingSelfhostResult = res.inmemRes
    let strictRes: ToolingSelfhostResult = res.strictRes
    let buildOk: bool = res.buildRc == 0
    var inmemOk: bool = false
    if res.inmemRequested && inmemRes != nil:
        inmemOk = inmemRes.ok
    var strictOk: bool = false
    if res.strictRequested && strictRes != nil:
        strictOk = strictRes.ok
    let closureOk: bool = res.closureRequested && res.closureRc == 0
    let buildStatus: str = buildOk ? "ok" : "fail"
    let inmemStatus: str = !res.inmemRequested ? "skip" : (inmemOk ? "ok" : "fail")
    let strictStatus: str = !res.strictRequested ? "skip" : (strictOk ? "ok" : "fail")
    let closureStatus: str = !res.closureRequested ? "skip" : (closureOk ? "ok" : "fail")
    var out: str = ""
    out = out + "selfhost_inner_loop_version=1\n"
    out = out + "ok=" + tooling_boolText(res.ok) + "\n"
    out = out + "failed_step=" + tooling_summaryOneLine(res.failedStep) + "\n"
    out = out + "message=" + tooling_summaryOneLine(res.message) + "\n"
    out = out + "out_dir=" + outDir + "\n"
    out = out + "timing_path=" + tooling_summaryOneLine(res.timingPath) + "\n"
    out = out + "summary_path=" + summaryPath + "\n"
    out = out + "build_driver_path=" + tooling_summaryOneLine(res.buildDriverPath) + "\n"
    out = out + "build_driver_status=" + buildStatus + "\n"
    out = out + "build_driver_rc=" + intToStr(res.buildRc) + "\n"
    out = out + "build_driver_ms=" + intToStr(int32(res.buildMs)) + "\n"
    out = out + "inmem_requested=" + tooling_boolText(res.inmemRequested) + "\n"
    out = out + "inmem_status=" + inmemStatus + "\n"
    out = out + "inmem_ms=" + intToStr(int32(res.inmemMs)) + "\n"
    if inmemRes != nil:
        out = out + "inmem_message=" + tooling_summaryOneLine(inmemRes.message) + "\n"
        out = out + "inmem_stage0=" + tooling_summaryOneLine(inmemRes.stage0Path) + "\n"
        out = out + "inmem_stage0_driver_kind=" + tooling_summaryOneLine(inmemRes.stage0DriverKind) + "\n"
        out = out + "inmem_stage1=" + tooling_summaryOneLine(inmemRes.stage1Path) + "\n"
        out = out + "inmem_stage1_status=" + tooling_summaryOneLine(inmemRes.stage1Status) + "\n"
    out = out + "strict_requested=" + tooling_boolText(res.strictRequested) + "\n"
    out = out + "strict_status=" + strictStatus + "\n"
    out = out + "strict_ms=" + intToStr(int32(res.strictMs)) + "\n"
    if strictRes != nil:
        out = out + "strict_message=" + tooling_summaryOneLine(strictRes.message) + "\n"
        out = out + "strict_stage0=" + tooling_summaryOneLine(strictRes.stage0Path) + "\n"
        out = out + "strict_stage0_driver_kind=" + tooling_summaryOneLine(strictRes.stage0DriverKind) + "\n"
        out = out + "strict_stage1=" + tooling_summaryOneLine(strictRes.stage1Path) + "\n"
        out = out + "strict_stage2=" + tooling_summaryOneLine(strictRes.stage2Path) + "\n"
        out = out + "strict_stage3=" + tooling_summaryOneLine(strictRes.stage3Path) + "\n"
        out = out + "strict_stage1_status=" + tooling_summaryOneLine(strictRes.stage1Status) + "\n"
        out = out + "strict_stage1_compile_mode=" + tooling_summaryOneLine(strictRes.stage1CompileMode) + "\n"
        out = out + "strict_rebuild_ok=" + tooling_boolText(strictRes.strictRebuildOk) + "\n"
        out = out + "strict_fixed_point_ok=" + tooling_boolText(strictRes.fixedPointOk) + "\n"
        out = out + "strict_stage2_sha256=" + tooling_summaryOneLine(strictRes.stage2Sha256) + "\n"
        out = out + "strict_stage3_sha256=" + tooling_summaryOneLine(strictRes.stage3Sha256) + "\n"
        out = out + "strict_mismatch_report=" + tooling_summaryOneLine(strictRes.strictMismatchReport) + "\n"
    out = out + "closure_requested=" + tooling_boolText(res.closureRequested) + "\n"
    out = out + "closure_status=" + closureStatus + "\n"
    out = out + "closure_rc=" + intToStr(res.closureRc) + "\n"
    out = out + "closure_ms=" + intToStr(int32(res.closureMs)) + "\n"
    out = out + "total_ms=" + intToStr(int32(res.totalMs)) + "\n"
    let _summaryWriteOk: bool = tooling_writeTextFileViaShell(root, summaryPath, out)
    return summaryPath

fn tooling_compileBackendDriverStrictInmemWitness(root: str, stage0: str, target: str, outPath: str,
                                                  timeoutSec: int32,
                                                  allowBootstrapCapabilityRefresh: bool): int32 =
    let stage0IdentityPath: str = tooling_pathAbsolute(root, stage0)
    if !tooling_stage0CapabilityPreflightOkEx(root, stage0IdentityPath,
                                              "selfhost_strict_inmem_witness",
                                              allowBootstrapCapabilityRefresh):
        return 2
    let sourcePath: str = tooling_pathAbsolute(root, "src/backend/tooling/backend_driver.cheng")
    if !os.fileExists(sourcePath):
        tooling_printErr("cheng_tooling: strict inmem witness source not found: " + sourcePath)
        return 1
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir) && !tooling_mkdirP(root, outDir):
        tooling_printErr("cheng_tooling: strict inmem witness failed to create output dir: " + outDir)
        return 1
    var stage0Exec: str = tooling_prepareStage0Exec(root, stage0, "strict_inmem_witness")
    if !tooling_strNonEmpty(stage0Exec):
        return 1
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 1
    var runtimeObj: str = tooling_runtimeObjPath(root, target)
    if !os.fileExists(runtimeObj):
        runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
    let preferSeedBaseRuntimeObj: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_SEED_BASE_RUNTIME_OBJ", "1"))
    let stage0LowerRaw: str = strutil.toLowerAscii(strutil.strip(stage0))
    let seedLikeStage0: bool =
        tooling_strContains(stage0LowerRaw, "/artifacts/backend_selfhost_self_obj/cheng.stage2") ||
        tooling_strContains(stage0LowerRaw, "/artifacts/backend_selfhost_self_obj/cheng.stage1")
    if preferSeedBaseRuntimeObj && seedLikeStage0:
        let baseRuntimeObj: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng." + target + ".o")
        if os.fileExists(baseRuntimeObj):
            runtimeObj = baseRuntimeObj
    if !os.fileExists(runtimeObj):
        tooling_printErr("cheng_tooling: strict inmem witness missing runtime object: " + runtimeObj)
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 1
    if os.fileExists(outPath):
        os.removeFile(outPath)
    var compileCmdBase: str = ""
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS_STRICT", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("MM", "orc")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("CACHE", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_AUTO_SYSTEM", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_BUILD_TRACK", "dev")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("WHOLE_PROGRAM", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_WHOLE_PROGRAM", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("whole_program", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_STAGE1_PARSE_MODE", "full")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_FN_SCHED", "ws")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_DIRECT_EXE", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_LINKERLESS_INMEM", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_FAST_FALLBACK_ALLOW", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MULTI", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MULTI_FORCE", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MULTI_MODULE_CACHE", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MODULE_CACHE", "")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_MODULE_CACHE_UNSTABLE_ALLOW", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_INCREMENTAL", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_JOBS", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_FN_JOBS", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_VALIDATE", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_OPT_LEVEL", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_OPT", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_OPT2", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("UIR_SIMD", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_SKIP_CPROFILE", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("STAGE1_PROFILE", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("GENERIC_MODE", "dict")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("GENERIC_SPEC_BUDGET", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("GENERIC_LOWERING", "mir_dict")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_STAGE1_DISABLE_DUP_SCAN", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_STAGE1_BUILDER", "stage1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_SKIP_GLOBAL_INIT", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_SKIP_UIR_FIXUPS", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_SKIP_UIR_NORMALIZE", "0")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_LINKER", "self")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "1")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_RUNTIME_OBJ", runtimeObj)
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_EMIT", "exe")
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_TARGET", target)
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_INPUT", sourcePath)
    compileCmdBase = compileCmdBase + tooling_envAssignCompat("BACKEND_OUTPUT", outPath)
    compileCmdBase = compileCmdBase + tooling_envAssignCompat(
        "BACKEND_CFLAGS", "-DCHENG_BACKEND_DRIVER_ENTRY_SHIM=1")
    compileCmdBase = compileCmdBase + tooling_buildBackendDriverLegacyStage0Prefix(
        "dev", sourcePath, outPath, target, "self", "full", "ws",
        "0", "0", "0", 1, "0", "0", "0", "dict", "0", "mir_dict", runtimeObj)
    compileCmdBase = compileCmdBase + tooling_stage0LegacyCStringCompatPrefix(root, stage0Exec)
    compileCmdBase = compileCmdBase + tooling_shellQuote(stage0Exec)
    compileCmdBase = compileCmdBase + " " + tooling_shellQuote("--input:" + sourcePath)
    compileCmdBase = compileCmdBase + " " + tooling_shellQuote("--output:" + outPath)
    compileCmdBase = compileCmdBase + " " + tooling_shellQuote("--target:" + target)
    compileCmdBase = compileCmdBase + " " + tooling_shellQuote("--linker:self")
    compileCmdBase = tooling_prefixUnsetLegacyFrontendEnv(compileCmdBase)
    let compileCmd: str = tooling_wrapStage0LockTimeout(root, timeoutSec, compileCmdBase,
                                                        "strict_inmem_witness")
    let res: os.ExecCmdResult = tooling_exec(root, compileCmd)
    tooling_printExecOutput(res)
    let rc: int32 = os.execCmdResultExitCode(res)
    if rc != 0:
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return rc
    if !tooling_driverBuildOutputOk(root, outPath, "full", false, false, "self"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 1
    tooling_cleanupStage0Exec(stage0, stage0Exec)
    return 0

fn tooling_selfhostStrictInmemWitnessHost(root: str, outDirRaw: str, timingOutRaw: str,
                                          stage0Raw: str,
                                          allowBootstrapCapabilityRefresh: bool): ToolingSelfhostResult =
    var result: ToolingSelfhostResult = new(ToolingSelfhostResult)
    result.ok = false
    result.message = ""
    result.totalMs = int64(0)
    result.mode = "strict-inmem-witness"
    result.stage1Path = ""
    result.stage2Path = ""
    result.stage3Path = ""
    result.stage0Path = ""
    result.stage0DriverKind = "unknown"
    result.stage1Status = "init"
    result.stage1CompileMode = "full-inmem"
    result.stage1RebuildOk = false
    result.fallbackUsed = false
    result.quarantineCleaned = 0
    result.lockWaitMs = 0
    result.strictRebuildOk = false
    result.stage2Sha256 = ""
    result.stage3Sha256 = ""
    result.fixedPointOk = false
    result.strictMismatchReport = ""
    result.stage1CompileMs = int64(0)
    result.stage1SanityMs = int64(0)
    result.stage1CompileAttempts = 0
    result.stage1CompileSegfaults = 0

    let hostTag: str = tooling_detectHostTag(root)
    if !tooling_strEq(hostTag, "darwin_arm64"):
        result.message = "selfhost_strict_inmem_witness unsupported host: " + hostTag
        return result
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        result.message = "selfhost_strict_inmem_witness failed to resolve host target"
        return result
    result.quarantineCleaned = tooling_stage0QuarantineSweepUe(root, "selfhost_strict_inmem_witness")
    if tooling_stage0BlockOnQuarantineUe(root, "TOOLING_SELFHOST_BLOCK_ON_UE", "selfhost_strict_inmem_witness"):
        result.message = "selfhost_strict_inmem_witness blocked by quarantine stuck/orphan processes"
        return result
    let explicitStage0Raw: str = strutil.strip(stage0Raw)
    let stage0: str = tooling_resolveStage0DriverStrict(root, stage0Raw)
    if !tooling_strNonEmpty(stage0) && tooling_strNonEmpty(explicitStage0Raw):
        result.message = "selfhost_strict_inmem_witness explicit stage0 failed strict probe: " + explicitStage0Raw
        return result
    if !tooling_strNonEmpty(stage0):
        result.message = "selfhost_strict_inmem_witness missing stage0 driver"
        return result
    result.stage0Path = stage0
    result.stage0DriverKind = tooling_stage0DriverKind(root, stage0)

    var outDir: str = outDirRaw
    if !tooling_strNonEmpty(outDir):
        outDir = "artifacts/backend_selfhost_self_obj"
    outDir = tooling_pathAbsolute(root, outDir)
    if !tooling_mkdirP(root, outDir):
        result.message = "selfhost_strict_inmem_witness failed to create out dir: " + outDir
        return result
    result.stage1Path = os.joinPath(outDir, "cheng.stage1.inmem_witness")
    var timingOut: str = timingOutRaw
    if !tooling_strNonEmpty(timingOut):
        timingOut = os.joinPath(outDir, "selfhost_inmem_witness_timing_native.tsv")
    var timeoutSec: int32 = tooling_parseInt32Default(
        os.getEnvDefault("SELF_OBJ_BOOTSTRAP_INMEM_WITNESS_TIMEOUT", "60"), 60)
    if timeoutSec < 1:
        timeoutSec = 60
    let startedMs: int64 = tooling_nowMs()
    let stage1StartedMs: int64 = tooling_nowMs()
    let rcStage1: int32 = tooling_compileBackendDriverStrictInmemWitness(
        root, stage0, target, result.stage1Path, timeoutSec, allowBootstrapCapabilityRefresh)
    let stage1Ms: int64 = tooling_nowMs() - stage1StartedMs
    result.stage1CompileMs = stage1Ms
    result.stage1CompileAttempts = 1
    if rcStage1 != 0:
        result.totalMs = tooling_nowMs() - startedMs
        result.message = "selfhost_strict_inmem_witness stage1 compile failed rc=" +
                         intToStr(rcStage1) + " kind=" + tooling_exitKind(rcStage1)
        tooling_selfhostWriteTiming(root, outDir, timingOut, "fail", stage1Ms,
                                    "skip", int64(0), "skip", int64(0),
                                    "skip", int64(0), "fail", result.totalMs)
        return result
    result.ok = true
    result.message = "ok"
    result.stage1Status = "rebuild"
    result.stage1RebuildOk = true
    result.strictRebuildOk = true
    result.totalMs = tooling_nowMs() - startedMs
    tooling_selfhostWriteTiming(root, outDir, timingOut, "rebuild", stage1Ms,
                                "skip", int64(0), "skip", int64(0),
                                "skip", int64(0), "ok", result.totalMs)
    result.lockWaitMs = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_LOCK_WAIT_MS", ""), 0)
    return result

fn tooling_selfhostStrictWriteMismatchDiagnostics(root: str, outDirRaw: str,
                                                  stage2PathRaw: str, stage3PathRaw: str,
                                                  stage2Sha: str, stage3Sha: str): str =
    let outDir: str = tooling_pathAbsolute(root, outDirRaw)
    let stage2Path: str = tooling_pathAbsolute(root, stage2PathRaw)
    let stage3Path: str = tooling_pathAbsolute(root, stage3PathRaw)
    if !tooling_strNonEmpty(outDir) || !tooling_strNonEmpty(stage2Path) || !tooling_strNonEmpty(stage3Path):
        return ""
    let diagDir: str = os.joinPath(outDir, "strict_mismatch")
    tooling_tryMkdirP(root, diagDir)
    let summaryPath: str = os.joinPath(diagDir, "summary.env")
    let bytesDiffPath: str = os.joinPath(diagDir, "bytes.diff.txt")
    let stage2SymPath: str = os.joinPath(diagDir, "stage2.symbols.txt")
    let stage3SymPath: str = os.joinPath(diagDir, "stage3.symbols.txt")
    let symbolsDiffPath: str = os.joinPath(diagDir, "symbols.diff.txt")
    let stage2StringsPath: str = os.joinPath(diagDir, "stage2.strings.txt")
    let stage3StringsPath: str = os.joinPath(diagDir, "stage3.strings.txt")
    let stringsDiffPath: str = os.joinPath(diagDir, "strings.diff.txt")
    let cmpCmd: str =
        "if command -v cmp >/dev/null 2>&1; then " +
        "cmp -l " + tooling_shellQuote(stage2Path) + " " + tooling_shellQuote(stage3Path) +
        " | head -n 200 > " + tooling_shellQuote(bytesDiffPath) + "; " +
        "else : > " + tooling_shellQuote(bytesDiffPath) + "; fi"
    let _cmpRes: os.ExecCmdResult = tooling_exec(root, cmpCmd)
    let symbolCmd: str =
        "if command -v nm >/dev/null 2>&1; then " +
        "nm -nm " + tooling_shellQuote(stage2Path) + " > " + tooling_shellQuote(stage2SymPath) + " 2>/dev/null || true; " +
        "nm -nm " + tooling_shellQuote(stage3Path) + " > " + tooling_shellQuote(stage3SymPath) + " 2>/dev/null || true; " +
        "diff -u " + tooling_shellQuote(stage2SymPath) + " " + tooling_shellQuote(stage3SymPath) +
        " > " + tooling_shellQuote(symbolsDiffPath) + " 2>/dev/null || true; " +
        "else : > " + tooling_shellQuote(symbolsDiffPath) + "; fi"
    let _symbolRes: os.ExecCmdResult = tooling_exec(root, symbolCmd)
    let stringsCmd: str =
        "if command -v strings >/dev/null 2>&1; then " +
        "strings " + tooling_shellQuote(stage2Path) + " > " + tooling_shellQuote(stage2StringsPath) + " 2>/dev/null || true; " +
        "strings " + tooling_shellQuote(stage3Path) + " > " + tooling_shellQuote(stage3StringsPath) + " 2>/dev/null || true; " +
        "diff -u " + tooling_shellQuote(stage2StringsPath) + " " + tooling_shellQuote(stage3StringsPath) +
        " > " + tooling_shellQuote(stringsDiffPath) + " 2>/dev/null || true; " +
        "else : > " + tooling_shellQuote(stringsDiffPath) + "; fi"
    let _stringsRes: os.ExecCmdResult = tooling_exec(root, stringsCmd)
    var summary: str = ""
    summary = summary + "strict_mismatch_report_version=1\n"
    summary = summary + "stage2_path=" + stage2Path + "\n"
    summary = summary + "stage3_path=" + stage3Path + "\n"
    summary = summary + "stage2_sha256=" + stage2Sha + "\n"
    summary = summary + "stage3_sha256=" + stage3Sha + "\n"
    summary = summary + "bytes_diff=" + bytesDiffPath + "\n"
    summary = summary + "symbols_diff=" + symbolsDiffPath + "\n"
    summary = summary + "strings_diff=" + stringsDiffPath + "\n"
    let _summaryWriteOk: bool = tooling_writeTextFileViaShell(root, summaryPath, summary)
    return summaryPath

fn tooling_selfhostBootstrapStrictHost(root: str, outDirRaw: str, timingOutRaw: str,
                                       stage0Raw: str, allowBootstrapCapabilityRefresh: bool): ToolingSelfhostResult =
    var result: ToolingSelfhostResult = new(ToolingSelfhostResult)
    result.ok = false
    result.message = ""
    result.totalMs = int64(0)
    result.mode = "strict"
    result.stage1Path = ""
    result.stage2Path = ""
    result.stage3Path = ""
    result.stage0Path = ""
    result.stage0DriverKind = "unknown"
    result.stage1Status = "init"
    result.stage1CompileMode = "full"
    result.stage1RebuildOk = false
    result.fallbackUsed = false
    result.quarantineCleaned = 0
    result.lockWaitMs = 0
    result.strictRebuildOk = false
    result.stage2Sha256 = ""
    result.stage3Sha256 = ""
    result.fixedPointOk = false
    result.strictMismatchReport = ""
    result.stage1CompileMs = int64(0)
    result.stage1SanityMs = int64(0)
    result.stage1CompileAttempts = 0
    result.stage1CompileSegfaults = 0

    let hostTag: str = tooling_detectHostTag(root)
    if !tooling_strEq(hostTag, "darwin_arm64"):
        result.message = "selfhost_strict_host unsupported host: " + hostTag
        return result
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        result.message = "selfhost_strict_host failed to resolve host target"
        return result
    result.quarantineCleaned = tooling_stage0QuarantineSweepUe(root, "selfhost_strict_host")
    if tooling_stage0BlockOnQuarantineUe(root, "TOOLING_SELFHOST_BLOCK_ON_UE", "selfhost_strict_host"):
        result.message = "selfhost_strict_host blocked by quarantine stuck/orphan processes"
        return result

    let explicitStage0Raw: str = strutil.strip(stage0Raw)
    let stage0: str = tooling_resolveStage0DriverStrict(root, stage0Raw)
    if !tooling_strNonEmpty(stage0) && tooling_strNonEmpty(explicitStage0Raw):
        result.message = "selfhost_strict_host explicit stage0 failed strict probe: " + explicitStage0Raw
        return result
    if !tooling_strNonEmpty(stage0):
        result.message = "selfhost_strict_host missing stage0 driver"
        return result
    result.stage0Path = stage0
    result.stage0DriverKind = tooling_stage0DriverKind(root, stage0)

    var outDir: str = outDirRaw
    if !tooling_strNonEmpty(outDir):
        outDir = "artifacts/backend_selfhost_self_obj"
    outDir = tooling_pathAbsolute(root, outDir)
    if !tooling_mkdirP(root, outDir):
        result.message = "selfhost_strict_host failed to create out dir: " + outDir
        return result
    result.stage1Path = os.joinPath(outDir, "cheng.stage1")
    result.stage2Path = os.joinPath(outDir, "cheng.stage2")
    result.stage3Path = os.joinPath(outDir, "cheng.stage3.witness")
    let stage3BuildDir: str = os.joinPath(outDir, ".strict_stage3_build")
    let stage3BuildPath: str = os.joinPath(stage3BuildDir, "cheng.stage2")

    let strictDiagAllowMismatch: bool = tooling_isTrue(
        os.getEnvDefault("SELF_OBJ_BOOTSTRAP_STRICT_DIAG_ALLOW_MISMATCH", "0"))
    let strictForceProbeOnFull: bool = tooling_isTrue(
        os.getEnvDefault("SELF_OBJ_BOOTSTRAP_STRICT_FORCE_PROBE", "0"))
    let strictSkipSem: str = "0"
    let strictSkipOwnership: str = "0"
    let strictLinkerMode: str = tooling_buildDriverEffectiveLinkerMode(
        tooling_buildDriverStrictNativeEnabled())

    let startedMs: int64 = tooling_nowMs()
    var stage1Ms: int64 = int64(0)
    var stage2Ms: int64 = int64(0)
    var stage3Ms: int64 = int64(0)
    var hashMs: int64 = int64(0)
    var stage1Status: str = "fail"
    var stage2Status: str = "skip"
    var stage3Status: str = "skip"
    var hashStatus: str = "skip"

    let stage1StartedMs: int64 = tooling_nowMs()
    let rcStage1: int32 = tooling_compileBackendDriverFastHostWithRebuildPolicy(
        root, stage0, target, result.stage1Path, true, strictSkipSem, strictSkipOwnership,
        allowBootstrapCapabilityRefresh)
    stage1Ms = tooling_nowMs() - stage1StartedMs
    if rcStage1 != 0:
        result.message = "selfhost_strict_host stage1 compile failed rc=" + intToStr(rcStage1) +
                         " kind=" + tooling_exitKind(rcStage1)
        let totalFail1: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail1
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail1)
        return result
    if !tooling_driverBuildOutputOk(root, result.stage1Path, "full", false, strictForceProbeOnFull,
                                    strictLinkerMode):
        result.message = "selfhost_strict_host stage1 output sanity failed"
        let totalFail1Sanity: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail1Sanity
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail1Sanity)
        return result
    stage1Status = "rebuild"
    result.stage1Status = "rebuild"
    result.stage1CompileMode = "full"
    result.stage1RebuildOk = true
    result.strictRebuildOk = true

    let stage2StartedMs: int64 = tooling_nowMs()
    let rcStage2: int32 = tooling_compileBackendDriverFastHostWithRebuildPolicy(
        root, result.stage1Path, target, result.stage2Path, true, strictSkipSem, strictSkipOwnership,
        false)
    stage2Ms = tooling_nowMs() - stage2StartedMs
    if rcStage2 != 0:
        stage2Status = "fail"
        result.message = "selfhost_strict_host stage2 compile failed rc=" + intToStr(rcStage2) +
                         " kind=" + tooling_exitKind(rcStage2)
        let totalFail2: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail2
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail2)
        return result
    if !tooling_driverBuildOutputOk(root, result.stage2Path, "full", false, strictForceProbeOnFull,
                                    strictLinkerMode):
        stage2Status = "fail"
        result.message = "selfhost_strict_host stage2 output sanity failed"
        let totalFail2Sanity: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail2Sanity
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail2Sanity)
        return result
    stage2Status = "rebuild"

    tooling_tryMkdirP(root, stage3BuildDir)
    let stage3StartedMs: int64 = tooling_nowMs()
    let rcStage3: int32 = tooling_compileBackendDriverFastHostWithRebuildPolicy(
        root, result.stage2Path, target, stage3BuildPath, true, strictSkipSem, strictSkipOwnership,
        false)
    stage3Ms = tooling_nowMs() - stage3StartedMs
    if rcStage3 != 0:
        stage3Status = "fail"
        result.message = "selfhost_strict_host stage3 witness compile failed rc=" + intToStr(rcStage3) +
                         " kind=" + tooling_exitKind(rcStage3)
        let totalFail3: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail3
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail3)
        return result
    if !tooling_driverBuildOutputOk(root, stage3BuildPath, "full", false, strictForceProbeOnFull,
                                    strictLinkerMode):
        stage3Status = "fail"
        result.message = "selfhost_strict_host stage3 witness output sanity failed"
        let totalFail3Sanity: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail3Sanity
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail3Sanity)
        return result
    if !tooling_copyExecutablePreserveBytes(root, stage3BuildPath, result.stage3Path):
        stage3Status = "fail"
        result.message = "selfhost_strict_host stage3 witness copy failed"
        let totalFail3Copy: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail3Copy
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail3Copy)
        return result
    stage3Status = "rebuild"

    let hashStartedMs: int64 = tooling_nowMs()
    result.stage2Sha256 = tooling_sha256File(root, result.stage2Path)
    result.stage3Sha256 = tooling_sha256File(root, result.stage3Path)
    hashMs = tooling_nowMs() - hashStartedMs
    if !tooling_strNonEmpty(result.stage2Sha256) || !tooling_strNonEmpty(result.stage3Sha256):
        hashStatus = "fail"
        result.message = "selfhost_strict_host requires SHA-256 tool (shasum or sha256sum)"
        let totalHashFail: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalHashFail
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalHashFail)
        return result

    result.fixedPointOk = tooling_strEq(result.stage2Sha256, result.stage3Sha256)
    if result.fixedPointOk:
        hashStatus = "ok"
        result.message = "ok"
        result.ok = true
    else:
        hashStatus = "mismatch"
        result.strictMismatchReport = tooling_selfhostStrictWriteMismatchDiagnostics(
            root, outDir, result.stage2Path, result.stage3Path, result.stage2Sha256, result.stage3Sha256)
        if strictDiagAllowMismatch:
            result.ok = true
            result.message = "selfhost_strict_host fixed-point mismatch allowed by SELF_OBJ_BOOTSTRAP_STRICT_DIAG_ALLOW_MISMATCH=1"
            if tooling_strNonEmpty(result.strictMismatchReport):
                result.message = result.message + " report=" + result.strictMismatchReport
        else:
            result.ok = false
            result.message = "selfhost_strict_host fixed-point mismatch stage2=" + result.stage2Sha256 +
                             " stage3=" + result.stage3Sha256 +
                             " stage2_path=" + result.stage2Path +
                             " stage3_path=" + result.stage3Path
            if tooling_strNonEmpty(result.strictMismatchReport):
                result.message = result.message + " report=" + result.strictMismatchReport
    let totalMs: int64 = tooling_nowMs() - startedMs
    result.totalMs = totalMs
    let totalStatus: str = result.ok ? "ok" : "fail"
    tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                stage2Status, stage2Ms, stage3Status, stage3Ms,
                                hashStatus, hashMs, totalStatus, totalMs)
    result.lockWaitMs = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_LOCK_WAIT_MS", ""), 0)
    return result

fn tooling_selfhostInnerLoop(root: str, outDirRaw: str, timingOutRaw: str,
                             runInmemWitness: bool, runStrict: bool,
                             runClosure: bool): ToolingSelfhostInnerLoopResult =
    var result: ToolingSelfhostInnerLoopResult = new(ToolingSelfhostInnerLoopResult)
    result.ok = false
    result.message = ""
    result.totalMs = int64(0)
    result.outDir = "artifacts/backend_selfhost_inner_loop"
    if tooling_strNonEmpty(outDirRaw):
        result.outDir = outDirRaw
    result.outDir = tooling_pathAbsolute(root, result.outDir)
    result.summaryPath = os.joinPath(result.outDir, "selfhost_inner_loop.summary.env")
    result.timingPath = os.joinPath(result.outDir, "selfhost_inner_loop_timing.tsv")
    if tooling_strNonEmpty(timingOutRaw):
        result.timingPath = tooling_pathAbsolute(root, timingOutRaw)
    result.buildDriverPath = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    result.buildMs = int64(0)
    result.buildRc = 1
    result.inmemRequested = runInmemWitness
    result.inmemMs = int64(0)
    result.inmemRes = nil
    result.strictRequested = runStrict
    result.strictMs = int64(0)
    result.strictRes = nil
    result.closureRequested = runClosure
    result.closureMs = int64(0)
    result.closureRc = 0
    result.failedStep = ""
    if !tooling_mkdirP(root, result.outDir):
        result.message = "selfhost_inner_loop failed to create out dir: " + result.outDir
        result.failedStep = "setup"
        return result

    let startedMs: int64 = tooling_nowMs()
    var buildStatus: str = "fail"
    var inmemStatus: str = "skip"
    var strictStatus: str = "skip"
    var closureStatus: str = "skip"
    if runInmemWitness:
        inmemStatus = "fail"
    if runStrict:
        strictStatus = "fail"
    if runClosure:
        closureStatus = "fail"

    let buildStartedMs: int64 = tooling_nowMs()
    let buildRc: int32 = tooling_cmdBuildBackendDriver(
        root, result.buildDriverPath, "", "", true, false, "seal")
    result.buildMs = tooling_nowMs() - buildStartedMs
    result.buildRc = buildRc
    if buildRc != 0:
        result.message = "selfhost_inner_loop build-backend-driver failed rc=" + intToStr(buildRc)
        result.failedStep = "build_driver"
        result.totalMs = tooling_nowMs() - startedMs
        tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                             buildStatus, result.buildMs,
                                             inmemStatus, result.inmemMs,
                                             strictStatus, result.strictMs,
                                             closureStatus, result.closureMs,
                                             "fail", result.totalMs)
        result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
        return result
    buildStatus = "ok"

    if runInmemWitness:
        let inmemOutDir: str = os.joinPath(result.outDir, "inmem_witness")
        let inmemTimingPath: str = os.joinPath(inmemOutDir, "selfhost_inmem_witness_timing_native.tsv")
        let inmemStartedMs: int64 = tooling_nowMs()
        result.inmemRes = tooling_selfhostStrictInmemWitnessHost(root, inmemOutDir, inmemTimingPath, "", false)
        result.inmemMs = tooling_nowMs() - inmemStartedMs
        let inmemRes: ToolingSelfhostResult = result.inmemRes
        if inmemRes == nil || !inmemRes.ok:
            result.message = "selfhost_inner_loop inmem witness failed"
            if inmemRes != nil && tooling_strNonEmpty(inmemRes.message):
                result.message = inmemRes.message
            if !tooling_strNonEmpty(result.message):
                result.message = "selfhost_inner_loop inmem witness failed"
            result.failedStep = "inmem_witness"
            result.totalMs = tooling_nowMs() - startedMs
            tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                                 buildStatus, result.buildMs,
                                                 inmemStatus, result.inmemMs,
                                                 strictStatus, result.strictMs,
                                                 closureStatus, result.closureMs,
                                                 "fail", result.totalMs)
            result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
            return result
        inmemStatus = "ok"
    else:
        inmemStatus = "skip"

    if runStrict:
        let strictOutDir: str = os.joinPath(result.outDir, "strict_host")
        let strictTimingPath: str = os.joinPath(strictOutDir, "selfhost_timing_native.tsv")
        let strictStartedMs: int64 = tooling_nowMs()
        result.strictRes = tooling_selfhostBootstrapStrictHost(root, strictOutDir, strictTimingPath, "", false)
        result.strictMs = tooling_nowMs() - strictStartedMs
        let strictRes: ToolingSelfhostResult = result.strictRes
        if strictRes == nil || !strictRes.ok:
            result.message = "selfhost_inner_loop strict host failed"
            if strictRes != nil && tooling_strNonEmpty(strictRes.message):
                result.message = strictRes.message
            if !tooling_strNonEmpty(result.message):
                result.message = "selfhost_inner_loop strict host failed"
            result.failedStep = "strict_host"
            result.totalMs = tooling_nowMs() - startedMs
            tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                                 buildStatus, result.buildMs,
                                                 inmemStatus, result.inmemMs,
                                                 strictStatus, result.strictMs,
                                                 closureStatus, result.closureMs,
                                                 "fail", result.totalMs)
            result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
            return result
        strictStatus = "ok"
    else:
        strictStatus = "skip"

    if runClosure:
        let closureStartedMs: int64 = tooling_nowMs()
        result.closureRc = tooling_cmdBackendProdClosureFromArgs(root, 1, 0)
        result.closureMs = tooling_nowMs() - closureStartedMs
        if result.closureRc != 0:
            result.message = "selfhost_inner_loop backend_prod_closure failed rc=" + intToStr(result.closureRc)
            result.failedStep = "closure"
            result.totalMs = tooling_nowMs() - startedMs
            tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                                 buildStatus, result.buildMs,
                                                 inmemStatus, result.inmemMs,
                                                 strictStatus, result.strictMs,
                                                 closureStatus, result.closureMs,
                                                 "fail", result.totalMs)
            result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
            return result
        closureStatus = "ok"
    else:
        closureStatus = "skip"

    result.ok = true
    result.message = "ok"
    result.failedStep = ""
    result.totalMs = tooling_nowMs() - startedMs
    tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                         buildStatus, result.buildMs,
                                         inmemStatus, result.inmemMs,
                                         strictStatus, result.strictMs,
                                         closureStatus, result.closureMs,
                                         "ok", result.totalMs)
    result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
    return result

fn tooling_sortInt32Asc(values: int32[]): int32[] =
    var out: int32[] = []
    if values.len > 0:
        reserve(out, values.len)
        setLen(out, values.len)
    for i in 0..<values.len:
        out[i] = values[i]
    for i in 1..<out.len:
        let key: int32 = out[i]
        var j: int32 = i - 1
        while j >= 0:
            if out[j] <= key:
                break
            out[j + 1] = out[j]
            j = j - 1
        out[j + 1] = key
    return out

fn toolingAppendInt32(seqInst: var int32[], val: int32) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn tooling_pickPercentile(sorted: int32[], pct: int32): int32 =
    if sorted.len <= 0:
        return -1
    var k: int32 = (pct * sorted.len + 99) / 100
    if k < 1:
        k = 1
    if k > sorted.len:
        k = sorted.len
    return sorted[k - 1]

fn tooling_pickPercentileNoSort(values: int32[], pct: int32): int32 =
    if values.len <= 0:
        return -1
    var k: int32 = (pct * values.len + 99) / 100
    if k < 1:
        k = 1
    if k > values.len:
        k = values.len
    var best: int32 = 0
    var bestSet: bool = false
    for i in 0..<values.len:
        let cand: int32 = values[i]
        var lessCnt: int32 = 0
        var lessEqCnt: int32 = 0
        for j in 0..<values.len:
            let v: int32 = values[j]
            if v < cand:
                lessCnt = lessCnt + 1
            if v <= cand:
                lessEqCnt = lessEqCnt + 1
        if lessCnt < k && k <= lessEqCnt:
            if !bestSet || cand < best:
                best = cand
                bestSet = true
    if bestSet:
        return best
    var fallbackMax: int32 = values[0]
    for i in 1..<values.len:
        if values[i] > fallbackMax:
            fallbackMax = values[i]
    return fallbackMax

fn tooling_backendDriverHistoryKeep(name: str): bool =
    if tooling_strEq(name, "cheng"):
        return true
    if tooling_strEq(name, "cheng.full_rebuild.stamp.env"):
        return true
    if tooling_strEq(name, "cheng.objs"):
        return true
    if tooling_strEq(name, "cheng.objs.lock"):
        return true
    return false

fn tooling_cmdCleanupBackendDriverHistory(root: str, dryRun: bool): int32 =
    let backendDir: str = os.joinPath(root, "artifacts/backend_driver")
    if !os.dirExists(backendDir):
        tooling_printOut("cleanup_backend_driver_history_status=noop")
        tooling_printOut("cleanup_backend_driver_history_dir_missing=" + backendDir)
        return 0
    let scanCmd: str = "find " + tooling_shellQuote(backendDir) + " -maxdepth 1 -mindepth 1 -name 'cheng*' -print"
    let scanRes: os.ExecCmdResult = tooling_exec(root, scanCmd)
    let scanRc: int32 = os.execCmdResultExitCode(scanRes)
    if scanRc != 0:
        tooling_printErr("cheng_tooling: cleanup_backend_driver_history scan failed")
        tooling_printExecOutput(scanRes)
        return scanRc
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(scanRes))
    var removedCount: int32 = 0
    var keepCount: int32 = 0
    var scannedCount: int32 = 0
    for i in 0..<rows.len:
        let path: str = strutil.strip(rows[i])
        if !tooling_strNonEmpty(path):
            continue
        scannedCount = scannedCount + 1
        let base: str = os.extractFilename(path)
        if tooling_backendDriverHistoryKeep(base):
            keepCount = keepCount + 1
            continue
        removedCount = removedCount + 1
        if dryRun:
            tooling_printOut("cleanup_backend_driver_history_plan_remove=" + path)
            continue
        let rmCmd: str = "rm -rf " + tooling_shellQuote(path)
        let rmRes: os.ExecCmdResult = tooling_exec(root, rmCmd)
        let rmRc: int32 = os.execCmdResultExitCode(rmRes)
        if rmRc != 0:
            tooling_printErr("cheng_tooling: cleanup_backend_driver_history remove failed: " + path)
            tooling_printExecOutput(rmRes)
            return rmRc
    tooling_printOut("cleanup_backend_driver_history_scanned=" + intToStr(scannedCount))
    tooling_printOut("cleanup_backend_driver_history_kept=" + intToStr(keepCount))
    tooling_printOut("cleanup_backend_driver_history_removed=" + intToStr(removedCount))
    if dryRun:
        tooling_printOut("cleanup_backend_driver_history_dry_run=1")
    else:
        tooling_printOut("cleanup_backend_driver_history_dry_run=0")
    return 0

fn tooling_cmdToolchainRoot(root: str): int32 =
    tooling_printOut("toolchain_root=" + os.absolutePath(root))
    return 0

fn tooling_cmdDetectHostTarget(root: str): int32 =
    let target: str = tooling_detectHostTarget(root)
    if tooling_strNonEmpty(target):
        tooling_printOut(target)
        return 0
    tooling_printErr("cheng_tooling: failed to detect host target")
    return 1

fn tooling_cmdDriverPath(root: str, pathOnly: bool): int32 =
    let stage0: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if !tooling_isExecutable(root, stage0):
        tooling_printErr("cheng_tooling: canonical stage0 driver missing: " + stage0)
        return 1
    if tooling_stage0BlockStamped(root, stage0):
        tooling_printErr("cheng_tooling: canonical stage0 driver blocked by quarantine stamp: " + stage0)
        tooling_printErr("cheng_tooling: cut off invocation chain to prevent new UE; rebuild/replace canonical driver")
        return 2
    if !tooling_driverSanityOk(root, stage0):
        tooling_printErr("cheng_tooling: canonical stage0 driver failed sanity: " + stage0)
        tooling_printErr("cheng_tooling: cut off invocation chain to prevent new UE; replace driver before retry")
        return 2
    if tooling_stage0HasUninterruptibleProcess(root, stage0):
        tooling_printErr("cheng_tooling: canonical stage0 driver blocked by stuck/orphan UE process: " + stage0)
        tooling_printErr("cheng_tooling: cut off invocation chain to prevent new UE; replace driver before retry")
        return 2
    if pathOnly:
        tooling_printOut(stage0)
        return 0
    let stage0Sha: str = tooling_sha256File(root, stage0)
    tooling_printOut("toolchain_root=" + os.absolutePath(root))
    tooling_printOut("driver_path=" + stage0)
    tooling_printOut("driver_sha256=" + stage0Sha)
    tooling_printOut("driver_kind=canonical")
    return 0

fn tooling_cmdCleanupBackendDriverHistoryFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var dryRun: bool = false
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("cleanup-backend-driver-history options:")
            tooling_printOut("  --dry-run                   print files to remove, no write")
            return 0
        if tooling_strEq(arg, "--dry-run"):
            dryRun = true
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown cleanup-backend-driver-history arg: " + arg)
        return 1
    return tooling_cmdCleanupBackendDriverHistory(root, dryRun)

fn tooling_cmdBuildBackendDriver(root: str, outRaw: str, stage0Raw: str, targetRaw: str,
                                 requireRebuild: bool, debugRebuild: bool, modeRaw: str): int32 =
    var target: str = tooling_trimAsciiSpace(targetRaw)
    if !tooling_strNonEmpty(target):
        target = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        tooling_printErr("cheng_tooling: failed to detect target")
        return 1
    var attemptSweepCleaned: int32 = tooling_backendDriverSweepAttemptOrphans(root, "build_backend_driver.pre")
    tooling_printOut("build_backend_driver_attempt_cleaned_pre=" + intToStr(attemptSweepCleaned))
    if !tooling_stage0QuarantineEnabled() &&
       tooling_stage0BlockOnQuarantineUe(root, "TOOLING_BUILD_DRIVER_BLOCK_ON_UE", "build_backend_driver"):
        return 1
    let explicitStage0Raw: str = strutil.strip(stage0Raw)
    let stage0ProbeEnabled: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_STAGE0_PROBE", "0"))
    var stage0Candidates: str[] = tooling_stage0CandidateListWithProbe(root, stage0Raw, stage0ProbeEnabled)
    if !tooling_strNonEmpty(explicitStage0Raw):
        let preferredStage0: str = tooling_buildBackendDriverPreferredStage0(root, stage0ProbeEnabled)
        if tooling_strNonEmpty(preferredStage0) && !tooling_idsContains(stage0Candidates, preferredStage0):
            var preferredCandidates: str[] = []
            add(preferredCandidates, preferredStage0)
            for pi in 0..<stage0Candidates.len:
                if !tooling_strEq(stage0Candidates[pi], preferredStage0):
                    add(preferredCandidates, stage0Candidates[pi])
            stage0Candidates = preferredCandidates
    if tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_DRIVER_DIST_RECOVERY", "0")):
        tooling_printErr("cheng_tooling: ignore removed env TOOLING_BUILD_DRIVER_DIST_RECOVERY (single canonical driver only)")
    if stage0Candidates.len <= 0 && tooling_strNonEmpty(explicitStage0Raw):
        tooling_printErr("cheng_tooling: explicit stage0 failed strict probe: " + explicitStage0Raw)
        return 1
    if stage0Candidates.len <= 0:
        tooling_printErr("cheng_tooling: stage0 driver not found")
        return 1
    var outPath: str = outRaw
    if !tooling_strNonEmpty(outPath):
        outPath = "artifacts/backend_driver/cheng"
    outPath = tooling_pathAbsolute(root, outPath)
    let canonicalDriverPath: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    let autoCleanHistory: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_AUTO_CLEAN_HISTORY", "1"))
    let buildMode: str = tooling_buildDriverRequestedMode(modeRaw, requireRebuild, debugRebuild)
    if !tooling_strNonEmpty(buildMode):
        tooling_printErr("cheng_tooling: invalid build-backend-driver mode: " + modeRaw + " (expected auto|fast|seal)")
        return 2
    let fullRebuild: bool = tooling_strEq(buildMode, "seal")
    let compileMode: str = fullRebuild ? "full" : "quick"
    let strictNative: bool = tooling_buildDriverEffectiveStrictNativeForRebuild(fullRebuild)
    let buildLinkerMode: str = tooling_buildDriverEffectiveLinkerMode(strictNative)
    let allowFallback: bool = tooling_buildDriverAllowFallbackEnabled()
    let quickLightSanity: bool = !fullRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_QUICK_LIGHT_SANITY", "1"))
    let forceProbeDefault: str = strictNative ? "1" : "0"
    let forceProbeOnFull: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_FULL_FORCE_PROBE", forceProbeDefault))
    let noRecover: bool = !allowFallback || tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_NO_RECOVER", "1"))
    let eagerRebuild: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_EAGER_REBUILD", "0"))
    let directFastReuse: bool = !fullRebuild && !requireRebuild && !debugRebuild && !eagerRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_FAST_REUSE", "1"))
    tooling_printOut("build_backend_driver_mode=" + buildMode)
    if directFastReuse:
        let existingOkFast: bool = tooling_buildDriverDirectFastReuseOk(
            root, outPath, target, buildLinkerMode, quickLightSanity)
        if existingOkFast:
            let _clearedReuseFast: int32 =
                tooling_stage0ClearStamps(root, outPath, "build_backend_driver.reuse_existing")
            tooling_printOut("build_backend_driver_compile_mode=" + compileMode)
            tooling_printOut("build_backend_driver_rebuilt=0")
            tooling_printOut("build_backend_driver_fallback_used=0")
            tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
            tooling_printOut("build_backend_driver_fast_path=reuse_existing")
            tooling_printOut("build_backend_driver_ok=" + outPath)
            if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                let cleanRcFast: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                if cleanRcFast != 0:
                    return cleanRcFast
            return 0
        let existingOkAfterReject: bool =
            tooling_buildDriverFastCanonicalRejectHit(root, outPath, target) &&
            tooling_driverBuildOutputOk(root, outPath, compileMode, quickLightSanity, false, buildLinkerMode)
        if existingOkAfterReject:
            let _clearedReuseAfterReject: int32 =
                tooling_stage0ClearStamps(root, outPath, "build_backend_driver.reuse_existing_after_reject")
            tooling_printOut("build_backend_driver_compile_mode=" + compileMode)
            tooling_printOut("build_backend_driver_rebuilt=0")
            tooling_printOut("build_backend_driver_fallback_used=0")
            tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
            tooling_printOut("build_backend_driver_fast_path=reuse_existing_after_source_reject")
            tooling_printOut("build_backend_driver_ok=" + outPath)
            if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                let cleanRcFastReject: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                if cleanRcFastReject != 0:
                    return cleanRcFastReject
            return 0
    var stage0AttemptCandidates: str[] = stage0Candidates
    var attemptCount: int32 = stage0AttemptCandidates.len
    var maxStage0Attempts: int32 = tooling_parseInt32Default(os.getEnvDefault("BACKEND_BUILD_DRIVER_MAX_STAGE0_ATTEMPTS", ""), 0)
    if maxStage0Attempts < 0:
        maxStage0Attempts = 0
    if maxStage0Attempts > 0 && maxStage0Attempts < attemptCount:
        attemptCount = maxStage0Attempts
    let debugRebuildEnabled: bool = debugRebuild ||
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_DEBUG_REBUILD", "0"))
    let keepFailedAttempt: bool = debugRebuildEnabled ||
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_KEEP_FAILED_ATTEMPT", "0"))
    var debugDir: str = ""
    if debugRebuildEnabled:
        debugDir = os.joinPath(root, "artifacts/stage0_candidate_probe/build_backend_driver_debug." + tooling_nowNonceText())
        tooling_tryMkdirP(root, debugDir)
        var sessionMeta: str = ""
        sessionMeta = sessionMeta + "debug_rebuild=1\n"
        sessionMeta = sessionMeta + "build_mode=" + buildMode + "\n"
        sessionMeta = sessionMeta + "require_rebuild=" + (requireRebuild ? "1" : "0") + "\n"
        sessionMeta = sessionMeta + "target=" + target + "\n"
        sessionMeta = sessionMeta + "out_path=" + outPath + "\n"
        sessionMeta = sessionMeta + "attempt_count=" + intToStr(attemptCount) + "\n"
        let sessionPath: str = os.joinPath(debugDir, "session.env")
        if !tooling_writeTextFileViaShell(root, sessionPath, sessionMeta):
            tooling_printErr("cheng_tooling: failed to write debug session meta: " + sessionPath)
        tooling_printOut("build_backend_driver_debug_dir=" + debugDir)
    var lastRc: int32 = 1
    var lastCompileMode: str = compileMode
    var lastStage0: str = ""
    var fallbackStage0: str = ""
    var sawCanonicalQuickSmokeFail: bool = false
    var i: int32 = 0
    while i < attemptCount:
        let stage0: str = stage0AttemptCandidates[i]
        var stage0ReusePath: str = stage0
        var attemptFallbackUsed: bool = i > 0
        if !tooling_strNonEmpty(fallbackStage0):
            fallbackStage0 = stage0
        let attemptIndex: int32 = i + 1
        tooling_printErr("cheng_tooling: build_backend_driver stage0 attempt " + intToStr(attemptIndex) +
                         "/" + intToStr(attemptCount) + " driver=" + stage0)
        let persistentQuickCachePath: bool = !debugRebuildEnabled && !fullRebuild
        var attemptOutPath: str = tooling_driverBuildTempPath(root, outPath, attemptIndex)
        if persistentQuickCachePath:
            attemptOutPath = tooling_driverBuildQuickCachePath(root, outPath, attemptIndex)
        if !persistentQuickCachePath:
            tooling_driverBuildTempCleanup(root, attemptOutPath)
        var attemptCompileMode: str = compileMode
        var rc: int32 = tooling_compileBackendDriverFastHost(root, stage0ReusePath, target, attemptOutPath, fullRebuild)
        var postBuildOk: bool = false
        var forceProbeThisAttempt: bool = fullRebuild && forceProbeOnFull
        var requireCanonicalQuickSmoke: bool = false
        var canonicalQuickSmokeFailed: bool = false
        if rc == 0:
            postBuildOk = tooling_driverBuildOutputOk(root, attemptOutPath, attemptCompileMode,
                                                      quickLightSanity, forceProbeThisAttempt,
                                                      buildLinkerMode)
            requireCanonicalQuickSmoke = postBuildOk &&
                tooling_buildDriverFastCanonicalSmokeEnabled(root, outPath, fullRebuild)
            if requireCanonicalQuickSmoke && !tooling_buildDriverFastCanonicalSmokeOk(root, attemptOutPath):
                canonicalQuickSmokeFailed = true
                sawCanonicalQuickSmokeFail = true
                postBuildOk = false
                tooling_stage0MarkBlocked(root, attemptOutPath, 1,
                                          "build_backend_driver_fast_canonical_smoke",
                                          "canonical_smoke")
                let _rejectWritten: bool =
                    tooling_buildDriverFastCanonicalRejectWrite(root, outPath, target)
                tooling_printErr("cheng_tooling: fast canonical smoke rejected candidate: " + attemptOutPath)
        lastRc = rc
        lastCompileMode = attemptCompileMode
        if debugRebuildEnabled:
            tooling_buildDriverDebugAttemptRecord(debugDir, attemptIndex, stage0, attemptOutPath, rc,
                                                  postBuildOk, attemptCompileMode)
        if rc == 0 && postBuildOk:
            if debugRebuildEnabled:
                let _clearedDebugAttempt: int32 =
                    tooling_stage0ClearStamps(root, attemptOutPath, "build_backend_driver.debug_output")
                tooling_printErr("cheng_tooling: build-backend-driver debug-rebuild mode enabled; skip canonical install")
                tooling_printOut("build_backend_driver_compile_mode=" + attemptCompileMode)
                tooling_printOut("build_backend_driver_rebuilt=1")
                tooling_printOut("build_backend_driver_fallback_used=" + (attemptFallbackUsed ? "1" : "0"))
                tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
                tooling_printOut("build_backend_driver_debug_output=" + attemptOutPath)
                tooling_printOut("build_backend_driver_ok=" + attemptOutPath)
                return 0
            if !tooling_installExecutableAtomic(root, attemptOutPath, outPath):
                tooling_printErr("cheng_tooling: stage0 attempt output install failed: " + attemptOutPath)
                postBuildOk = false
            elif !tooling_installBuildDriverSidecars(root, attemptOutPath, outPath, fullRebuild):
                tooling_printErr("cheng_tooling: warning: build-backend-driver sidecar install incomplete: " + outPath)
            elif requireCanonicalQuickSmoke &&
                 !tooling_buildDriverFastCanonicalSmokeWrite(root, outPath, target):
                tooling_printErr("cheng_tooling: warning: build-backend-driver fast canonical smoke proof write failed: " + outPath)
            if !persistentQuickCachePath:
                tooling_driverBuildTempCleanup(root, attemptOutPath)
        if rc == 0 && postBuildOk:
            let _clearedInstalledOut: int32 =
                tooling_stage0ClearStamps(root, outPath, "build_backend_driver.install_success")
            tooling_printOut("build_backend_driver_compile_mode=" + attemptCompileMode)
            tooling_printOut("build_backend_driver_rebuilt=1")
            tooling_printOut("build_backend_driver_fallback_used=" + (attemptFallbackUsed ? "1" : "0"))
            tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
            if requireCanonicalQuickSmoke:
                tooling_printOut("build_backend_driver_fast_path=installed_after_canonical_smoke")
            tooling_printOut("build_backend_driver_ok=" + outPath)
            if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                let cleanRc: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                if cleanRc != 0:
                    return cleanRc
            return 0
        if rc == 0 && !postBuildOk && !requireRebuild && !strictNative:
            let keepExistingOk: bool = tooling_driverBuildOutputOk(root, outPath, compileMode,
                                                                   quickLightSanity, false,
                                                                   buildLinkerMode)
            if keepExistingOk:
                let _clearedKeepExisting: int32 =
                    tooling_stage0ClearStamps(root, outPath, "build_backend_driver.keep_existing")
                tooling_printErr("cheng_tooling: rebuilt candidate failed sanity; keep existing canonical driver: " + outPath)
                tooling_printOut("build_backend_driver_compile_mode=" + attemptCompileMode)
                tooling_printOut("build_backend_driver_rebuilt=0")
                tooling_printOut("build_backend_driver_fallback_used=0")
                tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
                if canonicalQuickSmokeFailed:
                    tooling_printOut("build_backend_driver_fast_path=keep_existing_after_candidate_smoke_fail")
                tooling_printOut("build_backend_driver_last_stage0=" + stage0)
                tooling_printOut("build_backend_driver_last_rc=0")
                tooling_printOut("build_backend_driver_last_kind=ok")
                tooling_printOut("build_backend_driver_ok=" + outPath)
                if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                    let cleanRcKeep: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                    if cleanRcKeep != 0:
                        return cleanRcKeep
                return 0
        if !keepFailedAttempt:
            tooling_driverBuildTempCleanup(root, attemptOutPath)
        else:
            tooling_printErr("cheng_tooling: keep failed attempt artifact: " + attemptOutPath)
        if rc != 0:
            tooling_printErr("cheng_tooling: stage0 attempt failed rc=" + intToStr(rc) +
                             " kind=" + tooling_exitKind(rc) + " driver=" + stage0)
        else:
            tooling_printErr("cheng_tooling: stage0 attempt output sanity failed: " + stage0)
        let sweepAfterAttempt: int32 = tooling_backendDriverSweepAttemptOrphans(
            root, "build_backend_driver.attempt." + intToStr(attemptIndex))
        attemptSweepCleaned = attemptSweepCleaned + sweepAfterAttempt
        lastStage0 = stage0
        i = i + 1
    if !requireRebuild && (!strictNative || sawCanonicalQuickSmokeFail):
        let keepExistingAfterFail: bool = tooling_driverBuildOutputOk(root, outPath, compileMode,
                                                                       quickLightSanity, false,
                                                                       buildLinkerMode)
        if keepExistingAfterFail:
            let _clearedKeepAfterFail: int32 =
                tooling_stage0ClearStamps(root, outPath, "build_backend_driver.keep_existing_after_fail")
            tooling_printErr("cheng_tooling: keep existing canonical driver after rebuild failure: " + outPath)
            tooling_printOut("build_backend_driver_compile_mode=" + lastCompileMode)
            tooling_printOut("build_backend_driver_rebuilt=0")
            tooling_printOut("build_backend_driver_fallback_used=0")
            tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
            tooling_printOut("build_backend_driver_last_stage0=" + lastStage0)
            tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
            tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
            tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
            if sawCanonicalQuickSmokeFail:
                tooling_printOut("build_backend_driver_fast_path=keep_existing_after_candidate_smoke_fail")
            tooling_printOut("build_backend_driver_ok=" + outPath)
            if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                let cleanRcKeepExisting: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                if cleanRcKeepExisting != 0:
                    return cleanRcKeepExisting
            return 0
    # Shim fallback removed.
    if requireRebuild:
        let promoteDistOnFail: bool = tooling_isTrue(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_REQUIRE_REBUILD_PROMOTE_DIST", "0"))
        let distSeedPath: str = tooling_pathAbsolute(root, "dist/releases/current/cheng")
        let distSeedProbe: bool = tooling_isTrue(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_REQUIRE_REBUILD_PROMOTE_DIST_PROBE", "0"))
        if promoteDistOnFail &&
           tooling_strNonEmpty(distSeedPath) &&
           !tooling_strEq(distSeedPath, outPath) &&
           tooling_isExecutable(root, distSeedPath) &&
           tooling_driverSanityOk(root, distSeedPath) &&
           tooling_binaryHelpProbeOk(root, distSeedPath, true) &&
           (!distSeedProbe || tooling_driverCompileProbeOk(root, distSeedPath)):
            if tooling_installExecutableAtomic(root, distSeedPath, outPath) &&
               tooling_driverSanityOk(root, outPath) &&
               tooling_binaryHelpProbeOk(root, outPath, true) &&
               (!distSeedProbe || tooling_driverCompileProbeOk(root, outPath)):
                let _clearedPromoteDist: int32 =
                    tooling_stage0ClearStamps(root, outPath, "build_backend_driver.promote_dist")
                tooling_printErr("cheng_tooling: require-rebuild fallback promoted dist seed driver: " + distSeedPath)
                tooling_printOut("build_backend_driver_compile_mode=dist_promote")
                tooling_printOut("build_backend_driver_rebuilt=0")
                tooling_printOut("build_backend_driver_fallback_used=1")
                tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
                tooling_printOut("build_backend_driver_last_stage0=" + lastStage0)
                tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
                tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
                tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
                tooling_printOut("build_backend_driver_promoted_dist=1")
                tooling_printOut("build_backend_driver_ok=" + outPath)
                if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath):
                    let cleanRcPromote: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                    if cleanRcPromote != 0:
                        return cleanRcPromote
                return 0
        tooling_printErr("cheng_tooling: require-rebuild enabled; all stage0 attempts failed, stage0 reuse disabled")
        tooling_printOut("build_backend_driver_compile_mode=" + lastCompileMode)
        tooling_printOut("build_backend_driver_rebuilt=0")
        tooling_printOut("build_backend_driver_fallback_used=0")
        tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
        tooling_printOut("build_backend_driver_last_stage0=" + lastStage0)
        tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
        tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
        tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
        if lastRc != 0:
            return lastRc
        return 1
    if noRecover:
        if strictNative && !requireRebuild:
            # Strict-native mode no longer allows stage0 reuse on fail.
            let _fallbackStage0Unused: str = fallbackStage0
        tooling_printErr("cheng_tooling: build backend driver compile failed rc=" + intToStr(lastRc) +
                         " kind=" + tooling_exitKind(lastRc) + "; no-recover enabled, stage0 reuse disabled")
        tooling_printOut("build_backend_driver_compile_mode=" + lastCompileMode)
        tooling_printOut("build_backend_driver_rebuilt=0")
        tooling_printOut("build_backend_driver_fallback_used=0")
        tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
        tooling_printOut("build_backend_driver_last_stage0=" + lastStage0)
        tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
        tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
        tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
        tooling_printOut("build_backend_driver_ok=" + outPath)
        if lastRc != 0:
            return lastRc
        return 1
    tooling_printOut("build_backend_driver_fallback_used=0")
    tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
    if lastRc != 0:
        tooling_printOut("build_backend_driver_last_stage0=" + lastStage0)
        tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
        tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
        tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
        tooling_printErr("cheng_tooling: build backend driver failed rc=" + intToStr(lastRc))
        return lastRc
    tooling_printErr("cheng_tooling: build backend driver output sanity failed: " + outPath)
    return 1

fn tooling_cmdSelfhostBootstrapFastHost(root: str, compileStage1: bool, outDirRaw: str, timingOutRaw: str, stage0Raw: str): int32 =
    let res: ToolingSelfhostResult = tooling_selfhostBootstrapFastHost(
        root, compileStage1, outDirRaw, timingOutRaw, stage0Raw, false)
    if !res.ok:
        var msg: str = res.message
        if !tooling_strNonEmpty(msg):
            msg = "unknown failure"
        tooling_printErr("cheng_tooling: selfhost bootstrap fast host failed: " + msg)
        return 1
    tooling_printOut("selfhost_fast_stage1=" + res.stage1Path)
    tooling_printOut("selfhost_fast_stage2=" + res.stage2Path)
    tooling_printOut("selfhost_fast_stage0=" + res.stage0Path)
    tooling_printOut("selfhost_fast_stage0_driver_kind=" + res.stage0DriverKind)
    tooling_printOut("selfhost_fast_stage1_status=" + res.stage1Status)
    tooling_printOut("selfhost_fast_stage1_compile_mode=" + res.stage1CompileMode)
    var stage1RebuildOkText: str = "0"
    if res.stage1RebuildOk:
        stage1RebuildOkText = "1"
    var fallbackUsedText: str = "0"
    if res.fallbackUsed:
        fallbackUsedText = "1"
    var strictRebuildOkText: str = "0"
    if res.strictRebuildOk:
        strictRebuildOkText = "1"
    tooling_printOut("selfhost_fast_stage1_rebuild_ok=" + stage1RebuildOkText)
    tooling_printOut("selfhost_fast_fallback_used=" + fallbackUsedText)
    tooling_printOut("selfhost_fast_quarantine_cleaned=" + intToStr(res.quarantineCleaned))
    tooling_printOut("selfhost_fast_lock_wait_ms=" + intToStr(res.lockWaitMs))
    tooling_printOut("selfhost_fast_strict_rebuild_ok=" + strictRebuildOkText)
    tooling_printOut("selfhost_fast_total_ms=" + intToStr(int32(res.totalMs)))
    return 0

fn tooling_cmdSelfhost100msHost(root: str, hostOnlyRaw: str, itersRaw: str, p95Raw: str, p99Raw: str, enforceRaw: str, reportRaw: str, compileStage1: bool, outDirRaw: str, stage0Raw: str): int32 =
    var hostOnly: str = strutil.strip(hostOnlyRaw)
    if !tooling_strNonEmpty(hostOnly):
        hostOnly = "darwin_arm64"
    let defaultIters: int32 = compileStage1 ? 1 : 5
    var iters: int32 = tooling_parseInt32Default(itersRaw, defaultIters)
    if iters <= 0:
        iters = defaultIters
    var p95Limit: int32 = tooling_parseInt32Default(p95Raw, 100)
    if p95Limit <= 0:
        p95Limit = 100
    var p99Limit: int32 = tooling_parseInt32Default(p99Raw, 120)
    if p99Limit <= 0:
        p99Limit = 120
    let enforce: bool = tooling_isTrue(enforceRaw)
    let strictRebuild: bool = tooling_selfhostStrictRebuildEnabled()
    let requireStage1Rebuild: bool = compileStage1 &&
        (strictRebuild || tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_REQUIRE_REBUILD", "0")))
    let stage1FullRebuild: bool = compileStage1 &&
        (strictRebuild || tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_FULL_REBUILD", "0")))
    var stage1CompileModeBase: str = "alias"
    if compileStage1:
        if stage1FullRebuild:
            stage1CompileModeBase = "full"
        else:
            stage1CompileModeBase = "quick"
    var compileStage1TextBase: str = "0"
    if compileStage1:
        compileStage1TextBase = "1"

    let hostTag: str = tooling_detectHostTag(root)
    var reportPath: str = reportRaw
    if !tooling_strNonEmpty(reportPath):
        reportPath = "artifacts/backend_selfhost_100ms_host/report.tsv"
    reportPath = tooling_pathAbsolute(root, reportPath)
    let reportDir: str = os.parentDir(reportPath)
    tooling_tryMkdirP(root, reportDir)

    if hostTag != hostOnly:
        let reportSkip: str =
            "host=" + hostTag + "\n" +
            "host_only=" + hostOnly + "\n" +
            "compile_stage1=" + compileStage1TextBase + "\n" +
            "stage1_compile_mode=" + stage1CompileModeBase + "\n" +
            "strict_rebuild_ok=0\n" +
            "fallback_used=0\n" +
            "quarantine_cleaned=0\n" +
            "lock_wait_ms=0\n" +
            "status=skip_non_target_host\n"
        os.writeFile(reportPath, reportSkip)
        tooling_printOut("[selfhost_100ms_native] skip on non-target host: host=" + hostTag + " target=" + hostOnly)
        return 0
    var totalsMs: int32[] = []
    var stage1RebuildCount: int32 = 0
    var stage1ReuseCount: int32 = 0
    var stage1AliasCount: int32 = 0
    var stage1CompileModeFullCount: int32 = 0
    var stage1CompileModeQuickCount: int32 = 0
    var stage1CompileModeAliasCount: int32 = 0
    var fallbackUsedCount: int32 = 0
    var quarantineCleanedTotal: int32 = 0
    var lockWaitMsMax: int32 = 0
    var strictRebuildOkCount: int32 = 0
    var stage1CompileMsTotal: int64 = int64(0)
    var stage1CompileMsMax: int64 = int64(0)
    var stage1SanityMsTotal: int64 = int64(0)
    var stage1CompileAttemptsTotal: int32 = 0
    var stage1CompileSegfaultsTotal: int32 = 0
    var stage0DriverKindSummary: str = ""
    var warmupOk: bool = true
    var outDirInput: str = outDirRaw
    if !tooling_strNonEmpty(outDirInput):
        outDirInput = "artifacts/backend_selfhost_100ms_host"
    let outDir: str = tooling_pathAbsolute(root, outDirInput)
    tooling_tryMkdirP(root, outDir)
    let prewarmStage1: bool = compileStage1 && iters > 1 &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_100MS_PREWARM_STAGE1", "1"))
    if prewarmStage1:
        let warmupTimingPath: str = os.joinPath(outDir, "selfhost_timing_native.warmup.tsv")
        let warmupRes: ToolingSelfhostResult = tooling_selfhostBootstrapFastHost(
            root, compileStage1, outDir, warmupTimingPath, stage0Raw, false)
        if !warmupRes.ok:
            warmupOk = false
            var msgWarm: str = warmupRes.message
            if !tooling_strNonEmpty(msgWarm):
                msgWarm = "unknown failure"
            tooling_printErr("[selfhost_100ms_native] warmup failed (continue): reason=" + msgWarm)
            tooling_printOut("selfhost_100ms_warmup_failed=1")
        else:
            tooling_printOut("selfhost_100ms_warmup_ms=" + intToStr(int32(warmupRes.totalMs)))
    for i in 1..iters:
        let timingPath: str = os.joinPath(outDir, "selfhost_timing_native." + intToStr(i) + ".tsv")
        let res: ToolingSelfhostResult = tooling_selfhostBootstrapFastHost(
            root, compileStage1, outDir, timingPath, stage0Raw, false)
        if !res.ok:
            var msg: str = res.message
            if !tooling_strNonEmpty(msg):
                msg = "unknown failure"
            var stage0DriverKindFail: str = "unknown"
            var fallbackUsedFail: str = "0"
            var quarantineCleanedFail: str = "0"
            var lockWaitMsFail: str = "0"
            var strictRebuildOkFail: str = "0"
            var stage1CompileMsFail: str = "0"
            var stage1SanityMsFail: str = "0"
            var stage1CompileAttemptsFail: str = "0"
            var stage1CompileSegfaultsFail: str = "0"
            stage0DriverKindFail = res.stage0DriverKind
            if res.fallbackUsed:
                fallbackUsedFail = "1"
            quarantineCleanedFail = intToStr(res.quarantineCleaned)
            lockWaitMsFail = intToStr(res.lockWaitMs)
            if res.strictRebuildOk:
                strictRebuildOkFail = "1"
            stage1CompileMsFail = intToStr(int32(res.stage1CompileMs))
            stage1SanityMsFail = intToStr(int32(res.stage1SanityMs))
            stage1CompileAttemptsFail = intToStr(res.stage1CompileAttempts)
            stage1CompileSegfaultsFail = intToStr(res.stage1CompileSegfaults)
            let reportFail: str =
                "host=" + hostTag + "\n" +
                "iters=" + intToStr(iters) + "\n" +
                "failed_iter=" + intToStr(i) + "\n" +
                "status=bootstrap_fail\n" +
                "reason=" + msg + "\n" +
                "compile_stage1=" + compileStage1TextBase + "\n" +
                "stage1_compile_mode=" + stage1CompileModeBase + "\n" +
                "stage0_driver_kind=" + stage0DriverKindFail + "\n" +
                "fallback_used=" + fallbackUsedFail + "\n" +
                "quarantine_cleaned=" + quarantineCleanedFail + "\n" +
                "lock_wait_ms=" + lockWaitMsFail + "\n" +
                "strict_rebuild_ok=" + strictRebuildOkFail + "\n" +
                "stage1_compile_ms=" + stage1CompileMsFail + "\n" +
                "stage1_sanity_ms=" + stage1SanityMsFail + "\n" +
                "stage1_compile_attempts=" + stage1CompileAttemptsFail + "\n" +
                "stage1_compile_segfaults=" + stage1CompileSegfaultsFail + "\n" +
                "limit_p95_ms=" + intToStr(p95Limit) + "\n" +
                "limit_p99_ms=" + intToStr(p99Limit) + "\n"
            os.writeFile(reportPath, reportFail)
            tooling_printErr("[selfhost_100ms_native] bootstrap failed: iter=" + intToStr(i) + " reason=" + msg)
            if enforce:
                return 1
            return 0
        toolingAppendInt32(totalsMs, int32(res.totalMs))
        if res.fallbackUsed:
            fallbackUsedCount = fallbackUsedCount + 1
        quarantineCleanedTotal = quarantineCleanedTotal + res.quarantineCleaned
        if res.lockWaitMs > lockWaitMsMax:
            lockWaitMsMax = res.lockWaitMs
        if res.strictRebuildOk:
            strictRebuildOkCount = strictRebuildOkCount + 1
        stage1CompileMsTotal = stage1CompileMsTotal + res.stage1CompileMs
        if res.stage1CompileMs > stage1CompileMsMax:
            stage1CompileMsMax = res.stage1CompileMs
        stage1SanityMsTotal = stage1SanityMsTotal + res.stage1SanityMs
        stage1CompileAttemptsTotal = stage1CompileAttemptsTotal + res.stage1CompileAttempts
        stage1CompileSegfaultsTotal = stage1CompileSegfaultsTotal + res.stage1CompileSegfaults
        if !tooling_strNonEmpty(stage0DriverKindSummary):
            stage0DriverKindSummary = res.stage0DriverKind
        elif !tooling_strEq(stage0DriverKindSummary, res.stage0DriverKind):
            stage0DriverKindSummary = "mixed"
        if tooling_strEq(res.stage1Status, "rebuild") && res.stage1RebuildOk:
            stage1RebuildCount = stage1RebuildCount + 1
        elif tooling_strEq(res.stage1Status, "reused_stage0"):
            stage1ReuseCount = stage1ReuseCount + 1
        elif tooling_strEq(res.stage1Status, "alias"):
            stage1AliasCount = stage1AliasCount + 1
        if tooling_strEq(res.stage1CompileMode, "full"):
            stage1CompileModeFullCount = stage1CompileModeFullCount + 1
        elif tooling_strEq(res.stage1CompileMode, "quick"):
            stage1CompileModeQuickCount = stage1CompileModeQuickCount + 1
        else:
            stage1CompileModeAliasCount = stage1CompileModeAliasCount + 1
    if totalsMs.len <= 0:
        tooling_printErr("[selfhost_100ms_native] empty totals")
        return 1
    let p95Ms: int32 = tooling_pickPercentileNoSort(totalsMs, 95)
    let p99Ms: int32 = tooling_pickPercentileNoSort(totalsMs, 99)
    var maxMs: int32 = totalsMs[0]
    for i in 1..<totalsMs.len:
        if totalsMs[i] > maxMs:
            maxMs = totalsMs[i]
    var status: str = "ok"
    if p95Ms > p95Limit || p99Ms > p99Limit:
        status = "regression"
    var stage1StatusSummary: str = "alias"
    var stage1CompileModeSummary: str = "alias"
    var stage1RebuildOk: bool = false
    if compileStage1:
        if stage1CompileModeFullCount == iters:
            stage1CompileModeSummary = "full"
        elif stage1CompileModeQuickCount == iters:
            stage1CompileModeSummary = "quick"
        elif stage1CompileModeFullCount > 0 && stage1CompileModeQuickCount > 0:
            stage1CompileModeSummary = "mixed_full_quick"
        elif stage1CompileModeAliasCount == iters:
            stage1CompileModeSummary = "alias"
        else:
            stage1CompileModeSummary = "mixed"
        if stage1RebuildCount == iters:
            stage1StatusSummary = "rebuild"
            stage1RebuildOk = true
        elif stage1RebuildCount > 0 && stage1ReuseCount > 0:
            stage1StatusSummary = "mixed_rebuild_reuse"
            stage1RebuildOk = false
        elif stage1ReuseCount > 0:
            stage1StatusSummary = "reused_stage0"
            stage1RebuildOk = false
        else:
            stage1StatusSummary = "unknown"
            stage1RebuildOk = false
    var stage1RebuildOkText: str = "0"
    if stage1RebuildOk:
        stage1RebuildOkText = "1"
    var fallbackUsedText: str = fallbackUsedCount > 0 ? "1" : "0"
    var strictRebuildOkText: str = "0"
    if !strictRebuild || strictRebuildOkCount == iters:
        strictRebuildOkText = "1"
    var stage1CompileMsAvg: int32 = 0
    var stage1SanityMsAvg: int32 = 0
    if iters > 0:
        stage1CompileMsAvg = int32(stage1CompileMsTotal / int64(iters))
        stage1SanityMsAvg = int32(stage1SanityMsTotal / int64(iters))
    if !tooling_strNonEmpty(stage0DriverKindSummary):
        stage0DriverKindSummary = "unknown"
    var prewarmStage1Text: str = "0"
    if prewarmStage1:
        prewarmStage1Text = "1"
    var warmupOkText: str = "1"
    if !warmupOk:
        warmupOkText = "0"
    let report: str =
        "host=" + hostTag + "\n" +
        "iters=" + intToStr(iters) + "\n" +
        "compile_stage1=" + compileStage1TextBase + "\n" +
        "prewarm_stage1=" + prewarmStage1Text + "\n" +
        "prewarm_ok=" + warmupOkText + "\n" +
        "stage1_compile_mode=" + stage1CompileModeSummary + "\n" +
        "stage1_status=" + stage1StatusSummary + "\n" +
        "stage1_rebuild_ok=" + stage1RebuildOkText + "\n" +
        "stage0_driver_kind=" + stage0DriverKindSummary + "\n" +
        "fallback_used=" + fallbackUsedText + "\n" +
        "quarantine_cleaned=" + intToStr(quarantineCleanedTotal) + "\n" +
        "lock_wait_ms=" + intToStr(lockWaitMsMax) + "\n" +
        "strict_rebuild_ok=" + strictRebuildOkText + "\n" +
        "stage1_compile_ms_avg=" + intToStr(stage1CompileMsAvg) + "\n" +
        "stage1_compile_ms_max=" + intToStr(int32(stage1CompileMsMax)) + "\n" +
        "stage1_sanity_ms_avg=" + intToStr(stage1SanityMsAvg) + "\n" +
        "stage1_compile_attempts_total=" + intToStr(stage1CompileAttemptsTotal) + "\n" +
        "stage1_compile_segfaults_total=" + intToStr(stage1CompileSegfaultsTotal) + "\n" +
        "p95_ms=" + intToStr(p95Ms) + "\n" +
        "p99_ms=" + intToStr(p99Ms) + "\n" +
        "max_ms=" + intToStr(maxMs) + "\n" +
        "limit_p95_ms=" + intToStr(p95Limit) + "\n" +
        "limit_p99_ms=" + intToStr(p99Limit) + "\n" +
        "status=" + status + "\n"
    os.writeFile(reportPath, report)
    tooling_printOut("[selfhost_100ms_native] host=" + hostTag +
                     " p95=" + intToStr(p95Ms) + "ms p99=" + intToStr(p99Ms) +
                     "ms max=" + intToStr(maxMs) + "ms status=" + status +
                     " stage0_driver_kind=" + stage0DriverKindSummary +
                     " fallback_used=" + fallbackUsedText +
                     " stage1_compile_mode=" + stage1CompileModeSummary +
                     " stage1_status=" + stage1StatusSummary +
                     " stage1_rebuild_ok=" + stage1RebuildOkText +
                     " strict_rebuild_ok=" + strictRebuildOkText +
                     " stage1_compile_ms_avg=" + intToStr(stage1CompileMsAvg) +
                     " stage1_compile_segfaults_total=" + intToStr(stage1CompileSegfaultsTotal))
    let enforcePerfWithCompileStage1: bool = compileStage1 &&
                                            tooling_isTrue(os.getEnvDefault("SELFHOST_100MS_ENFORCE_WITH_COMPILE_STAGE1", "1"))
    let enforcePerfGate: bool = enforce && (!compileStage1 || enforcePerfWithCompileStage1)
    if !tooling_strEq(status, "ok") && enforcePerfGate:
        return 1
    if requireStage1Rebuild && !stage1RebuildOk:
        return 1
    return 0

fn tooling_printCompileUsage() =
    tooling_printOut("cheng options (canonical compile entry):")
    tooling_printOut("  --in:<file.cheng>            source file path")
    tooling_printOut("  --out:<path>                 output path")
    tooling_printOut("  --name:<name-or-path>        output name (defaults under artifacts/chengc)")
    tooling_printOut("  --emit:exe                  output format (default exe)")
    tooling_printOut("  --target:<triple>            backend target triple")
    tooling_printOut("  (linker fixed: self-link + direct-exe)")
    tooling_printOut("  --dev                        dev build track (default/fixed, alias of --dev:fast)")
    tooling_printOut("  --dev:fast|strict            dev profile (default fast)")
    tooling_printOut("  --run                        run output after successful compile (dev default: host runner)")
    tooling_printOut("  --run:host                   run via backend_host_runner (dev default mode)")
    tooling_printOut("  --run:file                   run output executable file directly")
    tooling_printOut("  [positional input]           same as --in:<file.cheng>")
    tooling_printOut("  env: TOOLING_COMPILE_TIMEOUT=60 (default/cap)")
    tooling_printOut("       TOOLING_COMPILE_BLOCK_ON_UE=1|0 (default 1; hard-block follows TOOLING_STAGE0_HARD_BLOCK_ON_UE)")
    tooling_printOut("       TOOLING_COMPILE_CRASH_REPORT_DIR=artifacts/tooling_compile_crash")
    tooling_printOut("       CHENGC_DEV_MODE=fast|strict (default fast)")
    tooling_printOut("  note: TOOLING_COMPILE_STAGE0_AUTO_REBUILD_ON_PREFLIGHT_FAIL is removed (fixed=0)")
    tooling_printOut("  note: TOOLING_COMPILE_CRASH_RETRY_MAX is removed (fixed=0)")
    tooling_printOut("  note: `compile` and `chengc` have been removed; use `cheng`.")

fn tooling_printReleaseCompileUsage() =
    tooling_printOut("release-compile options:")
    tooling_printOut("  --in:<file.cheng>            source file path")
    tooling_printOut("  --out:<path>                 output path")
    tooling_printOut("  --name:<name-or-path>        output name (defaults under artifacts/chengc)")
    tooling_printOut("  --emit:exe|shared|static    output format (default exe)")
    tooling_printOut("  --target:<triple>            backend target triple")
    tooling_printOut("  (linker fixed: system-link)")
    tooling_printOut("  --run                        run output executable file after successful compile")
    tooling_printOut("  --run:file                   explicit file-exec mode (same as --run in release)")
    tooling_printOut("  [positional input]           same as --in:<file.cheng>")
    tooling_printOut("  env: TOOLING_COMPILE_TIMEOUT=60 (default/cap)")
    tooling_printOut("       TOOLING_COMPILE_BLOCK_ON_UE=1|0 (default 1; hard-block follows TOOLING_STAGE0_HARD_BLOCK_ON_UE)")
    tooling_printOut("       TOOLING_COMPILE_CRASH_REPORT_DIR=artifacts/tooling_compile_crash")
    tooling_printOut("  note: --emit:shared|static use object-first release packaging (no --run)")
    tooling_printOut("  note: TOOLING_COMPILE_STAGE0_AUTO_REBUILD_ON_PREFLIGHT_FAIL is removed (fixed=0)")
    tooling_printOut("  note: TOOLING_COMPILE_CRASH_RETRY_MAX is removed (fixed=0)")

fn tooling_commandAllowsReleaseTrack(commandIdRaw: str): bool =
    let commandId: str = strutil.toLowerAscii(strutil.strip(commandIdRaw))
    if tooling_strEq(commandId, "release-compile") || tooling_strEq(commandId, "backend-prod-publish"):
        return true
    return false

fn tooling_normalizeBuildTrackRaw(raw: str): str =
    let track: str = strutil.toLowerAscii(strutil.strip(raw))
    if tooling_strEq(track, "release"):
        return "release"
    return "dev"

fn tooling_enforceBuildTrackPolicy(commandIdRaw: str, requestedTrackRaw: str): int32 =
    let commandId: str = strutil.toLowerAscii(strutil.strip(commandIdRaw))
    let track: str = tooling_normalizeBuildTrackRaw(requestedTrackRaw)
    if tooling_strEq(track, "release") && !tooling_commandAllowsReleaseTrack(commandId):
        tooling_printErr("cheng_tooling: " + commandId + " is dev-only; release track is only allowed for `release-compile` and `backend-prod-publish`")
        return 2
    return 0

fn tooling_compileDevModeParsed(raw: str): str =
    let mode: str = strutil.toLowerAscii(strutil.strip(raw))
    if tooling_strEq(mode, "strict"):
        return "strict"
    if tooling_strEq(mode, "fast"):
        return "fast"
    return ""

fn tooling_compileDevModeNormalized(raw: str): str =
    let parsed: str = tooling_compileDevModeParsed(raw)
    if tooling_strNonEmpty(parsed):
        return parsed
    return "fast"

fn tooling_compileDevModeFromEnv(): str =
    let raw: str = strutil.strip(os.getEnvDefault("CHENGC_DEV_MODE", ""))
    if tooling_strNonEmpty(raw):
        return tooling_compileDevModeNormalized(raw)
    let rawLegacy: str = strutil.strip(os.getEnvDefault("BACKEND_DEV_MODE", ""))
    if tooling_strNonEmpty(rawLegacy):
        return tooling_compileDevModeNormalized(rawLegacy)
    return "fast"

fn tooling_compileNoPointerDefault01(): str =
    let abiRaw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("ABI", "")))
    if tooling_strEq(abiRaw, "v2_noptr"):
        return "1"
    return "0"

fn tooling_compileNoPointerEnv01(name: str, fallback: str): str =
    var out: str = tooling_bool01Normalized(os.getEnvDefault(name, ""))
    if !tooling_strNonEmpty(out):
        out = fallback
    return out

fn tooling_compileProfileEnv01(name: str, fallback: str = "0"): str =
    var out: str = tooling_bool01Normalized(os.getEnvDefault(name, ""))
    if !tooling_strNonEmpty(out):
        out = fallback
    if !tooling_strNonEmpty(out):
        return "0"
    return out

fn tooling_cmdCompileExe(root: str, inRaw: str, outRaw: str, nameRaw: str, targetRaw: str,
                         releaseBuild: bool,
                         devModeRaw: str,
                         emitModeRaw: str,
                         runAfter: bool, runModeRaw: str): int32 =
    let compileStartMs: int64 = tooling_nowMs()
    var stage0ResolveMs: int64 = int64(0)
    var stage0PrepareMs: int64 = int64(0)
    var stage0PreflightMs: int64 = int64(0)
    var runtimeResolveMs: int64 = int64(0)
    var commandBuildMs: int64 = int64(0)
    var compileExecMs: int64 = int64(0)
    var publishMs: int64 = int64(0)
    let inPath: str = tooling_pathAbsolute(root, inRaw)
    if !tooling_strNonEmpty(inPath) || !os.fileExists(inPath):
        tooling_printErr("cheng_tooling: compile input not found: " + inRaw + " (resolved: " + inPath + ")")
        return 1
    let emitMode: str = strutil.toLowerAscii(strutil.strip(emitModeRaw))
    let libraryEmit: bool = tooling_emitModeIsLibrary(emitMode)
    if !tooling_strEq(emitMode, "exe") && !libraryEmit:
        tooling_printErr("cheng_tooling: compile only supports --emit:exe|shared|static")
        return 2
    if libraryEmit && !releaseBuild:
        tooling_printErr("cheng_tooling: --emit:shared|static is release-compile only")
        return 2
    if runAfter && libraryEmit:
        tooling_printErr("cheng_tooling: --emit:shared/static does not support --run/--run:*")
        return 2
    var target: str = tooling_normalizeTargetAlias(root, targetRaw)
    if !tooling_strNonEmpty(target):
        target = "auto"
    let linker: str = releaseBuild ? "system" : "self"
    if tooling_strEq(emitMode, "exe") && !releaseBuild && !tooling_targetSupportsSelfLinker(target):
        tooling_printErr("cheng_tooling: cheng requires self-link/direct-exe target support: " + target)
        return 2
    if !tooling_stage0QuarantineEnabled() &&
       tooling_stage0BlockOnQuarantineUe(root, "TOOLING_COMPILE_BLOCK_ON_UE", "compile_exe"):
        return 1
    let stage0ResolveStartMs: int64 = tooling_nowMs()
    let stage0ProbeEnabled: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_COMPILE_PROBE", "0"))
    let stage0: str = tooling_resolveStage0DriverForCompile(root, stage0ProbeEnabled)
    stage0ResolveMs = tooling_nowMs() - stage0ResolveStartMs
    if !tooling_strNonEmpty(stage0):
        tooling_printErr("cheng_tooling: stage0 driver not found")
        return 1
    let stage0PrepareStartMs: int64 = tooling_nowMs()
    var stage0Exec: str = tooling_prepareStage0Exec(root, stage0, "compile")
    stage0PrepareMs = tooling_nowMs() - stage0PrepareStartMs
    if !tooling_strNonEmpty(stage0Exec):
        tooling_printErr("cheng_tooling: stage0 prepare failed")
        return 1
    let stage0PreflightStartMs: int64 = tooling_nowMs()
    if !tooling_stage0PreflightOk(root, stage0Exec):
        stage0PreflightMs = tooling_nowMs() - stage0PreflightStartMs
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: stage0 preflight failed: " + stage0)
        return 1
    stage0PreflightMs = tooling_nowMs() - stage0PreflightStartMs
    let compileGenericModeRaw: str = os.getEnvDefault("GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(compileGenericModeRaw):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: compile only allows GENERIC_MODE=dict")
        return 2
    let compileGenericLoweringRaw: str = os.getEnvDefault("GENERIC_LOWERING", "")
    if !tooling_genericLoweringIsDictOnly(compileGenericLoweringRaw):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: compile only allows GENERIC_LOWERING=mir_dict")
        return 2
    let trackLabel: str = releaseBuild ? "release-compile" : "cheng"
    let devMode: str = releaseBuild ? "release" : tooling_compileDevModeNormalized(devModeRaw)
    let devStrict: bool = !releaseBuild && tooling_strEq(devMode, "strict")
    let parseExpected: str = releaseBuild ? "full" : "outline"
    let schedExpected: str = "ws"
    let directExpected: str = releaseBuild ? "0" : "1"
    let inmemExpected: str = releaseBuild ? "0" : "1"
    let linkerExpected: str = releaseBuild ? "system" : "self"
    if tooling_failFixedTrackEnv("BACKEND_STAGE1_PARSE_MODE", parseExpected, trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failFixedTrackEnv("BACKEND_FN_SCHED", schedExpected, trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failFixedTrackEnv("BACKEND_DIRECT_EXE", directExpected, trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failFixedTrackEnv("BACKEND_LINKERLESS_INMEM", inmemExpected, trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    if tooling_failFixedTrackEnv("BACKEND_LINKER", linkerExpected, trackLabel):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 2
    let runMode: str = tooling_compileRunModeNormalized(runAfter, runModeRaw, releaseBuild)
    let explicitOut: bool = tooling_strNonEmpty(strutil.strip(outRaw)) || tooling_strNonEmpty(strutil.strip(nameRaw))
    var outPath: str = tooling_defaultCompileOut(root, inPath, outRaw, nameRaw, emitMode)
    let runEphemeralOut: bool = runAfter &&
                                tooling_strEq(emitMode, "exe") &&
                                tooling_strEq(runMode, "host") &&
                                !releaseBuild &&
                                !explicitOut
    if runEphemeralOut:
        var tmpBase: str = os.extractFilename(inPath)
        tmpBase = tooling_stripSuffix(tmpBase, ".cheng")
        if !tooling_strNonEmpty(tmpBase):
            tmpBase = "cheng_run"
        outPath = os.joinPath(root, "chengcache/compile_run/" + tmpBase + "." + tooling_nowNonceText())
    let exeEmit: bool = tooling_strEq(emitMode, "exe")
    let atomicExePublish: bool = exeEmit && tooling_compileNeedsAtomicExePublish(root, outPath)
    let directExeOutput: bool = exeEmit && !atomicExePublish
    var backendOutPath: str = outPath
    if atomicExePublish:
        backendOutPath = outPath + ".compile." + tooling_nowNonceText() + ".tmp"
        if os.fileExists(backendOutPath):
            os.removeFile(backendOutPath)
    elif libraryEmit:
        backendOutPath = outPath + ".objtmp." + tooling_nowNonceText() + ".o"
        if os.fileExists(backendOutPath):
            os.removeFile(backendOutPath)
    let backendOutTmpLinkObj: str = backendOutPath + ".tmp.linkobj"
    let backendOutObj: str = backendOutPath + ".o"
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        if !tooling_mkdirP(root, outDir):
            tooling_printErr("cheng_tooling: failed to create output dir: " + outDir)
            return 1
    let compileLog: str = backendOutPath + ".compile.log"
    if os.fileExists(compileLog):
        os.removeFile(compileLog)
    let commandBuildStartMs: int64 = tooling_nowMs()
    var buildTrack: str = releaseBuild ? "release" : "dev"
    let noptrDefault: str = tooling_compileNoPointerDefault01()
    let stdNoptr: str = tooling_compileNoPointerEnv01("STAGE1_STD_NO_POINTERS", noptrDefault)
    let stdNoptrStrict: str = tooling_compileNoPointerEnv01("STAGE1_STD_NO_POINTERS_STRICT", "0")
    let noptrNonCAbi: str = tooling_compileNoPointerEnv01("STAGE1_NO_POINTERS_NON_C_ABI", noptrDefault)
    let noptrNonCAbiInternal: str = tooling_compileNoPointerEnv01("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", noptrNonCAbi)
    let stage1ProfileText: str = tooling_compileProfileEnv01("STAGE1_PROFILE", "0")
    let backendProfileText: str = tooling_compileProfileEnv01("BACKEND_PROFILE", "0")
    let uirProfileText: str = tooling_compileProfileEnv01("UIR_PROFILE", "0")
    let compileJobsText: str = tooling_compileParallelJobsText(root)
    let compileFnJobsText: str = tooling_compileParallelFnJobsText(root, compileJobsText)
    var envOverrides: str[] = []
    tooling_appendLegacyFrontendEnvUnsets(envOverrides)
    tooling_envAssignCollect(envOverrides, "MM", "orc")
    tooling_envAssignCollect(envOverrides, "CACHE", "0")
    tooling_envAssignCollect(envOverrides, "STAGE1_AUTO_SYSTEM", "0")
    tooling_envAssignCollect(envOverrides, "STAGE1_STD_NO_POINTERS", stdNoptr)
    tooling_envAssignCollect(envOverrides, "STAGE1_STD_NO_POINTERS_STRICT", stdNoptrStrict)
    tooling_envAssignCollect(envOverrides, "STAGE1_NO_POINTERS_NON_C_ABI", noptrNonCAbi)
    tooling_envAssignCollect(envOverrides, "STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", noptrNonCAbiInternal)
    tooling_envAssignCollect(envOverrides, "STAGE1_SKIP_CPROFILE", "1")
    tooling_envAssignCollect(envOverrides, "STAGE1_PROFILE", stage1ProfileText)
    tooling_envAssignCollect(envOverrides, "BACKEND_PROFILE", backendProfileText)
    tooling_envAssignCollect(envOverrides, "UIR_PROFILE", uirProfileText)
    tooling_envAssignCollect(envOverrides, "BACKEND_ENABLE_CLI", "1")
    tooling_envAssignCollect(envOverrides, "BACKEND_BUILD_TRACK", buildTrack)
    tooling_envAssignCollect(envOverrides, "BACKEND_ALLOW_DIRECT_DRIVER", "1")
    tooling_envAssignCollect(envOverrides, "BACKEND_LINKER", linker)
    tooling_envAssignCollect(envOverrides, "BACKEND_STAGE1_BUILDER", "stage1")
    tooling_envAssignCollect(envOverrides, "BACKEND_SKIP_GLOBAL_INIT", "0")
    tooling_envAssignCollect(envOverrides, "BACKEND_IR", "uir")
    tooling_envAssignCollect(envOverrides, "BACKEND_VALIDATE", "0")
    tooling_envAssignCollect(envOverrides, "BACKEND_ALLOW_NO_MAIN", libraryEmit ? "1" : "0")
    var releaseLdflagsRaw: str = ""
    if releaseBuild:
        let releaseMultiText: str = tooling_compileParallelMultiText(root)
        let releaseMultiForceText: str = tooling_compileParallelMultiForceText(root, releaseMultiText)
        var releaseOptLevelRaw: str = tooling_trimAsciiSpace(os.getEnvDefault("BACKEND_RELEASE_OPT_LEVEL", "0"))
        if !tooling_strNonEmpty(releaseOptLevelRaw):
            releaseOptLevelRaw = "0"
        var releaseBackendOpt: str = tooling_bool01Normalized(
            os.getEnvDefault("BACKEND_RELEASE_BACKEND_OPT", "0"))
        if !tooling_strNonEmpty(releaseBackendOpt):
            releaseBackendOpt = "0"
        var releaseBackendOpt2: str = tooling_bool01Normalized(
            os.getEnvDefault("BACKEND_RELEASE_BACKEND_OPT2", "0"))
        if !tooling_strNonEmpty(releaseBackendOpt2):
            releaseBackendOpt2 = "0"
        tooling_envAssignCollect(envOverrides, "BACKEND_FAST_DEV_PROFILE", "0")
        tooling_envAssignCollect(envOverrides, "BACKEND_STAGE1_PARSE_MODE", "full")
        tooling_envAssignCollect(envOverrides, "BACKEND_FN_SCHED", "ws")
        tooling_envAssignCollect(envOverrides, "BACKEND_DIRECT_EXE", "0")
        tooling_envAssignCollect(envOverrides, "BACKEND_LINKERLESS_INMEM", "0")
        tooling_envAssignCollect(envOverrides, "BACKEND_FAST_FALLBACK_ALLOW", "0")
        tooling_envAssignCollect(envOverrides, "BACKEND_MULTI", releaseMultiText)
        tooling_envAssignCollect(envOverrides, "BACKEND_MULTI_FORCE", releaseMultiForceText)
        tooling_envAssignCollect(envOverrides, "BACKEND_INCREMENTAL", "0")
        tooling_envAssignCollect(envOverrides, "BACKEND_JOBS", compileJobsText)
        tooling_envAssignCollect(envOverrides, "BACKEND_FN_JOBS", compileFnJobsText)
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT", releaseBackendOpt)
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT2", releaseBackendOpt2)
        tooling_envAssignCollect(envOverrides, "BACKEND_OPT_LEVEL", releaseOptLevelRaw)
        let releaseCflagsRaw: str = tooling_trimAsciiSpace(os.getEnvDefault("BACKEND_RELEASE_CFLAGS", "-O2"))
        releaseLdflagsRaw = tooling_releaseLdflagsForTarget(
            os.getEnvDefault("BACKEND_RELEASE_LDFLAGS", releaseCflagsRaw), target)
        if tooling_strNonEmpty(releaseCflagsRaw):
            tooling_envAssignCollect(envOverrides, "BACKEND_CFLAGS", releaseCflagsRaw)
        if tooling_strNonEmpty(releaseLdflagsRaw):
            tooling_envAssignCollect(envOverrides, "BACKEND_LDFLAGS", releaseLdflagsRaw)
    else:
        let devFastText: str = devStrict ? "0" : "1"
        let devMultiDefault: str = devStrict ? "0" : tooling_compileDefaultMulti(root)
        let devMultiText: str = tooling_compileParallelMultiText(root, devMultiDefault)
        let devMultiForceText: str = tooling_compileParallelMultiForceText(root, devMultiText)
        tooling_envAssignCollect(envOverrides, "BACKEND_FAST_DEV_PROFILE", devFastText)
        tooling_envAssignCollect(envOverrides, "BACKEND_STAGE1_PARSE_MODE", "outline")
        tooling_envAssignCollect(envOverrides, "BACKEND_FN_SCHED", "ws")
        tooling_envAssignCollect(envOverrides, "BACKEND_DIRECT_EXE", "1")
        tooling_envAssignCollect(envOverrides, "BACKEND_LINKERLESS_INMEM", "1")
        tooling_envAssignCollect(envOverrides, "BACKEND_FAST_FALLBACK_ALLOW", "0")
        tooling_envAssignCollect(envOverrides, "BACKEND_MULTI", devMultiText)
        tooling_envAssignCollect(envOverrides, "BACKEND_MULTI_FORCE", devMultiForceText)
        tooling_envAssignCollect(envOverrides, "BACKEND_INCREMENTAL", devFastText)
        tooling_envAssignCollect(envOverrides, "BACKEND_JOBS", compileJobsText)
        tooling_envAssignCollect(envOverrides, "BACKEND_FN_JOBS", compileFnJobsText)
    let backendEmitMode: str = libraryEmit ? "obj" : emitMode
    tooling_envAssignCollect(envOverrides, "BACKEND_EMIT", backendEmitMode)
    if libraryEmit:
        tooling_envAssignCollect(envOverrides, "BACKEND_INTERNAL_ALLOW_EMIT_OBJ", "1")
    tooling_envAssignCollect(envOverrides, "GENERIC_MODE", "dict")
    tooling_envAssignCollect(envOverrides, "GENERIC_SPEC_BUDGET", "0")
    tooling_envAssignCollect(envOverrides, "GENERIC_LOWERING", "mir_dict")
    tooling_envAssignCollect(envOverrides, "BACKEND_TARGET", target)
    tooling_envAssignCollect(envOverrides, "BACKEND_INPUT", inPath)
    tooling_envAssignCollect(envOverrides, "BACKEND_OUTPUT", backendOutPath)
    if tooling_strEq(linker, "self") && tooling_strEq(emitMode, "exe"):
        let runtimeResolveStartMs: int64 = tooling_nowMs()
        let compileNeedsCombinedRuntimeObj: bool =
            tooling_compileInputNeedsCombinedRuntimeObj(inPath)
        var runtimeObj: str = strutil.strip(os.getEnvDefault("BACKEND_RUNTIME_OBJ", ""))
        runtimeResolveMs = tooling_nowMs() - runtimeResolveStartMs
        if compileNeedsCombinedRuntimeObj:
            if !tooling_strNonEmpty(runtimeObj):
                runtimeObj = tooling_runtimeObjPath(root, target)
            if !os.fileExists(runtimeObj) || !tooling_runtimeObjHasRequiredSymbols(root, runtimeObj):
                runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
            runtimeResolveMs = tooling_nowMs() - runtimeResolveStartMs
            if !os.fileExists(runtimeObj) || !tooling_runtimeObjHasRequiredSymbols(root, runtimeObj):
                tooling_printErr("cheng_tooling: missing valid runtime object for self-link: " + runtimeObj)
                tooling_cleanupStage0Exec(stage0, stage0Exec)
                return 1
            tooling_envAssignCollect(envOverrides, "BACKEND_NO_RUNTIME_C", "1")
            tooling_envAssignCollect(envOverrides, "BACKEND_RUNTIME_OBJ", runtimeObj)
        else:
            if !tooling_strNonEmpty(runtimeObj):
                runtimeObj = tooling_runtimeObjBasePath(root, target)
            runtimeResolveMs = tooling_nowMs() - runtimeResolveStartMs
            if tooling_runtimeObjHasFastExeSymbols(root, runtimeObj):
                tooling_envAssignCollect(envOverrides, "BACKEND_NO_RUNTIME_C", "1")
                tooling_envAssignCollect(envOverrides, "BACKEND_RUNTIME_OBJ", runtimeObj)
            else:
                tooling_envAssignCollect(envOverrides, "BACKEND_NO_RUNTIME_C", "0")
    elif libraryEmit:
        tooling_envAssignCollect(envOverrides, "BACKEND_NO_RUNTIME_C", "1")
    else:
        tooling_envAssignCollect(envOverrides, "BACKEND_NO_RUNTIME_C", "0")
    tooling_stage0LegacyCStringCompatCollect(root, stage0Exec, envOverrides)
    var stage0Args: str[] = []
    add(stage0Args, "--input:" + inPath)
    add(stage0Args, "--output:" + backendOutPath)
    add(stage0Args, "--target:" + target)
    add(stage0Args, "--linker:" + linker)
    commandBuildMs = tooling_nowMs() - commandBuildStartMs
    var timeoutSec: int32 = tooling_clampCompileTimeoutSec(
        tooling_parseInt32Default(os.getEnvDefault("TOOLING_COMPILE_TIMEOUT", ""), 60))
    let compileExecStartMs: int64 = tooling_nowMs()
    let directCapturePreferred: bool =
        tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_DIRECT_CAPTURE", "0"))
    let directExecAllowed: bool =
        !releaseBuild &&
        !libraryEmit &&
        !devStrict &&
        tooling_strEq(linker, "self") &&
        !tooling_stage0LockContextEnabled("compile_exe") &&
        !tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_FORCE_SHELL", "0")) &&
        !tooling_isTrue(os.getEnvDefault("TOOLING_TIMEOUT_DIAG", "0"))
    var runCmd: str = ""
    var res: os.ExecCmdResult
    if directExecAllowed:
        runCmd = tooling_shellQuote(stage0Exec) + " [direct_spawn]"
        if directCapturePreferred:
            res = os.execFileCapture(stage0Exec, stage0Args, envOverrides, root, true, timeoutSec)
        else:
            let directRc: int32 = os.execFileStatus(stage0Exec, stage0Args, envOverrides, root, timeoutSec)
            if directRc == 0:
                res = os.ExecCmdResult(output: "", exitCode: 0)
            elif directRc == 124:
                res = os.ExecCmdResult(output: "", exitCode: directRc)
            else:
                res = os.execFileCapture(stage0Exec, stage0Args, envOverrides, root, true, timeoutSec)
    else:
        var shellCmdParts: str[] = []
        add(shellCmdParts, tooling_envOverridesShellPrefix(envOverrides))
        add(shellCmdParts, tooling_shellQuote(stage0Exec))
        add(shellCmdParts, " ")
        add(shellCmdParts, tooling_shellQuote("--input:" + inPath))
        add(shellCmdParts, " ")
        add(shellCmdParts, tooling_shellQuote("--output:" + backendOutPath))
        add(shellCmdParts, " ")
        add(shellCmdParts, tooling_shellQuote("--target:" + target))
        add(shellCmdParts, " ")
        add(shellCmdParts, tooling_shellQuote("--linker:" + linker))
        let cmdBase: str = tooling_joinFragments(shellCmdParts)
        runCmd = tooling_wrapStage0LockTimeout(root, timeoutSec, cmdBase, "compile_exe")
        res = tooling_exec(root, runCmd)
    compileExecMs = tooling_nowMs() - compileExecStartMs
    let compileOutput: str = os.execCmdResultOutput(res)
    let rc: int32 = os.execCmdResultExitCode(res)
    if rc != 0 && tooling_isCompileCrashExitCode(rc):
        let reportPath: str = tooling_writeCompileCrashReport(
            root,
            "compile_exe",
            rc,
            1,
            1,
            runCmd,
            compileOutput
        )
        if tooling_strNonEmpty(reportPath):
            tooling_printErr("cheng_tooling: compile crash report: " + reportPath)
    if rc != 0:
        if tooling_strNonEmpty(compileOutput):
            let _logWriteOk: bool = tooling_writeTextFileViaShell(root, compileLog, compileOutput)
            if !_logWriteOk:
                os.writeFile(compileLog, compileOutput)
        tooling_printErr("cheng_tooling: compile failed rc=" + intToStr(rc) +
                         " kind=" + tooling_exitKind(rc) + " stage0=" + stage0 +
                         "; log=" + compileLog)
        if rc == 124:
            tooling_printErr("compile timeout reached " + intToStr(timeoutSec) + "s")
        if tooling_fileExistsNonEmpty(compileLog):
            tooling_printCommandLogTail(root, compileLog, "compile_exe", 260)
        if exeEmit:
            tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj,
                                             atomicExePublish || directExeOutput)
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return rc
    if !tooling_fileExistsNonEmpty(backendOutPath):
        if exeEmit:
            tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj,
                                             atomicExePublish || directExeOutput)
        tooling_stage0MarkBlocked(root, stage0Exec, rc, "compile_exe_missing_output", "missing_output")
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: compile returned success but produced no output: " + backendOutPath)
        tooling_printErr("cheng_tooling: stage0 quarantined to prevent repeated false-success compiles: " + stage0)
        return 1
    if libraryEmit:
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        let linkRc: int32 = tooling_linkReleaseLibrary(root, emitMode, target, outPath, backendOutPath, releaseLdflagsRaw)
        if os.fileExists(backendOutPath):
            os.removeFile(backendOutPath)
        if os.fileExists(backendOutTmpLinkObj):
            os.removeFile(backendOutTmpLinkObj)
        if os.fileExists(backendOutObj):
            os.removeFile(backendOutObj)
        if linkRc != 0:
            return linkRc
        if tooling_compilePrintOutEnabled():
            tooling_printOut("compile_out=" + outPath)
        if tooling_compileSuccessMetaVerboseEnabled():
            tooling_printOut("compile_driver=" + stage0)
            tooling_printOut("compile_driver_track=canonical")
            tooling_printOut("compile_target=" + target)
            tooling_printOut("compile_linker=" + linker)
            tooling_printOut("compile_track=" + buildTrack)
            tooling_printOut("compile_dev_mode=" + devMode)
            tooling_printOut("compile_emit=" + emitMode)
            var compileProfileLib: str = "release_system_link_static_obj_packaged"
            if tooling_strEq(emitMode, "shared"):
                compileProfileLib = "release_system_link_shared_obj_packaged"
            tooling_printOut("compile_profile=" + compileProfileLib)
            tooling_printOut("compile_run_mode=none")
        return 0
    if tooling_strEq(emitMode, "exe"):
        let publishStartMs: int64 = tooling_nowMs()
        let chmodRes: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(backendOutPath))
        tooling_printExecOutput(chmodRes)
        if os.execCmdResultExitCode(chmodRes) != 0:
            tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj,
                                             atomicExePublish || directExeOutput)
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            tooling_printErr("cheng_tooling: chmod failed: " + backendOutPath)
            return 1
        if atomicExePublish && !tooling_strEq(backendOutPath, outPath):
            if !tooling_publishExecutableAtomicInPlace(root, backendOutPath, outPath):
                tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj, true)
                tooling_cleanupStage0Exec(stage0, stage0Exec)
                tooling_printErr("cheng_tooling: compile publish failed: " + outPath)
                return 1
        publishMs = tooling_nowMs() - publishStartMs
        tooling_cleanupCompileExeOutputs(backendOutPath, backendOutTmpLinkObj, backendOutObj, false)
        if atomicExePublish && os.fileExists(backendOutPath):
            os.removeFile(backendOutPath)
    tooling_cleanupStage0Exec(stage0, stage0Exec)
    if tooling_compilePrintOutEnabled():
        tooling_printOut("compile_out=" + outPath)
    if tooling_compileSuccessMetaVerboseEnabled():
        tooling_printOut("compile_driver=" + stage0)
        tooling_printOut("compile_driver_track=canonical")
        tooling_printOut("compile_target=" + target)
        tooling_printOut("compile_linker=" + linker)
        tooling_printOut("compile_track=" + buildTrack)
        tooling_printOut("compile_dev_mode=" + devMode)
        tooling_printOut("compile_emit=" + emitMode)
        var compileProfile: str = "release_system_link_canonical_driver"
        if !releaseBuild:
            if tooling_strEq(linker, "self"):
                compileProfile = devStrict ? "dev_strict_mem_exe" : "dev_fast_mem_exe"
            else:
                compileProfile = "dev_system_link_stable"
        tooling_printOut("compile_profile=" + compileProfile)
        var runModeText: str = runMode
        if !tooling_strNonEmpty(runModeText):
            runModeText = "none"
        tooling_printOut("compile_run_mode=" + runModeText)
    tooling_printCompilePhaseTiming("stage0_resolve", stage0ResolveMs)
    tooling_printCompilePhaseTiming("stage0_prepare", stage0PrepareMs)
    tooling_printCompilePhaseTiming("stage0_preflight", stage0PreflightMs)
    tooling_printCompilePhaseTiming("runtime_obj", runtimeResolveMs)
    tooling_printCompilePhaseTiming("command_build", commandBuildMs)
    tooling_printCompilePhaseTiming("compile_exec", compileExecMs)
    tooling_printCompilePhaseTiming("publish", publishMs)
    tooling_printCompilePhaseTiming("total", tooling_nowMs() - compileStartMs)
    if runAfter:
        var runCmd: str = ""
        if tooling_strEq(runMode, "host"):
            let selfExe: str = tooling_selfExecPath(root)
            if !tooling_strNonEmpty(selfExe):
                tooling_printErr("cheng_tooling: cannot resolve tooling executable for host runner reentry")
                if runEphemeralOut && os.fileExists(outPath):
                    os.removeFile(outPath)
                return 1
            runCmd = runCmd + tooling_envAssignCompat("TOOLING_SELF_BIN", selfExe)
            runCmd = runCmd + tooling_shellQuote(selfExe) + " run backend_host_runner run-host " +
                     tooling_shellQuote("--exe:" + outPath)
            let stateDirRaw: str = strutil.strip(os.getEnvDefault("BACKEND_HOSTRUNNER_STATE_DIR", ""))
            if tooling_strNonEmpty(stateDirRaw):
                let stateAbs: str = tooling_pathAbsolute(root, stateDirRaw)
                runCmd = runCmd + " " + tooling_shellQuote("--state:" + stateAbs)
        else:
            runCmd = tooling_shellQuote(outPath)
        let runRes: os.ExecCmdResult = tooling_exec(root, runCmd)
        tooling_printExecOutput(runRes)
        let runRc: int32 = os.execCmdResultExitCode(runRes)
        if runEphemeralOut:
            if os.fileExists(outPath):
                os.removeFile(outPath)
            let tmpLinkObj: str = outPath + ".tmp.linkobj"
            if os.fileExists(tmpLinkObj):
                os.removeFile(tmpLinkObj)
        return runRc
    return 0

fn tooling_cmdCompileFromArgsMode(root: str, firstArgIndex: int32, count: int32,
                                  commandIdRaw: str, forceRelease: bool): int32 =
    let commandId: str = strutil.toLowerAscii(strutil.strip(commandIdRaw))
    var inPath: str = ""
    var outPath: str = ""
    var outName: str = ""
    var target: str = os.getEnvDefault("BACKEND_TARGET", "")
    let linkerEnvRaw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_LINKER", "")))
    let expectedLinker: str = forceRelease ? "system" : "self"
    if tooling_strNonEmpty(linkerEnvRaw) && !tooling_strEq(linkerEnvRaw, "auto"):
        tooling_printErr("cheng_tooling: " + commandId + " does not accept BACKEND_LINKER (fixed: " + expectedLinker + "); unset BACKEND_LINKER")
        return 2
    let buildTrackEnvRaw: str = os.getEnvDefault("BACKEND_BUILD_TRACK", "dev")
    let trackPolicyRc: int32 = tooling_enforceBuildTrackPolicy(commandId, buildTrackEnvRaw)
    if trackPolicyRc != 0:
        return trackPolicyRc
    var releaseBuild: bool = forceRelease
    var devMode: str = tooling_compileDevModeFromEnv()
    var emitMode: str = "exe"
    var runAfter: bool = false
    var runMode: str = ""
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            if forceRelease:
                tooling_printReleaseCompileUsage()
            else:
                tooling_printCompileUsage()
            return 0
        if strutil.startsWith(arg, "--in:"):
            inPath = strings.dropPrefix(arg, "--in:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--out:"):
            outPath = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--name:"):
            outName = strings.dropPrefix(arg, "--name:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--target:"):
            target = strings.dropPrefix(arg, "--target:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--stage0:"):
            tooling_printErr("cheng_tooling: --stage0 has been removed; canonical driver is mandatory")
            return 2
        if strutil.startsWith(arg, "--linker:"):
            if forceRelease:
                tooling_printErr("cheng_tooling: release-compile no longer accepts --linker (fixed: system-link)")
            else:
                tooling_printErr("cheng_tooling: " + commandId + " no longer accepts --linker (fixed: self-link)")
            return 2
        if tooling_strEq(arg, "--release"):
            if forceRelease:
                i = i + 1
                continue
            tooling_printErr("cheng_tooling: " + commandId + " no longer accepts --release; use `release-compile`")
            return 2
        if tooling_strEq(arg, "--dev"):
            if forceRelease:
                tooling_printErr("cheng_tooling: release-compile does not accept --dev")
                return 2
            devMode = "fast"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--dev:"):
            if forceRelease:
                tooling_printErr("cheng_tooling: release-compile does not accept --dev:*")
                return 2
            let modeRaw: str = strings.dropPrefix(arg, "--dev:")
            let modeNorm: str = tooling_compileDevModeParsed(modeRaw)
            if !tooling_strNonEmpty(modeNorm):
                tooling_printErr("cheng_tooling: invalid --dev mode (expected fast|strict): " + modeRaw)
                return 2
            devMode = modeNorm
            i = i + 1
            continue
        if tooling_strEq(arg, "--run"):
            runAfter = true
            if !tooling_strNonEmpty(runMode):
                runMode = "host"
            i = i + 1
            continue
        if tooling_strEq(arg, "--run:host"):
            runAfter = true
            runMode = "host"
            i = i + 1
            continue
        if tooling_strEq(arg, "--run:file"):
            runAfter = true
            runMode = "file"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--emit:"):
            let emit: str = strutil.toLowerAscii(strutil.strip(strings.dropPrefix(arg, "--emit:")))
            if tooling_strEq(emit, "shared") || tooling_strEq(emit, "static"):
                if !forceRelease:
                    tooling_printErr("cheng_tooling: `cheng` only supports --emit:exe (library emit is release-compile only)")
                    return 2
            elif !tooling_strEq(emit, "exe"):
                if forceRelease:
                    tooling_printErr("cheng_tooling: release-compile supports --emit:exe|shared|static")
                else:
                    tooling_printErr("cheng_tooling: compile only supports --emit:exe")
                return 2
            emitMode = emit
            i = i + 1
            continue
        if strutil.startsWith(arg, "--frontend:"):
            let frontend: str = strings.dropPrefix(arg, "--frontend:")
            if !tooling_strEq(frontend, "stage1"):
                tooling_printErr("cheng_tooling: compile only supports --frontend:stage1")
                return 1
            i = i + 1
            continue
        if tooling_strEq(arg, "--orc") || strutil.startsWith(arg, "--mm:") ||
           tooling_strEq(arg, "--multi") || strutil.startsWith(arg, "--jobs:"):
            i = i + 1
            continue
        if strutil.startsWith(arg, "--manifest:") || strutil.startsWith(arg, "--lock:") ||
           strutil.startsWith(arg, "--registry:") || strutil.startsWith(arg, "--package:") ||
           strutil.startsWith(arg, "--channel:") || strutil.startsWith(arg, "--lock-format:") ||
           strutil.startsWith(arg, "--meta-out:") || strutil.startsWith(arg, "--buildmeta:") ||
           strutil.startsWith(arg, "--pkg-cache:") || strutil.startsWith(arg, "--ledger:") ||
           strutil.startsWith(arg, "--source-listen:") || strutil.startsWith(arg, "--source-peer:") ||
           strutil.startsWith(arg, "--pkg-roots:") || tooling_strEq(arg, "--skip-pkg") ||
           tooling_strEq(arg, "--verify"):
            i = i + 1
            continue
        if strutil.startsWith(arg, "-"):
            tooling_printErr("cheng_tooling: unknown compile arg: " + arg)
            return 1
        if !tooling_strNonEmpty(inPath):
            inPath = arg
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unexpected positional arg: " + arg)
        return 1
    if !tooling_strNonEmpty(inPath):
        tooling_printErr("cheng_tooling: " + commandId + " requires input file (use --in:<file.cheng>)")
        if forceRelease:
            tooling_printReleaseCompileUsage()
        else:
            tooling_printCompileUsage()
        return 1
    if forceRelease:
        releaseBuild = true
    else:
        releaseBuild = false
    if runAfter && tooling_emitModeIsLibrary(emitMode):
        tooling_printErr("cheng_tooling: --emit:shared/static does not support --run/--run:*")
        return 2
    return tooling_cmdCompileExe(root, inPath, outPath, outName, target, releaseBuild, devMode, emitMode, runAfter, runMode)

fn tooling_cmdCompileFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    return tooling_cmdCompileFromArgsMode(root, firstArgIndex, count, "cheng", false)

fn tooling_cmdCompileFromArgsNamed(root: str, firstArgIndex: int32, count: int32,
                                   commandIdRaw: str): int32 =
    let commandId: str = strutil.toLowerAscii(strutil.strip(commandIdRaw))
    if tooling_strEq(commandId, "compile") || tooling_strEq(commandId, "chengc"):
        tooling_printErr("cheng_tooling: `" + commandId + "` has been removed; use `cheng`")
        return 2
    return tooling_cmdCompileFromArgsMode(root, firstArgIndex, count, commandId, false)

fn tooling_cmdReleaseCompileFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    return tooling_cmdCompileFromArgsMode(root, firstArgIndex, count, "release-compile", true)

fn tooling_printBootstrapPureUsage() =
    tooling_printLines(tselfboot.toolingBootstrapPureUsageLines())

fn tooling_cmdBootstrapPureFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingBootstrapPureArgs =
        tselfboot.toolingBootstrapPureParseArgs(tooling_argsRange(firstArgIndex, count))
    if parsed.helpRequested:
        tooling_printBootstrapPureUsage()
        return 0
    if !parsed.ok:
        tooling_printErr(parsed.error)
        return parsed.exitCode
    let mode: str = parsed.mode
    var compileStage1: bool = parsed.compileStage1
    let outDir: str = parsed.outDir
    let timingOut: str = parsed.timingOut
    let fullspec: bool = parsed.fullspec
    if !tooling_strNonEmpty(mode):
        tooling_printErr("cheng_tooling: invalid bootstrap-pure mode")
        return 1
    var res: ToolingSelfhostResult
    let allowBootstrapCapabilityRefresh: bool = tooling_isTrue(
        os.getEnvDefault("BOOTSTRAP_UPDATE_SEED", "0"))
    if tooling_strEq(mode, "strict"):
        compileStage1 = true
        res = tooling_selfhostBootstrapStrictHost(root, outDir, timingOut, "",
                                                  allowBootstrapCapabilityRefresh)
    else:
        res = tooling_selfhostBootstrapFastHost(root, compileStage1, outDir, timingOut, "",
                                                allowBootstrapCapabilityRefresh)
    if !res.ok:
        var msg: str = res.message
        if !tooling_strNonEmpty(msg):
            msg = "unknown failure"
        tooling_printErr("cheng_tooling: bootstrap-pure failed: " + msg)
        if tooling_strEq(mode, "strict"):
            if tooling_strNonEmpty(res.stage2Sha256):
                tooling_printErr("cheng_tooling: bootstrap-pure strict stage2_sha256=" + res.stage2Sha256)
            if tooling_strNonEmpty(res.stage3Sha256):
                tooling_printErr("cheng_tooling: bootstrap-pure strict stage3_sha256=" + res.stage3Sha256)
            if tooling_strNonEmpty(res.strictMismatchReport):
                tooling_printErr("cheng_tooling: bootstrap-pure strict mismatch_report=" + res.strictMismatchReport)
        return 1
    tooling_printOut("bootstrap_pure_mode=" + mode)
    tooling_printOut("bootstrap_pure_stage1=" + res.stage1Path)
    tooling_printOut("bootstrap_pure_stage2=" + res.stage2Path)
    tooling_printOut("bootstrap_pure_stage1_status=" + res.stage1Status)
    tooling_printOut("bootstrap_pure_stage1_compile_mode=" + res.stage1CompileMode)
    tooling_printOut("bootstrap_pure_stage1_rebuild_ok=" + tooling_boolText(res.stage1RebuildOk))
    if tooling_strEq(mode, "strict"):
        tooling_printOut("bootstrap_pure_stage3=" + res.stage3Path)
        tooling_printOut("bootstrap_pure_stage2_sha256=" + res.stage2Sha256)
        tooling_printOut("bootstrap_pure_stage3_sha256=" + res.stage3Sha256)
        tooling_printOut("bootstrap_pure_fixed_point_ok=" + tooling_boolText(res.fixedPointOk))
        tooling_printOut("bootstrap_pure_strict_mismatch_report=" + res.strictMismatchReport)
    tooling_printOut("bootstrap_pure_total_ms=" + intToStr(int32(res.totalMs)))
    if fullspec:
        let fullspecScriptPath: str = tinv.toolingResolveScriptPath(root, "verify_fullchain_bootstrap")
        if !tooling_strNonEmpty(fullspecScriptPath):
            tooling_printErr("cheng_tooling: bootstrap-pure --fullspec missing verify_fullchain_bootstrap entry")
            return 1
        tooling_printOut("bootstrap_pure_fullspec=1")
        let fullspecRc: int32 = tooling_runScript(root, fullspecScriptPath, count + 1)
        if fullspecRc != 0:
            tooling_printErr("cheng_tooling: bootstrap-pure --fullspec failed rc=" + intToStr(fullspecRc))
            return fullspecRc
        tooling_printOut("bootstrap_pure_fullspec_ok=1")
    if tooling_isTrue(os.getEnvDefault("BOOTSTRAP_UPDATE_SEED", "0")):
        let seedOut: str = tooling_pathAbsolute(root, "artifacts/backend_seed/cheng.stage2")
        if !tooling_copyExecutable(root, res.stage2Path, seedOut):
            tooling_printErr("cheng_tooling: bootstrap-pure seed update failed: " + seedOut)
            return 1
        tooling_printOut("bootstrap_pure_seed_updated=" + seedOut)
    return 0

fn tooling_cmdDriverPathFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var pathOnly: bool = false
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("driver-path options:")
            tooling_printOut("  --path-only                  print only canonical driver path")
            return 0
        if tooling_strEq(arg, "--path-only"):
            pathOnly = true
            i = i + 1
            continue
        if strutil.startsWith(arg, "--stage0:"):
            tooling_printErr("cheng_tooling: --stage0 has been removed; canonical driver is mandatory")
            return 2
        tooling_printErr("cheng_tooling: unknown driver-path arg: " + arg)
        return 1
    return tooling_cmdDriverPath(root, pathOnly)

fn tooling_cmdBuildBackendDriverFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var outPath: str = os.getEnvDefault("BACKEND_LOCAL_DRIVER_REL", "artifacts/backend_driver/cheng")
    var stage0: str = ""
    var target: str = os.getEnvDefault("BACKEND_TARGET", "")
    var requireRebuild: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_REQUIRE_REBUILD", "0"))
    var debugRebuild: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_DEBUG_REBUILD", "0"))
    var modeRaw: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_MODE", "")
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build-backend-driver options:")
            tooling_printOut("  --out:<path>                 output path")
            tooling_printOut("  --name:<path>                legacy alias of --out")
            tooling_printOut("  --stage0:<path>              explicit stage0 override (requires TOOLING_STAGE0_ALLOW_EXPLICIT=1)")
            tooling_printOut("  --target:<triple>            explicit backend target")
            tooling_printOut("  --fast                       dev-fast rebuild (quick/system-link by default)")
            tooling_printOut("  --seal                       strict seal rebuild (full/system-link by default)")
            tooling_printOut("  --mode:auto|fast|seal       explicit build mode")
            tooling_printOut("  --require-rebuild            fail if stage0 reuse happens")
            tooling_printOut("  --require-rebuild:0|1        explicit require-rebuild toggle")
            tooling_printOut("  --debug-rebuild              keep attempt artifacts and skip canonical install")
            tooling_printOut("  --debug-rebuild:0|1          explicit debug-rebuild toggle")
            tooling_printOut("  --full-rebuild[[:0|1]]       alias of --seal / --mode:seal")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_LINKER=self|system (default: fast=system, seal=system)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_AUTO_CLEAN_HISTORY=1|0 (default 1)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_MODE=auto|fast|seal (default auto; fast unless require-rebuild/debug)")
            tooling_printOut("       BUILD_DRIVER_STRICT_NATIVE=1|0 (default 1; seal path)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_FAST_STRICT_NATIVE=1|0 (default 1; fast path, set 0 for experimental self-link)")
            tooling_printOut("  env: BUILD_DRIVER_ALLOW_FALLBACK (removed; fallback path hard-disabled)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_REBUILD_CRASH_RETRY_SAFE=1|0 (default 0)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_CRASH_RETRY_MAX=0..2 (default 1 when retry enabled)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_JOBS=<N> (default auto: 2 on multicore, 1 on single-core)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_REBUILD_TIMEOUT=60 (full-only, hard cap)")
            tooling_printOut("       TOOLING_BUILD_DRIVER_DIST_RECOVERY_TIMEOUT=60 (default; dist stage0 compile timeout cap)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_DIST_FAIL_FAST=1|0 (default 1; no retry loop on dist stage0 timeout/segfault)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_SKIP_GLOBAL_INIT=1|0 (fixed required: 0)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_DISABLE_DUP_SCAN=1|0 (default 0)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_REQUIRE_REBUILD=1|0 (default 0)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_EAGER_REBUILD=1|0 (default 0; only effective when require-rebuild=0 and strict-native=0)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_FAST_REUSE=1|0 (default 1; allow direct reuse only when final output stamp matches current source/capability)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_FAST_CANONICAL_SMOKE=1|0 (default 1; require dev/release smoke + proof sidecar before fast canonical install/reuse)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=1|0 (default 1)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=1|0 (default 1; share quick cache across different --out paths)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_QUICK_STAMP_HIT_FAST_SANITY=1|0 (default 1)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_QUICK_LIGHT_SANITY=1|0 (default 1)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_SOURCE=<path> (default src/backend/tooling/backend_driver.cheng)")
            tooling_printOut("  env: BACKEND_BUILD_DRIVER_PROFILE_MODE=backend|safe|stage1_uir|full (default backend)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_PROFILE_FAIL_OPEN=1|0 (default 0; auto-disable profile flags on segfault)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_STAMP_CACHE=1|0 (default 1; full-only)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REBUILD_STAMP_IGNORE_STAGE0_SHA=1|0 (tight profile default 1)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_CRASH_TRACE=1|0 (default 1; write stage1 trace log on rc=138/139)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_CRASH_TRACE_TIMEOUT=<sec> (default 25)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REQUIRE_REBUILD_PROMOTE_DIST=1|0 (default 0; emergency-only dist promote on rebuild failure)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_REQUIRE_REBUILD_PROMOTE_DIST_PROBE=1|0 (default 0; require compile probe when promoting dist seed)")
            tooling_printOut("       BACKEND_BUILD_DRIVER_DEBUG_REBUILD=1|0 (default 0; diagnostic mode)")
            tooling_printOut("       TOOLING_STAGE0_ALLOW_MAIN_ONLY=1|0 (default 0; reject main-only stage0 binaries)")
            tooling_printOut("  env: TOOLING_STAGE0_HARD_BLOCK_ON_UE=1|0 (default 1)")
            tooling_printOut("       TOOLING_STAGE0_GENERATION_GUARD=1|0 (default 1; ignore UE older than current driver generation)")
            tooling_printOut("       TOOLING_STAGE0_INODE_GUARD=1|0 (default 1; ignore UE mapped to an older driver inode)")
            tooling_printOut("       TOOLING_STAGE0_GENERATION_MARGIN_SEC=<sec> (default 3)")
            tooling_printOut("       TOOLING_STAGE0_BLOCK_SHA256=<sha[,sha...]> (hard-block known bad driver digests)")
            tooling_printOut("       SELFHOST_STAGE1_STAMP_HIT_FAST_SANITY=1|0 (default 1; selfhost compile-stage1 only)")
            return 0
        if strutil.startsWith(arg, "--out:"):
            outPath = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--name:"):
            outPath = strings.dropPrefix(arg, "--name:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--stage0:"):
            if !tooling_stage0ExplicitOverrideAllowed():
                tooling_printErr("cheng_tooling: --stage0 requires TOOLING_STAGE0_ALLOW_EXPLICIT=1")
                return 2
            stage0 = strings.dropPrefix(arg, "--stage0:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--target:"):
            target = strings.dropPrefix(arg, "--target:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--fast"):
            modeRaw = "fast"
            i = i + 1
            continue
        if tooling_strEq(arg, "--seal"):
            modeRaw = "seal"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--mode:"):
            modeRaw = strings.dropPrefix(arg, "--mode:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--require-rebuild"):
            requireRebuild = true
            i = i + 1
            continue
        if strutil.startsWith(arg, "--require-rebuild:"):
            requireRebuild = tooling_isTrue(strings.dropPrefix(arg, "--require-rebuild:"))
            i = i + 1
            continue
        if tooling_strEq(arg, "--debug-rebuild"):
            debugRebuild = true
            i = i + 1
            continue
        if strutil.startsWith(arg, "--debug-rebuild:"):
            debugRebuild = tooling_isTrue(strings.dropPrefix(arg, "--debug-rebuild:"))
            i = i + 1
            continue
        if tooling_strEq(arg, "--full-rebuild"):
            modeRaw = "seal"
            i = i + 1
            continue
        if strutil.startsWith(arg, "--full-rebuild:"):
            if tooling_isTrue(strings.dropPrefix(arg, "--full-rebuild:")):
                modeRaw = "seal"
            else:
                modeRaw = "fast"
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown build-backend-driver arg: " + arg)
        return 1
    return tooling_cmdBuildBackendDriver(root, outPath, stage0, target, requireRebuild, debugRebuild, modeRaw)

fn tooling_cmdSelfhostBootstrapFastHostFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingSelfhostBootstrapFastHostArgs =
        tselfboot.toolingSelfhostBootstrapFastHostParseArgs(tooling_argsRange(firstArgIndex, count))
    if parsed.helpRequested:
        tooling_printLines(tselfboot.toolingSelfhostBootstrapFastHostUsageLines())
        return 0
    if !parsed.ok:
        tooling_printErr(parsed.error)
        return parsed.exitCode
    return tooling_cmdSelfhostBootstrapFastHost(
        root, parsed.compileStage1, parsed.outDir, parsed.timingOut, "")

fn tooling_cmdSelfhostStrictInmemWitnessFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingSelfhostStrictInmemWitnessArgs =
        tselfboot.toolingSelfhostStrictInmemWitnessParseArgs(tooling_argsRange(firstArgIndex, count))
    if parsed.helpRequested:
        tooling_printLines(tselfboot.toolingSelfhostStrictInmemWitnessUsageLines())
        return 0
    if !parsed.ok:
        tooling_printErr(parsed.error)
        return parsed.exitCode
    let res: ToolingSelfhostResult =
        tooling_selfhostStrictInmemWitnessHost(root, parsed.outDir, parsed.timingOut, "", false)
    if !res.ok:
        var msg: str = res.message
        if !tooling_strNonEmpty(msg):
            msg = "unknown failure"
        tooling_printErr("cheng_tooling: verify_backend_selfhost_bootstrap_inmem_witness failed: " + msg)
        return 1
    tooling_printOut("selfhost_inmem_witness_mode=" + res.mode)
    tooling_printOut("selfhost_inmem_witness_stage0=" + res.stage0Path)
    tooling_printOut("selfhost_inmem_witness_stage0_driver_kind=" + res.stage0DriverKind)
    tooling_printOut("selfhost_inmem_witness_stage1=" + res.stage1Path)
    tooling_printOut("selfhost_inmem_witness_stage1_status=" + res.stage1Status)
    tooling_printOut("selfhost_inmem_witness_total_ms=" + intToStr(int32(res.totalMs)))
    return 0

fn tooling_cmdSelfhostInnerLoopFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingSelfhostInnerLoopArgs =
        tselfboot.toolingSelfhostInnerLoopParseArgs(tooling_argsRange(firstArgIndex, count))
    if parsed.helpRequested:
        tooling_printLines(tselfboot.toolingSelfhostInnerLoopUsageLines())
        return 0
    if !parsed.ok:
        tooling_printErr(parsed.error)
        return parsed.exitCode
    let res: ToolingSelfhostInnerLoopResult =
        tooling_selfhostInnerLoop(
            root, parsed.outDir, parsed.timingOut,
            parsed.runInmemWitness, parsed.runStrict, parsed.runClosure)
    let inmemRes: ToolingSelfhostResult = res.inmemRes
    let strictRes: ToolingSelfhostResult = res.strictRes
    tooling_printOut("selfhost_inner_loop_out_dir=" + res.outDir)
    tooling_printOut("selfhost_inner_loop_timing=" + res.timingPath)
    tooling_printOut("selfhost_inner_loop_summary=" + res.summaryPath)
    tooling_printOut("selfhost_inner_loop_build_driver=" + res.buildDriverPath)
    tooling_printOut("selfhost_inner_loop_build_driver_ms=" + intToStr(int32(res.buildMs)))
    tooling_printOut("selfhost_inner_loop_build_driver_rc=" + intToStr(res.buildRc))
    tooling_printOut("selfhost_inner_loop_inmem_requested=" + tooling_boolText(res.inmemRequested))
    if inmemRes != nil:
        tooling_printOut("selfhost_inner_loop_inmem_stage1=" + inmemRes.stage1Path)
        tooling_printOut("selfhost_inner_loop_inmem_total_ms=" + intToStr(int32(inmemRes.totalMs)))
    tooling_printOut("selfhost_inner_loop_strict_requested=" + tooling_boolText(res.strictRequested))
    if strictRes != nil:
        tooling_printOut("selfhost_inner_loop_strict_stage2=" + strictRes.stage2Path)
        tooling_printOut("selfhost_inner_loop_strict_stage3=" + strictRes.stage3Path)
        tooling_printOut("selfhost_inner_loop_strict_total_ms=" + intToStr(int32(strictRes.totalMs)))
        tooling_printOut("selfhost_inner_loop_strict_fixed_point_ok=" + tooling_boolText(strictRes.fixedPointOk))
    tooling_printOut("selfhost_inner_loop_closure_requested=" + tooling_boolText(res.closureRequested))
    tooling_printOut("selfhost_inner_loop_closure_rc=" + intToStr(res.closureRc))
    tooling_printOut("selfhost_inner_loop_total_ms=" + intToStr(int32(res.totalMs)))
    if !res.ok:
        tooling_printOut("selfhost_inner_loop_ok=0")
        tooling_printOut("selfhost_inner_loop_failed_step=" + res.failedStep)
    else:
        tooling_printOut("selfhost_inner_loop_ok=1")
    if !res.ok:
        var msg: str = res.message
        if !tooling_strNonEmpty(msg):
            msg = "unknown failure"
        tooling_printErr("cheng_tooling: verify_backend_selfhost_inner_loop failed step=" + res.failedStep +
                         " message=" + tooling_summaryOneLine(msg))
        return 1
    return 0

fn tooling_cmdSelfhostBootstrapVerifyFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let parsed: tselfboot.ToolingSelfhostBootstrapVerifyArgs =
        tselfboot.toolingSelfhostBootstrapVerifyParseArgs(tooling_argsRange(firstArgIndex, count))
    if parsed.helpRequested:
        tooling_printLines(tselfboot.toolingSelfhostBootstrapVerifyUsageLines())
        return 0
    if !parsed.ok:
        tooling_printErr(parsed.error)
        return parsed.exitCode
    let mode: str = parsed.mode
    var compileStage1: bool = parsed.compileStage1
    let outDir: str = parsed.outDir
    let timingOut: str = parsed.timingOut
    let strictInmemWitness: bool = parsed.strictInmemWitness
    if !tooling_strNonEmpty(mode):
        tooling_printErr("cheng_tooling: invalid verify_backend_selfhost_bootstrap_self_obj mode")
        return 1
    var res: ToolingSelfhostResult
    if tooling_strEq(mode, "strict"):
        compileStage1 = true
        if strictInmemWitness:
            let witnessRes: ToolingSelfhostResult =
                tooling_selfhostStrictInmemWitnessHost(root, outDir, timingOut, "", false)
            if !witnessRes.ok:
                var wmsg: str = witnessRes.message
                if !tooling_strNonEmpty(wmsg):
                    wmsg = "unknown failure"
                tooling_printErr("cheng_tooling: strict inmem witness failed before strict host fixed-point: " + wmsg)
                return 1
            tooling_printOut("selfhost_strict_inmem_witness_ok=1")
            tooling_printOut("selfhost_strict_inmem_witness_stage1=" + witnessRes.stage1Path)
            tooling_printOut("selfhost_strict_inmem_witness_total_ms=" + intToStr(int32(witnessRes.totalMs)))
        res = tooling_selfhostBootstrapStrictHost(root, outDir, timingOut, "", false)
    else:
        res = tooling_selfhostBootstrapFastHost(root, compileStage1, outDir, timingOut, "", false)
    if !res.ok:
        var msg: str = res.message
        if !tooling_strNonEmpty(msg):
            msg = "unknown failure"
        tooling_printErr("cheng_tooling: verify_backend_selfhost_bootstrap_self_obj failed: " + msg)
        if tooling_strEq(mode, "strict"):
            if tooling_strNonEmpty(res.stage2Sha256):
                tooling_printErr("cheng_tooling: stage2_sha256=" + res.stage2Sha256)
            if tooling_strNonEmpty(res.stage3Sha256):
                tooling_printErr("cheng_tooling: stage3_sha256=" + res.stage3Sha256)
            if tooling_strNonEmpty(res.strictMismatchReport):
                tooling_printErr("cheng_tooling: strict_mismatch_report=" + res.strictMismatchReport)
        return 1
    tooling_printOut("selfhost_bootstrap_mode=" + mode)
    tooling_printOut("selfhost_bootstrap_stage1=" + res.stage1Path)
    tooling_printOut("selfhost_bootstrap_stage2=" + res.stage2Path)
    tooling_printOut("selfhost_bootstrap_stage0=" + res.stage0Path)
    tooling_printOut("selfhost_bootstrap_stage0_driver_kind=" + res.stage0DriverKind)
    tooling_printOut("selfhost_bootstrap_stage1_status=" + res.stage1Status)
    tooling_printOut("selfhost_bootstrap_stage1_compile_mode=" + res.stage1CompileMode)
    tooling_printOut("selfhost_bootstrap_stage1_rebuild_ok=" + tooling_boolText(res.stage1RebuildOk))
    tooling_printOut("selfhost_bootstrap_fallback_used=" + tooling_boolText(res.fallbackUsed))
    tooling_printOut("selfhost_bootstrap_quarantine_cleaned=" + intToStr(res.quarantineCleaned))
    tooling_printOut("selfhost_bootstrap_lock_wait_ms=" + intToStr(res.lockWaitMs))
    tooling_printOut("selfhost_bootstrap_strict_rebuild_ok=" + tooling_boolText(res.strictRebuildOk))
    if tooling_strEq(mode, "strict"):
        tooling_printOut("selfhost_bootstrap_stage3=" + res.stage3Path)
        tooling_printOut("selfhost_bootstrap_stage2_sha256=" + res.stage2Sha256)
        tooling_printOut("selfhost_bootstrap_stage3_sha256=" + res.stage3Sha256)
        tooling_printOut("selfhost_bootstrap_fixed_point_ok=" + tooling_boolText(res.fixedPointOk))
        tooling_printOut("selfhost_bootstrap_strict_mismatch_report=" + res.strictMismatchReport)
        tooling_printOut("stage2_sha256=" + res.stage2Sha256)
        tooling_printOut("stage3_sha256=" + res.stage3Sha256)
        tooling_printOut("fixed_point_ok=" + tooling_boolText(res.fixedPointOk))
    tooling_printOut("selfhost_bootstrap_total_ms=" + intToStr(int32(res.totalMs)))
    return 0

fn tooling_cmdSelfhost100msHostFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var hostOnly: str = os.getEnvDefault("SELFHOST_100MS_HOST_ONLY", "darwin_arm64")
    var itersRaw: str = os.getEnvDefault("SELFHOST_100MS_ITERS", "1")
    var p95Raw: str = os.getEnvDefault("SELFHOST_100MS_P95_MS", "100")
    var p99Raw: str = os.getEnvDefault("SELFHOST_100MS_P99_MS", "120")
    var enforceRaw: str = os.getEnvDefault("SELFHOST_100MS_ENFORCE_ON_HOST", "1")
    var reportRaw: str = os.getEnvDefault("SELFHOST_100MS_REPORT", "artifacts/backend_selfhost_100ms_host/report.tsv")
    var compileStage1: bool = tooling_isTrue(os.getEnvDefault("SELFHOST_NATIVE_COMPILE_STAGE1", "1"))
    var outDir: str = os.getEnvDefault("SELFHOST_100MS_OUT_DIR", "artifacts/backend_selfhost_100ms_host")
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("selfhost-100ms-host options:")
            tooling_printOut("  --iters:<N> --p95-ms:<ms> --p99-ms:<ms>")
            tooling_printOut("  --host-only:<tag> --report:<path> --enforce:0|1")
            tooling_printOut("  --compile-stage1|--no-compile-stage1 --out-dir:<path>")
            tooling_printOut("  env: SELFHOST_STAGE1_FULL_REBUILD=1|0 (strict default 1)")
            tooling_printOut("       SELFHOST_STRICT_REBUILD=1|0 (default 1)")
            tooling_printOut("       SELFHOST_100MS_REQUIRE_COMPILE_STAGE1=1|0 (default 1)")
            tooling_printOut("       SELFHOST_100MS_ENFORCE_WITH_COMPILE_STAGE1=1|0 (default 1)")
            tooling_printOut("       SELFHOST_100MS_PREWARM_STAGE1=1|0 (default 1 when --compile-stage1 && iters>1)")
            return 0
        if strutil.startsWith(arg, "--host-only:"):
            hostOnly = strings.dropPrefix(arg, "--host-only:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--iters:"):
            itersRaw = strings.dropPrefix(arg, "--iters:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--p95-ms:"):
            p95Raw = strings.dropPrefix(arg, "--p95-ms:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--p99-ms:"):
            p99Raw = strings.dropPrefix(arg, "--p99-ms:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--enforce:"):
            enforceRaw = strings.dropPrefix(arg, "--enforce:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--report:"):
            reportRaw = strings.dropPrefix(arg, "--report:")
            i = i + 1
            continue
        if tooling_strEq(arg, "--compile-stage1"):
            compileStage1 = true
            i = i + 1
            continue
        if tooling_strEq(arg, "--no-compile-stage1"):
            compileStage1 = false
            i = i + 1
            continue
        if strutil.startsWith(arg, "--out-dir:"):
            outDir = strings.dropPrefix(arg, "--out-dir:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--stage0:"):
            tooling_printErr("cheng_tooling: selfhost-100ms-host no longer accepts --stage0; canonical driver is mandatory")
            return 2
        tooling_printErr("cheng_tooling: unknown selfhost-100ms-host arg: " + arg)
        return 1
    let requireCompileStage1: bool = tooling_isTrue(
        os.getEnvDefault("SELFHOST_100MS_REQUIRE_COMPILE_STAGE1", "1"))
    if requireCompileStage1 && !compileStage1:
        tooling_printErr("cheng_tooling: selfhost-100ms-host requires --compile-stage1 in strict mode")
        tooling_printErr("  hint: set SELFHOST_100MS_REQUIRE_COMPILE_STAGE1=0 only for emergency diagnostics")
        return 2
    return tooling_cmdSelfhost100msHost(root, hostOnly, itersRaw, p95Raw, p99Raw, enforceRaw, reportRaw,
                                        compileStage1, outDir, "")

fn tooling_cmdVerifyBackendFfiOutptrTupleFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var allowRunFailRaw: str = os.getEnvDefault("BACKEND_FFI_OUTPTR_TUPLE_ALLOW_RUN_FAIL", "0")
    let outDir: str = tooling_pathAbsolute(root, "artifacts/backend_ffi_outptr_tuple")
    let fixtureRun: str = "tests/cheng/backend/fixtures/ffi_outptr_tuple_importc_pair_i32.cheng"
    let fixtureStatus: str = "tests/cheng/backend/fixtures/ffi_outptr_tuple_status_i32_objonly.cheng"
    let fixtureFail: str = "tests/cheng/backend/fixtures/compile_fail_ffi_outptr_tuple_arity_mismatch.cheng"
    let toolRaw: str = strutil.strip(os.getEnvDefault("TOOLING_SELF_BIN", "artifacts/tooling_cmd/cheng_tooling"))
    let tool: str = tooling_pathAbsolute(root, toolRaw)
    if !tooling_isExecutable(root, tool):
        tooling_printErr("cheng_tooling: missing tooling binary: " + tool)
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "command -v rg >/dev/null 2>&1")) != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] rg is required")
        return 2

    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("verify_backend_ffi_outptr_tuple options:")
            tooling_printOut("  no supported options")
            return 0
        i = i + 1

    var driver: str = strutil.strip(os.getEnvDefault("BACKEND_DRIVER", ""))
    if !tooling_strNonEmpty(driver):
        let detectRes: os.ExecCmdResult = tooling_exec(root, tooling_shellQuote(tool) + " backend_driver_path")
        driver = strutil.strip(os.execCmdResultOutput(detectRes))
        if !tooling_strNonEmpty(driver):
            tooling_printErr("[verify_backend_ffi_outptr_tuple] failed to resolve backend driver")
            return 1

    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(driver) + " ]")) != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] backend driver not executable: " + driver)
        return 1

    let driverExecScript: str = tooling_pathAbsolute(root, "src/tooling/backend_driver_exec.sh")
    var driverExec: str = driver
    var driverRealEnv: str = ""
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(driverExecScript) + " ]")) == 0:
        driverExec = driverExecScript
        driverRealEnv = tooling_envAssignCompat("BACKEND_DRIVER_REAL", driver)

    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(driverExec) + " ]")) != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] backend driver_exec not executable: " + driverExec)
        return 1

    var target: str = strutil.strip(os.getEnvDefault("BACKEND_TARGET", ""))
    if !tooling_strNonEmpty(target):
        let detectTarget: os.ExecCmdResult =
            tooling_exec(root,
                        tooling_shellQuote(tool) +
                        " detect_host_target 2>/dev/null || echo arm64-apple-darwin")
        target = strutil.strip(os.execCmdResultOutput(detectTarget))
        if !tooling_strNonEmpty(target):
            target = "arm64-apple-darwin"

    let linkEnv: str = strutil.strip(
        os.execCmdResultOutput(tooling_exec(root,
            tooling_shellQuote(tool) + " backend_link_env --driver:" + tooling_shellQuote(driver) +
                " --target:" + tooling_shellQuote(target) + " --linker:" +
                tooling_shellQuote(os.getEnvDefault("BACKEND_LINKER", "auto")))))

    if !tooling_fileExistsNonEmpty(fixtureRun) ||
       !tooling_fileExistsNonEmpty(fixtureStatus) ||
       !tooling_fileExistsNonEmpty(fixtureFail):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] missing fixture file")
        return 1

    if !tooling_mkdirP(root, outDir):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] failed to create output dir: " + outDir)
        return 1

    let safeTarget: str =
        if tooling_strNonEmpty(tooling_sanitizeShellSafeToken(root, target)):
            tooling_sanitizeShellSafeToken(root, target)
        else:
            "unknown"
    var exePath: str = os.joinPath(outDir, "ffi_outptr_tuple_importc_pair_i32." + safeTarget)
    var objPath: str = os.joinPath(outDir, "ffi_outptr_tuple_status_i32_objonly." + safeTarget + ".bin")
    if strutil.contains(strutil.toLowerAscii(target), "windows") || strutil.contains(strutil.toLowerAscii(target), "msvc"):
        exePath = exePath + ".exe"

    let buildRunLog: str = os.joinPath(outDir, "ffi_outptr_tuple." + safeTarget + ".build_run.log")
    let runLog: str = os.joinPath(outDir, "ffi_outptr_tuple." + safeTarget + ".run.log")
    let buildObjLog: str = os.joinPath(outDir, "ffi_outptr_tuple." + safeTarget + ".build_obj.log")
    let buildFailLog: str = os.joinPath(outDir, "ffi_outptr_tuple." + safeTarget + ".build_fail.log")
    let report: str = os.joinPath(outDir, "backend_ffi_outptr_tuple." + safeTarget + ".report.txt")
    let snapshot: str = os.joinPath(outDir, "backend_ffi_outptr_tuple." + safeTarget + ".snapshot.env")
    let cleanup: os.ExecCmdResult = tooling_exec(root,
        "rm -f " + tooling_shellQuote(buildRunLog) + " " + tooling_shellQuote(runLog) + " " +
        tooling_shellQuote(buildObjLog) + " " + tooling_shellQuote(buildFailLog) + " " + tooling_shellQuote(exePath) + " " + tooling_shellQuote(objPath))
    let _ = tooling_exec(root, tooling_shellQuote("/bin/true"))

    let commonCompileEnv: str =
        (if tooling_strNonEmpty(driverRealEnv): driverRealEnv else: "") +
        (if tooling_strNonEmpty(linkEnv): linkEnv + " " else: "") +
        tooling_envAssignCompat("BACKEND_EMIT", "exe") +
        tooling_envAssignCompat("BACKEND_MULTI", "0") +
        tooling_envAssignCompat("BACKEND_MULTI_FORCE", "0") +
        tooling_envAssignCompat("BACKEND_TARGET", target) +
        tooling_envAssignCompat("BACKEND_INPUT", fixtureRun) +
        tooling_envAssignCompat("BACKEND_OUTPUT", exePath)

    let runCompileCmd: str =
        "env " + commonCompileEnv + " " +
        tooling_shellQuote(driverExec) + " >" + tooling_shellQuote(buildRunLog) + " 2>&1"
    let runCompileRes: os.ExecCmdResult = tooling_exec(root, runCompileCmd)
    let runCompileRc: int32 = os.execCmdResultExitCode(runCompileRes)
    if runCompileRc != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] runtime fixture build failed (status=" + intToStr(runCompileRc) + ")")
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,200p' " + tooling_shellQuote(buildRunLog)))
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(exePath) + " ]")) != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] missing executable output: " + exePath)
        return 1

    let runFixtureCmd: str = tooling_shellQuote(exePath) + " >" + tooling_shellQuote(runLog) + " 2>&1"
    let runFixtureRes: os.ExecCmdResult = tooling_exec(root, runFixtureCmd)
    var runStatus: int32 = os.execCmdResultExitCode(runFixtureRes)
    var runMode: str = "host"
    if runStatus != 0:
        let allowMissingSym: bool = tooling_isTrue(allowRunFailRaw)
        if allowMissingSym ||
           os.execCmdResultExitCode(tooling_exec(root,
               "rg -q 'Symbol not found: _cheng_memcpy' " + tooling_shellQuote(runLog) + " >/dev/null 2>&1")) == 0:
            runMode = "runtime_symbol_missing_skip"
            runStatus = 0
        else:
            tooling_printErr("[verify_backend_ffi_outptr_tuple] runtime fixture run failed (status=" + intToStr(runStatus) + ")")
            tooling_printExecOutput(tooling_exec(root, "sed -n '1,120p' " + tooling_shellQuote(runLog)))
            return 1

    let runObjCompileCmd: str =
        "env " +
        (if tooling_strNonEmpty(linkEnv): linkEnv + " " else: "") +
        tooling_envAssignCompat("BACKEND_LINKER", "self") +
        tooling_envAssignCompat("BACKEND_DIRECT_EXE", "1") +
        tooling_envAssignCompat("BACKEND_LINKERLESS_INMEM", "1") +
        tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "0") +
        tooling_envAssignCompat("BACKEND_EMIT", "exe") +
        tooling_envAssignCompat("BACKEND_MULTI", "0") +
        tooling_envAssignCompat("BACKEND_MULTI_FORCE", "0") +
        tooling_envAssignCompat("BACKEND_TARGET", target) +
        tooling_envAssignCompat("BACKEND_INPUT", fixtureStatus) +
        tooling_envAssignCompat("BACKEND_OUTPUT", objPath) +
        tooling_shellQuote(driverExec) + " >" + tooling_shellQuote(buildObjLog) + " 2>&1"
    if os.execCmdResultExitCode(tooling_exec(root, runObjCompileCmd)) != 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] status fixture exe build failed")
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,120p' " + tooling_shellQuote(buildObjLog)))
        return 1
    if !tooling_fileExistsNonEmpty(objPath):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] missing executable output: " + objPath)
        return 1

    let failCompileEnv: str =
        "env " +
        tooling_envAssignCompat("BACKEND_EMIT", "exe") +
        tooling_envAssignCompat("BACKEND_MULTI", "0") +
        tooling_envAssignCompat("BACKEND_MULTI_FORCE", "0") +
        tooling_envAssignCompat("BACKEND_TARGET", target) +
        tooling_envAssignCompat("BACKEND_INPUT", fixtureFail) +
        tooling_envAssignCompat("BACKEND_OUTPUT", os.joinPath(outDir, "compile_fail_ffi_outptr_tuple_arity_mismatch." + safeTarget)) +
        tooling_shellQuote(driverExec) + " >" + tooling_shellQuote(buildFailLog) + " 2>&1"
    let failCompileRes: os.ExecCmdResult = tooling_exec(root, failCompileEnv)
    let failCompileRc: int32 = os.execCmdResultExitCode(failCompileRes)
    if failCompileRc == 0:
        tooling_printErr("[verify_backend_ffi_outptr_tuple] negative fixture unexpectedly compiled")
        return 1

    let diagOk: str =
        if os.execCmdResultExitCode(tooling_exec(root,
            "rg -q --fixed-strings '" + "ffi_out_ptrs tuple arity mismatch" + "' " +
                tooling_shellQuote(buildFailLog) + " >/dev/null 2>&1")) == 0:
            "1"
        else:
            "0"
    if !tooling_strEq(diagOk, "1"):
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,220p' " + tooling_shellQuote(buildFailLog)))
        tooling_printErr("[verify_backend_ffi_outptr_tuple] missing expected ffi_out_ptrs diagnostic in negative fixture log")
        return 1

    let reportText: str =
        "verify_backend_ffi_outptr_tuple report\n" +
        "target=" + target + "\n" +
        "driver=" + driver + "\n" +
        "driver_exec=" + driverExec + "\n" +
        "fixture_run=" + fixtureRun + "\n" +
        "fixture_status_obj=" + fixtureStatus + "\n" +
        "fixture_fail=" + fixtureFail + "\n" +
        "build_run_status=" + intToStr(runCompileRc) + "\n" +
        "run_status=" + intToStr(runStatus) + "\n" +
        "run_mode=" + runMode + "\n" +
        "build_obj_status=0\n" +
        "build_fail_status=" + intToStr(failCompileRc) + "\n" +
        "diag_pattern=ffi_out_ptrs tuple arity mismatch\n" +
        "diag_ok=" + diagOk + "\n" +
        "build_run_log=" + buildRunLog + "\n" +
        "run_log=" + runLog + "\n" +
        "build_obj_log=" + buildObjLog + "\n" +
        "build_fail_log=" + buildFailLog + "\n"

    let snapshotText: str =
        "backend_ffi_outptr_tuple_target=" + target + "\n" +
        "backend_ffi_outptr_tuple_diag_ok=" + diagOk + "\n" +
        "backend_ffi_outptr_tuple_report=" + report + "\n"

    if !tooling_writeTextFileViaShell(root, report, reportText):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] failed to write report: " + report)
        return 1
    if !tooling_writeTextFileViaShell(root, snapshot, snapshotText):
        tooling_printErr("[verify_backend_ffi_outptr_tuple] failed to write snapshot: " + snapshot)
        return 1

    tooling_printOut("verify_backend_ffi_outptr_tuple ok")
    return 0

fn tooling_cmdVerifyBackendFfiSliceShimFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    let timeoutSec: int32 = 60
    let toolRaw: str = strutil.strip(os.getEnvDefault("TOOLING_SELF_BIN", "artifacts/tooling_cmd/cheng_tooling"))
    let tool: str = tooling_pathAbsolute(root, toolRaw)
    if !tooling_isExecutable(root, tool):
        tooling_printErr("[verify_backend_ffi_slice_shim] missing tooling binary: " + tool)
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "command -v rg >/dev/null 2>&1")) != 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] rg is required")
        return 2

    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("verify_backend_ffi_slice_shim options:")
            tooling_printOut("  no supported options")
            tooling_printOut("  env BACKEND_FFI_SLICE_SHIM_RUN=1")
            tooling_printOut("      enable direct executable run for positive fixture")
            return 0
        tooling_printErr("cheng_tooling: unknown verify_backend_ffi_slice_shim arg: " + arg)
        return 1

    var driver: str = strutil.strip(os.getEnvDefault("BACKEND_DRIVER", ""))
    if !tooling_strNonEmpty(driver):
        let detectRes: os.ExecCmdResult = tooling_exec(root, tooling_shellQuote(tool) + " backend_driver_path")
        if os.execCmdResultExitCode(detectRes) != 0:
            tooling_printExecOutput(detectRes)
            tooling_printErr("[verify_backend_ffi_slice_shim] failed to resolve backend driver")
            return 1
        driver = strutil.strip(os.execCmdResultOutput(detectRes))
        if !tooling_strNonEmpty(driver):
            tooling_printErr("[verify_backend_ffi_slice_shim] failed to resolve backend driver")
            return 1

    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(driver) + " ]")) != 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] backend driver not executable: " + driver)
        return 1

    let driverExecScript: str = tooling_pathAbsolute(root, "src/tooling/backend_driver_exec.sh")
    var driverExec: str = driver
    var driverRealEnv: str = ""
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(driverExecScript) + " ]")) == 0:
        driverExec = driverExecScript
        driverRealEnv = tooling_envAssignCompat("BACKEND_DRIVER_REAL", driver)

    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(driverExec) + " ]")) != 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] backend driver_exec not executable: " + driverExec)
        return 1

    var target: str = strutil.strip(os.getEnvDefault("BACKEND_TARGET", ""))
    if !tooling_strNonEmpty(target):
        let detectTarget: os.ExecCmdResult =
            tooling_exec(root,
                tooling_shellQuote(tool) +
                    " detect_host_target 2>/dev/null || echo arm64-apple-darwin")
        target = strutil.strip(os.execCmdResultOutput(detectTarget))
        if os.execCmdResultExitCode(detectTarget) != 0:
            tooling_printErr("[verify_backend_ffi_slice_shim] backend target auto-detect failed; fallback to default")
            tooling_printExecOutput(detectTarget)
            target = "arm64-apple-darwin"
        if !tooling_strNonEmpty(target):
            target = "arm64-apple-darwin"

    var backendLinkerMode: str = strutil.strip(os.getEnvDefault("BACKEND_LINKER", "system"))
    if !tooling_strNonEmpty(backendLinkerMode) || tooling_strEq(backendLinkerMode, "auto"):
        backendLinkerMode = "system"

    let backendNoRuntimeCRaw: str = os.getEnvDefault("BACKEND_NO_RUNTIME_C", "0")
    let backendRuntimeObj: str = os.getEnvDefault("BACKEND_RUNTIME_OBJ", "")
    let runPositiveRaw: str = strutil.strip(os.getEnvDefault("BACKEND_FFI_SLICE_SHIM_RUN", "0"))
    let runPositive: bool = tooling_isTrue(runPositiveRaw)

    let outDir: str = tooling_pathAbsolute(root, "artifacts/backend_ffi_slice_shim")
    let fixtureOk: str = tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/ffi_importc_slice_seq_i32.cheng")
    let fixtureFailLegacy: str = tooling_pathAbsolute(root,
                                "tests/cheng/backend/fixtures/compile_fail_ffi_importc_slice_openarray_i32.cheng")
    let fixtureFailSurface: str = tooling_pathAbsolute(root,
                                 "tests/cheng/backend/fixtures/compile_fail_ffi_slice_user_raw_ptr_surface.cheng")
    let importcSymbol: str = "cheng_abi_sum_seq_i32"
    let surfacePattern: str = "void\\*|ptr_add\\(|load_ptr\\(|store_ptr\\("
    let legacyDiagPattern: str = "Legacy type syntax is removed; use 'T\\[\\]' instead of 'openArray\\[T\\]'"
    let surfaceDiagPattern: str = "no-pointer policy: pointer (types are|dereference is|operation is) forbidden outside C ABI modules"

    if !tooling_fileExistsNonEmpty(fixtureOk) ||
       !tooling_fileExistsNonEmpty(fixtureFailLegacy) ||
       !tooling_fileExistsNonEmpty(fixtureFailSurface):
        tooling_printErr("[verify_backend_ffi_slice_shim] missing fixture file")
        return 1

    if !tooling_mkdirP(root, outDir):
        tooling_printErr("[verify_backend_ffi_slice_shim] failed to create output dir: " + outDir)
        return 1

    var safeTarget: str = tooling_sanitizeShellSafeToken(root, target)
    if !tooling_strNonEmpty(safeTarget):
        safeTarget = "unknown"
    var exePath: str = os.joinPath(outDir, "ffi_importc_slice_seq_i32." + safeTarget)
    if strutil.contains(strutil.toLowerAscii(target), "windows") || strutil.contains(strutil.toLowerAscii(target), "msvc"):
        exePath = exePath + ".exe"

    let runLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".run.log")
    let buildOkLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".build_ok.log")
    let buildFailLegacyLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".build_fail_legacy.log")
    let buildFailSurfaceLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".build_fail_surface.log")
    let surfaceScanLog: str = os.joinPath(outDir, "ffi_slice_shim." + safeTarget + ".surface_scan.log")
    let report: str = os.joinPath(outDir, "backend_ffi_slice_shim." + safeTarget + ".report.txt")
    let snapshot: str = os.joinPath(outDir, "backend_ffi_slice_shim." + safeTarget + ".snapshot.env")
    let failLegacyOutput: str = os.joinPath(
        outDir,
        "compile_fail_ffi_importc_slice_openarray_i32." + safeTarget)
    let failSurfaceOutput: str = os.joinPath(
        outDir,
        "compile_fail_ffi_slice_user_raw_ptr_surface." + safeTarget)

    let _ = tooling_exec(root,
        "rm -f " + tooling_shellQuote(exePath + ".o") + " " +
        tooling_shellQuote(buildOkLog) + " " +
        tooling_shellQuote(runLog) + " " +
        tooling_shellQuote(buildFailLegacyLog) + " " +
        tooling_shellQuote(buildFailSurfaceLog) + " " +
        tooling_shellQuote(surfaceScanLog) + " " +
        tooling_shellQuote(report) + " " +
        tooling_shellQuote(snapshot) + " " +
        tooling_shellQuote(failLegacyOutput) + " " +
        tooling_shellQuote(failSurfaceOutput) + " ; " +
        "rm -rf " + tooling_shellQuote(exePath + ".objs") + " " + tooling_shellQuote(exePath + ".objs.lock"))

    var surfaceOk: str = "1"
    let surfaceScanCommand: str =
        "rg -n " + tooling_shellQuote(surfacePattern) + " " + tooling_shellQuote(fixtureOk) +
        " > " + tooling_shellQuote(surfaceScanLog) + " 2>&1"
    if os.execCmdResultExitCode(tooling_exec(root, surfaceScanCommand)) == 0:
        surfaceOk = "0"
        tooling_printErr("[verify_backend_ffi_slice_shim] positive fixture leaks raw pointer surface (see " +
                        surfaceScanLog + ")")
        return 1

    let commonCompileEnv: str =
        (if tooling_strNonEmpty(driverRealEnv): driverRealEnv else: "") +
        tooling_envAssignCompat("BACKEND_LINKER", backendLinkerMode) +
        tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", backendNoRuntimeCRaw) +
        tooling_envAssignCompat("BACKEND_RUNTIME_OBJ", backendRuntimeObj) +
        tooling_envAssignCompat("BACKEND_EMIT", "exe") +
        tooling_envAssignCompat("BACKEND_MULTI", "0") +
        tooling_envAssignCompat("BACKEND_MULTI_FORCE", "0") +
        tooling_envAssignCompat("BACKEND_TARGET", target)

    let compileOkCommand: str = tooling_wrapCommandWithTimeout(
        root,
        timeoutSec,
        "env " + commonCompileEnv +
        tooling_envAssignCompat("BACKEND_INPUT", fixtureOk) +
        tooling_envAssignCompat("BACKEND_OUTPUT", exePath) + " " +
        tooling_shellQuote(driverExec) + " >" + tooling_shellQuote(buildOkLog) + " 2>&1")
    let compileOkRes: os.ExecCmdResult = tooling_exec(root, compileOkCommand)
    let compileOkRc: int32 = os.execCmdResultExitCode(compileOkRes)
    if compileOkRc != 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] positive fixture build failed (status=" + intToStr(compileOkRc) + ")")
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,200p' " + tooling_shellQuote(buildOkLog)))
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(exePath) + " ]")) != 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] missing executable output: " + exePath)
        return 1

    var symbolCheck: str = "skip"
    if os.execCmdResultExitCode(tooling_exec(root, "command -v nm >/dev/null 2>&1")) == 0:
        symbolCheck = "0"
        let symbolCheckCommand: str = "nm " + tooling_shellQuote(exePath) + " 2>/dev/null | rg -q " +
            tooling_shellQuote(importcSymbol)
        if os.execCmdResultExitCode(tooling_exec(root, symbolCheckCommand)) == 0:
            symbolCheck = "1"
        else:
            tooling_printErr("[verify_backend_ffi_slice_shim] missing expected importc symbol in positive artifact: " +
                             importcSymbol)
            return 1

    var runStatus: int32 = 0
    var runMode: str = "not_requested"
    if runPositive:
        runMode = "run"
        let runCommand: str = tooling_wrapCommandWithTimeout(
            root,
            timeoutSec,
            tooling_shellQuote(exePath) + " >" + tooling_shellQuote(runLog) + " 2>&1")
        let runRes: os.ExecCmdResult = tooling_exec(root, runCommand)
        runStatus = os.execCmdResultExitCode(runRes)
        if runStatus != 0:
            tooling_printErr("[verify_backend_ffi_slice_shim] positive fixture run failed (status=" + intToStr(runStatus) + ")")
            tooling_printExecOutput(tooling_exec(root, "sed -n '1,120p' " + tooling_shellQuote(runLog)))
            return 1

    let compileLegacyCommand: str = tooling_wrapCommandWithTimeout(
        root,
        timeoutSec,
        "env " + commonCompileEnv +
        tooling_envAssignCompat("BACKEND_INPUT", fixtureFailLegacy) +
        tooling_envAssignCompat("BACKEND_OUTPUT", failLegacyOutput) + " " +
        tooling_shellQuote(driverExec) + " >" + tooling_shellQuote(buildFailLegacyLog) + " 2>&1")
    let compileLegacyRes: os.ExecCmdResult = tooling_exec(root, compileLegacyCommand)
    let compileLegacyRc: int32 = os.execCmdResultExitCode(compileLegacyRes)
    if compileLegacyRc == 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] legacy openArray negative fixture unexpectedly compiled")
        return 1

    let legacyDiagCommand: str = "rg -q " + tooling_shellQuote(legacyDiagPattern) + " " +
        tooling_shellQuote(buildFailLegacyLog) + " >/dev/null 2>&1"
    let legacyDiagOkRaw: int32 = os.execCmdResultExitCode(tooling_exec(root, legacyDiagCommand))
    let legacyDiagOk: str = if legacyDiagOkRaw == 0: "1" else: "0"
    if legacyDiagOkRaw != 0:
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,200p' " + tooling_shellQuote(buildFailLegacyLog)))
        tooling_printErr("[verify_backend_ffi_slice_shim] missing expected legacy openArray diagnostic")
        return 1

    let compileSurfaceEnv: str =
        commonCompileEnv +
        tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "1") +
        tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "1")
    let compileSurfaceCommand: str = tooling_wrapCommandWithTimeout(
        root,
        timeoutSec,
        "env " + compileSurfaceEnv +
        tooling_envAssignCompat("BACKEND_INPUT", fixtureFailSurface) +
        tooling_envAssignCompat("BACKEND_OUTPUT", failSurfaceOutput) + " " +
        tooling_shellQuote(driverExec) + " >" + tooling_shellQuote(buildFailSurfaceLog) + " 2>&1")
    let compileSurfaceRes: os.ExecCmdResult = tooling_exec(root, compileSurfaceCommand)
    let compileSurfaceRc: int32 = os.execCmdResultExitCode(compileSurfaceRes)
    if compileSurfaceRc == 0:
        tooling_printErr("[verify_backend_ffi_slice_shim] raw pointer surface negative fixture unexpectedly compiled")
        return 1

    let surfaceDiagCommand: str = "rg -q " + tooling_shellQuote(surfaceDiagPattern) + " " +
        tooling_shellQuote(buildFailSurfaceLog) + " >/dev/null 2>&1"
    let surfaceDiagOkRaw: int32 = os.execCmdResultExitCode(tooling_exec(root, surfaceDiagCommand))
    let surfaceDiagOk: str = if surfaceDiagOkRaw == 0: "1" else: "0"
    if surfaceDiagOkRaw != 0:
        tooling_printExecOutput(tooling_exec(root, "sed -n '1,200p' " + tooling_shellQuote(buildFailSurfaceLog)))
        tooling_printErr("[verify_backend_ffi_slice_shim] missing expected no-pointer policy diagnostic")
        return 1

    let reportText: str =
        "verify_backend_ffi_slice_shim report\n" +
        "target=" + target + "\n" +
        "driver=" + driver + "\n" +
        "fixture_ok=" + fixtureOk + "\n" +
        "fixture_fail_legacy=" + fixtureFailLegacy + "\n" +
        "fixture_fail_surface=" + fixtureFailSurface + "\n" +
        "build_ok_status=" + intToStr(compileOkRc) + "\n" +
        "importc_symbol=" + importcSymbol + "\n" +
        "symbol_check=" + symbolCheck + "\n" +
        "run_status=" + intToStr(runStatus) + "\n" +
        "run_mode=" + runMode + "\n" +
        "run_positive=" + (if runPositive: "1" else: "0") + "\n" +
        "runtime_symbol_blocked=0\n" +
        "build_fail_legacy_status=" + intToStr(compileLegacyRc) + "\n" +
        "build_fail_surface_status=" + intToStr(compileSurfaceRc) + "\n" +
        "surface_pattern=" + surfacePattern + "\n" +
        "surface_ok=" + surfaceOk + "\n" +
        "legacy_diag_pattern=" + legacyDiagPattern + "\n" +
        "legacy_diag_ok=" + legacyDiagOk + "\n" +
        "surface_diag_pattern=" + surfaceDiagPattern + "\n" +
        "surface_diag_ok=" + surfaceDiagOk + "\n" +
        "build_ok_log=" + buildOkLog + "\n" +
        "run_log=" + runLog + "\n" +
        "build_fail_legacy_log=" + buildFailLegacyLog + "\n" +
        "build_fail_surface_log=" + buildFailSurfaceLog + "\n" +
        "surface_scan_log=" + surfaceScanLog + "\n"

    let snapshotText: str =
        "backend_ffi_slice_shim_target=" + target + "\n" +
        "backend_ffi_slice_shim_surface_ok=" + surfaceOk + "\n" +
        "backend_ffi_slice_shim_symbol_check=" + symbolCheck + "\n" +
        "backend_ffi_slice_shim_run_mode=" + runMode + "\n" +
        "backend_ffi_slice_shim_run_positive=" + (if runPositive: "1" else: "0") + "\n" +
        "backend_ffi_slice_shim_runtime_symbol_blocked=0\n" +
        "backend_ffi_slice_shim_legacy_diag_ok=" + legacyDiagOk + "\n" +
        "backend_ffi_slice_shim_surface_diag_ok=" + surfaceDiagOk + "\n" +
        "backend_ffi_slice_shim_report=" + report + "\n"

    if !tooling_writeTextFileViaShell(root, report, reportText):
        tooling_printErr("[verify_backend_ffi_slice_shim] failed to write report: " + report)
        return 1
    if !tooling_writeTextFileViaShell(root, snapshot, snapshotText):
        tooling_printErr("[verify_backend_ffi_slice_shim] failed to write snapshot: " + snapshot)
        return 1

    tooling_printOut("verify_backend_ffi_slice_shim ok")
    return 0

fn tooling_cmdRunSelfhostParallelPerfProbe(
    root: str,
    tool: str,
    stage0: str,
    timeoutRaw: str,
    session: str,
    skipSemRaw: str,
    skipOwnRaw: str,
    skipCProfileRaw: str,
    genericModeRaw: str,
    genericBudgetRaw: str,
    validateRaw: str,
    skipSmokeRaw: str,
    requireRunnableRaw: str,
    allowRetryRaw: str,
    multiRaw: str,
    multiForceRaw: str,
    jobsRaw: str,
    timingPath: str): int32 =
    let cmd: str =
        "env " +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SESSION", session) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_TIMEOUT", timeoutRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_REQUIRE", "1") +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_STAGE0", stage0) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_REUSE", "0") +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_STRICT_ALLOW_FAST_REUSE", "0") +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SKIP_SEM", skipSemRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SKIP_OWNERSHIP", skipOwnRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SKIP_CPROFILE", skipCProfileRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_GENERIC_MODE", genericModeRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_GENERIC_SPEC_BUDGET", genericBudgetRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_VALIDATE", validateRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_SKIP_SMOKE", skipSmokeRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_REQUIRE_RUNNABLE", requireRunnableRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_ALLOW_RETRY", allowRetryRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_MULTI", multiRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_MULTI_FORCE", multiForceRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_JOBS", jobsRaw) +
        tooling_envAssignCompat("SELFHOST_STRICT_PROBE_TIMING", timingPath) +
        tooling_shellQuote(tool) + " verify_backend_selfhost_strict_noreuse_probe"
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdVerifyBackendSelfhostParallelPerfFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var timeoutRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_TIMEOUT", "60")
    var baseSessionRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_BASE_SESSION", "perf.parallel")
    var jobsRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_JOBS", "0")
    var maxSlowdownRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_MAX_SLOWDOWN_SEC", "2")
    var skipSmokeRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_SKIP_SMOKE", "1")
    var requireRunnableRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_REQUIRE_RUNNABLE", "1")
    var validateRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_VALIDATE", "0")
    var skipSemRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_SKIP_SEM", "1")
    var skipOwnRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_SKIP_OWNERSHIP", "1")
    var skipCProfileRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_SKIP_CPROFILE", "1")
    var allowRetryRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_ALLOW_RETRY", "1")
    var genericModeRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_GENERIC_MODE", "dict")
    var genericBudgetRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_GENERIC_SPEC_BUDGET", "0")
    var reportRaw: str = os.getEnvDefault("SELFHOST_PARALLEL_PERF_REPORT", "")

    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("Usage:")
            tooling_printOut("  src/tooling/verify_backend_selfhost_parallel_perf.sh [--help]")
            tooling_printOut("")
            tooling_printOut("Env:")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_TIMEOUT=<seconds>          default: 60")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_STAGE0=<path>              optional stage0 override")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_BASE_SESSION=<name>        default: perf.parallel")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_JOBS=<N>                   default: 0 (auto)")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_MAX_SLOWDOWN_SEC=<N>       default: 2")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_SKIP_SMOKE=<0|1>           default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_REQUIRE_RUNNABLE=<0|1>     default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_VALIDATE=<0|1>             default: 0")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_SKIP_SEM=<0|1>             default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_SKIP_OWNERSHIP=<0|1>       default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_SKIP_CPROFILE=<0|1>        default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_ALLOW_RETRY=<0|1>          default: 1")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_GENERIC_MODE=<mode>        default: dict")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_GENERIC_SPEC_BUDGET=<N>    default: 0")
            tooling_printOut("  SELFHOST_PARALLEL_PERF_REPORT=<path>              optional report path")
            return 0
        tooling_printErr("cheng_tooling: unknown verify_backend_selfhost_parallel_perf arg: " + arg)
        return 2

    let toolRaw: str = strutil.strip(os.getEnvDefault("TOOLING_SELF_BIN", "artifacts/tooling_cmd/cheng_tooling"))
    let tool: str = tooling_pathAbsolute(root, toolRaw)
    if !tooling_isExecutable(root, tool):
        tooling_printErr("[selfhost_parallel_perf] missing tooling binary: " + tool)
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(tool) + " ]")) != 0:
        tooling_printErr("[selfhost_parallel_perf] missing tooling binary: " + tool)
        return 1

    var stage0: str = strutil.strip(os.getEnvDefault("SELFHOST_PARALLEL_PERF_STAGE0", ""))
    if !tooling_strNonEmpty(stage0):
        let stage0Probe: os.ExecCmdResult = tooling_exec(root, tooling_shellQuote(tool) + " backend_driver_path")
        if os.execCmdResultExitCode(stage0Probe) != 0:
            tooling_printErr("[selfhost_parallel_perf] failed to resolve stage0")
            return 1
        stage0 = strutil.strip(os.execCmdResultOutput(stage0Probe))
    if !tooling_strNonEmpty(stage0):
        tooling_printErr("[selfhost_parallel_perf] missing stage0")
        return 1
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(stage0) + " ]")) != 0:
        tooling_printErr("[selfhost_parallel_perf] stage0 is not executable: " + stage0)
        return 1

    var baseSession: str = baseSessionRaw
    if !tooling_strNonEmpty(baseSession):
        baseSession = "perf.parallel"
    let safeBaseSessionRaw: str = tooling_sanitizeShellSafeToken(root, baseSession)
    let safeBaseSession: str =
        if tooling_strNonEmpty(safeBaseSessionRaw):
            safeBaseSessionRaw
        else:
            "perf_parallel"

    let report: str =
        if tooling_strNonEmpty(strutil.strip(reportRaw)):
            tooling_pathAbsolute(root, strutil.strip(reportRaw))
        else:
            os.joinPath("artifacts/backend_selfhost_self_obj", "selfhost_parallel_perf_" + safeBaseSession + ".tsv")

    let reportDir: str = os.parentDir(report)
    if tooling_strNonEmpty(reportDir):
        if !tooling_mkdirP(root, reportDir):
            tooling_printErr("[selfhost_parallel_perf] failed to create report dir: " + reportDir)
            return 1

    let serialSession: str = baseSession + ".serial"
    let serialSessionSafeRaw: str = tooling_sanitizeShellSafeToken(root, serialSession)
    let serialSessionSafe: str =
        if tooling_strNonEmpty(serialSessionSafeRaw):
            serialSessionSafeRaw
        else:
            "perf_parallel_serial"
    let serialTiming: str = os.joinPath("artifacts/backend_selfhost_self_obj", "selfhost_timing_" + serialSessionSafe + ".tsv")

    let parallelSession: str = baseSession + ".parallel"
    let parallelSessionSafeRaw: str = tooling_sanitizeShellSafeToken(root, parallelSession)
    let parallelSessionSafe: str =
        if tooling_strNonEmpty(parallelSessionSafeRaw):
            parallelSessionSafeRaw
        else:
            "perf_parallel_parallel"
    let parallelTiming: str = os.joinPath("artifacts/backend_selfhost_self_obj", "selfhost_timing_" + parallelSessionSafe + ".tsv")

    let _ = tooling_exec(root, "rm -f " + tooling_shellQuote(serialTiming) + " " + tooling_shellQuote(parallelTiming))

    tooling_printOut("== backend.selfhost_parallel_perf.serial ==")
    let serialRc: int32 = tooling_cmdRunSelfhostParallelPerfProbe(
        root, tool, stage0, timeoutRaw, serialSession, skipSemRaw, skipOwnRaw,
        skipCProfileRaw, genericModeRaw, genericBudgetRaw, validateRaw,
        skipSmokeRaw, requireRunnableRaw, allowRetryRaw, "0", "0", jobsRaw, serialTiming)

    let serialStatusRaw: str = tooling_parseTimingRowField(root, serialTiming, "total", 2)
    let serialStatus: str =
        if tooling_strNonEmpty(serialStatusRaw): serialStatusRaw else: "unknown"
    let serialTotalRaw: str = tooling_parseTimingRowField(root, serialTiming, "total", 3)
    let serialTotal: str =
        if tooling_strNonEmpty(serialTotalRaw): serialTotalRaw else: "-1"
    let serialStage1Raw: str = tooling_parseTimingRowField(root, serialTiming, "stage1", 3)
    let serialStage1: str =
        if tooling_strNonEmpty(serialStage1Raw): serialStage1Raw else: "-1"

    let _ = tooling_exec(root, "rm -f " + tooling_shellQuote(parallelTiming))
    tooling_printOut("== backend.selfhost_parallel_perf.parallel ==")
    let parallelRc: int32 = tooling_cmdRunSelfhostParallelPerfProbe(
        root, tool, stage0, timeoutRaw, parallelSession, skipSemRaw, skipOwnRaw,
        skipCProfileRaw, genericModeRaw, genericBudgetRaw, validateRaw,
        skipSmokeRaw, requireRunnableRaw, allowRetryRaw, "1", "0", jobsRaw, parallelTiming)

    let parallelStatusRaw: str = tooling_parseTimingRowField(root, parallelTiming, "total", 2)
    let parallelStatus: str =
        if tooling_strNonEmpty(parallelStatusRaw): parallelStatusRaw else: "unknown"
    let parallelTotalRaw: str = tooling_parseTimingRowField(root, parallelTiming, "total", 3)
    let parallelTotal: str =
        if tooling_strNonEmpty(parallelTotalRaw): parallelTotalRaw else: "-1"
    let parallelStage1Raw: str = tooling_parseTimingRowField(root, parallelTiming, "stage1", 3)
    let parallelStage1: str =
        if tooling_strNonEmpty(parallelStage1Raw): parallelStage1Raw else: "-1"

    let reportText: str =
        "mode\tstatus\ttotal_sec\tstage1_sec\ttiming_file\n" +
        "serial\t" + serialStatus + "\t" + serialTotal + "\t" + serialStage1 + "\t" + serialTiming + "\n" +
        "parallel\t" + parallelStatus + "\t" + parallelTotal + "\t" + parallelStage1 + "\t" + parallelTiming + "\n"
    if !tooling_writeTextFileViaShell(root, report, reportText):
        tooling_printErr("[selfhost_parallel_perf] failed to write report: " + report)
        return 1

    tooling_printOut("[selfhost_parallel_perf] serial=" + serialTotal + "s status=" + serialStatus)
    tooling_printOut("[selfhost_parallel_perf] parallel=" + parallelTotal + "s status=" + parallelStatus)

    if !tooling_strEq(serialStatus, "ok") || !tooling_strEq(parallelStatus, "ok"):
        tooling_printErr("[selfhost_parallel_perf] fail: probe status is not ok (report=" + report + ")")
        return 1

    let totalsText: str = serialTotal + ":" + parallelTotal + ":" + maxSlowdownRaw
    if !tooling_isDigitsColonDash(totalsText):
        tooling_printErr("[selfhost_parallel_perf] fail: non-numeric totals (report=" + report + ")")
        return 1

    let serialTotalInt: int32 = tooling_parseInt32Default(serialTotal, -1)
    let parallelTotalInt: int32 = tooling_parseInt32Default(parallelTotal, -1)
    let maxSlowdownInt: int32 = tooling_parseInt32Default(maxSlowdownRaw, -1)
    if serialTotalInt < 0 || parallelTotalInt < 0 || maxSlowdownInt < 0:
        tooling_printErr("[selfhost_parallel_perf] fail: non-numeric totals (report=" + report + ")")
        return 1

    let limit: int32 = serialTotalInt + maxSlowdownInt
    if parallelTotalInt > limit:
        tooling_printErr("[selfhost_parallel_perf] fail: parallel slower than budget (parallel=" + parallelTotal + "s > serial=" + serialTotal + "s + " + maxSlowdownRaw + "s, report=" + report + ")")
        return 1

    tooling_printOut("[selfhost_parallel_perf] ok (report=" + report + ")")
    if serialRc != 0 || parallelRc != 0:
        return 1
    return 0

fn tooling_cmdSyncGlobalDeprecated(): int32 =
    tooling_printErr("cheng_tooling: sync-global removed; use `build-global --out:artifacts/tooling_cmd/cheng_tooling`")
    return 2

fn tooling_idsContains(ids: str[], id: str): bool =
    for i in 0..<ids.len:
        if tooling_strEq(ids[i], id):
            return true
    return false

fn tooling_bundle(root: str, spec: tbundle.ToolingBundleArgs): int32 =
    if spec == nil:
        tooling_printErr("cheng_tooling: internal bundle parse failure")
        return 1
    if !spec.ok:
        tooling_printErr(spec.error)
        return spec.exitCode
    var profileSelector: str = spec.profileSelector
    if !tooling_strNonEmpty(profileSelector):
        profileSelector = tinv.toolingSelectorAppend(profileSelector, "full")
    let mode: str = tinv.toolingNormalizeLinkMode(spec.mode)
    if !tooling_strNonEmpty(mode):
        tooling_printErr("cheng_tooling: invalid bundle --mode (expected symlink|hardlink|copy): " + spec.mode)
        return 1
    if !tinv.toolingSelectorContains(profileSelector, "full"):
        tooling_printErr("cheng_tooling: bundle profile set is empty (allowed: full)")
        return 1
    let outDir: str = tbundle.toolingBundlePathAbsolute(root, spec.outDir)
    if !tooling_strNonEmpty(outDir):
        tooling_printErr("cheng_tooling: bundle requires --out-dir:<path>")
        return 1
    if !tooling_mkdirP(root, outDir):
        tooling_printErr("cheng_tooling: failed to create bundle out dir: " + outDir)
        return 1
    let profileDir: str = os.joinPath(outDir, "full")
    let binPath: str = os.joinPath(profileDir, "cheng_tooling")
    let linksDir: str = os.joinPath(profileDir, "bin")
    let manifestPath: str = os.joinPath(profileDir, "manifest.tsv")
    let buildRc: int32 = tooling_buildGlobal(root, binPath, spec.linker, spec.driver)
    if buildRc != 0:
        return buildRc
    let installIds: str[] = tinv.toolingCollectScripts(root)
    let installRc: int32 = tinstall.toolingInstallLinks(root, installIds, binPath, linksDir, manifestPath, spec.force, "", "", mode)
    if installRc != 0:
        return installRc
    tooling_printOut("bundle_profile=full")
    tooling_printOut("bundle_profile_bin=" + binPath)
    tooling_printOut("bundle_profile_links=" + linksDir)
    tooling_printOut("bundle_profile_manifest=" + manifestPath)
    return 0

fn tooling_resolveBuildDriver(root: str, driverRaw: str): str =
    let explicitRaw: str = strutil.strip(driverRaw)
    if tooling_strNonEmpty(explicitRaw):
        return tooling_resolveStage0DriverStrict(root, explicitRaw)
    return tooling_resolveStage0DriverStrict(root, "")

fn tooling_buildGlobalPreferredDriver(root: str, targetRaw: str): str =
    let target: str = tooling_normalizeTargetAlias(root, targetRaw)
    let canonicalDriver: str = tooling_resolveBuildDriver(root, "")
    let preferCurrentsrcProof: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_PREFER_CURRENTSRC_PROOF", "0"))
    if tooling_strNonEmpty(canonicalDriver) &&
       tooling_stage0CandidateHealthy(root, canonicalDriver, false, "build_global_canonical_driver") &&
       !preferCurrentsrcProof:
        return canonicalDriver
    if tooling_strEq(target, "arm64-apple-darwin"):
        let currentsrcStage2: str =
            tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2")
        if tooling_stage0CandidateHealthy(root, currentsrcStage2, false, "build_global_currentsrc_proof"):
            return currentsrcStage2
    return canonicalDriver

fn tooling_buildGlobalDriverSurface(root: str, driverPathRaw: str): str =
    let driverPath: str = tooling_pathAbsolute(root, driverPathRaw)
    if !tooling_strNonEmpty(driverPath):
        return ""
    let currentsrcStage2: str =
        tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2")
    let canonicalDriver: str =
        tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if tooling_strEq(driverPath, currentsrcStage2):
        return "probe_currentsrc_proof"
    if tooling_strEq(driverPath, canonicalDriver):
        return "canonical_backend_driver"
    return "explicit_or_other"

fn tooling_buildGlobalStage0Route(root: str, driverPathRaw: str, driverRaw: str): str =
    let routeRaw: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_STAGE0_ROUTE", "")))
    if tooling_strEq(routeRaw, "sidecar"):
        return "sidecar"
    if tooling_strEq(routeRaw, "direct"):
        return "direct"
    let driverSurface: str = tooling_buildGlobalDriverSurface(root, driverPathRaw)
    if tooling_strNonEmpty(strutil.strip(driverRaw)):
        return "direct"
    if tooling_strEq(driverSurface, "probe_currentsrc_proof") ||
       tooling_strEq(driverSurface, "explicit_or_other"):
        return "direct"
    return "default"

fn tooling_binaryHelpProbeOk(root: str, binPathRaw: str, acceptRc1: bool): bool =
    let binPath: str = tooling_pathAbsolute(root, binPathRaw)
    if !tooling_isExecutable(root, binPath):
        return false
    if !tooling_binaryExecPolicyPreflightOk(root, binPath, "binary_help_probe"):
        return false
    let runProbe: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BINARY_HELP_PROBE_RUN", "0"))
    if !runProbe:
        return true
    var timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_BINARY_HELP_TIMEOUT", ""), 12)
    if timeoutSec <= 0:
        timeoutSec = 12
    var cmd: str = tooling_shellQuote(binPath) + " --help >/dev/null 2>&1"
    cmd = tooling_wrapCommandWithTimeout(root, timeoutSec, cmd)
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    let rc: int32 = os.execCmdResultExitCode(res)
    if rc == 0:
        return true
    if acceptRc1 && rc == 1:
        return true
    return false

fn tooling_verifyBuiltToolingBinarySurface(root: str, binPathRaw: str): bool =
    let binPath: str = tooling_pathAbsolute(root, binPathRaw)
    if !tooling_isExecutable(root, binPath):
        return false
    if !tooling_binaryExecPolicyPreflightOk(root, binPath, "tooling_surface_verify"):
        return false
    let isScriptShim: bool = tooling_driverIsScriptShim(root, binPath)
    var timeoutSec: int32 = tooling_parseInt32Default(
        os.getEnvDefault("TOOLING_BINARY_SURFACE_HELP_TIMEOUT", ""), 8)
    if timeoutSec <= 0:
        timeoutSec = 8
    if isScriptShim:
        var listCmd: str = tooling_shellQuote(binPath) + " list >/dev/null 2>&1"
        listCmd = tooling_wrapCommandWithTimeout(root, timeoutSec, listCmd)
        let listRes: os.ExecCmdResult = tooling_exec(root, listCmd)
        if os.execCmdResultExitCode(listRes) != 0:
            return false
        var helpShimCmd: str = tooling_shellQuote(binPath) + " --help >/dev/null 2>&1"
        helpShimCmd = tooling_wrapCommandWithTimeout(root, timeoutSec, helpShimCmd)
        let helpShimRes: os.ExecCmdResult = tooling_exec(root, helpShimCmd)
        return os.execCmdResultExitCode(helpShimRes) == 0
    # Guard against silently corrupted self-link output (for example zeroed
    # __TEXT,__cstring) that exits with rc=1 and no diagnostics.
    let cmd: str = "strings " + tooling_shellQuote(binPath) +
                   " | grep -q " + tooling_shellQuote("usage: cheng_tooling")
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    if os.execCmdResultExitCode(res) != 0:
        return false
    var helpCmd: str = tooling_shellQuote(binPath) + " --help >/dev/null 2>&1"
    helpCmd = tooling_wrapCommandWithTimeout(root, timeoutSec, helpCmd)
    let helpRes: os.ExecCmdResult = tooling_exec(root, helpCmd)
    if os.execCmdResultExitCode(helpRes) != 0:
        return false
    return true

fn tooling_buildGlobalReleaseFallbackTry(root: str, stage0Exec: str, src: str, outPath: str,
                                         target: str, timeoutSec: int32,
                                         releaseCflagsRaw: str, releaseLdflagsRaw: str,
                                         stage0RouteRaw: str): bool =
    if !tooling_isExecutable(root, stage0Exec):
        return false
    if os.fileExists(outPath):
        os.removeFile(outPath)
    let cmdLog: str = outPath + ".build_global_release_fallback.log"
    if os.fileExists(cmdLog):
        os.removeFile(cmdLog)
    var optLevel: str = strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RELEASE_FALLBACK_OPT_LEVEL", "0"))
    if !tooling_strNonEmpty(optLevel):
        optLevel = "0"
    var opt: str = tooling_bool01Normalized(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_RELEASE_FALLBACK_BACKEND_OPT", "0"))
    if !tooling_strNonEmpty(opt):
        opt = "0"
    var opt2: str = tooling_bool01Normalized(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_RELEASE_FALLBACK_BACKEND_OPT2", "0"))
    if !tooling_strNonEmpty(opt2):
        opt2 = "0"
    let entryShimCflags: str = "-DCHENG_TOOLING_ENTRY_SHIM=1"
    let effectiveReleaseCflags: str =
        tooling_strNonEmpty(releaseCflagsRaw) ? (releaseCflagsRaw + " " + entryShimCflags) : entryShimCflags
    let compileMultiText: str = tooling_compileParallelMultiText(root)
    let compileMultiForceText: str = tooling_compileParallelMultiForceText(root, compileMultiText)
    let compileJobsText: str = tooling_compileParallelJobsText(root)
    let compileFnJobsText: str = tooling_compileParallelFnJobsText(root, compileJobsText)
    let stage0Route: str = strutil.toLowerAscii(strutil.strip(stage0RouteRaw))
    var cmd: str = ""
    cmd = cmd + tooling_envAssignCompat("MM", "orc")
    cmd = cmd + tooling_envAssignCompat("CACHE", "0")
    cmd = cmd + tooling_envAssignCompat("STAGE1_AUTO_SYSTEM", "0")
    cmd = cmd + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS", "0")
    cmd = cmd + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS_STRICT", "0")
    cmd = cmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "0")
    cmd = cmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "0")
    cmd = cmd + tooling_envAssignCompat("STAGE1_SKIP_CPROFILE", "1")
    cmd = cmd + tooling_envAssignCompat("STAGE1_PROFILE", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_BUILD_TRACK", "release")
    cmd = cmd + tooling_envAssignCompat("BACKEND_LINKER", "system")
    cmd = cmd + tooling_envAssignCompat("BACKEND_FAST_DEV_PROFILE", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_STAGE1_PARSE_MODE", "full")
    cmd = cmd + tooling_envAssignCompat("BACKEND_STAGE1_BUILDER", "stage1")
    cmd = cmd + tooling_envAssignCompat("BACKEND_FN_SCHED", "ws")
    cmd = cmd + tooling_envAssignCompat("BACKEND_DIRECT_EXE", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_LINKERLESS_INMEM", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_FAST_FALLBACK_ALLOW", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_INCREMENTAL", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_SKIP_GLOBAL_INIT", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_IR", "uir")
    cmd = cmd + tooling_envAssignCompat("BACKEND_MULTI", compileMultiText)
    cmd = cmd + tooling_envAssignCompat("BACKEND_MULTI_FORCE", compileMultiForceText)
    cmd = cmd + tooling_envAssignCompat("BACKEND_JOBS", compileJobsText)
    cmd = cmd + tooling_envAssignCompat("BACKEND_FN_JOBS", compileFnJobsText)
    cmd = cmd + tooling_envAssignCompat("BACKEND_VALIDATE", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_ALLOW_NO_MAIN", "1")
    cmd = cmd + tooling_envAssignCompat("BACKEND_OPT", opt)
    cmd = cmd + tooling_envAssignCompat("BACKEND_OPT2", opt2)
    cmd = cmd + tooling_envAssignCompat("BACKEND_OPT_LEVEL", optLevel)
    if tooling_strNonEmpty(effectiveReleaseCflags):
        cmd = cmd + tooling_envAssignCompat("BACKEND_CFLAGS", effectiveReleaseCflags)
    if tooling_strNonEmpty(releaseLdflagsRaw):
        cmd = cmd + tooling_envAssignCompat("BACKEND_LDFLAGS", releaseLdflagsRaw)
    cmd = cmd + tooling_envAssignCompat("ABI", "v2_noptr")
    cmd = cmd + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
    cmd = cmd + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "0")
    cmd = cmd + tooling_envAssignCompat("BACKEND_EMIT", "exe")
    cmd = cmd + tooling_envAssignCompat("BACKEND_INPUT", src)
    cmd = cmd + tooling_envAssignCompat("BACKEND_OUTPUT", outPath)
    cmd = cmd + tooling_envAssignCompat("BACKEND_TARGET", target)
    if tooling_strEq(stage0Route, "direct"):
        cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_DISABLE", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_PREFER_SIDECAR", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_FORCE_SIDECAR", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_COMPILER", "")
        cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_BUNDLE", "")
    cmd = cmd + tooling_stage0LegacyCStringCompatPrefix(root, stage0Exec)
    cmd = cmd + tooling_shellQuote(stage0Exec)
    cmd = cmd + " > " + tooling_shellQuote(cmdLog) + " 2>&1"
    cmd = tooling_prefixUnsetLegacyFrontendEnv(cmd)
    cmd = tooling_wrapStage0LockTimeout(root, timeoutSec, cmd, "build_global_release_fallback")
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("cheng_tooling: build-global release fallback attempt failed, dumping log: " + cmdLog)
        if os.execCmdResultExitCode(res) == 124:
            tooling_printErr("build_global release fallback timeout reached " + intToStr(timeoutSec) + "s")
        tooling_printCommandLogTail(root, cmdLog, "build_global_release_fallback", 220)
    else:
        tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) != 0:
        return false
    return tooling_verifyBuiltToolingBinarySurface(root, outPath)

fn tooling_buildGlobal(root: str, outRaw: str, linkerRaw: str, driverRaw: str): int32 =
    let src: str = os.joinPath(root, "src/tooling/cheng_tooling.cheng")
    if !os.fileExists(src):
        tooling_printErr("cheng_tooling: source not found: " + src)
        return 1
    let embeddedSources: str[] = tooling_embeddedToolingSourceList(root)
    for i in 0..<embeddedSources.len:
        if !os.fileExists(embeddedSources[i]):
            tooling_printErr("cheng_tooling: embedded tooling source not found: " + embeddedSources[i])
            return 1
    let outPath: str = tooling_pathAbsolute(root, outRaw)
    if !tooling_strNonEmpty(outPath):
        tooling_printErr("cheng_tooling: build-global requires --out:<path>")
        return 1
    if bgsync.toolingBuildGlobalIsCanonicalWrapperTarget(root, outPath):
        let changed: bool = bgsync.toolingBuildGlobalCanonicalWrapperChanged(root, outPath)
        tooling_printOut("build_global_mode=canonical_wrapper_sync")
        tooling_printOut("build_global_out=" + outPath)
        tooling_printOut("build_global_release_fallback=0")
        tooling_printOut("build_global_release_fallback_allowed=0")
        if !bgsync.toolingBuildGlobalSyncCanonicalWrappers(root, outPath):
            tooling_printErr("cheng_tooling: build-global failed to sync canonical wrapper surface")
            tooling_printOut("build_global_rebuilt=0")
            tooling_printOut("build_global_binary_surface_ok=0")
            tooling_printOut("build_global_status=failed")
            tooling_printOut("build_global_rc=1")
            return 1
        if !tooling_verifyBuiltToolingBinarySurface(root, outPath):
            tooling_printErr("cheng_tooling: build-global synced canonical wrapper surface is unhealthy")
            tooling_printOut("build_global_rebuilt=0")
            tooling_printOut("build_global_binary_surface_ok=0")
            tooling_printOut("build_global_status=failed")
            tooling_printOut("build_global_rc=1")
            return 1
        tooling_printOut("build_global_rebuilt=" + tooling_boolText(changed))
        tooling_printOut("build_global_binary_surface_ok=1")
        tooling_printOut("build_global_status=ok")
        tooling_printOut("build_global_rc=0")
        return 0
    let eagerRebuild: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_GLOBAL_EAGER_REBUILD", "0"))
    let inheritedTarget: str = strutil.strip(os.getEnvDefault("BACKEND_TARGET", ""))
    var target: str = inheritedTarget
    if !tooling_strNonEmpty(target):
        target = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        target = "auto"
    let releaseFallbackDefault: str = tooling_strEq(target, "arm64-apple-darwin") ? "0" : "1"
    let releaseFallbackAllowedRaw: str = os.getEnvDefault(
        "TOOLING_BUILD_GLOBAL_RELEASE_FALLBACK", releaseFallbackDefault)
    let releaseFallbackAllowed: bool = tooling_isTrue(releaseFallbackAllowedRaw)
    let outHealthy: bool = tooling_verifyBuiltToolingBinarySurface(root, outPath)
    let sourceNewerThanOut: bool =
        tooling_fileIsNewer(root, src, outPath) ||
        tooling_anyFileNewerThan(root, embeddedSources, outPath)
    if !eagerRebuild && outHealthy && !sourceNewerThanOut:
        tooling_printOut("build_global_rebuilt=0")
        tooling_printOut("build_global_fast_path=reuse_existing")
        tooling_printOut("build_global_binary_surface_ok=1")
        tooling_printOut("build_global_release_fallback=0")
        tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
        tooling_printOut("build_global_out=" + outPath)
        return 0
    if !eagerRebuild && outHealthy && sourceNewerThanOut:
        tooling_printErr("cheng_tooling: build-global sources newer than existing binary; forcing rebuild")
    if !tooling_stage0QuarantineEnabled() &&
       tooling_stage0BlockOnQuarantineUe(root, "TOOLING_BUILD_GLOBAL_BLOCK_ON_UE", "build_global"):
        return 1
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        if !tooling_mkdirP(root, outDir):
            tooling_printErr("cheng_tooling: failed to create output dir: " + outDir)
            return 1
    let buildOutPath: str = os.joinPath(root, "chengcache/tooling_cmd/cheng_tooling.build_global." + tooling_nowNonceText() + ".tmp")
    let buildOutDir: str = os.parentDir(buildOutPath)
    if tooling_strNonEmpty(buildOutDir):
        if !tooling_mkdirP(root, buildOutDir):
            tooling_printErr("cheng_tooling: failed to create build-global temp dir: " + buildOutDir)
            return 1
    if os.fileExists(buildOutPath):
        os.removeFile(buildOutPath)
    let linker: str = tooling_trimAsciiSpace(linkerRaw)
    if !tooling_strEq(linker, "self"):
        tooling_printErr("cheng_tooling: build-global only supports --linker:self in dev in-memory mode")
        return 1
    var driverPath: str = tooling_buildGlobalPreferredDriver(root, target)
    if tooling_strNonEmpty(strutil.strip(driverRaw)):
        driverPath = tooling_resolveBuildDriver(root, driverRaw)
    if !tooling_strNonEmpty(driverPath):
        if tooling_strNonEmpty(driverRaw):
            tooling_printErr("cheng_tooling: --driver not found: " + driverRaw)
        else:
            tooling_printErr("cheng_tooling: failed to resolve build driver (set --driver:<path>)")
        return 1
    let stage0Exec: str = tooling_prepareStage0Exec(root, driverPath, "build_global")
    if !tooling_strNonEmpty(stage0Exec):
        tooling_printErr("cheng_tooling: build-global stage0 prepare failed: " + driverPath)
        return 1
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(driverPath, stage0Exec)
        tooling_printErr("cheng_tooling: build-global stage0 preflight failed: " + driverPath)
        return 1
    let stage0Route: str = tooling_buildGlobalStage0Route(root, driverPath, driverRaw)
    let releaseCflagsRaw: str = strutil.strip(os.getEnvDefault("BACKEND_RELEASE_CFLAGS", "-O0"))
    let releaseLdflagsRaw: str = tooling_releaseLdflagsForTarget(
        os.getEnvDefault("BACKEND_RELEASE_LDFLAGS", releaseCflagsRaw), target)
    let crashMemoEnabled: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_GLOBAL_CRASH_MEMO", "1"))
    let safeFirstDefault: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_GLOBAL_SAFE_FIRST", "1"))
    let crashMemoPath: str = tooling_buildGlobalCrashMemoPath(root)
    let driverPathSha: str = tooling_sha256File(root, driverPath)
    let srcSha: str = tooling_sha256File(root, src)
    var safeFirstFromMemo: bool = safeFirstDefault
    if crashMemoEnabled:
        safeFirstFromMemo = safeFirstFromMemo ||
            tooling_buildGlobalSafeFromMemo(root, crashMemoPath, driverPath, src, target, linker, driverPathSha, srcSha)
    var runtimeObj: str = ""
    if tooling_strEq(linker, "self"):
        runtimeObj = tooling_runtimeObjPath(root, target)
        if !os.fileExists(runtimeObj):
            runtimeObj = tooling_prepareRuntimeObjForTargetWithRoute(root, stage0Exec, target, stage0Route)
        if !os.fileExists(runtimeObj):
            tooling_cleanupStage0Exec(driverPath, stage0Exec)
            tooling_printErr("cheng_tooling: build-global missing runtime object for self-link: " + runtimeObj)
            return 1
    let timeoutDefault: int32 = 60
    var timeoutSec: int32 =
        tooling_clampCompileTimeoutSec(
            tooling_parseInt32Default(os.getEnvDefault("TOOLING_BUILD_GLOBAL_TIMEOUT", ""), timeoutDefault))
    let crashRetrySafe: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_GLOBAL_CRASH_RETRY_SAFE", "0"))
    var retryUsed: bool = false
    var compileOptLevel: str = strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_OPT_LEVEL", "0"))
    if !tooling_strNonEmpty(compileOptLevel):
        compileOptLevel = "0"
    var compileBackendOpt: str = tooling_bool01Normalized(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_BACKEND_OPT", "0"))
    if !tooling_strNonEmpty(compileBackendOpt):
        compileBackendOpt = "0"
    var compileBackendOpt2: str = tooling_bool01Normalized(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_BACKEND_OPT2", "0"))
    if !tooling_strNonEmpty(compileBackendOpt2):
        compileBackendOpt2 = "0"
    let devToolingBuild: bool = tooling_strEq(linker, "self")
    var compileCflagsRaw: str = devToolingBuild ? "" : releaseCflagsRaw
    var compileLdflagsRaw: str = devToolingBuild ? "" : releaseLdflagsRaw
    let compileMultiDefault: str = tooling_compileDefaultMulti(root)
    let compileMultiText: str = tooling_compileParallelMultiText(root, compileMultiDefault)
    let compileMultiForceText: str = tooling_compileParallelMultiForceText(root, compileMultiText)
    let compileJobsText: str = tooling_compileParallelJobsText(root)
    let compileFnJobsText: str = tooling_compileParallelFnJobsText(root, compileJobsText)
    var finalRc: int32 = 1
    tooling_printOut("build_global_driver=" + driverPath)
    tooling_printOut("build_global_driver_surface=" + tooling_buildGlobalDriverSurface(root, driverPath))
    tooling_printOut("build_global_stage0_route=" + stage0Route)
    tooling_printOut("build_global_driver_exec=" + stage0Exec)
    tooling_printOut("build_global_linker=" + linker)
    tooling_printOut("build_global_out=" + outPath)
    tooling_printOut("build_global_temp_out=" + buildOutPath)
    tooling_printOut("build_global_timeout_sec=" + intToStr(timeoutSec))
    tooling_printOut("build_global_release_fallback=0")
    tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
    tooling_printOut("build_global_status=building")
    if safeFirstFromMemo:
        compileOptLevel = strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_OPT_LEVEL", "0"))
        if !tooling_strNonEmpty(compileOptLevel):
            compileOptLevel = "2"
        compileBackendOpt = tooling_bool01Normalized(
            os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_BACKEND_OPT", "0"))
        if !tooling_strNonEmpty(compileBackendOpt):
            compileBackendOpt = "0"
        compileBackendOpt2 = tooling_bool01Normalized(
            os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_BACKEND_OPT2", "0"))
        if !tooling_strNonEmpty(compileBackendOpt2):
            compileBackendOpt2 = "0"
        compileCflagsRaw = strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_CFLAGS", "-O0"))
        compileLdflagsRaw = tooling_releaseLdflagsForTarget(
            os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_LDFLAGS", compileCflagsRaw), target)
        tooling_printOut("build_global_safe_first=1")
    for attempt in 0..<2:
        if attempt > 0 && (safeFirstFromMemo || !crashRetrySafe || !retryUsed):
            break
        let attemptLog: str = buildOutPath + ".attempt_" + intToStr(attempt) + ".log"
        if os.fileExists(attemptLog):
            os.removeFile(attemptLog)
        if os.fileExists(buildOutPath):
            os.removeFile(buildOutPath)
        var cmd: str = ""
        cmd = cmd + tooling_envAssignCompat("MM", "orc")
        cmd = cmd + tooling_envAssignCompat("CACHE", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_AUTO_SYSTEM", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_STD_NO_POINTERS_STRICT", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL", "0")
        cmd = cmd + tooling_envAssignCompat("STAGE1_SKIP_CPROFILE", "1")
        cmd = cmd + tooling_envAssignCompat("STAGE1_PROFILE", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_ENABLE_CLI", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_BUILD_TRACK", devToolingBuild ? "dev" : "release")
        cmd = cmd + tooling_envAssignCompat("BACKEND_LINKER", linker)
        cmd = cmd + tooling_envAssignCompat("BACKEND_FAST_DEV_PROFILE", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_STAGE1_PARSE_MODE", devToolingBuild ? "outline" : "full")
        cmd = cmd + tooling_envAssignCompat("BACKEND_STAGE1_BUILDER", "stage1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_FN_SCHED", "ws")
        cmd = cmd + tooling_envAssignCompat("BACKEND_DIRECT_EXE", devToolingBuild ? "1" : "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_LINKERLESS_INMEM", devToolingBuild ? "1" : "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_FAST_FALLBACK_ALLOW", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_INCREMENTAL", devToolingBuild ? "1" : "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_SKIP_GLOBAL_INIT", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_IR", "uir")
        cmd = cmd + tooling_envAssignCompat("BACKEND_MULTI", compileMultiText)
        cmd = cmd + tooling_envAssignCompat("BACKEND_MULTI_FORCE", compileMultiForceText)
        cmd = cmd + tooling_envAssignCompat("BACKEND_JOBS", compileJobsText)
        cmd = cmd + tooling_envAssignCompat("BACKEND_FN_JOBS", compileFnJobsText)
        cmd = cmd + tooling_envAssignCompat("BACKEND_VALIDATE", "0")
        cmd = cmd + tooling_envAssignCompat("BACKEND_ALLOW_NO_MAIN", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_OPT", compileBackendOpt)
        cmd = cmd + tooling_envAssignCompat("BACKEND_OPT2", compileBackendOpt2)
        cmd = cmd + tooling_envAssignCompat("BACKEND_OPT_LEVEL", compileOptLevel)
        if !devToolingBuild && tooling_strNonEmpty(compileCflagsRaw):
            cmd = cmd + tooling_envAssignCompat("BACKEND_CFLAGS", compileCflagsRaw)
        if !devToolingBuild && tooling_strNonEmpty(compileLdflagsRaw):
            cmd = cmd + tooling_envAssignCompat("BACKEND_LDFLAGS", compileLdflagsRaw)
        cmd = cmd + tooling_envAssignCompat("ABI", "v2_noptr")
        cmd = cmd + tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1")
        cmd = cmd + tooling_envAssignCompat("BACKEND_EMIT", "exe")
        cmd = cmd + tooling_envAssignCompat("BACKEND_INPUT", src)
        cmd = cmd + tooling_envAssignCompat("BACKEND_OUTPUT", buildOutPath)
        cmd = cmd + tooling_envAssignCompat("BACKEND_TARGET", target)
        if tooling_strEq(stage0Route, "direct"):
            cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_DISABLE", "1")
            cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_PREFER_SIDECAR", "0")
            cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_FORCE_SIDECAR", "0")
            cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_COMPILER", "")
            cmd = cmd + tooling_envAssignCompat("BACKEND_UIR_SIDECAR_BUNDLE", "")
        if tooling_strEq(linker, "self"):
            cmd = cmd + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "1")
            cmd = cmd + tooling_envAssignCompat("BACKEND_RUNTIME_OBJ", runtimeObj)
        else:
            cmd = cmd + tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "0")
        cmd = cmd + tooling_stage0LegacyCStringCompatPrefix(root, stage0Exec)
        cmd = cmd + tooling_shellQuote(stage0Exec)
        cmd = cmd + " > " + tooling_shellQuote(attemptLog) + " 2>&1"
        cmd = tooling_prefixUnsetLegacyFrontendEnv(cmd)
        cmd = tooling_wrapStage0LockTimeout(root, timeoutSec, cmd,
                                            "build_global_attempt_" + intToStr(attempt))
        let result: os.ExecCmdResult = tooling_exec(root, cmd)
        finalRc = os.execCmdResultExitCode(result)
        if finalRc != 0:
            tooling_printErr("cheng_tooling: build-global attempt " + intToStr(attempt) +
                             " failed rc=" + intToStr(finalRc) +
                             " kind=" + tooling_exitKind(finalRc) +
                             "; log=" + attemptLog)
            if finalRc == 124:
                tooling_printErr("build_global timeout reached " + intToStr(timeoutSec) + "s; capture tail diagnostic")
            tooling_printCommandLogTail(root, attemptLog, "build_global_attempt_" + intToStr(attempt), 220)
        elif os.execCmdResultExitCode(result) == 0:
            tooling_printExecOutput(result)
        if finalRc == 0:
            break
        if !crashRetrySafe || retryUsed || !tooling_isCrashExitCode(finalRc):
            break
        retryUsed = true
        compileOptLevel = strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_OPT_LEVEL", "0"))
        if !tooling_strNonEmpty(compileOptLevel):
            compileOptLevel = "2"
        compileBackendOpt = tooling_bool01Normalized(
            os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_BACKEND_OPT", "0"))
        if !tooling_strNonEmpty(compileBackendOpt):
            compileBackendOpt = "0"
        compileBackendOpt2 = tooling_bool01Normalized(
            os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_BACKEND_OPT2", "0"))
        if !tooling_strNonEmpty(compileBackendOpt2):
            compileBackendOpt2 = "0"
        compileCflagsRaw = strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_CFLAGS", "-O0"))
        compileLdflagsRaw = tooling_releaseLdflagsForTarget(
            os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_LDFLAGS", compileCflagsRaw), target)
        tooling_printErr("cheng_tooling: build-global crashed rc=" + intToStr(finalRc) +
                         " kind=" + tooling_exitKind(finalRc) +
                         "; retry safe profile opt=" + compileBackendOpt +
                         " opt2=" + compileBackendOpt2 +
                         " opt_level=" + compileOptLevel)
    tooling_cleanupStage0Exec(driverPath, stage0Exec)
    if crashMemoEnabled && tooling_strNonEmpty(driverPathSha) && tooling_strNonEmpty(srcSha):
        if finalRc == 0:
            tooling_buildGlobalWriteCrashMemo(root, crashMemoPath, driverPath, src, target, linker, driverPathSha, srcSha, retryUsed || safeFirstFromMemo)
        elif retryUsed:
            tooling_buildGlobalWriteCrashMemo(root, crashMemoPath, driverPath, src, target, linker, driverPathSha, srcSha, true)
    if retryUsed:
        tooling_printOut("build_global_retry=1")
    if finalRc != 0:
        if releaseFallbackAllowed:
            let fallbackOutOnFail: str = buildOutPath + ".release_fallback"
            tooling_printErr("cheng_tooling: build-global self-link failed; attempting release-system fallback rebuild")
            if tooling_buildGlobalReleaseFallbackTry(root, stage0Exec, src, fallbackOutOnFail, target, timeoutSec,
                                                     releaseCflagsRaw, releaseLdflagsRaw, stage0Route):
                if tooling_installExecutableAtomic(root, fallbackOutOnFail, outPath):
                    if os.fileExists(buildOutPath):
                        os.removeFile(buildOutPath)
                    if os.fileExists(fallbackOutOnFail):
                        os.removeFile(fallbackOutOnFail)
                    tooling_printOut("build_global_release_fallback=1")
                    tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
                    tooling_printOut("build_global_rebuilt=1")
                    tooling_printOut("build_global_binary_surface_ok=1")
                    return 0
                tooling_printErr("cheng_tooling: release fallback built healthy binary but install failed: " + outPath)
            if os.fileExists(fallbackOutOnFail):
                os.removeFile(fallbackOutOnFail)
        else:
            tooling_printErr("cheng_tooling: build-global release-system fallback disabled for target=" + target)
        if tooling_verifyBuiltToolingBinarySurface(root, outPath):
            tooling_printErr("cheng_tooling: build-global rebuild failed rc=" + intToStr(finalRc) +
                             " kind=" + tooling_exitKind(finalRc) +
                             "; keep existing healthy tooling binary")
            if os.fileExists(buildOutPath):
                os.removeFile(buildOutPath)
            tooling_printOut("build_global_rebuilt=0")
            tooling_printOut("build_global_fast_path=keep_existing_after_fail")
            tooling_printOut("build_global_binary_surface_ok=1")
            tooling_printOut("build_global_release_fallback=0")
            tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
            tooling_printOut("build_global_status=kept_existing_after_fail")
            tooling_printOut("build_global_rc=" + intToStr(finalRc))
            tooling_printOut("build_global_out=" + outPath)
            return 0
        if os.fileExists(buildOutPath):
            os.removeFile(buildOutPath)
        tooling_printOut("build_global_rebuilt=0")
        tooling_printOut("build_global_binary_surface_ok=0")
        tooling_printOut("build_global_status=failed")
        tooling_printOut("build_global_rc=" + intToStr(finalRc))
        return finalRc
    if !tooling_verifyBuiltToolingBinarySurface(root, buildOutPath):
        tooling_printErr("cheng_tooling: build-global produced unhealthy tooling binary: " + buildOutPath)
        tooling_printErr("  hint: inspect self-link output (__TEXT,__cstring) and keep canonical seed binary for execution")
        if releaseFallbackAllowed:
            let fallbackOut: str = buildOutPath + ".release_fallback"
            tooling_printErr("cheng_tooling: attempting release-system fallback rebuild for build-global")
            if tooling_buildGlobalReleaseFallbackTry(root, stage0Exec, src, fallbackOut, target, timeoutSec,
                                                     releaseCflagsRaw, releaseLdflagsRaw, stage0Route):
                if tooling_installExecutableAtomic(root, fallbackOut, outPath):
                    if os.fileExists(buildOutPath):
                        os.removeFile(buildOutPath)
                    if os.fileExists(fallbackOut):
                        os.removeFile(fallbackOut)
                    tooling_printOut("build_global_release_fallback=1")
                    tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
                    tooling_printOut("build_global_rebuilt=1")
                    tooling_printOut("build_global_binary_surface_ok=1")
                    return 0
                tooling_printErr("cheng_tooling: release fallback built healthy binary but install failed: " + outPath)
            if os.fileExists(fallbackOut):
                os.removeFile(fallbackOut)
            tooling_printErr("cheng_tooling: release-system fallback rebuild failed")
        else:
            tooling_printErr("cheng_tooling: build-global release-system fallback disabled for target=" + target)
        if tooling_verifyBuiltToolingBinarySurface(root, outPath):
            tooling_printErr("cheng_tooling: keep existing healthy tooling binary: " + outPath)
            if os.fileExists(buildOutPath):
                os.removeFile(buildOutPath)
            tooling_printOut("build_global_rebuilt=0")
            tooling_printOut("build_global_fast_path=keep_existing_unhealthy_build")
            tooling_printOut("build_global_binary_surface_ok=1")
            tooling_printOut("build_global_release_fallback=0")
            tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
            tooling_printOut("build_global_status=kept_existing_after_unhealthy_build")
            tooling_printOut("build_global_rc=1")
            tooling_printOut("build_global_out=" + outPath)
            return 0
        if os.fileExists(buildOutPath):
            os.removeFile(buildOutPath)
        tooling_printOut("build_global_rebuilt=0")
        tooling_printOut("build_global_binary_surface_ok=0")
        tooling_printOut("build_global_status=unhealthy_build")
        tooling_printOut("build_global_rc=1")
        return 1
    if !tooling_installExecutableAtomic(root, buildOutPath, outPath):
        tooling_printErr("cheng_tooling: build-global failed to install healthy tooling binary to: " + outPath)
        if os.fileExists(buildOutPath):
            os.removeFile(buildOutPath)
        return 1
    if os.fileExists(buildOutPath):
        os.removeFile(buildOutPath)
    tooling_printOut("build_global_rebuilt=1")
    tooling_printOut("build_global_binary_surface_ok=1")
    tooling_printOut("build_global_release_fallback=0")
    tooling_printOut("build_global_release_fallback_allowed=" + tooling_boolText(releaseFallbackAllowed))
    tooling_printOut("build_global_status=ok")
    tooling_printOut("build_global_rc=0")
    let embeddedCacheDir: str = os.joinPath(root, "chengcache/embedded_scripts")
    if os.dirExists(embeddedCacheDir):
        let purgeCmd: str = "find " + tooling_shellQuote(embeddedCacheDir) +
                            " -type f -name '*.embedded.sh' -delete"
        let purgeRes: os.ExecCmdResult = tooling_exec(root, purgeCmd)
        tooling_printExecOutput(purgeRes)
        if os.execCmdResultExitCode(purgeRes) == 0:
            tooling_printOut("build_global_embedded_cache_purged=1")
        else:
            tooling_printErr("cheng_tooling: warn: failed to purge embedded cache under " +
                             embeddedCacheDir)
    return 0

fn tooling_cmdBuildBackendRawptrContract(root: str, outFile: str, doc: str, formalDoc: str, toolingDoc: str): int32 =
    let cmd: str =
        "set -eu; " +
        "if ! command -v rg >/dev/null 2>&1; then " +
          "echo \"[build_backend_rawptr_contract] rg is required\" >&2; exit 2; " +
        "fi; " +
        "hash_file() { " +
          "file=\"$1\"; " +
          "if command -v shasum >/dev/null 2>&1; then shasum -a 256 \"$file\" | awk '{print $1}'; return; fi; " +
          "if command -v sha256sum >/dev/null 2>&1; then sha256sum \"$file\" | awk '{print $1}'; return; fi; " +
          "cksum \"$file\" | awk '{print $1}'; " +
        "}; " +
        "read_marker_value() { file=\"$1\"; marker_regex=\"$2\"; rg -o \"${marker_regex}=[A-Za-z0-9_]+\" \"$file\" | head -n 1 | cut -d= -f2 || true; }; " +
        "require_marker_value() { " +
          "file=\"$1\"; marker_regex=\"$2\"; marker_name=\"$3\"; expected=\"$4\"; " +
          "value=\"$(read_marker_value \"$file\" \"$marker_regex\")\"; " +
          "if [ \"$value\" != \"$expected\" ]; then echo \"[build_backend_rawptr_contract] ${marker_name} must be ${expected} in: $file\" >&2; exit 2; fi; " +
          "printf '%s\\n' \"$value\"; " +
        "}; " +
        "out=" + tooling_shellQuote(outFile) + "; " +
        "doc=" + tooling_shellQuote(doc) + "; " +
        "formal_doc=" + tooling_shellQuote(formalDoc) + "; " +
        "tooling_doc=" + tooling_shellQuote(toolingDoc) + "; " +
        "verify_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; " +
        "closedloop_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; " +
        "prod_closure_script=\"src/tooling/cheng_tooling_embedded_inline.cheng\"; " +
        "for required in \"$doc\" \"$formal_doc\" \"$tooling_doc\" \"$verify_script\" \"$closedloop_script\" \"$prod_closure_script\"; do " +
          "if [ ! -f \"$required\" ]; then echo \"[build_backend_rawptr_contract] missing file: $required\" >&2; exit 2; fi; " +
        "done; " +
        "tmp_markers=\"$(mktemp \"${TMPDIR:-/tmp}/backend_rawptr_contract_markers.XXXXXX\")\"; " +
        "tmp_required_gates=\"$(mktemp \"${TMPDIR:-/tmp}/backend_rawptr_contract_required.XXXXXX\")\"; " +
        "cleanup() { rm -f \"$tmp_markers\" \"$tmp_required_gates\"; }; " +
        "trap cleanup EXIT; " +
        "{ " +
          "rg -o 'rawptr_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$doc\" || true; " +
          "rg -o 'rawptr_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$formal_doc\" || true; " +
          "rg -o 'rawptr_contract\\.[a-z0-9_.]+=[A-Za-z0-9_]+' \"$tooling_doc\" || true; " +
        "} | LC_ALL=C sort -u >\"$tmp_markers\"; " +
        "marker_count=\"$(wc -l < \"$tmp_markers\" | tr -d ' ')\"; " +
        "if [ \"$marker_count\" -eq 0 ]; then echo \"[build_backend_rawptr_contract] no rawptr contract markers found\" >&2; exit 2; fi; " +
        "contract_version=\"$(read_marker_value \"$doc\" 'rawptr_contract\\.version')\"; " +
        "if [ \"$contract_version\" = \"\" ]; then echo \"[build_backend_rawptr_contract] missing rawptr_contract.version marker in: $doc\" >&2; exit 2; fi; " +
        "doc_scheme_id=\"$(require_marker_value \"$doc\" 'rawptr_contract\\.scheme\\.id' 'rawptr_contract.scheme.id' 'ZRPC')\"; " +
        "doc_scheme_name=\"$(require_marker_value \"$doc\" 'rawptr_contract\\.scheme\\.name' 'rawptr_contract.scheme.name' 'zero_rawptr_production_closure')\"; " +
        "doc_scheme_normative=\"$(require_marker_value \"$doc\" 'rawptr_contract\\.scheme\\.normative' 'rawptr_contract.scheme.normative' '1')\"; " +
        "doc_enforce_mode=\"$(require_marker_value \"$doc\" 'rawptr_contract\\.enforce\\.mode' 'rawptr_contract.enforce.mode' 'hard_fail')\"; " +
        "require_marker_value \"$formal_doc\" 'rawptr_contract\\.scheme\\.id' 'rawptr_contract.scheme.id' 'ZRPC' >/dev/null; " +
        "require_marker_value \"$formal_doc\" 'rawptr_contract\\.scheme\\.name' 'rawptr_contract.scheme.name' 'zero_rawptr_production_closure' >/dev/null; " +
        "require_marker_value \"$formal_doc\" 'rawptr_contract\\.scheme\\.normative' 'rawptr_contract.scheme.normative' '1' >/dev/null; " +
        "require_marker_value \"$formal_doc\" 'rawptr_contract\\.enforce\\.mode' 'rawptr_contract.enforce.mode' 'hard_fail' >/dev/null; " +
        "if ! rg -q 'rawptr_contract\\.formal_spec\\.synced=1' \"$formal_doc\"; then echo \"[build_backend_rawptr_contract] missing formal spec sync marker: $formal_doc\" >&2; exit 2; fi; " +
        "if ! rg -q 'rawptr_contract\\.tooling_readme\\.synced=1' \"$tooling_doc\"; then echo \"[build_backend_rawptr_contract] missing tooling README sync marker: $tooling_doc\" >&2; exit 2; fi; " +
        "annotation_count=\"$(rg -o 'rawptr_contract\\.annotation\\.[a-z0-9_]+=[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; " +
        "forbid_count=\"$(rg -o 'rawptr_contract\\.forbid\\.[a-z0-9_]+=[A-Za-z0-9_]+' \"$doc\" | LC_ALL=C sort -u | wc -l | tr -d ' ')\"; " +
        "rg -o 'rawptr_contract\\.required_gate\\.[a-z0-9_.]+=1' \"$doc\" | sed -E 's/^rawptr_contract\\.required_gate\\.([a-z0-9_.]+)=1$/\\1/' | LC_ALL=C sort -u >\"$tmp_required_gates\"; " +
        "required_gate_count=\"$(wc -l < \"$tmp_required_gates\" | tr -d ' ')\"; " +
        "if [ \"$required_gate_count\" -eq 0 ]; then echo \"[build_backend_rawptr_contract] no required rawptr gates found in: $doc\" >&2; exit 2; fi; " +
        "required_gates_csv=\"$(tr '\\n' ',' <\"$tmp_required_gates\" | sed -E 's/,+$//')\"; " +
        "if [ \"$required_gates_csv\" = \"\" ]; then echo \"[build_backend_rawptr_contract] failed to compute required gate CSV\" >&2; exit 2; fi; " +
        "marker_sha=\"$(hash_file \"$tmp_markers\")\"; " +
        "doc_sha=\"$(hash_file \"$doc\")\"; " +
        "formal_doc_sha=\"$(hash_file \"$formal_doc\")\"; " +
        "tooling_doc_sha=\"$(hash_file \"$tooling_doc\")\"; " +
        "verify_sha=\"$(hash_file \"$verify_script\")\"; " +
        "closedloop_sha=\"$(hash_file \"$closedloop_script\")\"; " +
        "prod_closure_sha=\"$(hash_file \"$prod_closure_script\")\"; " +
        "out_dir=\"$(dirname \"$out\")\"; " +
        "if [ \"$out_dir\" != \"\" ] && [ ! -d \"$out_dir\" ]; then mkdir -p \"$out_dir\"; fi; " +
        "{ " +
          "echo \"BACKEND_RAWPTR_CONTRACT_BASELINE_VERSION=1\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_DOC=$doc\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_FORMAL_DOC=$formal_doc\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_TOOLING_DOC=$tooling_doc\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_DOC_SHA256=$doc_sha\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_FORMAL_DOC_SHA256=$formal_doc_sha\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_TOOLING_DOC_SHA256=$tooling_doc_sha\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_VERSION=$contract_version\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_SCHEME_ID=$doc_scheme_id\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_SCHEME_NAME=$doc_scheme_name\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_SCHEME_NORMATIVE=$doc_scheme_normative\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_ENFORCE_MODE=$doc_enforce_mode\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_MARKER_COUNT=$marker_count\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_MARKER_SHA256=$marker_sha\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_ANNOTATION_COUNT=$annotation_count\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_FORBID_COUNT=$forbid_count\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_REQUIRED_GATE_COUNT=$required_gate_count\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_VERIFY_SCRIPT_SHA256=$verify_sha\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_CLOSEDLOOP_SHA256=$closedloop_sha\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_PROD_CLOSURE_SHA256=$prod_closure_sha\"; " +
          "echo \"BACKEND_RAWPTR_CONTRACT_REQUIRED_GATES=$required_gates_csv\"; " +
        "} >\"$out\"; " +
        "echo \"backend rawptr contract baseline generated: $out\""
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_cmdBuildBackendRawptrContractFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var outFile: str = "src/tooling/backend_rawptr_contract.env"
    var doc: str = "docs/raw-pointer-safety.md"
    var formalDoc: str = "docs/cheng-formal-spec.md"
    var toolingDoc: str = "src/tooling/README.md"
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("build_backend_rawptr_contract options:")
            tooling_printOut("  --out:<path>         output baseline env")
            tooling_printOut("  --doc:<path>         raw-pointer contract doc")
            tooling_printOut("  --formal-doc:<path>  formal spec doc")
            tooling_printOut("  --tooling-doc:<path> tooling README")
            return 0
        if strutil.startsWith(arg, "--out:"):
            outFile = strings.dropPrefix(arg, "--out:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--doc:"):
            doc = strings.dropPrefix(arg, "--doc:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--formal-doc:"):
            formalDoc = strings.dropPrefix(arg, "--formal-doc:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--tooling-doc:"):
            toolingDoc = strings.dropPrefix(arg, "--tooling-doc:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown build_backend_rawptr_contract arg: " + arg)
        return 2
    return tooling_cmdBuildBackendRawptrContract(root, outFile, doc, formalDoc, toolingDoc)

fn tooling_cmdVerifyBackendRawptrContract(root: str, firstArgIndex: int32, count: int32): int32 =
    let scriptPath: str = tooling_pathAbsolute(root, "src/tooling/verify_backend_rawptr_contract_native.sh")
    if !tooling_strNonEmpty(scriptPath) || !os.fileExists(scriptPath):
        tooling_printErr("cheng_tooling: missing rawptr contract script: " + scriptPath)
        return 1
    let _count: int32 = count
    return tooling_runScript(root, scriptPath, firstArgIndex)

