@importc("cheng_fd_write")
fn tooling_c_write_raw(fd: int32, buf: str, n: int32): int32

fn tooling_c_write(fd: int32, buf: str): int32 =
    if len(buf) <= 0:
        return 0
    return tooling_c_write_raw(fd, buf, len(buf))

fn tooling_paramCount(): int32 =
    let count: int32 = tcmdline.paramCount()
    if count <= 0 || count > 4096:
        return 0
    return count

fn tooling_paramStr(i: int32): str =
    if i <= 0:
        return ""
    return tcmdline.paramStr(i)

fn tooling_argEq(i: int32, expected: str): bool =
    return tooling_strEq(tooling_paramStr(i), expected)

fn tooling_printOut(text: str) =
    if len(text) > 0:
        let _nText: int32 = tooling_c_write(1, text)
    let _nNl: int32 = tooling_c_write(1, "\n")

fn tooling_printErr(text: str) =
    if len(text) > 0:
        let _nText: int32 = tooling_c_write(2, text)
    let _nNl: int32 = tooling_c_write(2, "\n")

fn tooling_printLines(lines: str[]) =
    for i in 0..<len(lines):
        tooling_printOut(lines[i])

fn tooling_argsRange(firstArgIndex: int32, count: int32): str[] =
    var out: str[] = []
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        add(out, tooling_paramStr(i))
        i = i + 1
    return out

fn tooling_argsReadPrefixedValue(args: str[], prefix: str, defaultValue: str): str =
    for offset in 0..<args.len:
        let i: int32 = args.len - 1 - offset
        let arg: str = args[i]
        if strutil.startsWith(arg, prefix):
            return strings.dropPrefix(arg, prefix)
    return defaultValue

fn tooling_argsHas(args: str[], expected: str): bool =
    for i in 0..<args.len:
        if tooling_strEq(args[i], expected):
            return true
    return false

fn tooling_runScriptDebugEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_RUN_SCRIPT_DEBUG", "0"))

fn tooling_debugRunScriptField(name: str, value: str) =
    if !tooling_runScriptDebugEnabled():
        return
    tooling_printErr("cheng_tooling.run_script." + name + "=" + value)

fn tooling_dispatchDebugEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_DISPATCH_DEBUG", "0"))

fn tooling_debugDispatchField(name: str, value: str) =
    if !tooling_dispatchDebugEnabled():
        return
    tooling_printErr("cheng_tooling.dispatch." + name + "=" + value)

fn tooling_addBool(dst: var bool[], val: bool) =
    if dst.buffer == nil || dst.len >= dst.cap:
        cheng__seqGrowToRaw(&dst.buffer, &dst.cap, dst.len + 1, int32(sizeof bool))
    let elemBytes: int32 = dst.len * int32(sizeof bool)
    let writePtr: bool* = bool*(ptr_add(dst.buffer, elemBytes))
    *writePtr = val
    dst.len = dst.len + 1

fn tooling_strNonEmpty(text: str): bool =
    return len(text) > 0

fn tooling_strEq(a: str, b: str): bool =
    if a == b:
        return true
    if len(a) == 0 || len(b) == 0:
        return false
    return strings.streq(a, b)

fn toolingOwnStr(s: str): str =
    return strings.sliceBytes(s, 0, len(s))

fn tooling_genericModeIsDictOnly(raw: str): bool =
    if !tooling_strNonEmpty(strutil.toLowerAscii(strutil.strip(raw))):
        return true
    return tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "dict")

fn tooling_genericLoweringIsDictOnly(raw: str): bool =
    if !tooling_strNonEmpty(strutil.toLowerAscii(strutil.strip(raw))):
        return true
    return tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "mir_dict")

fn tooling_strEndsWith(text: str, suffix: str): bool =
    if !tooling_strNonEmpty(text) || !tooling_strNonEmpty(suffix):
        return false
    let n: int32 = len(text)
    let m: int32 = len(suffix)
    if m > n:
        return false
    for i in 0..<m:
        if text[n - m + i] != suffix[i]:
            return false
    return true

fn tooling_stripShSuffix(name: str): str =
    if !tooling_strEndsWith(name, ".sh"):
        return name
    let n: int32 = len(name)
    if n <= 3:
        return ""
    return strings.sliceBytes(name, 0, n - 3)

fn tooling_selfhostStrictRebuildEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("SELFHOST_STRICT_REBUILD", "1"))

fn tooling_buildDriverStrictNativeEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("BUILD_DRIVER_STRICT_NATIVE", "1"))

fn tooling_buildDriverEffectiveStrictNativeForRebuild(fullRebuild: bool): bool =
    if fullRebuild:
        return tooling_buildDriverStrictNativeEnabled()
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_FAST_STRICT_NATIVE", "1"))):
        return tooling_isTrue(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_FAST_STRICT_NATIVE", "1")))
    return false

fn tooling_buildDriverAllowFallbackEnabled(): bool =
    # Fallback path has been removed from production closure.
    # Keep env read only for compatibility diagnostics.
    return false

fn tooling_buildDriverRequestedMode(modeRaw: str, requireRebuild: bool, debugRebuild: bool): str =
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "fast") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "quick"):
        return "fast"
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "seal") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "full") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "strict"):
        return "seal"
    if tooling_strNonEmpty(strutil.toLowerAscii(strutil.strip(modeRaw))) &&
       !tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "auto"):
        return ""
    if requireRebuild || debugRebuild:
        return "seal"
    return "fast"

fn tooling_removedEnvMessage(name: str, replacement: str): str =
    if tooling_strNonEmpty(replacement):
        return "cheng_tooling: removed env " + name + ", use " + replacement
    return "cheng_tooling: removed env " + name

fn tooling_failRemovedBoolEnvEnabled(name: str, replacement: str): bool =
    if !tooling_strNonEmpty(strutil.strip(os.getEnvDefault(name, ""))):
        return false
    if !tooling_isTrue(strutil.strip(os.getEnvDefault(name, ""))):
        return false
    tooling_printErr(tooling_removedEnvMessage(name, replacement))
    return true

fn tooling_failRemovedBoolEnvNonZero(name: str, replacement: str): bool =
    if !tooling_strNonEmpty(strutil.strip(os.getEnvDefault(name, ""))):
        return false
    if tooling_strEq(tooling_bool01Normalized(strutil.strip(os.getEnvDefault(name, ""))), "0"):
        return false
    tooling_printErr(tooling_removedEnvMessage(name, replacement))
    return true

fn tooling_failRemovedEnvPresent(name: str, replacement: str): bool =
    if !tooling_strNonEmpty(strutil.strip(os.getEnvDefault(name, ""))):
        return false
    tooling_printErr(tooling_removedEnvMessage(name, replacement))
    return true

fn tooling_failFixedTrackRemovedMessage(name: str, expected: str, trackLabel: str): str =
    return "cheng_tooling: " + trackLabel + " fixes " + name + "=" + expected +
           "; explicit env override is removed"

fn tooling_failFixedTrackInvalidMessage(name: str, expected: str, raw: str, trackLabel: str): str =
    return "cheng_tooling: " + trackLabel + " only allows " + name + "=" + expected +
           " (got " + raw + ")"

fn tooling_failFixedTrackEnv(name: str, expected: str, trackLabel: str): bool =
    if !tooling_strNonEmpty(strutil.strip(os.getEnvDefault(name, ""))):
        return false
    if tooling_strEq(
        strutil.toLowerAscii(strutil.strip(os.getEnvDefault(name, ""))),
        strutil.toLowerAscii(strutil.strip(expected))
    ):
        tooling_printErr(tooling_failFixedTrackRemovedMessage(name, expected, trackLabel))
    else:
        tooling_printErr(
            tooling_failFixedTrackInvalidMessage(
                name,
                expected,
                strutil.strip(os.getEnvDefault(name, "")),
                trackLabel
            )
        )
    return true

fn tooling_rejectRemovedRiskyEnvs(): bool =
    return false

fn tooling_buildDriverProfileMode(): str =
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_MODE", "backend"))), "full"):
        return "full"
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_MODE", "backend"))), "backend") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_MODE", "backend"))), "backend_only"):
        return "backend"
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_MODE", "backend"))), "stage1") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_MODE", "backend"))), "stage1_uir"):
        return "stage1_uir"
    return "safe"

fn tooling_prefixBuildDriverProfile(cmd: str, profileMode: str): str =
    if tooling_strEq(profileMode, "full"):
        return tooling_envAssignCompat("BACKEND_PROFILE", "1") +
               tooling_envAssignCompat("STAGE1_PROFILE", "1") +
               tooling_envAssignCompat("UIR_PROFILE", "1") + cmd
    if tooling_strEq(profileMode, "backend"):
        return tooling_envAssignCompat("BACKEND_PROFILE", "1") + cmd
    if tooling_strEq(profileMode, "stage1_uir"):
        return tooling_envAssignCompat("UIR_PROFILE", "1") + cmd
    return cmd

fn tooling_isSafeScriptName(name: str): bool =
    if !tooling_strNonEmpty(name):
        return false
    if strutil.contains(name, ".."):
        return false
    for i in 0..<len(name):
        let ch: char = name[i]
        let isAlphaLower: bool = ch >= 'a' && ch <= 'z'
        let isAlphaUpper: bool = ch >= 'A' && ch <= 'Z'
        let isDigit: bool = ch >= '0' && ch <= '9'
        if isAlphaLower || isAlphaUpper || isDigit || ch == '_' || ch == '-' || ch == '.':
            continue
        return false
    return true

fn tooling_shellQuote(raw: str): str =
    if len(raw) == 0:
        return "\"\""
    return "\"" + strutil.replace(
        strutil.replace(
            strutil.replace(
                strutil.replace(raw, "\\", "\\\\"),
                "$",
                "\\$"
            ),
            "`",
            "\\`"
        ),
        "\"",
        "\\\""
    ) + "\""

fn tooling_isAsciiSpace(ch: char): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn tooling_trimAsciiSpace(raw: str): str =
    if !tooling_strNonEmpty(raw):
        return ""
    let n: int32 = len(raw)
    if n <= 0:
        return ""
    var start: int32 = 0
    while start < n && tooling_isAsciiSpace(raw[start]):
        start = start + 1
    if start >= n:
        return ""
    var stop: int32 = n - 1
    while stop >= start && tooling_isAsciiSpace(raw[stop]):
        stop = stop - 1
    if start == 0 && stop == n - 1:
        return raw
    return strings.sliceBytes(raw, start, stop - start + 1)

fn tooling_stage0CompatPrefixEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_CSTRING_COMPAT", "1"))

fn tooling_stage0RemovedCStringCompatMarkerCommand(stage0Path: str): str =
    return "if ! command -v strings >/dev/null 2>&1; then exit 2; fi; " +
           "strings " + tooling_shellQuote(stage0Path) + " 2>/dev/null | " +
           "grep -Fq " + tooling_shellQuote("cstring lowering is always on (removed config)") + " || " +
           "strings " + tooling_shellQuote(stage0Path) + " 2>/dev/null | " +
           "grep -Fq " + tooling_shellQuote("removed env BACKEND_ENABLE_CSTRING_LOWERING")

fn tooling_stage0HasRemovedCStringCompatMarker(root: str, stage0Exec: str): bool =
    if !tooling_strNonEmpty(stage0Exec):
        return false
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0Exec)) ||
       !os.fileExists(tooling_pathAbsolute(root, stage0Exec)):
        return false
    let res: os.ExecCmdResult =
        tooling_exec(root, tooling_stage0RemovedCStringCompatMarkerCommand(tooling_pathAbsolute(root, stage0Exec)))
    return os.execCmdResultExitCode(res) == 0

fn tooling_stage0NeedsLegacyCStringCompat(root: str, stage0Exec: str): bool =
    if !tooling_stage0CompatPrefixEnabled():
        return false
    if tooling_strNonEmpty(tooling_trimAsciiSpace(os.getEnvDefault("TOOLING_STAGE0_CSTRING_COMPAT_FORCE", ""))):
        return tooling_isTrue(tooling_trimAsciiSpace(os.getEnvDefault("TOOLING_STAGE0_CSTRING_COMPAT_FORCE", "")))
    # Supported stage0 drivers no longer accept legacy cstring-lowering envs.
    # Avoid sha/strings probing on every process; keep explicit force escape hatch.
    let needsCompat: bool = false
    tooling_stage0CstringCompatProbeSig = tooling_trimAsciiSpace(stage0Exec)
    tooling_stage0CstringCompatProbeDone = true
    tooling_stage0CstringCompatProbeResult = needsCompat
    if tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_CSTRING_COMPAT_DEBUG", "0")):
        tooling_printOut("stage0_cstring_compat_probe_exec=" + stage0Exec)
        tooling_printOut("stage0_cstring_compat_enabled=" + (needsCompat ? "1" : "0"))
    return needsCompat

fn tooling_stage0LegacyCStringCompatPrefix(root: str, stage0Exec: str): str =
    if !tooling_stage0NeedsLegacyCStringCompat(root, stage0Exec):
        return ""
    return tooling_envAssignCompat("BACKEND_ENABLE_CSTRING_LOWERING", "1") +
           tooling_envAssignCompat("BACKEND_CSTRING_LOWERING", "1") +
           tooling_envAssignCompat("BACKEND_ISEL_CSTRING_LOWERING", "1")

fn tooling_envAssignQuoted(name: str, value: str): str =
    if !tooling_strNonEmpty(name):
        return ""
    return name + "=" + tooling_shellQuote(value) + " "

fn tooling_envAssignCompat(name: str, value: str): str =
    if !tooling_strNonEmpty(name):
        return ""
    return tooling_envAssignQuoted(name, value)

fn tooling_envAssignExpr(name: str, expr: str): str =
    if !tooling_strNonEmpty(name) || !tooling_strNonEmpty(expr):
        return ""
    return name + "=" + expr + " "

fn tooling_envOverride(name: str, value: str): str =
    if !tooling_strNonEmpty(name):
        return ""
    return name + "=" + value

fn tooling_envAssignCollect(envOverrides: var str[], name: str, value: str) =
    if tooling_strNonEmpty(tooling_envOverride(name, value)):
        add(envOverrides, tooling_envOverride(name, value))

fn tooling_envAssignExprCollect(parts: var str[], name: str, expr: str) =
    if tooling_strNonEmpty(tooling_envAssignExpr(name, expr)):
        add(parts, tooling_envAssignExpr(name, expr))

fn tooling_envOverrideEqIndex(entry: str): int32 =
    let n: int32 = len(entry)
    if n <= 0:
        return -1
    var j: int32 = 0
    while j < n && entry[j] != '=':
        j = j + 1
    if j <= 0:
        return -1
    return j

fn tooling_envOverrideName(entry: str): str =
    if tooling_envOverrideEqIndex(entry) <= 0:
        return ""
    return strings.sliceBytes(entry, 0, tooling_envOverrideEqIndex(entry))

fn tooling_envOverrideValue(entry: str): str =
    if tooling_envOverrideEqIndex(entry) < 0:
        return ""
    if tooling_envOverrideEqIndex(entry) + 1 >= len(entry):
        return ""
    return strings.sliceBytes(entry, tooling_envOverrideEqIndex(entry) + 1, len(entry) - tooling_envOverrideEqIndex(entry) - 1)

fn tooling_envOverridesShellPrefix(envOverrides: str[]): str =
    var parts: str[] = []
    for i in 0..<envOverrides.len:
        if len(envOverrides[i]) <= 0:
            continue
        if tooling_envOverrideEqIndex(envOverrides[i]) <= 0:
            continue
        if tooling_strNonEmpty(tooling_envAssignCompat(tooling_envOverrideName(envOverrides[i]), tooling_envOverrideValue(envOverrides[i]))):
            add(parts, tooling_envAssignCompat(tooling_envOverrideName(envOverrides[i]), tooling_envOverrideValue(envOverrides[i])))
    return tooling_joinFragments(parts)

fn tooling_envTextLookup(envText: str, name: str): str =
    let parts: str[] = strutil.split(strutil.strip(envText), ' ')
    for i in 0..<parts.len:
        let entry: str = strutil.strip(parts[i])
        if tooling_strEq(tooling_envOverrideName(entry), name):
            return tooling_envOverrideValue(entry)
    return ""

fn tooling_appendLegacyFrontendEnvUnsets(envOverrides: var str[]) =
    add(envOverrides, tooling_envOverride("BACKEND_MULTI_MODULE_CACHE", "0"))
    add(envOverrides, tooling_envOverride("BACKEND_MODULE_CACHE", ""))
    add(envOverrides, tooling_envOverride("BACKEND_UNIT_BATCH_FILE", ""))
    add(envOverrides, tooling_envOverride("BACKEND_UNIT_FILE", ""))

fn tooling_stage0LegacyCStringCompatCollect(root: str, stage0Exec: str,
                                            envOverrides: var str[]) =
    if !tooling_stage0NeedsLegacyCStringCompat(root, stage0Exec):
        return
    tooling_envAssignCollect(envOverrides, "BACKEND_ENABLE_CSTRING_LOWERING", "1")
    tooling_envAssignCollect(envOverrides, "BACKEND_CSTRING_LOWERING", "1")
    tooling_envAssignCollect(envOverrides, "BACKEND_ISEL_CSTRING_LOWERING", "1")

fn tooling_prefixUnsetLegacyFrontendEnv(cmd: str): str =
    if !tooling_strNonEmpty(cmd):
        return cmd
    # Stable stage0 path hard-disables module-cache surfaces to avoid old dist
    # binaries re-entering recursive cache-error paths.
    return tooling_envAssignCompat("BACKEND_MULTI_MODULE_CACHE", "0") +
           tooling_envAssignCompat("BACKEND_MODULE_CACHE", "") +
           tooling_envAssignCompat("BACKEND_UNIT_BATCH_FILE", "") +
           tooling_envAssignCompat("BACKEND_UNIT_FILE", "") + cmd

fn tooling_executableArg0Absolute(): str =
    if !tooling_strNonEmpty(strutil.strip(tooling_paramStr(0))):
        return ""
    if os.isAbsolute(strutil.strip(tooling_paramStr(0))):
        return strutil.strip(tooling_paramStr(0))
    return os.absolutePath(strutil.strip(tooling_paramStr(0)))

fn tooling_rootFromProbeDir(probe: str, depth: int32): str =
    if !tooling_strNonEmpty(probe) || depth >= 10:
        return ""
    if os.fileExists(os.joinPath(probe, "src/tooling/cheng_tooling.cheng")):
        return probe
    if !tooling_strNonEmpty(os.parentDir(probe)) || tooling_strEq(os.parentDir(probe), probe):
        return ""
    return tooling_rootFromProbeDir(os.parentDir(probe), depth + 1)

fn tooling_rootFromExecutablePath(): str =
    if !tooling_strNonEmpty(tooling_executableArg0Absolute()):
        return ""
    return tooling_rootFromProbeDir(os.parentDir(tooling_executableArg0Absolute()), 0)

fn tooling_findSubstr(hay: str, needle: str): int32 =
    if !tooling_strNonEmpty(hay) || !tooling_strNonEmpty(needle):
        return -1
    let n: int32 = len(hay)
    let m: int32 = len(needle)
    if m <= 0 || n < m:
        return -1
    for i in 0..n - m:
        var matched: bool = true
        for j in 0..<m:
            if hay[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return tooling_routeMiss()

fn tooling_rootFromExecutableMarker(): str =
    if !tooling_strNonEmpty(tooling_executableArg0Absolute()):
        return ""
    let hit: int32 = tooling_findSubstr(tooling_executableArg0Absolute(), "/artifacts/tooling_cmd/")
    if hit <= 0:
        return ""
    return strings.sliceBytes(tooling_executableArg0Absolute(), 0, hit)

fn tooling_root(): str =
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("TOOLING_ROOT", ""))):
        return strutil.strip(os.getEnvDefault("TOOLING_ROOT", ""))
    if tooling_strNonEmpty(tooling_rootFromExecutablePath()):
        return tooling_rootFromExecutablePath()
    if tooling_strNonEmpty(tooling_rootFromExecutableMarker()):
        return tooling_rootFromExecutableMarker()
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("PWD", ""))):
        return strutil.strip(os.getEnvDefault("PWD", ""))
    return os.getCurrentDir()

fn tooling_scriptDir(root: str): str =
    return os.joinPath(root, "src/tooling")

fn tooling_embeddedPrefix(): str =
    return "embedded:"

fn tooling_scriptIdFromResolvedPath(scriptPath: str): str =
    if !strutil.startsWith(scriptPath, tooling_embeddedPrefix()):
        return ""
    return strings.dropPrefix(scriptPath, tooling_embeddedPrefix())

fn tooling_splitLines(raw: str): str[] =
    var out: str[] = []
    if !tooling_strNonEmpty(raw):
        return out
    let n: int32 = len(raw)
    var start: int32 = 0
    var i: int32 = 0
    for _ in 0..<n:
        if raw[i] == '\n':
            if i > start:
                let piece: str = strutil.strip(strings.sliceBytes(raw, start, i - start))
                if tooling_strNonEmpty(piece):
                    add(out, piece)
            start = i + 1
        i = i + 1
    if start < n:
        let tail: str = strutil.strip(strings.sliceBytes(raw, start, n - start))
        if tooling_strNonEmpty(tail):
            add(out, tail)
    return out

fn tooling_readTextFile(root: str, pathRaw: str): str =
    let path: str = tooling_pathAbsolute(root, pathRaw)
    if !tooling_strNonEmpty(path) || !os.fileExists(path):
        return ""
    return os.readFile(path)

fn tooling_kvGet(raw: str, key: str): str =
    if !tooling_strNonEmpty(raw) || !tooling_strNonEmpty(key):
        return ""
    let rows: str[] = tooling_splitLines(raw)
    for i in 0..<rows.len:
        if !tooling_strNonEmpty(strutil.strip(rows[i])):
            continue
        if strutil.startsWith(strutil.strip(rows[i]), key + "="):
            return strings.dropPrefix(strutil.strip(rows[i]), key + "=")
    return ""

fn tooling_runtimeProofShellSetup(root: str, gateName: str): str =
    return "root=\"${TOOLING_ROOT:-$(CDPATH= cd -- \"$(dirname -- \"$0\")/../../..\" && pwd)}\""

fn tooling_stage0CapabilityAdd(out: str[]*, relPath: str) =
    if out == nil || !tooling_strNonEmpty(relPath):
        return
    add(*out, relPath)

