    add(out, os.joinPath(root, "src/tooling/cheng_tooling_embedded_part2.cheng"))
    add(out, os.joinPath(root, "src/tooling/cheng_tooling_embedded_part3.cheng"))
    add(out, os.joinPath(root, "src/tooling/cheng_tooling_embedded_part4.cheng"))
    add(out, os.joinPath(root, "src/tooling/cheng_tooling_embedded_part5.cheng"))
    add(out, os.joinPath(root, "src/tooling/cheng_tooling_embedded_part6.cheng"))
    return out

fn tooling_anyFileNewerThan(root: str, files: str[], outPath: str): bool =
    for i in 0..<files.len:
        if tooling_fileIsNewer(root, files[i], outPath):
            return true
    return false

fn tooling_stage0CapabilityBuilderSourcesConsistent(root: str, files: str[]): bool =
    let scanRes: os.ExecCmdResult = tooling_exec(
        root,
        "if ! command -v rg >/dev/null 2>&1; then exit 0; fi; " +
        "rg --files src/backend/uir/uir_internal 2>/dev/null | " +
        "rg '(^|/)uir_core_builder[^/]*\\.cheng$' || true")
    if os.execCmdResultExitCode(scanRes) != 0:
        return true
    let expected: str[] = tooling_splitLines(os.execCmdResultOutput(scanRes))
    for i in 0..<expected.len:
        let rel: str = strutil.strip(expected[i])
        if !tooling_strNonEmpty(rel):
            continue
        var listed: bool = false
        for j in 0..<files.len:
            if tooling_strEq(files[j], rel):
                listed = true
                break
        if !listed:
            tooling_printErr("cheng_tooling: stage0 capability builder source missing from source list: " + rel)
            return false
    return true

fn tooling_stage0CapabilityFilePath(stage0Path: str): str =
    if !tooling_strNonEmpty(stage0Path):
        return ""
    return stage0Path + ".cap.env"

fn tooling_stage0CapabilityManifestText(rows: str[]): str =
    if rows.len <= 0:
        return ""
    return strutil.join(rows, "\n") + "\n"

fn tooling_stage0CapabilityEnsureCache(root: str): bool =
    if tooling_strNonEmpty(tooling_stage0CapabilitySignatureCache) &&
       tooling_strNonEmpty(tooling_stage0CapabilityManifestCache):
        return true
    let files: str[] = tooling_stage0CapabilitySourceList()
    if files.len <= 0:
        return false
    if !tooling_stage0CapabilityBuilderSourcesConsistent(root, files):
        return false
    var manifestRows: str[] = []
    for i in 0..<files.len:
        if !os.fileExists(tooling_pathAbsolute(root, files[i])):
            tooling_printErr("cheng_tooling: stage0 capability source missing: " + files[i])
            return false
        if !tooling_strNonEmpty(tooling_sha256File(root, tooling_pathAbsolute(root, files[i]))):
            tooling_printErr("cheng_tooling: stage0 capability sha256 failed: " + files[i])
            return false
        add(manifestRows, files[i] + "=" + tooling_sha256File(root, tooling_pathAbsolute(root, files[i])))
    if !tooling_strNonEmpty(tooling_sha256Text(root, tooling_stage0CapabilityManifestText(manifestRows))):
        tooling_printErr("cheng_tooling: stage0 capability signature generation failed")
        return false
    tooling_stage0CapabilityManifestCache = tooling_stage0CapabilityManifestText(manifestRows)
    tooling_stage0CapabilitySignatureCache = tooling_sha256Text(root, tooling_stage0CapabilityManifestText(manifestRows))
    return true

fn tooling_stage0CapabilitySignature(root: str): str =
    if !tooling_stage0CapabilityEnsureCache(root):
        return ""
    return tooling_stage0CapabilitySignatureCache

fn tooling_stage0CapabilityWriteForOutput(root: str, outPathRaw: str): bool =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, outPathRaw)):
        return false
    if !tooling_stage0CapabilityEnsureCache(root):
        return false
    if !tooling_strNonEmpty(tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, outPathRaw))):
        return false
    if tooling_strNonEmpty(os.parentDir(tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, outPathRaw)))):
        tooling_tryMkdirP(root, os.parentDir(tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, outPathRaw))))
    let files: str[] = tooling_stage0CapabilitySourceList()
    if !tooling_writeTextFileViaShell(
        root,
        tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, outPathRaw)),
        "version=1\n" +
        "signature=" + tooling_stage0CapabilitySignatureCache + "\n" +
        "source_count=" + intToStr(files.len) + "\n" +
        "manifest=\n" + tooling_stage0CapabilityManifestCache
    ):
        return false
    return os.fileExists(tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, outPathRaw)))

fn tooling_stage0CapabilityPreflightAllowBootstrapRefresh(contextRaw: str, allowRefresh: bool): bool =
    if !allowRefresh:
        return false
    return tooling_strContains(strutil.toLowerAscii(strutil.strip(contextRaw)), "build_backend_driver")

fn tooling_stage0CapabilityContext(contextRaw: str): str =
    if tooling_strNonEmpty(strutil.strip(contextRaw)):
        return strutil.strip(contextRaw)
    return "stage0_preflight"

fn tooling_stage0CapabilityPreflightOkEx(root: str, stage0PathRaw: str, contextRaw: str,
                                         allowBootstrapRefresh: bool): bool =
    let enabled: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_CAPABILITY_PREFLIGHT", "1"))
    if !enabled:
        return true
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)):
        return false
    let requireCapFile: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_CAPABILITY_REQUIRE_FILE", "0"))
    let allowRefresh: bool = tooling_stage0CapabilityPreflightAllowBootstrapRefresh(
        tooling_stage0CapabilityContext(contextRaw), allowBootstrapRefresh)
    if !os.fileExists(tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, stage0PathRaw))):
        if requireCapFile:
            if allowRefresh:
                tooling_printErr("cheng_tooling: stage0 capability file missing during bootstrap refresh; allow seed refresh")
                tooling_printErr("cheng_tooling: stage0=" + tooling_pathAbsolute(root, stage0PathRaw))
                tooling_printErr("cheng_tooling: context=" + tooling_stage0CapabilityContext(contextRaw))
                return true
            tooling_printErr(
                "cheng_tooling: stage0 capability file missing: " +
                tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, stage0PathRaw))
            )
            tooling_printErr("cheng_tooling: capability preflight failed (" + tooling_stage0CapabilityContext(contextRaw) +
                             "); refresh seed/driver via `BOOTSTRAP_UPDATE_SEED=1 artifacts/tooling_cmd/cheng_tooling bootstrap-pure --mode:strict --compile-stage1 --fullspec`")
            return false
        return true
    if !tooling_strNonEmpty(tooling_stage0CapabilitySignature(root)):
        tooling_printErr("cheng_tooling: stage0 capability preflight skipped (signature unavailable)")
        return true
    if !tooling_strNonEmpty(
        tooling_kvGet(
            tooling_readTextFile(root, tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, stage0PathRaw))),
            "signature"
        )
    ):
        if requireCapFile:
            tooling_printErr(
                "cheng_tooling: stage0 capability signature missing in " +
                tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, stage0PathRaw))
            )
            return false
        return true
    if tooling_strEq(
        tooling_kvGet(
            tooling_readTextFile(root, tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, stage0PathRaw))),
            "signature"
        ),
        tooling_stage0CapabilitySignature(root)
    ):
        return true
    if allowRefresh:
        tooling_printErr(
            "cheng_tooling: stage0 capability mismatch allowed for bootstrap refresh (" +
            tooling_stage0CapabilityContext(contextRaw) + ")"
        )
        tooling_printErr("cheng_tooling: stage0=" + tooling_pathAbsolute(root, stage0PathRaw))
        tooling_printErr(
            "cheng_tooling: stage0_capability_signature=" +
            tooling_kvGet(
                tooling_readTextFile(root, tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, stage0PathRaw))),
                "signature"
            )
        )
        tooling_printErr("cheng_tooling: source_capability_signature=" + tooling_stage0CapabilitySignature(root))
        return true
    tooling_printErr("cheng_tooling: stage0 capability mismatch (" + tooling_stage0CapabilityContext(contextRaw) + ")")
    tooling_printErr("cheng_tooling: stage0=" + tooling_pathAbsolute(root, stage0PathRaw))
    tooling_printErr(
        "cheng_tooling: stage0_capability_signature=" +
        tooling_kvGet(
            tooling_readTextFile(root, tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, stage0PathRaw))),
            "signature"
        )
    )
    tooling_printErr("cheng_tooling: source_capability_signature=" + tooling_stage0CapabilitySignature(root))
    tooling_printErr("cheng_tooling: hint: refresh seed + canonical driver")
    tooling_printErr("cheng_tooling:   BOOTSTRAP_UPDATE_SEED=1 artifacts/tooling_cmd/cheng_tooling bootstrap-pure --mode:strict --compile-stage1 --fullspec")
    tooling_printErr("cheng_tooling:   artifacts/tooling_cmd/cheng_tooling build-backend-driver --require-rebuild")
    return false

fn tooling_stage0CapabilityPreflightOk(root: str, stage0PathRaw: str, contextRaw: str): bool =
    return tooling_stage0CapabilityPreflightOkEx(root, stage0PathRaw, contextRaw, false)

fn tooling_buildGlobalCrashMemoPath(root: str): str =
    return os.joinPath(root, "chengcache/tooling_cmd/build_global.crash_pref.env")

fn tooling_buildGlobalSafeFromMemo(root: str, memoPathRaw: str, driverPath: str, srcPath: str,
                                   target: str, linker: str, driverSha: str, srcSha: str): bool =
    let memoPath: str = tooling_pathAbsolute(root, memoPathRaw)
    if !tooling_strNonEmpty(memoPath) || !os.fileExists(memoPath):
        return false
    if !tooling_strNonEmpty(driverSha) || !tooling_strNonEmpty(srcSha):
        return false
    let raw: str = tooling_readTextFile(root, memoPath)
    if !tooling_strEq(tooling_kvGet(raw, "version"), "1"):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "prefer_safe"), "1"):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "driver_path"), tooling_pathAbsolute(root, driverPath)):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "driver_sha"), driverSha):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "src_path"), tooling_pathAbsolute(root, srcPath)):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "src_sha"), srcSha):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "target"), target):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "linker"), linker):
        return false
    return true

fn tooling_buildGlobalWriteCrashMemo(root: str, memoPathRaw: str, driverPath: str, srcPath: str,
                                     target: str, linker: str, driverSha: str, srcSha: str,
                                     preferSafe: bool) =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, memoPathRaw)):
        return
    if tooling_strNonEmpty(os.parentDir(tooling_pathAbsolute(root, memoPathRaw))):
        tooling_tryMkdirP(root, os.parentDir(tooling_pathAbsolute(root, memoPathRaw)))
    os.writeFile(
        tooling_pathAbsolute(root, memoPathRaw),
        "version=1\n" +
        "prefer_safe=" + (preferSafe ? "1" : "0") + "\n" +
        "driver_path=" + tooling_pathAbsolute(root, driverPath) + "\n" +
        "driver_sha=" + driverSha + "\n" +
        "src_path=" + tooling_pathAbsolute(root, srcPath) + "\n" +
        "src_sha=" + srcSha + "\n" +
        "target=" + target + "\n" +
        "linker=" + linker + "\n"
    )

fn tooling_escapeEmbeddedMapString(text: str): str =
    if len(text) == 0:
        return ""
    var parts: str[] = []
    let n: int32 = len(text)
    var i: int32 = 0
    while i < n:
        let ch: char = text[i]
        if ch == '\\':
            add(parts, "\\\\")
        elif ch == '"':
            add(parts, "\\\"")
        elif ch == '\n':
            add(parts, "\\n")
        elif ch == '\t':
            add(parts, "\\t")
        elif ch == '\r':
            add(parts, "\\r")
        else:
            add(parts, strings.sliceBytes(text, i, 1))
        i = i + 1
    return tooling_joinFragments(parts)

fn tooling_splitEmbeddedEscapedChunks(text: str, chunkSizeRaw: int32): str[] =
    var out: str[] = []
    if !tooling_strNonEmpty(text):
        add(out, "")
        return out
    var chunkSize: int32 = chunkSizeRaw
    if chunkSize <= 0:
        chunkSize = len(text)
    let n: int32 = len(text)
    var start: int32 = 0
    while start < n:
        var end: int32 = start + chunkSize
        if end >= n:
            add(out, strings.sliceBytes(text, start, n - start))
            break
        while end < n:
            var slashRun: int32 = 0
            var j: int32 = end - 1
            while j >= start && text[j] == '\\':
                slashRun = slashRun + 1
                j = j - 1
            if slashRun % 2 == 0:
                break
            end = end + 1
        if end > n:
            end = n
        add(out, strings.sliceBytes(text, start, end - start))
        start = end
    return out

fn tooling_renderRawLines(lines: str[], trailingNewline: bool): str =
    if trailingNewline:
        return strutil.join(lines, "\n") + "\n"
    return strutil.join(lines, "\n")

fn tooling_joinFragments(parts: str[]): str =
    return strutil.join(parts, "")

fn tooling_embeddedScriptEncoded(root: str, id: str): str =
    return tooling_escapeEmbeddedMapString(tooling_embeddedScriptText(root, id))

fn tooling_renderEmbeddedMapText(root: str): str =
    let ids: str[] = tinv.toolingCollectScripts(root)
    var parts: str[] = []
    add(parts, "# Auto-generated embedded tooling command payload map.\n")
    add(parts, "# Source: former src/tooling/tooling_inline/*.inline + src/tooling/verify_inline/*.inline.\n")
    add(parts, "# Generated by cheng_tooling embedded-map-rewrite.\n")
    add(parts, "# Do not edit manually.\n\n")
    add(parts, "import std/strutils as strutil\n\n")
    add(parts, "fn toolingEmbeddedScriptIds(): str[] =\n")
    add(parts, "    var out: str[] = []\n")
    for i in 0..<ids.len:
        add(parts, "    add(out, \"" + ids[i] + "\")\n")
    add(parts, "    return out\n\n")
    add(parts, "fn toolingEmbeddedJoinChunks(chunks: str[]): str =\n")
    add(parts, "    return strutil.join(chunks, \"\")\n\n")
    add(parts, "fn toolingEmbeddedJoinLines(lines: str[]): str =\n")
    add(parts, "    return strutil.join(lines, \"\\n\")\n\n")
    add(parts, "fn toolingEmbeddedRenderLines(lines: str[], trailingNewline: bool): str =\n")
    add(parts, "    let joined: str = toolingEmbeddedJoinLines(lines)\n")
    add(parts, "    if trailingNewline:\n")
    add(parts, "        return joined + \"\\n\"\n")
    add(parts, "    return joined\n\n")
    add(parts, "fn toolingEmbeddedScriptBody(id: str): str =\n")
    for i in 0..<ids.len:
        add(parts, "    if id == \"" + ids[i] + "\":\n")
        if len(tooling_embeddedScriptEncoded(root, ids[i])) <= 1800:
            add(parts, "        return \"" + tooling_embeddedScriptEncoded(root, ids[i]) + "\"\n")
        else:
            # Keep embedded scripts chunk-joined so regenerated maps stay rebuildable.
            let encodedChunks: str[] = tooling_splitEmbeddedEscapedChunks(tooling_embeddedScriptEncoded(root, ids[i]), 1800)
            add(parts, "        var chunks: str[] = []\n")
            for j in 0..<encodedChunks.len:
                add(parts, "        add(chunks, \"" + encodedChunks[j] + "\")\n")
            add(parts, "        return toolingEmbeddedJoinChunks(chunks)\n")
    add(parts, "    return \"\"\n")
    return tooling_joinFragments(parts)

fn tooling_embeddedNativeForwardScript(subcmd: str): str =
    return tembeddispatch.toolingEmbeddedDispatchNativeForwardScript(subcmd)

fn tooling_normalizeEmbeddedScriptText(id: str, raw: str): str =
    return tembeddispatch.toolingEmbeddedDispatchNormalizeScriptText(id, raw)

fn tooling_embeddedScriptText(root: str, id: str): str =
    return tembeddispatch.toolingEmbeddedScriptText(root, id)

fn tooling_patchEmbeddedRuntimeDefaults(scriptId: str, scriptText: str): str =
    return tproofopt.toolingEmbeddedPatchProofOptFamily(
        scriptId,
        strutil.replace(
            tembedrtdefaults.toolingEmbeddedPatchRuntimeDefaults(scriptId, scriptText),
            "root=\"$(CDPATH= cd -- \"$(dirname -- \"$0\")/../../..\" && pwd)\"",
            tooling_runtimeProofShellSetup("", scriptId)
        )
    )

fn tooling_pathExists(path: str): bool =
    return tpathhelp.toolingPathExists(path)

fn tooling_fileExistsNonEmpty(pathRaw: str): bool =
    return tpathhelp.toolingFileExistsNonEmpty(pathRaw)

fn tooling_fileIsNewer(root: str, lhsRaw: str, rhsRaw: str): bool =
    return tpathhelp.toolingFileIsNewer(root, lhsRaw, rhsRaw)

fn tooling_printExecOutput(result: os.ExecCmdResult) =
    if tooling_strNonEmpty(os.execCmdResultOutput(result)):
        os.write(os.get_stdout(), os.execCmdResultOutput(result))

fn tooling_exec(root: str, command: str): os.ExecCmdResult =
    let opts: uint64 = uint64(7)
    return os.execCmdEx(command, opts, root)

fn tooling_execAndPrint(root: str, command: str): int32 =
    let res: os.ExecCmdResult = tooling_exec(root, command)
    tooling_printExecOutput(res)
    return os.execCmdResultExitCode(res)

fn tooling_execFileDirect(filePath: str, argv: str[], envOverrides: str[],
                          workingDir: str, timeoutSec: int32,
                          capturePreferred: bool): os.ExecCmdResult =
    if capturePreferred:
        return hostos.execFileCapture(filePath, argv, envOverrides, workingDir, true, timeoutSec)
    let directRc: int32 = hostos.execFileStatus(filePath, argv, envOverrides, workingDir, timeoutSec)
    if directRc == 0 || directRc == 124:
        return os.ExecCmdResult(output: "", exitCode: directRc)
    return hostos.execFileCapture(filePath, argv, envOverrides, workingDir, true, timeoutSec)

fn tooling_commandPathCached(nameRaw: str): str =
    if !tooling_strNonEmpty(strutil.strip(nameRaw)):
        return ""
    for i in 0..<tooling_commandPathCacheNames.len:
        if tooling_strEq(tooling_commandPathCacheNames[i], strutil.strip(nameRaw)):
            if i < tooling_commandPathCacheValues.len:
                return tooling_commandPathCacheValues[i]
            return ""
    return ""

fn tooling_commandPathCachePut(nameRaw: str, pathRaw: str) =
    if !tooling_strNonEmpty(strutil.strip(nameRaw)):
        return
    for i in 0..<tooling_commandPathCacheNames.len:
        if tooling_strEq(tooling_commandPathCacheNames[i], strutil.strip(nameRaw)):
            if i < tooling_commandPathCacheValues.len:
                tooling_commandPathCacheValues[i] = strutil.strip(pathRaw)
            return
    add(tooling_commandPathCacheNames, strutil.strip(nameRaw))
    add(tooling_commandPathCacheValues, strutil.strip(pathRaw))

fn tooling_resolveCommandPathProbe(root: str, name: str): os.ExecCmdResult =
    return tooling_exec(root, "command -v " + tooling_shellQuote(name) + " 2>/dev/null")

fn tooling_resolveCommandPath(root: str, nameRaw: str): str =
    if !tooling_strNonEmpty(strutil.strip(nameRaw)):
        return ""
    if tooling_strNonEmpty(tooling_commandPathCached(strutil.strip(nameRaw))):
        return tooling_commandPathCached(strutil.strip(nameRaw))
    if strutil.contains(strutil.strip(nameRaw), "/"):
        if tooling_isExecutable(root, tooling_pathAbsolute(root, strutil.strip(nameRaw))):
            tooling_commandPathCachePut(strutil.strip(nameRaw), tooling_pathAbsolute(root, strutil.strip(nameRaw)))
            return tooling_pathAbsolute(root, strutil.strip(nameRaw))
        tooling_commandPathCachePut(strutil.strip(nameRaw), "")
        return ""
    let probeRes: os.ExecCmdResult = tooling_resolveCommandPathProbe(root, strutil.strip(nameRaw))
    if os.execCmdResultExitCode(probeRes) != 0:
        tooling_commandPathCachePut(strutil.strip(nameRaw), "")
        return ""
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(probeRes))
    if rows.len <= 0:
        tooling_commandPathCachePut(strutil.strip(nameRaw), "")
        return ""
    tooling_commandPathCachePut(strutil.strip(nameRaw), strutil.strip(rows[0]))
    return strutil.strip(rows[0])

fn tooling_execProgramDirect(root: str, programName: str, argv: str[], envOverrides: str[],
                             workingDir: str, timeoutSec: int32,
                             capturePreferred: bool): os.ExecCmdResult =
    if !tooling_strNonEmpty(tooling_resolveCommandPath(root, programName)):
        return os.ExecCmdResult(output: "missing executable: " + programName + "\n", exitCode: 127)
    return tooling_execFileDirect(
        tooling_resolveCommandPath(root, programName),
        argv,
        envOverrides,
        workingDir,
        timeoutSec,
        capturePreferred
    )

fn tooling_clampCompileTimeoutSec(timeoutSecRaw: int32): int32 =
    var timeoutSec: int32 = timeoutSecRaw
    if timeoutSec < 1:
        timeoutSec = 60
    if timeoutSec > 60:
        timeoutSec = 60
    return timeoutSec

fn tooling_timeoutContextPreferExternal(contextRaw: str): bool =
    if !tooling_strNonEmpty(strutil.strip(contextRaw)):
        return false
    return tooling_strContains(strutil.strip(contextRaw), "compile_exe")

fn tooling_timeoutContextLabel(contextRaw: str): str =
    if tooling_strNonEmpty(strutil.strip(contextRaw)):
        return strutil.strip(contextRaw)
    return "tooling_command"

fn tooling_wrapCommandWithExternalTimeoutTemplate(): str =
    return (
        "__ct_timeout=__CT_TIMEOUT__ ; " +
        "__ct_diag=${TOOLING_TIMEOUT_DIAG:-1} ; " +
        "__ct_root=__CT_ROOT_Q__ ; " +
        "__ct_diag_dir=${TOOLING_TIMEOUT_DIAG_DIR:-$__ct_root/chengcache/backend_timeout_diag} ; " +
        "__ct_diag_secs=${TOOLING_TIMEOUT_DIAG_SECONDS:-$__ct_timeout} ; " +
        "__ct_diag_summary=${TOOLING_TIMEOUT_DIAG_SUMMARY:-1} ; " +
        "__ct_diag_top=${TOOLING_TIMEOUT_DIAG_SUMMARY_TOP:-12} ; " +
        "__ct_ctx=__CT_CTX_Q__ ; " +
        "TOOLING_TIMEOUT_LABEL=__CT_CTX_Q__ ; " +
        "__ct_label=\"$TOOLING_TIMEOUT_LABEL\" ; " +
        "if [ -z \"$__ct_label\" ]; then __ct_label=$__ct_ctx; fi ; " +
        "if [ -z \"$__ct_label\" ]; then __ct_label=\"tooling_command\"; fi ; " +
        "__ct_start=$(date +%s 2>/dev/null || echo 0) ; " +
        "__ct_diag_file='' ; " +
        "__ct_diag_target_pid='' ; " +
        "__ct_label_safe=$(printf '%s' \"$__ct_label\" | tr -c 'A-Za-z0-9_.:-' '_') ; " +
        "if [ -z \"$__ct_label_safe\" ]; then __ct_label_safe=tooling_command ; fi ; " +
        "case \"$__ct_diag_secs\" in ''|*[!0-9]*) __ct_diag_secs=\"$__ct_timeout\" ;; esac ; " +
        "if [ \"$__ct_diag_secs\" -lt 1 ] 2>/dev/null; then __ct_diag_secs=\"$__ct_timeout\" ; fi ; " +
        "__ct_timeout_handler() { " +
        "  if [ \"$__ct_diag\" != \"0\" ] && command -v sample >/dev/null 2>&1; then " +
        "    mkdir -p \"$__ct_diag_dir\" >/dev/null 2>&1 || true ; " +
        "    __ct_stamp=$(date +%Y%m%dT%H%M%S 2>/dev/null || echo timeout) ; " +
        "    __ct_diag_file=\"$__ct_diag_dir/${__ct_stamp}_${__ct_label_safe}.sample.txt\" ; " +
        "    __ct_target=\"$__ct_pid\" ; " +
        "    if command -v ps >/dev/null 2>&1 && command -v awk >/dev/null 2>&1; then " +
        "      __ct_cur=\"$__ct_pid\" ; __ct_scan=0 ; " +
        "      while [ \"$__ct_scan\" -lt 32 ]; do " +
        "        __ct_next=$(ps -Ao pid=,ppid= 2>/dev/null | awk -v parent=\"$__ct_cur\" '$2==parent {child=$1} END {print child}') ; " +
        "        case \"$__ct_next\" in ''|*[!0-9]*) break ;; esac ; " +
        "        __ct_target=\"$__ct_next\" ; __ct_cur=\"$__ct_next\" ; __ct_scan=$((__ct_scan + 1)) ; " +
        "      done ; " +
        "    fi ; " +
        "    __ct_diag_target_pid=\"$__ct_target\" ; " +
        "    sample \"$__ct_target\" \"$__ct_diag_secs\" -file \"$__ct_diag_file\" >/dev/null 2>&1 || true ; " +
        "  fi ; " +
        "  if [ -n \"$__ct_pgid\" ]; then kill -TERM -\"$__ct_pgid\" >/dev/null 2>&1 || true ; fi ; " +
        "  kill -TERM \"$__ct_pid\" >/dev/null 2>&1 || true ; " +
        "  sleep 1 ; " +
        "  if [ -n \"$__ct_pgid\" ] && kill -0 -\"$__ct_pgid\" >/dev/null 2>&1; then kill -KILL -\"$__ct_pgid\" >/dev/null 2>&1 || true ; fi ; " +
        "  if kill -0 \"$__ct_pid\" >/dev/null 2>&1; then kill -KILL \"$__ct_pid\" >/dev/null 2>&1 || true ; fi ; " +
        "  __ct_elapsed=0 ; if [ \"$__ct_start\" -gt 0 ]; then __ct_end=$(date +%s 2>/dev/null || echo 0) ; if [ \"$__ct_end\" -gt \"$__ct_start\" ]; then __ct_elapsed=$((__ct_end - __ct_start)) ; fi ; fi ; " +
        "  echo \"cheng_tooling_timeout=1 timeout_sec=$__ct_timeout elapsed_sec=$__ct_elapsed child_pid=$__ct_pid sample_pid=$__ct_diag_target_pid label=$__ct_label_safe\" >&2 ; " +
        "  if [ -n \"$__ct_diag_file\" ]; then echo \"cheng_tooling_timeout_diag=$__ct_diag_file\" >&2 ; fi ; " +
        "  if [ \"$__ct_diag_summary\" != \"0\" ] && [ -n \"$__ct_diag_file\" ] && [ -s \"$__ct_diag_file\" ]; then " +
        "    __ct_diag_script=\"$__ct_root/src/tooling/cheng_tooling_embedded_scripts/summarize_timeout_diag.sh\" ; " +
        "    if [ -f \"$__ct_diag_script\" ]; then sh \"$__ct_diag_script\" --file:\"$__ct_diag_file\" --top:\"$__ct_diag_top\" >&2 || true ; fi ; " +
        "  fi ; " +
        "  exit 124 ; " +
        "} ; " +
        "trap '__ct_timeout_handler' TERM ; " +
        "if command -v setsid >/dev/null 2>&1; then setsid sh -c __CT_COMMAND_Q__ & " +
        "else sh -c __CT_COMMAND_Q__ & fi ; " +
        "__ct_pid=$! ; " +
        "__ct_pgid=$(ps -o pgid= -p \"$__ct_pid\" 2>/dev/null | tr -d '[:space:]') ; " +
        "case \"$__ct_pgid\" in ''|*[!0-9]*) __ct_pgid='' ;; esac ; " +
        "wait \"$__ct_pid\" ; __ct_rc=$? ; " +
        "trap - TERM ; " +
        "if [ \"$__ct_rc\" -gt 255 ]; then __ct_rc=1 ; fi ; " +
        "exit \"$__ct_rc\""
    )

fn tooling_wrapCommandWithExternalTimeoutScript(root: str, timeoutSec: int32,
                                                command: str, contextRaw: str): str =
    let ctxLabel: str = tooling_timeoutContextLabel(contextRaw)
    var script: str = tooling_wrapCommandWithExternalTimeoutTemplate()
    script = strutil.replace(script, "__CT_TIMEOUT__", intToStr(timeoutSec))
    script = strutil.replace(script, "__CT_ROOT_Q__", tooling_shellQuote(root))
    script = strutil.replace(script, "__CT_CTX_Q__", tooling_shellQuote(ctxLabel))
    script = strutil.replace(script, "__CT_COMMAND_Q__", tooling_shellQuote(command))
    return script

fn tooling_wrapCommandWithExternalTimeoutWithContext(root: str, timeoutSec: int32,
                                                     timeoutBin: str, command: str,
                                                     contextRaw: str): str =
    let killAfterSec: int32 = timeoutSec + 5
    return timeoutBin + " -k " + intToStr(killAfterSec) + "s " + intToStr(timeoutSec) +
           "s sh -c " + tooling_shellQuote(
               tooling_wrapCommandWithExternalTimeoutScript(root, timeoutSec, command, contextRaw)
           )

fn tooling_timeoutContextEffective(contextRaw: str): str =
    if tooling_strNonEmpty(contextRaw):
        return contextRaw
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("TOOLING_TIMEOUT_CONTEXT", ""))):
        return strutil.strip(os.getEnvDefault("TOOLING_TIMEOUT_CONTEXT", ""))
    return "tooling_command"

fn tooling_timeoutShouldUseExternal(contextRaw: str): bool =
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("TOOLING_TIMEOUT_USE_EXTERNAL", ""))):
        return tooling_isTrue(strutil.strip(os.getEnvDefault("TOOLING_TIMEOUT_USE_EXTERNAL", "")))
    if tooling_isTrue(os.getEnvDefault("TOOLING_TIMEOUT_USE_POLL", "0")):
        return false
    return tooling_timeoutContextPreferExternal(contextRaw)

fn tooling_timeoutNoOrphanText(): str =
    return tooling_isTrue(os.getEnvDefault("TOOLING_TIMEOUT_NO_ORPHAN", "1")) ? "1" : "0"

fn tooling_timeoutDrainSecDefault(): int32 =
    var drainSec: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_TIMEOUT_NO_ORPHAN_DRAIN_SEC", ""), 1)
    if drainSec < 0:
        return 0
    return drainSec

fn tooling_timeoutDrainMaxLoopsDefault(): int32 =
    var drainMaxLoops: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_TIMEOUT_NO_ORPHAN_DRAIN_MAX_LOOPS", ""), 8)
    if drainMaxLoops < 1:
        return 1
    return drainMaxLoops

fn tooling_wrapCommandWithTimeoutTemplate(): str =
    return (
        "__ct_timeout=__CT_TIMEOUT__ ; " +
        "__ct_no_orphan=__CT_NO_ORPHAN__ ; " +
        "__ct_drain_sec=__CT_DRAIN_SEC__ ; " +
        "__ct_drain_max=__CT_DRAIN_MAX__ ; " +
        "__ct_diag=${TOOLING_TIMEOUT_DIAG:-1} ; " +
        "__ct_root=__CT_ROOT_Q__ ; " +
        "__ct_diag_dir=${TOOLING_TIMEOUT_DIAG_DIR:-$__ct_root/chengcache/backend_timeout_diag} ; " +
        "__ct_diag_secs=${TOOLING_TIMEOUT_DIAG_SECONDS:-$__ct_timeout} ; " +
        "__ct_diag_summary=${TOOLING_TIMEOUT_DIAG_SUMMARY:-1} ; " +
        "__ct_diag_top=${TOOLING_TIMEOUT_DIAG_SUMMARY_TOP:-12} ; " +
        "__ct_ctx=__CT_CTX_Q__ ; " +
        "TOOLING_TIMEOUT_LABEL=__CT_CTX_Q__ ; " +
        "__ct_label=\"$TOOLING_TIMEOUT_LABEL\" ; " +
        "if [ -z \"$__ct_label\" ]; then __ct_label=$__ct_ctx; fi ; " +
        "if [ -z \"$__ct_label\" ]; then __ct_label=\"tooling_command\"; fi ; " +
        "__ct_start=$(date +%s 2>/dev/null || echo 0) ; " +
        "__ct_self_pgid=$(ps -o pgid= -p $$ 2>/dev/null | tr -d '[:space:]') ; " +
        "case \"$__ct_self_pgid\" in ''|*[!0-9]*) __ct_self_pgid='' ;; esac ; " +
        "if command -v setsid >/dev/null 2>&1; then setsid sh -c __CT_COMMAND_Q__ & " +
        "else sh -c __CT_COMMAND_Q__ & fi ; " +
        "__ct_pid=$! ; " +
        "__ct_pgid=$(ps -o pgid= -p \"$__ct_pid\" 2>/dev/null | tr -d '[:space:]') ; " +
        "case \"$__ct_pgid\" in ''|*[!0-9]*) __ct_pgid='' ;; esac ; " +
        "if [ -n \"$__ct_self_pgid\" ] && [ \"$__ct_pgid\" = \"$__ct_self_pgid\" ]; then __ct_pgid='' ; fi ; " +
        "__ct_diag_file='' ; " +
        "__ct_diag_target_pid='' ; " +
        "__ct_label_safe=$(printf '%s' \"$__ct_label\" | tr -c 'A-Za-z0-9_.:-' '_') ; " +
        "if [ -z \"$__ct_label_safe\" ]; then __ct_label_safe=tooling_command ; fi ; " +
        "case \"$__ct_diag_secs\" in ''|*[!0-9]*) __ct_diag_secs=\"$__ct_timeout\" ;; esac ; " +
        "if [ \"$__ct_diag_secs\" -lt 1 ] 2>/dev/null; then __ct_diag_secs=\"$__ct_timeout\" ; fi ; " +
        "__ct_deadline=$((__ct_start + __ct_timeout)) ; " +
        "__ct_timedout=0 ; " +
        "while kill -0 \"$__ct_pid\" >/dev/null 2>&1; do " +
        "  __ct_now=$(date +%s 2>/dev/null || echo 0) ; " +
        "  if [ \"$__ct_now\" -gt 0 ] && [ \"$__ct_start\" -gt 0 ] && [ \"$__ct_now\" -ge \"$__ct_deadline\" ]; then __ct_timedout=1 ; break ; fi ; " +
        "  sleep 0.1 ; " +
        "done ; " +
        "if [ \"$__ct_timedout\" = \"1\" ]; then " +
        "  if [ \"$__ct_diag\" != \"0\" ] && command -v sample >/dev/null 2>&1; then " +
        "    mkdir -p \"$__ct_diag_dir\" >/dev/null 2>&1 || true ; " +
        "    if [ -z \"$__ct_diag_file\" ]; then __ct_stamp=$(date +%Y%m%dT%H%M%S 2>/dev/null || echo timeout) ; __ct_diag_file=\"$__ct_diag_dir/${__ct_stamp}_${__ct_label_safe}.sample.txt\" ; fi ; " +
        "    __ct_target=\"$__ct_pid\" ; " +
        "    if command -v ps >/dev/null 2>&1 && command -v awk >/dev/null 2>&1; then " +
        "      __ct_cur=\"$__ct_pid\" ; __ct_scan=0 ; " +
        "      while [ \"$__ct_scan\" -lt 32 ]; do " +
        "        __ct_next=$(ps -Ao pid=,ppid= 2>/dev/null | awk -v parent=\"$__ct_cur\" '$2==parent {child=$1} END {print child}') ; " +
        "        case \"$__ct_next\" in ''|*[!0-9]*) break ;; esac ; " +
        "        __ct_target=\"$__ct_next\" ; __ct_cur=\"$__ct_next\" ; __ct_scan=$((__ct_scan + 1)) ; " +
        "      done ; " +
        "    fi ; " +
        "    __ct_diag_target_pid=\"$__ct_target\" ; " +
        "    sample \"$__ct_target\" \"$__ct_diag_secs\" -file \"$__ct_diag_file\" >/dev/null 2>&1 || true ; " +
        "  fi ; " +
        "  if [ -n \"$__ct_pgid\" ]; then kill -TERM -\"$__ct_pgid\" >/dev/null 2>&1 || true ; fi ; " +
        "  kill -TERM \"$__ct_pid\" >/dev/null 2>&1 || true ; " +
        "  sleep 1 ; " +
        "  if [ -n \"$__ct_pgid\" ] && kill -0 -\"$__ct_pgid\" >/dev/null 2>&1; then kill -KILL -\"$__ct_pgid\" >/dev/null 2>&1 || true ; fi ; " +
        "  if kill -0 \"$__ct_pid\" >/dev/null 2>&1; then kill -KILL \"$__ct_pid\" >/dev/null 2>&1 || true ; fi ; " +
        "  __ct_drain_loops=0 ; " +
        "  if [ \"$__ct_no_orphan\" = \"1\" ]; then " +
        "    __ct_now=$(date +%s 2>/dev/null || echo 0) ; __ct_drain_end=$((__ct_now + __ct_drain_sec)) ; " +
        "    while kill -0 \"$__ct_pid\" >/dev/null 2>&1; do " +
        "      __ct_now=$(date +%s 2>/dev/null || echo 0) ; " +
        "      if [ \"$__ct_now\" -gt 0 ] && [ \"$__ct_drain_sec\" -gt 0 ] && [ \"$__ct_now\" -ge \"$__ct_drain_end\" ]; then break ; fi ; " +
        "      if [ \"$__ct_drain_loops\" -ge \"$__ct_drain_max\" ]; then break ; fi ; " +
        "      __ct_drain_loops=$((__ct_drain_loops + 1)) ; " +
        "      if [ -n \"$__ct_pgid\" ]; then kill -KILL -\"$__ct_pgid\" >/dev/null 2>&1 || true ; fi ; " +
        "      kill -KILL \"$__ct_pid\" >/dev/null 2>&1 || true ; " +
        "      sleep 0.2 ; " +
        "    done ; " +
        "  fi ; " +
        "  wait \"$__ct_pid\" >/dev/null 2>&1 || true ; " +
        "  if [ \"$__ct_diag\" != \"0\" ]; then " +
        "    __ct_elapsed=0 ; if [ \"$__ct_start\" -gt 0 ]; then __ct_end=$(date +%s 2>/dev/null || echo 0) ; if [ \"$__ct_end\" -gt \"$__ct_start\" ]; then __ct_elapsed=$((__ct_end - __ct_start)) ; fi ; fi ; " +
        "    echo \"cheng_tooling_timeout=1 timeout_sec=$__ct_timeout elapsed_sec=$__ct_elapsed child_pid=$__ct_pid sample_pid=$__ct_diag_target_pid no_orphan=$__ct_no_orphan drain_sec=$__ct_drain_sec drain_loops=$__ct_drain_loops label=$__ct_label_safe\" >&2 ; " +
        "    if [ -n \"$__ct_diag_file\" ]; then echo \"cheng_tooling_timeout_diag=$__ct_diag_file\" >&2 ; fi ; " +
        "    if [ \"$__ct_diag_summary\" != \"0\" ] && [ -n \"$__ct_diag_file\" ] && [ -s \"$__ct_diag_file\" ]; then " +
        "      __ct_diag_script=\"$__ct_root/src/tooling/cheng_tooling_embedded_scripts/summarize_timeout_diag.sh\" ; " +
        "      if [ -f \"$__ct_diag_script\" ]; then sh \"$__ct_diag_script\" --file:\"$__ct_diag_file\" --top:\"$__ct_diag_top\" >&2 || true ; fi ; " +
        "    fi ; " +
        "  fi ; " +
        "  exit 124 ; " +
        "fi ; " +
        "wait \"$__ct_pid\" ; __ct_rc=$? ; " +
        "if [ \"$__ct_rc\" -gt 255 ]; then __ct_rc=1 ; fi ; " +
        "exit \"$__ct_rc\""
    )

fn tooling_wrapCommandWithTimeoutScript(root: str, timeoutSec: int32,
                                        command: str, contextRaw: str): str =
    let ctxLabel: str = tooling_timeoutContextEffective(contextRaw)
    var script: str = tooling_wrapCommandWithTimeoutTemplate()
    script = strutil.replace(script, "__CT_TIMEOUT__", intToStr(timeoutSec))
    script = strutil.replace(script, "__CT_NO_ORPHAN__", tooling_timeoutNoOrphanText())
    script = strutil.replace(script, "__CT_DRAIN_SEC__", intToStr(tooling_timeoutDrainSecDefault()))
    script = strutil.replace(script, "__CT_DRAIN_MAX__", intToStr(tooling_timeoutDrainMaxLoopsDefault()))
    script = strutil.replace(script, "__CT_ROOT_Q__", tooling_shellQuote(root))
    script = strutil.replace(script, "__CT_CTX_Q__", tooling_shellQuote(ctxLabel))
    script = strutil.replace(script, "__CT_COMMAND_Q__", tooling_shellQuote(command))
    return script

fn tooling_wrapCommandWithTimeoutWithContext(root: str, timeoutSecRaw: int32, command: str, contextRaw: str): str =
    if !tooling_strNonEmpty(command):
        return command
    var timeoutSec: int32 = timeoutSecRaw
    if timeoutSec <= 0:
        return command
    if tooling_isTrue(os.getEnvDefault("TOOLING_TIMEOUT_CONTEXT_DEBUG", "0")):
        tooling_printErr("tooling_wrapCommandWithTimeoutWithContext contextRaw=" + contextRaw +
                         " resolved=" + tooling_timeoutContextEffective(contextRaw))
    if tooling_timeoutShouldUseExternal(tooling_timeoutContextEffective(contextRaw)):
        if tooling_strNonEmpty(tooling_timeoutCommand(root)):
            return tooling_wrapCommandWithExternalTimeoutWithContext(
                root,
                timeoutSec,
                tooling_timeoutCommand(root),
                command,
                tooling_timeoutContextEffective(contextRaw)
            )
    return tooling_wrapCommandWithTimeoutScript(root, timeoutSec, command, tooling_timeoutContextEffective(contextRaw))

fn tooling_scriptShell(root: str, scriptPath: str): str =
    return tpathhelp.toolingScriptShell(root, scriptPath)

fn tooling_scriptShellFromText(scriptText: str): str =
    return tpathhelp.toolingScriptShellFromText(scriptText)

fn tooling_embeddedArgv0(root: str, scriptId: str): str =
    let _scriptIdUnused: str = scriptId
    let forcedRaw: str = strutil.strip(os.getEnvDefault("TOOLING_SELF_BIN", ""))
    if tooling_strNonEmpty(forcedRaw):
        let forcedAbs: str = tooling_pathAbsolute(root, forcedRaw)
        if tooling_strNonEmpty(forcedAbs) && os.fileExists(forcedAbs):
            return forcedAbs
    let canonical: str = tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling")
    if tooling_strNonEmpty(canonical) && os.fileExists(canonical):
        return canonical
    let raw0: str = strutil.strip(tooling_paramStr(0))
    if tooling_strNonEmpty(raw0) && !tooling_strContains(raw0, "cheng_tooling_embedded:"):
        var abs0: str = raw0
        if !os.isAbsolute(abs0):
            abs0 = tooling_pathAbsolute(root, abs0)
        if tooling_strNonEmpty(abs0) && os.fileExists(abs0):
            return abs0
    return "cheng_tooling"

fn tooling_embeddedScriptPreferFreshCache(scriptId: str): bool =
    return tembedfresh.toolingEmbeddedScriptPreferFreshCache(scriptId)

fn tooling_mkdirP(root: str, path: str): bool =
    if !tooling_strNonEmpty(path):
        return false
    if os.dirExists(path):
        return true
    let result: os.ExecCmdResult = tooling_exec(root, "mkdir -p " + tooling_shellQuote(path))
    tooling_printExecOutput(result)
    return os.execCmdResultExitCode(result) == 0

fn tooling_tryMkdirP(root: str, path: str) =
    if !tooling_strNonEmpty(path):
        return
    let created: bool = tooling_mkdirP(root, path)
    if created:
        return

fn tooling_writeTextFileViaShell(root: str, path: str, text: str): bool =
    # Avoid direct os.writeFile on large embedded payloads in multicall path;
    # shell heredoc write has proven stable across stage0 variants.
    if !tooling_strNonEmpty(path):
        return false
    if tooling_strNonEmpty(os.parentDir(path)):
        if !tooling_mkdirP(root, os.parentDir(path)):
            return false
    let res: os.ExecCmdResult =
        tooling_exec(
            root,
            "cat > " + tooling_shellQuote(path) + " <<'" + (
                strutil.contains(text, "__CHENG_TOOLING_EOF__") ?
                    (
                        strutil.contains(text, "__CHENG_TOOLING_EOF_X__") ?
                            "__CHENG_TOOLING_EOF_XX__" :
                            "__CHENG_TOOLING_EOF_X__"
                    ) :
                    "__CHENG_TOOLING_EOF__"
            ) + "'\n" +
            text + "\n" +
            (
                strutil.contains(text, "__CHENG_TOOLING_EOF__") ?
                    (
                        strutil.contains(text, "__CHENG_TOOLING_EOF_X__") ?
                            "__CHENG_TOOLING_EOF_XX__" :
                            "__CHENG_TOOLING_EOF_X__"
                    ) :
                    "__CHENG_TOOLING_EOF__"
            ) + "\n"
        )
    if os.execCmdResultExitCode(res) != 0:
        tooling_printExecOutput(res)
        return false
    return true

fn tooling_programBaseName(): str =
    return tpathhelp.toolingProgramBaseName(tooling_paramStr(0))

fn tooling_fileName(pathRaw: str): str =
    return tpathhelp.toolingFileName(pathRaw)

fn tooling_joinPathSimple(baseRaw: str, relRaw: str): str =
    return tpathhelp.toolingJoinPathSimple(baseRaw, relRaw)

fn tooling_pathAbsolute(root: str, raw: str): str =
    return tpathhelp.toolingPathAbsolute(root, raw)

fn tooling_isTrue(raw: str): bool =
    if !tooling_strNonEmpty(strutil.strip(raw)):
        return false
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "1") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "true") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "yes") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "on"):
        return true
    return false

fn tooling_exitKind(rc: int32): str =
    if rc == 124 || rc == 143:
        return "timeout"
    if rc == 126:
        return "not_executable"
    if rc == 127:
        return "missing_executable"
    if rc == 139:
        return "segfault"
    if rc == 223:
        return "deterministic_exit_223"
    if rc >= 129 && rc <= 192:
        return "signal"
    if rc == 0:
        return "ok"
    return "error"

fn tooling_exitHint(rc: int32): str =
    if rc == 223:
        return "child_exited_223_directly_non_posix_signal"
    return ""

fn tooling_isCrashExitCode(rc: int32): bool =
    if rc == 132 || rc == 133 || rc == 134 || rc == 135 ||
       rc == 136 || rc == 137 || rc == 139:
        return true
    return false

fn tooling_isCompileCrashExitCode(rc: int32): bool =
    if rc == 138 || rc == 139:
        return true
    return false

fn tooling_commandTailLineCount(tailLines: int32): int32 =
    if tailLines < 1:
        return 80
    return tailLines

fn tooling_printCommandLogTail(root: str, logPathRaw: str, labelRaw: str, tailLines: int32) =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, logPathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, logPathRaw)):
        if tooling_strNonEmpty(labelRaw):
            tooling_printErr(
                "cheng_tooling: no " + labelRaw + " log for command: " +
                tooling_pathAbsolute(root, logPathRaw)
            )
        return
    let res: os.ExecCmdResult =
        tooling_exec(
            root,
            "tail -n " + intToStr(tooling_commandTailLineCount(tailLines)) + " " +
            tooling_shellQuote(tooling_pathAbsolute(root, logPathRaw)) + " >&2"
        )
    tooling_printExecOutput(res)

fn tooling_compileCrashReportDir(root: str): str =
    if !tooling_strNonEmpty(strutil.strip(os.getEnvDefault("TOOLING_COMPILE_CRASH_REPORT_DIR", "artifacts/tooling_compile_crash"))):
        return os.joinPath(root, "artifacts/tooling_compile_crash")
    return tooling_pathAbsolute(
        root,
        strutil.strip(os.getEnvDefault("TOOLING_COMPILE_CRASH_REPORT_DIR", "artifacts/tooling_compile_crash"))
    )

fn tooling_compileCrashReportScopeText(scope: str): str =
    if tooling_strNonEmpty(strutil.strip(scope)):
        return strutil.strip(scope)
    return "compile"

fn tooling_compileCrashReportClippedOutput(output: str): str =
    var parts: str[] = []
    let lines: str[] = tooling_splitLines(output)
    var i: int32 = 0
    for _ in 0..<len(lines):
        if i >= 200:
            break
        add(parts, lines[i] + "\n")
        i = i + 1
    if parts.len <= 0:
        return len(output) > 24000 ? strings.sliceBytes(output, 0, 24000) : output
    if len(tooling_joinFragments(parts)) > 24000:
        return strings.sliceBytes(tooling_joinFragments(parts), 0, 24000)
    return tooling_joinFragments(parts)

fn tooling_compileCrashReportBody(scope: str, rc, attempt, maxAttempts: int32,
                                  command, output: str): str =
    return "scope=" + tooling_compileCrashReportScopeText(scope) + "\n" +
        "rc=" + intToStr(rc) + "\n" +
        "kind=" + tooling_exitKind(rc) + "\n" +
        (tooling_strNonEmpty(tooling_exitHint(rc)) ? "hint=" + tooling_exitHint(rc) + "\n" : "") +
        "attempt=" + intToStr(attempt) + "\n" +
        "max_attempts=" + intToStr(maxAttempts) + "\n" +
        "timestamp_monotonic_ns=" + tooling_nowNonceText() + "\n" +
        "env_summary=inline_in_command\n" +
        "command=" + command + "\n" +
        "output_line_limit=200\n" +
        "\n[output_head]\n" + tooling_compileCrashReportClippedOutput(output)

fn tooling_writeCompileCrashReport(root, scope: str, rc, attempt, maxAttempts: int32, command, output: str): str =
    if !tooling_mkdirP(root, tooling_compileCrashReportDir(root)):
        return ""
    let path: str = os.joinPath(
        tooling_compileCrashReportDir(root),
        tooling_compileCrashReportScopeText(scope) + "." + tooling_nowNonceText() + ".log"
    )
    if !tooling_writeTextFileViaShell(root, path, tooling_compileCrashReportBody(scope, rc, attempt, maxAttempts, command, output)):
        return ""
    return path

fn tooling_parseInt32Default(raw: str, defaultValue: int32): int32 =
    if !tooling_strNonEmpty(strutil.strip(raw)):
        return defaultValue
    let n: int32 = len(strutil.strip(raw))
    var neg: bool = false
    var i: int32 = 0
    if strutil.strip(raw)[0] == '-':
        neg = true
        i = 1
    if i >= n:
        return defaultValue
    var value: int64 = 0
    for _ in i..<n:
        let c: char = strutil.strip(raw)[i]
        if c < '0' || c > '9':
            return defaultValue
        value = value * int64(10) + int64(int32(c) - int32('0'))
        i = i + 1
    if neg:
        value = int64(0) - value
    return int32(value)

fn tooling_isDigitsColonDash(raw: str): bool =
    if !tooling_strNonEmpty(strutil.strip(raw)):
        return false
    let n: int32 = len(strutil.strip(raw))
    var i: int32 = 0
    while i < n:
        let c: char = strutil.strip(raw)[i]
        if c != ':' && c != '-' && (c < '0' || c > '9'):
            return false
        i = i + 1
    return true

fn tooling_sanitizeShellSafeToken(root: str, raw: str): str =
    if !tooling_strNonEmpty(strutil.strip(raw)):
        return ""
    let res: os.ExecCmdResult =
        tooling_exec(
            root,
            "printf '%s' " + tooling_shellQuote(strutil.strip(raw)) +
            " | tr -c 'A-Za-z0-9._-' '_' | tr -s '_'"
        )
    if os.execCmdResultExitCode(res) != 0:
        return ""
    return strutil.strip(os.execCmdResultOutput(res))

fn tooling_parseTimingRowField(root: str, timingPathRaw: str, rowRaw: str, field: int32): str =
    if !tooling_strNonEmpty(strutil.strip(timingPathRaw)) || !tooling_fileExistsNonEmpty(strutil.strip(timingPathRaw)):
        return ""
    if !tooling_strNonEmpty(strutil.strip(rowRaw)) || field <= 0:
        return ""
    let res: os.ExecCmdResult =
        tooling_exec(
            root,
            "awk -F '\t' '$1==\"" + strutil.strip(rowRaw) + "\" {v=$" + intToStr(field) + "} END{print v}' " +
            tooling_shellQuote(strutil.strip(timingPathRaw)) + " 2>/dev/null || true"
        )
    return strutil.strip(os.execCmdResultOutput(res))

fn tooling_strContains(text: str, needle: str): bool =
    if !tooling_strNonEmpty(text) || !tooling_strNonEmpty(needle):
        return false
    return strutil.contains(text, needle)

fn tooling_maybeAppendFlag(flags: str, flag: str): str =
    if !tooling_strNonEmpty(flag):
        return tooling_trimAsciiSpace(flags)
    if tooling_strContains(tooling_trimAsciiSpace(flags), flag):
        return tooling_trimAsciiSpace(flags)
    if !tooling_strNonEmpty(tooling_trimAsciiSpace(flags)):
        return flag
    return tooling_trimAsciiSpace(flags) + " " + flag

fn tooling_releaseLdflagsForTarget(flags: str, target: str): str =
    if tooling_strContains(strutil.toLowerAscii(tooling_trimAsciiSpace(target)), "darwin") ||
       tooling_strContains(strutil.toLowerAscii(tooling_trimAsciiSpace(target)), "apple-darwin"):
        if !(tooling_strEq(tooling_trimAsciiSpace(os.getEnvDefault("BACKEND_ALLOW_UUID", "0")), "1") ||
             tooling_strEq(strutil.toLowerAscii(tooling_trimAsciiSpace(os.getEnvDefault("BACKEND_ALLOW_UUID", "0"))), "true")):
            return tooling_maybeAppendFlag(
                tooling_maybeAppendFlag(tooling_trimAsciiSpace(flags), "-Wl,-no_uuid"),
                "-Wl,-no_adhoc_codesign"
            )
        return tooling_maybeAppendFlag(tooling_trimAsciiSpace(flags), "-Wl,-no_adhoc_codesign")
    return tooling_trimAsciiSpace(flags)

fn tooling_stripSuffix(text: str, suffix: str): str =
    if !tooling_strNonEmpty(text) || !tooling_strNonEmpty(suffix):
        return text
    let n: int32 = len(text)
    let m: int32 = len(suffix)
    if m > n:
        return text
    if !tooling_strEndsWith(text, suffix):
        return text
    return strings.sliceBytes(text, 0, n - m)

fn tooling_defaultCompileOut(root: str, inPath: str, outRaw: str, nameRaw: str,
                             emitMode: str): str =
    if tooling_strNonEmpty(outRaw):
        return tooling_pathAbsolute(root, outRaw)
    if tooling_strNonEmpty(nameRaw):
        if os.isAbsolute(strutil.strip(nameRaw)) || tooling_strContains(strutil.strip(nameRaw), "/") ||
           tooling_strContains(strutil.strip(nameRaw), "\\"):
            return tooling_pathAbsolute(root, strutil.strip(nameRaw))
        return os.joinPath(root, "artifacts/chengc/" + strutil.strip(nameRaw))
    if !tooling_strNonEmpty(tooling_stripSuffix(os.extractFilename(inPath), ".cheng")):
        if tooling_strEq(emitMode, "shared"):
            return os.joinPath(root, "artifacts/chengc/a.out.so")
        if tooling_strEq(emitMode, "static"):
            return os.joinPath(root, "artifacts/chengc/a.out.a")
        return os.joinPath(root, "artifacts/chengc/a.out")
    if tooling_strEq(emitMode, "shared"):
        if !tooling_strEndsWith(tooling_stripSuffix(os.extractFilename(inPath), ".cheng"), ".so") &&
           !tooling_strEndsWith(tooling_stripSuffix(os.extractFilename(inPath), ".cheng"), ".dylib"):
            return os.joinPath(root, "artifacts/chengc/" + tooling_stripSuffix(os.extractFilename(inPath), ".cheng") + ".so")
    elif tooling_strEq(emitMode, "static") &&
         !tooling_strEndsWith(tooling_stripSuffix(os.extractFilename(inPath), ".cheng"), ".a"):
        return os.joinPath(root, "artifacts/chengc/" + tooling_stripSuffix(os.extractFilename(inPath), ".cheng") + ".a")
    return os.joinPath(root, "artifacts/chengc/" + tooling_stripSuffix(os.extractFilename(inPath), ".cheng"))

fn tooling_nowMs(): int64 =
    let mt: monotimes.MonoTime = monotimes.getMonoTime()
    return monotimes.monoTimeNs(mt) / int64(1000000)

fn tooling_nowEpochMs(root: str): int64 =
    if tooling_nowEpochBaseReady:
        let deltaMs: int64 = tooling_nowMs() - tooling_nowEpochBaseMonoMs
        if deltaMs >= int64(0):
            return tooling_nowEpochBaseMs + deltaMs
    let res: os.ExecCmdResult = tooling_exec(root, "date +%s 2>/dev/null || echo 0")
    if os.execCmdResultExitCode(res) != 0:
        return int64(0)
    let secs: int32 = tooling_parseInt32Default(strutil.strip(os.execCmdResultOutput(res)), 0)
    if secs <= 0:
        return int64(0)
    tooling_nowEpochBaseReady = true
    tooling_nowEpochBaseMonoMs = tooling_nowMs()
    tooling_nowEpochBaseMs = int64(secs) * int64(1000)
    return tooling_nowEpochBaseMs

fn tooling_nowNonceText(): str =
    let mt: monotimes.MonoTime = monotimes.getMonoTime()
    return int64ToStr(monotimes.monoTimeNs(mt))

fn tooling_nowNonceValue(): int64 =
    let mt: monotimes.MonoTime = monotimes.getMonoTime()
    return monotimes.monoTimeNs(mt)

fn tooling_msToSecondsText(msRaw: int64): str =
    var ms: int64 = msRaw
    if ms < int64(0):
        ms = int64(0)
    let sec: int64 = ms / int64(1000)
    let rem: int64 = ms % int64(1000)
    if len(intToStr(int32(rem))) == 1:
        return intToStr(int32(sec)) + ".00" + intToStr(int32(rem))
    if len(intToStr(int32(rem))) == 2:
        return intToStr(int32(sec)) + ".0" + intToStr(int32(rem))
    return intToStr(int32(sec)) + "." + intToStr(int32(rem))

fn tooling_compilePhaseTimingEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_PHASE_TIMING", "0"))

fn tooling_printCompilePhaseTiming(labelRaw: str, msRaw: int64) =
    if !tooling_compilePhaseTimingEnabled():
        return
    if !tooling_strNonEmpty(strutil.strip(labelRaw)):
        return
    var ms: int64 = msRaw
    if ms < int64(0):
        ms = int64(0)
    tooling_printOut("compile_phase_" + strutil.strip(labelRaw) + "_ms=" + int64ToStr(ms))

fn tooling_compileSuccessMetaVerboseEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_SUCCESS_META", "0"))

fn tooling_compilePrintOutEnabled(): bool =
    if tooling_compileSuccessMetaVerboseEnabled():
        return true
    return tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_PRINT_OUT", "0"))

fn tooling_stage0PrepareTimingEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_PREPARE_TIMING", "0"))

fn tooling_printStage0PrepareTiming(labelRaw: str, msRaw: int64) =
    if !tooling_stage0PrepareTimingEnabled():
        return
    if !tooling_strNonEmpty(strutil.strip(labelRaw)):
        return
    var ms: int64 = msRaw
    if ms < int64(0):
        ms = int64(0)
    tooling_printOut("stage0_prepare_phase_" + strutil.strip(labelRaw) + "_ms=" + int64ToStr(ms))

fn tooling_stage0ResolveTimingEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_RESOLVE_TIMING", "0"))

fn tooling_printStage0ResolveTiming(labelRaw: str, msRaw: int64) =
    if !tooling_stage0ResolveTimingEnabled():
        return
    if !tooling_strNonEmpty(strutil.strip(labelRaw)):
        return
    var ms: int64 = msRaw
    if ms < int64(0):
        ms = int64(0)
    tooling_printOut("stage0_resolve_phase_" + strutil.strip(labelRaw) + "_ms=" + int64ToStr(ms))

fn tooling_boolText(v: bool): str =
    if v:
        return "1"
    return "0"

fn tooling_compileTargetFlag(targetRaw: str): str =
    if !tooling_strNonEmpty(strutil.strip(targetRaw)) || tooling_strEq(strutil.strip(targetRaw), "auto"):
        return ""
    return "-target " + tooling_shellQuote(strutil.strip(targetRaw))

fn tooling_emitModeIsLibrary(modeRaw: str): bool =
    return tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "shared") ||
           tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "static")

fn tooling_emitModeIsExeLike(modeRaw: str): bool =
    return tooling_strEq(strutil.toLowerAscii(strutil.strip(modeRaw)), "exe")

fn tooling_releaseSharedFlag(targetRaw: str): str =
    if tooling_strContains(strutil.toLowerAscii(strutil.strip(targetRaw)), "apple"):
        return "-dynamiclib"
    return "-shared"

fn tooling_targetNeedsDlForShared(targetRaw: str): bool =
    return tooling_strContains(strutil.toLowerAscii(strutil.strip(targetRaw)), "linux") ||
           tooling_strContains(strutil.toLowerAscii(strutil.strip(targetRaw)), "android") ||
           tooling_strContains(strutil.toLowerAscii(strutil.strip(targetRaw)), "ohos")

fn tooling_releaseCcBin(): str =
    return strutil.strip(os.getEnvDefault("BACKEND_RELEASE_CC", "cc"))

fn tooling_releaseArBin(): str =
    return strutil.strip(os.getEnvDefault("BACKEND_RELEASE_AR", "ar"))

fn tooling_releaseLibraryIncludeRuntime(): bool =
    return tooling_isTrue(os.getEnvDefault("BACKEND_RELEASE_LIBRARY_INCLUDE_RUNTIME", "1"))

fn tooling_releaseRuntimeSrcPath(root: str): str =
    return tooling_runtimeRefreshRuntimeSrc(root)

fn tooling_releaseRuntimeObjPath(root: str, target: str): str =
    let driver: str = tooling_resolveStage0Driver(root, "")
    return tooling_backendLinkEnvRuntimeObjPath(root, driver, target)

fn tooling_releaseStaticLinkCmd(outPath: str, objectPath: str, runtimeObjPath: str): str =
    if tooling_releaseLibraryIncludeRuntime() && tooling_strNonEmpty(runtimeObjPath):
        return tooling_shellQuote(tooling_releaseArBin()) + " rcs " + tooling_shellQuote(outPath) + " " +
               tooling_shellQuote(objectPath) + " " + tooling_shellQuote(runtimeObjPath)
    return tooling_shellQuote(tooling_releaseArBin()) + " rcs " + tooling_shellQuote(outPath) + " " +
           tooling_shellQuote(objectPath)

fn tooling_releaseSharedLinkCmd(root: str, target: str, outPath: str,
                                objectPath: str, releaseLdflagsRaw: str,
                                runtimeObjPath: str): str =
    return tooling_shellQuote(tooling_releaseCcBin()) + " " +
        (tooling_strNonEmpty(tooling_compileTargetFlag(target)) ? tooling_compileTargetFlag(target) + " " : "") +
        tooling_releaseSharedFlag(target) + " -o " + tooling_shellQuote(outPath) + " " +
        tooling_shellQuote(objectPath) +
        ((tooling_releaseLibraryIncludeRuntime() && tooling_strNonEmpty(runtimeObjPath)) ?
            " " + tooling_shellQuote(runtimeObjPath) :
            "") +
        (tooling_targetNeedsDlForShared(target) ? " -ldl" : "") +
        (tooling_strNonEmpty(releaseLdflagsRaw) ? " " + releaseLdflagsRaw : "")

fn tooling_linkReleaseLibrary(root: str, emitModeRaw: str, target: str, outPath: str,
                              objectPath: str, releaseLdflagsRaw: str): int32 =
    if !tooling_strNonEmpty(tooling_releaseCcBin()):
        tooling_printErr("cheng_tooling: BACKEND_RELEASE_CC is empty")
        return 1
    if !tooling_strNonEmpty(tooling_releaseArBin()):
        tooling_printErr("cheng_tooling: BACKEND_RELEASE_AR is empty")
        return 1
    let runtimeObjPath: str = tooling_releaseLibraryIncludeRuntime()
        ? tooling_releaseRuntimeObjPath(root, target)
        : ""
    if tooling_releaseLibraryIncludeRuntime():
        if !tooling_strNonEmpty(runtimeObjPath) || !os.fileExists(runtimeObjPath):
            tooling_printErr("cheng_tooling: missing release runtime object for target=" + target)
            return 1
    if os.fileExists(outPath):
        os.removeFile outPath
    let linkRes: os.ExecCmdResult =
        tooling_exec(
            root,
            tooling_strEq(strutil.toLowerAscii(strutil.strip(emitModeRaw)), "static") ?
                tooling_releaseStaticLinkCmd(outPath, objectPath, runtimeObjPath) :
                tooling_releaseSharedLinkCmd(root, target, outPath, objectPath, releaseLdflagsRaw, runtimeObjPath)
        )
    tooling_printExecOutput(linkRes)
    let linkRc: int32 = os.execCmdResultExitCode(linkRes)
    if linkRc != 0:
        tooling_printErr("cheng_tooling: release library link failed emit=" + strutil.toLowerAscii(strutil.strip(emitModeRaw)))
        return linkRc
    return 0

fn tooling_bool01Normalized(raw: str): str =
    if !tooling_strNonEmpty(strutil.toLowerAscii(strutil.strip(raw))):
        return ""
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "1") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "true") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "yes") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "on"):
        return "1"
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "0") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "false") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "no") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "off"):
        return "0"
    return ""

fn tooling_selfhostModeNormalized(raw: str): str =
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "fast") ||
       tooling_strEq(strutil.toLowerAscii(strutil.strip(raw)), "strict"):
        return strutil.toLowerAscii(strutil.strip(raw))
    return ""

fn tooling_selfhostModeFromEnv(defaultModeRaw: str): str =
    if tooling_strNonEmpty(tooling_selfhostModeNormalized(os.getEnvDefault(
        "SELF_OBJ_BOOTSTRAP_MODE",
        tooling_strNonEmpty(tooling_selfhostModeNormalized(defaultModeRaw)) ? tooling_selfhostModeNormalized(defaultModeRaw) : "fast"
    ))):
        return tooling_selfhostModeNormalized(os.getEnvDefault(
            "SELF_OBJ_BOOTSTRAP_MODE",
            tooling_strNonEmpty(tooling_selfhostModeNormalized(defaultModeRaw)) ? tooling_selfhostModeNormalized(defaultModeRaw) : "fast"
        ))
    if tooling_strNonEmpty(tooling_selfhostModeNormalized(defaultModeRaw)):
        return tooling_selfhostModeNormalized(defaultModeRaw)
    return "fast"

fn tooling_compileRunModeNormalized(runAfter: bool, runModeRaw: str, releaseBuild: bool): str =
    if !runAfter:
        return ""
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(runModeRaw)), "host") && !releaseBuild:
        return "host"
    if tooling_strEq(strutil.toLowerAscii(strutil.strip(runModeRaw)), "file"):
        return "file"
    if releaseBuild:
        return "file"
    return "host"

fn tooling_selfExecPath(root: str): str =
    let raw0: str = strutil.strip(tooling_paramStr(0))
    var abs0: str = raw0
    if tooling_strNonEmpty(abs0) && !os.isAbsolute(abs0):
        abs0 = tooling_pathAbsolute(root, abs0)
    let forcedRaw: str = strutil.strip(os.getEnvDefault("TOOLING_SELF_BIN", ""))
    if tooling_strNonEmpty(forcedRaw):
        let forcedAbs: str = tooling_pathAbsolute(root, forcedRaw)
        if tooling_strNonEmpty(forcedAbs) && os.fileExists(forcedAbs):
            if tooling_driverIsScriptShim(root, forcedAbs) &&
               tooling_strNonEmpty(abs0) && os.fileExists(abs0) &&
               !tooling_driverIsScriptShim(root, abs0):
                return abs0
            return forcedAbs
    if tooling_strNonEmpty(raw0):
        if tooling_strContains(raw0, "cheng_tooling_embedded:"):
            return ""
        if tooling_strNonEmpty(abs0) && os.fileExists(abs0):
            return abs0
    let canonical: str = tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling")
    if tooling_strNonEmpty(canonical) && os.fileExists(canonical):
        return canonical
    return ""

fn tooling_firstToken(raw: str): str =
    if !tooling_strNonEmpty(strutil.strip(raw)):
        return ""
    let n: int32 = len(strutil.strip(raw))
    var i: int32 = 0
    while i < n:
        let ch: char = strutil.strip(raw)[i]
        if ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r':
            break
        i = i + 1
    if i <= 0:
        return ""
    return strings.sliceBytes(strutil.strip(raw), 0, i)

fn tooling_sha256FileCmd(root: str, path: str): str =
    if os.execCmdResultExitCode(tooling_exec(root, "command -v shasum >/dev/null 2>&1")) == 0:
        return "shasum -a 256 " + tooling_shellQuote(path)
    if os.execCmdResultExitCode(tooling_exec(root, "command -v sha256sum >/dev/null 2>&1")) != 0:
        return ""
    return "sha256sum " + tooling_shellQuote(path)

fn tooling_sha256File(root: str, pathRaw: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, pathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, pathRaw)):
        return ""
    if !tooling_strNonEmpty(tooling_sha256FileCmd(root, tooling_pathAbsolute(root, pathRaw))):
        return ""
    let res: os.ExecCmdResult = tooling_exec(root, tooling_sha256FileCmd(root, tooling_pathAbsolute(root, pathRaw)))
    if os.execCmdResultExitCode(res) != 0:
        return ""
    if !tooling_strNonEmpty(tooling_firstToken(os.execCmdResultOutput(res))):
        return ""
    return tooling_firstToken(os.execCmdResultOutput(res))

fn tooling_sha256TextCmd(root: str, textRaw: str): str =
    if os.execCmdResultExitCode(tooling_exec(root, "command -v shasum >/dev/null 2>&1")) == 0:
        return "printf %s " + tooling_shellQuote(textRaw) + " | shasum -a 256"
    if os.execCmdResultExitCode(tooling_exec(root, "command -v sha256sum >/dev/null 2>&1")) != 0:
        return ""
    return "printf %s " + tooling_shellQuote(textRaw) + " | sha256sum"

fn tooling_sha256Text(root: str, textRaw: str): str =
    if !tooling_strNonEmpty(tooling_sha256TextCmd(root, textRaw)):
        return ""
    let res: os.ExecCmdResult = tooling_exec(root, tooling_sha256TextCmd(root, textRaw))
    if os.execCmdResultExitCode(res) != 0:
        return ""
    if !tooling_strNonEmpty(tooling_firstToken(os.execCmdResultOutput(res))):
        return ""
    return tooling_firstToken(os.execCmdResultOutput(res))

fn tooling_hash64Text(textRaw: str): uint64 =
    var h: uint64 = (uint64(1469598103) * uint64(1000000000)) + uint64(934665603)
    for i in 0..<len(textRaw):
        let ch: uint64 = uint64(int32(textRaw[i]) & 255)
        h = h ^ ch
        h = h * ((uint64(1099511628) * uint64(1000)) + uint64(211))
    return h

fn tooling_hexDigit(nibbleRaw: int32): char =
    let nibble: int32 = nibbleRaw & 15
    if nibble < 10:
        return char(int32('0') + nibble)
    return char(int32('a') + (nibble - 10))

fn tooling_u64HexFixed(valueRaw: uint64): str =
    var value: uint64 = valueRaw
    var parts: str[] = []
    var shift: int32 = 60
    while shift >= 0:
        let nibble: int32 = int32((value >> uint64(shift)) & uint64(15))
        add(parts, strings.charToStr(tooling_hexDigit(nibble)))
        shift = shift - 4
    return tooling_joinFragments(parts)

fn tooling_pathStableToken(textRaw: str): str =
    if !tooling_strNonEmpty(strutil.strip(textRaw)):
        return ""
    return tooling_u64HexFixed(tooling_hash64Text(strutil.strip(textRaw)))

fn tooling_stage0DigestMemoPath(root: str, stage0PathRaw: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)):
        return ""
    tooling_tryMkdirP(root, tooling_stage0QuarantineDir(root))
    if !tooling_strNonEmpty(tooling_pathStableToken(tooling_pathAbsolute(root, stage0PathRaw))):
        return ""
    return os.joinPath(
        tooling_stage0QuarantineDir(root),
        "stage0.digest." + tooling_pathStableToken(tooling_pathAbsolute(root, stage0PathRaw)) + ".memo"
    )

fn tooling_stage0Sha256MemoRead(root: str, stage0PathRaw: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, stage0PathRaw)):
        return ""
    if !tooling_strNonEmpty(tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))) ||
       !os.fileExists(tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
        return ""
    if !tooling_strEq(
        tooling_kvGet(
            tooling_readTextFile(root, tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))),
            "version"
        ),
        "1"
    ):
        return ""
    if !tooling_strEq(
        tooling_kvGet(
            tooling_readTextFile(root, tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))),
            "stage0_path"
        ),
        tooling_pathAbsolute(root, stage0PathRaw)
    ):
        return ""
    if !tooling_strEq(
        tooling_kvGet(
            tooling_readTextFile(root, tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))),
            "stage0_size"
        ),
        int64ToStr(os.fileSize(tooling_pathAbsolute(root, stage0PathRaw)))
    ):
        return ""
    if !tooling_strEq(
        tooling_kvGet(
            tooling_readTextFile(root, tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))),
            "stage0_mtime"
        ),
        int64ToStr(os.fileMtime(tooling_pathAbsolute(root, stage0PathRaw)))
    ):
        return ""
    return strutil.strip(
        tooling_kvGet(
            tooling_readTextFile(root, tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))),
            "stage0_sha"
        )
    )

fn tooling_stage0Sha256MemoText(root: str, stage0PathRaw: str, shaRaw: str): str =
    return "version=1\n" +
           "stage0_path=" + tooling_pathAbsolute(root, stage0PathRaw) + "\n" +
           "stage0_size=" + int64ToStr(os.fileSize(tooling_pathAbsolute(root, stage0PathRaw))) + "\n" +
           "stage0_mtime=" + int64ToStr(os.fileMtime(tooling_pathAbsolute(root, stage0PathRaw))) + "\n" +
           "stage0_sha=" + strutil.strip(shaRaw) + "\n"

fn tooling_stage0Sha256MemoWrite(root: str, stage0PathRaw: str, shaRaw: str) =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, stage0PathRaw)) ||
       !tooling_strNonEmpty(strutil.strip(shaRaw)):
        return
    if !tooling_strNonEmpty(tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
        return
    if tooling_strNonEmpty(os.parentDir(tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw)))):
        tooling_tryMkdirP(root, os.parentDir(tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw))))
    if !tooling_writeTextFileViaShell(
        root,
        tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw)),
        tooling_stage0Sha256MemoText(root, stage0PathRaw, shaRaw)
    ):
        os.writeFile(
            tooling_stage0DigestMemoPath(root, tooling_pathAbsolute(root, stage0PathRaw)),
            tooling_stage0Sha256MemoText(root, stage0PathRaw, shaRaw)
        )

fn tooling_stage0Sha256FileCached(root: str, pathRaw: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, pathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, pathRaw)):
        return ""
    if tooling_strNonEmpty(tooling_stage0Sha256MemoRead(root, tooling_pathAbsolute(root, pathRaw))):
        return tooling_stage0Sha256MemoRead(root, tooling_pathAbsolute(root, pathRaw))
    if tooling_strNonEmpty(tooling_sha256File(root, tooling_pathAbsolute(root, pathRaw))):
        tooling_stage0Sha256MemoWrite(
            root,
            tooling_pathAbsolute(root, pathRaw),
            tooling_sha256File(root, tooling_pathAbsolute(root, pathRaw))
        )
    return tooling_sha256File(root, tooling_pathAbsolute(root, pathRaw))

fn tooling_timeoutCommand(root: str): str =
    if tooling_strNonEmpty(tooling_trimAsciiSpace(os.getEnvDefault("TOOLING_TIMEOUT_BIN", ""))):
        return tooling_trimAsciiSpace(os.getEnvDefault("TOOLING_TIMEOUT_BIN", ""))
    if tooling_timeoutCommandCacheReady:
        return tooling_timeoutCommandCache
    if os.execCmdResultExitCode(tooling_exec(root, "command -v timeout >/dev/null 2>&1")) == 0:
        tooling_timeoutCommandCacheReady = true
        tooling_timeoutCommandCache = "timeout"
        return tooling_timeoutCommandCache
    if os.execCmdResultExitCode(tooling_exec(root, "command -v gtimeout >/dev/null 2>&1")) == 0:
        tooling_timeoutCommandCacheReady = true
        tooling_timeoutCommandCache = "gtimeout"
        return tooling_timeoutCommandCache
    tooling_timeoutCommandCacheReady = true
    tooling_timeoutCommandCache = ""
    return ""

fn tooling_commandTokenPath(root: str, cmdRaw: str): str =
    if !tooling_strNonEmpty(tooling_firstToken(cmdRaw)):
        return ""
    if tooling_firstToken(cmdRaw)[0] == '/':
        return tooling_firstToken(cmdRaw)
    return tooling_pathAbsolute(root, tooling_firstToken(cmdRaw))

fn tooling_pathFileInode(root: str, pathRaw: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, pathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, pathRaw)):
        return ""
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "path=" + tooling_shellQuote(tooling_pathAbsolute(root, pathRaw)) + " ; " +
        "if stat -f %i \"$path\" >/dev/null 2>&1; then stat -f %i \"$path\" 2>/dev/null; " +
        "elif stat -c %i \"$path\" >/dev/null 2>&1; then stat -c %i \"$path\" 2>/dev/null; " +
        "fi"
    )
    if os.execCmdResultExitCode(res) != 0:
        return ""
    if !tooling_isDigitsOnly(strutil.strip(os.execCmdResultOutput(res))):
        return ""
    return strutil.strip(os.execCmdResultOutput(res))

fn tooling_stage0PidTxtInode(root: str, pidTokenRaw: str): str =
    if !tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_INODE_GUARD", "1")):
        return ""
    if !tooling_isDigitsOnly(strutil.strip(pidTokenRaw)):
        return ""
    let hasLsof: os.ExecCmdResult = tooling_exec(root, "command -v lsof >/dev/null 2>&1")
    if os.execCmdResultExitCode(hasLsof) != 0:
        return ""
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "pid=" + tooling_shellQuote(strutil.strip(pidTokenRaw)) + " ; " +
        "lsof -a -p \"$pid\" -d txt -FnDi 2>/dev/null | " +
        "awk 'BEGIN{inode=\"\"} /^i/{ if (inode==\"\") inode=substr($0,2); } " +
        "END{ if (inode!=\"\") print inode; }'"
    )
    if os.execCmdResultExitCode(res) != 0:
        return ""
    if !tooling_isDigitsOnly(strutil.strip(os.execCmdResultOutput(res))):
        return ""
    return strutil.strip(os.execCmdResultOutput(res))

fn tooling_stage0UeGenerationPath(root: str, qdir: str, cmdRaw: str): str =
    if !tooling_strNonEmpty(strutil.strip(cmdRaw)):
        return ""
    if tooling_strEq(
        tooling_commandTokenPath(root, strutil.strip(cmdRaw)),
        tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    ):
        return tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if tooling_strNonEmpty(qdir) &&
       tooling_strContains(tooling_commandTokenPath(root, strutil.strip(cmdRaw)), qdir) &&
       os.fileExists(tooling_commandTokenPath(root, strutil.strip(cmdRaw))):
        return tooling_commandTokenPath(root, strutil.strip(cmdRaw))
    if tooling_strContains(strutil.strip(cmdRaw), "/artifacts/backend_driver/cheng") ||
       tooling_strContains(strutil.strip(cmdRaw), "artifacts/backend_driver/cheng"):
        return tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    return ""

fn tooling_stage0PidOlderThanGenerationPath(root: str, pidTokenRaw: str, generationPathRaw: str): bool =
    if !tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_GENERATION_GUARD", "1")):
        return false
    if !tooling_isDigitsOnly(strutil.strip(pidTokenRaw)):
        return false
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, generationPathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, generationPathRaw)):
        return false
    var marginSec: int32 = tooling_parseInt32Default(
        os.getEnvDefault("TOOLING_STAGE0_GENERATION_MARGIN_SEC", ""), 3)
    if marginSec < 0:
        marginSec = 0
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "pid=" + tooling_shellQuote(strutil.strip(pidTokenRaw)) + " ; " +
        "path=" + tooling_shellQuote(tooling_pathAbsolute(root, generationPathRaw)) + " ; " +
        "margin=" + intToStr(marginSec) + " ; " +
        "etime=$(ps -o etime= -p \"$pid\" 2>/dev/null | tr -d '[:space:]') ; " +
        "if [ -z \"$etime\" ]; then exit 1; fi ; " +
        "age=$(printf '%s\\n' \"$etime\" | awk -F '[-:]' '" +
        "function bad(){print -1; exit} " +
        "{ if (index($0,\"-\")>0) { if (NF!=4) bad(); d=$1; h=$2; m=$3; s=$4; } " +
        "  else if (NF==3) { d=0; h=$1; m=$2; s=$3; } " +
        "  else if (NF==2) { d=0; h=0; m=$1; s=$2; } " +
        "  else if (NF==1) { d=0; h=0; m=0; s=$1; } else bad(); " +
        "  if (d<0 || h<0 || m<0 || s<0) bad(); " +
        "  if (NF>=2 && s>=60) bad(); " +
        "  if (NF==3 && m>=60) bad(); " +
        "  print d*86400 + h*3600 + m*60 + s; }') ; " +
        "if [ -z \"$age\" ] || [ \"$age\" -lt 0 ]; then exit 1; fi ; " +
        "if stat -f %m \"$path\" >/dev/null 2>&1; then mt=$(stat -f %m \"$path\"); " +
        "elif stat -c %Y \"$path\" >/dev/null 2>&1; then mt=$(stat -c %Y \"$path\"); " +
        "else mt=0; fi ; " +
        "now=$(date +%s 2>/dev/null || echo 0) ; " +
        "if [ \"$mt\" -le 0 ] || [ \"$now\" -le 0 ] || [ \"$now\" -lt \"$mt\" ]; then exit 1; fi ; " +
        "gen_age=$((now - mt)) ; " +
        "threshold=$((gen_age + margin)) ; " +
        "if [ \"$age\" -gt \"$threshold\" ]; then exit 0; fi ; " +
        "exit 1"
    )
    return os.execCmdResultExitCode(res) == 0

fn tooling_stage0PidHistoricalForGenerationPath(root: str, pidTokenRaw: str,
                                                generationPathRaw: str): bool =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, generationPathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, generationPathRaw)):
        return false
    if tooling_strNonEmpty(tooling_pathFileInode(root, tooling_pathAbsolute(root, generationPathRaw))) &&
       tooling_strNonEmpty(tooling_stage0PidTxtInode(root, pidTokenRaw)) &&
       !tooling_strEq(
           tooling_pathFileInode(root, tooling_pathAbsolute(root, generationPathRaw)),
           tooling_stage0PidTxtInode(root, pidTokenRaw)
       ):
        return true
    return tooling_stage0PidOlderThanGenerationPath(
        root, pidTokenRaw, tooling_pathAbsolute(root, generationPathRaw))

fn tooling_uname(root: str, flag: str): str =
    if tooling_strEq(strutil.strip(flag), "-s") && tooling_unameSysnameCacheReady:
        return tooling_unameSysnameCache
    if tooling_strEq(strutil.strip(flag), "-m") && tooling_unameMachineCacheReady:
        return tooling_unameMachineCache
    let res: os.ExecCmdResult = tooling_exec(root, "uname " + flag)
    if tooling_strEq(strutil.strip(flag), "-s"):
        tooling_unameSysnameCacheReady = true
        if os.execCmdResultExitCode(res) != 0:
            tooling_unameSysnameCache = ""
        else:
            tooling_unameSysnameCache = strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res)))
    elif tooling_strEq(strutil.strip(flag), "-m"):
        tooling_unameMachineCacheReady = true
        if os.execCmdResultExitCode(res) != 0:
            tooling_unameMachineCache = ""
        else:
            tooling_unameMachineCache = strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res)))
    if os.execCmdResultExitCode(res) != 0:
        return ""
    return strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res)))

fn tooling_detectHostTag(root: str): str =
    if tooling_hostTagCacheReady:
        return tooling_hostTagCache
    let hostOs: str = tooling_uname(root, "-s")
    let hostArch: str = tooling_uname(root, "-m")
    if tooling_strEq(hostOs, "darwin") && tooling_strEq(hostArch, "arm64"):
        tooling_hostTagCacheReady = true
        tooling_hostTagCache = "darwin_arm64"
        return tooling_hostTagCache
    if !tooling_strNonEmpty(hostOs) || !tooling_strNonEmpty(hostArch):
        tooling_hostTagCacheReady = true
        tooling_hostTagCache = "unknown"
        return tooling_hostTagCache
    tooling_hostTagCacheReady = true
    tooling_hostTagCache = hostOs + "_" + hostArch
    return tooling_hostTagCache

fn tooling_detectHostTarget(root: str): str =
    if tooling_hostTargetCacheReady:
        return tooling_hostTargetCache
    let hostOs: str = tooling_uname(root, "-s")
    let hostArch: str = tooling_uname(root, "-m")
    if tooling_strEq(hostOs, "darwin") && tooling_strEq(hostArch, "arm64"):
        tooling_hostTargetCacheReady = true
        tooling_hostTargetCache = "arm64-apple-darwin"
        return tooling_hostTargetCache
    if tooling_strEq(hostOs, "darwin") &&
       (tooling_strEq(hostArch, "x86_64") || tooling_strEq(hostArch, "amd64")):
        tooling_hostTargetCacheReady = true
        tooling_hostTargetCache = "x86_64-apple-darwin"
        return tooling_hostTargetCache
    if tooling_strEq(hostOs, "linux") &&
       (tooling_strEq(hostArch, "aarch64") || tooling_strEq(hostArch, "arm64")):
        tooling_hostTargetCacheReady = true
        tooling_hostTargetCache = "aarch64-unknown-linux-gnu"
        return tooling_hostTargetCache
    if tooling_strEq(hostOs, "linux") &&
       (tooling_strEq(hostArch, "x86_64") || tooling_strEq(hostArch, "amd64")):
        tooling_hostTargetCacheReady = true
        tooling_hostTargetCache = "x86_64-unknown-linux-gnu"
        return tooling_hostTargetCache
    tooling_hostTargetCacheReady = true
    tooling_hostTargetCache = ""
    return tooling_hostTargetCache

fn tooling_buildDriverDefaultMulti(root: str): str =
    let hostTag: str = tooling_detectHostTag(root)
    if tooling_strEq(hostTag, "darwin_arm64"):
        return "1"
    return "0"

fn tooling_buildDriverDefaultJobs(root: str): int32 =
    let hostTag: str = tooling_detectHostTag(root)
    if tooling_strEq(hostTag, "darwin_arm64"):
        return 8
    return 1

fn tooling_compileDefaultMulti(root: str): str =
    return tooling_buildDriverDefaultMulti(root)

fn tooling_compileDefaultJobs(root: str): str =
    return intToStr(tooling_buildDriverDefaultJobs(root))

fn tooling_compileParallelMultiText(root: str, defaultText: str = ""): str =
    var fallback: str = defaultText
    if !tooling_strNonEmpty(fallback):
        fallback = tooling_compileDefaultMulti(root)
    var out: str = tooling_bool01Normalized(os.getEnvDefault("BACKEND_MULTI", fallback))
    if !tooling_strNonEmpty(out):
        out = tooling_bool01Normalized(fallback)
    if !tooling_strNonEmpty(out):
        return "0"
    return out

fn tooling_compileParallelMultiForceText(root: str, multiText: str): str =
    var out: str = tooling_bool01Normalized(multiText)
    if !tooling_strNonEmpty(out):
        out = tooling_bool01Normalized(tooling_compileDefaultMulti(root))
    if !tooling_strNonEmpty(out):
        return "0"
    return out

fn tooling_compileParallelJobsText(root: str, defaultText: str = ""): str =
    var fallback: str = defaultText
    if !tooling_strNonEmpty(fallback):
        fallback = tooling_compileDefaultJobs(root)
    var out: str = strutil.strip(os.getEnvDefault("BACKEND_JOBS", fallback))
    if !tooling_strNonEmpty(out):
        out = strutil.strip(fallback)
    if !tooling_strNonEmpty(out):
        return "1"
    return out

fn tooling_compileParallelFnJobsText(root: str, jobsText: str): str =
    var fallback: str = jobsText
    if !tooling_strNonEmpty(fallback):
        fallback = tooling_compileDefaultJobs(root)
    var out: str = strutil.strip(os.getEnvDefault("BACKEND_FN_JOBS", fallback))
    if !tooling_strNonEmpty(out):
        out = strutil.strip(fallback)
    if !tooling_strNonEmpty(out):
        return "1"
    return out

fn tooling_envOverridesCompatText(envOverrides: str[]): str =
    var parts: str[] = []
    for i in 0..<envOverrides.len:
        let name: str = tooling_envOverrideName(envOverrides[i])
        if !tooling_strNonEmpty(name):
            continue
        add(parts, tooling_envAssignCompat(name, tooling_envOverrideValue(envOverrides[i])))
    return tooling_joinFragments(parts)

fn tooling_backendCompileModuleCacheDisabledCollect(envOverrides: var str[]) =
    tooling_appendLegacyFrontendEnvUnsets(envOverrides)
    tooling_envAssignCollect(envOverrides, "BACKEND_MODULE_CACHE_UNSTABLE_ALLOW", "0")

fn tooling_backendCompileCompatCollect(envOverrides: var str[], stdNoptr: str,
                                       stdNoptrStrict: str, noptrNonCAbi: str,
                                       noptrNonCAbiInternal: str, stage1ProfileText: str) =
    tooling_envAssignCollect(envOverrides, "MM", "orc")
    tooling_envAssignCollect(envOverrides, "CACHE", "0")
    tooling_envAssignCollect(envOverrides, "STAGE1_AUTO_SYSTEM", "0")
    if tooling_strNonEmpty(stdNoptr):
        tooling_envAssignCollect(envOverrides, "STAGE1_STD_NO_POINTERS", stdNoptr)
    if tooling_strNonEmpty(stdNoptrStrict):
        tooling_envAssignCollect(envOverrides, "STAGE1_STD_NO_POINTERS_STRICT",
                                 stdNoptrStrict)
    tooling_envAssignCollect(envOverrides, "STAGE1_SKIP_CPROFILE", "1")
    tooling_envAssignCollect(envOverrides, "STAGE1_PROFILE", stage1ProfileText)

fn tooling_backendCompileBaseCollect(envOverrides: var str[], buildTrack: str,
                                     parseMode: str, stage1BuilderText: str,
                                     skipGlobalInitText: str, allowNoMainText: str) =
    tooling_envAssignCollect(envOverrides, "BACKEND_BUILD_TRACK", buildTrack)
    tooling_envAssignCollect(envOverrides, "BACKEND_ALLOW_DIRECT_DRIVER", "1")
    tooling_envAssignCollect(envOverrides, "BACKEND_STAGE1_PARSE_MODE", parseMode)
    tooling_envAssignCollect(envOverrides, "BACKEND_STAGE1_BUILDER", stage1BuilderText)
    tooling_envAssignCollect(envOverrides, "BACKEND_SKIP_GLOBAL_INIT", skipGlobalInitText)
    tooling_envAssignCollect(envOverrides, "BACKEND_IR", "uir")
    tooling_envAssignCollect(envOverrides, "BACKEND_VALIDATE", "0")
    if tooling_strNonEmpty(allowNoMainText):
        tooling_envAssignCollect(envOverrides, "BACKEND_ALLOW_NO_MAIN", allowNoMainText)

fn tooling_backendCompileExecutionCollect(envOverrides: var str[], wholeProgramText: str,
                                          directExeText: str, linkerlessInmemText: str,
                                          multiText: str, incrementalText: str,
                                          jobsText: str, fnJobsText: str) =
    if tooling_strNonEmpty(wholeProgramText):
        tooling_envAssignCollect(envOverrides, "BACKEND_WHOLE_PROGRAM", wholeProgramText)
    tooling_envAssignCollect(envOverrides, "BACKEND_FN_SCHED", "ws")
    tooling_envAssignCollect(envOverrides, "BACKEND_DIRECT_EXE", directExeText)
    tooling_envAssignCollect(envOverrides, "BACKEND_LINKERLESS_INMEM", linkerlessInmemText)
    tooling_envAssignCollect(envOverrides, "BACKEND_FAST_FALLBACK_ALLOW", "0")
    tooling_envAssignCollect(envOverrides, "BACKEND_MULTI", multiText)
    tooling_envAssignCollect(envOverrides, "BACKEND_INCREMENTAL", incrementalText)
    tooling_envAssignCollect(envOverrides, "BACKEND_JOBS", jobsText)
    tooling_envAssignCollect(envOverrides, "BACKEND_FN_JOBS", fnJobsText)

fn tooling_backendCompileGenericCollect(envOverrides: var str[], genericModeText: str,
                                        genericSpecBudgetText: str,
                                        genericLoweringText: str) =
    tooling_envAssignCollect(envOverrides, "GENERIC_MODE", genericModeText)
    tooling_envAssignCollect(envOverrides, "GENERIC_SPEC_BUDGET", genericSpecBudgetText)
    tooling_envAssignCollect(envOverrides, "GENERIC_LOWERING", genericLoweringText)

fn tooling_backendShellStableEnvText(buildTrack: str, allowNoMainText: str): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        buildTrack, "", "", "", "", "", "", allowNoMainText, "", "", "", "", "", "", "")
    return tooling_envAssignCompat("BACKEND_ALLOW_DIRECT_DRIVER", "1") +
           tooling_envAssignCompat("BACKEND_TOOLING_ENTRY", "1") +
           tooling_envAssignCompat("MM", "orc") +
           tooling_envAssignCompat("BACKEND_CACHE", "0") +
           tooling_envAssignCompat("STAGE1_AUTO_SYSTEM", "0") +
           tooling_compileCommandEnvText(compileOpts, tooling_strNonEmpty(buildTrack))

fn tooling_compileExprCoreCollect(parts: var str[], opts: ToolingCompileOptions) =
    tooling_envAssignExprCollect(parts, "STAGE1_STD_NO_POINTERS", opts.stdNoptr)
    tooling_envAssignExprCollect(parts, "STAGE1_STD_NO_POINTERS_STRICT", opts.stdNoptrStrict)
    tooling_envAssignExprCollect(parts, "STAGE1_PROFILE", opts.stage1ProfileText)
    tooling_envAssignExprCollect(parts, "BACKEND_PROFILE", opts.backendProfileText)
    tooling_envAssignExprCollect(parts, "UIR_PROFILE", opts.uirProfileText)
    tooling_envAssignExprCollect(parts, "BACKEND_BUILD_TRACK", opts.buildTrack)
    tooling_envAssignExprCollect(parts, "BACKEND_LINKER", opts.linkerText)
    tooling_envAssignExprCollect(parts, "BACKEND_WHOLE_PROGRAM", opts.wholeProgramText)
    tooling_envAssignExprCollect(parts, "BACKEND_DIRECT_EXE", opts.directExeText)
    tooling_envAssignExprCollect(parts, "BACKEND_LINKERLESS_INMEM", opts.linkerlessInmemText)
    tooling_envAssignExprCollect(parts, "BACKEND_MULTI", opts.multiText)
    tooling_envAssignExprCollect(parts, "BACKEND_INCREMENTAL", opts.incrementalText)
    tooling_envAssignExprCollect(parts, "BACKEND_JOBS", opts.jobsText)
    tooling_envAssignExprCollect(parts, "BACKEND_FN_JOBS", opts.fnJobsText)
    tooling_envAssignExprCollect(parts, "BACKEND_OPT", opts.optText)
    tooling_envAssignExprCollect(parts, "BACKEND_OPT2", opts.opt2Text)
    tooling_envAssignExprCollect(parts, "BACKEND_OPT_LEVEL", opts.optLevelText)
    tooling_envAssignExprCollect(parts, "ABI", opts.abiText)
    tooling_envAssignExprCollect(parts, "GENERIC_MODE", opts.genericModeText)
    tooling_envAssignExprCollect(parts, "GENERIC_SPEC_BUDGET", opts.genericSpecBudgetText)
    tooling_envAssignExprCollect(parts, "GENERIC_LOWERING", opts.genericLoweringText)
    tooling_envAssignExprCollect(parts, "UIR_SIMD", opts.uirSimdText)
    tooling_envAssignExprCollect(parts, "BACKEND_STAGE1_DISABLE_DUP_SCAN",
                                 opts.disableDupScanText)
    tooling_envAssignExprCollect(parts, "BACKEND_SKIP_UIR_FIXUPS", opts.skipFixupsText)
    tooling_envAssignExprCollect(parts, "BACKEND_SKIP_UIR_NORMALIZE",
                                 opts.skipNormalizeText)
    tooling_envAssignExprCollect(parts, "BACKEND_NO_RUNTIME_C", opts.noRuntimeCText)

fn tooling_compileExprRuntimeCollect(parts: var str[], opts: ToolingCompileOptions) =
    if opts.runtimeObjAssigned || tooling_strNonEmpty(opts.runtimeObjPath):
        tooling_envAssignExprCollect(
            parts,
            "BACKEND_RUNTIME_OBJ",
            tooling_strNonEmpty(opts.runtimeObjPath) ? opts.runtimeObjPath : tooling_shellQuote("")
        )

fn tooling_compileExprConcreteCollect(parts: var str[], opts: ToolingCompileOptions) =
    tooling_envAssignExprCollect(parts, "BACKEND_EMIT", opts.emitModeText)
    tooling_envAssignExprCollect(parts, "BACKEND_TARGET", opts.targetText)
    tooling_envAssignExprCollect(parts, "BACKEND_INPUT", opts.inputPath)
    tooling_envAssignExprCollect(parts, "BACKEND_OUTPUT", opts.outputPath)
    tooling_envAssignExprCollect(parts, "BACKEND_INTERNAL_ALLOW_EMIT_OBJ",
                                 opts.internalAllowEmitObjText)

fn tooling_compileExprSidecarCollect(parts: var str[], opts: ToolingCompileOptions) =
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_SIDECAR_MODE", opts.sidecarModeText)
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_SIDECAR_DISABLE",
                                 opts.sidecarDisableText)
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_SIDECAR_OBJ", opts.sidecarObjPath)
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_SIDECAR_BUNDLE",
                                 opts.sidecarBundlePath)
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_SIDECAR_COMPILER",
                                 opts.sidecarCompilerPath)
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_SIDECAR_CHILD_MODE",
                                 opts.sidecarChildModeText)
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_SIDECAR_OUTER_COMPILER",
                                 opts.sidecarOuterCompilerPath)
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_PREFER_SIDECAR",
                                 opts.sidecarPreferText)
    tooling_envAssignExprCollect(parts, "BACKEND_UIR_FORCE_SIDECAR",
                                 opts.sidecarForceText)

fn tooling_compileExprEnvText(opts: ToolingCompileOptions, extraEnvText: str,
                              includeConcreteCompileEnv: bool): str =
    var parts: str[] = []
    tooling_compileExprCoreCollect(parts, opts)
    tooling_compileExprRuntimeCollect(parts, opts)
    if tooling_strNonEmpty(extraEnvText):
        add(parts, extraEnvText)
    if includeConcreteCompileEnv:
        tooling_compileExprConcreteCollect(parts, opts)
    tooling_compileExprSidecarCollect(parts, opts)
    return tooling_joinFragments(parts)

fn tooling_backendShellExeCompileEnvText(targetExpr: str, inputExpr: str, outputExpr: str,
                                         optLevelExpr: str, incrementalExpr: str,
                                         jobsExpr: str,
                                         extraEnvText: str): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "", "", "", targetExpr, inputExpr, outputExpr, "exe", "", "", "", "", "0",
        incrementalExpr, jobsExpr, "")
    compileOpts.optLevelText = optLevelExpr
    return tooling_compileExprEnvText(compileOpts, extraEnvText, true)

fn tooling_normalizeTargetAlias(root: str, targetRaw: str): str =
    let lower: str = strutil.toLowerAscii(strutil.strip(targetRaw))
    if !tooling_strNonEmpty(lower) || tooling_strEq(lower, "auto") ||
       tooling_strEq(lower, "native") || tooling_strEq(lower, "host"):
        let detected: str = tooling_detectHostTarget(root)
        if tooling_strNonEmpty(detected):
            return detected
        return "auto"
    if tooling_strEq(lower, "darwin_arm64") || tooling_strEq(lower, "darwin_aarch64"):
        return "arm64-apple-darwin"
    if tooling_strEq(lower, "darwin_x86_64") || tooling_strEq(lower, "darwin_amd64"):
        return "x86_64-apple-darwin"
    if tooling_strEq(lower, "linux_arm64") || tooling_strEq(lower, "linux_aarch64"):
        return "aarch64-unknown-linux-gnu"
    if tooling_strEq(lower, "linux_x86_64") || tooling_strEq(lower, "linux_amd64"):
        return "x86_64-unknown-linux-gnu"
    if tooling_strEq(lower, "linux_riscv64"):
        return "riscv64-unknown-linux-gnu"
    if tooling_strEq(lower, "windows_arm64") || tooling_strEq(lower, "windows_aarch64"):
        return "aarch64-pc-windows-msvc"
    if tooling_strEq(lower, "windows_x86_64") || tooling_strEq(lower, "windows_amd64"):
        return "x86_64-pc-windows-msvc"
    return lower

fn tooling_targetSupportsSelfLinker(targetRaw: str): bool =
    let target: str = strutil.toLowerAscii(strutil.strip(targetRaw))
    if !tooling_strNonEmpty(target):
        return false
    # Keep tooling defaults aligned with backend_driver host-only self-link
    # capability to avoid selecting unsupported targets.
    if !tooling_strContains(target, "darwin"):
        return false
    if tooling_strContains(target, "arm64") || tooling_strContains(target, "aarch64"):
        return true
    return false

fn tooling_isExecutable(root: str, path: str): bool =
    if !tooling_strNonEmpty(path):
        return false
    let _root: str = root
    let absPath: str = tooling_pathAbsolute(root, path)
    if !tooling_strNonEmpty(absPath) || !os.fileExists(absPath):
        return false
    let probeRes: os.ExecCmdResult = tooling_exec(_root, "test -x " + tooling_shellQuote(absPath))
    return os.execCmdResultExitCode(probeRes) == 0

fn tooling_stage0RelevantProcessScanTemplate(): str =
    return (
        "ps -Ao pid=,ppid=,state=,command= | awk -v path=__PATH_Q__ -v base=__BASE_Q__ '" +
        "{ line=$0; sub(/^[ \t]+/, \"\", line); if (line == \"\") next; " +
        "  split(line, parts, /[ \t]+/); if (length(parts) < 4) next; " +
        "  ppid=parts[2]; state=parts[3]; " +
        "  if (substr(state, 1, 1) != \"U\" && ppid != \"1\") next; " +
        "  cmd=line; sub(/^[^ \t]+[ \t]+[^ \t]+[ \t]+[^ \t]+[ \t]+/, \"\", cmd); if (cmd == \"\") next; " +
        "  split(cmd, argv, /[ \t]+/); token=argv[1]; " +
        "  tokenLen=length(token); baseLen=length(base); " +
        "  tokenHasBase=(token == base || token == (\"./\" base) || " +
        "                (tokenLen > baseLen && substr(token, tokenLen - baseLen + 1) == base && " +
        "                 substr(token, tokenLen - baseLen, 1) == \"/\")); " +
        "  if (cmd == path || index(cmd, path \" \") == 1 || token == path || tokenHasBase) print line; " +
        "}'"
    )

fn tooling_stage0RelevantProcessScanCommand(root: str, stage0Path: str): str =
    let fullPath: str = tooling_pathAbsolute(root, stage0Path)
    let baseName: str = os.extractFilename(fullPath)
    var command: str = tooling_stage0RelevantProcessScanTemplate()
    command = strutil.replace(command, "__PATH_Q__", tooling_shellQuote(fullPath))
    command = strutil.replace(command, "__BASE_Q__", tooling_shellQuote(baseName))
    return command

fn tooling_stage0ParseRelevantProcessLine(line: str, pidToken: var str, ppidToken: var str,
                                          state: var str, cmd: var str): bool =
    let n: int32 = len(line)
    if n <= 0:
        return false
    var j: int32 = 0
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    let pidStart: int32 = j
    while j < n && line[j] != ' ' && line[j] != '\t':
        j = j + 1
    if j <= pidStart:
        return false
    pidToken = strings.sliceBytes(line, pidStart, j - pidStart)
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    let ppidStart: int32 = j
    while j < n && line[j] != ' ' && line[j] != '\t':
        j = j + 1
    if j <= ppidStart:
        return false
    ppidToken = strings.sliceBytes(line, ppidStart, j - ppidStart)
    var k: int32 = j
    while k < n && (line[k] == ' ' || line[k] == '\t'):
        k = k + 1
    let stateStart: int32 = k
    while k < n && line[k] != ' ' && line[k] != '\t':
        k = k + 1
    if k <= stateStart:
        return false
    state = strings.sliceBytes(line, stateStart, k - stateStart)
    while k < n && (line[k] == ' ' || line[k] == '\t'):
        k = k + 1
    if k >= n:
        return false
    cmd = strings.sliceBytes(line, k, n - k)
    return true

fn tooling_stage0CmdMatchesFullPath(root: str, cmd: str, fullPath: str): bool =
    var hit: bool = tooling_strEq(cmd, fullPath) || strutil.startsWith(cmd, fullPath + " ")
    if hit:
        return true
    var tEnd: int32 = 0
    while tEnd < len(cmd) && cmd[tEnd] != ' ' && cmd[tEnd] != '\t':
        tEnd = tEnd + 1
    if tEnd <= 0:
        return false
    let cmdToken: str = strings.sliceBytes(cmd, 0, tEnd)
    var cmdTokenPath: str = cmdToken
    if cmdToken[0] != '/':
        cmdTokenPath = tooling_pathAbsolute(root, cmdToken)
    return tooling_strEq(cmdTokenPath, fullPath)

fn tooling_stage0ProcessLineBlocks(root: str, line: str, fullPath: str,
                                   orphanGuard: bool, autoKill: bool,
                                   stage0Debug: bool): bool =
    var pidToken: str = ""
    var ppidToken: str = ""
    var state: str = ""
    var cmd: str = ""
    if !tooling_stage0ParseRelevantProcessLine(line, pidToken, ppidToken, state, cmd):
        return false
    let uninterruptible: bool = tooling_strNonEmpty(state) && state[0] == 'U'
    let orphaned: bool = orphanGuard && tooling_strEq(strutil.strip(ppidToken), "1")
    let exitingState: bool = strutil.contains(state, "E")
    if !uninterruptible && !orphaned:
        return false
    if !tooling_stage0CmdMatchesFullPath(root, cmd, fullPath):
        return false
    if tooling_stage0PidHistoricalForGenerationPath(root, pidToken, fullPath):
        if stage0Debug:
            tooling_printErr("cheng_tooling: ignore historical UE pid=" +
                             strutil.strip(pidToken) + " path=" + fullPath)
        return false
    if autoKill && tooling_stage0QuarantineKillPid(root, pidToken):
        tooling_printErr("cheng_tooling: auto-killed stuck/orphan stage0 process pid=" +
                         strutil.strip(pidToken) + " path=" + fullPath)
        return false
    if stage0Debug && (orphaned || exitingState):
        tooling_printErr("cheng_tooling: stage0 UE guard hard-block pid=" +
                         strutil.strip(pidToken) + " path=" + fullPath + " state=" + state)
    return true

fn tooling_stage0HasUninterruptibleProcess(root: str, stage0Path: str): bool =
    if tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_SKIP_UE_GUARD", "0")):
        tooling_printErr("cheng_tooling: ignore TOOLING_STAGE0_SKIP_UE_GUARD=1 because UE hard-block is enabled")
    if !tooling_strNonEmpty(stage0Path):
        return false
    let psRes: os.ExecCmdResult = tooling_exec(
        root, tooling_stage0RelevantProcessScanCommand(root, stage0Path))
    if os.execCmdResultExitCode(psRes) != 0:
        return false
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(psRes))
    let fullPath: str = tooling_pathAbsolute(root, stage0Path)
    let orphanGuard: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_ORPHAN_GUARD", "1"))
    let autoKill: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_AUTO_KILL_PATH_UE", "1"))
    let stage0Debug: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_DEBUG", "0"))
    for i in 0..<rows.len:
        if tooling_stage0ProcessLineBlocks(root, rows[i], fullPath, orphanGuard,
                                           autoKill, stage0Debug):
            return true
    return false

fn tooling_stage0CandidateAppendIfHealthy(out: var str[], candidateDigests: var str[],
                                          root: str, candidatePathRaw: str,
                                          requireHelpProbe: bool,
                                          probeEnabled: bool): bool =
    let candidatePath: str = tooling_pathAbsolute(root, candidatePathRaw)
    if !tooling_strNonEmpty(candidatePath):
        return false
    if tooling_idsContains(out, candidatePath):
        return false
    let _clearedStaleCandidate: bool =
        tooling_stage0MaybeClearStaleStamp(root, candidatePath, requireHelpProbe,
                                           "stage0_candidate_probe")
    let _recoveredSelfhostCandidate: bool =
        tooling_stage0MaybeRecoverStampedSelfhostCandidate(root, candidatePath,
                                                           requireHelpProbe,
                                                           "stage0_candidate_recovery")
    if tooling_stage0BlockStamped(root, candidatePath):
        tooling_printErr("cheng_tooling: skip stage0 candidate blocked by quarantine stamp: " + candidatePath)
        return false
    if tooling_stage0HasUninterruptibleProcess(root, candidatePath):
        if tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_DEBUG", "0")):
            tooling_printErr("cheng_tooling: skip stage0 candidate with stuck/orphan process: " + candidatePath)
        return false
    if !tooling_driverSanityOk(root, candidatePath):
        return false
    if requireHelpProbe && !tooling_binaryHelpProbeOk(root, candidatePath, true):
        if tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_DEBUG", "0")):
            tooling_printErr("cheng_tooling: skip stage0 candidate (--help probe failed): " + candidatePath)
        return false
    let digest: str = tooling_sha256File(root, candidatePath)
    if tooling_strNonEmpty(digest):
        if tooling_idsContains(candidateDigests, digest):
            if tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_DEBUG", "0")):
                tooling_printErr("cheng_tooling: skip duplicate stage0 candidate (same digest): " + candidatePath)
            return false
    if probeEnabled && !tooling_driverCompileProbeOk(root, candidatePath):
        return false
    add(out, candidatePath)
    if tooling_strNonEmpty(digest):
        add(candidateDigests, digest)
    return true

fn tooling_stage0CandidateListWithProbe(root: str, explicitRaw: str, probeEnabled: bool): str[] =
    var out: str[] = []
    let explicit: str = strutil.strip(explicitRaw)
    let requireHelpProbe: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_REQUIRE_HELP_PROBE", "1"))
    if tooling_strNonEmpty(explicit):
        var explicitDigests: str[] = []
        let _acceptedExplicit: bool =
            tooling_stage0CandidateAppendIfHealthy(out, explicitDigests, root, explicit,
                                                   requireHelpProbe, probeEnabled)
        return out
    let canonicalPath: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    let selfhostStage2Path: str = tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/cheng.stage2")
    let selfhostStage1Path: str = tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/cheng.stage1")
    var candidates: str[] = []
    var candidateDigests: str[] = []
    add(candidates, canonicalPath)
    add(candidates, selfhostStage2Path)
    add(candidates, selfhostStage1Path)
    for i in 0..<candidates.len:
        let _accepted: bool =
            tooling_stage0CandidateAppendIfHealthy(out, candidateDigests, root, candidates[i],
                                                   requireHelpProbe, probeEnabled)
    return out

fn tooling_resolveStage0DriverWithProbe(root: str, explicitRaw: str, probeEnabled: bool): str =
    let candidates: str[] = tooling_stage0CandidateListWithProbe(root, explicitRaw, probeEnabled)
    if candidates.len <= 0:
        return ""
    return candidates[0]

fn tooling_stage0CandidateHealthyForCompileFast(root: str, candidatePathRaw: str): bool =
    let totalStartMs: int64 = tooling_nowMs()
    let candidatePath: str = tooling_pathAbsolute(root, candidatePathRaw)
    if !tooling_strNonEmpty(candidatePath):
        return false
    let requireHelpProbe: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_REQUIRE_HELP_PROBE", "1"))
    let recoverStartMs: int64 = tooling_nowMs()
    let _recovered: bool =
        tooling_stage0MaybeRecoverStampedSelfhostCandidate(root, candidatePath,
                                                           requireHelpProbe,
                                                           "compile_fast_stage0_recovery")
    tooling_printStage0ResolveTiming("recover", tooling_nowMs() - recoverStartMs)
    let stampedStartMs: int64 = tooling_nowMs()
    var blocked: bool = tooling_stage0BlockStamped(root, candidatePath)
    tooling_printStage0ResolveTiming("block_stamped", tooling_nowMs() - stampedStartMs)
    if blocked:
        let clearStartMs: int64 = tooling_nowMs()
        let _cleared: bool =
            tooling_stage0MaybeClearStaleStamp(root, candidatePath, requireHelpProbe,
                                               "compile_fast_stage0_probe")
        tooling_printStage0ResolveTiming("clear_stamp", tooling_nowMs() - clearStartMs)
        let recheckStartMs: int64 = tooling_nowMs()
        blocked = tooling_stage0BlockStamped(root, candidatePath)
        tooling_printStage0ResolveTiming("block_stamped_recheck", tooling_nowMs() - recheckStartMs)
    else:
        tooling_printStage0ResolveTiming("clear_stamp", int64(0))
        tooling_printStage0ResolveTiming("block_stamped_recheck", int64(0))
    if blocked:
        return false
    # Fast compile resolve only decides which canonical stage0 to try.
    # Quarantine/UE handling and exec health are enforced again in
    # tooling_prepareStage0Exec/tooling_stage0PreflightOk, so avoid repeating
    # the slow path-level UE scan here.
    tooling_printStage0ResolveTiming("has_ue", int64(0))
    let sanityStartMs: int64 = tooling_nowMs()
    if !tooling_isExecutable(root, candidatePath):
        tooling_printStage0ResolveTiming("minimal_sanity", tooling_nowMs() - sanityStartMs)
        return false
    if os.fileSize(candidatePath) <= int64(0):
        tooling_printStage0ResolveTiming("minimal_sanity", tooling_nowMs() - sanityStartMs)
        return false
    tooling_printStage0ResolveTiming("minimal_sanity", tooling_nowMs() - sanityStartMs)
    tooling_printStage0ResolveTiming("help_probe", int64(0))
    tooling_printStage0ResolveTiming("total", tooling_nowMs() - totalStartMs)
    return true

fn tooling_resolveStage0DriverForCompile(root: str, probeEnabled: bool): str =
    let explicitDriver: str = strutil.strip(os.getEnvDefault("BACKEND_DRIVER", ""))
    if tooling_strNonEmpty(explicitDriver):
        return tooling_resolveStage0DriverWithProbe(root, explicitDriver, probeEnabled)
    let preferCanonicalFast: bool = !probeEnabled &&
        tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_PREFER_CANONICAL_FAST", "1"))
    if preferCanonicalFast:
        let canonicalPath: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
        if tooling_stage0CandidateHealthyForCompileFast(root, canonicalPath):
            return canonicalPath
    return tooling_resolveStage0DriverWithProbe(root, "", probeEnabled)

fn tooling_resolveStage0Driver(root: str, explicitRaw: str): str =
    let probeEnabled: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_COMPILE_PROBE", "0"))
    return tooling_resolveStage0DriverWithProbe(root, explicitRaw, probeEnabled)

fn tooling_resolveStage0DriverStrict(root: str, explicitRaw: str): str =
    let probeEnabled: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_STRICT_COMPILE_PROBE", "0"))
    return tooling_resolveStage0DriverWithProbe(root, explicitRaw, probeEnabled)

fn tooling_stage0CandidateHealthy(root: str, candidatePath: str, probeEnabled: bool, tag: str): bool =
    if !tooling_isExecutable(root, candidatePath):
        return false
    let requireHelpProbe: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_REQUIRE_HELP_PROBE", "1"))
    let _recovered: bool =
        tooling_stage0MaybeRecoverStampedSelfhostCandidate(root, candidatePath,
                                                           requireHelpProbe,
                                                           tag + "_recovery")
    let _cleared: bool =
        tooling_stage0MaybeClearStaleStamp(root, candidatePath, requireHelpProbe,
                                           tag + "_probe")
    if tooling_stage0BlockStamped(root, candidatePath):
        return false
    if tooling_stage0HasUninterruptibleProcess(root, candidatePath):
        return false
    if !tooling_driverSanityOk(root, candidatePath):
        return false
    if probeEnabled && !tooling_driverCompileProbeOk(root, candidatePath):
        return false
    return true

fn tooling_resolveRecoverySeedCompiler(root: str, probeEnabled: bool): str =
    let stage2Path: str = tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/cheng.stage2")
    if tooling_stage0CandidateHealthy(root, stage2Path, probeEnabled, "preferred_stage0"):
        return stage2Path
    let canonicalPath: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if tooling_stage0CandidateHealthy(root, canonicalPath, probeEnabled, "canonical_recovery_seed"):
        return canonicalPath
    return ""

fn tooling_buildBackendDriverPreferredStage0(root: str, probeEnabled: bool): str =
    return tooling_resolveRecoverySeedCompiler(root, probeEnabled)

fn tooling_stage0DriverKind(root: str, stage0Path: str): str =
    let absPath: str = tooling_pathAbsolute(root, stage0Path)
    let canonical: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if tooling_strEq(absPath, canonical):
        return "canonical"
    if strutil.contains(absPath, "/artifacts/backend_seed/"):
        return "backend_seed"
    if strutil.contains(absPath, "/artifacts/backend_selfhost_self_obj/"):
        return "selfhost_obj"
    return "explicit"

fn tooling_detectHostJobs(root: str): int32 =
    let fromGetconf: os.ExecCmdResult = tooling_exec(root, "getconf _NPROCESSORS_ONLN")
    if os.execCmdResultExitCode(fromGetconf) == 0:
        let parsed0: int32 = tooling_parseInt32Default(os.execCmdResultOutput(fromGetconf), 0)
        if parsed0 > 0:
            return parsed0
    let fromSysctl: os.ExecCmdResult = tooling_exec(root, "sysctl -n hw.logicalcpu")
    if os.execCmdResultExitCode(fromSysctl) == 0:
        let parsed1: int32 = tooling_parseInt32Default(os.execCmdResultOutput(fromSysctl), 0)
        if parsed1 > 0:
            return parsed1
    return 1

fn tooling_copyExecutable(root: str, srcPath: str, dstPath: str): bool =
    if !tooling_strNonEmpty(srcPath) || !tooling_strNonEmpty(dstPath):
        return false
    if tooling_strEq(srcPath, dstPath):
        if !tooling_pathExists(srcPath):
            return false
        let chmodSame: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(dstPath))
        tooling_printExecOutput(chmodSame)
        return os.execCmdResultExitCode(chmodSame) == 0
    return tooling_installExecutableAtomic(root, srcPath, dstPath)

fn tooling_publishTempPath(dstPath: str, suffix: str, nonce: int64): str =
    return dstPath + suffix + int64ToStr(nonce) + ".tmp"

fn tooling_copyExecutablePreserveBytes(root: str, srcPath: str, dstPath: str): bool =
    if !tooling_strNonEmpty(srcPath) || !tooling_strNonEmpty(dstPath):
        return false
    if tooling_strEq(srcPath, dstPath):
        if !tooling_pathExists(srcPath):
            return false
        let chmodSame: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(dstPath))
        tooling_printExecOutput(chmodSame)
        return os.execCmdResultExitCode(chmodSame) == 0
    if tooling_strNonEmpty(os.parentDir(dstPath)):
        if !tooling_mkdirP(root, os.parentDir(dstPath)):
            return false
    let tmpNonce: int64 = tooling_nowNonceValue()
    let copyRes: os.ExecCmdResult = tooling_exec(root,
        "cp -f " + tooling_shellQuote(srcPath) + " " +
        tooling_shellQuote(tooling_publishTempPath(dstPath, ".preserve.", tmpNonce)) +
        " && chmod +x " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".preserve.", tmpNonce)))
    tooling_printExecOutput(copyRes)
    if os.execCmdResultExitCode(copyRes) != 0:
        tooling_exec(root, "rm -f " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".preserve.", tmpNonce)))
        return false
    let mvRes: os.ExecCmdResult = tooling_exec(root,
        "mv -f " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".preserve.", tmpNonce)) +
        " " + tooling_shellQuote(dstPath))
    tooling_printExecOutput(mvRes)
    if os.execCmdResultExitCode(mvRes) != 0:
        tooling_exec(root, "rm -f " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".preserve.", tmpNonce)))
        return false
    return tooling_pathExists(dstPath)

fn tooling_installExecutableNeedsGlobalLock(root: str, dstPathRaw: str): bool =
    if tooling_strEq(
        tooling_pathAbsolute(root, dstPathRaw),
        tooling_pathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling")
    ):
        return true
    if tooling_strEq(
        tooling_pathAbsolute(root, dstPathRaw),
        tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    ):
        return true
    return false

fn tooling_compileNeedsAtomicExePublish(root: str, dstPathRaw: str): bool =
    if !tooling_isTrue(os.getEnvDefault("TOOLING_COMPILE_DIRECT_PUBLISH_NEW", "1")):
        return true
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, dstPathRaw)):
        return true
    if tooling_installExecutableNeedsGlobalLock(root, tooling_pathAbsolute(root, dstPathRaw)):
        return true
    if os.fileExists(tooling_pathAbsolute(root, dstPathRaw)):
        return true
    return false

fn tooling_cleanupCompileExeOutputs(primaryPath: str, tmpLinkObjPath: str,
                                    objPath: str, removePrimary: bool) =
    if removePrimary && os.fileExists(primaryPath):
        os.removeFile(primaryPath)
    if os.fileExists(tmpLinkObjPath):
        os.removeFile(tmpLinkObjPath)
    if os.fileExists(objPath):
        os.removeFile(objPath)

fn tooling_codesignIdentifierSource(dstPathRaw: str): str =
    if tooling_strNonEmpty(os.extractFilename(dstPathRaw)):
        return os.extractFilename(dstPathRaw)
    return "cheng_binary"

fn tooling_codesignIdentifierForPath(dstPathRaw: str): str =
    var out: str[] = []
    for i in 0..<len(tooling_codesignIdentifierSource(dstPathRaw)):
        let c: char = tooling_codesignIdentifierSource(dstPathRaw)[i]
        if (c >= 'a' && c <= 'z') ||
           (c >= 'A' && c <= 'Z') ||
           (c >= '0' && c <= '9') ||
           c == '.' || c == '_' || c == '-':
            add(out, strings.sliceBytes(tooling_codesignIdentifierSource(dstPathRaw), i, 1))
        else:
            add(out, "_")
    if len(out) == 0:
        return "cheng_binary"
    return strutil.join(out, "")

fn tooling_darwinPublishResealEnabled(root: str, dstPath: str): bool =
    return tooling_strEq(tooling_uname(root, "-s"), "darwin") &&
           tooling_installExecutableNeedsGlobalLock(root, dstPath) &&
           tooling_isTrue(os.getEnvDefault("TOOLING_DARWIN_CODESIGN_RESEAL", "1"))

fn tooling_darwinPublishResealSnippet(path: str, dstPath: str): str =
    return " && if command -v codesign >/dev/null 2>&1; then " +
           "codesign --force --sign - --identifier " +
           tooling_shellQuote(tooling_codesignIdentifierForPath(dstPath)) + " " +
           tooling_shellQuote(path) + " >/dev/null 2>&1 && " +
           "codesign --verify --verbose=2 " + tooling_shellQuote(path) + " >/dev/null 2>&1; " +
           "fi" +
           " && if command -v xattr >/dev/null 2>&1; then " +
           "xattr -d com.apple.quarantine " + tooling_shellQuote(path) + " >/dev/null 2>&1 || true; " +
           "xattr -d com.apple.provenance " + tooling_shellQuote(path) + " >/dev/null 2>&1 || true; " +
           "fi"

fn tooling_installExecutableAtomicBaseCommand(root: str, srcPath: str, dstPath: str, nonce: int64): str =
    if tooling_darwinPublishResealEnabled(root, dstPath):
        return "cp -f " + tooling_shellQuote(srcPath) + " " +
               tooling_shellQuote(tooling_publishTempPath(dstPath, ".publish.", nonce)) +
               " && chmod +x " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".publish.", nonce)) +
               tooling_darwinPublishResealSnippet(tooling_publishTempPath(dstPath, ".publish.", nonce), dstPath) +
               " && mv -f " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".publish.", nonce)) +
               " " + tooling_shellQuote(dstPath)
    return "cp -f " + tooling_shellQuote(srcPath) + " " +
           tooling_shellQuote(tooling_publishTempPath(dstPath, ".publish.", nonce)) +
           " && chmod +x " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".publish.", nonce)) +
           " && mv -f " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".publish.", nonce)) +
           " " + tooling_shellQuote(dstPath)

fn tooling_installExecutableAtomicCommand(root: str, srcPath: str, dstPath: str, nonce: int64): str =
    if tooling_installExecutableNeedsGlobalLock(root, dstPath):
        return tooling_wrapCommandWithTimeout(
            root,
            60,
            tooling_wrapStage0Lock(
                root,
                tooling_installExecutableAtomicBaseCommand(root, srcPath, dstPath, nonce),
                "install_exec"
            )
        )
    return tooling_installExecutableAtomicBaseCommand(root, srcPath, dstPath, nonce)

fn tooling_publishExecutableAtomicInPlaceBaseCommand(root: str, srcPath: str, dstPath: str): str =
    if tooling_darwinPublishResealEnabled(root, dstPath):
        return "chmod +x " + tooling_shellQuote(srcPath) +
               tooling_darwinPublishResealSnippet(srcPath, dstPath) +
               " && mv -f " + tooling_shellQuote(srcPath) + " " + tooling_shellQuote(dstPath)
    return "chmod +x " + tooling_shellQuote(srcPath) +
           " && mv -f " + tooling_shellQuote(srcPath) + " " + tooling_shellQuote(dstPath)

fn tooling_publishExecutableAtomicInPlaceCommand(root: str, srcPath: str, dstPath: str): str =
    if tooling_installExecutableNeedsGlobalLock(root, dstPath):
        return tooling_wrapCommandWithTimeout(
            root,
            60,
            tooling_wrapStage0Lock(
                root,
                tooling_publishExecutableAtomicInPlaceBaseCommand(root, srcPath, dstPath),
                "publish_exec"
            )
        )
    return tooling_publishExecutableAtomicInPlaceBaseCommand(root, srcPath, dstPath)

fn tooling_installFileAtomicBaseCommand(srcPath: str, dstPath: str, nonce: int64): str =
    return "cp -f " + tooling_shellQuote(srcPath) + " " +
           tooling_shellQuote(tooling_publishTempPath(dstPath, ".publish.", nonce)) +
           " && mv -f " + tooling_shellQuote(tooling_publishTempPath(dstPath, ".publish.", nonce)) +
           " " + tooling_shellQuote(dstPath)

fn tooling_installFileAtomicCommand(root: str, srcPath: str, dstPath: str, nonce: int64): str =
    if tooling_installExecutableNeedsGlobalLock(root, dstPath):
        return tooling_wrapCommandWithTimeout(
            root,
            60,
            tooling_wrapStage0Lock(
                root,
                tooling_installFileAtomicBaseCommand(srcPath, dstPath, nonce),
                "install_file"
            )
        )
    return tooling_installFileAtomicBaseCommand(srcPath, dstPath, nonce)

fn tooling_installExecutableAtomic(root: str, srcPath: str, dstPath: str): bool =
    if !tooling_strNonEmpty(srcPath) || !tooling_strNonEmpty(dstPath):
        return false
    if tooling_strEq(srcPath, dstPath):
        let chmodSame: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(dstPath))
        tooling_printExecOutput(chmodSame)
        return os.execCmdResultExitCode(chmodSame) == 0
    if tooling_strNonEmpty(os.parentDir(dstPath)):
        if !tooling_mkdirP(root, os.parentDir(dstPath)):
            return false
    let tmpNonce: int64 = tooling_nowNonceValue()
    let res: os.ExecCmdResult = tooling_exec(
        root,
        tooling_installExecutableAtomicCommand(root, srcPath, dstPath, tmpNonce)
    )
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) == 0:
        return true
    if tooling_darwinPublishResealEnabled(root, dstPath):
        tooling_printErr("cheng_tooling: darwin publish reseal/verify failed: " + dstPath)
        tooling_printErr("cheng_tooling: hint: do not execute binaries while they are being rebuilt")
    if os.fileExists(tooling_publishTempPath(dstPath, ".publish.", tmpNonce)):
        os.removeFile(tooling_publishTempPath(dstPath, ".publish.", tmpNonce))
    return false

fn tooling_publishExecutableAtomicInPlace(root: str, srcPathRaw: str, dstPathRaw: str): bool =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, srcPathRaw)) ||
       !tooling_strNonEmpty(tooling_pathAbsolute(root, dstPathRaw)):
        return false
    if !os.fileExists(tooling_pathAbsolute(root, srcPathRaw)):
        return false
    if tooling_strEq(tooling_pathAbsolute(root, srcPathRaw), tooling_pathAbsolute(root, dstPathRaw)):
        let chmodSame: os.ExecCmdResult = tooling_exec(
            root,
            "chmod +x " + tooling_shellQuote(tooling_pathAbsolute(root, dstPathRaw))
        )
        tooling_printExecOutput(chmodSame)
        return os.execCmdResultExitCode(chmodSame) == 0
    if tooling_strNonEmpty(os.parentDir(tooling_pathAbsolute(root, dstPathRaw))):
        if !tooling_mkdirP(root, os.parentDir(tooling_pathAbsolute(root, dstPathRaw))):
            return false
    let res: os.ExecCmdResult = tooling_exec(
        root,
        tooling_publishExecutableAtomicInPlaceCommand(
            root,
            tooling_pathAbsolute(root, srcPathRaw),
            tooling_pathAbsolute(root, dstPathRaw)
        )
    )
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) == 0:
        return true
    if tooling_darwinPublishResealEnabled(root, tooling_pathAbsolute(root, dstPathRaw)):
        tooling_printErr(
            "cheng_tooling: darwin in-place publish reseal/verify failed: " +
            tooling_pathAbsolute(root, dstPathRaw)
        )
        tooling_printErr("cheng_tooling: hint: do not execute binaries while they are being rebuilt")
    return false

fn tooling_installFileAtomic(root: str, srcPathRaw: str, dstPathRaw: str): bool =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, srcPathRaw)) ||
       !tooling_strNonEmpty(tooling_pathAbsolute(root, dstPathRaw)):
        return false
    if !os.fileExists(tooling_pathAbsolute(root, srcPathRaw)):
        return false
    if tooling_strEq(tooling_pathAbsolute(root, srcPathRaw), tooling_pathAbsolute(root, dstPathRaw)):
        return true
    if tooling_strNonEmpty(os.parentDir(tooling_pathAbsolute(root, dstPathRaw))):
        if !tooling_mkdirP(root, os.parentDir(tooling_pathAbsolute(root, dstPathRaw))):
            return false
    let tmpNonce: int64 = tooling_nowNonceValue()
    let res: os.ExecCmdResult = tooling_exec(
        root,
        tooling_installFileAtomicCommand(
            root,
            tooling_pathAbsolute(root, srcPathRaw),
            tooling_pathAbsolute(root, dstPathRaw),
            tmpNonce
        )
    )
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) == 0:
        return true
    if os.fileExists(tooling_publishTempPath(tooling_pathAbsolute(root, dstPathRaw), ".publish.", tmpNonce)):
        os.removeFile(tooling_publishTempPath(tooling_pathAbsolute(root, dstPathRaw), ".publish.", tmpNonce))
    return false

fn tooling_installBuildDriverSidecars(root: str, srcBinRaw: str, dstBinRaw: str, fullRebuild: bool): bool =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, srcBinRaw)) ||
       !tooling_strNonEmpty(tooling_pathAbsolute(root, dstBinRaw)):
        return false
    var ok: bool = true
    if os.fileExists(tooling_buildDriverStampPath(tooling_pathAbsolute(root, srcBinRaw), fullRebuild)):
        if !tooling_installFileAtomic(
            root,
            tooling_buildDriverStampPath(tooling_pathAbsolute(root, srcBinRaw), fullRebuild),
            tooling_buildDriverStampPath(tooling_pathAbsolute(root, dstBinRaw), fullRebuild)
        ):
            ok = false
    if os.fileExists(tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, srcBinRaw))):
        if !tooling_installFileAtomic(
            root,
            tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, srcBinRaw)),
            tooling_stage0CapabilityFilePath(tooling_pathAbsolute(root, dstBinRaw))
        ):
            ok = false
    elif !tooling_stage0CapabilityWriteForOutput(root, tooling_pathAbsolute(root, dstBinRaw)):
        ok = false
    return ok

fn tooling_stage0QuarantineEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_QUARANTINE", "1"))

fn tooling_stage0QuarantineDir(root: str): str =
    return os.joinPath(root, "chengcache/stage0_quarantine")

fn tooling_stage0StampPath(root: str, stage0PathRaw: str, prefixRaw: str): str =
    let prefix: str = strutil.strip(prefixRaw)
    if !tooling_strNonEmpty(prefix):
        return ""
    let stage0Path: str = tooling_pathAbsolute(root, stage0PathRaw)
    if !tooling_strNonEmpty(stage0Path) || !os.fileExists(stage0Path):
        return ""
    let stage0Sha: str = tooling_stage0Sha256FileCached(root, stage0Path)
    if !tooling_strNonEmpty(stage0Sha):
        return ""
    let qdir: str = tooling_stage0QuarantineDir(root)
    tooling_tryMkdirP(root, qdir)
    return os.joinPath(qdir, prefix + "." + stage0Sha + ".env")

fn tooling_stage0CrashStampPath(root: str, stage0PathRaw: str): str =
    return tooling_stage0StampPath(root, stage0PathRaw, "stage0_crash")

fn tooling_stage0BlockStampPath(root: str, stage0PathRaw: str): str =
    return tooling_stage0StampPath(root, stage0PathRaw, "stage0_block")

fn tooling_stage0IgnoreBlockStamp(): bool =
    if tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_IGNORE_BLOCK_STAMP", "0")):
        return true
    return tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_IGNORE_CRASH_STAMP", "0"))

fn tooling_stage0IsSelfhostRecoveryCandidate(root: str, stage0PathRaw: str): bool =
    let stage0Path: str = tooling_pathAbsolute(root, stage0PathRaw)
    if !tooling_strNonEmpty(stage0Path):
        return false
    let selfhostDir: str = tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj")
    if !tooling_strNonEmpty(selfhostDir):
        return false
    if !strutil.startsWith(stage0Path, selfhostDir + "/"):
        return false
    if tooling_strEndsWith(stage0Path, "/cheng.stage2"):
        return true
    if tooling_strEndsWith(stage0Path, "/cheng.stage1"):
        return true
    return false

fn tooling_stage0BlockStamped(root: str, stage0PathRaw: str): bool =
    if tooling_stage0IgnoreBlockStamp():
        return false
    let blockPath: str = tooling_stage0BlockStampPath(root, stage0PathRaw)
    if tooling_strNonEmpty(blockPath) && os.fileExists(blockPath):
        return true
    let crashPath: str = tooling_stage0CrashStampPath(root, stage0PathRaw)
    if !tooling_strNonEmpty(crashPath):
        return false
    return os.fileExists(crashPath)

fn tooling_stage0CrashStamped(root: str, stage0PathRaw: str): bool =
    if tooling_stage0IgnoreBlockStamp():
        return false
    let stampPath: str = tooling_stage0CrashStampPath(root, stage0PathRaw)
    if !tooling_strNonEmpty(stampPath):
        return false
    return os.fileExists(stampPath)

fn tooling_stage0StampContext(contextRaw: str, defaultText: str): str =
    if tooling_strNonEmpty(strutil.strip(contextRaw)):
        return strutil.strip(contextRaw)
    return defaultText

fn tooling_stage0StampReason(reasonRaw: str): str =
    if tooling_strNonEmpty(strutil.strip(reasonRaw)):
        return strutil.strip(reasonRaw)
    return "blocked"

fn tooling_stage0BlockedStampText(stage0Path: str, rc: int32, contextRaw: str, reasonRaw: str): str =
    return "stage0_path=" + stage0Path + "\n" +
           "rc=" + intToStr(rc) + "\n" +
           "kind=" + tooling_exitKind(rc) + "\n" +
           "reason=" + tooling_stage0StampReason(reasonRaw) + "\n" +
           "context=" + tooling_stage0StampContext(contextRaw, "stage0") + "\n" +
           "ts_ms=" + intToStr(tooling_nowMs()) + "\n"

fn tooling_stage0CrashStampText(stage0Path: str, rc: int32, contextRaw: str): str =
    return "stage0_path=" + stage0Path + "\n" +
           "rc=" + intToStr(rc) + "\n" +
           "kind=" + tooling_exitKind(rc) + "\n" +
           "context=" + tooling_stage0StampContext(contextRaw, "stage0") + "\n" +
           "ts_ms=" + intToStr(tooling_nowMs()) + "\n"

fn tooling_stage0ClearSweepCommand(qdir: str, stage0Path: str): str =
    return "qdir=" + tooling_shellQuote(qdir) + "; " +
           "target=" + tooling_shellQuote(stage0Path) + "; " +
           "count=0; " +
           "for stamp in \"$qdir\"/stage0_block.*.env \"$qdir\"/stage0_crash.*.env; do " +
           "  [ -f \"$stamp\" ] || continue; " +
           "  p=$(sed -n 's/^stage0_path=//p' \"$stamp\" | head -n 1); " +
           "  if [ \"$p\" = \"$target\" ]; then " +
           "    rm -f \"$stamp\" && count=$((count + 1)); " +
           "  fi; " +
           "done; " +
           "printf '%s' \"$count\""

fn tooling_stage0MarkBlocked(root: str, stage0PathRaw: str, rc: int32,
                             contextRaw: str, reasonRaw: str) =
    if !tooling_strNonEmpty(stage0PathRaw):
        return
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, stage0PathRaw)):
        return
    if !tooling_strNonEmpty(tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
        return
    if !tooling_writeTextFileViaShell(
        root,
        tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw)),
        tooling_stage0BlockedStampText(tooling_pathAbsolute(root, stage0PathRaw), rc, contextRaw, reasonRaw)
    ):
        os.writeFile(
            tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw)),
            tooling_stage0BlockedStampText(tooling_pathAbsolute(root, stage0PathRaw), rc, contextRaw, reasonRaw)
        )
    if os.fileExists(tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
        tooling_printErr(
            "cheng_tooling: stage0 blocked stamp written: " +
            tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))
        )
    else:
        tooling_printErr(
            "cheng_tooling: stage0 blocked stamp write failed: " +
            tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))
        )

fn tooling_stage0MarkCrash(root: str, stage0PathRaw: str, rc: int32, contextRaw: str) =
    if rc < 128:
        return
    tooling_stage0MarkBlocked(root, stage0PathRaw, rc, contextRaw, "crash")
    if !tooling_strNonEmpty(tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
        return
    if !tooling_writeTextFileViaShell(
        root,
        tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw)),
        tooling_stage0CrashStampText(tooling_pathAbsolute(root, stage0PathRaw), rc, contextRaw)
    ):
        os.writeFile(
            tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw)),
            tooling_stage0CrashStampText(tooling_pathAbsolute(root, stage0PathRaw), rc, contextRaw)
        )
    if os.fileExists(tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
        tooling_printErr(
            "cheng_tooling: stage0 crash stamped: " +
            tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))
        )
    else:
        tooling_printErr(
            "cheng_tooling: stage0 crash stamp write failed: " +
            tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))
        )

fn tooling_stage0ClearStamps(root: str, stage0PathRaw: str, contextRaw: str): int32 =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)):
        return 0
    if !os.dirExists(tooling_stage0QuarantineDir(root)):
        return 0
    var cleaned: int32 = 0
    if tooling_strNonEmpty(tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))) &&
       os.fileExists(tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
        os.removeFile(tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw)))
        if !os.fileExists(tooling_stage0BlockStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
            cleaned = cleaned + 1
    if tooling_strNonEmpty(tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))) &&
       os.fileExists(tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
        os.removeFile(tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw)))
        if !os.fileExists(tooling_stage0CrashStampPath(root, tooling_pathAbsolute(root, stage0PathRaw))):
            cleaned = cleaned + 1
    let res: os.ExecCmdResult = tooling_exec(
        root,
        tooling_stage0ClearSweepCommand(tooling_stage0QuarantineDir(root), tooling_pathAbsolute(root, stage0PathRaw))
    )
    if os.execCmdResultExitCode(res) == 0:
        cleaned = cleaned + tooling_parseInt32Default(strutil.strip(os.execCmdResultOutput(res)), 0)
    if cleaned > 0:
        tooling_printErr(
            "cheng_tooling: cleared stage0 quarantine stamps for " +
            tooling_stage0StampContext(contextRaw, "stage0_clear") +
            " path=" + tooling_pathAbsolute(root, stage0PathRaw) +
            " count=" + intToStr(cleaned)
        )
    return cleaned

fn tooling_stage0LockEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_LOCK", "1"))

fn tooling_stage0LockCompileExecEnabled(): bool =
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("TOOLING_STAGE0_LOCK_COMPILE_EXE", ""))):
        return tooling_isTrue(strutil.strip(os.getEnvDefault("TOOLING_STAGE0_LOCK_COMPILE_EXE", "")))
    return false

fn tooling_stage0LockContextEnabled(contextRaw: str): bool =
    if !tooling_stage0LockEnabled():
        return false
    if tooling_strContains(strutil.strip(contextRaw), "compile_exe"):
        # compile_exe already runs a mirrored immutable stage0 path produced by
        # tooling_prepareStage0Exec, so holding the global stage0 lock across
        # the whole compile only adds wrapper latency on the hot dev path.
        return tooling_stage0LockCompileExecEnabled()
    return true

fn tooling_stage0LockDir(root: str): str =
    return os.joinPath(tooling_stage0QuarantineDir(root), "stage0.lock")

fn tooling_stage0LockContextPreferTakeover(context: str): bool =
    if tooling_strContains(context, "build_backend_driver"):
        return true
    if tooling_strContains(context, "stage0_compile_probe"):
        return true
    if tooling_strContains(context, "runtime_obj_refresh"):
        return true
    return false

fn tooling_stage0LockContextText(contextRaw: str): str =
    return tooling_stage0StampContext(contextRaw, "stage0")

fn tooling_stage0LockWaitSecEnv(): str =
    return strutil.strip(os.getEnvDefault("TOOLING_STAGE0_LOCK_WAIT_SEC", ""))

fn tooling_stage0LockForceTakeoverEnv(): str =
    return strutil.strip(os.getEnvDefault("TOOLING_STAGE0_LOCK_FORCE_TAKEOVER", ""))

fn tooling_stage0LockWaitSecDefault(contextRaw: str, autoTakeoverDefault: bool): int32 =
    if autoTakeoverDefault &&
       !tooling_strNonEmpty(tooling_stage0LockWaitSecEnv()) &&
       tooling_stage0LockContextPreferTakeover(tooling_stage0LockContextText(contextRaw)):
        return 5
    return 60

fn tooling_stage0LockForceTakeoverEnabled(contextRaw: str, autoTakeoverDefault: bool): bool =
    if tooling_strNonEmpty(tooling_stage0LockForceTakeoverEnv()):
        return tooling_isTrue(tooling_stage0LockForceTakeoverEnv())
    if autoTakeoverDefault:
        return tooling_stage0LockContextPreferTakeover(tooling_stage0LockContextText(contextRaw))
    return false

fn tooling_stage0LockForceTakeoverText(contextRaw: str, autoTakeoverDefault: bool): str =
    if tooling_stage0LockForceTakeoverEnabled(contextRaw, autoTakeoverDefault):
        return "1"
    return "0"

fn tooling_stage0LockTimeoutMsg(root: str, contextRaw: str): str =
    return "cheng_tooling: stage0 lock timeout context=" +
           tooling_stage0LockContextText(contextRaw) +
           " lock=" + tooling_stage0LockDir(root)

fn tooling_stage0LockTakeoverMsg(root: str, contextRaw: str): str =
    return "cheng_tooling: stage0 lock forced takeover context=" +
           tooling_stage0LockContextText(contextRaw) +
           " lock=" + tooling_stage0LockDir(root)

fn tooling_stage0LockWrappedCommand(lockDir: str, waitSec: int32, staleSec: int32,
                                    forceTakeoverText: str, timeoutMsg: str,
                                    takeoverMsg: str, runSnippet: str): str =
    var parts: str[] = []
    add(parts, "lock_dir=")
    add(parts, tooling_shellQuote(lockDir))
    add(parts, " ; lock_owner=\"$lock_dir/owner.pid\" ; lock_owner_pgid=\"$lock_dir/owner.pgid\" ; ")
    add(parts, "lock_since=\"$lock_dir/since.epoch\" ; wait_sec=")
    add(parts, intToStr(waitSec))
    add(parts, " ; stale_sec=")
    add(parts, intToStr(staleSec))
    add(parts, " ; force_takeover=")
    add(parts, forceTakeoverText)
    add(parts, " ; lock_start=$(date +%s 2>/dev/null || echo 0) ; lock_wait_ms=0 ; ")
    add(parts, "while ! mkdir \"$lock_dir\" 2>/dev/null; do ")
    add(parts, "  now=$(date +%s 2>/dev/null || echo 0) ; ")
    add(parts, "  owner_pid=\"\" ; if [ -f \"$lock_owner\" ]; then owner_pid=$(cat \"$lock_owner\" 2>/dev/null); fi ; ")
    add(parts, "  owner_pgid=\"\" ; if [ -f \"$lock_owner_pgid\" ]; then owner_pgid=$(cat \"$lock_owner_pgid\" 2>/dev/null); fi ; ")
    add(parts, "  case \"$owner_pid\" in ''|*[!0-9]*) owner_pid=\"\" ;; esac ; ")
    add(parts, "  case \"$owner_pgid\" in ''|*[!0-9]*) owner_pgid=\"\" ;; esac ; ")
    add(parts, "  kill_group=\"$owner_pgid\" ; if [ -z \"$kill_group\" ]; then kill_group=\"$owner_pid\"; fi ; ")
    add(parts, "  owner_alive=0 ; if [ -n \"$owner_pid\" ] && kill -0 \"$owner_pid\" 2>/dev/null; then owner_alive=1; fi ; ")
    add(parts, "  stale=0 ; ")
    add(parts, "  if [ -f \"$lock_since\" ]; then ")
    add(parts, "    lock_ts=$(cat \"$lock_since\" 2>/dev/null) ; ")
    add(parts, "    if [ -n \"$lock_ts\" ] && [ \"$stale_sec\" -gt 0 ] && [ \"$now\" -gt 0 ] && [ \"$lock_ts\" -gt 0 ]; then ")
    add(parts, "      if [ $((now - lock_ts)) -ge \"$stale_sec\" ]; then stale=1; fi ; ")
    add(parts, "    fi ; ")
    add(parts, "  fi ; ")
    add(parts, "  if [ \"$owner_alive\" -eq 0 ]; then rm -rf \"$lock_dir\" 2>/dev/null ; continue; fi ; ")
    add(parts, "  if [ \"$stale\" -eq 1 ]; then ")
    add(parts, "    if [ \"$force_takeover\" = \"1\" ]; then ")
    add(parts, "      if [ -n \"$kill_group\" ]; then kill -TERM -\"$kill_group\" >/dev/null 2>&1 || true ; fi ; ")
    add(parts, "      if [ -n \"$owner_pid\" ]; then ")
    add(parts, "        kill -TERM \"$owner_pid\" >/dev/null 2>&1 || true ; sleep 0.2 ; ")
    add(parts, "        if [ -n \"$kill_group\" ]; then kill -KILL -\"$kill_group\" >/dev/null 2>&1 || true ; fi ; ")
    add(parts, "        kill -KILL \"$owner_pid\" >/dev/null 2>&1 || true ; ")
    add(parts, "      fi ; ")
    add(parts, "      rm -rf \"$lock_dir\" >/dev/null 2>&1 || true ; echo ")
    add(parts, tooling_shellQuote(takeoverMsg))
    add(parts, " >&2 ; lock_start=\"$now\" ; continue; ")
    add(parts, "    fi ; ")
    add(parts, "    echo ")
    add(parts, tooling_shellQuote(timeoutMsg))
    add(parts, " >&2 ; exit 125 ; ")
    add(parts, "  fi ; ")
    add(parts, "  if [ \"$wait_sec\" -gt 0 ] && [ \"$now\" -gt 0 ] && [ \"$lock_start\" -gt 0 ] && [ $((now - lock_start)) -ge \"$wait_sec\" ]; then ")
    add(parts, "    if [ \"$force_takeover\" = \"1\" ]; then ")
    add(parts, "      if [ -n \"$kill_group\" ]; then kill -TERM -\"$kill_group\" >/dev/null 2>&1 || true ; fi ; ")
    add(parts, "      if [ -n \"$owner_pid\" ]; then ")
    add(parts, "        kill -TERM \"$owner_pid\" >/dev/null 2>&1 || true ; sleep 0.2 ; ")
    add(parts, "        if [ -n \"$kill_group\" ]; then kill -KILL -\"$kill_group\" >/dev/null 2>&1 || true ; fi ; ")
    add(parts, "        kill -KILL \"$owner_pid\" >/dev/null 2>&1 || true ; ")
    add(parts, "      fi ; ")
    add(parts, "      rm -rf \"$lock_dir\" >/dev/null 2>&1 || true ; echo ")
    add(parts, tooling_shellQuote(takeoverMsg))
    add(parts, " >&2 ; lock_start=\"$now\" ; continue; ")
    add(parts, "    fi ; ")
    add(parts, "    echo ")
    add(parts, tooling_shellQuote(timeoutMsg))
    add(parts, " >&2 ; exit 125 ; ")
    add(parts, "  fi ; ")
    add(parts, "  sleep 0.1 ; done ; ")
    add(parts, "lock_now=$(date +%s 2>/dev/null || echo 0) ; ")
    add(parts, "if [ \"$lock_now\" -gt 0 ] && [ \"$lock_start\" -gt 0 ] && [ \"$lock_now\" -ge \"$lock_start\" ]; then ")
    add(parts, "  lock_wait_ms=$(( (lock_now - lock_start) * 1000 )) ; ")
    add(parts, "fi ; ")
    add(parts, "echo $$ > \"$lock_owner\" 2>/dev/null ; ")
    add(parts, "owner_pgid=$(ps -o pgid= -p $$ 2>/dev/null | tr -d '[:space:]') ; ")
    add(parts, "case \"$owner_pgid\" in ''|*[!0-9]*) owner_pgid=$$ ;; esac ; ")
    add(parts, "echo \"$owner_pgid\" > \"$lock_owner_pgid\" 2>/dev/null || true ; ")
    add(parts, "date +%s > \"$lock_since\" 2>/dev/null ; ")
    add(parts, "trap 'rm -rf \"$lock_dir\" >/dev/null 2>&1' EXIT INT TERM ; ")
    add(parts, "TOOLING_STAGE0_LOCK_WAIT_MS=\"$lock_wait_ms\" ; export TOOLING_STAGE0_LOCK_WAIT_MS ; ")
    add(parts, runSnippet)
    add(parts, "rm -rf \"$lock_dir\" >/dev/null 2>&1 ; trap - EXIT INT TERM ; exit $rc")
    return tooling_joinFragments(parts)

fn tooling_wrapStage0Lock(root: str, command: str, contextRaw: str): str =
    if !tooling_strNonEmpty(command):
        return command
    if !tooling_stage0LockContextEnabled(contextRaw):
        return command
    tooling_tryMkdirP(root, tooling_stage0QuarantineDir(root))
    let autoTakeoverDefault: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_LOCK_AUTO_TAKEOVER", "0"))
    var waitSec: int32 = tooling_parseInt32Default(
        tooling_stage0LockWaitSecEnv(),
        tooling_stage0LockWaitSecDefault(contextRaw, autoTakeoverDefault)
    )
    if waitSec < 0:
        waitSec = 0
    var staleSec: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_LOCK_STALE_SEC", ""), 600)
    if staleSec < 0:
        staleSec = 0
    return tooling_stage0LockWrappedCommand(
        tooling_stage0LockDir(root),
        waitSec,
        staleSec,
        tooling_stage0LockForceTakeoverText(contextRaw, autoTakeoverDefault),
        tooling_stage0LockTimeoutMsg(root, contextRaw),
        tooling_stage0LockTakeoverMsg(root, contextRaw),
        "eval " + tooling_shellQuote(command) + " ; rc=$? ; "
    )

fn tooling_wrapCommandWithTimeout(root: str, timeoutSecRaw: int32, command: str): str =
    return tooling_wrapCommandWithTimeoutWithContext(root, timeoutSecRaw, command, "")

fn tooling_timeoutInlineRunSnippet(root: str, timeoutSecRaw: int32, command: str, contextRaw: str): str =
    var timeoutSec: int32 = timeoutSecRaw
    if timeoutSec <= 0:
        return "eval " + tooling_shellQuote(command) + " ; rc=$? ; "
    let useExternalTimeout: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_TIMEOUT_USE_EXTERNAL", "0"))
    if useExternalTimeout:
        if tooling_strNonEmpty(tooling_timeoutCommand(root)):
            return tooling_timeoutCommand(root) + " " + intToStr(timeoutSec) + "s sh -c " + tooling_shellQuote(command) +
                   " ; rc=$? ; "
    return "eval " +
           tooling_shellQuote(tooling_wrapCommandWithTimeoutWithContext(root, timeoutSec, command, contextRaw)) +
           " ; rc=$? ; "

fn tooling_wrapStage0LockTimeout(root: str, timeoutSecRaw: int32, command: str, contextRaw: str): str =
    if !tooling_strNonEmpty(command):
        return command
    if !tooling_stage0LockContextEnabled(tooling_stage0LockContextText(contextRaw)):
        return tooling_wrapCommandWithTimeoutWithContext(
            root,
            timeoutSecRaw,
            command,
            tooling_stage0LockContextText(contextRaw)
        )
    tooling_tryMkdirP(root, tooling_stage0QuarantineDir(root))
    let autoTakeoverDefault: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_LOCK_AUTO_TAKEOVER", "0"))
    var waitSec: int32 = tooling_parseInt32Default(
        tooling_stage0LockWaitSecEnv(),
        tooling_stage0LockWaitSecDefault(contextRaw, autoTakeoverDefault)
    )
    if waitSec < 0:
        waitSec = 0
    var staleSec: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_LOCK_STALE_SEC", ""), 600)
    if staleSec < 0:
        staleSec = 0
    return tooling_stage0LockWrappedCommand(
        tooling_stage0LockDir(root),
        waitSec,
        staleSec,
        tooling_stage0LockForceTakeoverText(contextRaw, autoTakeoverDefault),
        tooling_stage0LockTimeoutMsg(root, contextRaw),
        tooling_stage0LockTakeoverMsg(root, contextRaw),
        tooling_timeoutInlineRunSnippet(root, timeoutSecRaw, command, tooling_stage0LockContextText(contextRaw))
    )

fn tooling_stage0UeCommandRelevant(root: str, qdir: str, cmdRaw: str): bool =
    if !tooling_strNonEmpty(strutil.strip(cmdRaw)):
        return false
    if tooling_strNonEmpty(qdir) && strutil.contains(strutil.strip(cmdRaw), qdir):
        return true
    # Cross-workspace guard is always on for production closure.
    if strutil.contains(strutil.strip(cmdRaw), "/stage0_quarantine/cheng."):
        return true
    if tooling_strNonEmpty(os.joinPath(root, "artifacts/backend_driver/cheng")) &&
       strutil.contains(strutil.strip(cmdRaw), os.joinPath(root, "artifacts/backend_driver/cheng")):
        return true
    if strutil.contains(strutil.strip(cmdRaw), "/artifacts/backend_driver/cheng") ||
       strutil.contains(strutil.strip(cmdRaw), "artifacts/backend_driver/cheng"):
        return true
    if tooling_strNonEmpty(os.joinPath(root, "artifacts/backend_selfhost_self_obj/cheng.stage2")) &&
       strutil.contains(
           strutil.strip(cmdRaw),
           os.joinPath(root, "artifacts/backend_selfhost_self_obj/cheng.stage2")
       ):
        return true
    if tooling_strNonEmpty(os.joinPath(root, "artifacts/backend_selfhost_self_obj/cheng.stage1")) &&
       strutil.contains(
           strutil.strip(cmdRaw),
           os.joinPath(root, "artifacts/backend_selfhost_self_obj/cheng.stage1")
       ):
        return true
    if strutil.contains(strutil.strip(cmdRaw), "/artifacts/backend_selfhost_self_obj/cheng.stage2") ||
       strutil.contains(strutil.strip(cmdRaw), "artifacts/backend_selfhost_self_obj/cheng.stage2"):
        return true
    if strutil.contains(strutil.strip(cmdRaw), "/artifacts/backend_selfhost_self_obj/cheng.stage1") ||
       strutil.contains(strutil.strip(cmdRaw), "artifacts/backend_selfhost_self_obj/cheng.stage1"):
        return true
    if strutil.contains(strutil.strip(cmdRaw), "artifacts/tooling_cmd/cheng_tooling"):
        return true
    if tooling_strNonEmpty(os.joinPath(root, "artifacts/tooling_cmd/cheng_tooling")) &&
       strutil.contains(strutil.strip(cmdRaw), os.joinPath(root, "artifacts/tooling_cmd/cheng_tooling")):
        return true
    if strutil.startsWith(strutil.strip(cmdRaw), "cheng_tooling ") ||
       tooling_strEq(strutil.strip(cmdRaw), "cheng_tooling"):
        return true
    return false

fn tooling_stage0PidHasOrphanRelevantAncestor(pidRaw: str, pidTokens: str[],
                                              ppidTokens: str[], relevant: bool[]): bool =
    return tooling_stage0PidHasOrphanRelevantAncestorAt(pidRaw, pidTokens, ppidTokens, relevant, 0)

fn tooling_stage0PidHasOrphanRelevantAncestorAt(pidRaw: str, pidTokens: str[],
                                                ppidTokens: str[], relevant: bool[],
                                                depth: int32): bool =
    if !tooling_strNonEmpty(strutil.strip(pidRaw)):
        return false
    if depth >= 32:
        return false
    var idx: int32 = -1
    for i in 0..<pidTokens.len:
        if tooling_strEq(strutil.strip(pidTokens[i]), strutil.strip(pidRaw)):
            idx = i
            break
    if idx < 0:
        return false
    if idx >= relevant.len || !relevant[idx]:
        return false
    if idx >= ppidTokens.len:
        return false
    if tooling_strEq(strutil.strip(ppidTokens[idx]), "1"):
        return true
    return tooling_stage0PidHasOrphanRelevantAncestorAt(
        strutil.strip(ppidTokens[idx]), pidTokens, ppidTokens, relevant, depth + 1)

fn tooling_stage0QuarantineOnlyOrphanUe(root: str): bool =
    return false

fn tooling_stage0QuarantineCleanMemoPath(root: str): str =
    return os.joinPath(tooling_stage0QuarantineDir(root), "ue.clean.memo")

fn tooling_stage0PreflightMemoPath(root: str): str =
    return os.joinPath(tooling_stage0QuarantineDir(root), "stage0.preflight.memo")

fn tooling_stage0PreflightMemoText(stage0Exec: str, runProbe: bool): str =
    return "version=1\n" +
           "stage0_exec=" + stage0Exec + "\n" +
           "stage0_size=" + int64ToStr(os.fileSize(stage0Exec)) + "\n" +
           "stage0_mtime=" + int64ToStr(os.fileMtime(stage0Exec)) + "\n" +
           "run_probe=" + tooling_boolText(runProbe) + "\n"

fn tooling_stage0QuarantineCleanMemoTtlMs(contextRaw: str): int32 =
    let envRaw: str = strutil.strip(os.getEnvDefault("TOOLING_STAGE0_QUARANTINE_CLEAN_TTL_MS", ""))
    if tooling_strNonEmpty(envRaw):
        let parsed: int32 = tooling_parseInt32Default(envRaw, 0)
        if parsed > 0:
            return parsed
    let context: str = strutil.toLowerAscii(strutil.strip(contextRaw))
    if strutil.contains(context, "compile") || strutil.contains(context, "build_global"):
        return tooling_stage0FastMemoTtlMs
    return 0

fn tooling_stage0QuarantineCleanMemoFresh(root: str, contextRaw: str): bool =
    let ttlMs: int32 = tooling_stage0QuarantineCleanMemoTtlMs(contextRaw)
    if ttlMs <= 0:
        return false
    let nowMonoMs: int64 = tooling_nowMs()
    if tooling_stage0QuarantineCleanProcessUntilMs > nowMonoMs:
        return true
    let memoPath: str = tooling_stage0QuarantineCleanMemoPath(root)
    if !os.fileExists(memoPath):
        return false
    let memoMtime: int64 = os.fileMtime(memoPath)
    if memoMtime <= int64(0):
        return false
    # file mtime is epoch-based, so use wall-clock here; mixing monotonic time
    # with epoch timestamps makes the clean memo appear permanently stale.
    let nowEpochMs: int64 = tooling_nowEpochMs(root)
    if nowEpochMs <= int64(0):
        return false
    let ageMs: int64 = nowEpochMs - memoMtime * int64(1000)
    if ageMs < int64(0):
        return false
    if ageMs > int64(ttlMs):
        return false
    tooling_stage0QuarantineCleanProcessUntilMs = nowMonoMs + int64(ttlMs)
    return true

fn tooling_stage0PreflightMemoTtlMs(): int32 =
    let envRaw: str = strutil.strip(os.getEnvDefault("TOOLING_STAGE0_PREFLIGHT_TTL_MS", ""))
    if tooling_strNonEmpty(envRaw):
        let parsed: int32 = tooling_parseInt32Default(envRaw, 0)
        if parsed > 0:
            return parsed
    return tooling_stage0FastMemoTtlMs

fn tooling_stage0PreflightMemoFresh(root: str, stage0ExecRaw: str, runProbe: bool): bool =
    let ttlMs: int32 = tooling_stage0PreflightMemoTtlMs()
    if ttlMs <= 0:
        return false
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0ExecRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, stage0ExecRaw)):
        return false
    if !tooling_strNonEmpty(tooling_stage0PreflightMemoPath(root)) ||
       !os.fileExists(tooling_stage0PreflightMemoPath(root)):
        return false
    let memoMtime: int64 = os.fileMtime(tooling_stage0PreflightMemoPath(root))
    if memoMtime <= int64(0):
        return false
    let nowEpochMs: int64 = tooling_nowEpochMs(root)
    if nowEpochMs <= int64(0):
        return false
    let ageMs: int64 = nowEpochMs - memoMtime * int64(1000)
    if ageMs < int64(0) || ageMs > int64(ttlMs):
        return false
    if !tooling_strEq(
        tooling_kvGet(tooling_readTextFile(root, tooling_stage0PreflightMemoPath(root)), "version"),
        "1"
    ):
        return false
    if !tooling_strEq(
        tooling_kvGet(tooling_readTextFile(root, tooling_stage0PreflightMemoPath(root)), "stage0_exec"),
        tooling_pathAbsolute(root, stage0ExecRaw)
    ):
        return false
    if !tooling_strEq(
        tooling_kvGet(tooling_readTextFile(root, tooling_stage0PreflightMemoPath(root)), "stage0_size"),
        int64ToStr(os.fileSize(tooling_pathAbsolute(root, stage0ExecRaw)))
    ):
        return false
    if !tooling_strEq(
        tooling_kvGet(tooling_readTextFile(root, tooling_stage0PreflightMemoPath(root)), "stage0_mtime"),
        int64ToStr(os.fileMtime(tooling_pathAbsolute(root, stage0ExecRaw)))
    ):
        return false
    if !tooling_strEq(
        tooling_kvGet(tooling_readTextFile(root, tooling_stage0PreflightMemoPath(root)), "run_probe"),
        tooling_boolText(runProbe)
    ):
        return false
    return true

fn tooling_stage0PreflightMemoWrite(root: str, stage0ExecRaw: str, runProbe: bool) =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0ExecRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, stage0ExecRaw)):
        return
    if !tooling_strNonEmpty(tooling_stage0PreflightMemoPath(root)):
        return
    if tooling_strNonEmpty(os.parentDir(tooling_stage0PreflightMemoPath(root))):
        tooling_tryMkdirP(root, os.parentDir(tooling_stage0PreflightMemoPath(root)))
    if !tooling_writeTextFileViaShell(
        root,
        tooling_stage0PreflightMemoPath(root),
        tooling_stage0PreflightMemoText(tooling_pathAbsolute(root, stage0ExecRaw), runProbe)
    ):
        os.writeFile(
            tooling_stage0PreflightMemoPath(root),
            tooling_stage0PreflightMemoText(tooling_pathAbsolute(root, stage0ExecRaw), runProbe)
        )

fn tooling_stage0QuarantineMarkClean(root: str, contextRaw: str) =
    let ttlMs: int32 = tooling_stage0QuarantineCleanMemoTtlMs(contextRaw)
    if ttlMs <= 0:
        return
    tooling_stage0QuarantineCleanProcessUntilMs = tooling_nowMs() + int64(ttlMs)
    if tooling_strNonEmpty(os.parentDir(tooling_stage0QuarantineCleanMemoPath(root))):
        tooling_tryMkdirP(root, os.parentDir(tooling_stage0QuarantineCleanMemoPath(root)))
    os.writeFile(tooling_stage0QuarantineCleanMemoPath(root), "")

fn tooling_stage0QuarantineClearCleanMemo(root: str, contextRaw: str) =
    let ttlMs: int32 = tooling_stage0QuarantineCleanMemoTtlMs(contextRaw)
    if ttlMs <= 0:
        return
    tooling_stage0QuarantineCleanProcessUntilMs = int64(0)
    if os.fileExists(tooling_stage0QuarantineCleanMemoPath(root)):
        os.removeFile(tooling_stage0QuarantineCleanMemoPath(root))

fn tooling_stage0UeRowRelevant(root: str, qdir: str, line: str, orphanGuard: bool): bool =
    let n: int32 = len(line)
    if n <= 0:
        return false
    var j: int32 = 0
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    let pidStart: int32 = j
    while j < n && line[j] != ' ' && line[j] != '\t':
        j = j + 1
    if j <= pidStart:
        return false
    let pidEnd: int32 = j
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    let ppidStart: int32 = j
    while j < n && line[j] != ' ' && line[j] != '\t':
        j = j + 1
    if j <= ppidStart:
        return false
    let ppidEnd: int32 = j
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    let stateStart: int32 = j
    while j < n && line[j] != ' ' && line[j] != '\t':
        j = j + 1
    if j <= stateStart:
        return false
    if !(tooling_strNonEmpty(strings.sliceBytes(line, stateStart, j - stateStart)) &&
         strings.sliceBytes(line, stateStart, j - stateStart)[0] == 'U') &&
       !(orphanGuard &&
         tooling_strEq(strutil.strip(strings.sliceBytes(line, ppidStart, ppidEnd - ppidStart)), "1")):
        return false
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    if j >= n:
        return false
    if !tooling_stage0UeCommandRelevant(root, qdir, strings.sliceBytes(line, j, n - j)):
        return false
    if tooling_strNonEmpty(tooling_stage0UeGenerationPath(root, qdir, strings.sliceBytes(line, j, n - j))) &&
       tooling_stage0PidHistoricalForGenerationPath(
           root,
           strings.sliceBytes(line, pidStart, pidEnd - pidStart),
           tooling_stage0UeGenerationPath(root, qdir, strings.sliceBytes(line, j, n - j))
       ):
        return false
    return true

fn tooling_stage0UeRowPreviewText(root: str, qdir: str, line: str, orphanGuard: bool): str =
    let n: int32 = len(line)
    if n <= 0:
        return ""
    var j: int32 = 0
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    let pidStart: int32 = j
    while j < n && line[j] != ' ' && line[j] != '\t':
        j = j + 1
    if j <= pidStart:
        return ""
    let pidEnd: int32 = j
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    let ppidStart: int32 = j
    while j < n && line[j] != ' ' && line[j] != '\t':
        j = j + 1
    if j <= ppidStart:
        return ""
    let ppidEnd: int32 = j
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    let stateStart: int32 = j
    while j < n && line[j] != ' ' && line[j] != '\t':
        j = j + 1
    if j <= stateStart:
        return ""
    let stateEnd: int32 = j
    while j < n && (line[j] == ' ' || line[j] == '\t'):
        j = j + 1
    if j >= n:
        return ""
    if !tooling_stage0UeRowRelevant(root, qdir, line, orphanGuard):
        return ""
    return "pid=" + strutil.strip(strings.sliceBytes(line, pidStart, pidEnd - pidStart)) +
           ",ppid=" + strutil.strip(strings.sliceBytes(line, ppidStart, ppidEnd - ppidStart)) +
           ",state=" + strings.sliceBytes(line, stateStart, stateEnd - stateStart) +
           ",cmd=" + strings.sliceBytes(line, j, n - j)

fn tooling_stage0QuarantineUeCount(root: str): int32 =
    let psRes: os.ExecCmdResult = tooling_exec(root, "ps -Ao pid=,ppid=,state=,command=")
    if os.execCmdResultExitCode(psRes) != 0:
        return 0
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(psRes))
    let orphanGuard: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_ORPHAN_GUARD", "1"))
    var count: int32 = 0
    for i in 0..<rows.len:
        if !tooling_stage0UeRowRelevant(root, tooling_stage0QuarantineDir(root), rows[i], orphanGuard):
            continue
        count = count + 1
    return count

fn tooling_stage0QuarantineUePreview(root: str, limitRaw: int32): str =
    let psRes: os.ExecCmdResult = tooling_exec(root, "ps -Ao pid=,ppid=,state=,command=")
    if os.execCmdResultExitCode(psRes) != 0:
        return ""
    var limit: int32 = limitRaw
    if limit < 1:
        limit = 1
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(psRes))
    let orphanGuard: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_ORPHAN_GUARD", "1"))
    var found: int32 = 0
    var parts: str[] = []
    for i in 0..<rows.len:
        if !tooling_strNonEmpty(
            tooling_stage0UeRowPreviewText(root, tooling_stage0QuarantineDir(root), rows[i], orphanGuard)
        ):
            continue
        found = found + 1
        if found > limit:
            continue
        add(parts, tooling_stage0UeRowPreviewText(root, tooling_stage0QuarantineDir(root), rows[i], orphanGuard))
    if found > limit:
        add(parts, "+" + intToStr(found - limit) + " more")
    return strutil.join(parts, " | ")

fn tooling_cmdStage0UeStatus(root: str, limitRaw: int32, showAll: bool): int32 =
    var limit: int32 = limitRaw
    if limit < 1:
        limit = 8
    let ueCount: int32 = tooling_stage0QuarantineUeCount(root)
    if showAll && ueCount > 0:
        limit = ueCount
    tooling_printOut("stage0_ue_count=" + intToStr(ueCount))
    tooling_printOut("stage0_ue_limit=" + intToStr(limit))
    tooling_printOut("stage0_ue_show_all=" + tooling_boolText(showAll))
    tooling_printOut("stage0_ue_hard_block=" + tooling_boolText(
                     tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_HARD_BLOCK_ON_UE", "1"))))
    if ueCount > 0 && tooling_strNonEmpty(tooling_stage0QuarantineUePreview(root, limit)):
        tooling_printOut("stage0_ue_preview=" + tooling_stage0QuarantineUePreview(root, limit))
    else:
        tooling_printOut("stage0_ue_preview=")
    return 0

fn tooling_cmdStage0UeStatusFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var limit: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_UE_STATUS_LIMIT", ""), 8)
    if limit < 1:
        limit = 8
    var showAll: bool = false
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        if tooling_strEq(tooling_paramStr(i), "--help") || tooling_strEq(tooling_paramStr(i), "-h"):
            tooling_printOut("stage0-ue-status options:")
            tooling_printOut("  --limit:<N>                 preview limit (default 8)")
            tooling_printOut("  --all                       show full preview list (can be long)")
            tooling_printOut("  env: TOOLING_STAGE0_UE_STATUS_LIMIT=<N>")
            return 0
        if strutil.startsWith(tooling_paramStr(i), "--limit:"):
            limit = tooling_parseInt32Default(strings.dropPrefix(tooling_paramStr(i), "--limit:"), limit)
            if limit < 1:
                limit = 1
            i = i + 1
            continue
        if tooling_strEq(tooling_paramStr(i), "--all"):
            showAll = true
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown stage0-ue-status arg: " + tooling_paramStr(i))
        return 1
    return tooling_cmdStage0UeStatus(root, limit, showAll)

fn tooling_stage0UeCleanContextText(contextRaw: str): str =
    if tooling_strNonEmpty(strutil.strip(contextRaw)):
        return strutil.strip(contextRaw)
    return "stage0_ue_clean"

fn tooling_cmdStage0UeClean(root: str, contextRaw: str, rechecksRaw: int32,
                            strict: bool, dryRun: bool, globalMode: bool): int32 =
    var rechecks: int32 = rechecksRaw
    if rechecks < 0:
        rechecks = 0
    let beforeCount: int32 = tooling_stage0QuarantineUeCount(root)
    var cleanedTotal: int32 = 0
    if !dryRun && beforeCount > 0:
        cleanedTotal = cleanedTotal + tooling_stage0QuarantineSweepUe(root, tooling_stage0UeCleanContextText(contextRaw))
        if globalMode:
            cleanedTotal = cleanedTotal + tooling_stage0QuarantineSweepUe(
                root, tooling_stage0UeCleanContextText(contextRaw) + ".global")
    var afterCount: int32 = tooling_stage0QuarantineUeCount(root)
    if !dryRun && afterCount > 0 && cleanedTotal > 0:
        for ri in 1..rechecks:
            let _sleepRes: os.ExecCmdResult = tooling_exec(root, "sleep 0.2")
            let cleanedRetry: int32 = tooling_stage0QuarantineSweepUe(
                root, tooling_stage0UeCleanContextText(contextRaw) + ".recheck." + intToStr(ri))
            cleanedTotal = cleanedTotal + cleanedRetry
            afterCount = tooling_stage0QuarantineUeCount(root)
            if afterCount <= 0:
                break
    let previewLimit: int32 = (afterCount > 0) ? 5 : 1
    tooling_printOut("stage0_ue_clean_context=" + tooling_stage0UeCleanContextText(contextRaw))
    tooling_printOut("stage0_ue_clean_dry_run=" + tooling_boolText(dryRun))
    tooling_printOut("stage0_ue_before=" + intToStr(beforeCount))
    tooling_printOut("stage0_ue_cleaned=" + intToStr(cleanedTotal))
    tooling_printOut("stage0_ue_after=" + intToStr(afterCount))
    tooling_printOut("stage0_ue_rechecks=" + intToStr(rechecks))
    tooling_printOut("stage0_ue_global=" + tooling_boolText(globalMode))
    if tooling_strNonEmpty(tooling_stage0QuarantineUePreview(root, previewLimit)):
        tooling_printOut("stage0_ue_preview=" + tooling_stage0QuarantineUePreview(root, previewLimit))
    else:
        tooling_printOut("stage0_ue_preview=")
    if strict && afterCount > 0:
        return 1
    return 0

fn tooling_cmdStage0UeCleanFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var rechecks: int32 = tooling_parseInt32Default(
        os.getEnvDefault("TOOLING_STAGE0_UE_CLEAN_RECHECKS", ""), 2)
    if rechecks < 0:
        rechecks = 0
    var strict: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_UE_CLEAN_STRICT", "1"))
    var dryRun: bool = false
    var globalMode: bool = true
    var contextArgIndex: int32 = -1
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        if tooling_strEq(tooling_paramStr(i), "--help") || tooling_strEq(tooling_paramStr(i), "-h"):
            tooling_printOut("stage0-ue-clean options:")
            tooling_printOut("  --context:<name>            clean context label")
            tooling_printOut("  --rechecks:<N>              extra clean retries after first sweep (default 2)")
            tooling_printOut("  --strict:0|1                exit non-zero when UE remains (default 1)")
            tooling_printOut("  --dry-run                   only report, no kill attempt")
            tooling_printOut("  --global                    cross-workspace cleanup mode")
            tooling_printOut("  env: TOOLING_STAGE0_UE_CLEAN_CONTEXT=<name>")
            tooling_printOut("       TOOLING_STAGE0_UE_CLEAN_RECHECKS=<N>")
            tooling_printOut("       TOOLING_STAGE0_UE_CLEAN_STRICT=0|1")
            return 0
        if strutil.startsWith(tooling_paramStr(i), "--context:"):
            contextArgIndex = i
            i = i + 1
            continue
        if strutil.startsWith(tooling_paramStr(i), "--rechecks:"):
            rechecks = tooling_parseInt32Default(strings.dropPrefix(tooling_paramStr(i), "--rechecks:"), rechecks)
            if rechecks < 0:
                rechecks = 0
            i = i + 1
            continue
        if strutil.startsWith(tooling_paramStr(i), "--strict:"):
            strict = tooling_isTrue(strings.dropPrefix(tooling_paramStr(i), "--strict:"))
            i = i + 1
            continue
        if tooling_strEq(tooling_paramStr(i), "--dry-run"):
            dryRun = true
            i = i + 1
            continue
        if tooling_strEq(tooling_paramStr(i), "--global"):
            globalMode = true
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown stage0-ue-clean arg: " + tooling_paramStr(i))
        return 1
    if contextArgIndex > 0:
        return tooling_cmdStage0UeClean(
            root,
            strings.dropPrefix(tooling_paramStr(contextArgIndex), "--context:"),
            rechecks,
            strict,
            dryRun,
            globalMode
        )
    return tooling_cmdStage0UeClean(
        root,
        os.getEnvDefault("TOOLING_STAGE0_UE_CLEAN_CONTEXT", "stage0_ue_clean"),
        rechecks,
        strict,
        dryRun,
        globalMode
    )

fn tooling_isDigitsOnly(raw: str): bool =
    if !tooling_strNonEmpty(strutil.strip(raw)):
        return false
    for i in 0..<len(strutil.strip(raw)):
        let ch: char = strutil.strip(raw)[i]
        if ch < '0' || ch > '9':
            return false
    return true

fn tooling_stage0QuarantineKillPid(root: str, pidTokenRaw: str): bool =
    if !tooling_isDigitsOnly(strutil.strip(pidTokenRaw)):
        return false
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "pgid=$(ps -o pgid= -p " + strutil.strip(pidTokenRaw) + " 2>/dev/null | tr -d '[:space:]') ; " +
        "case \"$pgid\" in ''|*[!0-9]*) pgid='' ;; esac ; " +
        "if [ -n \"$pgid\" ]; then kill -TERM -\"$pgid\" >/dev/null 2>&1 || true; fi ; " +
        "kill -TERM " + strutil.strip(pidTokenRaw) + " >/dev/null 2>&1 || true ; " +
        "sleep 0.2 ; " +
        "if [ -n \"$pgid\" ] && kill -0 -\"$pgid\" >/dev/null 2>&1; then " +
        "  kill -KILL -\"$pgid\" >/dev/null 2>&1 || true ; " +
        "  sleep 0.1 ; " +
        "fi ; " +
        "if kill -0 " + strutil.strip(pidTokenRaw) + " >/dev/null 2>&1; then " +
        "  kill -KILL " + strutil.strip(pidTokenRaw) + " >/dev/null 2>&1 || true ; " +
        "  sleep 0.1 ; " +
        "fi ; " +
        "if kill -0 " + strutil.strip(pidTokenRaw) + " >/dev/null 2>&1; then exit 1; fi ; " +
        "exit 0"
    )
    return os.execCmdResultExitCode(res) == 0

fn tooling_stage0QuarantineSweepUe(root: str, context: str): int32 =
    if !tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_QUARANTINE_AUTO_KILL_UE", "1")):
        return 0
    let qdir: str = tooling_stage0QuarantineDir(root)
    let psRes: os.ExecCmdResult = tooling_exec(root, "ps -Ao pid=,ppid=,state=,command=")
    if os.execCmdResultExitCode(psRes) != 0:
        return 0
    var maxKill: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_QUARANTINE_AUTO_KILL_MAX", ""), 8)
    if maxKill < 1:
        maxKill = 1
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(psRes))
    let orphanGuard: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_ORPHAN_GUARD", "1"))
    let killParentChain: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_QUARANTINE_KILL_PARENT_CHAIN", "1"))
    var attemptCount: int32 = 0
    var killedCount: int32 = 0
    var parentTried: str[] = []
    for i in 0..<rows.len:
        if attemptCount >= maxKill:
            break
        let line: str = rows[i]
        let n: int32 = len(line)
        if n <= 0:
            continue
        var j: int32 = 0
        while j < n && (line[j] == ' ' || line[j] == '\t'):
            j = j + 1
        let pidStart: int32 = j
        while j < n && line[j] != ' ' && line[j] != '\t':
            j = j + 1
        if j <= pidStart:
            continue
        let pidToken: str = strings.sliceBytes(line, pidStart, j - pidStart)
        while j < n && (line[j] == ' ' || line[j] == '\t'):
            j = j + 1
        let ppidStart: int32 = j
        while j < n && line[j] != ' ' && line[j] != '\t':
            j = j + 1
        if j <= ppidStart:
            continue
        let ppidToken: str = strings.sliceBytes(line, ppidStart, j - ppidStart)
        while j < n && (line[j] == ' ' || line[j] == '\t'):
            j = j + 1
        let stateStart: int32 = j
        while j < n && line[j] != ' ' && line[j] != '\t':
            j = j + 1
        if j <= stateStart:
            continue
        let state: str = strings.sliceBytes(line, stateStart, j - stateStart)
        let uninterruptible: bool = tooling_strNonEmpty(state) && state[0] == 'U'
        let orphaned: bool = orphanGuard && tooling_strEq(strutil.strip(ppidToken), "1")
        if !uninterruptible && !orphaned:
            continue
        while j < n && (line[j] == ' ' || line[j] == '\t'):
            j = j + 1
        if j >= n:
            continue
        let cmd: str = strings.sliceBytes(line, j, n - j)
        if !tooling_stage0UeCommandRelevant(root, qdir, cmd):
            continue
        let generationPath: str = tooling_stage0UeGenerationPath(root, qdir, cmd)
        if tooling_strNonEmpty(generationPath) &&
           tooling_stage0PidHistoricalForGenerationPath(root, pidToken, generationPath):
            continue
        let parentPid: str = strutil.strip(ppidToken)
        if killParentChain && tooling_isDigitsOnly(parentPid) &&
           !tooling_strEq(parentPid, "1") && !tooling_idsContains(parentTried, parentPid):
            add(parentTried, parentPid)
            if attemptCount < maxKill:
                attemptCount = attemptCount + 1
                if tooling_stage0QuarantineKillPid(root, parentPid):
                    killedCount = killedCount + 1
            if attemptCount >= maxKill:
                break
        attemptCount = attemptCount + 1
        if tooling_stage0QuarantineKillPid(root, pidToken):
            killedCount = killedCount + 1
    if killedCount > 0:
        tooling_printErr("cheng_tooling: auto-cleaned quarantine stuck/orphan processes for " + context +
                         ": killed=" + intToStr(killedCount) + ", attempts=" + intToStr(attemptCount))
    return killedCount

fn tooling_backendDriverAttemptCommandRelevant(root: str, cmdRaw: str): bool =
    let cmd: str = strutil.strip(cmdRaw)
    if !tooling_strNonEmpty(cmd):
        return false
    let attemptPrefixAbs: str = os.joinPath(root, "chengcache/backend_driver_build_tmp/cheng.attempt.")
    if strutil.contains(cmd, attemptPrefixAbs):
        return true
    if strutil.contains(cmd, "/chengcache/backend_driver_build_tmp/cheng.attempt."):
        return true
    return false

fn tooling_backendDriverSweepAttemptOrphans(root: str, context: str): int32 =
    let psRes: os.ExecCmdResult = tooling_exec(root, "ps -Ao pid=,ppid=,state=,command=")
    if os.execCmdResultExitCode(psRes) != 0:
        return 0
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(psRes))
    let orphanGuard: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_ORPHAN_GUARD", "1"))
    var killedCount: int32 = 0
    for i in 0..<rows.len:
        let line: str = rows[i]
        let n: int32 = len(line)
        if n <= 0:
            continue
        var j: int32 = 0
        while j < n && (line[j] == ' ' || line[j] == '\t'):
            j = j + 1
        let pidStart: int32 = j
        while j < n && line[j] != ' ' && line[j] != '\t':
            j = j + 1
        if j <= pidStart:
            continue
        let pidToken: str = strings.sliceBytes(line, pidStart, j - pidStart)
        while j < n && (line[j] == ' ' || line[j] == '\t'):
            j = j + 1
        let ppidStart: int32 = j
        while j < n && line[j] != ' ' && line[j] != '\t':
            j = j + 1
        if j <= ppidStart:
            continue
        let ppidToken: str = strings.sliceBytes(line, ppidStart, j - ppidStart)
        while j < n && (line[j] == ' ' || line[j] == '\t'):
            j = j + 1
        let stateStart: int32 = j
        while j < n && line[j] != ' ' && line[j] != '\t':
            j = j + 1
        if j <= stateStart:
            continue
        let state: str = strings.sliceBytes(line, stateStart, j - stateStart)
        let uninterruptible: bool = tooling_strNonEmpty(state) && state[0] == 'U'
        let orphaned: bool = orphanGuard && tooling_strEq(strutil.strip(ppidToken), "1")
        if !uninterruptible && !orphaned:
            continue
        while j < n && (line[j] == ' ' || line[j] == '\t'):
            j = j + 1
        if j >= n:
            continue
        let cmd: str = strings.sliceBytes(line, j, n - j)
        if !tooling_backendDriverAttemptCommandRelevant(root, cmd):
            continue
        if tooling_stage0QuarantineKillPid(root, pidToken):
            killedCount = killedCount + 1
    if killedCount > 0:
        tooling_printErr("cheng_tooling: auto-cleaned stale backend_driver attempt processes for " + context +
                         ": killed=" + intToStr(killedCount))
    return killedCount

fn tooling_stage0BlockOnQuarantineUe(root: str, blockEnv: str, context: str): bool =
    let hardBlock: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_HARD_BLOCK_ON_UE", "1"))
    var blockOnUe: bool = tooling_isTrue(os.getEnvDefault(blockEnv, "1"))
    if !blockOnUe && hardBlock:
        tooling_printErr("cheng_tooling: ignore " + blockEnv +
                         "=0 because TOOLING_STAGE0_HARD_BLOCK_ON_UE=1")
    if hardBlock:
        blockOnUe = true
    if !blockOnUe:
        return false
    if tooling_stage0QuarantineCleanMemoFresh(root, context):
        return false
    let ueCountBefore: int32 = tooling_stage0QuarantineUeCount(root)
    if ueCountBefore <= 0:
        tooling_stage0QuarantineMarkClean(root, context)
        return false
    let cleaned: int32 = tooling_stage0QuarantineSweepUe(root, context)
    var ueCount: int32 = tooling_stage0QuarantineUeCount(root)
    if ueCount > 0 && cleaned > 0:
        var rechecks: int32 = tooling_parseInt32Default(
            os.getEnvDefault("TOOLING_STAGE0_QUARANTINE_BLOCK_RECHECKS", ""), 2)
        if rechecks < 1:
            rechecks = 1
        for ri in 1..rechecks:
            let _sleepRes: os.ExecCmdResult = tooling_exec(root, "sleep 0.2")
            let _retryCleaned: int32 = tooling_stage0QuarantineSweepUe(root, context + ".recheck." + intToStr(ri))
            ueCount = tooling_stage0QuarantineUeCount(root)
            if ueCount <= 0:
                break
    if ueCount <= 0:
        tooling_stage0QuarantineMarkClean(root, context)
        return false
    tooling_stage0QuarantineClearCleanMemo(root, context)
    if tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_ORPHAN_ONLY_BYPASS", "0")):
        tooling_printErr("cheng_tooling: ignore TOOLING_STAGE0_ORPHAN_ONLY_BYPASS=1 for " + context +
                         " (orphan UE remains hard-block)")
    tooling_printErr("cheng_tooling: blocked " + context + " due to stuck/orphan UE processes: " +
                     intToStr(ueCount))
    let preview: str = tooling_stage0QuarantineUePreview(root, 3)
    if tooling_strNonEmpty(preview):
        tooling_printErr("cheng_tooling: quarantine UE preview: " + preview)
    tooling_printErr("cheng_tooling: cleanup hint: ps -Ao pid,ppid,state,command | awk '$3 ~ /^U/ {print}'")
    return true

fn tooling_stage0BlockOnQuarantineUeForExec(root: str, blockEnv: str, context: str,
                                            stage0ExecRaw: str): bool =
    let stage0Exec: str = tooling_pathAbsolute(root, stage0ExecRaw)
    if tooling_strNonEmpty(stage0Exec) &&
       tooling_stage0PreflightMemoFresh(root, stage0Exec, false):
        tooling_stage0QuarantineMarkClean(root, context)
        return false
    return tooling_stage0BlockOnQuarantineUe(root, blockEnv, context)

fn tooling_runScriptNeedsUeBlock(scriptIdRaw: str): bool =
    let id: str = tinv.toolingNormalizeScriptId(scriptIdRaw)
    if !tooling_strNonEmpty(id):
        return false
    if tooling_strEq(id, "backend_prod_closure") || tooling_strEq(id, "verify_backend_closedloop"):
        return true
    if tooling_strEq(id, "verify_fullchain_bootstrap") || tooling_strEq(id, "verify_stage1_fullspec"):
        return true
    if tooling_strEq(id, "verify_backend_nolibc_linux_aarch64"):
        return true
    return false


fn tooling_stage0PurposeTag(raw: str): str =
    if tooling_strNonEmpty(strutil.strip(raw)):
        return strutil.strip(raw)
    return "run"

fn tooling_stage0MirrorDigestShort(stage0Path: str): str =
    if len(tooling_pathStableToken(stage0Path)) > 12:
        return strings.sliceBytes(tooling_pathStableToken(stage0Path), 0, 12)
    if tooling_strNonEmpty(tooling_pathStableToken(stage0Path)):
        return tooling_pathStableToken(stage0Path)
    return "stage0"

fn tooling_stage0MirrorExecPath(root: str, stage0PathRaw: str, purposeRaw: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)):
        return ""
    if !tooling_mkdirP(root, tooling_stage0QuarantineDir(root)):
        return ""
    return os.joinPath(
        tooling_stage0QuarantineDir(root),
        "cheng." + tooling_stage0PurposeTag(purposeRaw) + "." +
        tooling_stage0MirrorDigestShort(tooling_pathAbsolute(root, stage0PathRaw))
    )

fn tooling_stage0MirrorBypassExec(root: str, stage0PathRaw: str, purposeRaw: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)):
        return ""
    if !tooling_strEq(tooling_stage0PurposeTag(purposeRaw), "build_global"):
        return ""
    if tooling_strEq(
        tooling_pathAbsolute(root, stage0PathRaw),
        tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2")
    ) || tooling_strEq(
        tooling_pathAbsolute(root, stage0PathRaw),
        tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage3.witness")
    ):
        return tooling_pathAbsolute(root, stage0PathRaw)
    return ""

fn tooling_stage0MirrorUpToDate(root: str, stage0PathRaw: str, mirrorPathRaw: str): bool =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, stage0PathRaw)) ||
       !tooling_strNonEmpty(tooling_pathAbsolute(root, mirrorPathRaw)):
        return false
    if !os.fileExists(tooling_pathAbsolute(root, stage0PathRaw)) ||
       !os.fileExists(tooling_pathAbsolute(root, mirrorPathRaw)):
        return false
    let srcSize: int64 = os.fileSize(tooling_pathAbsolute(root, stage0PathRaw))
    let dstSize: int64 = os.fileSize(tooling_pathAbsolute(root, mirrorPathRaw))
    if srcSize <= int64(0) || srcSize != dstSize:
        return false
    let srcMtime: int64 = os.fileMtime(tooling_pathAbsolute(root, stage0PathRaw))
    let dstMtime: int64 = os.fileMtime(tooling_pathAbsolute(root, mirrorPathRaw))
    if srcMtime <= int64(0) || dstMtime <= int64(0):
        return false
    return dstMtime >= srcMtime

fn tooling_prepareStage0Exec(root: str, stage0Path: str, purposeRaw: str): str =
    let prepareStartMs: int64 = tooling_nowMs()
    if !tooling_isExecutable(root, stage0Path):
        return ""
    if !tooling_stage0QuarantineEnabled():
        return stage0Path
    let bypassStartMs: int64 = tooling_nowMs()
    tooling_printStage0PrepareTiming("bypass", tooling_nowMs() - bypassStartMs)
    if tooling_strNonEmpty(tooling_stage0MirrorBypassExec(root, stage0Path, tooling_stage0PurposeTag(purposeRaw))):
        tooling_printStage0PrepareTiming("total", tooling_nowMs() - prepareStartMs)
        return tooling_stage0MirrorBypassExec(root, stage0Path, tooling_stage0PurposeTag(purposeRaw))
    if !tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_MIRROR_EXEC", "1")):
        tooling_printErr("cheng_tooling: ignore TOOLING_STAGE0_MIRROR_EXEC=0 because stage0 exec is always mirrored")
    let mirrorPathStartMs: int64 = tooling_nowMs()
    tooling_printStage0PrepareTiming("mirror_path", tooling_nowMs() - mirrorPathStartMs)
    if !tooling_strNonEmpty(tooling_stage0MirrorExecPath(root, stage0Path, tooling_stage0PurposeTag(purposeRaw))):
        return ""
    let mirrorSyncStartMs: int64 = tooling_nowMs()
    if !tooling_stage0MirrorUpToDate(
        root,
        stage0Path,
        tooling_stage0MirrorExecPath(root, stage0Path, tooling_stage0PurposeTag(purposeRaw))
    ):
        if !tooling_copyExecutablePreserveBytes(
            root,
            stage0Path,
            tooling_stage0MirrorExecPath(root, stage0Path, tooling_stage0PurposeTag(purposeRaw))
        ):
            tooling_printErr(
                "cheng_tooling: failed to mirror stage0 exec: " +
                tooling_stage0MirrorExecPath(root, stage0Path, tooling_stage0PurposeTag(purposeRaw))
            )
            return ""
    tooling_printStage0PrepareTiming("mirror_sync", tooling_nowMs() - mirrorSyncStartMs)
    let quarantineStartMs: int64 = tooling_nowMs()
    if tooling_stage0BlockOnQuarantineUeForExec(root, "TOOLING_STAGE0_QUARANTINE_BLOCK_ON_UE",
                                                "stage0 run." + tooling_stage0PurposeTag(purposeRaw),
                                                tooling_stage0MirrorExecPath(root, stage0Path, tooling_stage0PurposeTag(purposeRaw))):
        tooling_printStage0PrepareTiming("quarantine_block", tooling_nowMs() - quarantineStartMs)
        return ""
    tooling_printStage0PrepareTiming("quarantine_block", tooling_nowMs() - quarantineStartMs)
    tooling_printStage0PrepareTiming("total", tooling_nowMs() - prepareStartMs)
    return tooling_stage0MirrorExecPath(root, stage0Path, tooling_stage0PurposeTag(purposeRaw))

fn tooling_cleanupStage0Exec(stage0Original: str, stage0Exec: str) =
    if !tooling_strNonEmpty(stage0Exec):
        return
    if tooling_strEq(stage0Exec, stage0Original):
        return
    if strutil.contains(stage0Exec, "/chengcache/stage0_quarantine/cheng."):
        return
    if os.fileExists(stage0Exec):
        os.removeFile(stage0Exec)

fn tooling_stage0PreflightOk(root: str, stage0Exec: str): bool =
    if !tooling_isExecutable(root, stage0Exec):
        return false
    var timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_PREFLIGHT_TIMEOUT", ""), 8)
    if timeoutSec <= 0:
        timeoutSec = 8
    var retries: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_PREFLIGHT_RETRIES", ""), 3)
    if retries <= 0:
        retries = 1
    # Preflight must be timeout-bounded by default. Hanging --help checks were
    # silently accepted before and leaked broken stage0 drivers into compile path.
    let strictPreflight: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_PREFLIGHT_STRICT", "1"))
    let useWrapper: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_PREFLIGHT_WRAP", "1"))
    let runProbe: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_PREFLIGHT_RUN", "0"))
    if tooling_stage0PreflightMemoFresh(root, stage0Exec, runProbe):
        return true
    if !tooling_binaryExecPolicyPreflightOk(root, stage0Exec, "stage0_preflight"):
        return false
    if !runProbe:
        tooling_stage0PreflightMemoWrite(root, stage0Exec, false)
        return true
    var lastRc: int32 = 1
    for attempt in 1..retries:
        var res: os.ExecCmdResult
        if useWrapper:
            res = tooling_exec(
                root,
                tooling_wrapStage0LockTimeout(
                    root, timeoutSec, tooling_shellQuote(stage0Exec) + " --help", "stage0_preflight")
            )
        else:
            var helpArgs: str[] = []
            add(helpArgs, "--help")
            var helpEnv: str[] = []
            res = tooling_execFileDirect(stage0Exec, helpArgs, helpEnv, root, timeoutSec, false)
        let rc: int32 = os.execCmdResultExitCode(res)
        lastRc = rc
        if rc >= 128:
            tooling_stage0MarkCrash(root, stage0Exec, rc, "stage0_preflight")
        # backend_driver --help returns rc=1 on some builds; treat as healthy.
        if rc == 0 || rc == 1:
            tooling_stage0PreflightMemoWrite(root, stage0Exec, true)
            return true
        if tooling_strEq(tooling_exitKind(rc), "timeout"):
            tooling_printErr("cheng_tooling: stage0 preflight timeout: " + stage0Exec)
            if strictPreflight:
                return false
            # Non-strict mode exists for temporary diagnostics only.
            return false
        if attempt < retries:
            let cleaned: int32 = tooling_stage0QuarantineSweepUe(root, "stage0_preflight_retry")
            tooling_printErr("cheng_tooling: stage0 preflight retry " + intToStr(attempt) +
                             "/" + intToStr(retries) + " rc=" + intToStr(lastRc) +
                             " kind=" + tooling_exitKind(lastRc) + " cleaned=" + intToStr(cleaned))
    if lastRc >= 128:
        tooling_printErr("cheng_tooling: stage0 preflight failed rc=" + intToStr(lastRc) +
                         " kind=" + tooling_exitKind(lastRc) + " stage0=" + stage0Exec)
        return false
    return lastRc == 0

fn tooling_stripLeadingUnderscores(raw: str): str =
    if !tooling_strNonEmpty(raw):
        return ""
    let n: int32 = len(strutil.strip(raw))
    if n <= 0:
        return ""
    var i: int32 = 0
    while i < n && strutil.strip(raw)[i] == '_':
        i = i + 1
    if i >= n:
        return ""
    return strings.sliceBytes(strutil.strip(raw), i, n - i)

fn tooling_isForbiddenUndefinedDriverSymbol(raw: str): bool =
    if !tooling_strNonEmpty(tooling_stripLeadingUnderscores(raw)):
        return false
    if tooling_strEq(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "backendmain") ||
       tooling_strEq(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "getenvdefault") ||
       tooling_strEq(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "writeline"):
        return true
    if tooling_strEq(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "streq") ||
       tooling_strEq(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "paramcount") ||
       tooling_strEq(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "paramstr"):
        return true
    if strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "uir") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "macho") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "elf") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "coff") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "os_") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "walkdir") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "execcmd") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "readfile") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "writefile") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "joinpath") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "slice") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "parseint") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "lowerascii") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "pathcomponent") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "extractfilename") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "direxists") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "getcurrentdir") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "getmonotime") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "monotimens"):
        return true
    if strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "backend") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "driver_") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "tooling") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "hashmap") ||
       strutil.startsWith(strutil.toLowerAscii(tooling_stripLeadingUnderscores(raw)), "cheng_"):
        return true
    return false

fn tooling_driverUndefinedInternalSymbolsOk(root: str, binPath: str): bool =
    let guardEnabled: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_UNDEF_GUARD", "1"))
    if !guardEnabled:
        return true
    let probeNm: os.ExecCmdResult = tooling_exec(root, "command -v nm >/dev/null 2>&1")
    if os.execCmdResultExitCode(probeNm) != 0:
        return true
    let probeAwk: os.ExecCmdResult = tooling_exec(root, "command -v awk >/dev/null 2>&1")
    if os.execCmdResultExitCode(probeAwk) != 0:
        return true
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "nm -u " + tooling_shellQuote(binPath) + " 2>/dev/null | awk '{print $NF}'"
    )
    if os.execCmdResultExitCode(res) != 0:
        return true
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(res))
    var hitCount: int32 = 0
    var previewParts: str[] = []
    for i in 0..<rows.len:
        if !tooling_strNonEmpty(strutil.strip(rows[i])):
            continue
        if !tooling_isForbiddenUndefinedDriverSymbol(strutil.strip(rows[i])):
            continue
        hitCount = hitCount + 1
        if hitCount <= 8:
            add(previewParts, strutil.strip(rows[i]))
    if hitCount <= 0:
        return true
    tooling_printErr("cheng_tooling: forbidden undefined internal symbols in driver (count=" +
                     intToStr(hitCount) + "): " + strutil.join(previewParts, ", "))
    return false

fn tooling_driverRequiredSymbolsOk(root: str, binPath: str): bool =
    let requireEntrySymbol: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_REQUIRE_BACKENDMAIN", "1"))
    if !requireEntrySymbol:
        return true
    let allowMainOnlyFallback: bool =
        tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_ALLOW_MAIN_ONLY", "0"))
    let probeNm: os.ExecCmdResult = tooling_exec(root, "command -v nm >/dev/null 2>&1")
    if os.execCmdResultExitCode(probeNm) != 0:
        return true
    let probeAwk: os.ExecCmdResult = tooling_exec(root, "command -v awk >/dev/null 2>&1")
    if os.execCmdResultExitCode(probeAwk) != 0:
        return true
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "nm -gU " + tooling_shellQuote(binPath) + " 2>/dev/null | awk '{print $NF}'"
    )
    if os.execCmdResultExitCode(res) != 0:
        return true
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(res))
    var hasBackendMain: bool = false
    var hasMain: bool = false
    for i in 0..<rows.len:
        if !tooling_strNonEmpty(strutil.strip(rows[i])):
            continue
        if tooling_strEq(tooling_stripLeadingUnderscores(strutil.strip(rows[i])), "backendMain"):
            hasBackendMain = true
            continue
        if tooling_strEq(tooling_stripLeadingUnderscores(strutil.strip(rows[i])), "main"):
            hasMain = true
    if hasBackendMain:
        return true
    if hasMain && allowMainOnlyFallback:
        tooling_printErr("cheng_tooling: warning: stage0 main-only fallback accepted; missing backendMain: " + binPath)
        return true
    if hasMain:
        tooling_printErr("cheng_tooling: driver sanity rejected main-only binary (missing backendMain): " + binPath)
        tooling_printErr("cheng_tooling: hint: set TOOLING_STAGE0_ALLOW_MAIN_ONLY=1 only for temporary triage")
        return false
    tooling_printErr("cheng_tooling: driver sanity missing required entry symbol (backendMain): " + binPath)
    return false

fn tooling_driverRequiredLiteralMarkersOk(root: str, binPath: str): bool =
    # Literal marker matching is brittle across bootstrap generations.
    # Keep it opt-in; executable/symbol/probe checks are the hard guards.
    let requireMarkers: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_REQUIRE_LITERAL_MARKERS", "0"))
    if !requireMarkers:
        return true
    let hasStrings: os.ExecCmdResult = tooling_exec(root, "command -v strings >/dev/null 2>&1")
    if os.execCmdResultExitCode(hasStrings) != 0:
        return true
    let hasRg: os.ExecCmdResult = tooling_exec(root, "command -v rg >/dev/null 2>&1")
    if os.execCmdResultExitCode(hasRg) != 0:
        return true
    let hasOutputMsg: bool = os.execCmdResultExitCode(
        tooling_exec(
            root,
            "strings " + tooling_shellQuote(binPath) +
            " 2>/dev/null | rg -q 'backend_driver: output path required'"
        )
    ) == 0
    let hasOutputEnv: bool = os.execCmdResultExitCode(
        tooling_exec(
            root,
            "strings " + tooling_shellQuote(binPath) + " 2>/dev/null | rg -q '^BACKEND_OUTPUT$'"
        )
    ) == 0
    if hasOutputMsg && hasOutputEnv:
        return true
    tooling_printErr("cheng_tooling: driver sanity missing required literal markers (possible silent no-op binary): " + binPath)
    return false

fn tooling_driverIsScriptShim(root: str, binPath: str): bool =
    if !tooling_isExecutable(root, binPath):
        return false
    let headRes: os.ExecCmdResult = tooling_exec(root, "head -n 1 " + tooling_shellQuote(binPath))
    if os.execCmdResultExitCode(headRes) != 0:
        return false
    if strutil.startsWith(strutil.strip(os.execCmdResultOutput(headRes)), "#!"):
        return true
    return false

fn tooling_driverFileMagicOk(root: str, binPath: str): bool =
    let probeFile: os.ExecCmdResult = tooling_exec(root, "command -v file >/dev/null 2>&1")
    if os.execCmdResultExitCode(probeFile) != 0:
        return true
    let res: os.ExecCmdResult = tooling_exec(root, "file -b " + tooling_shellQuote(binPath))
    if os.execCmdResultExitCode(res) != 0:
        return true
    if strutil.contains(strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res))), "script"):
        tooling_printErr("cheng_tooling: driver sanity rejected script shim: " + binPath)
        return false
    if tooling_strEq(tooling_detectHostTag(root), "darwin_arm64"):
        if !strutil.contains(strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res))), "mach-o"):
            tooling_printErr("cheng_tooling: driver sanity expected mach-o binary on darwin_arm64: " + binPath +
                             " (file=" + strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res))) + ")")
            return false
    return true

fn tooling_binaryExecPolicyPreflightOk(root: str, binPathRaw: str, scopeRaw: str): bool =
    if !tooling_isExecutable(root, tooling_pathAbsolute(root, binPathRaw)):
        return false
    if tooling_driverIsScriptShim(root, tooling_pathAbsolute(root, binPathRaw)):
        return true
    if !tooling_strEq(tooling_uname(root, "-s"), "darwin"):
        return true
    let enabled: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_DARWIN_CODESIGN_PREFLIGHT", "1"))
    if !enabled:
        return true
    let hasCodesign: os.ExecCmdResult = tooling_exec(root, "command -v codesign >/dev/null 2>&1")
    if os.execCmdResultExitCode(hasCodesign) != 0:
        return true
    let verifyRes: os.ExecCmdResult = tooling_exec(
        root,
        "codesign --verify --verbose=2 " + tooling_shellQuote(tooling_pathAbsolute(root, binPathRaw)) +
        " >/dev/null 2>&1"
    )
    if os.execCmdResultExitCode(verifyRes) == 0:
        return true
    tooling_printErr(
        "cheng_tooling: darwin exec-policy preflight failed for " +
        (tooling_strNonEmpty(strutil.strip(scopeRaw)) ? strutil.strip(scopeRaw) : "binary") +
        ": " + tooling_pathAbsolute(root, binPathRaw)
    )
    tooling_printErr("cheng_tooling: hint: rebuild and publish atomically; avoid executing partially-updated binaries")
    return false

fn tooling_driverIsCdropEmergencySeed(root: str, binPath: str): bool =
    let probeStrings: os.ExecCmdResult = tooling_exec(root, "command -v strings >/dev/null 2>&1")
    if os.execCmdResultExitCode(probeStrings) != 0:
        return false
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "strings " + tooling_shellQuote(binPath) +
        " 2>/dev/null | grep -q " + tooling_shellQuote("cheng_boot.c emergency seed")
    )
    return os.execCmdResultExitCode(res) == 0

fn tooling_normalizedDigestText(raw: str): str =
    return strutil.toLowerAscii(strutil.strip(raw))

fn tooling_digestListContains(listRaw: str, digestRaw: str): bool =
    if !tooling_strNonEmpty(tooling_normalizedDigestText(digestRaw)):
        return false
    if !tooling_strNonEmpty(tooling_normalizedDigestText(listRaw)):
        return false
    let n: int32 = len(tooling_normalizedDigestText(listRaw))
    var start: int32 = 0
    var i: int32 = 0
    while i <= n:
        let atEnd: bool = i >= n
        if atEnd || tooling_normalizedDigestText(listRaw)[i] == ',':
            if i > start:
                if tooling_strEq(
                    strutil.strip(strings.sliceBytes(tooling_normalizedDigestText(listRaw), start, i - start)),
                    tooling_normalizedDigestText(digestRaw)
                ):
                    return true
            start = i + 1
        i = i + 1
    return false

fn tooling_driverDigestBlocked(digestRaw: str): bool =
    if !tooling_strNonEmpty(tooling_normalizedDigestText(digestRaw)):
        return false
    # Driver digest blocklist is now env-controlled only. Hardcoding digests
    # here caused canonical seed lockout during recovery.
    return tooling_digestListContains(
        os.getEnvDefault("TOOLING_STAGE0_BLOCK_SHA256", ""),
        tooling_normalizedDigestText(digestRaw)
    )

fn tooling_driverSanityCoreNoStamp(root: str, binPath: str): bool =
    if !tooling_isExecutable(root, binPath):
        return false
    if tooling_driverDigestBlocked(tooling_sha256File(root, binPath)):
        tooling_printErr(
            "cheng_tooling: driver sanity blocked known-bad digest: " +
            tooling_sha256File(root, binPath)
        )
        tooling_printErr("cheng_tooling: blocked path=" + binPath)
        tooling_printErr("cheng_tooling: hint: rebuild canonical driver from healthy stage2 before retry")
        return false
    if !tooling_binaryExecPolicyPreflightOk(root, binPath, "driver_sanity"):
        return false
    if os.fileSize(binPath) <= int64(0):
        return false
    if tooling_driverIsScriptShim(root, binPath):
        tooling_printErr("cheng_tooling: driver sanity rejected shebang script: " + binPath)
        return false
    if !tooling_driverFileMagicOk(root, binPath):
        return false
    if tooling_driverIsCdropEmergencySeed(root, binPath):
        tooling_printErr("cheng_tooling: driver sanity rejected cdrop emergency seed wrapper: " + binPath)
        tooling_printErr("cheng_tooling: hint: recover canonical driver from dist release before rebuild")
        return false
    if !tooling_driverRequiredSymbolsOk(root, binPath):
        return false
    if !tooling_driverRequiredLiteralMarkersOk(root, binPath):
        return false
    if !tooling_driverUndefinedInternalSymbolsOk(root, binPath):
        return false
    return true

fn tooling_driverSanityOk(root: str, binPath: str): bool =
    if tooling_stage0BlockStamped(root, binPath):
        tooling_printErr("cheng_tooling: driver sanity blocked quarantine-stamped digest: " + binPath)
        return false
    return tooling_driverSanityCoreNoStamp(root, binPath)

fn tooling_driverMinimalSanityOk(root: str, binPath: str): bool =
    if !tooling_isExecutable(root, binPath):
        return false
    if tooling_stage0BlockStamped(root, binPath):
        tooling_printErr("cheng_tooling: driver minimal sanity blocked quarantine-stamped digest: " + binPath)
        return false
    if os.fileSize(binPath) <= int64(0):
        return false
    return true

fn tooling_stage0MaybeClearStaleStamp(root: str, stage0PathRaw: str,
                                      requireHelpProbe: bool, contextRaw: str): bool =
    let stage0Path: str = tooling_pathAbsolute(root, stage0PathRaw)
    if !tooling_strNonEmpty(stage0Path):
        return false
    if !tooling_stage0BlockStamped(root, stage0Path):
        return false
    if !tooling_driverSanityCoreNoStamp(root, stage0Path):
        return false
    if requireHelpProbe && !tooling_binaryHelpProbeOk(root, stage0Path, true):
        return false
    let cleared: int32 = tooling_stage0ClearStamps(root, stage0Path, contextRaw)
    return cleared > 0

fn tooling_stage0BlockStampReason(root: str, stage0PathRaw: str): str =
    let stage0Path: str = tooling_pathAbsolute(root, stage0PathRaw)
    if !tooling_strNonEmpty(stage0Path):
        return ""
    let blockPath: str = tooling_stage0BlockStampPath(root, stage0Path)
    if !tooling_strNonEmpty(blockPath) || !os.fileExists(blockPath):
        return ""
    return strutil.strip(tooling_kvGet(tooling_readTextFile(root, blockPath), "reason"))

fn tooling_stage0MaybeClearCanonicalSmokeStamp(root: str, stage0PathRaw: str,
                                               contextRaw: str): bool =
    let stage0Path: str = tooling_pathAbsolute(root, stage0PathRaw)
    if !tooling_strNonEmpty(stage0Path):
        return false
    if !tooling_stage0BlockStamped(root, stage0Path):
        return false
    if !tooling_strEq(tooling_stage0BlockStampReason(root, stage0Path), "canonical_smoke"):
        return false
    if !tooling_buildDriverFastCanonicalSmokeOk(root, stage0Path):
        return false
    let cleared: int32 = tooling_stage0ClearStamps(root, stage0Path, contextRaw)
    return cleared > 0 || !tooling_stage0BlockStamped(root, stage0Path)

fn tooling_stage0MaybeRecoverStampedSelfhostCandidate(root: str, stage0PathRaw: str,
                                                      requireHelpProbe: bool,
                                                      contextRaw: str): bool =
    let stage0Path: str = tooling_pathAbsolute(root, stage0PathRaw)
    if !tooling_stage0IsSelfhostRecoveryCandidate(root, stage0Path):
        return false
    if !tooling_stage0BlockStamped(root, stage0Path):
        return false
    if !tooling_driverSanityCoreNoStamp(root, stage0Path):
        return false
    if requireHelpProbe && !tooling_binaryHelpProbeOk(root, stage0Path, true):
        return false
    let cleared: int32 = tooling_stage0ClearStamps(root, stage0Path, contextRaw)
    return cleared > 0 || !tooling_stage0BlockStamped(root, stage0Path)

fn tooling_driverCompileProbeOk(root: str, binPath: str): bool =
    let preferReleaseSystem: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_COMPILE_PROBE_RELEASE_SYSTEM", "1"))
    let allowDevInmemFallback: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_COMPILE_PROBE_ALLOW_DEV_INMEM", "0"))
    if preferReleaseSystem:
        if tooling_driverCompileSmokeReleaseSystemOk(root, binPath):
            return true
        if allowDevInmemFallback:
            return tooling_driverCompileSmokeDevInmemOk(root, binPath)
        return false
    if tooling_driverCompileSmokeDevInmemOk(root, binPath):
        return true
    return tooling_driverCompileSmokeReleaseSystemOk(root, binPath)

fn tooling_driverPostBuildOk(root: str, binPath: str): bool =
    if !tooling_driverSanityOk(root, binPath):
        return false
    if !tooling_binaryHelpProbeOk(root, binPath, true):
        tooling_printErr("cheng_tooling: driver post-build --help probe failed: " + binPath)
        return false
    let probeEnabled: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_POST_PROBE", "0"))
    if !probeEnabled:
        return true
    return tooling_driverCompileProbeOk(root, binPath)

fn tooling_driverBuildOutputOk(root: str, binPath: str, compileMode: str, quickLightSanity: bool,
                               forceProbeOnFull: bool, linkerModeRaw: str): bool =
    let _clearedCanonicalSmokeStamp: bool =
        tooling_stage0MaybeClearCanonicalSmokeStamp(
            root, binPath, "build_backend_driver.canonical_smoke_probe")
    let requireHelpProbe: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_REQUIRE_HELP_PROBE", "1"))
    let _clearedStaleStamp: bool =
        tooling_stage0MaybeClearStaleStamp(
            root, binPath, requireHelpProbe, "build_backend_driver.output_probe")
    var ok: bool = false
    if tooling_strEq(compileMode, "quick") && quickLightSanity:
        ok = tooling_driverSanityOk(root, binPath)
    else:
        ok = tooling_driverPostBuildOk(root, binPath)
    if !ok:
        return false
    if tooling_strEq(compileMode, "full") && forceProbeOnFull:
        if !tooling_driverCompileProbeOk(root, binPath):
            tooling_printErr("cheng_tooling: full rebuild compile-probe failed: " + binPath)
            return false
    let runSmokeOnFull: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_BUILD_DRIVER_FULL_SMOKE", "1"))
    if tooling_strEq(compileMode, "full") && runSmokeOnFull:
        let linkerMode: str = strutil.toLowerAscii(strutil.strip(linkerModeRaw))
        if tooling_strEq(linkerMode, "system"):
            if !tooling_driverCompileSmokeReleaseSystemOk(root, binPath):
                tooling_printErr("cheng_tooling: full rebuild release-system smoke failed: " + binPath)
                return false
        else:
            if !tooling_driverCompileSmokeDevInmemOk(root, binPath):
                tooling_printErr("cheng_tooling: full rebuild dev-inmem smoke failed: " + binPath)
                if tooling_driverCompileSmokeReleaseSystemOk(root, binPath):
                    tooling_printErr("cheng_tooling: full rebuild fallback smoke accepted (release-system): " + binPath)
                else:
                    tooling_printErr("cheng_tooling: full rebuild release-system smoke also failed: " + binPath)
                    return false
    return true

fn tooling_buildDriverFastCanonicalSmokeEnabled(root: str, outPathRaw: str, fullRebuild: bool): bool =
    if fullRebuild:
        return false
    let outPath: str = tooling_pathAbsolute(root, outPathRaw)
    let canonicalPath: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if !tooling_strEq(outPath, canonicalPath):
        return false
    return tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_FAST_CANONICAL_SMOKE", "1"))

fn tooling_buildDriverFastCanonicalSmokeProofPath(root: str, outPathRaw: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, outPathRaw)):
        return ""
    return tooling_pathAbsolute(root, outPathRaw) + ".quick_canonical_smoke.env"

fn tooling_buildDriverSourcePath(root: str, sourceRaw: str): str =
    return tooling_pathAbsolute(
        root,
        tooling_nonEmptyDefault(strutil.strip(sourceRaw), "src/backend/tooling/backend_driver.cheng"))

fn tooling_buildDriverFastCanonicalRejectKeyText(outPath: str, target: str,
                                                 sourceSha: str, sourceCapabilitySignature: str): str =
    return "version=1\n" +
           "mode=quick\n" +
           "out_path=" + outPath + "\n" +
           "target=" + target + "\n" +
           "source_sha=" + sourceSha + "\n" +
           "source_capability_signature=" + sourceCapabilitySignature + "\n"

fn tooling_buildDriverFastCanonicalRejectStampText(target: str, sourceSha: str,
                                                   sourceCapabilitySignature: str): str =
    return "version=1\n" +
           "mode=quick\n" +
           "target=" + target + "\n" +
           "source_sha=" + sourceSha + "\n" +
           "source_capability_signature=" + sourceCapabilitySignature + "\n" +
           "canonical_smoke=reject\n" +
           "ts_ms=" + intToStr(tooling_nowMs()) + "\n"

fn tooling_buildDriverFastCanonicalSmokeProofText(target: str, outSha: str,
                                                  sourceSha: str,
                                                  sourceCapabilitySignature: str): str =
    return "version=1\n" +
           "mode=quick\n" +
           "target=" + target + "\n" +
           "out_sha=" + outSha + "\n" +
           "source_sha=" + sourceSha + "\n" +
           "source_capability_signature=" + sourceCapabilitySignature + "\n" +
           "dev_inmem=1\n" +
           "release_system=1\n" +
           "ts_ms=" + intToStr(tooling_nowMs()) + "\n"

fn tooling_buildDriverFastCanonicalRejectStampPath(root: str, outPathRaw: str, target: str,
                                                   sourceSha: str, sourceCapabilitySignature: str): str =
    if !tooling_strNonEmpty(tooling_pathAbsolute(root, outPathRaw)) || !tooling_strNonEmpty(target) ||
       !tooling_strNonEmpty(sourceSha) || !tooling_strNonEmpty(sourceCapabilitySignature):
        return ""
    tooling_tryMkdirP(root, tooling_driverBuildTempDir(root))
    if !tooling_strNonEmpty(tooling_sha256Text(
        root,
        tooling_buildDriverFastCanonicalRejectKeyText(
            tooling_pathAbsolute(root, outPathRaw), target, sourceSha, sourceCapabilitySignature
        )
    )):
        return ""
    return os.joinPath(
        tooling_driverBuildTempDir(root),
        "backend_driver.quick_canonical_reject." +
        tooling_sha256Text(
            root,
            tooling_buildDriverFastCanonicalRejectKeyText(
                tooling_pathAbsolute(root, outPathRaw), target, sourceSha, sourceCapabilitySignature
            )
        ) + ".env"
    )

fn tooling_buildDriverFastCanonicalRejectHit(root: str, outPathRaw: str, target: str,
                                             sourcePathRaw: str): bool =
    if !tooling_buildDriverFastCanonicalSmokeEnabled(root, outPathRaw, false):
        return false
    let sourcePath: str = tooling_buildDriverSourcePath(root, sourcePathRaw)
    if !os.fileExists(sourcePath):
        return false
    let sourceSha: str = tooling_sha256File(root, sourcePath)
    let sourceCapabilitySignature: str = tooling_stage0CapabilitySignature(root)
    if !tooling_strNonEmpty(tooling_buildDriverFastCanonicalRejectStampPath(
        root, outPathRaw, target, sourceSha, sourceCapabilitySignature
    )) || !os.fileExists(tooling_buildDriverFastCanonicalRejectStampPath(
        root, outPathRaw, target, sourceSha, sourceCapabilitySignature
    )):
        return false
    return tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalRejectStampPath(
                           root, outPathRaw, target, sourceSha, sourceCapabilitySignature
                       )
                   ),
                   "version"
               ),
               "1"
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalRejectStampPath(
                           root, outPathRaw, target, sourceSha, sourceCapabilitySignature
                       )
                   ),
                   "mode"
               ),
               "quick"
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalRejectStampPath(
                           root, outPathRaw, target, sourceSha, sourceCapabilitySignature
                       )
                   ),
                   "target"
               ),
               target
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalRejectStampPath(
                           root, outPathRaw, target, sourceSha, sourceCapabilitySignature
                       )
                   ),
                   "source_sha"
               ),
               sourceSha
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalRejectStampPath(
                           root, outPathRaw, target, sourceSha, sourceCapabilitySignature
                       )
                   ),
                   "source_capability_signature"
               ),
               sourceCapabilitySignature
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalRejectStampPath(
                           root, outPathRaw, target, sourceSha, sourceCapabilitySignature
                       )
                   ),
                   "canonical_smoke"
               ),
               "reject"
           )

fn tooling_buildDriverFastCanonicalRejectWrite(root: str, outPathRaw: str, target: str,
                                               sourcePathRaw: str): bool =
    if !tooling_buildDriverFastCanonicalSmokeEnabled(root, outPathRaw, false):
        return true
    let sourcePath: str = tooling_buildDriverSourcePath(root, sourcePathRaw)
    if !os.fileExists(sourcePath):
        return false
    let sourceSha: str = tooling_sha256File(root, sourcePath)
    let sourceCapabilitySignature: str = tooling_stage0CapabilitySignature(root)
    if !tooling_strNonEmpty(tooling_buildDriverFastCanonicalRejectStampPath(
        root, outPathRaw, target, sourceSha, sourceCapabilitySignature
    )):
        return false
    return tooling_writeTextFileViaShell(
        root,
        tooling_buildDriverFastCanonicalRejectStampPath(
            root, outPathRaw, target, sourceSha, sourceCapabilitySignature
        ),
        tooling_buildDriverFastCanonicalRejectStampText(target, sourceSha, sourceCapabilitySignature)
    )

fn tooling_buildDriverFastCanonicalSmokeProofOk(root: str, outPathRaw: str, target: str,
                                                sourceSha: str, sourceCapabilitySignature: str): bool =
    if !tooling_buildDriverFastCanonicalSmokeEnabled(root, outPathRaw, false):
        return true
    if !tooling_fileExistsNonEmpty(tooling_pathAbsolute(root, outPathRaw)):
        return false
    if !tooling_strNonEmpty(sourceSha) || !tooling_strNonEmpty(sourceCapabilitySignature):
        return false
    if !tooling_strNonEmpty(tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))) ||
       !os.fileExists(tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))):
        return false
    if !tooling_strNonEmpty(tooling_sha256File(root, tooling_pathAbsolute(root, outPathRaw))):
        return false
    return tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))
                   ),
                   "version"
               ),
               "1"
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))
                   ),
                   "mode"
               ),
               "quick"
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))
                   ),
                   "target"
               ),
               target
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))
                   ),
                   "out_sha"
               ),
               tooling_sha256File(root, tooling_pathAbsolute(root, outPathRaw))
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))
                   ),
                   "source_sha"
               ),
               sourceSha
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))
                   ),
                   "source_capability_signature"
               ),
               sourceCapabilitySignature
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))
                   ),
                   "dev_inmem"
               ),
               "1"
           ) &&
           tooling_strEq(
               tooling_kvGet(
                   tooling_readTextFile(
                       root,
                       tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))
                   ),
                   "release_system"
               ),
               "1"
           )

fn tooling_buildDriverFastCanonicalSmokeWrite(root: str, outPathRaw: str, target: str,
                                              sourcePathRaw: str): bool =
    if !tooling_fileExistsNonEmpty(tooling_pathAbsolute(root, outPathRaw)):
        return false
    let sourcePath: str = tooling_buildDriverSourcePath(root, sourcePathRaw)
    if !os.fileExists(sourcePath):
        return false
    let sourceSha: str = tooling_sha256File(root, sourcePath)
    let sourceCapabilitySignature: str = tooling_stage0CapabilitySignature(root)
    let outSha: str = tooling_sha256File(root, tooling_pathAbsolute(root, outPathRaw))
    if !tooling_strNonEmpty(sourceSha) || !tooling_strNonEmpty(sourceCapabilitySignature) ||
       !tooling_strNonEmpty(outSha):
        return false
    if !tooling_strNonEmpty(tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw))):
        return false
    return tooling_writeTextFileViaShell(
        root,
        tooling_buildDriverFastCanonicalSmokeProofPath(root, tooling_pathAbsolute(root, outPathRaw)),
        tooling_buildDriverFastCanonicalSmokeProofText(
            target,
            outSha,
            sourceSha,
            sourceCapabilitySignature
        )
    )

fn tooling_buildDriverFastCanonicalSmokeOk(root: str, binPath: str): bool =
    if !tooling_driverCompileSmokeDevInmemOk(root, binPath):
        tooling_printErr("cheng_tooling: fast canonical dev smoke failed: " + binPath)
        return false
    if !tooling_driverCompileSmokeReleaseSystemOk(root, binPath):
        tooling_printErr("cheng_tooling: fast canonical release smoke failed: " + binPath)
        return false
    return true

fn tooling_buildDriverEffectiveLinkerMode(strictNative: bool): str =
    let _strictNative: bool = strictNative
    return "system"

fn tooling_symbolRowsContain(rows: str[], wanted: str): bool =
    let wantNorm: str = tooling_stripLeadingUnderscores(wanted)
    if !tooling_strNonEmpty(wantNorm):
        return false
    for i in 0..<rows.len:
        let raw: str = strutil.strip(rows[i])
        if !tooling_strNonEmpty(raw):
            continue
        let norm: str = tooling_stripLeadingUnderscores(raw)
        if tooling_strEq(norm, wantNorm):
            return true
    return false

fn tooling_nmLineHasUndefinedType(lineRaw: str): bool =
    let line: str = strutil.strip(lineRaw)
    if !tooling_strNonEmpty(line):
        return false
    if tooling_strEq(line, "U") || tooling_strEq(line, "u"):
        return true
    if strutil.startsWith(line, "U ") || strutil.startsWith(line, "u "):
        return true
    if tooling_strContains(line, " U ") || tooling_strContains(line, " u "):
        return true
    return false

fn tooling_nmLineHasDefinedType(lineRaw: str): bool =
    if !tooling_strNonEmpty(strutil.strip(lineRaw)):
        return false
    return !tooling_nmLineHasUndefinedType(lineRaw)

fn tooling_lineLastToken(lineRaw: str): str =
    let line: str = strutil.strip(lineRaw)
    let n: int32 = len(line)
    if n <= 0:
        return ""
    var end: int32 = n - 1
    while end >= 0:
        let ch: char = line[end]
        if ch == ' ' || ch == '\t' || ch == '\r' || ch == '\n':
            end = end - 1
            continue
        break
    if end < 0:
        return ""
    var start: int32 = end
    while start >= 0:
        let ch: char = line[start]
        if ch == ' ' || ch == '\t' || ch == '\r' || ch == '\n':
            break
        start = start - 1
    return strings.sliceBytes(line, start + 1, end - start)

fn tooling_nmRowsHasDefinedSymbol(rows: str[], wanted: str): bool =
    let wantNorm: str = tooling_stripLeadingUnderscores(wanted)
    if !tooling_strNonEmpty(wantNorm):
        return false
    for i in 0..<rows.len:
        let raw: str = strutil.strip(rows[i])
        if !tooling_strNonEmpty(raw):
            continue
        if !tooling_nmLineHasDefinedType(raw):
            continue
        let symRaw: str = tooling_lineLastToken(raw)
        let symNorm: str = tooling_stripLeadingUnderscores(symRaw)
        if tooling_strEq(symNorm, wantNorm):
            return true
    return false

fn tooling_nmRowsHasUndefinedSymbol(rows: str[], wanted: str): bool =
    let wantNorm: str = tooling_stripLeadingUnderscores(wanted)
    if !tooling_strNonEmpty(wantNorm):
        return false
    for i in 0..<rows.len:
        let raw: str = strutil.strip(rows[i])
        if !tooling_strNonEmpty(raw):
            continue
        if !tooling_nmLineHasUndefinedType(raw):
            continue
        let symRaw: str = tooling_lineLastToken(raw)
        let symNorm: str = tooling_stripLeadingUnderscores(symRaw)
        if tooling_strEq(symNorm, wantNorm):
            return true
    return false

fn tooling_runtimeObjSymbolCacheKey(root: str, objPathRaw: str): str =
    let objPath: str = tooling_pathAbsolute(root, objPathRaw)
    if !tooling_strNonEmpty(objPath) || !os.fileExists(objPath):
        return ""
    let objMtime: int64 = os.fileMtime(objPath)
    let objSize: int64 = os.fileSize(objPath)
    return objPath + "#" + intToStr(objMtime) + "#" + intToStr(objSize)

fn tooling_runtimeObjSymbolCacheLineKey(lineRaw: str): str =
    let n: int32 = len(lineRaw)
    if n <= 0:
        return ""
    for i in 0..<n:
        if lineRaw[i] == '\t':
            return strings.sliceBytes(lineRaw, 0, i)
    return lineRaw

fn tooling_runtimeObjSymbolCacheLineVal(lineRaw: str): str =
    let n: int32 = len(lineRaw)
    if n <= 0:
        return ""
    for i in 0..<n:
        if lineRaw[i] == '\t':
            if i + 1 >= n:
                return ""
            return strings.sliceBytes(lineRaw, i + 1, n - i - 1)
    return ""

fn tooling_runtimeObjSymbolCacheJoin(rows: str[]): str =
    return strutil.join(rows, "\n")

fn tooling_runtimeObjSymbolCacheRow(root: str, objPathRaw: str, ok: bool): str =
    return tooling_runtimeObjSymbolCacheKey(root, objPathRaw) + "\t" + tooling_boolText(ok)

fn tooling_runtimeObjSymbolCacheGet(root: str, objPathRaw: str): int32 =
    if !tooling_strNonEmpty(tooling_runtimeObjSymbolCacheKey(root, objPathRaw)):
        return -1
    let rows: str[] = tooling_splitLines(tooling_runtimeObjSymbolCacheText)
    for i in 0..<rows.len:
        if !tooling_strEq(tooling_runtimeObjSymbolCacheLineKey(rows[i]), tooling_runtimeObjSymbolCacheKey(root, objPathRaw)):
            continue
        if tooling_strEq(tooling_runtimeObjSymbolCacheLineVal(rows[i]), "1"):
            return 1
        return 0
    return -1

fn tooling_runtimeObjSymbolCachePut(root: str, objPathRaw: str, ok: bool) =
    if !tooling_strNonEmpty(tooling_runtimeObjSymbolCacheKey(root, objPathRaw)):
        return
    var rows: str[] = tooling_splitLines(tooling_runtimeObjSymbolCacheText)
    for i in 0..<rows.len:
        if !tooling_strEq(tooling_runtimeObjSymbolCacheLineKey(rows[i]), tooling_runtimeObjSymbolCacheKey(root, objPathRaw)):
            continue
        rows[i] = tooling_runtimeObjSymbolCacheRow(root, objPathRaw, ok)
        tooling_runtimeObjSymbolCacheText = tooling_runtimeObjSymbolCacheJoin(rows)
        return
    add(rows, tooling_runtimeObjSymbolCacheRow(root, objPathRaw, ok))
    tooling_runtimeObjSymbolCacheText = tooling_runtimeObjSymbolCacheJoin(rows)

fn tooling_runtimeObjHasRequiredSymbols(root: str, objPath: str): bool =
    if !tooling_strNonEmpty(objPath) || !os.fileExists(objPath):
        return false
    let cached: int32 = tooling_runtimeObjSymbolCacheGet(root, objPath)
    if cached == 1:
        return true
    if cached == 0:
        return false
    let hasNm: os.ExecCmdResult = tooling_exec(root, "command -v nm >/dev/null 2>&1")
    if os.execCmdResultExitCode(hasNm) != 0:
        tooling_runtimeObjSymbolCachePut(root, objPath, true)
        return true
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "nm -g " + tooling_shellQuote(objPath) + " 2>/dev/null | awk '" +
        "BEGIN{" +
        " need[\"cheng_strlen\"]=1;" +
        " need[\"cheng_memcpy\"]=1;" +
        " need[\"cheng_memset\"]=1;" +
        " need[\"cheng_malloc\"]=1;" +
        " need[\"cheng_free\"]=1;" +
        " need[\"cheng_realloc\"]=1;" +
        " need[\"cheng_mem_retain\"]=1;" +
        " need[\"cheng_mem_release\"]=1;" +
        " need[\"cheng_seq_get\"]=1;" +
        " need[\"cheng_seq_set\"]=1;" +
        " need[\"cheng_str_bridge_load_into\"]=1;" +
        " need[\"cheng_strcmp\"]=1;" +
        " need[\"cheng_f32_bits_to_i64\"]=1;" +
        " need[\"cheng_f64_bits_to_i64\"]=1;" +
        " need[\"cheng_open_w_trunc\"]=1;" +
        " need[\"driver_c_build_active_exe_default\"]=1;" +
        " need[\"driver_c_build_emit_obj_default\"]=1;" +
        " need[\"driver_c_backend_usage\"]=1;" +
        " need[\"driver_c_help_requested\"]=1;" +
        " need[\"driver_c_run_default\"]=1;" +
        " need[\"cheng_rt_paramStrCopy\"]=1;" +
        " need[\"cheng_cstrlen\"]=1;" +
        " need[\"cheng_seq_string_register_compat\"]=1;" +
        " need[\"cheng_str_param_to_cstring_compat\"]=1;" +
        " need[\"cheng_error_info_bridge_ok\"]=1;" +
        " need[\"cheng_error_info_bridge_new\"]=1;" +
        " need[\"cheng_error_info_bridge_copy_from\"]=1;" +
        " need[\"cheng_exec_cmd_ex\"]=1;" +
        " need[\"cheng_exec_file_pipe_spawn\"]=1;" +
        " need[\"cheng_pty_is_supported\"]=1;" +
        " need[\"cheng_pty_spawn\"]=1;" +
        " need[\"cheng_pipe_spawn\"]=1;" +
        " need[\"cheng_pty_read\"]=1;" +
        " need[\"cheng_fd_read\"]=1;" +
        " need[\"cheng_fd_read_wait\"]=1;" +
        " need[\"cheng_pty_write\"]=1;" +
        " need[\"cheng_pty_close\"]=1;" +
        " need[\"cheng_pty_wait\"]=1;" +
        " need[\"cheng_process_signal\"]=1;" +
        " need[\"cheng_abi_sum_ptr_len_i32\"]=1;" +
        " need[\"cheng_abi_sum_seq_i32\"]=1;" +
        " need[\"cheng_abi_borrow_mut_pair_i32\"]=1;" +
        " need[\"cheng_ffi_handle_register_ptr\"]=1;" +
        " need[\"cheng_ffi_handle_resolve_ptr\"]=1;" +
        " need[\"cheng_ffi_handle_invalidate\"]=1;" +
        " need[\"cheng_ffi_handle_new_i32\"]=1;" +
        " need[\"cheng_ffi_handle_get_i32\"]=1;" +
        " need[\"cheng_ffi_handle_add_i32\"]=1;" +
        " need[\"cheng_ffi_handle_release_i32\"]=1;" +
        " need[\"cheng_ffi_raw_new_i32\"]=1;" +
        " need[\"cheng_ffi_raw_get_i32\"]=1;" +
        " need[\"cheng_ffi_raw_add_i32\"]=1;" +
        " need[\"cheng_ffi_raw_release_i32\"]=1;" +
        " need[\"driver_c_write_text_file_bridge\"]=1;" +
        " need[\"driver_c_proof_buildModuleFromFileStage1TargetRetained\"]=1;" +
        " need[\"driver_c_proof_buildModuleFromFileStage1Retained\"]=1;" +
        " need[\"driver_c_proof_build_emit_obj_from_file_stage1_target_impl\"]=1;" +
        " need[\"bitand_0\"]=1;" +
        " need[\"ptr_add\"]=1;" +
        " need[\"load_ptr\"]=1;" +
        " need[\"store_ptr\"]=1;" +
        " forbid_undef[\"backendMain\"]=1;" +
        " forbid_undef[\"cheng_register_string_meta\"]=1;" +
        "}" +
        "{ raw=$0; " +
        "  undef=(raw==\"U\" || raw==\"u\" || raw ~ /^U[ \\t]/ || raw ~ /^u[ \\t]/ || raw ~ /[ \\t]U[ \\t]/ || raw ~ /[ \\t]u[ \\t]/); " +
        "  sym=$NF; gsub(/^_+/, \"\", sym); " +
        "  if (undef && (sym in forbid_undef)) bad=1; " +
        "  if (!undef && sym != \"\") have[sym]=1; }" +
        "END{" +
        "  if (bad) exit 1;" +
        "  for (sym in need) if (!(sym in have)) exit 1;" +
        "  exit 0;" +
        "}'"
    )
    let ok: bool = os.execCmdResultExitCode(res) == 0
    tooling_runtimeObjSymbolCachePut(root, objPath, ok)
    return ok

fn tooling_runtimeAuthoritySourcePath(root: str): str =
    return os.joinPath(root, "src/std/system_helpers_backend.cheng")

fn tooling_runtimeMinimalNativeBridgeRelativeList(): str[] =
    var out: str[] = []
    add(out, "src/runtime/native/system_helpers_selflink_shim.c")
    add(out, "src/runtime/native/system_helpers_io_time_bridge.c")
    add(out, "src/runtime/native/system_helpers_host_process_ffi_bridge.c")
    return out

fn tooling_runtimeMinimalNativeBridgeSourceList(root: str): str[] =
    let rels: str[] = tooling_runtimeMinimalNativeBridgeRelativeList()
    var out: str[] = []
    for i in 0..<rels.len:
        add(out, os.joinPath(root, rels[i]))
    return out

fn tooling_runtimeObjNeedsRefresh(root: str, objPath: str): bool =
    if !tooling_strNonEmpty(objPath) || !os.fileExists(objPath):
        return true
    let objMtime: int64 = os.fileMtime(objPath)
    if objMtime <= 0:
        return true
    var deps: str[] = []
    add(deps, tooling_runtimeAuthoritySourcePath(root))
    let bridgeDeps: str[] = tooling_runtimeMinimalNativeBridgeSourceList(root)
    for i in 0..<bridgeDeps.len:
        add(deps, bridgeDeps[i])
    for i in 0..<deps.len:
        let dep: str = deps[i]
        if os.fileExists(dep) && os.fileMtime(dep) > objMtime:
            return true
    return false

fn tooling_runtimeObjPath(root: str, target: str): str =
    let candidate0: str = os.joinPath(root, "chengcache/runtime_selflink/system_helpers.backend.fullcompat." + target + ".o")
    if os.fileExists(candidate0) && tooling_runtimeObjHasRequiredSymbols(root, candidate0) &&
       !tooling_runtimeObjNeedsRefresh(root, candidate0):
        return candidate0
    let candidate1: str = os.joinPath(root, "chengcache/runtime_selflink/system_helpers.backend.combined." + target + ".o")
    if os.fileExists(candidate1) && tooling_runtimeObjHasRequiredSymbols(root, candidate1) &&
       !tooling_runtimeObjNeedsRefresh(root, candidate1):
        return candidate1
    if os.fileExists(os.joinPath(root, "artifacts/backend_mm/system_helpers.backend.combined." + target + ".o")) &&
       tooling_runtimeObjHasRequiredSymbols(
           root,
           os.joinPath(root, "artifacts/backend_mm/system_helpers.backend.combined." + target + ".o")
       ) &&
       !tooling_runtimeObjNeedsRefresh(
           root,
           os.joinPath(root, "artifacts/backend_mm/system_helpers.backend.combined." + target + ".o")
       ):
        return os.joinPath(root, "artifacts/backend_mm/system_helpers.backend.combined." + target + ".o")
    let candidate3: str = os.joinPath(root, "artifacts/backend_selfhost_self_obj/stage1.native.runtime.dedup.o")
    if os.fileExists(candidate3) && tooling_runtimeObjHasRequiredSymbols(root, candidate3):
        return candidate3
    let candidate4: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng." + target + ".o")
    if os.fileExists(candidate4) && tooling_runtimeObjHasRequiredSymbols(root, candidate4):
        return candidate4
    let candidate5: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng.o")
    if os.fileExists(candidate5) && tooling_runtimeObjHasRequiredSymbols(root, candidate5):
        return candidate5
    return ""

fn tooling_runtimeObjBasePath(root: str, target: str): str =
    let candidate0: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng." + target + ".o")
    if os.fileExists(candidate0):
        return candidate0
    let candidate1: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng.o")
    if os.fileExists(candidate1):
        return candidate1
    return ""

fn tooling_runtimeObjSeedCompatiblePath(root: str, target: str): str =
    let candidate0: str = os.joinPath(root, "chengcache/runtime_selflink/system_helpers.backend.fullcompat." + target + ".o")
    if os.fileExists(candidate0) && tooling_runtimeObjHasRequiredSymbols(root, candidate0):
        return candidate0
    let candidate1: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng." + target + ".o")
    if os.fileExists(candidate1) && tooling_runtimeObjHasRequiredSymbols(root, candidate1):
        return candidate1
    let candidate2: str = os.joinPath(root, "chengcache/system_helpers.backend.cheng.o")
    if os.fileExists(candidate2) && tooling_runtimeObjHasRequiredSymbols(root, candidate2):
        return candidate2
    return ""

fn tooling_runtimeObjHasFastExeSymbols(root: str, objPath: str): bool =
    if !tooling_strNonEmpty(objPath) || !os.fileExists(objPath):
        return false
    let hasNm: os.ExecCmdResult = tooling_exec(root, "command -v nm >/dev/null 2>&1")
    if os.execCmdResultExitCode(hasNm) != 0:
        return true
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "nm -g " + tooling_shellQuote(objPath) + " 2>/dev/null | awk '" +
        "BEGIN{" +
        " need[\"cheng_strlen\"]=1;" +
        " need[\"cheng_memcpy\"]=1;" +
        " need[\"cheng_memset\"]=1;" +
        " need[\"cheng_malloc\"]=1;" +
        " need[\"cheng_free\"]=1;" +
        " need[\"cheng_realloc\"]=1;" +
        " need[\"cheng_mem_retain\"]=1;" +
        " need[\"cheng_mem_release\"]=1;" +
        " need[\"cheng_seq_get\"]=1;" +
        " need[\"cheng_seq_set\"]=1;" +
        " need[\"cheng_str_bridge_load_into\"]=1;" +
        " need[\"cheng_strcmp\"]=1;" +
        " need[\"cheng_f32_bits_to_i64\"]=1;" +
        " need[\"cheng_f64_bits_to_i64\"]=1;" +
        " need[\"reserve_ptr_void\"]=1;" +
        " forbid_undef[\"backendMain\"]=1;" +
        " forbid_undef[\"cheng_register_string_meta\"]=1;" +
        "}" +
        "{ raw=$0; " +
        "  undef=(raw==\"U\" || raw==\"u\" || raw ~ /^U[ \\t]/ || raw ~ /^u[ \\t]/ || raw ~ /[ \\t]U[ \\t]/ || raw ~ /[ \\t]u[ \\t]/); " +
        "  sym=$NF; gsub(/^_+/, \"\", sym); " +
        "  if (undef && (sym in forbid_undef)) bad=1; " +
        "  if (!undef && sym != \"\") have[sym]=1; }" +
        "END{" +
        "  if (bad) exit 1;" +
        "  for (sym in need) if (!(sym in have)) exit 1;" +
        "  exit 0;" +
        "}'"
    )
    return os.execCmdResultExitCode(res) == 0

fn tooling_compileInputNeedsCombinedRuntimeObj(inPath: str): bool =
    if !tooling_strNonEmpty(inPath):
        return false
    if tooling_strContains(inPath, "/src/backend/tooling/"):
        return true
    if tooling_strContains(inPath, "/src/tooling/"):
        return true
    return false

fn tooling_compileRuntimeObjSupportsInput(root: str, inPath: str, runtimeObj: str): bool =
    if tooling_compileInputNeedsCombinedRuntimeObj(inPath):
        return tooling_runtimeObjHasRequiredSymbols(root, runtimeObj)
    return tooling_runtimeObjHasFastExeSymbols(root, runtimeObj) ||
           tooling_runtimeObjHasRequiredSymbols(root, runtimeObj)

fn tooling_compileExplicitNoRuntimeRuntimeObjPath(root: str, stage0Exec: str,
                                                  target: str, inPath: str): str =
    if tooling_compileInputNeedsCombinedRuntimeObj(inPath):
        var combinedRuntimeObj: str = tooling_runtimeObjPath(root, target)
        if !tooling_runtimeObjHasRequiredSymbols(root, combinedRuntimeObj):
            combinedRuntimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
        if tooling_runtimeObjHasRequiredSymbols(root, combinedRuntimeObj):
            return combinedRuntimeObj
        return ""
    let baseRuntimeObj: str = tooling_runtimeObjBasePath(root, target)
    if tooling_runtimeObjHasFastExeSymbols(root, baseRuntimeObj):
        return baseRuntimeObj
    var combinedRuntimeObj: str = tooling_runtimeObjPath(root, target)
    if !tooling_runtimeObjHasRequiredSymbols(root, combinedRuntimeObj):
        combinedRuntimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
    if tooling_compileRuntimeObjSupportsInput(root, inPath, combinedRuntimeObj):
        return combinedRuntimeObj
    return ""

fn tooling_runtimeLdArch(target: str): str =
    if strutil.startsWith(target, "arm64") || strutil.startsWith(target, "aarch64"):
        return "arm64"
    if strutil.startsWith(target, "x86_64"):
        return "x86_64"
    if strutil.startsWith(target, "riscv64"):
        return "riscv64"
    return ""

fn tooling_runtimeRefreshStaleCombinedPath(root: str, target: str): str =
    return os.joinPath(root, "chengcache/runtime_selflink/system_helpers.backend.combined." + target + ".o")

fn tooling_runtimeRefreshStage0Route(raw: str): str =
    return strutil.toLowerAscii(strutil.strip(raw))

fn tooling_runtimeRefreshDisableSidecar(stage0RouteRaw: str): bool =
    let _stage0RouteRaw: str = stage0RouteRaw
    return false

fn tooling_runtimeRefreshRuntimeSrc(root: str): str =
    return tooling_runtimeAuthoritySourcePath(root)

fn tooling_runtimeRefreshShimSrc(root: str): str =
    return os.joinPath(root, "src/runtime/native/system_helpers_selflink_shim.c")

fn tooling_runtimeRefreshIoTimeBridgeSrc(root: str): str =
    return os.joinPath(root, "src/runtime/native/system_helpers_io_time_bridge.c")

fn tooling_runtimeRefreshHostProcessFfiBridgeSrc(root: str): str =
    return os.joinPath(root, "src/runtime/native/system_helpers_host_process_ffi_bridge.c")

fn tooling_runtimeRefreshBridgeSrc(root: str): str =
    return os.joinPath(root, "src/backend/tooling/backend_driver_symbol_bridge.c")

fn tooling_runtimeRefreshBaseObj(root: str, target: str): str =
    return os.joinPath(root, "chengcache/system_helpers.backend.cheng." + target + ".o")

fn tooling_runtimeRefreshRuntimeDir(root: str): str =
    return os.joinPath(root, "chengcache/runtime_selflink")

fn tooling_runtimeRefreshShimObj(root: str, target: str): str =
    return os.joinPath(tooling_runtimeRefreshRuntimeDir(root), "system_helpers_selflink_shim." + target + ".o")

fn tooling_runtimeRefreshIoTimeBridgeObj(root: str, target: str): str =
    return os.joinPath(tooling_runtimeRefreshRuntimeDir(root), "system_helpers_io_time_bridge." + target + ".o")

fn tooling_runtimeRefreshHostProcessFfiBridgeObj(root: str, target: str): str =
    return os.joinPath(tooling_runtimeRefreshRuntimeDir(root), "system_helpers_host_process_ffi_bridge." + target + ".o")

fn tooling_runtimeRefreshBridgeObj(root: str, target: str): str =
    return os.joinPath(tooling_runtimeRefreshRuntimeDir(root), "backend_driver_symbol_bridge." + target + ".o")

fn tooling_runtimeRefreshCombinedObj(root: str, target: str): str =
    return os.joinPath(tooling_runtimeRefreshRuntimeDir(root), "system_helpers.backend.combined." + target + ".o")

fn tooling_runtimeRefreshCombinedTmp(root: str, target: str): str =
    return tooling_runtimeRefreshCombinedObj(root, target) + ".tmp"

fn tooling_runtimeRefreshMmCombinedObj(root: str, target: str): str =
    return os.joinPath(root, "artifacts/backend_mm/system_helpers.backend.combined." + target + ".o")

fn tooling_runtimeRefreshMmCodexFullObj(root: str, target: str): str =
    return os.joinPath(
        tooling_runtimeRefreshRuntimeDir(root),
        "system_helpers.backend.combined." + target + ".codex_full.o"
    )

fn tooling_runtimeRefreshMmSourceObj(root: str, target: str): str =
    if os.fileExists(tooling_runtimeRefreshMmCodexFullObj(root, target)):
        return tooling_runtimeRefreshMmCodexFullObj(root, target)
    return tooling_runtimeRefreshMmCombinedObj(root, target)

fn tooling_runtimeRefreshAppendOutput(logs: var str[], res: os.ExecCmdResult) =
    add(logs, os.execCmdResultOutput(res))

fn tooling_runtimeRefreshLastOutput(logs: str[]): str =
    if logs.len <= 0:
        return ""
    return logs[logs.len - 1]

fn tooling_runtimeRefreshRenameFailText(root: str, target: str): str =
    return "rename failed: " + tooling_runtimeRefreshCombinedTmp(root, target) +
           " -> " + tooling_runtimeRefreshCombinedObj(root, target) + "\n"

fn tooling_prepareRuntimeObjForTargetWithRoute(root: str, compilerPath: str, target: str,
                                               stage0RouteRaw: str): str =
    let fallbackPath: str = tooling_runtimeObjPath(root, target)
    let fallbackUsable: bool = tooling_runtimeObjHasRequiredSymbols(root, fallbackPath)
    let fallbackOk: bool = fallbackUsable &&
                           !tooling_runtimeObjNeedsRefresh(root, fallbackPath)
    let staleCombinedUsable: bool =
        tooling_runtimeObjHasRequiredSymbols(root, tooling_runtimeRefreshStaleCombinedPath(root, target))
    if !tooling_isExecutable(root, compilerPath):
        if fallbackUsable:
            return fallbackPath
        return staleCombinedUsable ? tooling_runtimeRefreshStaleCombinedPath(root, target) : ""
    let refreshEnabled: bool =
        tooling_isTrue(os.getEnvDefault("BACKEND_RUNTIME_OBJ_REFRESH", "0")) ||
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_RUNTIME_OBJ_REFRESH", "0")) ||
        tooling_isTrue(os.getEnvDefault("BACKEND_SELFHOST_RUNTIME_OBJ_REFRESH", "0")) ||
        !fallbackOk
    if !refreshEnabled && fallbackOk:
        return fallbackPath
    if !tooling_strNonEmpty(tooling_runtimeLdArch(target)):
        return fallbackPath
    if tooling_strNonEmpty(os.parentDir(tooling_runtimeRefreshBaseObj(root, target))):
        tooling_tryMkdirP(root, os.parentDir(tooling_runtimeRefreshBaseObj(root, target)))
    tooling_tryMkdirP(root, tooling_runtimeRefreshRuntimeDir(root))
    var timeoutSec: int32 = tooling_parseInt32Default(os.getEnvDefault("BACKEND_RUNTIME_OBJ_REFRESH_TIMEOUT", ""), 60)
    if timeoutSec < 1:
        timeoutSec = 60
    var prepRcFinal: int32 = 1
    var prepOutLogs: str[] = []
    if !tooling_isExecutable(root, compilerPath):
        prepRcFinal = 127
    else:
        var prepared: bool = false
        if false && os.fileExists(tooling_runtimeRefreshMmSourceObj(root, target)) &&
           os.fileExists(tooling_runtimeRefreshIoTimeBridgeSrc(root)):
            var compileEnv: str[] = []
            var ccArgs: str[] = []
            add(ccArgs, "-std=c11")
            add(ccArgs, "-O2")
            add(ccArgs, "-mmacosx-version-min=11.0")
            add(ccArgs, "-c")
            add(ccArgs, tooling_runtimeRefreshIoTimeBridgeSrc(root))
            add(ccArgs, "-o")
            add(ccArgs, tooling_runtimeRefreshIoTimeBridgeObj(root, target))
            let prepMmFdRes: os.ExecCmdResult =
                tooling_execProgramDirect(root, "cc", ccArgs, compileEnv, root, timeoutSec, true)
            prepRcFinal = os.execCmdResultExitCode(prepMmFdRes)
            tooling_runtimeRefreshAppendOutput(prepOutLogs, prepMmFdRes)
            if prepRcFinal == 0:
                var ldArgs: str[] = []
                add(ldArgs, "-r")
                add(ldArgs, "-arch")
                add(ldArgs, tooling_runtimeLdArch(target))
                add(ldArgs, "-o")
                add(ldArgs, tooling_runtimeRefreshCombinedTmp(root, target))
                add(ldArgs, tooling_runtimeRefreshMmSourceObj(root, target))
                add(ldArgs, tooling_runtimeRefreshIoTimeBridgeObj(root, target))
                let prepMmLdRes: os.ExecCmdResult =
                    tooling_execProgramDirect(root, "ld", ldArgs, compileEnv, root, timeoutSec, true)
                    prepRcFinal = os.execCmdResultExitCode(prepMmLdRes)
                tooling_runtimeRefreshAppendOutput(prepOutLogs, prepMmLdRes)
                if prepRcFinal == 0 &&
                   !os.renameFile(
                       tooling_runtimeRefreshCombinedTmp(root, target),
                       tooling_runtimeRefreshCombinedObj(root, target)
                   ):
                    prepRcFinal = 1
                    add(prepOutLogs, tooling_runtimeRefreshRenameFailText(root, target))
            if prepRcFinal == 0 && os.fileExists(tooling_runtimeRefreshCombinedObj(root, target)) &&
               tooling_runtimeObjHasRequiredSymbols(root, tooling_runtimeRefreshCombinedObj(root, target)):
                return tooling_runtimeRefreshCombinedObj(root, target)
            prepared = prepRcFinal == 0 &&
                       os.fileExists(tooling_runtimeRefreshCombinedObj(root, target)) &&
                       tooling_runtimeObjHasRequiredSymbols(root, tooling_runtimeRefreshCombinedObj(root, target))
        if !prepared:
            if !os.fileExists(tooling_runtimeRefreshShimSrc(root)) ||
               !os.fileExists(tooling_runtimeRefreshIoTimeBridgeSrc(root)) ||
               !os.fileExists(tooling_runtimeRefreshHostProcessFfiBridgeSrc(root)):
                return fallbackPath
            prepRcFinal = 0
            if prepRcFinal == 0:
                var compileEnv: str[] = []
                var ccArgs: str[] = []
                add(ccArgs, "-std=c11")
                add(ccArgs, "-O2")
                add(ccArgs, "-mmacosx-version-min=11.0")
                add(ccArgs, "-c")
                add(ccArgs, tooling_runtimeRefreshShimSrc(root))
                add(ccArgs, "-o")
                add(ccArgs, tooling_runtimeRefreshShimObj(root, target))
                let shimRes: os.ExecCmdResult =
                    tooling_execProgramDirect(root, "cc", ccArgs, compileEnv, root, timeoutSec, true)
                prepRcFinal = os.execCmdResultExitCode(shimRes)
                tooling_runtimeRefreshAppendOutput(prepOutLogs, shimRes)
                if prepRcFinal == 0:
                    ccArgs = []
                    add(ccArgs, "-std=c11")
                    add(ccArgs, "-O2")
                    add(ccArgs, "-mmacosx-version-min=11.0")
                    add(ccArgs, "-c")
                    add(ccArgs, tooling_runtimeRefreshIoTimeBridgeSrc(root))
                    add(ccArgs, "-o")
                    add(ccArgs, tooling_runtimeRefreshIoTimeBridgeObj(root, target))
                    let fdRes: os.ExecCmdResult =
                        tooling_execProgramDirect(root, "cc", ccArgs, compileEnv, root, timeoutSec, true)
                    prepRcFinal = os.execCmdResultExitCode(fdRes)
                    tooling_runtimeRefreshAppendOutput(prepOutLogs, fdRes)
                if prepRcFinal == 0:
                    ccArgs = []
                    add(ccArgs, "-std=c11")
                    add(ccArgs, "-O2")
                    add(ccArgs, "-mmacosx-version-min=11.0")
                    add(ccArgs, "-c")
                    add(ccArgs, tooling_runtimeRefreshHostProcessFfiBridgeSrc(root))
                    add(ccArgs, "-o")
                    add(ccArgs, tooling_runtimeRefreshHostProcessFfiBridgeObj(root, target))
                    let hostBridgeRes: os.ExecCmdResult =
                        tooling_execProgramDirect(root, "cc", ccArgs, compileEnv, root, timeoutSec, true)
                    prepRcFinal = os.execCmdResultExitCode(hostBridgeRes)
                    tooling_runtimeRefreshAppendOutput(prepOutLogs, hostBridgeRes)
                if prepRcFinal == 0:
                    var ldArgs: str[] = []
                    add(ldArgs, "-r")
                    add(ldArgs, "-arch")
                    add(ldArgs, tooling_runtimeLdArch(target))
                    add(ldArgs, "-o")
                    add(ldArgs, tooling_runtimeRefreshCombinedTmp(root, target))
                    add(ldArgs, tooling_runtimeRefreshShimObj(root, target))
                    add(ldArgs, tooling_runtimeRefreshIoTimeBridgeObj(root, target))
                    add(ldArgs, tooling_runtimeRefreshHostProcessFfiBridgeObj(root, target))
                    let ldRes: os.ExecCmdResult =
                        tooling_execProgramDirect(root, "ld", ldArgs, compileEnv, root, timeoutSec, true)
                    prepRcFinal = os.execCmdResultExitCode(ldRes)
                    tooling_runtimeRefreshAppendOutput(prepOutLogs, ldRes)
                    if prepRcFinal == 0 &&
                       !os.renameFile(
                           tooling_runtimeRefreshCombinedTmp(root, target),
                           tooling_runtimeRefreshCombinedObj(root, target)
                       ):
                        prepRcFinal = 1
                        add(prepOutLogs, tooling_runtimeRefreshRenameFailText(root, target))
            if prepRcFinal == 0 && os.fileExists(tooling_runtimeRefreshCombinedObj(root, target)) &&
               tooling_runtimeObjHasRequiredSymbols(root, tooling_runtimeRefreshCombinedObj(root, target)):
                return tooling_runtimeRefreshCombinedObj(root, target)
    let strictRefresh: bool = tooling_isTrue(os.getEnvDefault("BACKEND_RUNTIME_OBJ_REFRESH_STRICT", "0"))
    if !strictRefresh && fallbackUsable:
        return fallbackPath
    if !strictRefresh && staleCombinedUsable:
        return tooling_runtimeRefreshStaleCombinedPath(root, target)
    tooling_printErr("cheng_tooling: runtime object refresh failed for target=" + target +
                     " rc=" + intToStr(prepRcFinal) + " kind=" + tooling_exitKind(prepRcFinal))
    let refreshDebug: bool = strictRefresh || tooling_isTrue(os.getEnvDefault("BACKEND_RUNTIME_OBJ_REFRESH_DEBUG", "0"))
    if refreshDebug && tooling_strNonEmpty(tooling_runtimeRefreshLastOutput(prepOutLogs)):
        let rows: str[] = tooling_splitLines(tooling_runtimeRefreshLastOutput(prepOutLogs))
        var shown: int32 = 0
        for i in 0..<rows.len:
            if shown >= 80:
                break
            tooling_printErr("cheng_tooling: runtime refresh log: " + rows[i])
            shown = shown + 1
    if strictRefresh:
        return ""
    if fallbackUsable:
        return fallbackPath
    return staleCombinedUsable ? tooling_runtimeRefreshStaleCombinedPath(root, target) : ""

fn tooling_prepareRuntimeObjForTarget(root: str, compilerPath: str, target: str): str =
    return tooling_prepareRuntimeObjForTargetWithRoute(root, compilerPath, target, "")

fn tooling_printBackendResolveSelflinkRuntimeObjUsage() =
    tooling_printOut("backend_resolve_selflink_runtime_obj options:")
    tooling_printOut("  --target:<triple>            backend target triple (default host target)")
    tooling_printOut("  --prepare:0|1                refresh runtime object when missing/incomplete (default 1)")
    tooling_printOut("  --strict:0|1                 fail when unresolved (default 1)")
    tooling_printOut("  --help|-h")

fn tooling_printBackendLinkEnvUsage() =
    tooling_printOut("backend_link_env options:")
    tooling_printOut("  --driver:<path>              backend driver path (optional)")
    tooling_printOut("  --target:<triple>            backend target triple (default host target)")
    tooling_printOut("  --linker:<self|system|auto>  linker mode (default auto)")
    tooling_printOut("  --help|-h")

fn tooling_backendResolveSelflinkTargetRawFromArgs(argIndex: int32): str =
    return strings.dropPrefix(tooling_paramStr(argIndex), "--target:")

fn tooling_backendResolveSelflinkRuntimeObjPath(root: str, target: str, prepare: bool): str =
    if !prepare:
        return tooling_runtimeObjPath(root, target)
    if os.fileExists(tooling_runtimeObjPath(root, target)) &&
       tooling_runtimeObjHasRequiredSymbols(root, tooling_runtimeObjPath(root, target)):
        return tooling_runtimeObjPath(root, target)
    if tooling_isExecutable(root, tooling_resolveStage0Driver(root, "")):
        return tooling_prepareRuntimeObjForTarget(root, tooling_resolveStage0Driver(root, ""), target)
    return tooling_runtimeObjPath(root, target)

fn tooling_cmdBackendResolveSelflinkRuntimeObjFromArgs(root: str, argStart: int32, count: int32): int32 =
    var prepare: bool = true
    var strict: bool = true
    var targetArgIndex: int32 = -1
    var i: int32 = argStart
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        if tooling_strEq(tooling_paramStr(i), "--help") || tooling_strEq(tooling_paramStr(i), "-h"):
            tooling_printBackendResolveSelflinkRuntimeObjUsage()
            return 0
        if strutil.startsWith(tooling_paramStr(i), "--target:"):
            targetArgIndex = i
            i = i + 1
            continue
        if strutil.startsWith(tooling_paramStr(i), "--prepare:"):
            prepare = tooling_isTrue(strings.dropPrefix(tooling_paramStr(i), "--prepare:"))
            i = i + 1
            continue
        if strutil.startsWith(tooling_paramStr(i), "--strict:"):
            strict = tooling_isTrue(strings.dropPrefix(tooling_paramStr(i), "--strict:"))
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown backend_resolve_selflink_runtime_obj arg: " + tooling_paramStr(i))
        return 1
    let target: str = tooling_normalizeTargetAlias(
        root,
        targetArgIndex > 0
            ? tooling_backendResolveSelflinkTargetRawFromArgs(targetArgIndex)
            : ""
    )
    if !tooling_strNonEmpty(target) || tooling_strEq(target, "auto"):
        tooling_printErr("cheng_tooling: unable to resolve backend target; pass --target:<triple>")
        return 1
    let runtimeObjPath: str = tooling_backendResolveSelflinkRuntimeObjPath(root, target, prepare)
    let ok: bool = tooling_strNonEmpty(runtimeObjPath) &&
                   os.fileExists(runtimeObjPath) &&
                   tooling_runtimeObjHasRequiredSymbols(root, runtimeObjPath)
    tooling_printOut("backend_runtime_obj_target=" + target)
    tooling_printOut("backend_runtime_obj_path=" + runtimeObjPath)
    tooling_printOut("backend_runtime_obj_ok=" + tooling_boolText(ok))
    if ok:
        return 0
    tooling_printErr("cheng_tooling: missing valid self-link runtime object for target=" + target)
    return strict ? 1 : 0

fn tooling_backendLinkEnvRuntimeObjPath(root: str, driverRaw: str, target: str): str =
    let driverPath: str = strutil.strip(driverRaw)
    let existing: str = tooling_runtimeObjPath(root, target)
    if os.fileExists(existing) && tooling_runtimeObjHasRequiredSymbols(root, existing):
        return existing
    if tooling_isExecutable(root, driverPath):
        let prepared: str = tooling_prepareRuntimeObjForTarget(root, driverPath, target)
        if tooling_strNonEmpty(prepared):
            return prepared
    return tooling_backendResolveSelflinkRuntimeObjPath(root, target, true)

fn tooling_cmdBackendLinkEnvFromArgs(root: str, argStart: int32, count: int32): int32 =
    var driverRaw: str = tooling_textLiteral("")
    var targetRaw: str = tooling_textLiteral("")
    var linkerRaw: str = tooling_textLiteral("")
    var i: int32 = argStart
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printBackendLinkEnvUsage()
            return 0
        if strutil.startsWith(arg, "--driver:"):
            driverRaw = strings.dropPrefix(arg, "--driver:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--target:"):
            targetRaw = strings.dropPrefix(arg, "--target:")
            i = i + 1
            continue
        if strutil.startsWith(arg, "--linker:"):
            linkerRaw = strings.dropPrefix(arg, "--linker:")
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown backend_link_env arg: " + arg)
        return 2
    let target: str = tooling_normalizeTargetAlias(root, targetRaw)
    if !tooling_strNonEmpty(target) || tooling_strEq(target, "auto"):
        tooling_printErr("cheng_tooling: unable to resolve backend target; pass --target:<triple>")
        return 1
    var linkerMode: str = tooling_verifyBackendRequestedLinkerMode(
        linkerRaw, "auto", true, "backend_link_env")
    if !tooling_strNonEmpty(linkerMode):
        return 2
    if tooling_strEq(linkerMode, "auto"):
        linkerMode = tooling_targetSupportsSelfLinker(target) ? "self" : "system"
    if tooling_strEq(linkerMode, "system"):
        tooling_printOut(strutil.strip(tooling_envAssignCompat("BACKEND_LINKER", "system")))
        return 0
    let runtimeObj: str = tooling_backendLinkEnvRuntimeObjPath(root, driverRaw, target)
    if !tooling_strNonEmpty(runtimeObj) || !os.fileExists(runtimeObj):
        tooling_printErr("[backend_link_env] missing runtime object for target=" + target)
        tooling_printErr("  hint: set up " + tooling_runtimeRefreshCombinedObj(root, target))
        return 1
    if !tooling_runtimeObjHasRequiredSymbols(root, runtimeObj):
        tooling_printErr("[backend_link_env] missing required self-link symbols: " + runtimeObj)
        return 1
    var parts: str[] = []
    add(parts, tooling_envAssignCompat("BACKEND_LINKER", "self"))
    add(parts, tooling_envAssignCompat("BACKEND_NO_RUNTIME_C", "1"))
    add(parts, tooling_envAssignCompat("BACKEND_RUNTIME_OBJ", runtimeObj))
    tooling_printOut(strutil.strip(tooling_joinFragments(parts)))
    return 0

fn tooling_outputLooksExecutable(root: str, outPath: str): bool =
    if !tooling_strNonEmpty(outPath) || !os.fileExists(outPath):
        return false
    let probeFile: os.ExecCmdResult = tooling_exec(root, "command -v file >/dev/null 2>&1")
    if os.execCmdResultExitCode(probeFile) != 0:
        return true
    let res: os.ExecCmdResult = tooling_exec(root, "file -b " + tooling_shellQuote(outPath))
    if os.execCmdResultExitCode(res) != 0:
        return true
    if !tooling_strNonEmpty(strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res)))):
        return true
    return tooling_strContains(strutil.toLowerAscii(strutil.strip(os.execCmdResultOutput(res))), "executable")

fn tooling_driverSmokeFixturePath(root: str, allowGrowthFallback: bool): str =
    let configuredRaw: str = tooling_trimAsciiSpace(
        os.getEnvDefault("TOOLING_STAGE0_SMOKE_FIXTURE", "tests/cheng/backend/fixtures/return_add.cheng"))
    if tooling_strNonEmpty(configuredRaw) && os.fileExists(tooling_pathAbsolute(root, configuredRaw)):
        return tooling_pathAbsolute(root, configuredRaw)
    let returnAdd: str = os.joinPath(root, "tests/cheng/backend/fixtures/return_add.cheng")
    if os.fileExists(returnAdd):
        return returnAdd
    let growth: str = os.joinPath(root, "tests/cheng/backend/fixtures/return_new_ref_seq_growth.cheng")
    if allowGrowthFallback && os.fileExists(growth):
        return growth
    return ""

fn tooling_driverSmokeRuntimeObj(root: str, stage0Exec: str, target: str): str =
    if os.fileExists(tooling_runtimeObjPath(root, target)):
        return tooling_runtimeObjPath(root, target)
    return tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)

fn tooling_driverSmokeTimeoutSec(): int32 =
    let parsed: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_SMOKE_TIMEOUT", ""), 60)
    return parsed <= 0 ? 60 : parsed

fn tooling_driverSmokeRunTimeoutSec(): int32 =
    let parsed: int32 = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_SMOKE_RUN_TIMEOUT", ""), 15)
    return parsed < 1 ? 15 : parsed

fn tooling_driverSmokeOutputPath(root: str, kind: str): str =
    return os.joinPath(root, "chengcache/tooling_stage0_smoke" + kind + "." + tooling_nowNonceText() + ".bin")

fn tooling_driverCompileSmokeDevInmemCommand(root: str, stage0Exec: str, fixturePath: str,
                                             smokeOut: str, runtimeObj: str, target: str,
                                             timeoutSec: int32): str =
    let compileOpts: ToolingCompileOptions = tooling_verifyBackendCompileOptions(
        root, "self", target, fixturePath, smokeOut)
    compileOpts.fastDevProfileText = "1"
    compileOpts.noRuntimeCText = "1"
    compileOpts.runtimeObjPath = runtimeObj
    return tooling_wrapStage0LockTimeout(
        root,
        timeoutSec,
        tooling_prefixUnsetLegacyFrontendEnv(
            tooling_compileOptionsEnvText(root, stage0Exec, compileOpts) +
            tooling_shellQuote(stage0Exec) +
            " " + tooling_shellQuote("--input:" + fixturePath) +
            " " + tooling_shellQuote("--output:" + smokeOut) +
            " " + tooling_shellQuote("--target:" + target) +
            " " + tooling_shellQuote("--linker:self")
        ),
        "stage0_compile_smoke")

fn tooling_driverCompileSmokeReleaseSystemCommand(root: str, stage0Exec: str, fixturePath: str,
                                                  smokeOut: str, target: str,
                                                  timeoutSec: int32): str =
    return tooling_wrapStage0LockTimeout(
        root,
        timeoutSec,
        tooling_prefixUnsetLegacyFrontendEnv(
            tooling_compileOptionsEnvText(
                root,
                stage0Exec,
                tooling_verifyBackendCompileOptions(root, "system", target, fixturePath, smokeOut)) +
            tooling_shellQuote(stage0Exec) +
            " " + tooling_shellQuote("--input:" + fixturePath) +
            " " + tooling_shellQuote("--output:" + smokeOut) +
            " " + tooling_shellQuote("--target:" + target) +
            " " + tooling_shellQuote("--linker:system")
        ),
        "stage0_compile_smoke_release")

fn tooling_driverSmokeRunCommand(root: str, smokeOut: str, timeoutSec: int32): str =
    return tooling_wrapCommandWithTimeout(root, timeoutSec, tooling_shellQuote(smokeOut) + " >/dev/null 2>&1")

fn tooling_driverSmokeSizeText(root: str, smokeOut: str): str =
    return tooling_trimAsciiSpace(
        os.execCmdResultOutput(tooling_exec(root, "wc -c < " + tooling_shellQuote(smokeOut))))

fn tooling_driverSmokeMagicText(root: str, smokeOut: str): str =
    return tooling_trimAsciiSpace(
        os.execCmdResultOutput(
            tooling_exec(root, "xxd -l 8 " + tooling_shellQuote(smokeOut) + " 2>/dev/null | head -n 1")))


fn tooling_driverCompileSmokeDevInmemOk(root: str, binPath: str): bool =
    if !tooling_isExecutable(root, binPath):
        return false
    let fixturePath: str = tooling_driverSmokeFixturePath(root, true)
    if !os.fileExists(fixturePath):
        return true
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        return true
    let stage0Exec: str = tooling_prepareStage0Exec(root, binPath, "probe_dev_inmem")
    if !tooling_strNonEmpty(stage0Exec):
        return false
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    let runtimeObj: str = tooling_driverSmokeRuntimeObj(root, stage0Exec, target)
    if !os.fileExists(runtimeObj):
        tooling_printErr("cheng_tooling: stage0 dev-inmem smoke missing runtime object: " + runtimeObj)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    let smokeOut: str = tooling_driverSmokeOutputPath(root, "")
    let smokeOutDir: str = os.parentDir(smokeOut)
    if tooling_strNonEmpty(smokeOutDir):
        tooling_tryMkdirP(root, smokeOutDir)
    if os.fileExists(smokeOut):
        os.removeFile(smokeOut)
    let smokeCmd: str = tooling_driverCompileSmokeDevInmemCommand(
        root, stage0Exec, fixturePath, smokeOut, runtimeObj, target, tooling_driverSmokeTimeoutSec())
    let smokeRes: os.ExecCmdResult = tooling_exec(root, smokeCmd)
    let smokeRc: int32 = os.execCmdResultExitCode(smokeRes)
    let smokeOutText: str = strutil.strip(os.execCmdResultOutput(smokeRes))
    if smokeRc != 0:
        tooling_printErr("cheng_tooling: stage0 dev-inmem smoke compile failed rc=" + intToStr(smokeRc) +
                         " kind=" + tooling_exitKind(smokeRc))
        if tooling_strNonEmpty(smokeOutText):
            let rows: str[] = tooling_splitLines(smokeOutText)
            var shown: int32 = 0
            for i in 0..<rows.len:
                if shown >= 6:
                    break
                tooling_printErr("cheng_tooling: stage0 dev-inmem smoke log: " + rows[i])
                shown = shown + 1
        if os.fileExists(smokeOut):
            os.removeFile(smokeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    let sizeProbe: os.ExecCmdResult = tooling_exec(root, "test -s " + tooling_shellQuote(smokeOut))
    if os.execCmdResultExitCode(sizeProbe) != 0 || !tooling_outputLooksExecutable(root, smokeOut):
        tooling_printErr("cheng_tooling: stage0 dev-inmem smoke produced invalid binary")
        let keepFailedSmoke: bool = tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_SMOKE_KEEP_FAIL", "0"))
        if os.fileExists(smokeOut):
            let sizeText: str = tooling_driverSmokeSizeText(root, smokeOut)
            if tooling_strNonEmpty(sizeText):
                tooling_printErr("cheng_tooling: stage0 dev-inmem smoke invalid size_bytes=" + sizeText)
            let magicText: str = tooling_driverSmokeMagicText(root, smokeOut)
            if tooling_strNonEmpty(magicText):
                tooling_printErr("cheng_tooling: stage0 dev-inmem smoke invalid magic=" + magicText)
            if keepFailedSmoke:
                tooling_printErr("cheng_tooling: stage0 dev-inmem smoke keep failed output: " + smokeOut)
            else:
                os.removeFile(smokeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    let runRes: os.ExecCmdResult = tooling_exec(
        root, tooling_driverSmokeRunCommand(root, smokeOut, tooling_driverSmokeRunTimeoutSec()))
    let runRc: int32 = os.execCmdResultExitCode(runRes)
    if runRc != 0:
        tooling_printErr("cheng_tooling: stage0 dev-inmem smoke run failed rc=" + intToStr(runRc) +
                         " kind=" + tooling_exitKind(runRc))
        if os.fileExists(smokeOut):
            os.removeFile(smokeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    if os.fileExists(smokeOut):
        os.removeFile(smokeOut)
    tooling_cleanupStage0Exec(binPath, stage0Exec)
    return true

fn tooling_driverCompileSmokeReleaseSystemOk(root: str, binPath: str): bool =
    if !tooling_isExecutable(root, binPath):
        return false
    let fixturePath: str = tooling_driverSmokeFixturePath(root, false)
    if !os.fileExists(fixturePath):
        return true
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        return true
    let stage0Exec: str = tooling_prepareStage0Exec(root, binPath, "probe_release_system")
    if !tooling_strNonEmpty(stage0Exec):
        return false
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    let smokeOut: str = tooling_driverSmokeOutputPath(root, ".release")
    let smokeOutDir: str = os.parentDir(smokeOut)
    if tooling_strNonEmpty(smokeOutDir):
        tooling_tryMkdirP(root, smokeOutDir)
    if os.fileExists(smokeOut):
        os.removeFile(smokeOut)
    let smokeCmd: str = tooling_driverCompileSmokeReleaseSystemCommand(
        root, stage0Exec, fixturePath, smokeOut, target, tooling_driverSmokeTimeoutSec())
    let smokeRes0: os.ExecCmdResult = tooling_exec(root, smokeCmd)
    if os.execCmdResultExitCode(smokeRes0) != 0:
        if os.fileExists(smokeOut):
            os.removeFile(smokeOut)
        let smokeRes1: os.ExecCmdResult = tooling_exec(root, smokeCmd)
        let smokeRc1: int32 = os.execCmdResultExitCode(smokeRes1)
        let smokeOutText1: str = strutil.strip(os.execCmdResultOutput(smokeRes1))
        if smokeRc1 != 0:
            tooling_printErr("cheng_tooling: stage0 release-system smoke compile failed rc=" + intToStr(smokeRc1) +
                             " kind=" + tooling_exitKind(smokeRc1))
            if tooling_strNonEmpty(smokeOutText1):
                let rows: str[] = tooling_splitLines(smokeOutText1)
                var shown: int32 = 0
                for i in 0..<rows.len:
                    if shown >= 6:
                        break
                    tooling_printErr("cheng_tooling: stage0 release-system smoke log: " + rows[i])
                    shown = shown + 1
            if os.fileExists(smokeOut):
                os.removeFile(smokeOut)
            tooling_cleanupStage0Exec(binPath, stage0Exec)
            return false
    let sizeProbe: os.ExecCmdResult = tooling_exec(root, "test -s " + tooling_shellQuote(smokeOut))
    if os.execCmdResultExitCode(sizeProbe) != 0 || !tooling_outputLooksExecutable(root, smokeOut):
        tooling_printErr("cheng_tooling: stage0 release-system smoke produced invalid binary")
        if os.fileExists(smokeOut):
            os.removeFile(smokeOut)
        tooling_cleanupStage0Exec(binPath, stage0Exec)
        return false
    let runRes0: os.ExecCmdResult = tooling_exec(
        root, tooling_driverSmokeRunCommand(root, smokeOut, tooling_driverSmokeRunTimeoutSec()))
    if os.execCmdResultExitCode(runRes0) != 0:
        let runRes1: os.ExecCmdResult = tooling_exec(
            root, tooling_driverSmokeRunCommand(root, smokeOut, tooling_driverSmokeRunTimeoutSec()))
        let runRc1: int32 = os.execCmdResultExitCode(runRes1)
        if runRc1 != 0:
            tooling_printErr("cheng_tooling: stage0 release-system smoke run failed rc=" + intToStr(runRc1) +
                             " kind=" + tooling_exitKind(runRc1))
            if os.fileExists(smokeOut):
                os.removeFile(smokeOut)
            tooling_cleanupStage0Exec(binPath, stage0Exec)
            return false
    if os.fileExists(smokeOut):
        os.removeFile(smokeOut)
    tooling_cleanupStage0Exec(binPath, stage0Exec)
    return true

fn tooling_driverBuildTempDir(root: str): str =
    return os.joinPath(root, "chengcache/backend_driver_build_tmp")

fn tooling_driverBuildTempBase(outPath: str): str =
    if tooling_strNonEmpty(os.extractFilename(outPath)):
        return os.extractFilename(outPath)
    return "cheng"

fn tooling_driverBuildQuickCacheKey(root: str, outPath: str): str =
    if tooling_strNonEmpty(tooling_sha256Text(root, tooling_pathAbsolute(root, outPath))):
        return tooling_sha256Text(root, tooling_pathAbsolute(root, outPath))
    return tooling_driverBuildTempBase(outPath)

fn tooling_driverBuildTempPath(root: str, outPath: str, attemptIndex: int32): str =
    let tempDir: str = tooling_driverBuildTempDir(root)
    tooling_tryMkdirP(root, tempDir)
    return os.joinPath(
        tempDir,
        tooling_driverBuildTempBase(outPath) + ".attempt." + intToStr(attemptIndex) + "." + tooling_nowNonceText())

fn tooling_driverBuildQuickCachePath(root: str, outPath: str, attemptIndex: int32): str =
    let tempDir: str = tooling_driverBuildTempDir(root)
    tooling_tryMkdirP(root, tempDir)
    return os.joinPath(
        tempDir,
        tooling_driverBuildTempBase(outPath) + ".quick." + intToStr(attemptIndex) + "." +
            tooling_driverBuildQuickCacheKey(root, outPath))

fn tooling_buildDriverAttemptOutPath(root: str, outPath: str, attemptIndex: int32,
                                     persistentQuickCachePath: bool): str =
    if persistentQuickCachePath:
        return tooling_driverBuildQuickCachePath(root, outPath, attemptIndex)
    return tooling_driverBuildTempPath(root, outPath, attemptIndex)

fn tooling_buildDriverStampPath(outPath: str, fullRebuild: bool): str =
    if fullRebuild:
        return outPath + ".full_rebuild.stamp.env"
    return outPath + ".quick_rebuild.stamp.env"

fn tooling_buildDriverStampText(compileModeText: str, target: str, linkerMode: str,
                                stage0IdentityPath: str, stage0IdentitySha: str,
                                sourcePath: str, sourceSha: str, sourceCapabilitySignature: str,
                                parseMode: str,
                                fnSchedText: str, directExeText: str, incrementalText: str,
                                multiText: str, multiForceText: str, stage1BuilderText: str,
                                skipGlobalInitText: str, disableDupScanText: str,
                                skipFixupsText: str, skipNormalizeText: str,
                                genericModeText: str, genericSpecBudgetText: str,
                                genericLoweringText: str, jobs: int32): str =
    return "version=1\n" +
           "mode=" + compileModeText + "\n" +
           "target=" + target + "\n" +
           "linker=" + linkerMode + "\n" +
           "stage0_path=" + stage0IdentityPath + "\n" +
           "stage0_sha=" + stage0IdentitySha + "\n" +
           "source_path=" + sourcePath + "\n" +
           "source_sha=" + sourceSha + "\n" +
           "source_capability_signature=" + sourceCapabilitySignature + "\n" +
           "parse_mode=" + parseMode + "\n" +
           "fn_sched=" + fnSchedText + "\n" +
           "direct_exe=" + directExeText + "\n" +
           "incremental=" + incrementalText + "\n" +
           "multi=" + multiText + "\n" +
           "multi_force=" + multiForceText + "\n" +
           "stage1_builder=" + stage1BuilderText + "\n" +
           "skip_global_init=" + skipGlobalInitText + "\n" +
           "disable_dup_scan=" + disableDupScanText + "\n" +
           "skip_fixups=" + skipFixupsText + "\n" +
           "skip_normalize=" + skipNormalizeText + "\n" +
           "generic_mode=" + genericModeText + "\n" +
           "generic_spec_budget=" + genericSpecBudgetText + "\n" +
           "generic_lowering=" + genericLoweringText + "\n" +
           "jobs=" + intToStr(jobs) + "\n"

fn tooling_buildDriverStampMatches(stampRaw: str, compileModeText: str, target: str,
                                   linkerMode: str, stage0IdentityPath: str,
                                   stage0IdentitySha: str, sourcePath: str, sourceSha: str,
                                   sourceCapabilitySignature: str,
                                   parseMode: str, fnSchedText: str, directExeText: str,
                                   incrementalText: str, multiText: str, multiForceText: str,
                                   stage1BuilderText: str, skipGlobalInitText: str,
                                   disableDupScanText: str, skipFixupsText: str,
                                   skipNormalizeText: str, genericModeText: str,
                                   genericSpecBudgetText: str, genericLoweringText: str,
                                   jobs: int32, stampIgnoreStage0Sha: bool): bool =
    if !tooling_strNonEmpty(sourceCapabilitySignature):
        return false
    return tooling_strEq(tooling_kvGet(stampRaw, "version"), "1") &&
           tooling_strEq(tooling_kvGet(stampRaw, "mode"), compileModeText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "target"), target) &&
           tooling_strEq(tooling_kvGet(stampRaw, "linker"), linkerMode) &&
           tooling_strEq(tooling_kvGet(stampRaw, "stage0_path"), stage0IdentityPath) &&
           (stampIgnoreStage0Sha ||
            tooling_strEq(tooling_kvGet(stampRaw, "stage0_sha"), stage0IdentitySha)) &&
           tooling_strEq(tooling_kvGet(stampRaw, "source_path"), sourcePath) &&
           tooling_strEq(tooling_kvGet(stampRaw, "source_sha"), sourceSha) &&
           tooling_strEq(tooling_kvGet(stampRaw, "source_capability_signature"), sourceCapabilitySignature) &&
           tooling_strEq(tooling_kvGet(stampRaw, "parse_mode"), parseMode) &&
           tooling_strEq(tooling_kvGet(stampRaw, "fn_sched"), fnSchedText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "direct_exe"), directExeText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "incremental"), incrementalText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "multi"), multiText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "multi_force"), multiForceText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "stage1_builder"), stage1BuilderText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "skip_global_init"), skipGlobalInitText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "disable_dup_scan"), disableDupScanText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "skip_fixups"), skipFixupsText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "skip_normalize"), skipNormalizeText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "generic_mode"), genericModeText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "generic_spec_budget"), genericSpecBudgetText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "generic_lowering"), genericLoweringText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "jobs"), intToStr(jobs))

fn tooling_buildDriverSharedCacheKey(root: str, fullRebuild: bool, stampTextRaw: str): str =
    let stampText: str = strutil.strip(stampTextRaw)
    if !tooling_strNonEmpty(stampText):
        return ""
    return tooling_sha256Text(
        root,
        "kind=backend_driver_shared_cache\n" +
            "full_rebuild=" + (fullRebuild ? "1" : "0") + "\n" +
            stampText + "\n")

fn tooling_buildDriverSharedCachePath(root: str, keyRaw: str, fullRebuild: bool): str =
    let tempDir: str = tooling_driverBuildTempDir(root)
    tooling_tryMkdirP(root, tempDir)
    return os.joinPath(
        tempDir,
        "backend_driver.shared." + (fullRebuild ? "full" : "quick") + "." +
            (tooling_strNonEmpty(strutil.strip(keyRaw)) ? strutil.strip(keyRaw) : "default"))

fn tooling_buildDriverSharedStampPath(root: str, keyRaw: str, fullRebuild: bool): str =
    let cachePath: str = tooling_buildDriverSharedCachePath(root, keyRaw, fullRebuild)
    if !tooling_strNonEmpty(cachePath):
        return ""
    return cachePath + ".stamp.env"

fn tooling_buildDriverReuseStampMatches(stampRaw: str, compileModeText: str, target: str,
                                        linkerMode: str, sourcePath: str, sourceSha: str,
                                        sourceCapabilitySignature: str, parseMode: str,
                                        fnSchedText: str, directExeText: str,
                                        incrementalText: str, multiText: str,
                                        multiForceText: str, stage1BuilderText: str,
                                        skipGlobalInitText: str, disableDupScanText: str,
                                        skipFixupsText: str, skipNormalizeText: str,
                                        genericModeText: str, genericSpecBudgetText: str,
                                        genericLoweringText: str): bool =
    if !tooling_strNonEmpty(sourceCapabilitySignature):
        return false
    return tooling_strEq(tooling_kvGet(stampRaw, "version"), "1") &&
           tooling_strEq(tooling_kvGet(stampRaw, "mode"), compileModeText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "target"), target) &&
           tooling_strEq(tooling_kvGet(stampRaw, "linker"), linkerMode) &&
           tooling_strEq(tooling_kvGet(stampRaw, "source_path"), sourcePath) &&
           tooling_strEq(tooling_kvGet(stampRaw, "source_sha"), sourceSha) &&
           tooling_strEq(tooling_kvGet(stampRaw, "source_capability_signature"), sourceCapabilitySignature) &&
           tooling_strEq(tooling_kvGet(stampRaw, "parse_mode"), parseMode) &&
           tooling_strEq(tooling_kvGet(stampRaw, "fn_sched"), fnSchedText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "direct_exe"), directExeText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "incremental"), incrementalText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "multi"), multiText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "multi_force"), multiForceText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "stage1_builder"), stage1BuilderText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "skip_global_init"), skipGlobalInitText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "disable_dup_scan"), disableDupScanText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "skip_fixups"), skipFixupsText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "skip_normalize"), skipNormalizeText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "generic_mode"), genericModeText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "generic_spec_budget"), genericSpecBudgetText) &&
           tooling_strEq(tooling_kvGet(stampRaw, "generic_lowering"), genericLoweringText)

fn tooling_nonEmptyDefault(raw: str, fallback: str): str =
    if tooling_strNonEmpty(strutil.strip(raw)):
        return strutil.strip(raw)
    return fallback

fn tooling_textLiteral(raw: str): str =
    return raw

fn tooling_bool01Default(raw: str, fallback: str): str =
    if tooling_strNonEmpty(tooling_bool01Normalized(raw)):
        return tooling_bool01Normalized(raw)
    if tooling_strNonEmpty(tooling_bool01Normalized(fallback)):
        return tooling_bool01Normalized(fallback)
    return fallback

fn tooling_boolTextResolved(raw: str, fallback: str, argName: str, tag: str): str =
    let resolved: str = tooling_bool01Default(raw, fallback)
    if !tooling_strNonEmpty(tooling_bool01Normalized(resolved)):
        tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw)
        return ""
    return resolved

fn tooling_optionalBoolTextResolved(raw: str, fallback: str, argName: str, tag: str): str =
    let normalizedRaw: str = tooling_bool01Normalized(raw)
    if tooling_strNonEmpty(strutil.strip(raw)):
        if tooling_strNonEmpty(normalizedRaw):
            return normalizedRaw
        tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw)
        return ""
    let normalizedFallback: str = tooling_bool01Normalized(fallback)
    if tooling_strNonEmpty(normalizedFallback):
        return normalizedFallback
    return ""

fn tooling_envBool01Default(name: str, fallback: str): str =
    return tooling_bool01Default(os.getEnvDefault(name, fallback), fallback)

fn tooling_buildDriverConfiguredSourcePath(root: str, sourceRaw: str): str =
    return tooling_buildDriverSourcePath(root, sourceRaw)

fn tooling_buildDriverBoolTextResolved(raw: str, fallback: str, argName: str, tag: str): str =
    return tooling_boolTextResolved(raw, fallback, argName, tag)

fn tooling_compileJobsTextResolved(raw: str, fallback: str, argName: str, tag: str): str =
    let normalized: str = strutil.strip(raw)
    var jobs: int32 = tooling_parseInt32Default(strutil.strip(fallback), 1)
    if tooling_strNonEmpty(normalized):
        jobs = tooling_parseInt32Default(normalized, -1)
        if jobs < 1:
            tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw)
            return ""
    if jobs < 1:
        jobs = 1
    if jobs > 8:
        jobs = 8
    return intToStr(jobs)

fn tooling_compileOptLevelTextResolved(raw: str, fallback: str, argName: str, tag: str): str =
    let normalized: str = strutil.strip(raw)
    if !tooling_strNonEmpty(normalized):
        let fallbackNorm: str = strutil.strip(fallback)
        if !tooling_strNonEmpty(fallbackNorm):
            return ""
        return tooling_compileOptLevelTextResolved(fallbackNorm, "", argName, tag)
    let parsed: int32 = tooling_parseInt32Default(normalized, -1)
    if parsed < 0 || parsed > 3:
        tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw)
        return ""
    return intToStr(parsed)

fn tooling_compileGenericModeTextResolved(raw: str, fallback: str, argName: str, tag: str): str =
    let normalized: str = strutil.toLowerAscii(strutil.strip(raw))
    if !tooling_strNonEmpty(normalized):
        return fallback
    if tooling_genericModeIsDictOnly(normalized):
        return "dict"
    tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw +
                     " (expected dict)")
    return ""

fn tooling_compileGenericSpecBudgetTextResolved(raw: str, fallback: str,
                                                argName: str, tag: str): str =
    let normalized: str = strutil.strip(raw)
    if !tooling_strNonEmpty(normalized):
        return fallback
    let parsed: int32 = tooling_parseInt32Default(normalized, -1)
    if parsed != 0:
        tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw +
                         " (expected 0)")
        return ""
    return "0"

fn tooling_compileGenericLoweringTextResolved(raw: str, fallback: str,
                                              argName: str, tag: str): str =
    let normalized: str = strutil.toLowerAscii(strutil.strip(raw))
    if !tooling_strNonEmpty(normalized):
        return fallback
    if tooling_genericLoweringIsDictOnly(normalized):
        return "mir_dict"
    tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw +
                     " (expected mir_dict)")
    return ""

fn tooling_compileRuntimeObjPathResolved(root: str, raw: str, argName: str, tag: str): str =
    let normalized: str = strutil.strip(raw)
    if !tooling_strNonEmpty(normalized):
        return ""
    let resolved: str = tooling_pathAbsolute(root, normalized)
    if tooling_strNonEmpty(resolved) && os.fileExists(resolved):
        return resolved
    tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw)
    return ""

fn tooling_compileSidecarModeTextResolved(raw: str, fallback: str, argName: str, tag: str): str =
    let normalized: str = strutil.toLowerAscii(strutil.strip(raw))
    if !tooling_strNonEmpty(normalized):
        return fallback
    if tooling_strEq(normalized, "cheng"):
        return normalized
    tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw +
                     " (expected cheng)")
    return ""

fn tooling_compileSidecarBundlePathResolved(root: str, raw: str, argName: str, tag: str): str =
    let normalized: str = strutil.strip(raw)
    if !tooling_strNonEmpty(normalized):
        return ""
    let resolved: str = tooling_pathAbsolute(root, normalized)
    if tooling_fileExistsNonEmpty(resolved):
        return resolved
    tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw)
    return ""

fn tooling_compileSidecarCompilerPathResolved(root: str, raw: str, argName: str, tag: str): str =
    let normalized: str = strutil.strip(raw)
    if !tooling_strNonEmpty(normalized):
        return ""
    let resolved: str = tooling_pathAbsolute(root, normalized)
    if tooling_strNonEmpty(resolved) && tooling_isExecutable(root, resolved):
        return resolved
    tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw)
    return ""

fn tooling_compileSidecarChildModeTextResolved(raw: str, fallback: str,
                                               argName: str, tag: str): str =
    let normalized: str = strutil.toLowerAscii(strutil.strip(raw))
    if !tooling_strNonEmpty(normalized):
        return fallback
    if tooling_backendDriverUirSidecarChildModeValid(normalized):
        return normalized
    tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw +
                     " (expected cli|outer_cli)")
    return ""

fn tooling_compileSidecarOuterCompilerPathResolved(root: str, raw: str,
                                                   argName: str, tag: str): str =
    let normalized: str = strutil.strip(raw)
    if !tooling_strNonEmpty(normalized):
        return ""
    let resolved: str = tooling_pathAbsolute(root, normalized)
    if tooling_strNonEmpty(resolved) && tooling_isExecutable(root, resolved):
        return resolved
    tooling_printErr("cheng_tooling: " + tag + " invalid " + argName + ": " + raw)
    return ""

fn tooling_buildDriverParseModeResolved(raw: str, fallback: str, tag: str): str =
    let normalized: str = strutil.toLowerAscii(strutil.strip(raw))
    if !tooling_strNonEmpty(normalized):
        return fallback
    if tooling_strEq(normalized, "outline") || tooling_strEq(normalized, "full"):
        return normalized
    tooling_printErr("cheng_tooling: " + tag + " invalid parse mode: " + raw +
                     " (expected outline|full)")
    return ""

fn tooling_buildDriverJobsResolved(raw: str, fallback: int32, tag: str): int32 =
    let normalized: str = strutil.strip(raw)
    var jobs: int32 = fallback
    if tooling_strNonEmpty(normalized):
        jobs = tooling_parseInt32Default(normalized, -1)
        if jobs < 1:
            tooling_printErr("cheng_tooling: " + tag + " invalid jobs: " + raw)
            return 0
    if jobs < 1:
        jobs = 1
    if jobs > 8:
        jobs = 8
    return jobs

fn tooling_buildDriverCompileProfileResolved(root: str, args: ToolingBuildDriverArgsState,
                                             fullRebuild: bool, tag: str): ToolingBuildDriverCompileProfile =
    var profile: ToolingBuildDriverCompileProfile = nil
    new(profile)
    var sourceRaw: str = tooling_textLiteral("")
    var jobsRaw: str = tooling_textLiteral("")
    var parseModeRaw: str = tooling_textLiteral("")
    var incrementalRaw: str = tooling_textLiteral("")
    var multiRaw: str = tooling_textLiteral("")
    var multiForceRaw: str = tooling_textLiteral("")
    var genericModeRaw: str = tooling_textLiteral("")
    var genericSpecBudgetRaw: str = tooling_textLiteral("")
    var genericLoweringRaw: str = tooling_textLiteral("")
    var disableDupScanRaw: str = tooling_textLiteral("")
    var skipFixupsRaw: str = tooling_textLiteral("")
    var skipNormalizeRaw: str = tooling_textLiteral("")
    if args != nil:
        sourceRaw = args.sourcePath
        jobsRaw = args.jobsRaw
        parseModeRaw = args.parseModeRaw
        incrementalRaw = args.incrementalRaw
        multiRaw = args.multiRaw
        multiForceRaw = args.multiForceRaw
        genericModeRaw = args.genericModeRaw
        genericSpecBudgetRaw = args.genericSpecBudgetRaw
        genericLoweringRaw = args.genericLoweringRaw
        disableDupScanRaw = args.disableDupScanRaw
        skipFixupsRaw = args.skipFixupsRaw
        skipNormalizeRaw = args.skipNormalizeRaw
    profile.sourcePath = tooling_buildDriverConfiguredSourcePath(root, sourceRaw)
    profile.jobs = tooling_buildDriverJobsResolved(
        jobsRaw, tooling_buildDriverDefaultJobs(root), tag)
    if profile.jobs <= 0:
        return nil
    profile.parseMode = tooling_buildDriverParseModeResolved(
        parseModeRaw, fullRebuild ? "full" : "outline", tag)
    if !tooling_strNonEmpty(profile.parseMode):
        return nil
    profile.fnSchedText = tooling_textLiteral("ws")
    profile.directExeText = tooling_textLiteral("0")
    profile.incrementalText = tooling_buildDriverBoolTextResolved(
        incrementalRaw, fullRebuild ? "0" : "1", "incremental", tag)
    if !tooling_strNonEmpty(profile.incrementalText):
        return nil
    profile.multiText = tooling_buildDriverBoolTextResolved(
        multiRaw, tooling_buildDriverDefaultMulti(root), "multi", tag)
    if !tooling_strNonEmpty(profile.multiText):
        return nil
    profile.multiForceText = tooling_buildDriverBoolTextResolved(
        multiForceRaw, profile.multiText, "multi-force", tag)
    if !tooling_strNonEmpty(profile.multiForceText):
        return nil
    profile.stage1BuilderText = tooling_textLiteral("stage1")
    profile.skipGlobalInitText = tooling_textLiteral("0")
    profile.disableDupScanText = tooling_buildDriverBoolTextResolved(
        disableDupScanRaw, "0", "disable-dup-scan", tag)
    if !tooling_strNonEmpty(profile.disableDupScanText):
        return nil
    profile.skipFixupsText = tooling_buildDriverBoolTextResolved(
        skipFixupsRaw, "0", "skip-fixups", tag)
    if !tooling_strNonEmpty(profile.skipFixupsText):
        return nil
    profile.skipNormalizeText = tooling_buildDriverBoolTextResolved(
        skipNormalizeRaw, "0", "skip-normalize", tag)
    if !tooling_strNonEmpty(profile.skipNormalizeText):
        return nil
    if !tooling_genericModeIsDictOnly(genericModeRaw):
        tooling_printErr("cheng_tooling: " + tag + " only allows generic-mode=dict")
        return nil
    profile.genericModeText = tooling_nonEmptyDefault(genericModeRaw, "dict")
    profile.genericSpecBudgetText = tooling_nonEmptyDefault(genericSpecBudgetRaw, "0")
    if !tooling_genericLoweringIsDictOnly(genericLoweringRaw):
        tooling_printErr("cheng_tooling: " + tag + " only allows generic-lowering=mir_dict")
        return nil
    profile.genericLoweringText = tooling_nonEmptyDefault(genericLoweringRaw, "mir_dict")
    return profile

fn tooling_buildDriverArgsApplyCompatEnv(args: ToolingBuildDriverArgsState,
                                         fullRebuild: bool) =
    if args == nil:
        return
    if !tooling_strNonEmpty(strutil.strip(args.sourcePath)):
        args.sourcePath = os.getEnvDefault("BACKEND_BUILD_DRIVER_SOURCE", "")
    if fullRebuild:
        if !tooling_strNonEmpty(strutil.strip(args.jobsRaw)):
            args.jobsRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_JOBS", "")
        if !tooling_strNonEmpty(strutil.strip(args.parseModeRaw)):
            args.parseModeRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_PARSE_MODE", "")
        if !tooling_strNonEmpty(strutil.strip(args.incrementalRaw)):
            args.incrementalRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_INCREMENTAL", "")
        if !tooling_strNonEmpty(strutil.strip(args.multiRaw)):
            args.multiRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_MULTI", "")
        if !tooling_strNonEmpty(strutil.strip(args.multiForceRaw)):
            args.multiForceRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_MULTI_FORCE", "")
        if !tooling_strNonEmpty(strutil.strip(args.genericModeRaw)):
            args.genericModeRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_GENERIC_MODE", "")
        if !tooling_strNonEmpty(strutil.strip(args.genericLoweringRaw)):
            args.genericLoweringRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_GENERIC_LOWERING", "")
        if !tooling_strNonEmpty(strutil.strip(args.disableDupScanRaw)):
            args.disableDupScanRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_DISABLE_DUP_SCAN", "")
        if !tooling_strNonEmpty(strutil.strip(args.skipFixupsRaw)):
            args.skipFixupsRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_SKIP_FIXUPS", "")
        if !tooling_strNonEmpty(strutil.strip(args.skipNormalizeRaw)):
            args.skipNormalizeRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_SKIP_NORMALIZE", "")
        return
    if !tooling_strNonEmpty(strutil.strip(args.jobsRaw)):
        args.jobsRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_JOBS", "")
    if !tooling_strNonEmpty(strutil.strip(args.parseModeRaw)):
        args.parseModeRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_PARSE_MODE", "")
    if !tooling_strNonEmpty(strutil.strip(args.incrementalRaw)):
        args.incrementalRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_INCREMENTAL", "")
    if !tooling_strNonEmpty(strutil.strip(args.multiRaw)):
        args.multiRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_MULTI", "")
    if !tooling_strNonEmpty(strutil.strip(args.multiForceRaw)):
        args.multiForceRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_MULTI_FORCE", "")
    if !tooling_strNonEmpty(strutil.strip(args.genericModeRaw)):
        args.genericModeRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_GENERIC_MODE", "")
    if !tooling_strNonEmpty(strutil.strip(args.genericSpecBudgetRaw)):
        args.genericSpecBudgetRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_GENERIC_SPEC_BUDGET", "")
    if !tooling_strNonEmpty(strutil.strip(args.genericLoweringRaw)):
        args.genericLoweringRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_GENERIC_LOWERING", "")
    if !tooling_strNonEmpty(strutil.strip(args.disableDupScanRaw)):
        args.disableDupScanRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_DISABLE_DUP_SCAN", "")
    if !tooling_strNonEmpty(strutil.strip(args.skipFixupsRaw)):
        args.skipFixupsRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_SKIP_FIXUPS", "")
    if !tooling_strNonEmpty(strutil.strip(args.skipNormalizeRaw)):
        args.skipNormalizeRaw = os.getEnvDefault("BACKEND_BUILD_DRIVER_SKIP_NORMALIZE", "")

fn tooling_buildDriverDirectExeText(linkerMode: str): str =
    if tooling_strEq(linkerMode, "self"):
        return "1"
    return "0"

fn tooling_buildDriverStage0Purpose(fullRebuild: bool): str =
    if fullRebuild:
        return "rebuild"
    return "quick"

fn tooling_buildDriverCompileModeText(fullRebuild: bool): str =
    if fullRebuild:
        return "full"
    return "quick"

fn tooling_buildDriverDirectExePolicyVar(fullRebuild: bool): str =
    if fullRebuild:
        return "BACKEND_BUILD_DRIVER_REBUILD_DIRECT_EXE"
    return "BACKEND_BUILD_DRIVER_DIRECT_EXE"

fn tooling_buildDriverSourceSha(root: str, sourcePath: str, sidecarSourcePath: str,
                                useUirSidecar: bool): str =
    let sourceSha: str = tooling_sha256File(root, sourcePath)
    let sidecarSha: str = tooling_sha256File(root, sidecarSourcePath)
    let runtimeSha: str = tooling_sha256File(root, tooling_releaseRuntimeSrcPath(root))
    let bridgeSha: str = tooling_sha256File(root, tooling_runtimeRefreshBridgeSrc(root))
    var manifest: str = "source_sha=" + sourceSha + "\n" +
                        "runtime_sha=" + runtimeSha + "\n" +
                        "bridge_sha=" + bridgeSha + "\n"
    if useUirSidecar && tooling_strNonEmpty(sidecarSha):
        manifest = manifest + "sidecar_sha=" + sidecarSha + "\n"
    if !tooling_strNonEmpty(sourceSha):
        return ""
    return tooling_sha256Text(root, manifest)

fn tooling_buildDriverResolvedTarget(root: str, targetRaw: str): str =
    let target: str = tooling_trimAsciiSpace(targetRaw)
    if tooling_strNonEmpty(target):
        return target
    return tooling_detectHostTarget(root)

fn tooling_buildDriverOutPath(root: str, outRaw: str): str =
    return tooling_pathAbsolute(root, tooling_nonEmptyDefault(outRaw, "artifacts/backend_driver/cheng"))

fn tooling_buildDriverDebugDir(root: str, debugRebuildEnabled: bool): str =
    if !debugRebuildEnabled:
        return ""
    return os.joinPath(root, "artifacts/stage0_candidate_probe/build_backend_driver_debug." + tooling_nowNonceText())

fn tooling_buildDriverDebugSessionMeta(buildMode: str, requireRebuild: bool, target: str,
                                       outPath: str, attemptCount: int32): str =
    return "debug_rebuild=1\n" +
           "build_mode=" + buildMode + "\n" +
           "require_rebuild=" + (requireRebuild ? "1" : "0") + "\n" +
           "target=" + target + "\n" +
           "out_path=" + outPath + "\n" +
           "attempt_count=" + intToStr(attemptCount) + "\n"

fn tooling_seqValueAtOrEmpty(items: str[], idx: int32): str =
    if idx >= 0 && idx < items.len:
        return items[idx]
    return ""

fn tooling_buildBackendDriverCompileCmdBase(root: str, sourcePath: str, outPath: str,
                                            target: str, linkerMode: str, parseMode: str,
                                            fnSchedText: str, directExeText: str,
                                            incrementalText: str, multiText: str,
                                            multiForceText: str, stage1BuilderText: str,
                                            skipGlobalInitText: str, disableDupScanText: str,
                                            skipFixupsText: str, skipNormalizeText: str,
                                            genericModeText: str, genericSpecBudgetText: str,
                                            genericLoweringText: str, runtimeObj: str,
                                            stage0Exec: str, jobs: int32,
                                            attemptTimeoutSec: int32,
                                            uirSidecarBundle: str): str =
    let _fnSchedText: str = fnSchedText
    let _multiForceText: str = multiForceText
    var envOverrides: str[] = []
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "dev", parseMode, linkerMode, target, sourcePath, outPath,
        "exe", "", "1", directExeText, directExeText, multiText, incrementalText,
        intToStr(jobs), intToStr(jobs))
    compileOpts.stage1BuilderText = stage1BuilderText
    compileOpts.skipGlobalInitText = skipGlobalInitText
    compileOpts.optLevelText = "0"
    compileOpts.optText = "0"
    compileOpts.opt2Text = "0"
    compileOpts.uirSimdText = "0"
    compileOpts.genericModeText = genericModeText
    compileOpts.genericSpecBudgetText = genericSpecBudgetText
    compileOpts.genericLoweringText = genericLoweringText
    compileOpts.disableDupScanText = disableDupScanText
    compileOpts.skipFixupsText = skipFixupsText
    compileOpts.skipNormalizeText = skipNormalizeText
    if tooling_strEq(linkerMode, "self"):
        compileOpts.noRuntimeCText = "1"
        compileOpts.runtimeObjPath = runtimeObj
        compileOpts.runtimeObjAssigned = true
    else:
        compileOpts.noRuntimeCText = "0"
    if tooling_fileExistsNonEmpty(uirSidecarBundle):
        if !tooling_compileApplyStrictSidecarContract(
                root, "build-backend-driver", stage0Exec, uirSidecarBundle, "", compileOpts):
            return tooling_wrapStage0LockTimeout(
                root,
                attemptTimeoutSec,
                "echo " + tooling_shellQuote(
                    "cheng_tooling: build-backend-driver missing strict fresh Cheng sidecar contract") +
                    " >&2; exit 1",
                "build_backend_driver_attempt")
    if tooling_strEq(os.extractFilename(sourcePath), "backend_driver.cheng"):
        compileOpts.cflagsRaw = "-DCHENG_BACKEND_DRIVER_ENTRY_SHIM=1"
    tooling_compileCollectEnvOverrides(root, stage0Exec, compileOpts, envOverrides)
    tooling_envAssignCollect(envOverrides, "TOOLING_TIMEOUT_DIAG", "1")
    tooling_envAssignCollect(envOverrides, "TOOLING_TIMEOUT_DIAG_DIR",
                             os.joinPath(root, "chengcache/backend_timeout_diag"))
    tooling_envAssignCollect(envOverrides, "TOOLING_TIMEOUT_DIAG_SECONDS",
                             intToStr(attemptTimeoutSec))
    tooling_envAssignCollect(envOverrides, "TOOLING_TIMEOUT_DIAG_SUMMARY", "1")
    tooling_envAssignCollect(envOverrides, "TOOLING_TIMEOUT_DIAG_SUMMARY_TOP", "12")
    return tooling_prefixUnsetLegacyFrontendEnv(
        tooling_envOverridesCompatText(envOverrides) +
        tooling_shellQuote(stage0Exec) +
        " " + tooling_shellQuote("--input:" + sourcePath) +
        " " + tooling_shellQuote("--output:" + outPath) +
        " " + tooling_shellQuote("--target:" + target) +
        " " + tooling_shellQuote("--linker:" + linkerMode))

fn tooling_buildBackendDriverCrashTraceCmd(root: str, compileCmdBase: str,
                                           traceTimeoutSec: int32): str =
    return tooling_wrapCommandWithTimeout(
        root,
        traceTimeoutSec,
        tooling_envAssignCompat("STAGE1_TRACE", "1") +
            tooling_envAssignCompat("STAGE1_TRACE_FLUSH", "1") +
            tooling_envAssignCompat("STAGE1_TOKEN_CACHE", "0") +
            compileCmdBase)

fn tooling_buildBackendDriverDiagCmd(root: str, lastCompileCmdBase: str,
                                     lastAttemptTimeoutSec: int32,
                                     profileEnabled: bool, profileMode: str): str =
    return tooling_wrapCommandWithTimeout(
        root,
        lastAttemptTimeoutSec,
        (profileEnabled ? tooling_prefixBuildDriverProfile("", profileMode) : "") +
            tooling_envAssignCompat("BACKEND_DEBUG_STAGE1_PIPE", "1") +
            lastCompileCmdBase)

fn tooling_buildDriverDirectFastReuseOk(root: str, outPathRaw: str, target: str,
                                        buildLinkerMode: str, quickLightSanity: bool,
                                        compileProfile: ToolingBuildDriverCompileProfile): bool =
    let outPath: str = tooling_pathAbsolute(root, outPathRaw)
    if !tooling_strNonEmpty(outPath) || !tooling_fileExistsNonEmpty(outPath):
        return false
    let stampPath: str = tooling_buildDriverStampPath(outPath, false)
    if !os.fileExists(stampPath):
        return false
    let linkerModeRaw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_LINKER", "")))
    if tooling_strNonEmpty(linkerModeRaw) &&
       !tooling_strEq(linkerModeRaw, "self") &&
       !tooling_strEq(linkerModeRaw, "system"):
        return false
    let strictLinkerRaw: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_LINKER_STRICT", "")))
    if tooling_strNonEmpty(strictLinkerRaw) &&
       !tooling_strEq(strictLinkerRaw, "self") &&
       !tooling_strEq(strictLinkerRaw, "system"):
        return false
    let fnSchedOverrideRaw: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_FN_SCHED", "")))
    if tooling_strNonEmpty(fnSchedOverrideRaw) && !tooling_strEq(fnSchedOverrideRaw, "ws"):
        return false
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_DIRECT_EXE", ""))):
        return false
    if compileProfile == nil:
        return false
    let sourcePath: str = compileProfile.sourcePath
    if !os.fileExists(sourcePath):
        return false
    let sourceSha: str = tooling_sha256File(root, sourcePath)
    let sourceCapabilitySignature: str = tooling_stage0CapabilitySignature(root)
    if !tooling_strNonEmpty(sourceSha) || !tooling_strNonEmpty(sourceCapabilitySignature):
        return false
    let incrementalText: str = compileProfile.incrementalText
    let multiText: str = compileProfile.multiText
    let multiForceText: str = compileProfile.multiForceText
    let stage1BuilderText: str = compileProfile.stage1BuilderText
    let skipGlobalInitText: str = compileProfile.skipGlobalInitText
    if !tooling_strEq(skipGlobalInitText, "0"):
        return false
    let disableDupScanText: str = compileProfile.disableDupScanText
    let skipFixupsText: str = compileProfile.skipFixupsText
    let skipNormalizeText: str = compileProfile.skipNormalizeText
    let genericSpecBudgetText: str = compileProfile.genericSpecBudgetText
    let directExeText: str = compileProfile.directExeText
    let stampRaw: str = tooling_readTextFile(root, stampPath)
    if !tooling_buildDriverReuseStampMatches(
        stampRaw, "quick", target, buildLinkerMode, sourcePath, sourceSha,
        sourceCapabilitySignature, compileProfile.parseMode, compileProfile.fnSchedText, directExeText,
        incrementalText, multiText, multiForceText, stage1BuilderText,
        skipGlobalInitText, disableDupScanText, skipFixupsText, skipNormalizeText,
        compileProfile.genericModeText, genericSpecBudgetText, compileProfile.genericLoweringText):
        return false
    if !tooling_driverBuildOutputOk(root, outPath, "quick", quickLightSanity, false, buildLinkerMode):
        return false
    if !tooling_buildDriverFastCanonicalSmokeProofOk(
        root, outPath, target, sourceSha, sourceCapabilitySignature):
        return false
    let capPath: str = tooling_stage0CapabilityFilePath(outPath)
    if !os.fileExists(capPath):
        let _capWritten: bool = tooling_stage0CapabilityWriteForOutput(root, outPath)
    return true

fn tooling_buildDriverDebugAttemptRecord(debugDir: str, attemptIndex: int32, stage0: str, outPath: str,
                                         rc: int32, postBuildOk: bool, compileMode: str) =
    if !tooling_strNonEmpty(debugDir):
        return
    let attemptPath: str = os.joinPath(debugDir, "attempt." + intToStr(attemptIndex) + ".env")
    if tooling_writeTextFileViaShell(
        "",
        attemptPath,
        "attempt=" + intToStr(attemptIndex) + "\n" +
            "stage0=" + stage0 + "\n" +
            "out=" + outPath + "\n" +
            "rc=" + intToStr(rc) + "\n" +
            "kind=" + tooling_exitKind(rc) + "\n" +
            "post_build_ok=" + (postBuildOk ? "1" : "0") + "\n" +
            "compile_mode=" + compileMode + "\n"):
        tooling_printOut("build_backend_driver_debug_attempt_record=" + attemptPath)
    else:
        tooling_printErr("cheng_tooling: failed to write debug attempt record: " + attemptPath)

fn tooling_driverBuildTempCleanup(root: str, outPath: str) =
    if !tooling_strNonEmpty(outPath):
        return
    if os.fileExists(outPath):
        os.removeFile(outPath)
    if os.fileExists(tooling_buildDriverStampPath(outPath, false)):
        os.removeFile(tooling_buildDriverStampPath(outPath, false))
    if os.fileExists(tooling_buildDriverStampPath(outPath, true)):
        os.removeFile(tooling_buildDriverStampPath(outPath, true))
    if os.fileExists(tooling_stage0CapabilityFilePath(outPath)):
        os.removeFile(tooling_stage0CapabilityFilePath(outPath))
    if tooling_strNonEmpty(tooling_buildDriverFastCanonicalSmokeProofPath(root, outPath)) &&
       os.fileExists(tooling_buildDriverFastCanonicalSmokeProofPath(root, outPath)):
        os.removeFile(tooling_buildDriverFastCanonicalSmokeProofPath(root, outPath))
    if os.fileExists(outPath + ".tmp.linkobj"):
        os.removeFile(outPath + ".tmp.linkobj")
    if os.dirExists(outPath + ".objs") || os.fileExists(outPath + ".objs.lock"):
        let cleanupRes: os.ExecCmdResult = tooling_exec(
            root,
            "rm -rf " + tooling_shellQuote(outPath + ".objs") + " " + tooling_shellQuote(outPath + ".objs.lock"))
        tooling_printExecOutput(cleanupRes)

fn tooling_collectLegacyDriverObjFiles(root: str): str[] =
    let _root: str = root
    var out: str[] = []
    return out

fn tooling_prepareBackendDriverCompatWrapObj(root: str): str =
    let _root: str = root
    return ""

fn tooling_backendDriverUirSidecarSnapshotPath(root: str): str =
    return os.joinPath(
        root, "artifacts/backend_sidecar_cheng_fresh/verify_backend_sidecar_cheng_fresh.snapshot.env")

fn tooling_backendDriverUirSidecarSnapshotRaw(root: str): str =
    return tooling_readTextFile(root, tooling_backendDriverUirSidecarSnapshotPath(root))

fn tooling_backendDriverUirSidecarChildModeValid(modeText: str): bool =
    if tooling_strEq(modeText, "cli"):
        return true
    if tooling_strEq(modeText, "outer_cli"):
        return true
    return false

fn tooling_backendDriverUirSidecarStablePathOk(root: str, rawPath: str,
                                               requireExecutable: bool): bool =
    let absRoot: str = tooling_pathAbsolute(root, root)
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if !tooling_strNonEmpty(absRoot) || !tooling_strNonEmpty(absPath):
        return false
    if !tooling_strEq(absPath, absRoot) &&
       !strutil.startsWith(absPath, absRoot + "/"):
        return false
    if requireExecutable:
        return tooling_isExecutable(root, absPath)
    return tooling_fileExistsNonEmpty(absPath)

fn tooling_backendDriverSidecarDistRealDriverPath(root: str): str =
    return tooling_pathAbsolute(root, "dist/releases/current/cheng")

fn tooling_backendDriverUirSidecarStrictRealDriverPathOk(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if !tooling_backendDriverUirSidecarStablePathOk(root, absPath, true):
        return false
    if tooling_strEq(absPath, tooling_backendDriverSidecarDistRealDriverPath(root)):
        return false
    return true

fn tooling_backendDriverUirSidecarSnapshotOk(root: str): bool =
    let snapshotRaw: str = tooling_backendDriverUirSidecarSnapshotRaw(root)
    let snapshotBundle: str = tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_bundle")
    let snapshotCompiler: str = tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_compiler")
    let snapshotRealDriver: str = tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_real_driver")
    let snapshotChildMode: str = strutil.toLowerAscii(strutil.strip(
        tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_child_mode")))
    let snapshotOuterCompanion: str = tooling_kvGet(
        snapshotRaw, "backend_sidecar_cheng_fresh_outer_companion")
    if !tooling_strEq(tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_status"), "ok"):
        return false
    if !tooling_strEq(tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_mode"), "cheng"):
        return false
    if !tooling_backendDriverUirSidecarStablePathOk(root, snapshotBundle, false):
        return false
    if !tooling_backendDriverUirSidecarStablePathOk(root, snapshotCompiler, true):
        return false
    if !tooling_backendDriverUirSidecarStrictRealDriverPathOk(root, snapshotRealDriver):
        return false
    if !tooling_backendDriverCurrentsrcProofRuntimeSurfaceOk(root, snapshotRealDriver):
        return false
    if !tooling_backendDriverUirSidecarChildModeValid(snapshotChildMode):
        return false
    if tooling_strEq(snapshotChildMode, "outer_cli") &&
       !tooling_backendDriverUirSidecarStablePathOk(root, snapshotOuterCompanion, true):
        return false
    return true

fn tooling_backendDriverUirSidecarLiveTarget(root: str, targetHint: str): str =
    let normalizedHint: str = tooling_normalizeTargetAlias(root, targetHint)
    if tooling_strNonEmpty(normalizedHint):
        return normalizedHint
    let envTarget: str = tooling_normalizeTargetAlias(
        root, strutil.strip(os.getEnvDefault("BACKEND_TARGET", "")))
    if tooling_strNonEmpty(envTarget):
        return envTarget
    return tooling_detectHostTarget(root)

fn tooling_backendDriverUirSidecarLiveBundlePath(root: str, targetHint: str): str =
    let target: str = tooling_backendDriverUirSidecarLiveTarget(root, targetHint)
    if !tooling_strNonEmpty(target):
        return ""
    let stableBundle: str = tooling_backendDriverUirSidecarBundlePath(root, target)
    if tooling_fileExistsNonEmpty(stableBundle):
        return stableBundle
    let currentBundle: str = stableBundle + ".current"
    if tooling_fileExistsNonEmpty(currentBundle):
        return currentBundle
    return ""

fn tooling_backendDriverUirSidecarLiveCompilerPath(root: str, targetHint: str): str =
    let target: str = tooling_backendDriverUirSidecarLiveTarget(root, targetHint)
    if !tooling_strNonEmpty(target):
        return ""
    let compilerPath: str = tooling_backendDriverCurrentsrcSidecarCompilerPath(root, target)
    if tooling_isExecutable(root, compilerPath):
        return compilerPath
    return ""

fn tooling_backendDriverUirSidecarLiveDriverPath(root: str, targetHint: str): str =
    let target: str = tooling_backendDriverUirSidecarLiveTarget(root, targetHint)
    if !tooling_strNonEmpty(target):
        return ""
    let driverPath: str = tooling_backendDriverSidecarOuterDriverPath(root, target)
    if tooling_isExecutable(root, driverPath):
        return driverPath
    return ""

fn tooling_backendDriverUirSidecarLiveRealDriverPathOk(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if !tooling_backendDriverUirSidecarStrictRealDriverPathOk(root, absPath):
        return false
    return tooling_backendDriverCurrentsrcProofDirectExportSurfaceOk(root, absPath)

fn tooling_backendDriverUirSidecarLiveExplicitRealDriver(root: str): str =
    let envPath0: str = tooling_pathAbsolute(
        root, strutil.strip(os.getEnvDefault("BACKEND_UIR_SIDECAR_REAL_DRIVER", "")))
    if tooling_backendDriverUirSidecarLiveRealDriverPathOk(root, envPath0):
        return envPath0
    let envPath1: str = tooling_pathAbsolute(
        root, strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_CURRENTSOURCE_REAL_DRIVER", "")))
    if tooling_backendDriverUirSidecarLiveRealDriverPathOk(root, envPath1):
        return envPath1
    return ""

fn tooling_backendDriverUirSidecarLiveContractOk(root: str, targetHint: str): bool =
    let bundlePath: str = tooling_backendDriverUirSidecarLiveBundlePath(root, targetHint)
    let compilerPath: str = tooling_backendDriverUirSidecarLiveCompilerPath(root, targetHint)
    let driverPath: str = tooling_backendDriverUirSidecarLiveDriverPath(root, targetHint)
    let realDriver: str = tooling_backendDriverUirSidecarLiveExplicitRealDriver(root)
    if !tooling_fileExistsNonEmpty(bundlePath):
        return false
    if !tooling_isExecutable(root, compilerPath):
        return false
    if !tooling_isExecutable(root, driverPath):
        return false
    if !tooling_isExecutable(root, realDriver):
        return false
    let childMode: str = tooling_backendDriverSidecarCompilerChildMode(root, compilerPath)
    if !tooling_backendDriverUirSidecarChildModeValid(childMode):
        return false
    if tooling_strEq(childMode, "outer_cli"):
        let outerCompanion: str = tooling_backendDriverSidecarCompilerOuterCompanion(root, compilerPath)
        if !tooling_isExecutable(root, outerCompanion):
            return false
    return true

fn tooling_backendDriverUirSidecarMode(root: str): str =
    let modeRaw: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("BACKEND_UIR_SIDECAR_MODE", "")))
    if tooling_strNonEmpty(modeRaw):
        if tooling_strEq(modeRaw, "cheng"):
            return "cheng"
        return ""
    if tooling_backendDriverUirSidecarSnapshotOk(root):
        return "cheng"
    if tooling_backendDriverUirSidecarLiveContractOk(root, ""):
        return "cheng"
    return ""

fn tooling_backendDriverUirSidecarChengSourcePath(root: str): str =
    return os.joinPath(root, "src/backend/tooling/backend_driver_uir_sidecar.cheng")

fn tooling_backendDriverUirSidecarWrapperSourcePath(root: str): str =
    return os.joinPath(root, "src/backend/tooling/backend_driver_uir_sidecar_wrapper.cheng")

fn tooling_backendDriverUirSidecarCSourcePath(root: str): str =
    return os.joinPath(root, "src/backend/tooling/backend_driver_uir_sidecar_bundle.c")

fn tooling_backendDriverUirSidecarSourcePath(root: str): str =
    return tooling_backendDriverUirSidecarWrapperSourcePath(root)

fn tooling_backendDriverUirSidecarObjPath(root: str, target: str): str =
    return os.joinPath(root, "chengcache/backend_driver_sidecar/backend_driver_uir_sidecar." + target + ".o")

fn tooling_backendDriverUirSidecarHelperObjPath(root: str, target: str): str =
    return os.joinPath(root, "chengcache/backend_driver_sidecar/backend_driver_uir_sidecar_helper." + target + ".o")

fn tooling_backendDriverUirSidecarBundlePath(root: str, target: str): str =
    return os.joinPath(root, "chengcache/backend_driver_sidecar/backend_driver_uir_sidecar." + target + ".bundle")

fn tooling_backendDriverSidecarOuterDriverSourcePath(root: str): str =
    return os.joinPath(root, "src/backend/tooling/backend_driver_sidecar_outer_main.c")

fn tooling_backendDriverSidecarOuterExportsSourcePath(root: str): str =
    return os.joinPath(root, "src/backend/tooling/backend_driver_sidecar_outer_exports.c")

fn tooling_backendDriverSidecarOuterDriverPath(root: str, target: str): str =
    return os.joinPath(root, "chengcache/backend_driver_sidecar/backend_driver_sidecar_outer." + target)

fn tooling_backendDriverCurrentsrcSidecarCompilerTemplatePath(root: str): str =
    return os.joinPath(root,
                       "src/tooling/cheng_tooling_embedded_scripts/backend_driver_currentsrc_sidecar_wrapper.sh")

fn tooling_backendDriverCurrentsrcSidecarCompilerPath(root: str, target: str): str =
    return os.joinPath(root,
                       "chengcache/backend_driver_sidecar/backend_driver_currentsrc_sidecar_wrapper." +
                       target + ".sh")

fn tooling_backendDriverCurrentsrcProofRealDriverPath(root: str): str =
    return os.joinPath(root,
                       "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng_stage0_currentsrc.proof")

fn tooling_backendDriverCurrentsrcProofBootstrapStage0Path(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    return tooling_strEq(absPath, tooling_backendDriverCurrentsrcProofRealDriverPath(root))

fn tooling_backendDriverCurrentsrcProofPublishedStage2Path(root: str): str =
    return os.joinPath(root,
                       "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof/cheng.stage2")

fn tooling_backendDriverCurrentsrcProofPublishedStage0Label(pathRaw: str): str =
    let path: str = strutil.strip(pathRaw)
    if strutil.endsWith(path, "/cheng.stage1"):
        return "stage1"
    if strutil.endsWith(path, "/cheng.stage2"):
        return "stage2"
    if strutil.endsWith(path, "/cheng.stage2.proof"):
        return "stage2.proof"
    return ""

fn tooling_backendDriverCurrentsrcProofStrictStage0Label(root: str, pathRaw: str): str =
    let absPath: str = tooling_pathAbsolute(root, pathRaw)
    if tooling_backendDriverCurrentsrcProofBootstrapStage0Path(root, absPath):
        return "currentsrc.proof.bootstrap"
    return tooling_backendDriverCurrentsrcProofPublishedStage0Label(absPath)

fn tooling_backendDriverCurrentsrcProofExpectedInput(labelRaw: str): str =
    let label: str = strutil.strip(labelRaw)
    if tooling_strEq(label, "currentsrc.proof.bootstrap"):
        return "src/backend/tooling/backend_driver_proof.cheng"
    if tooling_strEq(label, "stage1") || tooling_strEq(label, "stage2") ||
       tooling_strEq(label, "stage2.proof"):
        return "src/backend/tooling/backend_driver.cheng"
    return ""

fn tooling_backendDriverCurrentsrcProofPublishedStage0Path(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    let lineageDir: str =
        tooling_pathAbsolute(root, "artifacts/backend_selfhost_self_obj/probe_currentsrc_proof")
    return tooling_strEq(absPath, os.joinPath(lineageDir, "cheng.stage1")) ||
           tooling_strEq(absPath, os.joinPath(lineageDir, "cheng.stage2")) ||
           tooling_strEq(absPath, os.joinPath(lineageDir, "cheng.stage2.proof"))

fn tooling_backendDriverCurrentsrcProofRuntimeStage0Path(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    return tooling_backendDriverCurrentsrcProofPublishedStage0Path(root, absPath) ||
           tooling_backendDriverCurrentsrcProofBootstrapStage0Path(root, absPath)

fn tooling_backendDriverCurrentsrcProofDirectExportDriverPath(root: str, rawPath: str): str =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if strutil.endsWith(absPath, ".proof"):
        let metaRaw: str = tooling_readTextFile(root, absPath + ".meta")
        let outerDriverRaw: str = tooling_kvGet(metaRaw, "outer_driver")
        if tooling_strNonEmpty(outerDriverRaw):
            return tooling_pathAbsolute(root, outerDriverRaw)
    return absPath

fn tooling_backendDriverCurrentsrcProofDirectExportSurfaceOk(root: str, rawPath: str): bool =
    let exportDriver: str = tooling_backendDriverCurrentsrcProofDirectExportDriverPath(root, rawPath)
    if !tooling_strNonEmpty(exportDriver):
        return false
    if !tooling_isExecutable(root, exportDriver):
        return false
    if os.execCmdResultExitCode(tooling_exec(root, "command -v nm >/dev/null 2>&1")) != 0:
        return false
    if os.execCmdResultExitCode(tooling_exec(root, "command -v awk >/dev/null 2>&1")) != 0:
        return false
    let res: os.ExecCmdResult = tooling_exec(
        root,
        "(nm -gU " + tooling_shellQuote(exportDriver) + " 2>/dev/null || " +
            "nm " + tooling_shellQuote(exportDriver) + " 2>/dev/null) | awk '" +
            "BEGIN{ need1=0; need2=0; need3=0; legacy=0; }" +
            "{ sym=$NF; gsub(/^_+/, \"\", sym);" +
            "  if (sym == \"driver_export_build_emit_obj_from_file_stage1_target_impl\") need1=1;" +
            "  if (sym == \"driver_export_prefer_sidecar_builds\") need2=1;" +
            "  if (sym == \"driver_export_buildModuleFromFileStage1TargetRetained\") need3=1;" +
            "  if (sym ~ /^driverProof/) legacy=1;" +
            "}" +
            "END{ exit((need1 && need2 && need3 && !legacy) ? 0 : 1); }'"
    )
    return os.execCmdResultExitCode(res) == 0

fn tooling_backendDriverCurrentsrcProofPublishedStage0MetaOk(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if !tooling_backendDriverCurrentsrcProofPublishedStage0Path(root, absPath):
        return false
    let expectedLabel: str = tooling_backendDriverCurrentsrcProofPublishedStage0Label(absPath)
    if !tooling_strNonEmpty(expectedLabel):
        return false
    let metaRaw: str = tooling_readTextFile(root, absPath + ".meta")
    if !tooling_strNonEmpty(metaRaw):
        return false
    return tooling_strEq(tooling_kvGet(metaRaw, "meta_contract_version"), "2") &&
           tooling_strEq(tooling_kvGet(metaRaw, "label"), expectedLabel) &&
           tooling_strEq(tooling_kvGet(metaRaw, "outer_driver"), absPath) &&
           tooling_strEq(tooling_kvGet(metaRaw, "driver_input"),
                         tooling_backendDriverCurrentsrcProofExpectedInput(expectedLabel)) &&
           tooling_strEq(tooling_kvGet(metaRaw, "stage1_ownership_fixed_0_effective"), "0") &&
           tooling_strEq(tooling_kvGet(metaRaw, "stage1_ownership_fixed_0_default"), "0") &&
           tooling_strEq(tooling_kvGet(metaRaw, "generic_mode"), "dict") &&
           tooling_strEq(tooling_kvGet(metaRaw, "generic_lowering"), "mir_dict") &&
           tooling_backendDriverCurrentsrcProofDirectExportSurfaceOk(root, absPath)

fn tooling_backendDriverCurrentsrcProofBootstrapStage0MetaOk(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if !tooling_backendDriverCurrentsrcProofBootstrapStage0Path(root, absPath):
        return false
    let metaRaw: str = tooling_readTextFile(root, absPath + ".meta")
    if !tooling_strNonEmpty(metaRaw):
        return false
    let outerDriver: str = tooling_kvGet(metaRaw, "outer_driver")
    let sidecarBundle: str = tooling_kvGet(metaRaw, "sidecar_bundle")
    let sidecarCompiler: str = tooling_kvGet(metaRaw, "sidecar_compiler")
    let sidecarChildMode: str = tooling_kvGet(metaRaw, "sidecar_child_mode")
    return tooling_strEq(tooling_kvGet(metaRaw, "meta_contract_version"), "2") &&
           tooling_strEq(tooling_kvGet(metaRaw, "label"), "currentsrc.proof.bootstrap") &&
           tooling_strNonEmpty(outerDriver) &&
           tooling_isExecutable(root, outerDriver) &&
           tooling_strEq(tooling_kvGet(metaRaw, "driver_input"),
                         tooling_backendDriverCurrentsrcProofExpectedInput("currentsrc.proof.bootstrap")) &&
           tooling_strEq(tooling_kvGet(metaRaw, "sidecar_mode"), "cheng") &&
           tooling_backendDriverUirSidecarStablePathOk(root, sidecarBundle, false) &&
           tooling_backendDriverUirSidecarStablePathOk(root, sidecarCompiler, true) &&
           tooling_backendDriverUirSidecarChildModeValid(sidecarChildMode) &&
           tooling_strEq(tooling_kvGet(metaRaw, "stage1_ownership_fixed_0_effective"), "0") &&
           tooling_strEq(tooling_kvGet(metaRaw, "stage1_ownership_fixed_0_default"), "0") &&
           tooling_strEq(tooling_kvGet(metaRaw, "generic_mode"), "dict") &&
           tooling_strEq(tooling_kvGet(metaRaw, "generic_lowering"), "mir_dict") &&
           tooling_backendDriverCurrentsrcProofDirectExportSurfaceOk(root, absPath)

fn tooling_backendDriverCurrentsrcProofStrictStage0MetaOk(root: str, rawPath: str): bool =
    return tooling_backendDriverCurrentsrcProofPublishedStage0MetaOk(root, rawPath) ||
           tooling_backendDriverCurrentsrcProofBootstrapStage0MetaOk(root, rawPath)

fn tooling_backendDriverCurrentsrcProofPublishedStage0SourceList(): str[] =
    var out: str[] = tooling_stage0CapabilitySourceList()
    add(out, "src/backend/tooling/backend_driver.cheng")
    add(out, "src/backend/tooling/backend_driver_proof.cheng")
    add(out, "src/backend/tooling/backend_driver_uir_shared.cheng")
    add(out, "src/backend/tooling/backend_driver_uir_module_shared.cheng")
    add(out, "src/std/system_helpers_backend.cheng")
    let runtimeBridges: str[] = tooling_runtimeMinimalNativeBridgeRelativeList()
    for i in 0..<runtimeBridges.len:
        add(out, runtimeBridges[i])
    return out

fn tooling_backendDriverCurrentsrcProofBootstrapStage0SourceList(): str[] =
    var out: str[] = tooling_backendDriverCurrentsrcProofPublishedStage0SourceList()
    add(out, "src/backend/tooling/backend_driver_uir_sidecar_wrapper.cheng")
    add(out, "src/backend/tooling/backend_driver_uir_sidecar_bundle.c")
    add(out, "src/backend/tooling/backend_driver_sidecar_outer_main.c")
    add(out, "src/backend/tooling/backend_driver_sidecar_outer_exports.c")
    add(out, "src/tooling/cheng_tooling_embedded_scripts/backend_driver_currentsrc_sidecar_wrapper.sh")
    return out

fn tooling_backendDriverCurrentsrcProofPublishedStage0FreshOk(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if !tooling_backendDriverCurrentsrcProofPublishedStage0Path(root, absPath):
        return false
    return !tooling_anyFileNewerThan(
        root, tooling_backendDriverCurrentsrcProofPublishedStage0SourceList(), absPath)

fn tooling_backendDriverCurrentsrcProofBootstrapStage0FreshOk(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if !tooling_backendDriverCurrentsrcProofBootstrapStage0Path(root, absPath):
        return false
    return !tooling_anyFileNewerThan(
        root, tooling_backendDriverCurrentsrcProofBootstrapStage0SourceList(), absPath)

fn tooling_backendDriverCurrentsrcProofRuntimeSurfaceOk(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    if tooling_backendDriverCurrentsrcProofBootstrapStage0Path(root, absPath):
        return tooling_backendDriverUirSidecarStrictRealDriverPathOk(root, absPath) &&
               tooling_backendDriverCurrentsrcProofBootstrapStage0MetaOk(root, absPath)
    if tooling_backendDriverCurrentsrcProofPublishedStage0Path(root, absPath):
        return tooling_backendDriverUirSidecarStrictRealDriverPathOk(root, absPath) &&
               tooling_backendDriverCurrentsrcProofPublishedStage0MetaOk(root, absPath) &&
               tooling_backendDriverCurrentsrcProofPublishedStage0FreshOk(root, absPath)
    return false

fn tooling_backendDriverSidecarBootstrapDriverPathOk(root: str, rawPath: str): bool =
    let absPath: str = tooling_pathAbsolute(root, rawPath)
    return tooling_backendDriverCurrentsrcProofRuntimeSurfaceOk(root, absPath)

fn tooling_backendDriverSidecarBootstrapProbeObjPath(root: str, driverPath: str, target: str): str =
    let safeBase: str = tooling_nonEmptyDefault(
        tooling_sanitizeShellSafeToken(root, os.extractFilename(driverPath)), "stage0")
    return os.joinPath(
        root,
        "chengcache/backend_driver_sidecar/bootstrap_probe." + safeBase + "." + target + ".o")

fn tooling_backendDriverSidecarBootstrapCompileProbeOk(root: str, compilerPath: str,
                                                       driverPath: str, target: str): bool =
    if !tooling_isExecutable(root, compilerPath):
        return false
    if !tooling_backendDriverSidecarBootstrapDriverPathOk(root, driverPath):
        return false
    let wrapperSource: str = tooling_backendDriverUirSidecarWrapperSourcePath(root)
    if !tooling_fileExistsNonEmpty(wrapperSource):
        return false
    let probeOut: str = tooling_backendDriverSidecarBootstrapProbeObjPath(root, driverPath, target)
    if os.fileExists(probeOut):
        os.removeFile(probeOut)
    var argv: str[] = []
    add(argv, wrapperSource)
    add(argv, "--frontend:stage1")
    add(argv, "--emit:obj")
    add(argv, "--target:" + target)
    add(argv, "--linker:system")
    add(argv, "--allow-no-main")
    add(argv, "--whole-program")
    add(argv, "--no-multi")
    add(argv, "--no-multi-force")
    add(argv, "--no-incremental")
    add(argv, "--jobs:8")
    add(argv, "--fn-jobs:8")
    add(argv, "--opt-level:0")
    add(argv, "--no-opt")
    add(argv, "--no-opt2")
    add(argv, "--generic-mode:dict")
    add(argv, "--generic-spec-budget:0")
    add(argv, "--generic-lowering:mir_dict")
    add(argv, "--output:" + probeOut)
    var envOverrides: str[] = []
    add(envOverrides, "TOOLING_ROOT=" + root)
    add(envOverrides, "TOOLING_BUILD_GLOBAL_CURRENTSOURCE_REAL_DRIVER=" + tooling_pathAbsolute(root, driverPath))
    add(envOverrides, "MM=orc")
    add(envOverrides, "CACHE=0")
    add(envOverrides, "BACKEND_BUILD_TRACK=dev")
    let res: os.ExecCmdResult = tooling_execFileDirect(compilerPath, argv, envOverrides, root, 60, true)
    let ok: bool = (os.execCmdResultExitCode(res) == 0) && tooling_fileExistsNonEmpty(probeOut)
    if os.fileExists(probeOut):
        os.removeFile(probeOut)
    return ok

fn tooling_backendDriverSidecarBootstrapDriverPath(root: str, compilerPath: str, target: str): str =
    let envPath: str = tooling_pathAbsolute(
        root, strutil.strip(os.getEnvDefault("BACKEND_UIR_SIDECAR_BOOTSTRAP_DRIVER", "")))
    if tooling_strNonEmpty(envPath):
        if tooling_backendDriverSidecarBootstrapDriverPathOk(root, envPath) &&
           tooling_backendDriverSidecarBootstrapCompileProbeOk(root, compilerPath, envPath, target):
            return envPath
        return ""
    let bootstrapProofPath: str = tooling_backendDriverCurrentsrcProofRealDriverPath(root)
    if tooling_backendDriverSidecarBootstrapDriverPathOk(root, bootstrapProofPath) &&
       tooling_backendDriverSidecarBootstrapCompileProbeOk(root, compilerPath, bootstrapProofPath, target):
        return bootstrapProofPath
    let publishedProofPath: str = tooling_backendDriverCurrentsrcProofPublishedStage2Path(root)
    if tooling_backendDriverSidecarBootstrapDriverPathOk(root, publishedProofPath) &&
       tooling_backendDriverSidecarBootstrapCompileProbeOk(root, compilerPath, publishedProofPath, target):
        return publishedProofPath
    return ""

fn tooling_prepareBackendDriverCurrentsrcSidecarCompiler(root: str, target: str): str =
    let templatePath: str = tooling_backendDriverCurrentsrcSidecarCompilerTemplatePath(root)
    let outPath: str = tooling_backendDriverCurrentsrcSidecarCompilerPath(root, target)
    if !tooling_fileExistsNonEmpty(templatePath):
        return ""
    if !tooling_copyExecutablePreserveBytes(root, templatePath, outPath):
        return ""
    if !tooling_isExecutable(root, outPath):
        return ""
    return outPath

fn tooling_backendDriverSidecarCompilerMetaWrite(root: str, compilerPath: str,
                                                 childMode: str, outerCompanion: str,
                                                 realDriverRaw: str): bool =
    if !tooling_strNonEmpty(compilerPath):
        return false
    if !tooling_backendDriverUirSidecarChildModeValid(childMode):
        return false
    let metaPath: str = compilerPath + ".meta"
    let existingRaw: str = tooling_backendDriverUirSidecarCompilerMetaRaw(root, compilerPath)
    let existingLabel: str = tooling_kvGet(existingRaw, "label")
    let existingRealDriver: str = tooling_kvGet(existingRaw, "sidecar_real_driver")
    var realDriver: str = tooling_pathAbsolute(root, strutil.strip(realDriverRaw))
    if !tooling_strNonEmpty(realDriver):
        realDriver = existingRealDriver
    if tooling_strNonEmpty(realDriver) && !tooling_isExecutable(root, realDriver):
        return false
    var text: str =
        "sidecar_contract_version=1\n" +
        "sidecar_child_mode=" + childMode + "\n" +
        "sidecar_outer_companion=" + outerCompanion + "\n"
    if tooling_strNonEmpty(existingLabel):
        text = text + "label=" + existingLabel + "\n"
    if tooling_strNonEmpty(realDriver):
        text = text + "sidecar_real_driver=" + realDriver + "\n"
    return tooling_writeTextFileViaShell(
        root, metaPath, text)

fn tooling_backendDriverUirSidecarCompilerPath(root: str, stage0Exec: str): str =
    let _stage0Exec: str = stage0Exec
    let envPath: str = os.getEnvDefault("BACKEND_UIR_SIDECAR_COMPILER", "")
    if tooling_strNonEmpty(envPath) && tooling_isExecutable(root, envPath):
        return envPath
    if tooling_backendDriverUirSidecarSnapshotOk(root):
        let snapshotRaw: str = tooling_backendDriverUirSidecarSnapshotRaw(root)
        let snapshotCompiler: str = tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_compiler")
        if tooling_isExecutable(root, snapshotCompiler):
            return snapshotCompiler
    let liveCompiler: str = tooling_backendDriverUirSidecarLiveCompilerPath(root, "")
    if tooling_isExecutable(root, liveCompiler):
        return liveCompiler
    return ""

fn tooling_backendDriverUirSidecarCompilerMetaRaw(root: str, compilerPath: str): str =
    if !tooling_strNonEmpty(compilerPath):
        return ""
    let metaPath: str = compilerPath + ".meta"
    if !tooling_fileExistsNonEmpty(metaPath):
        return ""
    return tooling_readTextFile(root, metaPath)

fn tooling_backendDriverSidecarCompilerRealDriver(root: str, compilerPath: str): str =
    let envPath: str = tooling_backendDriverUirSidecarLiveExplicitRealDriver(root)
    if tooling_strNonEmpty(envPath):
        return envPath
    if tooling_backendDriverUirSidecarSnapshotOk(root):
        let snapshotRaw: str = tooling_backendDriverUirSidecarSnapshotRaw(root)
        let snapshotCompiler: str = tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_compiler")
        if tooling_strEq(tooling_pathAbsolute(root, compilerPath),
                         tooling_pathAbsolute(root, snapshotCompiler)):
            let snapshotRealDriver: str = tooling_kvGet(
                snapshotRaw, "backend_sidecar_cheng_fresh_real_driver")
            if tooling_backendDriverCurrentsrcProofPublishedStage0Path(root, snapshotRealDriver) &&
               tooling_backendDriverUirSidecarStrictRealDriverPathOk(root, snapshotRealDriver):
                return snapshotRealDriver
    let metaRaw: str = tooling_backendDriverUirSidecarCompilerMetaRaw(root, compilerPath)
    let realDriver: str = tooling_kvGet(metaRaw, "sidecar_real_driver")
    if tooling_backendDriverCurrentsrcProofPublishedStage0Path(root, realDriver) &&
       tooling_backendDriverUirSidecarStrictRealDriverPathOk(root, realDriver):
        return realDriver
    return ""

fn tooling_backendDriverSidecarCompilerChildMode(root: str, compilerPath: str): str =
    let envMode: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("BACKEND_UIR_SIDECAR_CHILD_MODE", "")))
    if tooling_backendDriverUirSidecarChildModeValid(envMode):
        return envMode
    if tooling_backendDriverUirSidecarSnapshotOk(root):
        let snapshotRaw: str = tooling_backendDriverUirSidecarSnapshotRaw(root)
        let snapshotCompiler: str = tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_compiler")
        if tooling_strEq(tooling_pathAbsolute(root, compilerPath),
                         tooling_pathAbsolute(root, snapshotCompiler)):
            let snapshotMode: str = strutil.toLowerAscii(strutil.strip(
                tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_child_mode")))
            if tooling_backendDriverUirSidecarChildModeValid(snapshotMode):
                return snapshotMode
    let metaRaw: str = tooling_backendDriverUirSidecarCompilerMetaRaw(root, compilerPath)
    let metaMode: str = strutil.toLowerAscii(strutil.strip(
        tooling_kvGet(metaRaw, "sidecar_child_mode")))
    if tooling_backendDriverUirSidecarChildModeValid(metaMode):
        return metaMode
    return ""

fn tooling_backendDriverUirSidecarBundleResolved(root: str, targetHint: str): str =
    let envPath: str = os.getEnvDefault("BACKEND_UIR_SIDECAR_BUNDLE", "")
    if tooling_fileExistsNonEmpty(envPath):
        return envPath
    if tooling_backendDriverUirSidecarSnapshotOk(root):
        let snapshotRaw: str = tooling_backendDriverUirSidecarSnapshotRaw(root)
        let snapshotBundle: str = tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_bundle")
        if tooling_fileExistsNonEmpty(snapshotBundle):
            return snapshotBundle
    let liveBundle: str = tooling_backendDriverUirSidecarLiveBundlePath(root, targetHint)
    if tooling_fileExistsNonEmpty(liveBundle):
        return liveBundle
    return ""

fn tooling_backendDriverSidecarCompilerRequiresOuterCliMode(root: str, compilerPath: str): bool =
    return tooling_strEq(
        tooling_backendDriverSidecarCompilerChildMode(root, compilerPath), "outer_cli")

fn tooling_backendDriverSidecarCompilerOuterCompanion(root: str, compilerPath: str): str =
    let envPath: str = os.getEnvDefault("BACKEND_UIR_SIDECAR_OUTER_COMPILER", "")
    if tooling_strNonEmpty(envPath) && tooling_isExecutable(root, envPath):
        return envPath
    let childMode: str = tooling_backendDriverSidecarCompilerChildMode(root, compilerPath)
    if !tooling_strNonEmpty(childMode):
        return ""
    if !tooling_strEq(childMode, "outer_cli"):
        return compilerPath
    if tooling_backendDriverUirSidecarSnapshotOk(root):
        let snapshotRaw: str = tooling_backendDriverUirSidecarSnapshotRaw(root)
        let snapshotCompiler: str = tooling_kvGet(snapshotRaw, "backend_sidecar_cheng_fresh_compiler")
        if tooling_strEq(tooling_pathAbsolute(root, compilerPath),
                         tooling_pathAbsolute(root, snapshotCompiler)):
            let snapshotOuter: str = tooling_kvGet(snapshotRaw,
                                                   "backend_sidecar_cheng_fresh_outer_companion")
            if tooling_isExecutable(root, snapshotOuter):
                return snapshotOuter
    let metaRaw: str = tooling_backendDriverUirSidecarCompilerMetaRaw(root, compilerPath)
    let outerPath: str = tooling_kvGet(metaRaw, "sidecar_outer_companion")
    if tooling_isExecutable(root, outerPath):
        return outerPath
    return ""

fn tooling_compileApplyStrictSidecarContract(root: str, tag: str,
                                             compilerPathHint: str,
                                             explicitBundlePath: str,
                                             explicitCompilerPath: str,
                                             opts: ToolingCompileOptions): bool =
    var bundlePath: str = explicitBundlePath
    if !tooling_strNonEmpty(bundlePath):
        bundlePath = tooling_backendDriverUirSidecarBundleResolved(root, opts.targetText)
    if !tooling_fileExistsNonEmpty(bundlePath):
        tooling_printErr("cheng_tooling: " + tag +
                         " missing strict fresh sidecar bundle: " + bundlePath)
        return false
    var compilerPath: str = explicitCompilerPath
    if !tooling_strNonEmpty(compilerPath):
        compilerPath = tooling_backendDriverUirSidecarCompilerPath(root, compilerPathHint)
    if !tooling_isExecutable(root, compilerPath):
        tooling_printErr("cheng_tooling: " + tag +
                         " missing strict fresh sidecar compiler: " + compilerPath)
        return false
    let childMode: str = tooling_backendDriverSidecarCompilerChildMode(root, compilerPath)
    if !tooling_backendDriverUirSidecarChildModeValid(childMode):
        tooling_printErr("cheng_tooling: " + tag +
                         " missing strict fresh sidecar child-mode contract: " + compilerPath)
        return false
    let realDriver: str = tooling_backendDriverSidecarCompilerRealDriver(root, compilerPath)
    if !tooling_isExecutable(root, realDriver):
        tooling_printErr("cheng_tooling: " + tag +
                         " missing strict fresh sidecar real-driver contract: " + compilerPath)
        return false
    let outerCompanion: str = tooling_backendDriverSidecarCompilerOuterCompanion(root, compilerPath)
    if tooling_strEq(childMode, "outer_cli") && !tooling_isExecutable(root, outerCompanion):
        tooling_printErr("cheng_tooling: " + tag +
                         " missing strict fresh sidecar outer companion: " + outerCompanion)
        return false
    opts.sidecarModeText = "cheng"
    opts.sidecarDisableText = "0"
    opts.sidecarPreferText = "1"
    opts.sidecarForceText = "1"
    opts.sidecarBundlePath = bundlePath
    opts.sidecarCompilerPath = compilerPath
    opts.sidecarChildModeText = childMode
    if tooling_strEq(childMode, "outer_cli"):
        opts.sidecarOuterCompilerPath = outerCompanion
    else:
        opts.sidecarOuterCompilerPath = ""
    return true

fn tooling_backendDriverUirSidecarCompileArgs(root: str, compilerPath: str, sourcePath: str,
                                              outPath: str, target: str): str[] =
    let _root: str = root
    let _compilerPath: str = compilerPath
    var argv: str[] = []
    add(argv, sourcePath)
    add(argv, "--frontend:stage1")
    add(argv, "--emit:obj")
    add(argv, "--output:" + outPath)
    add(argv, "--target:" + target)
    add(argv, "--allow-no-main")
    add(argv, "--no-whole-program")
    add(argv, "--linker:system")
    return argv

fn tooling_resolveBackendSidecarCompiler(root: str): str =
    var compilerPath: str = strutil.strip(os.getEnvDefault("BACKEND_UIR_SIDECAR_COMPILER", ""))
    if !tooling_isExecutable(root, compilerPath):
        compilerPath = tooling_backendDriverUirSidecarCompilerPath(root, "")
    return compilerPath

fn tooling_seqContainsStr(xs: str[], needle: str): bool =
    var i: int32 = 0
    let __for_guard_start_i_1 = i
    for __for_guard_i_1 in __for_guard_start_i_1..<xs.len:
        if ! (i < xs.len):
            break
        if xs[i] == needle:
            return true
        i = i + 1
    return false

fn tooling_backendDriverUirSidecarDependencyPaths(root: str): str[] =
    var out: str[] = []
    add(out, tooling_backendDriverUirSidecarCSourcePath(root))
    add(out, tooling_backendDriverUirSidecarWrapperSourcePath(root))
    let stage0Deps: str[] = tooling_stage0CapabilitySourceList()
    for i in 0..<stage0Deps.len:
        let dep: str = os.joinPath(root, stage0Deps[i])
        if !tooling_seqContainsStr(out, dep):
            add(out, dep)
    return out

fn tooling_backendDriverUirSidecarNeedsRebuild(root: str, outPath: str): bool =
    if !tooling_fileExistsNonEmpty(outPath):
        return true
    let deps: str[] = tooling_backendDriverUirSidecarDependencyPaths(root)
    for i in 0..<deps.len:
        let dep: str = deps[i]
        if !os.fileExists(dep):
            continue
        if tooling_fileIsNewer(root, dep, outPath):
            return true
    return false

fn tooling_backendDriverSidecarOuterDriverNeedsRebuild(root: str, outPath: str): bool =
    if !tooling_fileExistsNonEmpty(outPath):
        return true
    var deps: str[] = []
    add(deps, tooling_backendDriverSidecarOuterDriverSourcePath(root))
    add(deps, tooling_backendDriverSidecarOuterExportsSourcePath(root))
    add(deps, tooling_backendDriverUirSidecarCSourcePath(root))
    add(deps, tooling_runtimeRefreshShimSrc(root))
    for i in 0..<deps.len:
        let dep: str = deps[i]
        if !os.fileExists(dep):
            continue
        if tooling_fileIsNewer(root, dep, outPath):
            return true
    return false

fn tooling_prepareBackendDriverSidecarOuterDriver(root: str, target: str): str =
    let sourcePath: str = tooling_backendDriverSidecarOuterDriverSourcePath(root)
    let exportSourcePath: str = tooling_backendDriverSidecarOuterExportsSourcePath(root)
    let runtimePath: str = tooling_runtimeRefreshShimSrc(root)
    let outPath: str = tooling_backendDriverSidecarOuterDriverPath(root, target)
    if !os.fileExists(sourcePath) || !os.fileExists(exportSourcePath) || !os.fileExists(runtimePath):
        return ""
    if tooling_fileExistsNonEmpty(outPath) &&
       !tooling_backendDriverSidecarOuterDriverNeedsRebuild(root, outPath):
        return outPath
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        tooling_tryMkdirP(root, outDir)
    if os.fileExists(outPath):
        os.removeFile(outPath)
    let helperObjPath: str = tooling_prepareBackendDriverUirSidecarHelperObj(root, target)
    if !tooling_fileExistsNonEmpty(helperObjPath):
        tooling_printErr("cheng_tooling: backend_driver sidecar outer missing helper obj")
        return ""
    var ccArgs: str[] = []
    add(ccArgs, "-std=c11")
    add(ccArgs, "-Wno-deprecated-declarations")
    add(ccArgs, "-O0")
    add(ccArgs, "-Wl,-export_dynamic")
    add(ccArgs, sourcePath)
    add(ccArgs, exportSourcePath)
    add(ccArgs, runtimePath)
    add(ccArgs, helperObjPath)
    add(ccArgs, "-o")
    add(ccArgs, outPath)
    var ccEnv: str[] = []
    let res: os.ExecCmdResult = tooling_execProgramDirect(root, "cc", ccArgs, ccEnv, root, 60, true)
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("cheng_tooling: backend_driver sidecar outer build failed rc=" +
                         intToStr(os.execCmdResultExitCode(res)))
        return ""
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_printErr("cheng_tooling: backend_driver sidecar outer missing output: " + outPath)
        return ""
    return outPath

fn tooling_prepareBackendDriverUirSidecarHelperObj(root: str, target: str): str =
    let sourcePath: str = tooling_backendDriverUirSidecarCSourcePath(root)
    let outPath: str = tooling_backendDriverUirSidecarHelperObjPath(root, target)
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        tooling_tryMkdirP(root, outDir)
    if os.fileExists(outPath):
        os.removeFile(outPath)
    var ccArgs: str[] = []
    add(ccArgs, "-fPIC")
    add(ccArgs, "-c")
    add(ccArgs, sourcePath)
    add(ccArgs, "-o")
    add(ccArgs, outPath)
    var ccEnv: str[] = []
    let res: os.ExecCmdResult = tooling_execProgramDirect(root, "cc", ccArgs, ccEnv, root, 60, true)
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("cheng_tooling: backend_driver cheng sidecar helper compile failed rc=" +
                         intToStr(os.execCmdResultExitCode(res)))
        return ""
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_printErr("cheng_tooling: backend_driver cheng sidecar helper missing output: " + outPath)
        return ""
    return outPath

fn tooling_prepareBackendDriverUirSidecarBundle(root: str, target: str, objPath: str, sidecarMode: str): str =
    if !tooling_fileExistsNonEmpty(objPath):
        return ""
    if !tooling_strEq(sidecarMode, "cheng"):
        tooling_printErr("cheng_tooling: backend_driver sidecar requires --sidecar-mode:cheng")
        return ""
    let outPath: str = tooling_backendDriverUirSidecarBundlePath(root, target)
    if tooling_fileExistsNonEmpty(outPath) && !tooling_backendDriverUirSidecarNeedsRebuild(root, outPath) && !tooling_fileIsNewer(root, objPath, outPath):
        return outPath
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        tooling_tryMkdirP(root, outDir)
    if os.fileExists(outPath):
        os.removeFile(outPath)
    var ccArgs: str[] = []
    let helperObjPath: str = tooling_prepareBackendDriverUirSidecarHelperObj(root, target)
    if !tooling_fileExistsNonEmpty(helperObjPath):
        return ""
    add(ccArgs, "-bundle")
    add(ccArgs, "-undefined")
    add(ccArgs, "dynamic_lookup")
    add(ccArgs, objPath)
    add(ccArgs, helperObjPath)
    add(ccArgs, "-o")
    add(ccArgs, outPath)
    var ccEnv: str[] = []
    let res: os.ExecCmdResult = tooling_execProgramDirect(root, "cc", ccArgs, ccEnv, root, 60, true)
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("cheng_tooling: backend_driver sidecar bundle link failed rc=" +
                         intToStr(os.execCmdResultExitCode(res)))
        return ""
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_printErr("cheng_tooling: backend_driver sidecar bundle missing output: " + outPath)
        return ""
    return outPath

fn tooling_backendDriverUirSidecarCompileEnv(root: str, compilerPath: str, compileExecPath: str,
                                             sourcePath: str, outPath: str, target: str): str[] =
    let _compilerPath: str = compilerPath
    var envOverrides: str[] = []
    let compileJobsText: str = tooling_compileParallelJobsText(root, "8")
    let compileFnJobsText: str = tooling_compileParallelFnJobsText(root, compileJobsText)
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "dev", "outline", "system", target, sourcePath, outPath,
        "obj", "1", "0", "0", "0", "1", "0", compileJobsText, compileFnJobsText)
    tooling_envAssignCollect(envOverrides, "DYLD_INSERT_LIBRARIES", "")
    tooling_envAssignCollect(envOverrides, "DYLD_FORCE_FLAT_NAMESPACE", "")
    compileOpts.skipGlobalInitText = "1"
    compileOpts.optLevelText = "0"
    compileOpts.optText = "0"
    compileOpts.opt2Text = "0"
    compileOpts.uirSimdText = "0"
    compileOpts.disableDupScanText = "0"
    compileOpts.skipFixupsText = "0"
    compileOpts.skipNormalizeText = "0"
    compileOpts.noRuntimeCText = "0"
    compileOpts.internalAllowEmitObjText = "1"
    # Bootstrapping the Cheng sidecar bundle must not consume a preexisting sidecar.
    # The fresh gate later validates strict Cheng sidecar consumption separately.
    compileOpts.sidecarDisableText = "1"
    compileOpts.sidecarPreferText = "0"
    compileOpts.sidecarForceText = "0"
    tooling_compileCollectEnvOverrides(root, compileExecPath, compileOpts, envOverrides)
    tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_MODE", "")
    tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_OBJ", "")
    tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_BUNDLE", "")
    tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_COMPILER", "")
    tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_CHILD_MODE", "")
    tooling_envAssignCollect(envOverrides, "BACKEND_UIR_SIDECAR_OUTER_COMPILER", "")
    return envOverrides

fn tooling_prepareBackendDriverUirSidecarObj(root: str, compilerPath: str, target: str): str =
    let sourcePath: str = tooling_backendDriverUirSidecarSourcePath(root)
    let outPath: str = tooling_backendDriverUirSidecarObjPath(root, target)
    if !os.fileExists(sourcePath):
        return ""
    if tooling_fileExistsNonEmpty(outPath) && !tooling_backendDriverUirSidecarNeedsRebuild(root, outPath):
        return outPath
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        tooling_tryMkdirP(root, outDir)
    if os.fileExists(outPath):
        os.removeFile(outPath)
    let compileExecPath: str = tooling_prepareBackendDriverSidecarOuterDriver(root, target)
    if !tooling_isExecutable(root, compileExecPath):
        tooling_printErr("cheng_tooling: backend_driver sidecar missing outer bootstrap driver")
        return ""
    let envOverrides: str[] = tooling_backendDriverUirSidecarCompileEnv(
        root, compilerPath, compileExecPath, sourcePath, outPath, target)
    let compilerArgs: str[] = tooling_backendDriverUirSidecarCompileArgs(
        root, compilerPath, sourcePath, outPath, target)
    let res: os.ExecCmdResult = tooling_execFileDirect(compileExecPath, compilerArgs, envOverrides, root, 60, true)
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("cheng_tooling: backend_driver sidecar compile failed rc=" +
                         intToStr(os.execCmdResultExitCode(res)))
        return ""
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_printErr("cheng_tooling: backend_driver sidecar missing output: " + outPath)
        return ""
    return outPath

fn tooling_prepareBackendDriverUirSidecarChengObj(root: str, compilerPath: str, target: str): str =
    let sourcePath: str = tooling_backendDriverUirSidecarWrapperSourcePath(root)
    let outPath: str = tooling_backendDriverUirSidecarObjPath(root, target)
    if !os.fileExists(sourcePath):
        return ""
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        tooling_tryMkdirP(root, outDir)
    if os.fileExists(outPath):
        os.removeFile(outPath)
    let compileExecPath: str = tooling_prepareBackendDriverSidecarOuterDriver(root, target)
    if !tooling_isExecutable(root, compileExecPath):
        tooling_printErr("cheng_tooling: backend_driver cheng sidecar missing outer bootstrap driver")
        return ""
    let envOverrides: str[] = tooling_backendDriverUirSidecarCompileEnv(
        root, compilerPath, compileExecPath, sourcePath, outPath, target)
    let compilerArgs: str[] = tooling_backendDriverUirSidecarCompileArgs(
        root, compilerPath, sourcePath, outPath, target)
    let res: os.ExecCmdResult = tooling_execFileDirect(compileExecPath, compilerArgs, envOverrides, root, 60, true)
    tooling_printExecOutput(res)
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("cheng_tooling: backend_driver cheng sidecar compile failed rc=" +
                         intToStr(os.execCmdResultExitCode(res)))
        return ""
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_printErr("cheng_tooling: backend_driver cheng sidecar missing output: " + outPath)
        return ""
    return outPath

fn tooling_tryLegacyDriverObjRelink(root: str, outPath: str, targetRaw: str): int32 =
    let _root: str = root
    let _outPath: str = outPath
    let _targetRaw: str = targetRaw
    return tooling_routeMiss()

fn tooling_outputHasUndefinedSymbols(output: str): bool =
    if !tooling_strNonEmpty(output):
        return false
    let lower: str = strutil.toLowerAscii(output)
    if tooling_strContains(lower, "undefined symbols for architecture") ||
       tooling_strContains(lower, "undefined reference to") ||
       tooling_strContains(lower, "undefined symbol:"):
        return true
    return false

fn tooling_compileBackendDriverFastHostWithCompileProfile(root: str, stage0: str, target: str, outPath: str,
                                                          fullRebuild: bool, rebuildSkipSemRaw: str,
                                                          rebuildSkipOwnershipRaw: str,
                                                          allowBootstrapCapabilityRefresh: bool,
                                                          compileProfileInput: ToolingBuildDriverCompileProfile): int32 =
    tooling_buildDriverLastStampHit = false
    let strictNative: bool = tooling_buildDriverEffectiveStrictNativeForRebuild(fullRebuild)
    let buildLinkerMode: str = tooling_buildDriverEffectiveLinkerMode(strictNative)
    let allowFallback: bool = tooling_buildDriverAllowFallbackEnabled()
    var compileProfile: ToolingBuildDriverCompileProfile = compileProfileInput
    if compileProfile == nil:
        compileProfile = tooling_buildDriverCompileProfileResolved(
            root, nil, fullRebuild, "build-backend-driver")
        if compileProfile == nil:
            return 2
    let linkerModeRaw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_LINKER", "")))
    if tooling_strNonEmpty(linkerModeRaw) &&
       !tooling_strEq(linkerModeRaw, "system"):
        tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_LINKER=system")
        return 2
    let strictLinkerRaw: str = strutil.toLowerAscii(
        strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_LINKER_STRICT", "")))
    if strictNative && tooling_strNonEmpty(strictLinkerRaw) &&
       !tooling_strEq(strictLinkerRaw, "system"):
        tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_LINKER_STRICT=system")
        return 2
    var linkerMode: str = tooling_textLiteral("system")
    if tooling_strNonEmpty(linkerModeRaw):
        linkerMode = linkerModeRaw
    if tooling_strNonEmpty(strictLinkerRaw):
        linkerMode = strictLinkerRaw
    let stage0Purpose: str = tooling_buildDriverStage0Purpose(fullRebuild)
    var stage0Exec: str = tooling_textLiteral("")
    var runtimeObj: str = tooling_textLiteral("")
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir):
        if !tooling_mkdirP(root, outDir):
            tooling_printErr("cheng_tooling: failed to create output dir: " + outDir)
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            return 1
    var jobs: int32 = compileProfile.jobs
    let rebuildSkipSemOverride: str = tooling_bool01Normalized(rebuildSkipSemRaw)
    let rebuildSkipOwnershipOverride: str = tooling_bool01Normalized(rebuildSkipOwnershipRaw)
    if tooling_strEq(rebuildSkipSemOverride, "1") || tooling_strEq(rebuildSkipOwnershipOverride, "1"):
        tooling_printErr("cheng_tooling: stage0/driver bootstrap skip_sem/skip_ownership has been removed (expected 0/0)")
        return 2
    var timeoutEnv: str = tooling_textLiteral("BACKEND_BUILD_DRIVER_TIMEOUT")
    var timeoutDefault: int32 = 60
    var timeoutHintRaw: str = os.getEnvDefault(timeoutEnv, "")
    var timeoutHintSec: int32 = tooling_clampCompileTimeoutSec(
        tooling_parseInt32Default(timeoutHintRaw, timeoutDefault))
    var fullRebuildTightTimeoutProfile: bool = false
    let fnSchedOverrideRaw0: str = strutil.toLowerAscii(strutil.strip(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_FN_SCHED", "")))
    if tooling_strNonEmpty(fnSchedOverrideRaw0) && !tooling_strEq(fnSchedOverrideRaw0, "ws"):
        tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_FN_SCHED=ws")
        return 2
    if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_DIRECT_EXE", ""))):
        tooling_printErr("cheng_tooling: build-backend-driver removed env BACKEND_BUILD_DRIVER_DIRECT_EXE (fixed=1)")
        return 2
    var parseMode: str = compileProfile.parseMode
    var fnSchedText: str = compileProfile.fnSchedText
    var directExeText: str = compileProfile.directExeText
    var incrementalText: str = compileProfile.incrementalText
    var multiText: str = compileProfile.multiText
    var multiForceText: str = compileProfile.multiForceText
    var stage1BuilderText: str = compileProfile.stage1BuilderText
    var skipGlobalInitText: str = compileProfile.skipGlobalInitText
    var disableDupScanText: str = compileProfile.disableDupScanText
    var skipFixupsText: str = compileProfile.skipFixupsText
    var skipNormalizeText: str = compileProfile.skipNormalizeText
    var genericModeText: str = compileProfile.genericModeText
    var genericSpecBudgetText: str = compileProfile.genericSpecBudgetText
    var genericLoweringText: str = compileProfile.genericLoweringText
    if fullRebuild:
        timeoutEnv = tooling_textLiteral("BACKEND_BUILD_DRIVER_REBUILD_TIMEOUT")
        timeoutDefault = 60
        timeoutHintRaw = os.getEnvDefault(timeoutEnv, "")
        timeoutHintSec = tooling_clampCompileTimeoutSec(
            tooling_parseInt32Default(timeoutHintRaw, timeoutDefault))
        fullRebuildTightTimeoutProfile = timeoutHintSec <= 60 &&
            tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_TIGHT_TIMEOUT_PROFILE", "0"))
        let rebuildFnSchedOverrideRaw: str = strutil.toLowerAscii(strutil.strip(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_FN_SCHED", "")))
        if tooling_strNonEmpty(rebuildFnSchedOverrideRaw) && !tooling_strEq(rebuildFnSchedOverrideRaw, "ws"):
            tooling_printErr("cheng_tooling: build-backend-driver only allows BACKEND_BUILD_DRIVER_REBUILD_FN_SCHED=ws")
            return 2
        if tooling_strNonEmpty(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_DIRECT_EXE", ""))):
            tooling_printErr("cheng_tooling: build-backend-driver removed env BACKEND_BUILD_DRIVER_REBUILD_DIRECT_EXE (fixed=1)")
            return 2
        fnSchedText = tooling_textLiteral("ws")
        directExeText = tooling_textLiteral("0")
        # Full rebuild is hard-pinned to stage1 builder.
        stage1BuilderText = tooling_textLiteral("stage1")
    fnSchedText = tooling_textLiteral("ws")
    let directExePolicyVar: str = tooling_buildDriverDirectExePolicyVar(fullRebuild)
    directExeText = tooling_bool01Normalized(directExeText)
    if tooling_strEq(linkerMode, "self"):
        if !tooling_strEq(directExeText, "1"):
            tooling_printErr("cheng_tooling: build-backend-driver requires " + directExePolicyVar + "=1 when BACKEND_BUILD_DRIVER_LINKER=self")
            return 2
    else:
        if !tooling_strEq(directExeText, "0"):
            directExeText = tooling_textLiteral("0")
    if !tooling_strNonEmpty(incrementalText):
        incrementalText = tooling_textLiteral(fullRebuild ? "0" : "1")
    if !tooling_strNonEmpty(multiText):
        multiText = tooling_buildDriverDefaultMulti(root)
    if !tooling_strNonEmpty(multiForceText):
        multiForceText = tooling_buildDriverDefaultMulti(root)
    if !tooling_strNonEmpty(stage1BuilderText):
        stage1BuilderText = tooling_textLiteral("stage1")
    if !tooling_strNonEmpty(skipGlobalInitText):
        skipGlobalInitText = tooling_textLiteral("0")
    skipGlobalInitText = tooling_bool01Normalized(skipGlobalInitText)
    if !tooling_strEq(skipGlobalInitText, "0"):
        tooling_printErr("cheng_tooling: build-backend-driver requires BACKEND_BUILD_DRIVER_SKIP_GLOBAL_INIT=0 " +
                         "(and BACKEND_BUILD_DRIVER_REBUILD_SKIP_GLOBAL_INIT=0) for runtime-safe output")
        return 2
    if !tooling_strNonEmpty(disableDupScanText):
        disableDupScanText = tooling_textLiteral("0")
    disableDupScanText = tooling_bool01Normalized(disableDupScanText)
    if !tooling_strNonEmpty(skipFixupsText):
        skipFixupsText = tooling_textLiteral("0")
    skipFixupsText = tooling_bool01Normalized(skipFixupsText)
    if !tooling_strNonEmpty(skipNormalizeText):
        skipNormalizeText = tooling_textLiteral("0")
    skipNormalizeText = tooling_bool01Normalized(skipNormalizeText)
    if fullRebuild && !tooling_strEq(strutil.toLowerAscii(strutil.strip(stage1BuilderText)), "stage1"):
        stage1BuilderText = tooling_textLiteral("stage1")
    if !tooling_strNonEmpty(genericModeText):
        genericModeText = tooling_textLiteral("dict")
    if !tooling_strNonEmpty(genericSpecBudgetText):
        genericSpecBudgetText = tooling_textLiteral("0")
    if !tooling_strNonEmpty(genericLoweringText):
        genericLoweringText = tooling_textLiteral("mir_dict")
    var timeoutText: str = os.getEnvDefault(timeoutEnv, "")
    if !tooling_strNonEmpty(timeoutText):
        timeoutText = os.getEnvDefault("SELF_OBJ_BOOTSTRAP_TIMEOUT", "")
    var timeoutSec: int32 = tooling_parseInt32Default(timeoutText, timeoutDefault)
    if timeoutSec < 1:
        timeoutSec = timeoutDefault
    if fullRebuild && fullRebuildTightTimeoutProfile:
        let logEveryCall: bool = tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_DRIVER_TIGHT_PROFILE_LOG_EVERY_CALL", "0"))
        if !tooling_buildDriverTightProfileLogShown || logEveryCall:
            tooling_printErr("cheng_tooling: full rebuild using tight-timeout profile (parse=" + parseMode +
                             ", fn_sched=" + fnSchedText + ", skip_sem=0, skip_ownership=0, skip_fixups=" +
                             skipFixupsText + ", skip_normalize=" + skipNormalizeText +
                             ", skip_global_init=" + skipGlobalInitText +
                             ", disable_dup_scan=" + disableDupScanText + ")")
            tooling_printErr("cheng_tooling: full rebuild tight-timeout jobs=" + intToStr(jobs))
            tooling_buildDriverTightProfileLogShown = true
    let compileModeText: str = tooling_buildDriverCompileModeText(fullRebuild)
    let profileEnabledFromEnv: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE", "0"))
    let profileOutRaw: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_OUT", "")
    var profileOutPath: str = tooling_textLiteral("")
    if tooling_strNonEmpty(profileOutRaw):
        profileOutPath = tooling_pathAbsolute(root, profileOutRaw)
    let profileEnabled: bool = profileEnabledFromEnv || tooling_strNonEmpty(profileOutPath)
    let profileMode: str = tooling_buildDriverProfileMode()
    let profileFailOpen: bool = profileEnabled &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_FAIL_OPEN", "0"))
    var stampIgnoreStage0ShaEnv: str = tooling_textLiteral("")
    if fullRebuild:
        let rebuildStampIgnoreDefault: str = tooling_boolText(fullRebuildTightTimeoutProfile)
        stampIgnoreStage0ShaEnv = os.getEnvDefault(
            "BACKEND_BUILD_DRIVER_REBUILD_STAMP_IGNORE_STAGE0_SHA", rebuildStampIgnoreDefault)
    else:
        stampIgnoreStage0ShaEnv = os.getEnvDefault("BACKEND_BUILD_DRIVER_QUICK_STAMP_IGNORE_STAGE0_SHA", "0")
    let stampIgnoreStage0Sha: bool = tooling_isTrue(stampIgnoreStage0ShaEnv)
    var stampCacheEnvName: str = tooling_textLiteral("BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE")
    if fullRebuild:
        stampCacheEnvName = tooling_textLiteral("BACKEND_BUILD_DRIVER_REBUILD_STAMP_CACHE")
    let stampCacheEnabled: bool = tooling_isTrue(os.getEnvDefault(stampCacheEnvName, "1"))
    let quickStampHitFastSanity: bool = !fullRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_QUICK_STAMP_HIT_FAST_SANITY", "1"))
    let stage0IdentityPath: str = tooling_pathAbsolute(root, stage0)
    var sourcePath: str = compileProfile.sourcePath
    if !os.fileExists(sourcePath):
        tooling_printErr("cheng_tooling: build-backend-driver source not found: " + sourcePath)
        return 1
    let stampPath: str = tooling_buildDriverStampPath(outPath, fullRebuild)
    if !tooling_stage0CapabilityPreflightOkEx(root, stage0IdentityPath, "build_backend_driver",
                                              allowBootstrapCapabilityRefresh):
        return 2
    var stage0IdentitySha: str = tooling_textLiteral("")
    var sourceSha: str = tooling_textLiteral("")
    var sourceCapabilitySignature: str = tooling_textLiteral("")
    var stampText: str = tooling_textLiteral("")
    let sidecarSourcePath: str = tooling_backendDriverUirSidecarSourcePath(root)
    let useUirSidecar: bool = tooling_strEq(linkerMode, "system") && os.fileExists(sidecarSourcePath)
    let quickSharedCacheEnabled: bool = !fullRebuild &&
        stampCacheEnabled &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE", "1"))
    var quickSharedCachePath: str = tooling_textLiteral("")
    var quickSharedStampPath: str = tooling_textLiteral("")
    if stampCacheEnabled && tooling_isExecutable(root, stage0IdentityPath):
        sourceSha = tooling_buildDriverSourceSha(root, sourcePath, sidecarSourcePath, useUirSidecar)
        stage0IdentitySha = tooling_sha256File(root, stage0IdentityPath)
        sourceCapabilitySignature = tooling_stage0CapabilitySignature(root)
        stampText = tooling_buildDriverStampText(
            compileModeText, target, linkerMode, stage0IdentityPath, stage0IdentitySha,
            sourcePath, sourceSha, sourceCapabilitySignature,
            parseMode, fnSchedText, directExeText, incrementalText,
            multiText, multiForceText, stage1BuilderText, skipGlobalInitText,
            disableDupScanText, skipFixupsText, skipNormalizeText, genericModeText,
            genericSpecBudgetText, genericLoweringText, jobs)
        if quickSharedCacheEnabled:
            let sharedKey: str = tooling_buildDriverSharedCacheKey(root, fullRebuild, stampText)
            quickSharedCachePath = tooling_buildDriverSharedCachePath(root, sharedKey, fullRebuild)
            quickSharedStampPath = tooling_buildDriverSharedStampPath(root, sharedKey, fullRebuild)
    if stampCacheEnabled && os.fileExists(outPath) && os.fileExists(stampPath) &&
       os.fileExists(sourcePath) && tooling_isExecutable(root, stage0IdentityPath):
        let stampRaw: str = tooling_readTextFile(root, stampPath)
        if tooling_buildDriverStampMatches(
            stampRaw, compileModeText, target, linkerMode, stage0IdentityPath,
            stage0IdentitySha, sourcePath, sourceSha, sourceCapabilitySignature,
            parseMode, fnSchedText,
            directExeText, incrementalText, multiText, multiForceText,
            stage1BuilderText, skipGlobalInitText, disableDupScanText,
            skipFixupsText, skipNormalizeText, genericModeText,
            genericSpecBudgetText, genericLoweringText, jobs, stampIgnoreStage0Sha):
            if quickStampHitFastSanity && !tooling_driverMinimalSanityOk(root, outPath):
                tooling_printErr("cheng_tooling: quick stamp-hit sanity failed; rebuilding driver: " + outPath)
            else:
                tooling_buildDriverLastStampHit = true
                tooling_printOut("build_backend_driver_stamp_cache_hit=1")
                let capPath: str = tooling_stage0CapabilityFilePath(outPath)
                if !os.fileExists(capPath):
                    let _capWrittenOnHit: bool = tooling_stage0CapabilityWriteForOutput(root, outPath)
                tooling_cleanupStage0Exec(stage0, stage0Exec)
                return 0
    if quickSharedCacheEnabled && tooling_fileExistsNonEmpty(quickSharedCachePath) &&
       os.fileExists(quickSharedStampPath):
        let sharedStampRaw: str = tooling_readTextFile(root, quickSharedStampPath)
        if tooling_buildDriverStampMatches(
            sharedStampRaw, compileModeText, target, linkerMode, stage0IdentityPath,
            stage0IdentitySha, sourcePath, sourceSha, sourceCapabilitySignature,
            parseMode, fnSchedText,
            directExeText, incrementalText, multiText, multiForceText,
            stage1BuilderText, skipGlobalInitText, disableDupScanText,
            skipFixupsText, skipNormalizeText, genericModeText,
            genericSpecBudgetText, genericLoweringText, jobs, stampIgnoreStage0Sha):
            if quickStampHitFastSanity && !tooling_driverMinimalSanityOk(root, quickSharedCachePath):
                tooling_printErr("cheng_tooling: quick shared-cache sanity failed; rebuilding driver: " +
                                 quickSharedCachePath)
            elif !tooling_installExecutableAtomic(root, quickSharedCachePath, outPath):
                tooling_printErr("cheng_tooling: quick shared-cache install failed: " +
                                 quickSharedCachePath)
            else:
                tooling_buildDriverLastStampHit = true
                tooling_printOut("build_backend_driver_shared_cache_hit=1")
                if tooling_strNonEmpty(stampText):
                    if !tooling_writeTextFileViaShell(root, stampPath, stampText):
                        tooling_printErr("cheng_tooling: warning: failed to write build-backend-driver stamp: " +
                                         stampPath)
                let capPath: str = tooling_stage0CapabilityFilePath(outPath)
                if !os.fileExists(capPath):
                    let _capWrittenOnSharedHit: bool = tooling_stage0CapabilityWriteForOutput(root, outPath)
                tooling_cleanupStage0Exec(stage0, stage0Exec)
                return 0
    stage0Exec = tooling_prepareStage0Exec(root, stage0, stage0Purpose)
    if !tooling_strNonEmpty(stage0Exec):
        return 1
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 1
    var uirSidecarObj: str = tooling_textLiteral("")
    var uirSidecarBundle: str = tooling_textLiteral("")
    if useUirSidecar:
        uirSidecarObj = tooling_prepareBackendDriverUirSidecarObj(root, stage0Exec, target)
        if !tooling_fileExistsNonEmpty(uirSidecarObj):
            tooling_printErr("cheng_tooling: missing backend driver UIR sidecar object: " +
                             tooling_backendDriverUirSidecarObjPath(root, target))
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            return 1
        uirSidecarBundle = tooling_prepareBackendDriverUirSidecarBundle(root, target, uirSidecarObj,
                                                                        "cheng")
        if !tooling_fileExistsNonEmpty(uirSidecarBundle):
            tooling_printErr("cheng_tooling: missing backend driver UIR sidecar bundle: " +
                             tooling_backendDriverUirSidecarBundlePath(root, target))
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            return 1
    if tooling_strEq(linkerMode, "self"):
        let refreshRuntimeObj: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_RUNTIME_OBJ_REFRESH", "0"))
        if refreshRuntimeObj:
            runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
        else:
            runtimeObj = tooling_runtimeObjPath(root, target)
            if !os.fileExists(runtimeObj):
                runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
        let preferSeedBaseRuntimeObj: bool = tooling_isTrue(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_SEED_BASE_RUNTIME_OBJ", "1"))
        let stage0LowerRaw: str = strutil.toLowerAscii(strutil.strip(stage0))
        let seedLikeStage0: bool =
            tooling_strContains(stage0LowerRaw, "/artifacts/backend_selfhost_self_obj/cheng.stage2") ||
            tooling_strContains(stage0LowerRaw, "/artifacts/backend_selfhost_self_obj/cheng.stage1")
        if preferSeedBaseRuntimeObj && seedLikeStage0:
            let baseRuntimeObj: str = tooling_runtimeObjSeedCompatiblePath(root, target)
            if tooling_strNonEmpty(baseRuntimeObj):
                runtimeObj = baseRuntimeObj
        if !os.fileExists(runtimeObj):
            tooling_printErr("cheng_tooling: missing runtime object: " + runtimeObj)
            tooling_cleanupStage0Exec(stage0, stage0Exec)
            return 1
    let crashRetrySafe: bool = fullRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_CRASH_RETRY_SAFE", "1"))
    var crashRetryMax: int32 = 0
    if crashRetrySafe:
        crashRetryMax = tooling_parseInt32Default(
            os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_CRASH_RETRY_MAX", ""), 1)
    if crashRetryMax < 0:
        crashRetryMax = 0
    if crashRetryMax > 2:
        crashRetryMax = 2
    let compileAttemptLimit: int32 = crashRetryMax + 1
    var segfaultRetryCount: int32 = 0
    var finalRes: os.ExecCmdResult = tooling_exec(root, "true")
    var finalRc: int32 = 1
    var lastCompileCmdBase: str = tooling_textLiteral("")
    var lastAttemptTimeoutSec: int32 = timeoutSec
    var profileDisabledByCrash: bool = false
    let crashTraceEnabled: bool = fullRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_CRASH_TRACE", "1"))
    let crashTraceTimeoutMax: int32 = tooling_parseInt32Default(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_CRASH_TRACE_TIMEOUT", "25"), 25)
    for attempt in 0..<compileAttemptLimit:
        var attemptTimeoutSec: int32 = timeoutSec
        lastAttemptTimeoutSec = attemptTimeoutSec
        let compileCmdBase: str = tooling_buildBackendDriverCompileCmdBase(
            root, sourcePath, outPath, target, linkerMode, parseMode, fnSchedText,
            directExeText, incrementalText, multiText, multiForceText, stage1BuilderText,
            skipGlobalInitText, disableDupScanText, skipFixupsText, skipNormalizeText,
            genericModeText, genericSpecBudgetText, genericLoweringText, runtimeObj,
            stage0Exec, jobs, attemptTimeoutSec, uirSidecarBundle)
        lastCompileCmdBase = compileCmdBase
        var compileCmd: str = compileCmdBase
        let profileAttemptEnabled: bool = profileEnabled && !profileDisabledByCrash
        if profileAttemptEnabled:
            compileCmd = tooling_prefixBuildDriverProfile(compileCmd, profileMode)
        compileCmd = tooling_wrapStage0LockTimeout(root, attemptTimeoutSec, compileCmd,
                                                   "build_backend_driver_compile")
        var res: os.ExecCmdResult = tooling_exec(root, compileCmd)
        tooling_printExecOutput(res)
        finalRes = res
        finalRc = os.execCmdResultExitCode(res)
        if profileAttemptEnabled && profileFailOpen && finalRc == 139:
            tooling_printErr("cheng_tooling: profile-enabled full rebuild segfaulted; retrying same attempt without profile flags")
            profileDisabledByCrash = true
            var noProfileCmd: str = compileCmdBase
            noProfileCmd = tooling_wrapStage0LockTimeout(root, attemptTimeoutSec, noProfileCmd,
                                                         "build_backend_driver_compile")
            res = tooling_exec(root, noProfileCmd)
            tooling_printExecOutput(res)
            finalRes = res
            finalRc = os.execCmdResultExitCode(res)
        if crashTraceEnabled && (finalRc == 138 || finalRc == 139):
            var traceTimeoutSec: int32 = attemptTimeoutSec
            if traceTimeoutSec < 8:
                traceTimeoutSec = 8
            if crashTraceTimeoutMax > 0 && traceTimeoutSec > crashTraceTimeoutMax:
                traceTimeoutSec = crashTraceTimeoutMax
            let traceLogDir: str = tooling_driverBuildTempDir(root)
            tooling_tryMkdirP(root, traceLogDir)
            let traceLogPath: str = os.joinPath(traceLogDir, "backend_driver_crash_trace.attempt." +
                                                intToStr(attempt + 1) + ".log")
            let traceRes: os.ExecCmdResult = tooling_exec(
                root, tooling_buildBackendDriverCrashTraceCmd(root, compileCmdBase, traceTimeoutSec))
            let traceOut: str = os.execCmdResultOutput(traceRes)
            if !tooling_writeTextFileViaShell(root, traceLogPath, traceOut):
                tooling_printErr("cheng_tooling: failed to write crash trace log: " + traceLogPath)
            tooling_printOut("build_backend_driver_crash_trace_log=" + traceLogPath)
            tooling_printOut("build_backend_driver_crash_trace_rc=" + intToStr(os.execCmdResultExitCode(traceRes)))
            let traceSawFixupsStart: bool = tooling_strContains(traceOut, "backend: uir fixups start")
            let traceSawFixupsDone: bool = tooling_strContains(traceOut, "backend: uir fixups done")
            tooling_printOut("build_backend_driver_crash_trace_fixups_start=" + tooling_boolText(traceSawFixupsStart))
            tooling_printOut("build_backend_driver_crash_trace_fixups_done=" + tooling_boolText(traceSawFixupsDone))
        if finalRc != 139 || (attempt + 1) >= compileAttemptLimit:
            break
        segfaultRetryCount = segfaultRetryCount + 1
        tooling_printErr("cheng_tooling: full rebuild crashed with segfault; retrying safe stage1 builder profile (" +
                         intToStr(segfaultRetryCount) + "/" + intToStr(crashRetryMax) + ")")
        jobs = 1
        multiText = tooling_textLiteral("0")
        multiForceText = tooling_textLiteral("0")
        incrementalText = tooling_textLiteral("0")
        parseMode = tooling_textLiteral("outline")
        fnSchedText = tooling_textLiteral("ws")
        directExeText = tooling_buildDriverDirectExeText(linkerMode)
        stage1BuilderText = tooling_textLiteral("stage1")
    let finalOutTrim: str = strutil.strip(os.execCmdResultOutput(finalRes))
    let diagOnEmptyFailDefault: str = tooling_boolText(!fullRebuildTightTimeoutProfile)
    let diagOnEmptyFail: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_EMPTY_FAIL_DIAG", diagOnEmptyFailDefault))
    let finalKind: str = tooling_exitKind(finalRc)
    if fullRebuild && finalRc != 0 && finalRc != 139 && !tooling_strEq(finalKind, "timeout") &&
       !tooling_strNonEmpty(finalOutTrim) &&
       diagOnEmptyFail && tooling_strNonEmpty(lastCompileCmdBase):
        let diagRes: os.ExecCmdResult = tooling_exec(
            root,
            tooling_buildBackendDriverDiagCmd(
                root, lastCompileCmdBase, lastAttemptTimeoutSec,
                profileEnabled && !profileDisabledByCrash, profileMode))
        let diagOut: str = os.execCmdResultOutput(diagRes)
        tooling_printErr("cheng_tooling: full rebuild failed with empty output; printing inline diagnostics")
        if tooling_strNonEmpty(strutil.strip(diagOut)):
            let rows: str[] = tooling_splitLines(diagOut)
            var maxLines: int32 = 24
            if rows.len < maxLines:
                maxLines = rows.len
            for i in 0..<maxLines:
                tooling_printErr("cheng_tooling: full rebuild diag: " + rows[i])
        else:
            tooling_printErr("cheng_tooling: full rebuild diag produced empty output")
    elif fullRebuild && finalRc != 0 && tooling_strEq(finalKind, "timeout") && !diagOnEmptyFail:
        tooling_printErr("cheng_tooling: skip empty-output diag on timeout (tight-timeout profile)")
    if tooling_strNonEmpty(profileOutPath):
        if finalRc == 0 && profileEnabled && !profileDisabledByCrash:
            let profileOutDir: str = os.parentDir(profileOutPath)
            if tooling_strNonEmpty(profileOutDir):
                tooling_tryMkdirP(root, profileOutDir)
            os.writeFile(profileOutPath, os.execCmdResultOutput(finalRes))
            tooling_printOut("build_backend_driver_profile_log=" + profileOutPath)
        elif finalRc == 0 && profileDisabledByCrash:
            tooling_printErr("cheng_tooling: profile log disabled after segfault fail-open; build succeeded without profile flags")
        else:
            tooling_printErr("cheng_tooling: skip profile log write for failed full rebuild rc=" + intToStr(finalRc))
    if fullRebuild && (finalRc == 138 || finalRc == 139):
        let finalOutRaw: str = os.execCmdResultOutput(finalRes)
        let sawFixupsStart: bool = tooling_strContains(finalOutRaw, "backend: uir fixups start")
        let sawFixupsDone: bool = tooling_strContains(finalOutRaw, "backend: uir fixups done")
        if sawFixupsStart && !sawFixupsDone:
            tooling_printErr("cheng_tooling: detected stage0 crash window in uir fixups (start seen, done missing)")
            tooling_printErr("cheng_tooling: action: refresh seed/canonical stage0 before require-rebuild (tick/tock bootstrap)")
        if tooling_strContains(finalOutRaw, "unknown local/global: pcOther"):
            tooling_printErr("cheng_tooling: detected stale stage0 enum resolution failure for PathComponent.pcOther")
            tooling_printErr("cheng_tooling: action: keep PathComponent returns explicit (PathComponent(<int>)) and refresh stage0")
    if fullRebuild && finalRc != 0 && tooling_strNonEmpty(lastCompileCmdBase):
        let attemptsUsed: int32 = segfaultRetryCount + 1
        let reportPath: str = tooling_writeCompileCrashReport(
            root, "build_backend_driver_rebuild", finalRc, attemptsUsed, compileAttemptLimit,
            lastCompileCmdBase, os.execCmdResultOutput(finalRes))
        if tooling_strNonEmpty(reportPath):
            tooling_printOut("build_backend_driver_rebuild_report=" + reportPath)
    if finalRc != 0:
        # Legacy relink fallback has been removed.
        let _strictNativeUnused: bool = strictNative
        let _allowFallbackUnused: bool = allowFallback
        let _targetUnused: str = target
    if finalRc != 0:
        tooling_stage0MarkCrash(root, stage0Exec, finalRc, "build_backend_driver_compile")
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return finalRc
    if !tooling_fileExistsNonEmpty(outPath):
        tooling_stage0MarkBlocked(root, stage0Exec, finalRc,
                                  "build_backend_driver_missing_output", "missing_output")
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        tooling_printErr("cheng_tooling: build-backend-driver returned success but produced no output: " + outPath)
        return 1
    let chmodRes: os.ExecCmdResult = tooling_exec(root, "chmod +x " + tooling_shellQuote(outPath))
    tooling_printExecOutput(chmodRes)
    let chmodRc: int32 = os.execCmdResultExitCode(chmodRes)
    if chmodRc == 0:
        if !tooling_stage0CapabilityWriteForOutput(root, outPath):
            tooling_printErr("cheng_tooling: warning: stage0 capability sidecar write failed for " + outPath)
    if chmodRc == 0 && stampCacheEnabled:
        if !tooling_strNonEmpty(sourceSha):
            sourceSha = tooling_sha256File(root, sourcePath)
        if !tooling_strNonEmpty(stage0IdentitySha):
            stage0IdentitySha = tooling_sha256File(root, stage0IdentityPath)
        if !tooling_strNonEmpty(sourceCapabilitySignature):
            sourceCapabilitySignature = tooling_stage0CapabilitySignature(root)
        if !tooling_strNonEmpty(stampText):
            stampText = tooling_buildDriverStampText(
                compileModeText, target, linkerMode, stage0IdentityPath, stage0IdentitySha,
                sourcePath, sourceSha, sourceCapabilitySignature,
                parseMode, fnSchedText, directExeText, incrementalText,
                multiText, multiForceText, stage1BuilderText, skipGlobalInitText,
                disableDupScanText, skipFixupsText, skipNormalizeText, genericModeText,
                genericSpecBudgetText, genericLoweringText, jobs)
        if tooling_writeTextFileViaShell(root, stampPath, stampText):
            tooling_printOut("build_backend_driver_stamp_cache_write=1")
        else:
            tooling_printErr("cheng_tooling: failed to write build-backend-driver stamp: " + stampPath)
        if quickSharedCacheEnabled && tooling_strNonEmpty(quickSharedCachePath):
            if tooling_installExecutableAtomic(root, outPath, quickSharedCachePath):
                let _sharedCapWritten: bool = tooling_stage0CapabilityWriteForOutput(root, quickSharedCachePath)
                if tooling_writeTextFileViaShell(root, quickSharedStampPath, stampText):
                    tooling_printOut("build_backend_driver_shared_cache_write=1")
                else:
                    tooling_printErr("cheng_tooling: warning: failed to write build-backend-driver shared stamp: " +
                                     quickSharedStampPath)
            else:
                tooling_printErr("cheng_tooling: warning: failed to publish build-backend-driver shared cache: " +
                                 quickSharedCachePath)
    tooling_cleanupStage0Exec(stage0, stage0Exec)
    return chmodRc

fn tooling_compileBackendDriverFastHostWithRebuildPolicy(root: str, stage0: str, target: str, outPath: str,
                                                         fullRebuild: bool, rebuildSkipSemRaw: str,
                                                         rebuildSkipOwnershipRaw: str,
                                                         allowBootstrapCapabilityRefresh: bool): int32 =
    return tooling_compileBackendDriverFastHostWithCompileProfile(
        root, stage0, target, outPath, fullRebuild,
        rebuildSkipSemRaw, rebuildSkipOwnershipRaw,
        allowBootstrapCapabilityRefresh, nil)

fn tooling_compileBackendDriverFastHost(root: str, stage0: str, target: str, outPath: str, fullRebuild: bool): int32 =
    return tooling_compileBackendDriverFastHostWithCompileProfile(
        root, stage0, target, outPath, fullRebuild, "", "", false, nil)

fn tooling_selfhostBootstrapFastHost(root: str, compileStage1: bool, outDirRaw: str, timingOutRaw: str,
                                     allowBootstrapCapabilityRefresh: bool): ToolingSelfhostResult =
    var result: ToolingSelfhostResult = nil
    new(result)
    result.ok = false
    result.message = ""
    result.totalMs = int64(0)
    result.mode = "fast"
    result.stage1Path = ""
    result.stage2Path = ""
    result.stage3Path = ""
    result.stage0Path = ""
    result.stage0DriverKind = "unknown"
    result.stage1Status = "init"
    result.stage1CompileMode = "alias"
    result.stage1RebuildOk = false
    result.fallbackUsed = false
    result.quarantineCleaned = 0
    result.lockWaitMs = 0
    result.strictRebuildOk = false
    result.stage2Sha256 = ""
    result.stage3Sha256 = ""
    result.fixedPointOk = false
    result.strictMismatchReport = ""
    result.stage1CompileMs = int64(0)
    result.stage1SanityMs = int64(0)
    result.stage1CompileAttempts = 0
    result.stage1CompileSegfaults = 0

    let hostTag: str = tooling_detectHostTag(root)
    if !tooling_strEq(hostTag, "darwin_arm64"):
        result.message = "selfhost_fast_host unsupported host: " + hostTag
        return result
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        result.message = "selfhost_fast_host failed to resolve host target"
        return result
    result.quarantineCleaned = tooling_stage0QuarantineSweepUe(root, "selfhost_fast_host")
    if tooling_stage0BlockOnQuarantineUe(root, "TOOLING_SELFHOST_BLOCK_ON_UE", "selfhost_fast_host"):
        result.message = "selfhost_fast_host blocked by quarantine stuck/orphan processes"
        return result

    let stage0: str = tooling_resolveStage0DriverStrict(root, "")
    if !tooling_strNonEmpty(stage0):
        result.message = "selfhost_fast_host missing stage0 driver"
        return result
    result.stage0Path = stage0
    result.stage0DriverKind = tooling_stage0DriverKind(root, stage0)

    var outDir: str = tooling_pathAbsolute(
        root, tooling_nonEmptyDefault(outDirRaw, "artifacts/backend_selfhost_self_obj"))
    if !tooling_mkdirP(root, outDir):
        result.message = "selfhost_fast_host failed to create out dir: " + outDir
        return result
    let stage1Path: str = os.joinPath(outDir, "cheng.stage1")
    let stage2Path: str = os.joinPath(outDir, "cheng.stage2")
    result.stage1Path = stage1Path
    result.stage2Path = stage2Path

    let startedMs: int64 = tooling_nowMs()
    let stage1StartedMs: int64 = tooling_nowMs()
    var stage1Status: str = tooling_textLiteral("alias")
    var stage1CompileMode: str = tooling_textLiteral("alias")
    let strictRebuild: bool = tooling_selfhostStrictRebuildEnabled()
    let requireStage1Rebuild: bool = compileStage1 &&
        (strictRebuild || tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_REQUIRE_REBUILD", "0")))
    let stage1FullRebuild: bool = compileStage1 &&
        (strictRebuild || tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_FULL_REBUILD", "0")))
    let stage1ForceProbeOnFull: bool = compileStage1 &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_FORCE_PROBE_ON_FULL", "0"))
    let stage1AutoFullOnRequire: bool = compileStage1 && !stage1FullRebuild && requireStage1Rebuild &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_AUTO_FULL_ON_REQUIRE", "1"))
    let stage1QuickLightSanity: bool = compileStage1 && !stage1FullRebuild &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_QUICK_LIGHT_SANITY", "1"))
    let stage1StampHitFastSanity: bool = compileStage1 && stage1FullRebuild &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_STAMP_HIT_FAST_SANITY", "1"))
    var compileStage1TextBase: str = tooling_textLiteral("0")
    if compileStage1:
        compileStage1TextBase = tooling_textLiteral("1")
        if stage1FullRebuild:
            stage1CompileMode = tooling_textLiteral("full")
        else:
            stage1CompileMode = tooling_textLiteral("quick")
    result.stage1CompileMode = stage1CompileMode
    var stage1CompileMsTotal: int64 = int64(0)
    var stage1SanityMsTotal: int64 = int64(0)
    var stage1CompileAttempts: int32 = 0
    var stage1CompileSegfaults: int32 = 0
    let stageRebuildLinkerMode: str = tooling_buildDriverEffectiveLinkerMode(
        tooling_buildDriverEffectiveStrictNativeForRebuild(stage1FullRebuild))
    if compileStage1:
        let compileStarted0: int64 = tooling_nowMs()
        var rcBuild: int32 = tooling_compileBackendDriverFastHostWithRebuildPolicy(
            root, stage0, target, stage1Path, stage1FullRebuild, "", "",
            allowBootstrapCapabilityRefresh)
        stage1CompileMsTotal = stage1CompileMsTotal + (tooling_nowMs() - compileStarted0)
        stage1CompileAttempts = stage1CompileAttempts + 1
        if rcBuild != 0 && tooling_strEq(tooling_exitKind(rcBuild), "segfault"):
            stage1CompileSegfaults = stage1CompileSegfaults + 1
        var stage1BuildOk: bool = false
        if rcBuild == 0:
            let sanityStarted0: int64 = tooling_nowMs()
            if stage1StampHitFastSanity && tooling_buildDriverLastStampHit:
                stage1BuildOk = tooling_driverMinimalSanityOk(root, stage1Path)
            else:
                stage1BuildOk = tooling_driverBuildOutputOk(root, stage1Path, stage1CompileMode, stage1QuickLightSanity,
                                                            stage1ForceProbeOnFull, stageRebuildLinkerMode)
            stage1SanityMsTotal = stage1SanityMsTotal + (tooling_nowMs() - sanityStarted0)
        if stage1AutoFullOnRequire && (!stage1BuildOk || rcBuild != 0):
            tooling_printErr("cheng_tooling: selfhost fast stage1 quick rebuild failed or not runnable; retrying full-rebuild because require-rebuild is enabled")
            stage1CompileMode = tooling_textLiteral("full")
            let compileStarted1: int64 = tooling_nowMs()
            rcBuild = tooling_compileBackendDriverFastHostWithRebuildPolicy(
                root, stage0, target, stage1Path, true, "", "",
                allowBootstrapCapabilityRefresh)
            stage1CompileMsTotal = stage1CompileMsTotal + (tooling_nowMs() - compileStarted1)
            stage1CompileAttempts = stage1CompileAttempts + 1
            if rcBuild != 0 && tooling_strEq(tooling_exitKind(rcBuild), "segfault"):
                stage1CompileSegfaults = stage1CompileSegfaults + 1
            if rcBuild == 0:
                let sanityStarted1: int64 = tooling_nowMs()
                if stage1StampHitFastSanity && tooling_buildDriverLastStampHit:
                    stage1BuildOk = tooling_driverMinimalSanityOk(root, stage1Path)
                else:
                    stage1BuildOk = tooling_driverBuildOutputOk(root, stage1Path, stage1CompileMode, stage1QuickLightSanity,
                                                                stage1ForceProbeOnFull, stageRebuildLinkerMode)
                stage1SanityMsTotal = stage1SanityMsTotal + (tooling_nowMs() - sanityStarted1)
            else:
                stage1BuildOk = false
        if stage1BuildOk:
            stage1Status = tooling_textLiteral("rebuild")
            result.stage1RebuildOk = true
            result.fallbackUsed = false
        else:
            result.stage1CompileMs = stage1CompileMsTotal
            result.stage1SanityMs = stage1SanityMsTotal
            result.stage1CompileAttempts = stage1CompileAttempts
            result.stage1CompileSegfaults = stage1CompileSegfaults
            if rcBuild != 0:
                result.message = "selfhost_fast_host stage1 compile failed rc=" + intToStr(rcBuild) +
                                 " kind=" + tooling_exitKind(rcBuild)
            else:
                result.message = "selfhost_fast_host stage1 compile output sanity failed"
            return result
    else:
        if !tooling_copyExecutable(root, stage0, stage1Path):
            result.message = "selfhost_fast_host stage1 alias copy failed"
            return result
        stage1Status = tooling_textLiteral("alias")
        result.stage1RebuildOk = false
        # Alias mode is the intentional default fast path, not a fallback.
        result.fallbackUsed = false
    result.stage1CompileMs = stage1CompileMsTotal
    result.stage1SanityMs = stage1SanityMsTotal
    result.stage1CompileAttempts = stage1CompileAttempts
    result.stage1CompileSegfaults = stage1CompileSegfaults
    let stage1Ms: int64 = tooling_nowMs() - stage1StartedMs
    result.stage1Status = stage1Status
    result.stage1CompileMode = stage1CompileMode
    result.strictRebuildOk = !compileStage1 || !strictRebuild || result.stage1RebuildOk

    let stage2StartedMs: int64 = tooling_nowMs()
    if !tooling_copyExecutable(root, stage1Path, stage2Path):
        result.message = "selfhost_fast_host stage2 alias copy failed"
        return result
    let stage2Ms: int64 = tooling_nowMs() - stage2StartedMs

    let totalMs: int64 = tooling_nowMs() - startedMs
    result.totalMs = totalMs
    result.ok = true
    result.message = "ok"

    var timingOut: str = timingOutRaw
    if !tooling_strNonEmpty(timingOut):
        timingOut = os.joinPath(outDir, "selfhost_timing_native.tsv")
    timingOut = tooling_pathAbsolute(root, timingOut)
    let timingDir: str = os.parentDir(timingOut)
    tooling_tryMkdirP(root, timingDir)
    let _timingWriteOk: bool = tooling_writeTextFileViaShell(
        root,
        timingOut,
        "stage1\t" + stage1Status + "\t" + tooling_msToSecondsText(stage1Ms) + "\n" +
            "stage2\talias\t" + tooling_msToSecondsText(stage2Ms) + "\n" +
            "total\tok\t" + tooling_msToSecondsText(totalMs) + "\n")
    result.lockWaitMs = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_LOCK_WAIT_MS", ""), 0)
    return result

fn tooling_selfhostWriteTiming(root: str, outDirRaw: str, timingOutRaw: str, stage1Status: str, stage1Ms: int64,
                               stage2Status: str, stage2Ms: int64, stage3Status: str, stage3Ms: int64,
                               hashStatus: str, hashMs: int64, totalStatus: str, totalMs: int64) =
    var outDir: str = tooling_pathAbsolute(
        root, tooling_nonEmptyDefault(outDirRaw, "artifacts/backend_selfhost_self_obj"))
    var timingOut: str = timingOutRaw
    if !tooling_strNonEmpty(timingOut):
        timingOut = os.joinPath(outDir, "selfhost_timing_native.tsv")
    timingOut = tooling_pathAbsolute(root, timingOut)
    let timingDir: str = os.parentDir(timingOut)
    tooling_tryMkdirP(root, timingDir)
    let _timingWriteOk: bool = tooling_writeTextFileViaShell(
        root,
        timingOut,
        "stage1\t" + stage1Status + "\t" + tooling_msToSecondsText(stage1Ms) + "\n" +
            "stage2\t" + stage2Status + "\t" + tooling_msToSecondsText(stage2Ms) + "\n" +
            "stage3\t" + stage3Status + "\t" + tooling_msToSecondsText(stage3Ms) + "\n" +
            "hash_check\t" + hashStatus + "\t" + tooling_msToSecondsText(hashMs) + "\n" +
            "total\t" + totalStatus + "\t" + tooling_msToSecondsText(totalMs) + "\n")

fn tooling_summaryOneLine(raw: str): str =
    if !tooling_strNonEmpty(raw):
        return ""
    var out: str = raw
    out = strutil.replace(out, "\r", " ")
    out = strutil.replace(out, "\n", " ")
    out = strutil.replace(out, "\t", " ")
    return out

fn tooling_selfhostInnerLoopWriteTiming(root: str, outDirRaw: str, timingOutRaw: str,
                                        buildStatus: str, buildMs: int64,
                                        inmemStatus: str, inmemMs: int64,
                                        strictStatus: str, strictMs: int64,
                                        closureStatus: str, closureMs: int64,
                                        totalStatus: str, totalMs: int64) =
    var outDir: str = tooling_pathAbsolute(
        root, tooling_nonEmptyDefault(outDirRaw, "artifacts/backend_selfhost_inner_loop"))
    var timingOut: str = timingOutRaw
    if !tooling_strNonEmpty(timingOut):
        timingOut = os.joinPath(outDir, "selfhost_inner_loop_timing.tsv")
    timingOut = tooling_pathAbsolute(root, timingOut)
    let timingDir: str = os.parentDir(timingOut)
    tooling_tryMkdirP(root, timingDir)
    let _timingWriteOk: bool = tooling_writeTextFileViaShell(
        root,
        timingOut,
        "build_driver\t" + buildStatus + "\t" + tooling_msToSecondsText(buildMs) + "\n" +
            "inmem_witness\t" + inmemStatus + "\t" + tooling_msToSecondsText(inmemMs) + "\n" +
            "strict_host\t" + strictStatus + "\t" + tooling_msToSecondsText(strictMs) + "\n" +
            "closure\t" + closureStatus + "\t" + tooling_msToSecondsText(closureMs) + "\n" +
            "total\t" + totalStatus + "\t" + tooling_msToSecondsText(totalMs) + "\n")

fn tooling_statusOkFail(ok: bool): str =
    if ok:
        return "ok"
    return "fail"

fn tooling_statusSkipOkFail(requested: bool, ok: bool): str =
    if !requested:
        return "skip"
    return tooling_statusOkFail(ok)

fn tooling_messageOrUnknown(messageRaw: str): str =
    return tooling_nonEmptyDefault(messageRaw, "unknown failure")

fn tooling_selfhost100msHostOnly(hostOnlyRaw: str): str =
    return tooling_nonEmptyDefault(hostOnlyRaw, "darwin_arm64")

fn tooling_selfhost100msOutDir(root: str, outDirRaw: str): str =
    return tooling_pathAbsolute(root, tooling_nonEmptyDefault(outDirRaw, "artifacts/backend_selfhost_100ms_host"))

fn tooling_selfhost100msReportPath(root: str, reportRaw: str): str =
    return tooling_pathAbsolute(root, tooling_nonEmptyDefault(reportRaw, "artifacts/backend_selfhost_100ms_host/report.tsv"))

fn tooling_selfhost100msStage1CompileModeBase(compileStage1: bool, stage1FullRebuild: bool): str =
    if !compileStage1:
        return "alias"
    return tooling_buildDriverCompileModeText(stage1FullRebuild)

fn tooling_selfhost100msStatus(p95Ms: int32, p99Ms: int32, p95Limit: int32, p99Limit: int32): str =
    if p95Ms > p95Limit || p99Ms > p99Limit:
        return "regression"
    return "ok"

fn tooling_selfhost100msStage1CompileModeSummary(compileStage1: bool, iters: int32,
                                                 fullCount: int32, quickCount: int32,
                                                 aliasCount: int32): str =
    if !compileStage1:
        return "alias"
    if fullCount == iters:
        return "full"
    if quickCount == iters:
        return "quick"
    if fullCount > 0 && quickCount > 0:
        return "mixed_full_quick"
    if aliasCount == iters:
        return "alias"
    return "mixed"

fn tooling_selfhost100msStage1StatusSummary(compileStage1: bool, iters: int32,
                                            rebuildCount: int32, reuseCount: int32): str =
    if !compileStage1:
        return "alias"
    if rebuildCount == iters:
        return "rebuild"
    if rebuildCount > 0 && reuseCount > 0:
        return "mixed_rebuild_reuse"
    if reuseCount > 0:
        return "reused_stage0"
    return "unknown"

fn tooling_selfhost100msStage1RebuildOk(compileStage1: bool, iters: int32,
                                        rebuildCount: int32): bool =
    return compileStage1 && rebuildCount == iters

fn tooling_selfhost100msStage0DriverKindSummary(canonicalCount: int32, distReleaseCount: int32,
                                                backendSeedCount: int32, selfhostObjCount: int32,
                                                explicitCount: int32): str =
    let seenKinds: int32 =
        (canonicalCount > 0 ? 1 : 0) +
        (distReleaseCount > 0 ? 1 : 0) +
        (backendSeedCount > 0 ? 1 : 0) +
        (selfhostObjCount > 0 ? 1 : 0) +
        (explicitCount > 0 ? 1 : 0)
    if seenKinds > 1:
        return "mixed"
    if canonicalCount > 0:
        return "canonical"
    if distReleaseCount > 0:
        return "dist_release"
    if backendSeedCount > 0:
        return "backend_seed"
    if selfhostObjCount > 0:
        return "selfhost_obj"
    if explicitCount > 0:
        return "explicit"
    return "unknown"

fn tooling_selfhostInnerLoopInmemSummary(inmemRes: ToolingSelfhostResult): str =
    if inmemRes == nil:
        return ""
    return "inmem_message=" + tooling_summaryOneLine(inmemRes.message) + "\n" +
           "inmem_stage0=" + tooling_summaryOneLine(inmemRes.stage0Path) + "\n" +
           "inmem_stage0_driver_kind=" + tooling_summaryOneLine(inmemRes.stage0DriverKind) + "\n" +
           "inmem_stage1=" + tooling_summaryOneLine(inmemRes.stage1Path) + "\n" +
           "inmem_stage1_status=" + tooling_summaryOneLine(inmemRes.stage1Status) + "\n"

fn tooling_selfhostInnerLoopStrictSummary(strictRes: ToolingSelfhostResult): str =
    if strictRes == nil:
        return ""
    return "strict_message=" + tooling_summaryOneLine(strictRes.message) + "\n" +
           "strict_stage0=" + tooling_summaryOneLine(strictRes.stage0Path) + "\n" +
           "strict_stage0_driver_kind=" + tooling_summaryOneLine(strictRes.stage0DriverKind) + "\n" +
           "strict_stage1=" + tooling_summaryOneLine(strictRes.stage1Path) + "\n" +
           "strict_stage2=" + tooling_summaryOneLine(strictRes.stage2Path) + "\n" +
           "strict_stage3=" + tooling_summaryOneLine(strictRes.stage3Path) + "\n" +
           "strict_stage1_status=" + tooling_summaryOneLine(strictRes.stage1Status) + "\n" +
           "strict_stage1_compile_mode=" + tooling_summaryOneLine(strictRes.stage1CompileMode) + "\n" +
           "strict_rebuild_ok=" + tooling_boolText(strictRes.strictRebuildOk) + "\n" +
           "strict_fixed_point_ok=" + tooling_boolText(strictRes.fixedPointOk) + "\n" +
           "strict_stage2_sha256=" + tooling_summaryOneLine(strictRes.stage2Sha256) + "\n" +
           "strict_stage3_sha256=" + tooling_summaryOneLine(strictRes.stage3Sha256) + "\n" +
           "strict_mismatch_report=" + tooling_summaryOneLine(strictRes.strictMismatchReport) + "\n"

fn tooling_selfhostInnerLoopWriteSummary(root: str, res: ToolingSelfhostInnerLoopResult): str =
    let outDir: str = tooling_pathAbsolute(
        root, tooling_nonEmptyDefault(res.outDir, "artifacts/backend_selfhost_inner_loop"))
    let summaryPath: str = tooling_pathAbsolute(
        root,
        tooling_nonEmptyDefault(res.summaryPath, os.joinPath(outDir, "selfhost_inner_loop.summary.env")))
    let summaryDir: str = os.parentDir(summaryPath)
    tooling_tryMkdirP(root, summaryDir)
    let inmemRes: ToolingSelfhostResult = res.inmemRes
    let strictRes: ToolingSelfhostResult = res.strictRes
    let buildOk: bool = res.buildRc == 0
    var inmemOk: bool = false
    if res.inmemRequested && inmemRes != nil:
        inmemOk = inmemRes.ok
    var strictOk: bool = false
    if res.strictRequested && strictRes != nil:
        strictOk = strictRes.ok
    let closureOk: bool = res.closureRequested && res.closureRc == 0
    let buildStatus: str = tooling_statusOkFail(buildOk)
    let inmemStatus: str = tooling_statusSkipOkFail(res.inmemRequested, inmemOk)
    let strictStatus: str = tooling_statusSkipOkFail(res.strictRequested, strictOk)
    let closureStatus: str = tooling_statusSkipOkFail(res.closureRequested, closureOk)
    let _summaryWriteOk: bool = tooling_writeTextFileViaShell(
        root,
        summaryPath,
        "selfhost_inner_loop_version=1\n" +
            "ok=" + tooling_boolText(res.ok) + "\n" +
            "failed_step=" + tooling_summaryOneLine(res.failedStep) + "\n" +
            "message=" + tooling_summaryOneLine(res.message) + "\n" +
            "out_dir=" + outDir + "\n" +
            "timing_path=" + tooling_summaryOneLine(res.timingPath) + "\n" +
            "summary_path=" + summaryPath + "\n" +
            "build_driver_path=" + tooling_summaryOneLine(res.buildDriverPath) + "\n" +
            "build_driver_status=" + buildStatus + "\n" +
            "build_driver_rc=" + intToStr(res.buildRc) + "\n" +
            "build_driver_ms=" + intToStr(int32(res.buildMs)) + "\n" +
            "inmem_requested=" + tooling_boolText(res.inmemRequested) + "\n" +
            "inmem_status=" + inmemStatus + "\n" +
            "inmem_ms=" + intToStr(int32(res.inmemMs)) + "\n" +
            tooling_selfhostInnerLoopInmemSummary(inmemRes) +
            "strict_requested=" + tooling_boolText(res.strictRequested) + "\n" +
            "strict_status=" + strictStatus + "\n" +
            "strict_ms=" + intToStr(int32(res.strictMs)) + "\n" +
            tooling_selfhostInnerLoopStrictSummary(strictRes) +
            "closure_requested=" + tooling_boolText(res.closureRequested) + "\n" +
            "closure_status=" + closureStatus + "\n" +
            "closure_rc=" + intToStr(res.closureRc) + "\n" +
            "closure_ms=" + intToStr(int32(res.closureMs)) + "\n" +
            "total_ms=" + intToStr(int32(res.totalMs)) + "\n")
    return summaryPath

fn tooling_compileBackendDriverStrictInmemWitness(root: str, stage0: str, target: str, outPath: str,
                                                  timeoutSec: int32,
                                                  allowBootstrapCapabilityRefresh: bool): int32 =
    let stage0IdentityPath: str = tooling_pathAbsolute(root, stage0)
    if !tooling_stage0CapabilityPreflightOkEx(root, stage0IdentityPath,
                                              "selfhost_strict_inmem_witness",
                                              allowBootstrapCapabilityRefresh):
        return 2
    let sourcePath: str = tooling_pathAbsolute(root, "src/backend/tooling/backend_driver.cheng")
    if !os.fileExists(sourcePath):
        tooling_printErr("cheng_tooling: strict inmem witness source not found: " + sourcePath)
        return 1
    let outDir: str = os.parentDir(outPath)
    if tooling_strNonEmpty(outDir) && !tooling_mkdirP(root, outDir):
        tooling_printErr("cheng_tooling: strict inmem witness failed to create output dir: " + outDir)
        return 1
    var stage0Exec: str = tooling_prepareStage0Exec(root, stage0, "strict_inmem_witness")
    if !tooling_strNonEmpty(stage0Exec):
        return 1
    if !tooling_stage0PreflightOk(root, stage0Exec):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 1
    var runtimeObj: str = tooling_runtimeObjPath(root, target)
    if !os.fileExists(runtimeObj):
        runtimeObj = tooling_prepareRuntimeObjForTarget(root, stage0Exec, target)
    let preferSeedBaseRuntimeObj: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_SEED_BASE_RUNTIME_OBJ", "1"))
    let stage0LowerRaw: str = strutil.toLowerAscii(strutil.strip(stage0))
    let seedLikeStage0: bool =
        tooling_strContains(stage0LowerRaw, "/artifacts/backend_selfhost_self_obj/cheng.stage2") ||
        tooling_strContains(stage0LowerRaw, "/artifacts/backend_selfhost_self_obj/cheng.stage1")
    if preferSeedBaseRuntimeObj && seedLikeStage0:
        let baseRuntimeObj: str = tooling_runtimeObjSeedCompatiblePath(root, target)
        if tooling_strNonEmpty(baseRuntimeObj):
            runtimeObj = baseRuntimeObj
    if !os.fileExists(runtimeObj):
        tooling_printErr("cheng_tooling: strict inmem witness missing runtime object: " + runtimeObj)
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 1
    if os.fileExists(outPath):
        os.removeFile(outPath)
    let compileCmdBase: str = tooling_buildBackendDriverCompileCmdBase(
        root, sourcePath, outPath, target, "self", "full", "ws", "1", "0", "0", "0",
        "stage1", "0", "0", "0", "0", "dict", "0", "mir_dict", runtimeObj,
        stage0Exec, 1, timeoutSec, "")
    let compileCmd: str = tooling_wrapStage0LockTimeout(root, timeoutSec, compileCmdBase,
                                                        "strict_inmem_witness")
    let res: os.ExecCmdResult = tooling_exec(root, compileCmd)
    tooling_printExecOutput(res)
    let rc: int32 = os.execCmdResultExitCode(res)
    if rc != 0:
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return rc
    if !tooling_driverBuildOutputOk(root, outPath, "full", false, false, "self"):
        tooling_cleanupStage0Exec(stage0, stage0Exec)
        return 1
    tooling_cleanupStage0Exec(stage0, stage0Exec)
    return 0

fn tooling_selfhostStrictInmemWitnessHost(root: str, outDirRaw: str, timingOutRaw: str,
                                          allowBootstrapCapabilityRefresh: bool): ToolingSelfhostResult =
    var result: ToolingSelfhostResult = nil
    new(result)
    result.ok = false
    result.message = tooling_textLiteral("")
    result.totalMs = int64(0)
    result.mode = tooling_textLiteral("strict-inmem-witness")
    result.stage1Path = tooling_textLiteral("")
    result.stage2Path = tooling_textLiteral("")
    result.stage3Path = tooling_textLiteral("")
    result.stage0Path = tooling_textLiteral("")
    result.stage0DriverKind = tooling_textLiteral("unknown")
    result.stage1Status = tooling_textLiteral("init")
    result.stage1CompileMode = tooling_textLiteral("full-inmem")
    result.stage1RebuildOk = false
    result.fallbackUsed = false
    result.quarantineCleaned = 0
    result.lockWaitMs = 0
    result.strictRebuildOk = false
    result.stage2Sha256 = tooling_textLiteral("")
    result.stage3Sha256 = tooling_textLiteral("")
    result.fixedPointOk = false
    result.strictMismatchReport = tooling_textLiteral("")
    result.stage1CompileMs = int64(0)
    result.stage1SanityMs = int64(0)
    result.stage1CompileAttempts = 0
    result.stage1CompileSegfaults = 0

    let hostTag: str = tooling_detectHostTag(root)
    if !tooling_strEq(hostTag, "darwin_arm64"):
        result.message = "selfhost_strict_inmem_witness unsupported host: " + hostTag
        return result
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        result.message = "selfhost_strict_inmem_witness failed to resolve host target"
        return result
    result.quarantineCleaned = tooling_stage0QuarantineSweepUe(root, "selfhost_strict_inmem_witness")
    if tooling_stage0BlockOnQuarantineUe(root, "TOOLING_SELFHOST_BLOCK_ON_UE", "selfhost_strict_inmem_witness"):
        result.message = "selfhost_strict_inmem_witness blocked by quarantine stuck/orphan processes"
        return result
    let stage0: str = tooling_resolveStage0DriverStrict(root, "")
    if !tooling_strNonEmpty(stage0):
        result.message = "selfhost_strict_inmem_witness missing stage0 driver"
        return result
    result.stage0Path = stage0
    result.stage0DriverKind = tooling_stage0DriverKind(root, stage0)

    var outDir: str = tooling_pathAbsolute(
        root, tooling_nonEmptyDefault(outDirRaw, "artifacts/backend_selfhost_self_obj"))
    if !tooling_mkdirP(root, outDir):
        result.message = "selfhost_strict_inmem_witness failed to create out dir: " + outDir
        return result
    result.stage1Path = os.joinPath(outDir, "cheng.stage1.inmem_witness")
    var timingOut: str = timingOutRaw
    if !tooling_strNonEmpty(timingOut):
        timingOut = os.joinPath(outDir, "selfhost_inmem_witness_timing_native.tsv")
    var timeoutSec: int32 = tooling_parseInt32Default(
        os.getEnvDefault("SELF_OBJ_BOOTSTRAP_INMEM_WITNESS_TIMEOUT", "60"), 60)
    if timeoutSec < 1:
        timeoutSec = 60
    let startedMs: int64 = tooling_nowMs()
    let stage1StartedMs: int64 = tooling_nowMs()
    let rcStage1: int32 = tooling_compileBackendDriverStrictInmemWitness(
        root, stage0, target, result.stage1Path, timeoutSec, allowBootstrapCapabilityRefresh)
    let stage1Ms: int64 = tooling_nowMs() - stage1StartedMs
    result.stage1CompileMs = stage1Ms
    result.stage1CompileAttempts = 1
    if rcStage1 != 0:
        result.totalMs = tooling_nowMs() - startedMs
        result.message = "selfhost_strict_inmem_witness stage1 compile failed rc=" +
                         intToStr(rcStage1) + " kind=" + tooling_exitKind(rcStage1)
        tooling_selfhostWriteTiming(root, outDir, timingOut, "fail", stage1Ms,
                                    "skip", int64(0), "skip", int64(0),
                                    "skip", int64(0), "fail", result.totalMs)
        return result
    result.ok = true
    result.message = tooling_textLiteral("ok")
    result.stage1Status = tooling_textLiteral("rebuild")
    result.stage1RebuildOk = true
    result.strictRebuildOk = true
    result.totalMs = tooling_nowMs() - startedMs
    tooling_selfhostWriteTiming(root, outDir, timingOut, "rebuild", stage1Ms,
                                "skip", int64(0), "skip", int64(0),
                                "skip", int64(0), "ok", result.totalMs)
    result.lockWaitMs = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_LOCK_WAIT_MS", ""), 0)
    return result

fn tooling_selfhostStrictWriteMismatchDiagnostics(root: str, outDirRaw: str,
                                                  stage2PathRaw: str, stage3PathRaw: str,
                                                  stage2Sha: str, stage3Sha: str): str =
    let outDir: str = tooling_pathAbsolute(root, outDirRaw)
    let stage2Path: str = tooling_pathAbsolute(root, stage2PathRaw)
    let stage3Path: str = tooling_pathAbsolute(root, stage3PathRaw)
    if !tooling_strNonEmpty(outDir) || !tooling_strNonEmpty(stage2Path) || !tooling_strNonEmpty(stage3Path):
        return ""
    let diagDir: str = os.joinPath(outDir, "strict_mismatch")
    tooling_tryMkdirP(root, diagDir)
    let summaryPath: str = os.joinPath(diagDir, "summary.env")
    let bytesDiffPath: str = os.joinPath(diagDir, "bytes.diff.txt")
    let stage2SymPath: str = os.joinPath(diagDir, "stage2.symbols.txt")
    let stage3SymPath: str = os.joinPath(diagDir, "stage3.symbols.txt")
    let symbolsDiffPath: str = os.joinPath(diagDir, "symbols.diff.txt")
    let stage2StringsPath: str = os.joinPath(diagDir, "stage2.strings.txt")
    let stage3StringsPath: str = os.joinPath(diagDir, "stage3.strings.txt")
    let stringsDiffPath: str = os.joinPath(diagDir, "strings.diff.txt")
    let _cmpRes: os.ExecCmdResult = tooling_exec(
        root,
        "if command -v cmp >/dev/null 2>&1; then " +
            "cmp -l " + tooling_shellQuote(stage2Path) + " " + tooling_shellQuote(stage3Path) +
            " | head -n 200 > " + tooling_shellQuote(bytesDiffPath) + "; " +
            "else : > " + tooling_shellQuote(bytesDiffPath) + "; fi")
    let _symbolRes: os.ExecCmdResult = tooling_exec(
        root,
        "if command -v nm >/dev/null 2>&1; then " +
            "nm -nm " + tooling_shellQuote(stage2Path) + " > " + tooling_shellQuote(stage2SymPath) + " 2>/dev/null || true; " +
            "nm -nm " + tooling_shellQuote(stage3Path) + " > " + tooling_shellQuote(stage3SymPath) + " 2>/dev/null || true; " +
            "diff -u " + tooling_shellQuote(stage2SymPath) + " " + tooling_shellQuote(stage3SymPath) +
            " > " + tooling_shellQuote(symbolsDiffPath) + " 2>/dev/null || true; " +
            "else : > " + tooling_shellQuote(symbolsDiffPath) + "; fi")
    let _stringsRes: os.ExecCmdResult = tooling_exec(
        root,
        "if command -v strings >/dev/null 2>&1; then " +
            "strings " + tooling_shellQuote(stage2Path) + " > " + tooling_shellQuote(stage2StringsPath) + " 2>/dev/null || true; " +
            "strings " + tooling_shellQuote(stage3Path) + " > " + tooling_shellQuote(stage3StringsPath) + " 2>/dev/null || true; " +
            "diff -u " + tooling_shellQuote(stage2StringsPath) + " " + tooling_shellQuote(stage3StringsPath) +
            " > " + tooling_shellQuote(stringsDiffPath) + " 2>/dev/null || true; " +
            "else : > " + tooling_shellQuote(stringsDiffPath) + "; fi")
    let _summaryWriteOk: bool = tooling_writeTextFileViaShell(
        root,
        summaryPath,
        "strict_mismatch_report_version=1\n" +
            "stage2_path=" + stage2Path + "\n" +
            "stage3_path=" + stage3Path + "\n" +
            "stage2_sha256=" + stage2Sha + "\n" +
            "stage3_sha256=" + stage3Sha + "\n" +
            "bytes_diff=" + bytesDiffPath + "\n" +
            "symbols_diff=" + symbolsDiffPath + "\n" +
            "strings_diff=" + stringsDiffPath + "\n")
    return summaryPath

fn tooling_selfhostBootstrapStrictHost(root: str, outDirRaw: str, timingOutRaw: str,
                                       allowBootstrapCapabilityRefresh: bool): ToolingSelfhostResult =
    var result: ToolingSelfhostResult = nil
    new(result)
    result.ok = false
    result.message = tooling_textLiteral("")
    result.totalMs = int64(0)
    result.mode = tooling_textLiteral("strict")
    result.stage1Path = tooling_textLiteral("")
    result.stage2Path = tooling_textLiteral("")
    result.stage3Path = tooling_textLiteral("")
    result.stage0Path = tooling_textLiteral("")
    result.stage0DriverKind = tooling_textLiteral("unknown")
    result.stage1Status = tooling_textLiteral("init")
    result.stage1CompileMode = tooling_textLiteral("full")
    result.stage1RebuildOk = false
    result.fallbackUsed = false
    result.quarantineCleaned = 0
    result.lockWaitMs = 0
    result.strictRebuildOk = false
    result.stage2Sha256 = tooling_textLiteral("")
    result.stage3Sha256 = tooling_textLiteral("")
    result.fixedPointOk = false
    result.strictMismatchReport = tooling_textLiteral("")
    result.stage1CompileMs = int64(0)
    result.stage1SanityMs = int64(0)
    result.stage1CompileAttempts = 0
    result.stage1CompileSegfaults = 0

    let hostTag: str = tooling_detectHostTag(root)
    if !tooling_strEq(hostTag, "darwin_arm64"):
        result.message = "selfhost_strict_host unsupported host: " + hostTag
        return result
    let target: str = tooling_detectHostTarget(root)
    if !tooling_strNonEmpty(target):
        result.message = "selfhost_strict_host failed to resolve host target"
        return result
    result.quarantineCleaned = tooling_stage0QuarantineSweepUe(root, "selfhost_strict_host")
    if tooling_stage0BlockOnQuarantineUe(root, "TOOLING_SELFHOST_BLOCK_ON_UE", "selfhost_strict_host"):
        result.message = "selfhost_strict_host blocked by quarantine stuck/orphan processes"
        return result

    let stage0: str = tooling_resolveStage0DriverStrict(root, "")
    if !tooling_strNonEmpty(stage0):
        result.message = "selfhost_strict_host missing stage0 driver"
        return result
    result.stage0Path = stage0
    result.stage0DriverKind = tooling_stage0DriverKind(root, stage0)

    var outDir: str = tooling_pathAbsolute(
        root, tooling_nonEmptyDefault(outDirRaw, "artifacts/backend_selfhost_self_obj"))
    if !tooling_mkdirP(root, outDir):
        result.message = "selfhost_strict_host failed to create out dir: " + outDir
        return result
    result.stage1Path = os.joinPath(outDir, "cheng.stage1")
    result.stage2Path = os.joinPath(outDir, "cheng.stage2")
    result.stage3Path = os.joinPath(outDir, "cheng.stage3.witness")
    let stage3BuildDir: str = os.joinPath(outDir, ".strict_stage3_build")
    let stage3BuildPath: str = os.joinPath(stage3BuildDir, "cheng.stage2")

    let strictDiagAllowMismatch: bool = tooling_isTrue(
        os.getEnvDefault("SELF_OBJ_BOOTSTRAP_STRICT_DIAG_ALLOW_MISMATCH", "0"))
    let strictForceProbeOnFull: bool = tooling_isTrue(
        os.getEnvDefault("SELF_OBJ_BOOTSTRAP_STRICT_FORCE_PROBE", "0"))
    let strictSkipSem: str = tooling_textLiteral("0")
    let strictSkipOwnership: str = tooling_textLiteral("0")
    let strictLinkerMode: str = tooling_buildDriverEffectiveLinkerMode(
        tooling_buildDriverStrictNativeEnabled())

    let startedMs: int64 = tooling_nowMs()
    var stage1Ms: int64 = int64(0)
    var stage2Ms: int64 = int64(0)
    var stage3Ms: int64 = int64(0)
    var hashMs: int64 = int64(0)
    var stage1Status: str = tooling_textLiteral("fail")
    var stage2Status: str = tooling_textLiteral("skip")
    var stage3Status: str = tooling_textLiteral("skip")
    var hashStatus: str = tooling_textLiteral("skip")

    let stage1StartedMs: int64 = tooling_nowMs()
    let rcStage1: int32 = tooling_compileBackendDriverFastHostWithRebuildPolicy(
        root, stage0, target, result.stage1Path, true, strictSkipSem, strictSkipOwnership,
        allowBootstrapCapabilityRefresh)
    stage1Ms = tooling_nowMs() - stage1StartedMs
    if rcStage1 != 0:
        result.message = "selfhost_strict_host stage1 compile failed rc=" + intToStr(rcStage1) +
                         " kind=" + tooling_exitKind(rcStage1)
        let totalFail1: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail1
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail1)
        return result
    if !tooling_driverBuildOutputOk(root, result.stage1Path, "full", false, strictForceProbeOnFull,
                                    strictLinkerMode):
        result.message = "selfhost_strict_host stage1 output sanity failed"
        let totalFail1Sanity: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail1Sanity
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail1Sanity)
        return result
    stage1Status = tooling_textLiteral("rebuild")
    result.stage1Status = tooling_textLiteral("rebuild")
    result.stage1CompileMode = tooling_textLiteral("full")
    result.stage1RebuildOk = true
    result.strictRebuildOk = true

    let stage2StartedMs: int64 = tooling_nowMs()
    let rcStage2: int32 = tooling_compileBackendDriverFastHostWithRebuildPolicy(
        root, result.stage1Path, target, result.stage2Path, true, strictSkipSem, strictSkipOwnership,
        false)
    stage2Ms = tooling_nowMs() - stage2StartedMs
    if rcStage2 != 0:
        stage2Status = tooling_textLiteral("fail")
        result.message = "selfhost_strict_host stage2 compile failed rc=" + intToStr(rcStage2) +
                         " kind=" + tooling_exitKind(rcStage2)
        let totalFail2: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail2
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail2)
        return result
    if !tooling_driverBuildOutputOk(root, result.stage2Path, "full", false, strictForceProbeOnFull,
                                    strictLinkerMode):
        stage2Status = tooling_textLiteral("fail")
        result.message = "selfhost_strict_host stage2 output sanity failed"
        let totalFail2Sanity: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail2Sanity
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail2Sanity)
        return result
    stage2Status = tooling_textLiteral("rebuild")

    tooling_tryMkdirP(root, stage3BuildDir)
    let stage3StartedMs: int64 = tooling_nowMs()
    let rcStage3: int32 = tooling_compileBackendDriverFastHostWithRebuildPolicy(
        root, result.stage2Path, target, stage3BuildPath, true, strictSkipSem, strictSkipOwnership,
        false)
    stage3Ms = tooling_nowMs() - stage3StartedMs
    if rcStage3 != 0:
        stage3Status = tooling_textLiteral("fail")
        result.message = "selfhost_strict_host stage3 witness compile failed rc=" + intToStr(rcStage3) +
                         " kind=" + tooling_exitKind(rcStage3)
        let totalFail3: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail3
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail3)
        return result
    if !tooling_driverBuildOutputOk(root, stage3BuildPath, "full", false, strictForceProbeOnFull,
                                    strictLinkerMode):
        stage3Status = tooling_textLiteral("fail")
        result.message = "selfhost_strict_host stage3 witness output sanity failed"
        let totalFail3Sanity: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail3Sanity
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail3Sanity)
        return result
    if !tooling_copyExecutablePreserveBytes(root, stage3BuildPath, result.stage3Path):
        stage3Status = tooling_textLiteral("fail")
        result.message = "selfhost_strict_host stage3 witness copy failed"
        let totalFail3Copy: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalFail3Copy
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalFail3Copy)
        return result
    stage3Status = tooling_textLiteral("rebuild")

    let hashStartedMs: int64 = tooling_nowMs()
    result.stage2Sha256 = tooling_sha256File(root, result.stage2Path)
    result.stage3Sha256 = tooling_sha256File(root, result.stage3Path)
    hashMs = tooling_nowMs() - hashStartedMs
    if !tooling_strNonEmpty(result.stage2Sha256) || !tooling_strNonEmpty(result.stage3Sha256):
        hashStatus = tooling_textLiteral("fail")
        result.message = "selfhost_strict_host requires SHA-256 tool (shasum or sha256sum)"
        let totalHashFail: int64 = tooling_nowMs() - startedMs
        result.totalMs = totalHashFail
        tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                    stage2Status, stage2Ms, stage3Status, stage3Ms,
                                    hashStatus, hashMs, "fail", totalHashFail)
        return result

    result.fixedPointOk = tooling_strEq(result.stage2Sha256, result.stage3Sha256)
    if result.fixedPointOk:
        hashStatus = tooling_textLiteral("ok")
        result.message = tooling_textLiteral("ok")
        result.ok = true
    else:
        hashStatus = tooling_textLiteral("mismatch")
        result.strictMismatchReport = tooling_selfhostStrictWriteMismatchDiagnostics(
            root, outDir, result.stage2Path, result.stage3Path, result.stage2Sha256, result.stage3Sha256)
        if strictDiagAllowMismatch:
            result.ok = true
            result.message = "selfhost_strict_host fixed-point mismatch allowed by SELF_OBJ_BOOTSTRAP_STRICT_DIAG_ALLOW_MISMATCH=1"
            if tooling_strNonEmpty(result.strictMismatchReport):
                result.message = result.message + " report=" + result.strictMismatchReport
        else:
            result.ok = false
            result.message = "selfhost_strict_host fixed-point mismatch stage2=" + result.stage2Sha256 +
                             " stage3=" + result.stage3Sha256 +
                             " stage2_path=" + result.stage2Path +
                             " stage3_path=" + result.stage3Path
            if tooling_strNonEmpty(result.strictMismatchReport):
                result.message = result.message + " report=" + result.strictMismatchReport
    let totalMs: int64 = tooling_nowMs() - startedMs
    result.totalMs = totalMs
    tooling_selfhostWriteTiming(root, outDir, timingOutRaw, stage1Status, stage1Ms,
                                stage2Status, stage2Ms, stage3Status, stage3Ms,
                                hashStatus, hashMs, tooling_statusOkFail(result.ok), totalMs)
    result.lockWaitMs = tooling_parseInt32Default(os.getEnvDefault("TOOLING_STAGE0_LOCK_WAIT_MS", ""), 0)
    return result

fn tooling_selfhostInnerLoop(root: str, outDirRaw: str, timingOutRaw: str,
                             runInmemWitness: bool, runStrict: bool,
                             runClosure: bool): ToolingSelfhostInnerLoopResult =
    var result: ToolingSelfhostInnerLoopResult = nil
    new(result)
    result.ok = false
    result.message = tooling_textLiteral("")
    result.totalMs = int64(0)
    result.outDir = tooling_pathAbsolute(
        root, tooling_nonEmptyDefault(outDirRaw, "artifacts/backend_selfhost_inner_loop"))
    result.summaryPath = os.joinPath(result.outDir, "selfhost_inner_loop.summary.env")
    result.timingPath = tooling_pathAbsolute(
        root, tooling_nonEmptyDefault(timingOutRaw, os.joinPath(result.outDir, "selfhost_inner_loop_timing.tsv")))
    result.buildDriverPath = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    result.buildMs = int64(0)
    result.buildRc = 1
    result.inmemRequested = runInmemWitness
    result.inmemMs = int64(0)
    result.inmemRes = nil
    result.strictRequested = runStrict
    result.strictMs = int64(0)
    result.strictRes = nil
    result.closureRequested = runClosure
    result.closureMs = int64(0)
    result.closureRc = 0
    result.failedStep = tooling_textLiteral("")
    if !tooling_mkdirP(root, result.outDir):
        result.message = "selfhost_inner_loop failed to create out dir: " + result.outDir
        result.failedStep = "setup"
        return result

    let startedMs: int64 = tooling_nowMs()
    var buildOk: bool = false
    var inmemOk: bool = false
    var strictOk: bool = false
    var closureOk: bool = false

    let buildStartedMs: int64 = tooling_nowMs()
    let buildRc: int32 = tooling_cmdBuildBackendDriver(
        root, result.buildDriverPath, "", "", true, false, "seal")
    result.buildMs = tooling_nowMs() - buildStartedMs
    result.buildRc = buildRc
    if buildRc != 0:
        result.message = "selfhost_inner_loop build-backend-driver failed rc=" + intToStr(buildRc)
        result.failedStep = "build_driver"
        result.totalMs = tooling_nowMs() - startedMs
        tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                             tooling_statusOkFail(buildOk), result.buildMs,
                                             tooling_statusSkipOkFail(runInmemWitness, inmemOk), result.inmemMs,
                                             tooling_statusSkipOkFail(runStrict, strictOk), result.strictMs,
                                             tooling_statusSkipOkFail(runClosure, closureOk), result.closureMs,
                                             tooling_statusOkFail(false), result.totalMs)
        result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
        return result
    buildOk = true

    if runInmemWitness:
        let inmemOutDir: str = os.joinPath(result.outDir, "inmem_witness")
        let inmemTimingPath: str = os.joinPath(inmemOutDir, "selfhost_inmem_witness_timing_native.tsv")
        let inmemStartedMs: int64 = tooling_nowMs()
        result.inmemRes = tooling_selfhostStrictInmemWitnessHost(root, inmemOutDir, inmemTimingPath, false)
        result.inmemMs = tooling_nowMs() - inmemStartedMs
        let inmemRes: ToolingSelfhostResult = result.inmemRes
        if inmemRes == nil || !inmemRes.ok:
            result.message = "selfhost_inner_loop inmem witness failed"
            if inmemRes != nil && tooling_strNonEmpty(inmemRes.message):
                result.message = inmemRes.message
            if !tooling_strNonEmpty(result.message):
                result.message = "selfhost_inner_loop inmem witness failed"
            result.failedStep = "inmem_witness"
            result.totalMs = tooling_nowMs() - startedMs
            tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                                 tooling_statusOkFail(buildOk), result.buildMs,
                                                 tooling_statusSkipOkFail(runInmemWitness, inmemOk), result.inmemMs,
                                                 tooling_statusSkipOkFail(runStrict, strictOk), result.strictMs,
                                                 tooling_statusSkipOkFail(runClosure, closureOk), result.closureMs,
                                                 tooling_statusOkFail(false), result.totalMs)
            result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
            return result
        inmemOk = true

    if runStrict:
        let strictOutDir: str = os.joinPath(result.outDir, "strict_host")
        let strictTimingPath: str = os.joinPath(strictOutDir, "selfhost_timing_native.tsv")
        let strictStartedMs: int64 = tooling_nowMs()
        result.strictRes = tooling_selfhostBootstrapStrictHost(root, strictOutDir, strictTimingPath, false)
        result.strictMs = tooling_nowMs() - strictStartedMs
        let strictRes: ToolingSelfhostResult = result.strictRes
        if strictRes == nil || !strictRes.ok:
            result.message = "selfhost_inner_loop strict host failed"
            if strictRes != nil && tooling_strNonEmpty(strictRes.message):
                result.message = strictRes.message
            if !tooling_strNonEmpty(result.message):
                result.message = "selfhost_inner_loop strict host failed"
            result.failedStep = "strict_host"
            result.totalMs = tooling_nowMs() - startedMs
            tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                                 tooling_statusOkFail(buildOk), result.buildMs,
                                                 tooling_statusSkipOkFail(runInmemWitness, inmemOk), result.inmemMs,
                                                 tooling_statusSkipOkFail(runStrict, strictOk), result.strictMs,
                                                 tooling_statusSkipOkFail(runClosure, closureOk), result.closureMs,
                                                 tooling_statusOkFail(false), result.totalMs)
            result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
            return result
        strictOk = true

    if runClosure:
        let closureStartedMs: int64 = tooling_nowMs()
        result.closureRc = tooling_cmdBackendProdClosureFromArgs(root, 1, 0)
        result.closureMs = tooling_nowMs() - closureStartedMs
        if result.closureRc != 0:
            result.message = "selfhost_inner_loop backend_prod_closure failed rc=" + intToStr(result.closureRc)
            result.failedStep = "closure"
            result.totalMs = tooling_nowMs() - startedMs
            tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                                 tooling_statusOkFail(buildOk), result.buildMs,
                                                 tooling_statusSkipOkFail(runInmemWitness, inmemOk), result.inmemMs,
                                                 tooling_statusSkipOkFail(runStrict, strictOk), result.strictMs,
                                                 tooling_statusSkipOkFail(runClosure, closureOk), result.closureMs,
                                                 tooling_statusOkFail(false), result.totalMs)
            result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
            return result
        closureOk = true

    result.ok = true
    result.message = tooling_textLiteral("ok")
    result.failedStep = tooling_textLiteral("")
    result.totalMs = tooling_nowMs() - startedMs
    tooling_selfhostInnerLoopWriteTiming(root, result.outDir, result.timingPath,
                                         tooling_statusOkFail(buildOk), result.buildMs,
                                         tooling_statusSkipOkFail(runInmemWitness, inmemOk), result.inmemMs,
                                         tooling_statusSkipOkFail(runStrict, strictOk), result.strictMs,
                                         tooling_statusSkipOkFail(runClosure, closureOk), result.closureMs,
                                         tooling_statusOkFail(true), result.totalMs)
    result.summaryPath = tooling_selfhostInnerLoopWriteSummary(root, result)
    return result

fn tooling_sortInt32Asc(values: int32[]): int32[] =
    var out: int32[] = []
    if values.len > 0:
        reserve(out, values.len)
        setLen(out, values.len)
    for i in 0..<values.len:
        out[i] = values[i]
    for i in 1..<out.len:
        let key: int32 = out[i]
        var j: int32 = i - 1
        while j >= 0:
            if out[j] <= key:
                break
            out[j + 1] = out[j]
            j = j - 1
        out[j + 1] = key
    return out

fn toolingAppendInt32(seqInst: var int32[], val: int32) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn tooling_pickPercentile(sorted: int32[], pct: int32): int32 =
    if sorted.len <= 0:
        return -1
    var k: int32 = (pct * sorted.len + 99) / 100
    if k < 1:
        k = 1
    if k > sorted.len:
        k = sorted.len
    return sorted[k - 1]

fn tooling_pickPercentileNoSort(values: int32[], pct: int32): int32 =
    if values.len <= 0:
        return -1
    var k: int32 = (pct * values.len + 99) / 100
    if k < 1:
        k = 1
    if k > values.len:
        k = values.len
    var best: int32 = 0
    var bestSet: bool = false
    for i in 0..<values.len:
        let cand: int32 = values[i]
        var lessCnt: int32 = 0
        var lessEqCnt: int32 = 0
        for j in 0..<values.len:
            let v: int32 = values[j]
            if v < cand:
                lessCnt = lessCnt + 1
            if v <= cand:
                lessEqCnt = lessEqCnt + 1
        if lessCnt < k && k <= lessEqCnt:
            if !bestSet || cand < best:
                best = cand
                bestSet = true
    if bestSet:
        return best
    var fallbackMax: int32 = values[0]
    for i in 1..<values.len:
        if values[i] > fallbackMax:
            fallbackMax = values[i]
    return fallbackMax

fn tooling_backendDriverHistoryKeep(name: str): bool =
    if tooling_strEq(name, "cheng"):
        return true
    if tooling_strEq(name, "cheng.full_rebuild.stamp.env"):
        return true
    if tooling_strEq(name, "cheng.objs"):
        return true
    if tooling_strEq(name, "cheng.objs.lock"):
        return true
    return false

fn tooling_cmdCleanupBackendDriverHistory(root: str, dryRun: bool): int32 =
    let backendDir: str = os.joinPath(root, "artifacts/backend_driver")
    if !os.dirExists(backendDir):
        tooling_printOut("cleanup_backend_driver_history_status=noop")
        tooling_printOut("cleanup_backend_driver_history_dir_missing=" + backendDir)
        return 0
    let scanRes: os.ExecCmdResult = tooling_exec(
        root,
        "find " + tooling_shellQuote(backendDir) + " -maxdepth 1 -mindepth 1 -name 'cheng*' -print")
    let scanRc: int32 = os.execCmdResultExitCode(scanRes)
    if scanRc != 0:
        tooling_printErr("cheng_tooling: cleanup_backend_driver_history scan failed")
        tooling_printExecOutput(scanRes)
        return scanRc
    let rows: str[] = tooling_splitLines(os.execCmdResultOutput(scanRes))
    var removedCount: int32 = 0
    var keepCount: int32 = 0
    var scannedCount: int32 = 0
    for i in 0..<rows.len:
        let path: str = strutil.strip(rows[i])
        if !tooling_strNonEmpty(path):
            continue
        scannedCount = scannedCount + 1
        let base: str = os.extractFilename(path)
        if tooling_backendDriverHistoryKeep(base):
            keepCount = keepCount + 1
            continue
        removedCount = removedCount + 1
        if dryRun:
            tooling_printOut("cleanup_backend_driver_history_plan_remove=" + path)
            continue
        let rmRes: os.ExecCmdResult = tooling_exec(root, "rm -rf " + tooling_shellQuote(path))
        let rmRc: int32 = os.execCmdResultExitCode(rmRes)
        if rmRc != 0:
            tooling_printErr("cheng_tooling: cleanup_backend_driver_history remove failed: " + path)
            tooling_printExecOutput(rmRes)
            return rmRc
    tooling_printOut("cleanup_backend_driver_history_scanned=" + intToStr(scannedCount))
    tooling_printOut("cleanup_backend_driver_history_kept=" + intToStr(keepCount))
    tooling_printOut("cleanup_backend_driver_history_removed=" + intToStr(removedCount))
    if dryRun:
        tooling_printOut("cleanup_backend_driver_history_dry_run=1")
    else:
        tooling_printOut("cleanup_backend_driver_history_dry_run=0")
    return 0

fn tooling_cmdToolchainRoot(root: str): int32 =
    tooling_printOut("toolchain_root=" + os.absolutePath(root))
    return 0

fn tooling_cmdDetectHostTarget(root: str): int32 =
    let target: str = tooling_detectHostTarget(root)
    if tooling_strNonEmpty(target):
        tooling_printOut(target)
        return 0
    tooling_printErr("cheng_tooling: failed to detect host target")
    return 1

fn tooling_cmdDriverPath(root: str, pathOnly: bool): int32 =
    let stage0: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    if !tooling_isExecutable(root, stage0):
        tooling_printErr("cheng_tooling: canonical stage0 driver missing: " + stage0)
        return 1
    if tooling_stage0BlockStamped(root, stage0):
        tooling_printErr("cheng_tooling: canonical stage0 driver blocked by quarantine stamp: " + stage0)
        tooling_printErr("cheng_tooling: cut off invocation chain to prevent new UE; rebuild/replace canonical driver")
        return 2
    if !tooling_driverSanityOk(root, stage0):
        tooling_printErr("cheng_tooling: canonical stage0 driver failed sanity: " + stage0)
        tooling_printErr("cheng_tooling: cut off invocation chain to prevent new UE; replace driver before retry")
        return 2
    if tooling_stage0HasUninterruptibleProcess(root, stage0):
        tooling_printErr("cheng_tooling: canonical stage0 driver blocked by stuck/orphan UE process: " + stage0)
        tooling_printErr("cheng_tooling: cut off invocation chain to prevent new UE; replace driver before retry")
        return 2
    if pathOnly:
        tooling_printOut(stage0)
        return 0
    let stage0Sha: str = tooling_sha256File(root, stage0)
    tooling_printOut("toolchain_root=" + os.absolutePath(root))
    tooling_printOut("driver_path=" + stage0)
    tooling_printOut("driver_sha256=" + stage0Sha)
    tooling_printOut("driver_kind=canonical")
    return 0

fn tooling_cmdCleanupBackendDriverHistoryFromArgs(root: str, firstArgIndex: int32, count: int32): int32 =
    var dryRun: bool = false
    var i: int32 = firstArgIndex
    if i < 1:
        i = 1
    for _ in i..count:
        if i > count:
            break
        let arg: str = tooling_paramStr(i)
        if tooling_strEq(arg, "--help") || tooling_strEq(arg, "-h"):
            tooling_printOut("cleanup-backend-driver-history options:")
            tooling_printOut("  --dry-run                   print files to remove, no write")
            return 0
        if tooling_strEq(arg, "--dry-run"):
            dryRun = true
            i = i + 1
            continue
        tooling_printErr("cheng_tooling: unknown cleanup-backend-driver-history arg: " + arg)
        return 1
    return tooling_cmdCleanupBackendDriverHistory(root, dryRun)

fn tooling_cmdBuildBackendDriverWithArgsMode(root: str, args: ToolingBuildDriverArgsState,
                                             applyCompatEnv: bool): int32 =
    let allowBootstrapCapabilityRefresh: bool = tooling_isTrue(
        os.getEnvDefault("BOOTSTRAP_UPDATE_SEED", "0"))
    let target: str = tooling_buildDriverResolvedTarget(root, args.target)
    if !tooling_strNonEmpty(target):
        tooling_printErr("cheng_tooling: failed to detect target")
        return 1
    var attemptSweepCleaned: int32 = tooling_backendDriverSweepAttemptOrphans(root, "build_backend_driver.pre")
    tooling_printOut("build_backend_driver_attempt_cleaned_pre=" + intToStr(attemptSweepCleaned))
    if !tooling_stage0QuarantineEnabled() &&
       tooling_stage0BlockOnQuarantineUe(root, "TOOLING_BUILD_DRIVER_BLOCK_ON_UE", "build_backend_driver"):
        return 1
    let stage0ProbeEnabled: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_STAGE0_PROBE", "0"))
    var stage0Candidates: str[] = tooling_stage0CandidateListWithProbe(root, args.stage0, stage0ProbeEnabled)
    let preferredStage0: str = tooling_buildBackendDriverPreferredStage0(root, stage0ProbeEnabled)
    if tooling_strNonEmpty(preferredStage0) && !tooling_idsContains(stage0Candidates, preferredStage0):
        var preferredCandidates: str[] = []
        add(preferredCandidates, preferredStage0)
        for pi in 0..<stage0Candidates.len:
            if !tooling_strEq(stage0Candidates[pi], preferredStage0):
                add(preferredCandidates, stage0Candidates[pi])
        stage0Candidates = preferredCandidates
    if tooling_isTrue(os.getEnvDefault("TOOLING_BUILD_DRIVER_DIST_RECOVERY", "0")):
        tooling_printErr("cheng_tooling: ignore removed env TOOLING_BUILD_DRIVER_DIST_RECOVERY (single canonical driver only)")
    if stage0Candidates.len <= 0:
        tooling_printErr("cheng_tooling: stage0 driver not found")
        return 1
    let outPath: str = tooling_buildDriverOutPath(root, args.outPath)
    let canonicalDriverPath: str = tooling_pathAbsolute(root, "artifacts/backend_driver/cheng")
    let autoCleanHistory: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_AUTO_CLEAN_HISTORY", "1"))
    let buildMode: str = tooling_buildDriverRequestedMode(args.modeRaw, args.requireRebuild, args.debugRebuild)
    if !tooling_strNonEmpty(buildMode):
        tooling_printErr("cheng_tooling: invalid build-backend-driver mode: " + args.modeRaw + " (expected auto|fast|seal)")
        return 2
    let fullRebuild: bool = tooling_strEq(buildMode, "seal")
    if applyCompatEnv:
        tooling_buildDriverArgsApplyCompatEnv(args, fullRebuild)
    let compileProfile: ToolingBuildDriverCompileProfile = tooling_buildDriverCompileProfileResolved(
        root, args, fullRebuild, "build-backend-driver")
    if compileProfile == nil:
        return 2
    let compileMode: str = tooling_buildDriverCompileModeText(fullRebuild)
    let strictNative: bool = tooling_buildDriverEffectiveStrictNativeForRebuild(fullRebuild)
    let buildLinkerMode: str = tooling_buildDriverEffectiveLinkerMode(strictNative)
    let allowFallback: bool = tooling_buildDriverAllowFallbackEnabled()
    let quickLightSanity: bool = !fullRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_QUICK_LIGHT_SANITY", "1"))
    let forceProbeDefault: str = tooling_boolText(strictNative)
    let forceProbeOnFull: bool = tooling_isTrue(
        os.getEnvDefault("BACKEND_BUILD_DRIVER_FULL_FORCE_PROBE", forceProbeDefault))
    let noRecover: bool = !allowFallback || tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_NO_RECOVER", "1"))
    let eagerRebuild: bool = tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_EAGER_REBUILD", "0"))
    let directFastReuse: bool = !fullRebuild && !args.requireRebuild && !args.debugRebuild && !eagerRebuild &&
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_FAST_REUSE", "1"))
    tooling_printOut("build_backend_driver_mode=" + buildMode)
    if directFastReuse:
        let existingOkFast: bool = tooling_buildDriverDirectFastReuseOk(
            root, outPath, target, buildLinkerMode, quickLightSanity, compileProfile)
        if existingOkFast:
            let _clearedReuseFast: int32 =
                tooling_stage0ClearStamps(root, outPath, "build_backend_driver.reuse_existing")
            tooling_printOut("build_backend_driver_compile_mode=" + compileMode)
            tooling_printOut("build_backend_driver_rebuilt=0")
            tooling_printOut("build_backend_driver_fallback_used=0")
            tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
            tooling_printOut("build_backend_driver_fast_path=reuse_existing")
            tooling_printOut("build_backend_driver_ok=" + outPath)
            if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                let cleanRcFast: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                if cleanRcFast != 0:
                    return cleanRcFast
            return 0
        let existingOkAfterReject: bool =
            tooling_buildDriverFastCanonicalRejectHit(root, outPath, target, compileProfile.sourcePath) &&
            tooling_driverBuildOutputOk(root, outPath, compileMode, quickLightSanity, false, buildLinkerMode)
        if existingOkAfterReject:
            let _clearedReuseAfterReject: int32 =
                tooling_stage0ClearStamps(root, outPath, "build_backend_driver.reuse_existing_after_reject")
            tooling_printOut("build_backend_driver_compile_mode=" + compileMode)
            tooling_printOut("build_backend_driver_rebuilt=0")
            tooling_printOut("build_backend_driver_fallback_used=0")
            tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
            tooling_printOut("build_backend_driver_fast_path=reuse_existing_after_source_reject")
            tooling_printOut("build_backend_driver_ok=" + outPath)
            if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                let cleanRcFastReject: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                if cleanRcFastReject != 0:
                    return cleanRcFastReject
            return 0
    var stage0AttemptCandidates: str[] = stage0Candidates
    var attemptCount: int32 = stage0AttemptCandidates.len
    var maxStage0Attempts: int32 = tooling_parseInt32Default(os.getEnvDefault("BACKEND_BUILD_DRIVER_MAX_STAGE0_ATTEMPTS", ""), 0)
    if maxStage0Attempts < 0:
        maxStage0Attempts = 0
    if maxStage0Attempts > 0 && maxStage0Attempts < attemptCount:
        attemptCount = maxStage0Attempts
    let debugRebuildEnabled: bool = args.debugRebuild ||
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_DEBUG_REBUILD", "0"))
    let keepFailedAttempt: bool = debugRebuildEnabled ||
        tooling_isTrue(os.getEnvDefault("BACKEND_BUILD_DRIVER_KEEP_FAILED_ATTEMPT", "0"))
    let debugDir: str = tooling_buildDriverDebugDir(root, debugRebuildEnabled)
    if debugRebuildEnabled:
        tooling_tryMkdirP(root, debugDir)
        let sessionPath: str = os.joinPath(debugDir, "session.env")
        if !tooling_writeTextFileViaShell(
            root,
            sessionPath,
            tooling_buildDriverDebugSessionMeta(buildMode, args.requireRebuild, target, outPath, attemptCount)):
            tooling_printErr("cheng_tooling: failed to write debug session meta: " + sessionPath)
        tooling_printOut("build_backend_driver_debug_dir=" + debugDir)
    var lastRc: int32 = 1
    var lastStage0Index: int32 = -1
    var sawCanonicalQuickSmokeFail: bool = false
    var i: int32 = 0
    while i < attemptCount:
        let stage0: str = stage0AttemptCandidates[i]
        let attemptFallbackUsed: bool = i > 0
        let attemptIndex: int32 = i + 1
        tooling_printErr("cheng_tooling: build_backend_driver stage0 attempt " + intToStr(attemptIndex) +
                         "/" + intToStr(attemptCount) + " driver=" + stage0)
        let persistentQuickCachePath: bool = !debugRebuildEnabled && !fullRebuild
        let attemptOutPath: str = tooling_buildDriverAttemptOutPath(
            root, outPath, attemptIndex, persistentQuickCachePath)
        if !persistentQuickCachePath:
            tooling_driverBuildTempCleanup(root, attemptOutPath)
        let attemptCompileMode: str = compileMode
        var rc: int32 = tooling_compileBackendDriverFastHostWithCompileProfile(
            root, stage0, target, attemptOutPath, fullRebuild, "", "",
            allowBootstrapCapabilityRefresh, compileProfile)
        var postBuildOk: bool = false
        var forceProbeThisAttempt: bool = fullRebuild && forceProbeOnFull
        var requireCanonicalQuickSmoke: bool = false
        var canonicalQuickSmokeFailed: bool = false
        if rc == 0:
            postBuildOk = tooling_driverBuildOutputOk(root, attemptOutPath, attemptCompileMode,
                                                      quickLightSanity, forceProbeThisAttempt,
                                                      buildLinkerMode)
            requireCanonicalQuickSmoke = postBuildOk &&
                tooling_buildDriverFastCanonicalSmokeEnabled(root, outPath, fullRebuild)
            if requireCanonicalQuickSmoke && !tooling_buildDriverFastCanonicalSmokeOk(root, attemptOutPath):
                canonicalQuickSmokeFailed = true
                sawCanonicalQuickSmokeFail = true
                postBuildOk = false
                tooling_stage0MarkBlocked(root, attemptOutPath, 1,
                                          "build_backend_driver_fast_canonical_smoke",
                                          "canonical_smoke")
                let _rejectWritten: bool =
                    tooling_buildDriverFastCanonicalRejectWrite(
                        root, outPath, target, compileProfile.sourcePath)
                tooling_printErr("cheng_tooling: fast canonical smoke rejected candidate: " + attemptOutPath)
        lastRc = rc
        if debugRebuildEnabled:
            tooling_buildDriverDebugAttemptRecord(debugDir, attemptIndex, stage0, attemptOutPath, rc,
                                                  postBuildOk, attemptCompileMode)
        if rc == 0 && postBuildOk:
            if debugRebuildEnabled:
                let _clearedDebugAttempt: int32 =
                    tooling_stage0ClearStamps(root, attemptOutPath, "build_backend_driver.debug_output")
                tooling_printErr("cheng_tooling: build-backend-driver debug-rebuild mode enabled; skip canonical install")
                tooling_printOut("build_backend_driver_compile_mode=" + attemptCompileMode)
                tooling_printOut("build_backend_driver_rebuilt=1")
                tooling_printOut("build_backend_driver_fallback_used=" + (attemptFallbackUsed ? "1" : "0"))
                tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
                tooling_printOut("build_backend_driver_debug_output=" + attemptOutPath)
                tooling_printOut("build_backend_driver_ok=" + attemptOutPath)
                return 0
            if !tooling_installExecutableAtomic(root, attemptOutPath, outPath):
                tooling_printErr("cheng_tooling: stage0 attempt output install failed: " + attemptOutPath)
                postBuildOk = false
            elif !tooling_installBuildDriverSidecars(root, attemptOutPath, outPath, fullRebuild):
                tooling_printErr("cheng_tooling: warning: build-backend-driver sidecar install incomplete: " + outPath)
            elif requireCanonicalQuickSmoke &&
                 !tooling_buildDriverFastCanonicalSmokeWrite(
                     root, outPath, target, compileProfile.sourcePath):
                tooling_printErr("cheng_tooling: warning: build-backend-driver fast canonical smoke proof write failed: " + outPath)
            if !persistentQuickCachePath:
                tooling_driverBuildTempCleanup(root, attemptOutPath)
        if rc == 0 && postBuildOk:
            let _clearedInstalledOut: int32 =
                tooling_stage0ClearStamps(root, outPath, "build_backend_driver.install_success")
            tooling_printOut("build_backend_driver_compile_mode=" + attemptCompileMode)
            tooling_printOut("build_backend_driver_rebuilt=1")
            tooling_printOut("build_backend_driver_fallback_used=" + (attemptFallbackUsed ? "1" : "0"))
            tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
            if requireCanonicalQuickSmoke:
                tooling_printOut("build_backend_driver_fast_path=installed_after_canonical_smoke")
            tooling_printOut("build_backend_driver_ok=" + outPath)
            if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                let cleanRc: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                if cleanRc != 0:
                    return cleanRc
            return 0
        if rc == 0 && !postBuildOk && !args.requireRebuild && !strictNative:
            let keepExistingOk: bool = tooling_driverBuildOutputOk(root, outPath, compileMode,
                                                                   quickLightSanity, false,
                                                                   buildLinkerMode)
            if keepExistingOk:
                let _clearedKeepExisting: int32 =
                    tooling_stage0ClearStamps(root, outPath, "build_backend_driver.keep_existing")
                tooling_printErr("cheng_tooling: rebuilt candidate failed sanity; keep existing canonical driver: " + outPath)
                tooling_printOut("build_backend_driver_compile_mode=" + attemptCompileMode)
                tooling_printOut("build_backend_driver_rebuilt=0")
                tooling_printOut("build_backend_driver_fallback_used=0")
                tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
                if canonicalQuickSmokeFailed:
                    tooling_printOut("build_backend_driver_fast_path=keep_existing_after_candidate_smoke_fail")
                tooling_printOut("build_backend_driver_last_stage0=" + stage0)
                tooling_printOut("build_backend_driver_last_rc=0")
                tooling_printOut("build_backend_driver_last_kind=ok")
                tooling_printOut("build_backend_driver_ok=" + outPath)
                if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                    let cleanRcKeep: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                    if cleanRcKeep != 0:
                        return cleanRcKeep
                return 0
        if !keepFailedAttempt:
            tooling_driverBuildTempCleanup(root, attemptOutPath)
        else:
            tooling_printErr("cheng_tooling: keep failed attempt artifact: " + attemptOutPath)
        if rc != 0:
            tooling_printErr("cheng_tooling: stage0 attempt failed rc=" + intToStr(rc) +
                             " kind=" + tooling_exitKind(rc) + " driver=" + stage0)
        else:
            tooling_printErr("cheng_tooling: stage0 attempt output sanity failed: " + stage0)
        let sweepAfterAttempt: int32 = tooling_backendDriverSweepAttemptOrphans(
            root, "build_backend_driver.attempt." + intToStr(attemptIndex))
        attemptSweepCleaned = attemptSweepCleaned + sweepAfterAttempt
        lastStage0Index = i
        i = i + 1
    if !args.requireRebuild && (!strictNative || sawCanonicalQuickSmokeFail):
        let keepExistingAfterFail: bool = tooling_driverBuildOutputOk(root, outPath, compileMode,
                                                                       quickLightSanity, false,
                                                                       buildLinkerMode)
        if keepExistingAfterFail:
            let _clearedKeepAfterFail: int32 =
                tooling_stage0ClearStamps(root, outPath, "build_backend_driver.keep_existing_after_fail")
            tooling_printErr("cheng_tooling: keep existing canonical driver after rebuild failure: " + outPath)
            tooling_printOut("build_backend_driver_compile_mode=" + compileMode)
            tooling_printOut("build_backend_driver_rebuilt=0")
            tooling_printOut("build_backend_driver_fallback_used=0")
            tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
            tooling_printOut("build_backend_driver_last_stage0=" + tooling_seqValueAtOrEmpty(stage0AttemptCandidates, lastStage0Index))
            tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
            tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
            tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
            if sawCanonicalQuickSmokeFail:
                tooling_printOut("build_backend_driver_fast_path=keep_existing_after_candidate_smoke_fail")
            tooling_printOut("build_backend_driver_ok=" + outPath)
            if autoCleanHistory && tooling_strEq(outPath, canonicalDriverPath) && fullRebuild:
                let cleanRcKeepExisting: int32 = tooling_cmdCleanupBackendDriverHistory(root, false)
                if cleanRcKeepExisting != 0:
                    return cleanRcKeepExisting
            return 0
    # Shim fallback removed.
    if args.requireRebuild:
        tooling_printErr("cheng_tooling: require-rebuild enabled; all stage0 attempts failed, stage0 reuse disabled")
        tooling_printOut("build_backend_driver_compile_mode=" + compileMode)
        tooling_printOut("build_backend_driver_rebuilt=0")
        tooling_printOut("build_backend_driver_fallback_used=0")
        tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
        tooling_printOut("build_backend_driver_last_stage0=" + tooling_seqValueAtOrEmpty(stage0AttemptCandidates, lastStage0Index))
        tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
        tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
        tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
        if lastRc != 0:
            return lastRc
        return 1
    if noRecover:
        tooling_printErr("cheng_tooling: build backend driver compile failed rc=" + intToStr(lastRc) +
                         " kind=" + tooling_exitKind(lastRc) + "; no-recover enabled, stage0 reuse disabled")
        tooling_printOut("build_backend_driver_compile_mode=" + compileMode)
        tooling_printOut("build_backend_driver_rebuilt=0")
        tooling_printOut("build_backend_driver_fallback_used=0")
        tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
        tooling_printOut("build_backend_driver_last_stage0=" + tooling_seqValueAtOrEmpty(stage0AttemptCandidates, lastStage0Index))
        tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
        tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
        tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
        tooling_printOut("build_backend_driver_ok=" + outPath)
        if lastRc != 0:
            return lastRc
        return 1
    tooling_printErr("cheng_tooling: build backend driver compile failed rc=" + intToStr(lastRc) +
                     " kind=" + tooling_exitKind(lastRc) + "; fallback removed")
    tooling_printOut("build_backend_driver_compile_mode=" + compileMode)
    tooling_printOut("build_backend_driver_rebuilt=0")
    tooling_printOut("build_backend_driver_fallback_used=0")
    tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
    tooling_printOut("build_backend_driver_last_stage0=" + tooling_seqValueAtOrEmpty(stage0AttemptCandidates, lastStage0Index))
    tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
    tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
    tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
    tooling_printOut("build_backend_driver_ok=" + outPath)
    if lastRc != 0:
        return lastRc
    return 1

fn tooling_cmdBuildBackendDriverWithArgs(root: str, args: ToolingBuildDriverArgsState): int32 =
    return tooling_cmdBuildBackendDriverWithArgsMode(root, args, false)

fn tooling_cmdBuildBackendDriverWithCompatArgs(root: str, args: ToolingBuildDriverArgsState): int32 =
    return tooling_cmdBuildBackendDriverWithArgsMode(root, args, true)

fn tooling_cmdBuildBackendDriver(root: str, outRaw: str, stage0Raw: str, targetRaw: str,
                                 requireRebuild: bool, debugRebuild: bool, modeRaw: str): int32 =
    if tooling_strNonEmpty(strutil.strip(stage0Raw)):
        tooling_printErr("cheng_tooling: build-backend-driver no longer accepts explicit stage0 override")
        return 2
    var args: ToolingBuildDriverArgsState = nil
    new(args)
    args.outPath = outRaw
    args.stage0 = stage0Raw
    args.target = targetRaw
    args.requireRebuild = requireRebuild
    args.debugRebuild = debugRebuild
    args.modeRaw = modeRaw
    return tooling_cmdBuildBackendDriverWithCompatArgs(root, args)
    tooling_printOut("build_backend_driver_fallback_used=0")
    tooling_printOut("build_backend_driver_strict_native=" + (strictNative ? "1" : "0"))
    if lastRc != 0:
        tooling_printOut("build_backend_driver_last_stage0=" + tooling_seqValueAtOrEmpty(stage0AttemptCandidates, lastStage0Index))
        tooling_printOut("build_backend_driver_last_rc=" + intToStr(lastRc))
        tooling_printOut("build_backend_driver_last_kind=" + tooling_exitKind(lastRc))
        tooling_printOut("build_backend_driver_attempt_cleaned=" + intToStr(attemptSweepCleaned))
        tooling_printErr("cheng_tooling: build backend driver failed rc=" + intToStr(lastRc))
        return lastRc
    tooling_printErr("cheng_tooling: build backend driver output sanity failed: " + outPath)
    return 1

fn tooling_cmdSelfhostBootstrapFastHost(root: str, compileStage1: bool, outDirRaw: str, timingOutRaw: str): int32 =
    let res: ToolingSelfhostResult = tooling_selfhostBootstrapFastHost(
        root, compileStage1, outDirRaw, timingOutRaw, false)
    if !res.ok:
        tooling_printErr("cheng_tooling: selfhost bootstrap fast host failed: " + tooling_messageOrUnknown(res.message))
        return 1
    tooling_printOut("selfhost_fast_stage1=" + res.stage1Path)
    tooling_printOut("selfhost_fast_stage2=" + res.stage2Path)
    tooling_printOut("selfhost_fast_stage0=" + res.stage0Path)
    tooling_printOut("selfhost_fast_stage0_driver_kind=" + res.stage0DriverKind)
    tooling_printOut("selfhost_fast_stage1_status=" + res.stage1Status)
    tooling_printOut("selfhost_fast_stage1_compile_mode=" + res.stage1CompileMode)
    tooling_printOut("selfhost_fast_stage1_rebuild_ok=" + tooling_boolText(res.stage1RebuildOk))
    tooling_printOut("selfhost_fast_fallback_used=" + tooling_boolText(res.fallbackUsed))
    tooling_printOut("selfhost_fast_quarantine_cleaned=" + intToStr(res.quarantineCleaned))
    tooling_printOut("selfhost_fast_lock_wait_ms=" + intToStr(res.lockWaitMs))
    tooling_printOut("selfhost_fast_strict_rebuild_ok=" + tooling_boolText(res.strictRebuildOk))
    tooling_printOut("selfhost_fast_total_ms=" + intToStr(int32(res.totalMs)))
    return 0

fn tooling_cmdSelfhost100msHost(root: str, hostOnlyRaw: str, itersRaw: str, p95Raw: str, p99Raw: str, enforceRaw: str, reportRaw: str, compileStage1: bool, outDirRaw: str): int32 =
    let hostOnly: str = tooling_selfhost100msHostOnly(hostOnlyRaw)
    let defaultIters: int32 = compileStage1 ? 1 : 5
    var iters: int32 = tooling_parseInt32Default(itersRaw, defaultIters)
    if iters <= 0:
        iters = defaultIters
    var p95Limit: int32 = tooling_parseInt32Default(p95Raw, 100)
    if p95Limit <= 0:
        p95Limit = 100
    var p99Limit: int32 = tooling_parseInt32Default(p99Raw, 120)
    if p99Limit <= 0:
        p99Limit = 120
    let enforce: bool = tooling_isTrue(enforceRaw)
    let strictRebuild: bool = tooling_selfhostStrictRebuildEnabled()
    let requireStage1Rebuild: bool = compileStage1 &&
        (strictRebuild || tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_REQUIRE_REBUILD", "0")))
    let stage1FullRebuild: bool = compileStage1 &&
        (strictRebuild || tooling_isTrue(os.getEnvDefault("SELFHOST_STAGE1_FULL_REBUILD", "0")))
    let stage1CompileModeBase: str = tooling_selfhost100msStage1CompileModeBase(
        compileStage1, stage1FullRebuild)
    let compileStage1TextBase: str = tooling_boolText(compileStage1)

    let hostTag: str = tooling_detectHostTag(root)
    let reportPath: str = tooling_selfhost100msReportPath(root, reportRaw)
    let reportDir: str = os.parentDir(reportPath)
    tooling_tryMkdirP(root, reportDir)

    if hostTag != hostOnly:
        os.writeFile(
            reportPath,
            "host=" + hostTag + "\n" +
                "host_only=" + hostOnly + "\n" +
                "compile_stage1=" + compileStage1TextBase + "\n" +
                "stage1_compile_mode=" + stage1CompileModeBase + "\n" +
                "strict_rebuild_ok=0\n" +
                "fallback_used=0\n" +
                "quarantine_cleaned=0\n" +
                "lock_wait_ms=0\n" +
                "status=skip_non_target_host\n")
        tooling_printOut("[selfhost_100ms_native] skip on non-target host: host=" + hostTag + " target=" + hostOnly)
        return 0
    var totalsMs: int32[] = []
    var stage1RebuildCount: int32 = 0
    var stage1ReuseCount: int32 = 0
    var stage1AliasCount: int32 = 0
    var stage1CompileModeFullCount: int32 = 0
    var stage1CompileModeQuickCount: int32 = 0
    var stage1CompileModeAliasCount: int32 = 0
    var fallbackUsedCount: int32 = 0
    var quarantineCleanedTotal: int32 = 0
    var lockWaitMsMax: int32 = 0
    var strictRebuildOkCount: int32 = 0
    var stage1CompileMsTotal: int64 = int64(0)
    var stage1CompileMsMax: int64 = int64(0)
    var stage1SanityMsTotal: int64 = int64(0)
    var stage1CompileAttemptsTotal: int32 = 0
    var stage1CompileSegfaultsTotal: int32 = 0
    var stage0DriverKindCanonicalCount: int32 = 0
    var stage0DriverKindDistReleaseCount: int32 = 0
    var stage0DriverKindBackendSeedCount: int32 = 0
    var stage0DriverKindSelfhostObjCount: int32 = 0
    var stage0DriverKindExplicitCount: int32 = 0
    var warmupOk: bool = true
    let outDir: str = tooling_selfhost100msOutDir(root, outDirRaw)
    tooling_tryMkdirP(root, outDir)
    let prewarmStage1: bool = compileStage1 && iters > 1 &&
        tooling_isTrue(os.getEnvDefault("SELFHOST_100MS_PREWARM_STAGE1", "1"))
    if prewarmStage1:
        let warmupTimingPath: str = os.joinPath(outDir, "selfhost_timing_native.warmup.tsv")
        let warmupRes: ToolingSelfhostResult = tooling_selfhostBootstrapFastHost(
            root, compileStage1, outDir, warmupTimingPath, false)
        if !warmupRes.ok:
            warmupOk = false
            tooling_printErr("[selfhost_100ms_native] warmup failed (continue): reason=" +
                             tooling_messageOrUnknown(warmupRes.message))
            tooling_printOut("selfhost_100ms_warmup_failed=1")
        else:
            tooling_printOut("selfhost_100ms_warmup_ms=" + intToStr(int32(warmupRes.totalMs)))
    for i in 1..iters:
        let timingPath: str = os.joinPath(outDir, "selfhost_timing_native." + intToStr(i) + ".tsv")
        let res: ToolingSelfhostResult = tooling_selfhostBootstrapFastHost(
            root, compileStage1, outDir, timingPath, false)
        if !res.ok:
            let msg: str = tooling_messageOrUnknown(res.message)
            os.writeFile(
                reportPath,
                "host=" + hostTag + "\n" +
                    "iters=" + intToStr(iters) + "\n" +
                    "failed_iter=" + intToStr(i) + "\n" +
                    "status=bootstrap_fail\n" +
                    "reason=" + msg + "\n" +
                    "compile_stage1=" + compileStage1TextBase + "\n" +
                    "stage1_compile_mode=" + stage1CompileModeBase + "\n" +
                    "stage0_driver_kind=" + tooling_nonEmptyDefault(res.stage0DriverKind, "unknown") + "\n" +
                    "fallback_used=" + tooling_boolText(res.fallbackUsed) + "\n" +
                    "quarantine_cleaned=" + intToStr(res.quarantineCleaned) + "\n" +
                    "lock_wait_ms=" + intToStr(res.lockWaitMs) + "\n" +
                    "strict_rebuild_ok=" + tooling_boolText(res.strictRebuildOk) + "\n" +
                    "stage1_compile_ms=" + intToStr(int32(res.stage1CompileMs)) + "\n" +
                    "stage1_sanity_ms=" + intToStr(int32(res.stage1SanityMs)) + "\n" +
                    "stage1_compile_attempts=" + intToStr(res.stage1CompileAttempts) + "\n" +
                    "stage1_compile_segfaults=" + intToStr(res.stage1CompileSegfaults) + "\n" +
                    "limit_p95_ms=" + intToStr(p95Limit) + "\n" +
                    "limit_p99_ms=" + intToStr(p99Limit) + "\n")
            tooling_printErr("[selfhost_100ms_native] bootstrap failed: iter=" + intToStr(i) + " reason=" + msg)
            if enforce:
                return 1
            return 0
        toolingAppendInt32(totalsMs, int32(res.totalMs))
        if res.fallbackUsed:
            fallbackUsedCount = fallbackUsedCount + 1
        quarantineCleanedTotal = quarantineCleanedTotal + res.quarantineCleaned
        if res.lockWaitMs > lockWaitMsMax:
            lockWaitMsMax = res.lockWaitMs
        if res.strictRebuildOk:
            strictRebuildOkCount = strictRebuildOkCount + 1
        stage1CompileMsTotal = stage1CompileMsTotal + res.stage1CompileMs
        if res.stage1CompileMs > stage1CompileMsMax:
            stage1CompileMsMax = res.stage1CompileMs
        stage1SanityMsTotal = stage1SanityMsTotal + res.stage1SanityMs
        stage1CompileAttemptsTotal = stage1CompileAttemptsTotal + res.stage1CompileAttempts
        stage1CompileSegfaultsTotal = stage1CompileSegfaultsTotal + res.stage1CompileSegfaults
        if tooling_strEq(res.stage0DriverKind, "canonical"):
            stage0DriverKindCanonicalCount = stage0DriverKindCanonicalCount + 1
        elif tooling_strEq(res.stage0DriverKind, "dist_release"):
            stage0DriverKindDistReleaseCount = stage0DriverKindDistReleaseCount + 1
        elif tooling_strEq(res.stage0DriverKind, "backend_seed"):
            stage0DriverKindBackendSeedCount = stage0DriverKindBackendSeedCount + 1
        elif tooling_strEq(res.stage0DriverKind, "selfhost_obj"):
            stage0DriverKindSelfhostObjCount = stage0DriverKindSelfhostObjCount + 1
        else:
            stage0DriverKindExplicitCount = stage0DriverKindExplicitCount + 1
        if tooling_strEq(res.stage1Status, "rebuild") && res.stage1RebuildOk:
            stage1RebuildCount = stage1RebuildCount + 1
        elif tooling_strEq(res.stage1Status, "reused_stage0"):
            stage1ReuseCount = stage1ReuseCount + 1
        elif tooling_strEq(res.stage1Status, "alias"):
            stage1AliasCount = stage1AliasCount + 1
        if tooling_strEq(res.stage1CompileMode, "full"):
            stage1CompileModeFullCount = stage1CompileModeFullCount + 1
        elif tooling_strEq(res.stage1CompileMode, "quick"):
            stage1CompileModeQuickCount = stage1CompileModeQuickCount + 1
        else:
            stage1CompileModeAliasCount = stage1CompileModeAliasCount + 1
    if totalsMs.len <= 0:
        tooling_printErr("[selfhost_100ms_native] empty totals")
        return 1
    let p95Ms: int32 = tooling_pickPercentileNoSort(totalsMs, 95)
    let p99Ms: int32 = tooling_pickPercentileNoSort(totalsMs, 99)
    var maxMs: int32 = totalsMs[0]
    for i in 1..<totalsMs.len:
        if totalsMs[i] > maxMs:
            maxMs = totalsMs[i]
    let status: str = tooling_selfhost100msStatus(p95Ms, p99Ms, p95Limit, p99Limit)
    let stage1StatusSummary: str = tooling_selfhost100msStage1StatusSummary(
        compileStage1, iters, stage1RebuildCount, stage1ReuseCount)
    let stage1CompileModeSummary: str = tooling_selfhost100msStage1CompileModeSummary(
        compileStage1, iters, stage1CompileModeFullCount, stage1CompileModeQuickCount,
        stage1CompileModeAliasCount)
    let stage1RebuildOk: bool = tooling_selfhost100msStage1RebuildOk(
        compileStage1, iters, stage1RebuildCount)
    let stage0DriverKindSummary: str = tooling_selfhost100msStage0DriverKindSummary(
        stage0DriverKindCanonicalCount, stage0DriverKindDistReleaseCount,
        stage0DriverKindBackendSeedCount, stage0DriverKindSelfhostObjCount,
        stage0DriverKindExplicitCount)
    let fallbackUsedText: str = tooling_boolText(fallbackUsedCount > 0)
    let strictRebuildOkText: str = tooling_boolText(!strictRebuild || strictRebuildOkCount == iters)
    var stage1CompileMsAvg: int32 = 0
    var stage1SanityMsAvg: int32 = 0
    if iters > 0:
        stage1CompileMsAvg = int32(stage1CompileMsTotal / int64(iters))
        stage1SanityMsAvg = int32(stage1SanityMsTotal / int64(iters))
    os.writeFile(
        reportPath,
        "host=" + hostTag + "\n" +
            "iters=" + intToStr(iters) + "\n" +
            "compile_stage1=" + compileStage1TextBase + "\n" +
            "prewarm_stage1=" + tooling_boolText(prewarmStage1) + "\n" +
            "prewarm_ok=" + tooling_boolText(warmupOk) + "\n" +
            "stage1_compile_mode=" + stage1CompileModeSummary + "\n" +
            "stage1_status=" + stage1StatusSummary + "\n" +
            "stage1_rebuild_ok=" + tooling_boolText(stage1RebuildOk) + "\n" +
            "stage0_driver_kind=" + stage0DriverKindSummary + "\n" +
            "fallback_used=" + fallbackUsedText + "\n" +
            "quarantine_cleaned=" + intToStr(quarantineCleanedTotal) + "\n" +
            "lock_wait_ms=" + intToStr(lockWaitMsMax) + "\n" +
            "strict_rebuild_ok=" + strictRebuildOkText + "\n" +
            "stage1_compile_ms_avg=" + intToStr(stage1CompileMsAvg) + "\n" +
            "stage1_compile_ms_max=" + intToStr(int32(stage1CompileMsMax)) + "\n" +
            "stage1_sanity_ms_avg=" + intToStr(stage1SanityMsAvg) + "\n" +
            "stage1_compile_attempts_total=" + intToStr(stage1CompileAttemptsTotal) + "\n" +
            "stage1_compile_segfaults_total=" + intToStr(stage1CompileSegfaultsTotal) + "\n" +
            "p95_ms=" + intToStr(p95Ms) + "\n" +
            "p99_ms=" + intToStr(p99Ms) + "\n" +
            "max_ms=" + intToStr(maxMs) + "\n" +
            "limit_p95_ms=" + intToStr(p95Limit) + "\n" +
            "limit_p99_ms=" + intToStr(p99Limit) + "\n" +
            "status=" + status + "\n")
    tooling_printOut("[selfhost_100ms_native] host=" + hostTag +
                     " p95=" + intToStr(p95Ms) + "ms p99=" + intToStr(p99Ms) +
                     "ms max=" + intToStr(maxMs) + "ms status=" + status +
                     " stage0_driver_kind=" + stage0DriverKindSummary +
                     " fallback_used=" + fallbackUsedText +
                     " stage1_compile_mode=" + stage1CompileModeSummary +
                     " stage1_status=" + stage1StatusSummary +
                     " stage1_rebuild_ok=" + tooling_boolText(stage1RebuildOk) +
                     " strict_rebuild_ok=" + strictRebuildOkText +
                     " stage1_compile_ms_avg=" + intToStr(stage1CompileMsAvg) +
                     " stage1_compile_segfaults_total=" + intToStr(stage1CompileSegfaultsTotal))
    let enforcePerfWithCompileStage1: bool = compileStage1 &&
                                            tooling_isTrue(os.getEnvDefault("SELFHOST_100MS_ENFORCE_WITH_COMPILE_STAGE1", "1"))
    let enforcePerfGate: bool = enforce && (!compileStage1 || enforcePerfWithCompileStage1)
    if !tooling_strEq(status, "ok") && enforcePerfGate:
        return 1
    if requireStage1Rebuild && !stage1RebuildOk:
        return 1
    return 0

fn tooling_verifyRgAvailable(root: str, tag: str): bool =
    if os.execCmdResultExitCode(tooling_exec(root, "command -v rg >/dev/null 2>&1")) == 0:
        return true
    tooling_printErr("[" + tag + "] rg is required")
    return false

fn tooling_verifyToolingBinaryPath(root: str): str =
    let toolRaw: str = strutil.strip(
        os.getEnvDefault("TOOLING_SELF_BIN", "artifacts/tooling_cmd/cheng_tooling"))
    return tooling_pathAbsolute(root, tooling_nonEmptyDefault(toolRaw, "artifacts/tooling_cmd/cheng_tooling"))

fn tooling_verifySafeTarget(root: str, target: str): str =
    return tooling_nonEmptyDefault(tooling_sanitizeShellSafeToken(root, target), "unknown")

fn tooling_verifyTargetExePath(outDir: str, stem: str, safeTarget: str, target: str): str =
    let outPath: str = os.joinPath(outDir, stem + "." + safeTarget)
    if strutil.contains(strutil.toLowerAscii(target), "windows") ||
       strutil.contains(strutil.toLowerAscii(target), "msvc"):
        return outPath + ".exe"
    return outPath

fn tooling_verifyDriverTarget(root: str, targetRaw: str): str =
    let target: str = tooling_normalizeTargetAlias(root, targetRaw)
    if !tooling_strNonEmpty(target) || tooling_strEq(target, "auto"):
        return ""
    return target

fn tooling_verifyHostTarget(root: str, tag: str): str =
    let target: str = tooling_verifyDriverTarget(root, "")
    if tooling_strNonEmpty(target):
        return target
    tooling_printErr("[" + tag + "] failed to resolve host target")
    return ""

fn tooling_verifyBackendDriverExecInfo(root: str, tool: str, tag: str,
                                       targetRaw: str): ToolingBackendDriverExecInfo =
    var info: ToolingBackendDriverExecInfo = nil
    new(info)
    info.driver = strutil.strip(os.getEnvDefault("BACKEND_DRIVER", ""))
    if !tooling_strNonEmpty(info.driver):
        let detectRes: os.ExecCmdResult = tooling_exec(root, tooling_shellQuote(tool) + " backend_driver_path")
        if os.execCmdResultExitCode(detectRes) != 0:
            tooling_printExecOutput(detectRes)
        info.driver = strutil.strip(os.execCmdResultOutput(detectRes))
        if !tooling_strNonEmpty(info.driver):
            tooling_printErr("[" + tag + "] failed to resolve backend driver")
            return nil
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(info.driver) + " ]")) != 0:
        tooling_printErr("[" + tag + "] backend driver not executable: " + info.driver)
        return nil
    let driverExecScript: str = tooling_pathAbsolute(root, "src/tooling/backend_driver_exec.sh")
    info.driverExec = info.driver
    info.driverRealEnv = tooling_textLiteral("")
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(driverExecScript) + " ]")) == 0:
        info.driverExec = driverExecScript
        info.driverRealEnv = tooling_envAssignCompat("BACKEND_DRIVER_REAL", info.driver)
    if os.execCmdResultExitCode(tooling_exec(root, "[ -x " + tooling_shellQuote(info.driverExec) + " ]")) != 0:
        tooling_printErr("[" + tag + "] backend driver_exec not executable: " + info.driverExec)
        return nil
    info.target = tooling_verifyDriverTarget(root, targetRaw)
    if !tooling_strNonEmpty(info.target):
        tooling_printErr("[" + tag + "] failed to resolve backend target")
        return nil
    return info

fn tooling_verifyBackendRequestedLinkerMode(linkerRaw: str, defaultMode: str,
                                            allowAuto: bool, tag: str): str =
    let linkerMode: str = strutil.toLowerAscii(strutil.strip(linkerRaw))
    if !tooling_strNonEmpty(linkerMode):
        return defaultMode
    if tooling_strEq(linkerMode, "self") || tooling_strEq(linkerMode, "system"):
        return linkerMode
    if allowAuto && tooling_strEq(linkerMode, "auto"):
        return "auto"
    tooling_printErr("[" + tag + "] invalid linker mode: " + linkerRaw)
    return ""

fn tooling_verifyBackendLinkEnvResolved(root: str, tool: str, driver: str, target: str,
                                        linkerMode: str, tag: str): str =
    let res: os.ExecCmdResult = tooling_exec(
        root,
        tooling_shellQuote(tool) + " backend_link_env --driver:" + tooling_shellQuote(driver) +
            " --target:" + tooling_shellQuote(target) + " --linker:" +
            tooling_shellQuote(linkerMode))
    let out: str = strutil.strip(os.execCmdResultOutput(res))
    if os.execCmdResultExitCode(res) != 0:
        tooling_printErr("[" + tag + "] backend_link_env failed")
        tooling_printExecOutput(res)
        return ""
    if !tooling_strNonEmpty(out):
        tooling_printErr("[" + tag + "] backend_link_env returned empty env")
        return ""
    return out

fn tooling_verifyBackendCompileOptions(root: str, linkerText: str, target: str,
                                       inputPath: str, outputPath: str): ToolingCompileOptions =
    let compileMultiText: str = tooling_compileParallelMultiText(root)
    let useSelfLink: bool = tooling_strEq(linkerText, "self")
    let opts: ToolingCompileOptions = tooling_compileSemanticOptions(
        root, "dev", "outline", linkerText, "", useSelfLink ? "1" : "0",
        useSelfLink ? "1" : "0", compileMultiText, "0")
    opts.targetText = target
    opts.inputPath = inputPath
    opts.outputPath = outputPath
    opts.emitModeText = "exe"
    opts.allowNoMainText = "0"
    return opts

fn tooling_compileOptionsApplyLinkEnv(opts: ToolingCompileOptions, linkEnv: str,
                                      defaultLinker: str) =
    if opts == nil:
        return
    let resolvedLinker: str = tooling_nonEmptyDefault(
        tooling_envTextLookup(linkEnv, "BACKEND_LINKER"),
        defaultLinker)
    let useSelfLink: bool = tooling_strEq(resolvedLinker, "self")
    opts.linkerText = resolvedLinker
    opts.directExeText = useSelfLink ? "1" : "0"
    opts.linkerlessInmemText = useSelfLink ? "1" : "0"
    opts.noRuntimeCText = useSelfLink ? "1" : "0"
    opts.runtimeObjPath = ""
    let noRuntimeCText: str = tooling_envTextLookup(linkEnv, "BACKEND_NO_RUNTIME_C")
    let runtimeObjPath: str = tooling_envTextLookup(linkEnv, "BACKEND_RUNTIME_OBJ")
    if tooling_strNonEmpty(noRuntimeCText):
        opts.noRuntimeCText = noRuntimeCText
    if tooling_strNonEmpty(runtimeObjPath):
        opts.runtimeObjPath = runtimeObjPath

fn tooling_verifyBackendDriverCompileEnvText(root: str, stage0Exec: str, driverRealEnv: str,
                                             opts: ToolingCompileOptions): str =
    var parts: str[] = []
    if tooling_strNonEmpty(driverRealEnv):
        add(parts, driverRealEnv)
    add(parts, tooling_compileOptionsEnvText(root, stage0Exec, opts))
    return tooling_joinFragments(parts)

fn tooling_verifyBackendFfiOutptrTupleFixtureRun(root: str): str =
    return tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/ffi_outptr_tuple_importc_pair_i32.cheng")

fn tooling_verifyBackendFfiOutptrTupleFixtureStatus(root: str): str =
    return tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/ffi_outptr_tuple_status_i32_objonly.cheng")

fn tooling_verifyBackendFfiOutptrTupleFixtureFail(root: str): str =
    return tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/compile_fail_ffi_outptr_tuple_arity_mismatch.cheng")

fn tooling_verifyBackendFfiOutptrTupleRunMode(runtimeSymbolMissingSkip: bool): str =
    if runtimeSymbolMissingSkip:
        return "runtime_symbol_missing_skip"
    return "host"

fn tooling_verifyBackendFfiSliceShimFixtureOk(root: str): str =
    return tooling_pathAbsolute(root, "tests/cheng/backend/fixtures/ffi_importc_slice_seq_i32.cheng")

fn tooling_verifyBackendFfiSliceShimFixtureFailLegacy(root: str): str =
    return tooling_pathAbsolute(root,
                                "tests/cheng/backend/fixtures/compile_fail_ffi_importc_slice_openarray_i32.cheng")

fn tooling_verifyBackendFfiSliceShimFixtureFailSurface(root: str): str =
    return tooling_pathAbsolute(root,
                                "tests/cheng/backend/fixtures/compile_fail_ffi_slice_user_raw_ptr_surface.cheng")

fn tooling_verifyBackendFfiSliceShimImportcSymbol(): str =
    return "cheng_abi_sum_seq_i32"

fn tooling_verifyBackendFfiSliceShimSurfacePattern(): str =
    return "void\\*|ptr_add\\(|load_ptr\\(|store_ptr\\("

fn tooling_verifyBackendFfiSliceShimLegacyDiagPattern(): str =
    return "Legacy type syntax is removed; use 'T\\[\\]' instead of 'openArray\\[T\\]'"

fn tooling_verifyBackendFfiSliceShimSurfaceDiagPattern(): str =
    return "no-pointer policy: pointer (types are|dereference is|operation is) forbidden outside C ABI modules"

fn tooling_verifyBackendFfiSliceShimCommonCompileEnv(root: str, stage0Exec: str, driverRealEnv: str,
                                                     linkEnv: str, linkerMode: str, target: str,
                                                     inputPath: str, outputPath: str): str =
    let compileOpts: ToolingCompileOptions = tooling_verifyBackendCompileOptions(
        root, linkerMode, target, inputPath, outputPath)
    tooling_compileOptionsApplyLinkEnv(compileOpts, linkEnv, linkerMode)
    return tooling_verifyBackendDriverCompileEnvText(root, stage0Exec, driverRealEnv, compileOpts)

fn tooling_verifyBackendFfiSliceShimSurfaceCompileEnv(root: str, stage0Exec: str, driverRealEnv: str,
                                                      linkEnv: str, linkerMode: str, target: str,
                                                      inputPath: str, outputPath: str): str =
    let compileOpts: ToolingCompileOptions = tooling_verifyBackendCompileOptions(
        root, linkerMode, target, inputPath, outputPath)
    tooling_compileOptionsApplyLinkEnv(compileOpts, linkEnv, linkerMode)
    compileOpts.noptrNonCAbi = "1"
    compileOpts.noptrNonCAbiInternal = "1"
    return tooling_verifyBackendDriverCompileEnvText(root, stage0Exec, driverRealEnv, compileOpts)

fn tooling_verifyBackendFfiSliceShimSurfaceOk(root: str, fixtureOk: str, surfacePattern: str, surfaceScanLog: str): bool =
    return os.execCmdResultExitCode(tooling_exec(
        root,
        "rg -n " + tooling_shellQuote(surfacePattern) + " " + tooling_shellQuote(fixtureOk) +
            " > " + tooling_shellQuote(surfaceScanLog) + " 2>&1")) != 0

fn tooling_verifyBackendFfiSliceShimSymbolCheck(root: str, exePath: str, importcSymbol: str): str =
    if os.execCmdResultExitCode(tooling_exec(root, "command -v nm >/dev/null 2>&1")) != 0:
        return "skip"
    if os.execCmdResultExitCode(tooling_exec(
        root,
        "nm " + tooling_shellQuote(exePath) + " 2>/dev/null | rg -q " +
            tooling_shellQuote(importcSymbol))) == 0:
        return "1"
    return "0"

fn tooling_verifyBackendFfiSliceShimDiagOk(root: str, diagPattern: str, logPath: str): bool =
    return os.execCmdResultExitCode(tooling_exec(
        root,
        "rg -q " + tooling_shellQuote(diagPattern) + " " +
            tooling_shellQuote(logPath) + " >/dev/null 2>&1")) == 0

fn tooling_verifyBackendFfiSliceShimRunMode(runPositive: bool): str =
    if runPositive:
        return "run"
    return "not_requested"

fn tooling_selfhostParallelPerfStage0(root: str, tool: str): str =
    let info: ToolingBackendDriverExecInfo =
        tooling_verifyBackendDriverExecInfo(root, tool, "selfhost_parallel_perf", "")
    if info == nil:
        return ""
    return info.driver

fn tooling_selfhostParallelPerfSafeSession(root: str, session: str, fallback: str): str =
    return tooling_nonEmptyDefault(tooling_sanitizeShellSafeToken(root, session), fallback)

fn tooling_selfhostParallelPerfSession(baseSession: str, suffix: str): str =
    return baseSession + suffix

fn tooling_selfhostParallelPerfReport(root: str, reportRaw: str, safeBaseSession: str): str =
    if tooling_strNonEmpty(strutil.strip(reportRaw)):
        return tooling_pathAbsolute(root, strutil.strip(reportRaw))
    return os.joinPath("artifacts/backend_selfhost_self_obj", "selfhost_parallel_perf_" + safeBaseSession + ".tsv")

fn tooling_binaryHelpProbeCommand(binPath: str): str =
    return tooling_shellQuote(binPath) + " --help >/dev/null 2>&1"

fn tooling_binaryListProbeCommand(binPath: str): str =
    return tooling_shellQuote(binPath) + " list >/dev/null 2>&1"

fn tooling_binarySurfaceStringsProbeCommand(binPath: str): str =
    return "strings " + tooling_shellQuote(binPath) +
        " | grep -q " + tooling_shellQuote("usage: cheng_tooling")

fn tooling_buildGlobalReleaseFallbackCmdLog(outPath: str): str =
    return outPath + ".build_global_release_fallback.log"

fn tooling_buildGlobalReleaseFallbackOptLevel(): str =
    return tooling_nonEmptyDefault(
        strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RELEASE_FALLBACK_OPT_LEVEL", "0")), "0")

fn tooling_buildGlobalReleaseFallbackOpt(): str =
    return tooling_nonEmptyDefault(
        tooling_bool01Normalized(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RELEASE_FALLBACK_BACKEND_OPT", "0")), "0")

fn tooling_buildGlobalReleaseFallbackOpt2(): str =
    return tooling_nonEmptyDefault(
        tooling_bool01Normalized(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RELEASE_FALLBACK_BACKEND_OPT2", "0")), "0")

fn tooling_buildGlobalReleaseFallbackEffectiveCflags(releaseCflagsRaw: str): str =
    if tooling_strNonEmpty(releaseCflagsRaw):
        return releaseCflagsRaw + " " + "-DCHENG_TOOLING_ENTRY_SHIM=1"
    return "-DCHENG_TOOLING_ENTRY_SHIM=1"

fn tooling_buildGlobalReleaseFallbackStage0Route(stage0RouteRaw: str): str =
    return strutil.toLowerAscii(strutil.strip(stage0RouteRaw))

fn tooling_resolvedTargetOrHost(root: str, targetRaw: str): str =
    return tooling_nonEmptyDefault(tooling_normalizeTargetAlias(root, targetRaw), "auto")

fn tooling_buildGlobalResolvedTarget(root: str, targetRaw: str): str =
    return tooling_resolvedTargetOrHost(root, targetRaw)

fn tooling_buildGlobalReleaseFallbackDefault(target: str): str =
    if tooling_strEq(target, "arm64-apple-darwin"):
        return "0"
    return "1"

fn tooling_buildGlobalResolvedDriverPath(root: str, target: str, driverRaw: str): str =
    if tooling_strNonEmpty(strutil.strip(driverRaw)):
        return tooling_resolveBuildDriver(root, driverRaw)
    return tooling_buildGlobalPreferredDriver(root, target)

fn tooling_buildGlobalCompileOptLevelDefault(): str =
    return tooling_nonEmptyDefault(strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_OPT_LEVEL", "0")), "0")

fn tooling_buildGlobalCompileBackendOptDefault(): str =
    return tooling_nonEmptyDefault(
        tooling_bool01Normalized(os.getEnvDefault("TOOLING_BUILD_GLOBAL_BACKEND_OPT", "0")), "0")

fn tooling_buildGlobalCompileBackendOpt2Default(): str =
    return tooling_nonEmptyDefault(
        tooling_bool01Normalized(os.getEnvDefault("TOOLING_BUILD_GLOBAL_BACKEND_OPT2", "0")), "0")

fn tooling_buildGlobalCompileOptLevelRetry(): str =
    return tooling_nonEmptyDefault(strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_OPT_LEVEL", "0")), "2")

fn tooling_buildGlobalCompileBackendOptRetry(): str =
    return tooling_nonEmptyDefault(
        tooling_bool01Normalized(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_BACKEND_OPT", "0")), "0")

fn tooling_buildGlobalCompileBackendOpt2Retry(): str =
    return tooling_nonEmptyDefault(
        tooling_bool01Normalized(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_BACKEND_OPT2", "0")), "0")

fn tooling_buildGlobalCompileCflagsRetry(): str =
    return strutil.strip(os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_CFLAGS", "-O0"))

fn tooling_buildGlobalCompileLdflagsRetry(target: str, compileCflagsRaw: str): str =
    return tooling_releaseLdflagsForTarget(
        os.getEnvDefault("TOOLING_BUILD_GLOBAL_RETRY_LDFLAGS", compileCflagsRaw), target)

fn tooling_buildGlobalAttemptLog(buildOutPath: str, attempt: int32): str =
    return buildOutPath + ".attempt_" + intToStr(attempt) + ".log"

fn tooling_buildGlobalReleaseFallbackOut(buildOutPath: str): str =
    return buildOutPath + ".release_fallback"

fn tooling_buildGlobalPurgeEmbeddedCacheCommand(embeddedCacheDir: str): str =
    return "find " + tooling_shellQuote(embeddedCacheDir) +
        " -type f -name '*.embedded.sh' -delete"

fn tooling_buildGlobalAttemptCommand(root: str, stage0Exec: str, src: str, buildOutPath: str,
                                     target: str, stage0Route: str, runtimeObj: str,
                                     compileOptLevel: str, compileBackendOpt: str,
                                     compileBackendOpt2: str, compileCflagsRaw: str,
                                     compileLdflagsRaw: str, compileMultiText: str,
                                     compileJobsText: str, compileFnJobsText: str, attemptLog: str,
                                     timeoutSec: int32, attempt: int32): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "dev", "outline", "self", target, src, buildOutPath,
        "exe", "1", "", "1", "1", compileMultiText, "1", compileJobsText, compileFnJobsText)
    var envOverrides: str[] = []
    compileOpts.enableCliText = "1"
    compileOpts.abiText = "v2_noptr"
    compileOpts.optText = compileBackendOpt
    compileOpts.opt2Text = compileBackendOpt2
    compileOpts.optLevelText = compileOptLevel
    compileOpts.cflagsRaw = compileCflagsRaw
    compileOpts.ldflagsRaw = compileLdflagsRaw
    compileOpts.noRuntimeCText = "1"
    compileOpts.runtimeObjPath = runtimeObj
    if !tooling_compileApplyStrictSidecarContract(
            root, "build-global", stage0Exec, "", "", compileOpts):
        return tooling_wrapStage0LockTimeout(
            root,
            timeoutSec,
            "echo " + tooling_shellQuote(
                "cheng_tooling: build-global missing strict fresh Cheng sidecar contract") +
                " >&2; exit 1",
            "build_global_attempt_" + intToStr(attempt))
    tooling_compileCollectEnvOverrides(root, stage0Exec, compileOpts, envOverrides)
    var parts: str[] = []
    add(parts, "env ")
    add(parts, tooling_envOverridesCompatText(envOverrides))
    add(parts, tooling_shellQuote(stage0Exec))
    add(parts, " > " + tooling_shellQuote(attemptLog) + " 2>&1")
    return tooling_wrapStage0LockTimeout(
        root,
        timeoutSec,
        tooling_prefixUnsetLegacyFrontendEnv(strutil.join(parts, "")),
        "build_global_attempt_" + intToStr(attempt))

fn tooling_buildGlobalReleaseFallbackCommand(root: str, stage0Exec: str, src: str, outPath: str,
                                            target: str, timeoutSec: int32,
                                            effectiveReleaseCflags: str, releaseLdflagsRaw: str,
                                            stage0Route: str, optLevel: str, opt: str, opt2: str,
                                            compileMultiText: str, compileJobsText: str,
                                            compileFnJobsText: str, cmdLog: str): str =
    let compileOpts: ToolingCompileOptions = tooling_compileExplicitOptions(
        "release", "full", "system", target, src, outPath,
        "exe", "1", "", "0", "0", compileMultiText, "0", compileJobsText, compileFnJobsText)
    var envOverrides: str[] = []
    compileOpts.abiText = "v2_noptr"
    compileOpts.optText = opt
    compileOpts.opt2Text = opt2
    compileOpts.optLevelText = optLevel
    compileOpts.cflagsRaw = effectiveReleaseCflags
    compileOpts.ldflagsRaw = releaseLdflagsRaw
    compileOpts.noRuntimeCText = "0"
    if !tooling_compileApplyStrictSidecarContract(
            root, "build-global", stage0Exec, "", "", compileOpts):
        return tooling_wrapStage0LockTimeout(
            root,
            timeoutSec,
            "echo " + tooling_shellQuote(
                "cheng_tooling: build-global missing strict fresh Cheng sidecar contract") +
                " >&2; exit 1",
            "build_global_release_fallback")
    tooling_compileCollectEnvOverrides(root, stage0Exec, compileOpts, envOverrides)
    var parts: str[] = []
    add(parts, "env ")
    add(parts, tooling_envOverridesCompatText(envOverrides))
    add(parts, tooling_shellQuote(stage0Exec))
    add(parts, " > " + tooling_shellQuote(cmdLog) + " 2>&1")
    return tooling_wrapStage0LockTimeout(
        root,
        timeoutSec,
        tooling_prefixUnsetLegacyFrontendEnv(strutil.join(parts, "")),
        "build_global_release_fallback")

fn tooling_printCompileUsage() =
    tooling_printOut("cheng options (canonical compile entry):")
    tooling_printOut("  --in:<file.cheng>            source file path")
    tooling_printOut("  --out:<path>                 output path")
    tooling_printOut("  --name:<name-or-path>        output name (defaults under artifacts/chengc)")
    tooling_printOut("  --emit:exe                  output format (default exe)")
    tooling_printOut("  --target:<triple>            backend target triple")
    tooling_printOut("  --whole-program              alias of --whole-program:1")
    tooling_printOut("  --whole-program:0|1          explicit whole-program mode")
    tooling_printOut("  --opt                        alias of --opt:1")
    tooling_printOut("  --opt:0|1                    explicit backend opt mode")
    tooling_printOut("  --opt2                       alias of --opt2:1")
    tooling_printOut("  --opt2:0|1                   explicit backend opt2 mode")
    tooling_printOut("  --opt-level:0|1|2|3          explicit backend opt level")
    tooling_printOut("  --no-runtime-c               alias of --no-runtime-c:1")
    tooling_printOut("  --no-runtime-c:0|1           explicit self-link runtime-c mode")
    tooling_printOut("  --runtime-obj:<path>         explicit self-link runtime object")
    tooling_printOut("  --sidecar-mode:cheng              explicit backend sidecar mode")
    tooling_printOut("  --sidecar-bundle:<path>      explicit backend sidecar bundle")
    tooling_printOut("  --sidecar-compiler:<path>    explicit backend sidecar compiler")
    tooling_printOut("  --sidecar-child-mode:<cli|outer_cli>")
    tooling_printOut("                                explicit backend sidecar child-mode contract")
    tooling_printOut("  --sidecar-outer-compiler:<path>")
    tooling_printOut("                                explicit backend sidecar outer companion")
    tooling_printOut("  --generic-mode:dict          explicit generic mode")
    tooling_printOut("  --generic-spec-budget:0      explicit generic specialization budget")
    tooling_printOut("  --generic-lowering:mir_dict  explicit generic lowering")
    tooling_printOut("  --jobs:<N>                   explicit backend jobs")
    tooling_printOut("  --fn-jobs:<N>                explicit function worker jobs")
    tooling_printOut("  --multi                      alias of --multi:1")
    tooling_printOut("  --multi:0|1                  explicit function-parallel mode")
    tooling_printOut("  --incremental:0|1            explicit incremental mode")
    tooling_printOut("  (linker fixed: self-link + direct-exe)")
    tooling_printOut("  --dev                        dev build track (default/fixed, alias of --dev:fast)")
    tooling_printOut("  --dev:fast|strict            dev profile (default fast)")
    tooling_printOut("  --run                        run output after successful compile (dev default: host runner)")
    tooling_printOut("  --run:host                   run via backend_host_runner (dev default mode)")
    tooling_printOut("  --run:file                   run output executable file directly")
    tooling_printOut("  [positional input]           same as --in:<file.cheng>")
    tooling_printOut("  env: TOOLING_COMPILE_TIMEOUT=60 (default/cap)")
    tooling_printOut("       TOOLING_COMPILE_BLOCK_ON_UE=1|0 (default 1; hard-block follows TOOLING_STAGE0_HARD_BLOCK_ON_UE)")
    tooling_printOut("       TOOLING_COMPILE_CRASH_REPORT_DIR=artifacts/tooling_compile_crash")
    tooling_printOut("  note: TOOLING_COMPILE_STAGE0_AUTO_REBUILD_ON_PREFLIGHT_FAIL is removed (fixed=0)")
    tooling_printOut("  note: TOOLING_COMPILE_CRASH_RETRY_MAX is removed (fixed=0)")
    tooling_printOut("  note: `compile` and `chengc` have been removed; use `cheng`.")

