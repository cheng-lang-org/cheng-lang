        return tooling_cmdVerifyBackendEgraphCost(root)
    if tooling_strEq(selfName, "verify_backend_dod_opt_regression"):
        return tooling_cmdVerifyBackendDodOptRegression(root)
    if tooling_strEq(selfName, "verify_backend_noptr_exemption_scope"):
        return tooling_cmdVerifyBackendNoptrExemptionScope(root)
    if tooling_strEq(selfName, "verify_backend_linker_abi_core"):
        return tooling_cmdVerifyBackendLinkerAbiCore(root)
    if tooling_strEq(selfName, "verify_backend_linker_abi_core_cross"):
        return tooling_cmdVerifyBackendLinkerAbiCoreCrossFromArgs(root, 1, count)
    if tooling_strEq(selfName, "verify_backend_zero_script_closure"):
        return tooling_cmdVerifyBackendZeroScriptClosure(root)
    if tooling_strEq(selfName, "verify_backend_closedloop"):
        return tooling_cmdVerifyBackendClosedloopMinimal(root)
    if tooling_strEq(selfName, "verify_backend_rawptr_surface_forbid"):
        return tooling_cmdVerifyBackendRawptrSurfaceForbid(root)
    if tooling_strEq(selfName, "verify_stage1_ast_soa_surface"):
        return tooling_cmdVerifyStage1AstSoaSurface(root)
    if tooling_strEq(selfName, "backend_prod_closure"):
        return tooling_cmdBackendProdClosureFromArgs(root, 1, count)
    if tooling_strEq(selfName, "backend_prod_publish") || tooling_strEq(selfName, "backend-prod-publish"):
        return tooling_cmdBackendProdPublishFromArgs(root, 1, count)
    if tooling_strEq(selfName, "backend_resolve_selflink_runtime_obj") || tooling_strEq(selfName, "backend-resolve-selflink-runtime-obj"):
        return tooling_cmdBackendResolveSelflinkRuntimeObjFromArgs(root, 1, count)
    if tooling_strEq(selfName, "verify_backend_rawptr_migration"):
        return tooling_cmdVerifyBackendRawptrMigration(root)
    if tooling_strEq(selfName, "verify_backend_uir_soa_surface"):
        return tooling_cmdVerifyBackendUirSoaSurface(root)
    if tooling_strEq(selfName, "verify_backend_uir_soa_self_probe"):
        return tooling_cmdVerifyBackendUirSoaSelfProbe(root)
    if tooling_strEq(selfName, "verify_backend_emit_obj_contract"):
        return tooling_cmdVerifyBackendEmitObjContract(root)
    if tooling_strEq(selfName, "verify_mobile_crash_free"):
        return tooling_cmdVerifyMobileCrashFreeFromArgs(root, 1, count)
    if tooling_strEq(selfName, "infant-speak") || tooling_strEq(selfName, "infant_speak"):
        return tooling_cmdInfantSpeakFromArgs(root, 1, count)
    if tooling_strEq(selfName, "stage0_ue_status") || tooling_strEq(selfName, "stage0-ue-status"):
        return tooling_cmdStage0UeStatusFromArgs(root, 1, count)
    if tooling_strEq(selfName, "stage0_ue_clean") || tooling_strEq(selfName, "stage0-ue-clean"):
        return tooling_cmdStage0UeCleanFromArgs(root, 1, count)
    if tooling_strNonEmpty(selfName) &&
       !tooling_strEq(selfName, "cheng_tooling") &&
       !tooling_strEq(selfName, "cheng_tooling_global"):
        let multiScript: str = tooling_resolveScriptPath(root, selfName)
        if tooling_strNonEmpty(multiScript):
            return tooling_runScript(root, multiScript, 1)

    if count <= 0:
        tooling_printUsage()
        return 1
    let first: str = tooling_paramStr(1)
    if tooling_strEq(first, "help") || tooling_strEq(first, "--help") || tooling_strEq(first, "-h"):
        tooling_printUsage()
        return 0
    if tooling_strEq(first, "toolchain-root") || tooling_strEq(first, "toolchain_root"):
        return tooling_cmdToolchainRoot(root)
    if tooling_strEq(first, "backend_resolve_selflink_runtime_obj") || tooling_strEq(first, "backend-resolve-selflink-runtime-obj"):
        return tooling_cmdBackendResolveSelflinkRuntimeObjFromArgs(root, 2, count)
    if tooling_strEq(first, "backend_driver_path"):
        return tooling_cmdDriverPath(root, true)
    if tooling_strEq(first, "driver-path"):
        return tooling_cmdDriverPathFromArgs(root, 2, count)
    if tooling_strEq(first, "build-backend-driver") || tooling_strEq(first, "build_backend_driver"):
        return tooling_cmdBuildBackendDriverFromArgs(root, 2, count)
    if tooling_strEq(first, "cleanup-backend-driver-history") || tooling_strEq(first, "cleanup_backend_driver_history"):
