import cmdline
import std/os
import std/strutils as strutil
import std/strings
import std/monotimes
import tooling/cheng_tooling_embedded_inline as tooling_embedded_inline

type
    ToolingSelfhostResult = ref
        ok: bool
        message: str
        totalMs: int64
        mode: str
        stage1Path: str
        stage2Path: str
        stage3Path: str
        stage0Path: str
        stage0DriverKind: str
        stage1Status: str
        stage1CompileMode: str
        stage1RebuildOk: bool
        fallbackUsed: bool
        quarantineCleaned: int32
        lockWaitMs: int32
        strictRebuildOk: bool
        stage2Sha256: str
        stage3Sha256: str
        fixedPointOk: bool
        strictMismatchReport: str
        stage1CompileMs: int64
        stage1SanityMs: int64
        stage1CompileAttempts: int32
        stage1CompileSegfaults: int32

var
    tooling_buildDriverLastStampHit: bool = false
    tooling_buildDriverTightProfileLogShown: bool = false
    tooling_stage0CapabilitySignatureCache: str = ""
    tooling_stage0CapabilityManifestCache: str = ""
    tooling_stage0CstringCompatProbeSig: str = ""
    tooling_stage0CstringCompatProbeDone: bool = false
    tooling_stage0CstringCompatProbeResult: bool = false

fn tooling_setCmdLine(argc: int32, argv: str*) =
    cmdline.__cheng_captureCmdLine(argc, argv)

fn tooling_paramCount(): int32 =
    return cmdline.paramCount()

fn tooling_paramStr(i: int32): str =
    if i < 0:
        return ""
    return cmdline.paramStr(i)

fn tooling_printOut(text: str) =
    os.writeLine(os.get_stdout(), text)

fn tooling_printErr(text: str) =
    os.writeLine(os.get_stderr(), text)

fn tooling_strNonEmpty(text: str): bool =
    return len(text) > 0

fn tooling_strEq(a: str, b: str): bool =
    if a == b:
        return true
    if len(a) == 0 || len(b) == 0:
        return false
    return strings.streq(a, b)

fn tooling_genericModeIsDictOnly(raw: str): bool =
    let mode: str = strutil.toLowerAscii(strutil.strip(raw))
    if !tooling_strNonEmpty(mode):
        return true
    return tooling_strEq(mode, "dict")

fn tooling_genericLoweringIsDictOnly(raw: str): bool =
    let mode: str = strutil.toLowerAscii(strutil.strip(raw))
    if !tooling_strNonEmpty(mode):
        return true
    return tooling_strEq(mode, "mir_dict")

fn tooling_selfhostStrictRebuildEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("SELFHOST_STRICT_REBUILD", "1"))

fn tooling_buildDriverStrictNativeEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("BUILD_DRIVER_STRICT_NATIVE", "1"))

fn tooling_buildDriverAllowFallbackEnabled(): bool =
    # Fallback path has been removed from production closure.
    # Keep env read only for compatibility diagnostics.
    return false

fn tooling_failRemovedBoolEnvEnabled(name: str, replacement: str): bool =
    let raw: str = strutil.strip(os.getEnvDefault(name, ""))
    if !tooling_strNonEmpty(raw):
        return false
    if !tooling_isTrue(raw):
        return false
    var msg: str = "cheng_tooling: removed env " + name
    if tooling_strNonEmpty(replacement):
        msg = msg + ", use " + replacement
    tooling_printErr(msg)
    return true

fn tooling_failRemovedBoolEnvNonZero(name: str, replacement: str): bool =
    let raw: str = strutil.strip(os.getEnvDefault(name, ""))
    if !tooling_strNonEmpty(raw):
        return false
    let normalized: str = tooling_bool01Normalized(raw)
    if tooling_strEq(normalized, "0"):
        return false
    var msg: str = "cheng_tooling: removed env " + name
    if tooling_strNonEmpty(replacement):
        msg = msg + ", use " + replacement
    tooling_printErr(msg)
    return true

fn tooling_failRemovedEnvPresent(name: str, replacement: str): bool =
    let raw: str = strutil.strip(os.getEnvDefault(name, ""))
    if !tooling_strNonEmpty(raw):
        return false
    var msg: str = "cheng_tooling: removed env " + name
    if tooling_strNonEmpty(replacement):
        msg = msg + ", use " + replacement
    tooling_printErr(msg)
    return true

fn tooling_failFixedTrackEnv(name: str, expected: str, trackLabel: str): bool =
    let raw0: str = os.getEnvDefault(name, "")
    let raw: str = strutil.strip(raw0)
    if !tooling_strNonEmpty(raw):
        return false
    let expectedNorm: str = strutil.toLowerAscii(strutil.strip(expected))
    let rawNorm: str = strutil.toLowerAscii(raw)
    if tooling_strEq(rawNorm, expectedNorm):
        tooling_printErr("cheng_tooling: " + trackLabel + " fixes " + name + "=" + expected +
                         "; explicit env override is removed")
    else:
        tooling_printErr("cheng_tooling: " + trackLabel + " only allows " + name + "=" + expected +
                         " (got " + raw + ")")
    return true

fn tooling_rejectRemovedRiskyEnvs(): bool =
    if tooling_failRemovedBoolEnvEnabled("BACKEND_FAST_FALLBACK_ALLOW", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("BACKEND_MM_SKIP_OWNERSHIP", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("DRIVER_SELFBUILD_SMOKE_SKIP_SEM", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("DRIVER_SELFBUILD_SMOKE_SKIP_OWNERSHIP", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("TOOLING_STAGE0_SKIP_UE_GUARD", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("TOOLING_STAGE0_ALLOW_ORPHAN_UE_SOFT_BYPASS", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("TOOLING_STAGE0_ALLOW_EXITING_UE_SOFT_BYPASS", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("TOOLING_STAGE0_ALLOW_UE_OVERRIDE", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("TOOLING_COMPILE_STAGE0_AUTO_REBUILD_ON_PREFLIGHT_FAIL", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("FULLCHAIN_TOOL_FALLBACK_REUSE", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvEnabled("FULLCHAIN_TOOL_STUB_ON_FAIL", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvNonZero("BACKEND_FULLSPEC_SKIP_SEM", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvNonZero("BACKEND_FULLSPEC_SKIP_OWNERSHIP", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvNonZero("FRONTIER_SKIP_SEM", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvNonZero("FRONTIER_SKIP_OWNERSHIP", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvNonZero("FULLCHAIN_TOOL_SKIP_SEM", "fixed=0"):
        return true
    if tooling_failRemovedBoolEnvNonZero("FULLCHAIN_TOOL_SKIP_OWNERSHIP", "fixed=0"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_UIR_SOA_STRICT_RUNTIME_REPORT",
                                     "verify_backend_uir_soa_surface now enforces runtime-only policy (no source fallback)"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_DRIVER", "use `cheng_tooling driver-path` + canonical driver only"):
        return true
    if tooling_failRemovedEnvPresent("CHENG_BACKEND_DRIVER", "use `cheng_tooling driver-path` + canonical driver only"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_RELEASE_DRIVER", "single canonical driver only"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_RELEASE_DRIVER_STAGE0", "single canonical driver only"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_RELEASE_DRIVER_TIMEOUT", "single canonical driver only"):
        return true
    if tooling_failRemovedEnvPresent("SELF_OBJ_BOOTSTRAP_STAGE0", "single canonical driver only"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_BUILD_DRIVER_STAGE0", "single canonical driver only"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_TOOLING_ENTRY", "removed; tooling now uses BACKEND_ALLOW_DIRECT_DRIVER=1 internally"):
        return true
    if tooling_failRemovedEnvPresent("CHENG_BACKEND_FRONTEND", "remove legacy CHENG_* env prefix"):
        return true
    if tooling_failRemovedEnvPresent("CHENG_BACKEND_LINKER", "remove legacy CHENG_* env prefix"):
        return true
    if tooling_failRemovedEnvPresent("CHENG_BACKEND_TARGET", "remove legacy CHENG_* env prefix"):
        return true
    if tooling_failRemovedEnvPresent("CHENG_MM", "remove legacy CHENG_* env prefix"):
        return true
    if tooling_failRemovedEnvPresent("CHENG_CACHE", "remove legacy CHENG_* env prefix"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_ENABLE_CSTRING_LOWERING", "cstring lowering is always on (removed config)"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_CSTRING_LOWERING", "cstring lowering is always on (removed config)"):
        return true
    if tooling_failRemovedEnvPresent("BACKEND_ISEL_CSTRING_LOWERING", "cstring lowering is always on (removed config)"):
        return true
    let genericModeRaw: str = os.getEnvDefault("GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(genericModeRaw):
        tooling_printErr("cheng_tooling: removed env value GENERIC_MODE=" + strutil.strip(genericModeRaw) +
                         ", use GENERIC_MODE=dict")
        return true
    let genericLoweringRaw: str = os.getEnvDefault("GENERIC_LOWERING", "")
    if !tooling_genericLoweringIsDictOnly(genericLoweringRaw):
        tooling_printErr("cheng_tooling: removed env value GENERIC_LOWERING=" + strutil.strip(genericLoweringRaw) +
                         ", use GENERIC_LOWERING=mir_dict")
        return true
    let genericSpecBudgetRaw: str = strutil.strip(os.getEnvDefault("GENERIC_SPEC_BUDGET", ""))
    if tooling_strNonEmpty(genericSpecBudgetRaw):
        let genericSpecBudget: int32 = tooling_parseInt32Default(genericSpecBudgetRaw, 0)
        if genericSpecBudget != 0:
            tooling_printErr("cheng_tooling: removed env value GENERIC_SPEC_BUDGET=" +
                             genericSpecBudgetRaw + ", fixed=0")
            return true
    let closedloopGenericModeRaw: str = os.getEnvDefault("BACKEND_CLOSEDLOOP_STAGE1_GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(closedloopGenericModeRaw):
        tooling_printErr("cheng_tooling: removed env value BACKEND_CLOSEDLOOP_STAGE1_GENERIC_MODE=" +
                         strutil.strip(closedloopGenericModeRaw) + ", use dict")
        return true
    let fullspecGenericModeRaw: str = os.getEnvDefault("BACKEND_FULLSPEC_GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(fullspecGenericModeRaw):
        tooling_printErr("cheng_tooling: removed env value BACKEND_FULLSPEC_GENERIC_MODE=" +
                         strutil.strip(fullspecGenericModeRaw) + ", use dict")
        return true
    let mmGenericModeRaw: str = os.getEnvDefault("BACKEND_MM_GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(mmGenericModeRaw):
        tooling_printErr("cheng_tooling: removed env value BACKEND_MM_GENERIC_MODE=" +
                         strutil.strip(mmGenericModeRaw) + ", use dict")
        return true
    let fullchainGenericModeRaw: str = os.getEnvDefault("FULLCHAIN_TOOL_GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(fullchainGenericModeRaw):
        tooling_printErr("cheng_tooling: removed env value FULLCHAIN_TOOL_GENERIC_MODE=" +
                         strutil.strip(fullchainGenericModeRaw) + ", use dict")
        return true
    let mirBorrowGenericModeRaw: str = os.getEnvDefault("MIR_BORROW_GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(mirBorrowGenericModeRaw):
        tooling_printErr("cheng_tooling: removed env value MIR_BORROW_GENERIC_MODE=" +
                         strutil.strip(mirBorrowGenericModeRaw) + ", use dict")
        return true
    let uirStabilityModesRaw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("UIR_STABILITY_MODES", "")))
    if tooling_strNonEmpty(uirStabilityModesRaw):
        if tooling_strEq(uirStabilityModesRaw, "all") ||
           tooling_strContains(uirStabilityModesRaw, "hybrid"):
            tooling_printErr("cheng_tooling: removed env value UIR_STABILITY_MODES=" +
                             strutil.strip(os.getEnvDefault("UIR_STABILITY_MODES", "")) + ", use dict")
            return true
    let rebuildGenericModeRaw: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_GENERIC_MODE", "")
    if !tooling_genericModeIsDictOnly(rebuildGenericModeRaw):
        tooling_printErr("cheng_tooling: removed env value BACKEND_BUILD_DRIVER_REBUILD_GENERIC_MODE=" +
                         strutil.strip(rebuildGenericModeRaw) + ", use dict")
        return true
    let rebuildGenericLoweringRaw: str = os.getEnvDefault("BACKEND_BUILD_DRIVER_REBUILD_GENERIC_LOWERING", "")
    if !tooling_genericLoweringIsDictOnly(rebuildGenericLoweringRaw):
        tooling_printErr("cheng_tooling: removed env value BACKEND_BUILD_DRIVER_REBUILD_GENERIC_LOWERING=" +
                         strutil.strip(rebuildGenericLoweringRaw) + ", use mir_dict")
        return true
    let compileCrashRetryRaw: str = strutil.strip(os.getEnvDefault("TOOLING_COMPILE_CRASH_RETRY_MAX", ""))
    if tooling_strNonEmpty(compileCrashRetryRaw):
        let compileCrashRetry: int32 = tooling_parseInt32Default(compileCrashRetryRaw, 0)
        if compileCrashRetry > 0:
            tooling_printErr("cheng_tooling: removed env TOOLING_COMPILE_CRASH_RETRY_MAX>0, fixed=0")
            return true
    return false

fn tooling_buildDriverProfileMode(): str =
    let raw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("BACKEND_BUILD_DRIVER_PROFILE_MODE", "backend")))
    if tooling_strEq(raw, "full"):
        return "full"
    if tooling_strEq(raw, "backend") || tooling_strEq(raw, "backend_only"):
        return "backend"
    if tooling_strEq(raw, "stage1") || tooling_strEq(raw, "stage1_uir"):
        return "stage1_uir"
    return "safe"

fn tooling_prefixBuildDriverProfile(cmd: str, profileMode: str): str =
    var out: str = cmd
    if tooling_strEq(profileMode, "full"):
        out = tooling_envAssignCompat("UIR_PROFILE", "1") + out
        out = tooling_envAssignCompat("STAGE1_PROFILE", "1") + out
        out = tooling_envAssignCompat("BACKEND_PROFILE", "1") + out
        return out
    if tooling_strEq(profileMode, "backend"):
        out = tooling_envAssignCompat("BACKEND_PROFILE", "1") + out
        return out
    if tooling_strEq(profileMode, "stage1_uir"):
        out = tooling_envAssignCompat("UIR_PROFILE", "1") + out
        return out
    return out

fn tooling_strEndsWith(text: str, suffix: str): bool =
    if !tooling_strNonEmpty(text) || !tooling_strNonEmpty(suffix):
        return false
    let n: int32 = len(text)
    let m: int32 = len(suffix)
    if m > n:
        return false
    for i in 0..<m:
        if text[n - m + i] != suffix[i]:
            return false
    return true

fn tooling_stripShSuffix(name: str): str =
    if !tooling_strEndsWith(name, ".sh"):
        return name
    let n: int32 = len(name)
    if n <= 3:
        return ""
    return strings.sliceBytes(name, 0, n - 3)

fn tooling_isSafeScriptName(name: str): bool =
    if !tooling_strNonEmpty(name):
        return false
    if strutil.contains(name, ".."):
        return false
    for i in 0..<len(name):
        let ch: char = name[i]
        let isAlphaLower: bool = ch >= 'a' && ch <= 'z'
        let isAlphaUpper: bool = ch >= 'A' && ch <= 'Z'
        let isDigit: bool = ch >= '0' && ch <= '9'
        if isAlphaLower || isAlphaUpper || isDigit || ch == '_' || ch == '-' || ch == '.':
            continue
        return false
    return true

fn tooling_shellQuote(raw: str): str =
    if len(raw) == 0:
        return "\"\""
    var escaped: str = strutil.replace(raw, "\\", "\\\\")
    escaped = strutil.replace(escaped, "$", "\\$")
    escaped = strutil.replace(escaped, "`", "\\`")
    escaped = strutil.replace(escaped, "\"", "\\\"")
    return "\"" + escaped + "\""

fn tooling_isAsciiSpace(ch: char): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn tooling_trimAsciiSpace(raw: str): str =
    if !tooling_strNonEmpty(raw):
        return ""
    let n: int32 = len(raw)
    if n <= 0:
        return ""
    var start: int32 = 0
    while start < n && tooling_isAsciiSpace(raw[start]):
        start = start + 1
    if start >= n:
        return ""
    var stop: int32 = n - 1
    while stop >= start && tooling_isAsciiSpace(raw[stop]):
        stop = stop - 1
    if start == 0 && stop == n - 1:
        return raw
    return strings.sliceBytes(raw, start, stop - start + 1)

fn tooling_stage0CompatPrefixEnabled(): bool =
    return tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_CSTRING_COMPAT", "1"))

fn tooling_stage0HasRemovedCStringCompatMarker(root: str, stage0Exec: str): bool =
    if !tooling_strNonEmpty(stage0Exec):
        return false
    let stage0Path: str = tooling_pathAbsolute(root, stage0Exec)
    if !tooling_strNonEmpty(stage0Path) || !os.fileExists(stage0Path):
        return false
    let markerA: str = "cstring lowering is always on (removed config)"
    let markerB: str = "removed env BACKEND_ENABLE_CSTRING_LOWERING"
    var cmd: str = ""
    cmd = cmd + "if ! command -v strings >/dev/null 2>&1; then exit 2; fi; "
    cmd = cmd + "strings " + tooling_shellQuote(stage0Path) + " 2>/dev/null | "
    cmd = cmd + "grep -Fq " + tooling_shellQuote(markerA) + " || "
    cmd = cmd + "strings " + tooling_shellQuote(stage0Path) + " 2>/dev/null | "
    cmd = cmd + "grep -Fq " + tooling_shellQuote(markerB)
    let res: os.ExecCmdResult = tooling_exec(root, cmd)
    return os.execCmdResultExitCode(res) == 0

fn tooling_stage0NeedsLegacyCStringCompat(root: str, stage0Exec: str): bool =
    if !tooling_stage0CompatPrefixEnabled():
        return false
    let forcedRaw: str = tooling_trimAsciiSpace(os.getEnvDefault("TOOLING_STAGE0_CSTRING_COMPAT_FORCE", ""))
    if tooling_strNonEmpty(forcedRaw):
        return tooling_isTrue(forcedRaw)
    if !tooling_strNonEmpty(stage0Exec):
        return false
    let stage0Path: str = tooling_pathAbsolute(root, stage0Exec)
    var sig: str = stage0Path
    let stage0Sha: str = tooling_sha256File(root, stage0Path)
    if tooling_strNonEmpty(stage0Sha):
        sig = sig + "#" + stage0Sha
    if tooling_stage0CstringCompatProbeDone && tooling_strEq(tooling_stage0CstringCompatProbeSig, sig):
        return tooling_stage0CstringCompatProbeResult
    var probeCmd: str = ""
    var needsCompat: bool = true
    var probeRes: os.ExecCmdResult = tooling_exec(root, "true")
    let markerFastPath: bool = tooling_stage0HasRemovedCStringCompatMarker(root, stage0Path)
    if markerFastPath:
        needsCompat = false
    else:
        probeCmd = probeCmd + tooling_envAssignCompat("BACKEND_ENABLE_CSTRING_LOWERING", "1")
        probeCmd = probeCmd + tooling_shellQuote(stage0Path)
        probeCmd = tooling_prefixUnsetLegacyFrontendEnv(probeCmd)
        probeCmd = tooling_wrapCommandWithTimeout(root, 6, probeCmd)
        probeRes = tooling_exec(root, probeCmd)
        let probeOut: str = os.execCmdResultOutput(probeRes)
        if tooling_strContains(probeOut, "removed env BACKEND_ENABLE_CSTRING_LOWERING") ||
           tooling_strContains(probeOut, "cstring lowering is always on (removed config)"):
            needsCompat = false
    tooling_stage0CstringCompatProbeSig = sig
    tooling_stage0CstringCompatProbeDone = true
    tooling_stage0CstringCompatProbeResult = needsCompat
    if tooling_isTrue(os.getEnvDefault("TOOLING_STAGE0_CSTRING_COMPAT_DEBUG", "0")):
        tooling_printOut("stage0_cstring_compat_probe_exec=" + stage0Exec)
        tooling_printOut("stage0_cstring_compat_probe_rc=" + intToStr(os.execCmdResultExitCode(probeRes)))
        tooling_printOut("stage0_cstring_compat_enabled=" + (needsCompat ? "1" : "0"))
    return needsCompat

fn tooling_stage0LegacyCStringCompatPrefix(root: str, stage0Exec: str): str =
    if !tooling_stage0NeedsLegacyCStringCompat(root, stage0Exec):
        return ""
    var prefix: str = ""
    prefix = prefix + tooling_envAssignCompat("BACKEND_ENABLE_CSTRING_LOWERING", "1")
    prefix = prefix + tooling_envAssignCompat("BACKEND_CSTRING_LOWERING", "1")
    prefix = prefix + tooling_envAssignCompat("BACKEND_ISEL_CSTRING_LOWERING", "1")
    return prefix

fn tooling_envAssignQuoted(name: str, value: str): str =
    if !tooling_strNonEmpty(name):
        return ""
    return name + "=" + tooling_shellQuote(value) + " "

fn tooling_envAssignCompat(name: str, value: str): str =
    if !tooling_strNonEmpty(name):
        return ""
    return tooling_envAssignQuoted(name, value)

fn tooling_prefixUnsetLegacyFrontendEnv(cmd: str): str =
    if !tooling_strNonEmpty(cmd):
        return cmd
    var prefix: str = ""
    # Stable stage0 path hard-disables module-cache surfaces to avoid old dist
    # binaries re-entering recursive cache-error paths.
    prefix = prefix + tooling_envAssignCompat("BACKEND_MULTI_MODULE_CACHE", "0")
    prefix = prefix + tooling_envAssignCompat("BACKEND_MODULE_CACHE", "")
    prefix = prefix + tooling_envAssignCompat("BACKEND_UNIT_BATCH_FILE", "")
    prefix = prefix + tooling_envAssignCompat("BACKEND_UNIT_FILE", "")
    return prefix + cmd

fn tooling_rootFromExecutablePath(): str =
    let raw0: str = strutil.strip(tooling_paramStr(0))
    if !tooling_strNonEmpty(raw0):
        return ""
    var abs0: str = raw0
    if !os.isAbsolute(abs0):
        abs0 = os.absolutePath(abs0)
    if !tooling_strNonEmpty(abs0):
        return ""
    var probe: str = os.parentDir(abs0)
    var depth: int32 = 0
    while tooling_strNonEmpty(probe) && depth < 10:
        let marker: str = os.joinPath(probe, "src/tooling/cheng_tooling.cheng")
        if os.fileExists(marker):
            return probe
        let parent: str = os.parentDir(probe)
        if !tooling_strNonEmpty(parent) || tooling_strEq(parent, probe):
            break
        probe = parent
        depth = depth + 1
    return ""

fn tooling_findSubstr(hay: str, needle: str): int32 =
    if !tooling_strNonEmpty(hay) || !tooling_strNonEmpty(needle):
        return -1
    let n: int32 = len(hay)
    let m: int32 = len(needle)
    if m <= 0 || n < m:
        return -1
    for i in 0..n - m:
        var matched: bool = true
        for j in 0..<m:
            if hay[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn tooling_rootFromExecutableMarker(): str =
    let raw0: str = strutil.strip(tooling_paramStr(0))
    if !tooling_strNonEmpty(raw0):
        return ""
    var abs0: str = raw0
    if !os.isAbsolute(abs0):
        abs0 = os.absolutePath(abs0)
    if !tooling_strNonEmpty(abs0):
        return ""
    let marker: str = "/artifacts/tooling_cmd/"
    let hit: int32 = tooling_findSubstr(abs0, marker)
    if hit <= 0:
        return ""
    return strings.sliceBytes(abs0, 0, hit)

fn tooling_root(): str =
    let envRoot: str = strutil.strip(os.getEnvDefault("TOOLING_ROOT", ""))
    if tooling_strNonEmpty(envRoot):
        return envRoot
    let fromExe: str = tooling_rootFromExecutablePath()
    if tooling_strNonEmpty(fromExe):
        return fromExe
    let fromMarker: str = tooling_rootFromExecutableMarker()
    if tooling_strNonEmpty(fromMarker):
        return fromMarker
    let fromPwd: str = strutil.strip(os.getEnvDefault("PWD", ""))
    if tooling_strNonEmpty(fromPwd):
        return fromPwd
    return os.getCurrentDir()

fn tooling_scriptDir(root: str): str =
    return os.joinPath(root, "src/tooling")

fn tooling_embeddedPrefix(): str =
    return "embedded:"

fn tooling_scriptIdFromResolvedPath(scriptPath: str): str =
    let prefix: str = tooling_embeddedPrefix()
    if !strutil.startsWith(scriptPath, prefix):
        return ""
    return strings.dropPrefix(scriptPath, prefix)

fn tooling_splitLines(raw: str): str[] =
    var out: str[] = []
    if !tooling_strNonEmpty(raw):
        return out
    let n: int32 = len(raw)
    var start: int32 = 0
    var i: int32 = 0
    for _ in 0..<n:
        if raw[i] == '\n':
            if i > start:
                let piece: str = strutil.strip(strings.sliceBytes(raw, start, i - start))
                if tooling_strNonEmpty(piece):
                    add(out, piece)
            start = i + 1
        i = i + 1
    if start < n:
        let tail: str = strutil.strip(strings.sliceBytes(raw, start, n - start))
        if tooling_strNonEmpty(tail):
            add(out, tail)
    return out

fn tooling_readTextFile(root: str, pathRaw: str): str =
    let path: str = tooling_pathAbsolute(root, pathRaw)
    if !tooling_strNonEmpty(path) || !os.fileExists(path):
        return ""
    let res: os.ExecCmdResult = tooling_exec(root, "cat " + tooling_shellQuote(path))
    if os.execCmdResultExitCode(res) != 0:
        return ""
    return os.execCmdResultOutput(res)

fn tooling_kvGet(raw: str, key: str): str =
    if !tooling_strNonEmpty(raw) || !tooling_strNonEmpty(key):
        return ""
    let rows: str[] = tooling_splitLines(raw)
    let prefix: str = key + "="
    for i in 0..<rows.len:
        let line: str = strutil.strip(rows[i])
        if !tooling_strNonEmpty(line):
            continue
        if strutil.startsWith(line, prefix):
            return strings.dropPrefix(line, prefix)
    return ""

fn tooling_stage0CapabilitySourceList(): str[] =
    var out: str[] = []
    add(out, "src/stage1/ast.cheng")
    add(out, "src/stage1/parser.cheng")
    add(out, "src/stage1/semantics.cheng")
    add(out, "src/stage1/ownership.cheng")
    add(out, "src/stage1/monomorphize.cheng")
    add(out, "src/stage1/type_syntax_lowering.cheng")
    add(out, "src/backend/uir/uir_internal/uir_core_types.cheng")
    add(out, "src/backend/tooling/backend_driver.cheng")
    return out

fn tooling_stage0CapabilityFilePath(stage0Path: str): str =
    if !tooling_strNonEmpty(stage0Path):
        return ""
    return stage0Path + ".cap.env"

fn tooling_stage0CapabilityEnsureCache(root: str): bool =
    if tooling_strNonEmpty(tooling_stage0CapabilitySignatureCache) &&
       tooling_strNonEmpty(tooling_stage0CapabilityManifestCache):
        return true
    let files: str[] = tooling_stage0CapabilitySourceList()
    if files.len <= 0:
        return false
    var manifest: str = ""
    for i in 0..<files.len:
        let rel: str = files[i]
        let absPath: str = tooling_pathAbsolute(root, rel)
        if !os.fileExists(absPath):
            tooling_printErr("cheng_tooling: stage0 capability source missing: " + rel)
            return false
        let sha: str = tooling_sha256File(root, absPath)
        if !tooling_strNonEmpty(sha):
            tooling_printErr("cheng_tooling: stage0 capability sha256 failed: " + rel)
            return false
        manifest = manifest + rel + "=" + sha + "\n"
    let tmpDir: str = os.joinPath(root, "chengcache")
    tooling_tryMkdirP(root, tmpDir)
    let tmpPath: str = os.joinPath(tmpDir, "tooling_stage0_capability." + tooling_nowNonceText() + ".txt")
    os.writeFile(tmpPath, manifest)
    let signature: str = tooling_sha256File(root, tmpPath)
    if os.fileExists(tmpPath):
        os.removeFile(tmpPath)
    if !tooling_strNonEmpty(signature):
        tooling_printErr("cheng_tooling: stage0 capability signature generation failed")
        return false
    tooling_stage0CapabilityManifestCache = manifest
    tooling_stage0CapabilitySignatureCache = signature
    return true

fn tooling_stage0CapabilitySignature(root: str): str =
    if !tooling_stage0CapabilityEnsureCache(root):
        return ""
    return tooling_stage0CapabilitySignatureCache

fn tooling_stage0CapabilityWriteForOutput(root: str, outPathRaw: str): bool =
    let outPath: str = tooling_pathAbsolute(root, outPathRaw)
    if !tooling_strNonEmpty(outPath):
        return false
    if !tooling_stage0CapabilityEnsureCache(root):
        return false
    let capPath: str = tooling_stage0CapabilityFilePath(outPath)
    if !tooling_strNonEmpty(capPath):
        return false
    let capDir: str = os.parentDir(capPath)
    if tooling_strNonEmpty(capDir):
        tooling_tryMkdirP(root, capDir)
    let files: str[] = tooling_stage0CapabilitySourceList()
    var text: str = ""
    text = text + "version=1\n"
    text = text + "signature=" + tooling_stage0CapabilitySignatureCache + "\n"
    text = text + "source_count=" + intToStr(files.len) + "\n"
    text = text + "manifest=\n" + tooling_stage0CapabilityManifestCache
    os.writeFile(capPath, text)
    return os.fileExists(capPath)

fn tooling_stage0CapabilityPreflightOk(root: str, stage0PathRaw: str, contextRaw: str): bool =
    let enabled: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_CAPABILITY_PREFLIGHT", "1"))
    if !enabled:
        return true
    let stage0Path: str = tooling_pathAbsolute(root, stage0PathRaw)
    if !tooling_strNonEmpty(stage0Path):
        return false
    let capPath: str = tooling_stage0CapabilityFilePath(stage0Path)
    var context: str = strutil.strip(contextRaw)
    if !tooling_strNonEmpty(context):
        context = "stage0_preflight"
    let requireCapFile: bool = tooling_isTrue(
        os.getEnvDefault("TOOLING_STAGE0_CAPABILITY_REQUIRE_FILE", "0"))
    if !os.fileExists(capPath):
        if requireCapFile:
            tooling_printErr("cheng_tooling: stage0 capability file missing: " + capPath)
            tooling_printErr("cheng_tooling: capability preflight failed (" + context +
                             "); refresh seed/driver via `BOOTSTRAP_UPDATE_SEED=1 artifacts/tooling_cmd/cheng_tooling bootstrap-pure --mode:strict --compile-stage1 --fullspec`")
            return false
        return true
    let currentSig: str = tooling_stage0CapabilitySignature(root)
    if !tooling_strNonEmpty(currentSig):
        tooling_printErr("cheng_tooling: stage0 capability preflight skipped (signature unavailable)")
        return true
    let capRaw: str = tooling_readTextFile(root, capPath)
    let stage0Sig: str = tooling_kvGet(capRaw, "signature")
    if !tooling_strNonEmpty(stage0Sig):
        if requireCapFile:
            tooling_printErr("cheng_tooling: stage0 capability signature missing in " + capPath)
            return false
        return true
    if tooling_strEq(stage0Sig, currentSig):
        return true
    tooling_printErr("cheng_tooling: stage0 capability mismatch (" + context + ")")
    tooling_printErr("cheng_tooling: stage0=" + stage0Path)
    tooling_printErr("cheng_tooling: stage0_capability_signature=" + stage0Sig)
    tooling_printErr("cheng_tooling: source_capability_signature=" + currentSig)
    tooling_printErr("cheng_tooling: hint: refresh seed + canonical driver")
    tooling_printErr("cheng_tooling:   BOOTSTRAP_UPDATE_SEED=1 artifacts/tooling_cmd/cheng_tooling bootstrap-pure --mode:strict --compile-stage1 --fullspec")
    tooling_printErr("cheng_tooling:   artifacts/tooling_cmd/cheng_tooling build-backend-driver --require-rebuild")
    return false

fn tooling_buildGlobalCrashMemoPath(root: str): str =
    return os.joinPath(root, "chengcache/tooling_cmd/build_global.crash_pref.env")

fn tooling_buildGlobalSafeFromMemo(root: str, memoPathRaw: str, driverPath: str, srcPath: str,
                                   target: str, linker: str, driverSha: str, srcSha: str): bool =
    let memoPath: str = tooling_pathAbsolute(root, memoPathRaw)
    if !tooling_strNonEmpty(memoPath) || !os.fileExists(memoPath):
        return false
    if !tooling_strNonEmpty(driverSha) || !tooling_strNonEmpty(srcSha):
        return false
    let raw: str = tooling_readTextFile(root, memoPath)
    if !tooling_strEq(tooling_kvGet(raw, "version"), "1"):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "prefer_safe"), "1"):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "driver_path"), tooling_pathAbsolute(root, driverPath)):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "driver_sha"), driverSha):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "src_path"), tooling_pathAbsolute(root, srcPath)):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "src_sha"), srcSha):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "target"), target):
        return false
    if !tooling_strEq(tooling_kvGet(raw, "linker"), linker):
        return false
    return true

fn tooling_buildGlobalWriteCrashMemo(root: str, memoPathRaw: str, driverPath: str, srcPath: str,
                                     target: str, linker: str, driverSha: str, srcSha: str,
                                     preferSafe: bool) =
    let memoPath: str = tooling_pathAbsolute(root, memoPathRaw)
    if !tooling_strNonEmpty(memoPath):
        return
    let memoDir: str = os.parentDir(memoPath)
    if tooling_strNonEmpty(memoDir):
        tooling_tryMkdirP(root, memoDir)
    let preferSafeText: str = preferSafe ? "1" : "0"
    var text: str = ""
    text = text + "version=1\n"
    text = text + "prefer_safe=" + preferSafeText + "\n"
    text = text + "driver_path=" + tooling_pathAbsolute(root, driverPath) + "\n"
    text = text + "driver_sha=" + driverSha + "\n"
    text = text + "src_path=" + tooling_pathAbsolute(root, srcPath) + "\n"
    text = text + "src_sha=" + srcSha + "\n"
    text = text + "target=" + target + "\n"
    text = text + "linker=" + linker + "\n"
    os.writeFile(memoPath, text)

fn tooling_escapeEmbeddedMapString(text: str): str =
    if len(text) == 0:
        return ""
    var out: str = ""
    let n: int32 = len(text)
    var i: int32 = 0
    while i < n:
        let ch: char = text[i]
        if ch == '\\':
            out = out + "\\\\"
        elif ch == '"':
            out = out + "\\\""
        elif ch == '\n':
            out = out + "\\n"
        elif ch == '\t':
            out = out + "\\t"
        elif ch == '\r':
            out = out + "\\r"
        else:
            out = out + strings.sliceBytes(text, i, 1)
        i = i + 1
    return out

fn tooling_splitEmbeddedEscapedChunks(text: str, chunkSizeRaw: int32): str[] =
    var out: str[] = []
    if !tooling_strNonEmpty(text):
        add(out, "")
        return out
    var chunkSize: int32 = chunkSizeRaw
    if chunkSize <= 0:
        chunkSize = len(text)
    let n: int32 = len(text)
    var start: int32 = 0
    while start < n:
        var end: int32 = start + chunkSize
        if end >= n:
            add(out, strings.sliceBytes(text, start, n - start))
            break
        while end < n:
            var slashRun: int32 = 0
            var j: int32 = end - 1
            while j >= start && text[j] == '\\':
                slashRun = slashRun + 1
                j = j - 1
            if slashRun % 2 == 0:
                break
            end = end + 1
        if end > n:
            end = n
        add(out, strings.sliceBytes(text, start, end - start))
        start = end
    return out

fn tooling_renderEmbeddedMapText(root: str): str =
    let ids: str[] = tooling_collectScripts(root)
    var out: str = ""
    out = out + "# Auto-generated embedded tooling command payload map.\n"
    out = out + "# Source: former src/tooling/tooling_inline/*.inline + src/tooling/verify_inline/*.inline.\n"
    out = out + "# Generated by cheng_tooling embedded-map-rewrite.\n"
    out = out + "# Do not edit manually.\n\n"
    out = out + "fn toolingEmbeddedScriptIds(): str[] =\n"
    out = out + "    var out: str[] = []\n"
    for i in 0..<ids.len:
        out = out + "    add(out, \"" + ids[i] + "\")\n"
    out = out + "    return out\n\n"
    out = out + "fn toolingEmbeddedScriptBody(id: str): str =\n"
    for i in 0..<ids.len:
        let sid: str = ids[i]
        let rawBody: str = tooling_embeddedScriptText(root, sid)
        let encoded: str = tooling_escapeEmbeddedMapString(rawBody)
        out = out + "    if id == \"" + sid + "\":\n"
        if len(encoded) <= 1800:
            out = out + "        return \"" + encoded + "\"\n"
        else:
            out = out + "        var out: str = \"\"\n"
            let chunks: str[] = tooling_splitEmbeddedEscapedChunks(encoded, 1500)
            for j in 0..<chunks.len:
                out = out + "        out = out + \"" + chunks[j] + "\"\n"
            out = out + "        return out\n"
    out = out + "    return \"\"\n"
    return out

fn tooling_embeddedScriptIds(root: str): str[] =
    var out: str[] = []
    let ids: str[] = tooling_embedded_inline.toolingEmbeddedScriptIds()
    for i in 0..<ids.len:
        let id: str = ids[i]
        if tooling_strEq(id, "chengb"):
            continue
        if !tooling_isSafeScriptName(id):
            continue
        if tooling_idsContains(out, id):
            continue
        add(out, id)
    # Keep synthetic compatibility IDs available even if the embedded map
    # was generated by an older toolchain.
    var synthetic: str[] = []
    add(synthetic, "verify")
    add(synthetic, "verify_tooling_cmdline")
    add(synthetic, "verify_backend_zero_script_closure")
    add(synthetic, "verify_backend_driver_unified_global")
    add(synthetic, "verify_backend_compile_name_canonical")
    add(synthetic, "verify_backend_dev_track_only")
    add(synthetic, "verify_backend_rawptr_surface_forbid")
    add(synthetic, "verify_stage1_ast_soa_surface")
    add(synthetic, "verify_backend_rawptr_migration")
    add(synthetic, "verify_backend_uir_soa_surface")
    add(synthetic, "verify_backend_uir_soa_self_probe")
    add(synthetic, "verify_backend_rawptr_closedloop")
    add(synthetic, "verify_backend_linker_abi_core_cross")
    add(synthetic, "verify_backend_symbol_closure")
    add(synthetic, "verify_backend_new_expr_ref_stability")
    add(synthetic, "verify_backend_release_compile_stability")
    add(synthetic, "verify_backend_zero_script_residual")
    add(synthetic, "verify_backend_emit_c_surface")
    add(synthetic, "verify_backend_emit_c_ffi_shadow")
    add(synthetic, "verify_backend_emit_c_hard_fail")
    add(synthetic, "build_backend_native_contract")
    add(synthetic, "verify_backend_native_contract")
    add(synthetic, "verify_backend_native_contract_autosystem")
    for i in 0..<synthetic.len:
        let sid: str = synthetic[i]
        if !tooling_isSafeScriptName(sid):
            continue
        if tooling_idsContains(out, sid):
            continue
        add(out, sid)
    return out

fn tooling_embeddedNativeForwardScript(subcmd: str): str =
    var out: str = ""
    out = out + "#!/usr/bin/env sh\n"
    out = out + ":\n"
    out = out + "set -eu\n"
    out = out + "(set -o pipefail) 2>/dev/null && set -o pipefail\n"
    out = out + "tool=\"${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling}\"\n"
    out = out + "exec \"$tool\" " + subcmd + " \"$@\"\n"
    return out

fn tooling_normalizeEmbeddedScriptText(id: str, raw: str): str =
    var out: str = raw
    out = strutil.replace(out, "src/tooling/backend_prod_closure.sh", "src/tooling/cheng_tooling_embedded_inline.cheng")
    out = strutil.replace(out, "FRONTIER_SKIP_SEM=\"${FRONTIER_SKIP_SEM:-1}\"", "FRONTIER_SKIP_SEM=\"0\"")
    out = strutil.replace(out, "FRONTIER_SKIP_SEM=\"${FRONTIER_SKIP_SEM:-0}\"", "FRONTIER_SKIP_SEM=\"0\"")
    out = strutil.replace(out, "FRONTIER_SKIP_OWNERSHIP=\"${FRONTIER_SKIP_OWNERSHIP:-1}\"", "FRONTIER_SKIP_OWNERSHIP=\"0\"")
    out = strutil.replace(out, "FRONTIER_SKIP_OWNERSHIP=\"${FRONTIER_SKIP_OWNERSHIP:-0}\"", "FRONTIER_SKIP_OWNERSHIP=\"0\"")
    out = strutil.replace(out, "FRONTIER_SKIP_SEM=<0|1>      Stage1 skip semantics (default: 1)",
                          "FRONTIER_SKIP_SEM=<removed>  fixed=0 (removed config)")
    out = strutil.replace(out, "FRONTIER_SKIP_OWNERSHIP=<0|1> Stage1 skip ownership (default: 1)",
                          "FRONTIER_SKIP_OWNERSHIP=<removed> fixed=0 (removed config)")
    out = strutil.replace(out, "FULLCHAIN_TOOL_SKIP_SEM=\"${FULLCHAIN_TOOL_SKIP_SEM:-1}\"", "FULLCHAIN_TOOL_SKIP_SEM=\"0\"")
    out = strutil.replace(out, "FULLCHAIN_TOOL_SKIP_SEM=\"${FULLCHAIN_TOOL_SKIP_SEM:-0}\"", "FULLCHAIN_TOOL_SKIP_SEM=\"0\"")
    out = strutil.replace(out, "FULLCHAIN_TOOL_SKIP_OWNERSHIP=\"${FULLCHAIN_TOOL_SKIP_OWNERSHIP:-1}\"", "FULLCHAIN_TOOL_SKIP_OWNERSHIP=\"0\"")
    out = strutil.replace(out, "FULLCHAIN_TOOL_SKIP_OWNERSHIP=\"${FULLCHAIN_TOOL_SKIP_OWNERSHIP:-0}\"", "FULLCHAIN_TOOL_SKIP_OWNERSHIP=\"0\"")
    out = strutil.replace(out, "STAGE1_SEM_FIXED_0=\"${FULLCHAIN_TOOL_SKIP_SEM:-1}\"", "STAGE1_SEM_FIXED_0=\"0\"")
    out = strutil.replace(out, "STAGE1_SEM_FIXED_0=\"${FULLCHAIN_TOOL_SKIP_SEM:-0}\"", "STAGE1_SEM_FIXED_0=\"0\"")
    out = strutil.replace(out, "STAGE1_OWNERSHIP_FIXED_0=\"${FULLCHAIN_TOOL_SKIP_OWNERSHIP:-1}\"", "STAGE1_OWNERSHIP_FIXED_0=\"0\"")
    out = strutil.replace(out, "STAGE1_OWNERSHIP_FIXED_0=\"${FULLCHAIN_TOOL_SKIP_OWNERSHIP:-0}\"", "STAGE1_OWNERSHIP_FIXED_0=\"0\"")
    if tooling_strEq(id, "verify_backend_hotpatch") ||
       tooling_strEq(id, "verify_backend_hotpatch_meta") ||
       tooling_strEq(id, "verify_backend_driver_selfbuild_smoke") ||
       tooling_strEq(id, "verify_backend_mm") ||
       tooling_strEq(id, "verify_fullchain_bootstrap") ||
       tooling_strEq(id, "backend_prod_closure"):
        return out

    if tooling_strEq(id, "verify_backend_mem_contract"):
        out = strutil.replace(out, "if ! rg -q 'run_required \\\"backend.mem_contract\\\"' \"$prod_closure_file\"; then",
                              "if ! rg -q 'backend.mem_contract' \"$prod_closure_file\"; then")
    if tooling_strEq(id, "verify_backend_dod_contract"):
        out = strutil.replace(out, "if ! rg -q 'run_required \\\"backend.dod_contract\\\"' \"$prod_closure_file\"; then",
                              "if ! rg -q 'backend.dod_contract' \"$prod_closure_file\"; then")
    if tooling_strEq(id, "verify_backend_profile_baseline"):
        out = strutil.replace(out, "if ! rg -q 'run_required \\\"backend.profile_schema\\\"' \"$prod_closure_file\"; then",
                              "if ! rg -q 'backend.profile_schema' \"$prod_closure_file\"; then")
        out = strutil.replace(out, "if ! rg -q 'run_required \\\"backend.profile_baseline\\\"' \"$prod_closure_file\"; then",
                              "if ! rg -q 'backend.profile_baseline' \"$prod_closure_file\"; then")
    if tooling_strEq(id, "verify_backend_rawptr_migration"):
        out = strutil.replace(out, "if ! rg -q 'run_required \\\"backend.rawptr_migration\\\"' \"$prod_closure_file\"; then",
                              "if ! rg -q 'backend.rawptr_migration' \"$prod_closure_file\"; then")
    if tooling_strEq(id, "verify_backend_mem_exe_emit"):
        out = strutil.replace(out, "chengc_file=\"src/tooling/chengc.sh\"",
                              "chengc_file=\"src/tooling/cheng_tooling_embedded_inline.cheng\"")
        out = strutil.replace(out, "link_env_file=\"src/tooling/backend_link_env.sh\"",
                              "link_env_file=\"src/tooling/cheng_tooling_embedded_inline.cheng\"")
    if tooling_strEq(id, "verify_backend_hotpatch_inplace"):
        out = strutil.replace(out, "runner_file=\"src/tooling/backend_host_runner.sh\"",
                              "runner_file=\"src/tooling/cheng_tooling_embedded_inline.cheng\"")
        out = strutil.replace(out, "apply_file=\"src/tooling/backend_hotpatch_apply.sh\"",
                              "apply_file=\"src/tooling/cheng_tooling_embedded_inline.cheng\"")
        out = strutil.replace(out,
                              "marker_append=\"$(count_marker \"$runner_file\" 'commit_kind=\"append\"')\"",
                              "marker_append=\"$(count_marker \"$runner_file\" 'commit_kind')\"")
        out = strutil.replace(out,
                              "marker_restart_layout=\"$(count_marker \"$runner_file\" 'restart_reason=\"layout_change\"')\"",
                              "marker_restart_layout=\"$(count_marker \"$runner_file\" 'layout_change')\"")
        out = strutil.replace(out,
                              "marker_restart_pool=\"$(count_marker \"$runner_file\" 'restart_reason=\"pool_exhausted\"')\"",
                              "marker_restart_pool=\"$(count_marker \"$runner_file\" 'pool_exhausted')\"")
        out = strutil.replace(out,
                              "marker_apply_delegate=\"$(count_marker \"$apply_file\" 'commit_args=\"--state:')\"",
                              "marker_apply_delegate=\"$(count_marker \"$apply_file\" 'commit_args=')\"")
    if tooling_strEq(id, "backend_hotpatch_apply"):
        out = strutil.replace(out, "runner_inline=\"src/tooling/backend_host_runner.sh\"",
                              "runner_inline=\"src/tooling/cheng_tooling_embedded_inline.cheng\"")
    if tooling_strEq(id, "verify_backend_closedloop"):
        out = strutil.replace(out,
                              "profile_smoke_fixture=\"tests/cheng/backend/fixtures/return_add.cheng\"\n",
                              "closedloop_minimal=\"${BACKEND_CLOSEDLOOP_MINIMAL:-0}\"\nprofile_smoke_fixture=\"tests/cheng/backend/fixtures/return_add.cheng\"\n")
        out = strutil.replace(
            out,
            "backend_runtime_obj=\"${BACKEND_RUNTIME_OBJ:-chengcache/system_helpers.backend.cheng.${safe_target}.o}\"\n",
            "backend_runtime_obj=\"${BACKEND_RUNTIME_OBJ:-}\"\n\nruntime_nm_has_sym() {\n  sym=\"$1\"\n  printf '%s\\n' \"$nm_out\" | awk '{print $NF}' | sed 's/^_//' | grep -Fxq \"$sym\"\n}\n\nruntime_has_core_symbols() {\n  obj=\"$1\"\n  [ -f \"$obj\" ] || return 1\n  if ! command -v nm >/dev/null 2>&1; then\n    return 1\n  fi\n  nm_out=\"$(nm -g \"$obj\" 2>/dev/null || true)\"\n  [ \"$nm_out\" != \"\" ] || return 1\n  runtime_nm_has_sym cheng_strlen &&\n  runtime_nm_has_sym cheng_memcpy &&\n  runtime_nm_has_sym cheng_memset &&\n  runtime_nm_has_sym cheng_malloc &&\n  runtime_nm_has_sym cheng_free &&\n  runtime_nm_has_sym cheng_mem_retain &&\n  runtime_nm_has_sym cheng_mem_release &&\n  runtime_nm_has_sym cheng_seq_get &&\n  runtime_nm_has_sym cheng_seq_set &&\n  runtime_nm_has_sym cheng_strcmp &&\n  runtime_nm_has_sym cheng_f32_bits_to_i64 &&\n  runtime_nm_has_sym cheng_f64_bits_to_i64 &&\n  runtime_nm_has_sym cheng_open_w_trunc\n}\n\nresolve_runtime_obj() {\n  if [ \"$backend_runtime_obj\" != \"\" ]; then\n    if [ -f \"$backend_runtime_obj\" ] && runtime_has_core_symbols \"$backend_runtime_obj\"; then\n      printf '%s\\n' \"$backend_runtime_obj\"\n      return 0\n    fi\n    echo \"[Warn] ignore explicit BACKEND_RUNTIME_OBJ (missing required self-link symbols): $backend_runtime_obj\" 1>&2\n  fi\n  candidates=\"\nchengcache/runtime_selflink/system_helpers.backend.combined.${backend_target}.o\nartifacts/backend_mm/system_helpers.backend.combined.${backend_target}.o\n\"\n  for cand in $candidates; do\n    [ \"$cand\" != \"\" ] || continue\n    if [ -f \"$cand\" ] && runtime_has_core_symbols \"$cand\"; then\n      printf '%s\\n' \"$cand\"\n      return 0\n    fi\n  done\n  return 1\n}\n\nif [ \"$backend_linker\" = \"self\" ]; then\n  backend_runtime_obj=\"$(resolve_runtime_obj || true)\"\nfi\n")
        out = strutil.replace(
            out,
            "resolve_runtime_obj() {\n  if [ \"$backend_runtime_obj\" != \"\" ]; then\n    printf '%s\\n' \"$backend_runtime_obj\"\n    return 0\n  fi\n  candidates=\"\n",
            "resolve_runtime_obj() {\n  if [ \"$backend_runtime_obj\" != \"\" ]; then\n    if [ -f \"$backend_runtime_obj\" ] && runtime_has_core_symbols \"$backend_runtime_obj\"; then\n      printf '%s\\n' \"$backend_runtime_obj\"\n      return 0\n    fi\n    echo \"[Warn] ignore explicit BACKEND_RUNTIME_OBJ (missing required self-link symbols): $backend_runtime_obj\" 1>&2\n  fi\n  candidates=\"\n")
        out = strutil.replace(out,
                              "run_step \"backend.profile_smoke\" env \\\n",
                              "if [ \"$closedloop_minimal\" = \"1\" ]; then\n  echo \"== backend.closedloop.pre_gates (skip: BACKEND_CLOSEDLOOP_MINIMAL=1) ==\"\nelse\nrun_step \"backend.profile_smoke\" env \\\n")
        out = strutil.replace(out,
                              "\nrm -rf artifacts/backend_closedloop\n",
                              "\nfi\n\nrm -rf artifacts/backend_closedloop\n")

    return out

fn tooling_embeddedScriptText(root: str, id: str): str =
    if !tooling_isSafeScriptName(id):
        return ""
    if tooling_strEq(id, "backend_driver_path"):
        # Keep embedded runner path strict and canonical by forwarding to native command.
        return tooling_embeddedNativeForwardScript("backend_driver_path")
    if tooling_strEq(id, "toolchain_root"):
        return tooling_embeddedNativeForwardScript("toolchain_root")
    if tooling_strEq(id, "build_backend_rawptr_contract"):
        return tooling_embeddedNativeForwardScript("build_backend_rawptr_contract")
    if tooling_strEq(id, "build_backend_mem_contract"):
        return tooling_embeddedNativeForwardScript("build_backend_mem_contract")
    if tooling_strEq(id, "build_backend_dod_contract"):
        return tooling_embeddedNativeForwardScript("build_backend_dod_contract")
    if tooling_strEq(id, "build_backend_native_contract"):
        return tooling_embeddedNativeForwardScript("build_backend_native_contract")
    if tooling_strEq(id, "build_backend_profile_schema"):
        return tooling_embeddedNativeForwardScript("build_backend_profile_schema")
    if tooling_strEq(id, "build_backend_profile_baseline"):
        return tooling_embeddedNativeForwardScript("build_backend_profile_baseline")
    if tooling_strEq(id, "verify_backend_native_contract"):
        return tooling_embeddedNativeForwardScript("verify_backend_native_contract")
    if tooling_strEq(id, "verify_backend_native_contract_autosystem"):
        return tooling_embeddedNativeForwardScript("verify_backend_native_contract_autosystem")
    if tooling_strEq(id, "verify_backend_new_expr_ref_stability"):
        return tooling_embeddedNativeForwardScript("verify_backend_new_expr_ref_stability")
    if tooling_strEq(id, "verify_backend_opt2_impl_surface"):
        return tooling_embeddedNativeForwardScript("verify_backend_opt2_impl_surface")
    if tooling_strEq(id, "verify_backend_driver_unified_global"):
        return tooling_embeddedNativeForwardScript("verify_backend_driver_unified_global")
    if tooling_strEq(id, "verify_backend_compile_name_canonical"):
        return tooling_embeddedNativeForwardScript("verify_backend_compile_name_canonical")
    if tooling_strEq(id, "verify_backend_dev_track_only"):
        return tooling_embeddedNativeForwardScript("verify_backend_dev_track_only")
    if tooling_strEq(id, "verify_backend_rawptr_surface_forbid"):
        return tooling_embeddedNativeForwardScript("verify_backend_rawptr_surface_forbid")
    if tooling_strEq(id, "verify_stage1_ast_soa_surface"):
        return tooling_embeddedNativeForwardScript("verify_stage1_ast_soa_surface")
    if tooling_strEq(id, "verify_backend_rawptr_migration"):
        return tooling_embeddedNativeForwardScript("verify_backend_rawptr_migration")
    if tooling_strEq(id, "verify_backend_uir_soa_surface"):
        return tooling_embeddedNativeForwardScript("verify_backend_uir_soa_surface")
    if tooling_strEq(id, "verify_backend_uir_soa_self_probe"):
        return tooling_embeddedNativeForwardScript("verify_backend_uir_soa_self_probe")
    if tooling_strEq(id, "backend_prod_publish") || tooling_strEq(id, "backend-prod-publish"):
        return tooling_embeddedNativeForwardScript("backend-prod-publish")
    if tooling_strEq(id, "release_compile") || tooling_strEq(id, "release-compile"):
        return tooling_embeddedNativeForwardScript("release-compile")
    if tooling_strEq(id, "verify_backend_rawptr_contract"):
        let rawRawptrContract: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawRawptrContract):
            return ""
        var patchedRawptrContract: str = rawRawptrContract
        patchedRawptrContract = strutil.replace(
            patchedRawptrContract,
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} embedded-text --id:backend_prod_closure >\"$prod_closure_body\"\n",
            "prod_closure_cache=\"chengcache/embedded_scripts/backend_prod_closure.embedded.sh\"\nif [ -s \"$prod_closure_cache\" ]; then\n  cp \"$prod_closure_cache\" \"$prod_closure_body\"\nelse\n  ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_prod_closure --help >/dev/null 2>&1 || true\n  if [ -s \"$prod_closure_cache\" ]; then\n    cp \"$prod_closure_cache\" \"$prod_closure_body\"\n  else\n    ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} embedded-text --id:backend_prod_closure >\"$prod_closure_body\"\n  fi\nfi\n")
        patchedRawptrContract = strutil.replace(
            patchedRawptrContract,
            "prod_closure_cache=\"chengcache/embedded_scripts/backend_prod_closure.embedded.sh\"\nif [ -s \"$prod_closure_cache\" ]; then\n  cp \"$prod_closure_cache\" \"$prod_closure_body\"\nelse\n  ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_prod_closure --help >/dev/null 2>&1 || true\n  if [ -s \"$prod_closure_cache\" ]; then\n    cp \"$prod_closure_cache\" \"$prod_closure_body\"\n  else\n    ${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} embedded-text --id:backend_prod_closure >\"$prod_closure_body\"\n  fi\nfi\n",
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_prod_closure --help >\"$prod_closure_body\" 2>/dev/null || true\n")
        patchedRawptrContract = strutil.replace(
            patchedRawptrContract,
            "if ! rg -q \"run_required \\\"$gate_clean\\\"\" \"$prod_closure_body\"; then",
            "if ! rg -q 'tooling_strEq\\(first, \"backend_prod_closure\"\\)' src/tooling/cheng_tooling.cheng || ! rg -q 'tooling_strEq\\(selfName, \"backend_prod_closure\"\\)' src/tooling/cheng_tooling.cheng; then")
        return patchedRawptrContract
    if tooling_strEq(id, "verify_backend_coff_lld_link"):
        let rawCoff: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawCoff):
            return ""
        return strutil.replace(rawCoff, "BACKEND_EMIT=obj", "BACKEND_INTERNAL_ALLOW_EMIT_OBJ=1 BACKEND_EMIT=obj")
    if tooling_strEq(id, "verify_backend_mm"):
        let rawMm: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawMm):
            return ""
        var patchedMm: str = rawMm
        patchedMm = strutil.replace(
            patchedMm,
            "driver=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_driver_path --path-only)\"",
            "driver=\"${BACKEND_DRIVER:-}\"\nif [ \"$driver\" = \"\" ]; then\n  driver=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_driver_path --path-only)\"\nfi")
        patchedMm = strutil.replace(
            patchedMm,
            "linker_mode=\"${BACKEND_LINKER:-self}\"",
            "linker_mode=\"${BACKEND_MM_LINKER:-${BACKEND_LINKER:-system}}\"")
        patchedMm = strutil.replace(
            patchedMm,
            "timeout_s=\"${BACKEND_MM_TIMEOUT:-60}\"\nmkdir -p \"$out_dir\"\n",
            "timeout_s=\"${BACKEND_MM_TIMEOUT:-60}\"\nmkdir -p \"$out_dir\"\nruntime_env_line=\"\"\nruntime_env_log=\"$out_dir/runtime_env.log\"\nif [ \"$linker_mode\" = \"self\" ]; then\n  set +e\n  runtime_env_line=\"$(${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} backend_link_env --driver:\"$driver\" --target:\"$target\" --linker:self 2>\"$runtime_env_log\")\"\n  runtime_env_status=\"$?\"\n  set -e\n  if [ \"$runtime_env_status\" -ne 0 ] || [ \"$runtime_env_line\" = \"\" ]; then\n    echo \"[verify_backend_mm] backend_link_env failed for target=$target (log: $runtime_env_log)\" >&2\n    if [ -f \"$runtime_env_log\" ]; then\n      tail -n 120 \"$runtime_env_log\" >&2 || true\n    fi\n    exit 1\n  fi\nfi\n")
        patchedMm = strutil.replace(
            patchedMm,
            "    BACKEND_EMIT=obj \\\n    BACKEND_LINKER=self \\\n",
            "    BACKEND_INTERNAL_ALLOW_EMIT_OBJ=1 \\\n    BACKEND_EMIT=obj \\\n    BACKEND_LINKER=self \\\n")
        patchedMm = strutil.replace(
            patchedMm,
            "    run_with_timeout \"$timeout_s\" env \\\n",
            "    # shellcheck disable=SC2086\n    run_with_timeout \"$timeout_s\" env $runtime_env_line \\\n")
        patchedMm = strutil.replace(
            patchedMm,
            "      BACKEND_EMIT=exe \\\n      BACKEND_LINKER=self \\\n      BACKEND_RUNTIME=off \\\n      BACKEND_NO_RUNTIME_C=1 \\\n      BACKEND_RUNTIME_OBJ= \\\n      BACKEND_TARGET=\"$target\" \\\n",
            "      BACKEND_EMIT=exe \\\n      BACKEND_LINKER=self \\\n      BACKEND_NO_RUNTIME_C=1 \\\n      BACKEND_TARGET=\"$target\" \\\n")
        patchedMm = strutil.replace(
            patchedMm,
            "if is_known_mm_skip_log \"$self_log\"; then\n      echo \"[verify_backend_mm] known self-link instability, fallback compile-only: $base\" >&2\n      if compile_fixture_compile_only \"$fixture\" \"$base\" \"$fixture_frontend\"; then\n        return\n      fi\n      tail -n 200 \"$out_dir/${base}.compile_only.log\" >&2 || true\n      exit 1\n    fi\n",
            "if is_known_mm_skip_log \"$self_log\"; then\n      echo \"[verify_backend_mm] self-link runtime instability: $base\" >&2\n      tail -n 200 \"$self_log\" >&2 || true\n      exit \"$self_status\"\n    fi\n")
        patchedMm = strutil.replace(
            patchedMm,
            "      BACKEND_VALIDATE=1 \\\n      BACKEND_MULTI=0 \\\n",
            "      BACKEND_VALIDATE=1 \\\n      BACKEND_OPT_LEVEL=0 \\\n      BACKEND_OPT2=0 \\\n      BACKEND_MULTI=0 \\\n")
        patchedMm = strutil.replace(
            patchedMm,
            "    BACKEND_VALIDATE=1 \\\n    BACKEND_MULTI=0 \\\n",
            "    BACKEND_VALIDATE=1 \\\n    BACKEND_OPT_LEVEL=0 \\\n    BACKEND_OPT2=0 \\\n    BACKEND_MULTI=0 \\\n")
        patchedMm = strutil.replace(
            patchedMm,
            "    BACKEND_EMIT=exe \\\n    BACKEND_LINKER=system \\\n    BACKEND_TARGET=\"$target\" \\\n",
            "    BACKEND_EMIT=exe \\\n    BACKEND_LINKER=system \\\n    BACKEND_NO_RUNTIME_C=0 \\\n    BACKEND_TARGET=\"$target\" \\\n")
        patchedMm = strutil.replace(
            patchedMm,
            "if [ \"$mm_container\" = \"1\" ]; then\n  run_fixture \"tests/cheng/backend/fixtures/mm_container_balance.cheng\" \"mm_container_balance\" \"$mm_container_frontend\"\nelse\n  echo \"[verify_backend_mm] skip mm_container_balance (set BACKEND_MM_CONTAINER=1 to enable, current=$mm_container)\" >&2\nfi\n",
            "if [ \"$mm_container\" = \"1\" ]; then\n  run_fixture \"tests/cheng/backend/fixtures/mm_container_balance.cheng\" \"mm_container_balance\" \"$mm_container_frontend\"\nelse\n  echo \"[verify_backend_mm] BACKEND_MM_CONTAINER=0 is no longer supported (required runtime gate)\" >&2\n  exit 1\nfi\n")
        return patchedMm
    if tooling_strEq(id, "verify_backend_mem_exe_emit"):
        let rawMemExe: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawMemExe):
            return ""
        var patchedMemExe: str = rawMemExe
        patchedMemExe = strutil.replace(patchedMemExe, "chengc_file=\"src/tooling/chengc.sh\"",
                                        "cheng_file=\"src/tooling/cheng_tooling_embedded_inline.cheng\"")
        patchedMemExe = strutil.replace(patchedMemExe, "link_env_file=\"src/tooling/backend_link_env.sh\"",
                                        "link_env_file=\"src/tooling/cheng_tooling_embedded_inline.cheng\"")
        patchedMemExe = strutil.replace(patchedMemExe, "runtime_obj_chengc_marker", "runtime_obj_cheng_marker")
        patchedMemExe = strutil.replace(patchedMemExe, "chengc_fixture", "cheng_fixture")
        patchedMemExe = strutil.replace(patchedMemExe, "chengc_exe", "cheng_exe")
        patchedMemExe = strutil.replace(patchedMemExe, "chengc_build_log", "cheng_build_log")
        patchedMemExe = strutil.replace(
            patchedMemExe,
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} chengc ",
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} cheng ")
        patchedMemExe = strutil.replace(patchedMemExe, "chengc emit=exe", "cheng emit=exe")
        patchedMemExe = strutil.replace(patchedMemExe, "missing chengc executable output", "missing cheng executable output")
        patchedMemExe = strutil.replace(patchedMemExe, "chengc emit=exe path has sidecar residue", "cheng emit=exe path has sidecar residue")
        patchedMemExe = strutil.replace(patchedMemExe, "  BACKEND_DRIVER=\"$driver\" \\\n", "")
        patchedMemExe = strutil.replace(patchedMemExe, "  BACKEND_LINKER=self \\\n", "")
        return patchedMemExe
    if tooling_strEq(id, "verify_backend_hotpatch"):
        let rawHotpatch: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawHotpatch):
            return ""
        var patchedHotpatch: str = rawHotpatch
        patchedHotpatch = strutil.replace(
            patchedHotpatch,
            "preferred_linker=\"${BACKEND_HOTPATCH_GATE_LINKER:-system}\"",
            "preferred_linker=\"${BACKEND_HOTPATCH_GATE_LINKER:-self}\"")
        patchedHotpatch = strutil.replace(
            patchedHotpatch,
            "  {\n    echo \"verify_backend_hotpatch report\"\n    echo \"status=skip\"\n    echo \"reason=unsupported_target\"\n    echo \"target=$target\"\n    echo \"host_target=$host_target\"\n  } >\"$report\"\n  echo \"verify_backend_hotpatch skip: unsupported target ($target)\"\n  exit 0\n",
            "  echo \"[verify_backend_hotpatch] unsupported target: $target (host_target=$host_target)\" >&2\n  exit 1\n")
        patchedHotpatch = strutil.replace(
            patchedHotpatch,
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} chengc ",
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} cheng ")
        return patchedHotpatch
    if tooling_strEq(id, "verify_backend_hotpatch_meta"):
        let rawHotpatchMeta: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawHotpatchMeta):
            return ""
        var patchedHotpatchMeta: str = rawHotpatchMeta
        patchedHotpatchMeta = strutil.replace(
            patchedHotpatchMeta,
            "  {\n    echo \"verify_backend_hotpatch_meta report\"\n    echo \"status=skip\"\n    echo \"reason=unsupported_target\"\n    echo \"target=$target\"\n    echo \"host_target=$host_target\"\n  } >\"$report\"\n  echo \"verify_backend_hotpatch_meta skip: unsupported target ($target)\"\n  exit 0\n",
            "  echo \"[verify_backend_hotpatch_meta] unsupported target: $target (host_target=$host_target)\" >&2\n  exit 1\n")
        patchedHotpatchMeta = strutil.replace(
            patchedHotpatchMeta,
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} chengc ",
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} cheng ")
        return patchedHotpatchMeta
    if tooling_strEq(id, "verify_backend_mem_patch_regression"):
        let rawMemPatchRegression: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawMemPatchRegression):
            return ""
        var patchedMemPatchRegression: str = rawMemPatchRegression
        patchedMemPatchRegression = strutil.replace(
            patchedMemPatchRegression,
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} chengc ",
            "${TOOLING_SELF_BIN:-artifacts/tooling_cmd/cheng_tooling} cheng ")
        patchedMemPatchRegression = strutil.replace(
            patchedMemPatchRegression,
            "determinism_gate=chengc_double_build",
            "determinism_gate=cheng_double_build")
        return patchedMemPatchRegression
    if tooling_strEq(id, "verify_backend_closedloop"):
        let rawClosedloop: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawClosedloop):
            return ""
        var patchedClosedloop: str = rawClosedloop
        patchedClosedloop = strutil.replace(
            patchedClosedloop,
            "  compile_fullspec_self() {\n    echo \"[verify_backend_closedloop] fullspec self-link uses compile-only profile\" 1>&2\n    compile_fullspec_compile_only_fallback\n    return \"$?\"\n  }\n",
            "  compile_fullspec_self() {\n    echo \"[verify_backend_closedloop] fullspec self-link legacy fallback removed; run system-link fullspec path\" 1>&2\n    compile_fullspec_system\n    return \"$?\"\n  }\n")
        patchedClosedloop = strutil.replace(
            patchedClosedloop,
            "    if [ \"$status\" -ne 0 ]; then\n      if is_known_fullspec_link_instability \"$fullspec_log\"; then\n        echo \"[verify_backend_closedloop] fullspec system-link unstable, fallback to compile-only check\" 1>&2\n        compile_fullspec_compile_only_fallback\n        return \"$?\"\n      fi\n      tail -n 200 \"$fullspec_log\" 1>&2 || true\n    fi\n",
            "    if [ \"$status\" -ne 0 ]; then\n      if is_known_fullspec_link_instability \"$fullspec_log\"; then\n        echo \"[verify_backend_closedloop] fullspec system-link instability (strict-no-fallback): $fullspec_log\" 1>&2\n      fi\n      tail -n 200 \"$fullspec_log\" 1>&2 || true\n    fi\n")
        patchedClosedloop = strutil.replace(
            patchedClosedloop,
            "  if [ \"$fullspec_compile_only_ok\" = \"1\" ]; then\n    echo \"== backend.closedloop_fullspec.run (compile-only fallback) ==\"\n  elif [ -x \"$fullspec_out\" ]; then\n    run_step \"backend.closedloop_fullspec.symcheck\" verify_fullspec_no_seqbytes_undef\n    run_step \"backend.closedloop_fullspec.run\" sh -c '\n      ./artifacts/backend_closedloop/fullspec_backend | grep -Fq \"fullspec ok\"\n    '\n  else\n    echo \"[verify_backend_closedloop] fullspec compile did not produce runnable binary\" 1>&2\n    exit 1\n  fi\n",
            "  if [ -x \"$fullspec_out\" ]; then\n    run_step \"backend.closedloop_fullspec.symcheck\" verify_fullspec_no_seqbytes_undef\n    run_step \"backend.closedloop_fullspec.run\" sh -c '\n      ./artifacts/backend_closedloop/fullspec_backend | grep -Fq \"fullspec ok\"\n    '\n  else\n    echo \"[verify_backend_closedloop] fullspec compile did not produce runnable binary\" 1>&2\n    exit 1\n  fi\n")
        patchedClosedloop = strutil.replace(
            patchedClosedloop,
            "  fullspec_compile_only_out=\"${fullspec_out}.compile_only\"\n  fullspec_log=\"artifacts/backend_closedloop/fullspec_backend.compile.log\"\n  fullspec_compile_only_ok=\"0\"\n\n",
            "  fullspec_log=\"artifacts/backend_closedloop/fullspec_backend.compile.log\"\n\n")
        patchedClosedloop = strutil.replace(
            patchedClosedloop,
            "      BACKEND_LINKER=system \\\n      BACKEND_NO_RUNTIME_C=1 \\\n      BACKEND_RUNTIME_OBJ=\"$backend_runtime_obj\" \\\n",
            "      BACKEND_LINKER=system \\\n      BACKEND_NO_RUNTIME_C=0 \\\n      BACKEND_RUNTIME_OBJ=\"\" \\\n")
        patchedClosedloop = strutil.replace(
            patchedClosedloop,
            "        BACKEND_LINKER=system \\\n        BACKEND_NO_RUNTIME_C=1 \\\n        BACKEND_RUNTIME_OBJ=\"$backend_runtime_obj\" \\\n",
            "        BACKEND_LINKER=system \\\n        BACKEND_NO_RUNTIME_C=0 \\\n        BACKEND_RUNTIME_OBJ=\"\" \\\n")
        return tooling_normalizeEmbeddedScriptText(id, patchedClosedloop)
    if tooling_strEq(id, "verify_backend_float"):
        let rawFloat: str = tooling_embedded_inline.toolingEmbeddedScriptBody(id)
        if !tooling_strNonEmpty(rawFloat):
            return ""
        var patchedFloat: str = rawFloat
        patchedFloat = strutil.replace(
            patchedFloat,
            "    if is_known_float_skip_log \"$build_log\"; then\n      echo \"[verify_backend_float] known link instability, fallback compile-only: $fixture\" 1>&2\n      compile_fixture_compile_only \"$fixture\" \"$log_prefix\"\n      return\n    fi\n",
            "    if is_known_float_skip_log \"$build_log\"; then\n      echo \"[verify_backend_float] known link instability (strict-no-fallback): $fixture\" 1>&2\n      tail -n 200 \"$build_log\" >&2 || true\n      exit \"$build_status\"\n    fi\n")
        patchedFloat = strutil.replace(
