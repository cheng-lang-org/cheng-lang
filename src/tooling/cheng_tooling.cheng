    tooling_envAssignCollect(envOverrides, "BACKEND_SKIP_UIR_NORMALIZE", "0")
    tooling_envAssignCollect(envOverrides, "BACKEND_LINKER", "system")
    tooling_envAssignCollect(envOverrides, "BACKEND_NO_RUNTIME_C", "0")
