import std/os
import std/monotimes

fn toolingBuildGlobalStrNonEmpty(text: str): bool =
    return len(text) > 0

fn toolingBuildGlobalStrEq(a: str, b: str): bool =
    return a == b

fn toolingBuildGlobalIsAsciiSpace(ch: char): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn toolingBuildGlobalStartsWith(s: str, prefix: str): bool =
    if len(prefix) > len(s):
        return false
    for i in 0..<len(prefix):
        if s[i] != prefix[i]:
            return false
    return true

fn toolingBuildGlobalJoinPathSimple(base: str, rel: str): str =
    if !toolingBuildGlobalStrNonEmpty(base):
        return rel
    if !toolingBuildGlobalStrNonEmpty(rel):
        return base
    if toolingBuildGlobalStartsWith(rel, "/") || toolingBuildGlobalStartsWith(rel, "\\"):
        return base + rel
    let n: int32 = len(base)
    if n > 0:
        let tail: char = base[n - 1]
        if tail == '/' || tail == '\\':
            return base + rel
    return base + "/" + rel

fn toolingBuildGlobalPathAbsolute(root: str, raw: str): str =
    if !toolingBuildGlobalStrNonEmpty(raw):
        return ""
    if os.isAbsolute(raw):
        return raw
    if toolingBuildGlobalStartsWith(raw, "./") || toolingBuildGlobalStartsWith(raw, "../"):
        return os.absolutePath(raw)
    return toolingBuildGlobalJoinPathSimple(root, raw)

fn toolingBuildGlobalShellQuote(raw: str): str =
    if len(raw) == 0:
        return "\"\""
    # Internal tooling paths are repo-controlled; quoted wrapping is enough here.
    return "\"" + raw + "\""

fn toolingBuildGlobalNowNonceText(): str =
    let mt: monotimes.MonoTime = monotimes.getMonoTime()
    return int64ToStr(monotimes.monoTimeNs(mt))

fn toolingBuildGlobalExec(root: str, command: str): os.ExecCmdResult =
    return os.execCmdEx(command, uint64(7), root)

fn toolingBuildGlobalMkdirP(root: str, path: str): bool =
    if !toolingBuildGlobalStrNonEmpty(path):
        return true
    if os.dirExists(path):
        return true
    let res: os.ExecCmdResult =
        toolingBuildGlobalExec(root, "mkdir -p " + toolingBuildGlobalShellQuote(path))
    return os.execCmdResultExitCode(res) == 0

fn toolingBuildGlobalInstallTemplateCopy(root: str, srcPath: str, dstPath: str, tmpPath: str): bool =
    let res: os.ExecCmdResult =
        toolingBuildGlobalExec(
            root,
            "cp -f " + toolingBuildGlobalShellQuote(srcPath) + " " + toolingBuildGlobalShellQuote(tmpPath) +
            " && chmod +x " + toolingBuildGlobalShellQuote(tmpPath) +
            " && mv -f " + toolingBuildGlobalShellQuote(tmpPath) + " " + toolingBuildGlobalShellQuote(dstPath)
        )
    if os.execCmdResultExitCode(res) == 0:
        return true
    if os.fileExists(tmpPath):
        os.removeFile(tmpPath)
    return false

fn toolingBuildGlobalInstallTemplate(root: str, srcPath: str, dstPath: str): bool =
    if !toolingBuildGlobalStrNonEmpty(srcPath) || !toolingBuildGlobalStrNonEmpty(dstPath):
        return false
    if toolingBuildGlobalStrEq(srcPath, dstPath):
        let chmodSame: os.ExecCmdResult =
            toolingBuildGlobalExec(root, "chmod +x " + toolingBuildGlobalShellQuote(dstPath))
        return os.execCmdResultExitCode(chmodSame) == 0
    if toolingBuildGlobalStrNonEmpty(os.parentDir(dstPath)):
        if !toolingBuildGlobalMkdirP(root, os.parentDir(dstPath)):
            return false
    return toolingBuildGlobalInstallTemplateCopy(
        root,
        srcPath,
        dstPath,
        dstPath + ".publish." + toolingBuildGlobalNowNonceText() + ".tmp"
    )

fn toolingBuildGlobalFilesIdenticalAbs(root: str, left: str, right: str): bool =
    if !toolingBuildGlobalStrNonEmpty(left) || !toolingBuildGlobalStrNonEmpty(right):
        return false
    if !os.fileExists(left) || !os.fileExists(right):
        return false
    let cmpRes: os.ExecCmdResult =
        toolingBuildGlobalExec(root, "cmp -s " + toolingBuildGlobalShellQuote(left) + " " + toolingBuildGlobalShellQuote(right))
    return os.execCmdResultExitCode(cmpRes) == 0

fn toolingBuildGlobalFilesIdentical(root: str, leftRaw: str, rightRaw: str): bool =
    return toolingBuildGlobalFilesIdenticalAbs(
        root,
        toolingBuildGlobalPathAbsolute(root, leftRaw),
        toolingBuildGlobalPathAbsolute(root, rightRaw)
    )

fn toolingBuildGlobalCanonicalWrapperPath(root: str): str =
    return toolingBuildGlobalPathAbsolute(root, "artifacts/tooling_cmd/cheng_tooling")

fn toolingBuildGlobalWrapperTemplatePath(root: str): str =
    return toolingBuildGlobalPathAbsolute(root, "src/tooling/cheng_tooling_embedded_scripts/cheng_tooling_canonical.sh")

fn toolingBuildGlobalRealTemplatePath(root: str): str =
    return toolingBuildGlobalPathAbsolute(root, "src/tooling/cheng_tooling_embedded_scripts/cheng_tooling_real.sh")

fn toolingBuildGlobalRealPrimaryTemplatePath(root: str): str =
    return toolingBuildGlobalPathAbsolute(root, "src/tooling/cheng_tooling_embedded_scripts/cheng_tooling_real_bin.sh")

fn toolingBuildGlobalCanonicalRealOutPath(outPath: str): str =
    return os.joinPath(os.parentDir(outPath), "cheng_tooling.real")

fn toolingBuildGlobalCanonicalRealPrimaryOutPath(outPath: str): str =
    return os.joinPath(os.parentDir(outPath), "cheng_tooling.real.bin")

fn toolingBuildGlobalIsCanonicalWrapperTarget(root: str, outPathRaw: str): bool =
    if !toolingBuildGlobalStrNonEmpty(toolingBuildGlobalPathAbsolute(root, outPathRaw)):
        return false
    return toolingBuildGlobalStrEq(
        toolingBuildGlobalPathAbsolute(root, outPathRaw),
        toolingBuildGlobalCanonicalWrapperPath(root)
    )

fn toolingBuildGlobalCanonicalWrapperChangedAbs(root: str, outPath: str): bool =
    if !toolingBuildGlobalStrNonEmpty(outPath):
        return true
    let wrapperChanged: bool = !toolingBuildGlobalFilesIdenticalAbs(
        root,
        toolingBuildGlobalWrapperTemplatePath(root),
        outPath
    )
    let realChanged: bool = !toolingBuildGlobalFilesIdenticalAbs(
        root,
        toolingBuildGlobalRealTemplatePath(root),
        toolingBuildGlobalCanonicalRealOutPath(outPath)
    )
    let realPrimaryChanged: bool = !toolingBuildGlobalFilesIdenticalAbs(
        root,
        toolingBuildGlobalRealPrimaryTemplatePath(root),
        toolingBuildGlobalCanonicalRealPrimaryOutPath(outPath)
    )
    return wrapperChanged || realChanged || realPrimaryChanged

fn toolingBuildGlobalCanonicalWrapperChanged(root: str, outPathRaw: str): bool =
    return toolingBuildGlobalCanonicalWrapperChangedAbs(
        root,
        toolingBuildGlobalPathAbsolute(root, outPathRaw)
    )

fn toolingBuildGlobalSyncCanonicalWrappersAbs(root: str, outPath: str): bool =
    if !toolingBuildGlobalStrNonEmpty(outPath) || !toolingBuildGlobalStrNonEmpty(toolingBuildGlobalWrapperTemplatePath(root)) ||
       !toolingBuildGlobalStrNonEmpty(toolingBuildGlobalRealTemplatePath(root)) ||
       !toolingBuildGlobalStrNonEmpty(toolingBuildGlobalRealPrimaryTemplatePath(root)):
        return false
    if !os.fileExists(toolingBuildGlobalWrapperTemplatePath(root)) ||
       !os.fileExists(toolingBuildGlobalRealTemplatePath(root)) ||
       !os.fileExists(toolingBuildGlobalRealPrimaryTemplatePath(root)):
        return false
    if !toolingBuildGlobalInstallTemplate(root, toolingBuildGlobalWrapperTemplatePath(root), outPath):
        return false
    if !toolingBuildGlobalInstallTemplate(root, toolingBuildGlobalRealTemplatePath(root), toolingBuildGlobalCanonicalRealOutPath(outPath)):
        return false
    if !toolingBuildGlobalInstallTemplate(
        root,
        toolingBuildGlobalRealPrimaryTemplatePath(root),
        toolingBuildGlobalCanonicalRealPrimaryOutPath(outPath)
    ):
        return false
    return true

fn toolingBuildGlobalSyncCanonicalWrappers(root: str, outPathRaw: str): bool =
    return toolingBuildGlobalSyncCanonicalWrappersAbs(
        root,
        toolingBuildGlobalPathAbsolute(root, outPathRaw)
    )
