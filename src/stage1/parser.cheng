# parser.cheng
# Stage1 parser (rebuilt from stage0 parser, with Stage1 AST/diagnostics).
import std/strings
import std/seqs
import std/os
import std/hashmaps
import std/system
import std/rawbytes
import stage1/token
import stage1/diagnostics
import stage1/lexer
import stage1/ast
import std/rawmem_support

fn parserAppendTokenClone(seqInst: var Token[], val: Token) =
    var clone: Token = val
    tokenSeqAppendClone(seqInst, clone)

fn parserMaterializeTraceEnabled(): bool =
    return envIsTrue "BACKEND_TRACE_MATERIALIZE"

fn parserMaterializeRoutineName(routineId: AstNodeId): str =
    if !astNodeIdValid(routineId) || astKidCount(routineId) <= 0:
        return ""
    let nameId: AstNodeId = astKidAt(routineId, 0)
    if !astNodeIdValid(nameId):
        return ""
    return astPlainName(nameId)

fn parserMaterializeTrace(action: str, filename: str, routineId: AstNodeId) =
    if !parserMaterializeTraceEnabled():
        return
    let name: str = parserMaterializeRoutineName(routineId)
    let declOrdinal: int32 = astNodeIdValid(routineId) ? astNodeDeclOrdinal(routineId) : -1
    let startTok: int32 = astNodeIdValid(routineId) ? astNodeDeferredBodyStartTok(routineId) : -1
    let endTok: int32 = astNodeIdValid(routineId) ? astNodeDeferredBodyEndTok(routineId) : -1
    let fErr: os.File = os.Get_stderr()
    os.WriteLine(fErr, "[stage1] materialize: parser_" + action +
                       " file=" + filename +
                       " name=" + name +
                       " decl=" + intToStr(declOrdinal) +
                       " tok=" + intToStr(startTok) + ".." + intToStr(endTok))
    if os.GetEnvDefault("STAGE1_TRACE_FLUSH", "") == "1":
        os.C_fflush fErr

fn add(seqInst: var Node[], val: Node) =
    seqs.Add(seqInst, val)

fn add(seqInst: var str[], val: str) =
    seqs.Add(seqInst, val)

fn add(seqInst: var int32[], val: int32) =
    seqs.Add(seqInst, val)

fn add(seqInst: var Diagnostic[], val: Diagnostic) =
    seqs.Add(seqInst, val)

fn add(seqInst: Diagnostic[]*, val: Diagnostic) =
    seqs.Add(seqInst, val)

fn parserStrCharAt(s: str, idx: int32): char =
    if idx < 0 || idx >= len(s):
        return char(0)
    return s[idx]

fn parserJoinNodeIdentIdsWithChar(parts: Node[], sep: char): int32 =
    if parts.len <= 0:
        return 0
    var ids: int32[] = []
    ids.cap = parts.len
    for i in 0..<parts.len:
        let id: int32 = nodeIdentId(parts[i])
        if id > 0:
            add(ids, id)
    return tokenInternTextIdsJoinedByByte(ids, sep)

# ---- Precedence ----
const
    PrecNone: int32 = 0
    PrecTernary: int32 = 10
    PrecOr: int32 = 20
    PrecAnd: int32 = 30
    PrecBitOr: int32 = 40
    PrecBitXor: int32 = 45
    PrecBitAnd: int32 = 50
    PrecEquality: int32 = 60
    PrecComparison: int32 = 65
    PrecMembership: int32 = 70
    PrecRange: int32 = 75
    PrecShift: int32 = 77
    PrecAdditive: int32 = 80
    PrecMultiplicative: int32 = 90
    PrecPrefix: int32 = 100
    PrecCall: int32 = 110
    PrecDot: int32 = 120

# ---- ParserState ----
type
    ParserStateObj =
        tokens: Token[]
        idx: int32
        endExclusive: int32
        eofLine: int32
        eofCol: int32
        filename: str
        diags: Diagnostic[]*
        outlineOnly: bool
        routineOrdinalNext: int32

