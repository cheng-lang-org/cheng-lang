fn parserEnsureCommonTokenIds() =
    let epoch: int32 = tokenTextPoolCurrentEpoch()
    if parserCommonTokenIdsReady && parserCommonTokenIdsEpoch == epoch:
        return
    parserCommonTokenIdsEpoch = epoch
    parserTokLParenId = tokenCommonId(0)
    parserTokRParenId = tokenCommonId(1)
    parserTokLBracketId = tokenCommonId(2)
    parserTokRBracketId = tokenCommonId(3)
    parserTokLBraceId = tokenCommonId(4)
    parserTokRBraceId = tokenCommonId(5)
    parserTokCommaId = tokenCommonId(6)
    parserTokColonId = tokenCommonId(7)
    parserTokSemiId = tokenCommonId(8)
    parserTokDotId = tokenCommonId(9)
    parserTokEqId = tokenCommonId(10)
    parserTokPlusId = tokenCommonId(11)
    parserTokMinusId = tokenCommonId(12)
    parserTokStarId = tokenCommonId(13)
    parserTokSlashId = tokenCommonId(14)
    parserTokPercentId = tokenCommonId(15)
    parserTokLtId = tokenCommonId(16)
    parserTokGtId = tokenCommonId(17)
    parserTokAmpId = tokenCommonId(18)
    parserTokPipeId = tokenCommonId(19)
    parserTokCaretId = tokenCommonId(20)
    parserTokTildeId = tokenCommonId(21)
    parserTokBangId = tokenCommonId(22)
    parserTokDollarId = tokenCommonId(23)
    parserTokQuestionId = tokenCommonId(24)
    parserTokAtId = tokenCommonId(25)
    parserTokEqEqId = tokenCommonId(27)
    parserTokArrowId = tokenCommonId(28)
    parserTokMinusMinusId = tokenCommonId(29)
    parserTokNotEqId = tokenCommonId(30)
    parserTokPlusPlusId = tokenCommonId(31)
    parserTokAndAndId = tokenCommonId(32)
    parserTokOrOrId = tokenCommonId(33)
    parserTokLtLtId = tokenCommonId(34)
    parserTokLtEqId = tokenCommonId(35)
    parserTokGtGtId = tokenCommonId(36)
    parserTokGtEqId = tokenCommonId(37)
    parserTokDotDotId = tokenCommonId(38)
    parserTokDotDotLtId = tokenCommonId(39)
    parserTokFnId = tokenCommonId(41)
    parserTokIfId = tokenCommonId(42)
    parserTokAsId = tokenCommonId(43)
    parserTokInId = tokenCommonId(44)
    parserTokOfId = tokenCommonId(45)
    parserTokIsId = tokenCommonId(46)
    parserTokNotInId = tokenCommonId(40)
    parserTokVarId = tokenCommonId(48)
    parserTokForId = tokenCommonId(50)
    parserTokNilId = tokenCommonId(51)
    parserTokRefId = tokenCommonId(52)
    parserTokSetId = tokenCommonId(53)
    parserTokTypeId = tokenCommonId(55)
