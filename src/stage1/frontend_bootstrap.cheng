# Stage1 bootstrap runner (recovery mode uses stage0 to compile inputs).
import cheng/stage1/frontend_lib

fn main() =
    echo "stage1 bootstrap start"
    let runFullspec: bool =(stage1_getEnv "CHENG_STAGE1_FULLSPEC" ==  "1")
    let skipExamples: bool = envIsTrue "CHENG_BOOTSTRAP_SKIP_EXAMPLES" || envIsTrue "CHENG_STAGE1_BOOTSTRAP_SKIP_EXAMPLES"

    if ! skipExamples:
        echo "stage1 codegen hello begin"
        compileToC("examples/stage1_codegen_hello.cheng", "/tmp/stage1_codegen_hello.c")

        echo "stage1 codegen vars begin"
        compileToC("examples/stage1_codegen_vars.cheng", "/tmp/stage1_codegen_vars.c")

        echo "stage1 codegen control begin"
        compileToC("examples/stage1_codegen_control.cheng", "/tmp/stage1_codegen_control.c")

        echo "stage1 codegen expr begin"
        compileToC("examples/stage1_codegen_expr.cheng", "/tmp/stage1_codegen_expr.c")

        if runFullspec:
            echo "stage1 codegen fullspec begin"
            compileToC("examples/stage1_codegen_fullspec.cheng", "/tmp/stage1_codegen_fullspec.c")

    echo "stage1 build stage1 runner begin"
    compileToC("src/stage1/frontend_stage1.cheng", "/tmp/stage1_runner.c")
    echo "stage1 emit stage1 runner: /tmp/stage1_runner.c"
    return 0
