    found = false
    if textId <= 0:
        return 0
    if textId >= semSendTextIndexReady.len || textId >= semSendTextIndexValue.len:
        return 0
    if !semSendTextIndexReady[textId]:
        return 0
    found = true
    return semSendTextIndexValue[textId]

fn semSendTextIndexPut(textId: int32, idxPlus1: int32) =
    if textId <= 0:
        return
    semEnsureSendTextIndexCache(textId)
    if textId < semSendTextIndexReady.len && textId < semSendTextIndexValue.len:
        semSendTextIndexReady[textId] = true
