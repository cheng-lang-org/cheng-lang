# semantics.cheng
# Stage1 minimal semantic checks (conservative): undefined identifiers.
#
# Goal: avoid false positives (allow intrinsic / generic bases / import conservatively) for bootstrap and regressions.
import std/strings
import std/seqs
import std/strutils
import std/hashmaps
import std/os
import std/crash_trace_internal
import std/rawmem_support
import stage1/ast
import stage1/diagnostics
import stage1/lexer

fn add(dst: var int32[], val: int32) =
    seqs.Add(dst, val)

fn add(dst: int32[]*, val: int32) =
    seqs.Add(dst, val)

fn add(dst: var int64[], val: int64) =
    seqs.Add(dst, val)

fn add(dst: int64[]*, val: int64) =
    seqs.Add(dst, val)

fn add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn add(dst: str[]*, val: str) =
    seqs.Add(dst, val)

fn add(dst: var Node[], val: Node) =
    seqs.Add(dst, val)

fn add(dst: Node[]*, val: Node) =
    seqs.Add(dst, val)

fn add(dst: var AstNodeId[], val: AstNodeId) =
    seqs.Add(dst, val)

fn add(dst: AstNodeId[]*, val: AstNodeId) =
    seqs.Add(dst, val)

fn add(dst: var Diagnostic[], val: Diagnostic) =
    seqs.Add(dst, val)

fn add(dst: Diagnostic[]*, val: Diagnostic) =
    seqs.Add(dst, val)

type
    SemCtx =
        scopeStarts: int32[]
        names: str[]
        nameTextIds: int32[]
        namePtrKeys: int64[]
        nameDepths: hashmaps.HashMapStrInt
        namePrevDepthPlus1: int32[]
