fn semDebugLog(enabled: bool, msg: str) =
    if !enabled:
        return
    let f: os.File = os.Get_stderr()
    os.WriteLine(f, msg)
    os.C_fflush(f)

fn semWriteUIntRaw(f: os.File, value: int64) =
    if value >= 10:
        semWriteUIntRaw(f, value / 10)
    let digit: int64 = value % 10
    if digit == 0:
        os.Write(f, "0")
    elif digit == 1:
        os.Write(f, "1")
    elif digit == 2:
        os.Write(f, "2")
    elif digit == 3:
        os.Write(f, "3")
    elif digit == 4:
        os.Write(f, "4")
    elif digit == 5:
        os.Write(f, "5")
    elif digit == 6:
        os.Write(f, "6")
    elif digit == 7:
        os.Write(f, "7")
    elif digit == 8:
        os.Write(f, "8")
    else:
        os.Write(f, "9")

fn semWriteIntRaw(f: os.File, value: int32) =
    if value < 0:
        os.Write(f, "-")
        semWriteUIntRaw(f, int64(0) - int64(value))
        return
    semWriteUIntRaw(f, int64(value))

fn semBorrowDebugEnabled(): bool =
    return os.GetEnvDefault("STAGE1_BORROW_DEBUG", "") == "1"

fn semBorrowDebugNameEnabled(name: str): bool =
    if !semBorrowDebugEnabled():
        return false
    let filter: str = strutil.Strip(os.GetEnvDefault("STAGE1_BORROW_DEBUG_NAME", ""))
    if filter == "":
        return true
    let nm: str = semNormalizeName(name)
    if nm == "":
        return false
    if filter == nm:
        return true
    return strutil.Contains("," + filter + ",", "," + nm + ",")

fn semBorrowDebugWriteKvStr(f: os.File, key: str, value: str) =
    os.Write(f, " ")
    os.Write(f, key)
    os.Write(f, "=")
    os.Write(f, value)

fn semBorrowDebugWriteKvInt(f: os.File, key: str, value: int32) =
    os.Write(f, " ")
    os.Write(f, key)
    os.Write(f, "=")
    semWriteIntRaw(f, value)

fn semBorrowDebugKnownCount(textId: int32, depth: int32): int32 =
    if textId > 0:
        return semBorrowOriginKnownTextGet(textId, depth)
    return 0

fn semBorrowDebugUnknownCount(ctx: var SemCtx, name: str): int32 =
    var found: bool
    return hashmaps.HashMapStrIntGetEx(ctx.borrowOriginUnknownCount, name, found)

fn semBorrowDebugLogOriginDelta(ctx: var SemCtx, tag: str, name: str, textId: int32, depth: int32, delta: int32) =
    if !semBorrowDebugNameEnabled(name):
        return
    let f: os.File = os.Get_stderr()
    os.Write(f, "[sem-borrow]")
    semBorrowDebugWriteKvStr(f, "tag", tag)
    semBorrowDebugWriteKvStr(f, "name", name)
    semBorrowDebugWriteKvInt(f, "textId", textId)
    semBorrowDebugWriteKvInt(f, "depth", depth)
    semBorrowDebugWriteKvInt(f, "delta", delta)
    semBorrowDebugWriteKvInt(f, "known", semBorrowDebugKnownCount(textId, depth))
    semBorrowDebugWriteKvInt(f, "unknown", semBorrowDebugUnknownCount(ctx, name))
    semBorrowDebugWriteKvInt(f, "activeTotal", ctx.borrowActiveTotal)
    semBorrowDebugWriteKvInt(f, "scopeEpoch", semScopeEpoch)
    semBorrowDebugWriteKvInt(f, "borrowEpoch", semBorrowEpoch)
    os.WriteLine(f, "")
    os.C_fflush(f)

fn semBorrowDebugLogMark(ctx: var SemCtx, tag: str, name: str, textId: int32, borrowed: bool, origin: str, originTextId: int32, depth: int32, originDepth: int32) =
    if !semBorrowDebugNameEnabled(name) && !semBorrowDebugNameEnabled(origin):
        return
    let f: os.File = os.Get_stderr()
    os.Write(f, "[sem-borrow]")
    semBorrowDebugWriteKvStr(f, "tag", tag)
    semBorrowDebugWriteKvStr(f, "name", name)
    semBorrowDebugWriteKvInt(f, "textId", textId)
    semBorrowDebugWriteKvInt(f, "depth", depth)
    semBorrowDebugWriteKvInt(f, "borrowed", borrowed ? 1 : 0)
    semBorrowDebugWriteKvStr(f, "origin", origin)
    semBorrowDebugWriteKvInt(f, "originTextId", originTextId)
    semBorrowDebugWriteKvInt(f, "originDepth", originDepth)
    semBorrowDebugWriteKvInt(f, "activeTotal", ctx.borrowActiveTotal)
    semBorrowDebugWriteKvInt(f, "scopeEpoch", semScopeEpoch)
    semBorrowDebugWriteKvInt(f, "borrowEpoch", semBorrowEpoch)
    os.WriteLine(f, "")
    os.C_fflush(f)

fn semBorrowDebugLogWriteCheck(ctx: var SemCtx, tag: str, expr: Node, name: str) =
    if !semBorrowDebugNameEnabled(name):
        return
    let f: os.File = os.Get_stderr()
    let textId: int32 = nodeIdentId(expr)
    let depth: int32 = semIdentDefDepthCached(ctx, expr)
    os.Write(f, "[sem-borrow]")
    semBorrowDebugWriteKvStr(f, "tag", tag)
    semBorrowDebugWriteKvStr(f, "name", name)
    semBorrowDebugWriteKvInt(f, "textId", textId)
    semBorrowDebugWriteKvInt(f, "defDepth", depth)
    semBorrowDebugWriteKvInt(f, "line", nodePosLine(expr))
    semBorrowDebugWriteKvInt(f, "col", nodePosCol(expr))
    semBorrowDebugWriteKvInt(f, "known", semBorrowDebugKnownCount(textId, depth))
    semBorrowDebugWriteKvInt(f, "unknown", semBorrowDebugUnknownCount(ctx, name))
    semBorrowDebugWriteKvInt(f, "activeTotal", ctx.borrowActiveTotal)
    semBorrowDebugWriteKvInt(f, "scopeEpoch", semScopeEpoch)
    semBorrowDebugWriteKvInt(f, "borrowEpoch", semBorrowEpoch)
    os.WriteLine(f, "")
    os.C_fflush(f)

fn semInitHashMapStrInt(m: var hashmaps.HashMapStrInt, cap0: int32 = 0) =
    if cap0 > 0:
        hashmaps.HashMapStrIntInitInPlace(m, cap0)
        return
    m.keys = []
    m.vals = []
    m.states = []
    m.mask = 0
    m.used = 0

fn semProfResetI64Array(seqInst: var int64[], n: int32) =
    var count: int32 = n
    if count < 0:
        count = 0
    seqInst.len = 0
    seqInst.cap = int(count)
    for _ in 0..<count:
        add(seqInst, 0)

fn semProfResetI32Array(seqInst: var int32[], n: int32) =
    var count: int32 = n
    if count < 0:
        count = 0
    seqInst.len = 0
    seqInst.cap = int(count)
    for _ in 0..<count:
        add(seqInst, 0)

fn semProfResetKinds() =
    let nKinds: int32 = semNodeKindCount
    semProfResetI64Array(semProfStmtKindNs, nKinds)
    semProfResetI32Array(semProfStmtKindCalls, nKinds)
    semProfResetI64Array(semProfExprKindNs, nKinds)
    semProfResetI32Array(semProfExprKindCalls, nKinds)
    semProfResetI64Array(semProfSendKindNs, nKinds)
    semProfResetI32Array(semProfSendKindCalls, nKinds)
    semProfResetI64Array(semProfBorrowKindNs, nKinds)
    semProfResetI32Array(semProfBorrowKindCalls, nKinds)

fn semProfSkipStmtKind(kind: NodeKind): bool =
    return kind == nkModule || kind == nkStmtList

fn semProfKindLabel(idx: int32): str =
    let kind: NodeKind = NodeKind(idx)
    case kind
    of nkLet:
        return "nkLet"
    of nkVar:
        return "nkVar"
    of nkConst:
        return "nkConst"
    of nkAsgn:
        return "nkAsgn"
    of nkFastAsgn:
        return "nkFastAsgn"
    of nkIf:
        return "nkIf"
    of nkWhen:
        return "nkWhen"
    of nkWhile:
        return "nkWhile"
    of nkFor:
        return "nkFor"
    of nkCase:
        return "nkCase"
    of nkBlock:
        return "nkBlock"
    of nkReturn:
        return "nkReturn"
    of nkYield:
        return "nkYield"
    of nkCall:
        return "nkCall"
    of nkInfix:
        return "nkInfix"
    of nkPrefix:
        return "nkPrefix"
    of nkPostfix:
        return "nkPostfix"
    of nkIdent:
        return "nkIdent"
    of nkSymbol:
        return "nkSymbol"
    of nkDotExpr:
        return "nkDotExpr"
    of nkBracketExpr:
        return "nkBracketExpr"
    else:
        return "nk#" + intToStr(idx)

fn semReadI64(seqInst: int64[], idx: int32): int64 =
    if seqInst.len <= 0:
        return 0
    if idx < 0 || idx >= seqInst.len:
        return 0
    return seqInst[idx]

fn semWriteI64(seqInst: var int64[], idx: int32, val: int64) =
    if seqInst.len <= 0:
        return
    if idx < 0 || idx >= seqInst.len:
        return
    seqInst[idx] = val

fn semReadI32(seqInst: int32[], idx: int32): int32 =
    if seqInst.len <= 0:
        return 0
    if idx < 0 || idx >= seqInst.len:
        return 0
    return seqInst[idx]

fn semWriteI32(seqInst: var int32[], idx: int32, val: int32) =
    if seqInst.len <= 0:
        return
    if idx < 0 || idx >= seqInst.len:
        return
    seqInst[idx] = val

fn semReadStr(seqInst: str[], idx: int32): str =
    if seqInst.len <= 0:
        return ""
    if idx < 0 || idx >= seqInst.len:
        return ""
    return seqInst[idx]

fn semNodeIdVisitedList(ids: var AstNodeId[], target: AstNodeId): bool =
    if !astNodeIdValid(target):
        return false
    for i in 0..<ids.len:
        if ids[i] == target:
            return true
    return false

fn semNodeIdMarked(ids: var bool[], target: AstNodeId): bool =
    if !astNodeIdValid(target):
        return false
    let idx: int32 = astNodeIndex(target)
    if idx < 0 || idx >= ids.len:
        return false
    return ids[idx]

fn semMarkNodeIdVisitedList(ids: var AstNodeId[], target: AstNodeId): bool =
    if !astNodeIdValid(target):
        return false
    for i in 0..<ids.len:
        if ids[i] == target:
            return false
    add(ids, target)
    return true

fn semMarkNodeIdMarked(ids: var bool[], target: AstNodeId): bool =
    if !astNodeIdValid(target):
        return false
    let idx: int32 = astNodeIndex(target)
    if idx < 0:
        return false
    if idx >= ids.len:
        let oldLen: int32 = ids.len
        setLen(ids, idx + 1)
        for i in oldLen..idx:
            ids[i] = false
    if ids[idx]:
        return false
    ids[idx] = true
    return true

fn semProfRecordKind(nsSeq: var int64[], callsSeq: var int32[], kind: NodeKind, deltaNs: int64, mul: int32, skipStmtContainers: bool) =
    if mul <= 0:
        return
    if nsSeq.len <= 0 || callsSeq.len <= 0:
        return
    if skipStmtContainers && semProfSkipStmtKind(kind):
        return
    let idx: int32 = int32(kind)
    if idx < 0 || idx >= nsSeq.len || idx >= callsSeq.len:
        return
    let scaled: int64 = deltaNs * int64(mul)
    let curNs: int64 = nsSeq[idx]
    semWriteI64(nsSeq, idx, curNs + scaled)
    let curCalls: int32 = callsSeq[idx]
    semWriteI32(callsSeq, idx, curCalls + mul)

fn semProfSampleMul(): int32 =
    if semProfExprSampleOn:
        return semProfExprSampleMul
    if semProfStmtSampleOn:
        return semProfStmtSampleMul
    return 0

fn semProfRecordStmtKind(kind: NodeKind, deltaNs: int64) =
    if ! semProfOn || ! semProfStmtSampleOn:
        return
    if semProfSkipStmtKind(kind):
        return
    let idx: int32 = int32(kind)
    if idx < 0 || idx >= semProfStmtKindNs.len || idx >= semProfStmtKindCalls.len:
        return
    let mul: int32 = semProfStmtSampleMul
    if mul <= 0:
        return
    let scaled: int64 = deltaNs * int64(mul)
    let curNs: int64 = semReadI64(semProfStmtKindNs, idx)
    semWriteI64(semProfStmtKindNs, idx, curNs + scaled)
    let curCalls: int32 = semReadI32(semProfStmtKindCalls, idx)
    semWriteI32(semProfStmtKindCalls, idx, curCalls + mul)

fn semProfRecordExprKind(kind: NodeKind, deltaNs: int64) =
    if ! semProfOn || ! semProfExprSampleOn:
        return
    let idx: int32 = int32(kind)
    if idx < 0 || idx >= semProfExprKindNs.len || idx >= semProfExprKindCalls.len:
        return
    let mul: int32 = semProfExprSampleMul
    if mul <= 0:
        return
    let scaled: int64 = deltaNs * int64(mul)
    let curNs: int64 = semReadI64(semProfExprKindNs, idx)
    semWriteI64(semProfExprKindNs, idx, curNs + scaled)
    let curCalls: int32 = semReadI32(semProfExprKindCalls, idx)
    semWriteI32(semProfExprKindCalls, idx, curCalls + mul)

fn semProfRecordSendKind(kind: NodeKind, deltaNs: int64) =
    if ! semProfOn:
        return
    let mul: int32 = semProfSampleMul()
    if mul <= 0:
        return
    let idx: int32 = int32(kind)
    if idx < 0 || idx >= semProfSendKindNs.len || idx >= semProfSendKindCalls.len:
        return
    let scaled: int64 = deltaNs * int64(mul)
    let curNs: int64 = semReadI64(semProfSendKindNs, idx)
    semWriteI64(semProfSendKindNs, idx, curNs + scaled)
    let curCalls: int32 = semReadI32(semProfSendKindCalls, idx)
    semWriteI32(semProfSendKindCalls, idx, curCalls + mul)

fn semProfRecordBorrowKind(kind: NodeKind, deltaNs: int64) =
    if ! semProfOn:
        return
    let mul: int32 = semProfSampleMul()
    if mul <= 0:
        return
    let idx: int32 = int32(kind)
    if idx < 0 || idx >= semProfBorrowKindNs.len || idx >= semProfBorrowKindCalls.len:
        return
    let scaled: int64 = deltaNs * int64(mul)
    let curNs: int64 = semReadI64(semProfBorrowKindNs, idx)
    semWriteI64(semProfBorrowKindNs, idx, curNs + scaled)
    let curCalls: int32 = semReadI32(semProfBorrowKindCalls, idx)
    semWriteI32(semProfBorrowKindCalls, idx, curCalls + mul)

fn semProfTopKinds(nsSeq: int64[], callsSeq: int32[], skipStmtContainers: bool, label: str): str =
    var top1Idx: int32 = -1
    var top2Idx: int32 = -1
    var top3Idx: int32 = -1
    var top1Ns: int64
    var top2Ns: int64
    var top3Ns: int64
    for idx in 0..<nsSeq.len:
        let kind: NodeKind = NodeKind(idx)
        if skipStmtContainers && semProfSkipStmtKind(kind):
            continue
        let ns: int64 = semReadI64(nsSeq, idx)
        if ns > top1Ns:
            top3Ns = top2Ns
            top3Idx = top2Idx
            top2Ns = top1Ns
            top2Idx = top1Idx
            top1Ns = ns
            top1Idx = idx
        elif ns > top2Ns:
            top3Ns = top2Ns
            top3Idx = top2Idx
            top2Ns = ns
            top2Idx = idx
        elif ns > top3Ns:
            top3Ns = ns
            top3Idx = idx
    var parts: str[]
    add(parts, label)
    if top1Idx >= 0 && top1Ns > 0:
        let ms1: int32 = int32(top1Ns / 1000000)
        let c1: int32 = semReadI32(callsSeq, top1Idx)
        add(parts, " ")
        add(parts, semProfKindLabel(top1Idx))
        add(parts, "=")
        add(parts, intToStr(ms1))
        add(parts, "ms(")
        add(parts, intToStr(c1))
        add(parts, ")")
    if top2Idx >= 0 && top2Ns > 0:
        let ms2: int32 = int32(top2Ns / 1000000)
        let c2: int32 = semReadI32(callsSeq, top2Idx)
        add(parts, " ")
        add(parts, semProfKindLabel(top2Idx))
        add(parts, "=")
        add(parts, intToStr(ms2))
        add(parts, "ms(")
        add(parts, intToStr(c2))
        add(parts, ")")
    if top3Idx >= 0 && top3Ns > 0:
        let ms3: int32 = int32(top3Ns / 1000000)
        let c3: int32 = semReadI32(callsSeq, top3Idx)
        add(parts, " ")
        add(parts, semProfKindLabel(top3Idx))
        add(parts, "=")
        add(parts, intToStr(ms3))
        add(parts, "ms(")
        add(parts, intToStr(c3))
        add(parts, ")")
    return strutils.Join(parts, "")

fn semParseInt64(s: str, fallback: int64): int64 =
    if len(s) == 0:
        return fallback
    let n: int32 = len(s)
    var i: int32
    var sign: int64 = 1
    if s[0] == '-':
        sign = -1
        i = 1
    elif s[0] == '+':
        i = 1
    var val: int64
    var hadDigit: bool
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        let c: char = s[i]
        if c < '0' || c > '9':
            break
        let digit: int32 = int32(c) - int32('0')
        val = val * 10 + int64(digit)
        hadDigit = true
        i = i + 1
    if ! hadDigit:
        return fallback
    return val * sign

fn semProgressMaybe(kind: NodeKind, pos: SourcePos, phase: str) =
    if ! semProgressOn:
        return
    semProgressTick = semProgressTick + 1
    if (semProgressTick & semProgressSampleMask) != 0:
        return
    let now: int64 = cheng_monotime_ns()
    if semProgressNextNs == 0:
        semProgressNextNs = now + semProgressIntervalNs
        return
    if now < semProgressNextNs:
        return
    semProgressNextNs = now + semProgressIntervalNs
    let label: str = semProfKindLabel(int32(kind))
    var parts: str[]
    add(parts, "[stage1] internal: semantics progress")
    if phase != "":
        add(parts, " phase=")
        add(parts, phase)
    add(parts, " kind=")
    add(parts, label)
    add(parts, " line=")
    add(parts, intToStr(pos.line))
    add(parts, " col=")
    add(parts, intToStr(pos.col))
    add(parts, " stmt_calls=")
    add(parts, intToStr(semProfAnalyzeStmtCalls))
    add(parts, " expr_calls=")
    add(parts, intToStr(semProfAnalyzeExprCalls))
    echo(strutils.Join(parts, ""))
    if getEnv("STAGE1_TRACE_FLUSH") == "1":
        c_fflush(get_stdout())

fn semProgressMaybeDetail(kind: NodeKind, pos: SourcePos, phase: str, detail: str) =
    if ! semProgressOn:
        return
    semProgressTick = semProgressTick + 1
    if (semProgressTick & semProgressSampleMask) != 0:
        return
    let now: int64 = cheng_monotime_ns()
    if semProgressNextNs == 0:
        semProgressNextNs = now + semProgressIntervalNs
        return
    if now < semProgressNextNs:
        return
    semProgressNextNs = now + semProgressIntervalNs
    let label: str = semProfKindLabel(int32(kind))
    var parts: str[]
    add(parts, "[stage1] internal: semantics progress")
    if phase != "":
        add(parts, " phase=")
        add(parts, phase)
    if detail != "":
        add(parts, " detail=")
        add(parts, detail)
    add(parts, " kind=")
    add(parts, label)
    add(parts, " line=")
    add(parts, intToStr(pos.line))
    add(parts, " col=")
    add(parts, intToStr(pos.col))
    add(parts, " stmt_calls=")
    add(parts, intToStr(semProfAnalyzeStmtCalls))
    add(parts, " expr_calls=")
    add(parts, intToStr(semProfAnalyzeExprCalls))
    echo(strutils.Join(parts, ""))
    if getEnv("STAGE1_TRACE_FLUSH") == "1":
        c_fflush(get_stdout())

fn semHasPrefix(s: str, prefix: str): bool =
    let prefixLen: int32 = len(prefix)
    if len(s) < prefixLen:
        return false
    for i in 0..<prefixLen:
        if s[i] != prefix[i]:
            return false
    return true

fn semStrEq(a: str, b: str): bool =
    let n: int32 = len(a)
    if n != len(b):
        return false
    for i in 0..<n:
        if a[i] != b[i]:
            return false
    return true

fn semIsStdModulePath(path: str): bool =
    if len(path) == 0:
        return false
    if len(path) > semPolicyMaxPathLen:
        return false
    if semHasPrefix(path, "src/std/"):
        return true
    if semHasPrefix(path, "src\\std\\"):
        return true
    if semHasPrefix(path, "std/"):
        return true
    if semHasPrefix(path, "std\\"):
        return true
    if strContains(path, "/src/std/"):
        return true
    if strContains(path, "\\src\\std\\"):
        return true
    return false

fn semIsGeneratedModule(name: str): bool =
    return semHasPrefix(name, "<generated>/")

fn semLooksLikeModulePath(path: str): bool =
    if len(path) == 0:
        return false
    if len(path) > semPolicyMaxPathLen:
        return false
    if semHasPrefix(path, "<generated>/"):
        return true
    if semHasPrefix(path, "src/") || semHasPrefix(path, "src\\"):
        return true
    if strContains(path, "/") || strContains(path, "\\"):
        return true
    let n: int32 = len(path)
    if n >= 6:
        if path[n - 6] == '.' &&
           path[n - 5] == 'c' &&
           path[n - 4] == 'h' &&
           path[n - 3] == 'e' &&
           path[n - 2] == 'n' &&
           path[n - 1] == 'g':
            return true
    return false

fn semPolicyKidCount(n: Node): int32 =
    if stage1AstRefIsNil(n):
        return 0
    let count: int32 = kidCount(n)
    if count < 0:
        return 0
    if count > semPolicyMaxKidCount:
        return 0
    return count

fn semPolicyKidCountId(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return 0
    let count: int32 = astKidCount(id)
    if count < 0:
        return 0
    if count > semPolicyMaxKidCount:
        return 0
    return count

fn semShouldEnforceStdNoPointer(): bool =
    let stdNoPtrEnv: str = getEnv("STAGE1_STD_NO_POINTERS")
    if semStrEq(stdNoPtrEnv, "1"):
        return true
    if semStrEq(stdNoPtrEnv, "0"):
        return false
    return true

fn semShouldEnforceNonCAbiNoPointer(): bool =
    # Public no-pointer policy is no longer controlled by legacy env names.
    # User-visible source modules are always checked here.
    return true

fn semShouldEnforceNonCAbiNoPointerInternal(): bool =
    # Compiler-internal handling is path-based now; legacy env toggles are ignored.
    return false

fn semIsStdPointerPolicyExempt(path: str): bool =
    if len(path) == 0:
        return false
    let strictStdNoPointer: bool = semStrEq(getEnv("STAGE1_STD_NO_POINTERS_STRICT"), "1")
    if strictStdNoPointer:
        return false
    if strContains(path, "src/std/system_helpers_backend.cheng"):
