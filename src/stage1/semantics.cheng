    if semBorrowQueryEpoch <= 0:
        semBorrowQueryEpoch = 1

fn semGenericParamEpochBump() =
    semGenericParamEpoch = semGenericParamEpoch + 1
    if semGenericParamEpoch <= 0:
        semGenericParamEpoch = 1

fn semNameClassComputeNormalized(nm: str): int32 =
    if nm == "":
        return 0
    var mask: int32
    if nm == "nil" || nm == "true" || nm == "false":
        mask = mask | semNameClassLiteral
    if nm == "__addr" || nm == "sizeof" || nm == "default" || nm == "elemSize" || nm == "system" || nm == "result":
        mask = mask | semNameClassIntrinsic
    if nm == "seq" || nm == "add" || nm == "set" || nm == "get" || nm == "[]" || nm == "[]=":
        mask = mask | semNameClassGenericBase
    if nm == "+" || nm == "-" || nm == "*" || nm == "/" || nm == "%" || nm == "==" || nm == "!=" || nm == "<" || nm == "<=" || nm == ">" || nm == ">=" || nm == "&&" || nm == "||" || nm == "!" || nm == "<<" || nm == ">>" || nm == "in" || nm == "notin" || nm == "is" || nm == "isnot" || nm == "&" || nm == "|" || nm == "^" || nm == "~" || nm == ".." || nm == "..<" || nm == "$" || nm == "await":
        mask = mask | semNameClassOperator
    return mask

fn semStrPtrKey(s: str): int64 =
    return int64(strDataPtr(s))

fn semCanonicalTextId(nm: str, textId: int32): int32 =
    if textId > 0:
        semEnsureCanonicalTextCache(textId)
        if textId < semCanonicalTextReady.len && textId < semCanonicalTextValue.len &&
           semCanonicalTextReady[textId]:
            let cachedId: int32 = semCanonicalTextValue[textId]
            if cachedId > 0:
                return cachedId
        let canonicalId: int32 = tokenTextTrimmedCanonicalId(textId)
        if textId < semCanonicalTextReady.len && textId < semCanonicalTextValue.len:
            semCanonicalTextReady[textId] = true
            semCanonicalTextValue[textId] = canonicalId
        if canonicalId > 0:
            return canonicalId
    if nm == "":
        return 0
    return tokenInternText(nm)

fn semNormalizedNameFromTextId(nm: str, textId: int32): str =
    if textId > 0:
        let textNorm: str = semNormalizeTextId(textId)
        if textNorm != "":
            return textNorm
    if nm != "":
        return nm
    return ""

fn semNormalizedTextIdOrName(textId: int32, name: str): str =
    if textId > 0:
        return semNormalizeTextId(textId)
    return semNormalizeName(name)

fn semNameDepthPtrPutCached(nm: str, depthPlus1: int32) =
    let ptrKey: int64 = semStrPtrKey(nm)
    semNameDepthPtrPutCachedKey(ptrKey, depthPlus1)

fn semNameDepthPtrPutCachedKey(ptrKey: int64, depthPlus1: int32) =
    if ptrKey == 0:
        return
    var foundPtr: bool
    let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(semNameDepthPtrIndex, ptrKey, foundPtr)
    if foundPtr && idxPlus1Ptr > 0 && idxPlus1Ptr <= semNameDepthPtrValue.len:
        semNameDepthPtrValue[idxPlus1Ptr - 1] = depthPlus1
        return
    add(semNameDepthPtrValue, depthPlus1)
    hashmaps.HashMapPtrIntPut(semNameDepthPtrIndex, ptrKey, semNameDepthPtrValue.len)

fn semNameDepthLinearFind(ctx: var SemCtx, nm: str): int32 =
    if nm == "":
        return 0
    let nameLen: int32 = ctx.names.len
    let scopeLen: int32 = ctx.scopeStarts.len
    if nameLen <= 0 || scopeLen <= 0:
        return 0
    let ptrKey: int64 = semStrPtrKey(nm)
    var scopeIdx: int32 = scopeLen - 1
    var scopeStart: int32 = ctx.scopeStarts[scopeIdx]
    var i: int32 = nameLen - 1
    while i >= 0:
        while scopeIdx > 0 && i < scopeStart:
            scopeIdx = scopeIdx - 1
            scopeStart = ctx.scopeStarts[scopeIdx]
        if ptrKey != 0:
            let entryPtrKey: int64 = ctx.namePtrKeys[i]
            if entryPtrKey != 0:
                if entryPtrKey == ptrKey:
                    return scopeIdx + 1
                i = i - 1
                continue
        if ctx.names[i] == nm:
            return scopeIdx + 1
        i = i - 1
    return 0

fn semNameDepthLinearFindTextId(ctx: var SemCtx, textId: int32): int32 =
    if textId <= 0:
        return 0
    let nameLen: int32 = ctx.nameTextIds.len
    let scopeLen: int32 = ctx.scopeStarts.len
    if nameLen <= 0 || scopeLen <= 0:
        return 0
    var scopeIdx: int32 = scopeLen - 1
    var scopeStart: int32 = ctx.scopeStarts[scopeIdx]
    var i: int32 = nameLen - 1
    while i >= 0:
        while scopeIdx > 0 && i < scopeStart:
            scopeIdx = scopeIdx - 1
            scopeStart = ctx.scopeStarts[scopeIdx]
        if ctx.nameTextIds[i] == textId:
            return scopeIdx + 1
        i = i - 1
    return 0

fn semNameDepthGetCached(ctx: var SemCtx, nm: str): int32 =
    if nm == "":
        return 0
    let ptrKey: int64 = semStrPtrKey(nm)
    if semNameDepthFindRecentValid && semNameDepthFindRecentEpoch == semScopeEpoch:
        if ptrKey != 0 && semNameDepthFindRecentPtrKey == ptrKey:
            return semNameDepthFindRecentResult
        if ptrKey == 0 && nm == semNameDepthFindRecentName:
            return semNameDepthFindRecentResult
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(semNameDepthPtrIndex, ptrKey, foundPtr)
        if foundPtr && idxPlus1Ptr > 0 && idxPlus1Ptr <= semNameDepthPtrValue.len:
            let outPtr: int32 = semReadI32(semNameDepthPtrValue, idxPlus1Ptr - 1)
            semNameDepthFindRecentEpoch = semScopeEpoch
            semNameDepthFindRecentPtrKey = ptrKey
            semNameDepthFindRecentName = nm
            semNameDepthFindRecentResult = outPtr
            semNameDepthFindRecentValid = true
            return outPtr
    var found: bool
    var depthPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.nameDepths, nm, found)
    if !found:
        depthPlus1 = semNameDepthLinearFind(ctx, nm)
        if depthPlus1 > 0:
            hashmaps.HashMapStrIntPut(ctx.nameDepths, nm, depthPlus1)
    if ptrKey != 0:
        semNameDepthPtrPutCached(nm, depthPlus1)
    semNameDepthFindRecentEpoch = semScopeEpoch
    semNameDepthFindRecentPtrKey = ptrKey
    semNameDepthFindRecentTextId = 0
    semNameDepthFindRecentName = nm
    semNameDepthFindRecentResult = depthPlus1
    semNameDepthFindRecentValid = true
    return depthPlus1

fn semNameDepthGetCachedWithTextId(ctx: var SemCtx, nm: str, textId: int32): int32 =
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if queryTextId > 0:
        if semNameDepthFindRecentValid && semNameDepthFindRecentEpoch == semScopeEpoch &&
           semNameDepthFindRecentTextId == queryTextId:
            let recentDepthPlus1: int32 = semNameDepthFindRecentResult
            if textId > 0 && queryTextId != textId:
                semNameDepthTextPut(textId, recentDepthPlus1)
            return recentDepthPlus1
        var foundText: bool
        let depthPlus1Text: int32 = semNameDepthTextGet(queryTextId, foundText)
        if foundText:
            if textId > 0 && queryTextId != textId:
                semNameDepthTextPut(textId, depthPlus1Text)
            semNameDepthFindRecentEpoch = semScopeEpoch
            semNameDepthFindRecentPtrKey = 0
            semNameDepthFindRecentTextId = queryTextId
            semNameDepthFindRecentName = nm
            semNameDepthFindRecentResult = depthPlus1Text
            semNameDepthFindRecentValid = true
            return depthPlus1Text
        var depthPlus1: int32 = semNameDepthLinearFindTextId(ctx, queryTextId)
        semNameDepthTextPut(queryTextId, depthPlus1)
        if textId > 0 && queryTextId != textId:
            semNameDepthTextPut(textId, depthPlus1)
        semNameDepthFindRecentEpoch = semScopeEpoch
        semNameDepthFindRecentPtrKey = 0
        semNameDepthFindRecentTextId = queryTextId
        semNameDepthFindRecentName = nm
        semNameDepthFindRecentResult = depthPlus1
        semNameDepthFindRecentValid = true
        return depthPlus1
    if nm == "":
        return 0
    return semNameDepthGetCached(ctx, nm)

fn semNameDepthPutCachedResolved(ctx: var SemCtx, nm: str, textId: int32,
                                 ptrKey: int64, depthPlus1: int32) =
    if ptrKey != 0 &&
       semNameDepthRecentValid &&
       semNameDepthRecentEpoch == semScopeEpoch &&
       semNameDepthRecentPtrKey == ptrKey &&
       semNameDepthRecentDepthPlus1 == depthPlus1:
        return
    var ptrSame: bool
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(semNameDepthPtrIndex, ptrKey, foundPtr)
        if foundPtr && idxPlus1Ptr > 0 && idxPlus1Ptr <= semNameDepthPtrValue.len:
            ptrSame = semReadI32(semNameDepthPtrValue, idxPlus1Ptr - 1) == depthPlus1
    if textId > 0:
        var foundText: bool
        let cachedTextDepth: int32 = semNameDepthTextGet(textId, foundText)
        if foundText && cachedTextDepth == depthPlus1:
            if !ptrSame:
                semNameDepthPtrPutCachedKey(ptrKey, depthPlus1)
            semNameDepthRecentEpoch = semScopeEpoch
            semNameDepthRecentPtrKey = ptrKey
            semNameDepthRecentTextId = textId
            semNameDepthRecentDepthPlus1 = depthPlus1
            semNameDepthRecentValid = ptrKey != 0 || textId > 0
            semNameDepthFindRecentEpoch = semScopeEpoch
            semNameDepthFindRecentPtrKey = ptrKey
            semNameDepthFindRecentTextId = textId
            semNameDepthFindRecentName = nm
            semNameDepthFindRecentResult = depthPlus1
            semNameDepthFindRecentValid = true
            return
    var found: bool
    let cachedDepth: int32 = hashmaps.HashMapStrIntGetEx(ctx.nameDepths, nm, found)
    if !found || cachedDepth != depthPlus1:
        hashmaps.HashMapStrIntPut(ctx.nameDepths, nm, depthPlus1)
    if !ptrSame:
        semNameDepthPtrPutCachedKey(ptrKey, depthPlus1)
    if textId > 0:
        semNameDepthTextPut(textId, depthPlus1)
    semNameDepthRecentEpoch = semScopeEpoch
    semNameDepthRecentPtrKey = ptrKey
    semNameDepthRecentTextId = textId
    semNameDepthRecentDepthPlus1 = depthPlus1
    semNameDepthRecentValid = ptrKey != 0 || textId > 0
    semNameDepthFindRecentEpoch = semScopeEpoch
    semNameDepthFindRecentPtrKey = ptrKey
    semNameDepthFindRecentTextId = textId
    semNameDepthFindRecentName = nm
    semNameDepthFindRecentResult = depthPlus1
    semNameDepthFindRecentValid = true

fn semNameDepthPutCachedWithPtrKey(ctx: var SemCtx, nm: str, ptrKey: int64, depthPlus1: int32) =
    semNameDepthPutCachedResolved(ctx, nm, 0, ptrKey, depthPlus1)

fn semNameDepthPutCached(ctx: var SemCtx, nm: str, depthPlus1: int32) =
    semNameDepthPutCachedWithPtrKey(ctx, nm, semStrPtrKey(nm), depthPlus1)

fn semNameDepthTextGet(textId: int32, found: var bool): int32 =
    found = false
    if textId <= 0:
        return 0
    if textId >= semNameDepthTextReady.len || textId >= semNameDepthTextValue.len:
        return 0
    if !semNameDepthTextReady[textId]:
        return 0
    found = true
    return semNameDepthTextValue[textId]

fn semNameDepthTextPut(textId: int32, depthPlus1: int32) =
    if textId <= 0:
        return
    semEnsureNameDepthTextCache(textId)
    if textId < semNameDepthTextReady.len && textId < semNameDepthTextValue.len:
        semNameDepthTextReady[textId] = true
        semNameDepthTextValue[textId] = depthPlus1

fn semBorrowAllowTextGet(textId: int32, found: var bool): bool =
    found = false
    if textId <= 0:
        return false
    if textId >= semBorrowAllowTextReady.len || textId >= semBorrowAllowTextValue.len:
        return false
    if !semBorrowAllowTextReady[textId]:
        return false
    found = true
    return semBorrowAllowTextValue[textId]

fn semBorrowAllowTextPut(textId: int32, allowed: bool) =
