fn semTextIdInList(values: int32[], textId: int32): bool =
    if textId <= 0:
        return false
    for i in 0..<values.len:
        if values[i] == textId:
            return true
    return false

fn semEnsureBorrowAllowTextCache(textId: int32) =
    if textId <= 0:
        return
    let needLen: int32 = textId + 1
    let oldReadyLen: int32 = semBorrowAllowTextReady.len
    if oldReadyLen < needLen:
        seqs.reserve(semBorrowAllowTextReady, needLen)
        seqs.setLen(semBorrowAllowTextReady, needLen)
        for i in oldReadyLen..<needLen:
            semBorrowAllowTextReady[i] = false
    let oldValueLen: int32 = semBorrowAllowTextValue.len
    if oldValueLen < needLen:
        seqs.reserve(semBorrowAllowTextValue, needLen)
        seqs.setLen(semBorrowAllowTextValue, needLen)
        for i in oldValueLen..<needLen:
            semBorrowAllowTextValue[i] = false

