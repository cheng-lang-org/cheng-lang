    if nm ==  "findBitswapEntry":
        return true
    if nm ==  "findConnectionIndex":
        return true
    if nm ==  "findDataTransferChannel":
        return true
    if nm ==  "findDataTransferSnapshot":
        return true
    if nm ==  "findFreeDataTransferChannel":
