fn semIsBorrowPassAllowedLibp2pCallNameWithTextId(nm: str, textId: int32): bool =
    if textId > 0:
        semEnsureLibp2pBorrowPassTextIds()
        return semTextIdInList(semLibp2pBorrowPassTextIds, textId)
    return semIsBorrowPassAllowedLibp2pCallName(nm)

fn semIsBorrowPassAllowedCallNameNormalized(nm: str): bool =
    return (semCallNameFlagsOfNormalized(nm) & semCallNameFlagBorrowPassAllowed) != 0

fn semIsBorrowPassAllowedCallName(name: str): bool =
    let nm: str = semNormalizeName(name)
    return semIsBorrowPassAllowedCallNameNormalized(nm)

fn semExprIsBorrowSource(ctx: var SemCtx, n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    var out: bool
    case nodeKind(n)
    of nkIdent, nkSymbol:
        out = semBorrowIsActiveIdentCached(ctx, n)
    of nkDotExpr, nkBracketExpr, nkHiddenDeref, nkDerefExpr:
        if kidCount(n) > 0:
            out = semExprIsBorrowSource(ctx, kid(n, 0))
        else:
            out = false
    of nkCallArg:
        if kidCount(n) > 1:
            out = semExprIsBorrowSource(ctx, kid(n, 1))
        else:
            out = false
    of nkPar:
        if kidCount(n) == 1:
            out = semExprIsBorrowSource(ctx, kid(n, 0))
        else:
            out = false
    else:
        out = false
    return out

fn semExprIsBorrowed(ctx: var SemCtx, n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    if ctx.borrowActiveTotal == 0:
        return false
    let profKindOn: bool = semProfOn && (semProfExprSampleOn || semProfStmtSampleOn)
    var profStartNs: int64
    if profKindOn:
        profStartNs = cheng_monotime_ns()
    var res: bool
    case nodeKind(n)
    of nkIdent, nkSymbol:
        res = semBorrowIsActiveIdentCached(ctx, n)
    of nkDotExpr, nkBracketExpr:
        res = false
    of nkHiddenDeref, nkDerefExpr:
        if kidCount(n) > 0:
            res = semExprIsBorrowed(ctx, kid(n, 0))
        else:
            res = false
    of nkCall:
        let callInfo: SemCallInfo = semCallInfoNormalized(n)
        if (callInfo.flags & semCallNameFlagExplicitPtr) != 0:
            res = false
        elif semCallInfoIsBorrowedWithCtx(ctx, callInfo):
            for i in 1..<kidCount(n):
                let arg: Node = kid(n, i)
                if semExprIsBorrowSource(ctx, arg):
                    res = true
                    break
    of nkCallArg:
        if kidCount(n) > 1:
            res = semExprIsBorrowed(ctx, kid(n, 1))
        else:
            res = false
    of nkPar:
        if kidCount(n) == 1:
            res = semExprIsBorrowed(ctx, kid(n, 0))
        else:
            res = false
    of nkTupleLit, nkSeqLit, nkTableLit, nkCurly, nkBracket:
        res = false
        for i in 0..<kidCount(n):
            if semExprIsBorrowed(ctx, kid(n, i)):
                res = true
                break
    of nkIfExpr, nkWhenExpr, nkCaseExpr:
        res = false
        for i in 0..<kidCount(n):
            if semExprIsBorrowed(ctx, kid(n, i)):
                res = true
                break
    else:
        res = false
    if profKindOn:
        semProfRecordBorrowKind(nodeKind(n), cheng_monotime_ns() - profStartNs)
    return res

fn semExprIsBorrowedForCall(ctx: var SemCtx, n: Node): bool =
    if ctx.borrowActiveTotal == 0:
        return false
    if semIsAddrCall(n):
        return false
    if semIsExplicitPtrCall(n):
        return false
    if semExprIsBorrowed(ctx, n):
        return true
    let n2: Node = semStripParExpr(n)
    if stage1AstRefNonNil(n2) && (nodeKind(n2) == nkIdent || nodeKind(n2) == nkSymbol):
        if semBorrowIsActiveIdentCached(ctx, n2):
            return true
    return false

fn semBorrowOriginName(ctx: var SemCtx, n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    if nodeKind(n) == nkCallArg && kidCount(n) > 1:
        return semBorrowOriginName(ctx, kid(n, 1))
    if nodeKind(n) == nkPar && kidCount(n) == 1:
        return semBorrowOriginName(ctx, kid(n, 0))
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        return semIdentNameNormalized(n)
    if nodeKind(n) == nkDotExpr || nodeKind(n) == nkBracketExpr || nodeKind(n) == nkHiddenDeref || nodeKind(n) == nkDerefExpr:
        if kidCount(n) > 0:
            return semBorrowOriginName(ctx, kid(n, 0))
        return ""
    if nodeKind(n) == nkCall:
        let callInfo: SemCallInfo = semCallInfoNormalized(n)
        if semCallInfoIsBorrowedWithCtx(ctx, callInfo):
            if (callInfo.flags & semCallNameFlagExplicitPtr) != 0:
                return ""
            for i in 1..<kidCount(n):
                let arg: Node = kid(n, i)
                let val: Node = semCallArgValue(arg)
                let sub: str = semBorrowOriginName(ctx, val)
                if len(sub) > 0:
                    return sub
        return ""
    return ""

fn semBorrowOriginTextId(ctx: var SemCtx, n: Node): int32 =
    if stage1AstRefIsNil(n):
        return 0
    if nodeKind(n) == nkCallArg && kidCount(n) > 1:
        return semBorrowOriginTextId(ctx, kid(n, 1))
    if nodeKind(n) == nkPar && kidCount(n) == 1:
        return semBorrowOriginTextId(ctx, kid(n, 0))
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        return nodeIdentId(n)
    if nodeKind(n) == nkDotExpr || nodeKind(n) == nkBracketExpr || nodeKind(n) == nkHiddenDeref || nodeKind(n) == nkDerefExpr:
        if kidCount(n) > 0:
            return semBorrowOriginTextId(ctx, kid(n, 0))
        return 0
    if nodeKind(n) == nkCall:
        let callInfo: SemCallInfo = semCallInfoNormalized(n)
        if semCallInfoIsBorrowedWithCtx(ctx, callInfo):
            if (callInfo.flags & semCallNameFlagExplicitPtr) != 0:
                return 0
            for i in 1..<kidCount(n):
                let arg: Node = kid(n, i)
                let val: Node = semCallArgValue(arg)
                let sub: int32 = semBorrowOriginTextId(ctx, val)
                if sub > 0:
                    return sub
        return 0
    return 0

fn semBorrowRootName(ctx: var SemCtx, n: Node): str =
    return semBorrowOriginName(ctx, n)

fn semBorrowEscapeMessage(what: str, name: str): str =
    if (name ==  ""):
        return "Borrowed value cannot " + what
    return "Borrowed value cannot " + what + ": " + name

fn semBorrowOriginUseMessage(name: str): str =
    if (name ==  ""):
        return "Cannot use while borrowed"
    return "Cannot use while borrowed: " + name

fn semBorrowOriginWriteMessage(name: str): str =
    if (name ==  ""):
        return "Cannot write while borrowed"
    return "Cannot write while borrowed: " + name

fn semCheckBorrowEscape(ctx: var SemCtx, expr: Node, what: str) =
    if stage1AstRefIsNil(expr):
        return
    if ctx.borrowActiveTotal == 0:
        return
    if semExprIsBorrowed(ctx, expr):
        let nm: str = semBorrowRootName(ctx, expr)
        semAddError(ctx, nodePos(expr), semBorrowEscapeMessage(what, nm))
        return
    let expr2: Node = semStripParExpr(expr)
    if stage1AstRefNonNil(expr2) && (nodeKind(expr2) == nkIdent || nodeKind(expr2) == nkSymbol):
        if semBorrowIsActiveIdentCached(ctx, expr2):
            let nm2: str = semBorrowRootName(ctx, expr2)
            semAddError(ctx, nodePos(expr2), semBorrowEscapeMessage(what, nm2))

fn semCheckBorrowOriginUse(ctx: var SemCtx, expr: Node) =
    if stage1AstRefIsNil(expr):
        return
    if ctx.borrowActiveTotal == 0:
        return
    if nodeKind(expr) != nkIdent && nodeKind(expr) != nkSymbol:
        return
    let textId: int32 = semCanonicalTextId("", nodeIdentId(expr))
    var nm: str
    if textId > 0:
        if tokenTextEqLitId(textId, "_"):
            return
        nm = semNormalizedNameFromTextId("", textId)
    else:
        nm = semIdentNameNormalized(expr)
        if (nm ==  "") ||(nm ==  "_"):
            return
    if semBorrowOriginIsActiveIdentCached(ctx, expr):
        semAddError(ctx, nodePos(expr), semBorrowOriginUseMessage(nm))

fn semCheckBorrowOriginWrite(ctx: var SemCtx, expr: Node) =
    if stage1AstRefIsNil(expr):
        return
    if ctx.borrowActiveTotal == 0:
        return
    if nodeKind(expr) != nkIdent && nodeKind(expr) != nkSymbol:
        return
    let textId: int32 = semCanonicalTextId("", nodeIdentId(expr))
    var nm: str
    if textId > 0:
        if tokenTextEqLitId(textId, "_"):
            return
        nm = semNormalizedNameFromTextId("", textId)
    else:
        nm = semIdentNameNormalized(expr)
        if (nm ==  "") ||(nm ==  "_"):
            return
    semBorrowDebugLogWriteCheck(ctx, "write_check", expr, nm)
    if semBorrowOriginIsActiveIdentCached(ctx, expr):
        semBorrowDebugLogWriteCheck(ctx, "write_error", expr, nm)
        semAddError(ctx, nodePos(expr), semBorrowOriginWriteMessage(nm))

fn semCheckVarParamCall(ctx: var SemCtx, callNode: Node, callInfo: SemCallInfo) =
    if stage1AstRefIsNil(callNode) || nodeKind(callNode) != nkCall || kidCount(callNode) == 0:
        return
    if ctx.borrowActiveTotal == 0 && kidCount(callNode) <= 1:
        return
    if ctx.fnSigNames.len == 0:
        return
    if !semCallInfoHasName(callInfo):
        return
    var name: str
    if semCallInfoDefDepthCached(ctx, callNode, callInfo) > 0:
        return
    let sigIdx: int32 = semCallInfoFnSigFindCached(ctx, callNode, callInfo)
    if sigIdx < 0:
        if ctx.borrowActiveTotal == 0:
            return
        var escapesBorrow: bool
        let allowBorrow: bool = semCallInfoBorrowPassAllowedCached(ctx, callNode, callInfo, escapesBorrow)
        # Unknown/unresolved calls cannot silently bypass borrow proof when a borrow is active.
        # Require an explicit signature (or @borrows/@escapes annotation) at call boundaries.
        if stage1AstRefNonNil(callInfo.base):
            let baseVal: Node = semCallArgValue(callInfo.base)
            if !allowBorrow && stage1AstRefNonNil(baseVal) && semExprIsBorrowed(ctx, baseVal):
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semAddError(ctx, nodePos(baseVal), "Borrowed value cannot be passed to unresolved call: " + name + " self/arg1")
            if escapesBorrow:
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semCheckBorrowEscape(ctx, baseVal, "escape via call " + name)
        for i0 in 1..<kidCount(callNode):
            let arg0: Node = kid(callNode, i0)
            let val0: Node = semCallArgValue(arg0)
            if !allowBorrow && stage1AstRefNonNil(val0) && semExprIsBorrowed(ctx, val0):
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semAddError(ctx, nodePos(val0), "Borrowed value cannot be passed to unresolved call: " + name + " argument #" + intToStr(i0))
            if escapesBorrow:
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semCheckBorrowEscape(ctx, val0, "escape via call " + name)
        return
    let hasVar: bool = semFnSigHasVar(ctx, sigIdx)
    let hasNonPtr: bool = semFnSigHasNonPtr(ctx, sigIdx)
    var escapesBorrow: bool
    var allowBorrow: bool
    if ctx.borrowActiveTotal == 0:
        if !hasVar:
            return
    else:
        allowBorrow = semCallInfoBorrowPassAllowedCached(ctx, callNode, callInfo, escapesBorrow)
        if !hasVar:
            if allowBorrow || !hasNonPtr:
                return
    let count: int32 = semReadI32(ctx.fnSigParamCounts, sigIdx)
    var baseArg0: Node = callInfo.base
    if stage1AstRefNonNil(baseArg0):
        # Dot-call base can be a module qualifier (e.g. `tables.TablePut(...)`), not an implicit self argument.
        # If the resolved signature arity matches the explicit argument count, ignore the base for borrow checks.
        let argCount: int32 = kidCount(callNode) - 1
        if count == argCount:
            baseArg0 = astInvalidNodeId()
    var posIdx: int32
    if stage1AstRefNonNil(baseArg0):
        let baseIsVar: bool = semFnSigParamIsVar(ctx, sigIdx, 0)
        let baseIsPtrLike: bool = semFnSigParamIsPtrLike(ctx, sigIdx, 0)
        if baseIsVar:
            if ! semIsAddrCall(baseArg0) && ! semIsLValueExpr(baseArg0):
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semAddError(ctx, nodePos(baseArg0), "var parameter requires a mutable borrow (lvalue): " + name + " self/arg1")
        else:
            if escapesBorrow:
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semCheckBorrowEscape(ctx, semCallArgValue(baseArg0), "escape via call " + name)
            if ctx.borrowActiveTotal != 0 && !allowBorrow && !baseIsPtrLike && semExprIsBorrowedForCall(ctx, baseArg0):
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semAddError(ctx, nodePos(baseArg0), "Borrowed value cannot be passed to non-var parameter: " + name + " self/arg1")
        posIdx = 1
    for i in 1..<kidCount(callNode):
        let arg: Node = kid(callNode, i)
        if stage1AstRefIsNil(arg):
            continue
        if nodeKind(arg) == nkCallArg && kidCount(arg) > 1:
            let argNameTextId: int32 = semCallArgNameTextId(arg)
            var argNameNm: str
            var idx: int32 = -1
            if argNameTextId > 0:
                idx = semFnSigParamIndexNormalizedWithTextId(ctx, sigIdx, "", argNameTextId)
            else:
                argNameNm = semCallArgNameNormalized(arg)
                idx = semFnSigParamIndexNormalized(ctx, sigIdx, argNameNm)
            if idx >= 0 && semFnSigParamIsVar(ctx, sigIdx, idx):
                let val: Node = semCallArgValue(arg)
                if stage1AstRefNonNil(val) && ! semIsAddrCall(val) && ! semIsLValueExpr(val):
                    if argNameNm == "":
                        argNameNm = semCallArgNameNormalized(arg)
                    if name == "":
                        name = semCallInfoNormalizedName(callInfo)
                    semAddError(ctx, nodePos(val), "var parameter requires a mutable borrow (lvalue): " + name + " argument " + semCallArgDisplayName(argNameNm, arg))
            elif idx >= 0:
                let isPtrLikeParam: bool = semFnSigParamIsPtrLike(ctx, sigIdx, idx)
                let val2: Node = semCallArgValue(arg)
                if escapesBorrow:
                    if name == "":
                        name = semCallInfoNormalizedName(callInfo)
                    semCheckBorrowEscape(ctx, val2, "escape via call " + name)
                if ctx.borrowActiveTotal != 0 && !allowBorrow && !isPtrLikeParam && stage1AstRefNonNil(val2) && semExprIsBorrowedForCall(ctx, val2):
                    if argNameNm == "":
                        argNameNm = semCallArgNameNormalized(arg)
                    if name == "":
                        name = semCallInfoNormalizedName(callInfo)
                    semAddError(ctx, nodePos(val2), "Borrowed value cannot be passed to non-var parameter: " + name + " argument " + semCallArgDisplayName(argNameNm, arg))
        else:
            if posIdx < count && semFnSigParamIsVar(ctx, sigIdx, posIdx):
                let val2: Node = semCallArgValue(arg)
                if stage1AstRefNonNil(val2) && ! semIsAddrCall(val2) && ! semIsLValueExpr(val2):
                    let argIdx: int32 = posIdx + 1
                    if name == "":
                        name = semCallInfoNormalizedName(callInfo)
                    semAddError(ctx, nodePos(val2), "var parameter requires a mutable borrow (lvalue): " + name + " argument #" + intToStr(argIdx))
            elif posIdx < count:
                let isPtrLikePos: bool = semFnSigParamIsPtrLike(ctx, sigIdx, posIdx)
                let val3: Node = semCallArgValue(arg)
                if escapesBorrow:
                    if name == "":
                        name = semCallInfoNormalizedName(callInfo)
                    semCheckBorrowEscape(ctx, val3, "escape via call " + name)
                if ctx.borrowActiveTotal != 0 && !allowBorrow && !isPtrLikePos && stage1AstRefNonNil(val3) && semExprIsBorrowedForCall(ctx, val3):
                    let argIdx: int32 = posIdx + 1
                    if name == "":
                        name = semCallInfoNormalizedName(callInfo)
                    semAddError(ctx, nodePos(val3), "Borrowed value cannot be passed to non-var parameter: " + name + " argument #" + intToStr(argIdx))
            posIdx = posIdx + 1

fn semThreadBoundaryBorrowMessage(name: str, label: str): str =
    return "Borrowed value cannot be passed across threads: " + name + " argument " + label

fn semThreadBoundarySendMessage(name: str, label: str): str =
    return "Cross-thread argument must be Send/Sync: " + name + " argument " + label

fn semCheckThreadBoundaryArg(ctx: var SemCtx, name: str, argNode: Node, label: str) =
    if stage1AstRefIsNil(argNode):
        return
    let val: Node = semCallArgValue(argNode)
    if stage1AstRefIsNil(val):
        return
    if semExprIsBorrowed(ctx, val):
        semAddError(ctx, nodePos(val), semThreadBoundaryBorrowMessage(name, label))
        return
    if ! semExprIsSend(ctx, val):
        semAddError(ctx, nodePos(val), semThreadBoundarySendMessage(name, label))

fn semSpawnEntryMessage(label: str): str =
    return "spawn entry expects function reference: " + label

fn semExprIsSpawnEntry(ctx: var SemCtx, n0: Node): bool =
    if stage1AstRefIsNil(n0):
        return false
    var n: Node = n0
    while stage1AstRefNonNil(n) && nodeKind(n) == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if stage1AstRefIsNil(n):
        return false
    if nodeKind(n) == nkNilLit:
        return true
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        return semIdentFnSigFindCached(ctx, n) >= 0
    if nodeKind(n) == nkPrefix && kidCount(n) > 1:
        let opNode: Node = kid(n, 0)
        let opTextId: int32 = semCanonicalTextId("", nodeIdentId(opNode))
        let isAddrOp: bool = (opTextId > 0 && tokenTextEqLitId(opTextId, "&")) ||
                             (opTextId <= 0 && semNodeNameNormalized(opNode) == "&")
        if isAddrOp:
            let inner: Node = kid(n, 1)
            if stage1AstRefNonNil(inner) && (nodeKind(inner) == nkIdent || nodeKind(inner) == nkSymbol):
                return semIdentFnSigFindCached(ctx, inner) >= 0
            return false
    if nodeKind(n) == nkCall:
        let callInfo: SemCallInfo = semCallInfoNormalized(n)
        semEnsureCallNameTextIds()
        if semCallInfoNameMatches(callInfo, semCallNameIdAddr, "__addr") && kidCount(n) > 1:
            let inner2: Node = semCallArgValue(kid(n, 1))
            if stage1AstRefNonNil(inner2) && (nodeKind(inner2) == nkIdent || nodeKind(inner2) == nkSymbol):
                return semIdentFnSigFindCached(ctx, inner2) >= 0
    return false

fn semCheckSpawnEntryArg(ctx: var SemCtx, argNode: Node, label: str) =
    if stage1AstRefIsNil(argNode):
        return
    let val: Node = semCallArgValue(argNode)
    if stage1AstRefIsNil(val):
        return
    if semExprIsBorrowed(ctx, val):
        semAddError(ctx, nodePos(val), semThreadBoundaryBorrowMessage("spawn", label))
        return
    if !semExprIsSpawnEntry(ctx, val):
        semAddError(ctx, nodePos(val), semSpawnEntryMessage(label))

fn semCallArgNameTextId(argNode: Node): int32 =
    if stage1AstRefIsNil(argNode) || nodeKind(argNode) != nkCallArg || kidCount(argNode) <= 1:
        return 0
    let nameNode: Node = kid(argNode, 0)
    if stage1AstRefIsNil(nameNode) || nodeKind(nameNode) == nkEmpty:
        return 0
    if nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol:
        return semCanonicalTextId("", nodeIdentId(nameNode))
    return 0

fn semCallArgNameNormalized(argNode: Node): str =
    if stage1AstRefIsNil(argNode) || nodeKind(argNode) != nkCallArg || kidCount(argNode) <= 1:
        return ""
    let nameNode: Node = kid(argNode, 0)
    if stage1AstRefIsNil(nameNode) || nodeKind(nameNode) == nkEmpty:
        return ""
    let textId: int32 = semCallArgNameTextId(argNode)
    if textId > 0:
        return semNormalizedNameFromTextId("", textId)
    return semNodeNameNormalized(nameNode)

fn semCallArgHasName(argNode: Node): bool =
    if stage1AstRefIsNil(argNode) || nodeKind(argNode) != nkCallArg || kidCount(argNode) <= 1:
        return false
    let nameNode: Node = kid(argNode, 0)
    if stage1AstRefIsNil(nameNode) || nodeKind(nameNode) == nkEmpty:
        return false
    if semCallArgNameTextId(argNode) > 0:
        return true
    return true

fn semCallArgDisplayName(argNameNm: str, argNode: Node): str =
    if argNameNm != "":
        return argNameNm
    return plainName(kid(argNode, 0))

fn semThreadBoundarySkipArg(callInfo: SemCallInfo, argNode: Node, posIdx: int32): bool =
    if (callInfo.flags & semCallNameFlagThreadBoundary) == 0 || stage1AstRefIsNil(argNode):
        return false
    if (callInfo.flags & semCallNameFlagSpawnBoundary) == 0:
        return false
    # Spawn entry is always the first logical argument even if parser lowering
    # materializes it as a call-arg node with a synthetic name slot.
    if posIdx == 0:
        return true
    if semCallArgHasName(argNode):
        semEnsureCallNameTextIds()
        let argNameTextId: int32 = semCallArgNameTextId(argNode)
        if argNameTextId > 0 && semTextEqId(argNameTextId, semCallArgNameIdEntry):
            return true
        let argNameNm: str = semCallArgNameNormalized(argNode)
        if argNameNm == "entry":
            return true
        return false
    return false

fn semCheckThreadBoundaryCall(ctx: var SemCtx, callNode: Node, callInfo: SemCallInfo) =
    if stage1AstRefIsNil(callNode) || nodeKind(callNode) != nkCall:
        return
    let count: int32 = kidCount(callNode)
    if count == 0:
        return
    if !semCallInfoHasName(callInfo):
        return
    var name: str
    let isRequiredBoundary: bool = (callInfo.flags & semCallNameFlagThreadBoundary) != 0
    if !isRequiredBoundary && ctx.threadBoundaryNames.len <= 3:
        return
    let isThreadBoundary: bool = semIsThreadBoundaryNormalizedWithTextId(ctx, callInfo.name, callInfo.nameTextId)
    if isRequiredBoundary && !isThreadBoundary:
        if name == "":
            name = semCallInfoNormalizedName(callInfo)
        semAddError(ctx, nodePos(callNode), "thread boundary requires @thread_boundary: " + name)
        return
    if !isThreadBoundary:
        return
    var baseArg0: Node = callInfo.base
    if stage1AstRefNonNil(baseArg0):
        let sigIdx: int32 = semCallInfoFnSigFindCached(ctx, callNode, callInfo)
        if sigIdx >= 0:
            let sigCount: int32 = semReadI32(ctx.fnSigParamCounts, sigIdx)
            let argCount: int32 = kidCount(callNode) - 1
            if sigCount == argCount:
                baseArg0 = astInvalidNodeId()
    if stage1AstRefNonNil(baseArg0):
        if name == "":
            name = semCallInfoNormalizedName(callInfo)
        semCheckThreadBoundaryArg(ctx, name, baseArg0, "self/arg1")
    var posIdx: int32
    for i in 1..<count:
        let arg: Node = kid(callNode, i)
        if stage1AstRefIsNil(arg):
            continue
        let isPositionalArg: bool = (nodeKind(arg) != nkCallArg) || !semCallArgHasName(arg)
        if semThreadBoundarySkipArg(callInfo, arg, posIdx):
            if isPositionalArg:
                semCheckSpawnEntryArg(ctx, arg, "#" + intToStr(posIdx + 1))
                posIdx = posIdx + 1
            else:
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semCheckSpawnEntryArg(ctx, arg, semCallArgNameNormalized(arg))
            continue
        if nodeKind(arg) == nkCallArg:
            if kidCount(arg) > 1:
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semCheckThreadBoundaryArg(ctx, name, arg, semCallArgDisplayName(semCallArgNameNormalized(arg), arg))
            else:
                let argIdx: int32 = posIdx + 1
                if name == "":
                    name = semCallInfoNormalizedName(callInfo)
                semCheckThreadBoundaryArg(ctx, name, arg, "#" + intToStr(argIdx))
                posIdx = posIdx + 1
        else:
            let argIdx: int32 = posIdx + 1
            if name == "":
                name = semCallInfoNormalizedName(callInfo)
            semCheckThreadBoundaryArg(ctx, name, arg, "#" + intToStr(argIdx))
            posIdx = posIdx + 1

fn semSendCtorMessage(name: str, label: str): str =
    return "Cross-thread constructor requires Send/Sync: " + name + " argument " + label

fn semCheckSendCtorCall(ctx: var SemCtx, callNode: Node, callInfo: SemCallInfo) =
    if stage1AstRefIsNil(callNode) || nodeKind(callNode) != nkCall:
        return
    let count: int32 = kidCount(callNode)
    if count == 0:
        return
    if !semCallInfoHasName(callInfo):
        return
    if (callInfo.flags & semCallNameFlagSendCtor) == 0:
        return
    semEnsureCallNameTextIds()
    if !semCallInfoNameMatches(callInfo, semCallNameIdArcNew, "arcNew") &&
       !semCallInfoNameMatches(callInfo, semCallNameIdShareMt, "share_mt") &&
       !semCallInfoNameMatches(callInfo, semCallNameIdMutexNew, "mutexNew") &&
       !semCallInfoNameMatches(callInfo, semCallNameIdRwLockNew, "rwLockNew") &&
       !semCallInfoNameMatches(callInfo, semCallNameIdAtomicNew, "atomicNew"):
        return
    var name: str
    var posIdx: int32
    for i in 1..<count:
        let arg: Node = kid(callNode, i)
        if stage1AstRefIsNil(arg):
            continue
        if nodeKind(arg) == nkCallArg:
            if kidCount(arg) > 1:
                let argName: str = plainName(kid(arg, 0))
                let val: Node = semCallArgValue(arg)
                if stage1AstRefNonNil(val) && ! semExprIsSend(ctx, val):
                    if !semIsGenericValueParamNode(ctx, val):
                        if name == "":
                            name = semCallInfoNormalizedName(callInfo)
                        semAddError(ctx, nodePos(val), semSendCtorMessage(name, argName))
            else:
                let val2: Node = semCallArgValue(arg)
                if stage1AstRefNonNil(val2) && ! semExprIsSend(ctx, val2):
                    if !semIsGenericValueParamNode(ctx, val2):
                        let argIdx: int32 = posIdx + 1
                        if name == "":
                            name = semCallInfoNormalizedName(callInfo)
                        semAddError(ctx, nodePos(val2), semSendCtorMessage(name, "#" + intToStr(argIdx)))
                posIdx = posIdx + 1
        else:
            let val2: Node = semCallArgValue(arg)
            if stage1AstRefNonNil(val2) && ! semExprIsSend(ctx, val2):
                if !semIsGenericValueParamNode(ctx, val2):
                    let argIdx: int32 = posIdx + 1
                    if name == "":
                        name = semCallInfoNormalizedName(callInfo)
                    semAddError(ctx, nodePos(val2), semSendCtorMessage(name, "#" + intToStr(argIdx)))
            posIdx = posIdx + 1

fn semIsLiteralIdent(name: str): bool =
    return semIsLiteralIdentNormalized(semNormalizeName(name))

fn semIsIntrinsicIdent(name: str): bool =
    return semIsIntrinsicIdentNormalized(semNormalizeName(name))

fn semIsGenericBaseIdent(name: str): bool =
    return semIsGenericBaseIdentNormalized(semNormalizeName(name))

fn semAppendDiag(ctx: var SemCtx, severity: Severity, fileName: str, pos: SourcePos, msg: str) =
    if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_DIAG_ADD", "") == "1":
        let f: os.File = os.Get_stderr()
        os.Write(f, "[sem-diag-add] sev=")
        semWriteIntRaw(f, int32(severity))
        os.Write(f, " file='")
        os.Write(f, fileName)
        os.Write(f, "' line=")
        semWriteIntRaw(f, pos.line)
        os.Write(f, " col=")
        semWriteIntRaw(f, pos.col)
        os.Write(f, " msg='")
        os.Write(f, msg)
        os.WriteLine(f, "'")
    let d: Diagnostic = diagMake(severity, fileName, pos.line, pos.col, msg)
    var out: Diagnostic[] = ctx.diags
    add(out, d)
    ctx.diags = out

fn semDiagFileNameOrDefault(primary: str, fallback: str): str =
    if len(primary) > 0:
        return primary
    if len(fallback) > 0:
        return fallback
    return "stdin"

fn semBorrowOriginNameIfBorrowed(ctx: var SemCtx, n: Node, borrowed: bool): str =
    if borrowed:
        return semBorrowOriginName(ctx, n)
    return ""

fn semYieldEscapeWhat(kind: NodeKind): str =
    if kind == nkReturn:
        return "be returned"
    return "be yielded"

fn semAddError(ctx: var SemCtx, pos: SourcePos, msg: str) =
    semAppendDiag(ctx, svError, semDiagFileNameOrDefault(ctx.filename, ""), pos, msg)

fn semAddErrorAtFile(ctx: var SemCtx, fileName0: str, pos: SourcePos, msg: str) =
    semAppendDiag(ctx, svError, semDiagFileNameOrDefault(fileName0, ctx.filename), pos, msg)

fn semAddWarning(ctx: var SemCtx, pos: SourcePos, msg: str) =
    semAppendDiag(ctx, svWarning, semDiagFileNameOrDefault(ctx.filename, ""), pos, msg)

fn semAddHint(ctx: var SemCtx, pos: SourcePos, msg: str) =
    semAppendDiag(ctx, svHint, semDiagFileNameOrDefault(ctx.filename, ""), pos, msg)

fn semOwnershipEnabled(ctx: var SemCtx): bool =
    return ctx.ownershipEnabled

fn semScopeDepth(ctx: var SemCtx): int32 =
    if ctx.scopeStarts.len <= 0:
        return 0
    return ctx.scopeStarts.len - 1

fn semFindDefDepthCore(ctx: var SemCtx, name: str): int32 =
    let nm: str = semNormalizeName(name)
    if (nm ==  ""):
        return -1
    let depthPlus1: int32 = semNameDepthGetCached(ctx, nm)
    if depthPlus1 > 0:
        return depthPlus1 - 1
    return -1

fn semFindDefDepthNormalized(ctx: var SemCtx, nameNorm: str): int32 =
    if (nameNorm ==  ""):
        return -1
    let ptrKey: int64 = semStrPtrKey(nameNorm)
    var foundPtr: bool
    var ptrSlot: int32
    if ptrKey != 0:
        ptrSlot = hashmaps.HashMapPtrIntGet(semDefDepthPtrIndex, ptrKey, foundPtr)
        if foundPtr && ptrSlot > 0 &&
           ptrSlot <= semDefDepthPtrEpoch.len &&
           ptrSlot <= semDefDepthPtrValue.len:
            if semReadI32(semDefDepthPtrEpoch, ptrSlot - 1) == semScopeEpoch:
                return semReadI32(semDefDepthPtrValue, ptrSlot - 1)
    let depthPlus1: int32 = semNameDepthGetCached(ctx, nameNorm)
    let depth: int32 = depthPlus1 > 0 ? (depthPlus1 - 1) : -1
    if ptrKey != 0:
        if foundPtr && ptrSlot > 0 &&
           ptrSlot <= semDefDepthPtrEpoch.len &&
           ptrSlot <= semDefDepthPtrValue.len:
            semDefDepthPtrEpoch[ptrSlot - 1] = semScopeEpoch
            semDefDepthPtrValue[ptrSlot - 1] = depth
        else:
            add(semDefDepthPtrEpoch, semScopeEpoch)
            add(semDefDepthPtrValue, depth)
            hashmaps.HashMapPtrIntPut(semDefDepthPtrIndex, ptrKey, semDefDepthPtrValue.len)
    return depth

fn semFindDefDepthNormalizedWithTextId(ctx: var SemCtx, nameNorm: str, textId: int32): int32 =
    if textId > 0:
        let depthPlus1: int32 = semNameDepthGetCachedWithTextId(ctx, nameNorm, textId)
        let depth: int32 = depthPlus1 > 0 ? (depthPlus1 - 1) : -1
        return depth
    if nameNorm == "":
        return -1
    let depth: int32 = semFindDefDepthNormalized(ctx, nameNorm)
    if textId > 0:
        semNameDepthTextPut(textId, depth >= 0 ? (depth + 1) : 0)
    return depth

fn semFindDefDepth(ctx: var SemCtx, name: str): int32 =
    if ! semProfOn:
        return semFindDefDepthCore(ctx, name)
    semProfFindDefCalls = semProfFindDefCalls + 1
    if (semProfFindDefCalls & 31) == 0:
        let startNs: int64 = cheng_monotime_ns()
        let depth: int32 = semFindDefDepthCore(ctx, name)
        semProfFindDefNs = semProfFindDefNs + ((cheng_monotime_ns() - startNs) * 32)
        return depth
    return semFindDefDepthCore(ctx, name)

fn pushSemScope(ctx: var SemCtx) =
    let profOn: bool = semProfOn && (semProfStmtSampleOn || semProfExprSampleOn)
    var startNs: int64
    if profOn:
        startNs = cheng_monotime_ns()
    semAddInt32(ctx.scopeStarts, ctx.names.len)
    semAddInt32(ctx.borrowScopeStarts, ctx.borrowNames.len)
    semAddInt32(ctx.sendScopeStarts, ctx.sendNames.len)
    if profOn:
        let mul: int32 = semProfSampleMul()
        let delta: int64 = cheng_monotime_ns() - startNs
        semProfScopePushNs = semProfScopePushNs + (delta * int64(mul))
        semProfScopePushCalls = semProfScopePushCalls + mul

fn popSemScope(ctx: var SemCtx) =
    if ctx.scopeStarts.len <= 1:
        return
    let profOn: bool = semProfOn && (semProfStmtSampleOn || semProfExprSampleOn)
    var startNs: int64
    if profOn:
        startNs = cheng_monotime_ns()
    let start: int32 = semReadI32(ctx.scopeStarts, ctx.scopeStarts.len - 1)
    let oldLen: int32 = ctx.names.len
    for i in start..<oldLen:
        let nm: str = semReadStr(ctx.names, i)
        let textId: int32 = semReadI32(ctx.nameTextIds, i)
        let ptrKey: int64 = semReadI64(ctx.namePtrKeys, i)
        let prevDepthPlus1: int32 = semReadI32(ctx.namePrevDepthPlus1, i)
        semNameDepthPutCachedWithPtrKey(ctx, nm, ptrKey, prevDepthPlus1)
        semNameDepthTextPut(textId, prevDepthPlus1)
    ctx.scopeStarts.len = ctx.scopeStarts.len - 1
    ctx.names.len = start
    ctx.nameTextIds.len = start
    ctx.namePtrKeys.len = start
    ctx.namePrevDepthPlus1.len = start
    let bstart: int32 = semReadI32(ctx.borrowScopeStarts, ctx.borrowScopeStarts.len - 1)
    let boldLen: int32 = ctx.borrowNames.len
    let __for_start_bi = boldLen - 1
    for __for_rev_bi in 0..(__for_start_bi - (bstart)):
        let bi = __for_start_bi - __for_rev_bi
        let bname: str = semReadStr(ctx.borrowNames, bi)
        let btextId: int32 = semReadI32(ctx.borrowTextIds, bi)
        let bdepth: int32 = semReadI32(ctx.borrowDepths, bi)
        if semReadI32(ctx.borrowFlags, bi) != 0:
            let oname: str = semReadStr(ctx.borrowOriginNames, bi)
            let otextId: int32 = semReadI32(ctx.borrowOriginTextIds, bi)
            let odepth: int32 = semReadI32(ctx.borrowOriginDepths, bi)
            semBorrowOriginCountAddWithTextId(ctx, oname, otextId, odepth, -1)
            ctx.borrowActiveTotal = ctx.borrowActiveTotal - 1
            semBorrowDebugLogMark(ctx, "pop_remove", bname, btextId, true, oname, otextId, bdepth, odepth)
        let prevIndexPlus1: int32 = semReadI32(ctx.borrowPrevIndexPlus1, bi)
        let prevTextIndexPlus1: int32 = semReadI32(ctx.borrowPrevTextIndexPlus1, bi)
        let prevExactIndexPlus1: int32 = semReadI32(ctx.borrowPrevExactIndexPlus1, bi)
        hashmaps.HashMapStrIntPut(ctx.borrowIndex, bname, prevIndexPlus1)
        let bptrKey: int64 = semStrPtrKey(bname)
        if bptrKey != 0:
            hashmaps.HashMapPtrIntPut(ctx.borrowPtrIndex, bptrKey, prevIndexPlus1)
        semBorrowTextIndexPut(btextId, prevTextIndexPlus1)
        semBorrowExactPut(ctx, btextId, bdepth, prevExactIndexPlus1)
        if prevIndexPlus1 > 0:
            let prevIdx: int32 = prevIndexPlus1 - 1
            if prevIdx >= 0 && prevIdx < ctx.borrowNames.len && semReadI32(ctx.borrowFlags, prevIdx) != 0:
                let oname2: str = semReadStr(ctx.borrowOriginNames, prevIdx)
                let otextId2: int32 = semReadI32(ctx.borrowOriginTextIds, prevIdx)
                let odepth2: int32 = semReadI32(ctx.borrowOriginDepths, prevIdx)
                semBorrowOriginCountAddWithTextId(ctx, oname2, otextId2, odepth2, 1)
                ctx.borrowActiveTotal = ctx.borrowActiveTotal + 1
                semBorrowDebugLogMark(ctx, "pop_restore", bname, btextId, true, oname2, otextId2, bdepth, odepth2)
    ctx.borrowScopeStarts.len = ctx.borrowScopeStarts.len - 1
    ctx.borrowNames.len = bstart
    ctx.borrowTextIds.len = bstart
    ctx.borrowDepths.len = bstart
    ctx.borrowFlags.len = bstart
    ctx.borrowOriginNames.len = bstart
    ctx.borrowOriginTextIds.len = bstart
    ctx.borrowOriginDepths.len = bstart
    ctx.borrowPrevIndexPlus1.len = bstart
    ctx.borrowPrevTextIndexPlus1.len = bstart
    ctx.borrowPrevExactIndexPlus1.len = bstart
    let sstart: int32 = semReadI32(ctx.sendScopeStarts, ctx.sendScopeStarts.len - 1)
    let soldLen: int32 = ctx.sendNames.len
    let __for_start_si = soldLen - 1
    for __for_rev_si in 0..(__for_start_si - (sstart)):
        let si = __for_start_si - __for_rev_si
        let stextId: int32 = semReadI32(ctx.sendTextIds, si)
        let prevIndexPlus1: int32 = semReadI32(ctx.sendPrevIndexPlus1, si)
        let prevTextIndexPlus1: int32 = semReadI32(ctx.sendPrevTextIndexPlus1, si)
        if stextId <= 0:
            let sname: str = semReadStr(ctx.sendNames, si)
            hashmaps.HashMapStrIntPut(ctx.sendIndex, sname, prevIndexPlus1)
        semSendTextIndexPut(stextId, prevTextIndexPlus1)
    ctx.sendScopeStarts.len = ctx.sendScopeStarts.len - 1
    ctx.sendNames.len = sstart
    ctx.sendTextIds.len = sstart
    ctx.sendFlags.len = sstart
    ctx.sendPrevIndexPlus1.len = sstart
    ctx.sendPrevTextIndexPlus1.len = sstart
    semScopeEpochBump()
    semBorrowEpoch = semBorrowEpoch + 1
    semSendEpoch = semSendEpoch + 1
    if profOn:
        let mul: int32 = semProfSampleMul()
        let delta: int64 = cheng_monotime_ns() - startNs
        semProfScopePopNs = semProfScopePopNs + (delta * int64(mul))
        semProfScopePopCalls = semProfScopePopCalls + mul

fn defineSemNameNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32) =
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if (nameNorm ==  ""):
        return
    if (nameNorm ==  "_"):
        return
    let nameTextId: int32 = semCanonicalTextId(nameNorm, textId)
    let depth: int32 = semScopeDepth(ctx)
    let ptrKey: int64 = semStrPtrKey(nameNorm)
    if semGlobalCollectMode && depth == 0 && nameTextId > 0:
        semAddStr(ctx.names, nameNorm)
        semAddInt32(ctx.nameTextIds, nameTextId)
        semAddInt64(ctx.namePtrKeys, ptrKey)
        semAddInt32(ctx.namePrevDepthPlus1, int32(0))
        if ptrKey != 0:
            semNameDepthPtrPutCachedKey(ptrKey, 1)
        semNameDepthTextPut(nameTextId, 1)
        if textId > 0 && textId != nameTextId:
            semNameDepthTextPut(textId, 1)
        semNameDepthRecentEpoch = semScopeEpoch
        semNameDepthRecentPtrKey = ptrKey
        semNameDepthRecentTextId = nameTextId
        semNameDepthRecentDepthPlus1 = 1
        semNameDepthRecentValid = true
        semNameDepthFindRecentEpoch = semScopeEpoch
        semNameDepthFindRecentPtrKey = ptrKey
        semNameDepthFindRecentTextId = nameTextId
        semNameDepthFindRecentName = nameNorm
        semNameDepthFindRecentResult = 1
        semNameDepthFindRecentValid = true
        return
    if semGlobalCollectMode && depth == 0:
        semNameDepthPutCachedResolved(ctx, nameNorm, nameTextId, ptrKey, 1)
        return
    let prevDepthPlus1: int32 = semNameDepthGetCachedWithTextId(ctx, nameNorm, nameTextId)
    semAddStr(ctx.names, nameNorm)
    semAddInt32(ctx.nameTextIds, nameTextId)
    semAddInt64(ctx.namePtrKeys, ptrKey)
    if prevDepthPlus1 > 0:
        semAddInt32(ctx.namePrevDepthPlus1, prevDepthPlus1)
    else:
        semAddInt32(ctx.namePrevDepthPlus1, int32(0))
    semNameDepthPutCachedResolved(ctx, nameNorm, nameTextId, ptrKey, depth + 1)
    semScopeEpochBump()

fn defineSemNameNormalized(ctx: var SemCtx, nm: str) =
    defineSemNameNormalizedWithTextId(ctx, nm, 0)

fn defineSemName(ctx: var SemCtx, name: str) =
    defineSemNameNormalized(ctx, semNormalizeName(name))

fn isSemNameDefinedCore(ctx: var SemCtx, name: str): bool =
    let nameNorm: str = semNormalizeName(name)
    return isSemNameDefinedNormalizedWithClass(ctx, nameNorm, semNameClassOfNormalized(nameNorm))

fn isSemNameDefinedNormalizedWithClass(ctx: var SemCtx, nameNorm: str, classMask: int32): bool =
    if (nameNorm ==  ""):
        return true
    if semNameClassDefinesName(classMask):
        return true
    let depthPlus1: int32 = semNameDepthGetCached(ctx, nameNorm)
    if depthPlus1 > 0:
        return true
    if ctx.allowUnknown:
        return true
    return false

fn isSemNameDefinedNormalized(ctx: var SemCtx, nameNorm: str): bool =
    return isSemNameDefinedNormalizedWithClass(ctx, nameNorm, semNameClassOfNormalized(nameNorm))

fn isSemNameDefined(ctx: var SemCtx, name: str): bool =
    if ! semProfOn:
        return isSemNameDefinedCore(ctx, name)
    semProfIsDefinedCalls = semProfIsDefinedCalls + 1
    if (semProfIsDefinedCalls & 31) == 0:
        let startNs: int64 = cheng_monotime_ns()
        let ok: bool = isSemNameDefinedCore(ctx, name)
        semProfIsDefinedNs = semProfIsDefinedNs + ((cheng_monotime_ns() - startNs) * 32)
        return ok
    return isSemNameDefinedCore(ctx, name)

fn semIsRemovedCastCall(callNode: Node): bool =
    if stage1AstRefIsNil(callNode) || nodeKind(callNode) != nkCall || kidCount(callNode) == 0:
        return false
    let callee: Node = kid(callNode, 0)
    if stage1AstRefIsNil(callee) || nodeKind(callee) != nkBracketExpr || kidCount(callee) == 0:
        return false
    let base: Node = kid(callee, 0)
    if stage1AstRefIsNil(base):
        return false
    if nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol:
        let textId: int32 = semCanonicalTextId("", nodeIdentId(base))
        semEnsureCallNameTextIds()
        if textId > 0:
            return semTextEqId(textId, semCallNameIdCast)
        return semNodeNameNormalized(base) == "cast"
    if nodeKind(base) == nkDotExpr && kidCount(base) > 1:
        let member: Node = kid(base, 1)
        let textId: int32 = semCanonicalTextId("", nodeIdentId(member))
        semEnsureCallNameTextIds()
        if textId > 0:
            return semTextEqId(textId, semCallNameIdCast)
        return semNodeNameNormalized(member) == "cast"
    return false

const semImportedOwnerMarkerPrefix: str = "__cheng_import_owner__:"

fn semImportedOwnerMarkerHasPrefix(raw: str): bool =
    let rawLen: int32 = len(raw)
    let prefixLen: int32 = len(semImportedOwnerMarkerPrefix)
    if rawLen < prefixLen || prefixLen <= 0:
        return false
    for i in 0..<prefixLen:
        if raw[i] != semImportedOwnerMarkerPrefix[i]:
            return false
    return true

fn semIsImportedQualifiedIdent(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    let marker: str = nodeStrVal(n)
    if len(marker) <= 0:
        return false
    return semImportedOwnerMarkerHasPrefix(marker)

fn semIsAsciiUpperChar(ch: char): bool =
    return ch >= 'A' && ch <= 'Z'

fn semIsExportedIdentByCase(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    let textId: int32 = nodeIdentId(n)
    if textId > 0:
        let rawLen: int32 = tokenTextLen(textId)
        if rawLen <= 0:
            return false
        return semIsAsciiUpperChar(tokenTextByteAtId(textId, 0))
    let rawName: str = nodeIdent(n)
    if len(rawName) <= 0:
        return false
    return semIsAsciiUpperChar(rawName[0])

fn semImportedOwnerModulePath(n: Node): str =
    if !semIsImportedQualifiedIdent(n):
        return ""
    let marker: str = nodeStrVal(n)
    let prefixLen: int32 = len(semImportedOwnerMarkerPrefix)
    if len(marker) <= prefixLen:
        return ""
    return strings.SliceBytes(marker, prefixLen, len(marker) - prefixLen)

fn semFindChar(s: str, ch: char, start: int32): int32 =
    for i in start..<len(s):
        if s[i] == ch:
            return i
    return -1

fn semParseQuotedValue(line: str): str =
    let first: int32 = semFindChar(line, '"', 0)
    if first >= 0:
        let second: int32 = semFindChar(line, '"', first + 1)
        if second > first:
            return strings.SliceBytes(line, first + 1, second)
    return ""

fn semPackageIdFromManifest(manifestPath: str): str =
    if len(manifestPath) <= 0 || !os.fileExists(manifestPath):
        return ""
    let content: str = os.readFile(manifestPath)
    if len(content) <= 0:
        return ""
    let contentLen: int32 = len(content)
    var start: int32
    for i in 0..contentLen:
        if i == contentLen || content[i] == '\n':
            if i > start:
                let line: str = strutils.Trim(strings.SliceBytes(content, start, i))
                if strings.HasPrefix(line, "package_id"):
                    let value: str = semParseQuotedValue(line)
                    if len(value) > 0:
                        return value
            start = i + 1
    return ""

fn semPackageKeyFromPackageId(packageIdRaw: str): str =
    if len(packageIdRaw) <= 0:
        return ""
    if strings.HasPrefix(packageIdRaw, "pkg://"):
        return strings.SliceBytes(packageIdRaw, 6, len(packageIdRaw) - 6)
    return packageIdRaw

fn semSplitDir(path: str): str =
    let pathLen: int32 = len(path)
    if pathLen == 0:
        return ""
    var lastSep: int32 = -1
    for i in 0..<pathLen:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    if lastSep < 0:
        return ""
    if lastSep == 0:
        return strings.SliceBytes(path, 0, 1)
    return strings.SliceBytes(path, 0, lastSep)

fn semLogicalChengPackageKey(modulePath: str): str =
    if !strings.HasPrefix(modulePath, "cheng/"):
        return ""
    let rest: str = strings.SliceBytes(modulePath, 6, len(modulePath) - 6)
    if len(rest) <= 0:
        return "cheng"
    var slash: int32 = -1
    for i in 0..<len(rest):
        if rest[i] == '/':
            slash = i
            break
    let head: str =
        slash >= 0 ? strings.SliceBytes(rest, 0, slash) : rest
    if head == "codex":
        return "cheng/codex"
    if head == "core" ||
       head == "runtime" ||
       head == "std" ||
       head == "stage1" ||
       head == "chain" ||
       head == "tests" ||
       head == "apps" ||
       head == "libp2p" ||
       head == "mobile" ||
       head == "r2c" ||
       head == "overlay" ||
       head == "quic" ||
       head == "http3" ||
       head == "qpack" ||
       head == "oracle" ||
       head == "evomap" ||
       head == "moq" ||
       head == "fountain" ||
       head == "hysteria2" ||
       head == "diloco":
        return "cheng"
    return "cheng/" + head

fn semManifestPathForModulePath(modulePathRaw: str): str =
    if len(modulePathRaw) <= 0:
        return ""
    if strings.HasPrefix(modulePathRaw, "pkg://"):
        return ""
    if !os.fileExists(modulePathRaw) &&
       !strings.HasPrefix(modulePathRaw, "/") &&
       !strings.HasPrefix(modulePathRaw, "./") &&
       !strings.HasPrefix(modulePathRaw, "../"):
        return ""
    let normalizedPath: str = os.absolutePath(modulePathRaw)
    if len(normalizedPath) <= 0:
        return ""
    var cursor: str = normalizedPath
    if os.fileExists(normalizedPath) && strings.HasSuffix(normalizedPath, ".cheng"):
        cursor = semSplitDir(normalizedPath)
    while len(cursor) > 0:
        let manifestPath: str = os.joinPath(cursor, "cheng-package.toml")
        if os.fileExists(manifestPath):
            return manifestPath
        let parent: str = semSplitDir(cursor)
        if len(parent) <= 0 || parent == cursor:
            break
        cursor = parent
    return ""

fn semModulePackageKeyFromModulePath(modulePath: str): str =
    var normalizedPath: str = modulePath
    if strings.HasPrefix(normalizedPath, "pkg://"):
        return semPackageKeyFromPackageId(normalizedPath)
    if len(normalizedPath) <= 0:
        return ""
    let manifestPath: str = semManifestPathForModulePath(normalizedPath)
    if len(manifestPath) > 0:
        let packageId: str = semPackageIdFromManifest(manifestPath)
        let packageKey: str = semPackageKeyFromPackageId(packageId)
        if len(packageKey) > 0:
            return packageKey
    if normalizedPath == "std" ||
       strings.HasPrefix(normalizedPath, "std/") ||
       normalizedPath == "stage1" ||
       strings.HasPrefix(normalizedPath, "stage1/") ||
       normalizedPath == "core" ||
       strings.HasPrefix(normalizedPath, "core/") ||
       normalizedPath == "system" ||
       strings.HasPrefix(normalizedPath, "system/"):
        return "cheng"
    if normalizedPath == "src" ||
       strings.HasPrefix(normalizedPath, "src/") ||
       semTextContains(normalizedPath, "/src/"):
        return "cheng"
    if normalizedPath == "codex/src" ||
       strings.HasPrefix(normalizedPath, "codex/src/") ||
       semTextContains(normalizedPath, "/codex/src/"):
        return "cheng/codex"
    let chengKey: str = semLogicalChengPackageKey(normalizedPath)
    if len(chengKey) > 0:
        return chengKey
    var firstSlash: int32 = -1
    var secondSlash: int32 = -1
    for i in 0..<len(normalizedPath):
        if normalizedPath[i] != '/':
            continue
        if firstSlash < 0:
            firstSlash = i
        elif secondSlash < 0:
            secondSlash = i
            break
    if firstSlash < 0:
        if normalizedPath == "cheng":
            return "cheng"
        return normalizedPath
    let firstPart = strings.SliceBytes(normalizedPath, 0, firstSlash)
    if firstPart == "src":
        return "cheng"
    if firstPart == "cheng":
        let secondPart =
            secondSlash > firstSlash ?
                strings.SliceBytes(normalizedPath, firstSlash + 1, secondSlash) :
                strings.SliceBytes(normalizedPath, firstSlash + 1, len(normalizedPath))
        if secondPart == "codex":
            return "cheng/codex"
        return "cheng"
    if firstPart == "codex" &&
       (normalizedPath == "codex/src" || strings.HasPrefix(normalizedPath, "codex/src/")):
        return "cheng/codex"
    return firstPart

fn semTextContains(haystack: str, needle: str): bool =
    let hayLen: int32 = len(haystack)
    let needleLen: int32 = len(needle)
    if needleLen <= 0:
        return true
    if hayLen < needleLen:
        return false
    var start: int32
    while start + needleLen <= hayLen:
        var matched: bool = true
        for i in 0..<needleLen:
            if haystack[start + i] != needle[i]:
                matched = false
                break
        if matched:
            return true
        start = start + 1
    return false

fn semCurrentFilePackageKey(ctx: SemCtx): str =
    return semModulePackageKeyFromModulePath(ctx.filename)

fn semAllowPackagePrivateImport(ctx: SemCtx, n: Node): bool =
    let importedModulePath: str = semImportedOwnerModulePath(n)
    let importedPackageKey: str = semModulePackageKeyFromModulePath(importedModulePath)
    let currentPackageKey: str = semCurrentFilePackageKey(ctx)
    if len(importedPackageKey) <= 0 || len(currentPackageKey) <= 0:
        return false
    return importedPackageKey == currentPackageKey

fn semRequireIdentDefined(ctx: var SemCtx, n: Node) =
    if stage1AstRefIsNil(n):
        return
    if nodeKind(n) != nkIdent:
        if nodeKind(n) != nkSymbol:
            return
    if semIsImportedQualifiedIdent(n) &&
       !semIsExportedIdentByCase(n) &&
       !semAllowPackagePrivateImport(ctx, n):
        let nmImported: str = semIdentNameNormalized(n)
        semAddError(ctx, nodePos(n), "Imported private symbol '" + nmImported + "' is not exported; use uppercase initial")
        return
    if semIdentDefinedCached(ctx, n):
        return
    let nm: str = semIdentNameNormalized(n)
    semAddError(ctx, nodePos(n), "Undefined identifier '" + nm + "'")

fn semDefinePattern(ctx: var SemCtx, pat: Node) =
    if stage1AstRefIsNil(pat):
        return
    case nodeKind(pat)
    of nkPattern:
        if kidCount(pat) > 0:
            semDefinePattern(ctx, kid(pat, 0))
    of nkCallArg:
        if kidCount(pat) > 1:
            semDefinePattern(ctx, kid(pat, 1))
    of nkIdent, nkSymbol:
        let textId: int32 = nodeIdentId(pat)
        if textId > 0:
            if !tokenTextEqLitId(textId, "_"):
                defineSemNameNormalizedWithTextId(ctx, "", textId)
        else:
            let nm: str = semIdentNameNormalized(pat)
            if nm != "_":
                defineSemNameNormalizedWithTextId(ctx, nm, textId)
    of nkTupleLit:
        for i in 0..<kidCount(pat):
            semDefinePattern(ctx, kid(pat, i))
    of nkSeqLit, nkBracket:
        for si in 0..<kidCount(pat):
            semDefinePattern(ctx, kid(pat, si))
    of nkCall:
        for ci in 1..<kidCount(pat):
            let arg: Node = kid(pat, ci)
            if stage1AstRefNonNil(arg) && nodeKind(arg) == nkCallArg && kidCount(arg) > 1:
                semDefinePattern(ctx, kid(arg, 1))
            else:
                semDefinePattern(ctx, arg)
    of nkPar:
        if kidCount(pat) == 1:
            semDefinePattern(ctx, kid(pat, 0))
    else:
        return
fn semDefineCasePattern(ctx: var SemCtx, pat: Node) =
    if stage1AstRefIsNil(pat):
        return
    case nodeKind(pat)
    of nkPattern:
        if kidCount(pat) > 0:
            let inner: Node = kid(pat, 0)
            if stage1AstRefNonNil(inner) && (nodeKind(inner) == nkIdent || nodeKind(inner) == nkSymbol):
                let textId: int32 = nodeIdentId(inner)
                if textId > 0:
                    if !tokenTextEqLitId(textId, "_"):
                        defineSemNameNormalizedWithTextId(ctx, "", textId)
                else:
                    let nm: str = semIdentNameNormalized(inner)
                    if nm != "_":
                        defineSemNameNormalizedWithTextId(ctx, nm, textId)
            elif stage1AstRefNonNil(inner) && nodeKind(inner) == nkPar && kidCount(inner) == 1:
                semDefineCasePattern(ctx, kid(inner, 0))
    of nkPar:
        if kidCount(pat) == 1:
            semDefineCasePattern(ctx, kid(pat, 0))
    else:
        return
fn semCollectGlobals(ctx: var SemCtx, root: Node) =
    let semDbg: bool = getEnv("STAGE1_SEM_DEBUG") == "1"
    semDebugLog(semDbg, "[sem-debug] semCollectGlobals:enter")
    if stage1AstRefIsNil(root):
        return
    if nodeKind(root) != nkModule:
        if nodeKind(root) != nkStmtList:
            return
    let progressOn: bool = semProgressOn
    var stack: Node[]
    stack.buffer = nil
    stack.len = 0
    stack.cap = 16
    var visited: bool[]
    visited.buffer = nil
    visited.len = 0
    visited.cap = 0
    add(stack, root)
    let oldGlobalCollectMode: bool = semGlobalCollectMode
    semGlobalCollectMode = true
    if semDbg:
        semDebugLog(semDbg, "[sem-debug] semCollectGlobals:init_done len=" + intToStr(stack.len))
    semDebugLog(semDbg, "[sem-debug] semCollectGlobals:before_loop")
    while stack.len > 0:
        semDebugLog(semDbg, "[sem-debug] semCollectGlobals:loop_top")
        let lastIdx: int32 = stack.len - 1
        semDebugLog(semDbg, "[sem-debug] semCollectGlobals:loop_before_read")
        let cur: Node = stack[lastIdx]
        semDebugLog(semDbg, "[sem-debug] semCollectGlobals:loop_after_read")
        stack.len = int(lastIdx)
        if stage1AstRefIsNil(cur):
            continue
        if nodeKind(cur) != nkModule:
            if nodeKind(cur) != nkStmtList:
                continue
        if nodeKind(cur) == nkModule:
            if !semMarkNodeIdMarked(visited, cur):
                continue
        if progressOn:
            semProgressMaybe(nodeKind(cur), nodePos(cur), "collect-globals")
        for i in 0..<kidCount(cur):
            let n: Node = kid(cur, i)
            if stage1AstRefIsNil(n):
                continue
            if nodeKind(n) == nkStmtList || nodeKind(n) == nkModule:
                add(stack, n)
                continue
            case nodeKind(n)
            of nkFnDecl, nkMacroDecl, nkTemplateDecl, nkIteratorDecl:
                if kidCount(n) > 0:
                    let nameNode: Node = kid(n, 0)
                    let fnTextId: int32 = nodeIdentId(nameNode)
                    var fnNameNorm: str
                    if fnTextId <= 0:
                        fnNameNorm = semNodeNameNormalized(nameNode)
                    let fnHasName: bool = fnTextId > 0 || fnNameNorm != ""
                    defineSemNameNormalizedWithTextId(ctx, fnNameNorm, fnTextId)
                    if kidCount(n) > 1:
                        semFnSigAddNormalizedWithTextId(ctx, fnNameNorm, fnTextId, kid(n, 1))
                    let hasThreadBoundary: bool = semFnHasAnnotation(n, "thread_boundary")
                    if hasThreadBoundary && fnHasName:
                        semThreadBoundaryAddNormalizedWithTextId(ctx, fnNameNorm, fnTextId)
                    if fnHasName && semIsThreadBoundaryRequiredNameNormalizedWithTextId(fnNameNorm, fnTextId) && !hasThreadBoundary:
                        semAddError(ctx, nodePos(n), "thread boundary requires @thread_boundary")
                    let hasBorrows: bool = semFnHasAnnotation(n, "borrows")
                    let hasEscapes: bool = semFnHasAnnotation(n, "escapes")
                    if hasBorrows && fnHasName:
                        semBorrowAllowAddNormalizedWithTextId(ctx, fnNameNorm, fnTextId)
                    if hasEscapes && fnHasName:
                        semBorrowEscapeAddNormalizedWithTextId(ctx, fnNameNorm, fnTextId)
                    if hasBorrows && hasEscapes && fnHasName:
                        semAddError(ctx, nodePos(n), "@borrows and @escapes cannot be used together")
            of nkTypeDecl:
                if kidCount(n) > 0:
                    let typeName: Node = kid(n, 0)
                    let typeTextId: int32 = nodeIdentId(typeName)
                    var typeNameNorm: str
                    if typeTextId <= 0:
                        typeNameNorm = semNodeNameNormalized(typeName)
                    defineSemNameNormalizedWithTextId(ctx, typeNameNorm, typeTextId)
                if kidCount(n) > 1:
                    let def: Node = kid(n, 1)
                    if stage1AstRefNonNil(def):
                        if nodeKind(def) == nkEnumDecl:
                            for fi in 0..<kidCount(def):
                                let f: Node = kid(def, fi)
                                if stage1AstRefNonNil(f):
                                    if nodeKind(f) == nkEnumFieldDecl:
                                        if kidCount(f) > 0:
                                            let fieldName: Node = kid(f, 0)
                                            let fieldTextId: int32 = nodeIdentId(fieldName)
                                            var fieldNameNorm: str
                                            if fieldTextId <= 0:
                                                fieldNameNorm = semNodeNameNormalized(fieldName)
                                            defineSemNameNormalizedWithTextId(ctx, fieldNameNorm, fieldTextId)
            of nkLet, nkVar, nkConst:
                if kidCount(n) > 0:
                    semDefinePattern(ctx, kid(n, 0))
    semGlobalCollectMode = oldGlobalCollectMode
    semScopeEpochBump()
    semDebugLog(semDbg, "[sem-debug] semCollectGlobals:done")

fn semSliceRange(s: str, start: int32, stop: int32): str =
    if len(s) == 0:
        return ""
    if stop < start:
        return ""
    var a: int32 = start
    var b: int32 = stop
    let n: int32 = len(s)
    if a < 0:
        a = 0
    if b >= n:
        b = n - 1
    if b < a:
        return ""
    return __cheng_slice_string(s, a, b + 1, true)

fn semSliceFrom(s: str, start: int32): str =
    return semSliceRange(s, start, len(s) - 1)

fn semLastPathSegment(p: str): str =
    if (p ==  ""):
        return ""
    let __for_start_i = len(p) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        let c: char = p[i]
        if c == '/':
            return semSliceFrom(p, i + 1)
        if c == '\\':
            return semSliceFrom(p, i + 1)
    return p

fn semStripChengExt(name: str): str =
    let n: int32 = len(name)
    if n > 6:
        if name[n - 6] == '.':
            if name[n - 5] == 'c':
                if name[n - 4] == 'h':
                    if name[n - 3] == 'e':
                        if name[n - 2] == 'n':
                            if name[n - 1] == 'g':
                                return semSliceRange(name, 0, n - 7)
    return name

fn semImportModuleName(path: str): str =
    return semStripChengExt(semLastPathSegment(path))

fn semLastPathSegmentTextId(pathId: int32): int32 =
    if pathId <= 0:
        return 0
    let n: int32 = tokenTextLen(pathId)
    if n <= 0:
        return 0
    var start: int32
    let __for_start_i = n - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        let c: char = tokenTextByteAtId(pathId, i)
        if c == '/' || c == '\\':
            start = i + 1
            break
    let kept: int32 = n - start
    if kept <= 0:
        return 0
    return tokenInternTextRangeById(pathId, start, kept)

fn semStripChengExtTextId(nameId: int32): int32 =
    if nameId <= 0:
        return 0
    let n: int32 = tokenTextLen(nameId)
    if n > 6 &&
       tokenTextByteAtId(nameId, n - 6) == '.' &&
       tokenTextByteAtId(nameId, n - 5) == 'c' &&
       tokenTextByteAtId(nameId, n - 4) == 'h' &&
       tokenTextByteAtId(nameId, n - 3) == 'e' &&
       tokenTextByteAtId(nameId, n - 2) == 'n' &&
       tokenTextByteAtId(nameId, n - 1) == 'g':
        return tokenInternTextRangeById(nameId, 0, n - 6)
    return nameId

fn semImportModuleNameTextId(pathId: int32): int32 =
    return semStripChengExtTextId(semLastPathSegmentTextId(pathId))

fn semDefineImportedModuleName(ctx: var SemCtx, rawName: str) =
    let nm: str = semImportModuleName(rawName)
    if nm == "":
        return
    let textId: int32 = tokenInternText(nm)
    let norm: str = semNormalizedTextIdOrName(textId, nm)
    defineSemNameNormalizedWithTextId(ctx, norm, textId)

fn semDefineImportedModuleNameId(ctx: var SemCtx, rawNameId: int32) =
    let textId: int32 = semImportModuleNameTextId(rawNameId)
    if textId <= 0:
        return
    let nm: str = tokenTextById(textId)
    let norm: str = semNormalizedTextIdOrName(textId, nm)
    defineSemNameNormalizedWithTextId(ctx, norm, textId)

fn semDefineImportItem(ctx: var SemCtx, item: Node) =
    if stage1AstRefIsNil(item):
        return
    case nodeKind(item)
    of nkImportAs:
        if kidCount(item) > 1:
            let aliasNode: Node = kid(item, 1)
            let aliasTextId: int32 = nodeIdentId(aliasNode)
            var aliasNameNorm: str
            if aliasTextId <= 0:
                aliasNameNorm = semNodeNameNormalized(aliasNode)
            defineSemNameNormalizedWithTextId(ctx, aliasNameNorm, aliasTextId)
        elif kidCount(item) > 0:
            semDefineImportedModuleNameId(ctx, plainNameId(kid(item, 0)))
    of nkImportGroup:
        if kidCount(item) > 0:
            for j in 1..<kidCount(item):
                semDefineImportItem(ctx, kid(item, j))
            if kidCount(item) == 1:
                semDefineImportedModuleNameId(ctx, plainNameId(kid(item, 0)))
    of nkIdent, nkSymbol:
        semDefineImportedModuleNameId(ctx, nodeIdentId(item))
    of nkStrLit:
        semDefineImportedModuleNameId(ctx, nodeStrValId(item))
    else:
        return
fn semBindImports(ctx: var SemCtx, root: Node) =
    if stage1AstRefIsNil(root):
        return
    for i in 0..<kidCount(root):
        let n: Node = kid(root, i)
        if stage1AstRefIsNil(n):
            continue
        semProgressMaybe(nodeKind(n), nodePos(n), "bind-imports")
        if nodeKind(n) == nkImportStmt:
            ctx.allowUnknown = true
            for j in 0..<kidCount(n):
                semDefineImportItem(ctx, kid(n, j))
        elif nodeKind(n) == nkImportGroup:
            ctx.allowUnknown = true
            for j in 0..<kidCount(n):
                semDefineImportItem(ctx, kid(n, j))

fn semAnalyzeExprWithCtx(ctx: var SemCtx, expr: Node, allowEmptySeq: bool) =
    if stage1AstRefIsNil(expr):
        return
    let count: int32 = kidCount(expr)
    if crashTraceEnabled():
        crashTraceMark(strToCStringTemp("sem.expr"), int32(nodeKind(expr)), nodePosLine(expr), nodePosCol(expr), count)
    let profKindOn: bool = semProfOn && semProfExprSampleOn
    let profKind: NodeKind = nodeKind(expr)
    var profStartNs: int64
    if profKindOn:
        profStartNs = cheng_monotime_ns()
    if nodeKind(expr) == nkSeqLit && count == 0:
        if ! allowEmptySeq:
            semAddError(ctx, nodePos(expr), "Empty seq literal can only be used in assignment/return/call arguments")
        if profKindOn:
            semProfRecordExprKind(profKind, cheng_monotime_ns() - profStartNs)
        return
    case nodeKind(expr)
    of nkIdent, nkSymbol:
        semRequireIdentDefined(ctx, expr)
        if ctx.borrowActiveTotal > 0:
            semCheckBorrowOriginUse(ctx, expr)
    of nkCallArg:
        if count > 1:
            semAnalyzeExprWithCtx(ctx, kid(expr, 1), allowEmptySeq)
    of nkPar:
        if count == 1:
            semAnalyzeExprWithCtx(ctx, kid(expr, 0), allowEmptySeq)
    of nkPrefix:
        if count > 1:
            semAnalyzeExprWithCtx(ctx, kid(expr, 1), allowEmptySeq)
    of nkInfix:
        if count > 1:
            semAnalyzeExprWithCtx(ctx, kid(expr, 1), allowEmptySeq)
        if count > 2:
            semAnalyzeExprWithCtx(ctx, kid(expr, 2), allowEmptySeq)
    of nkDotExpr:
        if count > 0:
            semAnalyzeExprWithCtx(ctx, kid(expr, 0), allowEmptySeq)
    of nkBracketExpr, nkHiddenDeref, nkDerefExpr:
        if count > 0:
            semAnalyzeExprWithCtx(ctx, kid(expr, 0), allowEmptySeq)
        for j in 1..<count:
            semAnalyzeExpr(ctx, kid(expr, j))
    of nkCall:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(expr), nodePos(expr), "expr", "call")
        var callInfo: SemCallInfo
        callInfo.name = ""
        callInfo.nameTextId = 0
        callInfo.base = astInvalidNodeId()
        callInfo.flags = 0
        if profKindOn:
            let nameStartNs: int64 = cheng_monotime_ns()
            callInfo = semCallInfoNormalized(expr)
            let nameDelta: int64 = cheng_monotime_ns() - nameStartNs
            semProfCallNameNs = semProfCallNameNs + (nameDelta * int64(semProfExprSampleMul))
            semProfCallNameCalls = semProfCallNameCalls + semProfExprSampleMul
        else:
            callInfo = semCallInfoNormalized(expr)
        semEnsureCallNameTextIds()
        if semCallInfoNameMatches(callInfo, semCallNameIdCast, "cast"):
            var callee: Node = astInvalidNodeId()
            if count > 0:
                callee = kid(expr, 0)
            if stage1AstRefNonNil(callee) && nodeKind(callee) == nkBracketExpr:
                semAddError(ctx, nodePos(expr), "cast[T](x) is removed; use T(x)")
        if semCallInfoHasName(callInfo):
            if profKindOn:
                let varStartNs: int64 = cheng_monotime_ns()
                semCheckVarParamCall(ctx, expr, callInfo)
                let varDelta: int64 = cheng_monotime_ns() - varStartNs
                semProfCallVarNs = semProfCallVarNs + (varDelta * int64(semProfExprSampleMul))
                semProfCallVarCalls = semProfCallVarCalls + semProfExprSampleMul
            else:
                semCheckVarParamCall(ctx, expr, callInfo)
            if profKindOn:
                let threadStartNs: int64 = cheng_monotime_ns()
                semCheckThreadBoundaryCall(ctx, expr, callInfo)
                let threadDelta: int64 = cheng_monotime_ns() - threadStartNs
                semProfCallThreadNs = semProfCallThreadNs + (threadDelta * int64(semProfExprSampleMul))
                semProfCallThreadCalls = semProfCallThreadCalls + semProfExprSampleMul
            else:
                semCheckThreadBoundaryCall(ctx, expr, callInfo)
            if profKindOn:
                let sendStartNs: int64 = cheng_monotime_ns()
                semCheckSendCtorCall(ctx, expr, callInfo)
                let sendDelta: int64 = cheng_monotime_ns() - sendStartNs
                semProfCallSendCtorNs = semProfCallSendCtorNs + (sendDelta * int64(semProfExprSampleMul))
                semProfCallSendCtorCalls = semProfCallSendCtorCalls + semProfExprSampleMul
            else:
                semCheckSendCtorCall(ctx, expr, callInfo)
            if (callInfo.flags & semCallNameFlagShare) != 0:
                if ctx.borrowActiveTotal > 0:
                    var si: int32 = 1
                    var shareStartNs: int64
                    if profKindOn:
                        shareStartNs = cheng_monotime_ns()
                    for si in 1..<count:
                        let arg: Node = kid(expr, si)
                        let val: Node = semCallArgValue(arg)
                        semCheckBorrowEscape(ctx, val, "be shared")
                    if profKindOn:
                        let shareDelta: int64 = cheng_monotime_ns() - shareStartNs
                        semProfCallShareNs = semProfCallShareNs + (shareDelta * int64(semProfExprSampleMul))
                        semProfCallShareCalls = semProfCallShareCalls + semProfExprSampleMul
        if count > 0:
            semAnalyzeExprWithCtx(ctx, kid(expr, 0), false)
        if count > 1:
            if semProgressOn:
                semProgressMaybeDetail(nodeKind(expr), nodePos(expr), "expr", "call-args")
            var argStartNs: int64
            if profKindOn:
                argStartNs = cheng_monotime_ns()
            for i in 1..<count:
                let argNode: Node = kid(expr, i)
                let val: Node = semCallArgValue(argNode)
                if stage1AstRefNonNil(val):
                    semAnalyzeExprWithCtx(ctx, val, true)
            if profKindOn:
                let argDelta: int64 = cheng_monotime_ns() - argStartNs
                semProfCallArgsNs = semProfCallArgsNs + (argDelta * int64(semProfExprSampleMul))
                semProfCallArgsCalls = semProfCallArgsCalls + semProfExprSampleMul
    of nkComprehension:
        var pat: Node = astInvalidNodeId()
        var iterExpr: Node = astInvalidNodeId()
        var cond: Node = astInvalidNodeId()
        var body: Node = astInvalidNodeId()
        if count > 0:
            pat = kid(expr, 0)
        if count > 1:
            iterExpr = kid(expr, 1)
        if count == 3:
            body = kid(expr, 2)
        elif count > 3:
            cond = kid(expr, 2)
            body = kid(expr, 3)
        if stage1AstRefNonNil(iterExpr):
            semAnalyzeExpr(ctx, iterExpr)
        pushSemScope(ctx)
        if stage1AstRefNonNil(pat):
            semDefinePattern(ctx, pat)
        if stage1AstRefNonNil(cond) && nodeKind(cond) != nkEmpty:
            semAnalyzeExpr(ctx, cond)
        if stage1AstRefNonNil(body):
            semAnalyzeExpr(ctx, body)
        popSemScope(ctx)
    else:
        for i in 0..<count:
            semAnalyzeExprWithCtx(ctx, kid(expr, i), false)
    if profKindOn:
        semProfRecordExprKind(profKind, cheng_monotime_ns() - profStartNs)

fn semAnalyzeExprCore(ctx: var SemCtx, expr: Node) =
    semAnalyzeExprWithCtx(ctx, expr, false)

fn semAnalyzeExpr(ctx: var SemCtx, expr: Node) =
    if stage1AstRefNonNil(expr) && semProgressOn:
        semProgressMaybe(nodeKind(expr), nodePos(expr), "analyze-expr")
    if ! semProfOn:
        semAnalyzeExprCore(ctx, expr)
        return
    semProfAnalyzeExprCalls = semProfAnalyzeExprCalls + 1
    if (semProfAnalyzeExprCalls & semSampleMask) == 0:
        let startNs: int64 = cheng_monotime_ns()
        semProfExprSampleOn = true
        semProfExprSampleMul = semSampleRate
        semAnalyzeExprCore(ctx, expr)
        semProfExprSampleOn = false
        semProfExprSampleMul = 1
        semProfAnalyzeExprNs = semProfAnalyzeExprNs + ((cheng_monotime_ns() - startNs) * int64(semSampleRate))
        return
    semAnalyzeExprCore(ctx, expr)

fn semAnalyzeExprWrite(ctx: var SemCtx, expr: Node) =
    if stage1AstRefIsNil(expr):
        return
    let count: int32 = kidCount(expr)
    if nodeKind(expr) == nkIdent || nodeKind(expr) == nkSymbol:
        semRequireIdentDefined(ctx, expr)
        if ctx.borrowActiveTotal > 0:
            semCheckBorrowOriginWrite(ctx, expr)
        return
    if nodeKind(expr) == nkPar && count == 1:
        semAnalyzeExprWrite(ctx, kid(expr, 0))
        return
    if nodeKind(expr) == nkCallArg && kidCount(expr) > 1:
        semAnalyzeExprWrite(ctx, kid(expr, 1))
        return
    if nodeKind(expr) == nkDotExpr:
        if kidCount(expr) > 0:
            semAnalyzeExprWrite(ctx, kid(expr, 0))
        # Do not analyze field name as identifier.
        return
    if nodeKind(expr) == nkBracketExpr || nodeKind(expr) == nkHiddenDeref || nodeKind(expr) == nkDerefExpr:
        if kidCount(expr) > 0:
            semAnalyzeExprWrite(ctx, kid(expr, 0))
        for j in 1..<count:
            semAnalyzeExpr(ctx, kid(expr, j))
        return
    for i in 0..<count:
        semAnalyzeExpr(ctx, kid(expr, i))

fn semMarkVarParamBorrow(ctx: var SemCtx, fp: Node) =
    if stage1AstRefIsNil(fp):
        return
    if nodeKind(fp) != nkFormalParams:
        return
    for i in 0..<kidCount(fp):
        let defs: Node = kid(fp, i)
        if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount(defs) >= 2:
            let typeNode: Node = identDefsType(defs)
            if semIsVarTypeNode(typeNode):
                let namesN: int32 = identDefsNameCount(defs)
                for j in 0..<namesN:
                    semBorrowMarkNode(ctx, kid(defs, j), true)

fn semAnalyzeRoutine(ctx: var SemCtx, n: Node) =
    if stage1AstRefIsNil(n):
        return
    if semProgressOn:
        semProgressMaybeDetail(nodeKind(n), nodePos(n), "routine", "enter")
    pushSemScope(ctx)
    semGenericScopePush(ctx)
    if kidCount(n) > 4:
        let gp: Node = kid(n, 4)
        if stage1AstRefNonNil(gp) && nodeKind(gp) == nkGenericParams:
            for gi in 0..<kidCount(gp):
                let gdef: Node = kid(gp, gi)
                if stage1AstRefNonNil(gdef) && nodeKind(gdef) == nkIdentDefs && kidCount(gdef) > 0:
                    let gnameNode: Node = kid(gdef, 0)
                    let gtextId: int32 = nodeIdentId(gnameNode)
                    var gnameHint: str
                    if gtextId <= 0:
                        gnameHint = plainName(gnameNode)
                    let gname: str = semNormalizedTextIdOrName(gtextId, gnameHint)
                    semGenericParamAddWithTextId(ctx, gname, gtextId)
    if kidCount(n) > 1:
        let fp: Node = kid(n, 1)
        if stage1AstRefNonNil(fp):
            if nodeKind(fp) == nkFormalParams:
                for i in 0..<kidCount(fp):
                    let d: Node = kid(fp, i)
                    if stage1AstRefNonNil(d):
                        if nodeKind(d) == nkIdentDefs:
                            let namesN: int32 = identDefsNameCount(d)
                            if namesN > 0:
                                for j in 0..<namesN:
                                    semDefinePattern(ctx, kid(d, j))
                            let typeNode: Node = identDefsType(d)
                            if semIsGenericParamType(ctx, typeNode):
                                for j in 0..<namesN:
                                    let pnameNode: Node = kid(d, j)
                                    let ptextId: int32 = nodeIdentId(pnameNode)
                                    var pnameHint: str
                                    if ptextId <= 0:
                                        pnameHint = plainName(pnameNode)
                                    let pname: str = semNormalizedTextIdOrName(ptextId, pnameHint)
                                    semGenericValueParamAddWithTextId(ctx, pname, ptextId)
            semMarkVarParamBorrow(ctx, fp)
            semMarkParamSend(ctx, fp)
    if kidCount(n) > 3:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(n), nodePos(n), "routine", "body")
        semAnalyzeStmt(ctx, kid(n, 3))
    semGenericScopePop(ctx)
    popSemScope(ctx)

fn semAnalyzeStmtCore(ctx: var SemCtx, stmt: Node) =
    if stage1AstRefIsNil(stmt):
        return
    let count: int32 = kidCount(stmt)
    if crashTraceEnabled():
        crashTraceMark(strToCStringTemp("sem.stmt"), int32(nodeKind(stmt)), nodePosLine(stmt), nodePosCol(stmt), count)
    let profKindOn: bool = semProfOn && semProfStmtSampleOn
    let profKind: NodeKind = nodeKind(stmt)
    var profStartNs: int64
    if profKindOn:
        profStartNs = cheng_monotime_ns()
    case nodeKind(stmt)
    of nkStmtList, nkModule:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "list")
        for i in 0..<count:
            semAnalyzeStmt(ctx, kid(stmt, i))
    of nkBlock:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "block")
        pushSemScope(ctx)
        if count > 1:
            let body: Node = kid(stmt, 1)
            if stage1AstRefNonNil(body):
                semAnalyzeStmt(ctx, body)
        popSemScope(ctx)
    of nkFnDecl, nkMacroDecl, nkTemplateDecl, nkIteratorDecl:
        if !semMarkNodeIdMarked(semStmtVisitedDecls, stmt):
            if profKindOn:
                semProfRecordStmtKind(profKind, cheng_monotime_ns() - profStartNs)
            return
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "routine-decl")
        semAnalyzeRoutine(ctx, stmt)
    of nkLet, nkVar, nkConst:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "binding")
        var pat: Node = astInvalidNodeId()
        if count > 0:
            pat = kid(stmt, 0)
        var typeNode: Node = astInvalidNodeId()
        if count > 1:
            typeNode = kid(stmt, 1)
        var init: Node = astInvalidNodeId()
        if count > 2:
            init = kid(stmt, 2)
        let hasInit: bool = stage1AstRefNonNil(init) && nodeKind(init) != nkEmpty
        let bindingType: Node = semBindingTypeNode(pat, typeNode)
        if ! hasInit &&(stage1AstRefIsNil(bindingType) || nodeKind(bindingType) == nkEmpty):
            semAddError(ctx, nodePos(stmt), "Binding requires a type annotation or initializer")
        let initExpr: Node = semStripParExpr(init)
        if hasInit && stage1AstRefNonNil(initExpr) && nodeKind(initExpr) == nkSeqLit && kidCount(initExpr) == 0:
            if stage1AstRefIsNil(bindingType) || nodeKind(bindingType) == nkEmpty:
                semAddError(ctx, nodePos(initExpr), "Empty list literal requires a type annotation; e.g. let xs: T[] = []")
        if stage1AstRefNonNil(pat):
            semDefinePattern(ctx, pat)
        var sendable: bool
        if stage1AstRefNonNil(bindingType) && nodeKind(bindingType) != nkEmpty:
            sendable = semTypeIsSend(bindingType)
        elif hasInit:
            sendable = semExprIsSend(ctx, init)
        if stage1AstRefNonNil(pat):
            semSendMarkPattern(ctx, pat, sendable)
        if hasInit:
            var initBorrowed: bool = semExprIsBorrowed(ctx, init)
            if ! initBorrowed:
                if stage1AstRefNonNil(initExpr) && (nodeKind(initExpr) == nkIdent || nodeKind(initExpr) == nkSymbol):
                    if semBorrowIsActiveIdentCached(ctx, initExpr):
                        initBorrowed = true
            let origin: str = semBorrowOriginNameIfBorrowed(ctx, init, initBorrowed)
            var originTextId: int32
            if initBorrowed:
                originTextId = semBorrowOriginTextId(ctx, init)
            semAnalyzeExprWithCtx(ctx, init, true)
            let patIdent: Node = semPatternIdent(pat)
            if initBorrowed:
                if stage1AstRefNonNil(patIdent):
                    semBorrowMarkNodeWithOriginAndTextId(ctx, patIdent, true, origin, originTextId)
                else:
                    semBorrowMarkPatternWithOriginAndTextId(ctx, pat, origin, originTextId)
            else:
                if stage1AstRefNonNil(patIdent):
                    semBorrowMarkNodeWithOrigin(ctx, patIdent, false, "")
                else:
                    semBorrowMarkPattern(ctx, pat, false)
        elif stage1AstRefNonNil(bindingType) && nodeKind(bindingType) != nkEmpty:
            semBorrowMarkPattern(ctx, pat, false)
    of nkIf, nkWhen:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "if-when")
        var i: int32
        while i + 1 < count:
            let cond: Node = kid(stmt, i)
            let body: Node = kid(stmt, i + 1)
            if semProfOn && semProfStmtSampleOn:
                let startNs: int64 = cheng_monotime_ns()
                semAnalyzeExpr(ctx, cond)
                let delta: int64 = cheng_monotime_ns() - startNs
                semProfIfCondNs = semProfIfCondNs + (delta * int64(semProfStmtSampleMul))
                semProfIfCondCalls = semProfIfCondCalls + semProfStmtSampleMul
            else:
                semAnalyzeExpr(ctx, cond)
            if stage1AstRefNonNil(body):
                pushSemScope(ctx)
                if semProfOn && semProfStmtSampleOn:
                    let startNs2: int64 = cheng_monotime_ns()
                    semAnalyzeStmt(ctx, body)
                    let delta2: int64 = cheng_monotime_ns() - startNs2
                    semProfIfBodyNs = semProfIfBodyNs + (delta2 * int64(semProfStmtSampleMul))
                    semProfIfBodyCalls = semProfIfBodyCalls + semProfStmtSampleMul
                else:
                    semAnalyzeStmt(ctx, body)
                popSemScope(ctx)
            i = i + 2
    of nkWhile:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "while")
        if count > 0:
            let cond: Node = kid(stmt, 0)
            if semProfOn && semProfStmtSampleOn:
                let startNs: int64 = cheng_monotime_ns()
                semAnalyzeExpr(ctx, cond)
                let delta: int64 = cheng_monotime_ns() - startNs
                semProfWhileCondNs = semProfWhileCondNs + (delta * int64(semProfStmtSampleMul))
                semProfWhileCondCalls = semProfWhileCondCalls + semProfStmtSampleMul
            else:
                semAnalyzeExpr(ctx, cond)
        if count > 1:
            let body: Node = kid(stmt, 1)
            if stage1AstRefNonNil(body):
                pushSemScope(ctx)
                if semProfOn && semProfStmtSampleOn:
                    let startNs2: int64 = cheng_monotime_ns()
                    semAnalyzeStmt(ctx, body)
                    let delta2: int64 = cheng_monotime_ns() - startNs2
                    semProfWhileBodyNs = semProfWhileBodyNs + (delta2 * int64(semProfStmtSampleMul))
                    semProfWhileBodyCalls = semProfWhileBodyCalls + semProfStmtSampleMul
                else:
                    semAnalyzeStmt(ctx, body)
                popSemScope(ctx)
    of nkFor:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "for")
        if count > 1:
            if semProfOn && semProfStmtSampleOn:
                let startNs: int64 = cheng_monotime_ns()
                semAnalyzeExpr(ctx, kid(stmt, 1))
                let delta: int64 = cheng_monotime_ns() - startNs
                semProfForIterNs = semProfForIterNs + (delta * int64(semProfStmtSampleMul))
                semProfForIterCalls = semProfForIterCalls + semProfStmtSampleMul
            else:
                semAnalyzeExpr(ctx, kid(stmt, 1))
        pushSemScope(ctx)
        if count > 0:
            semDefinePattern(ctx, kid(stmt, 0))
        if count > 2:
            let body: Node = kid(stmt, 2)
            if stage1AstRefNonNil(body):
                if semProfOn && semProfStmtSampleOn:
                    let startNs2: int64 = cheng_monotime_ns()
                    semAnalyzeStmt(ctx, body)
                    let delta2: int64 = cheng_monotime_ns() - startNs2
                    semProfForBodyNs = semProfForBodyNs + (delta2 * int64(semProfStmtSampleMul))
                    semProfForBodyCalls = semProfForBodyCalls + semProfStmtSampleMul
                else:
                    semAnalyzeStmt(ctx, body)
        popSemScope(ctx)
    of nkCase:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "case")
        if count > 0:
            if semProfOn && semProfStmtSampleOn:
                let startNs: int64 = cheng_monotime_ns()
                semAnalyzeExpr(ctx, kid(stmt, 0))
                let delta: int64 = cheng_monotime_ns() - startNs
                semProfCaseExprNs = semProfCaseExprNs + (delta * int64(semProfStmtSampleMul))
                semProfCaseExprCalls = semProfCaseExprCalls + semProfStmtSampleMul
            else:
                semAnalyzeExpr(ctx, kid(stmt, 0))
        for i in 1..<count:
            let br: Node = kid(stmt, i)
            if stage1AstRefIsNil(br):
                continue
            if nodeKind(br) == nkOfBranch:
                pushSemScope(ctx)
                var bi: int32
                let brCount: int32 = kidCount(br)
                while bi + 1 < brCount:
                    let ent: Node = kid(br, bi)
                    if stage1AstRefNonNil(ent):
                        if nodeKind(ent) == nkGuard:
                            if kidCount(ent) > 0:
                                semAnalyzeExpr(ctx, kid(ent, 0))
                        else:
                            semDefineCasePattern(ctx, ent)
                    bi = bi + 1
                if brCount > 0:
                    if semProfOn && semProfStmtSampleOn:
                        let startNs2: int64 = cheng_monotime_ns()
                        semAnalyzeStmt(ctx, kid(br, brCount - 1))
                        let delta2: int64 = cheng_monotime_ns() - startNs2
                        semProfCaseBodyNs = semProfCaseBodyNs + (delta2 * int64(semProfStmtSampleMul))
                        semProfCaseBodyCalls = semProfCaseBodyCalls + semProfStmtSampleMul
                    else:
                        semAnalyzeStmt(ctx, kid(br, brCount - 1))
                popSemScope(ctx)
            elif nodeKind(br) == nkElse:
                if kidCount(br) > 0:
                    let body: Node = kid(br, 0)
                    if stage1AstRefNonNil(body):
                        pushSemScope(ctx)
                        if semProfOn && semProfStmtSampleOn:
                            let startNs3: int64 = cheng_monotime_ns()
                            semAnalyzeStmt(ctx, body)
                            let delta3: int64 = cheng_monotime_ns() - startNs3
                            semProfCaseBodyNs = semProfCaseBodyNs + (delta3 * int64(semProfStmtSampleMul))
                            semProfCaseBodyCalls = semProfCaseBodyCalls + semProfStmtSampleMul
                        else:
                            semAnalyzeStmt(ctx, body)
                        popSemScope(ctx)
    of nkReturn, nkYield:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "return-yield")
        for i in 0..<count:
            let expr: Node = kid(stmt, i)
            if nodeKind(stmt) == nkReturn:
                semAnalyzeExprWithCtx(ctx, expr, true)
            else:
                semAnalyzeExpr(ctx, expr)
            semCheckBorrowEscape(ctx, expr, semYieldEscapeWhat(nodeKind(stmt)))
    of nkBreak, nkContinue, nkDefer:
        for i in 0..<count:
            semAnalyzeExpr(ctx, kid(stmt, i))
    of nkAsgn, nkFastAsgn:
        if semProgressOn:
            semProgressMaybeDetail(nodeKind(stmt), nodePos(stmt), "stmt", "assign")
        var lhs: Node = astInvalidNodeId()
        if count > 0:
            lhs = kid(stmt, 0)
        var rhs: Node = astInvalidNodeId()
        if count > 1:
            rhs = kid(stmt, 1)
        if stage1AstRefNonNil(lhs):
            if semProfOn && semProfStmtSampleOn:
                let startNs: int64 = cheng_monotime_ns()
                semAnalyzeExprWrite(ctx, lhs)
                let delta: int64 = cheng_monotime_ns() - startNs
                semProfAsgnLhsNs = semProfAsgnLhsNs + (delta * int64(semProfStmtSampleMul))
                semProfAsgnLhsCalls = semProfAsgnLhsCalls + semProfStmtSampleMul
            else:
                semAnalyzeExprWrite(ctx, lhs)
        if stage1AstRefNonNil(rhs):
            if semProfOn && semProfStmtSampleOn:
                let startNs2: int64 = cheng_monotime_ns()
                semAnalyzeExprWithCtx(ctx, rhs, true)
                let delta2: int64 = cheng_monotime_ns() - startNs2
                semProfAsgnRhsNs = semProfAsgnRhsNs + (delta2 * int64(semProfStmtSampleMul))
                semProfAsgnRhsCalls = semProfAsgnRhsCalls + semProfStmtSampleMul
            else:
                semAnalyzeExprWithCtx(ctx, rhs, true)
            if stage1AstRefNonNil(lhs) && (nodeKind(lhs) == nkIdent || nodeKind(lhs) == nkSymbol):
                var rhsBorrowed: bool
                if semProfOn && semProfStmtSampleOn:
                    let startNsB: int64 = cheng_monotime_ns()
                    rhsBorrowed = semExprIsBorrowed(ctx, rhs)
                    let deltaB: int64 = cheng_monotime_ns() - startNsB
                    semProfAsgnBorrowCheckNs = semProfAsgnBorrowCheckNs + (deltaB * int64(semProfStmtSampleMul))
                    semProfAsgnBorrowCheckCalls = semProfAsgnBorrowCheckCalls + semProfStmtSampleMul
                else:
                    rhsBorrowed = semExprIsBorrowed(ctx, rhs)
                if ! rhsBorrowed:
                    let rhsExpr: Node = semStripParExpr(rhs)
                    if stage1AstRefNonNil(rhsExpr) && (nodeKind(rhsExpr) == nkIdent || nodeKind(rhsExpr) == nkSymbol):
                        if semBorrowIsActiveIdentCached(ctx, rhsExpr):
                            rhsBorrowed = true
                var rhsSendable: bool
                if semProfOn && semProfStmtSampleOn:
                    let startNsS: int64 = cheng_monotime_ns()
                    rhsSendable = semExprIsSend(ctx, rhs)
                    let deltaS: int64 = cheng_monotime_ns() - startNsS
                    semProfAsgnSendCheckNs = semProfAsgnSendCheckNs + (deltaS * int64(semProfStmtSampleMul))
                    semProfAsgnSendCheckCalls = semProfAsgnSendCheckCalls + semProfStmtSampleMul
                else:
                    rhsSendable = semExprIsSend(ctx, rhs)
                let lname: str = plainName(lhs)
                let ltextId: int32 = (nodeKind(lhs) == nkIdent || nodeKind(lhs) == nkSymbol) ? nodeIdentId(lhs) : 0
                if rhsBorrowed && semFindDefDepth(ctx, lname) == 0:
                    semAddError(ctx, nodePos(rhs), semBorrowEscapeMessage("be written to global", semBorrowRootName(ctx, rhs)))
                if rhsBorrowed:
                    let origin: str = semBorrowOriginName(ctx, rhs)
                    let originTextId: int32 = semBorrowOriginTextId(ctx, rhs)
                    semBorrowMarkNodeWithOriginAndTextId(ctx, lhs, true, origin, originTextId)
                else:
                    semBorrowMarkNodeWithOrigin(ctx, lhs, false, "")
                let lnameNorm: str = semNormalizedTextIdOrName(ltextId, lname)
                semSendSetNormalizedWithTextId(ctx, lnameNorm, ltextId, rhsSendable)
    of nkImportStmt, nkImportGroup:
        if profKindOn:
            semProfRecordStmtKind(profKind, cheng_monotime_ns() - profStartNs)
        return
    else:
        semAnalyzeExpr(ctx, stmt)
    if profKindOn:
        semProfRecordStmtKind(profKind, cheng_monotime_ns() - profStartNs)

fn semAnalyzeStmt(ctx: var SemCtx, stmt: Node) =
    if stage1AstRefIsNil(stmt):
        return
    if nodeKind(stmt) == nkModule || nodeKind(stmt) == nkStmtList:
        if !semMarkNodeIdMarked(semStmtVisitedModules, stmt):
            return
    if stage1AstRefNonNil(stmt) && semProgressOn:
        semProgressMaybe(nodeKind(stmt), nodePos(stmt), "analyze-stmt")
    if ! semProfOn:
        semAnalyzeStmtCore(ctx, stmt)
        return
    semProfAnalyzeStmtCalls = semProfAnalyzeStmtCalls + 1
    if (semProfAnalyzeStmtCalls & semSampleMask) == 0:
        let startNs: int64 = cheng_monotime_ns()
        semProfStmtSampleOn = true
        semProfStmtSampleMul = semSampleRate
        semAnalyzeStmtCore(ctx, stmt)
        semProfStmtSampleOn = false
        semProfStmtSampleMul = 1
        semProfAnalyzeStmtNs = semProfAnalyzeStmtNs + ((cheng_monotime_ns() - startNs) * int64(semSampleRate))
        return
    semAnalyzeStmtCore(ctx, stmt)

fn checkSemanticsId(rootId: AstNodeId, diags: var Diagnostic[], ownershipEnabled: bool, orcStrictWarn: bool) =
    let root: Node = rootId
    if stage1AstRefIsNil(root):
        return
    crashTraceSetPhase(strToCStringTemp("sem.reset"))
    if crashTraceEnabled():
        crashTraceMark(strToCStringTemp("sem.root"), astNodeIndex(rootId), nodePosLine(root), nodePosCol(root), kidCount(root))
    let semDbg: bool = getEnv("STAGE1_SEM_DEBUG") == "1"
    semDebugLog(semDbg, "[sem-debug] checkSemantics:enter")
    semProfOn = getEnv("STAGE1_PROFILE") == "1"
    let semTraceOn: bool = getEnv("STAGE1_TRACE") == "1"
    let semProgressRaw: str = getEnv("STAGE1_SEM_PROGRESS")
    if semProgressRaw == "1":
        semProgressOn = true
    elif semProgressRaw == "0":
        semProgressOn = false
    else:
        semProgressOn = semProfOn || semTraceOn
    let semProgressMsRaw: str = getEnv("STAGE1_SEM_PROGRESS_MS")
    var semProgressMs: int64 = 10000
    if len(semProgressMsRaw) > 0:
        semProgressMs = semParseInt64(semProgressMsRaw, 10000)
        if semProgressMs <= 0:
            semProgressMs = 10000
    semProgressIntervalNs = semProgressMs * 1000000
    semProgressNextNs = 0
    semProgressTick = 0
    if semProfOn:
        semProfNormalizeNs = 0
        semProfNormalizeCalls = 0
        semProfIsDefinedNs = 0
        semProfIsDefinedCalls = 0
        semProfFindDefNs = 0
        semProfFindDefCalls = 0
        semProfCollectGlobalsNs = 0
        semProfBindImportsNs = 0
        semProfAnalyzeNs = 0
        semProfAnalyzeStmtNs = 0
        semProfAnalyzeStmtCalls = 0
        semProfAnalyzeExprNs = 0
        semProfAnalyzeExprCalls = 0
        semProfIfCondNs = 0
        semProfIfCondCalls = 0
        semProfIfBodyNs = 0
        semProfIfBodyCalls = 0
        semProfWhileCondNs = 0
        semProfWhileCondCalls = 0
        semProfWhileBodyNs = 0
        semProfWhileBodyCalls = 0
        semProfAsgnLhsNs = 0
        semProfAsgnLhsCalls = 0
        semProfAsgnRhsNs = 0
        semProfAsgnRhsCalls = 0
        semProfAsgnBorrowCheckNs = 0
        semProfAsgnBorrowCheckCalls = 0
        semProfAsgnSendCheckNs = 0
        semProfAsgnSendCheckCalls = 0
        semProfScopePushNs = 0
        semProfScopePushCalls = 0
        semProfScopePopNs = 0
        semProfScopePopCalls = 0
        semProfStmtSampleOn = false
        semProfStmtSampleMul = 1
        semProfExprSampleOn = false
        semProfExprSampleMul = 1
        semProfResetKinds()
        semProfCallNameNs = 0
        semProfCallNameCalls = 0
        semProfCallVarNs = 0
        semProfCallVarCalls = 0
        semProfCallThreadNs = 0
        semProfCallThreadCalls = 0
        semProfCallSendCtorNs = 0
        semProfCallSendCtorCalls = 0
        semProfCallShareNs = 0
        semProfCallShareCalls = 0
        semProfCallArgsNs = 0
        semProfCallArgsCalls = 0
        semProfForIterNs = 0
        semProfForIterCalls = 0
        semProfForBodyNs = 0
        semProfForBodyCalls = 0
        semProfCaseExprNs = 0
        semProfCaseExprCalls = 0
        semProfCaseBodyNs = 0
        semProfCaseBodyCalls = 0
    hashmaps.HashMapStrIntClear(semNormalizeIndexStr)
    hashmaps.HashMapPtrIntClear(semNormalizeIndexPtr)
    freeSeq[str](semNormalizeValues)
    semNormalizeValues.cap = 256
    hashmaps.HashMapStrIntClear(semNameClassIndex)
    hashmaps.HashMapPtrIntClear(semNameClassPtrIndex)
    freeSeq[int32](semNameClassValues)
    semNameClassValues.cap = 64
    freeSeq[bool](semNameClassTextReady)
    semNameClassTextReady.cap = 512
    freeSeq[int32](semNameClassTextValue)
    semNameClassTextValue.cap = 512
    hashmaps.HashMapStrIntClear(semCallNameFlagIndex)
    hashmaps.HashMapPtrIntClear(semCallNameFlagPtrIndex)
    freeSeq[int32](semCallNameFlagValues)
    semCallNameFlagValues.cap = 128
    freeSeq[bool](semCallNameFlagTextReady)
    semCallNameFlagTextReady.cap = 512
    freeSeq[int32](semCallNameFlagTextValue)
    semCallNameFlagTextValue.cap = 512
    freeSeq[bool](semIdentNormReady)
    semIdentNormReady.cap = 512
    freeSeq[str](semIdentNormValues)
    semIdentNormValues.cap = 512
    freeSeq[bool](semIdentNameClassReady)
    semIdentNameClassReady.cap = 512
    freeSeq[int32](semIdentNameClassValues)
    semIdentNameClassValues.cap = 512
    freeSeq[int32](semIdentDefinedEpoch)
    semIdentDefinedEpoch.cap = 512
    freeSeq[bool](semIdentDefinedValue)
    semIdentDefinedValue.cap = 512
    freeSeq[int32](semIdentDepthEpoch)
    semIdentDepthEpoch.cap = 512
    freeSeq[int32](semIdentDepthValue)
    semIdentDepthValue.cap = 512
    freeSeq[int32](semIdentFnSigEpoch)
    semIdentFnSigEpoch.cap = 512
    freeSeq[int32](semIdentFnSigValue)
    semIdentFnSigValue.cap = 512
    freeSeq[bool](semNormalizeTextReady)
    semNormalizeTextReady.cap = 512
    freeSeq[str](semNormalizeTextValue)
    semNormalizeTextValue.cap = 512
    freeSeq[bool](semCanonicalTextReady)
    semCanonicalTextReady.cap = 512
    freeSeq[int32](semCanonicalTextValue)
    semCanonicalTextValue.cap = 512
    freeSeq[bool](semNameDepthTextReady)
    semNameDepthTextReady.cap = 512
    freeSeq[int32](semNameDepthTextValue)
    semNameDepthTextValue.cap = 512
    freeSeq[bool](semBorrowAllowTextReady)
    semBorrowAllowTextReady.cap = 512
    freeSeq[bool](semBorrowAllowTextValue)
    semBorrowAllowTextValue.cap = 512
    freeSeq[bool](semBorrowEscapeTextReady)
    semBorrowEscapeTextReady.cap = 512
    freeSeq[bool](semBorrowEscapeTextValue)
    semBorrowEscapeTextValue.cap = 512
    freeSeq[bool](semThreadBoundaryTextReady)
    semThreadBoundaryTextReady.cap = 512
    freeSeq[bool](semThreadBoundaryTextValue)
    semThreadBoundaryTextValue.cap = 512
    freeSeq[bool](semFnSigTextReady)
    semFnSigTextReady.cap = 512
    freeSeq[int32](semFnSigTextValue)
    semFnSigTextValue.cap = 512
    freeSeq[int32](semGenericValueParamTextEpoch)
    semGenericValueParamTextEpoch.cap = 256
    freeSeq[bool](semGenericValueParamTextValue)
    semGenericValueParamTextValue.cap = 256
    hashmaps.HashMapPtrIntClear(semNameDepthPtrIndex)
    freeSeq[int32](semNameDepthPtrValue)
    semNameDepthPtrValue.cap = 512
    hashmaps.HashMapPtrIntClear(semDefDepthPtrIndex)
    freeSeq[int32](semDefDepthPtrEpoch)
    semDefDepthPtrEpoch.cap = 512
    freeSeq[int32](semDefDepthPtrValue)
    semDefDepthPtrValue.cap = 512
    freeSeq[int32](semDefDepthTextEpoch)
    semDefDepthTextEpoch.cap = 512
    freeSeq[int32](semDefDepthTextValue)
    semDefDepthTextValue.cap = 512
    freeSeq[int32](semGenericParamTypeEpoch)
    semGenericParamTypeEpoch.cap = 512
    freeSeq[bool](semGenericParamTypeValue)
    semGenericParamTypeValue.cap = 512
    freeSeq[int32](semCallInfoEpoch)
    semCallInfoEpoch.cap = 512
    freeSeq[str](semCallInfoNameValues)
    semCallInfoNameValues.cap = 512
    freeSeq[int32](semCallInfoNameTextValues)
    semCallInfoNameTextValues.cap = 512
    freeSeq[AstNodeId](semCallInfoBaseValues)
    semCallInfoBaseValues.cap = 512
    freeSeq[int32](semCallInfoFlagValues)
    semCallInfoFlagValues.cap = 512
    freeSeq[int32](semCallInfoDefDepthEpoch)
    semCallInfoDefDepthEpoch.cap = 512
    freeSeq[int32](semCallInfoDefDepthValues)
    semCallInfoDefDepthValues.cap = 512
    freeSeq[int32](semCallInfoSigEpoch)
    semCallInfoSigEpoch.cap = 512
    freeSeq[int32](semCallInfoSigValues)
    semCallInfoSigValues.cap = 512
    freeSeq[int32](semCallInfoBorrowEpoch)
    semCallInfoBorrowEpoch.cap = 512
    freeSeq[int32](semCallInfoBorrowValues)
    semCallInfoBorrowValues.cap = 512
    freeSeq[int32](semExprSendEpoch)
    semExprSendEpoch.cap = 512
    freeSeq[int32](semExprFnSigEpoch)
    semExprFnSigEpoch.cap = 512
    freeSeq[bool](semExprSendValue)
    semExprSendValue.cap = 512
    freeSeq[int32](semBorrowActiveScopeEpoch)
    semBorrowActiveScopeEpoch.cap = 512
    freeSeq[int32](semBorrowActiveBorrowEpoch)
    semBorrowActiveBorrowEpoch.cap = 512
    freeSeq[bool](semBorrowActiveValue)
    semBorrowActiveValue.cap = 512
    freeSeq[int32](semBorrowActiveTextScopeEpoch)
    semBorrowActiveTextScopeEpoch.cap = 512
    freeSeq[int32](semBorrowActiveTextBorrowEpoch)
    semBorrowActiveTextBorrowEpoch.cap = 512
    freeSeq[bool](semBorrowActiveTextValue)
    semBorrowActiveTextValue.cap = 512
    freeSeq[bool](semBorrowTextIndexReady)
    semBorrowTextIndexReady.cap = 512
    freeSeq[int32](semBorrowTextIndexValue)
    semBorrowTextIndexValue.cap = 512
    freeSeq[bool](semSendTextIndexReady)
    semSendTextIndexReady.cap = 512
    freeSeq[int32](semSendTextIndexValue)
    semSendTextIndexValue.cap = 512
    freeSeq[int32](semSendActiveTextEpoch)
    semSendActiveTextEpoch.cap = 512
    freeSeq[bool](semSendActiveTextValue)
    semSendActiveTextValue.cap = 512
    freeSeq[int32](semBorrowOriginScopeEpoch)
    semBorrowOriginScopeEpoch.cap = 512
    freeSeq[int32](semBorrowOriginBorrowEpoch)
    semBorrowOriginBorrowEpoch.cap = 512
    freeSeq[bool](semBorrowOriginValue)
    semBorrowOriginValue.cap = 512
    freeSeq[int32](semBorrowOriginTextScopeEpoch)
    semBorrowOriginTextScopeEpoch.cap = 512
    freeSeq[int32](semBorrowOriginTextBorrowEpoch)
    semBorrowOriginTextBorrowEpoch.cap = 512
    freeSeq[bool](semBorrowOriginTextValue)
    semBorrowOriginTextValue.cap = 512
    freeSeq[int32](semBorrowOriginUnknownTextCount)
    semBorrowOriginUnknownTextCount.cap = 512
    hashmaps.HashMapPtrIntClear(semBorrowOriginKnownIndex)
    freeSeq[int32](semBorrowOriginKnownValue)
    semBorrowOriginKnownValue.cap = 512
    freeSeq[bool](semTypeSendReady)
    semTypeSendReady.cap = 512
    freeSeq[bool](semTypeSendValue)
    semTypeSendValue.cap = 512
    freeSeq[bool](semStmtVisitedModules)
    freeSeq[bool](semStmtVisitedDecls)
    let semVisitedNodeCount: int32 = len(astKindByNode)
    if semVisitedNodeCount > 0:
        setLen(semStmtVisitedModules, semVisitedNodeCount)
        setLen(semStmtVisitedDecls, semVisitedNodeCount)
    semStmtVisitedModules.cap = semVisitedNodeCount > 512 ? semVisitedNodeCount : 512
    semStmtVisitedDecls.cap = semVisitedNodeCount > 512 ? semVisitedNodeCount : 512
    semScopeEpoch = 1
    semFnSigEpoch = 1
    semAnalyzeEpoch = 1
    semSendEpoch = 1
    semBorrowEpoch = 1
    semDebugLog(semDbg, "[sem-debug] checkSemantics:state_reset_done")
    semDebugLog(semDbg, "[sem-debug] checkSemantics:init_ctx_prepare")
    var ctx: SemCtx
    semDebugLog(semDbg, "[sem-debug] checkSemantics:init_ctx_start")
    initSemCtxInPlace(ctx)
    semDebugLog(semDbg, "[sem-debug] checkSemantics:ctx_init_done")
    ctx.diags = diags
    ctx.filename = nodeStrVal(root)
    ctx.allowUnknown = true
    ctx.ownershipEnabled = ownershipEnabled
    ctx.orcStrictWarn = orcStrictWarn
    if semIsGeneratedModule(ctx.filename):
        diags = ctx.diags
        return
    semDebugLog(semDbg, "[sem-debug] checkSemantics:ctx_ready")
    let enforceStdNoPointer: bool = semShouldEnforceStdNoPointer()
    if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_DIAG_ADD", "") == "1":
        let f: os.File = os.Get_stderr()
        os.Write(f, "[sem-policy] enforce_std_no_ptr=")
        os.WriteLine(f, enforceStdNoPointer ? "1" : "0")
    if enforceStdNoPointer:
        let stdPointerViolations: int32 = semCheckStdNoPointerPolicy(ctx, rootId)
        if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_DIAG_ADD", "") == "1":
            let f: os.File = os.Get_stderr()
            os.Write(f, "[sem-policy] std_no_ptr_hits=")
            semWriteIntRaw(f, stdPointerViolations)
            os.WriteLine(f, "")
        if stdPointerViolations > 0:
            diags = ctx.diags
            return
    let enforceNonCAbiNoPointer: bool = semShouldEnforceNonCAbiNoPointer()
    if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_DIAG_ADD", "") == "1":
        let f: os.File = os.Get_stderr()
        os.Write(f, "[sem-policy] enforce_non_cabi_no_ptr=")
        os.WriteLine(f, enforceNonCAbiNoPointer ? "1" : "0")
    if enforceNonCAbiNoPointer:
        let nonCAbiPointerViolations: int32 = semCheckNoPointerNonCAbiPolicy(ctx, rootId)
        if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_DIAG_ADD", "") == "1":
            let f: os.File = os.Get_stderr()
            os.Write(f, "[sem-policy] non_cabi_no_ptr_hits=")
            semWriteIntRaw(f, nonCAbiPointerViolations)
            os.WriteLine(f, "")
        if nonCAbiPointerViolations > 0:
            diags = ctx.diags
            return
    semDebugLog(semDbg, "[sem-debug] checkSemantics:policy_done")
    crashTraceSetPhase(strToCStringTemp("sem.collect_globals"))
    if semProfOn:
        let startNs: int64 = cheng_monotime_ns()
        semCollectGlobals(ctx, root)
        semProfCollectGlobalsNs = cheng_monotime_ns() - startNs
    else:
        semCollectGlobals(ctx, root)
    if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_DIAG_ADD", "") == "1":
        let f: os.File = os.Get_stderr()
        os.Write(f, "[sem-phase] after_collect_globals has_error=")
        os.WriteLine(f, hasError(ctx.diags) ? "1" : "0")
    semDebugLog(semDbg, "[sem-debug] checkSemantics:collect_globals_done")
    crashTraceSetPhase(strToCStringTemp("sem.bind_imports"))
    if semProfOn:
        let startNs2: int64 = cheng_monotime_ns()
        semBindImports(ctx, root)
        semProfBindImportsNs = cheng_monotime_ns() - startNs2
    else:
        semBindImports(ctx, root)
    if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_DIAG_ADD", "") == "1":
        let f: os.File = os.Get_stderr()
        os.Write(f, "[sem-phase] after_bind_imports has_error=")
        os.WriteLine(f, hasError(ctx.diags) ? "1" : "0")
    semDebugLog(semDbg, "[sem-debug] checkSemantics:bind_imports_done")
    crashTraceSetPhase(strToCStringTemp("sem.analyze"))
    if semProfOn:
        let startNs3: int64 = cheng_monotime_ns()
        semAnalyzeStmt(ctx, root)
        semProfAnalyzeNs = cheng_monotime_ns() - startNs3
    else:
        semAnalyzeStmt(ctx, root)
    if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_DIAG_ADD", "") == "1":
        let f: os.File = os.Get_stderr()
        os.Write(f, "[sem-phase] after_analyze has_error=")
        os.WriteLine(f, hasError(ctx.diags) ? "1" : "0")
    semDebugLog(semDbg, "[sem-debug] checkSemantics:analyze_done")
    if semProfOn:
        var msgParts: str[]
        add(msgParts, "[sem] globals=")
        add(msgParts, intToStr(int32(semProfCollectGlobalsNs / 1000000)))
        add(msgParts, "ms imports=")
        add(msgParts, intToStr(int32(semProfBindImportsNs / 1000000)))
        add(msgParts, "ms analyze=")
        add(msgParts, intToStr(int32(semProfAnalyzeNs / 1000000)))
        add(msgParts, "ms")
        echo(strutils.Join(msgParts, ""))
        var detailParts: str[]
        add(detailParts, "[sem-detail] normalize=")
        add(detailParts, intToStr(int32(semProfNormalizeNs / 1000000)))
        add(detailParts, "ms(")
        add(detailParts, intToStr(semProfNormalizeCalls))
        add(detailParts, ") defined=")
        add(detailParts, intToStr(int32(semProfIsDefinedNs / 1000000)))
        add(detailParts, "ms(")
        add(detailParts, intToStr(semProfIsDefinedCalls))
        add(detailParts, ") findDef=")
        add(detailParts, intToStr(int32(semProfFindDefNs / 1000000)))
        add(detailParts, "ms(")
        add(detailParts, intToStr(semProfFindDefCalls))
        add(detailParts, ") stmt=")
        add(detailParts, intToStr(int32(semProfAnalyzeStmtNs / 1000000)))
        add(detailParts, "ms(")
        add(detailParts, intToStr(semProfAnalyzeStmtCalls))
        add(detailParts, ") expr=")
        add(detailParts, intToStr(int32(semProfAnalyzeExprNs / 1000000)))
        add(detailParts, "ms(")
        add(detailParts, intToStr(semProfAnalyzeExprCalls))
        add(detailParts, ")")
        echo(strutils.Join(detailParts, ""))
        let stmtTop: str = semProfTopKinds(semProfStmtKindNs, semProfStmtKindCalls, true, "[sem-stmt-top]")
        echo(stmtTop)
        let exprTop: str = semProfTopKinds(semProfExprKindNs, semProfExprKindCalls, false, "[sem-expr-top]")
        echo(exprTop)
        let sendTop: str = semProfTopKinds(semProfSendKindNs, semProfSendKindCalls, false, "[sem-send-top]")
        echo(sendTop)
        let borrowTop: str = semProfTopKinds(semProfBorrowKindNs, semProfBorrowKindCalls, false, "[sem-borrow-top]")
        echo(borrowTop)
        var scopeParts: str[]
        add(scopeParts, "[sem-scope] push=")
        add(scopeParts, intToStr(int32(semProfScopePushNs / 1000000)))
        add(scopeParts, "ms(")
        add(scopeParts, intToStr(semProfScopePushCalls))
        add(scopeParts, ") pop=")
        add(scopeParts, intToStr(int32(semProfScopePopNs / 1000000)))
        add(scopeParts, "ms(")
        add(scopeParts, intToStr(semProfScopePopCalls))
        add(scopeParts, ")")
        echo(strutils.Join(scopeParts, ""))
        var stmtParts: str[]
        add(stmtParts, "[sem-stmt] if_cond=")
        add(stmtParts, intToStr(int32(semProfIfCondNs / 1000000)))
        add(stmtParts, "ms(")
        add(stmtParts, intToStr(semProfIfCondCalls))
        add(stmtParts, ") if_body=")
        add(stmtParts, intToStr(int32(semProfIfBodyNs / 1000000)))
        add(stmtParts, "ms(")
        add(stmtParts, intToStr(semProfIfBodyCalls))
        add(stmtParts, ") while_cond=")
        add(stmtParts, intToStr(int32(semProfWhileCondNs / 1000000)))
        add(stmtParts, "ms(")
        add(stmtParts, intToStr(semProfWhileCondCalls))
        add(stmtParts, ") while_body=")
        add(stmtParts, intToStr(int32(semProfWhileBodyNs / 1000000)))
        add(stmtParts, "ms(")
        add(stmtParts, intToStr(semProfWhileBodyCalls))
        add(stmtParts, ") asgn_lhs=")
        add(stmtParts, intToStr(int32(semProfAsgnLhsNs / 1000000)))
        add(stmtParts, "ms(")
        add(stmtParts, intToStr(semProfAsgnLhsCalls))
        add(stmtParts, ") asgn_rhs=")
        add(stmtParts, intToStr(int32(semProfAsgnRhsNs / 1000000)))
        add(stmtParts, "ms(")
        add(stmtParts, intToStr(semProfAsgnRhsCalls))
        add(stmtParts, ")")
        echo(strutils.Join(stmtParts, ""))
        var loopParts: str[]
        add(loopParts, "[sem-loop] for_iter=")
        add(loopParts, intToStr(int32(semProfForIterNs / 1000000)))
        add(loopParts, "ms(")
        add(loopParts, intToStr(semProfForIterCalls))
        add(loopParts, ") for_body=")
        add(loopParts, intToStr(int32(semProfForBodyNs / 1000000)))
        add(loopParts, "ms(")
        add(loopParts, intToStr(semProfForBodyCalls))
        add(loopParts, ")")
        echo(strutils.Join(loopParts, ""))
        var caseParts: str[]
        add(caseParts, "[sem-case] expr=")
        add(caseParts, intToStr(int32(semProfCaseExprNs / 1000000)))
        add(caseParts, "ms(")
        add(caseParts, intToStr(semProfCaseExprCalls))
        add(caseParts, ") body=")
        add(caseParts, intToStr(int32(semProfCaseBodyNs / 1000000)))
        add(caseParts, "ms(")
        add(caseParts, intToStr(semProfCaseBodyCalls))
        add(caseParts, ")")
        echo(strutils.Join(caseParts, ""))
        var asgnParts: str[]
        add(asgnParts, "[sem-asgn] borrow=")
        add(asgnParts, intToStr(int32(semProfAsgnBorrowCheckNs / 1000000)))
        add(asgnParts, "ms(")
        add(asgnParts, intToStr(semProfAsgnBorrowCheckCalls))
        add(asgnParts, ") send=")
        add(asgnParts, intToStr(int32(semProfAsgnSendCheckNs / 1000000)))
        add(asgnParts, "ms(")
        add(asgnParts, intToStr(semProfAsgnSendCheckCalls))
        add(asgnParts, ")")
        echo(strutils.Join(asgnParts, ""))
        var callParts: str[]
        add(callParts, "[sem-call] name=")
        add(callParts, intToStr(int32(semProfCallNameNs / 1000000)))
        add(callParts, "ms(")
        add(callParts, intToStr(semProfCallNameCalls))
        add(callParts, ") var=")
        add(callParts, intToStr(int32(semProfCallVarNs / 1000000)))
        add(callParts, "ms(")
        add(callParts, intToStr(semProfCallVarCalls))
        add(callParts, ") thread=")
        add(callParts, intToStr(int32(semProfCallThreadNs / 1000000)))
        add(callParts, "ms(")
        add(callParts, intToStr(semProfCallThreadCalls))
        add(callParts, ") sendCtor=")
        add(callParts, intToStr(int32(semProfCallSendCtorNs / 1000000)))
        add(callParts, "ms(")
        add(callParts, intToStr(semProfCallSendCtorCalls))
        add(callParts, ") share=")
        add(callParts, intToStr(int32(semProfCallShareNs / 1000000)))
        add(callParts, "ms(")
        add(callParts, intToStr(semProfCallShareCalls))
        add(callParts, ") args=")
        add(callParts, intToStr(int32(semProfCallArgsNs / 1000000)))
        add(callParts, "ms(")
        add(callParts, intToStr(semProfCallArgsCalls))
        add(callParts, ")")
        echo(strutils.Join(callParts, ""))
    diags = ctx.diags
