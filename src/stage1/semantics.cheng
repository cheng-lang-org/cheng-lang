fn semPointerPolicyShouldCheckNonCAbi(path: str): bool =
    if !semShouldEnforceNonCAbiNoPointer():
        return false
    if len(path) == 0:
        return false
    if semIsGeneratedModule(path):
        return false
    # Legacy-named user-surface no-pointer gate targets business/user modules.
    # Standard library modules are governed by std-specific policy switches.
    let strictStdNoPointer: bool = semStrEq(getEnv("STAGE1_STD_NO_POINTERS_STRICT"), "1")
    if semIsStdModulePath(path) && !strictStdNoPointer:
        return false
    # Compiler-internal modules no longer depend on a public env toggle here.
    # Their low-level surfaces are constrained by dedicated rawptr/bridge gates.
    if semIsCompilerInternalModulePath(path):
        return false
    return true

