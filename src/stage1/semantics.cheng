fn semTextEqId(textId: int32, cachedId: int32): bool =
    return textId > 0 && cachedId > 0 && textId == cachedId

fn semEnsureNameClassTextIds() =
    let epoch: int32 = tokenTextPoolCurrentEpoch()
    if semNameClassTextEpoch == epoch:
        return
    semNameClassTextEpoch = epoch
    semNameClassIdNil = tokenInternText("nil")
    semNameClassIdTrue = tokenInternText("true")
    semNameClassIdFalse = tokenInternText("false")
    semNameClassIdAddr = tokenInternText("__addr")
    semNameClassIdSizeof = tokenInternText("sizeof")
    semNameClassIdDefault = tokenInternText("default")
    semNameClassIdElemSize = tokenInternText("elemSize")
    semNameClassIdSystem = tokenInternText("system")
    semNameClassIdResult = tokenInternText("result")
    semNameClassIdSeq = tokenInternText("seq")
    semNameClassIdAdd = tokenInternText("add")
    semNameClassIdSet = tokenInternText("set")
    semNameClassIdGet = tokenInternText("get")
    semNameClassIdBracketGet = tokenInternText("[]")
    semNameClassIdBracketSet = tokenInternText("[]=")

fn semNameClassComputeTextId(textId: int32): int32 =
    if textId <= 0:
        return 0
    semEnsureNameClassTextIds()
    var mask: int32 = 0
    if semTextEqId(textId, semNameClassIdNil) || semTextEqId(textId, semNameClassIdTrue) ||
       semTextEqId(textId, semNameClassIdFalse):
        mask = mask | semNameClassLiteral
    if semTextEqId(textId, semNameClassIdAddr) || semTextEqId(textId, semNameClassIdSizeof) ||
       semTextEqId(textId, semNameClassIdDefault) || semTextEqId(textId, semNameClassIdElemSize) ||
       semTextEqId(textId, semNameClassIdSystem) || semTextEqId(textId, semNameClassIdResult):
        mask = mask | semNameClassIntrinsic
    if semTextEqId(textId, semNameClassIdSeq) || semTextEqId(textId, semNameClassIdAdd) ||
       semTextEqId(textId, semNameClassIdSet) || semTextEqId(textId, semNameClassIdGet) ||
       semTextEqId(textId, semNameClassIdBracketGet) || semTextEqId(textId, semNameClassIdBracketSet):
        mask = mask | semNameClassGenericBase
    return mask

