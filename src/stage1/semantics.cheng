fn semCallInfoNameMatches(callInfo: SemCallInfo, cachedTextId: int32, fallbackName: str): bool =
    if callInfo.nameTextId > 0 && cachedTextId > 0:
        return semTextEqId(callInfo.nameTextId, cachedTextId)
    return callInfo.name == fallbackName

