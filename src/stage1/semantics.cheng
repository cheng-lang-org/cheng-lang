fn semSendIsActiveTextCached(ctx: var SemCtx, textId: int32, found: var bool): bool =
    found = false
    if textId <= 0:
        return false
    semEnsureSendActiveTextCache(textId)
    if textId < semSendActiveTextEpoch.len && textId < semSendActiveTextValue.len:
        if semSendActiveTextEpoch[textId] == semSendEpoch:
            found = true
            return semSendActiveTextValue[textId]
    var foundText: bool
    let idxPlus1Text: int32 = semSendTextIndexGet(textId, foundText)
    if !foundText:
        if textId < semSendActiveTextEpoch.len && textId < semSendActiveTextValue.len:
            semSendActiveTextEpoch[textId] = semSendEpoch
            semSendActiveTextValue[textId] = false
        found = true
        return false
    found = true
    let active: bool = idxPlus1Text > 0 && (idxPlus1Text - 1) < ctx.sendFlags.len &&
        semReadI32(ctx.sendFlags, idxPlus1Text - 1) != 0
    if textId < semSendActiveTextEpoch.len && textId < semSendActiveTextValue.len:
        semSendActiveTextEpoch[textId] = semSendEpoch
        semSendActiveTextValue[textId] = active
    return active

fn semNameClassOfNormalized(nm: str): int32 =
    if nm == "":
        return 0
    let ptrKey: int64 = semStrPtrKey(nm)
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(semNameClassPtrIndex, ptrKey, foundPtr)
        if foundPtr && idxPlus1Ptr > 0 && idxPlus1Ptr <= semNameClassValues.len:
            return semReadI32(semNameClassValues, idxPlus1Ptr - 1)
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(semNameClassIndex, nm, found)
    if found && idxPlus1 > 0 && idxPlus1 <= semNameClassValues.len:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(semNameClassPtrIndex, ptrKey, idxPlus1)
        return semReadI32(semNameClassValues, idxPlus1 - 1)
    let mask: int32 = semNameClassComputeNormalized(nm)
    add(semNameClassValues, mask)
    let storedIdx: int32 = semNameClassValues.len
    hashmaps.HashMapStrIntPut(semNameClassIndex, nm, storedIdx)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(semNameClassPtrIndex, ptrKey, storedIdx)
    return mask

fn semNameClassOfNormalizedWithTextId(nm: str, textId: int32): int32 =
    if textId > 0:
        semEnsureNameClassTextCache(textId)
        if textId < semNameClassTextReady.len && textId < semNameClassTextValue.len:
            if semNameClassTextReady[textId]:
                return semNameClassTextValue[textId]
        let maskText: int32 = semNameClassComputeTextId(textId)
        if textId < semNameClassTextReady.len && textId < semNameClassTextValue.len:
            semNameClassTextReady[textId] = true
            semNameClassTextValue[textId] = maskText
        return maskText
    return semNameClassOfNormalized(nm)

fn semNameClassDefinesName(mask: int32): bool =
    return (mask & semNameClassBuiltinMask) != 0

fn semIdentNameClassNormalized(n: Node): int32 =
    if stage1AstRefIsNil(n):
        return 0
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return 0
    semEnsureIdentNormCache(n)
    let idx: int32 = astNodeIndex(n)
    if idx >= 0 && idx < semIdentNameClassReady.len && semIdentNameClassReady[idx]:
        if idx < semIdentNameClassValues.len:
            return semIdentNameClassValues[idx]
    let textId: int32 = nodeIdentId(n)
    var mask: int32
    if textId > 0:
        mask = semNameClassOfNormalizedWithTextId("", textId)
    else:
        mask = semNameClassComputeNormalized(semIdentNameNormalized(n))
    if idx >= 0 && idx < semIdentNameClassReady.len && idx < semIdentNameClassValues.len:
        semIdentNameClassReady[idx] = true
        semIdentNameClassValues[idx] = mask
    return mask

fn semIsLiteralIdentNormalized(nm: str): bool =
    return (semNameClassOfNormalized(nm) & semNameClassLiteral) != 0

fn semIsIntrinsicIdentNormalized(nm: str): bool =
    return (semNameClassOfNormalized(nm) & semNameClassIntrinsic) != 0

fn semIsGenericBaseIdentNormalized(nm: str): bool =
    return (semNameClassOfNormalized(nm) & semNameClassGenericBase) != 0

fn semIsOperatorNameNormalized(nm: str): bool =
    return (semNameClassOfNormalized(nm) & semNameClassOperator) != 0

fn semNormalizeNameCore(name: str): str =
    if len(name) == 0:
        return ""
    let n: int32 = len(name)
    if n <= 0:
        return ""
    if name[0] != ' ' && name[n - 1] != ' ':
        return name
    var start: int32
    for __for_guard_start in 0..<n:
        if !(start < n):
            break
        if name[start] != ' ':
            break
        start = start + 1
    var last: int32 = n - 1
    if last >= start:
        for __for_rev_last in 0..(last - start):
            if name[last] != ' ':
                break
            last = last - 1
    else:
        last = start - 1
    if last < start:
        return ""
    if start == 0:
        if last == n - 1:
            return name
    return __cheng_slice_string(name, start, last + 1, true)

fn semNormalizeName(name: str): str =
    if len(name) == 0:
        return ""
    let profOn: bool = semProfOn
    if profOn:
        semProfNormalizeCalls = semProfNormalizeCalls + 1
    let n: int32 = len(name)
    if n > 0 && name[0] != ' ' && name[n - 1] != ' ':
        return name
    let ptrKey: int64 = semStrPtrKey(name)
    if ptrKey != 0:
        var cachedPtr: bool
        let cachedIdxPtr: int32 = hashmaps.HashMapPtrIntGet(semNormalizeIndexPtr, ptrKey, cachedPtr)
        if cachedPtr && cachedIdxPtr > 0 && cachedIdxPtr <= semNormalizeValues.len:
            return semReadStr(semNormalizeValues, cachedIdxPtr - 1)
    var cachedStr: bool
    let cachedIdxStr: int32 = hashmaps.HashMapStrIntGetEx(semNormalizeIndexStr, name, cachedStr)
    if cachedStr && cachedIdxStr > 0 && cachedIdxStr <= semNormalizeValues.len:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(semNormalizeIndexPtr, ptrKey, cachedIdxStr)
        return semReadStr(semNormalizeValues, cachedIdxStr - 1)
    if profOn && (semProfNormalizeCalls & 31) == 0:
        let startNs: int64 = cheng_monotime_ns()
        let res: str = semNormalizeNameCore(name)
        semProfNormalizeNs = semProfNormalizeNs + ((cheng_monotime_ns() - startNs) * 32)
        add(semNormalizeValues, res)
        let storedIdx: int32 = semNormalizeValues.len
        hashmaps.HashMapStrIntPut(semNormalizeIndexStr, name, storedIdx)
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(semNormalizeIndexPtr, ptrKey, storedIdx)
        return res
    else:
        let res: str = semNormalizeNameCore(name)
        add(semNormalizeValues, res)
        let storedIdx: int32 = semNormalizeValues.len
        hashmaps.HashMapStrIntPut(semNormalizeIndexStr, name, storedIdx)
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(semNormalizeIndexPtr, ptrKey, storedIdx)
        return res

fn semCacheNormalizedTextValue(textId: int32, value: str): str =
    if textId < semNormalizeTextReady.len && textId < semNormalizeTextValue.len:
        semNormalizeTextReady[textId] = true
        semNormalizeTextValue[textId] = value
    return value

fn semNormalizeTextId(textId: int32): str =
    if textId <= 0:
        return ""
    semEnsureNormalizeTextCache(textId)
    if textId < semNormalizeTextReady.len && semNormalizeTextReady[textId]:
        return semReadStr(semNormalizeTextValue, textId)
    let rawLen: int32 = tokenTextLen(textId)
    if rawLen <= 0:
        return semCacheNormalizedTextValue(textId, "")
    if tokenTextByteAtId(textId, 0) != ' ' && tokenTextByteAtId(textId, rawLen - 1) != ' ':
        return semCacheNormalizedTextValue(textId, tokenTextById(textId))
    var start: int32
    var stop: int32 = rawLen
    while start < stop && tokenTextByteAtId(textId, start) == ' ':
        start = start + 1
    while stop > start && tokenTextByteAtId(textId, stop - 1) == ' ':
        stop = stop - 1
    if stop <= start:
        return semCacheNormalizedTextValue(textId, "")
    if start == 0 && stop == rawLen:
        return semCacheNormalizedTextValue(textId, tokenTextById(textId))
    let raw: str = tokenTextById(textId)
    return semCacheNormalizedTextValue(textId, __cheng_slice_string(raw, start, stop, true))

fn semNodeNameNormalized(n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        return semIdentNameNormalized(n)
    return semNormalizeName(plainName(n))

fn semNodeNameNormalizedId(nId: AstNodeId): str =
    if !astNodeIdValid(nId):
        return ""
    if astNodeKind(nId) == nkIdent || astNodeKind(nId) == nkSymbol:
        return semIdentNameNormalized(nId)
    return semNormalizeName(astPlainName(nId))

fn semIdentNameNormalized(n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return ""
    semEnsureIdentNormCache(n)
    let idx: int32 = astNodeIndex(n)
    if idx >= 0 && idx < semIdentNormReady.len && semIdentNormReady[idx]:
        return semReadStr(semIdentNormValues, idx)
    let textId: int32 = nodeIdentId(n)
    var nm: str
    if textId > 0:
        nm = semNormalizedNameFromTextId("", textId)
    else:
        nm = semNormalizeName(nodeIdent(n))
    if idx >= 0 && idx < semIdentNormReady.len && idx < semIdentNormValues.len:
        semIdentNormReady[idx] = true
        semIdentNormValues[idx] = nm
    return nm

fn semIdentDefinedCached(ctx: var SemCtx, n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return false
    semEnsureIdentLookupCache(n)
    let idx: int32 = astNodeIndex(n)
    if idx >= 0 && idx < semIdentDefinedEpoch.len && semIdentDefinedEpoch[idx] == semScopeEpoch:
        if idx < semIdentDefinedValue.len:
            return semIdentDefinedValue[idx]
    let classMask: int32 = semIdentNameClassNormalized(n)
    var ok: bool
    if semNameClassDefinesName(classMask):
        ok = true
    else:
        ok = semIdentDefDepthCached(ctx, n) >= 0 || ctx.allowUnknown
    if idx >= 0 && idx < semIdentDefinedEpoch.len && idx < semIdentDefinedValue.len:
        semIdentDefinedEpoch[idx] = semScopeEpoch
        semIdentDefinedValue[idx] = ok
    return ok

fn semIdentDefDepthCached(ctx: var SemCtx, n: Node): int32 =
    if stage1AstRefIsNil(n):
        return -1
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return -1
    semEnsureIdentLookupCache(n)
    let idx: int32 = astNodeIndex(n)
    if idx >= 0 && idx < semIdentDepthEpoch.len && semIdentDepthEpoch[idx] == semScopeEpoch:
        if idx < semIdentDepthValue.len:
            return semIdentDepthValue[idx]
    let rawTextId: int32 = nodeIdentId(n)
    let textId: int32 = semCanonicalTextId("", rawTextId)
    if textId > 0:
        semEnsureDefDepthTextCache(textId)
        if textId < semDefDepthTextEpoch.len && textId < semDefDepthTextValue.len:
            if semDefDepthTextEpoch[textId] == semScopeEpoch:
                let cachedDepth: int32 = semDefDepthTextValue[textId]
                if idx >= 0 && idx < semIdentDepthEpoch.len && idx < semIdentDepthValue.len:
                    semIdentDepthEpoch[idx] = semScopeEpoch
                    semIdentDepthValue[idx] = cachedDepth
                return cachedDepth
        let depthPlus1: int32 = semNameDepthGetCachedWithTextId(ctx, "", textId)
        let depthLinear: int32 = depthPlus1 > 0 ? (depthPlus1 - 1) : -1
        semNameDepthTextPut(textId, depthLinear >= 0 ? (depthLinear + 1) : 0)
        if textId < semDefDepthTextEpoch.len && textId < semDefDepthTextValue.len:
            semDefDepthTextEpoch[textId] = semScopeEpoch
            semDefDepthTextValue[textId] = depthLinear
        if idx >= 0 && idx < semIdentDepthEpoch.len && idx < semIdentDepthValue.len:
            semIdentDepthEpoch[idx] = semScopeEpoch
            semIdentDepthValue[idx] = depthLinear
        return depthLinear
    let nm: str = semIdentNameNormalized(n)
    let depth: int32 = semFindDefDepthNormalized(ctx, nm)
    if textId > 0 && textId < semDefDepthTextEpoch.len && textId < semDefDepthTextValue.len:
        semDefDepthTextEpoch[textId] = semScopeEpoch
        semDefDepthTextValue[textId] = depth
    if idx >= 0 && idx < semIdentDepthEpoch.len && idx < semIdentDepthValue.len:
        semIdentDepthEpoch[idx] = semScopeEpoch
        semIdentDepthValue[idx] = depth
    return depth

fn semIdentFnSigFindCached(ctx: var SemCtx, n: Node): int32 =
    if stage1AstRefIsNil(n):
        return -1
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return -1
    semEnsureIdentLookupCache(n)
    let idx: int32 = astNodeIndex(n)
    if idx >= 0 && idx < semIdentFnSigEpoch.len && idx < semIdentFnSigValue.len:
        let cachedSigIdx: int32 = semIdentFnSigValue[idx]
        if cachedSigIdx >= 0:
            return cachedSigIdx
        if semIdentFnSigEpoch[idx] == semFnSigEpoch:
            return cachedSigIdx
    let textId: int32 = semCanonicalTextId("", nodeIdentId(n))
    var sigIdx: int32 = -1
    if textId > 0:
        sigIdx = semFnSigFindNormalizedWithTextId(ctx, "", textId)
    else:
        sigIdx = semFnSigFindNormalizedWithTextId(ctx, semIdentNameNormalized(n), textId)
    if idx >= 0 && idx < semIdentFnSigEpoch.len && idx < semIdentFnSigValue.len:
        semIdentFnSigEpoch[idx] = semFnSigEpoch
        semIdentFnSigValue[idx] = sigIdx
    return sigIdx

fn semIsOperatorName(name: str): bool =
    return semIsOperatorNameNormalized(semNormalizeName(name))

fn semIsVarTypeNode(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    return nodeKind(n) == nkVarTy
fn semIsPtrLikeTypeNode(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    var base: Node = n
    if nodeKind(base) == nkVarTy && kidCount(base) > 0:
        base = kid(base, 0)
    if stage1AstRefIsNil(base):
        return false
    if nodeKind(base) == nkPtrTy || nodeKind(base) == nkRefTy:
        return true
    if nodeKind(base) == nkBracketExpr && kidCount(base) > 0:
        let ctorNode: Node = kid(base, 0)
        if stage1AstRefNonNil(ctorNode) && (nodeKind(ctorNode) == nkIdent || nodeKind(ctorNode) == nkSymbol):
            let ctorTextId: int32 = semCanonicalTextId("", nodeIdentId(ctorNode))
            if ctorTextId > 0:
                semEnsureTypeNameTextIds()
                return semTextEqId(ctorTextId, semTypeNameIdPtr) || semTextEqId(ctorTextId, semTypeNameIdRef)
        let ctorName: str = semNodeNameNormalized(ctorNode)
        if ctorName == "ptr" || ctorName == "ref":
            return true
    return false

fn semIsVoidTypeNode(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    var base: Node = n
    while stage1AstRefNonNil(base) && nodeKind(base) == nkPar && kidCount(base) == 1:
        base = kid(base, 0)
    if stage1AstRefIsNil(base):
        return false
    if nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol:
        let textId: int32 = semCanonicalTextId("", nodeIdentId(base))
        if textId > 0:
            semEnsureTypeNameTextIds()
            return semTextEqId(textId, semTypeNameIdVoid)
        let nm: str = semNodeNameNormalized(base)
        return nm == "void"
    return false

fn semIsVoidPtrTypeNode(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    var base: Node = n
    if nodeKind(base) == nkVarTy && kidCount(base) > 0:
        base = kid(base, 0)
    if stage1AstRefIsNil(base):
        return false
    if nodeKind(base) == nkPtrTy && kidCount(base) > 0:
        return semIsVoidTypeNode(kid(base, 0))
    if nodeKind(base) == nkBracketExpr && kidCount(base) > 1:
        let ctorNode: Node = kid(base, 0)
        if stage1AstRefNonNil(ctorNode) && (nodeKind(ctorNode) == nkIdent || nodeKind(ctorNode) == nkSymbol):
            let ctorTextId: int32 = semCanonicalTextId("", nodeIdentId(ctorNode))
            if ctorTextId > 0:
                semEnsureTypeNameTextIds()
                if semTextEqId(ctorTextId, semTypeNameIdPtr):
                    return semIsVoidTypeNode(kid(base, 1))
                return false
        let ctorName: str = semNodeNameNormalized(ctorNode)
        if ctorName == "ptr":
            return semIsVoidTypeNode(kid(base, 1))
    return false

fn semIsPtrLikeTypeNodeId(nId: AstNodeId): bool =
    if !astNodeIdValid(nId):
        return false
    var baseId: AstNodeId = nId
    if astNodeKind(baseId) == nkVarTy && astKidCount(baseId) > 0:
        baseId = astKidAt(baseId, 0)
    if !astNodeIdValid(baseId):
        return false
    let baseKind: NodeKind = astNodeKind(baseId)
    if baseKind == nkPtrTy || baseKind == nkRefTy:
        return true
    if baseKind == nkBracketExpr && astKidCount(baseId) > 0:
        let ctorId: AstNodeId = astKidAt(baseId, 0)
        let ctorTextId: int32 = semCanonicalTextId("", astNodeIdentId(ctorId))
        if ctorTextId > 0:
            semEnsureTypeNameTextIds()
            return semTextEqId(ctorTextId, semTypeNameIdPtr) || semTextEqId(ctorTextId, semTypeNameIdRef)
        let ctorName: str = semNodeNameNormalizedId(ctorId)
        if ctorName == "ptr" || ctorName == "ref":
            return true
    return false

fn semIsVoidTypeNodeId(nId: AstNodeId): bool =
    if !astNodeIdValid(nId):
        return false
    var baseId: AstNodeId = nId
    while astNodeIdValid(baseId) && astNodeKind(baseId) == nkPar && astKidCount(baseId) == 1:
        baseId = astKidAt(baseId, 0)
    if !astNodeIdValid(baseId):
        return false
    let baseKind: NodeKind = astNodeKind(baseId)
    if baseKind == nkIdent || baseKind == nkSymbol:
        let textId: int32 = semCanonicalTextId("", astNodeIdentId(baseId))
        if textId > 0:
            semEnsureTypeNameTextIds()
            return semTextEqId(textId, semTypeNameIdVoid)
        let nm: str = semNodeNameNormalizedId(baseId)
        return nm == "void"
    return false

fn semIsVoidPtrTypeNodeId(nId: AstNodeId): bool =
    if !astNodeIdValid(nId):
        return false
    var baseId: AstNodeId = nId
    if astNodeKind(baseId) == nkVarTy && astKidCount(baseId) > 0:
        baseId = astKidAt(baseId, 0)
    if !astNodeIdValid(baseId):
        return false
    if astNodeKind(baseId) == nkPtrTy && astKidCount(baseId) > 0:
        return semIsVoidTypeNodeId(astKidAt(baseId, 0))
    if astNodeKind(baseId) == nkBracketExpr && astKidCount(baseId) > 1:
        let ctorId: AstNodeId = astKidAt(baseId, 0)
        let ctorTextId: int32 = semCanonicalTextId("", astNodeIdentId(ctorId))
        if ctorTextId > 0:
            semEnsureTypeNameTextIds()
            if semTextEqId(ctorTextId, semTypeNameIdPtr):
                return semIsVoidTypeNodeId(astKidAt(baseId, 1))
            return false
        let ctorName: str = semNodeNameNormalizedId(ctorId)
        if ctorName == "ptr":
            return semIsVoidTypeNodeId(astKidAt(baseId, 1))
    return false

fn semStripParExpr(n: Node): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    if nodeKind(n) == nkPar && kidCount(n) == 1:
        return semStripParExpr(kid(n, 0))
    return n

fn semIsSeqTypeNode(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    var base: Node = n
    if nodeKind(base) == nkVarTy && kidCount(base) > 0:
        base = kid(base, 0)
    if stage1AstRefIsNil(base):
        return false
    if nodeKind(base) == nkBracketExpr && kidCount(base) > 1:
        let ctorNode: Node = kid(base, 0)
        if stage1AstRefNonNil(ctorNode) && (nodeKind(ctorNode) == nkIdent || nodeKind(ctorNode) == nkSymbol):
            let textId: int32 = semCanonicalTextId("", nodeIdentId(ctorNode))
            if textId > 0:
                semEnsureTypeNameTextIds()
                return semTextEqId(textId, semTypeNameIdSeq) ||
                       semTextEqId(textId, semTypeNameIdSeqFixed) ||
                       semTextEqId(textId, semTypeNameIdOpenArray)
        let name: str = semNodeNameNormalized(ctorNode)
        if (name ==  "seq") ||(name ==  "seq_fixed") ||(name ==  "openArray"):
            return true
    if nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol:
        let nm: str = semIdentNameNormalized(base)
        if hasPrefix(nm, "seq_"):
            return true
    return false

fn semTypeIsSend(typeNode: Node): bool =
    if stage1AstRefIsNil(typeNode):
        return false
    let typeId: AstNodeId = astNodeIndex(typeNode)
    if astNodeIdValid(typeId):
        semEnsureTypeSendCache(typeId)
        let cacheIdx: int32 = typeId
        if cacheIdx >= 0 && cacheIdx < semTypeSendReady.len && cacheIdx < semTypeSendValue.len && semTypeSendReady[cacheIdx]:
            return semTypeSendValue[cacheIdx]
    var res: bool
    var base: Node = typeNode
    if nodeKind(base) == nkVarTy && kidCount(base) > 0:
        base = kid(base, 0)
    if stage1AstRefIsNil(base):
        res = false
    elif nodeKind(base) == nkTupleTy:
        res = true
        for ti in 0..<kidCount(base):
            var elem: Node = kid(base, ti)
            if stage1AstRefNonNil(elem) && nodeKind(elem) == nkIdentDefs && kidCount(elem) > 1:
                elem = kid(elem, 1)
            if ! semTypeIsSend(elem):
                res = false
                break
    elif nodeKind(base) == nkPtrTy || nodeKind(base) == nkRefTy:
        res = false
    elif nodeKind(base) == nkBracketExpr:
        if kidCount(base) > 0:
            let ctorNode: Node = kid(base, 0)
            if stage1AstRefNonNil(ctorNode) && (nodeKind(ctorNode) == nkIdent || nodeKind(ctorNode) == nkSymbol):
                let textId: int32 = semCanonicalTextId("", nodeIdentId(ctorNode))
                if textId > 0:
                    semEnsureTypeNameTextIds()
                    if semTextEqId(textId, semTypeNameIdArc) || semTextEqId(textId, semTypeNameIdMutex) ||
                       semTextEqId(textId, semTypeNameIdRwLock) || semTextEqId(textId, semTypeNameIdAtomic):
                        if kidCount(base) > 1:
                            res = semTypeIsSend(kid(base, 1))
                        else:
                            res = true
                    else:
                        res = false
                else:
                    let name: str = semNodeNameNormalized(ctorNode)
                    if (name ==  "Arc") ||(name ==  "Mutex") ||(name ==  "RwLock") ||(name ==  "Atomic"):
                        if kidCount(base) > 1:
                            res = semTypeIsSend(kid(base, 1))
                        else:
                            res = true
                    else:
                        res = false
            else:
                let name: str = semNodeNameNormalized(ctorNode)
                if (name ==  "Arc") ||(name ==  "Mutex") ||(name ==  "RwLock") ||(name ==  "Atomic"):
                    if kidCount(base) > 1:
                        res = semTypeIsSend(kid(base, 1))
                    else:
                        res = true
                else:
                    res = false
        else:
            res = false
    elif nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol:
        let textId: int32 = semCanonicalTextId("", nodeIdentId(base))
        if textId > 0:
            semEnsureTypeNameTextIds()
            res = semTextEqId(textId, semTypeNameIdInt) || semTextEqId(textId, semTypeNameIdInt8) ||
                  semTextEqId(textId, semTypeNameIdInt16) || semTextEqId(textId, semTypeNameIdInt32) ||
                  semTextEqId(textId, semTypeNameIdInt64) || semTextEqId(textId, semTypeNameIdUint) ||
                  semTextEqId(textId, semTypeNameIdUint8) || semTextEqId(textId, semTypeNameIdUint16) ||
                  semTextEqId(textId, semTypeNameIdUint32) || semTextEqId(textId, semTypeNameIdUint64) ||
                  semTextEqId(textId, semTypeNameIdFloat) || semTextEqId(textId, semTypeNameIdFloat32) ||
                  semTextEqId(textId, semTypeNameIdFloat64) || semTextEqId(textId, semTypeNameIdBool) ||
                  semTextEqId(textId, semTypeNameIdChar) || semTextEqId(textId, semTypeNameIdChanI32) ||
                  semTextEqId(textId, semTypeNameIdArc) || semTextEqId(textId, semTypeNameIdMutex) ||
                  semTextEqId(textId, semTypeNameIdRwLock) || semTextEqId(textId, semTypeNameIdAtomic)
        else:
            let name: str = semIdentNameNormalized(base)
            if (name ==  "int") ||(name ==  "int8") ||(name ==  "int16") ||(name ==  "int32") ||(name ==  "int64"):
                res = true
            elif (name ==  "uint") ||(name ==  "uint8") ||(name ==  "uint16") ||(name ==  "uint32") ||(name ==  "uint64"):
                res = true
            elif (name ==  "float") ||(name ==  "float32") ||(name ==  "float64"):
                res = true
            elif (name ==  "bool") ||(name ==  "char"):
                res = true
            elif name ==  "chan_i32":
                res = true
            elif (name ==  "Arc") ||(name ==  "Mutex") ||(name ==  "RwLock") ||(name ==  "Atomic"):
                res = true
            else:
                res = false
    else:
        res = false
    if astNodeIdValid(typeId):
        let cacheIdx2: int32 = typeId
        if cacheIdx2 >= 0 && cacheIdx2 < semTypeSendReady.len && cacheIdx2 < semTypeSendValue.len:
            semTypeSendReady[cacheIdx2] = true
            semTypeSendValue[cacheIdx2] = res
    return res

fn semSendDefine(ctx: var SemCtx, name: str, sendable: bool) =
    semSendDefineNormalizedWithTextId(ctx, semNormalizeName(name), 0, sendable)

fn semSendFindIndexNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32): int32 =
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if semSendFindRecentValid && semSendFindRecentEpoch == semSendEpoch:
        if queryTextId > 0 && queryTextId == semSendFindRecentTextId:
            return semSendFindRecentResult
        if queryTextId <= 0 && nm != "" && nm == semSendFindRecentName:
            return semSendFindRecentResult
    if queryTextId > 0:
        var foundText: bool
        let idxPlus1Text: int32 = semSendTextIndexGet(queryTextId, foundText)
        if foundText:
            let outText: int32 = idxPlus1Text > 0 ? (idxPlus1Text - 1) : -1
            semSendFindRecentEpoch = semSendEpoch
            semSendFindRecentTextId = queryTextId
            semSendFindRecentName = nm
            semSendFindRecentResult = outText
            semSendFindRecentValid = true
            return outText
    if (nm ==  "") ||(nm ==  "_"):
        return -1
    if ctx.sendNames.len <= 0:
        if queryTextId > 0:
            semSendTextIndexPut(queryTextId, 0)
            if textId > 0 && queryTextId != textId:
                semSendTextIndexPut(textId, 0)
        semSendFindRecentEpoch = semSendEpoch
        semSendFindRecentTextId = queryTextId
        semSendFindRecentName = nm
        semSendFindRecentResult = -1
        semSendFindRecentValid = true
        return -1
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.sendIndex, nm, found)
    if found && idxPlus1 > 0:
        if queryTextId > 0:
            semSendTextIndexPut(queryTextId, idxPlus1)
            if textId > 0 && queryTextId != textId:
                semSendTextIndexPut(textId, idxPlus1)
        let outDirect: int32 = idxPlus1 - 1
        semSendFindRecentEpoch = semSendEpoch
        semSendFindRecentTextId = queryTextId
        semSendFindRecentName = nm
        semSendFindRecentResult = outDirect
        semSendFindRecentValid = true
        return outDirect
    let __for_start_si = ctx.sendNames.len - 1
    for __for_rev_si in 0..(__for_start_si):
        let si = __for_start_si - __for_rev_si
        if si < 0 || si >= ctx.sendNames.len:
            break
        if queryTextId > 0:
            if semReadI32(ctx.sendTextIds, si) == queryTextId:
                semSendTextIndexPut(queryTextId, si + 1)
                if textId > 0 && queryTextId != textId:
                    semSendTextIndexPut(textId, si + 1)
                semSendFindRecentEpoch = semSendEpoch
                semSendFindRecentTextId = queryTextId
                semSendFindRecentName = nm
                semSendFindRecentResult = si
                semSendFindRecentValid = true
                return si
        elif semReadStr(ctx.sendNames, si) == nm:
            hashmaps.HashMapStrIntPut(ctx.sendIndex, nm, si + 1)
            semSendFindRecentEpoch = semSendEpoch
            semSendFindRecentTextId = queryTextId
            semSendFindRecentName = nm
            semSendFindRecentResult = si
            semSendFindRecentValid = true
            return si
    if queryTextId > 0:
        semSendTextIndexPut(queryTextId, 0)
        if textId > 0 && queryTextId != textId:
            semSendTextIndexPut(textId, 0)
    semSendFindRecentEpoch = semSendEpoch
    semSendFindRecentTextId = queryTextId
    semSendFindRecentName = nm
    semSendFindRecentResult = -1
    semSendFindRecentValid = true
    return -1

fn semSendDefineNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32, sendable: bool) =
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if (nameNorm ==  "") ||(nameNorm ==  "_"):
        return
    let nameTextId: int32 = semCanonicalTextId(nameNorm, textId)
    var foundText: bool
    let prevTextIndexPlus1: int32 = semSendTextIndexGet(nameTextId, foundText)
    var found: bool
    var prevIndexPlus1: int32
    if nameTextId > 0:
        if foundText && prevTextIndexPlus1 > 0:
            found = true
            prevIndexPlus1 = prevTextIndexPlus1
    else:
        prevIndexPlus1 = hashmaps.HashMapStrIntGetEx(ctx.sendIndex, nameNorm, found)
    let idx: int32 = ctx.sendNames.len
    if found:
        semAddInt32(ctx.sendPrevIndexPlus1, prevIndexPlus1)
    else:
        semAddInt32(ctx.sendPrevIndexPlus1, int32(0))
    semAddStr(ctx.sendNames, nameNorm)
    semAddInt32(ctx.sendTextIds, nameTextId)
    var flag: int32
    if sendable:
        flag = 1
    semAddInt32(ctx.sendFlags, flag)
    if foundText && prevTextIndexPlus1 > 0:
        semAddInt32(ctx.sendPrevTextIndexPlus1, prevTextIndexPlus1)
    else:
        semAddInt32(ctx.sendPrevTextIndexPlus1, int32(0))
    if nameTextId <= 0:
        hashmaps.HashMapStrIntPut(ctx.sendIndex, nameNorm, idx + 1)
    semSendTextIndexPut(nameTextId, idx + 1)
    if textId > 0 && nameTextId != textId:
        semSendTextIndexPut(textId, idx + 1)
    semSendEpoch = semSendEpoch + 1

fn semSendDefineNormalized(ctx: var SemCtx, nm: str, sendable: bool) =
    semSendDefineNormalizedWithTextId(ctx, nm, 0, sendable)

fn semSendSet(ctx: var SemCtx, name: str, sendable: bool) =
    let nm: str = semNormalizeName(name)
    semSendSetNormalizedWithTextId(ctx, nm, 0, sendable)

fn semSendSetNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32, sendable: bool) =
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if (nameNorm ==  "") ||(nameNorm ==  "_"):
        return
    var flag: int32
    if sendable:
        flag = 1
    let idx: int32 = semSendFindIndexNormalizedWithTextId(ctx, nameNorm, textId)
    if idx >= 0 && idx < ctx.sendFlags.len:
        semWriteI32(ctx.sendFlags, idx, flag)
        semSendEpoch = semSendEpoch + 1
        return
    semSendEpoch = semSendEpoch + 1

fn semSendIsActive(ctx: var SemCtx, name: str): bool =
    return semSendIsActiveNormalized(ctx, semNormalizeName(name))

fn semSendIsActiveNormalized(ctx: var SemCtx, nm: str): bool =
    return semSendIsActiveNormalizedWithTextId(ctx, nm, 0)

fn semSendIsActiveNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32): bool =
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if queryTextId > 0:
        var foundText: bool
        let activeText: bool = semSendIsActiveTextCached(ctx, queryTextId, foundText)
        if foundText:
            return activeText
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if (nameNorm ==  "") ||(nameNorm ==  "_"):
        return false
    let idx: int32 = semSendFindIndexNormalizedWithTextId(ctx, nameNorm, queryTextId)
    if idx >= 0 && idx < ctx.sendFlags.len:
        return semReadI32(ctx.sendFlags, idx) != 0
    return false

fn semSendMarkPattern(ctx: var SemCtx, pat: Node, sendable: bool) =
    if stage1AstRefIsNil(pat):
        return
    case nodeKind(pat)
    of nkPattern:
        if kidCount(pat) > 0:
            semSendMarkPattern(ctx, kid(pat, 0), sendable)
    of nkCallArg:
        if kidCount(pat) > 1:
            semSendMarkPattern(ctx, kid(pat, 1), sendable)
    of nkIdent, nkSymbol:
        let textId: int32 = semCanonicalTextId("", nodeIdentId(pat))
        if textId > 0:
            semSendDefineNormalizedWithTextId(ctx, "", textId, sendable)
        else:
            semSendDefineNormalizedWithTextId(ctx, semIdentNameNormalized(pat), textId, sendable)
    of nkTupleLit, nkSeqLit, nkBracket:
        for i in 0..<kidCount(pat):
            semSendMarkPattern(ctx, kid(pat, i), sendable)
    of nkCall:
        for ci in 1..<kidCount(pat):
            let arg: Node = kid(pat, ci)
            if stage1AstRefNonNil(arg) && nodeKind(arg) == nkCallArg && kidCount(arg) > 1:
                semSendMarkPattern(ctx, kid(arg, 1), sendable)
            else:
                semSendMarkPattern(ctx, arg, sendable)
    of nkPar:
        if kidCount(pat) == 1:
            semSendMarkPattern(ctx, kid(pat, 0), sendable)
    else:
        return
fn semMarkParamSend(ctx: var SemCtx, fp: Node) =
    if stage1AstRefIsNil(fp):
        return
    if nodeKind(fp) != nkFormalParams:
        return
    for i in 0..<kidCount(fp):
        let defs: Node = kid(fp, i)
        if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount(defs) >= 2:
            let typeNode: Node = identDefsType(defs)
            let sendable: bool = semTypeIsSend(typeNode)
            let namesN: int32 = identDefsNameCount(defs)
            for j in 0..<namesN:
                let nameNode: Node = kid(defs, j)
                let textId: int32 = semCanonicalTextId("", nodeIdentId(nameNode))
                if textId > 0:
                    semSendDefineNormalizedWithTextId(ctx, "", textId, sendable)
                else:
                    semSendDefineNormalizedWithTextId(ctx, semIdentNameNormalized(nameNode), textId, sendable)

fn semIsSendCtorCallName(name: str): bool =
    return (semCallNameFlagsOfNormalized(name) & semCallNameFlagSendCtor) != 0

fn semExprIsSend(ctx: var SemCtx, n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    let nId: AstNodeId = astNodeIndex(n)
    if astNodeIdValid(nId):
        semEnsureExprSendCache(nId)
        let idx: int32 = nId
        if idx >= 0 && idx < semExprSendEpoch.len && idx < semExprFnSigEpoch.len && idx < semExprSendValue.len:
            if semExprSendEpoch[idx] == semSendEpoch && semExprFnSigEpoch[idx] == semFnSigEpoch:
                return semExprSendValue[idx]
    let profKindOn: bool = semProfOn && (semProfExprSampleOn || semProfStmtSampleOn)
    var profStartNs: int64
    if profKindOn:
        profStartNs = cheng_monotime_ns()
    var res: bool
    case nodeKind(n)
    of nkIntLit, nkFloatLit, nkBoolLit, nkCharLit:
        res = true
    of nkNilLit:
        res = true
    of nkStrLit:
        res = false
    of nkIdent, nkSymbol:
        let textId: int32 = semCanonicalTextId("", nodeIdentId(n))
        let classMask: int32 = semIdentNameClassNormalized(n)
        if (classMask & semNameClassLiteral) != 0:
            res = true
        else:
            var foundText: bool
            let activeText: bool = semSendIsActiveTextCached(ctx, textId, foundText)
            if foundText && activeText:
                res = true
            elif semIdentFnSigFindCached(ctx, n) >= 0:
                res = true
            elif foundText:
                res = false
            else:
                if textId > 0:
                    res = semSendIsActiveNormalizedWithTextId(ctx, "", textId)
                else:
                    res = semSendIsActiveNormalizedWithTextId(ctx, semIdentNameNormalized(n), textId)
    of nkInfix, nkPrefix, nkPostfix:
        res = true
        for i in 1..<kidCount(n):
            if ! semExprIsSend(ctx, kid(n, i)):
                res = false
                break
    of nkPar:
        if kidCount(n) == 1:
            res = semExprIsSend(ctx, kid(n, 0))
        else:
            res = false
    of nkCallArg:
        if kidCount(n) > 1:
            res = semExprIsSend(ctx, kid(n, 1))
        else:
            res = false
    of nkTupleLit:
        res = true
        for ti in 0..<kidCount(n):
            if ! semExprIsSend(ctx, kid(n, ti)):
                res = false
                break
    of nkIfExpr, nkWhenExpr, nkCaseExpr:
        res = true
        for ci in 0..<kidCount(n):
            if ! semExprIsSend(ctx, kid(n, ci)):
                res = false
                break
    of nkCall:
        let callInfo: SemCallInfo = semCallInfoNormalized(n)
        if semCallInfoHasName(callInfo):
            if (callInfo.flags & semCallNameFlagSendCtor) != 0:
                res = true
            elif semCallInfoNameMatches(callInfo, semCallNameIdAddr, "__addr"):
                if kidCount(n) > 1:
                    let target: Node = semCallArgValue(kid(n, 1))
                    if stage1AstRefNonNil(target) &&(nodeKind(target) == nkIdent || nodeKind(target) == nkSymbol):
                        res = semIdentFnSigFindCached(ctx, target) >= 0
                    else:
                        res = false
                else:
                    res = false
            else:
                res = false
        else:
            res = false
    else:
        res = false
    if profKindOn:
        semProfRecordSendKind(nodeKind(n), cheng_monotime_ns() - profStartNs)
    if astNodeIdValid(nId):
        let idx2: int32 = nId
        if idx2 >= 0 && idx2 < semExprSendEpoch.len && idx2 < semExprFnSigEpoch.len && idx2 < semExprSendValue.len:
            semExprSendEpoch[idx2] = semSendEpoch
            semExprFnSigEpoch[idx2] = semFnSigEpoch
            semExprSendValue[idx2] = res
    return res

fn semFnHasAnnotation(n: Node, annName: str): bool =
    if stage1AstRefIsNil(n):
        return false
    if nodeKind(n) != nkFnDecl && nodeKind(n) != nkIteratorDecl:
        return false
    if kidCount(n) <= 5:
        return false
    let pragmas: Node = kid(n, 5)
    if stage1AstRefIsNil(pragmas) || nodeKind(pragmas) != nkPragma:
        return false
    for i in 0..<kidCount(pragmas):
        let a: Node = kid(pragmas, i)
        if stage1AstRefNonNil(a) && nodeKind(a) == nkAnnotation && kidCount(a) > 0:
            let annNode: Node = kid(a, 0)
            let annTextId: int32 = semCanonicalTextId("", nodeIdentId(annNode))
            if annTextId > 0:
                if tokenTextEqLitId(annTextId, annName):
                    return true
            else:
                let name: str = semNodeNameNormalized(annNode)
                if name == annName:
                    return true
    return false

fn semBorrowAllowAddWithTextId(ctx: var SemCtx, name: str, textId: int32) =
    var nm: str
    if textId <= 0:
        nm = semNormalizeName(name)
    semBorrowAllowAddNormalizedWithTextId(ctx, nm, textId)

fn semBorrowAllowAddNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32) =
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if (nameNorm ==  ""):
        return
    let nameTextId: int32 = semCanonicalTextId(nameNorm, textId)
    semBorrowAllowTextPut(nameTextId, true)
    if textId > 0 && nameTextId != textId:
        semBorrowAllowTextPut(textId, true)
    let ptrKey: int64 = semStrPtrKey(nameNorm)
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(ctx.borrowAllowPtrIndex, ptrKey, foundPtr)
        if foundPtr && idxPlus1Ptr > 0:
            return
    var existed: bool
    let idx: int32 = hashmaps.HashMapStrIntGetOrInsertEx(ctx.borrowAllowIndex, nameNorm, ctx.borrowAllowNames.len + 1, existed)
    if existed && idx > 0:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(ctx.borrowAllowPtrIndex, ptrKey, idx)
        return
    let storedIdx: int32 = ctx.borrowAllowNames.len + 1
    hashmaps.HashMapStrIntPut(ctx.borrowAllowIndex, nameNorm, storedIdx)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.borrowAllowPtrIndex, ptrKey, storedIdx)
    semAddStr(ctx.borrowAllowNames, nameNorm)
    semBorrowQueryEpochBump()

fn semBorrowAllowAdd(ctx: var SemCtx, name: str) =
    semBorrowAllowAddWithTextId(ctx, name, 0)

fn semBorrowEscapeAddWithTextId(ctx: var SemCtx, name: str, textId: int32) =
    var nm: str
    if textId <= 0:
        nm = semNormalizeName(name)
    semBorrowEscapeAddNormalizedWithTextId(ctx, nm, textId)

fn semBorrowEscapeAddNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32) =
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if (nameNorm ==  ""):
        return
    let nameTextId: int32 = semCanonicalTextId(nameNorm, textId)
    semBorrowEscapeTextPut(nameTextId, true)
    if textId > 0 && nameTextId != textId:
        semBorrowEscapeTextPut(textId, true)
    let ptrKey: int64 = semStrPtrKey(nameNorm)
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(ctx.borrowEscapePtrIndex, ptrKey, foundPtr)
        if foundPtr && idxPlus1Ptr > 0:
            return
    var existed: bool
    let idx: int32 = hashmaps.HashMapStrIntGetOrInsertEx(ctx.borrowEscapeIndex, nameNorm, ctx.borrowEscapeNames.len + 1, existed)
    if existed && idx > 0:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(ctx.borrowEscapePtrIndex, ptrKey, idx)
        return
    let storedIdx: int32 = ctx.borrowEscapeNames.len + 1
    hashmaps.HashMapStrIntPut(ctx.borrowEscapeIndex, nameNorm, storedIdx)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.borrowEscapePtrIndex, ptrKey, storedIdx)
    semAddStr(ctx.borrowEscapeNames, nameNorm)
    semBorrowQueryEpochBump()

fn semBorrowEscapeAdd(ctx: var SemCtx, name: str) =
    semBorrowEscapeAddWithTextId(ctx, name, 0)

fn semIsBorrowAllowNameNormalized(ctx: var SemCtx, nm: str): bool =
    if nm == "":
        return false
    if ctx.borrowAllowNames.len <= 0:
        return false
    let ptrKey: int64 = semStrPtrKey(nm)
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(ctx.borrowAllowPtrIndex, ptrKey, foundPtr)
        if foundPtr:
            return idxPlus1Ptr > 0
    var found: bool
    let idx: int32 = hashmaps.HashMapStrIntGetEx(ctx.borrowAllowIndex, nm, found)
    if found && ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.borrowAllowPtrIndex, ptrKey, idx)
    if found:
        return idx > 0
    hashmaps.HashMapStrIntPut(ctx.borrowAllowIndex, nm, 0)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.borrowAllowPtrIndex, ptrKey, 0)
    return false

fn semIsBorrowAllowNameNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32): bool =
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if ctx.borrowAllowNames.len <= 0:
        if queryTextId > 0:
            semBorrowAllowTextPut(queryTextId, false)
            if textId > 0 && queryTextId != textId:
                semBorrowAllowTextPut(textId, false)
        return false
    if queryTextId > 0:
        var foundText: bool
        let okText: bool = semBorrowAllowTextGet(queryTextId, foundText)
        if foundText:
            return okText
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if nameNorm == "":
        return false
    let ok: bool = semIsBorrowAllowNameNormalized(ctx, nameNorm)
    if queryTextId > 0:
        semBorrowAllowTextPut(queryTextId, ok)
        if textId > 0 && queryTextId != textId:
            semBorrowAllowTextPut(textId, ok)
    return ok

fn semIsBorrowEscapeNameNormalized(ctx: var SemCtx, nm: str): bool =
    if nm == "":
        return false
    if ctx.borrowEscapeNames.len <= 0:
        return false
    let ptrKey: int64 = semStrPtrKey(nm)
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(ctx.borrowEscapePtrIndex, ptrKey, foundPtr)
        if foundPtr:
            return idxPlus1Ptr > 0
    var found: bool
    let idx: int32 = hashmaps.HashMapStrIntGetEx(ctx.borrowEscapeIndex, nm, found)
    if found && ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.borrowEscapePtrIndex, ptrKey, idx)
    if found:
        return idx > 0
    hashmaps.HashMapStrIntPut(ctx.borrowEscapeIndex, nm, 0)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.borrowEscapePtrIndex, ptrKey, 0)
    return false

fn semIsBorrowEscapeNameNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32): bool =
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if ctx.borrowEscapeNames.len <= 0:
        if queryTextId > 0:
            semBorrowEscapeTextPut(queryTextId, false)
            if textId > 0 && queryTextId != textId:
                semBorrowEscapeTextPut(textId, false)
        return false
    if queryTextId > 0:
        var foundText: bool
        let okText: bool = semBorrowEscapeTextGet(queryTextId, foundText)
        if foundText:
            return okText
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if nameNorm == "":
        return false
    let ok: bool = semIsBorrowEscapeNameNormalized(ctx, nameNorm)
    if queryTextId > 0:
        semBorrowEscapeTextPut(queryTextId, ok)
        if textId > 0 && queryTextId != textId:
            semBorrowEscapeTextPut(textId, ok)
    return ok

fn semNameHasQualifiedTail(nm: str, tail: str): bool =
    if nm == "" || tail == "":
        return false
    let n: int32 = len(nm)
    let t: int32 = len(tail)
    if n <= t:
        return false
    let dotIdx: int32 = n - t - 1
    if dotIdx < 0 || nm[dotIdx] != '.':
        return false
    for i in 0..<t:
        if nm[n - t + i] != tail[i]:
            return false
    return true

fn semTextHasQualifiedTail(textId: int32, tail: str): bool =
    if textId <= 0 || tail == "":
        return false
    let rawLen: int32 = tokenTextLen(textId)
    let tailLen: int32 = len(tail)
    if rawLen <= tailLen:
        return false
    let dotIdx: int32 = rawLen - tailLen - 1
    if dotIdx < 0 || tokenTextByteAtId(textId, dotIdx) != '.':
        return false
    for i in 0..<tailLen:
        if tokenTextByteAtId(textId, rawLen - tailLen + i) != tail[i]:
            return false
    return true

fn semTextHasPrefix(textId: int32, prefix: str): bool =
    if textId <= 0 || prefix == "":
        return false
    let prefixLen: int32 = len(prefix)
    if tokenTextLen(textId) < prefixLen:
        return false
    for i in 0..<prefixLen:
        if tokenTextByteAtId(textId, i) != prefix[i]:
            return false
    return true

fn semTextHasPrefixGetUnderscore(textId: int32): bool =
    return tokenTextLen(textId) >= 4 &&
           tokenTextByteAtId(textId, 0) == 'g' &&
           tokenTextByteAtId(textId, 1) == 'e' &&
           tokenTextByteAtId(textId, 2) == 't' &&
           tokenTextByteAtId(textId, 3) == '_'

fn semTextHasPrefixTableGet(textId: int32): bool =
    return tokenTextLen(textId) >= 8 &&
           tokenTextByteAtId(textId, 0) == 'T' &&
           tokenTextByteAtId(textId, 1) == 'a' &&
           tokenTextByteAtId(textId, 2) == 'b' &&
           tokenTextByteAtId(textId, 3) == 'l' &&
           tokenTextByteAtId(textId, 4) == 'e' &&
           tokenTextByteAtId(textId, 5) == 'G' &&
           tokenTextByteAtId(textId, 6) == 'e' &&
           tokenTextByteAtId(textId, 7) == 't'

fn semTextHasPrefixSeqGet(textId: int32): bool =
    return tokenTextLen(textId) >= 6 &&
           tokenTextByteAtId(textId, 0) == 'S' &&
           tokenTextByteAtId(textId, 1) == 'e' &&
           tokenTextByteAtId(textId, 2) == 'q' &&
           tokenTextByteAtId(textId, 3) == 'G' &&
           tokenTextByteAtId(textId, 4) == 'e' &&
           tokenTextByteAtId(textId, 5) == 't'

fn semTextHasPrefixStringView(textId: int32): bool =
    return tokenTextLen(textId) >= 10 &&
           tokenTextByteAtId(textId, 0) == 'S' &&
           tokenTextByteAtId(textId, 1) == 't' &&
           tokenTextByteAtId(textId, 2) == 'r' &&
           tokenTextByteAtId(textId, 3) == 'i' &&
           tokenTextByteAtId(textId, 4) == 'n' &&
           tokenTextByteAtId(textId, 5) == 'g' &&
           tokenTextByteAtId(textId, 6) == 'V' &&
           tokenTextByteAtId(textId, 7) == 'i' &&
           tokenTextByteAtId(textId, 8) == 'e' &&
           tokenTextByteAtId(textId, 9) == 'w'

fn semTextHasPrefixCUnderscore(textId: int32): bool =
    return tokenTextLen(textId) >= 2 &&
           tokenTextByteAtId(textId, 0) == 'c' &&
           tokenTextByteAtId(textId, 1) == '_'

fn semTextHasPrefixCheng(textId: int32): bool =
    return tokenTextLen(textId) >= 8 &&
           tokenTextByteAtId(textId, 0) == '_' &&
           tokenTextByteAtId(textId, 1) == '_' &&
           tokenTextByteAtId(textId, 2) == 'c' &&
           tokenTextByteAtId(textId, 3) == 'h' &&
           tokenTextByteAtId(textId, 4) == 'e' &&
           tokenTextByteAtId(textId, 5) == 'n' &&
           tokenTextByteAtId(textId, 6) == 'g' &&
           tokenTextByteAtId(textId, 7) == '_'

fn semTextHasQualifiedTailSpawn(textId: int32): bool =
    let rawLen: int32 = tokenTextLen(textId)
    return rawLen > 6 &&
           tokenTextByteAtId(textId, rawLen - 6) == '.' &&
           tokenTextByteAtId(textId, rawLen - 5) == 's' &&
           tokenTextByteAtId(textId, rawLen - 4) == 'p' &&
           tokenTextByteAtId(textId, rawLen - 3) == 'a' &&
           tokenTextByteAtId(textId, rawLen - 2) == 'w' &&
           tokenTextByteAtId(textId, rawLen - 1) == 'n'

fn semTextHasQualifiedTailChanI32Send(textId: int32): bool =
    let rawLen: int32 = tokenTextLen(textId)
    return rawLen > 12 &&
           tokenTextByteAtId(textId, rawLen - 12) == '.' &&
           tokenTextByteAtId(textId, rawLen - 11) == 'c' &&
           tokenTextByteAtId(textId, rawLen - 10) == 'h' &&
           tokenTextByteAtId(textId, rawLen - 9) == 'a' &&
           tokenTextByteAtId(textId, rawLen - 8) == 'n' &&
           tokenTextByteAtId(textId, rawLen - 7) == 'I' &&
           tokenTextByteAtId(textId, rawLen - 6) == '3' &&
           tokenTextByteAtId(textId, rawLen - 5) == '2' &&
           tokenTextByteAtId(textId, rawLen - 4) == 'S' &&
           tokenTextByteAtId(textId, rawLen - 3) == 'e' &&
           tokenTextByteAtId(textId, rawLen - 2) == 'n' &&
           tokenTextByteAtId(textId, rawLen - 1) == 'd'

fn semTextHasQualifiedTailChanI32Recv(textId: int32): bool =
    let rawLen: int32 = tokenTextLen(textId)
    return rawLen > 12 &&
           tokenTextByteAtId(textId, rawLen - 12) == '.' &&
           tokenTextByteAtId(textId, rawLen - 11) == 'c' &&
           tokenTextByteAtId(textId, rawLen - 10) == 'h' &&
           tokenTextByteAtId(textId, rawLen - 9) == 'a' &&
           tokenTextByteAtId(textId, rawLen - 8) == 'n' &&
           tokenTextByteAtId(textId, rawLen - 7) == 'I' &&
           tokenTextByteAtId(textId, rawLen - 6) == '3' &&
           tokenTextByteAtId(textId, rawLen - 5) == '2' &&
           tokenTextByteAtId(textId, rawLen - 4) == 'R' &&
           tokenTextByteAtId(textId, rawLen - 3) == 'e' &&
           tokenTextByteAtId(textId, rawLen - 2) == 'c' &&
           tokenTextByteAtId(textId, rawLen - 1) == 'v'

fn semTextIdIsThreadBoundaryRequired(textId: int32): bool =
    if textId <= 0:
        return false
    let rawLen: int32 = tokenTextLen(textId)
    if rawLen == 5 &&
       tokenTextByteAtId(textId, 0) == 's' &&
       tokenTextByteAtId(textId, 1) == 'p' &&
       tokenTextByteAtId(textId, 2) == 'a' &&
       tokenTextByteAtId(textId, 3) == 'w' &&
       tokenTextByteAtId(textId, 4) == 'n':
        return true
    if rawLen == 11 &&
       tokenTextByteAtId(textId, 0) == 'c' &&
       tokenTextByteAtId(textId, 1) == 'h' &&
       tokenTextByteAtId(textId, 2) == 'a' &&
       tokenTextByteAtId(textId, 3) == 'n' &&
       tokenTextByteAtId(textId, 4) == 'I' &&
       tokenTextByteAtId(textId, 5) == '3' &&
       tokenTextByteAtId(textId, 6) == '2' &&
       tokenTextByteAtId(textId, 7) == 'S' &&
       tokenTextByteAtId(textId, 8) == 'e' &&
       tokenTextByteAtId(textId, 9) == 'n' &&
       tokenTextByteAtId(textId, 10) == 'd':
        return true
    if rawLen == 11 &&
       tokenTextByteAtId(textId, 0) == 'c' &&
       tokenTextByteAtId(textId, 1) == 'h' &&
       tokenTextByteAtId(textId, 2) == 'a' &&
       tokenTextByteAtId(textId, 3) == 'n' &&
       tokenTextByteAtId(textId, 4) == 'I' &&
       tokenTextByteAtId(textId, 5) == '3' &&
       tokenTextByteAtId(textId, 6) == '2' &&
       tokenTextByteAtId(textId, 7) == 'R' &&
       tokenTextByteAtId(textId, 8) == 'e' &&
       tokenTextByteAtId(textId, 9) == 'c' &&
       tokenTextByteAtId(textId, 10) == 'v':
        return true
    if rawLen > 6 &&
       tokenTextByteAtId(textId, rawLen - 6) == '.' &&
       tokenTextByteAtId(textId, rawLen - 5) == 's' &&
       tokenTextByteAtId(textId, rawLen - 4) == 'p' &&
       tokenTextByteAtId(textId, rawLen - 3) == 'a' &&
       tokenTextByteAtId(textId, rawLen - 2) == 'w' &&
       tokenTextByteAtId(textId, rawLen - 1) == 'n':
        return true
    if rawLen > 12 &&
       tokenTextByteAtId(textId, rawLen - 12) == '.' &&
       tokenTextByteAtId(textId, rawLen - 11) == 'c' &&
       tokenTextByteAtId(textId, rawLen - 10) == 'h' &&
       tokenTextByteAtId(textId, rawLen - 9) == 'a' &&
       tokenTextByteAtId(textId, rawLen - 8) == 'n' &&
       tokenTextByteAtId(textId, rawLen - 7) == 'I' &&
       tokenTextByteAtId(textId, rawLen - 6) == '3' &&
       tokenTextByteAtId(textId, rawLen - 5) == '2' &&
       tokenTextByteAtId(textId, rawLen - 4) == 'S' &&
       tokenTextByteAtId(textId, rawLen - 3) == 'e' &&
       tokenTextByteAtId(textId, rawLen - 2) == 'n' &&
       tokenTextByteAtId(textId, rawLen - 1) == 'd':
        return true
    if rawLen > 12 &&
       tokenTextByteAtId(textId, rawLen - 12) == '.' &&
       tokenTextByteAtId(textId, rawLen - 11) == 'c' &&
       tokenTextByteAtId(textId, rawLen - 10) == 'h' &&
       tokenTextByteAtId(textId, rawLen - 9) == 'a' &&
       tokenTextByteAtId(textId, rawLen - 8) == 'n' &&
       tokenTextByteAtId(textId, rawLen - 7) == 'I' &&
       tokenTextByteAtId(textId, rawLen - 6) == '3' &&
       tokenTextByteAtId(textId, rawLen - 5) == '2' &&
       tokenTextByteAtId(textId, rawLen - 4) == 'R' &&
       tokenTextByteAtId(textId, rawLen - 3) == 'e' &&
       tokenTextByteAtId(textId, rawLen - 2) == 'c' &&
       tokenTextByteAtId(textId, rawLen - 1) == 'v':
        return true
    return false

fn semCallNameFlagsComputeNormalized(nm: str): int32 =
    if nm == "":
        return 0
    var flags: int32
    if nm == "share" || nm == "share_mt":
        flags = flags | semCallNameFlagShare
    if nm == "arcNew" || nm == "arcClone" || nm == "share_mt" || nm == "mutexNew" ||
       nm == "rwLockNew" || nm == "atomicNew" || nm == "chanI32New":
        flags = flags | semCallNameFlagSendCtor
    if nm == "spawn" || semNameHasQualifiedTail(nm, "spawn"):
        flags = flags | semCallNameFlagThreadBoundary
        flags = flags | semCallNameFlagSpawnBoundary
    if nm == "chanI32Send" || semNameHasQualifiedTail(nm, "chanI32Send"):
        flags = flags | semCallNameFlagThreadBoundary
    if nm == "chanI32Recv" || semNameHasQualifiedTail(nm, "chanI32Recv"):
        flags = flags | semCallNameFlagThreadBoundary
    if nm == "get" || nm == "getPointer" || nm == "dataPtr" || nm == "__addr":
        flags = flags | semCallNameFlagBorrowed
    elif semHasPrefix(nm, "get_") || semHasPrefix(nm, "TableGet") ||
         semHasPrefix(nm, "SeqGet") || semHasPrefix(nm, "StringView"):
        flags = flags | semCallNameFlagBorrowed
    if nm == "__addr" || nm == "dataPtr" || nm == "getPointer":
        flags = flags | semCallNameFlagExplicitPtr
    if (flags & semCallNameFlagExplicitPtr) != 0 ||
       nm == "ptr_add" || nm == "load_ptr" || nm == "store_ptr" ||
       nm == "copyMem" || nm == "setMem" || nm == "zeroMem" ||
       nm == "alloc" || nm == "dealloc":
        flags = flags | semCallNameFlagStdPointerOp
    if (flags & semCallNameFlagBorrowed) != 0 || semIsBorrowPassAllowedLibp2pCallName(nm):
        flags = flags | semCallNameFlagBorrowPassAllowed
    if nm == "IsOk" || nm == "IsErr" || nm == "Value" || nm == "Error" || nm == "ErrorInfoOf":
        flags = flags | semCallNameFlagBorrowPassAllowed
    if nm == "writeBytes" || nm == "runProtocol" || nm == "hostOpenProtocolStreamToAddressText":
        flags = flags | semCallNameFlagBorrowPassAllowed
    if nm == "getIpnsNamespacePolicy" || nm == "getIprsNamespacePolicy":
        flags = flags | semCallNameFlagBorrowPassAllowed
    if semHasPrefix(nm, "c_") || semHasPrefix(nm, "__cheng_"):
        flags = flags | semCallNameFlagBorrowPassAllowed
    if nm == "alloc" || nm == "realloc" || nm == "dealloc" ||
       nm == "ptr_add" || nm == "copyMem" || nm == "setMem" ||
       nm == "memRetain" || nm == "memRelease" || nm == "memRefCount" ||
       nm == "memRetainAtomic" || nm == "memReleaseAtomic" || nm == "memRefCountAtomic" ||
       nm == "atomicCasI32" || nm == "atomicStoreI32" || nm == "atomicLoadI32" ||
       nm == "addDiag":
        flags = flags | semCallNameFlagBorrowPassAllowed
    return flags

fn semCallNameFlagsComputeWithTextId(nm: str, textId: int32): int32 =
    if textId <= 0:
        return semCallNameFlagsComputeNormalized(nm)
    semEnsureCallNameTextIds()
    var flags: int32
    if semTextEqId(textId, semCallNameIdShare) || semTextEqId(textId, semCallNameIdShareMt):
        flags = flags | semCallNameFlagShare
    if semTextEqId(textId, semCallNameIdArcNew) || semTextEqId(textId, semCallNameIdArcClone) ||
       semTextEqId(textId, semCallNameIdShareMt) || semTextEqId(textId, semCallNameIdMutexNew) ||
       semTextEqId(textId, semCallNameIdRwLockNew) || semTextEqId(textId, semCallNameIdAtomicNew) ||
       semTextEqId(textId, semCallNameIdChanI32New):
        flags = flags | semCallNameFlagSendCtor
    if semTextEqId(textId, semCallNameIdSpawn) || semTextHasQualifiedTailSpawn(textId):
        flags = flags | semCallNameFlagThreadBoundary
        flags = flags | semCallNameFlagSpawnBoundary
    if semTextEqId(textId, semCallNameIdChanI32Send) || semTextHasQualifiedTailChanI32Send(textId):
        flags = flags | semCallNameFlagThreadBoundary
    if semTextEqId(textId, semCallNameIdChanI32Recv) || semTextHasQualifiedTailChanI32Recv(textId):
        flags = flags | semCallNameFlagThreadBoundary
    if semTextEqId(textId, semCallNameIdGet) || semTextEqId(textId, semCallNameIdGetPointer) ||
       semTextEqId(textId, semCallNameIdDataPtr) || semTextEqId(textId, semCallNameIdAddr):
        flags = flags | semCallNameFlagBorrowed
    elif semTextHasPrefixGetUnderscore(textId) || semTextHasPrefixTableGet(textId) ||
         semTextHasPrefixSeqGet(textId) || semTextHasPrefixStringView(textId):
        flags = flags | semCallNameFlagBorrowed
    if semTextEqId(textId, semCallNameIdAddr) || semTextEqId(textId, semCallNameIdDataPtr) ||
       semTextEqId(textId, semCallNameIdGetPointer):
        flags = flags | semCallNameFlagExplicitPtr
    if (flags & semCallNameFlagExplicitPtr) != 0 ||
       semTextEqId(textId, semCallNameIdPtrAdd) || semTextEqId(textId, semCallNameIdLoadPtr) ||
       semTextEqId(textId, semCallNameIdStorePtr) || semTextEqId(textId, semCallNameIdCopyMem) ||
       semTextEqId(textId, semCallNameIdSetMem) || semTextEqId(textId, semCallNameIdZeroMem) ||
       semTextEqId(textId, semCallNameIdAlloc) || semTextEqId(textId, semCallNameIdDealloc):
        flags = flags | semCallNameFlagStdPointerOp
    if (flags & semCallNameFlagBorrowed) != 0 || semIsBorrowPassAllowedLibp2pCallNameWithTextId(nm, textId):
        flags = flags | semCallNameFlagBorrowPassAllowed
    if semTextEqId(textId, semCallNameIdIsOk) || semTextEqId(textId, semCallNameIdIsErr) ||
       semTextEqId(textId, semCallNameIdValue) || semTextEqId(textId, semCallNameIdError) ||
       semTextEqId(textId, semCallNameIdErrorInfoOf):
        flags = flags | semCallNameFlagBorrowPassAllowed
    if semTextEqId(textId, semCallNameIdWriteBytes) || semTextEqId(textId, semCallNameIdRunProtocol) ||
       semTextEqId(textId, semCallNameIdHostOpenProtocolStreamToAddressText):
        flags = flags | semCallNameFlagBorrowPassAllowed
    if semTextEqId(textId, semCallNameIdGetIpnsNamespacePolicy) ||
       semTextEqId(textId, semCallNameIdGetIprsNamespacePolicy):
        flags = flags | semCallNameFlagBorrowPassAllowed
    if semTextHasPrefixCUnderscore(textId) || semTextHasPrefixCheng(textId):
        flags = flags | semCallNameFlagBorrowPassAllowed
    if semTextEqId(textId, semCallNameIdAlloc) || semTextEqId(textId, semCallNameIdRealloc) ||
       semTextEqId(textId, semCallNameIdDealloc) || semTextEqId(textId, semCallNameIdPtrAdd) ||
       semTextEqId(textId, semCallNameIdCopyMem) || semTextEqId(textId, semCallNameIdSetMem) ||
       semTextEqId(textId, semCallNameIdMemRetain) || semTextEqId(textId, semCallNameIdMemRelease) ||
       semTextEqId(textId, semCallNameIdMemRefCount) || semTextEqId(textId, semCallNameIdMemRetainAtomic) ||
       semTextEqId(textId, semCallNameIdMemReleaseAtomic) || semTextEqId(textId, semCallNameIdMemRefCountAtomic) ||
       semTextEqId(textId, semCallNameIdAtomicCasI32) || semTextEqId(textId, semCallNameIdAtomicStoreI32) ||
       semTextEqId(textId, semCallNameIdAtomicLoadI32) || semTextEqId(textId, semCallNameIdAddDiag):
        flags = flags | semCallNameFlagBorrowPassAllowed
    return flags

fn semCallNameFlagsOfNormalized(nm: str): int32 =
    if nm == "":
        return 0
    let ptrKey: int64 = semStrPtrKey(nm)
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(semCallNameFlagPtrIndex, ptrKey, foundPtr)
        if foundPtr && idxPlus1Ptr > 0 && idxPlus1Ptr <= semCallNameFlagValues.len:
            return semReadI32(semCallNameFlagValues, idxPlus1Ptr - 1)
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(semCallNameFlagIndex, nm, found)
    if found && idxPlus1 > 0 && idxPlus1 <= semCallNameFlagValues.len:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(semCallNameFlagPtrIndex, ptrKey, idxPlus1)
        return semReadI32(semCallNameFlagValues, idxPlus1 - 1)
    let flags: int32 = semCallNameFlagsComputeNormalized(nm)
    add(semCallNameFlagValues, flags)
    let storedIdx: int32 = semCallNameFlagValues.len
    hashmaps.HashMapStrIntPut(semCallNameFlagIndex, nm, storedIdx)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(semCallNameFlagPtrIndex, ptrKey, storedIdx)
    return flags

fn semCallNameFlagsOfNormalizedWithTextId(nm: str, textId: int32): int32 =
    if textId > 0:
        semEnsureCallNameFlagTextCache(textId)
        if textId < semCallNameFlagTextReady.len && textId < semCallNameFlagTextValue.len:
            if semCallNameFlagTextReady[textId]:
                return semCallNameFlagTextValue[textId]
        let flagsText: int32 = semCallNameFlagsComputeWithTextId(nm, textId)
        if textId < semCallNameFlagTextReady.len && textId < semCallNameFlagTextValue.len:
            semCallNameFlagTextReady[textId] = true
            semCallNameFlagTextValue[textId] = flagsText
        return flagsText
    return semCallNameFlagsOfNormalized(nm)

fn semIsThreadBoundaryRequiredNameNormalized(nm: str): bool =
    if nm == "":
        return false
    if nm == "spawn" || nm == "chanI32Send" || nm == "chanI32Recv":
        return true
    if semNameHasQualifiedTail(nm, "spawn"):
        return true
    if semNameHasQualifiedTail(nm, "chanI32Send"):
        return true
    if semNameHasQualifiedTail(nm, "chanI32Recv"):
        return true
    return false

fn semIsThreadBoundaryRequiredNameNormalizedWithTextId(nm: str, textId: int32): bool =
    if textId > 0:
        if semTextIdIsThreadBoundaryRequired(textId):
            return true
        return false
    return semIsThreadBoundaryRequiredNameNormalized(nm)

fn semIsBorrowedCallNameNormalizedWithCtx(ctx: var SemCtx, nm: str): bool =
    if semIsBorrowAllowNameNormalized(ctx, nm):
        return true
    return semIsBorrowedCallNameNormalized(nm)

fn semIsBorrowPassAllowedCallNameNormalizedWithCtx(ctx: var SemCtx, nm: str): bool =
    if nm == "":
        return false
    if semIsBorrowEscapeNameNormalized(ctx, nm):
        return false
    if semIsBorrowAllowNameNormalized(ctx, nm):
        return true
    return semIsBorrowPassAllowedCallNameNormalized(nm)

fn semThreadBoundaryAdd(ctx: var SemCtx, name: str) =
    let nm: str = semNormalizeName(name)
    semThreadBoundaryAddNormalizedWithTextId(ctx, nm, 0)

fn semThreadBoundaryAddNormalized(ctx: var SemCtx, nm: str) =
    semThreadBoundaryAddNormalizedWithTextId(ctx, nm, 0)

fn semThreadBoundaryAddNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32) =
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if (nameNorm ==  ""):
        return
    let nameTextId: int32 = semCanonicalTextId(nameNorm, textId)
    semThreadBoundaryTextPut(nameTextId, true)
    if textId > 0 && nameTextId != textId:
        semThreadBoundaryTextPut(textId, true)
    let ptrKey: int64 = semStrPtrKey(nameNorm)
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(ctx.threadBoundaryPtrIndex, ptrKey, foundPtr)
        if foundPtr && idxPlus1Ptr > 0:
            return
    var existed: bool
    let idx: int32 = hashmaps.HashMapStrIntGetOrInsertEx(ctx.threadBoundaryIndex, nameNorm, ctx.threadBoundaryNames.len + 1, existed)
    if existed && idx > 0:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(ctx.threadBoundaryPtrIndex, ptrKey, idx)
        return
    let storedIdx: int32 = ctx.threadBoundaryNames.len + 1
    hashmaps.HashMapStrIntPut(ctx.threadBoundaryIndex, nameNorm, storedIdx)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.threadBoundaryPtrIndex, ptrKey, storedIdx)
    semAddStr(ctx.threadBoundaryNames, nameNorm)

fn semIsThreadBoundaryName(ctx: var SemCtx, name: str): bool =
    let nm: str = semNormalizeName(name)
    return semIsThreadBoundaryNormalizedWithTextId(ctx, nm, 0)

fn semIsThreadBoundaryNormalized(ctx: var SemCtx, nm: str): bool =
    return semIsThreadBoundaryNormalizedWithTextId(ctx, nm, 0)

fn semIsThreadBoundaryNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32): bool =
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if queryTextId > 0:
        var foundText: bool
        let okText: bool = semThreadBoundaryTextGet(queryTextId, foundText)
        if foundText:
            return okText
        semEnsureCallNameTextIds()
        if semTextEqId(queryTextId, semCallNameIdSpawn) || semTextEqId(queryTextId, semCallNameIdChanI32Send) ||
           semTextEqId(queryTextId, semCallNameIdChanI32Recv):
            semThreadBoundaryTextPut(queryTextId, true)
            if textId > 0 && queryTextId != textId:
                semThreadBoundaryTextPut(textId, true)
            return true
    if ctx.threadBoundaryNames.len <= 3:
        if queryTextId > 0:
            semThreadBoundaryTextPut(queryTextId, false)
            if textId > 0 && queryTextId != textId:
                semThreadBoundaryTextPut(textId, false)
        return false
    let nameNorm: str = semNormalizedNameFromTextId(nm, queryTextId)
    if nameNorm == "":
        return false
    let ptrKey: int64 = semStrPtrKey(nameNorm)
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(ctx.threadBoundaryPtrIndex, ptrKey, foundPtr)
        if foundPtr:
            let okPtr: bool = idxPlus1Ptr > 0
            if queryTextId > 0:
                semThreadBoundaryTextPut(queryTextId, okPtr)
                if textId > 0 && queryTextId != textId:
                    semThreadBoundaryTextPut(textId, okPtr)
            return okPtr
    var found: bool
    let idx: int32 = hashmaps.HashMapStrIntGetEx(ctx.threadBoundaryIndex, nameNorm, found)
    if found:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(ctx.threadBoundaryPtrIndex, ptrKey, idx)
        let ok: bool = idx > 0
        if queryTextId > 0:
            semThreadBoundaryTextPut(queryTextId, ok)
            if textId > 0 && queryTextId != textId:
                semThreadBoundaryTextPut(textId, ok)
        return ok
    hashmaps.HashMapStrIntPut(ctx.threadBoundaryIndex, nameNorm, 0)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.threadBoundaryPtrIndex, ptrKey, 0)
    if queryTextId > 0:
        semThreadBoundaryTextPut(queryTextId, false)
        if textId > 0 && queryTextId != textId:
            semThreadBoundaryTextPut(textId, false)
    return false

fn semGenericScopePush(ctx: var SemCtx) =
    semAddInt32(ctx.genericParamScopeStarts, ctx.genericParamNames.len)
    semAddInt32(ctx.genericValueParamScopeStarts, ctx.genericValueParamNames.len)

fn semGenericScopePop(ctx: var SemCtx) =
    if ctx.genericParamScopeStarts.len > 0:
        let start: int32 = semReadI32(ctx.genericParamScopeStarts, ctx.genericParamScopeStarts.len - 1)
        let oldLen: int32 = ctx.genericParamNames.len
        let __for_start_gi = oldLen - 1
        for __for_rev_gi in 0..(__for_start_gi - (start)):
            let gi = __for_start_gi - __for_rev_gi
            let gname: str = semReadStr(ctx.genericParamNames, gi)
            let prevIndexPlus1: int32 = semReadI32(ctx.genericParamPrevIndexPlus1, gi)
            hashmaps.HashMapStrIntPut(ctx.genericParamIndex, gname, prevIndexPlus1)
        ctx.genericParamScopeStarts.len = ctx.genericParamScopeStarts.len - 1
        ctx.genericParamNames.len = start
        ctx.genericParamTextIds.len = start
        ctx.genericParamPrevIndexPlus1.len = start
    if ctx.genericValueParamScopeStarts.len > 0:
        let start2: int32 = semReadI32(ctx.genericValueParamScopeStarts, ctx.genericValueParamScopeStarts.len - 1)
        let oldLen2: int32 = ctx.genericValueParamNames.len
        let __for_start_gi2 = oldLen2 - 1
        for __for_rev_gi2 in 0..(__for_start_gi2 - (start2)):
            let gi2 = __for_start_gi2 - __for_rev_gi2
            let gname2: str = semReadStr(ctx.genericValueParamNames, gi2)
            let prevIndexPlus1b: int32 = semReadI32(ctx.genericValueParamPrevIndexPlus1, gi2)
            hashmaps.HashMapStrIntPut(ctx.genericValueParamIndex, gname2, prevIndexPlus1b)
        ctx.genericValueParamScopeStarts.len = ctx.genericValueParamScopeStarts.len - 1
        ctx.genericValueParamNames.len = start2
        ctx.genericValueParamTextIds.len = start2
        ctx.genericValueParamPrevIndexPlus1.len = start2
    semGenericParamEpochBump()

fn semGenericParamAddWithTextId(ctx: var SemCtx, name: str, textId: int32) =
    let rawTextId: int32 = semCanonicalTextId("", textId)
    let nm: str = semNormalizedTextIdOrName(rawTextId, name)
    if (nm ==  ""):
        return
    let nameTextId: int32 = semCanonicalTextId(nm, rawTextId)
    var found: bool
    let prevIndexPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.genericParamIndex, nm, found)
    let idx: int32 = ctx.genericParamNames.len
    if found:
        semAddInt32(ctx.genericParamPrevIndexPlus1, prevIndexPlus1)
    else:
        semAddInt32(ctx.genericParamPrevIndexPlus1, int32(0))
    semAddStr(ctx.genericParamNames, nm)
    semAddInt32(ctx.genericParamTextIds, nameTextId)
    hashmaps.HashMapStrIntPut(ctx.genericParamIndex, nm, idx + 1)
    semGenericParamEpochBump()

fn semGenericParamAdd(ctx: var SemCtx, name: str) =
    semGenericParamAddWithTextId(ctx, name, 0)

fn semGenericValueParamAdd(ctx: var SemCtx, name: str) =
    semGenericValueParamAddWithTextId(ctx, name, 0)

fn semGenericValueParamAddWithTextId(ctx: var SemCtx, name: str, textId: int32) =
    let rawTextId: int32 = semCanonicalTextId("", textId)
    let nm: str = semNormalizedTextIdOrName(rawTextId, name)
    if (nm ==  ""):
        return
    let nameTextId: int32 = semCanonicalTextId(nm, rawTextId)
    var found: bool
    let prevIndexPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.genericValueParamIndex, nm, found)
    let idx: int32 = ctx.genericValueParamNames.len
    if found:
        semAddInt32(ctx.genericValueParamPrevIndexPlus1, prevIndexPlus1)
    else:
        semAddInt32(ctx.genericValueParamPrevIndexPlus1, int32(0))
    semAddStr(ctx.genericValueParamNames, nm)
    semAddInt32(ctx.genericValueParamTextIds, nameTextId)
    hashmaps.HashMapStrIntPut(ctx.genericValueParamIndex, nm, idx + 1)

fn semIsGenericParamName(ctx: var SemCtx, name: str): bool =
    return semIsGenericParamNameNormalized(ctx, semNormalizeName(name))

fn semIsGenericParamNameNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32): bool =
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if queryTextId > 0:
        semEnsureGenericParamTextCache(queryTextId)
        if queryTextId < semGenericParamTextEpoch.len && queryTextId < semGenericParamTextValue.len:
            if semGenericParamTextEpoch[queryTextId] == semGenericParamEpoch:
                return semGenericParamTextValue[queryTextId]
        var foundText: bool
        if ctx.genericParamTextIds.len > 0:
            let __for_start_gti = ctx.genericParamTextIds.len - 1
            for __for_rev_gti in 0..(__for_start_gti):
                let i = __for_start_gti - __for_rev_gti
                if semReadI32(ctx.genericParamTextIds, i) == queryTextId:
                    foundText = true
                    break
        var res: bool = foundText
        if !res && nm != "":
            var found: bool
            let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.genericParamIndex, nm, found)
            res = found && idxPlus1 > 0
        if queryTextId < semGenericParamTextEpoch.len && queryTextId < semGenericParamTextValue.len:
            semGenericParamTextEpoch[queryTextId] = semGenericParamEpoch
            semGenericParamTextValue[queryTextId] = res
        return res
    return semIsGenericParamNameNormalized(ctx, nm)

fn semIsGenericParamNameNormalized(ctx: var SemCtx, nm: str): bool =
    if (nm ==  ""):
        return false
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.genericParamIndex, nm, found)
    return found && idxPlus1 > 0

fn semIsGenericValueParam(ctx: var SemCtx, name: str): bool =
    let nm: str = semNormalizeName(name)
    if (nm ==  ""):
        return false
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.genericValueParamIndex, nm, found)
    return found && idxPlus1 > 0

fn semIsGenericValueParamWithTextId(ctx: var SemCtx, name: str, textId: int32): bool =
    let queryTextId: int32 = semCanonicalTextId(name, textId)
    if queryTextId > 0:
        semEnsureGenericValueParamTextCache(queryTextId)
        if queryTextId < semGenericValueParamTextEpoch.len && queryTextId < semGenericValueParamTextValue.len:
            if semGenericValueParamTextEpoch[queryTextId] == semGenericParamEpoch:
                return semGenericValueParamTextValue[queryTextId]
        var foundText: bool
        if ctx.genericValueParamTextIds.len > 0:
            let __for_start_gti = ctx.genericValueParamTextIds.len - 1
            for __for_rev_gti in 0..(__for_start_gti):
                let i = __for_start_gti - __for_rev_gti
                if semReadI32(ctx.genericValueParamTextIds, i) == queryTextId:
                    foundText = true
                    break
        if queryTextId < semGenericValueParamTextEpoch.len && queryTextId < semGenericValueParamTextValue.len:
            semGenericValueParamTextEpoch[queryTextId] = semGenericParamEpoch
            semGenericValueParamTextValue[queryTextId] = foundText
        if foundText:
            return true
        if name == "":
            return false
        let nm: str = semNormalizedNameFromTextId(name, queryTextId)
        if nm == "":
            return false
        var found: bool
        let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.genericValueParamIndex, nm, found)
        let res: bool = found && idxPlus1 > 0
        if queryTextId < semGenericValueParamTextEpoch.len && queryTextId < semGenericValueParamTextValue.len:
            semGenericValueParamTextEpoch[queryTextId] = semGenericParamEpoch
            semGenericValueParamTextValue[queryTextId] = res
        return res
    return semIsGenericValueParam(ctx, name)

fn semIsGenericValueParamNode(ctx: var SemCtx, n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return false
    let textId: int32 = semCanonicalTextId("", nodeIdentId(n))
    if textId > 0:
        return semIsGenericValueParamWithTextId(ctx, "", textId)
    return semIsGenericValueParam(ctx, semNodeNameNormalized(n))

fn semIsGenericParamType(ctx: var SemCtx, typeNode: Node): bool =
    if stage1AstRefIsNil(typeNode):
        return false
    let typeId: AstNodeId = astNodeIndex(typeNode)
    if astNodeIdValid(typeId):
        semEnsureGenericParamTypeCache(typeId)
        let idx: int32 = typeId
        if idx >= 0 && idx < semGenericParamTypeEpoch.len && idx < semGenericParamTypeValue.len:
            if semGenericParamTypeEpoch[idx] == semScopeEpoch:
                return semGenericParamTypeValue[idx]
    var res: bool
    if nodeKind(typeNode) == nkIdent || nodeKind(typeNode) == nkSymbol:
        let textId: int32 = nodeIdentId(typeNode)
        if textId > 0:
            res = semIsGenericParamNameNormalizedWithTextId(ctx, "", textId)
        else:
            res = semIsGenericParamNameNormalized(ctx, semIdentNameNormalized(typeNode))
    if astNodeIdValid(typeId):
        let idx2: int32 = typeId
        if idx2 >= 0 && idx2 < semGenericParamTypeEpoch.len && idx2 < semGenericParamTypeValue.len:
            semGenericParamTypeEpoch[idx2] = semScopeEpoch
            semGenericParamTypeValue[idx2] = res
    return res

fn semFnSigAddWithTextId(ctx: var SemCtx, name: str, textId: int32, paramsNode: Node) =
    var nm: str
    if textId <= 0:
        nm = semNormalizeName(name)
    semFnSigAddNormalizedWithTextId(ctx, nm, textId, paramsNode)

fn semFnSigAddNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32, paramsNode: Node) =
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if (nameNorm ==  ""):
        return
    let nameTextId: int32 = semCanonicalTextId(nameNorm, textId)
    let off: int32 = ctx.fnSigParamNames.len
    var count: int32
    var hasVar: int32
    var hasNonPtr: int32
    if stage1AstRefNonNil(paramsNode) && nodeKind(paramsNode) == nkFormalParams:
        for i in 0..<kidCount(paramsNode):
            let defs: Node = kid(paramsNode, i)
            if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount(defs) >= 2:
                let typeNode: Node = identDefsType(defs)
                var isVar: int32
                if semIsVarTypeNode(typeNode):
                    isVar = 1
                var isPtrLike: int32
                if semIsPtrLikeTypeNode(typeNode):
                    isPtrLike = 1
                if isVar != 0:
                    hasVar = 1
                if isPtrLike == 0:
                    hasNonPtr = 1
                let namesN: int32 = identDefsNameCount(defs)
                for j in 0..<namesN:
                    let pnameNode: Node = kid(defs, j)
                    let pnameTextId: int32 = nodeIdentId(pnameNode)
                    var pname: str
                    if pnameTextId > 0:
                        pname = semNormalizedNameFromTextId("", pnameTextId)
                    else:
                        pname = semNodeNameNormalized(pnameNode)
                    if pname != "":
                        let pnameCanonTextId: int32 = semCanonicalTextId(pname, pnameTextId)
                        semAddStr(ctx.fnSigParamNames, pname)
                        semAddInt32(ctx.fnSigParamTextIds, pnameCanonTextId)
                        semAddInt32(ctx.fnSigParamIsVar, isVar)
                        semAddInt32(ctx.fnSigParamIsPtrLike, isPtrLike)
                        count = count + 1
    semAddStr(ctx.fnSigNames, nameNorm)
    semAddInt32(ctx.fnSigTextIds, nameTextId)
    semAddInt32(ctx.fnSigParamOffsets, off)
    semAddInt32(ctx.fnSigParamCounts, count)
    semAddInt32(ctx.fnSigHasVar, hasVar)
    semAddInt32(ctx.fnSigHasNonPtr, hasNonPtr)
    let sigIdx: int32 = ctx.fnSigNames.len - 1
    let ptrKey: int64 = semStrPtrKey(nameNorm)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.fnSigPtrIndex, ptrKey, sigIdx + 1)
    if !semGlobalCollectMode || nameTextId <= 0:
        hashmaps.HashMapStrIntPut(ctx.fnSigIndex, nameNorm, sigIdx + 1)
    semFnSigTextPut(nameTextId, sigIdx)
    semFnSigEpochBump()

fn semFnSigAdd(ctx: var SemCtx, name: str, paramsNode: Node) =
    semFnSigAddWithTextId(ctx, name, 0, paramsNode)

fn semFnSigFind(ctx: var SemCtx, name: str): int32 =
    let nm: str = semNormalizeName(name)
    if nm ==  "":
        return -1
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.fnSigIndex, nm, found)
    if found && idxPlus1 > 0:
        return idxPlus1 - 1
    return -1

fn semFnSigFindNormalized(ctx: var SemCtx, nm: str): int32 =
    if nm == "":
        return -1
    let ptrKey: int64 = semStrPtrKey(nm)
    if semFnSigNormRecentValid && semFnSigNormRecentEpoch == semFnSigEpoch:
        if ptrKey != 0 && semFnSigNormRecentPtrKey == ptrKey:
            return semFnSigNormRecentResult
        if ptrKey == 0 && nm == semFnSigNormRecentName:
            return semFnSigNormRecentResult
    if ptrKey != 0:
        var foundPtr: bool
        let idxPlus1Ptr: int32 = hashmaps.HashMapPtrIntGet(ctx.fnSigPtrIndex, ptrKey, foundPtr)
        if foundPtr:
            let outPtr: int32 = idxPlus1Ptr > 0 ? (idxPlus1Ptr - 1) : -1
            semFnSigNormRecentEpoch = semFnSigEpoch
            semFnSigNormRecentPtrKey = ptrKey
            semFnSigNormRecentName = nm
            semFnSigNormRecentResult = outPtr
            semFnSigNormRecentValid = true
            return outPtr
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapStrIntGetEx(ctx.fnSigIndex, nm, found)
    if found:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(ctx.fnSigPtrIndex, ptrKey, idxPlus1)
        let outFound: int32 = idxPlus1 > 0 ? (idxPlus1 - 1) : -1
        semFnSigNormRecentEpoch = semFnSigEpoch
        semFnSigNormRecentPtrKey = ptrKey
        semFnSigNormRecentName = nm
        semFnSigNormRecentResult = outFound
        semFnSigNormRecentValid = true
        return outFound
    hashmaps.HashMapStrIntPut(ctx.fnSigIndex, nm, 0)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(ctx.fnSigPtrIndex, ptrKey, 0)
    semFnSigNormRecentEpoch = semFnSigEpoch
    semFnSigNormRecentPtrKey = ptrKey
    semFnSigNormRecentName = nm
    semFnSigNormRecentResult = -1
    semFnSigNormRecentValid = true
    return -1

fn semFnSigFindNormalizedWithTextId(ctx: var SemCtx, nm: str, textId: int32): int32 =
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if semFnSigFindRecentValid && semFnSigFindRecentEpoch == semFnSigEpoch:
        if queryTextId > 0 && queryTextId == semFnSigFindRecentTextId:
            return semFnSigFindRecentResult
        if queryTextId <= 0 && nm != "" && nm == semFnSigFindRecentName:
            return semFnSigFindRecentResult
    if queryTextId > 0:
        var foundText: bool
        let sigIdxText: int32 = semFnSigTextGet(queryTextId, foundText)
        if foundText:
            semFnSigFindRecentEpoch = semFnSigEpoch
            semFnSigFindRecentTextId = queryTextId
            semFnSigFindRecentName = ""
            semFnSigFindRecentResult = sigIdxText
            semFnSigFindRecentValid = true
            return sigIdxText
        let sigIdxLinear: int32 = semFnSigLinearFindTextId(ctx, queryTextId)
        if sigIdxLinear >= 0:
            semFnSigTextPut(queryTextId, sigIdxLinear)
            if textId > 0 && queryTextId != textId:
                semFnSigTextPut(textId, sigIdxLinear)
            semFnSigFindRecentEpoch = semFnSigEpoch
            semFnSigFindRecentTextId = queryTextId
            semFnSigFindRecentName = ""
            semFnSigFindRecentResult = sigIdxLinear
            semFnSigFindRecentValid = true
            return sigIdxLinear
        semFnSigTextPut(queryTextId, -1)
        if textId > 0 && queryTextId != textId:
            semFnSigTextPut(textId, -1)
        semFnSigFindRecentEpoch = semFnSigEpoch
        semFnSigFindRecentTextId = queryTextId
        semFnSigFindRecentName = ""
        semFnSigFindRecentResult = -1
        semFnSigFindRecentValid = true
        return -1
    let nameNorm: str = semNormalizedNameFromTextId(nm, textId)
    if nameNorm == "":
        if queryTextId > 0:
            semFnSigTextPut(queryTextId, -1)
            semFnSigFindRecentEpoch = semFnSigEpoch
            semFnSigFindRecentTextId = queryTextId
            semFnSigFindRecentName = ""
            semFnSigFindRecentResult = -1
            semFnSigFindRecentValid = true
        return -1
    let sigIdx: int32 = semFnSigFindNormalized(ctx, nameNorm)
    if queryTextId > 0:
        semFnSigTextPut(queryTextId, sigIdx)
        if textId > 0 && queryTextId != textId:
            semFnSigTextPut(textId, sigIdx)
    semFnSigFindRecentEpoch = semFnSigEpoch
    semFnSigFindRecentTextId = queryTextId
    semFnSigFindRecentName = nameNorm
    semFnSigFindRecentResult = sigIdx
    semFnSigFindRecentValid = true
    return sigIdx

fn semFnSigParamIndex(ctx: var SemCtx, sigIdx: int32, name: str): int32 =
    let nm: str = semNormalizeName(name)
    if nm ==  "":
        return -1
    return semFnSigParamIndexNormalized(ctx, sigIdx, nm)

fn semFnSigParamIndexNormalizedWithTextId(ctx: var SemCtx, sigIdx: int32, nm: str, textId: int32): int32 =
    if sigIdx < 0 || sigIdx >= ctx.fnSigNames.len:
        return -1
    let off: int32 = semReadI32(ctx.fnSigParamOffsets, sigIdx)
    let count: int32 = semReadI32(ctx.fnSigParamCounts, sigIdx)
    let queryTextId: int32 = semCanonicalTextId(nm, textId)
    if queryTextId > 0:
        for i in 0..<count:
            if semReadI32(ctx.fnSigParamTextIds, off + i) == queryTextId:
                return i
    if nm == "":
        return -1
    return semFnSigParamIndexNormalized(ctx, sigIdx, nm)

fn semFnSigParamIndexNormalized(ctx: var SemCtx, sigIdx: int32, nm: str): int32 =
    if sigIdx < 0 || sigIdx >= ctx.fnSigNames.len:
        return -1
    if nm ==  "":
        return -1
    let off: int32 = semReadI32(ctx.fnSigParamOffsets, sigIdx)
    let count: int32 = semReadI32(ctx.fnSigParamCounts, sigIdx)
    for i in 0..<count:
        let pname: str = semReadStr(ctx.fnSigParamNames, off + i)
        if pname ==  nm:
            return i
    return -1

fn semFnSigParamIsVar(ctx: var SemCtx, sigIdx: int32, paramIdx: int32): bool =
    if sigIdx < 0:
        return false
    let off: int32 = semReadI32(ctx.fnSigParamOffsets, sigIdx)
    let count: int32 = semReadI32(ctx.fnSigParamCounts, sigIdx)
    if paramIdx < 0 || paramIdx >= count:
        return false
    return semReadI32(ctx.fnSigParamIsVar, off + paramIdx) != 0

fn semFnSigParamIsPtrLike(ctx: var SemCtx, sigIdx: int32, paramIdx: int32): bool =
    if sigIdx < 0:
        return false
    let off: int32 = semReadI32(ctx.fnSigParamOffsets, sigIdx)
    let count: int32 = semReadI32(ctx.fnSigParamCounts, sigIdx)
    if paramIdx < 0 || paramIdx >= count:
        return false
    return semReadI32(ctx.fnSigParamIsPtrLike, off + paramIdx) != 0

fn semFnSigHasVar(ctx: var SemCtx, sigIdx: int32): bool =
    if sigIdx < 0 || sigIdx >= ctx.fnSigNames.len:
        return false
    return semReadI32(ctx.fnSigHasVar, sigIdx) != 0

fn semFnSigHasNonPtr(ctx: var SemCtx, sigIdx: int32): bool =
    if sigIdx < 0 || sigIdx >= ctx.fnSigNames.len:
        return false
    return semReadI32(ctx.fnSigHasNonPtr, sigIdx) != 0

fn semCallArgValue(n: Node): Node =
    if stage1AstRefNonNil(n) && nodeKind(n) == nkCallArg:
        if kidCount(n) > 1:
            return kid(n, 1)
        if kidCount(n) > 0:
            return kid(n, 0)
    return n

fn semIsAddrCall(n: Node): bool =
    if stage1AstRefIsNil(n) || nodeKind(n) != nkCall || kidCount(n) <= 0:
        return false
    let callee: Node = kid(n, 0)
    if stage1AstRefNonNil(callee) && (nodeKind(callee) == nkIdent || nodeKind(callee) == nkSymbol):
        semEnsureCallNameTextIds()
        let textId: int32 = semCanonicalTextId("", nodeIdentId(callee))
        if textId > 0:
            return semTextEqId(textId, semCallNameIdAddr)
        let nm: str = semIdentNameNormalized(callee)
        return (nm ==  "__addr")
    return false

fn semIsExplicitPtrCall(n: Node): bool =
    if stage1AstRefIsNil(n) || nodeKind(n) != nkCall:
        return false
    let info: SemCallInfo = semCallInfoNormalized(n)
    return (info.flags & semCallNameFlagExplicitPtr) != 0

fn semIsShareCall(n: Node): bool =
    if stage1AstRefIsNil(n) || nodeKind(n) != nkCall:
        return false
    let info: SemCallInfo = semCallInfoNormalized(n)
    return (info.flags & semCallNameFlagShare) != 0

fn semIsLValueExpr(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    var cur: Node = n
    if nodeKind(cur) == nkPar && kidCount(cur) == 1:
        return semIsLValueExpr(kid(cur, 0))
    if nodeKind(cur) == nkHiddenDeref || nodeKind(cur) == nkDerefExpr:
        return true
    if nodeKind(cur) == nkIdent || nodeKind(cur) == nkSymbol:
        return true
    if (nodeKind(cur) == nkDotExpr || nodeKind(cur) == nkBracketExpr) && kidCount(cur) > 0:
        return semIsLValueExpr(kid(cur, 0))
    return false

fn semBorrowMarkNormalizedWithOriginAndTextIds(ctx: var SemCtx, nm: str, textId: int32, borrowed: bool, onm: str, originTextId: int32) =
    if (nm ==  ""):
        return
    if (nm ==  "_"):
        return
    let depth: int32 = semScopeDepth(ctx)
    let prevIdx: int32 = semBorrowFindIndexWithTextId(ctx, nm, textId, depth)
    if prevIdx >= 0:
        if semReadI32(ctx.borrowFlags, prevIdx) != 0:
            let prevOname: str = semReadStr(ctx.borrowOriginNames, prevIdx)
            let prevOtextId: int32 = semReadI32(ctx.borrowOriginTextIds, prevIdx)
            let prevOdepth: int32 = semReadI32(ctx.borrowOriginDepths, prevIdx)
            semBorrowOriginCountAddWithTextId(ctx, prevOname, prevOtextId, prevOdepth, -1)
            ctx.borrowActiveTotal = ctx.borrowActiveTotal - 1
    var foundText: bool
    let prevTextIndexPlus1: int32 = semBorrowTextIndexGet(textId, foundText)
    var found: bool
    var prevIndexPlus1: int32
    if foundText && prevTextIndexPlus1 > 0:
        found = true
        prevIndexPlus1 = prevTextIndexPlus1
    else:
        let ptrKey: int64 = semStrPtrKey(nm)
        if ptrKey != 0:
            prevIndexPlus1 = hashmaps.HashMapPtrIntGet(ctx.borrowPtrIndex, ptrKey, found)
        if !found && textId <= 0:
            prevIndexPlus1 = hashmaps.HashMapStrIntGetEx(ctx.borrowIndex, nm, found)
            if found && ptrKey != 0:
                hashmaps.HashMapPtrIntPut(ctx.borrowPtrIndex, ptrKey, prevIndexPlus1)
    let idx: int32 = ctx.borrowNames.len
    if found:
        semAddInt32(ctx.borrowPrevIndexPlus1, prevIndexPlus1)
    else:
        semAddInt32(ctx.borrowPrevIndexPlus1, int32(0))
    semAddStr(ctx.borrowNames, nm)
    semAddInt32(ctx.borrowTextIds, textId)
    semAddInt32(ctx.borrowDepths, depth)
    var flag: int32
    if borrowed:
        flag = 1
    semAddInt32(ctx.borrowFlags, flag)
    semAddStr(ctx.borrowOriginNames, onm)
    semAddInt32(ctx.borrowOriginTextIds, originTextId)
    var odepth: int32 = -1
    if ! (onm ==  ""):
        odepth = semFindDefDepthNormalizedWithTextId(ctx, onm, originTextId)
    semAddInt32(ctx.borrowOriginDepths, odepth)
    if foundText && prevTextIndexPlus1 > 0:
        semAddInt32(ctx.borrowPrevTextIndexPlus1, prevTextIndexPlus1)
    else:
    semAddInt32(ctx.borrowPrevTextIndexPlus1, int32(0))
    semAddInt32(ctx.borrowPrevExactIndexPlus1, semBorrowExactGet(ctx, textId, depth))
    let ptrKey2: int64 = semStrPtrKey(nm)
    if textId <= 0:
        hashmaps.HashMapStrIntPut(ctx.borrowIndex, nm, idx + 1)
    if ptrKey2 != 0:
        hashmaps.HashMapPtrIntPut(ctx.borrowPtrIndex, ptrKey2, idx + 1)
    semBorrowTextIndexPut(textId, idx + 1)
    semBorrowExactPut(ctx, textId, depth, idx + 1)
    if flag != 0:
        semBorrowOriginCountAddWithTextId(ctx, onm, originTextId, odepth, 1)
        ctx.borrowActiveTotal = ctx.borrowActiveTotal + 1
    semBorrowDebugLogMark(ctx, "mark", nm, textId, borrowed, onm, originTextId, depth, odepth)
    semBorrowEpoch = semBorrowEpoch + 1

fn semBorrowMarkWithOriginAndTextIds(ctx: var SemCtx, name: str, textId: int32, borrowed: bool, origin: str, originTextId: int32) =
    var nameHint: str
    if textId <= 0:
        nameHint = name
    var originHint: str
    if originTextId <= 0:
        originHint = origin
    let nm: str = semNormalizedTextIdOrName(textId, nameHint)
    let onm: str = semNormalizedTextIdOrName(originTextId, originHint)
    semBorrowMarkNormalizedWithOriginAndTextIds(ctx, nm, textId, borrowed, onm, originTextId)

fn semBorrowMarkWithOriginAndTextId(ctx: var SemCtx, name: str, textId: int32, borrowed: bool, origin: str) =
    semBorrowMarkWithOriginAndTextIds(ctx, name, textId, borrowed, origin, 0)

fn semBorrowMarkWithOrigin(ctx: var SemCtx, name: str, borrowed: bool, origin: str) =
    semBorrowMarkWithOriginAndTextId(ctx, name, 0, borrowed, origin)

fn semBorrowMarkNodeWithOriginAndTextId(ctx: var SemCtx, n: Node, borrowed: bool, origin: str, originTextId: int32) =
    if stage1AstRefIsNil(n):
        return
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return
    let textId: int32 = nodeIdentId(n)
    var nameHint: str
    if textId <= 0:
        nameHint = nodeIdent(n)
    var originHint: str
    if originTextId <= 0:
        originHint = origin
    let nm: str = semNormalizedTextIdOrName(textId, nameHint)
    let onm: str = semNormalizedTextIdOrName(originTextId, originHint)
    semBorrowMarkNormalizedWithOriginAndTextIds(ctx, nm, textId, borrowed, onm, originTextId)

fn semBorrowMarkNodeWithOrigin(ctx: var SemCtx, n: Node, borrowed: bool, origin: str) =
    semBorrowMarkNodeWithOriginAndTextId(ctx, n, borrowed, origin, 0)

fn semBorrowFindIndexCore(ctx: var SemCtx, name: str, defDepth: int32): int32 =
    if defDepth < 0:
        return -1
    let ptrKey: int64 = semStrPtrKey(name)
    var found: bool
    var idxPlus1: int32
    if ptrKey != 0:
        idxPlus1 = hashmaps.HashMapPtrIntGet(ctx.borrowPtrIndex, ptrKey, found)
    if !found:
        idxPlus1 = hashmaps.HashMapStrIntGetEx(ctx.borrowIndex, name, found)
        if found && ptrKey != 0:
            hashmaps.HashMapPtrIntPut(ctx.borrowPtrIndex, ptrKey, idxPlus1)
    if !found:
        idxPlus1 = semBorrowFindLatestIndexLinear(ctx, name)
        if idxPlus1 > 0:
            found = true
            hashmaps.HashMapStrIntPut(ctx.borrowIndex, name, idxPlus1)
            if ptrKey != 0:
                hashmaps.HashMapPtrIntPut(ctx.borrowPtrIndex, ptrKey, idxPlus1)
    if ! found || idxPlus1 <= 0:
        return -1
    var idx: int32 = idxPlus1 - 1
    while idx >= 0 && idx < ctx.borrowNames.len:
        let bdepth: int32 = semReadI32(ctx.borrowDepths, idx)
        if bdepth == defDepth:
            return idx
        let prevPlus1: int32 = semReadI32(ctx.borrowPrevIndexPlus1, idx)
        if prevPlus1 <= 0:
            break
        idx = prevPlus1 - 1
    return -1

fn semBorrowFindLatestIndexLinear(ctx: var SemCtx, name: str): int32 =
    if name == "":
        return 0
    if ctx.borrowNames.len <= 0:
        return 0
    let __for_start_i = ctx.borrowNames.len - 1
    for __for_rev_i in 0..(__for_start_i):
        let i = __for_start_i - __for_rev_i
        if semReadStr(ctx.borrowNames, i) == name:
            return i + 1
    return 0

fn semBorrowFindIndexWithTextId(ctx: var SemCtx, name: str, textId: int32, defDepth: int32): int32 =
    if defDepth < 0:
        return -1
    if textId > 0:
        let idxPlus1Exact: int32 = semBorrowExactGet(ctx, textId, defDepth)
        if idxPlus1Exact > 0:
            return idxPlus1Exact - 1
        return -1
    return semBorrowFindIndexCore(ctx, name, defDepth)

fn semBorrowFindIndex(ctx: var SemCtx, name: str, defDepth: int32): int32 =
    return semBorrowFindIndexCore(ctx, name, defDepth)

fn semBorrowMark(ctx: var SemCtx, name: str, borrowed: bool) =
    semBorrowMarkWithOrigin(ctx, name, borrowed, "")

fn semBorrowMarkNode(ctx: var SemCtx, n: Node, borrowed: bool) =
    semBorrowMarkNodeWithOrigin(ctx, n, borrowed, "")

fn semBorrowIsActive(ctx: var SemCtx, name: str): bool =
    return semBorrowIsActiveNormalized(ctx, semNormalizeName(name))

fn semBorrowIsActiveNormalized(ctx: var SemCtx, nm: str): bool =
    if (nm ==  ""):
        return false
    let defDepth: int32 = semFindDefDepthNormalized(ctx, nm)
    return semBorrowIsActiveNormalizedWithDepth(ctx, nm, defDepth)

fn semBorrowIsActiveNormalizedWithDepth(ctx: var SemCtx, nm: str, defDepth: int32): bool =
    if defDepth < 0:
        return false
    let idx: int32 = semBorrowFindIndex(ctx, nm, defDepth)
    if idx < 0:
        return false
    return semReadI32(ctx.borrowFlags, idx) != 0

fn semBorrowIsActiveIdentCached(ctx: var SemCtx, n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return false
    let nId: AstNodeId = astNodeIndex(n)
    if astNodeIdValid(nId):
        semEnsureBorrowActiveCache(nId)
        let idx: int32 = nId
        if idx >= 0 && idx < semBorrowActiveScopeEpoch.len && idx < semBorrowActiveBorrowEpoch.len && idx < semBorrowActiveValue.len:
            if semBorrowActiveScopeEpoch[idx] == semScopeEpoch && semBorrowActiveBorrowEpoch[idx] == semBorrowEpoch:
                return semBorrowActiveValue[idx]
    let textId: int32 = nodeIdentId(n)
    if textId > 0:
        semEnsureBorrowActiveTextCache(textId)
        if textId < semBorrowActiveTextScopeEpoch.len &&
           textId < semBorrowActiveTextBorrowEpoch.len &&
           textId < semBorrowActiveTextValue.len:
            if semBorrowActiveTextScopeEpoch[textId] == semScopeEpoch &&
               semBorrowActiveTextBorrowEpoch[textId] == semBorrowEpoch:
                return semBorrowActiveTextValue[textId]
    let defDepth: int32 = semIdentDefDepthCached(ctx, n)
    var idx3: int32 = -1
    if textId > 0:
        idx3 = semBorrowFindIndexWithTextId(ctx, "", textId, defDepth)
    elif defDepth >= 0:
        let nm: str = semIdentNameNormalized(n)
        idx3 = semBorrowFindIndexWithTextId(ctx, nm, 0, defDepth)
    let res: bool = idx3 >= 0 && semReadI32(ctx.borrowFlags, idx3) != 0
    if textId > 0 &&
       textId < semBorrowActiveTextScopeEpoch.len &&
       textId < semBorrowActiveTextBorrowEpoch.len &&
       textId < semBorrowActiveTextValue.len:
        semBorrowActiveTextScopeEpoch[textId] = semScopeEpoch
        semBorrowActiveTextBorrowEpoch[textId] = semBorrowEpoch
        semBorrowActiveTextValue[textId] = res
    if astNodeIdValid(nId):
        let idx2: int32 = nId
        if idx2 >= 0 && idx2 < semBorrowActiveScopeEpoch.len && idx2 < semBorrowActiveBorrowEpoch.len && idx2 < semBorrowActiveValue.len:
            semBorrowActiveScopeEpoch[idx2] = semScopeEpoch
            semBorrowActiveBorrowEpoch[idx2] = semBorrowEpoch
            semBorrowActiveValue[idx2] = res
    return res

fn semBorrowSeen(names: str[], depths: int32[], name: str, depth: int32): bool =
    for i in 0..<names.len:
        let cur: str = names[i]
        if cur ==  name && semReadI32(depths, i) == depth:
            return true
    return false

fn semHash64(s: str): uint64 =
    return hashmaps.HashMapHash64Str(s)

fn semHashBorrowPair(name: str, depth: int32): uint64 =
    var h: uint64 = semHash64(name)
    h = h ^ uint64(uint32(depth))
    h = h * ((uint64(1099511628) * uint64(1000)) + uint64(211))
    return h

fn semNextPow2(n: int32): int32 =
    return hashmaps.HashMapNextPow2(n, 8)

fn semBorrowSeenFastHas(seenNames: str[], seenDepths: int32[], mask: uint64, name: str, depth: int32): bool =
    var idx: uint64 = semHashBorrowPair(name, depth) & mask
    while true:
        let slotName: str = seenNames[int32(idx)]
        if len(slotName) == 0:
            return false
        if slotName == name && semReadI32(seenDepths, int32(idx)) == depth:
            return true
        idx =(idx + 1) & mask

fn semBorrowSeenFastPut(seenNames: var str[], seenDepths: var int32[], mask: uint64, name: str, depth: int32) =
    var idx: uint64 = semHashBorrowPair(name, depth) & mask
    while true:
        let slotName: str = seenNames[int32(idx)]
        if len(slotName) == 0:
            seenNames[int32(idx)] = name
            seenDepths[int32(idx)] = depth
            return
        if slotName == name && seenDepths[int32(idx)] == depth:
            return
        idx =(idx + 1) & mask

fn semBorrowOriginKey(name: str, depth: int32): str =
    return name + "@" + intToStr(depth)

fn semBorrowExactKey(textId: int32, depth: int32): int64 =
    if textId <= 0 || depth < 0:
        return 0
    return (int64(textId) << 32) | int64(depth + 1)

fn semBorrowExactGet(ctx: var SemCtx, textId: int32, depth: int32): int32 =
    let key: int64 = semBorrowExactKey(textId, depth)
    if key == 0:
        return 0
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapPtrIntGet(ctx.borrowExactIndex, key, found)
    if !found || idxPlus1 <= 0:
        return 0
    return idxPlus1

fn semBorrowExactPut(ctx: var SemCtx, textId: int32, depth: int32, idxPlus1: int32) =
    let key: int64 = semBorrowExactKey(textId, depth)
    if key == 0:
        return
    hashmaps.HashMapPtrIntPut(ctx.borrowExactIndex, key, idxPlus1)

fn semBorrowOriginKnownKey(textId: int32, depth: int32): int64 =
    if textId <= 0 || depth < 0:
        return 0
    return (int64(textId) << 32) | int64(depth + 1)

fn semEnsureBorrowOriginUnknownTextCount(textId: int32) =
    if textId <= 0:
        return
    let needLen: int32 = textId + 1
    let oldLen: int32 = semBorrowOriginUnknownTextCount.len
    if oldLen < needLen:
        seqs.Reserve(semBorrowOriginUnknownTextCount, needLen)
        seqs.SetLen(semBorrowOriginUnknownTextCount, needLen)
        for i in oldLen..<needLen:
            semBorrowOriginUnknownTextCount[i] = 0

fn semBorrowOriginUnknownTextGet(textId: int32): int32 =
    if textId <= 0 || textId >= semBorrowOriginUnknownTextCount.len:
        return 0
    return semBorrowOriginUnknownTextCount[textId]

fn semBorrowOriginUnknownTextAdd(textId: int32, delta: int32) =
    if textId <= 0 || delta == 0:
        return
    semEnsureBorrowOriginUnknownTextCount(textId)
    let next: int32 = semBorrowOriginUnknownTextCount[textId] + delta
    if next <= 0:
        semBorrowOriginUnknownTextCount[textId] = 0
    else:
        semBorrowOriginUnknownTextCount[textId] = next

fn semBorrowOriginKnownTextGet(textId: int32, depth: int32): int32 =
    let key: int64 = semBorrowOriginKnownKey(textId, depth)
    if key == 0:
        return 0
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapPtrIntGet(semBorrowOriginKnownIndex, key, found)
    if !found || idxPlus1 <= 0 || idxPlus1 > semBorrowOriginKnownValue.len:
        return 0
    return semBorrowOriginKnownValue[idxPlus1 - 1]

fn semBorrowOriginKnownTextAdd(textId: int32, depth: int32, delta: int32) =
    if delta == 0:
        return
    let key: int64 = semBorrowOriginKnownKey(textId, depth)
    if key == 0:
        return
    var found: bool
    let idxPlus1: int32 = hashmaps.HashMapPtrIntGet(semBorrowOriginKnownIndex, key, found)
    if found && idxPlus1 > 0 && idxPlus1 <= semBorrowOriginKnownValue.len:
        let next: int32 = semBorrowOriginKnownValue[idxPlus1 - 1] + delta
        if next <= 0:
            semBorrowOriginKnownValue[idxPlus1 - 1] = 0
        else:
            semBorrowOriginKnownValue[idxPlus1 - 1] = next
        return
    if delta <= 0:
        return
    add(semBorrowOriginKnownValue, delta)
    hashmaps.HashMapPtrIntPut(semBorrowOriginKnownIndex, key, semBorrowOriginKnownValue.len)

fn semBorrowOriginCountAddWithTextId(ctx: var SemCtx, name: str, textId: int32, depth: int32, delta: int32) =
    if delta == 0:
        return
    if name ==  "":
        return
    if depth < 0:
        semBorrowOriginUnknownTextAdd(textId, delta)
        var found: bool
        let cur: int32 = hashmaps.HashMapStrIntGetEx(ctx.borrowOriginUnknownCount, name, found)
        let next: int32 = cur + delta
        if next <= 0:
            hashmaps.HashMapStrIntPut(ctx.borrowOriginUnknownCount, name, 0)
        else:
            hashmaps.HashMapStrIntPut(ctx.borrowOriginUnknownCount, name, next)
        semBorrowDebugLogOriginDelta(ctx, "origin_delta", name, textId, depth, delta)
        return
    semBorrowOriginKnownTextAdd(textId, depth, delta)
    let key: str = semBorrowOriginKey(name, depth)
    var found: bool
    let cur: int32 = hashmaps.HashMapStrIntGetEx(ctx.borrowOriginCount, key, found)
    let next: int32 = cur + delta
    if next <= 0:
        hashmaps.HashMapStrIntPut(ctx.borrowOriginCount, key, 0)
    else:
        hashmaps.HashMapStrIntPut(ctx.borrowOriginCount, key, next)
    semBorrowDebugLogOriginDelta(ctx, "origin_delta", name, textId, depth, delta)

fn semBorrowOriginCountAdd(ctx: var SemCtx, name: str, depth: int32, delta: int32) =
    semBorrowOriginCountAddWithTextId(ctx, name, 0, depth, delta)

fn semBorrowOriginIsActive(ctx: var SemCtx, name: str): bool =
    return semBorrowOriginIsActiveNormalized(ctx, semNormalizeName(name))

fn semBorrowOriginIsActiveNormalized(ctx: var SemCtx, nm: str): bool =
    if (nm ==  ""):
        return false
    let originDepth: int32 = semFindDefDepthNormalized(ctx, nm)
    var found: bool
    if originDepth >= 0:
        let key: str = semBorrowOriginKey(nm, originDepth)
        let count: int32 = hashmaps.HashMapStrIntGetEx(ctx.borrowOriginCount, key, found)
        return found && count > 0
    let unk: int32 = hashmaps.HashMapStrIntGetEx(ctx.borrowOriginUnknownCount, nm, found)
    return found && unk > 0

fn semBorrowOriginIsActiveIdentCached(ctx: var SemCtx, n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return false
    let nId: AstNodeId = astNodeIndex(n)
    if astNodeIdValid(nId):
        semEnsureBorrowOriginCache(nId)
        let idx: int32 = nId
        if idx >= 0 && idx < semBorrowOriginScopeEpoch.len && idx < semBorrowOriginBorrowEpoch.len && idx < semBorrowOriginValue.len:
            if semBorrowOriginScopeEpoch[idx] == semScopeEpoch && semBorrowOriginBorrowEpoch[idx] == semBorrowEpoch:
                return semBorrowOriginValue[idx]
    let textId: int32 = nodeIdentId(n)
    if textId > 0:
        semEnsureBorrowOriginTextCache(textId)
        if textId < semBorrowOriginTextScopeEpoch.len &&
           textId < semBorrowOriginTextBorrowEpoch.len &&
           textId < semBorrowOriginTextValue.len:
            if semBorrowOriginTextScopeEpoch[textId] == semScopeEpoch &&
               semBorrowOriginTextBorrowEpoch[textId] == semBorrowEpoch:
                return semBorrowOriginTextValue[textId]
    var res: bool
    let originDepth: int32 = semIdentDefDepthCached(ctx, n)
    if originDepth >= 0:
        if textId > 0:
            res = semBorrowOriginKnownTextGet(textId, originDepth) > 0
        else:
            var found: bool
            let nm: str = semIdentNameNormalized(n)
            let key: str = semBorrowOriginKey(nm, originDepth)
            let count: int32 = hashmaps.HashMapStrIntGetEx(ctx.borrowOriginCount, key, found)
            res = found && count > 0
    elif textId > 0:
        res = semBorrowOriginUnknownTextGet(textId) > 0
    else:
        var found: bool
        let nm: str = semIdentNameNormalized(n)
        let unk: int32 = hashmaps.HashMapStrIntGetEx(ctx.borrowOriginUnknownCount, nm, found)
        res = found && unk > 0
    if textId > 0 &&
       textId < semBorrowOriginTextScopeEpoch.len &&
       textId < semBorrowOriginTextBorrowEpoch.len &&
       textId < semBorrowOriginTextValue.len:
        semBorrowOriginTextScopeEpoch[textId] = semScopeEpoch
        semBorrowOriginTextBorrowEpoch[textId] = semBorrowEpoch
        semBorrowOriginTextValue[textId] = res
    if astNodeIdValid(nId):
        let idx2: int32 = nId
        if idx2 >= 0 && idx2 < semBorrowOriginScopeEpoch.len && idx2 < semBorrowOriginBorrowEpoch.len && idx2 < semBorrowOriginValue.len:
            semBorrowOriginScopeEpoch[idx2] = semScopeEpoch
            semBorrowOriginBorrowEpoch[idx2] = semBorrowEpoch
            semBorrowOriginValue[idx2] = res
    return res

fn semBorrowMarkPattern(ctx: var SemCtx, pat: Node, borrowed: bool) =
    if stage1AstRefIsNil(pat):
        return
    case nodeKind(pat)
    of nkPattern:
        if kidCount(pat) > 0:
            semBorrowMarkPattern(ctx, kid(pat, 0), borrowed)
    of nkCallArg:
        if kidCount(pat) > 1:
            semBorrowMarkPattern(ctx, kid(pat, 1), borrowed)
    of nkIdent, nkSymbol:
        semBorrowMarkNode(ctx, pat, borrowed)
    of nkTupleLit:
        for i in 0..<kidCount(pat):
            semBorrowMarkPattern(ctx, kid(pat, i), borrowed)
    of nkSeqLit, nkBracket:
        for si in 0..<kidCount(pat):
            semBorrowMarkPattern(ctx, kid(pat, si), borrowed)
    of nkCall:
        for ci in 1..<kidCount(pat):
            let arg: Node = kid(pat, ci)
            if stage1AstRefNonNil(arg) && nodeKind(arg) == nkCallArg && kidCount(arg) > 1:
                semBorrowMarkPattern(ctx, kid(arg, 1), borrowed)
            else:
                semBorrowMarkPattern(ctx, arg, borrowed)
    of nkPar:
        if kidCount(pat) == 1:
            semBorrowMarkPattern(ctx, kid(pat, 0), borrowed)
    else:
        return
fn semPatternIdent(pat: Node): Node =
    if stage1AstRefIsNil(pat):
        return astInvalidNodeId()
    case nodeKind(pat)
    of nkPattern:
        if kidCount(pat) > 0:
            return semPatternIdent(kid(pat, 0))
    of nkCallArg:
        if kidCount(pat) > 1:
            return semPatternIdent(kid(pat, 1))
    of nkPar:
        if kidCount(pat) == 1:
            return semPatternIdent(kid(pat, 0))
    of nkIdent, nkSymbol:
        return pat
    else:
        return astInvalidNodeId()
    return astInvalidNodeId()

fn semBindingTypeNode(pat: Node, typeNode: Node): Node =
    if stage1AstRefNonNil(typeNode) && nodeKind(typeNode) != nkEmpty:
        return typeNode
    if stage1AstRefNonNil(pat) && nodeKind(pat) == nkPattern && kidCount(pat) > 1:
        let ty: Node = kid(pat, 1)
        if stage1AstRefNonNil(ty) && nodeKind(ty) != nkEmpty:
            return ty
    return typeNode

fn semBorrowMarkPatternWithOrigin(ctx: var SemCtx, pat: Node, origin: str) =
    semBorrowMarkPatternWithOriginAndTextId(ctx, pat, origin, 0)

fn semBorrowMarkPatternWithOriginAndTextId(ctx: var SemCtx, pat: Node, origin: str, originTextId: int32) =
    if stage1AstRefIsNil(pat):
        return
    case nodeKind(pat)
    of nkPattern:
        if kidCount(pat) > 0:
            semBorrowMarkPatternWithOriginAndTextId(ctx, kid(pat, 0), origin, originTextId)
    of nkCallArg:
        if kidCount(pat) > 1:
            semBorrowMarkPatternWithOriginAndTextId(ctx, kid(pat, 1), origin, originTextId)
    of nkIdent, nkSymbol:
        semBorrowMarkNodeWithOriginAndTextId(ctx, pat, true, origin, originTextId)
    of nkTupleLit:
        for i in 0..<kidCount(pat):
            semBorrowMarkPatternWithOriginAndTextId(ctx, kid(pat, i), origin, originTextId)
    of nkSeqLit, nkBracket:
        for si in 0..<kidCount(pat):
            semBorrowMarkPatternWithOriginAndTextId(ctx, kid(pat, si), origin, originTextId)
    of nkCall:
        for ci in 1..<kidCount(pat):
            let arg: Node = kid(pat, ci)
            if stage1AstRefNonNil(arg) && nodeKind(arg) == nkCallArg && kidCount(arg) > 1:
                semBorrowMarkPatternWithOriginAndTextId(ctx, kid(arg, 1), origin, originTextId)
            else:
                semBorrowMarkPatternWithOriginAndTextId(ctx, arg, origin, originTextId)
    of nkPar:
        if kidCount(pat) == 1:
            semBorrowMarkPatternWithOriginAndTextId(ctx, kid(pat, 0), origin, originTextId)
    else:
        return

type SemCallInfo = object
    name: str
    nameTextId: int32
    base: Node
    flags: int32

fn semCallInfoHasName(info: SemCallInfo): bool =
    return info.nameTextId > 0 || info.name != ""

fn semCallInfoNormalizedName(info: SemCallInfo): str =
    if info.nameTextId > 0:
        return semNormalizeTextId(info.nameTextId)
    return info.name

fn semCallInfoIsBorrowedWithCtx(ctx: var SemCtx, info: SemCallInfo): bool =
    if !semCallInfoHasName(info):
        return false
    if (info.flags & semCallNameFlagBorrowed) != 0:
        return true
    if ctx.borrowAllowNames.len <= 0:
        return false
    return semIsBorrowAllowNameNormalizedWithTextId(ctx, info.name, info.nameTextId)

fn semCallInfoIsBorrowPassAllowedWithCtx(ctx: var SemCtx, info: SemCallInfo): bool =
    var escapesBorrow: bool
    return semCallInfoIsBorrowPassAllowedWithCtx(ctx, info, escapesBorrow)

fn semCallInfoIsBorrowPassAllowedWithCtx(ctx: var SemCtx, info: SemCallInfo, escapesBorrow: var bool): bool =
    if !semCallInfoHasName(info):
        escapesBorrow = false
        return false
    let hasEscapeOverrides: bool = ctx.borrowEscapeNames.len > 0
    let hasAllowOverrides: bool = ctx.borrowAllowNames.len > 0
    if !hasEscapeOverrides && !hasAllowOverrides:
        escapesBorrow = false
        return (info.flags & semCallNameFlagBorrowPassAllowed) != 0
    if hasEscapeOverrides:
        escapesBorrow = semIsBorrowEscapeNameNormalizedWithTextId(ctx, info.name, info.nameTextId)
        if escapesBorrow:
            return false
    else:
        escapesBorrow = false
    if hasAllowOverrides && semIsBorrowAllowNameNormalizedWithTextId(ctx, info.name, info.nameTextId):
        return true
    return (info.flags & semCallNameFlagBorrowPassAllowed) != 0

fn semCallInfoBorrowPassAllowedCached(ctx: var SemCtx, callNode: Node, info: SemCallInfo, escapesBorrow: var bool): bool =
    if stage1AstRefIsNil(callNode) || nodeKind(callNode) != nkCall:
        return semCallInfoIsBorrowPassAllowedWithCtx(ctx, info, escapesBorrow)
    if !semCallInfoHasName(info):
        escapesBorrow = false
        return false
    let nId: AstNodeId = astNodeIndex(callNode)
    if astNodeIdValid(nId):
        semEnsureCallInfoCache(nId)
        let idx: int32 = nId
        if idx >= 0 && idx < semCallInfoBorrowEpoch.len && idx < semCallInfoBorrowValues.len:
            if semCallInfoBorrowEpoch[idx] == semBorrowQueryEpoch:
                let cachedBits: int32 = semCallInfoBorrowValues[idx]
                escapesBorrow = (cachedBits & semCallBorrowCacheEscape) != 0
                return (cachedBits & semCallBorrowCacheAllow) != 0
    let allowBorrow: bool = semCallInfoIsBorrowPassAllowedWithCtx(ctx, info, escapesBorrow)
    if astNodeIdValid(nId):
        let idx2: int32 = nId
        if idx2 >= 0 && idx2 < semCallInfoBorrowEpoch.len && idx2 < semCallInfoBorrowValues.len:
            var bits: int32
            if allowBorrow:
                bits = bits | semCallBorrowCacheAllow
            if escapesBorrow:
                bits = bits | semCallBorrowCacheEscape
            semCallInfoBorrowEpoch[idx2] = semBorrowQueryEpoch
            semCallInfoBorrowValues[idx2] = bits
    return allowBorrow

fn semCallInfoFnSigFindCached(ctx: var SemCtx, callNode: Node, info: SemCallInfo): int32 =
    if stage1AstRefIsNil(callNode) || nodeKind(callNode) != nkCall:
        return -1
    if !semCallInfoHasName(info):
        return -1
    let nId: AstNodeId = astNodeIndex(callNode)
    if astNodeIdValid(nId):
        semEnsureCallInfoCache(nId)
        let idx: int32 = nId
        if idx >= 0 && idx < semCallInfoSigEpoch.len && idx < semCallInfoSigValues.len:
            let cachedSigIdx: int32 = semCallInfoSigValues[idx]
            if cachedSigIdx >= 0:
                return cachedSigIdx
            if semCallInfoSigEpoch[idx] == semFnSigEpoch:
                return cachedSigIdx
    let sigIdx: int32 = semFnSigFindNormalizedWithTextId(ctx, info.name, info.nameTextId)
    if astNodeIdValid(nId):
        let idx2: int32 = nId
        if idx2 >= 0 && idx2 < semCallInfoSigEpoch.len && idx2 < semCallInfoSigValues.len:
            semCallInfoSigEpoch[idx2] = semFnSigEpoch
            semCallInfoSigValues[idx2] = sigIdx
    return sigIdx

fn semCallInfoDefDepthCached(ctx: var SemCtx, callNode: Node, info: SemCallInfo): int32 =
    if stage1AstRefIsNil(callNode) || nodeKind(callNode) != nkCall:
        return -1
    if !semCallInfoHasName(info):
        return -1
    let nId: AstNodeId = astNodeIndex(callNode)
    if astNodeIdValid(nId):
        semEnsureCallInfoCache(nId)
        let idx: int32 = nId
        if idx >= 0 && idx < semCallInfoDefDepthEpoch.len && idx < semCallInfoDefDepthValues.len:
            if semCallInfoDefDepthEpoch[idx] == semScopeEpoch:
                return semCallInfoDefDepthValues[idx]
    let depth: int32 = semFindDefDepthNormalizedWithTextId(ctx, info.name, info.nameTextId)
    if astNodeIdValid(nId):
        let idx2: int32 = nId
        if idx2 >= 0 && idx2 < semCallInfoDefDepthEpoch.len && idx2 < semCallInfoDefDepthValues.len:
            semCallInfoDefDepthEpoch[idx2] = semScopeEpoch
            semCallInfoDefDepthValues[idx2] = depth
    return depth

fn semCallBaseName(n: Node): str =
    if stage1AstRefIsNil(n) || nodeKind(n) != nkCall || kidCount(n) == 0:
        return ""
    return semCallInfoNormalizedName(semCallInfoNormalized(n))

fn semCallName(n: Node): str =
    if stage1AstRefIsNil(n) || nodeKind(n) != nkCall || kidCount(n) == 0:
        return ""
    let info: SemCallInfo = semCallInfoNormalized(n)
    return semCallInfoNormalizedName(info)

fn semCallInfoNormalized(n: Node): SemCallInfo =
    var info: SemCallInfo
    info.name = ""
    info.nameTextId = 0
    info.base = astInvalidNodeId()
    info.flags = 0
    if stage1AstRefIsNil(n) || nodeKind(n) != nkCall || kidCount(n) == 0:
        return info
    let nId: AstNodeId = astNodeIndex(n)
    if astNodeIdValid(nId):
        semEnsureCallInfoCache(nId)
        let idx: int32 = nId
        if idx >= 0 && idx < semCallInfoEpoch.len && idx < semCallInfoNameValues.len &&
           idx < semCallInfoNameTextValues.len && idx < semCallInfoBaseValues.len &&
           idx < semCallInfoFlagValues.len:
            if semCallInfoEpoch[idx] == semAnalyzeEpoch:
                info.name = semCallInfoNameValues[idx]
                info.nameTextId = semCallInfoNameTextValues[idx]
                info.base = semCallInfoBaseValues[idx]
                info.flags = semCallInfoFlagValues[idx]
                return info
    var callee: Node = kid(n, 0)
    if stage1AstRefNonNil(callee) && nodeKind(callee) == nkBracketExpr && kidCount(callee) > 0:
        callee = kid(callee, 0)
    var base: Node = astInvalidNodeId()
    var nameNode: Node = callee
    if stage1AstRefNonNil(callee) && nodeKind(callee) == nkDotExpr && kidCount(callee) > 1:
        base = kid(callee, 0)
        nameNode = kid(callee, 1)
    if stage1AstRefNonNil(nameNode) && (nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol):
        info.nameTextId = semCanonicalTextId("", nodeIdentId(nameNode))
    if info.nameTextId > 0:
        info.name = ""
    else:
        info.name = semNodeNameNormalized(nameNode)
    info.base = base
    info.flags = semCallNameFlagsOfNormalizedWithTextId(info.name, info.nameTextId)
    if astNodeIdValid(nId):
        let idx2: int32 = nId
        if idx2 >= 0 && idx2 < semCallInfoEpoch.len && idx2 < semCallInfoNameValues.len &&
           idx2 < semCallInfoNameTextValues.len && idx2 < semCallInfoBaseValues.len &&
           idx2 < semCallInfoFlagValues.len:
            semCallInfoEpoch[idx2] = semAnalyzeEpoch
            semCallInfoNameValues[idx2] = info.name
            semCallInfoNameTextValues[idx2] = info.nameTextId
            semCallInfoBaseValues[idx2] = info.base
            semCallInfoFlagValues[idx2] = info.flags
    return info

fn semCallNameNormalizedId(nId: AstNodeId): str =
    if !astNodeIdValid(nId) || astNodeKind(nId) != nkCall || astKidCount(nId) == 0:
        return ""
    return semCallInfoNormalizedName(semCallInfoNormalized(nId))

fn semIsShareCallName(nm: str): bool =
    return (semCallNameFlagsOfNormalized(nm) & semCallNameFlagShare) != 0

fn semIsBorrowedCallNameNormalized(nm: str): bool =
    return (semCallNameFlagsOfNormalized(nm) & semCallNameFlagBorrowed) != 0

fn semIsBorrowedCallName(name: str): bool =
    let nm: str = semNormalizeName(name)
    return semIsBorrowedCallNameNormalized(nm)

fn semIsExplicitPtrCallNameNormalized(nm: str): bool =
    return (semCallNameFlagsOfNormalized(nm) & semCallNameFlagExplicitPtr) != 0

fn semIsExplicitPtrCallName(name: str): bool =
    let nm: str = semNormalizeName(name)
    return semIsExplicitPtrCallNameNormalized(nm)

fn semIsStdPointerOpCallNameNormalized(nm: str): bool =
    return (semCallNameFlagsOfNormalized(nm) & semCallNameFlagStdPointerOp) != 0

fn semPolicyNodeFileName(inheritedFile: str, nodePath: str): str =
    if semLooksLikeModulePath(nodePath):
        return nodePath
    return inheritedFile

fn semPolicyStdFileName(fileName: str, ctxFilenameIsStd: bool, ctxFilename: str): str =
    if !semIsStdModulePath(fileName) && ctxFilenameIsStd:
        return ctxFilename
    return fileName

fn semPolicyNonCAbiFileName(fileName: str, ctxFilename: str): str =
    if !semLooksLikeModulePath(fileName):
        return ctxFilename
    return fileName

fn semCheckStdNoPointerPolicy(ctx: var SemCtx, rootId: AstNodeId): int32 =
    if !astNodeIdValid(rootId):
        return 0
    var hits: int32
    let ctxFilenameIsStd: bool = semIsStdModulePath(ctx.filename)
    var stackNodes: AstNodeId[]
    stackNodes.buffer = nil
    stackNodes.len = 0
    stackNodes.cap = 256
    var stackFiles: str[]
    stackFiles.buffer = nil
    stackFiles.len = 0
    stackFiles.cap = 256
    var visitedMods: bool[]
    visitedMods.buffer = nil
    visitedMods.len = 0
    visitedMods.cap = 0
    var policyFiles: str[]
    policyFiles.buffer = nil
    policyFiles.len = 0
    policyFiles.cap = 32
    var policyEnforce: int32[]
    policyEnforce.buffer = nil
    policyEnforce.len = 0
    policyEnforce.cap = 32
    add(stackNodes, rootId)
    add(stackFiles, ctx.filename)
    while stackNodes.len > 0:
        let lastIdx: int32 = stackNodes.len - 1
        let nId: AstNodeId = stackNodes[lastIdx]
        let inheritedFile: str = stackFiles[lastIdx]
        stackNodes.len = int(lastIdx)
        stackFiles.len = int(lastIdx)
        if !astNodeIdValid(nId):
            continue
        let nKind: NodeKind = astNodeKind(nId)
        if nKind == nkModule || nKind == nkStmtList:
            if !semMarkNodeIdMarked(visitedMods, nId):
                continue
        let fileName: str = semPolicyNodeFileName(inheritedFile, astNodeStrVal(nId))
        var shouldEnforceStdForFile: bool
        if len(fileName) > 0:
            var cachedDecision: int32 = -1
            for i in 0..<policyFiles.len:
                if semStrEq(policyFiles[i], fileName):
                    cachedDecision = policyEnforce[i]
                    break
            if cachedDecision < 0:
                let policyFile: str = semPolicyStdFileName(fileName, ctxFilenameIsStd, ctx.filename)
                cachedDecision = (semIsStdModulePath(policyFile) && !semIsStdPointerPolicyExempt(policyFile)) ? 1 : 0
                add(policyFiles, fileName)
                add(policyEnforce, cachedDecision)
            shouldEnforceStdForFile = cachedDecision == 1
        if shouldEnforceStdForFile:
            let policyFile: str = semPolicyStdFileName(fileName, ctxFilenameIsStd, ctx.filename)
            if semIsPtrLikeTypeNodeId(nId):
                semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("std policy: pointer types are forbidden in standard library"))
                hits = hits + 1
            elif nKind == nkHiddenDeref || nKind == nkDerefExpr:
                semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("std policy: pointer dereference is forbidden in standard library"))
                hits = hits + 1
            elif nKind == nkCall:
                let callName: str = semCallNameNormalizedId(nId)
                if semIsStdPointerOpCallNameNormalized(callName):
                    semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("std policy: pointer operation is forbidden in standard library: " + callName))
                    hits = hits + 1
            if hits == semStdNoPointerDiagLimit:
                semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("std policy: too many pointer violations; further diagnostics are suppressed"))
                return hits
        let childCount: int32 = semPolicyKidCountId(nId)
        for i in 0..<childCount:
            add(stackNodes, astKidAt(nId, i))
            add(stackFiles, fileName)
    return hits

fn semCheckNoPointerNonCAbiPolicy(ctx: var SemCtx, rootId: AstNodeId): int32 =
    if !astNodeIdValid(rootId):
        return 0
    var hits: int32
    var stackNodes: AstNodeId[]
    stackNodes.buffer = nil
    stackNodes.len = 0
    stackNodes.cap = 256
    var stackFiles: str[]
    stackFiles.buffer = nil
    stackFiles.len = 0
    stackFiles.cap = 256
    var visitedMods: bool[]
    visitedMods.buffer = nil
    visitedMods.len = 0
    visitedMods.cap = 0
    add(stackNodes, rootId)
    add(stackFiles, ctx.filename)
    while stackNodes.len > 0:
        let lastIdx: int32 = stackNodes.len - 1
        let nId: AstNodeId = stackNodes[lastIdx]
        let inheritedFile: str = stackFiles[lastIdx]
        stackNodes.len = int(lastIdx)
        stackFiles.len = int(lastIdx)
        if !astNodeIdValid(nId):
            continue
        let nKind: NodeKind = astNodeKind(nId)
        if nKind == nkModule || nKind == nkStmtList:
            if !semMarkNodeIdMarked(visitedMods, nId):
                continue
        let fileName: str = semPolicyNodeFileName(inheritedFile, astNodeStrVal(nId))
        let policyFile: str = semPolicyNonCAbiFileName(fileName, ctx.filename)
        if semPointerPolicyShouldCheckNonCAbi(policyFile):
            if semIsPtrLikeTypeNodeId(nId):
                if semIsVoidPtrTypeNodeId(nId):
                    semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("no-pointer policy: bare void* surface is forbidden in user modules"))
                    hits = hits + 1
                else:
                    semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("no-pointer policy: pointer types are forbidden in user modules"))
                    hits = hits + 1
            elif nKind == nkHiddenDeref || nKind == nkDerefExpr:
                semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("no-pointer policy: pointer dereference is forbidden in user modules"))
                hits = hits + 1
            elif nKind == nkCall:
                let callName: str = semCallNameNormalizedId(nId)
                if semIsStdPointerOpCallNameNormalized(callName):
                    semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("no-pointer policy: pointer operation is forbidden in user modules: " + callName))
                    hits = hits + 1
            if hits == semStdNoPointerDiagLimit:
                semAddErrorAtFile(ctx, policyFile, astNodePos(nId), rawPointerForbidMessage("no-pointer policy: too many violations; further diagnostics are suppressed"))
                return hits
        let childCount: int32 = semPolicyKidCountId(nId)
        for i in 0..<childCount:
            add(stackNodes, astKidAt(nId, i))
            add(stackFiles, fileName)
    return hits

