fn semThreadBoundaryTextPut(textId: int32, required: bool) =
    if textId <= 0:
        return
    semEnsureThreadBoundaryTextCache(textId)
    if textId < semThreadBoundaryTextReady.len && textId < semThreadBoundaryTextValue.len:
        semThreadBoundaryTextReady[textId] = true
        semThreadBoundaryTextValue[textId] = required

fn semFnSigTextGet(textId: int32, found: var bool): int32 =
    found = false
    if textId <= 0:
        return -1
    if textId >= semFnSigTextReady.len || textId >= semFnSigTextValue.len:
        return -1
    if !semFnSigTextReady[textId]:
        return -1
    found = true
    return semFnSigTextValue[textId]

fn semFnSigTextPut(textId: int32, sigIdx: int32) =
    if textId <= 0:
        return
    semEnsureFnSigTextCache(textId)
    if textId < semFnSigTextReady.len && textId < semFnSigTextValue.len:
        semFnSigTextReady[textId] = true
        semFnSigTextValue[textId] = sigIdx

fn semFnSigLinearFindTextId(ctx: var SemCtx, textId: int32): int32 =
    if textId <= 0:
        return -1
    let sigLen: int32 = ctx.fnSigTextIds.len
    if sigLen <= 0:
        return -1
    let __for_start_sig = sigLen - 1
    for __for_rev_sig in 0..(__for_start_sig):
        let sigIdx: int32 = __for_start_sig - __for_rev_sig
        if sigIdx < 0 || sigIdx >= ctx.fnSigTextIds.len:
            break
        if semReadI32(ctx.fnSigTextIds, sigIdx) == textId:
            return sigIdx
    return -1

fn semBorrowTextIndexGet(textId: int32, found: var bool): int32 =
    found = false
    if textId <= 0:
        return 0
    if textId >= semBorrowTextIndexReady.len || textId >= semBorrowTextIndexValue.len:
        return 0
    if !semBorrowTextIndexReady[textId]:
        return 0
    found = true
    return semBorrowTextIndexValue[textId]

fn semBorrowTextIndexPut(textId: int32, idxPlus1: int32) =
    if textId <= 0:
        return
    semEnsureBorrowTextIndexCache(textId)
    if textId < semBorrowTextIndexReady.len && textId < semBorrowTextIndexValue.len:
        semBorrowTextIndexReady[textId] = true
        semBorrowTextIndexValue[textId] = idxPlus1

