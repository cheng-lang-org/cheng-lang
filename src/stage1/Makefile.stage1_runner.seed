CC=gcc
CXX=g++
CFLAGS=-Iruntime/include -Isrc/runtime/native
CCLINKER=gcc

program: stage1_runner.seed.o system_helpers.o
	$(CCLINKER) -o stage1_runner.seed src/stage1/stage1_runner.seed.o src/stage1/system_helpers.o

stage1_runner.seed.o:
	$(CC) $(CFLAGS) -c src/stage1/stage1_runner.seed.c -o src/stage1/stage1_runner.seed.o
system_helpers.o:
	$(CC) $(CFLAGS) -c src/runtime/native/system_helpers.c -o src/stage1/system_helpers.o
