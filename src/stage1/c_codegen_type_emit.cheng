fn collectRecListFieldTypes(owner: str, recList: Node) =
    if owner == "" || recList == nil:
        return
    var i: int32 = 0
    while i < kidCount recList:
        let entry: Node = kid(recList, i)
        if entry != nil && entry.kind == nkIdentDefs:
            let typeNode: Node = identDefsType entry
            let nameCount: int32 = identDefsNameCount entry
            var j: int32 = 0
            while j < nameCount:
                var nameNode: Node = kid(entry, j)
                if nameNode != nil && nameNode.kind == nkPattern && kidCount nameNode > 0:
                    nameNode = kid(nameNode, 0)
                if nameNode != nil:
                    let fieldRaw: str = plainName nameNode
                    let fieldName: str = cgenStripSpaces fieldRaw
                    if !strIsEmpty(fieldName):
                        addFieldType(owner, fieldName, typeNode)
                j = j + 1
        elif entry != nil && entry.kind == nkRecCase:
            if kidCount entry > 0:
                let caseDefs: Node = kid(entry, 0)
                if caseDefs != nil && caseDefs.kind == nkIdentDefs:
                    let tagType: Node = identDefsType caseDefs
                    let tagCount: int32 = identDefsNameCount caseDefs
                    var tj: int32 = 0
                    while tj < tagCount:
                        var tagName: Node = kid(caseDefs, tj)
                        if tagName != nil && tagName.kind == nkPattern && kidCount tagName > 0:
                            tagName = kid(tagName, 0)
                        if tagName != nil:
                            let raw: str = plainName tagName
                            let name: str = cgenStripSpaces raw
                            if !strIsEmpty(name):
                                addFieldType(owner, name, tagType)
                        tj = tj + 1
            var bi: int32 = 1
            while bi < kidCount entry:
                let branch: Node = kid(entry, bi)
                var body: Node = nil
                if branch != nil && branch.kind == nkOfBranch && kidCount branch > 1:
                    body = kid(branch, 1)
                elif branch != nil && branch.kind == nkElse && kidCount branch > 0:
                    body = kid(branch, 0)
                if body != nil && body.kind == nkRecList:
                    collectRecListFieldTypes(owner, body)
                bi = bi + 1
        i = i + 1

fn collectObjectFieldTypes(owner: str, objDef: Node) =
    if owner == "" || objDef == nil:
        return
    var recList: Node = nil
    if kidCount objDef > 1:
        recList = kid(objDef, 1)
    if recList == nil:
        return
    collectRecListFieldTypes(owner, recList)

fn recCaseBranchBody(entry: Node, idx: int32): Node =
    if entry == nil:
        return nil
    if idx < 0 || idx >= kidCount entry:
        return nil
    let branch: Node = kid(entry, idx)
    if branch == nil:
        return nil
    if branch.kind == nkOfBranch && kidCount branch > 1:
        return kid(branch, 1)
    if branch.kind == nkElse && kidCount branch > 0:
        return kid(branch, 0)
    return nil

fn emitObjectFields(w: CWriter*, recList: Node) =
    if recList == nil:
        return
    var i: int32 = 0
    while i < kidCount recList:
        let entry: Node = kid(recList, i)
        if entry != nil && entry.kind == nkIdentDefs:
            let typeNode: Node = identDefsType entry
            let nameCount: int32 = identDefsNameCount entry
            var j: int32 = 0
            while j < nameCount:
                var nameNode: Node = kid(entry, j)
                if nameNode != nil && nameNode.kind == nkPattern && kidCount nameNode > 0:
                    nameNode = kid(nameNode, 0)
                if nameNode != nil:
                    let fieldRaw: str = plainName nameNode
                    let fieldName: str = cgenStripSpaces fieldRaw
                    if !strIsEmpty(fieldName):
                        cwIndent w
                        emitTypeName(w, typeNode)
                        cwWrite(w, " ")
                        cwWrite(w, cgenEscapeCIdent(fieldName))
                        cwWrite(w, ";")
                        cwNewline w
                j = j + 1
        elif entry != nil && entry.kind == nkRecCase:
            emitRecCaseFields(w, entry)
        i = i + 1

fn emitRecCaseFields(w: CWriter*, entry: Node) =
    if entry == nil || entry.kind != nkRecCase:
        return
    if kidCount entry > 0:
        let defs: Node = kid(entry, 0)
        if defs != nil && defs.kind == nkIdentDefs:
            let typeNode: Node = identDefsType defs
            let nameCount: int32 = identDefsNameCount defs
            var j: int32 = 0
            while j < nameCount:
                var nameNode: Node = kid(defs, j)
                if nameNode != nil && nameNode.kind == nkPattern && kidCount nameNode > 0:
                    nameNode = kid(nameNode, 0)
                if nameNode != nil:
                    let fieldRaw: str = plainName nameNode
                    let fieldName: str = cgenStripSpaces fieldRaw
                    if !strIsEmpty(fieldName):
                        cwIndent w
                        emitTypeName(w, typeNode)
                        cwWrite(w, " ")
                        cwWrite(w, cgenEscapeCIdent(fieldName))
                        cwWrite(w, ";")
                        cwNewline w
                j = j + 1
    var hasUnion: bool = false
    var i: int32 = 1
    while i < kidCount entry:
        let body: Node = recCaseBranchBody(entry, i)
        if body != nil && recListHasFields body:
            hasUnion = true
            break
        i = i + 1
    if ! hasUnion:
        return
    cwIndent w
    cwWriteLine(w, "union {")
    cwIndentPush w
    i = 1
    while i < kidCount entry:
        let body2: Node = recCaseBranchBody(entry, i)
        if body2 != nil && recListHasFields body2:
            cwIndent w
            cwWriteLine(w, "struct {")
            cwIndentPush w
            emitObjectFields(w, body2)
            cwIndentPop w
            cwIndent w
            cwWriteLine(w, "};")
        i = i + 1
    cwIndentPop w
    cwIndent w
    cwWriteLine(w, "};")

fn cgenEmitLayoutChecks(w: CWriter*, tagName: str, objDef: Node, packed: bool, alignVal: int32) =
    if objDef == nil:
        return
    let ctagName: str = cgenEscapeCIdent(tagName)
    var fieldNames: seq[str] = newSeqWithCap[str](0, 8)
    var fieldTypes: seq[Node] = newSeqWithCap[Node](0, 8)
    let base: Node = kid(objDef, 0)
    if base != nil && base.kind != nkEmpty:
        addPtr[str](&fieldNames, "__base")
        addPtr[Node](&fieldTypes, base)
    var recList: Node = nil
    if kidCount objDef > 1:
        recList = kid(objDef, 1)
    if recList != nil:
        var i: int32 = 0
        while i < kidCount recList:
            let entry: Node = kid(recList, i)
            if entry != nil && entry.kind == nkIdentDefs:
                let typeNode: Node = identDefsType entry
                let nameCount: int32 = identDefsNameCount entry
                var j: int32 = 0
                while j < nameCount:
                    var nameNode: Node = kid(entry, j)
                    if nameNode != nil && nameNode.kind == nkPattern && kidCount nameNode > 0:
                        nameNode = kid(nameNode, 0)
                    if nameNode != nil:
                        let fieldRaw: str = plainName nameNode
                        let fieldName: str = cgenStripSpaces fieldRaw
                        if !strIsEmpty(fieldName):
                            addPtr[str](&fieldNames, fieldName)
                            addPtr[Node](&fieldTypes, typeNode)
                    j = j + 1
            elif entry != nil && entry.kind == nkRecCase:
                if kidCount entry > 0:
                    let defs: Node = kid(entry, 0)
                    if defs != nil && defs.kind == nkIdentDefs:
                        let typeNode2: Node = identDefsType defs
                        let nameCount2: int32 = identDefsNameCount defs
                        var k: int32 = 0
                        while k < nameCount2:
                            var nameNode2: Node = kid(defs, k)
                            if nameNode2 != nil && nameNode2.kind == nkPattern && kidCount nameNode2 > 0:
                                nameNode2 = kid(nameNode2, 0)
                            if nameNode2 != nil:
                                let fieldRaw2: str = plainName nameNode2
                                let fieldName2: str = cgenStripSpaces fieldRaw2
                                if !strIsEmpty(fieldName2):
                                    addPtr[str](&fieldNames, fieldName2)
                                    addPtr[Node](&fieldTypes, typeNode2)
                            k = k + 1
            i = i + 1
    if fieldNames.len == 0:
        return
    var offsetExpr: str = "0"
    var maxAlignExpr: str = "1"
    if alignVal > 0:
        maxAlignExpr = int64ToStr alignVal
    var fi: int32 = 0
    while fi < fieldNames.len:
        let fname: str = get[str](fieldNames, fi)
        let cfname: str = cgenEscapeCIdent(fname)
        let ftype: Node = get[Node](fieldTypes, fi)
        let typeStr: str = typeNameToStr ftype
        let sizeExpr: str = "sizeof(" + typeStr + ")"
        let alignExpr: str = "CHENG_ALIGNOF(" + typeStr + ")"
        if ! packed:
            offsetExpr = "CHENG_C_ALIGN_UP(" + offsetExpr + ", " + alignExpr + ")"
            maxAlignExpr = "CHENG_C_MAX(" + maxAlignExpr + ", " + alignExpr + ")"
        cwIndent w
        cwWrite(w, "CHENG_C_STATIC_ASSERT(offsetof(struct ")
        cwWrite(w, ctagName)
        cwWrite(w, ", ")
        cwWrite(w, cfname)
        cwWrite(w, ") == ")
        cwWrite(w, offsetExpr)
        cwWrite(w, ", \"layout ")
        cwWrite(w, ctagName)
        cwWrite(w, ".")
        cwWrite(w, cfname)
        cwWrite(w, "\");")
        cwNewline w
        offsetExpr = offsetExpr + " + " + sizeExpr
        fi = fi + 1
    var sizeExpr2: str = offsetExpr
    if packed:
        if alignVal > 0:
            sizeExpr2 = "CHENG_C_ALIGN_UP(" + offsetExpr + ", " + int64ToStr(alignVal) + ")"
    else:
        sizeExpr2 = "CHENG_C_ALIGN_UP(" + offsetExpr + ", " + maxAlignExpr + ")"
    cwIndent w
    cwWrite(w, "CHENG_C_STATIC_ASSERT(sizeof(struct ")
    cwWrite(w, ctagName)
    cwWrite(w, ") == ")
    cwWrite(w, sizeExpr2)
    cwWrite(w, ", \"layout ")
    cwWrite(w, ctagName)
    cwWrite(w, ".size\");")
    cwNewline w

fn cgenEmitObjectDecl(w: CWriter*, tagName: str, objDef: Node, packed: bool, alignVal: int32) =
    if objDef == nil:
        return
    let ctagName: str = cgenEscapeCIdent(tagName)
    let base: Node = kid(objDef, 0)
    var recList: Node = nil
    if kidCount objDef > 1:
        recList = kid(objDef, 1)
    if packed:
        cwWriteLine(w, "CHENG_C_PACKED_BEGIN")
    if alignVal > 0:
        cwWrite(w, "CHENG_C_ALIGN_PREFIX(")
        cwWrite(w, int64ToStr alignVal)
        cwWrite(w, ") ")
    cwWrite(w, "struct ")
    cwWrite(w, ctagName)
    cwWrite(w, " {")
    cwNewline w
    cwIndentPush w
    if base != nil && base.kind != nkEmpty:
        cwIndent w
        emitTypeName(w, base)
        cwWrite(w, " __base;")
        cwNewline w
    if recListHasFields recList:
        emitObjectFields(w, recList)
    else:
        emitBuiltinObjectFields(w, tagName)
    cwIndentPop w
    cwIndent w
    cwWrite(w, "}")
    if packed:
        if alignVal > 0:
            cwWrite(w, " CHENG_C_PACKED_ALIGN_SUFFIX(")
            cwWrite(w, int64ToStr alignVal)
            cwWrite(w, ")")
        else:
            cwWrite(w, " CHENG_C_PACKED_SUFFIX")
    else:
        if alignVal > 0:
            cwWrite(w, " CHENG_C_ALIGN_SUFFIX(")
            cwWrite(w, int64ToStr alignVal)
            cwWrite(w, ")")
    cwWrite(w, ";")
    cwNewline w
    if packed:
        cwWriteLine(w, "CHENG_C_PACKED_END")
    if packed || alignVal > 0:
        cgenEmitLayoutChecks(w, tagName, objDef, packed, alignVal)
    cwNewline w

fn cgenEmitEnumDecl(w: CWriter*, name: str, def: Node) =
    if def == nil:
        return
    cwWrite(w, "enum ")
    cwWrite(w, name)
    cwWrite(w, " {")
    cwNewline w
    cwIndentPush w
    var i: int32 = 0
    while i < kidCount def:
        let field: Node = kid(def, i)
        if field != nil && field.kind == nkEnumFieldDecl && kidCount field > 0:
            let nameNode: Node = kid(field, 0)
            var valNode: Node = nil
            if kidCount field > 1:
                valNode = kid(field, 1)
            let fnameRaw: str = plainName nameNode
            let fname: str = cgenStripSpaces fnameRaw
            if !strIsEmpty fname:
                cwIndent w
                cwWrite(w, cgenEscapeCIdent(fname))
                if valNode != nil && valNode.kind != nkEmpty:
                    cwWrite(w, " = ")
                    cgenEmitExpr(w, valNode)
                if i + 1 < kidCount def:
                    cwWrite(w, ",")
                cwNewline w
        i = i + 1
    cwIndentPop w
    cwWriteLine(w, "};")
    cwNewline w

fn emitTypeAlias(w: CWriter*, name: str, def: Node) =
    if name == "" || def == nil:
        return
    cwWrite(w, "typedef ")
    emitTypeName(w, def)
    cwWrite(w, " ")
    cwWrite(w, name)
    cwWrite(w, ";")
    cwNewline w

fn cgenEmitArrayDecl(w: CWriter*, name: str, def: Node) =
    if w == nil || name == "" || def == nil:
        return
    if def.kind != nkBracketExpr || kidCount def < 3:
        return
    var lenNode: Node = nil
    var elemNode: Node = nil
    if !cgenCanonicalArrayArgs(def, &lenNode, &elemNode):
        lenNode = kid(def, 1)
        elemNode = kid(def, 2)
    cwWrite(w, "typedef struct ")
    cwWrite(w, name)
    cwWrite(w, " {")
    cwNewline w
    cwIndentPush w
    cwIndent w
    emitTypeName(w, elemNode)
    cwWrite(w, " data[")
    var lenVal: int64 = 0
    if lenNode != nil && lenNode.kind != nkEmpty && cgenConstIntValueFromExpr(lenNode, &lenVal):
        cwWrite(w, int64ToStr lenVal)
    else:
        cgenAddError(def.pos, "C backend requires array length as const int")
        cwWrite(w, "0")
    cwWrite(w, "];")
    cwNewline w
    cwIndentPop w
    cwWrite(w, "} ")
    cwWrite(w, name)
    cwWrite(w, ";")
    cwNewline w
    cwNewline w

fn typeNameIndex(names: seq[str], name: str): int32 =
    if name == nil || len name == 0:
        return -1
    var i: int32 = 0
    while i < names.len:
        if get[str](names, i) == name:
            return i
        i = i + 1
    return -1

fn cgenArrayTypeClear() =
    cgenArrayTypeKeys.len = 0
    cgenArrayTypeDecls.len = 0
    hashsets.hashSetStrClear(&cgenArrayTypeKeySet)

fn cgenArrayTypeHas(name: str): bool =
    if name == nil || len name == 0:
        return false
    return strSeqHas(&cgenArrayTypeKeys, name)

fn cgenTupleTypeClear() =
    cgenTupleTypeKeys.len = 0
    cgenTupleTypeDecls.len = 0
    hashsets.hashSetStrClear(&cgenTupleTypeKeySet)

fn cgenTupleTypeHas(name: str): bool =
    if name == nil || len name == 0:
        return false
    return strSeqHas(&cgenTupleTypeKeys, name)

fn cgenConstIntClear() =
    cgenConstIntNames.len = 0
    cgenConstIntValues.len = 0
    hashsets.hashSetStrClear(&cgenConstIntNameSet)

fn cgenConstIntDefine(name: str, value: int64) =
    if name == nil || len name == 0:
        return
    if strSeqHas(&cgenConstIntNames, name):
        return
    addPtr[str](&cgenConstIntNames, name)
    hashsets.hashSetStrAdd(&cgenConstIntNameSet, name)
    addPtr[int64](&cgenConstIntValues, value)

fn cgenConstIntLookup(name: str, outVal: int64*): bool =
    if name == nil || len name == 0:
        return false
    var i: int32 = cgenConstIntNames.len - 1
    while i >= 0:
        if get[str](cgenConstIntNames, i) == name:
            if outVal != nil:
                *outVal = get[int64](cgenConstIntValues, i)
            return true
        i = i - 1
    return false

fn cgenCollectEnumConstInts(def: Node) =
    if def == nil || def.kind != nkEnumDecl:
        return
    var nextVal: int64 = 0
    var i: int32 = 0
    while i < kidCount def:
        let field: Node = kid(def, i)
        if field != nil && field.kind == nkEnumFieldDecl && kidCount field > 0:
            let nameNode: Node = kid(field, 0)
            let nm: str = cgenIdentNameNormalized(nameNode)
            if nm != "":
                var v: int64 = nextVal
                if kidCount field > 1:
                    let valNode: Node = kid(field, 1)
                    if valNode != nil && valNode.kind != nkEmpty:
                        var tmp: int64 = 0
                        if cgenConstIntValueFromExpr(valNode, &tmp):
                            v = tmp
                cgenConstIntDefine(nm, v)
                nextVal = v + 1
        i = i + 1

fn cgenConstIntValueFromExpr(n: Node, outVal: int64*): bool =
    if n == nil:
        return false
    case n.kind
    of nkIntLit:
        if outVal != nil:
            *outVal = n.intVal
        return true
    of nkIdent, nkSymbol:
        let nm: str = cgenStripSpaces n.ident
        return cgenConstIntLookup(nm, outVal)
    of nkDotExpr:
        if kidCount n >= 2:
            let member: Node = kid(n, 1)
            if member != nil && (member.kind == nkIdent || member.kind == nkSymbol):
                let nm: str = cgenStripSpaces member.ident
                return cgenConstIntLookup(nm, outVal)
        return false
    of nkPar:
        if kidCount n == 1:
            return cgenConstIntValueFromExpr(kid(n, 0), outVal)
        return false
    of nkPrefix:
        if kidCount n > 1:
            let opNode: Node = kid(n, 0)
            let rhs: Node = kid(n, 1)
            let opName: str = plainName(opNode)
            var tmp: int64 = 0
            if (opName == "-" || opName == "+") && cgenConstIntValueFromExpr(rhs, &tmp):
                if opName == "-":
                    tmp = 0 - tmp
                if outVal != nil:
                    *outVal = tmp
                return true
        return false
    of nkInfix:
        if kidCount n > 2:
            let opNode: Node = kid(n, 0)
            let lhs: Node = kid(n, 1)
            let rhs: Node = kid(n, 2)
            let opName: str = plainName(opNode)
            var lv: int64 = 0
            var rv: int64 = 0
            if cgenConstIntValueFromExpr(lhs, &lv) && cgenConstIntValueFromExpr(rhs, &rv):
                if opName == "+":
                    if outVal != nil:
                        *outVal = lv + rv
                    return true
                if opName == "-":
                    if outVal != nil:
                        *outVal = lv - rv
                    return true
        return false
    else:
        return false

fn cgenCollectConstInts(n: Node) =
    if n == nil:
        return
    case n.kind
    of nkModule, nkStmtList:
        var i: int32 = 0
        while i < kidCount n:
            cgenCollectConstInts kid(n, i)
            i = i + 1
    of nkConst:
        let nameNode: Node = cgenVarNameNode n
        var valNode: Node = nil
        if kidCount n > 2:
            valNode = kid(n, 2)
        if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol) && valNode != nil:
            var v: int64 = 0
            if cgenConstIntValueFromExpr(valNode, &v):
                cgenConstIntDefine(cgenStripSpaces(nameNode.ident), v)
    else:
        var j: int32 = 0
        while j < kidCount n:
            cgenCollectConstInts kid(n, j)
            j = j + 1

fn addTypeDep(out: seq[str]*, names: seq[str], name: str) =
    if out == nil:
        return
    if typeNameIndex(names, name) < 0:
        return
    if strSeqHas(out, name):
        return
    addPtr[str](out, name)

fn collectTypeDepsFromAlias(name: str, names: seq[str], out: seq[str]*, visited: seq[str]*) =
    if out == nil || name == nil || len name == 0:
        return
    if visited != nil && strSeqHas(visited, name):
        return
    if visited != nil:
        addPtr[str](visited, name)
    let def: Node = lookupTypeDef name
    if def == nil:
        return
    let cur: Node = unwrapParType def
    if cur == nil:
        return
    if cur.kind == nkPtrTy || cur.kind == nkRefTy || cur.kind == nkVarTy:
        return
    if cur.kind == nkIdent || cur.kind == nkSymbol:
        let aliasName: str = cgenStripSpaces cur.ident
        if aliasName != name:
            addTypeDep(out, names, aliasName)
            collectTypeDepsFromAlias(aliasName, names, out, visited)
        return
    if cur.kind == nkBracketExpr:
        let key: str = cgenTypeKey cur
        if len key > 0:
            addTypeDep(out, names, key)
        return
    if cur.kind == nkTupleTy:
        let key2: str = cgenEnsureTupleDecl cur
        if len key2 > 0:
            addTypeDep(out, names, key2)
        return

fn collectTypeDepsFromNode(ty: Node, names: seq[str], out: seq[str]*) =
    if ty == nil:
        return
    let cur: Node = unwrapParType ty
    if cur == nil:
        return
    if cur.kind == nkPtrTy || cur.kind == nkRefTy || cur.kind == nkVarTy:
        return
    if cur.kind == nkIdent || cur.kind == nkSymbol:
        let name: str = cgenStripSpaces cur.ident
        addTypeDep(out, names, name)
        var visited: seq[str] = newSeqWithCap[str](0, 4)
        collectTypeDepsFromAlias(name, names, out, &visited)
        return
    if cur.kind == nkBracketExpr:
        let key: str = cgenTypeKey cur
        if len key > 0:
            addTypeDep(out, names, key)
        return
    if cur.kind == nkTupleTy:
        var i: int32 = 0
        while i < kidCount cur:
            collectTypeDepsFromNode(kid(cur, i), names, out)
            i = i + 1
        return
    var j: int32 = 0
    while j < kidCount cur:
        collectTypeDepsFromNode(kid(cur, j), names, out)
        j = j + 1

fn collectTypeDeclDeps(td: Node, names: seq[str], out: seq[str]*) =
    if td == nil || out == nil:
        return
    let def: Node = typeDeclDef td
    let refObj: Node = typeDeclRefObjectDef def
    var objDef: Node = def
    if refObj != nil:
        objDef = refObj
    if objDef == nil || objDef.kind != nkObjectDecl:
        if def != nil && cgenIsArrayTypeExpr(def):
            if kidCount def > 2:
                collectTypeDepsFromNode(kid(def, 2), names, out)
        return
    var recList: Node = nil
    if kidCount objDef > 1:
        recList = kid(objDef, 1)
    if recList == nil:
        return
    var i: int32 = 0
    while i < kidCount recList:
        let entry: Node = kid(recList, i)
        if entry != nil && entry.kind == nkIdentDefs:
            let typeNode: Node = identDefsType entry
            collectTypeDepsFromNode(typeNode, names, out)
        elif entry != nil && entry.kind == nkRecCase:
            if kidCount entry > 0:
                let defs: Node = kid(entry, 0)
                if defs != nil && defs.kind == nkIdentDefs:
                    let tagType: Node = identDefsType defs
                    collectTypeDepsFromNode(tagType, names, out)
            var bi: int32 = 1
            while bi < kidCount entry:
                let branch: Node = kid(entry, bi)
                var body: Node = nil
                if branch != nil && branch.kind == nkOfBranch && kidCount branch > 1:
                    body = kid(branch, 1)
                elif branch != nil && branch.kind == nkElse && kidCount branch > 0:
                    body = kid(branch, 0)
                if body != nil && body.kind == nkRecList:
                    var bj: int32 = 0
                    while bj < kidCount body:
                        let inner: Node = kid(body, bj)
                        if inner != nil && inner.kind == nkIdentDefs:
                            let innerType: Node = identDefsType inner
                            collectTypeDepsFromNode(innerType, names, out)
                        elif inner != nil && inner.kind == nkRecCase:
                            if kidCount inner > 0:
                                let defs2: Node = kid(inner, 0)
                                if defs2 != nil && defs2.kind == nkIdentDefs:
                                    collectTypeDepsFromNode(identDefsType defs2, names, out)
                        bj = bj + 1
                bi = bi + 1
        i = i + 1

fn orderTypeDeclsVisit(idx: int32, decls: seq[Node], names: seq[str], deps: seq[seq[str]],
                       temp: seq[bool]*, perm: seq[bool]*, out: seq[Node]*) =
    if idx < 0 || idx >= decls.len:
        return
    if get[bool](*perm, idx):
        return
    if get[bool](*temp, idx):
        return
    setPtr[bool](temp, idx, true)
    let depList2: seq[str] = get[seq[str]](deps, idx)
    var i1: int32 = 0
    while i1 < depList2.len:
        let depName: str = get[str](depList2, i1)
        let depIdx: int32 = typeNameIndex(names, depName)
        if depIdx >= 0:
            orderTypeDeclsVisit(depIdx, decls, names, deps, temp, perm, out)
        i1 = i1 + 1
    setPtr[bool](temp, idx, false)
    setPtr[bool](perm, idx, true)
    addPtr[Node](out, get[Node](decls, idx))

fn orderTypeDecls(decls: seq[Node]): seq[Node] =
    var out: seq[Node] = newSeqWithCap[Node](0, decls.len)
    if decls.len <= 1:
        var i0: int32 = 0
        while i0 < decls.len:
            addPtr[Node](&out, get[Node](decls, i0))
            i0 = i0 + 1
        return out
    var names: seq[str] = newSeqWithCap[str](0, decls.len)
    var di: int32 = 0
    while di < decls.len:
        addPtr[str](&names, typeDeclName get[Node](decls, di))
        di = di + 1
    var deps: seq[seq[str]] = newSeqWithCap[seq[str]](0, decls.len)
    di = 0
    while di < decls.len:
        var depList: seq[str] = newSeqWithCap[str](0, 4)
        collectTypeDeclDeps(get[Node](decls, di), names, &depList)
        addPtr[seq[str]](&deps, depList)
        di = di + 1
    var temp: seq[bool] = newSeqWithCap[bool](0, decls.len)
    var perm: seq[bool] = newSeqWithCap[bool](0, decls.len)
    temp.len = decls.len
    perm.len = decls.len
    di = 0
    while di < decls.len:
        orderTypeDeclsVisit(di, decls, names, deps, &temp, &perm, &out)
        di = di + 1
    return out

fn emitTypeForwardDeclsFromDecls(w: CWriter*, decls: seq[Node]) =
    var seen: seq[str] = newSeqWithCap[str](0, 64)
    var i: int32 = 0
    while i < decls.len:
        let td: Node = get[Node](decls, i)
        let name: str = typeDeclName td
        let def: Node = typeDeclDef td
        let refObj: Node = typeDeclRefObjectDef def
        if !strIsEmpty name:
            if strSeqHas(&seen, name):
                i = i + 1
                continue
            addPtr[str](&seen, name)
            if refObj != nil:
                let tag: str = refStructTag name
                cwWriteLine(w, "typedef struct " + tag + " " + tag + ";")
                cwWriteLine(w, "typedef struct " + tag + "* " + name + ";")
            elif def != nil && def.kind == nkObjectDecl:
                cwWriteLine(w, "typedef struct " + name + " " + name + ";")
            elif def != nil && def.kind == nkEnumDecl:
                cwWriteLine(w, "typedef enum " + name + " " + name + ";")
        i = i + 1
    cwNewline w

fn emitTypeForwardDecls(w: CWriter*, root: Node) =
    let decls: seq[Node] = dedupTypeDecls(collectAllTypeDecls(root))
    emitTypeForwardDeclsFromDecls(w, decls)

fn emitTypeDeclsFromDecls(w: CWriter*, decls: seq[Node]) =
    let ordered: seq[Node] = orderTypeDecls(decls)
    var seen: seq[str] = newSeqWithCap[str](0, 64)
    var i: int32 = 0
    while i < ordered.len:
        let td: Node = get[Node](ordered, i)
        let name: str = typeDeclName td
        let def: Node = typeDeclDef td
        let refObj: Node = typeDeclRefObjectDef def
        if !strIsEmpty name:
            if strSeqHas(&seen, name):
                i = i + 1
                continue
            addPtr[str](&seen, name)
            let packed: bool = cgenTypeDeclPacked td
            let alignVal: int32 = cgenTypeDeclAlign td
            if refObj != nil:
                let tag: str = refStructTag name
                cgenEmitObjectDecl(w, tag, refObj, packed, alignVal)
                cwNewline w
            elif def != nil && def.kind == nkObjectDecl:
                cgenEmitObjectDecl(w, name, def, packed, alignVal)
            elif def != nil && def.kind == nkEnumDecl:
                cgenEmitEnumDecl(w, name, def)
            elif def != nil && cgenIsArrayTypeExpr(def) && strStartsWith(name, "array_"):
                cgenEmitArrayDecl(w, name, def)
            else:
                if packed || alignVal > 0:
                    cgenAddError(td.pos, "packed/align applies only to object types")
                emitTypeAlias(w, name, def)
        i = i + 1

fn emitTypeDecls(w: CWriter*, root: Node) =
    let decls: seq[Node] = dedupTypeDecls(collectAllTypeDecls(root))
    collectFnTypes(root)
    emitFnTypeDecls(w)
    emitTypeDeclsFromDecls(w, decls)

fn cgenEmitDefaultValue(w: CWriter*, n: Node) =
    if n == nil:
        cwWrite(w, "0")
        return
    if n.kind == nkBracketExpr:
        let key: str = cgenTypeKey n
        if len key > 0:
            cwWriteChar(w, '(')
            cwWrite(w, key)
            cwWrite(w, "){0}")
            return
    if n.kind == nkTupleTy:
        let key2: str = cgenEnsureTupleDecl n
        if len key2 > 0:
            cwWriteChar(w, '(')
            cwWrite(w, key2)
            cwWrite(w, "){0}")
            return
    if n.kind == nkIdent || n.kind == nkSymbol:
        let tname: str = cgenStripSpaces n.ident
        if tname == "bool":
            cwWrite(w, "0")
            return
        if tname == "float" || tname == "float64" || tname == "float32":
            cwWrite(w, "0.0")
            return
        if tname == "char":
            cwWrite(w, "0")
            return
        if tname == "cstring" || tname == "str" || tname == "string":
            cwWrite(w, "\"\"")
            return
        if tname == "void":
            cwWrite(w, "0")
            return
        if isRefTypeName tname:
            cwWrite(w, "CHENG_NIL")
            return
        let resolved: str = cgenTypeNameResolve tname
        if isKnownTypeName resolved:
            cwWriteChar(w, '(')
            cwWrite(w, resolved)
            cwWrite(w, "){0}")
            return
        if len tname > 0:
            cwWriteChar(w, '(')
            cwWrite(w, tname)
            cwWrite(w, "){0}")
            return
    if n.kind == nkPtrTy || n.kind == nkRefTy || n.kind == nkVarTy:
        cwWrite(w, "CHENG_NIL")
        return
    if n.kind == nkPostfix && kidCount n > 1:
        let opn0: Node = kid(n, 0)
        let opn1: Node = kid(n, 1)
        if opn0 != nil && cgenStripSpaces(opn0.ident) == "*":
            cwWrite(w, "CHENG_NIL")
            return
        if opn1 != nil && cgenStripSpaces(opn1.ident) == "*":
            cwWrite(w, "CHENG_NIL")
            return
    if n.kind == nkInfix && kidCount n >= 3:
        let opn2: Node = kid(n, 0)
        if opn2 != nil && cgenStripSpaces(opn2.ident) == "*":
            let rhs: Node = kid(n, 2)
            if rhs == nil || rhs.kind == nkEmpty:
                cwWrite(w, "CHENG_NIL")
                return
        let opnMid: Node = kid(n, 1)
        if opnMid != nil && cgenStripSpaces(opnMid.ident) == "*":
            let rhsMid: Node = kid(n, 2)
            if rhsMid == nil || rhsMid.kind == nkEmpty:
                cwWrite(w, "CHENG_NIL")
                return
    cwWrite(w, "0")

fn isConstExpr(n: Node): bool =
    if n == nil || n.kind == nkEmpty:
        return true
    case n.kind
    of nkIntLit, nkFloatLit, nkStrLit, nkCharLit, nkBoolLit, nkNilLit:
        return true
    of nkIdent, nkSymbol:
        let nm: str = cgenStripSpaces n.ident
        return cgenConstIntLookup(nm, nil)
    of nkDotExpr:
        if kidCount n >= 2:
            let member: Node = kid(n, 1)
            if member != nil && (member.kind == nkIdent || member.kind == nkSymbol):
                let nm: str = cgenStripSpaces member.ident
                return cgenConstIntLookup(nm, nil)
        return false
    of nkPar:
        if kidCount n == 1:
            return isConstExpr kid(n, 0)
        return false
    of nkPrefix:
        if kidCount n > 1:
            return isConstExpr kid(n, 1)
        return false
    of nkInfix:
        if kidCount n >= 3:
            return isConstExpr kid(n, 1) && isConstExpr kid(n, 2)
        return false
    else:
        return false

fn addLocalVar(name: str, typeNode: Node) =
    if name == "":
        return
    let idx: int32 = localVarNames.len
    addPtr[str](&localVarNames, name)
    addPtr[Node](&localVarTypes, typeNode)
    hashmaps.hashMapStrIntPut(&localVarIndex, name, idx)
    cgenScopeTrackLocal(name, typeNode)

fn addGlobalVar(name: str, typeNode: Node) =
    if name == "":
        return
    let idx: int32 = globalVarNames.len
    addPtr[str](&globalVarNames, name)
    addPtr[Node](&globalVarTypes, typeNode)
    hashmaps.hashMapStrIntPut(&globalVarIndex, name, idx)

fn addGlobalInit(name: str, val: Node) =
    if name == "" || val == nil:
        return
    addPtr[str](&globalInitNames, name)
    addPtr[Node](&globalInitExprs, val)
    hasGlobalInit = true

fn cgenIsFloatTypeNode(n: Node): bool =
    if n == nil:
        return false
    if n.kind == nkIdent || n.kind == nkSymbol:
        let tname: str = cgenStripSpaces n.ident
        return tname == "float" || tname == "float32" || tname == "float64"
    return false

fn inferSimpleTypeNode(n: Node): Node =
    if n == nil:
        return nil
    let kids: seq[void*] = n.kids
    let count: int32 = kids.len
    case n.kind
    of nkIntLit:
        return newIdent("int", n.pos)
    of nkFloatLit:
        return newIdent("float64", n.pos)
    of nkBoolLit:
        return newIdent("bool", n.pos)
    of nkCharLit:
        return newIdent("char", n.pos)
    of nkStrLit:
        return newIdent("str", n.pos)
    of nkIdent, nkSymbol:
        let nm: str = cgenStripSpaces n.ident
        if nm == "true" || nm == "false":
            return newIdent("bool", n.pos)
        let t0: Node = lookupVarType nm
        if t0 != nil && t0.kind != nkEmpty:
            return t0
        return nil
    of nkDotExpr:
        if count >= 2:
            let base: Node = Node(get[void*](kids, 0))
            let member: Node = Node(get[void*](kids, 1))
            let mraw: str = plainName member
            let mname: str = cgenStripSpaces mraw
            let baseType0: Node = inferSimpleTypeNode base
            var baseType: Node = stripVarType baseType0
            if baseType != nil && (baseType.kind == nkPtrTy || baseType.kind == nkRefTy):
                if kidCount baseType > 0:
                    baseType = stripVarType kid(baseType, 0)
            var owner: str = ""
            if baseType != nil:
                if baseType.kind == nkIdent || baseType.kind == nkSymbol:
                    owner = cgenStripSpaces baseType.ident
                elif baseType.kind == nkDotExpr && kidCount(baseType) > 1:
                    owner = cgenStripSpaces(plainName(kid(baseType, 1)))
            # Resolve aliases like `JsonNode = ref JsonNode_obj` so dot-field typing works.
            if !strIsEmpty(owner):
                var steps: int32 = 0
                while steps < 6:
                    let def: Node = lookupTypeDef owner
                    if def == nil:
                        break
                    var defCur: Node = unwrapParType(stripVarType(def))
                    if defCur != nil && (defCur.kind == nkPtrTy || defCur.kind == nkRefTy || defCur.kind == nkVarTy):
                        if kidCount(defCur) > 0:
                            defCur = unwrapParType(stripVarType(kid(defCur, 0)))
                    var nextOwner: str = ""
                    if defCur != nil:
                        if defCur.kind == nkIdent || defCur.kind == nkSymbol:
                            nextOwner = cgenStripSpaces defCur.ident
                        elif defCur.kind == nkDotExpr && kidCount(defCur) > 1:
                            nextOwner = cgenStripSpaces(plainName(kid(defCur, 1)))
                    if strIsEmpty(nextOwner) || streq(nextOwner, owner):
                        break
                    owner = nextOwner
                    steps = steps + 1
                var fieldTy: Node = lookupFieldType(owner, mname)
                if (fieldTy == nil || fieldTy.kind == nkEmpty) && !strIsEmpty(owner):
                    if hasSuffix(owner, "_obj") && len owner > 4:
                        let baseOwner: str = cgenSliceRange(owner, 0, len owner - 4)
                        fieldTy = lookupFieldType(baseOwner, mname)
                    else:
                        fieldTy = lookupFieldType(refStructTag(owner), mname)
                if fieldTy != nil && fieldTy.kind != nkEmpty:
                    return fieldTy
        return nil
    of nkPar:
        if count == 1:
            return inferSimpleTypeNode Node(get[void*](kids, 0))
        return nil
    of nkHiddenDeref, nkDerefExpr:
        if count > 0:
            let inner: Node = Node(get[void*](kids, 0))
            let innerTy0: Node = inferSimpleTypeNode inner
            var innerTy: Node = stripVarType(innerTy0)
            if innerTy != nil && (innerTy.kind == nkPtrTy || innerTy.kind == nkRefTy || innerTy.kind == nkVarTy):
                if kidCount innerTy > 0:
                    return stripVarType kid(innerTy, 0)
        return nil
    of nkCallArg:
        if count > 1:
            return inferSimpleTypeNode Node(get[void*](kids, 1))
        if count > 0:
            return inferSimpleTypeNode Node(get[void*](kids, 0))
        return nil
    of nkPrefix:
        if count > 1:
            let op: str = prefixOp n
            if op == "$":
                return newIdent("str", n.pos)
            if op == "&":
                let rhsType: Node = inferSimpleTypeNode Node(get[void*](kids, 1))
                if rhsType != nil && rhsType.kind != nkEmpty:
                    var ptrTy: Node = newNode(nkPtrTy, n.pos)
                    addSon(ptrTy, rhsType)
                    return ptrTy
            if op == "await":
                let rhsType: Node = inferSimpleTypeNode Node(get[void*](kids, 1))
                let valueType: Node = cgenAwaitValueType(rhsType, n.pos)
                if valueType != nil:
                    return valueType
            return inferSimpleTypeNode Node(get[void*](kids, 1))
        return nil
    of nkTupleLit:
        var tup: Node = newNode(nkTupleTy, n.pos)
        var ti: int32 = 0
        while ti < count:
            let elem: Node = Node(get[void*](kids, ti))
            var elemNode: Node = elem
            var nameNode: Node = nil
            if elemNode != nil && elemNode.kind == nkCallArg:
                let elemKids: seq[void*] = elemNode.kids
                if elemKids.len > 1:
                    nameNode = Node(get[void*](elemKids, 0))
                    elemNode = Node(get[void*](elemKids, 1))
                elif elemKids.len > 0:
                    elemNode = Node(get[void*](elemKids, 0))
            let elemTy: Node = inferSimpleTypeNode elemNode
            if elemTy == nil || elemTy.kind == nkEmpty:
                return nil
            if nameNode != nil:
                var defs: Node = newNode(nkIdentDefs, n.pos)
                addSon(defs, nameNode)
                addSon(defs, elemTy)
                addSon(defs, newNode(nkEmpty, n.pos))
                addSon(tup, defs)
            else:
                addSon(tup, elemTy)
            ti = ti + 1
        if kidCount tup > 0:
            return tup
        return nil
    of nkSeqLit:
        var elemTy0: Node = nil
        var si: int32 = 0
        while si < count:
            let elem: Node = cgenCallArgValue Node(get[void*](kids, si))
            let elemTy: Node = inferSimpleTypeNode elem
            if elemTy != nil:
                if elemTy0 == nil:
                    elemTy0 = elemTy
                else:
                    let k0: str = cgenTypeKey elemTy0
                    let k1: str = cgenTypeKey elemTy
                    if !strIsEmpty(k0) && !strIsEmpty(k1) && !streq(k0, k1):
                        return nil
            si = si + 1
        if elemTy0 != nil:
            var br: Node = newNode(nkBracketExpr, n.pos)
            addSon(br, newIdent("seq", n.pos))
            addSon(br, elemTy0)
            return br
        return nil
    of nkBracketExpr:
        if count == 1:
            let innerExpr: Node = Node(get[void*](kids, 0))
            let innerTy0: Node = inferSimpleTypeNode innerExpr
            let innerTy: Node = unwrapParType(stripVarType(innerTy0))
            if innerTy == nil:
                return nil
            if innerTy.kind == nkPtrTy || innerTy.kind == nkRefTy || innerTy.kind == nkVarTy:
                if kidCount innerTy > 0:
                    return stripVarType kid(innerTy, 0)
                return nil
            if innerTy.kind == nkPostfix && kidCount innerTy > 1:
                let opn0: Node = kid(innerTy, 0)
                let opn1: Node = kid(innerTy, 1)
                if opn0 != nil && cgenStripSpaces(opn0.ident) == "*":
                    return stripVarType opn1
                if opn1 != nil && cgenStripSpaces(opn1.ident) == "*":
                    return stripVarType opn0
                return nil
            if innerTy.kind == nkInfix && kidCount innerTy >= 3:
                let opn2: Node = kid(innerTy, 0)
                if opn2 != nil && cgenStripSpaces(opn2.ident) == "*":
                    let rhs: Node = kid(innerTy, 2)
                    if rhs == nil || rhs.kind == nkEmpty:
                        return stripVarType kid(innerTy, 1)
                let opnMid: Node = kid(innerTy, 1)
                if opnMid != nil && cgenStripSpaces(opnMid.ident) == "*":
                    let rhsMid: Node = kid(innerTy, 2)
                    if rhsMid == nil || rhsMid.kind == nkEmpty:
                        return stripVarType kid(innerTy, 0)
                return nil
            return nil
        if count >= 2:
            let baseExpr: Node = Node(get[void*](kids, 0))
            let idxExpr: Node = Node(get[void*](kids, 1))
            let baseTy0: Node = inferSimpleTypeNode baseExpr
            var baseTy: Node = stripVarType baseTy0
            if baseTy != nil && (baseTy.kind == nkPtrTy || baseTy.kind == nkRefTy):
                if kidCount baseTy > 0:
                    baseTy = stripVarType kid(baseTy, 0)
            if cgenIsStringTypeNode(baseTy) || exprIsStringLike(baseExpr):
                if cgenIsRangeExpr idxExpr:
                    return newIdent("str", n.pos)
                return newIdent("char", n.pos)
            let elemTy: Node = cgenSeqElemType baseTy
            if elemTy != nil:
                if cgenIsRangeExpr idxExpr:
                    var br: Node = newNode(nkBracketExpr, n.pos)
                    addSon(br, newIdent("seq", n.pos))
                    addSon(br, elemTy)
                    return br
                return elemTy
            # Fall back to resolving the bracket operator signature for other types
            # (e.g. JsonNode, Tables, etc.) so unannotated locals can infer types.
            var call: Node = newNode(nkCall, n.pos)
            call.callStyle = CallStyleParen
            addSon(call, newIdent("[]", n.pos))
            var ai: int32 = 0
            while ai < count:
                addSon(call, Node(get[void*](kids, ai)))
                ai = ai + 1
            let sigIdx: int32 = cgenFindFnSigIndexForCall call
            if sigIdx >= 0 && sigIdx < cFnSigRetNodes.len:
                let rt: Node = Node(get[void*](cFnSigRetNodes, sigIdx))
                if rt != nil && rt.kind != nkEmpty:
                    return rt
            var baseKey: str = ""
            if baseTy0 != nil && baseTy0.kind != nkEmpty:
                baseKey = cgenTypeKey(stripVarType(baseTy0))
            var idxKey: str = ""
            let idxTy0: Node = inferSimpleTypeNode idxExpr
            if idxTy0 != nil && idxTy0.kind != nkEmpty:
                idxKey = cgenTypeKey(stripVarType(idxTy0))
            if !strIsEmpty(baseKey) && !strIsEmpty(idxKey):
                let cPrefix: str = "Cbracket__" + baseKey + "_" + idxKey
                let sigIdx2: int32 = cFnSigFindMatchForPrefix(cPrefix, call)
                if sigIdx2 >= 0 && sigIdx2 < cFnSigRetNodes.len:
                    let rt2: Node = Node(get[void*](cFnSigRetNodes, sigIdx2))
                    if rt2 != nil && rt2.kind != nkEmpty:
                        return rt2
        return nil
    of nkIf, nkWhen:
        var outTy: Node = nil
        var i4: int32 = 0
        while i4 + 1 < count:
            let body: Node = Node(get[void*](kids, i4 + 1))
            var bodyTy: Node = nil
            if body != nil && body.kind == nkStmtList && kidCount body > 0:
                bodyTy = inferSimpleTypeNode kid(body, kidCount(body) - 1)
            else:
                bodyTy = inferSimpleTypeNode body
            if bodyTy != nil && bodyTy.kind != nkEmpty:
                if outTy == nil:
                    outTy = bodyTy
                else:
                    let k0: str = cgenTypeKey outTy
                    let k1: str = cgenTypeKey bodyTy
                    if !strIsEmpty(k0) && !strIsEmpty(k1) && !streq(k0, k1):
                        if streq(k0, "int") && !streq(k1, "int"):
                            outTy = bodyTy
                        elif streq(k1, "int") && !streq(k0, "int"):
                            outTy = outTy
                        else:
                            return nil
            i4 = i4 + 2
        if (count % 2) == 1:
            let elseBody: Node = Node(get[void*](kids, count - 1))
            var elseTy: Node = nil
            if elseBody != nil && elseBody.kind == nkStmtList && kidCount elseBody > 0:
                elseTy = inferSimpleTypeNode kid(elseBody, kidCount(elseBody) - 1)
            else:
                elseTy = inferSimpleTypeNode elseBody
            if elseTy != nil && elseTy.kind != nkEmpty:
                if outTy == nil:
                    outTy = elseTy
                else:
                    let k0: str = cgenTypeKey outTy
                    let k1: str = cgenTypeKey elseTy
                    if !strIsEmpty(k0) && !strIsEmpty(k1) && !streq(k0, k1):
                        if streq(k0, "int") && !streq(k1, "int"):
                            outTy = elseTy
                        elif streq(k1, "int") && !streq(k0, "int"):
                            outTy = outTy
                        else:
                            return nil
        return outTy
    of nkCase:
        var outTy2: Node = nil
        var bi: int32 = 1
        while bi < count:
            let br: Node = Node(get[void*](kids, bi))
            var body2: Node = nil
            if br != nil && kidCount br > 0:
                body2 = kid(br, 0)
            var bodyTy2: Node = nil
            if body2 != nil && body2.kind == nkStmtList && kidCount body2 > 0:
                bodyTy2 = inferSimpleTypeNode kid(body2, kidCount(body2) - 1)
            else:
                bodyTy2 = inferSimpleTypeNode body2
            if bodyTy2 != nil && bodyTy2.kind != nkEmpty:
                if outTy2 == nil:
                    outTy2 = bodyTy2
                else:
                    let k0: str = cgenTypeKey outTy2
                    let k1: str = cgenTypeKey bodyTy2
                    if !strIsEmpty(k0) && !strIsEmpty(k1) && !streq(k0, k1):
                        if streq(k0, "int") && !streq(k1, "int"):
                            outTy2 = bodyTy2
                        elif streq(k1, "int") && !streq(k0, "int"):
                            outTy2 = outTy2
                        else:
                            return nil
            bi = bi + 1
        return outTy2
    of nkInfix:
        if count >= 3:
            let lhs: Node = Node(get[void*](kids, 1))
            let rhs: Node = Node(get[void*](kids, 2))
            let op: str = infixOp n
            let lt: Node = inferSimpleTypeNode lhs
            let rt: Node = inferSimpleTypeNode rhs
            if op == "+" || op == "==":
                if cgenIsStringTypeNode(lt) || cgenIsStringTypeNode(rt):
                    if op == "==":
                        return newIdent("bool", n.pos)
                    return newIdent("str", n.pos)
            if cgenIsFloatTypeNode lt || cgenIsFloatTypeNode rt:
                return newIdent("float64", n.pos)
            if lt != nil || rt != nil:
                if lt != nil && rt == nil:
                    return lt
                if rt != nil && lt == nil:
                    return rt
                if lt != nil && rt != nil:
                    let lk: str = cgenTypeKey lt
                    let rk: str = cgenTypeKey rt
                    if !strIsEmpty(lk) && !strIsEmpty(rk) && streq(lk, rk):
                        return lt
                    if streq(lk, "int") && !streq(rk, "int"):
                        return rt
                    if streq(rk, "int") && !streq(lk, "int"):
                        return lt
                return newIdent("int", n.pos)
        return nil
    of nkCall:
        if count == 0:
            return nil
        let callee: Node = Node(get[void*](kids, 0))
        if callee != nil && cgenIsTypeExprNode callee:
            return callee
        let baseName: str = cgenCallBaseName n
        if baseName == "ord":
            return newIdent("int32", n.pos)
        let rt: Node = cFnSigRetTypeForCall n
        if rt != nil && rt.kind != nkEmpty:
            return rt
        return nil
    else:
        return nil

fn inferArrayElemTypeNode(n: Node): Node =
    if n == nil:
        return nil
    let kids: seq[void*] = n.kids
    let count: int32 = kids.len
    var i: int32 = 0
    while i < count:
        let elem: Node = Node(get[void*](kids, i))
        let ty: Node = inferSimpleTypeNode elem
        if ty != nil && ty.kind != nkEmpty:
            return ty
        i = i + 1
    return nil

fn cgenIsExprNode(n: Node): bool =
    if n == nil:
        return false
    case n.kind
    of nkIntLit, nkFloatLit, nkStrLit, nkCharLit, nkBoolLit, nkNilLit,
       nkIdent, nkSymbol, nkInfix, nkPrefix, nkCall, nkDotExpr, nkPar:
        return true
    else:
        return false

fn cgenIsControlFlowExpr(n: Node): bool =
    if n == nil:
        return false
    let cur: Node = unwrapParExpr n
    if cur == nil:
        return false
    return cur.kind == nkIf || cur.kind == nkWhen || cur.kind == nkCase

fn cgenIsRangeExpr(n: Node): bool =
    if n == nil:
        return false
    if n.kind == nkInfix && n.kids.len >= 3:
        let op: str = infixOp n
        return op == ".." || op == "..<" || op == "dotdot" || op == "dotdotless"
    return false

fn cgenIsStringInfix(n: Node): bool =
    if n == nil || n.kind != nkInfix || n.kids.len < 3:
        return false
    let op: str = infixOp n
    if op != "+" && op != "==" && op != "!=":
        return false
    let lhs: Node = kid(n, 1)
    let rhs: Node = kid(n, 2)
    return exprIsStringLike(lhs) || exprIsStringLike(rhs)

fn exprIsStringLike(n: Node): bool =
    if n == nil:
        return false
    var cached: bool = false
    let idx: int32 = hashmaps.hashMapPtrIntGet(cgenExprStringLikeIndex, void*(n), &cached)
    if cached:
        if idx <= 0:
            return false
        return get[bool](cgenExprStringLikeValues, idx - 1)
    var result: bool = false
    let cur: Node = unwrapParExpr n
    if cur != nil:
        if cur.kind == nkStrLit:
            result = true
        elif cur.kind == nkInfix && cur.kids.len >= 3:
            let op: str = infixOp cur
            if op == "+":
                let ckids: seq[void*] = cur.kids
                result = exprIsStringLike(Node(get[void*](ckids, 1))) || exprIsStringLike(Node(get[void*](ckids, 2)))
        elif cur.kind == nkCall:
            let sigIdx: int32 = cgenFindFnSigIndexForCall cur
            if sigIdx >= 0 && sigIdx < cFnSigRetNodes.len:
                let rt: Node = Node(get[void*](cFnSigRetNodes, sigIdx))
                if cgenIsStringTypeNode(rt):
                    result = true
        if !result:
            let t: Node = cgenInferSimpleTypeCached cur
            result = cgenIsStringTypeNode(t)
    addPtr[bool](&cgenExprStringLikeValues, result)
    let storedIdx: int32 = cgenExprStringLikeValues.len
    hashmaps.hashMapPtrIntPut(&cgenExprStringLikeIndex, void*(n), storedIdx)
    return result

fn cgenRangeIsExclusive(n: Node): bool =
    if n == nil:
        return false
    if n.kind == nkInfix && n.kids.len >= 3:
        let op: str = infixOp n
        return op == "..<" || op == "dotdotless"
    return false

fn cgenVarNameNode(n: Node): Node =
    if n == nil:
        return nil
    let kids: seq[void*] = n.kids
    if kids.len == 0:
        return nil
    let nameNode: Node = Node(get[void*](kids, 0))
    if nameNode != nil && nameNode.kind == nkPattern:
        let nameKids: seq[void*] = nameNode.kids
        if nameKids.len > 0:
            return Node(get[void*](nameKids, 0))
    return nameNode

fn cgenVarTypeNode(n: Node): Node =
    if n == nil:
        return nil
    let kids: seq[void*] = n.kids
    if kids.len <= 1:
        return nil
    var typeNode: Node = Node(get[void*](kids, 1))
    let nameNode: Node = Node(get[void*](kids, 0))
    if nameNode != nil && nameNode.kind == nkPattern:
        let nameKids: seq[void*] = nameNode.kids
        if nameKids.len > 1:
            if typeNode == nil || typeNode.kind == nkEmpty:
                typeNode = Node(get[void*](nameKids, 1))
    return typeNode

fn cgenEmitArrayLiteral(w: CWriter*, n: Node) =
    if n == nil:
        cwWrite(w, "0")
        return
    let elemTy: Node = inferArrayElemTypeNode n
    if elemTy == nil || elemTy.kind == nkEmpty:
        cgenAddError(n.pos, "C backend requires array literal with element type")
        cwWrite(w, "0")
        return
    let elemKey: str = cgenTypeKey elemTy
    if elemKey == "":
        cgenAddError(n.pos, "C backend requires array literal with concrete element type")
        cwWrite(w, "0")
        return
    let sliceName: str = "slice_" + elemKey
    cwWrite(w, "((")
    cwWrite(w, sliceName)
    cwWrite(w, "){ .ptr = ")
    if kidCount n > 0:
        cwWriteChar(w, '(')
        emitTypeName(w, elemTy)
        cwWrite(w, "[]){")
        var i: int32 = 0
        while i < kidCount n:
            cgenEmitExpr(w, kid(n, i))
            if i + 1 < kidCount n:
                cwWrite(w, ", ")
            i = i + 1
        cwWriteChar(w, '}')
    else:
        cwWrite(w, "CHENG_NIL")
    cwWrite(w, ", .len = ")
    cwWrite(w, int64ToStr int64(kidCount n))
    cwWrite(w, " })")

fn cgenEmitAwaitExpr(w: CWriter*, rhs: Node, pos: SourcePos) =
    let awaitType: Node = inferSimpleTypeNode rhs
    let fnName: str = cgenAwaitFuncName awaitType
    if strIsEmpty fnName:
        cgenAddError(pos, "[C-Profile] not-mapped: await type (FULLC.R03). hint: only await_i32/await_void supported in v0.")
        cwWrite(w, "0")
        return
    cwWrite(w, fnName)
    cwWriteChar(w, '(')
    cgenEmitExpr(w, rhs)
    cwWriteChar(w, ')')

fn cgenEmitTupleLitWithType(w: CWriter*, lit: Node, tupleType: Node) =
    if w == nil || lit == nil:
        return
    let key: str = cgenEnsureTupleDecl tupleType
    if strIsEmpty key:
        cgenAddError(lit.pos, "C backend requires tuple literal type")
        cwWrite(w, "0")
        return
    cwWrite(w, "(")
    cwWrite(w, key)
    cwWrite(w, "){")
    var ti: int32 = 0
    while ti < kidCount lit:
        let elem: Node = cgenCallArgValue kid(lit, ti)
        if elem != nil:
            cgenEmitExpr(w, elem)
        else:
            cwWrite(w, "0")
        if ti + 1 < kidCount lit:
            cwWrite(w, ", ")
        ti = ti + 1
    cwWrite(w, "}")

fn cgenEmitTupleLitFromCall(w: CWriter*, callNode: Node, tupleType: Node) =
    if w == nil || callNode == nil || tupleType == nil:
        return
    let key: str = cgenEnsureTupleDecl tupleType
    if strIsEmpty key:
        cgenAddError(callNode.pos, "C backend requires tuple literal type")
        cwWrite(w, "0")
        return
    cwWrite(w, "(")
    cwWrite(w, key)
    cwWrite(w, "){")
    let count: int32 = kidCount callNode
    var i: int32 = 1
    while i < count:
        let elem: Node = cgenCallArgValue kid(callNode, i)
        if elem != nil:
            cgenEmitExpr(w, elem)
        else:
            cwWrite(w, "0")
        if i + 1 < count:
            cwWrite(w, ", ")
        i = i + 1
    cwWrite(w, "}")

fn cgenEmitObjectLitWithType(w: CWriter*, typeNode: Node, callNode: Node) =
    if w == nil || typeNode == nil || callNode == nil:
        return
    let typeName: str = cgenTypeNameFromTypeNode(typeNode)
    if strIsEmpty typeName:
        cgenAddError(callNode.pos, "C backend requires object literal type")
        cwWrite(w, "0")
        return
    var fields: seq[str] = newSeqWithCap[str](0, 8)
    if ! cgenObjectFieldOrder(typeName, &fields):
        cgenAddError(callNode.pos, "C backend requires positional object literal mapping")
        cwWrite(w, "0")
        return
    var namedNames: seq[str] = newSeqWithCap[str](0, 4)
    var namedVals: seq[Node] = newSeqWithCap[Node](0, 4)
    var posVals: seq[Node] = newSeqWithCap[Node](0, 4)
    var ai: int32 = 1
    while ai < kidCount callNode:
        let arg: Node = kid(callNode, ai)
        if arg != nil && arg.kind == nkCallArg && kidCount arg > 1:
            let nameNode: Node = kid(arg, 0)
            let valNode: Node = kid(arg, 1)
            let nm: str = cgenStripSpaces(plainName(nameNode))
            if !strIsEmpty nm:
                addPtr[str](&namedNames, nm)
                addPtr[Node](&namedVals, valNode)
            else:
                addPtr[Node](&posVals, valNode)
        else:
            addPtr[Node](&posVals, cgenCallArgValue arg)
        ai = ai + 1
    let isRef: bool = typeIsRefLike typeNode
    if isRef:
        let refTag: str = refStructTag typeName
        let tmpName: str = cgenNextTempName("obj")
        cwWrite(w, "({ struct ")
        cwWrite(w, refTag)
        cwWrite(w, "* ")
        cwWrite(w, tmpName)
        cwWrite(w, " = (struct ")
        cwWrite(w, refTag)
        cwWrite(w, "*)alloc(sizeof(struct ")
        cwWrite(w, refTag)
        cwWrite(w, ")); ")
        cwWrite(w, "if (")
        cwWrite(w, tmpName)
        cwWrite(w, " != CHENG_NIL) { ")
        var posIdx: int32 = 0
        var fi: int32 = 0
        while fi < fields.len:
            let fname: str = get[str](fields, fi)
            cwWrite(w, tmpName)
            cwWrite(w, "->")
            cwWrite(w, cgenEscapeCIdent(fname))
            cwWrite(w, " = ")
            var val: Node = nil
            var namedPos: int32 = 0
            while namedPos < namedNames.len:
                if get[str](namedNames, namedPos) == fname:
                    val = get[Node](namedVals, namedPos)
                    break
                namedPos = namedPos + 1
            if val == nil && posIdx < posVals.len:
                val = get[Node](posVals, posIdx)
                posIdx = posIdx + 1
            if val != nil:
                cgenEmitExpr(w, val)
            else:
                let fty: Node = lookupFieldType(typeName, fname)
                if fty != nil:
                    cgenEmitDefaultValue(w, fty)
                else:
                    cwWrite(w, "0")
            cwWrite(w, "; ")
            fi = fi + 1
        cwWrite(w, "} ")
        cwWrite(w, tmpName)
        cwWrite(w, "; })")
        return
    cwWrite(w, "(")
    emitTypeName(w, typeNode)
    cwWrite(w, "){")
    var posIdx2: int32 = 0
    var fi2: int32 = 0
    while fi2 < fields.len:
        let fname2: str = get[str](fields, fi2)
        cwWrite(w, ".")
        cwWrite(w, cgenEscapeCIdent(fname2))
        cwWrite(w, " = ")
        var val2: Node = nil
        var namedPos2: int32 = 0
        while namedPos2 < namedNames.len:
            if get[str](namedNames, namedPos2) == fname2:
                val2 = get[Node](namedVals, namedPos2)
                break
            namedPos2 = namedPos2 + 1
        if val2 == nil && posIdx2 < posVals.len:
            val2 = get[Node](posVals, posIdx2)
            posIdx2 = posIdx2 + 1
        if val2 != nil:
            cgenEmitExpr(w, val2)
        else:
            let fty2: Node = lookupFieldType(typeName, fname2)
            if fty2 != nil:
                cgenEmitDefaultValue(w, fty2)
            else:
                cwWrite(w, "0")
        if fi2 + 1 < fields.len:
            cwWrite(w, ", ")
        fi2 = fi2 + 1
    cwWrite(w, "}")

fn cgenEmitExpr(w: CWriter*, n: Node) =
    if ! cgenProfOn:
        cgenEmitExprImpl(w, n)
        return
    cgenProfExprCalls = cgenProfExprCalls + 1
    if (cgenProfExprCalls & 63) != 0:
        cgenEmitExprImpl(w, n)
        return
    let startNs: int64 = cheng_monotime_ns()
    let hadRoot: bool = cgenProfExprSampleRoot != nil
    if ! hadRoot:
        cgenProfExprSampleRoot = n
    cgenEmitExprImpl(w, n)
    if ! hadRoot:
        cgenProfExprSampleRoot = nil
    let durNs: int64 = (cheng_monotime_ns() - startNs) * 64
    cgenProfExprNsTotal = cgenProfExprNsTotal + durNs
    if n != nil:
        case n.kind
        of nkCall:
            cgenProfExprNsCall = cgenProfExprNsCall + durNs
        of nkInfix:
            cgenProfExprNsInfix = cgenProfExprNsInfix + durNs
            if cgenIsStringInfix(n):
                cgenProfExprNsInfixStr = cgenProfExprNsInfixStr + durNs
            else:
                cgenProfExprNsInfixNonStr = cgenProfExprNsInfixNonStr + durNs
        of nkIdent, nkSymbol:
            cgenProfExprNsIdent = cgenProfExprNsIdent + durNs
        of nkDotExpr:
            cgenProfExprNsDot = cgenProfExprNsDot + durNs
        of nkBracketExpr:
            cgenProfExprNsBracket = cgenProfExprNsBracket + durNs
        else:
            cgenProfExprNsOther = cgenProfExprNsOther + durNs

fn cgenEmitShiftExpr(w: CWriter*, lhs: Node, rhs: Node, op: str) =
    var lhsTy: Node = stripVarType(inferSimpleTypeNode lhs)
    var key: str = ""
    if cgenIsSetTypeNode(lhsTy):
        key = "uint64"
    elif lhsTy != nil:
        key = cgenTypeKey lhsTy
    if key == "char":
        key = "uint8"
    if strIsEmpty key:
        key = "int"
    var callee: str = ""
    if op == "<<":
        if key == "int8":
            callee = "cheng_shl_i8"
        elif key == "int16":
            callee = "cheng_shl_i16"
        elif key == "int32":
            callee = "cheng_shl_i32"
        elif key == "int64":
            callee = "cheng_shl_i64"
        elif key == "int":
            callee = "cheng_shl_ni"
        elif key == "uint8":
            callee = "cheng_shl_u8"
        elif key == "uint16":
            callee = "cheng_shl_u16"
        elif key == "uint32":
            callee = "cheng_shl_u32"
        elif key == "uint64":
            callee = "cheng_shl_u64"
        elif key == "uint":
            callee = "cheng_shl_nu"
        else:
            callee = "cheng_shl_ni"
    else:
        if key == "int8":
            callee = "cheng_ashr_i8"
        elif key == "int16":
            callee = "cheng_ashr_i16"
        elif key == "int32":
            callee = "cheng_ashr_i32"
        elif key == "int64":
            callee = "cheng_ashr_i64"
        elif key == "int":
            callee = "cheng_ashr_ni"
        elif key == "uint8":
            callee = "cheng_lshr_u8"
        elif key == "uint16":
            callee = "cheng_lshr_u16"
        elif key == "uint32":
            callee = "cheng_lshr_u32"
        elif key == "uint64":
            callee = "cheng_lshr_u64"
        elif key == "uint":
            callee = "cheng_lshr_nu"
        else:
            callee = "cheng_ashr_ni"
    cwWrite(w, callee)
    cwWriteChar(w, '(')
    cgenEmitExpr(w, lhs)
    cwWrite(w, ", (NU64)(")
    cgenEmitExpr(w, rhs)
    cwWrite(w, ")")
    cwWriteChar(w, ')')

fn cgenEmitExprImpl(w: CWriter*, n: Node) =
    if n == nil:
        cwWrite(w, "0")
        return
    case n.kind
    of nkIntLit:
        cwWrite(w, int64ToStr n.intVal)
    of nkFloatLit:
        if n.strVal != nil && len n.strVal > 0:
            cwWrite(w, n.strVal)
        else:
            cwWrite(w, "0.0")
    of nkStrLit:
        escapeCString(w, n.strVal)
    of nkCharLit:
        escapeCChar(w, n.strVal)
    of nkBoolLit:
        if cgenStripSpaces n.ident == "true":
            cwWrite(w, "1")
        else:
            cwWrite(w, "0")
    of nkNilLit:
        cwWrite(w, "CHENG_NIL")
    of nkIdent, nkSymbol:
        let nm: str = cgenIdentNameNormalized n
        if nm == "true":
            cwWrite(w, "1")
        elif nm == "false":
            cwWrite(w, "0")
        else:
            cwWrite(w, cgenEscapeCIdent(nm))
    of nkPar:
        cwWriteChar(w, '(')
        let kids: seq[void*] = n.kids
        if kids.len == 1:
            cgenEmitExpr(w, Node(get[void*](kids, 0)))
        cwWriteChar(w, ')')
    of nkHiddenDeref, nkDerefExpr:
        let kids: seq[void*] = n.kids
        if kids.len > 0:
            cwWrite(w, "(*")
            cgenEmitExpr(w, Node(get[void*](kids, 0)))
            cwWrite(w, ")")
        else:
            cwWrite(w, "0")
    of nkDotExpr:
        let kids: seq[void*] = n.kids
        if kids.len >= 2:
            let base: Node = Node(get[void*](kids, 0))
            let useArrow: bool = dotNeedsArrow base
            cgenEmitExpr(w, base)
            if useArrow:
                cwWrite(w, "->")
            else:
                cwWriteChar(w, '.')
            let member: Node = Node(get[void*](kids, 1))
            let mnameNorm: str = cgenIdentNameNormalized member
            if mnameNorm != "":
                cwWrite(w, cgenEscapeCIdent(mnameNorm))
            else:
                let mname: str = plainName member
                cwWrite(w, cgenEscapeCIdent(mname))
    of nkBracket:
        cgenEmitArrayLiteral(w, n)
    of nkBracketExpr:
        let kids: seq[void*] = n.kids
        let count: int32 = kids.len
        if count == 1:
            cwWrite(w, "(*")
            cgenEmitExpr(w, Node(get[void*](kids, 0)))
            cwWrite(w, ")")
        elif count > 1:
            let baseExpr0: Node = Node(get[void*](kids, 0))
            if baseExpr0 != nil && (baseExpr0.kind == nkIdent || baseExpr0.kind == nkSymbol):
                let baseName0: str = cgenIdentNameNormalized baseExpr0
                if baseName0 == "default":
                    if count == 2:
                        cgenEmitDefaultValue(w, Node(get[void*](kids, 1)))
                    else:
                        cgenAddError(n.pos, "default[T] expects single type argument")
                        cwWrite(w, "0")
                    return
            if count == 2:
                let baseExpr: Node = Node(get[void*](kids, 0))
                let idxExpr: Node = Node(get[void*](kids, 1))
                if idxExpr != nil && idxExpr.kind == nkIntLit:
                    let idxVal: int64 = idxExpr.intVal
                    if idxVal >= 0:
                        let idx: int32 = int32(idxVal)
                        let useArrow: bool = dotNeedsArrow baseExpr
                        let baseTy0: Node = inferSimpleTypeNode baseExpr
                        var baseTy: Node = stripVarType baseTy0
                        if baseTy != nil && (baseTy.kind == nkPtrTy || baseTy.kind == nkRefTy || baseTy.kind == nkVarTy):
                            if kidCount baseTy > 0:
                                baseTy = stripVarType kid(baseTy, 0)
                        if baseTy != nil:
                            if baseTy.kind == nkTupleTy:
                                if idx < kidCount baseTy:
                                    cgenEmitExpr(w, baseExpr)
                                    if useArrow:
                                        cwWrite(w, "->")
                                    else:
                                        cwWriteChar(w, '.')
                                    cwWrite(w, "f")
                                    cwWrite(w, intToStr idx)
                                    return
                            else:
                                if !(cgenIsSeqTypeNode(baseTy0) || cgenIsTableTypeNode(baseTy0)):
                                    let typeName: str = cgenTypeNameFromTypeNode baseTy
                                    if !strIsEmpty typeName:
                                        var fields: seq[str] = newSeqWithCap[str](0, 0)
                                        if cgenObjectFieldOrder(typeName, &fields):
                                            if idx < fields.len:
                                                cgenEmitExpr(w, baseExpr)
                                                if useArrow:
                                                    cwWrite(w, "->")
                                                else:
                                                    cwWriteChar(w, '.')
                                                cwWrite(w, cgenEscapeCIdent(get[str](fields, idx)))
                                                return
                if cgenIsRangeExpr idxExpr && kidCount idxExpr >= 3:
                    let baseType2: Node = inferSimpleTypeNode baseExpr
                    let startExpr: Node = kid(idxExpr, 1)
                    let endExpr: Node = kid(idxExpr, 2)
                    let exclusive: bool = cgenRangeIsExclusive idxExpr
                    if cgenIsStringTypeNode(baseType2) || exprIsStringLike(baseExpr):
                        var callSlice: Node = newNode(nkCall, n.pos)
                        callSlice.callStyle = CallStyleParen
                        addSon(callSlice, newIdent("__cheng_slice_string", n.pos))
                        addSon(callSlice, baseExpr)
                        addSon(callSlice, startExpr)
                        addSon(callSlice, endExpr)
                        addSon(callSlice, cgenMakeBoolLitNode(exclusive, n.pos))
                        cgenEmitExpr(w, callSlice)
                        return
                    let vecElem2: Node = cgenSeqElemType baseType2
                    if vecElem2 != nil:
                        var callSlice2: Node = newNode(nkCall, n.pos)
                        callSlice2.callStyle = CallStyleParen
                        addSon(callSlice2, cgenMakeGenericCallee("__cheng_slice_vec", vecElem2, n.pos))
                        addSon(callSlice2, baseExpr)
                        addSon(callSlice2, startExpr)
                        addSon(callSlice2, endExpr)
                        addSon(callSlice2, cgenMakeBoolLitNode(exclusive, n.pos))
                        cgenEmitExpr(w, callSlice2)
                        return
                let baseType: Node = resolveBracketBaseType baseExpr
                if cgenIsArrayTypeNode baseType:
                    cgenEmitArrayIndex(w, baseExpr, idxExpr)
                    return
            var call: Node = newNode(nkCall, n.pos)
            call.callStyle = CallStyleParen
            addSon(call, newIdent("[]", n.pos))
            var bi: int32 = 0
            while bi < count:
                addSon(call, Node(get[void*](kids, bi)))
                bi = bi + 1
            var prefix: str = "[]"
            var instPrefix: str = buildBracketInstPrefix(Node(get[void*](kids, 0)), prefix)
            var sigIdx: int32 = -1
            if !strIsEmpty instPrefix:
                if strHasChar(instPrefix, '_'):
                    sigIdx = cFnSigFindByPrefixName(instPrefix, call)
                if sigIdx < 0:
                    sigIdx = cFnSigFindMatchForPrefix(instPrefix, call)
                if sigIdx >= 0:
                    prefix = instPrefix
            if sigIdx < 0:
                sigIdx = cFnSigFindMatchForPrefix(prefix, call)
            if sigIdx < 0:
                let normPrefix: str = cgenNormalizeInstanceBase prefix
                if normPrefix != prefix:
                    prefix = normPrefix
                    sigIdx = cFnSigFindMatchForPrefix(prefix, call)
            if sigIdx >= 0:
                cwWrite(w, mangleCName(cFnSigName sigIdx))
            else:
                cwWrite(w, mangleCName(prefix))
            cwWriteChar(w, '(')
            if sigIdx >= 0:
                cgenEmitCallArgsBySig(w, sigIdx, call)
            else:
                var bj: int32 = 0
                while bj < count:
                    cgenEmitExpr(w, cgenCallArgValue kid(n, bj))
                    if bj + 1 < count:
                        cwWrite(w, ", ")
                    bj = bj + 1
            cwWriteChar(w, ')')
    of nkPrefix:
        let kids: seq[void*] = n.kids
        let count: int32 = kids.len
        if count >= 2:
            let rhs: Node = Node(get[void*](kids, 1))
            let op: str = prefixOp n
            if op == "$":
                var call: Node = newNode(nkCall, n.pos)
                call.callStyle = CallStyleParen
                addSon(call, newIdent("$", n.pos))
                addSon(call, rhs)
                cgenEmitExpr(w, call)
                return
            if op == "&":
                if rhs != nil && (rhs.kind == nkIdent || rhs.kind == nkSymbol):
                    let nm: str = cgenStripSpaces(plainName(rhs))
                    if !strIsEmpty nm:
                        var sigIdx: int32 = cFnSigFindAny nm
                        if sigIdx < 0:
                            sigIdx = cFnSigFindBySuffix nm
                        if sigIdx >= 0:
                            let fnNode: Node = Node(get[void*](cFnSigNodes, sigIdx))
                            var resolved: str = ""
                            let imp: str = cgenGetImportC fnNode
                            if !strIsEmpty imp:
                                if cFnSigIsVarargs sigIdx:
                                    resolved = cgenImportcVarargsWrapperName imp
                                else:
                                    resolved = imp
                            else:
                                resolved = mangleCName(cFnSigName sigIdx)
                            if !strIsEmpty resolved:
                                cwWrite(w, "(&")
                                cwWrite(w, resolved)
                                cwWrite(w, ")")
                                return
            if op == "await":
                cgenEmitAwaitExpr(w, rhs, n.pos)
                return
            cwWriteChar(w, '(')
            if !strIsEmpty op:
                cwWrite(w, op)
            cgenEmitExpr(w, rhs)
            cwWriteChar(w, ')')
    of nkInfix:
        let kids: seq[void*] = n.kids
        let count: int32 = kids.len
        if count >= 3:
            let lhs: Node = Node(get[void*](kids, 1))
            let rhs2: Node = Node(get[void*](kids, 2))
            let op: str = infixOp n
            if op == "+" || op == "==" || op == "!=":
                if exprIsStringLike(lhs) || exprIsStringLike(rhs2):
                    var opCall: str = op
                    if op == "!=":
                        opCall = "=="
                    if op == "!=":
                        cwWrite(w, "(!")
                    var foundSig: bool = false
                    var sigIdx2: int32 = hashmaps.hashMapPtrIntGet(cgenInfixSigIndex, void*(n), &foundSig)
                    if !foundSig:
                        var call2: Node = newNode(nkCall, n.pos)
                        call2.callStyle = CallStyleParen
                        addSon(call2, newIdent(opCall, n.pos))
                        addSon(call2, lhs)
                        addSon(call2, rhs2)
                        sigIdx2 = cFnSigFindMatchForCall(opCall, call2)
                        hashmaps.hashMapPtrIntPut(&cgenInfixSigIndex, void*(n), sigIdx2)
                    if sigIdx2 >= 0:
                        cwWrite(w, mangleCName(cFnSigName sigIdx2))
                    else:
                        cwWrite(w, mangleCName(opCall))
                    cwWriteChar(w, '(')
                    cgenEmitExpr(w, lhs)
                    cwWrite(w, ", ")
                    cgenEmitExpr(w, rhs2)
                    cwWriteChar(w, ')')
                    if op == "!=":
                        cwWriteChar(w, ')')
                    return
            if op == "<<" || op == ">>":
                cgenEmitShiftExpr(w, lhs, rhs2, op)
                return
            if op == "in" || op == "notin":
                cgenEmitInCond(w, lhs, rhs2, n.pos, op == "notin")
                return
            cwWriteChar(w, '(')
            cgenEmitExpr(w, lhs)
            cwWrite(w, " ")
            cwWrite(w, op)
            cwWrite(w, " ")
            cgenEmitExpr(w, rhs2)
            cwWriteChar(w, ')')
    of nkTupleLit:
        let tupTy: Node = inferSimpleTypeNode n
        if tupTy == nil || tupTy.kind == nkEmpty:
            cgenAddError(n.pos, "C backend requires tuple literal type")
            cwWrite(w, "0")
            return
        let key: str = cgenEnsureTupleDecl tupTy
        if strIsEmpty key:
            cgenAddError(n.pos, "C backend requires tuple literal type")
            cwWrite(w, "0")
            return
        cwWrite(w, "(")
        cwWrite(w, key)
        cwWrite(w, "){")
        var ti: int32 = 0
        let kids: seq[void*] = n.kids
        let count: int32 = kids.len
        while ti < count:
            let elem: Node = cgenCallArgValue Node(get[void*](kids, ti))
            if elem != nil:
                cgenEmitExpr(w, elem)
            else:
                cwWrite(w, "0")
            if ti + 1 < count:
                cwWrite(w, ", ")
            ti = ti + 1
        cwWrite(w, "}")
    of nkSeqLit:
        cgenAddError(n.pos, "C backend requires seq literal assigned to variable or returned")
        cwWrite(w, "0")
    of nkCurly:
        let kids: seq[void*] = n.kids
        let count: int32 = kids.len
        if count == 0:
            cwWrite(w, "0")
        else:
            cwWriteChar(w, '(')
            var ci: int32 = 0
            var wrote: bool = false
            while ci < count:
                let elem0: Node = cgenCallArgValue Node(get[void*](kids, ci))
                if elem0 != nil:
                    if wrote:
                        cwWrite(w, " | ")
                    if cgenIsRangeExpr elem0:
                        cgenEmitExpr(w, cgenSetElemMaskExpr(elem0))
                    else:
                        cwWrite(w, "setMask_0((NU64)(")
                        cgenEmitExpr(w, elem0)
                        cwWrite(w, "))")
                    wrote = true
                ci = ci + 1
            if !wrote:
                cwWrite(w, "0")
            cwWriteChar(w, ')')
    of nkCall:
        let kids: seq[void*] = n.kids
        let count: int32 = kids.len
        if count == 0:
            cwWrite(w, "0")
            return
        let profCallOn: bool = cgenProfOn && cgenProfExprSampleRoot == n
        let profScale: int64 = 64
        let callee: Node = Node(get[void*](kids, 0))
        let typeNode: Node = typeNodeFromCallee callee
        let isTypeCall: bool = typeNode != nil
        if isTypeCall:
            if count == 1:
                cgenEmitDefaultValue(w, typeNode)
                return
            let tupleElems: seq[Node] = cgenTupleElemTypesFromType typeNode
            if tupleElems.len > 0:
                cgenEmitTupleLitFromCall(w, n, typeNode)
                return
            let typeName: str = cgenTypeNameFromTypeNode(typeNode)
            if !strIsEmpty typeName && !typeIsRefLike(typeNode):
                var fields: seq[str] = newSeqWithCap[str](0, 0)
                if cgenObjectFieldOrder(typeName, &fields):
                    cgenEmitObjectLitWithType(w, typeNode, n)
                    return
            if count == 2:
                cwWriteChar(w, '(')
                cwWriteChar(w, '(')
                emitTypeName(w, typeNode)
                cwWriteChar(w, ')')
                cgenEmitExpr(w, Node(get[void*](kids, 1)))
                cwWriteChar(w, ')')
                return
        var baseName: str = cgenCallBaseName n
        var intrinsicName: str = baseName
        if strIsEmpty intrinsicName:
            let flat: Node = unwrapCallTarget callee
            intrinsicName = cgenStripSpaces(plainName(flat))
        if intrinsicName == "sizeof":
            if count > 1:
                let arg0: Node = cgenCallArgValue Node(get[void*](kids, 1))
                cwWrite(w, "sizeof(")
                if cgenIsTypeExprNode arg0 || arg0.kind == nkBracketExpr || arg0.kind == nkPtrTy ||
                   arg0.kind == nkRefTy || arg0.kind == nkVarTy:
                    emitTypeName(w, arg0)
                else:
                    cgenEmitExpr(w, arg0)
                cwWrite(w, ")")
            else:
                cwWrite(w, "0")
            return
        if intrinsicName == "ord":
            if count > 1:
                let arg0: Node = cgenCallArgValue Node(get[void*](kids, 1))
                cwWrite(w, "((NI32)(")
                cgenEmitExpr(w, arg0)
                cwWrite(w, "))")
            else:
                cwWrite(w, "0")
            return
        if intrinsicName == "len":
            if count > 1:
                let arg0: Node = cgenCallArgValue Node(get[void*](kids, 1))
                let argTy: Node = cgenInferSimpleTypeCached arg0
                let elemTy: Node = cgenSeqElemType argTy
                if elemTy != nil && elemTy.kind != nkEmpty:
                    let elemKey: str = cgenTypeKey elemTy
                    if !strIsEmpty elemKey:
                        cwWrite(w, "len_")
                        cwWrite(w, elemKey)
                        cwWriteChar(w, '(')
                        cgenEmitExpr(w, arg0)
                        cwWriteChar(w, ')')
                        return
        if intrinsicName == "TableInit" || strStartsWith(intrinsicName, "TableInit_") || strHasSubstr(intrinsicName, ".TableInit"):
            var rt0: Node = cFnSigRetTypeForCall n
            if rt0 == nil || rt0.kind == nkEmpty || !cgenIsTableTypeNode(rt0):
                var key: str = ""
                if strStartsWith(intrinsicName, "TableInit_"):
                    key = cgenSliceRange(intrinsicName, 10, len intrinsicName)
                else:
                    let idxTableInit: int32 = findSubstr(intrinsicName, ".TableInit_")
                    if idxTableInit >= 0:
                        key = cgenSliceRange(intrinsicName, idxTableInit + 11, len intrinsicName)
                if !strIsEmpty key:
                    rt0 = newIdent("Table_" + key, n.pos)
            if rt0 != nil && rt0.kind != nkEmpty && cgenIsTableTypeNode(rt0):
                let posCount: int32 = callPosCountTrimmed n
                var capExpr: Node = nil
                if posCount > 0 && count > 1:
                    capExpr = cgenCallArgValue Node(get[void*](kids, 1))
                if capExpr == nil:
                    capExpr = newIntLit(64, n.pos)
                cwWrite(w, "((")
                emitTypeName(w, rt0)
                cwWrite(w, "){ .slots = __cheng_tables_initSlots(")
                cgenEmitExpr(w, capExpr)
                cwWrite(w, "), .len = 0 })")
                return
        if intrinsicName == "default":
            if count > 1:
                cgenEmitDefaultValue(w, cgenCallArgValue Node(get[void*](kids, 1)))
            else:
                cwWrite(w, "0")
            return
        if intrinsicName == "__addr":
            if count > 1:
                cwWrite(w, "(&")
                cgenEmitExpr(w, cgenCallArgValue Node(get[void*](kids, 1)))
                cwWrite(w, ")")
            else:
                cwWrite(w, "0")
            return
        var sigIdx: int32 = -1
        if profCallOn:
            let t1: int64 = cheng_monotime_ns()
            sigIdx = cgenFindFnSigIndexForCall n
            cgenProfCallSigNs = cgenProfCallSigNs + ((cheng_monotime_ns() - t1) * profScale)
        else:
            sigIdx = cgenFindFnSigIndexForCall n
        var callNode: Node = n
        # Method-style calls are parsed as calling a dot expression:
        #   obj.method(args...)  => call(callee=dot(obj, method), args...)
        # Lower to a regular call if the direct call cannot be resolved.
        if sigIdx < 0 && !isTypeCall:
            let calleeFlat2: Node = unwrapCallTarget callee
            if calleeFlat2 != nil && calleeFlat2.kind == nkDotExpr && kidCount(calleeFlat2) >= 2:
                let recv0: Node = kid(calleeFlat2, 0)
                let member2: Node = kid(calleeFlat2, 1)
                if member2 != nil && (member2.kind == nkIdent || member2.kind == nkSymbol):
                    var recvArg: Node = recv0
                    var recvHasDeref: bool = false
                    if recv0 != nil && (recv0.kind == nkHiddenDeref || recv0.kind == nkDerefExpr) && kidCount(recv0) > 0:
                        recvArg = kid(recv0, 0)
                        recvHasDeref = true
                    var callPtr: Node = nil
                    let recvTy0: Node = cgenInferSimpleTypeCached recvArg
                    let recvTy: Node = stripVarType recvTy0
                    let isPtrRecv: bool = recvTy != nil && (recvTy.kind == nkPtrTy || recvTy.kind == nkRefTy || recvTy.kind == nkVarTy)
                    let mname: str = cgenStripSpaces(plainName(member2))
                    if !strIsEmpty mname:
                        var ptrName: str = mname
                        if !hasSuffix(ptrName, "Ptr"):
                            ptrName = ptrName + "Ptr"
                        var recvPtrArg: Node = recvArg
                        if !isPtrRecv:
                            if recvArg != nil && (recvArg.kind == nkIdent || recvArg.kind == nkSymbol || recvArg.kind == nkDotExpr):
                                recvPtrArg = newNode(nkPrefix, n.pos)
                                addSon(recvPtrArg, newIdent("&", n.pos))
                                addSon(recvPtrArg, recvArg)
                            else:
                                recvPtrArg = nil
                        if recvPtrArg != nil:
                            callPtr = newNode(nkCall, n.pos)
                            callPtr.callStyle = CallStyleParen
                            addSon(callPtr, newIdent(ptrName, n.pos))
                            addSon(callPtr, recvPtrArg)
                            var ai: int32 = 1
                            while ai < count:
                                addSon(callPtr, Node(get[void*](kids, ai)))
                                ai = ai + 1
                    var call2: Node = newNode(nkCall, n.pos)
                    call2.callStyle = CallStyleParen
                    addSon(call2, member2)
                    addSon(call2, recvArg)
                    var ai2: int32 = 1
                    while ai2 < count:
                        addSon(call2, Node(get[void*](kids, ai2)))
                        ai2 = ai2 + 1
                    var sigIdxPtr: int32 = -1
                    if callPtr != nil:
                        sigIdxPtr = cgenFindFnSigIndexForCall callPtr
                    if sigIdxPtr >= 0:
                        callNode = callPtr
                        baseName = cgenCallBaseName callPtr
                        sigIdx = sigIdxPtr
                    else:
                        let sigIdx2: int32 = cgenFindFnSigIndexForCall call2
                        if sigIdx2 >= 0:
                            callNode = call2
                            baseName = cgenCallBaseName call2
                            sigIdx = sigIdx2
                        elif recvHasDeref:
                            var call3: Node = newNode(nkCall, n.pos)
                            call3.callStyle = CallStyleParen
                            addSon(call3, member2)
                            addSon(call3, recv0)
                            var ai3: int32 = 1
                            while ai3 < count:
                                addSon(call3, Node(get[void*](kids, ai3)))
                                ai3 = ai3 + 1
                            let sigIdx3: int32 = cgenFindFnSigIndexForCall call3
                            if sigIdx3 >= 0:
                                callNode = call3
                                baseName = cgenCallBaseName call3
                                sigIdx = sigIdx3
        if cgenCallImportcAggRetTypeBySig(sigIdx) != nil:
            cgenAddError(n.pos, "[C-Profile] not-mapped: importc aggregate return in expression (FULLC.F01). hint: assign to local or use wrapper/out parameter.")
            cwWrite(w, "0")
            return
        var resolvedName: str = ""
        if !isTypeCall:
            if profCallOn:
                let t0: int64 = cheng_monotime_ns()
                resolvedName = resolveCallNameWithSig(callNode, baseName, sigIdx)
                cgenProfCallResolveNs = cgenProfCallResolveNs + ((cheng_monotime_ns() - t0) * profScale)
            else:
                resolvedName = resolveCallNameWithSig(callNode, baseName, sigIdx)
            var rawName: str = resolvedName
            if strIsEmpty rawName:
                if callee != nil && (callee.kind == nkIdent || callee.kind == nkSymbol || callee.kind == nkPostfix):
                    rawName = cgenStripSpaces(plainName(callee))
            let castTarget: str = cgenCastTargetFromFnName(rawName)
            if !strIsEmpty castTarget && count == 2:
                cwWriteChar(w, '(')
                cwWriteChar(w, '(')
                emitTypeName(w, newIdent(castTarget, n.pos))
                cwWriteChar(w, ')')
                cgenEmitExpr(w, cgenCallArgValue Node(get[void*](kids, 1)))
                cwWriteChar(w, ')')
                return
        let calleeName: str = resolvedName
        if !strIsEmpty calleeName:
            cwWrite(w, calleeName)
        else:
            if callee != nil &&(callee.kind == nkIdent || callee.kind == nkSymbol || callee.kind == nkPostfix):
                let nm: str = cgenStripSpaces(plainName(callee))
                if !strIsEmpty nm:
                    cwWrite(w, mangleCName nm)
                else:
                    cgenEmitExpr(w, callee)
            else:
                cgenEmitExpr(w, callee)
        cwWriteChar(w, '(')
        if sigIdx >= 0:
            if profCallOn:
                let t2: int64 = cheng_monotime_ns()
                cgenEmitCallArgsBySig(w, sigIdx, callNode)
                cgenProfCallArgsNs = cgenProfCallArgsNs + ((cheng_monotime_ns() - t2) * profScale)
            else:
                cgenEmitCallArgsBySig(w, sigIdx, callNode)
        else:
            if profCallOn:
                let t3: int64 = cheng_monotime_ns()
                var i: int32 = 1
                while i < count:
                    let arg: Node = Node(get[void*](kids, i))
                    if arg != nil && arg.kind == nkCallArg:
                        let argKids: seq[void*] = arg.kids
                        if argKids.len > 1:
                            cgenEmitExpr(w, Node(get[void*](argKids, 1)))
                        else:
                            cgenEmitExpr(w, cgenCallArgValue arg)
                    else:
                        cgenEmitExpr(w, cgenCallArgValue arg)
                    if i + 1 < count:
                        cwWrite(w, ", ")
                    i = i + 1
                cgenProfCallArgsNs = cgenProfCallArgsNs + ((cheng_monotime_ns() - t3) * profScale)
            else:
                var i: int32 = 1
                while i < count:
                    let arg: Node = Node(get[void*](kids, i))
                    if arg != nil && arg.kind == nkCallArg:
                        let argKids: seq[void*] = arg.kids
                        if argKids.len > 1:
                            cgenEmitExpr(w, Node(get[void*](argKids, 1)))
                        else:
                            cgenEmitExpr(w, cgenCallArgValue arg)
                    else:
                        cgenEmitExpr(w, cgenCallArgValue arg)
                    if i + 1 < count:
                        cwWrite(w, ", ")
                    i = i + 1
        cwWriteChar(w, ')')
    of nkIf:
        # Ternary `?:` is parsed as `nkIf` with exactly 3 kids (cond, then, else).
        # Allow mapping to C's `?:` for expression contexts.
        let kids: seq[void*] = n.kids
        var thenExpr: Node = nil
        if kids.len > 1:
            thenExpr = Node(get[void*](kids, 1))
        var elseExpr: Node = nil
        if kids.len > 2:
            elseExpr = Node(get[void*](kids, 2))
        if kids.len == 3 && thenExpr != nil && elseExpr != nil && thenExpr.kind != nkStmtList && elseExpr.kind != nkStmtList:
            cwWrite(w, "((")
            cgenEmitCondExpr(w, Node(get[void*](kids, 0)))
            cwWrite(w, ") ? (")
            cgenEmitExpr(w, thenExpr)
            cwWrite(w, ") : (")
            cgenEmitExpr(w, elseExpr)
            cwWrite(w, "))")
        else:
            cgenAddError(n.pos, "[C-Profile] not-mapped: control-flow expression (FULLC.L01). hint: lower to if/elif with tag checks.")
            cwWrite(w, "0")
    of nkWhen, nkCase:
        cgenAddError(n.pos, "[C-Profile] not-mapped: control-flow expression (FULLC.L01). hint: lower to if/elif with tag checks.")
        cwWrite(w, "0")
    else:
        cwWrite(w, "0")

fn cgenEmitCondExpr(w: CWriter*, n: Node) =
    if n != nil && (n.kind == nkIdent || n.kind == nkSymbol):
        let nm: str = cgenStripSpaces n.ident
        if nm == "true":
            cwWrite(w, "1")
            return
        if nm == "false":
            cwWrite(w, "0")
            return
    if n == nil:
        cwWrite(w, "0")
        return
    case n.kind
    of nkInfix:
        let kids: seq[void*] = n.kids
        let count: int32 = kids.len
        if count >= 3:
            let lhs: Node = Node(get[void*](kids, 1))
            let rhs2: Node = Node(get[void*](kids, 2))
            let op: str = infixOp n
            if op == "+" || op == "==" || op == "!=":
                if exprIsStringLike(lhs) || exprIsStringLike(rhs2):
                    var opCall: str = op
                    if op == "!=":
                        opCall = "=="
                    var call2: Node = newNode(nkCall, n.pos)
                    call2.callStyle = CallStyleParen
                    addSon(call2, newIdent(opCall, n.pos))
                    addSon(call2, lhs)
                    addSon(call2, rhs2)
                    if op == "!=":
                        cwWrite(w, "(!")
                    let sigIdx2: int32 = cFnSigFindMatchForCall(opCall, call2)
                    if sigIdx2 >= 0:
                        cwWrite(w, mangleCName(cFnSigName sigIdx2))
                    else:
                        cwWrite(w, mangleCName(opCall))
                    cwWriteChar(w, '(')
                    cgenEmitExpr(w, lhs)
                    cwWrite(w, ", ")
                    cgenEmitExpr(w, rhs2)
                    cwWriteChar(w, ')')
                    if op == "!=":
                        cwWriteChar(w, ')')
                    return
            if op == "in" || op == "notin":
                cgenEmitInCond(w, lhs, rhs2, n.pos, op == "notin")
                return
            cgenEmitExpr(w, lhs)
            cwWrite(w, " ")
            cwWrite(w, op)
            cwWrite(w, " ")
            cgenEmitExpr(w, rhs2)
        else:
            cwWrite(w, "0")
    of nkPrefix:
        let kids: seq[void*] = n.kids
        let count: int32 = kids.len
        if count >= 2:
            let rhs: Node = Node(get[void*](kids, 1))
            let op: str = prefixOp n
            if op == "await":
                cgenEmitAwaitExpr(w, rhs, n.pos)
                return
            if !strIsEmpty op:
                cwWrite(w, op)
            cgenEmitExpr(w, rhs)
        else:
            cwWrite(w, "0")
    of nkPar:
        let kids: seq[void*] = n.kids
        if kids.len == 1:
            cgenEmitCondExpr(w, Node(get[void*](kids, 0)))
        else:
            cwWrite(w, "0")
    else:
        cgenEmitExpr(w, n)

fn cgenEmitInCond(w: CWriter*, lhs: Node, rhs: Node, pos: SourcePos, negate: bool) =
    if rhs == nil:
        cwWrite(w, "0")
        return
    if negate:
        cwWrite(w, "(!")
    if cgenIsRangeExpr rhs && kidCount rhs >= 3:
        let startExpr: Node = kid(rhs, 1)
        let endExpr: Node = kid(rhs, 2)
        var leOp: str = "<="
        if cgenRangeIsExclusive rhs:
            leOp = "<"
        cwWriteChar(w, '(')
        cwWrite(w, "((")
        cgenEmitExpr(w, lhs)
        cwWrite(w, ") >= (")
        cgenEmitExpr(w, startExpr)
        cwWrite(w, ")) && ((")
        cgenEmitExpr(w, lhs)
        cwWrite(w, ") ")
        cwWrite(w, leOp)
        cwWrite(w, " (")
        cgenEmitExpr(w, endExpr)
        cwWrite(w, "))")
        cwWriteChar(w, ')')
        if negate:
            cwWriteChar(w, ')')
        return
    if rhs.kind == nkTupleLit || rhs.kind == nkSeqLit || rhs.kind == nkBracket:
        cwWriteChar(w, '(')
        var i: int32 = 0
        var wrote: bool = false
        while i < kidCount rhs:
            let elem: Node = cgenCallArgValue kid(rhs, i)
            if elem != nil:
                if wrote:
                    cwWrite(w, " || ")
                cwWriteChar(w, '(')
                cgenEmitExpr(w, lhs)
                cwWrite(w, " == ")
                cgenEmitExpr(w, elem)
                cwWriteChar(w, ')')
                wrote = true
            i = i + 1
        if !wrote:
            cwWrite(w, "0")
        cwWriteChar(w, ')')
        if negate:
            cwWriteChar(w, ')')
        return
    if rhs.kind == nkCurly:
        cwWrite(w, "setHas_0((NU64)(")
        cgenEmitExpr(w, rhs)
        cwWrite(w, "), (NU64)(")
        cgenEmitExpr(w, lhs)
        cwWrite(w, "))")
        if negate:
            cwWriteChar(w, ')')
        return
    let rhsTy: Node = inferSimpleTypeNode rhs
    if cgenIsSetTypeNode rhsTy:
        cwWrite(w, "setHas_0((NU64)(")
        cgenEmitExpr(w, rhs)
        cwWrite(w, "), (NU64)(")
        cgenEmitExpr(w, lhs)
        cwWrite(w, "))")
        if negate:
            cwWriteChar(w, ')')
        return
    let vecElem: Node = cgenSeqElemType rhsTy
    if vecElem != nil:
        var call: Node = newNode(nkCall, pos)
        call.callStyle = CallStyleParen
        addSon(call, cgenMakeGenericCallee("__cheng_vec_contains", vecElem, pos))
        addSon(call, rhs)
        addSon(call, lhs)
        cgenEmitExpr(w, call)
        if negate:
            cwWriteChar(w, ')')
        return
    if cgenIsStringTypeNode(rhsTy) || exprIsStringLike(rhs):
        let lhsTy: Node = inferSimpleTypeNode lhs
        if cgenIsStringTypeNode(lhsTy) || exprIsStringLike(lhs):
            cwWrite(w, "__cheng_string_contains_str")
        else:
            cwWrite(w, "__cheng_string_contains_char")
        cwWriteChar(w, '(')
        cgenEmitExpr(w, rhs)
        cwWrite(w, ", ")
        cgenEmitExpr(w, lhs)
        cwWriteChar(w, ')')
        if negate:
            cwWriteChar(w, ')')
        return
    let tabVal: Node = cgenTableValueType rhsTy
    if tabVal != nil:
        var call3: Node = newNode(nkCall, pos)
        call3.callStyle = CallStyleParen
        addSon(call3, cgenMakeGenericCallee("TableHas", tabVal, pos))
        addSon(call3, rhs)
        addSon(call3, lhs)
        cgenEmitExpr(w, call3)
        if negate:
            cwWriteChar(w, ')')
        return
    var call4: Node = newNode(nkCall, pos)
    call4.callStyle = CallStyleParen
    addSon(call4, newIdent("in", pos))
    addSon(call4, lhs)
    addSon(call4, rhs)
    cgenEmitExpr(w, call4)
    if negate:
        cwWriteChar(w, ')')
