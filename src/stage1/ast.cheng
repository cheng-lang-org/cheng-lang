fn plainName(n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    if nodeKind(n) == nkPattern && kidCount(n) > 0:
        return plainName(kid(n, 0))
    if nodeKind(n) == nkIdent:
        return nodeIdent(n)
    if nodeKind(n) == nkSymbol:
        return nodeIdent(n)
    if nodeKind(n) == nkDotExpr && kidCount(n) > 1:
        return plainName(kid(n, 1))
    if nodeKind(n) == nkBracketExpr && kidCount(n) > 0:
        return plainName(kid(n, 0))
    if nodeKind(n) == nkPostfix && kidCount(n) > 1:
        return plainName(kid(n, 1))
    return ""

fn plainNameId(n: Node): int32 =
    if stage1AstRefIsNil(n):
        return 0
    if nodeKind(n) == nkPattern && kidCount(n) > 0:
        return plainNameId(kid(n, 0))
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        return nodeIdentId(n)
    if nodeKind(n) == nkDotExpr && kidCount(n) > 1:
        return plainNameId(kid(n, 1))
    if nodeKind(n) == nkBracketExpr && kidCount(n) > 0:
        return plainNameId(kid(n, 0))
    if nodeKind(n) == nkPostfix && kidCount(n) > 1:
        return plainNameId(kid(n, 1))
    return 0

fn identDefsNameCount(defs: Node): int32 =
    if stage1AstRefIsNil(defs) || nodeKind(defs) != nkIdentDefs:
        return 0
    let n: int32 = kidCount(defs)
    if n <= 0:
        return 0
    if n == 1:
        return 1
    if n == 2:
        # Legacy short layout: name, type
        return 1
    return n - 2

fn identDefsNameCountId(defsId: AstNodeId): int32 =
    return identDefsNameCount(defsId)

fn identDefsType(defs: Node): Node =
    if stage1AstRefIsNil(defs) || nodeKind(defs) != nkIdentDefs:
        return astInvalidNodeId()
    let n: int32 = kidCount(defs)
    if n < 2:
        return astInvalidNodeId()
    if n == 2:
        # Legacy short layout: name, type
        return kid(defs, 1)
    # IdentDefs layout: names..., type, default (type at n-2).
    return kid(defs, n - 2)

fn identDefsTypeId(defsId: AstNodeId): AstNodeId =
    return identDefsType(defsId)

fn cloneTree(n: Node): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    var n2: Node = newNode(nodeKind(n), nodePos(n))
    nodeSetIdent(n2, nodeIdent(n))
    nodeSetStrVal(n2, nodeStrVal(n))
    nodeSetIntVal(n2, nodeIntVal(n))
    nodeSetFloatVal(n2, nodeFloatVal(n))
    nodeSetCallStyle(n2, nodeCallStyle(n))
    nodeSetDeferredBodyStartTok(n2, nodeDeferredBodyStartTok(n))
    nodeSetDeferredBodyEndTok(n2, nodeDeferredBodyEndTok(n))
    nodeSetDeferredBodyState(n2, nodeDeferredBodyState(n))
    nodeSetDeclOrdinal(n2, nodeDeclOrdinal(n))
    for i in 0..<kidCount(n):
        addSon(n2, cloneTree(kid(n, i)))
    return n2

fn astCloneTreeId(id: AstNodeId): AstNodeId =
    return cloneTree(id)

fn astArenaFromNodeArena(): AstArena =
    var arena: AstArena
    arena.kind.buffer = nil
    arena.kind.len = 0
    arena.kind.cap = 0
    arena.posLine.buffer = nil
    arena.posLine.len = 0
    arena.posLine.cap = 0
    arena.posCol.buffer = nil
    arena.posCol.len = 0
    arena.posCol.cap = 0
    arena.ident.buffer = nil
    arena.ident.len = 0
    arena.ident.cap = 0
    arena.strVal.buffer = nil
    arena.strVal.len = 0
    arena.strVal.cap = 0
    arena.intVal.buffer = nil
    arena.intVal.len = 0
    arena.intVal.cap = 0
    arena.floatVal.buffer = nil
    arena.floatVal.len = 0
    arena.floatVal.cap = 0
    arena.callStyle.buffer = nil
    arena.callStyle.len = 0
    arena.callStyle.cap = 0
    arena.deferredBodyStartTok.buffer = nil
    arena.deferredBodyStartTok.len = 0
    arena.deferredBodyStartTok.cap = 0
    arena.deferredBodyEndTok.buffer = nil
    arena.deferredBodyEndTok.len = 0
    arena.deferredBodyEndTok.cap = 0
    arena.deferredBodyState.buffer = nil
    arena.deferredBodyState.len = 0
    arena.deferredBodyState.cap = 0
    arena.declOrdinal.buffer = nil
    arena.declOrdinal.len = 0
    arena.declOrdinal.cap = 0
    arena.typeCache.buffer = nil
    arena.typeCache.len = 0
    arena.typeCache.cap = 0
    arena.typeCacheValid.buffer = nil
    arena.typeCacheValid.len = 0
    arena.typeCacheValid.cap = 0
    arena.managedCacheState.buffer = nil
    arena.managedCacheState.len = 0
    arena.managedCacheState.cap = 0
    arena.firstKid.buffer = nil
    arena.firstKid.len = 0
    arena.firstKid.cap = 0
    arena.kidLen.buffer = nil
    arena.kidLen.len = 0
    arena.kidLen.cap = 0
    arena.kidIndex.buffer = nil
    arena.kidIndex.len = 0
    arena.kidIndex.cap = 0
    if !nodeArenaReady:
        return arena

    arena.kind = astKindByNode
    arena.posLine = astPosLineByNode
    arena.posCol = astPosColByNode
    arena.ident = astIdentByNode
    arena.strVal = astStrValByNode
    arena.intVal = astIntValByNode
    arena.floatVal = astFloatValByNode
    arena.callStyle = astCallStyleByNode
    arena.deferredBodyStartTok = astDeferredBodyStartTokByNode
    arena.deferredBodyEndTok = astDeferredBodyEndTokByNode
    arena.deferredBodyState = astDeferredBodyStateByNode
    arena.declOrdinal = astDeclOrdinalByNode
    arena.typeCache = astTypeCacheByNode
    arena.typeCacheValid = astTypeCacheValidByNode
    arena.managedCacheState = astManagedCacheStateByNode

    let count: int32 = len(astKindByNode)
    reserve(arena.firstKid, count)
    reserve(arena.kidLen, count)
    for i in 0..<count:
        astAppendI32(arena.firstKid, arena.kidIndex.len)
        let id: AstNodeId = i + 1
        let kc: int32 = astKidCount(id)
        astAppendI32(arena.kidLen, kc)
        for k in 0..<kc:
            astAppendNodeId(arena.kidIndex, astKidAt(id, k))
    return arena

fn astArenaFromRoot(root: Node): AstArena =
    let _root: Node = root
    return astArenaFromNodeArena()
