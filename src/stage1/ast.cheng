    if seqInst.buffer != nil:
        memRelease(seqInst.buffer)
    seqInst.buffer = nil
    seqInst.len = 0
    seqInst.cap = 0

fn astResetSeq(seqInst: var NodeKind[], releaseBuffer: bool) =
    if releaseBuffer:
        if seqInst.buffer != nil:
            memRelease(seqInst.buffer)
    seqInst.buffer = nil
    seqInst.len = 0
    seqInst.cap = 0

