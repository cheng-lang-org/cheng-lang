type
    NodeKind = enum
        nkError, nkEmpty,
        nkModule, nkStmtList,
        # Declarations
        nkImportStmt, nkImportAs, nkImportGroup,
        nkFnDecl, nkIteratorDecl, nkMacroDecl, nkTemplateDecl,
        nkFormalParams, nkIdentDefs,
        nkTypeDecl, nkObjectDecl, nkEnumDecl, nkEnumFieldDecl, nkConceptDecl, nkTraitDecl,
        nkRefTy, nkPtrTy, nkVarTy, nkTupleTy, nkSetTy, nkFnTy,
        nkRecList, nkRecCase,
        nkGenericParams,
        nkLet, nkVar, nkConst,
        nkPragma, nkAnnotation,
        # Statements
        nkReturn, nkYield, nkBreak, nkContinue, nkDefer,
        nkIf, nkWhen, nkWhile, nkFor, nkCase, nkBlock,
        nkOfBranch, nkElse,
        nkAsgn, nkFastAsgn,
        # Expressions
        nkCall, nkInfix, nkPrefix, nkPostfix, nkDotExpr, nkBracketExpr,
        nkCurlyExpr, nkPar, nkTupleLit, nkSeqLit, nkTableLit,
        nkCurly, nkBracket, nkRange, nkPattern, nkCallArg, nkGuard,
        nkLambda, nkDo, nkIfExpr, nkWhenExpr, nkCaseExpr, nkComprehension,
        nkHiddenDeref, nkDerefExpr,
        # Leaves
        nkIdent, nkSymbol,
        nkIntLit, nkFloatLit, nkStrLit, nkCharLit, nkBoolLit, nkNilLit

const
    CallStyleSpace: int8 = 1
    CallStyleTypeDiag: int8 = 2
    CallStyleParen: int8 = 4

type
    SourcePos =
        line: int32
        col: int32

fn zeroPos(): SourcePos =
    var pos: SourcePos
    return pos

type
    AstNodeId = int32
    Node = AstNodeId

    AstArena =
        kind: NodeKind[]
        posLine: int32[]
        posCol: int32[]
        ident: int32[]
        strVal: int32[]
        intVal: int64[]
        floatVal: float64[]
        callStyle: int8[]
        deferredBodyStartTok: int32[]
        deferredBodyEndTok: int32[]
        deferredBodyState: int8[]
        declOrdinal: int32[]
        typeCache: AstNodeId[]
        typeCacheValid: bool[]
        managedCacheState: int8[]
        firstKid: int32[]
        kidLen: int32[]
        kidIndex: AstNodeId[]

fn astResetSeq(seqInst: var AstNodeId[], releaseBuffer: bool) =
    if releaseBuffer:
        if seqInst.buffer != nil:
            memRelease(seqInst.buffer)
    seqInst.buffer = nil
    seqInst.len = 0
    seqInst.cap = 0

var
    nodeArenaReady: bool
    nodeArenaEnabled: bool = true
    astArenaStorageReady: bool = true
    astKindByNode: NodeKind[]
    astPosLineByNode: int32[]
    astPosColByNode: int32[]
    astIdentByNode: int32[]
    astStrValByNode: int32[]
    astIntValByNode: int64[]
    astFloatValByNode: float64[]
    astCallStyleByNode: int8[]
    astDeferredBodyStartTokByNode: int32[]
    astDeferredBodyEndTokByNode: int32[]
    astDeferredBodyStateByNode: int8[]
    astDeclOrdinalByNode: int32[]
    astTypeCacheByNode: AstNodeId[]
    astTypeCacheValidByNode: bool[]
    astManagedCacheStateByNode: int8[]
    astKidHeadByNode: int32[]
    astKidTailByNode: int32[]
    astKidCountByNode: int32[]
    astKidValue: AstNodeId[]
    astKidNext: int32[]
fn astInvalidNodeId(): AstNodeId =
    return int32(0)

fn astNodeIdValid(id: AstNodeId): bool =
    if id <= 0:
        return false
    if !nodeArenaReady:
        return false
    return id <= len(astKindByNode)

fn astNodeIndex(id: AstNodeId): int32 =
    return id - 1

fn stage1AstRefIsNil(v: Node): bool =
    return !astNodeIdValid(v)

fn stage1AstRefNonNil(v: Node): bool =
    return astNodeIdValid(v)

fn astEnsureArenaRuntime() =
    if !astArenaStorageReady:
        panic "ast arena storage not initialized"

fn astReserveNodeI32(seqInst: var int32[], needLen: int32) =
    if needLen > 0 && seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)

fn astReserveNodeI64(seqInst: var int64[], needLen: int32) =
    if needLen > 0 && seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)

fn astReserveNodeF64(seqInst: var float64[], needLen: int32) =
    if needLen > 0 && seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)

fn astReserveNodeI8(seqInst: var int8[], needLen: int32) =
    if needLen > 0 && seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)

fn astReserveNodeBool(seqInst: var bool[], needLen: int32) =
    if needLen > 0 && seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)

fn astReserveNodeKindSeq(seqInst: var NodeKind[], needLen: int32) =
    if needLen > 0 && seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)

fn astReserveNodeIdSeq(seqInst: var AstNodeId[], needLen: int32) =
    if needLen > 0 && seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)

fn astReserveAdditional(nodeCount: int32, kidCount: int32) =
    astEnsureArenaRuntime()
    if nodeCount > 0:
        let needNodes: int32 = len(astKindByNode) + nodeCount
        astReserveNodeKindSeq(astKindByNode, needNodes)
        astReserveNodeI32(astPosLineByNode, needNodes)
        astReserveNodeI32(astPosColByNode, needNodes)
        astReserveNodeI32(astIdentByNode, needNodes)
        astReserveNodeI32(astStrValByNode, needNodes)
        astReserveNodeI64(astIntValByNode, needNodes)
        astReserveNodeF64(astFloatValByNode, needNodes)
        astReserveNodeI8(astCallStyleByNode, needNodes)
        astReserveNodeI32(astDeferredBodyStartTokByNode, needNodes)
        astReserveNodeI32(astDeferredBodyEndTokByNode, needNodes)
        astReserveNodeI8(astDeferredBodyStateByNode, needNodes)
        astReserveNodeI32(astDeclOrdinalByNode, needNodes)
        astReserveNodeIdSeq(astTypeCacheByNode, needNodes)
        astReserveNodeBool(astTypeCacheValidByNode, needNodes)
        astReserveNodeI8(astManagedCacheStateByNode, needNodes)
        astReserveNodeI32(astKidHeadByNode, needNodes)
        astReserveNodeI32(astKidTailByNode, needNodes)
        astReserveNodeI32(astKidCountByNode, needNodes)
    if kidCount > 0:
        let needKids: int32 = len(astKidValue) + kidCount
        astReserveNodeIdSeq(astKidValue, needKids)
        astReserveNodeI32(astKidNext, needKids)

fn astResetArenaStorage(releaseBuffers: bool) =
    astResetSeq(astKindByNode, releaseBuffers)
    astResetSeq(astPosLineByNode, releaseBuffers)
    astResetSeq(astPosColByNode, releaseBuffers)
    astResetSeq(astIdentByNode, releaseBuffers)
    astResetSeq(astStrValByNode, releaseBuffers)
    astResetSeq(astIntValByNode, releaseBuffers)
    astResetSeq(astFloatValByNode, releaseBuffers)
    astResetSeq(astCallStyleByNode, releaseBuffers)
    astResetSeq(astDeferredBodyStartTokByNode, releaseBuffers)
    astResetSeq(astDeferredBodyEndTokByNode, releaseBuffers)
    astResetSeq(astDeferredBodyStateByNode, releaseBuffers)
    astResetSeq(astDeclOrdinalByNode, releaseBuffers)
    astResetSeq(astTypeCacheByNode, releaseBuffers)
    astResetSeq(astTypeCacheValidByNode, releaseBuffers)
    astResetSeq(astManagedCacheStateByNode, releaseBuffers)
    astResetSeq(astKidHeadByNode, releaseBuffers)
    astResetSeq(astKidTailByNode, releaseBuffers)
    astResetSeq(astKidCountByNode, releaseBuffers)
    astResetSeq(astKidValue, releaseBuffers)
    astResetSeq(astKidNext, releaseBuffers)

fn astZeroArenaState() =
    # Avoid direct global `seq = []` writes here; sidecar bundles can materialize
    # those headers incorrectly, while the var-ref reset path is stable.
    astResetArenaStorage(false)

fn astResetArenaState() =
    astEnsureArenaRuntime()
    astResetArenaStorage(true)

fn initNodeArena() =
    if nodeArenaReady:
        return
    astEnsureArenaRuntime()
    nodeArenaReady = true

fn astKidNodeAppend(id: AstNodeId, childId: AstNodeId) =
    if !astNodeIdValid(id):
        return
    let nodeIdx: int32 = astNodeIndex(id)
    let slot: int32 = len(astKidValue)
    astAppendNodeId(astKidValue, childId)
    astAppendI32(astKidNext, -1)
    let tail: int32 = astKidTailByNode[nodeIdx]
    if tail < 0:
        astKidHeadByNode[nodeIdx] = slot
    else:
        astKidNext[tail] = slot
    astKidTailByNode[nodeIdx] = slot
    let count0: int32 = astKidCountByNode[nodeIdx]
    astKidCountByNode[nodeIdx] = count0 + 1

fn astNodeKind(id: AstNodeId): NodeKind =
    if !astNodeIdValid(id):
        return nkEmpty
    return astKindByNode[astNodeIndex(id)]

fn astSetNodeKind(id: AstNodeId, kind: NodeKind) =
    if !astNodeIdValid(id):
        return
    astKindByNode[astNodeIndex(id)] = kind

fn astNodePos(id: AstNodeId): SourcePos =
    var pos: SourcePos
    if !astNodeIdValid(id):
        return pos
    pos.line = astPosLineByNode[astNodeIndex(id)]
    pos.col = astPosColByNode[astNodeIndex(id)]
    return pos

fn astSetNodePos(id: AstNodeId, pos: SourcePos) =
    if !astNodeIdValid(id):
        return
    astPosLineByNode[astNodeIndex(id)] = pos.line
    astPosColByNode[astNodeIndex(id)] = pos.col

fn astNodePosLine(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return 0
    return astPosLineByNode[astNodeIndex(id)]

fn astNodePosCol(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return 0
    return astPosColByNode[astNodeIndex(id)]

fn astNodeIdent(id: AstNodeId): str =
    if !astNodeIdValid(id):
        return ""
    return tokenTextById(astIdentByNode[astNodeIndex(id)])

fn astNodeIdentId(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return 0
    return astIdentByNode[astNodeIndex(id)]

fn astNodeStrVal(id: AstNodeId): str =
    if !astNodeIdValid(id):
        return ""
    return tokenTextById(astStrValByNode[astNodeIndex(id)])

fn astNodeStrValId(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return 0
    return astStrValByNode[astNodeIndex(id)]

fn astNodeIntVal(id: AstNodeId): int64 =
    if !astNodeIdValid(id):
        return 0
    return astIntValByNode[astNodeIndex(id)]

fn astNodeFloatVal(id: AstNodeId): float64 =
    if !astNodeIdValid(id):
        return 0.0
    return astFloatValByNode[astNodeIndex(id)]

fn astNodeCallStyle(id: AstNodeId): int8 =
    if !astNodeIdValid(id):
        return int8(0)
    return astCallStyleByNode[astNodeIndex(id)]

fn astNodeTypeCacheValid(id: AstNodeId): bool =
    if !astNodeIdValid(id):
        return false
    return astTypeCacheValidByNode[astNodeIndex(id)]

fn astNodeTypeCache(id: AstNodeId): Node =
    if !astNodeIdValid(id):
        return astInvalidNodeId()
    return astTypeCacheByNode[astNodeIndex(id)]

fn astNodeTypeCacheId(id: AstNodeId): AstNodeId =
    return astNodeTypeCache(id)

fn astNodeManagedCacheState(id: AstNodeId): int8 =
    if !astNodeIdValid(id):
        return int8(0)
    return astManagedCacheStateByNode[astNodeIndex(id)]

fn astSetNodeManagedCacheState(id: AstNodeId, state: int8) =
    if !astNodeIdValid(id):
        return
    astManagedCacheStateByNode[astNodeIndex(id)] = state

fn astSetNodeTypeCacheValid(id: AstNodeId, valid: bool) =
    if !astNodeIdValid(id):
        return
    astTypeCacheValidByNode[astNodeIndex(id)] = valid

fn astSetNodeTypeCache(id: AstNodeId, cache: Node) =
    if !astNodeIdValid(id):
        return
    astTypeCacheByNode[astNodeIndex(id)] = cache

fn astSetNodeTypeCacheId(id: AstNodeId, cacheId: AstNodeId) =
    astSetNodeTypeCache(id, cacheId)

fn astSetNodeIdent(id: AstNodeId, s: str) =
    if !astNodeIdValid(id):
        return
    let textId: int32 = tokenInternText(s)
    if astIdentByNode[astNodeIndex(id)] == textId:
        return
    astIdentByNode[astNodeIndex(id)] = textId

fn astSetNodeIdentId(id: AstNodeId, textId: int32) =
    if !astNodeIdValid(id):
        return
    if textId <= 0:
        astIdentByNode[astNodeIndex(id)] = 0
        return
    if astIdentByNode[astNodeIndex(id)] == textId:
        return
    astIdentByNode[astNodeIndex(id)] = textId

fn astSetNodeStrVal(id: AstNodeId, s: str) =
    if !astNodeIdValid(id):
        return
    let textId: int32 = tokenInternText(s)
    if astStrValByNode[astNodeIndex(id)] == textId:
        return
    astStrValByNode[astNodeIndex(id)] = textId

fn astSetNodeStrValId(id: AstNodeId, textId: int32) =
    if !astNodeIdValid(id):
        return
    if textId <= 0:
        astStrValByNode[astNodeIndex(id)] = 0
        return
    if astStrValByNode[astNodeIndex(id)] == textId:
        return
    astStrValByNode[astNodeIndex(id)] = textId

fn astSetNodeIntVal(id: AstNodeId, v: int64) =
    if !astNodeIdValid(id):
        return
    astIntValByNode[astNodeIndex(id)] = v

fn astSetNodeFloatVal(id: AstNodeId, v: float64) =
    if !astNodeIdValid(id):
        return
    astFloatValByNode[astNodeIndex(id)] = v

fn astSetNodeCallStyle(id: AstNodeId, style: int8) =
    if !astNodeIdValid(id):
        return
    astCallStyleByNode[astNodeIndex(id)] = style

fn astPlainName(id: AstNodeId): str =
    return plainName(id)

fn astPlainNameId(id: AstNodeId): int32 =
    return plainNameId(id)

fn astNodeDeferredBodyStartTok(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return -1
    return astDeferredBodyStartTokByNode[astNodeIndex(id)]

fn astNodeDeferredBodyEndTok(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return -1
    return astDeferredBodyEndTokByNode[astNodeIndex(id)]

fn astNodeDeferredBodyState(id: AstNodeId): int8 =
    if !astNodeIdValid(id):
        return int8(0)
    return astDeferredBodyStateByNode[astNodeIndex(id)]

fn astNodeDeclOrdinal(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return -1
    return astDeclOrdinalByNode[astNodeIndex(id)]

fn astSetNodeDeferredBodyStartTok(id: AstNodeId, tok: int32) =
    if !astNodeIdValid(id):
        return
    astDeferredBodyStartTokByNode[astNodeIndex(id)] = tok

fn astSetNodeDeferredBodyEndTok(id: AstNodeId, tok: int32) =
    if !astNodeIdValid(id):
        return
    astDeferredBodyEndTokByNode[astNodeIndex(id)] = tok

fn astSetNodeDeferredBodyState(id: AstNodeId, state: int8) =
    if !astNodeIdValid(id):
        return
    astDeferredBodyStateByNode[astNodeIndex(id)] = state

fn astSetNodeDeclOrdinal(id: AstNodeId, ordinal: int32) =
    if !astNodeIdValid(id):
        return
    astDeclOrdinalByNode[astNodeIndex(id)] = ordinal

fn nodeArenaId(n: Node): AstNodeId =
    return n

fn nodeKind(n: Node): NodeKind =
    return astNodeKind(n)

fn nodeSetKind(n: Node, kind: NodeKind) =
    astSetNodeKind(n, kind)

fn nodePos(n: Node): SourcePos =
