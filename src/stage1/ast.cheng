    astSetNodeManagedCacheState(n, state)

fn astResetKidsByNodeId(id: AstNodeId) =
    if !astNodeIdValid(id):
        return
    astKidHeadByNode[astNodeIndex(id)] = -1
    astKidTailByNode[astNodeIndex(id)] = -1
    astKidCountByNode[astNodeIndex(id)] = 0

fn astReplaceKidsByIds(n: Node, kidIds: AstNodeId[]) =
    if stage1AstRefIsNil(n):
        return
    let id: AstNodeId = n
    astResetKidsByNodeId(id)
    for i in 0..<kidIds.len:
        astKidNodeAppend(id, kidIds[i])

fn astKidCount(id: AstNodeId): int32 =
    if !astNodeIdValid(id):
        return 0
    return astKidCountByNode[astNodeIndex(id)]

fn astKidAt(id: AstNodeId, i: int32): AstNodeId =
    if !astNodeIdValid(id):
        return astInvalidNodeId()
    if i < 0 || i >= astKidCountByNode[astNodeIndex(id)]:
        return astInvalidNodeId()
    var cur: int32 = astKidHeadByNode[astNodeIndex(id)]
    var pos: int32
    while cur >= 0:
        if pos == i:
            if cur >= 0 && cur < len(astKidValue):
                return astKidValue[cur]
            return astInvalidNodeId()
        if cur < 0 || cur >= len(astKidNext):
            break
        cur = astKidNext[cur]
        pos = pos + 1
    return astInvalidNodeId()

fn astSetKid(id: AstNodeId, i: int32, child: AstNodeId) =
    if !astNodeIdValid(id):
        return
    if i < 0 || i >= astKidCountByNode[astNodeIndex(id)]:
        return
    var cur: int32 = astKidHeadByNode[astNodeIndex(id)]
    var pos: int32
    while cur >= 0:
        if pos == i:
            astKidValue[cur] = child
            return
        if cur < 0 || cur >= len(astKidNext):
            break
        cur = astKidNext[cur]
        pos = pos + 1

fn astAddKid(id: AstNodeId, child: AstNodeId) =
    if !astNodeIdValid(id):
        return
    astKidNodeAppend(id, child)

fn releaseNodeArena() =
    if !nodeArenaReady:
        return
    astResetArenaState()
    nodeArenaReady = false

fn newNode(kind: NodeKind, pos: SourcePos): Node =
    initNodeArena()
    let idx: int32 = len(astKindByNode)
    astAppendKind(astKindByNode, kind)
    astAppendI32(astPosLineByNode, pos.line)
    astAppendI32(astPosColByNode, pos.col)
    astAppendI32(astIdentByNode, 0)
    astAppendI32(astStrValByNode, 0)
    astAppendI64(astIntValByNode, 0)
    astAppendF64(astFloatValByNode, 0.0)
    astAppendI8(astCallStyleByNode, int8(0))
    astAppendI32(astDeferredBodyStartTokByNode, -1)
    astAppendI32(astDeferredBodyEndTokByNode, -1)
    astAppendI8(astDeferredBodyStateByNode, int8(0))
    astAppendI32(astDeclOrdinalByNode, -1)
    astAppendNodeId(astTypeCacheByNode, astInvalidNodeId())
    astAppendBool(astTypeCacheValidByNode, false)
    astAppendI8(astManagedCacheStateByNode, int8(0))

    astAppendI32(astKidHeadByNode, -1)
    astAppendI32(astKidTailByNode, -1)
    astAppendI32(astKidCountByNode, 0)
    return idx + 1

fn astNewNodeId(kind: NodeKind, pos: SourcePos): AstNodeId =
    return newNode(kind, pos)

