# ast.cheng
# Stage1 AST definitions in SoA form (Node = AstNodeId).
import std/strings
import std/seqs as seqs
import std/rawmem_support
import stage1/token

fn add(seqInst: var NodeKind[], val: NodeKind) =
    seqs.Add(seqInst, val)

fn add(seqInst: var int32[], val: int32) =
    seqs.Add(seqInst, val)

fn astAppendI32(seqInst: var int32[], val: int32) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)
    seqs.SetLen(seqInst, needLen)
    seqInst[idx] = val

fn astAppendNodeId(seqInst: var AstNodeId[], val: AstNodeId) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)
    seqs.SetLen(seqInst, needLen)
    seqInst[idx] = val

fn astAppendKind(seqInst: var NodeKind[], val: NodeKind) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        seqs.Reserve(seqInst, needLen)
    seqs.SetLen(seqInst, needLen)
    seqInst[idx] = val

