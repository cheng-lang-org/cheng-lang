# Stage1 frontend (recovery mode): only supports self-host seed copy.
import std/strings
import std/cmdline
import cheng/stage1/frontend_lib


fn usageCli() =
    echo "Usage:"
    echo "  stage1_runner --mode:c --file:<input.cheng> --out:<output.c>"
    echo "  stage1_runner --mode:c-modules --file:<input.cheng> --out:<modules.dir> --modules:<deps.list>"
    echo "  stage1_runner --mode:deps-list --file:<input.cheng> [--out:<output.deps.list>]"
    echo ""
    echo "Notes:"
    echo "  - No-arg run: generates /tmp/stage1_runner.c (for bootstrap determinism check)."
    echo "  - Recovery mode only; supports c/deps-list."

fn runCli() =
    var mode: str = ""
    var inPath: str = ""
    var outPath: str = ""
    var modulesPath: str = ""
    var i: int32 = 1
    while i <= paramCount():
        let a: str = paramStr i
        if streq(a, "--help"):
            usageCli()
            exit 0
        if streq(a, "-h"):
            usageCli()
            exit 0
        elif hasPrefix(a, "--mode:"):
            mode = dropPrefix(a, "--mode:")
        elif hasPrefix(a, "--file:"):
            inPath = dropPrefix(a, "--file:")
        elif hasPrefix(a, "--out:"):
            outPath = dropPrefix(a, "--out:")
        elif hasPrefix(a, "--modules:"):
            modulesPath = dropPrefix(a, "--modules:")
        else:
            let msg: str = "Unknown argument: " + a
            echo msg
            usageCli()
            exit 2
        i = i + 1

    if streq(mode, ""):
        mode = "c"
    if streq(mode, "deps"):
        echo "Unsupported --mode: deps (removed; use deps-list)"
        usageCli()
        exit 2
    if ! streq(mode, "deps-list") && !streq(mode, "c") && !streq(mode, "c-modules"):
        let msg: str = "Unsupported --mode: " + mode
        echo msg
        usageCli()
        exit 2
    if streq(inPath, ""):
        echo "Missing --file:<input.cheng>"
        usageCli()
        exit 2
    let modeMsg: str = "cli: mode=" + mode
    stage1Trace modeMsg
    let fileMsg: str = "cli: file=" + inPath
    stage1Trace fileMsg
    if streq(mode, "c"):
        if streq(outPath, ""):
            echo "Missing --out:<output.c>"
            usageCli()
            exit 2
        let outMsg2: str = "cli: out=" + outPath
        stage1Trace outMsg2
        compileToC(inPath, outPath)
        return
    if streq(mode, "c-modules"):
        if streq(outPath, ""):
            echo "Missing --out:<modules.dir>"
            usageCli()
            exit 2
        if streq(modulesPath, ""):
            modulesPath = stage1_getEnv "CHENG_C_MODULES_LIST"
        if streq(modulesPath, ""):
            echo "Missing --modules:<deps.list>"
            usageCli()
            exit 2
        let outMsg3: str = "cli: out=" + outPath
        stage1Trace outMsg3
        let listMsg: str = "cli: modules=" + modulesPath
        stage1Trace listMsg
        compileToCModules(inPath, outPath, modulesPath)
        return
    if streq(mode, "deps-list"):
        if ! compileToDepsList(inPath, outPath):
            exit 1
        return

fn main(argc: int32, argv: str*): int32 =
    __cheng_setCmdLine(argc, void*(argv))
    if paramCount() > 0:
        runCli()
        return 0
    echo "stage1 runner start"
    echo "stage1 self-host begin"
    compileToC("src/stage1/frontend_stage1.cheng", "/tmp/stage1_runner.c")
    echo "stage1 emit stage1 runner: /tmp/stage1_runner.c"
    return 0
