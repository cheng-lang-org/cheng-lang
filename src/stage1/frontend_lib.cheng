@importc("cheng_file_exists")
fn stage1_c_fileExists(path: cstring): int32
@importc("cheng_file_size")
fn stage1_c_fileSize(path: cstring): int64
type
    Stage1StrBridge =
        ptr: cstring
        len: int32
        store_id: int32
        flags: int32
@importc("driver_c_read_file_all_bridge_into")
fn stage1_c_readFileAllBridgeInto(path: cstring, out: var Stage1StrBridge)
@importc("cheng_strlen")
fn stage1_c_strlen(s: str): int32
@importc("driver_c_active_input_path")
fn stage1_c_activeInputPath(): cstring

var stage1_main_input_raw: cstring = nil
var stage1_main_input_raw_pending: bool = false

fn stage1_setMainInputRaw(pathRaw: cstring) =
    stage1_main_input_raw = pathRaw
    stage1_main_input_raw_pending = (pathRaw != nil)

fn stage1_clearMainInputRaw() =
    stage1_main_input_raw = nil
    stage1_main_input_raw_pending = false

fn stage1_bridgeStrToOwned(value: Stage1StrBridge): str =
    if value.ptr == nil || value.len <= 0:
        return ""
    return newStringCopy(value.ptr, value.len)

fn stage1_bridgeStrZero(value: var Stage1StrBridge) =
    value.ptr = nil
    value.len = 0
    value.store_id = 0
    value.flags = 0

fn stage1_readFileFast(path: str): str =
    if stage1_c_strlen(path) == 0:
        return ""
    var bridge: Stage1StrBridge
    stage1_bridgeStrZero(bridge)
    stage1_c_readFileAllBridgeInto(cstring(path), bridge)
    return stage1_bridgeStrToOwned(bridge)

fn stage1_readFileIntoRaw(pathRaw: cstring, out: var str): bool =
    if pathRaw == nil:
        out = ""
        return false
    var bridge: Stage1StrBridge
    stage1_bridgeStrZero(bridge)
    stage1_c_readFileAllBridgeInto(cstring(pathRaw), bridge)
    let fastText: str = stage1_bridgeStrToOwned(bridge)
    out = fastText
    if stage1_c_strlen(fastText) > 0:
        return true
    return stage1_c_fileExists(cstring(pathRaw)) != 0

fn stage1_pathLooksPrintable(path: str): bool =
    if stage1_c_strlen(path) == 0:
        return false
    for i in 0..<len(path):
        let c: char = path[i]
        if c == '/' || c == '.' || c == '_' || c == '-' || c == ':' || c == '\\':
            continue
        if c >= '0' && c <= '9':
            continue
        if c >= 'a' && c <= 'z':
            continue
        if c >= 'A' && c <= 'Z':
            continue
        return false
    return true

fn add(dst: var int32[], val: int32) =
    seqs.add(dst, val)

fn add(dst: int32[]*, val: int32) =
    seqs.add(dst, val)

fn add(dst: var str[], val: str) =
    seqs.add(dst, val)

fn add(dst: str[]*, val: str) =
    seqs.add(dst, val)

fn add(dst: var AstNodeId[], val: AstNodeId) =
    seqs.add(dst, val)

fn add(dst: AstNodeId[]*, val: AstNodeId) =
    seqs.add(dst, val)

fn add(dst: var Node[], val: Node) =
    seqs.add(dst, val)

fn add(dst: Node[]*, val: Node) =
    seqs.add(dst, val)

fn add(dst: var Token[], val: Token) =
    seqs.add(dst, val)

fn add(dst: Token[]*, val: Token) =
    seqs.add(dst, val)

fn add(dst: var Diagnostic[], val: Diagnostic) =
    seqs.add(dst, val)

fn add(dst: ptr, val: Diagnostic) =
    if dst == nil:
        return
    var seqVal: Diagnostic[] = load(dst)
    seqs.add(seqVal, val)
    store(dst, seqVal)

fn stage1TraceHas(trace: ptr, path: str): bool =
    if trace == nil:
        return false
    let traceVal: ImportTrace = load(trace)
    return importTraceHas(traceVal, path)

fn stage1TracePush(trace: ptr, path: str) =
    if trace == nil:
        return
    var traceVal: ImportTrace = load(trace)
    importTracePush(traceVal, path)
    store(trace, traceVal)

fn stage1TracePop(trace: ptr) =
    if trace == nil:
        return
    var traceVal: ImportTrace = load(trace)
    importTracePop(traceVal)
    store(trace, traceVal)

fn stage1VisitedHas(visited: ptr, path: str): bool =
    if visited == nil:
        return false
    let visitedVal: StrSetList = load(visited)
    return setHasNormalizedStr(visitedVal, path)

fn stage1VisitedAdd(visited: ptr, path: str) =
    if visited == nil:
        return
    var visitedVal: StrSetList = load(visited)
    setAddNormalizedStr(visitedVal, path)
    store(visited, visitedVal)

fn stage1CacheHasNodes(cache: ptr, path: str): bool =
    if cache == nil:
        return false
    let cacheVal: NodeCache = load(cache)
    return mapHasNodes(cacheVal, path)

fn stage1CacheGetNodes(cache: ptr, path: str): AstNodeId[] =
    var empty: AstNodeId[]
    if cache == nil:
        return empty
    let cacheVal: NodeCache = load(cache)
    return mapGetNodes(cacheVal, path)

fn stage1CacheSetNodes(cache: ptr, path: str, values: AstNodeId[]) =
    if cache == nil:
        return
    var cacheVal: NodeCache = load(cache)
    mapSetNodes(cacheVal, path, values)
    store(cache, cacheVal)

fn stage1DiagsHasError(diags: ptr): bool =
    if diags == nil:
        return false
    let diagVals: Diagnostic[] = load(diags)
    return hasError(diagVals)

fn stage1_c_getenv(name: cstring): str =
    return os.getEnvDefault(name, "")
fn stage1_getEnv(name: str): str =
    return stage1_c_getenv name

fn stage1SafeStr(s: str): str =
    return strNonEmpty(s) ? s : ""

fn lowerAscii(s: str): str =
    return strutils.toLowerAscii(stage1SafeStr(s))

fn stage1Concat2(left: str, right: str): str =
    let safeLeft: str = stage1SafeStr(left)
    let safeRight: str = stage1SafeStr(right)
    let nLeft: int32 = len(safeLeft)
    let nRight: int32 = len(safeRight)
    if nLeft <= 0:
        return safeRight
    if nRight <= 0:
        return safeLeft
    return safeLeft + safeRight

fn stage1JoinWithSlash(left: str, right: str): str =
    let safeLeft: str = stage1SafeStr(left)
    let safeRight: str = stage1SafeStr(right)
    let nLeft: int32 = len(safeLeft)
    let nRight: int32 = len(safeRight)
    if nLeft <= 0:
        return safeRight
    if nRight <= 0:
        return safeLeft
    return safeLeft + "/" + safeRight

fn stage1AppendChengExt(path: str): str =
    return endsWith(path, ".cheng") ? path : stage1Concat2(path, ".cheng")

fn stage1EqAsciiLowerKeyword(raw: str, lowerKeyword: str): bool =
    if len(raw) != len(lowerKeyword):
        return false
    for i in 0..<len(lowerKeyword):
        var ch: char = raw[i]
        if ch >= 'A' && ch <= 'Z':
            ch = chr(int32(ch) + 32)
        if ch != lowerKeyword[i]:
            return false
    return true

fn envIsTrue(name: str): bool =
    let raw: str = stage1_getEnv(name)
    let n: int32 = len raw
    if n == 0:
        return false
    let c0: char = raw[0]
    if c0 == '1':
        return n == 1
    if c0 == 't' || c0 == 'T':
        if n != 4:
            return false
        let c1: char = raw[1]
        if c1 != 'r' && c1 != 'R':
            return false
        let c2: char = raw[2]
        if c2 != 'u' && c2 != 'U':
            return false
        let c3: char = raw[3]
        if c3 != 'e' && c3 != 'E':
            return false
        return true
    if c0 == 'y' || c0 == 'Y':
        if n != 3:
            return false
        let c1: char = raw[1]
        if c1 != 'e' && c1 != 'E':
            return false
        let c2: char = raw[2]
        if c2 != 's' && c2 != 'S':
            return false
        return true
    return false

fn stage1_autoSystemEnabled(): bool =
    # Native-contract compile path is host-agnostic/nolibc and must not
    # auto-import std/system; enforce in frontend to avoid env-mismatch crashes.
    if envIsTrue("BACKEND_NATIVE_CONTRACT"):
        return false
    let raw: str = stage1_getEnv("STAGE1_AUTO_SYSTEM")
    if raw == "":
        return true
    if raw == "0" || stage1EqAsciiLowerKeyword(raw, "false") || stage1EqAsciiLowerKeyword(raw, "no"):
        return false
    if raw == "1" || stage1EqAsciiLowerKeyword(raw, "true") || stage1EqAsciiLowerKeyword(raw, "yes"):
        return true
    return true

fn stage1_parseModeNormalized(): str =
    var raw: str = stage1_getEnv("BACKEND_STAGE1_PARSE_MODE")
    if raw == "":
        raw = stage1_getEnv("STAGE1_PARSE_MODE")
    if stage1EqAsciiLowerKeyword(raw, "outline"):
        return "outline"
    if stage1EqAsciiLowerKeyword(raw, "full"):
        return "full"
    let trackRaw: str = stage1_getEnv("BACKEND_BUILD_TRACK")
    if stage1EqAsciiLowerKeyword(trackRaw, "release"):
        return "full"
    return "outline"

fn stage1_parseModuleByMode(tokens: Token[], path: str, diags: ptr): AstNodeId =
    let mode: str = stage1_parseModeNormalized()
    if mode == "outline":
        return parseModuleOutlineWithDiagnosticsId(tokens, path, diags)
    return parseModuleWithDiagnosticsId(tokens, path, diags)

fn stage1_materializeModuleBodiesForMode(tokens: Token[], path: str, rootId: AstNodeId, diags: ptr): int32 =
    if !astNodeIdValid(rootId):
        return 0
    let mode: str = stage1_parseModeNormalized()
    if mode != "outline":
        return 0
    return materializeModuleRoutineBodiesFromTokensId(tokens, path, rootId, diags)

var stage1TraceEnabledCached: int32 = -1
var stage1TraceImportsEnabledCached: int32 = -1
var stage1TraceFlushEnabledCached: int32 = -1
var stage1PhaseTraceEnabledCached: int32 = -1
var stage1PhaseStack: str[]
var stage1GuiRootCached: str
var stage1GuiRootCachedReady: bool
var stage1IdeRootCached: str
var stage1IdeRootCachedReady: bool
var stage1PkgRootsCached: str[]
var stage1PkgRootsCachedReady: bool
var stage1ImportRootDirCurrent: str
var stage1ImportPathPool: str[]
var stage1ImportPathPoolReady: bool
var stage1PluginEnableCached: int32 = -1
var stage1PluginPathsCachedReady: bool
var stage1PluginPathsCached: str[]
var stage1PluginMeteringCached: str
var stage1PluginMeteringCachedReady: bool

fn stage1TraceEnabled(): bool =
    if stage1TraceEnabledCached >= 0:
        return stage1TraceEnabledCached == 1
    stage1TraceEnabledCached = envIsTrue("STAGE1_TRACE") ? 1 : 0
    return stage1TraceEnabledCached == 1

fn stage1TraceImportsEnabled(): bool =
    if stage1TraceImportsEnabledCached >= 0:
        return stage1TraceImportsEnabledCached == 1
    stage1TraceImportsEnabledCached = envIsTrue("STAGE1_TRACE_IMPORTS") ? 1 : 0
    return stage1TraceImportsEnabledCached == 1

fn stage1TraceFlushEnabled(): bool =
    if stage1TraceFlushEnabledCached >= 0:
        return stage1TraceFlushEnabledCached == 1
    stage1TraceFlushEnabledCached = (stage1_getEnv("STAGE1_TRACE_FLUSH") == "1") ? 1 : 0
    return stage1TraceFlushEnabledCached == 1

fn stage1PhaseTraceEnabled(): bool =
    if stage1PhaseTraceEnabledCached >= 0:
        return stage1PhaseTraceEnabledCached == 1
    stage1PhaseTraceEnabledCached = (envIsTrue("BACKEND_DEBUG_STAGE1_PHASES") || (stage1_getEnv("BACKEND_DEBUG_STAGE1_PIPE") == "1")) ? 1 : 0
    return stage1PhaseTraceEnabledCached == 1

fn stage1PhaseWriteLine(text: str) =
    if !stage1PhaseTraceEnabled():
        return
    let fErr: os.File = os.get_stderr()
    os.writeLine(fErr, text)
    if stage1TraceFlushEnabled():
        c_fflush fErr

fn stage1Concat3(left: str, middle: str, right: str): str =
    let safeLeft: str = stage1SafeStr(left)
    let safeMiddle: str = stage1SafeStr(middle)
    let safeRight: str = stage1SafeStr(right)
    let nLeft: int32 = len(safeLeft)
    let nMiddle: int32 = len(safeMiddle)
    let nRight: int32 = len(safeRight)
    if nLeft <= 0:
        return stage1Concat2(safeMiddle, safeRight)
    if nMiddle <= 0:
        return stage1Concat2(safeLeft, safeRight)
    if nRight <= 0:
        return stage1Concat2(safeLeft, safeMiddle)
    return safeLeft + safeMiddle + safeRight

fn stage1PhaseWritePrefixItem(prefix: str, item: str) =
    if !stage1PhaseTraceEnabled():
        return
    let fErr: os.File = os.get_stderr()
    os.write(fErr, prefix)
    os.write(fErr, item)
    os.write(fErr, "\n")
    if stage1TraceFlushEnabled():
        c_fflush fErr

fn stage1PhaseWriteIndexItem(index: int32, item: str) =
    if !stage1PhaseTraceEnabled():
        return
    let fErr: os.File = os.get_stderr()
    os.write(fErr, "[stage1.phase] ")
    os.write(fErr, intToStr(index))
    os.write(fErr, ": ")
    os.write(fErr, item)
    os.write(fErr, "\n")
    if stage1TraceFlushEnabled():
        c_fflush fErr

fn stage1DebugPipeWriteConst(f: os.File, text: str) =
    if f == nil:
        return
    os.write(f, text)
    os.write(f, "\n")

fn stage1DebugPipeWritePrefixInt(f: os.File, prefix: str, value: int32) =
    if f == nil:
        return
    os.write(f, prefix)
    os.write(f, intToStr(value))
    os.write(f, "\n")

fn stage1PhasePush(name: str, detail: str = "") =
    if !stage1PhaseTraceEnabled():
        return
    var item: str = name
    if len(detail) > 0:
        item = stage1Concat3(name, ": ", detail)
    add(stage1PhaseStack, item)
    stage1PhaseWritePrefixItem("[stage1.phase+] ", item)

fn stage1PhasePop() =
    if !stage1PhaseTraceEnabled():
        return
    if stage1PhaseStack.len == 0:
        return
    let item: str = stage1PhaseStack[stage1PhaseStack.len - 1]
    stage1PhaseWritePrefixItem("[stage1.phase-] ", item)
    stage1PhaseStack.len = stage1PhaseStack.len - 1

fn stage1PhaseDump() =
    if !stage1PhaseTraceEnabled():
        return
    stage1PhaseWriteLine("[stage1.phase] dump.begin")
    for i in 0..<stage1PhaseStack.len:
        stage1PhaseWriteIndexItem(i, stage1PhaseStack[i])
    stage1PhaseWriteLine("[stage1.phase] dump.end")

fn stage1GuiRoot(): str =
    if stage1GuiRootCachedReady:
        return stage1GuiRootCached
    stage1GuiRootCached = stage1_getEnv("GUI_ROOT")
    stage1GuiRootCachedReady = true
    return stage1GuiRootCached

fn stage1IdeRoot(): str =
    if stage1IdeRootCachedReady:
        return stage1IdeRootCached
    stage1IdeRootCached = stage1_getEnv("IDE_ROOT")
    stage1IdeRootCachedReady = true
    return stage1IdeRootCached

fn stage1PkgRoots(): str[] =
    if stage1PkgRootsCachedReady:
        return stage1PkgRootsCached
    stage1PkgRootsCached = stage1_pkgRootsFromEnv()
    stage1PkgRootsCachedReady = true
    return stage1PkgRootsCached

fn stage1ImportPathPoolEnsure() =
    if stage1ImportPathPoolReady:
        return
    stage1ImportPathPool = []
    add(stage1ImportPathPool, "")
    stage1ImportPathPoolReady = true

fn stage1ImportPathPushSlot(): int32 =
    stage1ImportPathPoolEnsure()
    add(stage1ImportPathPool, "")
    return stage1ImportPathPool.len - 1

fn stage1ImportPathById(pathId: int32): str =
    stage1ImportPathPoolEnsure()
    if pathId <= 0 || pathId >= stage1ImportPathPool.len:
        return ""
    return stage1ImportPathPool[pathId]

fn stage1PluginEnabled(): bool =
    if stage1PluginEnableCached >= 0:
        return stage1PluginEnableCached == 1
    let raw: str = stage1_getEnv("PLUGIN_ENABLE")
    if raw == "" || raw == "1" || stage1EqAsciiLowerKeyword(raw, "true") || stage1EqAsciiLowerKeyword(raw, "yes"):
        stage1PluginEnableCached = 1
        return true
    if raw == "0" || stage1EqAsciiLowerKeyword(raw, "false") || stage1EqAsciiLowerKeyword(raw, "no"):
        stage1PluginEnableCached = 0
        return false
    stage1PluginEnableCached = 1
    return true

fn stage1PluginPaths(): str[] =
    if stage1PluginPathsCachedReady:
        return stage1PluginPathsCached
    var out: str[]
    let legacy: str = stage1_getEnv "PLUGIN_PATH"
    if len(legacy) > 0:
        add(out, stripSpaces(legacy))
    let raw: str = stage1_getEnv "PLUGIN_PATHS"
    if len(raw) > 0:
        var hasCommaOrSemi: bool = false
        for ki in 0..<len(raw):
            let ck: char = raw[ki]
            if ck == ',' || ck == ';':
                hasCommaOrSemi = true
                break
        let useColon: bool = !hasCommaOrSemi
        var start: int32 = 0
        for i in 0..len(raw):
            let c: char = (i < len(raw)) ? raw[i] : char(0)
            if i == len(raw) || c == ',' || c == ';' || (useColon && c == ':'):
                if i > start:
                    let part: str = sliceRange(raw, start, i - 1)
                    let trimmed: str = stripSpaces(part)
                    if len(trimmed) > 0:
                        add(out, trimmed)
                start = i + 1
    stage1PluginPathsCached = out
    stage1PluginPathsCachedReady = true
    return out

fn stage1PluginActiveMetering(): str =
    if stage1PluginMeteringCachedReady:
        return stage1PluginMeteringCached
    let raw: str = stage1_getEnv "METERING_PLUGIN"
    let trimmed: str = stripSpaces(raw)
    stage1PluginMeteringCached = trimmed
    stage1PluginMeteringCachedReady = true
    return trimmed

fn stage1ResolvePluginImportCandidate(candidate: str): str =
    if len(candidate) == 0:
        return ""
    if stage1_fileExists(candidate):
        return normalizeImportPath candidate
    let withExt: str = stage1AppendChengExt(candidate)
    if stage1_fileExists(withExt):
        return normalizeImportPath withExt
    return ""

fn stage1ResolvePluginImportPath(path: str): str =
    if !stage1PluginEnabled():
        return ""
    if len(path) == 0:
        return ""
    if !hasPrefix(path, "cheng/web/") && !hasPrefix(path, "cheng/decentralized/"):
        return ""
    let pluginPaths: str[] = stage1PluginPaths()
    if pluginPaths.len == 0:
        return ""
    let relFromPkg: str = importPathDropChengPrefix(path)
    var pluginRel: str = relFromPkg
    if relFromPkg == "":
        pluginRel = path
    for i in 0..<pluginPaths.len:
        let root: str = pluginPaths[i]
        if len(root) == 0:
            continue
        let candidate0: str = joinPath(root, path)
        let hit0: str = stage1ResolvePluginImportCandidate(candidate0)
        if len(hit0) > 0:
            return hit0
        let candidate1: str = joinPath(root, "src", path)
        let hit1: str = stage1ResolvePluginImportCandidate(candidate1)
        if len(hit1) > 0:
            return hit1
        let candidate2: str = joinPath(root, "cheng", path)
        let hit2: str = stage1ResolvePluginImportCandidate(candidate2)
        if len(hit2) > 0:
            return hit2
        let candidate3: str = joinPath(root, pluginRel)
        let hit3: str = stage1ResolvePluginImportCandidate(candidate3)
        if len(hit3) > 0:
            return hit3
        let candidate4: str = joinPath(root, "src", pluginRel)
        let hit4: str = stage1ResolvePluginImportCandidate(candidate4)
        if len(hit4) > 0:
            return hit4
        let candidate5: str = joinPath(root, "cheng", pluginRel)
        let hit5: str = stage1ResolvePluginImportCandidate(candidate5)
        if len(hit5) > 0:
            return hit5
    return ""

fn stage1ApplyAstPluginHooksId(path: str, rootId: AstNodeId): AstNodeId =
    let _pathUnused: str = path
    if !astNodeIdValid(rootId):
        return astInvalidNodeId()
    if !stage1PluginEnabled():
        return rootId
    return rootId

fn stage1Trace(msg: str) =
    if stage1TraceEnabled():
        let fOut: os.File = get_stdout()
        os.write(fOut, "[stage1] ")
        if len(msg) > 0:
            os.write(fOut, msg)
        os.writeLine(fOut, "")
        if stage1TraceFlushEnabled():
            c_fflush fOut

fn memMode(): str =
    let mm: str = stage1_getEnv("MM")
    if len mm > 0:
        if mm == "0" || stage1EqAsciiLowerKeyword(mm, "off") || stage1EqAsciiLowerKeyword(mm, "none"):
            return "off"
        return "orc"
    return "orc"

fn ownershipDiagnosticsEnabled(): bool =
    let raw: str = stage1_getEnv("OWNERSHIP_DIAGS")
    if raw == "1" || stage1EqAsciiLowerKeyword(raw, "true") || stage1EqAsciiLowerKeyword(raw, "yes"):
        return true
    if raw == "0" || stage1EqAsciiLowerKeyword(raw, "false") || stage1EqAsciiLowerKeyword(raw, "no"):
        return false
    let mm: str = memMode()
    return ! ((mm == "off") || (mm == "none") || (mm == "0"))

fn ownershipHintsEnabled(): bool =
    let raw: str = stage1_getEnv("OWNERSHIP_HINTS")
    if raw == "1" || stage1EqAsciiLowerKeyword(raw, "true") || stage1EqAsciiLowerKeyword(raw, "yes"):
        return true
    if raw == "0" || stage1EqAsciiLowerKeyword(raw, "false") || stage1EqAsciiLowerKeyword(raw, "no"):
        return false
    return true

fn arcEnabled(): bool =
    let mm: str = memMode()
    if (mm == "off") || (mm == "none") || (mm == "0"):
        return false
    return true

fn orcStrictEnabled(): bool =
    let raw: str = stage1_getEnv("MM_STRICT")
    if raw == "1" || stage1EqAsciiLowerKeyword(raw, "true") || stage1EqAsciiLowerKeyword(raw, "yes"):
        return true
    if raw == "0" || stage1EqAsciiLowerKeyword(raw, "false") || stage1EqAsciiLowerKeyword(raw, "no"):
        return false
    let mm: str = memMode()
    return (mm == "orc")

var arcEnabledFlag: bool = true
var orcEnabledFlag: bool = true
var orcStrictFlag: bool

fn setArcEnabled(enabled: bool) =
    arcEnabledFlag = enabled

fn setOrcEnabled(enabled: bool) =
    orcEnabledFlag = enabled

fn setOrcStrict(enabled: bool) =
    orcStrictFlag = enabled

let cacheHeader: str = "CHENGTOK17"
let cacheSpecVersion: str = "2026-03-07-tokenid-strpool"

fn cacheCompilerVersion(): str =
    let v: str = stage1_getEnv "COMPILER_VERSION"
    if len v > 0:
        return v
    let v2: str = stage1_getEnv "STAGE1_VERSION"
    if len v2 > 0:
        return v2
    let v3: str = stage1_getEnv "STAGE1_HASH"
    if len v3 > 0:
        return v3
    let v4: str = stage1_getEnv "VERSION"
    if len v4 > 0:
        return v4
    return "dev"

fn cacheTargetPlatform(): str =
    let t: str = stage1_getEnv "TARGET"
    if len t > 0:
        return t
    let t2: str = stage1_getEnv "TARGET"
    if len t2 > 0:
        return t2
    let t3: str = stage1_getEnv "HOSTTYPE"
    if len t3 > 0:
        return t3
    return "unknown"

fn cacheMetaLine(): str =
    let mm: str = memMode()
    var strictVal: str = "0"
    if orcStrictEnabled():
        strictVal = "1"
    return "meta=compiler=" + cacheCompilerVersion() +
           ";mm=" + mm +
           ";mm_strict=" + strictVal +
           ";target=" + cacheTargetPlatform() +
           ";spec=" + cacheSpecVersion

fn cacheEnabled(): bool =
    let tokenCache: str = stage1_getEnv("STAGE1_TOKEN_CACHE")
    if tokenCache == "1" || stage1EqAsciiLowerKeyword(tokenCache, "true") || stage1EqAsciiLowerKeyword(tokenCache, "yes"):
        return !(stage1_getEnv "CACHE" == "0")
    return false

fn cacheDir(): str =
    let env: str = stage1_getEnv "CACHE_DIR"
    if len env > 0:
        return env
    return joinPath(getCurrentDir(), ".cheng-cache/stage1")

fn stage1SplitDir(path: str): str =
    let pathLen: int32 = len path
    if pathLen == 0:
        return ""
    var lastSep: int32 = -1
    for i in 0..<pathLen:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    if lastSep < 0:
        return ""
    if lastSep == 0:
        return sliceRange(path, 0, 0)
    return sliceRange(path, 0, lastSep - 1)

fn stage1SplitName(path: str): str =
    let pathLen: int32 = len path
    if pathLen == 0:
        return ""
    var lastSep: int32 = -1
    for i in 0..<pathLen:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    let nameStart: int32 = lastSep + 1
    if nameStart >= pathLen:
        return ""
    var lastDot: int32 = -1
    let __for_start_i = pathLen - 1
    for __for_rev_i in 0..(__for_start_i - (nameStart)):
        let i = __for_start_i - __for_rev_i
        let ch: char = path[i]
        if ch == '.':
            lastDot = i
            break
    if lastDot > lastSep && lastDot >= 0:
        if lastDot - 1 < nameStart:
            return ""
        return sliceRange(path, nameStart, lastDot - 1)
    return sliceRange(path, nameStart, pathLen - 1)

fn stage1SplitExt(path: str): str =
    let pathLen: int32 = len path
    if pathLen == 0:
        return ""
    var lastSep: int32 = -1
    for i in 0..<pathLen:
        let ch: char = path[i]
        if ch == '/' || ch == '\\':
            lastSep = i
    var lastDot: int32 = -1
    let __for_start_i = pathLen - 1
    for __for_rev_i in 0..(__for_start_i - ((lastSep) + (1))):
        let i = __for_start_i - __for_rev_i
        let ch: char = path[i]
        if ch == '.':
            lastDot = i
            break
    if lastDot > lastSep && lastDot >= 0:
        return sliceRange(path, lastDot, pathLen - 1)
    return ""

fn ensureDir(path: str) =
    if len path == 0:
        return
    if bos_dirExists path:
        return
    let parentDir: str = stage1SplitDir path
    if len parentDir > 0 && ! bos_dirExists parentDir:
        makeDir parentDir
    makeDir path

fn startsWith(s: str, prefix: str): bool =
    let n: int32 = len s
    let m: int32 = len prefix
    if m == 0:
        return true
    if n < m:
        return false
    for i in 0..<m:
        if s[i] != prefix[i]:
            return false
    return true

fn hash64(s: str): uint64 =
    var h: uint64 =(uint64(1469598103) * uint64(1000000000)) + uint64(934665603)
    let n: int32 = len s
    for i in 0..<n:
        let c: char = s[i]
        h = h ^ uint64(c)
        h = h * ((uint64(1099511628) * uint64(1000)) + uint64(211))
    return h

fn hexDigit(v: int32): char =
    if v < 10:
        let code: int32 = int32('0') + v
        return chr code
    let code: int32 = int32('a') + (v - 10)
    return chr code

fn u64ToHex(v: uint64): str =
    var outText: str = ""
    for i in 0..<16:
        let shift: int32 =(15 - i) * 4
        let masked: uint64 =(v >> uint64(shift)) & uint64(15)
        let digit: int32 = int32(masked)
        let c: char = hexDigit digit
        outText = outText + charToStr(c)
    return outText

fn moduleTag(path: str): str =
    var base: str = stage1SplitName path
    if len base == 0:
        base = "module"
    let key: str = u64ToHex(hash64(path))
    let tag: str = base + "-" + key
    releaseString key
    return tag

fn stage1_int64ToStr(v: int64): str =
    if v == 0:
        return "0"
    var n: int64 = v
    var neg: bool = false
    if n < 0:
        neg = true
        n = -n
    var out: str = ""
    while n > 0:
        let digitVal: int64 = n % 10
        let digit: int32 = int32(digitVal)
        let code: int32 = int32('0') + digit
        let digitChar: char = chr code
        out = charToStr digitChar + out
        n = n / 10
    if neg:
        out = "-" + out
    return out

fn parseInt64(s: str): int64 =
    let n: int32 = len s
    if n == 0:
        return 0
    var i: int32 = 0
    var neg: bool = false
    if s[0] == '-':
        neg = true
        i = 1
    var val: int64 = 0
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        let c: char = s[i]
        if c < '0' || c > '9':
            break
        val = val * 10 + int64(c) - int64('0')
        i = i + 1
    if neg:
        return -val
    return val

fn tokenTraceEnabled(path: str): bool =
    if ! envIsTrue "STAGE1_TRACE_TOKENS":
        return false
    let only: str = stage1_getEnv "STAGE1_TRACE_TOKENS_FILE"
    if len only == 0:
        return true
    return only == path

fn tokenTraceMax(): int32 =
    let raw: str = stage1_getEnv "STAGE1_TRACE_TOKENS_MAX"
    if len raw == 0:
        return 120
    let v: int64 = parseInt64 raw
    if v <= 0:
        return 120
    return int32(v)

fn dumpTokens(path: str, tokens: Token[]) =
    if ! tokenTraceEnabled path:
        return
    let maxCount: int32 = tokenTraceMax()
    let header: str = "TOKENS " + path
    echo header
    releaseString header
    for i in 0..<tokens.len:
        if !(i < maxCount):
            break
        let t: Token = tokens[i]
        let lineStr: str = stage1_int64ToStr int64(t.line)
        let colStr: str = stage1_int64ToStr int64(t.col)
        let kindStr: str = kindName t.kind
        let lexStr: str = escapeCacheField tokenLexeme(t)
        let msg0: str = lineStr + ":" + colStr
        let msg1: str = msg0 + " " + kindStr
        let msg2: str = msg1 + " " + lexStr
        echo msg2
        releaseString lineStr
        releaseString colStr
        releaseString lexStr
        releaseString msg0
        releaseString msg1
        releaseString msg2
    if tokens.len > maxCount:
        let totalStr: str = stage1_int64ToStr int64(tokens.len)
        let tail: str = "... total=" + totalStr
        echo tail
        releaseString totalStr
        releaseString tail

fn escapeCacheField(s: str): str =
    let n: int32 = len s
    if n == 0:
        return ""
    var outText: str = ""
    for i in 0..<n:
        let c: char = s[i]
        if c == '\\':
            outText = outText + "\\\\"
        elif c == '\n':
            outText = outText + "\\n"
        elif c == '\r':
            outText = outText + "\\r"
        elif c == '\t':
            outText = outText + "\\t"
        else:
            outText = outText + charToStr(c)
    return outText

fn unescapeCacheField(s: str): str =
    let n: int32 = len s
    if n == 0:
        return ""
    var outText: str = ""
    var i: int32 = 0
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        let c: char = s[i]
        if c == '\\' && i + 1 < n:
            let n2: char = s[i + 1]
            if n2 == 'n':
                outText = outText + "\n"
                i = i + 2
                continue
            elif n2 == 'r':
                outText = outText + "\r"
                i = i + 2
                continue
            elif n2 == 't':
                outText = outText + "\t"
                i = i + 2
                continue
            elif n2 == '\\':
                outText = outText + "\\"
                i = i + 2
                continue
        outText = outText + charToStr(c)
        i = i + 1
    return outText

fn sliceRangePlainKnownLen(s: str, n: int32, start: int32, stop: int32): str =
    var a: int32 = start
    var b: int32 = stop
    if a < 0:
        a = 0
    if b >= n:
        b = n - 1
    if b < a:
        return ""
    let count: int32 = b - a + 1
    return strings.sliceBytes(s, a, count)

fn sliceRangePlain(s: str, start: int32, stop: int32): str =
    let n: int32 = len s
    return sliceRangePlainKnownLen(s, n, start, stop)

fn trimTrailingCRPlain(line: str): str =
    let n: int32 = len line
    if n <= 0:
        return line
    if line[n - 1] == '\r':
        let trimmed: str = sliceRangePlain(line, 0, n - 2)
        releaseString line
        return trimmed
    return line

fn splitTabs(line: str): str[] =
    var parts: str[8]
    let n: int32 = len line
    var start: int32 = 0
    for i in 0..n:
        if i == n || line[i] == '\t':
            if i >= start:
                let seg: str = sliceRangePlain(line, start, i - 1)
                add(parts, seg)
            start = i + 1
    return parts

fn splitLinesPlain(text: str): str[] =
    var lines: str[] = []
    let n: int32 = len text
    if n == 0:
        return lines
    var start: int32 = 0
    for i in 0..n:
        if i == n || text[i] == '\n':
            let lineRaw: str = sliceRangePlain(text, start, i - 1)
            let lineTrimmed: str = trimTrailingCRPlain(lineRaw)
            add(lines, lineTrimmed)
            start = i + 1
    return lines

fn freeOwnedStrSeq(items: var str[]) =
    for i in 0..<items.len:
        releaseString items[i]
    if items.buffer != nil:
        memRelease(items.buffer)
    items.buffer = nil
    items.len = 0
    items.cap = 0

fn cacheFieldValue(line: str, prefix: str): str =
    if !startsWith(line, prefix):
        return ""
    return sliceRangePlain(line, len(prefix), len(line) - 1)

fn cachePath(path: str): str =
    let dir: str = cacheDir()
    let key: str = u64ToHex(hash64(path))
    let name: str = key + ".tok"
    let out: str = joinPath(dir, name)
    releaseString key
    releaseString name
    return out

fn loadTokenCacheInto(path: str, size: int64, mtime: int64, out: Token[]*): bool =
    if !cacheEnabled() || out == nil:
        return false
    let cpath: str = cachePath(path)
    defer:
        releaseString cpath
    if !stage1_fileExists(cpath):
        return false
    var content: str = ""
    let readOk: bool = stage1_readFileInto(cpath, content)
    defer:
        releaseString content
    if !readOk || len(content) == 0:
        return false
    var lines: str[] = splitLinesPlain(content)
    defer:
        freeOwnedStrSeq(lines)
    if lines.len < 5:
        return false
    if !(lines[0] == cacheHeader):
        return false
    let metaExpected: str = cacheMetaLine()
    defer:
        releaseString metaExpected
    if !(lines[1] == metaExpected):
        return false
    let sizeRaw: str = cacheFieldValue(lines[2], "size=")
    let mtimeRaw: str = cacheFieldValue(lines[3], "mtime=")
    let countRaw: str = cacheFieldValue(lines[4], "count=")
    defer:
        releaseString sizeRaw
        releaseString mtimeRaw
        releaseString countRaw
    if parseInt64(sizeRaw) != size:
        return false
    if parseInt64(mtimeRaw) != mtime:
        return false
    let count: int32 = int32(parseInt64(countRaw))
    if count < 0 || lines.len < count + 5:
        return false
    tokenTextPoolEnsure()
    var tokens: Token[] = []
    if count > 0:
        reserve(tokens, count)
    for i in 0..<count:
        let line: str = lines[5 + i]
        var parts: str[] = splitTabs(line)
        if parts.len < 5:
            freeSeq_Token(tokens)
            for pi in 0..<parts.len:
                releaseString parts[pi]
            return false
        var tok: Token
        tokenZero(tok)
        tok.kind = TokenKind(int32(parseInt64(parts[0])))
        tok.line = int32(parseInt64(parts[1]))
        tok.col = int32(parseInt64(parts[2]))
        tok.strPrefix = chr(int32(parseInt64(parts[3])))
        let lexemeEsc: str = parts[4]
        let lexeme: str = unescapeCacheField(lexemeEsc)
        tokenSetLexeme(tok, lexeme)
        releaseString lexeme
        add(tokens, tok)
        for pi in 0..<parts.len:
            releaseString parts[pi]
    *out = tokens
    return true

fn writeInt64(f: File, v: int64) =
    if v == 0:
        write(f, "0")
        return
    let s: str = stage1_int64ToStr v
    write(f, s)
    releaseString s

fn writeTokenCache(path: str, size: int64, mtime: int64, tokens: Token[]) =
    if ! cacheEnabled():
        return
    let dir: str = cacheDir()
    ensureDir dir
    let cpath: str = cachePath path
    defer:
        releaseString cpath
    let f: File = open(cpath, fmWrite)
    if f == nil:
        return
    write(f, cacheHeader)
    write(f, "\n")
    let meta: str = cacheMetaLine()
    write(f, meta)
    releaseString meta
    write(f, "\n")
    write(f, "size=")
    writeInt64(f, size)
    write(f, "\n")
    write(f, "mtime=")
    writeInt64(f, mtime)
    write(f, "\n")
    write(f, "count=")
    writeInt64(f, int64(tokens.len))
    write(f, "\n")
    for i in 0..<tokens.len:
        let t: Token = tokens[i]
        writeInt64(f, int64(t.kind))
        write(f, "\t")
        writeInt64(f, int64(t.line))
        write(f, "\t")
        writeInt64(f, int64(t.col))
        write(f, "\t")
        writeInt64(f, int64(t.strPrefix))
        write(f, "\t")
        let esc: str = escapeCacheField tokenLexeme(t)
        write(f, esc)
        releaseString esc
        write(f, "\n")
    c_fclose f

fn stage1_fileExists(path: str): bool =
    let n: int32 = stage1_c_strlen(path)
    if n == 0:
        return false
    let stablePath: str = path
    let exists: bool = stage1_c_fileExists(cstring(stablePath)) != 0
    if exists:
        return true
    if !stage1_pathLooksPrintable(stablePath):
        let activeRaw: cstring = stage1_c_activeInputPath()
        if activeRaw != nil:
            return stage1_c_fileExists(activeRaw) != 0
    if stage1_main_input_raw_pending && stage1_main_input_raw != nil:
        return stage1_c_fileExists(cstring(stage1_main_input_raw)) != 0
    return false

fn stage1_readFileInto(path: str, out: var str): bool =
    let dbgRead: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    let dbgFile: os.File = dbgRead ? os.get_stderr() : nil
    let pathLen: int32 = stage1_c_strlen(path)
    if pathLen == 0:
        if dbgRead:
            os.writeLine(dbgFile, "[frontend] read empty_path")
        out = ""
        return false
    if dbgRead:
        os.writeLine(dbgFile, "[frontend] read path_nonempty")
    let stablePath: str = path
    if dbgRead:
        os.write(dbgFile, "[frontend] read path=")
        os.writeLine(dbgFile, stablePath)
        os.writeLine(dbgFile, stage1_c_fileExists(cstring(stablePath)) != 0 ? "[frontend] read exists_pre_yes" : "[frontend] read exists_pre_no")
    let fastText: str = stage1_readFileFast(stablePath)
    if stage1_c_strlen(fastText) > 0:
        if dbgRead:
            os.writeLine(dbgFile, "[frontend] read fast_nonempty")
        out = fastText
        return true
    if dbgRead:
        os.writeLine(dbgFile, "[frontend] read fast_empty")
    let size64: int64 = stage1_c_fileSize(cstring(stablePath))
    if size64 > 0 && size64 <= int64(2147483647):
        if dbgRead:
            os.writeLine(dbgFile, "[frontend] read size_positive")
        var sizedText: str = ""
        let _sizedOk: bool = os.readFileSizedInto(stablePath, int32(size64), sizedText)
        if len(sizedText) > 0:
            if dbgRead:
                os.writeLine(dbgFile, "[frontend] read sized_nonempty")
            out = sizedText
            return true
        if dbgRead:
            os.writeLine(dbgFile, "[frontend] read sized_empty")
    elif dbgRead:
        os.writeLine(dbgFile, "[frontend] read size_nonpositive")
    var fallbackText: str = ""
    let _fallbackOk: bool = os.readFileInto(stablePath, fallbackText)
    out = fallbackText
    if len(fallbackText) > 0:
        if dbgRead:
            os.writeLine(dbgFile, "[frontend] read fallback_nonempty")
        return true
    if dbgRead:
        os.writeLine(dbgFile, stage1_c_fileExists(cstring(stablePath)) != 0 ? "[frontend] read fallback_empty_exists_yes" : "[frontend] read fallback_empty_exists_no")
    if !stage1_pathLooksPrintable(stablePath):
        let activeRaw: cstring = stage1_c_activeInputPath()
        let activeOk: bool = stage1_readFileIntoRaw(activeRaw, out)
        if activeOk:
            if dbgRead:
                os.writeLine(dbgFile, "[frontend] read active_input_raw_fallback")
            return true
    if stage1_main_input_raw_pending && stage1_main_input_raw != nil:
        let rawOk: bool = stage1_readFileIntoRaw(stage1_main_input_raw, out)
        if rawOk:
            stage1_main_input_raw_pending = false
            if dbgRead:
                os.writeLine(dbgFile, "[frontend] read raw_main_input_fallback")
            return true
    return stage1_c_fileExists(cstring(stablePath)) != 0

fn stage1_readFile(path: str): str =
    var out: str = ""
    let _ok: bool = stage1_readFileInto(path, out)
    return out

fn stage1_writeFile(path: str, content: str) =
    let f: File = open(path, fmWrite)
    if f == nil:
        return
    write(f, content)
    c_fclose f

fn releaseString(s: str) =
    if s[0] == char(0):
        return
    stage1_memRelease(s)

fn endsWith(s: str, suffix: str): bool =
    let n: int32 = len s
    let m: int32 = len suffix
    if m == 0:
        return true
    if n < m:
        return false
    for i in 0..<m:
        if s[n - m + i] != suffix[i]:
            return false
    return true

fn isPathSep(ch: char): bool =
    return ch == '/' || ch == '\\'

fn normalizePath(path: str): str =
    if len(path) == 0:
        return ""
    return absolutePath(path)
    let total: int32 = len path
    var prefix: str = ""
    var start: int32 = 0
    var absolute: bool = false
    if total >= 2 && path[1] == ':':
        prefix = sliceRangePlain(path, 0, 1)
        absolute = true
        start = 2
        if start < total && isPathSep path[start]:
            start = start + 1
    elif total > 0 && isPathSep path[0]:
        prefix = "/"
        absolute = true
        start = 1
    var parts: str[8]
    var segStart: int32 = start
    for i in start..total:
        if i == total:
            if i > segStart:
                let seg: str = sliceRangePlain(path, segStart, i - 1)
                if (seg == "."):
                    releaseString seg
                elif (seg == ".."):
                    if parts.len > 0:
                        let last: str = parts[parts.len - 1]
                        releaseString last
                        parts.len = parts.len - 1
                        releaseString seg
                    elif ! absolute:
                        add(parts, seg)
                    else:
                        releaseString seg
                else:
                    add(parts, seg)
            segStart = i + 1
        elif isPathSep path[i]:
            if i > segStart:
                let seg: str = sliceRangePlain(path, segStart, i - 1)
                if (seg == "."):
                    releaseString seg
                elif (seg == ".."):
                    if parts.len > 0:
                        let last: str = parts[parts.len - 1]
                        releaseString last
                        parts.len = parts.len - 1
                        releaseString seg
                    elif ! absolute:
                        add(parts, seg)
                    else:
                        releaseString seg
                else:
                    add(parts, seg)
            segStart = i + 1
    var out: str = ""
    if len prefix > 0:
        out = prefix
    for j in 0..<parts.len:
        let seg: str = parts[j]
        if len out > 0 && out[len out - 1] != '/':
            out = stage1JoinWithSlash(out, seg)
        else:
            out = stage1Concat2(out, seg)
        releaseString seg
    freeSeq[str](parts)
    if len out == 0 && len prefix > 0:
        return prefix
    return out

fn trimTrailingSlash(path: str): str =
    if len(path) == 0:
        return ""
    var end: int32 = len path
    if end > 1:
        for __for_guard_end in 0..<(end - 1):
            if !(end > 1 && path[end - 1] == '/'):
                break
            end = end - 1
    if end == len path:
        return path
    return sliceRangePlain(path, 0, end - 1)

fn pathWithinRoot(root: str, path: str): bool =
    if len(root) == 0:
        return false
    if len(path) == 0:
        return false
    let rootAbs0: str = normalizePath(absolutePath(root))
    let pathAbs: str = normalizePath(absolutePath(path))
    let rootAbs: str = trimTrailingSlash rootAbs0
    if len rootAbs == 0 || len pathAbs == 0:
        return false
    if ! startsWith(pathAbs, rootAbs):
        return false
    if len pathAbs == len rootAbs:
        return true
    return pathAbs[len rootAbs] == '/'

fn normalizeImportPathChecked(path: str, root: str): str =
    let norm: str = normalizeImportPath path
    if len norm == 0:
        return ""
    if len root == 0:
        return norm
    if pathWithinRoot(root, norm):
        return norm
    let guiRoot: str = stage1GuiRoot()
    if len guiRoot > 0 && pathWithinRoot(guiRoot, norm):
        return norm
    let ideRoot: str = stage1IdeRoot()
    if len ideRoot > 0 && pathWithinRoot(ideRoot, norm):
        return norm
    let pkgRoots: str[] = stage1PkgRoots()
    for i in 0..<pkgRoots.len:
        let pkgRoot: str = pkgRoots[i]
        if len pkgRoot > 0 && pathWithinRoot(pkgRoot, norm):
            return norm
    return ""

fn importNodePathId(nId: AstNodeId): str =
    if !astNodeIdValid(nId):
        return ""
    let kind: NodeKind = astNodeKind(nId)
    case kind
    of nkImportAs:
        if astKidCount(nId) > 0:
            return importNodePathId(astKidAt(nId, 0))
        return ""
    of nkIdent, nkSymbol:
        let rawIdent: str = astNodeIdent(nId)
        if len(rawIdent) == 0:
            let idx: int32 = astNodeIndex(nId)
            let identId: int32 = astNodeIdentId(nId)
            let storedIdent: str = tokenTextById(identId)
            echo("[importdbg] ident.empty node=" + intToStr(nId) +
                 " idx=" + intToStr(idx) +
                 " raw='" + rawIdent +
                 "' rawlen=" + intToStr(len(rawIdent)) +
                 " identId=" + intToStr(identId) +
                 " store='" + storedIdent +
                 "' storelen=" + intToStr(len(storedIdent)) +
                 " str='" + astNodeStrVal(nId) +
                 "' kids=" + intToStr(astKidCount(nId)))
        if len(rawIdent) > 0:
            return rawIdent
        return astNodeStrVal(nId)
    of nkStrLit:
        return astNodeStrVal(nId)
    else:
        return ""

fn collectImportNodesId(rootId: AstNodeId, acc: AstNodeId[]*) =
    if !astNodeIdValid(rootId) || acc == nil:
        return
    let kind: NodeKind = astNodeKind(rootId)
    if kind != nkModule && kind != nkStmtList:
        return
    for i in 0..<astKidCount(rootId):
        let nId: AstNodeId = astKidAt(rootId, i)
        let nKind: NodeKind = astNodeKind(nId)
        if nKind == nkImportStmt || nKind == nkImportGroup:
            add(acc, nId)

fn collectImportPathsId(nId: AstNodeId, out: str[]*) =
    if !astNodeIdValid(nId) || out == nil:
        return
    let dbgImports: bool = os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1"
    let kind: NodeKind = astNodeKind(nId)
    if kind == nkImportGroup:
        if astKidCount(nId) <= 0:
            return
        let base: str = importNodePathId(astKidAt(nId, 0))
        if dbgImports:
            let baseId: AstNodeId = astKidAt(nId, 0)
            echo("[importdbg] group.base kind=" + intToStr(int32(astNodeKind(baseId))) + " ident='" + astNodeIdent(baseId) + "' str='" + astNodeStrVal(baseId) + "' path='" + base + "'")
        for i in 1..<astKidCount(nId):
            let entry: str = importNodePathId(astKidAt(nId, i))
            if dbgImports:
                let entryId: AstNodeId = astKidAt(nId, i)
                echo("[importdbg] group.entry[" + intToStr(i) + "] kind=" + intToStr(int32(astNodeKind(entryId))) + " ident='" + astNodeIdent(entryId) + "' str='" + astNodeStrVal(entryId) + "' path='" + entry + "'")
            if len entry > 0:
                if len base > 0:
                    let combined: str = stage1JoinWithSlash(base, entry)
                    if dbgImports:
                        echo("[importdbg] group.combined='" + combined + "'")
                    trackLexStringStr(combined)
                    add(out, combined)
                else:
                    trackLexStringStr(entry)
                    add(out, entry)
        return
    if kind == nkImportStmt:
        for j in 0..<astKidCount(nId):
            let itemId: AstNodeId = astKidAt(nId, j)
            if astNodeKind(itemId) == nkImportGroup:
                collectImportPathsId(itemId, out)
            else:
                let path: str = importNodePathId(itemId)
                if dbgImports:
                    echo("[importdbg] stmt.item[" + intToStr(j) + "] kind=" + intToStr(int32(astNodeKind(itemId))) + " ident='" + astNodeIdent(itemId) + "' str='" + astNodeStrVal(itemId) + "' path='" + path + "'")
                if len path > 0:
                    trackLexStringStr(path)
                    add(out, path)
        return
    if kind == nkImportAs:
        if astKidCount(nId) > 0:
            let path: str = importNodePathId(astKidAt(nId, 0))
            if dbgImports:
                echo("[importdbg] as.path='" + path + "'")
            if len path > 0:
                trackLexStringStr(path)
                add(out, path)
        return
    let path2: str = importNodePathId(nId)
    if dbgImports:
        echo("[importdbg] single kind=" + intToStr(int32(kind)) + " path='" + path2 + "'")
    if len path2 > 0:
        trackLexStringStr(path2)
        add(out, path2)

fn stage1DebugImportNodeState(rootId: AstNodeId, tag: str) =
    if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") != "1":
        return
    var importNodes: AstNodeId[]
    reserve(importNodes, 32)
    collectImportNodesId(rootId, &importNodes)
    echo("[importdbg] " + tag + ".count=" + intToStr(importNodes.len))
    for ii in 0..<importNodes.len:
        let impId: AstNodeId = importNodes[ii]
        echo("[importdbg] " + tag + ".node[" + intToStr(ii) + "] kind=" + intToStr(int32(astNodeKind(impId))) + " kids=" + intToStr(astKidCount(impId)))
        for jj in 0..<astKidCount(impId):
            let kidId: AstNodeId = astKidAt(impId, jj)
            echo("[importdbg] " + tag + ".kid[" + intToStr(ii) + "," + intToStr(jj) + "] kind=" + intToStr(int32(astNodeKind(kidId))) + " ident='" + astNodeIdent(kidId) + "' str='" + astNodeStrVal(kidId) + "'")

fn importAliasNameId(nId: AstNodeId): str =
    if !astNodeIdValid(nId):
        return ""
    let kind: NodeKind = astNodeKind(nId)
    case kind
    of nkImportAs:
        if astKidCount(nId) > 1:
            return astPlainName(astKidAt(nId, 1))
        if astKidCount(nId) > 0:
            return semImportModuleName(astPlainName(astKidAt(nId, 0)))
        return ""
    of nkIdent, nkSymbol:
        let rawIdent: str = astNodeIdent(nId)
        if len(rawIdent) > 0:
            return semImportModuleName(rawIdent)
        return semImportModuleName(astNodeStrVal(nId))
    of nkStrLit:
        return semImportModuleName(astNodeStrVal(nId))
    else:
        return ""

fn importAliasValueId(nId: AstNodeId): str =
    if !astNodeIdValid(nId):
        return ""
    if astNodeKind(nId) == nkImportAs:
        return importAliasNameId(nId)
    return ""

fn appendImportDepId(base: str, itemId: AstNodeId, out: str[]*) =
    if !astNodeIdValid(itemId) || out == nil:
        return
    let path: str = importNodePathId(itemId)
    if len path == 0:
        return
    var full: str = path
    if len base > 0:
        full = stage1JoinWithSlash(base, path)
    let alias: str = importAliasValueId(itemId)
    if len alias > 0:
        full = full + " as "
        full = full + alias
    add(out, full)

fn stripImportAlias(item: str): str =
    if len(item) == 0:
        return ""
    let n: int32 = len item
    if n < 4:
        return item
    for i in 0..n - 4:
        if item[i] ==  ' ' && item[i + 1] ==  'a' && item[i + 2] ==  's' &&
            item[i + 3] ==  ' ':
            if i == 0:
                return ""
            return sliceRange(item, 0, i - 1)
    return item

fn collectImportAliasesId(rootId: AstNodeId, out: str[]*) =
    if !astNodeIdValid(rootId) || out == nil:
        return
    let rootKind: NodeKind = astNodeKind(rootId)
    if rootKind != nkModule && rootKind != nkStmtList:
        return
    for i in 0..<astKidCount(rootId):
        let nId: AstNodeId = astKidAt(rootId, i)
        if !astNodeIdValid(nId):
            continue
        let nKind: NodeKind = astNodeKind(nId)
        if nKind == nkImportStmt:
            for j in 0..<astKidCount(nId):
                let itemId: AstNodeId = astKidAt(nId, j)
                if astNodeKind(itemId) == nkImportGroup:
                    if astKidCount(itemId) <= 1:
                        let baseName: str = importAliasNameId(astKidAt(itemId, 0))
                        if len baseName > 0:
                            add(out, baseName)
                    else:
                        for k in 1..<astKidCount(itemId):
                            let entryName: str = importAliasNameId(astKidAt(itemId, k))
                            if len entryName > 0:
                                add(out, entryName)
                else:
                    let aliasName: str = importAliasNameId(itemId)
                    if len aliasName > 0:
                        add(out, aliasName)
        elif nKind == nkImportGroup:
            if astKidCount(nId) <= 1:
                let baseName2: str = importAliasNameId(astKidAt(nId, 0))
                if len baseName2 > 0:
                    add(out, baseName2)
            else:
                for k2 in 1..<astKidCount(nId):
                    let entryName2: str = importAliasNameId(astKidAt(nId, k2))
                    if len entryName2 > 0:
                        add(out, entryName2)

fn isModuleAlias(name: str, aliases: str[]): bool =
    if len name == 0:
        return false
    for i in 0..<aliases.len:
        if (aliases[i] ==  name):
            return true
    return false

fn lowerModuleQualifiersCtxShadowId(nId: AstNodeId, aliases: str[], shadowed: str[], keepDot: bool): AstNodeId =
    if !astNodeIdValid(nId):
        return astInvalidNodeId()
    var localShadowed: str[] = shadowed
    let nKind: NodeKind = astNodeKind(nId)
    if (nKind == nkFnDecl || nKind == nkIteratorDecl) && astKidCount(nId) > 1:
        var fnShadowed: str[4]
        let paramsId: AstNodeId = astKidAt(nId, 1)
        if astNodeKind(paramsId) == nkFormalParams:
            for pi in 0..<astKidCount(paramsId):
                let defsId: AstNodeId = astKidAt(paramsId, pi)
                if astNodeKind(defsId) == nkIdentDefs && astKidCount(defsId) > 0:
                    let nameId: AstNodeId = astKidAt(defsId, 0)
                    let nameKind: NodeKind = astNodeKind(nameId)
                    if nameKind == nkIdent || nameKind == nkSymbol:
                        let nm: str = stripSpaces(astNodeIdent(nameId))
                        if isModuleAlias(nm, aliases) && !isModuleAlias(nm, fnShadowed):
                            add(fnShadowed, nm)
        localShadowed = fnShadowed
    if nKind == nkDotExpr && astKidCount(nId) > 1:
        let baseId: AstNodeId = astKidAt(nId, 0)
        let memberId: AstNodeId = astKidAt(nId, 1)
        let baseKind: NodeKind = astNodeKind(baseId)
        if !keepDot && (baseKind == nkIdent || baseKind == nkSymbol):
            let bname: str = stripSpaces(astNodeIdent(baseId))
            if isModuleAlias(bname, aliases) && !isModuleAlias(bname, localShadowed):
                return lowerModuleQualifiersCtxShadowId(memberId, aliases, localShadowed, keepDot)
    for i in 0..<astKidCount(nId):
        let childId: AstNodeId = astKidAt(nId, i)
        var childKeep: bool = false
        if keepDot:
            if nKind == nkBracketExpr:
                childKeep = (i == 0)
            else:
                childKeep = true
        elif nKind == nkCall && i == 0:
            childKeep = true
        let loweredId: AstNodeId = lowerModuleQualifiersCtxShadowId(childId, aliases, localShadowed, childKeep)
        if astNodeIdValid(loweredId) && loweredId != childId:
            astSetKid(nId, i, loweredId)
    return nId

fn lowerModuleQualifiersCtxId(nId: AstNodeId, aliases: str[], keepDot: bool): AstNodeId =
    var empty: str[1]
    return lowerModuleQualifiersCtxShadowId(nId, aliases, empty, keepDot)

fn lowerModuleQualifiersId(nId: AstNodeId, aliases: str[]): AstNodeId =
    var empty: str[1]
    return lowerModuleQualifiersCtxShadowId(nId, aliases, empty, false)

fn normalizeImportPath(path: str): str =
    let abs: str = absolutePath path
    let norm: str = normalizePath abs
    if stage1TraceImportsEnabled():
        stage1Trace("import: normalizeImportPath path=" + path + " abs=" + abs + " norm=" + norm)
    return norm

fn stage1PathReadable(path: str): bool =
    if len(path) == 0:
        return false
    if stage1_fileExists(path):
        return true
    var content: str = ""
    let readOk: bool = stage1_readFileInto(path, content)
    if readOk && len(content) > 0:
        return true
    return false

fn stage1_pkgRootsFromEnv(): str[] =
    var out: str[4]
    let single: str = stage1_getEnv "PKG_ROOT"
    if len(single) > 0:
        add(out, single)
    let raw: str = stage1_getEnv "PKG_ROOTS"
    var start: int32 = 0
    if len(raw) > 0:
        let rawLen: int32 = len raw
        # Accept ',' ';' and ':' separators (':' is common on Unix PATH-like lists).
        # Only treat ':' as a separator when the list is not already using ',' or ';'
        # to avoid breaking Windows drive letters like "C:\\" in ';'-separated lists.
        var hasCommaOrSemi: bool = false
        for k in 0..<rawLen:
            let c0: char = raw[k]
            if c0 == ',' || c0 == ';':
                hasCommaOrSemi = true
                break
        let useColon: bool = !hasCommaOrSemi
        for i in 0..rawLen:
            if i == rawLen || raw[i] == ',' || raw[i] == ';' ||
               (useColon && raw[i] == ':'):
                if i > start:
                    let part: str = sliceRange(raw, start, i - 1)
                    let trimmed: str = stripSpaces part
                    if len trimmed > 0:
                        add(out, trimmed)
                start = i + 1
    if out.len == 0:
        let home: str = stage1_getEnv "HOME"
        if len(home) > 0:
            let fallback: str = joinPath(home, ".cheng-packages")
            add(out, fallback)
    return out

fn indexOfSlash(path: str): int32 =
    if len(path) == 0 || path[0] == char(0):
        return -1
    let pathLen: int32 = len path
    for i in 0..<pathLen:
        if path[i] == '/':
            return i
    return -1

fn importPathDropChengPrefix(importPath: str): str =
    if len(importPath) == 0:
        return ""
    if hasPrefix(importPath, "cheng/"):
        if len importPath <= 6:
            return ""
        return sliceRange(importPath, 6, len importPath - 1)
    return importPath

fn packageNameFromImport(importPath: str): str =
    let normalized: str = importPathDropChengPrefix(importPath)
    if len(normalized) == 0:
        return ""
    let slash: int32 = indexOfSlash(normalized)
    if slash <= 0:
        return ""
    let pkgName: str = sliceRange(normalized, 0, slash - 1)
    if pkgName == "std" || pkgName == "core" || pkgName == "system" ||
       pkgName == "ide" || pkgName == "gui":
        return ""
    return pkgName

fn packageIdFromImport(importPath: str): str =
    let name: str = packageNameFromImport importPath
    if len(name) == 0:
        return ""
    if (name == "stdlib"):
        return ""
    return "pkg://cheng/" + name

fn pathBaseName(path: str): str =
    if len(path) == 0:
        return ""
    var end: int32 = len path - 1
    let __for_start_end = end
    for __for_rev_end in 0..(__for_start_end - (0)):
        end = __for_start_end - __for_rev_end
        if !(path[end] == '/'):
            break
    if end < 0:
        return ""
    var start: int32 = end
    let __for_start_start = end
    for __for_rev_start in 0..(__for_start_start - (0)):
        start = __for_start_start - __for_rev_start
        if !(path[start] != '/'):
            break
    return sliceRange(path, start + 1, end)

fn findChar(s: str, ch: char, start: int32): int32 =
    if len(s) == 0 || s[0] == char(0):
        return -1
    if start < 0:
        start = 0
    let sLen: int32 = len s
    for i in start..<sLen:
        if s[i] == ch:
            return i
    return -1

fn parseQuotedValue(line: str): str =
    if len(line) == 0:
        return ""
    let first: int32 = findChar(line, '"', 0)
    if first >= 0:
        let second: int32 = findChar(line, '"', first + 1)
        if second > first:
            return sliceRange(line, first + 1, second - 1)
    return ""

fn packageIdFromManifest(manifestPath: str): str =
    if len(manifestPath) == 0:
        return ""
    if !stage1PathReadable(manifestPath):
        return ""
    var content: str = ""
    let _readOk: bool = stage1_readFileInto(manifestPath, content)
    if len(content) == 0 || content[0] == char(0):
        return ""
    let contentLen: int32 = len content
    let key: str = "package_id"
    var start: int32 = 0
    for i in 0..contentLen:
        if i == contentLen || content[i] == '\n':
            if i > start:
                let line: str = sliceRange(content, start, i - 1)
                let trimmed: str = stripSpaces line
                if startsWith(trimmed, key):
                    if len trimmed == len key || trimmed[len key] == '=' ||
                       trimmed[len key] == ':' || trimmed[len key] == ' ':
                        let value: str = parseQuotedValue trimmed
                        if len value > 0:
                            return value
            start = i + 1
    return ""

fn packageIdMatches(manifestPath: str, expected: str): bool =
    if len(expected) == 0:
        return true
    let got: str = packageIdFromManifest manifestPath
    if len(got) == 0:
        return false
    return (got == expected)

fn resolvePkgCandidate(root: str, rel: str): str =
    if len(root) == 0 || len(rel) == 0:
        return ""
    var candidate: str = joinPath(root, rel)
    var fullCandidate: str = candidate
    if ! endsWith(fullCandidate, ".cheng"):
        fullCandidate = stage1AppendChengExt(fullCandidate)
    if stage1PathReadable(fullCandidate):
        let resolved: str = normalizeImportPathChecked(fullCandidate, root)
        if len resolved > 0:
            return resolved
    return ""

fn resolvePkgPathInRoot(root: str, rel: str): str =
    if len(root) == 0 || len(rel) == 0:
        return ""
    var resolved: str = resolvePkgCandidate(root, rel)
    if len resolved > 0:
        return resolved
    var relSub: str = rel
    if hasPrefix(relSub, "cheng/"):
        if len relSub > 6:
            relSub = sliceRange(relSub, 6, len relSub - 1)
        else:
            relSub = ""
    if len relSub > 0:
        resolved = resolvePkgCandidate(joinPath(root, "src"), relSub)
        if len resolved > 0:
            return resolved
        resolved = resolvePkgCandidate(joinPath(root, "cheng"), relSub)
        if len resolved > 0:
            return resolved
    return ""

fn resolvePkgPathInRoot2(root: str, relInPkg: str, relForPkgRoot: str): str =
    if len(root) == 0:
        return ""
    if len(relInPkg) > 0:
        let resolvedSrc: str = resolvePkgCandidate(joinPath(root, "src"), relInPkg)
        if len resolvedSrc > 0:
            return resolvedSrc
        let resolvedCheng: str = resolvePkgCandidate(joinPath(root, "cheng"), relInPkg)
        if len resolvedCheng > 0:
            return resolvedCheng
        let resolvedRoot: str = resolvePkgCandidate(root, relInPkg)
        if len resolvedRoot > 0:
            return resolvedRoot
    if len(relForPkgRoot) > 0:
        let resolvedLegacySrc: str = resolvePkgCandidate(joinPath(root, "src"), relForPkgRoot)
        if len resolvedLegacySrc > 0:
            return resolvedLegacySrc
        let resolvedLegacyCheng: str = resolvePkgCandidate(joinPath(root, "cheng"), relForPkgRoot)
        if len resolvedLegacyCheng > 0:
            return resolvedLegacyCheng
        let resolvedLegacyRoot: str = resolvePkgCandidate(root, relForPkgRoot)
        if len resolvedLegacyRoot > 0:
            return resolvedLegacyRoot
    return ""

fn resolvePkgImportPath(importPath: str): str =
    if len(importPath) == 0:
        return ""
    let expectedPkgId: str = packageIdFromImport importPath
    let importPkgName: str = packageNameFromImport importPath
    var relForPkgRoot: str = importPathDropChengPrefix(importPath)
    if len(relForPkgRoot) == 0:
        relForPkgRoot = importPath
    let roots: str[] = stage1PkgRoots()
    for i in 0..<roots.len:
        let root: str = roots[i]
        if len root > 0:
            let manifest: str = joinPath(root, "cheng-package.toml")
            if stage1_fileExists manifest:
                if ! packageIdMatches(manifest, expectedPkgId):
                    continue
                # Production layout: a package root contains `src/` as the module root.
                # Example: import `ai/foo/bar` -> <pkgroot>/src/foo/bar.cheng
                var relInPkg: str = relForPkgRoot
                if len expectedPkgId > 0 && len importPkgName > 0:
                    let prefix: str = stage1JoinWithSlash(importPkgName, "")
                    if len relInPkg > len prefix && hasPrefix(relInPkg, prefix):
                        relInPkg = sliceRange(relInPkg, len prefix, len relInPkg - 1)

                if len relInPkg > 0:
                    let resolvedSrc: str = resolvePkgCandidate(joinPath(root, "src"), relInPkg)
                    if len resolvedSrc > 0:
                        return resolvedSrc
                    let resolvedCheng: str = resolvePkgCandidate(joinPath(root, "cheng"), relInPkg)
                    if len resolvedCheng > 0:
                        return resolvedCheng
                    let resolvedRoot: str = resolvePkgCandidate(root, relInPkg)
                    if len resolvedRoot > 0:
                        return resolvedRoot

                # Fallback for legacy layouts where the package name is part of the path.
                let resolvedLegacySrc: str = resolvePkgCandidate(joinPath(root, "src"), relForPkgRoot)
                if len resolvedLegacySrc > 0:
                    return resolvedLegacySrc
                let resolvedLegacyCheng: str = resolvePkgCandidate(joinPath(root, "cheng"), relForPkgRoot)
                if len resolvedLegacyCheng > 0:
                    return resolvedLegacyCheng
                let resolvedLegacyRoot: str = resolvePkgCandidate(root, relForPkgRoot)
                if len resolvedLegacyRoot > 0:
                    return resolvedLegacyRoot
            else:
                if len expectedPkgId > 0:
                    let pkgName: str = packageNameFromImport importPath
                    if len pkgName > 0:
                        let prefixedRoot: str = joinPath(root, stage1Concat2("cheng-", pkgName))
                        let prefixedManifest: str = joinPath(prefixedRoot, "cheng-package.toml")
                        if stage1PathReadable(prefixedManifest) && packageIdMatches(prefixedManifest, expectedPkgId):
                            var relInPkg: str = relForPkgRoot
                            let prefix: str = stage1JoinWithSlash(pkgName, "")
                            if len relInPkg > len prefix && hasPrefix(relInPkg, prefix):
                                relInPkg = sliceRange(relInPkg, len prefix, len relInPkg - 1)
                            let resolvedPref: str = resolvePkgPathInRoot2(prefixedRoot, relInPkg, relForPkgRoot)
                            if len resolvedPref > 0:
                                return resolvedPref
                        let plainRoot: str = joinPath(root, pkgName)
                        let plainManifest: str = joinPath(plainRoot, "cheng-package.toml")
                        if stage1PathReadable(plainManifest) && packageIdMatches(plainManifest, expectedPkgId):
                            var relInPkg2: str = relForPkgRoot
                            let prefix2: str = stage1JoinWithSlash(pkgName, "")
                            if len relInPkg2 > len prefix2 && hasPrefix(relInPkg2, prefix2):
                                relInPkg2 = sliceRange(relInPkg2, len prefix2, len relInPkg2 - 1)
                            let resolvedPlain: str = resolvePkgPathInRoot2(plainRoot, relInPkg2, relForPkgRoot)
                            if len resolvedPlain > 0:
                                return resolvedPlain
                    continue
                let slash: int32 = indexOfSlash(importPath)
                if slash > 0 && slash < len importPath - 1:
                    let pkgName: str = sliceRange(importPath, 0, slash - 1)
                    let rel: str = sliceRange(importPath, slash + 1, len importPath - 1)
                    let pkgRoot: str = joinPath(root, pkgName)
                    let resolved: str = resolvePkgPathInRoot(pkgRoot, rel)
                    if len resolved > 0:
                        return resolved
    return ""

fn resolveImportPath(path: str, baseDir: str, rootDir: str): str =
    if len(path) == 0:
        return ""
    let dbgImports: bool = os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1"
    if stage1PluginEnabled():
        let pluginResolved: str = stage1ResolvePluginImportPath(path)
        if len pluginResolved > 0:
            return pluginResolved
    var full: str = path
    if isAbsolute(full) || hasPrefix(full, "/") || hasPrefix(full, "./") || hasPrefix(full, "../") || hasPrefix(full, "."):
        return ""
    if isAbsolute full:
        if ! endsWith(full, ".cheng"):
            full = stage1AppendChengExt(full)
        if stage1_fileExists full:
            let resolved: str = normalizeImportPathChecked(full, rootDir)
            if len resolved > 0:
                return resolved
        return ""
    if hasPrefix(full, "std/"):
        var stdPath: str = joinPath(joinPath(rootDir, "src"), full)
        if ! endsWith(stdPath, ".cheng"):
            stdPath = stage1AppendChengExt(stdPath)
        if dbgImports:
            let readableText: str = stage1PathReadable(stdPath) ? "1" : "0"
            echo("[importdbg] resolve.std raw='" + path + "' baseDir='" + baseDir + "' rootDir='" + rootDir + "' stdPath='" + stdPath + "' readable=" + readableText)
        if stage1PathReadable(stdPath):
            let resolved: str = normalizeImportPathChecked(stdPath, rootDir)
            if dbgImports:
                echo("[importdbg] resolve.std.resolved='" + resolved + "'")
            if len resolved > 0:
                return resolved
        return ""
    if hasPrefix(full, "core/"):
        var corePath0: str = joinPath(joinPath(rootDir, "src"), full)
        if ! endsWith(corePath0, ".cheng"):
            corePath0 = stage1AppendChengExt(corePath0)
        if stage1PathReadable(corePath0):
            let resolved: str = normalizeImportPathChecked(corePath0, rootDir)
            if len resolved > 0:
                return resolved
        return ""
    if hasPrefix(full, "system/"):
        var systemPath0: str = joinPath(joinPath(rootDir, "src"), full)
        if ! endsWith(systemPath0, ".cheng"):
            systemPath0 = stage1AppendChengExt(systemPath0)
        if stage1PathReadable(systemPath0):
            let resolved: str = normalizeImportPathChecked(systemPath0, rootDir)
            if len resolved > 0:
                return resolved
        return ""
    if hasPrefix(full, "cheng/stdlib/bootstrap/"):
        var legacyBase: str = joinPath(rootDir, "src/std")
        var legacyRest: str = sliceRange(full, 23, len full - 1)
        if hasPrefix(full, "cheng/stdlib/bootstrap/core/"):
            legacyBase = joinPath(rootDir, "src/core")
            legacyRest = sliceRange(full, 28, len full - 1)
        elif hasPrefix(full, "cheng/stdlib/bootstrap/system/"):
            legacyBase = joinPath(rootDir, "src/system")
            legacyRest = sliceRange(full, 30, len full - 1)
        elif hasPrefix(full, "cheng/stdlib/bootstrap/std/"):
            legacyBase = joinPath(rootDir, "src/std")
            legacyRest = sliceRange(full, 27, len full - 1)
        var legacyPath: str = joinPath(legacyBase, legacyRest)
        if ! endsWith(legacyPath, ".cheng"):
            legacyPath = stage1AppendChengExt(legacyPath)
        if stage1PathReadable(legacyPath):
            let resolved: str = normalizeImportPathChecked(legacyPath, rootDir)
            if len resolved > 0:
                return resolved
        return ""
    if hasPrefix(full, "cheng/"):
        let rest: str = sliceRange(full, 6, len full - 1)
        var localCandidate: str = joinPath(joinPath(rootDir, "src"), rest)
        var localFull: str = localCandidate
        if ! endsWith(localFull, ".cheng"):
            localFull = stage1AppendChengExt(localFull)
        if stage1PathReadable(localFull):
            let resolved: str = normalizeImportPathChecked(localFull, rootDir)
            if len resolved > 0:
                return resolved
        let candidate: str = joinPath(rootDir, full)
        var fullCandidate: str = candidate
        if ! endsWith(fullCandidate, ".cheng"):
            fullCandidate = stage1AppendChengExt(fullCandidate)
        if stage1PathReadable(fullCandidate):
            let resolved: str = normalizeImportPathChecked(fullCandidate, rootDir)
            if len resolved > 0:
                return resolved
        let pkgResolved: str = resolvePkgImportPath full
        if len pkgResolved > 0:
            return pkgResolved
        return ""
    if hasPrefix(full, "gui/"):
        let guiRoot: str = stage1_getEnv "GUI_ROOT"
        if len guiRoot > 0:
            let rest: str = sliceRange(full, 4, len full - 1)
            full = joinPath(guiRoot, rest)
            if ! endsWith(full, ".cheng"):
                full = stage1AppendChengExt(full)
            if stage1PathReadable(full):
                let resolved: str = normalizeImportPathChecked(full, guiRoot)
                if len resolved > 0:
                    return resolved
            return ""
    if hasPrefix(full, "ide/gui/"):
        let guiRoot: str = stage1_getEnv "GUI_ROOT"
        if len guiRoot > 0:
            let rest: str = sliceRange(full, 8, len full - 1)
            full = joinPath(guiRoot, rest)
            if ! endsWith(full, ".cheng"):
                full = stage1AppendChengExt(full)
            if stage1PathReadable(full):
                let resolved: str = normalizeImportPathChecked(full, guiRoot)
                if len resolved > 0:
                    return resolved
            return ""
        let ideRoot: str = stage1_getEnv "IDE_ROOT"
        if len ideRoot > 0:
            let rest: str = sliceRange(full, 4, len full - 1)
            full = joinPath(ideRoot, rest)
            if ! endsWith(full, ".cheng"):
                full = stage1AppendChengExt(full)
            if stage1PathReadable(full):
                let resolved: str = normalizeImportPathChecked(full, ideRoot)
                if len resolved > 0:
                    return resolved
            return ""
    if hasPrefix(full, "ide/"):
        let ideRoot: str = stage1_getEnv "IDE_ROOT"
        if len ideRoot > 0:
            let rest: str = sliceRange(full, 4, len full - 1)
            full = joinPath(ideRoot, rest)
            if ! endsWith(full, ".cheng"):
                full = stage1AppendChengExt(full)
            if stage1PathReadable(full):
                let resolved: str = normalizeImportPathChecked(full, ideRoot)
                if len resolved > 0:
                    return resolved
            return ""
        full = joinPath(rootDir, full)
        if ! endsWith(full, ".cheng"):
            full = stage1AppendChengExt(full)
        if stage1PathReadable(full):
            let resolved: str = normalizeImportPathChecked(full, rootDir)
            if len resolved > 0:
                return resolved
        return ""
    # Default source import root: resolve plain module paths from `<repo>/src`.
    var srcRootPath: str = joinPath(joinPath(rootDir, "src"), full)
    if ! endsWith(srcRootPath, ".cheng"):
        srcRootPath = stage1AppendChengExt(srcRootPath)
    if stage1PathReadable(srcRootPath):
        let resolved: str = normalizeImportPathChecked(srcRootPath, rootDir)
        if len resolved > 0:
            return resolved
    let fullNoExt: str = full
    if ! endsWith(full, ".cheng"):
        full = stage1AppendChengExt(full)
    if len baseDir > 0:
        let candidate: str = joinPath(baseDir, full)
        if stage1PathReadable(candidate):
            let resolved: str = normalizeImportPathChecked(candidate, rootDir)
            if len resolved > 0:
                return resolved
        let corePath: str = joinPath(joinPath(rootDir, "src/core"), full)
        if stage1PathReadable(corePath):
            let resolved: str = normalizeImportPathChecked(corePath, rootDir)
            if len resolved > 0:
                return resolved
        let systemPath: str = joinPath(joinPath(rootDir, "src/system"), full)
        if stage1PathReadable(systemPath):
            let resolved: str = normalizeImportPathChecked(systemPath, rootDir)
            if len resolved > 0:
                return resolved
        let stdPath: str = joinPath(joinPath(rootDir, "src/std"), full)
        if stage1PathReadable(stdPath):
            let resolved: str = normalizeImportPathChecked(stdPath, rootDir)
            if len resolved > 0:
                return resolved
        if indexOfSlash(fullNoExt) >= 0:
            let pkgResolved: str = resolvePkgImportPath fullNoExt
            if len pkgResolved > 0:
                return pkgResolved
        return ""
    let corePath2: str = joinPath(joinPath(rootDir, "src/core"), full)
    if stage1PathReadable(corePath2):
        let resolved: str = normalizeImportPathChecked(corePath2, rootDir)
        if len resolved > 0:
            return resolved
    let systemPath2: str = joinPath(joinPath(rootDir, "src/system"), full)
    if stage1PathReadable(systemPath2):
        let resolved: str = normalizeImportPathChecked(systemPath2, rootDir)
        if len resolved > 0:
            return resolved
    let stdPath2: str = joinPath(joinPath(rootDir, "src/std"), full)
    if stage1PathReadable(stdPath2):
        let resolved: str = normalizeImportPathChecked(stdPath2, rootDir)
        if len resolved > 0:
            return resolved
    if indexOfSlash(fullNoExt) >= 0:
        let pkgResolved2: str = resolvePkgImportPath fullNoExt
        if len pkgResolved2 > 0:
            return pkgResolved2
    return ""

fn canonicalizeResolvedPath(resolved: str, rootDir: str): str =
    if len(resolved) == 0:
        return ""
    let srcRoot: str = joinPath(rootDir, "src")
    let chengRoot: str = joinPath(rootDir, "cheng")
    let srcPrefix: str = stage1JoinWithSlash(srcRoot, "")
    if hasPrefix(resolved, srcPrefix):
        let rel: str = sliceRange(resolved, len srcPrefix, len resolved - 1)
        let candidate: str = joinPath(chengRoot, rel)
        if stage1_fileExists candidate:
            return candidate
    return resolved

type
    StrSetList =
        items: str[]
        set: hashsets.HashSetStr

    ImportTrace =
        items: str[]

    NodeCache =
        keys: str[]
        valStart: int32[]
        valLen: int32[]
        pool: AstNodeId[]
        index: hashmaps.HashMapStrInt

fn strSetListInit(cap0: int32 = 16): StrSetList =
    var s: StrSetList
    var cap: int32 = cap0
    if cap < 8:
        cap = 8
    s.items = []
    s.items.cap = cap
    s.set = hashsets.hashSetStrInit(cap * 2)
    return s

fn nodeCacheInit(cap0: int32 = 32): NodeCache =
    var c: NodeCache
    var cap: int32 = cap0
    if cap < 8:
        cap = 8
    c.keys = []
    c.keys.cap = cap
    c.valStart = []
    c.valStart.cap = cap
    c.valLen = []
    c.valLen.cap = cap
    c.pool = []
    c.index = hashmaps.hashMapStrIntInit(cap * 2)
    return c

fn stage1NormalizeVisitedPath(path: str): str =
    if len(path) == 0:
        return ""
    if path[0] == '/':
        return path
    let trimmed: str = stripSpaces(path)
    if len(trimmed) == 0:
        return ""
    if trimmed[0] == '/':
        return trimmed
    return normalizeImportPath(trimmed)

fn setHasStr(v: StrSetList, key: str): bool =
    let normKey: str = stage1NormalizeVisitedPath(key)
    if len(normKey) == 0:
        return false
    if hashsets.hashSetStrHas(v.set, normKey):
        return true
    for i in 0..<v.items.len:
        if stage1StrEq(v.items[i], normKey):
            return true
    return false

fn setHasNormalizedStr(v: StrSetList, key: str): bool =
    if len(key) == 0:
        return false
    return hashsets.hashSetStrHas(v.set, key)

fn setAddStr(v: var StrSetList, key: str) =
    let normKey: str = stage1NormalizeVisitedPath(key)
    if len(normKey) == 0:
        return
    if setHasStr(v, normKey):
        return
    var items0: str[] = v.items
    add(items0, normKey)
    v.items = items0
    hashsets.hashSetStrAdd(v.set, normKey)

fn setAddNormalizedStr(v: var StrSetList, key: str) =
    if len(key) == 0:
        return
    if setHasNormalizedStr(v, key):
        return
    var items0: str[] = v.items
    add(items0, key)
    v.items = items0
    hashsets.hashSetStrAdd(v.set, key)

fn stage1StrEq(a: str, b: str): bool =
    let n: int32 = len(a)
    let m: int32 = len(b)
    if n != m:
        return false
    if n == 0:
        return true
    var i: int32 = 0
    while i < n:
        if a[i] != b[i]:
            return false
        i = i + 1
    return true

fn importTraceFind(v: ImportTrace, path: str): int32 =
    if len(path) == 0:
        return -1
    for i in 0..<v.items.len:
        if stage1StrEq(v.items[i], path):
            return i
    return -1

fn importTraceHas(v: ImportTrace, path: str): bool =
    return importTraceFind(v, path) >= 0

fn importTracePush(v: var ImportTrace, path: str) =
    if len(path) == 0:
        return
    var items0: str[] = v.items
    add(items0, path)
    v.items = items0

fn importTracePop(v: var ImportTrace) =
    if v.items.len <= 0:
        return
    v.items.len = v.items.len - 1

fn importTraceCycleMessage(v: ImportTrace, path: str): str =
    var msg: str = "Import cycle detected: "
    let start: int32 = importTraceFind(v, path)
    if start < 0:
        return msg + path + " -> " + path
    var first: bool = true
    for i in start..<v.items.len:
        if !first:
            msg = msg + " -> "
        msg = msg + v.items[i]
        first = false
    if !first:
        msg = msg + " -> "
    msg = msg + path
    return msg

fn mapHasNodes(cache: NodeCache, key: str): bool =
    var ok: bool = false
    let idx: int32 = hashmaps.hashMapStrIntGetEx(cache.index, key, ok)
    return ok && idx >= 0 && idx < cache.valStart.len

fn mapGetNodes(cache: NodeCache, key: str): AstNodeId[] =
    var ok: bool = false
    let idx: int32 = hashmaps.hashMapStrIntGetEx(cache.index, key, ok)
    if !(ok && idx >= 0 && idx < cache.valStart.len):
        return []
    let start: int32 = cache.valStart[idx]
    let n: int32 = cache.valLen[idx]
    var out: AstNodeId[]
    if start >= 0 && n > 0:
        reserve(out, n)
        for i in 0..<n:
            add(out, cache.pool[start + i])
    return out

fn mapSetNodes(cache: var NodeCache, key: str, val: AstNodeId[]) =
    if len(key) == 0:
        return
    var existed: bool = false
    let idx: int32 = hashmaps.hashMapStrIntGetOrInsertEx(cache.index, key, cache.keys.len, existed)
    let start: int32 = cache.pool.len
    let n: int32 = val.len
    var pool0: AstNodeId[] = cache.pool
    for i in 0..<n:
        add(pool0, val[i])
    cache.pool = pool0
    if existed && idx >= 0 && idx < cache.valStart.len:
        var valStartSeq: int32[] = cache.valStart
        var valLenSeq: int32[] = cache.valLen
        valStartSeq[idx] = start
        valLenSeq[idx] = n
        cache.valStart = valStartSeq
        cache.valLen = valLenSeq
        return
    let newIdx: int32 = cache.keys.len
    var keys0: str[] = cache.keys
    var starts0: int32[] = cache.valStart
    var lens0: int32[] = cache.valLen
    add(keys0, key)
    add(starts0, start)
    add(lens0, n)
    cache.keys = keys0
    cache.valStart = starts0
    cache.valLen = lens0
    if existed || idx != newIdx:
        hashmaps.hashMapStrIntPut(cache.index, key, newIdx)

fn loadModuleRecursiveId(pathId: int32, visited: ptr, diags: ptr,
                         cache: ptr = nil, trace: ptr = nil): AstNodeId[] =
    var out: AstNodeId[]
    reserve(out, 64)
    let rootDir: str = stage1ImportRootDirCurrent
    let path: str = stage1ImportPathById(pathId)
    let pathNorm: str = stage1NormalizeVisitedPath(path)
    stage1PhasePush("loadModuleRecursiveId", pathNorm)
    defer:
        stage1PhasePop()
    if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
        echo("[importdbg] recursive.enter pathId=" + intToStr(pathId) + " path='" + path + "' pathNorm='" + pathNorm + "' rootDir='" + rootDir + "'")
    if len(pathNorm) == 0:
        return out
    if stage1TraceImportsEnabled():
        stage1Trace("import: load " + pathNorm)
    if stage1TraceHas(trace, pathNorm):
        if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
            echo("[importdbg] recursive.cycle_skip pathNorm='" + pathNorm + "'")
        if stage1TraceImportsEnabled():
            stage1Trace("import: cycle-skip " + pathNorm)
        return out
    if stage1VisitedHas(visited, pathNorm):
        return out
    var tracePushed: bool = false
    if trace != nil:
        stage1TracePush(trace, pathNorm)
        tracePushed = true
    defer:
        if tracePushed:
            stage1TracePop(trace)
    if visited != nil:
        stage1VisitedAdd(visited, pathNorm)
    if cache != nil:
        if stage1CacheHasNodes(cache, pathNorm):
            let cached: AstNodeId[] = stage1CacheGetNodes(cache, pathNorm)
            return cached
    if !stage1PathReadable(pathNorm):
        if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
            echo("[importdbg] recursive.missing pathNorm='" + pathNorm + "'")
        if stage1TraceImportsEnabled():
            stage1Trace("import: missing " + pathNorm)
        addDiag(diags, svError, pathNorm, 1, 1, "Unable to read imported module")
        stage1PhaseDump()
        return out
    let size: int64 = fileSize pathNorm
    let mtime: int64 = fileMtime pathNorm
    var tokens: Token[]
    var lexDiags: Diagnostic[]
    lexDiags.buffer = nil
    lexDiags.len = 0
    lexDiags.cap = 0
    let cacheHit: bool = loadTokenCacheInto(pathNorm, size, mtime, &tokens)
    if !cacheHit:
        var content: str = ""
        let _readOk: bool = stage1_readFileInto(pathNorm, content)
        if len(content) == 0:
            if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
                echo("[importdbg] recursive.readempty pathNorm='" + pathNorm + "'")
            addDiag(diags, svError, pathNorm, 1, 1, "Unable to read imported module")
            stage1PhaseDump()
            return out
        let _lexOk: bool = lexInto(content, pathNorm, &tokens, &lexDiags)
        releaseString content
        appendDiagnostics(diags, lexDiags)
        if lexDiags.len == 0:
            writeTokenCache(pathNorm, size, mtime, tokens)
    let mrootParsedId: AstNodeId = stage1_parseModuleByMode(tokens, pathNorm, diags)
    let _mrootBodies: int32 = stage1_materializeModuleBodiesForMode(tokens, pathNorm, mrootParsedId, diags)
    let mrootId: AstNodeId = stage1ApplyAstPluginHooksId(pathNorm, mrootParsedId)
    if !astNodeIdValid(mrootId):
        freeSeq_Token(tokens)
        freeSeq[Diagnostic](lexDiags)
        return out
    if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
        var dbgImportNodes0: AstNodeId[]
        reserve(dbgImportNodes0, 32)
        collectImportNodesId(mrootId, &dbgImportNodes0)
        echo("[importdbg] post_parse.count=" + intToStr(dbgImportNodes0.len))
        for di in 0..<dbgImportNodes0.len:
            let impDbgId: AstNodeId = dbgImportNodes0[di]
            echo("[importdbg] post_parse.node[" + intToStr(di) + "] kind=" + intToStr(int32(astNodeKind(impDbgId))) + " kids=" + intToStr(astKidCount(impDbgId)))
            for dj in 0..<astKidCount(impDbgId):
                let kidDbgId: AstNodeId = astKidAt(impDbgId, dj)
                echo("[importdbg] post_parse.kid[" + intToStr(di) + "," + intToStr(dj) + "] kind=" + intToStr(int32(astNodeKind(kidDbgId))) + " ident='" + astNodeIdent(kidDbgId) + "' str='" + astNodeStrVal(kidDbgId) + "'")
    tagModuleChildrenId(mrootId, pathNorm)
    var aliases: str[]
    reserve(aliases, 32)
    collectImportAliasesId(mrootId, &aliases)
    if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
        var dbgImportNodes1: AstNodeId[]
        reserve(dbgImportNodes1, 32)
        collectImportNodesId(mrootId, &dbgImportNodes1)
        echo("[importdbg] post_alias_collect.count=" + intToStr(dbgImportNodes1.len))
        for di in 0..<dbgImportNodes1.len:
            let impDbgId: AstNodeId = dbgImportNodes1[di]
            echo("[importdbg] post_alias_collect.node[" + intToStr(di) + "] kind=" + intToStr(int32(astNodeKind(impDbgId))) + " kids=" + intToStr(astKidCount(impDbgId)))
            for dj in 0..<astKidCount(impDbgId):
                let kidDbgId: AstNodeId = astKidAt(impDbgId, dj)
                echo("[importdbg] post_alias_collect.kid[" + intToStr(di) + "," + intToStr(dj) + "] kind=" + intToStr(int32(astNodeKind(kidDbgId))) + " ident='" + astNodeIdent(kidDbgId) + "' str='" + astNodeStrVal(kidDbgId) + "'")
    if aliases.len > 0:
        let _loweredRootId: AstNodeId = lowerModuleQualifiersId(mrootId, aliases)
    if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
        var dbgImportNodes2: AstNodeId[]
        reserve(dbgImportNodes2, 32)
        collectImportNodesId(mrootId, &dbgImportNodes2)
        echo("[importdbg] post_lower.count=" + intToStr(dbgImportNodes2.len))
        for di in 0..<dbgImportNodes2.len:
            let impDbgId: AstNodeId = dbgImportNodes2[di]
            echo("[importdbg] post_lower.node[" + intToStr(di) + "] kind=" + intToStr(int32(astNodeKind(impDbgId))) + " kids=" + intToStr(astKidCount(impDbgId)))
            for dj in 0..<astKidCount(impDbgId):
                let kidDbgId: AstNodeId = astKidAt(impDbgId, dj)
                echo("[importdbg] post_lower.kid[" + intToStr(di) + "," + intToStr(dj) + "] kind=" + intToStr(int32(astNodeKind(kidDbgId))) + " ident='" + astNodeIdent(kidDbgId) + "' str='" + astNodeStrVal(kidDbgId) + "'")
    let moduleDir: str = stage1SplitDir pathNorm
    var importNodes: AstNodeId[]
    reserve(importNodes, 32)
    collectImportNodesId(mrootId, &importNodes)
    for ii in 0..<importNodes.len:
        let impId: AstNodeId = importNodes[ii]
        var paths: str[]
        reserve(paths, 16)
        collectImportPathsId(impId, &paths)
        for pi in 0..<paths.len:
            let rawPath: str = paths[pi]
            if len rawPath > 0 && !(rawPath == "system"):
                var resolved: str = resolveImportPath(rawPath, moduleDir, rootDir)
                if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
                    echo("[importdbg] load.resolve owner='" + pathNorm + "' raw='" + rawPath + "' moduleDir='" + moduleDir + "' rootDir='" + rootDir + "' resolved='" + resolved + "'")
                if len resolved == 0:
                    addDiag(diags, svError, pathNorm, 1, 1, "Unable to read imported module: " + rawPath)
                    continue
                resolved = canonicalizeResolvedPath(resolved, rootDir)
                resolved = stage1NormalizeVisitedPath(resolved)
                if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
                    echo("[importdbg] load.norm owner='" + pathNorm + "' raw='" + rawPath + "' normalized='" + resolved + "'")
                if stage1TraceImportsEnabled():
                    stage1Trace("import: " + pathNorm + " -> " + rawPath + " => " + resolved)
                let nestedPathId: int32 = stage1ImportPathPushSlot()
                stage1ImportPathPool[nestedPathId] = resolved
                if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
                    echo("[importdbg] load.slot id=" + intToStr(nestedPathId) + " stored='" + stage1ImportPathPool[nestedPathId] + "'")
                let nested: AstNodeId[] = loadModuleRecursiveId(nestedPathId, visited, diags, cache, trace)
                for ni in 0..<nested.len:
                    add(out, nested[ni])
    let mrootKind: NodeKind = astNodeKind(mrootId)
    if mrootKind == nkModule || mrootKind == nkStmtList:
        for ci in 0..<astKidCount(mrootId):
                let childId: AstNodeId = astKidAt(mrootId, ci)
                let childKind: NodeKind = astNodeKind(childId)
                if childKind != nkEmpty && childKind != nkImportStmt && childKind != nkImportGroup:
                    if len(astNodeStrVal(childId)) == 0:
                        astSetNodeStrVal(childId, pathNorm)
                    add(out, childId)
    else:
        if mrootKind != nkEmpty:
            add(out, mrootId)
    if cache != nil:
        stage1CacheSetNodes(cache, pathNorm, out)
    freeSeq_Token(tokens)
    freeSeq[Diagnostic](lexDiags)
    return out

fn loadImportsId(rootId: AstNodeId, baseDir: str, rootDir: str, diags: ptr, visitedIn: ptr = nil,
                 cache: ptr = nil): AstNodeId[] =
    var out: AstNodeId[]
    reserve(out, 64)
    stage1PhasePush("loadImportsId", baseDir)
    defer:
        stage1PhasePop()
    if !astNodeIdValid(rootId):
        return out
    let prevRootDir: str = stage1ImportRootDirCurrent
    stage1ImportRootDirCurrent = rootDir
    defer:
        stage1ImportRootDirCurrent = prevRootDir
    var localVisited: StrSetList = strSetListInit(16)
    var visited: ptr = visitedIn
    if visited == nil:
        visited = &localVisited
    var trace: ImportTrace
    trace.items = []
    reserve(trace.items, 16)
    var rootTracePushed: bool = false
    let rootPath: str = astNodeStrVal(rootId)
    if len(rootPath) > 0:
        importTracePush(trace, rootPath)
        rootTracePushed = true
    defer:
        if rootTracePushed:
            importTracePop(trace)
    var importNodes: AstNodeId[]
    reserve(importNodes, 32)
    collectImportNodesId(rootId, &importNodes)
    for i in 0..<importNodes.len:
        let impId: AstNodeId = importNodes[i]
        var paths: str[]
        reserve(paths, 16)
        collectImportPathsId(impId, &paths)
        for pi in 0..<paths.len:
            let rawPath: str = paths[pi]
            if len rawPath > 0 && !(rawPath == "system"):
                var resolved: str = resolveImportPath(rawPath, baseDir, rootDir)
                if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
                    echo("[importdbg] root.load.resolve raw='" + rawPath + "' baseDir='" + baseDir + "' rootDir='" + rootDir + "' resolved='" + resolved + "'")
                if len resolved == 0:
                    addDiag(diags, svError, baseDir, 1, 1, "Unable to read imported module: " + rawPath)
                    stage1PhaseDump()
                    continue
                resolved = canonicalizeResolvedPath(resolved, rootDir)
                resolved = stage1NormalizeVisitedPath(resolved)
                if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
                    echo("[importdbg] root.load.norm raw='" + rawPath + "' normalized='" + resolved + "'")
                if stage1TraceImportsEnabled():
                    let owner: str = (len(rootPath) > 0) ? rootPath : baseDir
                    stage1Trace("import: " + owner + " -> " + rawPath + " => " + resolved)
                let nestedPathId: int32 = stage1ImportPathPushSlot()
                stage1ImportPathPool[nestedPathId] = resolved
                if os.getEnvDefault("BACKEND_DEBUG_IMPORT_PATHS", "") == "1":
                    echo("[importdbg] root.load.slot id=" + intToStr(nestedPathId) + " stored='" + stage1ImportPathPool[nestedPathId] + "'")
                let nested: AstNodeId[] = loadModuleRecursiveId(nestedPathId, visited, diags, cache, &trace)
                for ni in 0..<nested.len:
                    add(out, nested[ni])
    return out

fn copyFile(src: str, dst: str): bool =
    var content: str = ""
    let _readOk: bool = stage1_readFileInto(src, content)
    if len(content) == 0:
        return false
    stage1_writeFile(dst, content)
    return true

fn appendDiagnostics(dst: ptr, src: Diagnostic[]) =
    if dst == nil:
        return
    for i in 0..<src.len:
        add(dst, src[i])

fn hasError(diags: var Diagnostic[]): bool =
    for i in 0..<diags.len:
        let d: Diagnostic = diags[i]
        if d.severity == svError:
            return true
    return false

fn hasHint(diags: Diagnostic[]): bool =
    for i in 0..<diags.len:
        let d: Diagnostic = diags[i]
        if d.severity == svHint:
            return true
    return false

fn printDiagnosticStable(d: Diagnostic) =
    let f: os.File = os.get_stderr()
    os.write(f, diagFilename(d))
    os.write(f, ":")
    os.write(f, intToStr(d.line))
    os.write(f, ":")
    os.write(f, intToStr(d.col))
    os.write(f, ": [")
    case d.severity
    of svError:
        os.write(f, "error")
    of svWarning:
        os.write(f, "warning")
    of svHint:
        os.write(f, "hint")
    else:
        os.write(f, "unknown")
    os.write(f, "] ")
    os.writeLine(f, diagMessage(d))

fn printDiagnostics(diags: Diagnostic[]) =
    for i in 0..<diags.len:
        printDiagnosticStable(diags[i])

fn printHints(diags: Diagnostic[]) =
    for i in 0..<diags.len:
        let d: Diagnostic = diags[i]
        if d.severity == svHint:
            printDiagnosticStable(d)

fn loadSystemModuleId(userFile: str, diags: ptr): AstNodeId =
    stage1PhasePush("loadSystemModuleId", userFile)
    defer:
        stage1PhasePop()
    if !stage1_autoSystemEnabled():
        return astInvalidNodeId()
    let dbgPipe: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    let dbgFile: os.File = dbgPipe ? os.get_stderr() : nil
    var sysPath: str = "src/std/system.cheng"
    if (userFile == sysPath):
        return astInvalidNodeId()
    var tokens: Token[]
    var lexDiags: Diagnostic[]
    lexDiags.buffer = nil
    lexDiags.len = 0
    lexDiags.cap = 0
    var content: str = stage1_readFileFast(sysPath)
    if stage1_c_strlen(content) == 0:
        let _readOk: bool = stage1_readFileInto(sysPath, content)
    if dbgPipe:
        stage1DebugPipeWritePrefixInt(dbgFile, "[frontend] sysmod content_len=", len(content))
    if len(content) == 0:
        if dbgPipe:
            stage1DebugPipeWriteConst(dbgFile, "[frontend] sysmod empty_content")
        stage1PhaseDump()
        return astInvalidNodeId()
    let _lexOk: bool = lexInto(content, sysPath, &tokens, &lexDiags)
    releaseString content
    if dbgPipe:
        stage1DebugPipeWritePrefixInt(dbgFile, "[frontend] sysmod lex_diags=", lexDiags.len)
    if diags != nil:
        appendDiagnostics(diags, lexDiags)
    if lexDiags.len > 0:
        if dbgPipe:
            stage1DebugPipeWriteConst(dbgFile, "[frontend] sysmod lex_failed")
        stage1PhaseDump()
        freeSeq_Token(tokens)
        freeSeq[Diagnostic](lexDiags)
        return astInvalidNodeId()
    let sysRootParsedId: AstNodeId = stage1_parseModuleByMode(tokens, sysPath, diags)
    let _sysBodies: int32 = stage1_materializeModuleBodiesForMode(tokens, sysPath, sysRootParsedId, diags)
    let sysRootId: AstNodeId = stage1ApplyAstPluginHooksId(sysPath, sysRootParsedId)
    if dbgPipe:
        stage1DebugPipeWritePrefixInt(dbgFile, "[frontend] sysmod parsed_kids=", astKidCount(sysRootId))
    freeSeq_Token(tokens)
    freeSeq[Diagnostic](lexDiags)
    return sysRootId

fn parseModuleForDepsId(path: str, diags: ptr): AstNodeId =
    stage1PhasePush("parseModuleForDepsId", path)
    defer:
        stage1PhasePop()
    if len path == 0:
        stage1PhaseDump()
        return astInvalidNodeId()
    if ! stage1_fileExists path:
        addDiag(diags, svError, path, 1, 1, "Unable to read input file")
        stage1PhaseDump()
        return astInvalidNodeId()
    let size: int64 = fileSize path
    let mtime: int64 = fileMtime path
    var tokens: Token[]
    var lexDiags: Diagnostic[]
    lexDiags.buffer = nil
    lexDiags.len = 0
    lexDiags.cap = 0
    let cacheHit: bool = loadTokenCacheInto(path, size, mtime, &tokens)
    if !cacheHit:
        var content: str = ""
        let _readOk: bool = stage1_readFileInto(path, content)
        if len(content) == 0:
            addDiag(diags, svError, path, 1, 1, "Unable to read input file")
            stage1PhaseDump()
            return astInvalidNodeId()
        let _lexOk: bool = lexInto(content, path, &tokens, &lexDiags)
        releaseString content
        appendDiagnostics(diags, lexDiags)
        if lexDiags.len == 0:
            writeTokenCache(path, size, mtime, tokens)
    let rootParsedId: AstNodeId = stage1_parseModuleByMode(tokens, path, diags)
    let _rootBodies: int32 = stage1_materializeModuleBodiesForMode(tokens, path, rootParsedId, diags)
    let rootId: AstNodeId = stage1ApplyAstPluginHooksId(path, rootParsedId)
    freeSeq_Token(tokens)
    freeSeq[Diagnostic](lexDiags)
    return rootId

fn mergeModulesId(sysRootId: AstNodeId, userRootId: AstNodeId): AstNodeId =
    if !astNodeIdValid(userRootId):
        return sysRootId
    if !astNodeIdValid(sysRootId):
        return userRootId
    let rootId: AstNodeId = astNewNodeId(nkModule, astNodePos(userRootId))
    astSetNodeStrVal(rootId, astNodeStrVal(userRootId))
    astSetNodeIdent(rootId, astNodeIdent(userRootId))
    for i in 0..<astKidCount(sysRootId):
        astAddKid(rootId, astKidAt(sysRootId, i))
    for j in 0..<astKidCount(userRootId):
        astAddKid(rootId, astKidAt(userRootId, j))
    return rootId

fn tagModuleChildrenId(rootId: AstNodeId, path: str) =
    if !astNodeIdValid(rootId):
        return
    if len(path) == 0 || path[0] == char(0):
        return
    for i in 0..<astKidCount(rootId):
        let childId: AstNodeId = astKidAt(rootId, i)
        let childKind: NodeKind = astNodeKind(childId)
        if childKind != nkEmpty:
            if childKind == nkStmtList:
                for j in 0..<astKidCount(childId):
                    let stmtId: AstNodeId = astKidAt(childId, j)
                    if astNodeKind(stmtId) != nkEmpty:
                        if len(astNodeStrVal(stmtId)) == 0:
                            astSetNodeStrVal(stmtId, path)
            elif len(astNodeStrVal(childId)) == 0:
                astSetNodeStrVal(childId, path)

fn collectImportDepsId(rootId: AstNodeId, out: str[]*) =
    if !astNodeIdValid(rootId) || out == nil:
        return
    let kind: NodeKind = astNodeKind(rootId)
    if kind == nkImportStmt:
        for j in 0..<astKidCount(rootId):
            let itemId: AstNodeId = astKidAt(rootId, j)
            if astNodeKind(itemId) == nkImportGroup:
                if astKidCount(itemId) > 0:
                    let base: str = importNodePathId(astKidAt(itemId, 0))
                    for k in 1..<astKidCount(itemId):
                        appendImportDepId(base, astKidAt(itemId, k), out)
            else:
                appendImportDepId("", itemId, out)
        return
    if kind == nkImportGroup:
        if astKidCount(rootId) > 0:
            let base2: str = importNodePathId(astKidAt(rootId, 0))
            for m in 1..<astKidCount(rootId):
                appendImportDepId(base2, astKidAt(rootId, m), out)
        return
    for i in 0..<astKidCount(rootId):
        collectImportDepsId(astKidAt(rootId, i), out)

fn collectResolvedDeps(inPath: str, diags: ptr): str[] =
    releaseNodeArena()
    releaseLexStrings()
    initNodeArena()
    initLexStringPool()
    defer:
        releaseNodeArena()
        releaseLexStrings()
    let userRootId: AstNodeId = parseModuleForDepsId(inPath, diags)
    let sysRootId: AstNodeId = loadSystemModuleId(inPath, diags)
    if stage1DiagsHasError(diags):
        return []
    let combinedId: AstNodeId = mergeModulesId(sysRootId, userRootId)
    var imports: str[16]
    collectImportDepsId(combinedId, &imports)
    var uniqSet: StrSetList = strSetListInit(imports.len)
    for importIndex in 0..<imports.len:
        let imp: str = imports[importIndex]
        if len imp > 0:
            setAddStr(uniqSet, imp)
    let inName: str = stage1SplitName inPath
    let inExt: str = stage1SplitExt inPath
    if stage1_autoSystemEnabled() && !(inName == "system" && inExt == ".cheng"):
        setAddStr(uniqSet, "system")
    var resolvedDeps: str[] = uniqSet.items
    let resolveEnv: str = stage1_getEnv "DEPS_RESOLVE"
    if (resolveEnv == "1") || (resolveEnv == "true") || (resolveEnv == "yes"):
        let repoRoot: str = getCurrentDir()
        let baseDir: str = stage1SplitDir inPath
        var resolvedSet: StrSetList = strSetListInit(uniqSet.items.len + 4)
        var visitedModules: StrSetList = strSetListInit(uniqSet.items.len + 4)
        var pending: str[]
        for resolvedIndex in 0..<uniqSet.items.len:
            let raw: str = stripImportAlias uniqSet.items[resolvedIndex]
            var resolved: str = resolveImportPath(raw, baseDir, repoRoot)
            if len resolved == 0:
                resolved = raw
            if len resolved > 0:
                resolved = canonicalizeResolvedPath(resolved, repoRoot)
                setAddStr(resolvedSet, resolved)
                if stage1_fileExists resolved && ! setHasStr(visitedModules, resolved):
                    setAddStr(visitedModules, resolved)
                    add(pending, resolved)
        while true:
            let pendingLen: int32 = pending.len
            if pendingLen == 0:
                break
            var nextPending: str[]
            for pi in 0..<pendingLen:
                let modPath: str = pending[pi] + ""
                let modRootId: AstNodeId = parseModuleForDepsId(modPath, diags)
                if !astNodeIdValid(modRootId):
                    continue
                let modDir: str = stage1SplitDir modPath
                var modImports: str[8]
                collectImportDepsId(modRootId, &modImports)
                for mi in 0..<modImports.len:
                    let rawNext: str = stripImportAlias modImports[mi]
                    if len rawNext > 0:
                        var resolvedNext: str = resolveImportPath(rawNext, modDir, repoRoot)
                        if len resolvedNext == 0:
                            resolvedNext = rawNext
                        if len resolvedNext > 0:
                            resolvedNext = canonicalizeResolvedPath(resolvedNext, repoRoot)
                            setAddStr(resolvedSet, resolvedNext)
                            if stage1_fileExists resolvedNext && ! setHasStr(visitedModules, resolvedNext):
                                setAddStr(visitedModules, resolvedNext)
                                add(nextPending, resolvedNext)
            pending = nextPending
        resolvedDeps = resolvedSet.items
    return resolvedDeps

fn compileToDepsList(inPath: str, outPath: str): bool =
    if (inPath == ""):
        panic "stage1 frontend: missing input"
    var diags: Diagnostic[16]
    let resolvedDeps: str[] = collectResolvedDeps(inPath, &diags)
    if hasError diags:
        printDiagnostics diags
        return false
    var payload: str = ""
    for depIndex in 0..<resolvedDeps.len:
        let item: str = resolvedDeps[depIndex]
        if depIndex > 0:
            payload = payload + "\n"
        payload = payload + item
    if len outPath > 0:
        stage1_writeFile(outPath, payload)
    else:
        echo payload
    return true
