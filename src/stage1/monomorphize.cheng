fn monoZeroHashMapStrInt(): hashmaps.HashMapStrInt =
    var m: hashmaps.HashMapStrInt
    m.keys.buffer = nil
    m.keys.len = 0
    m.keys.cap = 0
    m.vals.buffer = nil
    m.vals.len = 0
    m.vals.cap = 0
    m.states.buffer = nil
    m.states.len = 0
    m.states.cap = 0
    m.mask = 0
    m.used = 0
    return m

fn mono_getenv(name: cstring): str =
    return os.GetEnvDefault(name, "")

fn monoStrEq(a: str, b: str): bool =
    return a == b

fn monoStrNe(a: str, b: str): bool =
    return a != b

fn monoStrPtrKey(s: str): int64 =
    s
    return 0

fn monoNodeEq(a: Node, b: Node): bool =
    return a == b

fn monoNodeNe(a: Node, b: Node): bool =
    return !monoNodeEq(a, b)

fn monoProfileEnabled(): bool =
    let v0: str = mono_getenv("STAGE1_MONO_PROFILE")
    if monoStrEq(v0, "1"):
        return true
    let v1: str = mono_getenv("STAGE1_PROFILE")
    return monoStrEq(v1, "1")

fn monoDebugProgressEnabled(): bool =
    if monoDebugProgressMode < int8(0):
        let v0: str = mono_getenv("STAGE1_MONO_DEBUG_PROGRESS")
        if monoStrEq(v0, "1"):
            monoDebugProgressMode = int8(1)
        else:
            let v1: str = mono_getenv("BACKEND_DEBUG_STAGE1_PIPE")
            if monoStrEq(v1, "1"):
                monoDebugProgressMode = int8(1)
            else:
                monoDebugProgressMode = int8(0)
    return monoDebugProgressMode == int8(1)

fn monoDebugProgress(msg: str) =
    if monoDebugProgressEnabled():
        let f: os.File = os.Get_stderr()
        os.WriteLine(f, "[mono] " + msg)
        os.C_fflush f

fn monoDebugInstantiateEnabled(): bool =
    if monoDebugInstantiateMode < int8(0):
        let v0: str = mono_getenv("STAGE1_MONO_DEBUG_INSTANTIATE")
        if monoStrEq(v0, "1"):
            monoDebugInstantiateMode = int8(1)
        else:
            monoDebugInstantiateMode = int8(0)
    return monoDebugInstantiateMode == int8(1)

fn monoDebugInstantiateWatchName(name: str): bool =
    let tail: str = monoDebugWatchTail(name)
    if monoStrEq(tail, "Err"):
        return true
    if monoStrEq(tail, "Ok"):
        return true
    if monoStrEq(tail, "ErrInfo"):
        return true
    if monoStrEq(tail, "Some"):
        return true
    if monoStrEq(tail, "None"):
        return true
    return false

fn monoDebugInstantiate(msg: str) =
    if monoDebugInstantiateEnabled():
        let f: os.File = os.Get_stderr()
        os.WriteLine(f, "[mono-inst] " + msg)
        os.C_fflush f

fn monoEagerContainerInstEnabled(): bool =
    if monoEagerContainerInstMode < int8(0):
        let v0: str = mono_getenv("STAGE1_EAGER_CONTAINER_INST")
        # Keep eager container instantiation enabled by default.
        # STAGE1_EAGER_CONTAINER_INST=0 can be used for local profiling only.
        if monoStrEq(v0, "0"):
            monoEagerContainerInstMode = int8(0)
        else:
            monoEagerContainerInstMode = int8(1)
    return monoEagerContainerInstMode == int8(1)

fn monoProfResetKinds() =
    monoProfExprKindNs.len = 0
    monoProfExprKindNs.len = int(monoNodeKindCount)
    monoProfExprKindCalls.len = 0
    monoProfExprKindCalls.len = int(monoNodeKindCount)

fn monoProfKindLabel(idx: int32): str =
    let kind: NodeKind = NodeKind(idx)
    case kind
    of nkCall:
        return "nkCall"
    of nkDotExpr:
        return "nkDotExpr"
    of nkBracketExpr:
        return "nkBracketExpr"
    of nkIdent:
        return "nkIdent"
    of nkSymbol:
        return "nkSymbol"
    of nkInfix:
        return "nkInfix"
    of nkPrefix:
        return "nkPrefix"
    of nkPostfix:
        return "nkPostfix"
    of nkPar:
        return "nkPar"
    of nkHiddenDeref:
        return "nkHiddenDeref"
    of nkDerefExpr:
        return "nkDerefExpr"
    else:
        return "nk#" + intToStr(idx)
    return "nk#" + intToStr(idx)

fn monoProfRecordExprKind(kind: NodeKind, deltaNs: int64) =
    if ! monoProfileActive:
        return
    let idx: int32 = int32(kind)
    if idx < 0 || idx >= monoProfExprKindNs.len:
        return
    var nsSeq: int64[] = monoProfExprKindNs
    let prevNs: int64 = get(monoProfExprKindNs, idx)
    nsSeq[idx] = prevNs + deltaNs
    monoProfExprKindNs = nsSeq
    var callsSeq: int32[] = monoProfExprKindCalls
    let prevCalls: int32 = get(monoProfExprKindCalls, idx)
    callsSeq[idx] = prevCalls + 1
    monoProfExprKindCalls = callsSeq

fn monoProfTopKinds(nsSeq: int64[], callsSeq: int32[], label: str): str =
    var top1Ns: int64
    var top2Ns: int64
    var top3Ns: int64
    var top1Idx: int32 = -1
    var top2Idx: int32 = -1
    var top3Idx: int32 = -1
    var top1Calls: int32
    var top2Calls: int32
    var top3Calls: int32
    for i in 0..<nsSeq.len:
        let v: int64 = get(nsSeq, i)
        if v > top1Ns:
            top3Ns = top2Ns
            top3Idx = top2Idx
            top3Calls = top2Calls
            top2Ns = top1Ns
            top2Idx = top1Idx
            top2Calls = top1Calls
            top1Ns = v
            top1Idx = i
            top1Calls = get(callsSeq, i)
        elif v > top2Ns:
            top3Ns = top2Ns
            top3Idx = top2Idx
            top3Calls = top2Calls
            top2Ns = v
            top2Idx = i
            top2Calls = get(callsSeq, i)
        elif v > top3Ns:
            top3Ns = v
            top3Idx = i
            top3Calls = get(callsSeq, i)
    if top1Ns <= 0:
        return ""
    var parts: str[]
    add(parts, label)
    let ms1: int32 = int32(top1Ns / 1000000)
    add(parts, " ")
    add(parts, monoProfKindLabel(top1Idx))
    add(parts, "=")
    add(parts, intToStr(ms1))
    add(parts, "ms(")
    add(parts, intToStr(top1Calls))
    add(parts, ")")
    if top2Ns > 0:
        let ms2: int32 = int32(top2Ns / 1000000)
        add(parts, " ")
        add(parts, monoProfKindLabel(top2Idx))
        add(parts, "=")
        add(parts, intToStr(ms2))
        add(parts, "ms(")
        add(parts, intToStr(top2Calls))
        add(parts, ")")
    if top3Ns > 0:
        let ms3: int32 = int32(top3Ns / 1000000)
        add(parts, " ")
        add(parts, monoProfKindLabel(top3Idx))
        add(parts, "=")
        add(parts, intToStr(ms3))
        add(parts, "ms(")
        add(parts, intToStr(top3Calls))
        add(parts, ")")
    return strutils.Join(parts, "")

fn transform(n: Node, rootStmts: Node[]*, inTypeContext: bool = false): Node

fn monoHashMapStrIntGetCompat(m: hashmaps.HashMapStrInt, key: str, found: var bool): int32 =
    return hashmaps.HashMapStrIntGet(m, key, found)

fn monoHashMapStrIntGetCompat(m: var hashmaps.HashMapStrInt, key: str, found: var bool): int32 =
    return hashmaps.HashMapStrIntGet(m, key, found)


fn monoIsNameChar(c: char): bool =
    if c >= 'a' && c <= 'z':
        return true
    if c >= 'A' && c <= 'Z':
        return true
    if c >= '0' && c <= '9':
        return true
    if c == '$':
        return true
    return c == '_'

fn monoHasUpperAlpha(s: str): bool =
    if len(s) == 0:
        return false
    for i in 0..<len s:
        let c: char = s[i]
        if c >= 'A' && c <= 'Z':
            return true
    return false

fn monoNameTailMatches(full: str, tail: str): bool =
    if len(full) == 0 || len(tail) == 0:
        return false
    if full == tail:
        return true
    let n: int32 = len full
    let m: int32 = len tail
    if m <= 0 || n <= m:
        return false
    let off: int32 = n - m
    for j in 0..<m:
        if full[off + j] != tail[j]:
            return false
    let prev: char = full[off - 1]
    return !monoIsNameChar(prev)

fn monoNameTail(full: str): str =
    if len(full) == 0:
        return ""
    let n: int32 = len full
    if n <= 0:
        return ""
    var cut: int32 = -1
    for i in 0..<n:
        if !monoIsNameChar(full[i]):
            cut = i
    if cut < 0:
        return full
    if cut >= n - 1:
        return ""
    return rawmemStrFromOffset(full, cut + 1)

fn genericFnHas(name: str): bool =
    if len name == 0:
        return false
    if monoHasChar(name, '_'):
        if ! genericFnHasUnderscore:
            return false
        if ! genericFnHasLowerUnderscore && ! monoHasUpperAlpha(name):
            return false
    var foundExact: bool
    let rawIdx: int32 = monoHashMapStrIntGetCompat(genericFnIndex, name, foundExact)
    if rawIdx > 0:
        let idx: int32 = rawIdx - 1
        if idx >= 0 && idx < genericFnNames.len && monoStrEq(get(genericFnNames, idx), name):
            return true
    var foundAlias: bool
    let rawAliasIdx: int32 = monoHashMapStrIntGetCompat(genericFnAliasIndex, name, foundAlias)
    if rawAliasIdx > 0:
        let aliasIdx: int32 = rawAliasIdx - 1
        if aliasIdx < 0 || aliasIdx >= genericFnNames.len:
            return false
        let fullName: str = get(genericFnNames, aliasIdx)
        if monoStrEq(monoNameTail(fullName), name):
            return true
    return false

fn genericFnGet(name: str): Node =
    if len name == 0:
        return astInvalidNodeId()
    if monoHasChar(name, '_'):
        if ! genericFnHasUnderscore:
            return astInvalidNodeId()
        if ! genericFnHasLowerUnderscore && ! monoHasUpperAlpha(name):
            return astInvalidNodeId()
    var foundExact: bool
    let rawIdx: int32 = monoHashMapStrIntGetCompat(genericFnIndex, name, foundExact)
    if rawIdx > 0:
        let idx: int32 = rawIdx - 1
        if idx >= 0 && idx < genericFnNodes.len && idx < genericFnNames.len:
            if monoStrEq(get(genericFnNames, idx), name):
                return get(genericFnNodes, idx)
    var foundAlias: bool
    let rawAliasIdx: int32 = monoHashMapStrIntGetCompat(genericFnAliasIndex, name, foundAlias)
    if rawAliasIdx > 0:
        let aliasIdx: int32 = rawAliasIdx - 1
        if aliasIdx >= 0 && aliasIdx < genericFnNodes.len && aliasIdx < genericFnNames.len:
            let fullName2: str = get(genericFnNames, aliasIdx)
            if monoStrEq(monoNameTail(fullName2), name):
                return get(genericFnNodes, aliasIdx)
    return astInvalidNodeId()

fn genericFnAdd(name: str, node: Node) =
    if len name == 0:
        return
    mapPutStrNode(genericFnNames, genericFnNodes, name, node)
    let newIdx: int32 = genericFnNames.len - 1
    hashmaps.HashMapStrIntPut(genericFnIndex, name, newIdx + 1)
    let tail: str = monoNameTail(name)
    if len(tail) > 0 && !monoStrEq(tail, name):
        var foundTail: bool
        let prevTail: int32 = monoHashMapStrIntGetCompat(genericFnAliasIndex, tail, foundTail)
        if prevTail == 0:
            hashmaps.HashMapStrIntPut(genericFnAliasIndex, tail, newIdx + 1)
        elif prevTail > 0 && prevTail != (newIdx + 1):
            hashmaps.HashMapStrIntPut(genericFnAliasIndex, tail, -1)
    if monoHasChar(name, '_'):
        genericFnHasUnderscore = true
        if ! monoHasUpperAlpha(name):
            genericFnHasLowerUnderscore = true

fn monoGenericFnFirstParamIsSeq(fnNode: Node): bool =
    if stage1AstRefIsNil(fnNode) || kidCount(fnNode) <= 1:
        return false
    let params: Node = kid(fnNode, 1)
    if stage1AstRefIsNil(params) || nodeKind(params) != nkFormalParams || kidCount(params) <= 0:
        return false
    let defs: Node = kid(params, 0)
    if stage1AstRefIsNil(defs) || nodeKind(defs) != nkIdentDefs || kidCount(defs) <= 1:
        return false
    var ty: Node = identDefsType(defs)
    while stage1AstRefNonNil(ty):
        if nodeKind(ty) == nkPar || nodeKind(ty) == nkVarTy || nodeKind(ty) == nkRefTy || nodeKind(ty) == nkPtrTy:
            if kidCount(ty) <= 0:
                break
            ty = kid(ty, 0)
            continue
        break
    if stage1AstRefIsNil(ty):
        return false
    if nodeKind(ty) == nkBracketExpr && kidCount(ty) > 0:
        let base: str = monoStripSpaces(plainName(kid(ty, 0)))
        return monoStrEq(base, "seq") || monoStrEq(base, "seq_fixed")
    if nodeKind(ty) == nkIdent || nodeKind(ty) == nkSymbol:
        let key: str = monoStripSpaces(plainName(ty))
        return monoStrEq(key, "seq") || monoStrEq(key, "seq_fixed") || monoStartsWith(key, "seq_") || monoStartsWith(key, "seq_fixed_")
    return false


fn collectGenericDecls(n: Node) =
    if stage1AstRefIsNil(n):
        return
    if nodeKind(n) == nkTypeDecl:
        let nameNode: Node = kid(n, 0)
        if stage1AstRefNonNil(nameNode):
            let nm: str = getName nameNode
            if len nm > 0 && ! mapHasStrIndex(monoTypeIndex, nm):
                mapPutStrNodeIndex(monoTypeIndex, monoTypeNames, monoTypeNodes, nm, n)
        if kidCount n > 2:
            let gens: Node = kid(n, 2)
            if stage1AstRefNonNil(gens) && nodeKind(gens) == nkGenericParams && kidCount gens > 0:
                if stage1AstRefNonNil(nameNode):
                    let nm2: str = getName nameNode
                    if len nm2 > 0 && ! mapHasStrIndex(genericTypeIndex, nm2):
                        mapPutStrNodeIndex(genericTypeIndex, genericTypeNames, genericTypeNodes, nm2, n)
    if nodeKind(n) == nkFnDecl || nodeKind(n) == nkIteratorDecl:
        if kidCount n > 4:
            let gens2: Node = kid(n, 4)
            if stage1AstRefNonNil(gens2) && nodeKind(gens2) == nkGenericParams && kidCount gens2 > 0:
                let nameNode2: Node = kid(n, 0)
                if stage1AstRefNonNil(nameNode2):
                    let nm2: str = getName nameNode2
                    if len nm2 > 0:
                        if ! genericFnHas(nm2):
                            genericFnAdd(nm2, n)
                        elif monoStrEq(nm2, "len"):
                            let prev: Node = genericFnGet(nm2)
                            if stage1AstRefNonNil(prev) && !monoGenericFnFirstParamIsSeq(prev) && monoGenericFnFirstParamIsSeq(n):
                                genericFnAdd(nm2, n)
    if nodeKind(n) == nkTraitDecl:
        let nameNode3: Node = kid(n, 0)
        if stage1AstRefNonNil(nameNode3):
            let nm3: str = getName nameNode3
            if len nm3 > 0 && ! mapHasStrIndex(traitIndex, nm3):
                mapPutStrNodeIndex(traitIndex, traitNames, traitNodes, nm3, n)
    if nodeKind(n) == nkConceptDecl:
        let nameNode4: Node = kid(n, 0)
        if stage1AstRefNonNil(nameNode4):
            let nm4: str = getName nameNode4
            if len nm4 > 0 && ! mapHasStrIndex(conceptIndex, nm4):
                mapPutStrNodeIndex(conceptIndex, conceptNames, conceptNodes, nm4, n)
    for i in 0..<kidCount n:
        collectGenericDecls kid(n, i)

fn vecClearStr(v: var str[]) =
    v.len = 0

fn vecClearNode(v: var Node[]) =
    v.len = 0

fn monoValueClear() =
    monoValueNames.len = 0
    monoValueTypes.len = 0
    monoValueScopeStarts.len = 0
    monoValuePrevIndexPlus1.len = 0
    hashmaps.HashMapStrIntClear(monoValueIndex)

fn monoValueScopePush() =
    add(monoValueScopeStarts, monoValueNames.len)

fn monoValueScopePop() =
    if monoValueScopeStarts.len <= 0:
        return
    let start: int32 = get(monoValueScopeStarts, monoValueScopeStarts.len - 1)
    monoValueScopeStarts.len = monoValueScopeStarts.len - 1
    let __for_start_i = monoValueNames.len - 1
    for __for_rev_i in 0..(__for_start_i - (start)):
        let i = __for_start_i - __for_rev_i
        let nm: str = get(monoValueNames, i)
        let prevIndexPlus1: int32 = get(monoValuePrevIndexPlus1, i)
        hashmaps.HashMapStrIntPut(monoValueIndex, nm, prevIndexPlus1)
    monoValueNames.len = start
    monoValueTypes.len = start
    monoValuePrevIndexPlus1.len = start

fn monoValueAdd(name: str, ty: Node) =
    if len(name) == 0 || monoStrEq(name, "_"):
        return
    if stage1AstRefIsNil(ty) || nodeKind(ty) == nkEmpty:
        return
    var found: bool
    let prevIndexPlus1: int32 = monoHashMapStrIntGetCompat(monoValueIndex, name, found)
    if found:
        add(monoValuePrevIndexPlus1, prevIndexPlus1)
    else:
        add(monoValuePrevIndexPlus1, int32(0))
    add(monoValueNames, name)
    add(monoValueTypes, ty)
    let idx: int32 = monoValueNames.len - 1
    hashmaps.HashMapStrIntPut(monoValueIndex, name, idx + 1)

fn monoValueLookup(name: str): Node =
    if len(name) == 0:
        return astInvalidNodeId()
    var found: bool
    let idxPlus1: int32 = monoHashMapStrIntGetCompat(monoValueIndex, name, found)
    if ! found || idxPlus1 <= 0:
        return astInvalidNodeId()
    let idx: int32 = idxPlus1 - 1
    if idx < 0 || idx >= monoValueTypes.len:
        return astInvalidNodeId()
    return get(monoValueTypes, idx)

fn monoNormalizeType(ty: Node): Node =
    if stage1AstRefIsNil(ty):
        return astInvalidNodeId()
    if nodeKind(ty) == nkVarTy && kidCount ty > 0:
        let inner: Node = monoNormalizeType kid(ty, 0)
        if inner != kid(ty, 0):
            var wrap: Node = newNode(nkVarTy, nodePos(ty))
            addSon(wrap, inner)
            return wrap
        return ty
    if nodeKind(ty) == nkIdent || nodeKind(ty) == nkSymbol:
        let nm: str = monoStripSpaces(plainName(ty))
        let inst: Node = mapGetStrNodeIndex(instTypeIndex, instTypeNodes, nm)
        if stage1AstRefNonNil(inst):
            return inst
    return ty

fn monoUnwrapParType(n: Node): Node =
    var cur: Node = n
    while stage1AstRefNonNil(cur) && nodeKind(cur) == nkPar && kidCount cur == 1:
        cur = kid(cur, 0)
    return cur

fn monoStripPtrRefVar(ty: Node): Node =
    var cur: Node = monoUnwrapParType ty
    while stage1AstRefNonNil(cur) && (nodeKind(cur) == nkVarTy || nodeKind(cur) == nkPtrTy || nodeKind(cur) == nkRefTy):
        if kidCount cur > 0:
            cur = monoUnwrapParType kid(cur, 0)
        else:
            break
    return cur

fn monoFieldClear() =
    monoFieldKeys.len = 0
    monoFieldTypes.len = 0
    hashmaps.HashMapStrIntClear(monoFieldIndex)

fn monoAddFieldType(owner: str, fieldName: str, typeNode: Node) =
    if len(owner) == 0 || len(fieldName) == 0 || stage1AstRefIsNil(typeNode):
        return
    let key: str = monoFieldKey(owner, fieldName)
    var found: bool
    let idxPlus1: int32 = monoHashMapStrIntGetCompat(monoFieldIndex, key, found)
    if found && idxPlus1 > 0:
        return
    add(monoFieldKeys, key)
    add(monoFieldTypes, typeNode)
    let idx: int32 = monoFieldKeys.len - 1
    hashmaps.HashMapStrIntPut(monoFieldIndex, key, idx + 1)

fn monoLookupFieldType(owner: str, fieldName: str): Node =
    if len(owner) == 0 || len(fieldName) == 0:
        return astInvalidNodeId()
    let key: str = monoFieldKey(owner, fieldName)
    var found: bool
    let idxPlus1: int32 = monoHashMapStrIntGetCompat(monoFieldIndex, key, found)
    if found && idxPlus1 > 0 && idxPlus1 <= monoFieldTypes.len:
        return get(monoFieldTypes, idxPlus1 - 1)
    return astInvalidNodeId()

fn monoTypeDeclObjectDef(def: Node): Node =
    if stage1AstRefIsNil(def):
        return astInvalidNodeId()
    let cur: Node = monoUnwrapParType def
    if stage1AstRefIsNil(cur):
        return astInvalidNodeId()
    if nodeKind(cur) == nkObjectDecl:
        return cur
    if nodeKind(cur) == nkRefTy || nodeKind(cur) == nkPtrTy || nodeKind(cur) == nkVarTy:
        if kidCount cur > 0:
            let base: Node = monoUnwrapParType kid(cur, 0)
            if stage1AstRefNonNil(base) && nodeKind(base) == nkObjectDecl:
                return base
    return astInvalidNodeId()

fn monoCollectRecListFieldTypes(owner: str, recList: Node) =
    if len(owner) == 0 || stage1AstRefIsNil(recList):
        return
    for i in 0..<kidCount recList:
        let entry: Node = kid(recList, i)
        if stage1AstRefNonNil(entry) && nodeKind(entry) == nkIdentDefs:
            let typeNode: Node = identDefsType entry
            let nameCount: int32 = identDefsNameCount entry
            for j in 0..<nameCount:
                var nameNode: Node = kid(entry, j)
                if stage1AstRefNonNil(nameNode) && nodeKind(nameNode) == nkPattern && kidCount nameNode > 0:
                    nameNode = kid(nameNode, 0)
                if stage1AstRefNonNil(nameNode):
                    let fieldName: str = monoStripSpaces(plainName(nameNode))
                    if len fieldName > 0:
                        monoAddFieldType(owner, fieldName, typeNode)
        elif stage1AstRefNonNil(entry) && nodeKind(entry) == nkRecCase:
            if kidCount entry > 0:
                let caseDefs: Node = kid(entry, 0)
                if stage1AstRefNonNil(caseDefs) && nodeKind(caseDefs) == nkIdentDefs:
                    let tagType: Node = identDefsType caseDefs
                    let tagCount: int32 = identDefsNameCount caseDefs
                    for tj in 0..<tagCount:
                        var tagName: Node = kid(caseDefs, tj)
                        if stage1AstRefNonNil(tagName) && nodeKind(tagName) == nkPattern && kidCount tagName > 0:
                            tagName = kid(tagName, 0)
                        if stage1AstRefNonNil(tagName):
                            let name: str = monoStripSpaces(plainName(tagName))
                            if len name > 0:
                                monoAddFieldType(owner, name, tagType)
            for bi in 1..<kidCount entry:
                let branch: Node = kid(entry, bi)
                var body: Node = astInvalidNodeId()
                if stage1AstRefNonNil(branch) && nodeKind(branch) == nkOfBranch && kidCount branch > 1:
                    body = kid(branch, 1)
                elif stage1AstRefNonNil(branch) && nodeKind(branch) == nkElse && kidCount branch > 0:
                    body = kid(branch, 0)
                if stage1AstRefNonNil(body) && nodeKind(body) == nkRecList:
                    monoCollectRecListFieldTypes(owner, body)

fn monoCollectObjectFieldTypes(owner: str, objDef: Node) =
    if len(owner) == 0 || stage1AstRefIsNil(objDef):
        return
    var recList: Node = astInvalidNodeId()
    if kidCount objDef > 1:
        recList = kid(objDef, 1)
    if stage1AstRefIsNil(recList):
        return
    monoCollectRecListFieldTypes(owner, recList)

fn monoCollectFieldTypes(n: Node) =
    if stage1AstRefIsNil(n):
        return
    if nodeKind(n) == nkTypeDecl:
        let nameNode: Node = kid(n, 0)
        let owner: str = getName nameNode
        if kidCount n > 1 && len owner > 0:
            let defNode: Node = kid(n, 1)
            let objDef: Node = monoTypeDeclObjectDef(defNode)
            if stage1AstRefNonNil(objDef):
                monoCollectObjectFieldTypes(owner, objDef)
    for i in 0..<kidCount n:
        monoCollectFieldTypes kid(n, i)

fn monoLookupExprType(n: Node): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    let profOn: bool = monoProfileActive
    let profKind: NodeKind = nodeKind(n)
    var startNs: int64
    if profOn:
        monoLookupExprTypeCalls = monoLookupExprTypeCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            let deltaNs: int64 = cheng_monotime_ns() - startNs
            monoLookupExprTypeNs = monoLookupExprTypeNs + deltaNs
            monoProfRecordExprKind(profKind, deltaNs)
    if nodeKind(n) == nkPar && kidCount n == 1:
        return monoLookupExprType kid(n, 0)
    if nodeKind(n) == nkDotExpr && kidCount n > 1:
        let base: Node = kid(n, 0)
        let member: Node = kid(n, 1)
        let baseType0: Node = monoLookupExprType base
        var baseType: Node = monoStripPtrRefVar(monoNormalizeType(baseType0))
        let owner: str = monoTypeOwnerName(baseType)
        if len owner > 0 && stage1AstRefNonNil(member):
            let fieldName: str = monoStripSpaces(plainName(member))
            let fieldTy: Node = monoLookupFieldType(owner, fieldName)
            if stage1AstRefNonNil(fieldTy) && nodeKind(fieldTy) != nkEmpty:
                return fieldTy
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        let nm: str = monoStripSpaces(plainName(n))
        return monoNormalizeType(monoValueLookup(nm))
    if nodeKind(n) == nkBracketExpr:
        if kidCount n == 1:
            let baseTy: Node = monoNormalizeType(monoLookupExprType(kid(n, 0)))
            if stage1AstRefNonNil(baseTy) && (nodeKind(baseTy) == nkPtrTy || nodeKind(baseTy) == nkRefTy || nodeKind(baseTy) == nkVarTy) && kidCount baseTy > 0:
                return monoNormalizeType(kid(baseTy, 0))
        elif kidCount n > 1:
            let baseTy0: Node = monoLookupExprType(kid(n, 0))
            let baseTy: Node = monoStripPtrRefVar(monoNormalizeType(baseTy0))
            if stage1AstRefNonNil(baseTy) && nodeKind(baseTy) == nkBracketExpr && kidCount baseTy > 1:
                let baseName: str = monoStripSpaces(plainName(kid(baseTy, 0)))
                if monoStrEq(baseName, "seq") || monoStrEq(baseName, "seq_fixed"):
                    return monoNormalizeType(kid(baseTy, 1))
    if nodeKind(n) == nkCall && kidCount n > 0:
        let head: Node = kid(n, 0)
        var headNameNode: Node = head
        if stage1AstRefNonNil(head) && nodeKind(head) == nkDotExpr && kidCount head > 1:
            headNameNode = kid(head, 1)
        elif stage1AstRefNonNil(head) && nodeKind(head) == nkBracketExpr && kidCount head > 0:
            let h0: Node = kid(head, 0)
            headNameNode = h0
            if stage1AstRefNonNil(h0) && nodeKind(h0) == nkDotExpr && kidCount h0 > 1:
                headNameNode = kid(h0, 1)
        if stage1AstRefNonNil(headNameNode) && (nodeKind(headNameNode) == nkIdent || nodeKind(headNameNode) == nkSymbol):
            let nm2: str = monoStripSpaces(plainName(headNameNode))
            if monoStrEq(nm2, "new") && kidCount(n) > 1:
                let newTy: Node = monoInferNewResultType(monoCallArgValue(kid(n, 1)))
                if stage1AstRefNonNil(newTy) && nodeKind(newTy) != nkEmpty:
                    return monoNormalizeType(newTy)
            let retTy: Node = mapGetStrNodeIndex(monoFnRetIndex, monoFnRetTypes, nm2)
            if stage1AstRefNonNil(retTy) && nodeKind(retTy) != nkEmpty:
                return monoNormalizeType(retTy)
    return astInvalidNodeId()

fn monoBindNameWithType(nameNode: Node, ty: Node) =
    if stage1AstRefIsNil(nameNode):
        return
    if nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol:
        let nm: str = monoStripSpaces(plainName(nameNode))
        monoValueAdd(nm, ty)
        return
    if nodeKind(nameNode) == nkPattern && kidCount nameNode > 0:
        monoBindNameWithType(kid(nameNode, 0), ty)

fn monoBindFormalParams(paramsNode: Node) =
    if stage1AstRefIsNil(paramsNode) || nodeKind(paramsNode) != nkFormalParams:
        return
    for i in 0..<kidCount paramsNode:
        let defs: Node = kid(paramsNode, i)
        if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount defs >= 2:
            let typeNode: Node = identDefsType(defs)
            for j in 0..<identDefsNameCount(defs):
                monoBindNameWithType(kid(defs, j), typeNode)

fn monoFirstParamType(fnNode: Node): Node =
    if stage1AstRefIsNil(fnNode):
        return astInvalidNodeId()
    if kidCount fnNode > 1:
        let paramsNode: Node = kid(fnNode, 1)
        if stage1AstRefNonNil(paramsNode) && nodeKind(paramsNode) == nkFormalParams && kidCount paramsNode > 0:
            let defs: Node = kid(paramsNode, 0)
            if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount defs > 1:
                return identDefsType(defs)
    return astInvalidNodeId()

fn monoFnSetClear() =
    monoZeroArgFnNames.len = 0
    monoOneArgFnNames.len = 0
    monoOneArgFnParamNames.len = 0
    monoOneArgFnParamTypes.len = 0
    monoFnRetNames.len = 0
    monoFnRetTypes.len = 0
    hashmaps.HashMapStrIntClear(monoZeroArgFnIndex)
    hashmaps.HashMapStrIntClear(monoOneArgFnIndex)
    hashmaps.HashMapStrIntClear(monoFnRetIndex)

fn monoFnSetAdd(v: var str[], name: str, index: var hashmaps.HashMapStrInt) =
    if len(name) == 0:
        return
    var found: bool
    let idxPlus1: int32 = monoHashMapStrIntGetCompat(index, name, found)
    if found && idxPlus1 > 0:
        return
    add(v, name)
    let idx: int32 = v.len - 1
    hashmaps.HashMapStrIntPut(index, name, idx + 1)

fn monoFnSetAdd(v: var str[], name: str) =
    if len(name) == 0:
        return
    if monoSeqStrHas(v, name):
        return
    add(v, name)

fn monoFnRetAdd(name: str, ty: Node) =
    if len(name) == 0:
        return
    if stage1AstRefIsNil(ty) || nodeKind(ty) == nkEmpty:
        return
    var found: bool
    let prevIdx: int32 = monoHashMapStrIntGetCompat(monoFnRetIndex, name, found)
    if found:
        if prevIdx >= 0:
            hashmaps.HashMapStrIntPut(monoFnRetIndex, name, -1)
        return
    mapPutStrNodeIndex(monoFnRetIndex, monoFnRetNames, monoFnRetTypes, name, ty)

fn monoFnHasArity(name: str, arity: int32): bool =
    if len(name) == 0:
        return false
    if arity == 0:
        if monoZeroArgFnIndex.mask != 0:
            var found: bool
            let idxPlus1: int32 = monoHashMapStrIntGetCompat(monoZeroArgFnIndex, name, found)
            return found && idxPlus1 > 0
        return monoSeqStrHas(monoZeroArgFnNames, name)
    if arity == 1:
        if monoOneArgFnIndex.mask != 0:
            var found: bool
            let idxPlus1: int32 = monoHashMapStrIntGetCompat(monoOneArgFnIndex, name, found)
            return found && idxPlus1 > 0
        return monoSeqStrHas(monoOneArgFnNames, name)
    return false

fn monoFnParamAdd(name: str, ty: Node) =
    if len(name) == 0:
        return
    if stage1AstRefIsNil(ty) || nodeKind(ty) == nkEmpty:
        return
    add(monoOneArgFnParamNames, name)
    add(monoOneArgFnParamTypes, ty)

fn monoStripVarType(ty: Node): Node =
    if stage1AstRefNonNil(ty) && nodeKind(ty) == nkVarTy && kidCount ty > 0:
        return kid(ty, 0)
    return ty

fn monoTypeKeyNorm(ty: Node): str =
    let norm: Node = monoNormalizeType ty
    return typeKey norm

fn monoTypeMatches(paramTy: Node, baseTy: Node): bool =
    if stage1AstRefIsNil(paramTy) || stage1AstRefIsNil(baseTy):
        return false
    if paramTy == baseTy:
        return true
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        monoTypeMatchesCalls = monoTypeMatchesCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            monoTypeMatchesNs = monoTypeMatchesNs + (cheng_monotime_ns() - startNs)
    let baseNorm: Node = monoNormalizeType baseTy
    let paramNorm: Node = monoNormalizeType paramTy
    let baseKey: str = typeKey baseNorm
    let paramKey: str = typeKey paramNorm
    if len paramKey > 0 && paramKey == baseKey:
        return true
    let paramStripKey: str = monoStripVarTypeKey(paramTy, paramKey)
    if len paramStripKey > 0 && paramStripKey == baseKey:
        return true
    let baseStripKey: str = monoStripVarTypeKey(baseTy, baseKey)
    if len paramKey > 0 && paramKey == baseStripKey:
        return true
    if len paramStripKey > 0 && paramStripKey == baseStripKey:
        return true
    return false

fn monoStartsWith(s: str, prefix: str): bool =
    if len(s) == 0 || len(prefix) == 0:
        if len(prefix) == 0:
            return true
        return false
    let n: int32 = len s
    let m: int32 = len prefix
    if m == 0:
        return true
    if n < m:
        return false
    for i in 0..<m:
        if s[i] != prefix[i]:
            return false
    return true

fn monoHasChar(s: str, ch: char): bool =
    if len(s) == 0:
        return false
    let n: int32 = len s
    for i in 0..<n:
        if s[i] == ch:
            return true
    return false

fn monoFirstUnderscorePos(name: str): int32 =
    if len(name) == 0:
        return -1
    let n: int32 = len name
    var cached: bool
    let cachedPlus2: int32 = hashmaps.HashMapStrIntGetEx(monoUnderscoreIndex, name, cached)
    if cached && cachedPlus2 > 0:
        return cachedPlus2 - 2
    for i in 0..<n:
        if name[i] == '_':
            let stored: int32 = i + 2
            hashmaps.HashMapStrIntPut(monoUnderscoreIndex, name, stored)
            return i
    hashmaps.HashMapStrIntPut(monoUnderscoreIndex, name, 1)
    return -1

fn monoSliceRange(s: str, start: int32, stop: int32): str =
    if len(s) == 0:
        return ""
    if start < 0:
        return ""
    if stop < start:
        return ""
    let n: int32 = len s
    if start >= n:
        return ""
    var endIdx: int32 = stop
    if endIdx >= n:
        endIdx = n - 1
    let count: int32 = endIdx - start + 1
    return strings.SliceBytes(s, start, count)

fn monoDropPrefix(s: str, prefixLen: int32): str =
    if len(s) == 0:
        return ""
    let n: int32 = len s
    if prefixLen <= 0:
        return s
    if prefixLen >= n:
        return ""
    return strings.SliceBytes(s, prefixLen, n - prefixLen)

fn monoStripDotSuffix(s: str): str =
    if len(s) == 0:
        return ""
    let n: int32 = len s
    for i in 0..<n:
        if s[i] == '.':
            if i == 0:
                return ""
            return monoSliceRange(s, 0, i - 1)
    return s

fn monoDummyPos(): SourcePos =
    var pos: SourcePos
    pos.line = 0
    pos.col = 0
    return pos

fn monoIsBuiltinTypeKey(key: str): bool =
    if monoStrEq(key, "int") || monoStrEq(key, "int8") || monoStrEq(key, "int16") || monoStrEq(key, "int32") || monoStrEq(key, "int64"):
        return true
    if monoStrEq(key, "uint") || monoStrEq(key, "uint8") || monoStrEq(key, "uint16") || monoStrEq(key, "uint32") || monoStrEq(key, "uint64"):
        return true
    if monoStrEq(key, "bool") || monoStrEq(key, "char"):
        return true
    if monoStrEq(key, "float") || monoStrEq(key, "float32") || monoStrEq(key, "float64"):
        return true
    if monoStrEq(key, "str") || monoStrEq(key, "cstring"):
        return true
    if monoStrEq(key, "void"):
        return true
    return false

fn monoIsValidTypeKey(key: str): bool =
    if monoStrEq(key, ""):
        return false
    var found: bool
    let cached: int32 = monoHashMapStrIntGetCompat(monoTypeKeyValidIndex, key, found)
    if found:
        return cached != 0
    var ok: bool
    if monoIsBuiltinTypeKey(key):
        ok = true
    elif monoStartsWith(key, "ptr_"):
        ok = monoIsValidTypeKey(monoDropPrefix(key, 4))
    elif monoStartsWith(key, "ref_"):
        ok = monoIsValidTypeKey(monoDropPrefix(key, 4))
    elif monoStartsWith(key, "var_"):
        ok = monoIsValidTypeKey(monoDropPrefix(key, 4))
    elif monoStartsWith(key, "set_"):
        ok = monoIsValidTypeKey(monoDropPrefix(key, 4))
    elif monoStartsWith(key, "seq_"):
        ok = monoIsValidTypeKey(monoDropPrefix(key, 4))
    elif monoStartsWith(key, "Table_"):
        ok = monoIsValidTypeKey(monoDropPrefix(key, 6))
    elif monoStartsWith(key, "__cheng_tables_Entry_"):
        ok = monoIsValidTypeKey(monoDropPrefix(key, 22))
    elif mapHasStrIndex(monoTypeIndex, key):
        ok = true
    elif mapHasStrIndex(instTypeIndex, key):
        ok = true
    elif mapHasStrIndex(genericTypeIndex, key):
        ok = true
    if ok:
        hashmaps.HashMapStrIntPut(monoTypeKeyValidIndex, key, 1)
    return ok

fn monoTypeNodeFromKey(key: str): Node =
    if monoStrEq(key, ""):
        return astInvalidNodeId()
    var found: bool
    let cachedIdx: int32 = monoHashMapStrIntGetCompat(monoTypeNodeIndex, key, found)
    if found && cachedIdx >= 0 && cachedIdx < monoTypeNodeValues.len:
        return get(monoTypeNodeValues, cachedIdx)
    let pos: SourcePos = monoDummyPos()
    var out: Node = astInvalidNodeId()
    if monoStartsWith(key, "ptr_"):
        let rest: str = monoDropPrefix(key, 4)
        var n: Node = newNode(nkPtrTy, pos)
        var base: Node = monoTypeNodeFromKey(rest)
        if stage1AstRefIsNil(base):
            base = newIdent("void", pos)
        addSon(n, base)
        out = n
    elif monoStartsWith(key, "ref_"):
        let rest2: str = monoDropPrefix(key, 4)
        var n2: Node = newNode(nkRefTy, pos)
        var base2: Node = monoTypeNodeFromKey(rest2)
        if stage1AstRefIsNil(base2):
            base2 = newIdent("void", pos)
        addSon(n2, base2)
        out = n2
    elif monoStartsWith(key, "var_"):
        let rest3: str = monoDropPrefix(key, 4)
        var n3: Node = newNode(nkVarTy, pos)
        var base3: Node = monoTypeNodeFromKey(rest3)
        if stage1AstRefIsNil(base3):
            base3 = newIdent("void", pos)
        addSon(n3, base3)
        out = n3
    elif monoStartsWith(key, "seq_"):
        let rest4: str = monoDropPrefix(key, 4)
        var n4: Node = newNode(nkBracketExpr, pos)
        addSon(n4, newIdent("seq", pos))
        if len rest4 > 0:
            addSon(n4, monoTypeNodeFromKey(rest4))
        out = n4
    elif monoStartsWith(key, "Table_"):
        let rest5: str = monoDropPrefix(key, 6)
        var n5: Node = newNode(nkBracketExpr, pos)
        addSon(n5, newIdent("Table", pos))
        if len rest5 > 0:
            addSon(n5, monoTypeNodeFromKey(rest5))
        out = n5
    elif monoStartsWith(key, "__cheng_tables_Entry_"):
        let rest6: str = monoDropPrefix(key, 22)
        var n6: Node = newNode(nkBracketExpr, pos)
        addSon(n6, newIdent("__cheng_tables_Entry", pos))
        if len rest6 > 0:
            addSon(n6, monoTypeNodeFromKey(rest6))
        out = n6
    else:
        out = newIdent(key, pos)
    if out != nil:
        add(monoTypeNodeValues, out)
        let outIdx: int32 = monoTypeNodeValues.len - 1
        hashmaps.HashMapStrIntPut(monoTypeNodeIndex, key, outIdx)
    return out

fn monoMaybeInstantiateMangledFnName(n: Node, rootStmts: Node[]*) =
    if stage1AstRefIsNil(n) || rootStmts == nil:
        return
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return
    if genericFnNames.len == 0:
        return
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        monoMaybeCalls = monoMaybeCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            monoMaybeNs = monoMaybeNs + (cheng_monotime_ns() - startNs)
    let name: str = monoStripSpaces(plainName(n))
    if len(name) == 0:
        return
    let nameLen: int32 = len name
    let scanAll: bool
    let firstIdx: int32 = monoFirstUnderscorePos(name)
    if firstIdx < 0:
        return
    if ! scanAll:
        if profOn:
            monoMaybeScans = monoMaybeScans + 1
        if firstIdx > 0:
            let base: str = monoSliceRange(name, 0, firstIdx - 1)
            if len base > 0:
                let baseLen: int32 = firstIdx
                let genNode: Node = genericFnGet(base)
                if stage1AstRefNonNil(genNode):
                    var generics: Node = astInvalidNodeId()
                    if kidCount genNode > 4:
                        generics = kid(genNode, 4)
                    if stage1AstRefNonNil(generics) && nodeKind(generics) == nkGenericParams && kidCount generics == 1:
                        let rest0: str = monoDropPrefix(name, baseLen + 1)
                        let rest: str = monoStripDotSuffix(rest0)
                        if len rest > 0 && monoIsValidTypeKey(rest):
                            let arg0: Node = monoTypeNodeFromKey(rest)
                            if stage1AstRefNonNil(arg0):
                                var args: Node[1]
                                add(args, arg0)
                                instantiateFn(base, args, rootStmts)
        return
    for i in firstIdx..<nameLen:
        if name[i] == '_':
            if profOn:
                monoMaybeScans = monoMaybeScans + 1
            if i > 0:
                let base: str = monoSliceRange(name, 0, i - 1)
                if len base > 0:
                    let baseLen: int32 = i
                    let genNode: Node = genericFnGet(base)
                    if stage1AstRefNonNil(genNode):
                        var generics: Node = astInvalidNodeId()
                        if kidCount genNode > 4:
                            generics = kid(genNode, 4)
                        if stage1AstRefNonNil(generics) && nodeKind(generics) == nkGenericParams && kidCount generics == 1:
                            let rest0: str = monoDropPrefix(name, baseLen + 1)
                            let rest: str = monoStripDotSuffix(rest0)
                            if len rest > 0 && monoIsValidTypeKey(rest):
                                let arg0: Node = monoTypeNodeFromKey(rest)
                                if stage1AstRefNonNil(arg0):
                                    var args: Node[1]
                                    add(args, arg0)
                                    instantiateFn(base, args, rootStmts)

fn monoFnOneArgMatches(name: str, baseTy: Node): bool =
    if len(name) == 0 || stage1AstRefIsNil(baseTy):
        return false
    let __for_start_i = monoOneArgFnParamNames.len - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if monoStrEq(get(monoOneArgFnParamNames, i), name):
            let paramTy: Node = get(monoOneArgFnParamTypes, i)
            if monoTypeMatches(paramTy, baseTy):
                return true
    return false

fn monoBracketBaseName(ty: Node): str =
    if stage1AstRefIsNil(ty) || nodeKind(ty) != nkBracketExpr || kidCount ty == 0:
        return ""
    return monoStripSpaces(plainName(kid(ty, 0)))

fn fnParamCount(paramsNode: Node): int32 =
    if stage1AstRefIsNil(paramsNode) || nodeKind(paramsNode) != nkFormalParams:
        return 0
    return kidCount paramsNode

fn monoInferGenericArgsFromCall(fnNode: Node, callNode: Node, outArgs: var Node[]): bool =
    if stage1AstRefIsNil(fnNode) || stage1AstRefIsNil(callNode):
        return false
    var generics: Node = astInvalidNodeId()
    if kidCount fnNode > 4:
        generics = kid(fnNode, 4)
    if stage1AstRefIsNil(generics) || nodeKind(generics) != nkGenericParams || kidCount generics == 0:
        return false
    var paramNames: str[4]
    collectGenericParamNames(generics, paramNames)
    var mapNames: str[4]
    var mapTypes: Node[4]
    var paramTypes: Node[4]
    fnParamTypes(fnNode, paramTypes)
    var paramIndex: int32
    for argIndex in 1..<kidCount callNode:
        if paramIndex >= paramTypes.len:
            break
        var argNode: Node = kid(callNode, argIndex)
        if stage1AstRefNonNil(argNode) && nodeKind(argNode) == nkCallArg && kidCount argNode > 1:
            argNode = kid(argNode, 1)
        var actualTy: Node = monoLookupExprType argNode
        let paramTy: Node = get(paramTypes, paramIndex)
        if stage1AstRefNonNil(actualTy) && stage1AstRefNonNil(paramTy):
            var actualAdj: Node = actualTy
            if stage1AstRefNonNil(actualAdj) && (nodeKind(actualAdj) == nkIdent || nodeKind(actualAdj) == nkSymbol):
                let key: str = typeKey actualAdj
                let parsed: Node = monoTypeNodeFromKey(key)
                if stage1AstRefNonNil(parsed) && nodeKind(parsed) != nkIdent && nodeKind(parsed) != nkSymbol:
                    actualAdj = parsed
            if nodeKind(paramTy) == nkVarTy && nodeKind(actualAdj) != nkVarTy:
                var wrap: Node = newNode(nkVarTy, nodePos(callNode))
                addSon(wrap, actualAdj)
                actualAdj = wrap
            let pCore: Node = monoStripVarType paramTy
            let aCore: Node = monoStripVarType actualAdj
            if stage1AstRefNonNil(pCore) && nodeKind(pCore) == nkBracketExpr:
                if stage1AstRefIsNil(aCore) || nodeKind(aCore) != nkBracketExpr:
                    actualAdj = astInvalidNodeId()
                else:
                    let pBase: str = monoBracketBaseName pCore
                    let aBase: str = monoBracketBaseName aCore
                    if len pBase > 0 && len aBase > 0 && pBase != aBase:
                        actualAdj = astInvalidNodeId()
            if stage1AstRefNonNil(actualAdj):
                bindTypeVars(paramTy, actualAdj, paramNames, mapNames, mapTypes)
        paramIndex = paramIndex + 1
    var emptyArgs: Node[]
    buildFullTypeArgs(generics, mapNames, mapTypes, emptyArgs, outArgs)
    return outArgs.len == kidCount generics

fn monoMaybeLowerAssignToEqCall(lhs0: Node, rhs0: Node, rootStmts: Node[]*): Node =
    if stage1AstRefIsNil(lhs0) || stage1AstRefIsNil(rhs0) || rootStmts == nil:
        return astInvalidNodeId()
    var lhs: Node = lhs0
    while stage1AstRefNonNil(lhs) && nodeKind(lhs) == nkPar && kidCount(lhs) > 0:
        lhs = kid(lhs, 0)
    # Indexed assignment lowers through `[]=`; do not rewrite into `=`.
    if stage1AstRefNonNil(lhs) && nodeKind(lhs) == nkBracketExpr && kidCount(lhs) > 1:
        return astInvalidNodeId()
    # Prefer explicit simple lvalues for assignment overloads.
    if stage1AstRefIsNil(lhs) || (nodeKind(lhs) != nkIdent && nodeKind(lhs) != nkSymbol):
        return astInvalidNodeId()
    var genNode: Node = genericFnGet("=")
    if stage1AstRefIsNil(genNode) && genericFnHas("="):
        genNode = findGenericFnDecl(monoRoot, "=")
        if stage1AstRefNonNil(genNode):
            genericFnAdd("=", genNode)
    if stage1AstRefIsNil(genNode):
        return astInvalidNodeId()
    var probeCall: Node = newNode(nkCall, nodePos(lhs))
    addSon(probeCall, newIdent("=", nodePos(lhs)))
    addSon(probeCall, lhs0)
    addSon(probeCall, rhs0)
    var instArgs: Node[4]
    if !monoInferGenericArgsFromCall(genNode, probeCall, instArgs):
        return astInvalidNodeId()
    let instName: str = mangleInstance("=", instArgs)
    if !instantiateFn("=", instArgs, rootStmts):
        return astInvalidNodeId()
    var callNode: Node = newNode(nkCall, nodePos(lhs))
    addSon(callNode, newIdent(instName, nodePos(lhs)))
    addSon(callNode, lhs0)
    addSon(callNode, rhs0)
    return callNode

fn collectFnArities(n: Node) =
    if stage1AstRefIsNil(n):
        return
    if nodeKind(n) == nkFnDecl || nodeKind(n) == nkIteratorDecl:
        var generics: Node = astInvalidNodeId()
        if kidCount n > 4:
            generics = kid(n, 4)
        if stage1AstRefIsNil(generics) || nodeKind(generics) != nkGenericParams || kidCount generics == 0:
            let nameNode: Node = kid(n, 0)
            let paramsNode: Node = kid(n, 1)
            let pname: str = getName nameNode
            let count: int32 = fnParamCount paramsNode
            if count == 0:
                monoFnSetAdd(monoZeroArgFnNames, pname, monoZeroArgFnIndex)
            elif count == 1:
                monoFnSetAdd(monoOneArgFnNames, pname, monoOneArgFnIndex)
                if stage1AstRefNonNil(paramsNode) && kidCount paramsNode > 0:
                    let defs: Node = kid(paramsNode, 0)
                    if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount defs > 1:
                        monoFnParamAdd(pname, identDefsType(defs))
            if kidCount n > 2:
                let retTy: Node = kid(n, 2)
                monoFnRetAdd(pname, retTy)
    for i in 0..<kidCount n:
        collectFnArities kid(n, i)

fn monoCallHeadName(callNode: Node): str =
    if stage1AstRefIsNil(callNode) || nodeKind(callNode) != nkCall || kidCount callNode == 0:
        return ""
    let head: Node = kid(callNode, 0)
    if stage1AstRefIsNil(head):
        return ""
    var headNameNode: Node = head
    if nodeKind(head) == nkDotExpr && kidCount head > 1:
        headNameNode = kid(head, 1)
    elif nodeKind(head) == nkBracketExpr && kidCount head > 0:
        let h0: Node = kid(head, 0)
        headNameNode = h0
        if stage1AstRefNonNil(h0) && nodeKind(h0) == nkDotExpr && kidCount h0 > 1:
            headNameNode = kid(h0, 1)
    if stage1AstRefNonNil(headNameNode) && (nodeKind(headNameNode) == nkIdent || nodeKind(headNameNode) == nkSymbol):
        return monoStripSpaces(plainName(headNameNode))
    return ""

fn monoCallArgValue(argNode0: Node): Node =
    var argNode: Node = argNode0
    if stage1AstRefNonNil(argNode) && nodeKind(argNode) == nkCallArg:
        if kidCount(argNode) > 1:
            argNode = kid(argNode, 1)
        elif kidCount(argNode) > 0:
            argNode = kid(argNode, 0)
    while stage1AstRefNonNil(argNode) && nodeKind(argNode) == nkPar && kidCount(argNode) == 1:
        argNode = kid(argNode, 0)
    return argNode

fn monoTypeDeclDefByName(name: str): Node =
    if len(name) == 0:
        return astInvalidNodeId()
    var decl: Node = mapGetStrNodeIndex(monoTypeIndex, monoTypeNodes, name)
    if stage1AstRefIsNil(decl):
        decl = monoGenericTypeGet(name)
    if stage1AstRefNonNil(decl) && kidCount(decl) > 1:
        return kid(decl, 1)
    return astInvalidNodeId()

fn monoTypeExprReturnsRefLikeValue(ty0: Node): bool =
    let ty: Node = monoUnwrapParType(monoNormalizeType(ty0))
    if stage1AstRefIsNil(ty):
        return false
    if nodeKind(ty) == nkRefTy || nodeKind(ty) == nkPtrTy || nodeKind(ty) == nkVarTy:
        return true
    let baseName: str = monoTypeExprBaseName(ty)
    if len(baseName) == 0:
        return false
    let defNode: Node = monoUnwrapParType(monoTypeDeclDefByName(baseName))
    if stage1AstRefNonNil(defNode) &&
       (nodeKind(defNode) == nkRefTy || nodeKind(defNode) == nkPtrTy || nodeKind(defNode) == nkVarTy):
        return true
    return false

fn monoInferNewResultType(allocTypeNode0: Node): Node =
    let allocTypeNode: Node = monoUnwrapParType(monoNormalizeType(allocTypeNode0))
    if stage1AstRefIsNil(allocTypeNode):
        return astInvalidNodeId()
    if monoTypeExprReturnsRefLikeValue(allocTypeNode):
        return cloneTree(allocTypeNode)
    var out: Node = newNode(nkRefTy, nodePos(allocTypeNode))
    addSon(out, cloneTree(allocTypeNode))
    return out

fn monoInferBindTypeFromInitCall(initNode: Node): Node =
    if stage1AstRefIsNil(initNode) || nodeKind(initNode) != nkCall:
        return astInvalidNodeId()
    let calleeName: str = monoCallHeadName(initNode)
    if len calleeName == 0:
        return astInvalidNodeId()
    if monoStrEq(calleeName, "new") && kidCount(initNode) > 1:
        let argNode: Node = monoCallArgValue(kid(initNode, 1))
        if stage1AstRefNonNil(argNode) && looksLikeTypeExpr(argNode):
            return monoInferNewResultType(argNode)
    return mapGetStrNodeIndex(monoFnRetIndex, monoFnRetTypes, calleeName)

fn cloneNodeShallow(n: Node): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    var out: Node = newNode(nodeKind(n), nodePos(n))
    nodeSetIdent(out, nodeIdent(n))
    nodeSetStrVal(out, nodeStrVal(n))
    nodeSetIntVal(out, nodeIntVal(n))
    nodeSetFloatVal(out, nodeFloatVal(n))
    nodeSetCallStyle(out, nodeCallStyle(n))
    # Monomorphization rewrites expression shape without changing its semantic type.
    # Preserve the analyzed type so backend lowering can still recognize object/seq values.
    nodeSetTypeCache(out, nodeTypeCache(n))
    nodeSetTypeCacheValid(out, nodeTypeCacheValid(n))
    return out

fn lowerImplicitCallsExpr(n: Node, rootStmts: Node[]*): Node
fn lowerImplicitCallsStmt(n: Node, rootStmts: Node[]*): Node

fn monoCallHeadIsCharAt(head: Node): bool =
    if stage1AstRefIsNil(head):
        return false
    if nodeKind(head) == nkIdent || nodeKind(head) == nkSymbol:
        return monoStrEq(monoStripSpaces(plainName(head)), "charAt")
    if nodeKind(head) == nkDotExpr && kidCount(head) > 1:
        return monoStrEq(monoStripSpaces(plainName(kid(head, 1))), "charAt")
    return false

fn monoIsIntLitZero(n: Node): bool =
    return stage1AstRefNonNil(n) && nodeKind(n) == nkIntLit && nodeIntVal(n) == 0

fn monoExprMentionsIdent(n: Node, name: str): bool =
    if stage1AstRefIsNil(n) || len(name) == 0:
        return false
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        return monoStrEq(monoStripSpaces(plainName(n)), name)
    for i in 0..<kidCount n:
        if monoExprMentionsIdent(kid(n, i), name):
            return true
    return false

fn monoSeqElemTypeFromExpr(n: Node): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    var ty0: Node = monoLookupExprType n
    # Fallback: some identifier nodes (especially globals) may not be in the
    # local value map during implicit-call lowering, but still carry semantic
    # typeCache.
    if (stage1AstRefIsNil(ty0) || nodeKind(ty0) == nkEmpty) && nodeTypeCacheValid(n) && stage1AstRefNonNil(nodeTypeCache(n)):
        ty0 = nodeTypeCache(n)
    var ty: Node = monoStripPtrRefVar(monoNormalizeType(ty0))
    if stage1AstRefIsNil(ty):
        return astInvalidNodeId()
    # Normalize instantiated seq types like `seq_T` into `seq[T]` so we can
    # extract the element type.
    if nodeKind(ty) == nkIdent || nodeKind(ty) == nkSymbol:
        let key: str = typeKey ty
        if monoStartsWith(key, "seq_") || monoStartsWith(key, "seq_fixed_"):
            let parsed: Node = monoTypeNodeFromKey key
            if stage1AstRefNonNil(parsed):
                ty = parsed
    if nodeKind(ty) != nkBracketExpr:
        return astInvalidNodeId()
    let baseName: str = monoBracketBaseName ty
    if monoStrNe(baseName, "seq") && monoStrNe(baseName, "seq_fixed"):
        # Defensive fallback for old/new parser boundary shapes:
        # - `T[]` may surface as `nkBracketExpr(T)`
        # - `T[N]` may surface as `nkBracketExpr(T, N)`
        # Only treat these as seq-like when no explicit ctor base name exists.
        if (len(baseName) == 0):
            if kidCount ty == 1:
                return monoNormalizeType(kid(ty, 0))
            if kidCount ty == 2:
                return monoNormalizeType(kid(ty, 0))
        return astInvalidNodeId()
    if kidCount ty <= 1:
        return astInvalidNodeId()
    return monoNormalizeType(kid(ty, 1))

fn monoMaybeLowerSeqLenCapAssign(stmt: Node, lhs: Node, rhs: Node, rootStmts: Node[]*): Node =
    if stage1AstRefIsNil(stmt) || stage1AstRefIsNil(lhs) || stage1AstRefIsNil(rhs) || rootStmts == nil:
        return astInvalidNodeId()
    # `std/seqs` implements low-level seq header mutations; do not rewrite.
    if len(nodeStrVal(stmt)) > 0 && strContains(nodeStrVal(stmt), "src/std/seqs.Cheng"):
        return astInvalidNodeId()
    if nodeKind(lhs) != nkDotExpr || kidCount lhs <= 1:
        return astInvalidNodeId()
    let base: Node = kid(lhs, 0)
    let member: Node = kid(lhs, 1)
    if stage1AstRefIsNil(base) || stage1AstRefIsNil(member):
        return astInvalidNodeId()
    let memberName: str = monoStripSpaces(plainName(member))
    if monoStrNe(memberName, "len") && monoStrNe(memberName, "cap"):
        return astInvalidNodeId()
    # Keep `_` placeholder untouched when it appears as a direct base.
    if nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol:
        let baseName: str = monoStripSpaces(plainName(base))
        if len(baseName) == 0 || monoStrEq(baseName, "_"):
            return astInvalidNodeId()
        # Don't rewrite self-referential mutations like `xs.len = xs.len - 1`.
        if monoExprMentionsIdent(rhs, baseName):
            return astInvalidNodeId()
    # Keep raw header mutations for `var` params (common in low-level code).
    let baseTyRaw: Node = monoLookupExprType base
    if stage1AstRefNonNil(baseTyRaw) && nodeKind(baseTyRaw) == nkVarTy:
        return astInvalidNodeId()
    # Keep explicit zeroing patterns (bootstrap header init).
    if monoIsIntLitZero rhs:
        return astInvalidNodeId()
    let elemTy: Node = monoSeqElemTypeFromExpr base
    if stage1AstRefIsNil(elemTy) || nodeKind(elemTy) == nkEmpty:
        return astInvalidNodeId()
    var instArgs: Node[1]
    add(instArgs, elemTy)
    let calleeBase: str = monoSeqLenCapCalleeBase(memberName)
    let instName: str = mangleInstance(calleeBase, instArgs)
    if !instantiateFn(calleeBase, instArgs, rootStmts):
        return astInvalidNodeId()
    if len(instName) == 0:
        return astInvalidNodeId()

    var addr: Node = newNode(nkCall, nodePos(stmt))
    addSon(addr, newIdent("__addr", nodePos(stmt)))
    addSon(addr, base)

    var call: Node = newNode(nkCall, nodePos(stmt))
    addSon(call, newIdent(instName, nodePos(stmt)))
    addSon(call, addr)
    addSon(call, rhs)
    return call

fn lowerImplicitCallsExpr(n: Node, rootStmts: Node[]*): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    if nodeKind(n) == nkTypeDecl || nodeKind(n) == nkObjectDecl || nodeKind(n) == nkEnumDecl || nodeKind(n) == nkEnumFieldDecl ||       nodeKind(n) == nkConceptDecl || nodeKind(n) == nkTraitDecl || nodeKind(n) == nkMacroDecl || nodeKind(n) == nkTemplateDecl ||       nodeKind(n) == nkFormalParams || nodeKind(n) == nkIdentDefs || nodeKind(n) == nkGenericParams ||       nodeKind(n) == nkRefTy || nodeKind(n) == nkPtrTy || nodeKind(n) == nkVarTy || nodeKind(n) == nkTupleTy || nodeKind(n) == nkSetTy || nodeKind(n) == nkFnTy ||       nodeKind(n) == nkRecList || nodeKind(n) == nkRecCase ||       nodeKind(n) == nkPragma || nodeKind(n) == nkAnnotation ||       nodeKind(n) == nkImportStmt || nodeKind(n) == nkImportAs || nodeKind(n) == nkImportGroup:
        return n
    case nodeKind(n)
    of nkIdent, nkSymbol:
        let nm: str = monoStripSpaces(plainName(n))
        if monoFnHasArity(nm, 0) && stage1AstRefIsNil(monoValueLookup(nm)):
            var call0: Node = newNode(nkCall, nodePos(n))
            addSon(call0, n)
            return call0
        return n
    of nkCall:
        if kidCount n > 0:
            var changedCall: bool
            var outKidsCall: Node[4]
            add(outKidsCall, kid(n, 0))
            for ci in 1..<kidCount n:
                let oldArg: Node = kid(n, ci)
                let newArg: Node = lowerImplicitCallsExpr(oldArg, rootStmts)
                if monoNodeNe(newArg, oldArg):
                    changedCall = true
                if stage1AstRefNonNil(newArg):
                    add(outKidsCall, newArg)
            if outKidsCall.len == 3 && monoCallHeadIsCharAt(kid(n, 0)):
                var bracketCall: Node = newNode(nkCall, nodePos(n))
                addSon(bracketCall, newIdent("[]", nodePos(n)))
                addSon(bracketCall, get(outKidsCall, 1))
                addSon(bracketCall, get(outKidsCall, 2))
                return bracketCall
            if ! changedCall:
                return n
            var outCall: Node = cloneNodeShallow n
            for ck in 0..<outKidsCall.len:
                addSon(outCall, get(outKidsCall, ck))
            return outCall
        return n
    of nkDotExpr:
        if kidCount n > 1:
            let base: Node = kid(n, 0)
            let member: Node = kid(n, 1)
            let base2: Node = lowerImplicitCallsExpr(base, rootStmts)
            let memberName: str = monoStripSpaces(plainName(member))
            if len memberName > 0:
                # `T[]`/`T[N]` container headers expose `.len`/`.cap` as structural
                # fields. Do not rewrite them into UFCS-style calls (which can
                # introduce missing symbol instantiations during bootstrap).
                if monoStrEq(memberName, "len") || monoStrEq(memberName, "cap"):
                    let elemTy: Node = monoSeqElemTypeFromExpr base2
                    if stage1AstRefNonNil(elemTy) && nodeKind(elemTy) != nkEmpty:
                        if monoNodeNe(base2, base):
                            var dotHdr: Node = newNode(nkDotExpr, nodePos(n))
                            addSon(dotHdr, base2)
                            addSon(dotHdr, member)
                            return dotHdr
                        return n
                let genNode: Node = genericFnGet(memberName)
                let baseTy: Node = monoLookupExprType base2
                var generics: Node = astInvalidNodeId()
                if stage1AstRefNonNil(genNode) && kidCount genNode > 4:
                    generics = kid(genNode, 4)
                if stage1AstRefNonNil(genNode) && stage1AstRefNonNil(baseTy) && stage1AstRefNonNil(generics) && nodeKind(generics) == nkGenericParams && kidCount generics > 0:
                    var paramNames: str[4]
                    collectGenericParamNames(generics, paramNames)
                    var mapNames: str[4]
                    var mapTypes: Node[4]
                    let firstParamTy: Node = monoFirstParamType genNode
                    if stage1AstRefNonNil(firstParamTy):
                        var actualTy: Node = baseTy
                        if nodeKind(firstParamTy) == nkVarTy && stage1AstRefNonNil(actualTy) && nodeKind(actualTy) != nkVarTy:
                            var wrap: Node = newNode(nkVarTy, nodePos(base2))
                            addSon(wrap, actualTy)
                            actualTy = wrap
                        let fpCore: Node = monoStripVarType firstParamTy
                        let actCore: Node = monoStripVarType actualTy
                        if stage1AstRefNonNil(fpCore) && nodeKind(fpCore) == nkBracketExpr:
                            if stage1AstRefIsNil(actCore) || nodeKind(actCore) != nkBracketExpr:
                                actualTy = astInvalidNodeId()
                            else:
                                let fpBase: str = monoBracketBaseName fpCore
                                let actBase: str = monoBracketBaseName actCore
                                if len fpBase > 0 && len actBase > 0 && fpBase != actBase:
                                    actualTy = astInvalidNodeId()
                        if stage1AstRefNonNil(actualTy):
                            bindTypeVars(firstParamTy, actualTy, paramNames, mapNames, mapTypes)
                    var instArgs: Node[4]
                    var emptyArgs: Node[]
                    buildFullTypeArgs(generics, mapNames, mapTypes, emptyArgs, instArgs)
                    if instArgs.len == kidCount generics:
                        let instName: str = mangleInstance(memberName, instArgs)
                        if instantiateFn(memberName, instArgs, rootStmts):
                            var call1: Node = newNode(nkCall, nodePos(n))
                            addSon(call1, newIdent(instName, nodePos(n)))
                            addSon(call1, base2)
                            return call1
                if monoFnHasArity(memberName, 1) && stage1AstRefNonNil(baseTy) && monoFnOneArgMatches(memberName, baseTy):
                    var dotOut: Node = n
                    if monoNodeNe(base2, base):
                        dotOut = newNode(nkDotExpr, nodePos(n))
                        addSon(dotOut, base2)
                        addSon(dotOut, member)
                    var call2: Node = newNode(nkCall, nodePos(n))
                    addSon(call2, dotOut)
                    return call2
            if monoNodeNe(base2, base):
                var dotNew: Node = newNode(nkDotExpr, nodePos(n))
                addSon(dotNew, base2)
                addSon(dotNew, member)
                return dotNew
        return n
    of nkCallArg:
        if kidCount n > 1:
            let nameNode: Node = kid(n, 0)
            let valNode: Node = kid(n, 1)
            let newVal: Node = lowerImplicitCallsExpr(valNode, rootStmts)
            if monoNodeNe(newVal, valNode):
                var outArg: Node = newNode(nkCallArg, nodePos(n))
                addSon(outArg, nameNode)
                addSon(outArg, newVal)
                return outArg
        return n
    of nkLambda:
        monoValueScopePush()
        if kidCount n > 1:
            monoBindFormalParams kid(n, 1)
        var changedL: bool
        var outKidsL: Node[6]
        for li in 0..<kidCount n:
            let oldChildL: Node = kid(n, li)
            var childL: Node = oldChildL
            if li == 3:
                childL = lowerImplicitCallsStmt(oldChildL, rootStmts)
            if monoNodeNe(childL, oldChildL):
                changedL = true
            if stage1AstRefNonNil(childL):
                add(outKidsL, childL)
        monoValueScopePop()
        if ! changedL:
            return n
        var outL: Node = cloneNodeShallow n
        for lk in 0..<outKidsL.len:
            addSon(outL, get(outKidsL, lk))
        return outL
    of nkComprehension:
        var changedC: bool
        var outKidsC: Node[4]
        for ci in 0..<kidCount n:
            let oldChildC: Node = kid(n, ci)
            var childC: Node = oldChildC
            if ci > 0:
                childC = lowerImplicitCallsExpr(oldChildC, rootStmts)
            if monoNodeNe(childC, oldChildC):
                changedC = true
            if stage1AstRefNonNil(childC):
                add(outKidsC, childC)
        if ! changedC:
            return n
        var outC: Node = cloneNodeShallow n
        for ck in 0..<outKidsC.len:
            addSon(outC, get(outKidsC, ck))
        return outC
    else:
        var changed: bool
        var outKids: Node[4]
        for i in 0..<kidCount n:
            let oldChild: Node = kid(n, i)
            let child: Node = lowerImplicitCallsExpr(oldChild, rootStmts)
            if monoNodeNe(child, oldChild):
                changed = true
            if stage1AstRefNonNil(child):
                add(outKids, child)
        if ! changed:
            return n
        var out: Node = cloneNodeShallow n
        for k in 0..<outKids.len:
            addSon(out, get(outKids, k))
        return out

fn lowerImplicitCallsStmt(n: Node, rootStmts: Node[]*): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    case nodeKind(n)
    of nkModule, nkStmtList:
        monoValueScopePush()
        var changed: bool
        var outKids: Node[4]
        for i in 0..<kidCount n:
            let oldChild: Node = kid(n, i)
            let child: Node = lowerImplicitCallsStmt(oldChild, rootStmts)
            if monoNodeNe(child, oldChild):
                changed = true
            if stage1AstRefNonNil(child):
                add(outKids, child)
        monoValueScopePop()
        if ! changed:
            return n
        var out: Node = cloneNodeShallow n
        for k in 0..<outKids.len:
            addSon(out, get(outKids, k))
        return out
    of nkFnDecl, nkIteratorDecl:
        monoValueScopePush()
        if kidCount n > 1:
            monoBindFormalParams kid(n, 1)
        var changed2: bool
        var outKids2: Node[6]
        for i2 in 0..<kidCount n:
            let oldChild2: Node = kid(n, i2)
            var child2: Node = oldChild2
            if i2 == 3:
                child2 = lowerImplicitCallsStmt(oldChild2, rootStmts)
            if monoNodeNe(child2, oldChild2):
                changed2 = true
            add(outKids2, child2)
        monoValueScopePop()
        if ! changed2:
            return n
        var out2: Node = cloneNodeShallow n
        for k2 in 0..<outKids2.len:
            addSon(out2, get(outKids2, k2))
        return out2
    of nkVar, nkLet, nkConst:
        var nameNode: Node = astInvalidNodeId()
        var typeNode: Node = astInvalidNodeId()
        var valNode: Node = astInvalidNodeId()
        var pragmaNode: Node = astInvalidNodeId()
        if kidCount n > 0:
            nameNode = kid(n, 0)
        if kidCount n > 1:
            typeNode = kid(n, 1)
        if kidCount n > 2:
            valNode = kid(n, 2)
        if kidCount n > 3:
            pragmaNode = kid(n, 3)
        let newVal: Node = lowerImplicitCallsExpr(valNode, rootStmts)
        var out3: Node = n
        if monoNodeNe(newVal, valNode):
            out3 = newNode(nodeKind(n), nodePos(n))
            addSon(out3, nameNode)
            addSon(out3, typeNode)
            addSon(out3, newVal)
            addSon(out3, pragmaNode)
        var patternType: Node = astInvalidNodeId()
        if stage1AstRefNonNil(nameNode) && nodeKind(nameNode) == nkPattern && kidCount nameNode > 1:
            patternType = kid(nameNode, 1)
        var bindType: Node = typeNode
        if stage1AstRefIsNil(bindType) || nodeKind(bindType) == nkEmpty:
            bindType = patternType
        if stage1AstRefIsNil(bindType) || nodeKind(bindType) == nkEmpty:
            if stage1AstRefNonNil(newVal) && nodeTypeCacheValid(newVal) && !isEmpty(nodeTypeCache(newVal)):
                bindType = nodeTypeCache(newVal)
            elif stage1AstRefNonNil(valNode) && nodeTypeCacheValid(valNode) && !isEmpty(nodeTypeCache(valNode)):
                bindType = nodeTypeCache(valNode)
        if stage1AstRefIsNil(bindType) || nodeKind(bindType) == nkEmpty:
            let inferred: Node = monoInferBindTypeFromInitCall(newVal)
            if stage1AstRefNonNil(inferred) && nodeKind(inferred) != nkEmpty:
                bindType = inferred
        if stage1AstRefIsNil(bindType) || nodeKind(bindType) == nkEmpty:
            let inferred2: Node = monoLookupExprType(newVal)
            if stage1AstRefNonNil(inferred2) && nodeKind(inferred2) != nkEmpty:
                bindType = inferred2
        monoBindNameWithType(nameNode, bindType)
        return out3
    of nkReturn, nkYield:
        if kidCount n > 0:
            let oldExpr: Node = kid(n, 0)
            let newExpr: Node = lowerImplicitCallsExpr(oldExpr, rootStmts)
            if monoNodeNe(newExpr, oldExpr):
                var out4: Node = cloneNodeShallow n
                addSon(out4, newExpr)
                return out4
        return n
    of nkAsgn, nkFastAsgn:
        if kidCount n > 1:
            let lhs: Node = kid(n, 0)
            let rhs: Node = kid(n, 1)
            let newRhs: Node = lowerImplicitCallsExpr(rhs, rootStmts)
            let seqAssignCall: Node = monoMaybeLowerSeqLenCapAssign(n, lhs, newRhs, rootStmts)
            if stage1AstRefNonNil(seqAssignCall):
                return seqAssignCall
            let eqCall: Node = monoMaybeLowerAssignToEqCall(lhs, newRhs, rootStmts)
            if stage1AstRefNonNil(eqCall):
                return eqCall
            if monoNodeNe(newRhs, rhs):
                var out5: Node = cloneNodeShallow n
                addSon(out5, lhs)
                addSon(out5, newRhs)
                return out5
        return n
    of nkIf, nkWhen:
        var changed3: bool
        var outKids3: Node[4]
        var i3: int32
        while i3 + 1 < kidCount n:
            let cond: Node = kid(n, i3)
            let body: Node = kid(n, i3 + 1)
            let cond2: Node = lowerImplicitCallsExpr(cond, rootStmts)
            let body2: Node = lowerImplicitCallsStmt(body, rootStmts)
            if monoNodeNe(cond2, cond) || monoNodeNe(body2, body):
                changed3 = true
            add(outKids3, cond2)
            add(outKids3, body2)
            i3 = i3 + 2
        if i3 < kidCount n:
            let tail: Node = kid(n, i3)
            let tail2: Node = lowerImplicitCallsStmt(tail, rootStmts)
            if monoNodeNe(tail2, tail):
                changed3 = true
            add(outKids3, tail2)
        if ! changed3:
            return n
        var out6: Node = cloneNodeShallow n
        for k3 in 0..<outKids3.len:
            addSon(out6, get(outKids3, k3))
        return out6
    of nkWhile:
        if kidCount n > 1:
            let condW: Node = kid(n, 0)
            let bodyW: Node = kid(n, 1)
            let condW2: Node = lowerImplicitCallsExpr(condW, rootStmts)
            let bodyW2: Node = lowerImplicitCallsStmt(bodyW, rootStmts)
            if monoNodeNe(condW2, condW) || monoNodeNe(bodyW2, bodyW):
                var out7: Node = cloneNodeShallow n
                addSon(out7, condW2)
                addSon(out7, bodyW2)
                return out7
        return n
    of nkFor:
        if kidCount n > 2:
            let pat: Node = kid(n, 0)
            let iterExpr: Node = kid(n, 1)
            let bodyF: Node = kid(n, 2)
            let iterExpr2: Node = lowerImplicitCallsExpr(iterExpr, rootStmts)
            let bodyF2: Node = lowerImplicitCallsStmt(bodyF, rootStmts)
            if monoNodeNe(iterExpr2, iterExpr) || monoNodeNe(bodyF2, bodyF):
                var out8: Node = cloneNodeShallow n
                addSon(out8, pat)
                addSon(out8, iterExpr2)
                addSon(out8, bodyF2)
                return out8
        return n
    of nkCase:
        var changed4: bool
        var outKids4: Node[4]
        var ci: int32
        if kidCount n > 0:
            let sel: Node = kid(n, 0)
            let sel2: Node = lowerImplicitCallsExpr(sel, rootStmts)
            if monoNodeNe(sel2, sel):
                changed4 = true
            add(outKids4, sel2)
            ci = 1
        let __for_start_ci_1 = ci
        for __for_ci_1 in __for_start_ci_1..<kidCount n:
            ci = __for_ci_1
            let br: Node = kid(n, ci)
            let br2: Node = lowerImplicitCallsStmt(br, rootStmts)
            if monoNodeNe(br2, br):
                changed4 = true
            add(outKids4, br2)
            ci = ci + 1
        if ! changed4:
            return n
        var out9: Node = cloneNodeShallow n
        for k4 in 0..<outKids4.len:
            addSon(out9, get(outKids4, k4))
        return out9
    of nkOfBranch:
        var changed5: bool
        var outKids5: Node[4]
        for bi in 0..<kidCount n:
            let ch: Node = kid(n, bi)
            var ch2: Node = ch
            if stage1AstRefNonNil(ch) && nodeKind(ch) == nkGuard && kidCount ch > 0:
                let gexpr: Node = kid(ch, 0)
                let gexpr2: Node = lowerImplicitCallsExpr(gexpr, rootStmts)
                if monoNodeNe(gexpr2, gexpr):
                    ch2 = newNode(nkGuard, nodePos(ch))
                    addSon(ch2, gexpr2)
            elif stage1AstRefNonNil(ch) && nodeKind(ch) == nkStmtList:
                ch2 = lowerImplicitCallsStmt(ch, rootStmts)
            if monoNodeNe(ch2, ch):
                changed5 = true
            add(outKids5, ch2)
        if ! changed5:
            return n
        var out10: Node = cloneNodeShallow n
        for k5 in 0..<outKids5.len:
            addSon(out10, get(outKids5, k5))
        return out10
    of nkElse:
        if kidCount n > 0:
            let bodyE: Node = kid(n, 0)
            let bodyE2: Node = lowerImplicitCallsStmt(bodyE, rootStmts)
            if monoNodeNe(bodyE2, bodyE):
                var out11: Node = cloneNodeShallow n
                addSon(out11, bodyE2)
                return out11
        return n
    of nkBlock:
        if kidCount n > 1:
            let label: Node = kid(n, 0)
            let bodyB: Node = kid(n, 1)
            let bodyB2: Node = lowerImplicitCallsStmt(bodyB, rootStmts)
            if monoNodeNe(bodyB2, bodyB):
                var out12: Node = cloneNodeShallow n
                addSon(out12, label)
                addSon(out12, bodyB2)
                return out12
        return n
    of nkDefer:
        if kidCount n > 0:
            let bodyD: Node = kid(n, 0)
            let bodyD2: Node = lowerImplicitCallsStmt(bodyD, rootStmts)
            if monoNodeNe(bodyD2, bodyD):
                var out13: Node = cloneNodeShallow n
                addSon(out13, bodyD2)
                return out13
        return n
    else:
        return lowerImplicitCallsExpr(n, rootStmts)

fn mapPutStrNode(keys: var str[], vals: var Node[], key: str, val: Node) =
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        mapPutCalls = mapPutCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            mapPutNs = mapPutNs + (cheng_monotime_ns() - startNs)
    add(keys, key)
    add(vals, val)

fn mapPutStrNodeIndex(index: var hashmaps.HashMapStrInt, keys: var str[], vals: var Node[], key: str, val: Node) =
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        mapPutCalls = mapPutCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            mapPutNs = mapPutNs + (cheng_monotime_ns() - startNs)
    add(keys, key)
    add(vals, val)
    let idx: int32 = keys.len - 1
    hashmaps.HashMapStrIntPut(index, key, idx)

fn mapGetStrNode(keys: str[], vals: Node[], key: str): Node =
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        mapGetCalls = mapGetCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            mapGetNs = mapGetNs + (cheng_monotime_ns() - startNs)
    for i in 0..<keys.len:
        if monoStrEq(get(keys, i), key):
            return get(vals, i)
    return astInvalidNodeId()

fn mapGetStrNodeIndex(index: hashmaps.HashMapStrInt, vals: Node[], key: str): Node =
    if len(key) == 0:
        return astInvalidNodeId()
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        mapGetCalls = mapGetCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            mapGetNs = mapGetNs + (cheng_monotime_ns() - startNs)
    var found: bool
    let idx: int32 = monoHashMapStrIntGetCompat(index, key, found)
    if found && idx >= 0 && idx < vals.len:
        return get(vals, idx)
    return astInvalidNodeId()

fn mapHasStr(keys: str[], key: str): bool =
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        mapHasCalls = mapHasCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            mapHasNs = mapHasNs + (cheng_monotime_ns() - startNs)
    for i in 0..<keys.len:
        if monoStrEq(get(keys, i), key):
            return true
    return false

fn mapHasStrIndex(index: hashmaps.HashMapStrInt, key: str): bool =
    if len(key) == 0:
        return false
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        mapHasCalls = mapHasCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            mapHasNs = mapHasNs + (cheng_monotime_ns() - startNs)
    var found: bool
    let idx: int32 = monoHashMapStrIntGetCompat(index, key, found)
    return found && idx >= 0

fn traitDispatchKey(selfTy: Node, methodName: str): str =
    let sk: str = typeKey selfTy
    if monoStrEq(sk, "") || monoStrEq(methodName, ""):
        return ""
    return sk + "|" + methodName

fn traitDispatchAdd(selfTy: Node, methodName: str, vtblName: str, initName: str, pos: SourcePos) =
    let key: str = traitDispatchKey(selfTy, methodName)
    if monoStrEq(key, ""):
        return
    for i in 0..<traitDispatchKeys.len:
        if monoStrEq(get(traitDispatchKeys, i), key):
            let prev: str = get(traitDispatchVtableNames, i)
            if monoStrNe(prev, vtblName):
                addWhereDiag(pos, "trait dispatch conflict for " + methodName + ": " + prev + " vs " + vtblName)
            return
    add(traitDispatchKeys, key)
    add(traitDispatchVtableNames, vtblName)
    add(traitDispatchInitNames, initName)

fn traitDispatchLookup(selfTy: Node, methodName: str): int32 =
    let key: str = traitDispatchKey(selfTy, methodName)
    if monoStrEq(key, ""):
        return -1
    for i in 0..<traitDispatchKeys.len:
        if monoStrEq(get(traitDispatchKeys, i), key):
            return i
    return -1

fn traitVtableKey(traitName: str, selfTy: Node, traitArgs: Node[]): str =
    if monoStrEq(traitName, ""):
        return ""
    var parts: str[]
    add(parts, traitName)
    add(parts, "|")
    add(parts, typeKey(selfTy))
    for i in 0..<traitArgs.len:
        let part: str = typeKey get(traitArgs, i)
        if monoStrNe(part, ""):
            add(parts, "|")
            add(parts, part)
    return strutils.Join(parts, "")

fn traitVtableName(traitName: str, selfTy: Node, traitArgs: Node[]): str =
    var parts: str[]
    add(parts, traitName)
    add(parts, "__vtbl")
    let sk: str = typeKey selfTy
    if monoStrNe(sk, ""):
        add(parts, "_")
        add(parts, sk)
    for i in 0..<traitArgs.len:
        let part: str = typeKey get(traitArgs, i)
        if monoStrNe(part, ""):
            add(parts, "_")
            add(parts, part)
    return strutils.Join(parts, "")

fn traitVtableInitName(vtblName: str): str =
    if monoStrEq(vtblName, ""):
        return ""
    return vtblName + "__init"

fn monoSeqStrHas(v: str[], key: str): bool =
    for i in 0..<v.len:
        if monoStrEq(get(v, i), key):
            return true
    return false

fn monoSeqStrHas(v: var str[], key: str): bool =
    for i in 0..<v.len:
        if monoStrEq(v[i], key):
            return true
    return false


fn monoSeqStrAdd(v: var str[], key: str) =
    if monoSeqStrHas(v, key):
        return
    add(v, key)

fn instHash64(s: str): uint64 =
    var h: uint64 =(uint64(1469598103) * uint64(1000000000)) + uint64(934665603)
    if len(s) == 0:
        return h
    let n: int32 = len s
    for i in 0..<n:
        let c: char = s[i]
        h = h ^ uint64(c)
        h = h * ((uint64(1099511628) * uint64(1000)) + uint64(211))
    return h

fn instRoundUpPow2(x0: int32): int32 =
    var x: int32 = x0
    if x <= 1:
        return 1
    x = x - 1
    x = x |(x >> 1)
    x = x |(x >> 2)
    x = x |(x >> 4)
    x = x |(x >> 8)
    x = x |(x >> 16)
    x = x + 1
    return x

fn instMapSet(idx: int32, key: str) =
    if idx < 0 || idx >= instMapKeys.len:
        return
    instMapKeys[idx] = key

fn instMapInit(cap0: int32) =
    var cap: int32 = cap0
    if cap < 256:
        cap = 256
    cap = instRoundUpPow2 cap
    if instMapKeys.buffer != nil && instMapKeys.cap >= cap:
        instMapKeys.len = instMapKeys.cap
        rawmemSet(instMapKeys.buffer, 0, instMapKeys.cap * 8)
        instMapCount = 0
        return
    instMapKeys = []
    instMapKeys.cap = cap
    instMapKeys.len = int(cap)
    if instMapKeys.buffer != nil:
        rawmemSet(instMapKeys.buffer, 0, cap * 8)
    instMapCount = 0

fn instMapHas(key: str): bool =
    if len(key) == 0:
        return false
    if instMapKeys.buffer == nil || instMapKeys.cap == 0:
        instMapInit 256
    let mask: uint64 = uint64(instMapKeys.cap) - 1
    var idx: uint64 = instHash64 key & mask
    while true:
        let slot: str = get(instMapKeys, int32(idx))
        if len(slot) == 0:
            return false
        if monoStrEq(slot, key):
            return true
        idx =(idx + 1) & mask

fn instMapGet(key: str): str =
    if len(key) == 0:
        return ""
    if instMapKeys.buffer == nil || instMapKeys.cap == 0:
        instMapInit 256
    let mask: uint64 = uint64(instMapKeys.cap) - 1
    var idx: uint64 = instHash64 key & mask
    while true:
        let slot: str = get(instMapKeys, int32(idx))
        if len(slot) == 0:
            return ""
        if monoStrEq(slot, key):
            return slot
        idx =(idx + 1) & mask

fn instMapGetOrTrack(key: str): str =
    let existing: str = instMapGet(key)
    if len(existing) > 0:
        return existing
    trackLexStringStr(key)
    return key

fn instMapAdd(key: str) =
    if len(key) == 0:
        return
    if instMapKeys.buffer == nil || instMapKeys.cap == 0:
        instMapInit 256
    if instMapCount * 2 >= instMapKeys.cap:
        let oldKeys: str[] = instMapKeys
        instMapInit(instMapKeys.cap * 2)
        for i in 0..<oldKeys.len:
            let k: str = get(oldKeys, i)
            if len(k) > 0:
                instMapAdd k
        return
    let mask: uint64 = uint64(instMapKeys.cap) - 1
    var idx: uint64 = instHash64 key & mask
    while true:
        let slot: str = get(instMapKeys, int32(idx))
        if len(slot) == 0:
            instMapSet(int32(idx), key)
            instMapCount = instMapCount + 1
            return
        if monoStrEq(slot, key):
            return
        idx =(idx + 1) & mask

fn monoStripSpaces(s: str): str =
    if len(s) == 0:
        return ""
    let n: int32 = len s
    if n > 0 && s[0] != ' ' && s[n - 1] != ' ':
        return s
    let ptrKey: int64 = monoStrPtrKey(s)
    if ptrKey != 0:
        var foundPtr: bool
        let cachedIdxPtr: int32 = hashmaps.HashMapPtrIntGet(monoStripPtrIndex, ptrKey, foundPtr)
        if foundPtr && cachedIdxPtr > 0 && cachedIdxPtr <= monoStripValues.len:
            return get(monoStripValues, cachedIdxPtr - 1)
    var cached: bool
    let cachedIdx: int32 = hashmaps.HashMapStrIntGetEx(monoStripIndex, s, cached)
    if cached && cachedIdx > 0 && cachedIdx <= monoStripValues.len:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(monoStripPtrIndex, ptrKey, cachedIdx)
        return get(monoStripValues, cachedIdx - 1)
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        stripSpacesCalls = stripSpacesCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            stripSpacesNs = stripSpacesNs + (cheng_monotime_ns() - startNs)
    if n <= 0:
        trackLexStringStr("")
        add(monoStripValues, "")
        let storedIdx: int32 = monoStripValues.len
        hashmaps.HashMapStrIntPut(monoStripIndex, s, storedIdx)
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(monoStripPtrIndex, ptrKey, storedIdx)
        return ""
    var a: int32
    var b: int32 = n - 1
    for _ in a..<(b + 1):
        if a > b || s[a] != ' ':
            break
        a = a + 1
    for _ in a..<(b + 1):
        if b < a || s[b] != ' ':
            break
        b = b - 1
    if b < a:
        trackLexStringStr("")
        add(monoStripValues, "")
        let storedIdx2: int32 = monoStripValues.len
        hashmaps.HashMapStrIntPut(monoStripIndex, s, storedIdx2)
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(monoStripPtrIndex, ptrKey, storedIdx2)
        return ""
    if a == 0 && b == n - 1:
        trackLexStringStr(s)
        add(monoStripValues, s)
        let storedIdx3: int32 = monoStripValues.len
        hashmaps.HashMapStrIntPut(monoStripIndex, s, storedIdx3)
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(monoStripPtrIndex, ptrKey, storedIdx3)
        return s
    let count: int32 = b - a + 1
    let res: str = strings.SliceBytes(s, a, count)
    trackLexStringStr(res)
    add(monoStripValues, res)
    let storedIdx4: int32 = monoStripValues.len
    hashmaps.HashMapStrIntPut(monoStripIndex, s, storedIdx4)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(monoStripPtrIndex, ptrKey, storedIdx4)
    return res

fn nextLambdaName(): str =
    let name: str = monoLambdaNameValue(lambdaCounter)
    trackLexStringStr(name)
    lambdaCounter = lambdaCounter + 1
    return name

fn unwrapLambda(n: Node): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    if nodeKind(n) == nkLambda:
        return n
    if nodeKind(n) == nkPar && kidCount n == 1:
        let inner: Node = kid(n, 0)
        if stage1AstRefNonNil(inner) && nodeKind(inner) == nkLambda:
            return inner
    return astInvalidNodeId()

fn lambdaDeclKind(lam: Node): NodeKind =
    if stage1AstRefIsNil(lam):
        return nkFnDecl
    let kw: str = monoStripSpaces nodeIdent(lam)
    if monoStrEq(kw, "iterator"):
        return nkIteratorDecl
    if monoStrEq(kw, "fn"):
        return nkFnDecl
    return nkFnDecl

fn lambdaBaseName(lam: Node): str =
    if stage1AstRefNonNil(lam) && kidCount lam > 0:
        let nameNode: Node = kid(lam, 0)
        let nm: str = monoStripSpaces(plainName(nameNode))
        if len nm > 0:
            return nm
    return nextLambdaName()

fn monoCollectPatternNames(n: Node, out: var str[]) =
    if stage1AstRefIsNil(n):
        return
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        let nm: str = monoStripSpaces(plainName(n))
        if len nm > 0:
            monoSeqStrAdd(out, nm)
        return
    if nodeKind(n) == nkPattern && kidCount n > 0:
        monoCollectPatternNames(kid(n, 0), out)
        return
    for i in 0..<kidCount n:
        monoCollectPatternNames(kid(n, i), out)

fn monoCollectLocalsInBody(n: Node, out: var str[]) =
    if stage1AstRefIsNil(n):
        return
    if nodeKind(n) == nkLambda:
        return
    if nodeKind(n) == nkLet || nodeKind(n) == nkVar || nodeKind(n) == nkConst:
        if kidCount n > 0:
            monoCollectPatternNames(kid(n, 0), out)
    elif nodeKind(n) == nkFor:
        if kidCount n > 0:
            monoCollectPatternNames(kid(n, 0), out)
    for i in 0..<kidCount n:
        monoCollectLocalsInBody(kid(n, i), out)

fn monoCollectLambdaLocals(lam: Node, out: var str[]) =
    if stage1AstRefIsNil(lam):
        return
    if kidCount lam > 1:
        let paramsNode: Node = kid(lam, 1)
        if stage1AstRefNonNil(paramsNode) && nodeKind(paramsNode) == nkFormalParams:
            for i in 0..<kidCount paramsNode:
                let defs: Node = kid(paramsNode, i)
                if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs:
                    let nameCount: int32 = identDefsNameCount(defs)
                    for j in 0..<nameCount:
                        monoCollectPatternNames(kid(defs, j), out)
    if kidCount lam > 3:
        let bodyNode: Node = kid(lam, 3)
        monoCollectLocalsInBody(bodyNode, out)

fn monoLambdaHasCaptureVisit(n: Node, locals: str[], found: var bool) =
    if stage1AstRefIsNil(n) || found:
        return
    if nodeKind(n) == nkLambda:
        return
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        let nm: str = monoStripSpaces(plainName(n))
        if len nm > 0 && !monoSeqStrHas(locals, nm):
            if stage1AstRefNonNil(monoValueLookup(nm)):
                found = true
                return
    for i in 0..<kidCount n:
        monoLambdaHasCaptureVisit(kid(n, i), locals, found)

fn monoLambdaHasCapture(lam: Node): bool =
    if stage1AstRefIsNil(lam):
        return false
    var cached: bool
    let lamKey: int64 = int64(astNodeIndex(lam))
    let cachedIdx: int32 = hashmaps.HashMapPtrIntGet(monoLambdaCaptureIndex, lamKey, cached)
    if cached && cachedIdx > 0 && cachedIdx <= monoLambdaCaptureValues.len:
        return get(monoLambdaCaptureValues, cachedIdx - 1) != 0
    var locals: str[8]
    monoCollectLambdaLocals(lam, locals)
    var found: bool
    var body: Node = astInvalidNodeId()
    if kidCount lam > 3:
        body = kid(lam, 3)
    monoLambdaHasCaptureVisit(body, locals, found)
    var capVal: int8
    if found:
        capVal = 1
    add(monoLambdaCaptureValues, capVal)
    let storedIdx: int32 = monoLambdaCaptureValues.len
    hashmaps.HashMapPtrIntPut(&monoLambdaCaptureIndex, lamKey, storedIdx)
    return found

fn addWhereDiag(pos: SourcePos, msg: str) =
    if currentDiags == nil:
        return
    let d: Diagnostic = diagMake(svError, currentFilename, pos.line, pos.col, msg)
    add(currentDiags, d)

fn collectGenericParamNames(generics: Node, outNames: var str[]) =
    if stage1AstRefIsNil(generics) || nodeKind(generics) != nkGenericParams:
        return
    for i in 0..<kidCount generics:
        let defn: Node = kid(generics, i)
        if stage1AstRefNonNil(defn) && nodeKind(defn) == nkIdentDefs && kidCount defn > 0:
            let nm: str = monoStripSpaces(plainName(kid(defn, 0)))
            if len nm > 0:
                add(outNames, nm)

fn mapGetStrNodeByIndex(keys: str[], vals: Node[], key: str): Node =
    # Stage0 safety: keep generic arg lookup on the linear path.
    # The key set is tiny (generic params, usually <= 4), so O(n) is stable
    # and avoids invalid pointer deref crashes observed in mixed stage0 builds.
    for i in 0..<keys.len:
        if i >= vals.len:
            break
        if monoStrEq(get(keys, i), key):
            return get(vals, i)
    return astInvalidNodeId()

fn bindTypeVars(genericTy: Node, actualTy: Node, paramNames: str[], outNames: var str[], outTypes: var Node[]) =
    if stage1AstRefIsNil(genericTy) || stage1AstRefIsNil(actualTy):
        return
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        bindTypeVarsCalls = bindTypeVarsCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            bindTypeVarsNs = bindTypeVarsNs + (cheng_monotime_ns() - startNs)
    if nodeKind(genericTy) == nkIdent || nodeKind(genericTy) == nkSymbol:
        let nm: str = monoStripSpaces(plainName(genericTy))
        if len nm > 0 && monoSeqStrHas(paramNames, nm):
            if ! monoSeqStrHas(outNames, nm):
                add(outNames, nm)
                add(outTypes, actualTy)
            return
    if nodeKind(genericTy) == nkBracketExpr && nodeKind(actualTy) == nkBracketExpr:
        for i in 0..<kidCount genericTy:
            if !(i < kidCount actualTy):
                break
            bindTypeVars(kid(genericTy, i), kid(actualTy, i), paramNames, outNames, outTypes)
        return
    if (nodeKind(genericTy) == nkPtrTy || nodeKind(genericTy) == nkRefTy || nodeKind(genericTy) == nkVarTy || nodeKind(genericTy) == nkSetTy) &&       (nodeKind(actualTy) == nkPtrTy || nodeKind(actualTy) == nkRefTy || nodeKind(actualTy) == nkVarTy || nodeKind(actualTy) == nkSetTy):
        if kidCount genericTy > 0 && kidCount actualTy > 0:
            bindTypeVars(kid(genericTy, 0), kid(actualTy, 0), paramNames, outNames, outTypes)
        return
    if nodeKind(genericTy) == nkTupleTy && nodeKind(actualTy) == nkTupleTy:
        for j in 0..<kidCount genericTy:
            if !(j < kidCount actualTy):
                break
            bindTypeVars(kid(genericTy, j), kid(actualTy, j), paramNames, outNames, outTypes)
        return
    if nodeKind(genericTy) == nkFnTy && nodeKind(actualTy) == nkFnTy:
        if kidCount genericTy > 0 && kidCount actualTy > 0:
            let gfp: Node = kid(genericTy, 0)
            let afp: Node = kid(actualTy, 0)
            var pi: int32
            while stage1AstRefNonNil(gfp) && stage1AstRefNonNil(afp) && pi < kidCount gfp && pi < kidCount afp:
                let gdef: Node = kid(gfp, pi)
                let adef: Node = kid(afp, pi)
                if stage1AstRefNonNil(gdef) && stage1AstRefNonNil(adef) && kidCount gdef > 1 && kidCount adef > 1:
                    bindTypeVars(kid(gdef, 1), kid(adef, 1), paramNames, outNames, outTypes)
                pi = pi + 1
        if kidCount genericTy > 1 && kidCount actualTy > 1:
            bindTypeVars(kid(genericTy, 1), kid(actualTy, 1), paramNames, outNames, outTypes)
        return

fn buildTypeArgsFromMap(generics: Node, mapNames: str[], mapTypes: Node[], outArgs: var Node[]): bool =
    if stage1AstRefIsNil(generics) || nodeKind(generics) != nkGenericParams:
        return true
    var ok: bool = true
    for i in 0..<kidCount generics:
        let defn: Node = kid(generics, i)
        if stage1AstRefNonNil(defn) && nodeKind(defn) == nkIdentDefs && kidCount defn > 0:
            let name: str = monoStripSpaces(plainName(kid(defn, 0)))
            var mapped: Node = astInvalidNodeId()
            if len name > 0:
                mapped = mapGetStrNodeByIndex(mapNames, mapTypes, name)
            if stage1AstRefIsNil(mapped) && kidCount defn > 2:
                let defaultVal: Node = kid(defn, 2)
                if stage1AstRefNonNil(defaultVal) && nodeKind(defaultVal) != nkEmpty:
                    mapped = replaceTypeVars(defaultVal, mapNames, mapTypes)
            if stage1AstRefNonNil(mapped):
                add(outArgs, mapped)
            else:
                ok = false
    return ok

fn inferTypeArgsFromExpectedFn(lam: Node, expectedFn: Node, outArgs: var Node[]): bool =
    if stage1AstRefIsNil(lam):
        return false
    var generics: Node = astInvalidNodeId()
    if kidCount lam > 4:
        generics = kid(lam, 4)
    if stage1AstRefIsNil(generics) || nodeKind(generics) != nkGenericParams || kidCount generics == 0:
        return true
    if stage1AstRefIsNil(expectedFn) || nodeKind(expectedFn) != nkFnTy:
        return false
    var paramNames: str[4]
    collectGenericParamNames(generics, paramNames)
    if paramNames.len == 0:
        return true
    var mapNames: str[4]
    var mapTypes: Node[4]
    var lamParams: Node = astInvalidNodeId()
    if kidCount lam > 1:
        lamParams = kid(lam, 1)
    var expParams: Node = astInvalidNodeId()
    if kidCount expectedFn > 0:
        expParams = kid(expectedFn, 0)
    if stage1AstRefNonNil(lamParams) && stage1AstRefNonNil(expParams):
        for i in 0..<kidCount lamParams:
            if i >= kidCount expParams:
                break
            let ldef: Node = kid(lamParams, i)
            let edef: Node = kid(expParams, i)
            if stage1AstRefNonNil(ldef) && stage1AstRefNonNil(edef) && kidCount ldef > 1 && kidCount edef > 1:
                bindTypeVars(kid(ldef, 1), kid(edef, 1), paramNames, mapNames, mapTypes)
    var lamRet: Node = astInvalidNodeId()
    if kidCount lam > 2:
        lamRet = kid(lam, 2)
    var expRet: Node = astInvalidNodeId()
    if kidCount expectedFn > 1:
        expRet = kid(expectedFn, 1)
    if stage1AstRefNonNil(lamRet) && stage1AstRefNonNil(expRet):
        bindTypeVars(lamRet, expRet, paramNames, mapNames, mapTypes)
    return buildTypeArgsFromMap(generics, mapNames, mapTypes, outArgs)

fn sanitizeKey(s: str): str =
    if len(s) == 0:
        return "anon"
    let n: int32 = len s
    if n <= 0:
        return "anon"
    var needsSanitize: bool
    for i in 0..<n:
        let c: char = s[i]
        if !(((c >= 'a' && c <= 'z') ||(c >= 'A' && c <= 'Z') ||
           (c >= '0' && c <= '9') || c == '_')):
            needsSanitize = true
            break
    if !needsSanitize:
        return s
    let ptrKey: int64 = monoStrPtrKey(s)
    if ptrKey != 0:
        var foundPtr: bool
        let cachedIdxPtr: int32 = hashmaps.HashMapPtrIntGet(monoSanitizePtrIndex, ptrKey, foundPtr)
        if foundPtr && cachedIdxPtr > 0 && cachedIdxPtr <= monoSanitizeValues.len:
            return get(monoSanitizeValues, cachedIdxPtr - 1)
    var cached: bool
    let cachedIdx: int32 = monoHashMapStrIntGetCompat(monoSanitizeIndex, s, cached)
    if cached && cachedIdx > 0 && cachedIdx <= monoSanitizeValues.len:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(monoSanitizePtrIndex, ptrKey, cachedIdx)
        return get(monoSanitizeValues, cachedIdx - 1)
    var parts: str[]
    for i in 0..<n:
        let c2: char = s[i]
        if (c2 >= 'a' && c2 <= 'z') ||(c2 >= 'A' && c2 <= 'Z') ||
           (c2 >= '0' && c2 <= '9') || c2 == '_':
            add(parts, charToStr(c2))
        else:
            add(parts, "_")
    let out: str = monoChooseNonEmpty(strutils.Join(parts, ""), "anon")
    add(monoSanitizeValues, out)
    let storedIdx: int32 = monoSanitizeValues.len
    hashmaps.HashMapStrIntPut(monoSanitizeIndex, s, storedIdx)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(monoSanitizePtrIndex, ptrKey, storedIdx)
    return out

fn monoTypeKeyEnsureStored(key: str): int32 =
    let ptrKey: int64 = monoStrPtrKey(key)
    if ptrKey != 0:
        var foundPtr: bool
        let cachedIdxPtr: int32 = hashmaps.HashMapPtrIntGet(monoTypeKeyPtrIndex, ptrKey, foundPtr)
        if foundPtr && cachedIdxPtr > 0 && cachedIdxPtr <= monoTypeKeyValues.len:
            return cachedIdxPtr
    var found: bool
    let cachedIdx: int32 = monoHashMapStrIntGetCompat(monoTypeKeyValueIndex, key, found)
    if found && cachedIdx > 0 && cachedIdx <= monoTypeKeyValues.len:
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(monoTypeKeyPtrIndex, ptrKey, cachedIdx)
        return cachedIdx
    trackLexStringStr(key)
    add(monoTypeKeyValues, key)
    let storedIdx: int32 = monoTypeKeyValues.len
    hashmaps.HashMapStrIntPut(monoTypeKeyValueIndex, key, storedIdx)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(monoTypeKeyPtrIndex, ptrKey, storedIdx)
    return storedIdx

fn monoTypeKeyEnsureNodeCache(n: Node) =
    if !astNodeIdValid(n):
        return
    let needLen: int32 = int32(n) + 1
    if needLen <= 0:
        return
    if monoTypeKeyIndex.cap < needLen:
        reserve(monoTypeKeyIndex, needLen)
    if monoTypeKeyIndex.len < needLen:
        setLen(monoTypeKeyIndex, needLen)

fn monoTypeLeafKeyEnsureNodeCache(n: Node) =
    if !astNodeIdValid(n):
        return
    let needLen: int32 = int32(n) + 1
    if needLen <= 0:
        return
    if monoTypeLeafKeyValues.cap < needLen:
        reserve(monoTypeLeafKeyValues, needLen)
    if monoTypeLeafKeyReady.cap < needLen:
        reserve(monoTypeLeafKeyReady, needLen)
    if monoTypeLeafKeyValues.len < needLen:
        setLen(monoTypeLeafKeyValues, needLen)
    if monoTypeLeafKeyReady.len < needLen:
        setLen(monoTypeLeafKeyReady, needLen)

fn monoTypeLeafKeyEnsureTextCache(textId: int32) =
    if textId <= 0:
        return
    let needLen: int32 = textId + 1
    if monoTypeLeafTextValues.cap < needLen:
        reserve(monoTypeLeafTextValues, needLen)
    if monoTypeLeafTextReady.cap < needLen:
        reserve(monoTypeLeafTextReady, needLen)
    if monoTypeLeafTextValues.len < needLen:
        setLen(monoTypeLeafTextValues, needLen)
    if monoTypeLeafTextReady.len < needLen:
        setLen(monoTypeLeafTextReady, needLen)

fn monoRawLooksSafeKey(raw: str): bool =
    let n: int32 = len(raw)
    if n <= 0:
        return false
    for i in 0..<n:
        let c: char = raw[i]
        if (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') ||
           (c >= '0' && c <= '9') || c == '_':
            continue
        return false
    return true

fn monoTextIdLooksSafeKey(textId: int32): bool =
    let n: int32 = tokenTextLen(textId)
    if n <= 0:
        return false
    for i in 0..<n:
        let c: char = tokenTextByteAtId(textId, i)
        if (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') ||
           (c >= '0' && c <= '9') || c == '_':
            continue
        return false
    return true

fn monoJoinKeyParts(base: str, parts: str[]): str =
    if parts.len == 0:
        return base
    var outParts: str[]
    add(outParts, base)
    for i in 0..<parts.len:
        let part: str = get(parts, i)
        if len(part) > 0:
            add(outParts, "_")
            add(outParts, part)
    return strutils.Join(outParts, "")

fn monoJoinKeyPart(base: str, part: str): str =
    if len(part) == 0:
        return base
    return base + "_" + part

fn monoTypeLeafKey(n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    let textId: int32 = nodeIdentId(n)
    if textId > 0:
        monoTypeLeafKeyEnsureTextCache(textId)
        if textId >= 0 && textId < monoTypeLeafTextReady.len && monoTypeLeafTextReady[textId] != 0:
            let cachedText: str = get(monoTypeLeafTextValues, textId)
            if astNodeIdValid(n):
                monoTypeLeafKeyEnsureNodeCache(n)
                let idxText: int32 = int32(n)
                if idxText >= 0 && idxText < monoTypeLeafKeyReady.len:
                    monoTypeLeafKeyValues[idxText] = cachedText
                    monoTypeLeafKeyReady[idxText] = 1
            return cachedText
    if astNodeIdValid(n):
        monoTypeLeafKeyEnsureNodeCache(n)
        let idx0: int32 = int32(n)
        if idx0 >= 0 && idx0 < monoTypeLeafKeyReady.len && monoTypeLeafKeyReady[idx0] != 0:
            return get(monoTypeLeafKeyValues, idx0)
    let raw: str = monoNodeRawText(n, textId)
    let res: str = monoTypeLeafKeyValue(textId, raw)
    if textId > 0:
        monoTypeLeafKeyEnsureTextCache(textId)
        if textId >= 0 && textId < monoTypeLeafTextReady.len:
            monoTypeLeafTextValues[textId] = res
            monoTypeLeafTextReady[textId] = 1
    if astNodeIdValid(n):
        monoTypeLeafKeyEnsureNodeCache(n)
        let idx1: int32 = int32(n)
        if idx1 >= 0 && idx1 < monoTypeLeafKeyReady.len:
            monoTypeLeafKeyValues[idx1] = res
            monoTypeLeafKeyReady[idx1] = 1
    return res

fn typeKeyCore(n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    let profOn: bool = monoProfileActive
    var tkStart: int64
    if profOn:
        typeKeyCalls = typeKeyCalls + 1
        tkStart = cheng_monotime_ns()
    defer:
        if profOn:
            typeKeyNs = typeKeyNs + (cheng_monotime_ns() - tkStart)
    case nodeKind(n)
    of nkIdent, nkSymbol:
        return monoTypeLeafKey(n)
    of nkIdentDefs:
        if kidCount n > 1:
            return typeKey kid(n, 1)
        return ""
    of nkCallArg:
        if kidCount n > 1:
            return typeKey kid(n, 1)
        if kidCount n > 0:
            return typeKey kid(n, 0)
        return ""
    of nkIntLit:
        return intToStr int32(nodeIntVal(n))
    of nkPtrTy:
        if kidCount n > 0:
            return monoJoinKeyPart("ptr", typeKey kid(n, 0))
        return "ptr"
    of nkRefTy:
        if kidCount n > 0:
            return monoJoinKeyPart("ref", typeKey kid(n, 0))
        return "ref"
    of nkVarTy:
        if kidCount n > 0:
            return monoJoinKeyPart("var", typeKey kid(n, 0))
        return "var"
    of nkSetTy:
        if kidCount n > 0:
            return monoJoinKeyPart("set", typeKey kid(n, 0))
        return "set"
    of nkFnTy:
        var parts: str[]
        parts.cap = 8
        if kidCount n > 0:
            let fp: Node = kid(n, 0)
            if stage1AstRefNonNil(fp) && nodeKind(fp) == nkFormalParams:
                for i in 0..<kidCount fp:
                    let d: Node = kid(fp, i)
                    if stage1AstRefNonNil(d) && nodeKind(d) == nkIdentDefs && kidCount d > 1:
                        let k: str = typeKey kid(d, 1)
                        if len k > 0:
                            add(parts, k)
        if kidCount n > 1:
            let retKey: str = typeKey kid(n, 1)
            if len retKey > 0:
                add(parts, "ret")
                add(parts, retKey)
        return monoJoinKeyParts("fn", parts)
    of nkTupleTy, nkTupleLit:
        var parts: str[]
        parts.cap = kidCount(n)
        for i2 in 0..<kidCount n:
            let k2: str = typeKey kid(n, i2)
            if len k2 > 0:
                add(parts, k2)
        return monoJoinKeyParts("tuple", parts)
    of nkBracketExpr:
        if kidCount n > 0:
            if !bracketLooksLikeTypeCall(n):
                # Parser/type-lowering boundary can still surface postfix container
                # syntax as `T[]` => `nkBracketExpr(T)` or `T[N]` => `nkBracketExpr(T, N)`.
                # Treat these as seq-like type identity instead of collapsing them to
                # the bare element key (for example `bool[]` must not hash like `bool`).
                if kidCount n == 1 || kidCount n == 2:
                    let elemKey0: str = typeKey kid(n, 0)
                    if len(elemKey0) > 0:
                        return monoJoinKeyPart("seq", elemKey0)
                    return "seq"
            let base: Node = kid(n, 0)
            let baseKey: str = typeKey base
            # `seq_fixed[T, N]` is treated as `seq[T]` for type identity.
            # The `N` parameter is an initialization hint (reserve cap), not a distinct type.
            if monoStrEq(baseKey, "seq_fixed"):
                if kidCount n > 1:
                    let elemKey: str = typeKey kid(n, 1)
                    if len elemKey > 0:
                        return monoJoinKeyPart("seq", elemKey)
                return "seq"
            var parts: str[]
            parts.cap = kidCount(n)
            let argc: int32 = kidCount n
            if argc == 2:
                let k1: str = typeKey kid(n, 1)
                if len k1 > 0:
                    return monoJoinKeyPart(baseKey, k1)
                return baseKey
            for i3 in 1..<argc:
                let k3: str = typeKey kid(n, i3)
                if len k3 > 0:
                    add(parts, k3)
            return monoJoinKeyParts(baseKey, parts)
    else:
        if len nodeIdent(n) > 0:
            return monoTypeLeafKey(n)
        return "node"
    return ""

fn typeKey(n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    if astNodeIdValid(n):
        monoTypeKeyEnsureNodeCache(n)
        let idx0: int32 = int32(n)
        if idx0 >= 0 && idx0 < monoTypeKeyIndex.len:
            let cachedIdx0: int32 = monoTypeKeyIndex[idx0]
            if cachedIdx0 > 0 && cachedIdx0 <= monoTypeKeyValues.len:
                return get(monoTypeKeyValues, cachedIdx0 - 1)
    let res: str = typeKeyCore(n)
    let storedIdx: int32 = monoTypeKeyEnsureStored(res)
    if astNodeIdValid(n):
        monoTypeKeyEnsureNodeCache(n)
        let idx1: int32 = int32(n)
        if idx1 >= 0 && idx1 < monoTypeKeyIndex.len:
            monoTypeKeyIndex[idx1] = storedIdx
    return get(monoTypeKeyValues, storedIdx - 1)

fn constraintBaseName(n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        return monoStripSpaces(plainName(n))
    if nodeKind(n) == nkBracketExpr && kidCount n > 0:
        return monoStripSpaces(plainName(kid(n, 0)))
    return ""

fn constraintArgs(n: Node, mapNames: str[], mapTypes: Node[], outArgs: var Node[]) =
    if stage1AstRefIsNil(n):
        return
    if nodeKind(n) == nkBracketExpr && kidCount n > 1:
        for i in 1..<kidCount n:
            let raw: Node = kid(n, i)
            let resolved: Node = replaceTypeVars(raw, mapNames, mapTypes)
            add(outArgs, resolved)

fn traitBodyNode(traitNode: Node): Node =
    if stage1AstRefNonNil(traitNode) && kidCount traitNode > 2:
        return kid(traitNode, 2)
    return astInvalidNodeId()

fn traitGenericsNode(traitNode: Node): Node =
    if stage1AstRefNonNil(traitNode) && kidCount traitNode > 1:
        return kid(traitNode, 1)
    return astInvalidNodeId()

fn collectTraitMethods(traitNode: Node, out: var Node[]) =
    let body: Node = traitBodyNode traitNode
    if stage1AstRefIsNil(body):
        return
    for i in 0..<kidCount body:
        let n: Node = kid(body, i)
        if stage1AstRefNonNil(n) && (nodeKind(n) == nkFnDecl || nodeKind(n) == nkIteratorDecl):
            add(out, n)

fn fnParamTypes(fnNode: Node, out: var Node[]) =
    if stage1AstRefIsNil(fnNode) || kidCount fnNode < 2:
        return
    let params: Node = kid(fnNode, 1)
    if stage1AstRefIsNil(params) || nodeKind(params) != nkFormalParams:
        return
    for i in 0..<kidCount params:
        let defs: Node = kid(params, i)
        if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount defs > 1:
            let ty: Node = identDefsType(defs)
            let namesN: int32 = identDefsNameCount(defs)
            for ni in 0..<namesN:
                add(out, ty)

fn fnSigMatches(fnNode: Node, expParams: Node[], expRet: Node): bool =
    if stage1AstRefIsNil(fnNode):
        return false
    var params: Node[4]
    fnParamTypes(fnNode, params)
    if params.len != expParams.len:
        return false
    for i in 0..<expParams.len:
        let a: str = typeKey(monoNormalizeType(get(params, i)))
        let b: str = typeKey(monoNormalizeType(get(expParams, i)))
        if monoStrEq(a, "") || monoStrEq(b, "") || monoStrNe(a, b):
            return false
    var retNode: Node = newNode(nkEmpty, nodePos(fnNode))
    if kidCount fnNode > 2:
        retNode = kid(fnNode, 2)
    if stage1AstRefIsNil(expRet) || nodeKind(expRet) == nkEmpty:
        return stage1AstRefIsNil(retNode) || nodeKind(retNode) == nkEmpty
    let rk: str = typeKey(monoNormalizeType(retNode))
    let ek: str = typeKey(monoNormalizeType(expRet))
    return monoStrNe(rk, "") && monoStrEq(rk, ek)

fn findFnImplIn(n: Node, name: str, expParams: Node[], expRet: Node): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    if nodeKind(n) == nkFnDecl || nodeKind(n) == nkIteratorDecl:
        let nameNode: Node = kid(n, 0)
        if stage1AstRefNonNil(nameNode) && monoStrEq(monoStripSpaces(plainName(nameNode)), name):
            if fnSigMatches(n, expParams, expRet):
                return n
    for i in 0..<kidCount n:
        let found: Node = findFnImplIn(kid(n, i), name, expParams, expRet)
        if stage1AstRefNonNil(found):
            return found
    return astInvalidNodeId()

fn findFnImpl(name: str, expParams: Node[], expRet: Node, rootStmts: Node[]*): Node =
    let found: Node = findFnImplIn(monoRoot, name, expParams, expRet)
    if stage1AstRefNonNil(found):
        return found
    if rootStmts != nil:
        for i in 0..<rootStmts->len:
            let n: Node = get(*rootStmts, i)
            let found2: Node = findFnImplIn(n, name, expParams, expRet)
            if stage1AstRefNonNil(found2):
                return found2
    return astInvalidNodeId()

fn monoFindFnByFirstParamMatchIn(n: Node, name: str, baseTy: Node, paramCount: int32): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    if nodeKind(n) == nkFnDecl || nodeKind(n) == nkIteratorDecl:
        let nameNode: Node = kid(n, 0)
        if stage1AstRefNonNil(nameNode) && monoStrEq(monoStripSpaces(plainName(nameNode)), name):
            var gens: Node = astInvalidNodeId()
            if kidCount n > 4:
                gens = kid(n, 4)
            if stage1AstRefIsNil(gens) || nodeKind(gens) != nkGenericParams || kidCount gens == 0:
                let paramsNode: Node = kid(n, 1)
                if stage1AstRefNonNil(paramsNode) && nodeKind(paramsNode) == nkFormalParams:
                    if paramCount < 0 || fnParamCount(paramsNode) == paramCount:
                        let firstTy: Node = monoFirstParamType n
                        if monoTypeMatches(firstTy, baseTy):
                            return n
    for i in 0..<kidCount n:
        let found: Node = monoFindFnByFirstParamMatchIn(kid(n, i), name, baseTy, paramCount)
        if stage1AstRefNonNil(found):
            return found
    return astInvalidNodeId()

fn monoFirstParamMatchCacheKey(name: str, baseTy: Node, paramCount: int32): str =
    if len(name) == 0:
        return ""
    let tk: str = typeKey(monoNormalizeType(baseTy))
    if monoStrEq(tk, ""):
        return ""
    return name + "|" + tk + "|" + intToStr(int64(paramCount))

fn monoFindFnByFirstParamMatch(name: str, baseTy: Node, paramCount: int32, rootStmts: Node[]*): Node =
    let cacheKey: str = monoFirstParamMatchCacheKey(name, baseTy, paramCount)
    if monoStrNe(cacheKey, ""):
        var cached: bool
        let cachedIdx: int32 = monoHashMapStrIntGetCompat(monoFirstParamMatchIndex, cacheKey, cached)
        if cached && cachedIdx >= 0 && cachedIdx < monoFirstParamMatchNodes.len:
            let cachedNode: Node = get(monoFirstParamMatchNodes, cachedIdx)
            if stage1AstRefNonNil(cachedNode):
                return cachedNode
        else:
            let foundInRoot: Node = monoFindFnByFirstParamMatchIn(monoRoot, name, baseTy, paramCount)
            trackLexStringStr(cacheKey)
            mapPutStrNodeIndex(monoFirstParamMatchIndex, monoFirstParamMatchKeys, monoFirstParamMatchNodes, cacheKey, foundInRoot)
            if stage1AstRefNonNil(foundInRoot):
                return foundInRoot
    else:
        let found: Node = monoFindFnByFirstParamMatchIn(monoRoot, name, baseTy, paramCount)
        if stage1AstRefNonNil(found):
            return found
    if rootStmts != nil:
        for i in 0..<rootStmts->len:
            let n: Node = get(*rootStmts, i)
            let found2: Node = monoFindFnByFirstParamMatchIn(n, name, baseTy, paramCount)
            if stage1AstRefNonNil(found2):
                return found2
    return astInvalidNodeId()

fn traitMethodFnType(methodNode: Node, substNames: str[], substTypes: Node[]): Node =
    if stage1AstRefIsNil(methodNode):
        return astInvalidNodeId()
    var fp: Node = newNode(nkFormalParams, nodePos(methodNode))
    if kidCount methodNode > 1:
        let params: Node = kid(methodNode, 1)
        if stage1AstRefNonNil(params) && nodeKind(params) == nkFormalParams:
            for i in 0..<kidCount params:
                let defs: Node = kid(params, i)
                if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount defs > 1:
                    let tyNode: Node = replaceTypeVars(identDefsType(defs), substNames, substTypes)
                    let namesN: int32 = identDefsNameCount(defs)
                    for ni in 0..<namesN:
                        let nameNode: Node = kid(defs, ni)
                        var outDefs: Node = newNode(nkIdentDefs, nodePos(defs))
                        addSon(outDefs, cloneTree nameNode)
                        addSon(outDefs, tyNode)
                        addSon(outDefs, newNode(nkEmpty, nodePos(defs)))
                        addSon(fp, outDefs)
    var retNode: Node = newNode(nkEmpty, nodePos(methodNode))
    if kidCount methodNode > 2:
        retNode = replaceTypeVars(kid(methodNode, 2), substNames, substTypes)
    var fnTy: Node = newNode(nkFnTy, nodePos(methodNode))
    addSon(fnTy, fp)
    addSon(fnTy, retNode)
    return fnTy

fn ensureTraitVtable(traitNode: Node, traitName: str, selfTy: Node, traitArgs: Node[], rootStmts: Node[]*): str =
    let key: str = traitVtableKey(traitName, selfTy, traitArgs)
    if monoStrEq(key, ""):
        return ""
    for i in 0..<traitVtableKeys.len:
        if monoStrEq(get(traitVtableKeys, i), key):
            return get(traitVtableNames, i)
    let vtblName: str = traitVtableName(traitName, selfTy, traitArgs)
    let initName: str = traitVtableInitName(vtblName)
    add(traitVtableKeys, key)
    add(traitVtableNames, vtblName)
    add(traitVtableInitNames, initName)
    if rootStmts == nil:
        return vtblName
    var methodDecls: Node[4]
    collectTraitMethods(traitNode, methodDecls)
    var substNames: str[4]
    var substTypes: Node[4]
    add(substNames, "Self")
    add(substTypes, selfTy)
    var genNames: str[4]
    collectGenericParamNames(traitGenericsNode(traitNode), genNames)
    for gi in 0..<genNames.len:
        if ! (gi < traitArgs.len):
            break
        add(substNames, get(genNames, gi))
        add(substTypes, get(traitArgs, gi))
    var recList: Node = newNode(nkRecList, nodePos(traitNode))
    for mi in 0..<methodDecls.len:
        let m: Node = get(methodDecls, mi)
        let mname: str = monoStripSpaces(plainName(kid(m, 0)))
        if monoStrNe(mname, ""):
            var defs: Node = newNode(nkIdentDefs, nodePos(m))
            addSon(defs, newIdent(mname, nodePos(m)))
            addSon(defs, traitMethodFnType(m, substNames, substTypes))
            addSon(defs, newNode(nkEmpty, nodePos(m)))
            addSon(recList, defs)
    var obj: Node = newNode(nkObjectDecl, nodePos(traitNode))
    addSon(obj, newNode(nkEmpty, nodePos(traitNode)))
    addSon(obj, recList)
    var decl: Node = newNode(nkTypeDecl, nodePos(traitNode))
    nodeSetStrVal(decl, nodeStrVal(traitNode))
    addSon(decl, newIdent(vtblName, nodePos(traitNode)))
    addSon(decl, obj)
    addSon(decl, newNode(nkEmpty, nodePos(traitNode)))
    addSon(decl, newNode(nkEmpty, nodePos(traitNode)))
    addSon(decl, newNode(nkEmpty, nodePos(traitNode)))
    add(rootStmts, decl)
    var initFn: Node = newNode(nkFnDecl, nodePos(traitNode))
    nodeSetStrVal(initFn, nodeStrVal(traitNode))
    addSon(initFn, newIdent(initName, nodePos(traitNode)))
    var fpInit: Node = newNode(nkFormalParams, nodePos(traitNode))
    addSon(initFn, fpInit)
    addSon(initFn, newIdent(vtblName, nodePos(traitNode)))
    var body: Node = newNode(nkStmtList, nodePos(traitNode))
    var vdecl: Node = newNode(nkVar, nodePos(traitNode))
    addSon(vdecl, newIdent("__vt", nodePos(traitNode)))
    addSon(vdecl, newIdent(vtblName, nodePos(traitNode)))
    var oc: Node = newNode(nkBracketExpr, nodePos(traitNode))
    addSon(oc, newIdent("default", nodePos(traitNode)))
    addSon(oc, newIdent(vtblName, nodePos(traitNode)))
    addSon(vdecl, oc)
    addSon(vdecl, newNode(nkEmpty, nodePos(traitNode)))
    addSon(body, vdecl)
    for mi2 in 0..<methodDecls.len:
        let m2: Node = get(methodDecls, mi2)
        let mname2: str = monoStripSpaces(plainName(kid(m2, 0)))
        if monoStrNe(mname2, ""):
            var asg: Node = newNode(nkAsgn, nodePos(m2))
            var lhs: Node = newNode(nkDotExpr, nodePos(m2))
            addSon(lhs, newIdent("__vt", nodePos(m2)))
            addSon(lhs, newIdent(mname2, nodePos(m2)))
            addSon(asg, lhs)
            addSon(asg, newIdent(mname2, nodePos(m2)))
            addSon(body, asg)
    var retNode: Node = newNode(nkReturn, nodePos(traitNode))
    addSon(retNode, newIdent("__vt", nodePos(traitNode)))
    addSon(body, retNode)
    addSon(initFn, body)
    addSon(initFn, newNode(nkEmpty, nodePos(traitNode)))
    addSon(initFn, newNode(nkEmpty, nodePos(traitNode)))
    add(rootStmts, initFn)
    return vtblName

fn checkTraitConstraints(generics: Node, mapNames: str[], mapTypes: Node[], rootStmts: Node[]*) =
    if stage1AstRefIsNil(generics) || nodeKind(generics) != nkGenericParams:
        return
    for i in 0..<kidCount generics:
        let defn: Node = kid(generics, i)
        if stage1AstRefNonNil(defn) && nodeKind(defn) == nkIdentDefs && kidCount defn > 1:
            let nameNode: Node = kid(defn, 0)
            let paramName: str = monoStripSpaces(plainName(nameNode))
            let constraint: Node = kid(defn, 1)
            if monoStrNe(paramName, "") && stage1AstRefNonNil(constraint) && nodeKind(constraint) != nkEmpty:
                let actualTy: Node = mapGetStrNodeByIndex(mapNames, mapTypes, paramName)
                if stage1AstRefNonNil(actualTy):
                    let baseName: str = constraintBaseName(constraint)
                    var traitNode: Node = mapGetStrNodeIndex(traitIndex, traitNodes, baseName)
                    var isConcept: bool
                    if stage1AstRefIsNil(traitNode):
                        traitNode = mapGetStrNodeIndex(conceptIndex, conceptNodes, baseName)
                        if stage1AstRefNonNil(traitNode):
                            isConcept = true
                    if stage1AstRefNonNil(traitNode):
                        var args: Node[4]
                        constraintArgs(constraint, mapNames, mapTypes, args)
                        var genNode: Node = traitGenericsNode(traitNode)
                        var mapNames2: str[4]
                        var mapTypes2: Node[4]
                        collectTypeArgMap(genNode, args, mapNames2, mapTypes2)
                        var fullArgs: Node[4]
                        buildFullTypeArgs(genNode, mapNames2, mapTypes2, args, fullArgs)
                        if stage1AstRefNonNil(genNode) && nodeKind(genNode) == nkGenericParams && kidCount genNode > 0 && fullArgs.len != kidCount genNode:
                            addWhereDiag(nodePos(constraint), "trait constraint missing type args: " + baseName)
                        let vtblName: str = ensureTraitVtable(traitNode, baseName, actualTy, fullArgs, rootStmts)
                        let initName: str = traitVtableInitName vtblName
                        var methodDecls: Node[4]
                        collectTraitMethods(traitNode, methodDecls)
                        var substNames: str[4]
                        var substTypes: Node[4]
                        add(substNames, "Self")
                        add(substTypes, actualTy)
                        var genNames: str[4]
                        collectGenericParamNames(genNode, genNames)
                        for gi in 0..<genNames.len:
                            if ! (gi < fullArgs.len):
                                break
                            add(substNames, get(genNames, gi))
                            add(substTypes, get(fullArgs, gi))
                        for mi in 0..<methodDecls.len:
                            let m: Node = get(methodDecls, mi)
                            let mname: str = monoStripSpaces(plainName(kid(m, 0)))
                            if monoStrNe(mname, ""):
                                var expParams: Node[4]
                                if kidCount m > 1:
                                    let params: Node = kid(m, 1)
                                    if stage1AstRefNonNil(params) && nodeKind(params) == nkFormalParams:
                                        for pi in 0..<kidCount params:
                                            let defs: Node = kid(params, pi)
                                            if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount defs > 1:
                                                let tyNode: Node = replaceTypeVars(identDefsType(defs), substNames, substTypes)
                                                let namesN: int32 = identDefsNameCount(defs)
                                                for ni in 0..<namesN:
                                                    add(expParams, tyNode)
                                var expRet: Node = newNode(nkEmpty, nodePos(m))
                                if kidCount m > 2:
                                    expRet = replaceTypeVars(kid(m, 2), substNames, substTypes)
                                let impl: Node = findFnImpl(mname, expParams, expRet, rootStmts)
                                if stage1AstRefIsNil(impl):
                                    var parts: str[]
                                    add(parts, "missing implementation for ")
                                    if isConcept:
                                        add(parts, "concept ")
                                    else:
                                        add(parts, "trait ")
                                    add(parts, baseName)
                                    add(parts, ".")
                                    add(parts, mname)
                                    addWhereDiag(nodePos(m), strutils.Join(parts, ""))
                                traitDispatchAdd(actualTy, mname, vtblName, initName, nodePos(m))

fn mangleInstance(name: str, typeArgs: Node[]): str =
    let base: str = monoMangleBaseName(name)
    var keys: str[]
    keys.cap = typeArgs.len
    for i in 0..<typeArgs.len:
        let key: str = typeKey get(typeArgs, i)
        if len key > 0:
            add(keys, key)
    return monoJoinKeyParts(base, keys)

fn inferLitType(n: Node): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    case nodeKind(n)
    of nkIntLit:
        if nodeIntVal(n) > 2147483647 || nodeIntVal(n) < (-2147483647 - 1):
            return newIdent("int64", nodePos(n))
        return newIdent("int32", nodePos(n))
    of nkFloatLit:
        return newIdent("float64", nodePos(n))
    of nkBoolLit:
        return newIdent("bool", nodePos(n))
    of nkCharLit:
        return newIdent("char", nodePos(n))
    of nkStrLit:
        return newIdent("str", nodePos(n))
    of nkIdent, nkSymbol:
        let nm: str = monoStripSpaces nodeIdent(n)
        if monoStrEq(nm, "true") || monoStrEq(nm, "false"):
            return newIdent("bool", nodePos(n))
        return astInvalidNodeId()
    of nkCallArg:
        if kidCount n > 1:
            return inferLitType kid(n, 1)
        return astInvalidNodeId()
    of nkPar:
        if kidCount n == 1:
            return inferLitType kid(n, 0)
        return astInvalidNodeId()
    else:
        return astInvalidNodeId()

fn replaceTypeVars(n: Node, names: str[], types: Node[]): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        replaceTypeVarsCalls = replaceTypeVarsCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            replaceTypeVarsNs = replaceTypeVarsNs + (cheng_monotime_ns() - startNs)
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        let nm: str = monoStripSpaces nodeIdent(n)
        for i in 0..<names.len:
            if monoStrEq(get(names, i), nm):
                return cloneTree get(types, i)
        return n
    let kc: int32 = kidCount n
    if kc <= 0:
        return n
    var changed: bool
    var outKids: Node[]
    for j in 0..<kc:
        let oldChild: Node = kid(n, j)
        let child: Node = replaceTypeVars(oldChild, names, types)
        if !changed && monoNodeNe(child, oldChild):
            changed = true
            outKids.cap = kc
            for back in 0..<j:
                let prev: Node = kid(n, back)
                if stage1AstRefNonNil(prev):
                    add(outKids, prev)
        if changed && stage1AstRefNonNil(child):
            add(outKids, child)
    if ! changed:
        return n
    var out: Node = newNode(nodeKind(n), nodePos(n))
    nodeSetIdent(out, nodeIdent(n))
    nodeSetStrVal(out, nodeStrVal(n))
    nodeSetIntVal(out, nodeIntVal(n))
    nodeSetFloatVal(out, nodeFloatVal(n))
    nodeSetCallStyle(out, nodeCallStyle(n))
    for k in 0..<outKids.len:
        addSon(out, get(outKids, k))
    return out

fn replaceTypeVars(n: Node, names: var str[], types: var Node[]): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        replaceTypeVarsCalls = replaceTypeVarsCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            replaceTypeVarsNs = replaceTypeVarsNs + (cheng_monotime_ns() - startNs)
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        let nm: str = monoStripSpaces nodeIdent(n)
        for i in 0..<names.len:
            if monoStrEq(names[i], nm):
                return cloneTree(types[i])
        return n
    let kc: int32 = kidCount n
    if kc <= 0:
        return n
    var changed: bool
    var outKids: Node[]
    for j in 0..<kc:
        let oldChild: Node = kid(n, j)
        let child: Node = replaceTypeVars(oldChild, names, types)
        if !changed && monoNodeNe(child, oldChild):
            changed = true
            outKids.cap = kc
            for back in 0..<j:
                let prev: Node = kid(n, back)
                if stage1AstRefNonNil(prev):
                    add(outKids, prev)
        if changed && stage1AstRefNonNil(child):
            add(outKids, child)
    if ! changed:
        return n
    var out: Node = newNode(nodeKind(n), nodePos(n))
    nodeSetIdent(out, nodeIdent(n))
    nodeSetStrVal(out, nodeStrVal(n))
    nodeSetIntVal(out, nodeIntVal(n))
    nodeSetFloatVal(out, nodeFloatVal(n))
    nodeSetCallStyle(out, nodeCallStyle(n))
    for k in 0..<outKids.len:
        addSon(out, outKids[k])
    return out


fn whereTypeKey(expr: Node, names: str[], types: Node[]): str =
    if stage1AstRefIsNil(expr):
        return ""
    var e: Node = expr
    if nodeKind(e) == nkPar && kidCount e == 1:
        e = kid(e, 0)
    let resolved: Node = replaceTypeVars(e, names, types)
    if stage1AstRefIsNil(resolved):
        return ""
    case nodeKind(resolved)
    of nkIdent, nkSymbol, nkPtrTy, nkRefTy, nkVarTy, nkSetTy, nkFnTy, nkTupleTy, nkBracketExpr:
        return typeKey resolved
    else:
        return ""

fn evalWhereExpr(expr: Node, names: str[], types: Node[]): int32 =
    if stage1AstRefIsNil(expr) || nodeKind(expr) == nkEmpty:
        return 1
    case nodeKind(expr)
    of nkBoolLit:
        let v: str = monoStripSpaces nodeIdent(expr)
        if monoStrEq(v, "true"): return 1
        if monoStrEq(v, "false"): return 0
        return -1
    of nkIdent, nkSymbol:
        let v2: str = monoStripSpaces nodeIdent(expr)
        if monoStrEq(v2, "true"): return 1
        if monoStrEq(v2, "false"): return 0
        return -1
    of nkPar:
        if kidCount expr == 1:
            return evalWhereExpr(kid(expr, 0), names, types)
        return -1
    of nkPrefix:
        if kidCount expr > 1:
            let opn: Node = kid(expr, 0)
            if stage1AstRefNonNil(opn) && monoStrEq(monoStripSpaces(nodeIdent(opn)), "!"):
                let inner: int32 = evalWhereExpr(kid(expr, 1), names, types)
                if inner < 0:
                    return -1
                if inner == 0:
                    return 1
                return 0
        return -1
    of nkInfix:
        if kidCount expr > 2:
            let opn2: Node = kid(expr, 0)
            let op: str = monoWhereOpName(opn2)
            if monoStrEq(op, "&&"):
                let lhs: int32 = evalWhereExpr(kid(expr, 1), names, types)
                let rhs: int32 = evalWhereExpr(kid(expr, 2), names, types)
                if lhs == 0 || rhs == 0:
                    return 0
                if lhs < 0 || rhs < 0:
                    return -1
                return 1
            if monoStrEq(op, "||"):
                let lhs2: int32 = evalWhereExpr(kid(expr, 1), names, types)
                let rhs2: int32 = evalWhereExpr(kid(expr, 2), names, types)
                if lhs2 == 1 || rhs2 == 1:
                    return 1
                if lhs2 < 0 || rhs2 < 0:
                    return -1
                return 0
            if monoStrEq(op, "is") || monoStrEq(op, "isnot"):
                let lk: str = whereTypeKey(kid(expr, 1), names, types)
                let rk: str = whereTypeKey(kid(expr, 2), names, types)
                if len lk == 0 || len rk == 0:
                    return -1
                let eq: bool = monoStrEq(lk, rk)
                if monoStrEq(op, "is"):
                    if eq:
                        return 1
                    return 0
                if eq:
                    return 0
                return 1
        return -1
    else:
        return -1

fn getName(n: Node): str =
    let nm: str = monoStripSpaces(plainName(n))
    return nm

fn findGenericFnDecl(n: Node, name: str): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        findGenericFnDeclCalls = findGenericFnDeclCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            findGenericFnDeclNs = findGenericFnDeclNs + (cheng_monotime_ns() - startNs)
    if nodeKind(n) == nkFnDecl || nodeKind(n) == nkIteratorDecl:
        if kidCount n > 4:
            let gens: Node = kid(n, 4)
            if stage1AstRefNonNil(gens) && nodeKind(gens) == nkGenericParams && kidCount gens > 0:
                if monoStrEq(getName(kid(n, 0)), name):
                    return n
    for i in 0..<kidCount n:
        let found: Node = findGenericFnDecl(kid(n, i), name)
        if stage1AstRefNonNil(found):
            return found
    return astInvalidNodeId()

fn findGenericTypeDecl(n: Node, name: str): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    if nodeKind(n) == nkTypeDecl:
        if kidCount n > 2:
            let gens: Node = kid(n, 2)
            if stage1AstRefNonNil(gens) && nodeKind(gens) == nkGenericParams && kidCount gens > 0:
                if monoStrEq(getName(kid(n, 0)), name):
                    return n
    for i in 0..<kidCount n:
        let found: Node = findGenericTypeDecl(kid(n, i), name)
        if stage1AstRefNonNil(found):
            return found
    return astInvalidNodeId()

fn monoGenericTypeGet(name: str): Node =
    var genNode: Node = mapGetStrNodeIndex(genericTypeIndex, genericTypeNodes, name)
    if stage1AstRefIsNil(genNode):
        genNode = findGenericTypeDecl(monoRoot, name)
        if stage1AstRefNonNil(genNode):
            mapPutStrNodeIndex(genericTypeIndex, genericTypeNames, genericTypeNodes, name, genNode)
    return genNode

fn monoHasGenericType(name: str): bool =
    return stage1AstRefNonNil(monoGenericTypeGet(name))


fn isComparableType(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    if nodeKind(n) == nkPtrTy || nodeKind(n) == nkRefTy:
        return true
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        let name: str = monoStripSpaces(plainName(n))
        if monoStrEq(name, "int") || monoStrEq(name, "int8") || monoStrEq(name, "int16") || monoStrEq(name, "int32") || monoStrEq(name, "int64"):
            return true
        if monoStrEq(name, "uint") || monoStrEq(name, "uint8") || monoStrEq(name, "uint16") || monoStrEq(name, "uint32") || monoStrEq(name, "uint64"):
            return true
        if monoStrEq(name, "float") || monoStrEq(name, "float32") || monoStrEq(name, "float64"):
            return true
        if monoStrEq(name, "bool") || monoStrEq(name, "char") || monoStrEq(name, "byte"):
            return true
        if monoStrEq(name, "str") || monoStrEq(name, "cstring"):
            return true
    return false

fn collectTypeArgMap(generics: Node, args: Node[], outNames: var str[], outTypes: var Node[]) =
    if stage1AstRefIsNil(generics) || nodeKind(generics) != nkGenericParams:
        return
    for i in 0..<kidCount generics:
        let defn: Node = kid(generics, i)
        if stage1AstRefNonNil(defn) && nodeKind(defn) == nkIdentDefs && kidCount defn > 0:
            let nameNode: Node = kid(defn, 0)
            let name: str = monoStripSpaces(plainName(nameNode))
            if len name > 0:
                var mapped: Node = astInvalidNodeId()
                if i < args.len:
                    mapped = get(args, i)
                elif kidCount defn > 2:
                    let defaultVal: Node = kid(defn, 2)
                    if stage1AstRefNonNil(defaultVal) && nodeKind(defaultVal) != nkEmpty:
                        mapped = replaceTypeVars(defaultVal, outNames, outTypes)
                if stage1AstRefNonNil(mapped):
                    add(outNames, name)
                    add(outTypes, mapped)

fn buildFullTypeArgs(generics: Node, mapNames: str[], mapTypes: Node[], fallbackArgs: Node[], outArgs: var Node[]) =
    if stage1AstRefNonNil(generics) && nodeKind(generics) == nkGenericParams:
        if buildTypeArgsFromMap(generics, mapNames, mapTypes, outArgs):
            return
    for i in 0..<fallbackArgs.len:
        add(outArgs, get(fallbackArgs, i))

fn instantiateType(name: str, typeArgs: Node[], rootStmts: Node[]*): bool =
    let dbgTypeFilter: str = os.GetEnvDefault("MONO_DEBUG_TYPE", "")
    let dbgTypeHit: bool = len(dbgTypeFilter) > 0 && name == dbgTypeFilter
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        instantiateTypeCalls = instantiateTypeCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            instantiateTypeNs = instantiateTypeNs + (cheng_monotime_ns() - startNs)
    let genNode: Node = monoGenericTypeGet(name)
    if dbgTypeHit:
        os.WriteLine(os.Get_stderr(),
                     "[mono] debugType: instantiateType name=" + name +
                     " hasGen=" + (stage1AstRefNonNil(genNode) ? "1" : "0") +
                     " argc=" + intToStr(typeArgs.len))
        os.C_fflush(os.Get_stderr())
    if stage1AstRefIsNil(genNode):
        return false
    var generics: Node = astInvalidNodeId()
    if kidCount genNode > 2:
        generics = kid(genNode, 2)
    var mapNames: str[4]
    var mapTypes: Node[4]
    collectTypeArgMap(generics, typeArgs, mapNames, mapTypes)
    var instArgs: Node[4]
    buildFullTypeArgs(generics, mapNames, mapTypes, typeArgs, instArgs)
    checkTraitConstraints(generics, mapNames, mapTypes, rootStmts)
    let instName: str = mangleInstance(name, instArgs)
    if dbgTypeHit:
        os.WriteLine(os.Get_stderr(),
                     "[mono] debugType: instName=" + instName +
                     " already=" + ((len(instMapGet(instName)) > 0) ? "1" : "0"))
        os.C_fflush(os.Get_stderr())
    if len(instMapGet(instName)) > 0:
        return true
    if ! mapHasStrIndex(instTypeIndex, instName):
        var instTy: Node = newNode(nkBracketExpr, nodePos(genNode))
        addSon(instTy, newIdent(name, nodePos(genNode)))
        for ti in 0..<instArgs.len:
            addSon(instTy, cloneTree get(instArgs, ti))
        mapPutStrNodeIndex(instTypeIndex, instTypeNames, instTypeNodes, instName, instTy)
    var whereExpr: Node = astInvalidNodeId()
    if kidCount genNode > 3:
        whereExpr = kid(genNode, 3)
    if stage1AstRefNonNil(whereExpr) && nodeKind(whereExpr) != nkEmpty:
        let res: int32 = evalWhereExpr(whereExpr, mapNames, mapTypes)
        if res == 0:
            addWhereDiag(nodePos(whereExpr), "where condition not satisfied: " + instName)
            return false
    trackLexStringStr(instName)
    instMapAdd instName
    var defNode: Node = astInvalidNodeId()
    if kidCount genNode > 1:
        defNode = kid(genNode, 1)
    let replacedDef: Node = replaceTypeVars(defNode, mapNames, mapTypes)
    var newDef: Node = transform(replacedDef, rootStmts, true)
    if stage1AstRefIsNil(newDef):
        newDef = replacedDef
    var decl: Node = newNode(nkTypeDecl, nodePos(genNode))
    nodeSetStrVal(decl, nodeStrVal(genNode))
    addSon(decl, newIdent(instName, nodePos(genNode)))
    addSon(decl, newDef)
    addSon(decl, newNode(nkEmpty, nodePos(genNode)))
    addSon(decl, newNode(nkEmpty, nodePos(genNode)))
    var pragmaNode: Node = astInvalidNodeId()
    if kidCount genNode > 4:
        pragmaNode = kid(genNode, 4)
    if stage1AstRefNonNil(pragmaNode) && nodeKind(pragmaNode) != nkEmpty:
        addSon(decl, cloneTree pragmaNode)
    else:
        addSon(decl, newNode(nkEmpty, nodePos(genNode)))
    add(rootStmts, decl)
    if dbgTypeHit:
        os.WriteLine(os.Get_stderr(),
                     "[mono] debugType: appended decl " + instName +
                     " defKind=nk#" + intToStr(int32(nodeKind(newDef))))
        os.C_fflush(os.Get_stderr())
    if monoEagerContainerInstEnabled():
        if monoStrEq(name, "seq"):
            instantiateFn("setLen", instArgs, rootStmts)
            instantiateFn("reserve", instArgs, rootStmts)
            instantiateFn("add", instArgs, rootStmts)
            instantiateFn("get", instArgs, rootStmts)
            instantiateFn("[]", instArgs, rootStmts)
            instantiateFn("[]=", instArgs, rootStmts)
            instantiateFn("arcRetainSeq", instArgs, rootStmts)
            instantiateFn("arcReleaseSeq", instArgs, rootStmts)
            if instArgs.len > 0 && isComparableType get(instArgs, 0):
                instantiateFn("__cheng_vec_contains", instArgs, rootStmts)
            instantiateFn("__cheng_slice_vec", instArgs, rootStmts)
        elif monoStrEq(name, "Table"):
            instantiateFn("TableNext", instArgs, rootStmts)
            instantiateFn("TableHas", instArgs, rootStmts)
            instantiateFn("TableGet", instArgs, rootStmts)
            instantiateFn("TablePut", instArgs, rootStmts)
            instantiateFn("TableLen", instArgs, rootStmts)
            instantiateFn("arcRetainTable", instArgs, rootStmts)
            instantiateFn("arcReleaseTable", instArgs, rootStmts)
    return true

fn instantiateFn(name: str, typeArgs: Node[], rootStmts: Node[]*): bool =
    let profOn: bool = monoProfileActive
    var startNs: int64
    if profOn:
        instantiateFnCalls = instantiateFnCalls + 1
        startNs = cheng_monotime_ns()
    defer:
        if profOn:
            instantiateFnNs = instantiateFnNs + (cheng_monotime_ns() - startNs)
    var genNode: Node = genericFnGet(name)
    if stage1AstRefIsNil(genNode):
        var missCached: bool
        let missFlag: int32 = monoHashMapStrIntGetCompat(genericFnMissingIndex, name, missCached)
        if missCached && missFlag != 0:
            return false
        # Defensive fallback: generic maps can miss under heavy mixed-source trees.
        # Re-scan once by exact name and backfill indices so the instantiation
        # defines the same symbol that transform() rewrites calls to.
        genNode = findGenericFnDecl(monoRoot, name)
        if stage1AstRefNonNil(genNode):
            genericFnAdd(name, genNode)
            hashmaps.HashMapStrIntPut(genericFnMissingIndex, name, 0)
        else:
            hashmaps.HashMapStrIntPut(genericFnMissingIndex, name, 1)
    if stage1AstRefIsNil(genNode):
        return false
    var generics: Node = astInvalidNodeId()
    if kidCount genNode > 4:
        generics = kid(genNode, 4)
    var mapNames: str[4]
    var mapTypes: Node[4]
    collectTypeArgMap(generics, typeArgs, mapNames, mapTypes)
    var instArgs: Node[4]
    buildFullTypeArgs(generics, mapNames, mapTypes, typeArgs, instArgs)
    checkTraitConstraints(generics, mapNames, mapTypes, rootStmts)
    let instName: str = mangleInstance(name, instArgs)
    if len(instMapGet(instName)) > 0:
        return true
    var pragmaNode: Node = astInvalidNodeId()
    if kidCount genNode > 5:
        pragmaNode = kid(genNode, 5)
    if stage1AstRefNonNil(pragmaNode) && nodeKind(pragmaNode) == nkPragma:
        for wi in 0..<kidCount pragmaNode:
            let ann: Node = kid(pragmaNode, wi)
            if stage1AstRefNonNil(ann) && nodeKind(ann) == nkAnnotation && kidCount ann > 0:
                let aname: str = monoStripSpaces(plainName(kid(ann, 0)))
                if monoStrEq(aname, "where") && kidCount ann > 1:
                    let whereExpr2: Node = kid(ann, 1)
                    if stage1AstRefNonNil(whereExpr2) && nodeKind(whereExpr2) != nkEmpty:
                        let res2: int32 = evalWhereExpr(whereExpr2, mapNames, mapTypes)
                        if res2 == 0:
                            addWhereDiag(nodePos(whereExpr2), "where condition not satisfied: " + instName)
                            return false
    trackLexStringStr(instName)
    instMapAdd instName
    var paramsNode: Node = astInvalidNodeId()
    if kidCount genNode > 1:
        paramsNode = kid(genNode, 1)
    var retNode: Node = astInvalidNodeId()
    if kidCount genNode > 2:
        retNode = kid(genNode, 2)
    var bodyNode: Node = astInvalidNodeId()
    if kidCount genNode > 3:
        bodyNode = kid(genNode, 3)
    let replacedParams: Node = replaceTypeVars(paramsNode, mapNames, mapTypes)
    let replacedRet: Node = replaceTypeVars(retNode, mapNames, mapTypes)
    let replacedBody: Node = replaceTypeVars(bodyNode, mapNames, mapTypes)
    var newParams: Node = transform(replacedParams, rootStmts, false)
    var newRet: Node = transform(replacedRet, rootStmts, true)
    var newBody: Node = transform(replacedBody, rootStmts, false)
    if stage1AstRefIsNil(newParams):
        newParams = replacedParams
    if stage1AstRefIsNil(newRet):
        newRet = replacedRet
    if stage1AstRefIsNil(newBody):
        newBody = replacedBody
    var decl: Node = newNode(nodeKind(genNode), nodePos(genNode))
    nodeSetStrVal(decl, nodeStrVal(genNode))
    addSon(decl, newIdent(instName, nodePos(genNode)))
    addSon(decl, newParams)
    addSon(decl, newRet)
    addSon(decl, newBody)
    addSon(decl, newNode(nkEmpty, nodePos(genNode)))
    if stage1AstRefNonNil(pragmaNode) && nodeKind(pragmaNode) != nkEmpty:
        addSon(decl, cloneTree pragmaNode)
    else:
        addSon(decl, newNode(nkEmpty, nodePos(genNode)))
    add(rootStmts, decl)
    return true

fn instantiateLambda(lam: Node, typeArgs: Node[], rootStmts: Node[]*): Node =
    if stage1AstRefIsNil(lam):
        return astInvalidNodeId()
    let baseName: str = lambdaBaseName lam
    var generics: Node = astInvalidNodeId()
    if kidCount lam > 4:
        generics = kid(lam, 4)
    var mapNames: str[4]
    var mapTypes: Node[4]
    if stage1AstRefNonNil(generics) && nodeKind(generics) == nkGenericParams && kidCount generics > 0:
        collectTypeArgMap(generics, typeArgs, mapNames, mapTypes)
    var instArgs: Node[4]
    buildFullTypeArgs(generics, mapNames, mapTypes, typeArgs, instArgs)
    let instName: str = monoInstanceName(baseName, instArgs)
    let existing: str = instMapGet(instName)
    if len(existing) > 0:
        return newIdent(existing, nodePos(lam))
    if instArgs.len > 0:
        trackLexStringStr(instName)
    instMapAdd instName
    var paramsNode: Node = astInvalidNodeId()
    if kidCount lam > 1:
        paramsNode = kid(lam, 1)
    var retNode: Node = astInvalidNodeId()
    if kidCount lam > 2:
        retNode = kid(lam, 2)
    var bodyNode: Node = astInvalidNodeId()
    if kidCount lam > 3:
        bodyNode = kid(lam, 3)
    let newParams: Node = transform(replaceTypeVars(paramsNode, mapNames, mapTypes), rootStmts, false)
    let newRet: Node = transform(replaceTypeVars(retNode, mapNames, mapTypes), rootStmts, true)
    let newBody: Node = transform(replaceTypeVars(bodyNode, mapNames, mapTypes), rootStmts, false)
    var decl: Node = newNode(lambdaDeclKind lam, nodePos(lam))
    nodeSetStrVal(decl, nodeStrVal(lam))
    addSon(decl, newIdent(instName, nodePos(lam)))
    addSon(decl, newParams)
    addSon(decl, newRet)
    addSon(decl, newBody)
    addSon(decl, newNode(nkEmpty, nodePos(lam)))
    addSon(decl, newNode(nkEmpty, nodePos(lam)))
    add(rootStmts, decl)
    return newIdent(instName, nodePos(lam))

fn lambdaFnType(lam: Node, typeArgs: Node[], rootStmts: Node[]*): Node =
    if stage1AstRefIsNil(lam):
        return astInvalidNodeId()
    var generics: Node = astInvalidNodeId()
    if kidCount lam > 4:
        generics = kid(lam, 4)
    var mapNames: str[4]
    var mapTypes: Node[4]
    if stage1AstRefNonNil(generics) && nodeKind(generics) == nkGenericParams && kidCount generics > 0:
        collectTypeArgMap(generics, typeArgs, mapNames, mapTypes)
    var paramsNode: Node = astInvalidNodeId()
    if kidCount lam > 1:
        paramsNode = kid(lam, 1)
    var retNode: Node = astInvalidNodeId()
    if kidCount lam > 2:
        retNode = kid(lam, 2)
    let newParams: Node = transform(replaceTypeVars(paramsNode, mapNames, mapTypes), rootStmts, false)
    let newRet: Node = transform(replaceTypeVars(retNode, mapNames, mapTypes), rootStmts, true)
    var ty: Node = newNode(nkFnTy, nodePos(lam))
    addSon(ty, newParams)
    addSon(ty, newRet)
    return ty

fn transformCallTemplate(name: str, templNode: Node, callNode: Node, rootStmts: Node[]*): Node =
    if stage1AstRefIsNil(templNode) || stage1AstRefIsNil(callNode):
        return callNode
    var paramsNode: Node = astInvalidNodeId()
    if kidCount templNode > 1:
        paramsNode = kid(templNode, 1)
    var bodyNode: Node = astInvalidNodeId()
    if kidCount templNode > 3:
        bodyNode = kid(templNode, 3)
    if stage1AstRefIsNil(paramsNode) || stage1AstRefIsNil(bodyNode):
        return callNode
    var mapNames: str[4]
    var mapTypes: Node[4]
    var argIdx: int32 = 1
    for pi in 0..<kidCount paramsNode:
        let defs: Node = kid(paramsNode, pi)
        if stage1AstRefNonNil(defs) && nodeKind(defs) == nkIdentDefs && kidCount defs > 2:
            for ni in 0..<identDefsNameCount(defs):
                let nameNode: Node = kid(defs, ni)
                if argIdx < kidCount callNode:
                    add(mapNames, monoStripSpaces(plainName(nameNode)))
                    add(mapTypes, kid(callNode, argIdx))
                    argIdx = argIdx + 1
    let expanded: Node = replaceTypeVars(bodyNode, mapNames, mapTypes)
    let transformed: Node = transform(expanded, rootStmts)
    if stage1AstRefNonNil(transformed) && nodeKind(transformed) == nkStmtList && kidCount transformed == 1:
        return kid(transformed, 0)
    return transformed

fn typeBaseName(n: Node): str =
    if stage1AstRefIsNil(n):
        return ""
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        return monoStripSpaces(plainName(n))
    if nodeKind(n) == nkDotExpr && kidCount n > 1:
        return monoStripSpaces(plainName(kid(n, 1)))
    return ""

fn startsUpperAscii(s: str): bool =
    if len(s) == 0:
        return false
    let c: char = s[0]
    return (c >= 'A' && c <= 'Z')

fn looksLikeTypeNameNode(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    if nodeKind(n) != nkIdent && nodeKind(n) != nkSymbol:
        return false
    if isComparableType n:
        return true
    let nm: str = monoStripSpaces(plainName(n))
    if len nm == 0:
        return false
    return startsUpperAscii nm

fn looksLikeTypeExpr(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    case nodeKind(n)
    of nkIdent, nkSymbol:
        return looksLikeTypeNameNode n
    of nkPtrTy, nkRefTy, nkVarTy, nkSetTy:
        if kidCount n > 0:
            return looksLikeTypeExpr kid(n, 0)
        return true
    of nkFnTy, nkTupleTy:
        return true
    of nkDotExpr:
        if kidCount n > 1:
            return looksLikeTypeNameNode kid(n, 1)
        return false
    of nkBracketExpr:
        if kidCount n == 0:
            return false
        let baseName: str = typeBaseName kid(n, 0)
        if len baseName == 0 || !monoHasGenericType(baseName):
            return false
        for i in 1..<kidCount n:
            if ! looksLikeTypeExpr kid(n, i):
                return false
        return true
    of nkPar:
        if kidCount n == 1:
            return looksLikeTypeExpr kid(n, 0)
        return false
    else:
        return false

fn bracketLooksLikeTypeCall(n: Node): bool =
    if stage1AstRefIsNil(n) || nodeKind(n) != nkBracketExpr:
        return false
    if kidCount n == 0:
        return false
    let baseName: str = typeBaseName kid(n, 0)
    if len baseName == 0 || !monoHasGenericType(baseName):
        return false
    for i in 1..<kidCount n:
        if ! looksLikeTypeExpr kid(n, i):
            return false
    return true

fn isDefiniteTypeCallee(n: Node): bool =
    if stage1AstRefIsNil(n):
        return false
    case nodeKind(n)
    of nkPtrTy, nkRefTy, nkVarTy, nkTupleTy, nkSetTy, nkFnTy:
        return true
    of nkPar:
        if kidCount n == 1:
            return isDefiniteTypeCallee kid(n, 0)
        return false
    of nkIdent, nkSymbol:
        let nm: str = monoStripSpaces(plainName(n))
        if monoStrEq(nm, ""):
            return false
        if monoIsBuiltinTypeKey(nm):
            return true
        if mapHasStrIndex(monoTypeIndex, nm) || mapHasStrIndex(instTypeIndex, nm) || monoHasGenericType(nm):
            return true
        return false
    of nkDotExpr:
        if kidCount n > 1:
            let member: Node = kid(n, 1)
            if stage1AstRefNonNil(member) && (nodeKind(member) == nkIdent || nodeKind(member) == nkSymbol):
                let nm2: str = monoStripSpaces(plainName(member))
                if monoIsBuiltinTypeKey(nm2):
                    return true
                if mapHasStrIndex(monoTypeIndex, nm2) || mapHasStrIndex(instTypeIndex, nm2) || monoHasGenericType(nm2):
                    return true
        return false
    of nkBracketExpr:
        if kidCount n == 0:
            return false
        let baseName: str = typeBaseName kid(n, 0)
        if monoStrEq(baseName, ""):
            return false
        if monoIsBuiltinTypeKey(baseName):
            return true
        if mapHasStrIndex(monoTypeIndex, baseName) || mapHasStrIndex(instTypeIndex, baseName) || monoHasGenericType(baseName):
            return true
        return false
    else:
        return false

fn bracketCallToExpr(n: Node): Node =
    if stage1AstRefIsNil(n) || nodeKind(n) != nkCall || kidCount n < 2:
        return astInvalidNodeId()
    let head: Node = kid(n, 0)
    if stage1AstRefIsNil(head):
        return astInvalidNodeId()
    let hname: str = monoStripSpaces(plainName(head))
    if monoStrNe(hname, "bracket") && monoStrNe(hname, "[]"):
        return astInvalidNodeId()
    var br: Node = newNode(nkBracketExpr, nodePos(n))
    for i in 1..<kidCount n:
        addSon(br, kid(n, i))
    return br

fn transformIdentDefs(n: Node, rootStmts: Node[]*, defaultsAreTypes: bool): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    var changed: bool
    var outKids: Node[4]
    for i in 0..<kidCount n:
        let oldChild: Node = kid(n, i)
        var child: Node = astInvalidNodeId()
        if i == 0:
            child = transform(oldChild, rootStmts, false)
        elif i == 1:
            child = transform(oldChild, rootStmts, true)
        elif i == 2:
            if defaultsAreTypes:
                child = transform(oldChild, rootStmts, true)
            else:
                child = transform(oldChild, rootStmts, false)
        else:
            child = transform(oldChild, rootStmts, false)
        if monoNodeNe(child, oldChild):
            changed = true
        if stage1AstRefNonNil(child):
            add(outKids, child)
    if ! changed:
        return n
    var out: Node = newNode(nodeKind(n), nodePos(n))
    nodeSetIdent(out, nodeIdent(n))
    nodeSetStrVal(out, nodeStrVal(n))
    nodeSetIntVal(out, nodeIntVal(n))
    nodeSetFloatVal(out, nodeFloatVal(n))
    for j in 0..<outKids.len:
        addSon(out, get(outKids, j))
    return out

fn transformGenericParams(n: Node, rootStmts: Node[]*): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    var changed: bool
    var outKids: Node[4]
    for i in 0..<kidCount n:
        let oldChild: Node = kid(n, i)
        var child: Node = oldChild
        if stage1AstRefNonNil(oldChild) && nodeKind(oldChild) == nkIdentDefs:
            child = transformIdentDefs(oldChild, rootStmts, true)
        else:
            child = transform(oldChild, rootStmts, true)
        if monoNodeNe(child, oldChild):
            changed = true
        if stage1AstRefNonNil(child):
            add(outKids, child)
    if ! changed:
        return n
    var out: Node = newNode(nodeKind(n), nodePos(n))
    nodeSetIdent(out, nodeIdent(n))
    nodeSetStrVal(out, nodeStrVal(n))
    nodeSetIntVal(out, nodeIntVal(n))
    nodeSetFloatVal(out, nodeFloatVal(n))
    for j in 0..<outKids.len:
        addSon(out, get(outKids, j))
    return out

fn transformFallback(n: Node, rootStmts: Node[]*, inTypeContext: bool): Node =
    var profStartFb: int64
    if monoProfileActive:
        transformFallbackCalls = transformFallbackCalls + 1
        profStartFb = cheng_monotime_ns()
    defer:
        if monoProfileActive:
            transformFallbackNs = transformFallbackNs + (cheng_monotime_ns() - profStartFb)
    let kc: int32 = kidCount n
    if kc == 0:
        return n
    var changed: bool
    var outKids: Node[]
    for k in 0..<kc:
        let oldChild: Node = kid(n, k)
        let child: Node = transform(oldChild, rootStmts, inTypeContext)
        let removed: bool = (stage1AstRefIsNil(child)) && (stage1AstRefNonNil(oldChild))
        if !changed && (monoNodeNe(child, oldChild) || removed):
            changed = true
            outKids.cap = kc
            for back in 0..<k:
                let prev: Node = kid(n, back)
                if stage1AstRefNonNil(prev):
                    add(outKids, prev)
        if changed && stage1AstRefNonNil(child):
            add(outKids, child)
    if ! changed:
        return n
    var out: Node = newNode(nodeKind(n), nodePos(n))
    nodeSetIdent(out, nodeIdent(n))
    nodeSetStrVal(out, nodeStrVal(n))
    nodeSetIntVal(out, nodeIntVal(n))
    nodeSetFloatVal(out, nodeFloatVal(n))
    for ki in 0..<outKids.len:
        addSon(out, get(outKids, ki))
    return out

fn transform(n: Node, rootStmts: Node[]*, inTypeContext: bool = false): Node =
    if stage1AstRefIsNil(n):
        return astInvalidNodeId()
    var profStart: int64
    if monoProfileActive:
        transformCalls = transformCalls + 1
        profStart = cheng_monotime_ns()
    defer:
        if monoProfileActive:
            transformNs = transformNs + (cheng_monotime_ns() - profStart)
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        monoMaybeInstantiateMangledFnName(n, rootStmts)
    var changed: bool
    case nodeKind(n)
    of nkModule, nkStmtList:
        var profStartMod: int64
        if monoProfileActive:
            transformModuleCalls = transformModuleCalls + 1
            profStartMod = cheng_monotime_ns()
        defer:
            if monoProfileActive:
                transformModuleNs = transformModuleNs + (cheng_monotime_ns() - profStartMod)
        monoValueScopePush()
        var outKids0: Node[4]
        for i0 in 0..<kidCount n:
            let oldChild0: Node = kid(n, i0)
            let child0: Node = transform(oldChild0, rootStmts, false)
            if monoNodeNe(child0, oldChild0):
                changed = true
            if stage1AstRefNonNil(child0):
                add(outKids0, child0)
        monoValueScopePop()
        if ! changed:
            return n
        var out0: Node = newNode(nodeKind(n), nodePos(n))
        nodeSetIdent(out0, nodeIdent(n))
        nodeSetStrVal(out0, nodeStrVal(n))
        nodeSetIntVal(out0, nodeIntVal(n))
        nodeSetFloatVal(out0, nodeFloatVal(n))
        for k0 in 0..<outKids0.len:
            addSon(out0, get(outKids0, k0))
        return out0
    of nkTypeDecl:
        var profStartTypeDecl: int64
        if monoProfileActive:
            transformTypeDeclCalls = transformTypeDeclCalls + 1
            profStartTypeDecl = cheng_monotime_ns()
        defer:
            if monoProfileActive:
                transformTypeDeclNs = transformTypeDeclNs + (cheng_monotime_ns() - profStartTypeDecl)
        if kidCount n > 2:
            let gens: Node = kid(n, 2)
            if stage1AstRefNonNil(gens) && nodeKind(gens) == nkGenericParams && kidCount gens > 0:
                let nm0: str = getName kid(n, 0)
                if len nm0 > 0 && ! mapHasStrIndex(genericTypeIndex, nm0):
                    mapPutStrNodeIndex(genericTypeIndex, genericTypeNames, genericTypeNodes, nm0, n)
                return newNode(nkEmpty, nodePos(n))
        var outKids: Node[4]
        for i in 0..<kidCount n:
            let oldChild: Node = kid(n, i)
            var child: Node = astInvalidNodeId()
            if i == 0:
                child = transform(oldChild, rootStmts, false)
            elif i == 1:
                child = transform(oldChild, rootStmts, true)
            elif i == 2 && stage1AstRefNonNil(oldChild) && nodeKind(oldChild) == nkGenericParams:
                child = transformGenericParams(oldChild, rootStmts)
            else:
                child = transform(oldChild, rootStmts, false)
            if stage1AstRefIsNil(child):
                child = oldChild
            if monoNodeNe(child, oldChild):
                changed = true
            if stage1AstRefNonNil(child):
                add(outKids, child)
        if ! changed:
            return n
        var out: Node = newNode(nodeKind(n), nodePos(n))
        nodeSetIdent(out, nodeIdent(n))
        nodeSetStrVal(out, nodeStrVal(n))
        nodeSetIntVal(out, nodeIntVal(n))
        nodeSetFloatVal(out, nodeFloatVal(n))
        for ki in 0..<outKids.len:
            addSon(out, get(outKids, ki))
        return out
    of nkFnDecl, nkIteratorDecl:
        var profStartFnDecl: int64
        if monoProfileActive:
            transformFnDeclCalls = transformFnDeclCalls + 1
            profStartFnDecl = cheng_monotime_ns()
        defer:
            if monoProfileActive:
                transformFnDeclNs = transformFnDeclNs + (cheng_monotime_ns() - profStartFnDecl)
        if kidCount n > 4:
            let gens2: Node = kid(n, 4)
            if stage1AstRefNonNil(gens2) && nodeKind(gens2) == nkGenericParams && kidCount gens2 > 0:
                let nm1: str = getName kid(n, 0)
                if len nm1 > 0 && ! genericFnHas(nm1):
                    genericFnAdd(nm1, n)
                return newNode(nkEmpty, nodePos(n))
        monoValueScopePush()
        if kidCount n > 1:
            monoBindFormalParams kid(n, 1)
        var outKids2: Node[6]
        for i2 in 0..<kidCount n:
            let oldChild2: Node = kid(n, i2)
            var child2: Node = astInvalidNodeId()
            if i2 == 0:
                child2 = oldChild2
            elif i2 == 1:
                child2 = transform(oldChild2, rootStmts, false)
            elif i2 == 2:
                child2 = transform(oldChild2, rootStmts, true)
            elif i2 == 3:
                child2 = transform(oldChild2, rootStmts, false)
            elif i2 == 4 && stage1AstRefNonNil(oldChild2) && nodeKind(oldChild2) == nkGenericParams:
                child2 = transformGenericParams(oldChild2, rootStmts)
            else:
                child2 = transform(oldChild2, rootStmts, false)
            if stage1AstRefIsNil(child2):
                child2 = oldChild2
            if monoNodeNe(child2, oldChild2):
                changed = true
            add(outKids2, child2)
        monoValueScopePop()
        if ! changed:
            return n
        var out2: Node = newNode(nodeKind(n), nodePos(n))
        nodeSetIdent(out2, nodeIdent(n))
        nodeSetStrVal(out2, nodeStrVal(n))
        nodeSetIntVal(out2, nodeIntVal(n))
        nodeSetFloatVal(out2, nodeFloatVal(n))
        for ki2 in 0..<outKids2.len:
            addSon(out2, get(outKids2, ki2))
        return out2
    of nkGenericParams:
        return transformGenericParams(n, rootStmts)
    of nkIdentDefs:
        return transformIdentDefs(n, rootStmts, false)
    of nkTemplateDecl:
        mapPutStrNodeIndex(templateIndex, templateNames, templateNodes, getName kid(n, 0), n)
        return newNode(nkEmpty, nodePos(n))
    of nkMacroDecl:
        mapPutStrNodeIndex(macroIndex, macroNames, macroNodes, getName kid(n, 0), n)
        return newNode(nkEmpty, nodePos(n))
    of nkLet, nkVar, nkConst:
        var profStartLet: int64
        if monoProfileActive:
            transformLetCalls = transformLetCalls + 1
            profStartLet = cheng_monotime_ns()
        defer:
            if monoProfileActive:
                transformLetNs = transformLetNs + (cheng_monotime_ns() - profStartLet)
        var nameNode: Node = astInvalidNodeId()
        if kidCount n > 0:
            nameNode = kid(n, 0)
        var typeNode: Node = astInvalidNodeId()
        if kidCount n > 1:
            typeNode = kid(n, 1)
        var valNode: Node = astInvalidNodeId()
        if kidCount n > 2:
            valNode = kid(n, 2)
        var pragmaNode: Node = astInvalidNodeId()
        if kidCount n > 3:
            pragmaNode = kid(n, 3)
        var patternType: Node = astInvalidNodeId()
        if stage1AstRefNonNil(nameNode) && nodeKind(nameNode) == nkPattern && kidCount nameNode > 1:
            patternType = kid(nameNode, 1)
        var newType: Node = transform(typeNode, rootStmts, true)
        if (stage1AstRefIsNil(newType) || nodeKind(newType) == nkEmpty) && stage1AstRefNonNil(patternType) && nodeKind(patternType) != nkEmpty:
            newType = transform(patternType, rootStmts, true)
        var newVal: Node = astInvalidNodeId()
        var lamArgs: Node[4]
        var lamArgsReady: bool
        let lam: Node = unwrapLambda valNode
        if stage1AstRefNonNil(lam):
            let hasCapture: bool = monoLambdaHasCapture lam
            if ! hasCapture:
                var gen: Node = astInvalidNodeId()
                if kidCount lam > 4:
                    gen = kid(lam, 4)
                if stage1AstRefNonNil(gen) && nodeKind(gen) == nkGenericParams && kidCount gen > 0:
                    var expectedType: Node = newType
                    if stage1AstRefIsNil(expectedType) || nodeKind(expectedType) != nkFnTy:
                        expectedType = typeNode
                    if (stage1AstRefIsNil(expectedType) || nodeKind(expectedType) != nkFnTy) && stage1AstRefNonNil(patternType):
                        expectedType = patternType
                    if stage1AstRefNonNil(expectedType) && nodeKind(expectedType) == nkFnTy:
                        var args: Node[4]
                        if inferTypeArgsFromExpectedFn(lam, expectedType, args):
                            newVal = instantiateLambda(lam, args, rootStmts)
                            lamArgs = args
                            lamArgsReady = true
                        else:
                            var paramNames: str[2]
                            collectGenericParamNames(gen, paramNames)
                            if paramNames.len == 1:
                                var picked: Node = astInvalidNodeId()
                                if kidCount expectedType > 0:
                                    let expParams: Node = kid(expectedType, 0)
                                    if stage1AstRefNonNil(expParams) && kidCount expParams > 0:
                                        let edef: Node = kid(expParams, 0)
                                        if stage1AstRefNonNil(edef) && kidCount edef > 1:
                                            let et: Node = kid(edef, 1)
                                            if stage1AstRefNonNil(et) && nodeKind(et) != nkEmpty:
                                                picked = et
                                if stage1AstRefIsNil(picked) && kidCount expectedType > 1:
                                    let retTy: Node = kid(expectedType, 1)
                                    if stage1AstRefNonNil(retTy) && nodeKind(retTy) != nkEmpty:
                                        picked = retTy
                                if stage1AstRefNonNil(picked):
                                    var args2: Node[1]
                                    add(args2, picked)
                                    newVal = instantiateLambda(lam, args2, rootStmts)
                                    lamArgs = args2
                                    lamArgsReady = true
                else:
                    newVal = instantiateLambda(lam, default[Node[]], rootStmts)
                    lamArgsReady = true
                if (stage1AstRefIsNil(newType) || nodeKind(newType) == nkEmpty) && lamArgsReady:
                    let fnTy: Node = lambdaFnType(lam, lamArgs, rootStmts)
                    if stage1AstRefNonNil(fnTy):
                        newType = fnTy
        if stage1AstRefIsNil(newVal):
            newVal = transform(valNode, rootStmts, false)
        if stage1AstRefIsNil(newVal):
            newVal = valNode
        var newName: Node = transform(nameNode, rootStmts, false)
        if stage1AstRefIsNil(newName):
            newName = nameNode
        var outLet: Node = newNode(nodeKind(n), nodePos(n))
        addSon(outLet, newName)
        addSon(outLet, newType)
        addSon(outLet, newVal)
        addSon(outLet, transform(pragmaNode, rootStmts, false))
        var bindType: Node = typeNode
        if stage1AstRefIsNil(bindType) || nodeKind(bindType) == nkEmpty:
            bindType = patternType
        if stage1AstRefIsNil(bindType) || nodeKind(bindType) == nkEmpty:
            if stage1AstRefNonNil(newVal) && nodeTypeCacheValid(newVal) && !isEmpty(nodeTypeCache(newVal)):
                bindType = nodeTypeCache(newVal)
            elif stage1AstRefNonNil(valNode) && nodeTypeCacheValid(valNode) && !isEmpty(nodeTypeCache(valNode)):
                bindType = nodeTypeCache(valNode)
        if stage1AstRefIsNil(bindType) || nodeKind(bindType) == nkEmpty:
            let inferred: Node = monoInferBindTypeFromInitCall(newVal)
            if stage1AstRefNonNil(inferred) && nodeKind(inferred) != nkEmpty:
                bindType = inferred
        if stage1AstRefIsNil(bindType) || nodeKind(bindType) == nkEmpty:
            let inferred2: Node = monoLookupExprType(newVal)
            if stage1AstRefNonNil(inferred2) && nodeKind(inferred2) != nkEmpty:
                bindType = inferred2
        monoBindNameWithType(nameNode, bindType)
        return outLet
    of nkBracketExpr:
        var profStartBracket: int64
        if monoProfileActive:
            transformBracketCalls = transformBracketCalls + 1
            profStartBracket = cheng_monotime_ns()
        defer:
            if monoProfileActive:
                transformBracketNs = transformBracketNs + (cheng_monotime_ns() - profStartBracket)
        if kidCount n > 0:
            let head: Node = kid(n, 0)
            let lam2: Node = unwrapLambda head
            if stage1AstRefNonNil(lam2):
                if monoLambdaHasCapture lam2:
                    return transformFallback(n, rootStmts, inTypeContext)
                var args0: Node[4]
                for ai in 1..<kidCount n:
                    let arg0: Node = transform(kid(n, ai), rootStmts, false)
                    if stage1AstRefNonNil(arg0):
                        add(args0, arg0)
                return instantiateLambda(lam2, args0, rootStmts)
            if stage1AstRefNonNil(head) && (nodeKind(head) == nkIdent || nodeKind(head) == nkSymbol || nodeKind(head) == nkDotExpr):
                let name: str = monoHeadDisplayName(head)
                if len name > 0:
                    let dbgTypeFilter: str = os.GetEnvDefault("MONO_DEBUG_TYPE", "")
                    let dbgTypeHit: bool = len(dbgTypeFilter) > 0 && name == dbgTypeFilter
                    if dbgTypeHit:
                        os.WriteLine(os.Get_stderr(),
                                     "[mono] debugType: bracket name=" + name +
                                     " inTypeContext=" + (inTypeContext ? "1" : "0") +
                                     " hasGenericType=" + (monoHasGenericType(name) ? "1" : "0") +
                                     " argc=" + intToStr(kidCount(n) - 1))
                        os.C_fflush(os.Get_stderr())
                    if inTypeContext && len(name) > 0:
                        var args: Node[4]
                        for i in 1..<kidCount n:
                            add(args, kid(n, i))
                        var instArgs: Node[4]
                        if instantiateType(name, args, rootStmts):
                            let genNode: Node = monoGenericTypeGet(name)
                            var generics: Node = astInvalidNodeId()
                            if stage1AstRefNonNil(genNode) && kidCount genNode > 2:
                                generics = kid(genNode, 2)
                            var mapNames: str[4]
                            var mapTypes: Node[4]
                            collectTypeArgMap(generics, args, mapNames, mapTypes)
                            buildFullTypeArgs(generics, mapNames, mapTypes, args, instArgs)
                            let instTypeName: str = mangleInstance(name, instArgs)
                            return newIdent(instTypeName, nodePos(n))
                    var genNode2: Node = genericFnGet(name)
                    if stage1AstRefIsNil(genNode2) && genericFnHas(name):
                        genNode2 = findGenericFnDecl(monoRoot, name)
                        if stage1AstRefNonNil(genNode2):
                            genericFnAdd(name, genNode2)
                    if stage1AstRefNonNil(genNode2):
                        var args2: Node[4]
                        for j in 1..<kidCount n:
                            add(args2, kid(n, j))
                        var generics2: Node = astInvalidNodeId()
                        if kidCount genNode2 > 4:
                            generics2 = kid(genNode2, 4)
                        var mapNames2: str[4]
                        var mapTypes2: Node[4]
                        collectTypeArgMap(generics2, args2, mapNames2, mapTypes2)
                        var instArgs2: Node[4]
                        buildFullTypeArgs(generics2, mapNames2, mapTypes2, args2, instArgs2)
                        let instFnName2: str = mangleInstance(name, instArgs2)
                        if instantiateFn(name, instArgs2, rootStmts):
                            return newIdent(instFnName2, nodePos(n))
        return transformFallback(n, rootStmts, inTypeContext)
    of nkPrefix:
        if kidCount n > 1:
            let opNode: Node = kid(n, 0)
            if stage1AstRefNonNil(opNode) && monoStrEq(getName(opNode), "$"):
                let argNode: Node = kid(n, 1)
                let callNode: Node = newNode(nkCall, nodePos(n))
                nodeSetTypeCache(callNode, nodeTypeCache(n))
                nodeSetTypeCacheValid(callNode, nodeTypeCacheValid(n))
                addSon(callNode, newIdent("$", nodePos(n)))
                addSon(callNode, argNode)
                return transform(callNode, rootStmts, false)
        return transformFallback(n, rootStmts, inTypeContext)
    of nkLambda:
        var profStartLambda: int64
        if monoProfileActive:
            transformLambdaCalls = transformLambdaCalls + 1
            profStartLambda = cheng_monotime_ns()
        defer:
            if monoProfileActive:
                transformLambdaNs = transformLambdaNs + (cheng_monotime_ns() - profStartLambda)
        var gen2: Node = astInvalidNodeId()
        if kidCount n > 4:
            gen2 = kid(n, 4)
        if stage1AstRefNonNil(gen2) && nodeKind(gen2) == nkGenericParams && kidCount gen2 > 0:
            return n
        if monoLambdaHasCapture n:
            var outKidsL: Node[6]
            for li in 0..<kidCount n:
                let oldChildL: Node = kid(n, li)
                var childL: Node = astInvalidNodeId()
                if li == 1:
                    childL = transform(oldChildL, rootStmts, false)
                elif li == 2:
                    childL = transform(oldChildL, rootStmts, true)
                elif li == 3:
                    childL = transform(oldChildL, rootStmts, false)
                elif li == 4 && stage1AstRefNonNil(oldChildL) && nodeKind(oldChildL) == nkGenericParams:
                    childL = transformGenericParams(oldChildL, rootStmts)
                else:
                    childL = transform(oldChildL, rootStmts, false)
                if stage1AstRefIsNil(childL):
                    childL = oldChildL
                add(outKidsL, childL)
            var outL: Node = newNode(nodeKind(n), nodePos(n))
            nodeSetIdent(outL, nodeIdent(n))
            nodeSetStrVal(outL, nodeStrVal(n))
            nodeSetIntVal(outL, nodeIntVal(n))
            nodeSetFloatVal(outL, nodeFloatVal(n))
            for lk in 0..<outKidsL.len:
                addSon(outL, get(outKidsL, lk))
            return outL
        return instantiateLambda(n, default[Node[]], rootStmts)
    of nkCall:
        var profStartCall: int64
        if monoProfileActive:
            transformCallCalls = transformCallCalls + 1
            profStartCall = cheng_monotime_ns()
        defer:
            if monoProfileActive:
                transformCallNs = transformCallNs + (cheng_monotime_ns() - profStartCall)
        if kidCount n > 0:
            let rawHead: Node = kid(n, 0)
            var head2: Node = rawHead
            let bracketHead: Node = bracketCallToExpr rawHead
            let headFromBracket: bool = stage1AstRefNonNil(bracketHead)
            if headFromBracket:
                head2 = bracketHead
            let headName0: str = monoHeadDisplayName(head2)
            let isTypeCall: bool = (kidCount n == 2) && isDefiniteTypeCallee(head2)
            if monoStrEq(headName0, "new"):
                var changedNew: bool
                var outKidsNew: Node[4]
                for ciNew in 0..<kidCount n:
                    let oldChildNew: Node = kid(n, ciNew)
                    var childNew: Node = astInvalidNodeId()
                    if ciNew == 0:
                        childNew = transform(oldChildNew, rootStmts, false)
                    else:
                        var useTypeContext: bool
                        if ciNew == 1:
                            let argValue: Node = monoCallArgValue(oldChildNew)
                            useTypeContext =
                                looksLikeTypeExpr(argValue) ||
                                isDefiniteTypeCallee(argValue) ||
                                bracketLooksLikeTypeCall(argValue)
                        childNew = transform(oldChildNew, rootStmts, useTypeContext)
                        if ciNew == 1:
                            var argValue2: Node = monoCallArgValue(childNew)
                            if stage1AstRefNonNil(argValue2) && nodeKind(argValue2) == nkBracketExpr && kidCount(argValue2) > 0:
                                let baseName2: str = typeBaseName(kid(argValue2, 0))
                                if len(baseName2) > 0:
                                    var argsNew2: Node[4]
                                    for aiNew2 in 1..<kidCount(argValue2):
                                        add(argsNew2, kid(argValue2, aiNew2))
                                    if instantiateType(baseName2, argsNew2, rootStmts):
                                        let instTypeName2: str = mangleInstance(baseName2, argsNew2)
                                        let instTypeNode2: Node = newIdent(instTypeName2, nodePos(argValue2))
                                        if stage1AstRefNonNil(childNew) && nodeKind(childNew) == nkCallArg:
                                            var replArg2: Node = cloneNodeShallow(childNew)
                                            if kidCount(childNew) > 1:
                                                addSon(replArg2, cloneTree(kid(childNew, 0)))
                                                addSon(replArg2, instTypeNode2)
                                            elif kidCount(childNew) > 0:
                                                addSon(replArg2, instTypeNode2)
                                            childNew = replArg2
                                        else:
                                            childNew = instTypeNode2
                    if monoNodeNe(childNew, oldChildNew):
                        changedNew = true
                    if stage1AstRefNonNil(childNew):
                        add(outKidsNew, childNew)
                if !changedNew:
                    return n
                var outCallNew: Node = newNode(nodeKind(n), nodePos(n))
                nodeSetIdent(outCallNew, nodeIdent(n))
                nodeSetStrVal(outCallNew, nodeStrVal(n))
                nodeSetIntVal(outCallNew, nodeIntVal(n))
                nodeSetFloatVal(outCallNew, nodeFloatVal(n))
                nodeSetCallStyle(outCallNew, nodeCallStyle(n))
                for cjNew in 0..<outKidsNew.len:
                    addSon(outCallNew, get(outKidsNew, cjNew))
                return outCallNew
            if stage1AstRefNonNil(head2) && nodeKind(head2) == nkBracketExpr && bracketLooksLikeTypeCall head2:
                var callChanged: bool
                var outKidsCall: Node[4]
                for ci in 0..<kidCount n:
                    var oldChildC: Node = kid(n, ci)
                    if ci == 0 && headFromBracket:
                        oldChildC = head2
                    var childC: Node = astInvalidNodeId()
                    if ci == 0:
                        childC = transform(oldChildC, rootStmts, true)
                    else:
                        childC = transform(oldChildC, rootStmts, false)
                    if monoNodeNe(childC, oldChildC):
                        callChanged = true
                    if stage1AstRefNonNil(childC):
                        add(outKidsCall, childC)
                if ! callChanged:
                    return n
                var outCall: Node = newNode(nodeKind(n), nodePos(n))
                nodeSetIdent(outCall, nodeIdent(n))
                nodeSetStrVal(outCall, nodeStrVal(n))
                nodeSetIntVal(outCall, nodeIntVal(n))
                nodeSetFloatVal(outCall, nodeFloatVal(n))
                for cj in 0..<outKidsCall.len:
                    addSon(outCall, get(outKidsCall, cj))
                return outCall
            if headFromBracket:
                var callChanged2: bool = true
                var outKidsCall2: Node[4]
                for ci2 in 0..<kidCount n:
                    var oldChild2: Node = kid(n, ci2)
                    if ci2 == 0:
                        oldChild2 = head2
                    var child2: Node = astInvalidNodeId()
                    if ci2 == 0:
                        child2 = transform(oldChild2, rootStmts, false)
                    else:
                        child2 = transform(oldChild2, rootStmts, false)
                    if monoNodeNe(child2, oldChild2):
                        callChanged2 = true
                    if stage1AstRefNonNil(child2):
                        add(outKidsCall2, child2)
                if ! callChanged2:
                    return n
                var outCall2: Node = newNode(nodeKind(n), nodePos(n))
                nodeSetIdent(outCall2, nodeIdent(n))
                nodeSetStrVal(outCall2, nodeStrVal(n))
                nodeSetIntVal(outCall2, nodeIntVal(n))
                nodeSetFloatVal(outCall2, nodeFloatVal(n))
                for cj2 in 0..<outKidsCall2.len:
                    addSon(outCall2, get(outKidsCall2, cj2))
                return outCall2
            if stage1AstRefNonNil(head2) && nodeKind(head2) == nkDotExpr && kidCount head2 > 1:
                let base2: Node = kid(head2, 0)
                let member2: Node = kid(head2, 1)
                if stage1AstRefNonNil(member2) && (nodeKind(member2) == nkIdent || nodeKind(member2) == nkSymbol):
                    let nm2: str = monoStripSpaces(plainName(member2))
                    let baseTy2: Node = monoLookupExprType base2
                    let dispatchIdx: int32 = traitDispatchLookup(baseTy2, nm2)
                    if dispatchIdx >= 0:
                        let initName: str = get(traitDispatchInitNames, dispatchIdx)
                        var vtCall: Node = newNode(nkCall, nodePos(n))
                        addSon(vtCall, newIdent(initName, nodePos(n)))
                        var dotCall: Node = newNode(nkDotExpr, nodePos(n))
                        addSon(dotCall, vtCall)
                        addSon(dotCall, newIdent(nm2, nodePos(n)))
                        var outCallV: Node = newNode(nkCall, nodePos(n))
                        addSon(outCallV, dotCall)
                        addSon(outCallV, transform(base2, rootStmts, false))
                        for aiV in 1..<kidCount n:
                            let argV: Node = transform(kid(n, aiV), rootStmts, false)
                            if stage1AstRefNonNil(argV):
                                addSon(outCallV, argV)
                        return outCallV
                    let genNode3: Node = genericFnGet(nm2)
                    let baseTy: Node = monoLookupExprType base2
                    var generics3: Node = astInvalidNodeId()
                    if stage1AstRefNonNil(genNode3) && kidCount genNode3 > 4:
                        generics3 = kid(genNode3, 4)
                    if stage1AstRefNonNil(genNode3) && stage1AstRefNonNil(baseTy) && stage1AstRefNonNil(generics3) && nodeKind(generics3) == nkGenericParams && kidCount generics3 > 0:
                        var paramNames3: str[4]
                        collectGenericParamNames(generics3, paramNames3)
                        var mapNames3: str[4]
                        var mapTypes3: Node[4]
                        let firstParamTy: Node = monoFirstParamType genNode3
                        if stage1AstRefNonNil(firstParamTy):
                            var actualTy: Node = baseTy
                            if nodeKind(firstParamTy) == nkVarTy && stage1AstRefNonNil(actualTy) && nodeKind(actualTy) != nkVarTy:
                                var wrap: Node = newNode(nkVarTy, nodePos(base2))
                                addSon(wrap, actualTy)
                                actualTy = wrap
                            bindTypeVars(firstParamTy, actualTy, paramNames3, mapNames3, mapTypes3)
                        var instArgs3: Node[4]
                        var emptyArgs3: Node[]
                        buildFullTypeArgs(generics3, mapNames3, mapTypes3, emptyArgs3, instArgs3)
                        if instArgs3.len == kidCount generics3:
                            let instName: str = mangleInstance(nm2, instArgs3)
                            if instantiateFn(nm2, instArgs3, rootStmts):
                                var outCall2: Node = newNode(nkCall, nodePos(n))
                                addSon(outCall2, newIdent(instName, nodePos(n)))
                                addSon(outCall2, transform(base2, rootStmts, false))
                                for ai2 in 1..<kidCount n:
                                    let arg2: Node = transform(kid(n, ai2), rootStmts, false)
                                    if stage1AstRefNonNil(arg2):
                                        addSon(outCall2, arg2)
                                return outCall2
                    if stage1AstRefNonNil(genNode3) && stage1AstRefIsNil(baseTy) && stage1AstRefNonNil(generics3) && nodeKind(generics3) == nkGenericParams && kidCount generics3 > 0:
                        var instArgs4: Node[4]
                        if monoInferGenericArgsFromCall(genNode3, n, instArgs4):
                            let instName4: str = mangleInstance(nm2, instArgs4)
                            if instantiateFn(nm2, instArgs4, rootStmts):
                                var outCall4: Node = newNode(nkCall, nodePos(n))
                                nodeSetCallStyle(outCall4, nodeCallStyle(n))
                                addSon(outCall4, newIdent(instName4, nodePos(n)))
                                for ai4 in 1..<kidCount n:
                                    let arg4: Node = transform(kid(n, ai4), rootStmts, false)
                                    if stage1AstRefNonNil(arg4):
                                        addSon(outCall4, arg4)
                                return outCall4
                    if stage1AstRefNonNil(baseTy):
                        let paramCount: int32 = (kidCount n - 1) + 1
                        let foundFn: Node = monoFindFnByFirstParamMatch(nm2, baseTy, paramCount, rootStmts)
                        if stage1AstRefNonNil(foundFn):
                            var outCall3: Node = newNode(nkCall, nodePos(n))
                            nodeSetCallStyle(outCall3, nodeCallStyle(n))
                            addSon(outCall3, newIdent(nm2, nodePos(n)))
                            addSon(outCall3, transform(base2, rootStmts, false))
                            for ai3 in 1..<kidCount n:
                                let arg3: Node = transform(kid(n, ai3), rootStmts, false)
                                if stage1AstRefNonNil(arg3):
                                    addSon(outCall3, arg3)
                            return outCall3
            if stage1AstRefNonNil(head2) && (nodeKind(head2) == nkIdent || nodeKind(head2) == nkSymbol):
                let nm: str = monoStripSpaces(plainName(head2))
                if monoStrEq(nm, "len") && kidCount n == 2:
                    var argNodeL: Node = kid(n, 1)
                    if stage1AstRefNonNil(argNodeL) && nodeKind(argNodeL) == nkCallArg && kidCount argNodeL > 1:
                        argNodeL = kid(argNodeL, 1)
                    let argTy0: Node = monoLookupExprType argNodeL
                    var argTy: Node = monoStripPtrRefVar(monoNormalizeType(argTy0))
                    var seqLikeL: bool
                    if stage1AstRefNonNil(argTy) && (nodeKind(argTy) == nkIdent || nodeKind(argTy) == nkSymbol):
                        let keyL: str = typeKey argTy
                        if monoStartsWith(keyL, "seq_") || monoStartsWith(keyL, "seq_fixed_"):
                            seqLikeL = true
                        elif len(keyL) > 0:
                            let parsedL: Node = monoTypeNodeFromKey(keyL)
                            if stage1AstRefNonNil(parsedL) && nodeKind(parsedL) == nkBracketExpr:
                                argTy = parsedL
                    if !seqLikeL && stage1AstRefNonNil(argTy) && nodeKind(argTy) == nkBracketExpr:
                        let baseNameL: str = monoBracketBaseName argTy
                        if monoStrEq(baseNameL, "seq") || monoStrEq(baseNameL, "seq_fixed"):
                            seqLikeL = true
                    if seqLikeL:
                        var outDot: Node = newNode(nkDotExpr, nodePos(n))
                        addSon(outDot, transform(argNodeL, rootStmts, false))
                        addSon(outDot, newIdent("len", nodePos(n)))
                        return outDot
                let templ: Node = mapGetStrNodeIndex(templateIndex, templateNodes, nm)
                if stage1AstRefNonNil(templ):
                    return transformCallTemplate(nm, templ, n, rootStmts)
                let mac: Node = mapGetStrNodeIndex(macroIndex, macroNodes, nm)
                if stage1AstRefNonNil(mac):
                    return transformCallTemplate(nm, mac, n, rootStmts)
                if !isTypeCall:
                    var genNode4: Node = genericFnGet(nm)
                    if stage1AstRefIsNil(genNode4) && genericFnHas(nm):
                        genNode4 = findGenericFnDecl(monoRoot, nm)
                        if stage1AstRefNonNil(genNode4):
                            genericFnAdd(nm, genNode4)
                    if stage1AstRefNonNil(genNode4):
                        var instArgs4: Node[4]
                        if monoInferGenericArgsFromCall(genNode4, n, instArgs4):
                            let instName4: str = mangleInstance(nm, instArgs4)
                            if instantiateFn(nm, instArgs4, rootStmts):
                                var outCall4: Node = newNode(nkCall, nodePos(n))
                                nodeSetCallStyle(outCall4, nodeCallStyle(n))
                                addSon(outCall4, newIdent(instName4, nodePos(n)))
                                for ai4 in 1..<kidCount n:
                                    let arg4: Node = transform(kid(n, ai4), rootStmts, false)
                                    if stage1AstRefNonNil(arg4):
                                        addSon(outCall4, arg4)
                                return outCall4
        return transformFallback(n, rootStmts, inTypeContext)
    of nkSeqLit:
        var profStartSeqLit: int64
        if monoProfileActive:
            transformSeqLitCalls = transformSeqLitCalls + 1
            profStartSeqLit = cheng_monotime_ns()
        defer:
            if monoProfileActive:
                transformSeqLitNs = transformSeqLitNs + (cheng_monotime_ns() - profStartSeqLit)
        var elemTy: Node = astInvalidNodeId()
        for si in 0..<kidCount n:
            if !(stage1AstRefIsNil(elemTy)):
                break
            elemTy = inferLitType kid(n, si)
        if stage1AstRefNonNil(elemTy):
            var args3: Node[1]
            add(args3, elemTy)
            instantiateType("seq", args3, rootStmts)
        return transformFallback(n, rootStmts, inTypeContext)
    else:
        return transformFallback(n, rootStmts, inTypeContext)

fn monomorphizeImpl(root: Node, diags: Diagnostic[]*): Node =
    monoDebugProgress("enter")
    let monoProfOn: bool = monoProfileEnabled()
    var monoProfStart: int64
    var monoProfMark: int64
    var monoProfCollect: int64
    var monoProfTransform: int64
    var monoProfLower: int64
    if monoProfOn:
        monoProfStart = cheng_monotime_ns()
        monoProfMark = monoProfStart
    monoProfileActive = monoProfOn
    monoEnsureInitMaps()
    if monoProfOn:
        monoProfResetKinds()
    typeKeyCalls = 0
    typeKeyNs = 0
    replaceTypeVarsCalls = 0
    replaceTypeVarsNs = 0
    instantiateTypeCalls = 0
    instantiateTypeNs = 0
    instantiateFnCalls = 0
    instantiateFnNs = 0
    monoMaybeCalls = 0
    monoMaybeNs = 0
    monoMaybeScans = 0
    monoLookupExprTypeCalls = 0
    monoLookupExprTypeNs = 0
    bindTypeVarsCalls = 0
    bindTypeVarsNs = 0
    monoTypeMatchesCalls = 0
    monoTypeMatchesNs = 0
    stripSpacesCalls = 0
    stripSpacesNs = 0
    hashmaps.HashMapStrIntClear(monoStripIndex)
    hashmaps.HashMapPtrIntClear(monoStripPtrIndex)
    hashmaps.HashMapStrIntClear(monoUnderscoreIndex)
    monoStripValues = []
    monoStripValues.cap = 4096
    hashmaps.HashMapStrIntClear(monoSanitizeIndex)
    hashmaps.HashMapPtrIntClear(monoSanitizePtrIndex)
    monoSanitizeValues = []
    monoSanitizeValues.cap = 4096
    setLen(monoTypeKeyIndex, 0)
    monoTypeKeyIndex.cap = 8192
    monoTypeKeyValues = []
    monoTypeKeyValues.cap = 16384
    setLen(monoTypeLeafKeyReady, 0)
    monoTypeLeafKeyReady.cap = 8192
    monoTypeLeafKeyValues = []
    monoTypeLeafKeyValues.cap = 8192
    setLen(monoTypeLeafTextReady, 0)
    monoTypeLeafTextReady.cap = 4096
    monoTypeLeafTextValues = []
    monoTypeLeafTextValues.cap = 4096
    hashmaps.HashMapStrIntClear(monoTypeKeyValueIndex)
    hashmaps.HashMapPtrIntClear(monoTypeKeyPtrIndex)
    hashmaps.HashMapPtrIntClear(&monoLambdaCaptureIndex)
    monoLambdaCaptureValues = []
    monoLambdaCaptureValues.cap = 128
    hashmaps.HashMapStrIntClear(monoTypeNodeIndex)
    monoTypeNodeValues = []
    monoTypeNodeValues.cap = 256
    hashmaps.HashMapStrIntClear(monoTypeKeyValidIndex)
    mapHasCalls = 0
    mapHasNs = 0
    mapGetCalls = 0
    mapGetNs = 0
    mapPutCalls = 0
    mapPutNs = 0
    findGenericFnDeclCalls = 0
    findGenericFnDeclNs = 0
    transformCalls = 0
    transformNs = 0
    transformFallbackCalls = 0
    transformFallbackNs = 0
    transformModuleCalls = 0
    transformModuleNs = 0
    transformTypeDeclCalls = 0
    transformTypeDeclNs = 0
    transformFnDeclCalls = 0
    transformFnDeclNs = 0
    transformLetCalls = 0
    transformLetNs = 0
    transformBracketCalls = 0
    transformBracketNs = 0
    transformLambdaCalls = 0
    transformLambdaNs = 0
    transformCallCalls = 0
    transformCallNs = 0
    transformSeqLitCalls = 0
    transformSeqLitNs = 0
    currentDiags = diags
    if stage1AstRefNonNil(root) && len(nodeStrVal(root)) > 0:
        currentFilename = nodeStrVal(root)
    else:
        currentFilename = ""
    vecClearStr(genericTypeNames)
    vecClearNode(genericTypeNodes)
    hashmaps.HashMapStrIntClear(genericTypeIndex)
    vecClearStr(monoTypeNames)
    vecClearNode(monoTypeNodes)
    hashmaps.HashMapStrIntClear(monoTypeIndex)
    vecClearStr(genericFnNames)
    vecClearNode(genericFnNodes)
    hashmaps.HashMapStrIntClear(genericFnIndex)
    hashmaps.HashMapStrIntClear(genericFnAliasIndex)
    hashmaps.HashMapStrIntClear(genericFnMissingIndex)
    genericFnHasUnderscore = false
    genericFnHasLowerUnderscore = false
    vecClearStr(templateNames)
    vecClearNode(templateNodes)
    hashmaps.HashMapStrIntClear(templateIndex)
    vecClearStr(macroNames)
    vecClearNode(macroNodes)
    hashmaps.HashMapStrIntClear(macroIndex)
    vecClearStr(instTypeNames)
    vecClearNode(instTypeNodes)
    hashmaps.HashMapStrIntClear(instTypeIndex)
    vecClearStr(instantiatedNames)
    vecClearStr(traitNames)
    vecClearNode(traitNodes)
    hashmaps.HashMapStrIntClear(traitIndex)
    vecClearStr(conceptNames)
    vecClearNode(conceptNodes)
    hashmaps.HashMapStrIntClear(conceptIndex)
    traitVtableKeys.len = 0
    traitVtableNames.len = 0
    traitVtableInitNames.len = 0
    traitDispatchKeys.len = 0
    traitDispatchVtableNames.len = 0
    traitDispatchInitNames.len = 0
    monoFieldClear()
    monoValueClear()
    instMapInit 1024
    lambdaCounter = 0
    if stage1AstRefIsNil(root):
        monoDebugProgress("root=nil")
        return astInvalidNodeId()
    monoRoot = root
    monoDebugProgress("collectGenericDecls.start")
    collectGenericDecls root
    monoDebugProgress("collectGenericDecls.done")
    monoDebugProgress("monoCollectFieldTypes.start")
    monoCollectFieldTypes root
    monoDebugProgress("monoCollectFieldTypes.done")
    monoFnSetClear()
    monoDebugProgress("collectFnArities.root.start")
    collectFnArities root
    monoDebugProgress("collectFnArities.root.done")
    if monoProfOn:
        monoProfCollect = cheng_monotime_ns() - monoProfMark
        monoProfMark = cheng_monotime_ns()
    var newStmts: Node[8]
    var bodyStmts: Node[8]
    monoDebugProgress("transform.root.start")
    for i in 0..<kidCount root:
        let raw: Node = kid(root, i)
        if monoDebugProgressEnabled():
            let itemName: str = monoDebugRootItemSuffix(raw)
            monoDebugProgress("transform.root.item.start i=" + intToStr(i) +
                              " kind=" + intToStr(int32(nodeKind(raw))) +
                              " line=" + intToStr(nodePos(raw).line) +
                              itemName)
        let t: Node = transform(raw, &newStmts)
        if monoDebugProgressEnabled():
            monoDebugProgress("transform.root.item.done i=" + intToStr(i))
        if stage1AstRefNonNil(t) && nodeKind(t) != nkEmpty:
            add(bodyStmts, t)
    monoDebugProgress("transform.root.done")
    var out: Node = newNode(nodeKind(root), nodePos(root))
    nodeSetIdent(out, nodeIdent(root))
    nodeSetStrVal(out, nodeStrVal(root))
    nodeSetIntVal(out, nodeIntVal(root))
    nodeSetFloatVal(out, nodeFloatVal(root))
    nodeSetCallStyle(out, nodeCallStyle(root))
    for j in 0..<newStmts.len:
        addSon(out, get(newStmts, j))
    for k in 0..<bodyStmts.len:
        addSon(out, get(bodyStmts, k))
    if monoProfOn:
        monoProfTransform = cheng_monotime_ns() - monoProfMark
        monoProfMark = cheng_monotime_ns()
    monoFnSetClear()
    monoDebugProgress("collectFnArities.out.start")
    collectFnArities out
    monoDebugProgress("collectFnArities.out.done")
    monoValueClear()
    var implicitStmts: Node[8]
    monoDebugProgress("lowerImplicitCallsStmt.start")
    var lowered: Node = lowerImplicitCallsStmt(out, &implicitStmts)
    monoDebugProgress("lowerImplicitCallsStmt.done")
    if implicitStmts.len > 0:
        var merged: Node = cloneNodeShallow lowered
        for mi in 0..<implicitStmts.len:
            addSon(merged, get(implicitStmts, mi))
        for mk in 0..<kidCount lowered:
            addSon(merged, kid(lowered, mk))
        out = merged
    else:
        out = lowered
    if monoProfOn:
        monoProfLower = cheng_monotime_ns() - monoProfMark
    currentDiags = nil
    currentFilename = ""
    monoRoot = astInvalidNodeId()
    monoDebugProgress("leave")
    if monoProfOn:
        let collectMs: int32 = int32(monoProfCollect / 1000000)
        let transformMs: int32 = int32(monoProfTransform / 1000000)
        let lowerMs: int32 = int32(monoProfLower / 1000000)
        let totalMs: int32 = int32((cheng_monotime_ns() - monoProfStart) / 1000000)
        let typeKeyMs: int32 = int32(typeKeyNs / 1000000)
        let replaceMs: int32 = int32(replaceTypeVarsNs / 1000000)
        let instTypeMs: int32 = int32(instantiateTypeNs / 1000000)
        let instFnMs: int32 = int32(instantiateFnNs / 1000000)
        let monoMaybeMs: int32 = int32(monoMaybeNs / 1000000)
        let lookupMs: int32 = int32(monoLookupExprTypeNs / 1000000)
        let bindMs: int32 = int32(bindTypeVarsNs / 1000000)
        let typeMatchesMs: int32 = int32(monoTypeMatchesNs / 1000000)
        let stripMs: int32 = int32(stripSpacesNs / 1000000)
        let mapHasMs: int32 = int32(mapHasNs / 1000000)
        let mapGetMs: int32 = int32(mapGetNs / 1000000)
        let mapPutMs: int32 = int32(mapPutNs / 1000000)
        let findGenericFnDeclMs: int32 = int32(findGenericFnDeclNs / 1000000)
        let transformTotalMs: int32 = int32(transformNs / 1000000)
        let fallbackMs: int32 = int32(transformFallbackNs / 1000000)
        let moduleMs: int32 = int32(transformModuleNs / 1000000)
        let typeDeclMs: int32 = int32(transformTypeDeclNs / 1000000)
        let fnDeclMs: int32 = int32(transformFnDeclNs / 1000000)
        let letMs: int32 = int32(transformLetNs / 1000000)
        let bracketMs: int32 = int32(transformBracketNs / 1000000)
        let lambdaMs: int32 = int32(transformLambdaNs / 1000000)
        let callMs: int32 = int32(transformCallNs / 1000000)
        let seqLitMs: int32 = int32(transformSeqLitNs / 1000000)
        var msgParts: str[]
        add(msgParts, "[mono] collect=")
        add(msgParts, intToStr(collectMs))
        add(msgParts, "ms transform=")
        add(msgParts, intToStr(transformMs))
        add(msgParts, "ms lower=")
        add(msgParts, intToStr(lowerMs))
        add(msgParts, "ms total=")
        add(msgParts, intToStr(totalMs))
        add(msgParts, "ms inst=")
        add(msgParts, intToStr(instMapCount))
        add(msgParts, " genFns=")
        add(msgParts, intToStr(genericFnNames.len))
        add(msgParts, " genTypes=")
        add(msgParts, intToStr(genericTypeNames.len))
        add(msgParts, " typeKey=")
        add(msgParts, intToStr(typeKeyMs))
        add(msgParts, "ms typeKeyCalls=")
        add(msgParts, intToStr(typeKeyCalls))
        add(msgParts, " replaceTypeVars=")
        add(msgParts, intToStr(replaceMs))
        add(msgParts, "ms replaceCalls=")
        add(msgParts, intToStr(replaceTypeVarsCalls))
        add(msgParts, " instType=")
        add(msgParts, intToStr(instTypeMs))
        add(msgParts, "ms instTypeCalls=")
        add(msgParts, intToStr(instantiateTypeCalls))
        add(msgParts, " instFn=")
        add(msgParts, intToStr(instFnMs))
        add(msgParts, "ms instFnCalls=")
        add(msgParts, intToStr(instantiateFnCalls))
        add(msgParts, " monoMaybe=")
        add(msgParts, intToStr(monoMaybeMs))
        add(msgParts, "ms monoMaybeCalls=")
        add(msgParts, intToStr(monoMaybeCalls))
        add(msgParts, " monoMaybeScans=")
        add(msgParts, intToStr(monoMaybeScans))
        add(msgParts, " lookup=")
        add(msgParts, intToStr(lookupMs))
        add(msgParts, "ms lookupCalls=")
        add(msgParts, intToStr(monoLookupExprTypeCalls))
        add(msgParts, " bind=")
        add(msgParts, intToStr(bindMs))
        add(msgParts, "ms bindCalls=")
        add(msgParts, intToStr(bindTypeVarsCalls))
        add(msgParts, " typeMatches=")
        add(msgParts, intToStr(typeMatchesMs))
        add(msgParts, "ms typeMatchesCalls=")
        add(msgParts, intToStr(monoTypeMatchesCalls))
        add(msgParts, " monoStripSpaces=")
        add(msgParts, intToStr(stripMs))
        add(msgParts, "ms stripSpacesCalls=")
        add(msgParts, intToStr(stripSpacesCalls))
        add(msgParts, " mapHas=")
        add(msgParts, intToStr(mapHasMs))
        add(msgParts, "ms mapHasCalls=")
        add(msgParts, intToStr(mapHasCalls))
        add(msgParts, " mapGet=")
        add(msgParts, intToStr(mapGetMs))
        add(msgParts, "ms mapGetCalls=")
        add(msgParts, intToStr(mapGetCalls))
        add(msgParts, " mapPut=")
        add(msgParts, intToStr(mapPutMs))
        add(msgParts, "ms mapPutCalls=")
        add(msgParts, intToStr(mapPutCalls))
        add(msgParts, " findGenericFnDecl=")
        add(msgParts, intToStr(findGenericFnDeclMs))
        add(msgParts, "ms findGenericFnDeclCalls=")
        add(msgParts, intToStr(findGenericFnDeclCalls))
        add(msgParts, " transformTotal=")
        add(msgParts, intToStr(transformTotalMs))
        add(msgParts, "ms transformCalls=")
        add(msgParts, intToStr(transformCalls))
        add(msgParts, " fallback=")
        add(msgParts, intToStr(fallbackMs))
        add(msgParts, "ms fallbackCalls=")
        add(msgParts, intToStr(transformFallbackCalls))
        add(msgParts, " module=")
        add(msgParts, intToStr(moduleMs))
        add(msgParts, "ms moduleCalls=")
        add(msgParts, intToStr(transformModuleCalls))
        add(msgParts, " typeDecl=")
        add(msgParts, intToStr(typeDeclMs))
        add(msgParts, "ms typeDeclCalls=")
        add(msgParts, intToStr(transformTypeDeclCalls))
        add(msgParts, " fnDecl=")
        add(msgParts, intToStr(fnDeclMs))
        add(msgParts, "ms fnDeclCalls=")
        add(msgParts, intToStr(transformFnDeclCalls))
        add(msgParts, " let=")
        add(msgParts, intToStr(letMs))
        add(msgParts, "ms letCalls=")
        add(msgParts, intToStr(transformLetCalls))
        add(msgParts, " bracket=")
        add(msgParts, intToStr(bracketMs))
        add(msgParts, "ms bracketCalls=")
        add(msgParts, intToStr(transformBracketCalls))
        add(msgParts, " lambda=")
        add(msgParts, intToStr(lambdaMs))
        add(msgParts, "ms lambdaCalls=")
        add(msgParts, intToStr(transformLambdaCalls))
        add(msgParts, " call=")
        add(msgParts, intToStr(callMs))
        add(msgParts, "ms callCalls=")
        add(msgParts, intToStr(transformCallCalls))
        add(msgParts, " seqLit=")
        add(msgParts, intToStr(seqLitMs))
        add(msgParts, "ms seqLitCalls=")
        add(msgParts, intToStr(transformSeqLitCalls))
        echo strutils.Join(msgParts, "")
        let exprTop: str = monoProfTopKinds(monoProfExprKindNs, monoProfExprKindCalls, "[mono-expr-top]")
        if len exprTop > 0:
            echo exprTop
    monoProfileActive = false
    return out

fn monomorphizeId(rootId: AstNodeId, diags: Diagnostic[]*): AstNodeId =
    let root: Node = rootId
    let out: Node = monomorphizeImpl(root, diags)
    return out
