fn add(dst: var int32[], val: int32) =
    add[int32](dst, val)

fn add(dst: var int8[], val: int8) =
    add[int8](dst, val)

fn add(dst: var str[], val: str) =
    add[str](dst, val)

fn get(seqInst: int32[], at: int32): int32 =
    return seqInst[at]

fn get(seqInst: int64[], at: int32): int64 =
    return seqInst[at]

fn get(seqInst: int8[], at: int32): int8 =
    return seqInst[at]

fn get(seqInst: str[], at: int32): str =
    return seqInst[at]

fn get(seqInst: Node[], at: int32): Node =
    return seqInst[at]

fn add(dst: var Node[], val: Node) =
    add[Node](dst, val)

fn add(dst: Node[]*, val: Node) =
    add[Node](dst, val)

fn add(dst: var Diagnostic[], val: Diagnostic) =
    add[Diagnostic](dst, val)

fn add(dst: Diagnostic[]*, val: Diagnostic) =
    add[Diagnostic](dst, val)

fn monoChooseNonEmpty(primary: str, fallback: str): str =
    if len(primary) > 0:
        return primary
    return fallback

fn monoDebugWatchTail(name: str): str =
    return monoChooseNonEmpty(monoNameTail(name), name)

fn monoTypeOwnerName(baseType: Node): str =
    if stage1AstRefNonNil(baseType) && (nodeKind(baseType) == nkIdent || nodeKind(baseType) == nkSymbol):
        return monoStripSpaces(plainName(baseType))
    if stage1AstRefNonNil(baseType) && nodeKind(baseType) == nkBracketExpr && kidCount(baseType) > 0:
        return monoStripSpaces(plainName(kid(baseType, 0)))
    return ""

fn monoTypeExprBaseName(ty: Node): str =
    if nodeKind(ty) == nkBracketExpr && kidCount(ty) > 0:
        return typeBaseName(kid(ty, 0))
    return typeBaseName(ty)

fn monoStripVarTypeKey(rawTy: Node, normalizedKey: str): str =
    let stripTy: Node = monoStripVarType(rawTy)
    if stripTy == rawTy:
        return normalizedKey
    return typeKey(monoNormalizeType(stripTy))

fn monoNodeRawText(n: Node, textId: int32): str =
    if textId > 0:
        return tokenTextById(textId)
    return nodeIdent(n)

fn monoTypeLeafKeyValue(textId: int32, raw: str): str =
    if len(raw) == 0:
        return ""
    if (textId > 0 && monoTextIdLooksSafeKey(textId)) || monoRawLooksSafeKey(raw):
        return raw
    return sanitizeKey(monoStripSpaces(raw))

fn monoMangleBaseName(name: str): str =
    if monoStrEq(name, "[]"):
        return "bracket"
    if monoStrEq(name, "[]="):
        return "bracketEq"
    if monoStrEq(name, ".."):
        return "dotdot"
    if monoStrEq(name, "..<"):
        return "dotdotless"
    if monoStrEq(name, "=>"):
        return "arrow"
    if monoStrEq(name, "."):
        return "dot"
    return name

fn monoInstanceName(baseName: str, instArgs: Node[]): str =
    if instArgs.len > 0:
        return mangleInstance(baseName, instArgs)
    return baseName

fn monoHeadDisplayName(head: Node): str =
    var headNameNode: Node = head
    if stage1AstRefNonNil(head) && nodeKind(head) == nkDotExpr && kidCount(head) > 1:
        headNameNode = kid(head, 1)
    if stage1AstRefNonNil(headNameNode) && (nodeKind(headNameNode) == nkIdent || nodeKind(headNameNode) == nkSymbol):
        return monoStripSpaces(plainName(headNameNode))
    return ""

fn monoDebugRootItemSuffix(raw: Node): str =
    if !stage1AstRefNonNil(raw):
        return ""
    if nodeKind(raw) != nkFnDecl && nodeKind(raw) != nkIteratorDecl &&
       nodeKind(raw) != nkTypeDecl && nodeKind(raw) != nkMacroDecl &&
       nodeKind(raw) != nkTemplateDecl:
        return ""
    if kidCount(raw) <= 0:
        return ""
    let name0: str = getName(kid(raw, 0))
    if len(name0) == 0:
        return ""
    return " name=" + name0

fn monoWhereOpName(opNode: Node): str =
    if stage1AstRefNonNil(opNode):
        return monoStripSpaces(nodeIdent(opNode))
    return ""

fn monoSeqLenCapCalleeBase(memberName: str): str =
    if monoStrEq(memberName, "len"):
        return "setLen"
    return "reserve"

fn monoFieldKey(owner: str, fieldName: str): str =
    var parts: str[]
    add(parts, owner)
    add(parts, ".")
    add(parts, fieldName)
    return strutils.Join(parts, "")

fn monoLambdaNameValue(counter: int32): str =
    var parts: str[]
    add(parts, "__cheng_lambda_")
    add(parts, intToStr(counter))
    return strutils.Join(parts, "")

fn monoEnsureInitMaps() =
    # Avoid stage0 seed global-init codegen bugs by initializing maps lazily.
    if genericTypeIndex.mask == 0:
        genericTypeIndex = hashmaps.HashMapStrIntInit(256)
    if genericFnIndex.mask == 0:
        genericFnIndex = hashmaps.HashMapStrIntInit(32)
    if genericFnAliasIndex.mask == 0:
        genericFnAliasIndex = hashmaps.HashMapStrIntInit(64)
    if genericFnMissingIndex.mask == 0:
        genericFnMissingIndex = hashmaps.HashMapStrIntInit(512)
    if templateIndex.mask == 0:
        templateIndex = hashmaps.HashMapStrIntInit(64)
    if macroIndex.mask == 0:
        macroIndex = hashmaps.HashMapStrIntInit(64)
    if instTypeIndex.mask == 0:
        instTypeIndex = hashmaps.HashMapStrIntInit(256)
    if monoValueIndex.mask == 0:
        monoValueIndex = hashmaps.HashMapStrIntInit(256)
    if monoFnRetIndex.mask == 0:
        monoFnRetIndex = hashmaps.HashMapStrIntInit(256)
    if monoTypeIndex.mask == 0:
        monoTypeIndex = hashmaps.HashMapStrIntInit(256)
    if monoFieldIndex.mask == 0:
        monoFieldIndex = hashmaps.HashMapStrIntInit(256)
    if traitIndex.mask == 0:
        traitIndex = hashmaps.HashMapStrIntInit(64)
    if conceptIndex.mask == 0:
        conceptIndex = hashmaps.HashMapStrIntInit(64)
    if monoTypeNodeIndex.mask == 0:
        monoTypeNodeIndex = hashmaps.HashMapStrIntInit(256)
    if monoTypeKeyValidIndex.mask == 0:
        monoTypeKeyValidIndex = hashmaps.HashMapStrIntInit(256)
    if monoTypeKeyValueIndex.mask == 0:
        monoTypeKeyValueIndex = hashmaps.HashMapStrIntInit(32768)
    if monoTypeKeyPtrIndex.mask == 0:
        hashmaps.HashMapPtrIntInitInPlace(monoTypeKeyPtrIndex, 32768)
    if monoStripIndex.mask == 0:
        monoStripIndex = hashmaps.HashMapStrIntInit(8192)
    if monoStripPtrIndex.mask == 0:
        hashmaps.HashMapPtrIntInitInPlace(monoStripPtrIndex, 8192)
    if monoSanitizeIndex.mask == 0:
        monoSanitizeIndex = hashmaps.HashMapStrIntInit(8192)
    if monoSanitizePtrIndex.mask == 0:
        hashmaps.HashMapPtrIntInitInPlace(monoSanitizePtrIndex, 8192)
    if monoUnderscoreIndex.mask == 0:
        monoUnderscoreIndex = hashmaps.HashMapStrIntInit(2048)
    if monoZeroArgFnIndex.mask == 0:
        monoZeroArgFnIndex = hashmaps.HashMapStrIntInit(128)
    if monoOneArgFnIndex.mask == 0:
        monoOneArgFnIndex = hashmaps.HashMapStrIntInit(128)
    if monoFirstParamMatchIndex.mask == 0:
        monoFirstParamMatchIndex = hashmaps.HashMapStrIntInit(512)
