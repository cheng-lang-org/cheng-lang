fn setCCodegenDiagnostics(diags: seq[Diagnostic]*) =
    codegenDiags = diags
    codegenHasError = false

fn setCCodegenFilename(name: str) =
    codegenFilename = name

fn cgenWriterCapForOut(outPath: str): int32 =
    if strIsEmpty(outPath):
        return 65536
    if hasSuffix(outPath, "stage1_runner.c"):
        return 8 * 1024 * 1024
    if hasSuffix(outPath, ".seed.c"):
        return 4 * 1024 * 1024
    if hasSuffix(outPath, ".c"):
        return 512 * 1024
    return 65536

fn cgenWriterFlushThreshold(outPath: str): int32 =
    if strIsEmpty(outPath):
        return 0
    if hasSuffix(outPath, "stage1_runner.c"):
        return 4 * 1024 * 1024
    if hasSuffix(outPath, ".seed.c"):
        return 2 * 1024 * 1024
    return 0

fn cgenWriterStreamForOut(outPath: str): bool =
    if cgenEnvFlag "CHENG_CGEN_NO_STREAM":
        return false
    if cgenEnvFlag "CHENG_CGEN_STREAM":
        return true
    return cgenWriterFlushThreshold(outPath) > 0

fn cgenAddError(pos: SourcePos, msg: str) =
    codegenHasError = true
    if codegenDiags != nil:
        var fileName: str = codegenFilename
        if fileName == "":
            fileName = "stdin"
        addDiag(codegenDiags, svError, fileName, pos.line, pos.col, msg)
    else:
        panic msg

fn cgenProfUpdateFnTop(name: str, durNs: int64) =
    if ! cgenProfOn:
        return
    if durNs <= 0:
        return
    let nm: str = name
    if nm == "":
        return
    if durNs > cgenProfFnTop1Ns:
        cgenProfFnTop3Ns = cgenProfFnTop2Ns
        cgenProfFnTop3Name = cgenProfFnTop2Name
        cgenProfFnTop2Ns = cgenProfFnTop1Ns
        cgenProfFnTop2Name = cgenProfFnTop1Name
        cgenProfFnTop1Ns = durNs
        cgenProfFnTop1Name = nm
    elif durNs > cgenProfFnTop2Ns:
        cgenProfFnTop3Ns = cgenProfFnTop2Ns
        cgenProfFnTop3Name = cgenProfFnTop2Name
        cgenProfFnTop2Ns = durNs
        cgenProfFnTop2Name = nm
    elif durNs > cgenProfFnTop3Ns:
        cgenProfFnTop3Ns = durNs
        cgenProfFnTop3Name = nm

fn cgenStripSpaces(s: str): str =
    if s == nil:
        return ""
    if cgenProfOn:
        cgenStripCalls = cgenStripCalls + 1
    var cached: bool = false
    let cachedIdx: int32 = hashmaps.hashMapPtrIntGet(cgenStripIndex, void*(s), &cached)
    if cached && cachedIdx > 0 && cachedIdx <= cgenStripValues.len:
        if cgenProfOn:
            cgenStripHits = cgenStripHits + 1
        return get[str](cgenStripValues, cachedIdx - 1)
    let n: int32 = len s
    if n <= 0:
        return ""
    var i: int32 = 0
    while i < n:
        let c: char = charAt(s, i)
        if c == ' ' || c == '\t' || c == '\n' || c == '\r':
            var b: ByteBuffer = initByteBuffer(n)
            var j: int32 = 0
            while j < n:
                let cj: char = charAt(s, j)
                if cj != ' ' && cj != '\t' && cj != '\n' && cj != '\r':
                    bufAddChar(&b, cj)
                j = j + 1
            let out: str = toString(&b)
            addPtr[str](&cgenStripValues, out)
            let storedIdx: int32 = cgenStripValues.len
            hashmaps.hashMapPtrIntPut(&cgenStripIndex, void*(s), storedIdx)
            return out
        i = i + 1
    addPtr[str](&cgenStripValues, s)
    let storedIdx: int32 = cgenStripValues.len
    hashmaps.hashMapPtrIntPut(&cgenStripIndex, void*(s), storedIdx)
    return s

fn cgenMangleCacheStore(raw: str, out: str): str =
    if raw == nil:
        return out
    addPtr[str](&cgenMangleValues, out)
    let storedIdx: int32 = cgenMangleValues.len
    hashmaps.hashMapPtrIntPut(&cgenMangleIndex, void*(raw), storedIdx)
    return out

fn cgenIdentNameNormalized(n: Node): str =
    if n == nil:
        return ""
    if n.kind != nkIdent && n.kind != nkSymbol:
        return ""
    var cached: bool = false
    let idx: int32 = hashmaps.hashMapPtrIntGet(cgenIdentNameIndex, void*(n), &cached)
    if cached && idx > 0 && idx <= cgenIdentNameValues.len:
        return get[str](cgenIdentNameValues, idx - 1)
    let nm: str = cgenStripSpaces n.ident
    addPtr[str](&cgenIdentNameValues, nm)
    let storedIdx: int32 = cgenIdentNameValues.len
    hashmaps.hashMapPtrIntPut(&cgenIdentNameIndex, void*(n), storedIdx)
    return nm

fn opNameFromNode(opNode: Node, fallback: str): str =
    if opNode != nil:
        let raw: str = opNode.ident
        let trimmed: str = cgenStripSpaces raw
        if len trimmed > 0:
            return trimmed
        if raw != nil && len raw > 0:
            return raw
    if fallback != nil:
        let trimmed2: str = cgenStripSpaces fallback
        if len trimmed2 > 0:
            return trimmed2
        if len fallback > 0:
            return fallback
    return ""

fn infixOp(n: Node): str =
    if n == nil || n.kind != nkInfix:
        return ""
    var opNode: Node = nil
    if kidCount n > 0:
        opNode = kid(n, 0)
    return opNameFromNode(opNode, n.ident)

fn prefixOp(n: Node): str =
    if n == nil || n.kind != nkPrefix:
        return ""
    var opNode: Node = nil
    if kidCount n > 0:
        opNode = kid(n, 0)
    return opNameFromNode(opNode, n.ident)

fn cgenSanitizeKey(s: str): str =
    var out: str = ""
    var i: int32 = 0
    while i < len s:
        let c: char = charAt(s, i)
        if (c >= 'a' && c <= 'z') ||(c >= 'A' && c <= 'Z') ||
           (c >= '0' && c <= '9') || c == '_':
            out = out + charToStr c
        else:
            out = out + "_"
        i = i + 1
    if len out == 0:
        out = "anon"
    return out

fn cgenNormalizeInstanceBase(name: str): str =
    if name == nil:
        return "empty"
    var n: str = cgenStripSpaces name
    if len n == 0:
        return "empty"
    if n == "[]":
        return "bracket"
    if n == "[]=":
        return "bracketEq"
    if n == "..":
        return "dotdot"
    if n == "..<":
        return "dotdotless"
    if n == "=>":
        return "arrow"
    if n == ".":
        return "dot"
    return n

fn resetTypeMaps() =
    typeNames = newSeqWithCap[str](0, 64)
    refTypeNames = newSeqWithCap[str](0, 64)
    typeNameSet = hashsets.hashSetStrInit(128)
    refTypeNameSet = hashsets.hashSetStrInit(128)
    cgenTypeNameResolveIndex = hashmaps.hashMapStrIntInit(256)
    cgenTypeNameResolveValues = newSeqWithCap[str](0, 128)
    cgenTypeNameResolveEpoch = 1
    cgenTypeNameResolveReadyEpoch = 0
    fnRetNames = newSeqWithCap[str](0, 64)
    fnRetTypes = newSeqWithCap[Node](0, 64)
    fnRetIndex = hashmaps.hashMapStrIntInit(128)
    globalVarNames = newSeqWithCap[str](0, 64)
    globalVarTypes = newSeqWithCap[Node](0, 64)
    globalVarIndex = hashmaps.hashMapStrIntInit(128)
    globalInitNames = newSeqWithCap[str](0, 64)
    globalInitExprs = newSeqWithCap[Node](0, 64)
    localVarNames = newSeqWithCap[str](0, 64)
    localVarTypes = newSeqWithCap[Node](0, 64)
    localVarIndex = hashmaps.hashMapStrIntInit(128)
    typeDefKeys = newSeqWithCap[str](0, 64)
    typeDefNodes = newSeqWithCap[Node](0, 64)
    typeDefIndex = hashmaps.hashMapStrIntInit(128)
    cgenArrayTypeKeys = newSeqWithCap[str](0, 64)
    cgenArrayTypeKeySet = hashsets.hashSetStrInit(128)
    cgenArrayTypeDecls = newSeqWithCap[Node](0, 64)
    cgenTupleTypeKeys = newSeqWithCap[str](0, 64)
    cgenTupleTypeKeySet = hashsets.hashSetStrInit(128)
    cgenTupleTypeDecls = newSeqWithCap[Node](0, 64)
    cgenConstIntNames = newSeqWithCap[str](0, 64)
    cgenConstIntNameSet = hashsets.hashSetStrInit(128)
    cgenConstIntValues = newSeqWithCap[int64](0, 64)
    fieldTypeKeys = newSeqWithCap[str](0, 128)
    fieldTypeKeySet = hashsets.hashSetStrInit(256)
    fieldTypeNodes = newSeqWithCap[Node](0, 128)
    fieldTypeIndex = hashmaps.hashMapStrIntInit(256)
    fnTypeKeys = newSeqWithCap[str](0, 64)
    fnTypeKeySet = hashsets.hashSetStrInit(128)
    fnTypeNodes = newSeqWithCap[Node](0, 64)
    cgenFnDecls = newSeqWithCap[Node](0, 128)
    cgenFnDefDecls = newSeqWithCap[Node](0, 128)
    cgenFnProtoDecls = newSeqWithCap[Node](0, 128)
    emittedProtoNames = newSeqWithCap[str](0, 128)
    emittedDefNames = newSeqWithCap[str](0, 128)
    emittedProtoNameSet = hashsets.hashSetStrInit(256)
    emittedDefNameSet = hashsets.hashSetStrInit(256)
    cFnSigKeySet = hashsets.hashSetStrInit(256)
    hasGlobalInit = false
    inFn = false

fn resetLocalVars() =
    localVarNames = newSeqWithCap[str](0, 64)
    localVarTypes = newSeqWithCap[Node](0, 64)
    localVarIndex = hashmaps.hashMapStrIntInit(128)

fn strSeqHas(items: seq[str]*, name: str): bool =
    if items == nil:
        return false
    if items == &typeNames:
        return hashsets.hashSetStrHas(typeNameSet, name)
    if items == &refTypeNames:
        return hashsets.hashSetStrHas(refTypeNameSet, name)
    if items == &cFnSigKeys:
        return hashsets.hashSetStrHas(cFnSigKeySet, name)
    if items == &cgenArrayTypeKeys:
        return hashsets.hashSetStrHas(cgenArrayTypeKeySet, name)
    if items == &cgenTupleTypeKeys:
        return hashsets.hashSetStrHas(cgenTupleTypeKeySet, name)
    if items == &cgenConstIntNames:
        return hashsets.hashSetStrHas(cgenConstIntNameSet, name)
    if items == &fieldTypeKeys:
        return hashsets.hashSetStrHas(fieldTypeKeySet, name)
    if items == &fnTypeKeys:
        return hashsets.hashSetStrHas(fnTypeKeySet, name)
    if items == &emittedProtoNames:
        return hashsets.hashSetStrHas(emittedProtoNameSet, name)
    if items == &emittedDefNames:
        return hashsets.hashSetStrHas(emittedDefNameSet, name)
    var i: int32 = 0
    while i < items->len:
        if get[str](*items, i) == name:
            return true
        i = i + 1
    return false

fn strSeqAddUnique(items: seq[str]*, name: str) =
    if items == nil:
        return
    if name == "":
        return
    if strSeqHas(items, name):
        return
    addPtr[str](items, name)
    if items == &typeNames:
        hashsets.hashSetStrAdd(&typeNameSet, name)
        cgenTypeNameResolveEpoch = cgenTypeNameResolveEpoch + 1
    elif items == &refTypeNames:
        hashsets.hashSetStrAdd(&refTypeNameSet, name)
    elif items == &cFnSigKeys:
        hashsets.hashSetStrAdd(&cFnSigKeySet, name)
    elif items == &cgenArrayTypeKeys:
        hashsets.hashSetStrAdd(&cgenArrayTypeKeySet, name)
    elif items == &cgenTupleTypeKeys:
        hashsets.hashSetStrAdd(&cgenTupleTypeKeySet, name)
    elif items == &cgenConstIntNames:
        hashsets.hashSetStrAdd(&cgenConstIntNameSet, name)
    elif items == &fieldTypeKeys:
        hashsets.hashSetStrAdd(&fieldTypeKeySet, name)
    elif items == &fnTypeKeys:
        hashsets.hashSetStrAdd(&fnTypeKeySet, name)
    elif items == &emittedProtoNames:
        hashsets.hashSetStrAdd(&emittedProtoNameSet, name)
    elif items == &emittedDefNames:
        hashsets.hashSetStrAdd(&emittedDefNameSet, name)

fn findTypeByName(names: seq[str], types: seq[Node], name: str): Node =
    var i: int32 = names.len - 1
    while i >= 0:
        if names[i] == name:
            return types[i]
        i = i - 1
    return nil

fn addTypeDef(name: str, def: Node) =
    if name == "" || def == nil:
        return
    var found: bool = false
    let idx: int32 = hashmaps.hashMapStrIntGet(typeDefIndex, name, &found)
    if found && idx >= 0 && idx < typeDefNodes.len:
        return
    if findTypeByName(typeDefKeys, typeDefNodes, name) != nil:
        return
    let newIdx: int32 = typeDefKeys.len
    addPtr[str](&typeDefKeys, name)
    addPtr[Node](&typeDefNodes, def)
    hashmaps.hashMapStrIntPut(&typeDefIndex, name, newIdx)
    cgenTypeNameResolveEpoch = cgenTypeNameResolveEpoch + 1

fn lookupTypeDef(name: str): Node =
    var found: bool = false
    let idx: int32 = hashmaps.hashMapStrIntGet(typeDefIndex, name, &found)
    var def: Node = nil
    if found && idx >= 0 && idx < typeDefNodes.len:
        def = get[Node](typeDefNodes, idx)
    else:
        def = findTypeByName(typeDefKeys, typeDefNodes, name)
    if def != nil:
        return def
    var resolved: str = name
    if name != "" && name != nil && !strHasSubstr(name, "__"):
        if def == nil:
            let suffix: str = "__" + name
            var match: str = ""
            var i: int32 = 0
            while i < typeNames.len:
                let curName: str = get[str](typeNames, i)
                if hasSuffix(curName, suffix):
                    if !strIsEmpty(match):
                        match = ""
                        break
                    match = curName
                i = i + 1
            if !strIsEmpty(match):
                resolved = match
    if !strIsEmpty(resolved) && !streq(resolved, name):
        found = false
        let idx2: int32 = hashmaps.hashMapStrIntGet(typeDefIndex, resolved, &found)
        if found && idx2 >= 0 && idx2 < typeDefNodes.len:
            def = get[Node](typeDefNodes, idx2)
        else:
            def = findTypeByName(typeDefKeys, typeDefNodes, resolved)
        if def != nil:
            return def
    return nil

fn lookupFieldType(owner: str, fieldName: str): Node =
    if owner == "" || fieldName == "":
        return nil
    let key: str = owner + "." + fieldName
    var found: bool = false
    let idx: int32 = hashmaps.hashMapStrIntGet(fieldTypeIndex, key, &found)
    if found && idx >= 0 && idx < fieldTypeNodes.len:
        return get[Node](fieldTypeNodes, idx)
    var i: int32 = fieldTypeKeys.len - 1
    while i >= 0:
        if get[str](fieldTypeKeys, i) == key:
            return get[Node](fieldTypeNodes, i)
        i = i - 1
    if owner != nil && fieldName != nil && !strHasSubstr(owner, "__"):
        let suffix: str = "__" + owner + "." + fieldName
        var matchIdx: int32 = -1
        var j: int32 = fieldTypeKeys.len - 1
        while j >= 0:
            let curKey: str = get[str](fieldTypeKeys, j)
            if hasSuffix(curKey, suffix):
                if matchIdx >= 0:
                    return nil
                matchIdx = j
            j = j - 1
        if matchIdx >= 0 && matchIdx < fieldTypeNodes.len:
            return get[Node](fieldTypeNodes, matchIdx)
    if owner != nil && fieldName != nil && strHasSubstr(owner, "__"):
        var last: int32 = -1
        var k: int32 = 0
        while k + 1 < len owner:
            if charAt(owner, k) == '_' && charAt(owner, k + 1) == '_':
                last = k
                k = k + 2
            else:
                k = k + 1
        if last >= 0 && last + 2 < len owner:
            let shortOwner: str = cgenSliceRange(owner, last + 2, len owner)
            if !strIsEmpty(shortOwner) && !streq(shortOwner, owner):
                return lookupFieldType(shortOwner, fieldName)
    return nil

fn identDefsTailIndex(defs: Node): int32 =
    if defs == nil:
        return -1
    let total: int32 = kidCount defs
    if total <= 0:
        return -1
    var last: int32 = total - 1
    let tail: Node = kid(defs, last)
    if tail != nil && (tail.kind == nkPragma || tail.kind == nkAnnotation):
        last = last - 1
    return last

fn identDefsType(defs: Node): Node =
    let last: int32 = identDefsTailIndex(defs)
    if last < 1:
        return nil
    if last == 1:
        return kid(defs, last)
    return kid(defs, last - 1)

fn identDefsDefault(defs: Node): Node =
    let last: int32 = identDefsTailIndex(defs)
    if last <= 1:
        return nil
    return kid(defs, last)

fn identDefsNameCount(defs: Node): int32 =
    let last: int32 = identDefsTailIndex(defs)
    if last < 1:
        return 0
    if last == 1:
        return 1
    let nameCount: int32 = last - 1
    if nameCount < 0:
        return 0
    return nameCount

fn typeDeclNameNode(n: Node): Node =
    if n == nil || kidCount n < 1:
        return nil
    return kid(n, 0)

fn typeDeclDefNode(n: Node): Node =
    if n == nil || kidCount n < 2:
        return nil
    return kid(n, 1)

fn typeDeclPragmaNode(n: Node): Node =
    if n == nil || kidCount n < 5:
        return nil
    let pr: Node = kid(n, 4)
    if pr != nil && pr.kind == nkPragma:
        return pr
    return nil

fn cgenSliceRange(s: str, start: int32, stop: int32): str =
    if s == nil:
        return ""
    if start < 0:
        return ""
    if stop < start:
        return ""
    let n: int32 = len s
    if start >= n:
        return ""
    var endIdx: int32 = stop
    if endIdx >= n:
        endIdx = n - 1
    let count: int32 = endIdx - start + 1
    let p: void* = alloc(count + 1)
    let src: void* = ptr_add(s, start)
    copyMem(p, src, count)
    setMem(ptr_add(p, count), 0, 1)
    return str(p)

fn cgenNextTempName(prefix: str): str =
    var name: str = "__cheng_" + prefix + "_"
    name = name + int64ToStr cgenTempId
    cgenTempId = cgenTempId + 1
    return name

fn cgenHasPrefix(s: str, prefix: str): bool =
    if s == nil || prefix == nil:
        return false
    let n: int32 = len s
    let m: int32 = len prefix
    if m == 0:
        return true
    if n < m:
        return false
    var i: int32 = 0
    while i < m:
        if charAt(s, i) != charAt(prefix, i):
            return false
        i = i + 1
    return true

fn strHasSubstr(s: str, sub: str): bool =
    if s == nil || sub == nil:
        return false
    let n: int32 = len s
    let m: int32 = len sub
    if m == 0:
        return true
    if n < m:
        return false
    var i: int32 = 0
    while i + m <= n:
        var j: int32 = 0
        var ok: bool = true
        while j < m:
            if charAt(s, i + j) != charAt(sub, j):
                ok = false
                break
            j = j + 1
        if ok:
            return true
        i = i + 1
    return false

fn hasSuffix(s: str, suffix: str): bool =
    if s == nil || suffix == nil:
        return false
    let n: int32 = len s
    let m: int32 = len suffix
    if m == 0:
        return true
    if n < m:
        return false
    let start: int32 = n - m
    var i: int32 = 0
    while i < m:
        if charAt(s, start + i) != charAt(suffix, i):
            return false
        i = i + 1
    return true

fn strHasChar(s: str, target: char): bool =
    if s == nil:
        return false
    var i: int32 = 0
    while i < len s:
        if charAt(s, i) == target:
            return true
        i = i + 1
    return false

fn strIsEmpty(s: str): bool =
    if s == nil:
        return true
    return len s == 0

fn cgen_isAlphaNum(c: char): bool =
    if (c >= 'a' && c <= 'z') ||(c >= 'A' && c <= 'Z'):
        return true
    if c >= '0' && c <= '9':
        return true
    return false

fn isSafeCIdent(name: str): bool =
    if strIsEmpty(name):
        return false
    var i: int32 = 0
    while i < len name:
        let c: char = charAt(name, i)
        if i == 0:
            if !(c == '_' || (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z')):
                return false
        else:
            if !(cgen_isAlphaNum(c) || c == '_'):
                return false
        i = i + 1
    return true

fn isCKeyword(name: str): bool =
    if strIsEmpty(name):
        return false
    if name == "auto" || name == "break" || name == "case" || name == "char" ||
       name == "const" || name == "continue" || name == "default" || name == "do" ||
       name == "double" || name == "else" || name == "enum" || name == "extern" ||
       name == "float" || name == "for" || name == "goto" || name == "if" ||
       name == "inline" || name == "int" || name == "long" || name == "register" ||
       name == "restrict" || name == "return" || name == "short" || name == "signed" ||
       name == "sizeof" || name == "static" || name == "struct" || name == "switch" ||
       name == "typedef" || name == "union" || name == "unsigned" || name == "void" ||
       name == "volatile" || name == "while":
        return true
    if name == "_Alignas" || name == "_Alignof" || name == "_Atomic" || name == "_Bool" ||
       name == "_Complex" || name == "_Generic" || name == "_Imaginary" || name == "_Noreturn" ||
       name == "_Static_assert" || name == "_Thread_local":
        return true
    return false

fn cgenEscapeCIdent(raw: str): str =
    if raw == nil:
        return ""
    let name: str = cgenStripSpaces raw
    if strIsEmpty(name):
        return ""
    var out: str = name
    if !isSafeCIdent(out):
        out = mangleCName out
    if isCKeyword(out):
        return out + "_"
    return out

fn cgenCallIsSpace(n: Node): bool =
    if n == nil:
        return false
    return (int32(n.callStyle) & int32(CallStyleSpace)) != 0

fn cgenCallIsParen(n: Node): bool =
    if n == nil:
        return false
    return (int32(n.callStyle) & int32(CallStyleParen)) != 0

fn isTypeName(name: str): bool =
    if name == "int" || name == "int8" || name == "int16" || name == "int32" || name == "int64":
        return true
    if name == "uint" || name == "uint8" || name == "uint16" || name == "uint32" || name == "uint64":
        return true
    if name == "bool" || name == "char":
        return true
    if name == "float" || name == "float32" || name == "float64":
        return true
    if name == "cstring" || name == "str" || name == "string":
        return true
    if name == "void":
        return true
    return false

fn cgenIsTypeExprNode(n: Node): bool =
    if n == nil:
        return false
    var cur: Node = n
    if cur != nil && cur.kind == nkPar && kidCount cur == 1:
        cur = kid(cur, 0)
    if cur == nil:
        return false
    if cur.kind == nkIdent || cur.kind == nkSymbol:
        let nm: str = cgenStripSpaces cur.ident
        if isTypeName nm:
            return true
        if isKnownTypeName nm:
            return true
        if isRefTypeName nm:
            return true
        return false
    if cur.kind == nkBracketExpr && kidCount cur > 0:
        return cgenIsTypeExprNode kid(cur, 0)
    if cur.kind == nkPostfix && kidCount cur > 1:
        let opn0: Node = kid(cur, 0)
        let opn1: Node = kid(cur, 1)
        if opn0 != nil && cgenStripSpaces(opn0.ident) == "*":
            return cgenIsTypeExprNode kid(cur, 1)
        if opn1 != nil && cgenStripSpaces(opn1.ident) == "*":
            return cgenIsTypeExprNode kid(cur, 0)
    if cur.kind == nkInfix && kidCount cur >= 3:
        let opn2: Node = kid(cur, 0)
        if opn2 != nil && cgenStripSpaces(opn2.ident) == "*":
            let rhs: Node = kid(cur, 2)
            if rhs == nil || rhs.kind == nkEmpty:
                return cgenIsTypeExprNode kid(cur, 1)
        let opnMid: Node = kid(cur, 1)
        if opnMid != nil && cgenStripSpaces(opnMid.ident) == "*":
            let rhsMid: Node = kid(cur, 2)
            if rhsMid == nil || rhsMid.kind == nkEmpty:
                return cgenIsTypeExprNode kid(cur, 0)
    if cur.kind == nkPtrTy || cur.kind == nkRefTy || cur.kind == nkVarTy:
        return true
    return false

fn typeNodeFromCallee(callee: Node): Node =
    if callee == nil:
        return nil
    if cgenIsTypeExprNode callee:
        return callee
    let baseName: str = calleeBaseName callee
    if baseName == "":
        return nil
    if isTypeName baseName || isKnownTypeName baseName || isRefTypeName baseName:
        return newIdent(baseName, callee.pos)
    return nil

fn cgenCastTargetFromFnName(name: str): str =
    if name == nil || len name == 0:
        return ""
    var i: int32 = 0
    while i < len name:
        if charAt(name, i) == '_':
            break
        i = i + 1
    if i <= 0 || i + 1 >= len name:
        return ""
    let lhs: str = cgenSliceRange(name, 0, i - 1)
    let rhs: str = cgenSliceRange(name, i + 1, len name - 1)
    if !isTypeName(lhs) || !isTypeName(rhs):
        return ""
    return lhs

fn cgenTypeKey(n: Node): str =
    if n == nil:
        return ""
    var cached: bool = false
    let idx: int32 = hashmaps.hashMapPtrIntGet(cgenTypeKeyIndex, void*(n), &cached)
    if cached:
        if idx <= 0:
            return ""
        return get[str](cgenTypeKeyValues, idx - 1)
    let key: str = cgenTypeKeyImpl n
    addPtr[str](&cgenTypeKeyValues, key)
    let storedIdx: int32 = cgenTypeKeyValues.len
    hashmaps.hashMapPtrIntPut(&cgenTypeKeyIndex, void*(n), storedIdx)
    return key

fn cgenTypeKeyImpl(n: Node): str =
    if n == nil:
        return ""
    case n.kind
    of nkDotExpr:
        # Type expressions may be qualified as `Module.Type`. For backend purposes,
        # the module prefix is only for disambiguation; treat the key as the member.
        if kidCount n > 1:
            return cgenTypeKey kid(n, 1)
        return ""
    of nkIdent, nkSymbol:
        var name: str = cgenStripSpaces n.ident
        if name == "float":
            name = "float64"
        return cgenSanitizeKey(name)
    of nkIdentDefs:
        if kidCount n > 1:
            return cgenTypeKey kid(n, 1)
        return ""
    of nkCallArg:
        if kidCount n > 1:
            return cgenTypeKey kid(n, 1)
        return ""
    of nkIntLit:
        return int64ToStr n.intVal
    of nkPtrTy:
        if kidCount n > 0:
            return "ptr_" + cgenTypeKey kid(n, 0)
        return "ptr"
    of nkRefTy:
        if kidCount n > 0:
            return "ref_" + cgenTypeKey kid(n, 0)
        return "ref"
    of nkVarTy:
        if kidCount n > 0:
            return "var_" + cgenTypeKey kid(n, 0)
        return "var"
    of nkPostfix:
        if kidCount n > 1:
            let opn0: Node = kid(n, 0)
            let opn1: Node = kid(n, 1)
            if opn0 != nil && cgenStripSpaces(opn0.ident) == "*":
                return "ptr_" + cgenTypeKey kid(n, 1)
            if opn1 != nil && cgenStripSpaces(opn1.ident) == "*":
                return "ptr_" + cgenTypeKey kid(n, 0)
        return ""
    of nkInfix:
        if kidCount n >= 3:
            let opn2: Node = kid(n, 0)
            if opn2 != nil && cgenStripSpaces(opn2.ident) == "*":
                let rhs: Node = kid(n, 2)
                if rhs == nil || rhs.kind == nkEmpty:
                    return "ptr_" + cgenTypeKey kid(n, 1)
            let opnMid: Node = kid(n, 1)
            if opnMid != nil && cgenStripSpaces(opnMid.ident) == "*":
                let rhsMid: Node = kid(n, 2)
                if rhsMid == nil || rhsMid.kind == nkEmpty:
                    return "ptr_" + cgenTypeKey kid(n, 0)
        return ""
    of nkSetTy:
        if kidCount n > 0:
            return "set_" + cgenTypeKey kid(n, 0)
        return "set"
    of nkFnTy:
        var parts: seq[str] = newSeqWithCap[str](0, 4)
        if kidCount n > 0:
            let fp: Node = kid(n, 0)
            if fp != nil && fp.kind == nkFormalParams:
                var i: int32 = 0
                while i < kidCount fp:
                    let d: Node = kid(fp, i)
                    if d != nil && d.kind == nkIdentDefs && kidCount d > 1:
                        let k: str = cgenTypeKey kid(d, 1)
                        if len k > 0:
                            addPtr[str](&parts, k)
                    i = i + 1
        var sig: str = "fn"
        var pi: int32 = 0
        while pi < parts.len:
            sig = sig + "_"
            sig = sig + get[str](parts, pi)
            pi = pi + 1
        if kidCount n > 1:
            let retKey: str = cgenTypeKey kid(n, 1)
            if len retKey > 0:
                sig = sig + "_ret_"
                sig = sig + retKey
        return sig
    of nkTupleTy, nkTupleLit:
        var parts2: seq[str] = newSeqWithCap[str](0, 4)
        var i2: int32 = 0
        while i2 < kidCount n:
            let k2: str = cgenTypeKey kid(n, i2)
            if len k2 > 0:
                addPtr[str](&parts2, k2)
            i2 = i2 + 1
        var out2: str = "tuple"
        var j2: int32 = 0
        while j2 < parts2.len:
            out2 = out2 + "_"
            out2 = out2 + get[str](parts2, j2)
            j2 = j2 + 1
        return out2
    of nkBracketExpr:
        if kidCount n > 0:
            let base: Node = kid(n, 0)
            var baseKey: str = cgenTypeKey base
            if baseKey == "array" && kidCount n == 3:
                var a1: Node = kid(n, 1)
                var a2: Node = kid(n, 2)
                if a1 != nil && a2 != nil:
                    var tmp1: int64 = 0
                    var tmp2: int64 = 0
                    let c1: bool = a1.kind != nkEmpty && cgenConstIntValueFromExpr(a1, &tmp1)
                    let c2: bool = a2.kind != nkEmpty && cgenConstIntValueFromExpr(a2, &tmp2)
                    if c2 && !c1:
                        let t: Node = a1
                        a1 = a2
                        a2 = t
                    let kLen: str = cgenTypeKey a1
                    let kElem: str = cgenTypeKey a2
                    if len(kLen) > 0 && len(kElem) > 0:
                        return baseKey + "_" + kLen + "_" + kElem
            var parts3: seq[str] = newSeqWithCap[str](0, 4)
            var i3: int32 = 1
            while i3 < kidCount n:
                var k3: str = cgenTypeKey kid(n, i3)
                if len k3 > 0:
                    addPtr[str](&parts3, k3)
                i3 = i3 + 1
            var out3: str = baseKey
            var j3: int32 = 0
            while j3 < parts3.len:
                out3 = out3 + "_"
                out3 = out3 + get[str](parts3, j3)
                j3 = j3 + 1
            return out3
    else:
        if n.ident != nil && len n.ident > 0:
            return cgenSanitizeKey(cgenStripSpaces(n.ident))
        return "node"
    return ""

fn recordFnType(n: Node): str =
    if n == nil:
        return ""
    let key: str = cgenTypeKey n
    if key == "":
        return ""
    if strSeqHas(&fnTypeKeys, key):
        return key
    addPtr[str](&fnTypeKeys, key)
    hashsets.hashSetStrAdd(&fnTypeKeySet, key)
    addPtr[Node](&fnTypeNodes, n)
    return key

fn collectFnTypesFromType(n: Node) =
    if n == nil:
        return
    if n.kind == nkFnTy:
        recordFnType n
        return
    if n.kind == nkIdentDefs:
        if kidCount n > 1:
            collectFnTypesFromType kid(n, 1)
        return
    var i: int32 = 0
    while i < kidCount n:
        collectFnTypesFromType kid(n, i)
        i = i + 1

fn collectFnTypes(root: Node) =
    fnTypeKeys.len = 0
    fnTypeNodes.len = 0
    hashsets.hashSetStrClear(&fnTypeKeySet)
    var decls: seq[Node] = newSeqWithCap[Node](0, 64)
    collectTypeDecls(root, &decls)
    var i: int32 = 0
    while i < decls.len:
        let def: Node = typeDeclDef get[Node](decls, i)
        if def != nil:
            collectFnTypesFromType def
        i = i + 1
    collectFnTypesFromNode root

fn collectFnTypesFromNode(n: Node) =
    if n == nil:
        return
    if n.kind == nkFnTy:
        recordFnType n
    var i: int32 = 0
    while i < kidCount n:
        collectFnTypesFromNode kid(n, i)
        i = i + 1

fn emitFnTypeDecl(w: CWriter*, name: str, fnNode: Node) =
    if w == nil || name == "" || fnNode == nil:
        return
    var retNode: Node = newNode(nkEmpty, fnNode.pos)
    if kidCount fnNode > 1:
        retNode = kid(fnNode, 1)
    cwWrite(w, "typedef ")
    emitTypeName(w, retNode)
    cwWrite(w, " (*")
    cwWrite(w, name)
    cwWrite(w, ")(")
    var wrote: bool = false
    if kidCount fnNode > 0:
        let fp: Node = kid(fnNode, 0)
        if fp != nil && fp.kind == nkFormalParams:
            var i: int32 = 0
            while i < kidCount fp:
                let defs: Node = kid(fp, i)
                if defs != nil && defs.kind == nkIdentDefs && kidCount defs > 1:
                    if wrote:
                        cwWrite(w, ", ")
                    emitTypeName(w, kid(defs, 1))
                    wrote = true
                i = i + 1
    if !wrote:
        cwWrite(w, "void")
    cwWriteLine(w, ");")

fn emitFnTypeDecls(w: CWriter*) =
    if w == nil:
        return
    var i: int32 = 0
    while i < fnTypeKeys.len:
        emitFnTypeDecl(w, get[str](fnTypeKeys, i), get[Node](fnTypeNodes, i))
        i = i + 1
    if fnTypeKeys.len > 0:
        cwNewline w

fn strStartsWith(s: str, prefix: str): bool =
    if s == nil || prefix == nil:
        return false
    let n: int32 = len s
    let m: int32 = len prefix
    if m == 0:
        return true
    if n < m:
        return false
    var i: int32 = 0
    while i < m:
        if charAt(s, i) != charAt(prefix, i):
            return false
        i = i + 1
    return true

fn dummyPos(): SourcePos =
    var pos: SourcePos
    pos.line = 0
    pos.col = 0
    return pos

fn typeNodeFromKey(key: str): Node =
    if key == "":
        return nil
    let pos: SourcePos = dummyPos()
    if strStartsWith(key, "ptr_"):
        let rest: str = cgenSliceRange(key, 4, len key)
        var n: Node = newNode(nkPtrTy, pos)
        var base: Node = typeNodeFromKey(rest)
        if base == nil:
            base = newIdent("void", pos)
        addSon(n, base)
        return n
    if strStartsWith(key, "ref_"):
        let rest2: str = cgenSliceRange(key, 4, len key)
        var n2: Node = newNode(nkRefTy, pos)
        var base2: Node = typeNodeFromKey(rest2)
        if base2 == nil:
            base2 = newIdent("void", pos)
        addSon(n2, base2)
        return n2
    if strStartsWith(key, "var_"):
        let rest3: str = cgenSliceRange(key, 4, len key)
        var n3: Node = newNode(nkVarTy, pos)
        var base3: Node = typeNodeFromKey(rest3)
        if base3 == nil:
            base3 = newIdent("void", pos)
        addSon(n3, base3)
        return n3
    if strStartsWith(key, "seq_"):
        let rest4: str = cgenSliceRange(key, 4, len key)
        var n4: Node = newNode(nkBracketExpr, pos)
        addSon(n4, newIdent("seq", pos))
        if len rest4 > 0:
            addSon(n4, typeNodeFromKey(rest4))
        return n4
    if strStartsWith(key, "Table_"):
        let rest5: str = cgenSliceRange(key, 6, len key)
        var n5: Node = newNode(nkBracketExpr, pos)
        addSon(n5, newIdent("Table", pos))
        if len rest5 > 0:
            addSon(n5, typeNodeFromKey(rest5))
        return n5
    if strStartsWith(key, "__cheng_tables_Entry_"):
        let rest6: str = cgenSliceRange(key, 22, len key)
        var n6: Node = newNode(nkBracketExpr, pos)
        addSon(n6, newIdent("__cheng_tables_Entry", pos))
        if len rest6 > 0:
            addSon(n6, typeNodeFromKey(rest6))
        return n6
    return newIdent(key, pos)

fn cgenIsDigits(s: str): bool =
    if s == nil || len s == 0:
        return false
    var i: int32 = 0
    while i < len s:
        let c: char = charAt(s, i)
        if c < '0' || c > '9':
            return false
        i = i + 1
    return true

fn cgenParseDigits(s: str): int64 =
    if s == nil:
        return 0
    var val: int64 = 0
    var i: int32 = 0
    while i < len s:
        let c: char = charAt(s, i)
        if c < '0' || c > '9':
            break
        val = val * 10 + (int64(c) - int64('0'))
        i = i + 1
    return val

fn cgenArrayTypeExprFromName(name: str): Node =
    if name == nil || !cgenHasPrefix(name, "array_"):
        return nil
    let totalLen: int32 = len name
    if totalLen <= 6:
        return nil
    let rest: str = cgenSliceRange(name, 6, totalLen - 1)
    if strIsEmpty(rest):
        return nil
    var sepIdx: int32 = -1
    var i: int32 = 0
    while i < len rest:
        if charAt(rest, i) == '_':
            sepIdx = i
            break
        i = i + 1
    if sepIdx <= 0:
        return nil
    let lenPart: str = cgenSliceRange(rest, 0, sepIdx - 1)
    let elemKey: str = cgenSliceRange(rest, sepIdx + 1, len rest - 1)
    if strIsEmpty(lenPart) || strIsEmpty(elemKey):
        return nil
    let pos: SourcePos = dummyPos()
    var lenNode: Node = nil
    if cgenIsDigits(lenPart):
        lenNode = newIntLit(cgenParseDigits(lenPart), pos)
    else:
        lenNode = newIdent(lenPart, pos)
    var elemNode: Node = typeNodeFromKey(elemKey)
    if elemNode == nil:
        elemNode = newIdent(elemKey, pos)
    var arrNode: Node = newNode(nkBracketExpr, pos)
    addSon(arrNode, newIdent("array", pos))
    addSon(arrNode, lenNode)
    addSon(arrNode, elemNode)
    return arrNode

fn recListHasFields(recList: Node): bool =
    if recList == nil:
        return false
    var i: int32 = 0
    while i < kidCount recList:
        let entry: Node = kid(recList, i)
        if entry != nil && entry.kind == nkIdentDefs && kidCount entry >= 2:
            return true
        if entry != nil && entry.kind == nkRecCase:
            return true
        i = i + 1
    return false

fn emitBuiltinObjectFields(w: CWriter*, tagName: str): bool =
    if tagName == "":
        return false
    if strStartsWith(tagName, "seq_"):
        cwIndent w
        cwWrite(w, "NI32 len;")
        cwNewline w
        cwIndent w
        cwWrite(w, "NI32 cap;")
        cwNewline w
        cwIndent w
        cwWrite(w, "void* buffer;")
        cwNewline w
        return true
    if strStartsWith(tagName, "Table_"):
        cwIndent w
        cwWrite(w, "seq_ptr_void slots;")
        cwNewline w
        cwIndent w
        cwWrite(w, "NI32 len;")
        cwNewline w
        return true
    if strStartsWith(tagName, "__cheng_tables_Entry_"):
        let pos: SourcePos = dummyPos()
        let valKey: str = cgenSliceRange(tagName, 22, len tagName)
        cwIndent w
        emitTypeName(w, newIdent("str", pos))
        cwWrite(w, " key;")
        cwNewline w
        cwIndent w
        let valNode: Node = typeNodeFromKey(valKey)
        emitTypeName(w, valNode)
        cwWrite(w, " val;")
        cwNewline w
        return true
    if tagName == "CatchableError" || tagName == "IOError" || tagName == "ValueError":
        let pos2: SourcePos = dummyPos()
        cwIndent w
        emitTypeName(w, newIdent("str", pos2))
        cwWrite(w, " msg;")
        cwNewline w
        return true
    return false

fn mangleCName(raw: str): str =
    if raw == nil:
        return ""
    if cgenProfOn:
        cgenMangleCalls = cgenMangleCalls + 1
    var cached: bool = false
    let cachedIdx: int32 = hashmaps.hashMapPtrIntGet(cgenMangleIndex, void*(raw), &cached)
    if cached && cachedIdx > 0 && cachedIdx <= cgenMangleValues.len:
        if cgenProfOn:
            cgenMangleHits = cgenMangleHits + 1
        return get[str](cgenMangleValues, cachedIdx - 1)
    var name: str = cgenStripSpaces raw
    if len name == 0:
        return cgenMangleCacheStore(raw, "")
    if name == "main":
        return cgenMangleCacheStore(raw, "main")
    if hasSuffix(name, ".c"):
        if len name > 2:
            name = cgenSliceRange(name, 0, len name - 3)
        else:
            name = ""
    if name == "[]=":
        return cgenMangleCacheStore(raw, "putQ")
    if name == "[]":
        return cgenMangleCacheStore(raw, "getQ")
    if name == "==":
        return cgenMangleCacheStore(raw, "eqQ")
    if name == "<=":
        return cgenMangleCacheStore(raw, "leQ")
    if name == ">=":
        return cgenMangleCacheStore(raw, "geQ")
    if name == "$":
        return cgenMangleCacheStore(raw, "dollarQ")
    if name == "%":
        return cgenMangleCacheStore(raw, "percentQ")
    if name == "&":
        return cgenMangleCacheStore(raw, "ampQ")
    if name == "^":
        return cgenMangleCacheStore(raw, "roofQ")
    if name == "!":
        return cgenMangleCacheStore(raw, "emarkQ")
    if name == "?":
        return cgenMangleCacheStore(raw, "qmarkQ")
    if name == "*":
        return cgenMangleCacheStore(raw, "starQ")
    if name == "+":
        return cgenMangleCacheStore(raw, "plusQ")
    if name == "-":
        return cgenMangleCacheStore(raw, "minusQ")
    if name == "/":
        return cgenMangleCacheStore(raw, "slashQ")
    if name == "\\":
        return cgenMangleCacheStore(raw, "bslashQ")
    if name == "=":
        return cgenMangleCacheStore(raw, "eQ")
    if name == "<":
        return cgenMangleCacheStore(raw, "ltQ")
    if name == ">":
        return cgenMangleCacheStore(raw, "gtQ")
    if name == "~":
        return cgenMangleCacheStore(raw, "tildeQ")
    if name == ":":
        return cgenMangleCacheStore(raw, "colonQ")
    if name == "@":
        return cgenMangleCacheStore(raw, "atQ")
    if name == "|":
        return cgenMangleCacheStore(raw, "barQ")
    if strStartsWith(name, "[]=") && len name > 3:
        return cgenMangleCacheStore(raw, "putQ" + cgenSliceRange(name, 3, len name - 1))
    if strStartsWith(name, "[]") && len name > 2:
        return cgenMangleCacheStore(raw, "getQ" + cgenSliceRange(name, 2, len name - 1))
    if strStartsWith(name, "==") && len name > 2:
        return cgenMangleCacheStore(raw, "eqQ" + cgenSliceRange(name, 2, len name - 1))
    if strStartsWith(name, "<=") && len name > 2:
        return cgenMangleCacheStore(raw, "leQ" + cgenSliceRange(name, 2, len name - 1))
    if strStartsWith(name, ">=") && len name > 2:
        return cgenMangleCacheStore(raw, "geQ" + cgenSliceRange(name, 2, len name - 1))
    if strStartsWith(name, "$") && len name > 1:
        return cgenMangleCacheStore(raw, "dollarQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "%") && len name > 1:
        return cgenMangleCacheStore(raw, "percentQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "&") && len name > 1:
        return cgenMangleCacheStore(raw, "ampQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "^") && len name > 1:
        return cgenMangleCacheStore(raw, "roofQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "!") && len name > 1:
        return cgenMangleCacheStore(raw, "emarkQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "?") && len name > 1:
        return cgenMangleCacheStore(raw, "qmarkQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "*") && len name > 1:
        return cgenMangleCacheStore(raw, "starQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "+") && len name > 1:
        return cgenMangleCacheStore(raw, "plusQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "-") && len name > 1:
        return cgenMangleCacheStore(raw, "minusQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "/") && len name > 1:
        return cgenMangleCacheStore(raw, "slashQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "\\") && len name > 1:
        return cgenMangleCacheStore(raw, "bslashQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "=") && len name > 1:
        return cgenMangleCacheStore(raw, "eQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "<") && len name > 1:
        return cgenMangleCacheStore(raw, "ltQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, ">") && len name > 1:
        return cgenMangleCacheStore(raw, "gtQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "~") && len name > 1:
        return cgenMangleCacheStore(raw, "tildeQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, ":") && len name > 1:
        return cgenMangleCacheStore(raw, "colonQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "@") && len name > 1:
        return cgenMangleCacheStore(raw, "atQ" + cgenSliceRange(name, 1, len name - 1))
    if strStartsWith(name, "|") && len name > 1:
        return cgenMangleCacheStore(raw, "barQ" + cgenSliceRange(name, 1, len name - 1))
    if isSafeCIdent(name):
        return cgenMangleCacheStore(raw, name)
    var out: ByteBuffer = initByteBuffer 64
    var i: int32 = 0
    while i < len name:
        if i + 2 < len name && charAt(name, i) == '[' && charAt(name, i + 1) == ']' && charAt(name, i + 2) == '=':
            bufAddStr(&out, "putQ")
            i = i + 3
            continue
        if i + 1 < len name && charAt(name, i) == '[' && charAt(name, i + 1) == ']':
            bufAddStr(&out, "getQ")
            i = i + 2
            continue
        if i + 1 < len name && charAt(name, i) == '=' && charAt(name, i + 1) == '=':
            bufAddStr(&out, "eqQ")
            i = i + 2
            continue
        if i + 1 < len name && charAt(name, i) == '<' && charAt(name, i + 1) == '=':
            bufAddStr(&out, "leQ")
            i = i + 2
            continue
        if i + 1 < len name && charAt(name, i) == '>' && charAt(name, i + 1) == '=':
            bufAddStr(&out, "geQ")
            i = i + 2
            continue
        let c: char = charAt(name, i)
        if c == 'Q':
            bufAddStr(&out, "QQ")
        elif c == '_':
            bufAddStr(&out, "Q_")
        elif c == '.':
            bufAddChar(&out, '_')
        elif c == '$':
            bufAddStr(&out, "dollarQ")
        elif c == '%':
            bufAddStr(&out, "percentQ")
        elif c == '&':
            bufAddStr(&out, "ampQ")
        elif c == '^':
            bufAddStr(&out, "roofQ")
        elif c == '!':
            bufAddStr(&out, "emarkQ")
        elif c == '?':
            bufAddStr(&out, "qmarkQ")
        elif c == '*':
            bufAddStr(&out, "starQ")
        elif c == '+':
            bufAddStr(&out, "plusQ")
        elif c == '-':
            bufAddStr(&out, "minusQ")
        elif c == '/':
            bufAddStr(&out, "slashQ")
        elif c == '\\':
            bufAddStr(&out, "bslashQ")
        elif c == '=':
            bufAddStr(&out, "eQ")
        elif c == '<':
            bufAddStr(&out, "ltQ")
        elif c == '>':
            bufAddStr(&out, "gtQ")
        elif c == '~':
            bufAddStr(&out, "tildeQ")
        elif c == ':':
            bufAddStr(&out, "colonQ")
        elif c == '@':
            bufAddStr(&out, "atQ")
        elif c == '|':
            bufAddStr(&out, "barQ")
        else:
            if cgen_isAlphaNum c:
                bufAddChar(&out, c)
            else:
                let v: int32 = int32(c)
                bufAddChar(&out, 'X')
                bufAddChar(&out, hexDigitUpper v / 16)
                bufAddChar(&out, hexDigitUpper v % 16)
                bufAddChar(&out, 'Q')
        i = i + 1
    return cgenMangleCacheStore(raw, toString(&out))

var importKeys: seq[str] = newSeqWithCap[str](0, 16)
var importVals: seq[str] = newSeqWithCap[str](0, 16)
var importIndexMap: hashmaps.HashMapStrInt

fn importMapClear() =
    importKeys.len = 0
    importVals.len = 0
    hashmaps.hashMapStrIntClear(&importIndexMap)

fn importMapPut(key: str, val: str) =
    if key == nil:
        return
    var found: bool = false
    let idx: int32 = hashmaps.hashMapStrIntGetOrInsert(&importIndexMap, key, importVals.len + 1, &found)
    if found:
        if idx > 0 && idx <= importVals.len:
            setPtr[str](&importKeys, idx - 1, key)
            setPtr[str](&importVals, idx - 1, val)
        return
    addPtr[str](&importKeys, key)
    addPtr[str](&importVals, val)

fn importMapGet(key: str): str =
    var found: bool = false
    let idx: int32 = hashmaps.hashMapStrIntGet(importIndexMap, key, &found)
    if found && idx > 0 && idx <= importVals.len:
        return get[str](importVals, idx - 1)
    return ""

fn cgenGetImportC(n: Node): str =
    if n == nil:
        return ""
    if n.kind != nkFnDecl && n.kind != nkIteratorDecl:
        return ""
    var cached: bool = false
    let idx: int32 = hashmaps.hashMapPtrIntGet(cgenImportCIndex, void*(n), &cached)
    if cached:
        if idx <= 0:
            return ""
        return get[str](cgenImportCValues, idx - 1)
    var found: str = ""
    if kidCount n > 5:
        let pragmas: Node = kid(n, 5)
        if pragmas != nil && pragmas.kind == nkPragma:
            var i: int32 = 0
            while i < kidCount pragmas:
                let a: Node = kid(pragmas, i)
                if a != nil && a.kind == nkAnnotation && kidCount a > 0:
                    let name: str = plainName kid(a, 0)
                    if name == "importc":
                        if kidCount a > 1 && kid(a, 1) != nil && kid(a, 1).kind == nkStrLit:
                            found = kid(a, 1).strVal
                        else:
                            found = name
                i = i + 1
    let nm: str = plainName kid(n, 0)
    if (nm == "cgenGetenv") && ((found == "") || (found == "cheng_free")):
        found = "getenv"
    if found == "":
        hashmaps.hashMapPtrIntPut(&cgenImportCIndex, void*(n), 0)
        return ""
    addPtr[str](&cgenImportCValues, found)
    let storedIdx: int32 = cgenImportCValues.len
    hashmaps.hashMapPtrIntPut(&cgenImportCIndex, void*(n), storedIdx)
    return found

fn cgenFnHasVarargs(n: Node): bool =
    if n == nil:
        return false
    var cached: bool = false
    let idx: int32 = hashmaps.hashMapPtrIntGet(cgenFnVarargsIndex, void*(n), &cached)
    if cached:
        return idx == 1
    if kidCount n > 5:
        let pragmas: Node = kid(n, 5)
        if pragmas != nil && pragmas.kind == nkPragma:
            var i: int32 = 0
            while i < kidCount pragmas:
                let a: Node = kid(pragmas, i)
                if a != nil && a.kind == nkAnnotation && kidCount a > 0:
                    let name: str = plainName kid(a, 0)
                    if name == "varargs":
                        hashmaps.hashMapPtrIntPut(&cgenFnVarargsIndex, void*(n), 1)
                        return true
                i = i + 1
    hashmaps.hashMapPtrIntPut(&cgenFnVarargsIndex, void*(n), 2)
    return false

fn cgenIsVarargsTypeNode(n: Node): bool =
    if n == nil:
        return false
    if n.kind == nkIdent || n.kind == nkSymbol:
        let name: str = cgenStripSpaces n.ident
        return name == "varargs"
    if n.kind != nkBracketExpr:
        return false
    if kidCount n < 1:
        return false
    let base: Node = kid(n, 0)
    if base == nil:
        return false
    if base.kind == nkIdent || base.kind == nkSymbol:
        let name2: str = cgenStripSpaces base.ident
        return name2 == "varargs"
    return false

fn cgenVarargsElemType(n: Node): Node =
    if ! cgenIsVarargsTypeNode n:
        return nil
    if n.kind == nkBracketExpr && kidCount n > 1:
        return kid(n, 1)
    return nil

fn cgenVarargsElemAllowed(ty: Node): bool =
    if ty == nil:
        return false
    if cgenIsAggregateTypeNode(ty):
        return false
    return true

fn cgenFnVarargsKeySuffix(fnNode: Node, paramsNode: Node): str =
    if fnNode != nil:
        var cached: bool = false
        let idx: int32 = hashmaps.hashMapPtrIntGet(cgenFnVarargsSuffixIndex, void*(fnNode), &cached)
        if cached:
            if idx <= 0:
                return ""
            return get[str](cgenFnVarargsSuffixValues, idx - 1)
    var hasVarargs: bool = false
    var varargsElemType: Node = nil
    if fnNode != nil && cgenFnHasVarargs(fnNode):
        hasVarargs = true
    if paramsNode != nil && paramsNode.kind == nkFormalParams:
        var i: int32 = 0
        while i < kidCount paramsNode:
            let defs: Node = kid(paramsNode, i)
            if defs != nil && defs.kind == nkIdentDefs:
                let typeNode: Node = identDefsType defs
                if cgenIsVarargsTypeNode typeNode:
                    hasVarargs = true
                    if varargsElemType == nil:
                        varargsElemType = cgenVarargsElemType typeNode
            i = i + 1
    if !hasVarargs:
        if fnNode != nil:
            hashmaps.hashMapPtrIntPut(&cgenFnVarargsSuffixIndex, void*(fnNode), 0)
        return ""
    var out: str = "_varargs"
    if varargsElemType != nil:
        let vkey: str = cgenTypeKey varargsElemType
        if len vkey > 0:
            out = out + "_"
            out = out + vkey
    if fnNode != nil:
        addPtr[str](&cgenFnVarargsSuffixValues, out)
        let storedIdx: int32 = cgenFnVarargsSuffixValues.len
        hashmaps.hashMapPtrIntPut(&cgenFnVarargsSuffixIndex, void*(fnNode), storedIdx)
    return out

fn cgenFnIsAsync(n: Node): bool =
    if n == nil:
        return false
    if n.kind != nkFnDecl && n.kind != nkIteratorDecl:
        return false
    var cached: bool = false
    let idx: int32 = hashmaps.hashMapPtrIntGet(cgenFnAsyncIndex, void*(n), &cached)
    if cached:
        return idx == 1
    if kidCount n > 5:
        let pragmas: Node = kid(n, 5)
        if pragmas != nil && pragmas.kind == nkPragma:
            var i: int32 = 0
            while i < kidCount pragmas:
                let a: Node = kid(pragmas, i)
                if a != nil && a.kind == nkAnnotation && kidCount a > 0:
                    let name: str = cgenStripSpaces plainName(kid(a, 0))
                    if name == "async":
                        hashmaps.hashMapPtrIntPut(&cgenFnAsyncIndex, void*(n), 1)
                        return true
                i = i + 1
    hashmaps.hashMapPtrIntPut(&cgenFnAsyncIndex, void*(n), 2)
    return false

fn cgenFnIsWeak(n: Node): bool =
    if n == nil:
        return false
    if n.kind != nkFnDecl && n.kind != nkIteratorDecl:
        return false
    var cached: bool = false
    let idx: int32 = hashmaps.hashMapPtrIntGet(cgenFnWeakIndex, void*(n), &cached)
    if cached:
        return idx == 1
    if kidCount n > 5:
        let pragmas: Node = kid(n, 5)
        if pragmas != nil && pragmas.kind == nkPragma:
            var i: int32 = 0
            while i < kidCount pragmas:
                let a: Node = kid(pragmas, i)
                if a != nil && a.kind == nkAnnotation && kidCount a > 0:
                    let name: str = cgenStripSpaces plainName(kid(a, 0))
                    if name == "weak":
                        hashmaps.hashMapPtrIntPut(&cgenFnWeakIndex, void*(n), 1)
                        return true
                i = i + 1
    hashmaps.hashMapPtrIntPut(&cgenFnWeakIndex, void*(n), 2)
    return false

fn cgenNodeIsExprLike(n: Node): bool =
    if n == nil:
        return false
    case n.kind
    of nkCall, nkInfix, nkPrefix, nkPostfix, nkDotExpr, nkBracketExpr,
       nkCurlyExpr, nkPar, nkTupleLit, nkSeqLit, nkTableLit,
       nkCurly, nkBracket, nkRange, nkPattern, nkCallArg, nkGuard,
       nkLambda, nkDo, nkIfExpr, nkWhenExpr, nkCaseExpr, nkComprehension,
       nkHiddenDeref, nkDerefExpr,
       nkIdent, nkSymbol, nkIntLit, nkFloatLit, nkStrLit, nkCharLit, nkBoolLit, nkNilLit:
        return true
    else:
        return false

fn cgenAsyncAwaitableType(retNode: Node, pos: SourcePos): Node =
    if retNode == nil || retNode.kind == nkEmpty || cgenIsVoidTypeNode(retNode):
        return newIdent("await_void", pos)
    let key: str = cgenTypeKey retNode
    if key == "int32":
        return newIdent("await_i32", pos)
    return nil

fn cgenAsyncRetType(fnNode: Node, retNode: Node): Node =
    if fnNode == nil:
        return retNode
    let pos: SourcePos = fnNode.pos
    let awaitType: Node = cgenAsyncAwaitableType(retNode, pos)
    if awaitType == nil:
        cgenAddError(pos, "[C-Profile] not-mapped: async return type (FULLC.R03). hint: only int32/void awaitable in v0.")
        return retNode
    return awaitType

fn cgenAsyncReadyFuncName(retNode: Node): str =
    if retNode == nil || retNode.kind == nkEmpty || cgenIsVoidTypeNode(retNode):
        return "cheng_async_ready_void"
    let key: str = cgenTypeKey retNode
    if key == "int32":
        return "cheng_async_ready_i32"
    return ""

fn cgenAwaitFuncName(awaitType: Node): str =
    if awaitType == nil:
        return ""
    let key: str = cgenTypeKey awaitType
    if key == "await_i32":
        return "cheng_await_i32"
    if key == "await_void":
        return "cheng_await_void"
    return ""

fn cgenAwaitValueType(awaitType: Node, pos: SourcePos): Node =
    if awaitType == nil:
        return nil
    let key: str = cgenTypeKey awaitType
    if key == "await_i32":
        return newIdent("int32", pos)
    if key == "await_void":
        return newIdent("void", pos)
    return nil

fn cgenCollectImportC(n: Node) =
    if n == nil:
        return
    if n.kind == nkFnDecl || n.kind == nkIteratorDecl:
        let imp: str = cgenGetImportC n
        if !strIsEmpty(imp):
            let nm: str = plainName kid(n, 0)
            if !strIsEmpty(nm):
                importMapPut(nm, imp)
        return
    if cgenNodeIsExprLike n:
        return
    var i: int32 = 0
    while i < kidCount n:
        cgenCollectImportC kid(n, i)
        i = i + 1

fn isSystemPath(path: str): bool =
    if path == nil || len path == 0:
        return false
    if hasSuffix(path, "/stdlib/bootstrap/system.cheng"):
        return true
    if hasSuffix(path, "\\stdlib\\bootstrap\\system.cheng"):
        return true
    if hasSuffix(path, "/stdlib/bootstrap/system_c.cheng"):
        return true
    return hasSuffix(path, "\\stdlib\\bootstrap\\system_c.cheng")

fn findSubstr(hay: str, needle: str): int32 =
    if hay == nil || needle == nil:
        return -1
    let hayLen: int32 = len hay
    let needleLen: int32 = len needle
    if needleLen == 0:
        return 0
    if hayLen < needleLen:
        return -1
    var i: int32 = 0
    while i <= hayLen - needleLen:
        var j: int32 = 0
        while j < needleLen && charAt(hay, i + j) == charAt(needle, j):
            j = j + 1
        if j == needleLen:
            return i
        i = i + 1
    return -1

fn modulePathKeyStart(path: str): int32 =
    if path == nil || len path == 0:
        return -1
    let idxSrc: int32 = findSubstr(path, "/src/")
    if idxSrc >= 0:
        return idxSrc + 5
    let idxCheng: int32 = findSubstr(path, "/cheng/")
    if idxCheng >= 0:
        return idxCheng + 7
    let idxSrcWin: int32 = findSubstr(path, "\\src\\")
    if idxSrcWin >= 0:
        return idxSrcWin + 5
    let idxChengWin: int32 = findSubstr(path, "\\cheng\\")
    if idxChengWin >= 0:
        return idxChengWin + 7
    return 0

fn modulePathKeyLen(path: str, start: int32): int32 =
    if start < 0:
        return 0
    let n: int32 = len path
    if start >= n:
        return 0
    return n - start

fn modulePathMatches(path: str, modulePath: str): bool =
    if streq(path, modulePath):
        return true
    if path == nil || modulePath == nil:
        return false
    let startA: int32 = modulePathKeyStart(path)
    let startB: int32 = modulePathKeyStart(modulePath)
    let lenA: int32 = modulePathKeyLen(path, startA)
    let lenB: int32 = modulePathKeyLen(modulePath, startB)
    if lenA == 0 || lenB == 0:
        return false
    if lenA != lenB:
        return false
    var i: int32 = 0
    while i < lenA:
        if charAt(path, startA + i) != charAt(modulePath, startB + i):
            return false
        i = i + 1
    return true

fn isSystemIntrinsicFn(n: Node): bool =
    if n == nil || kidCount n < 1:
        return false
    let nameNode: Node = kid(n, 0)
    let nameRaw: str = plainName nameNode
    let nameStr: str = cgenStripSpaces nameRaw
    if nameStr == "":
        return false
    if strStartsWith(nameStr, "bracketEq"):
        return true
    if strStartsWith(nameStr, "bracket"):
        return true
    if strStartsWith(nameStr, "load_"):
        return true
    if strStartsWith(nameStr, "store_"):
        return true
    return false

fn shouldSkipSystem(path: str, modulePath: str): bool =
    if ! isSystemPath path:
        return false
    if strIsEmpty modulePath:
        return false
    let v: str = cgenGetenv("CHENG_C_SYSTEM")
    if v == nil || len v == 0:
        return false
    if v == "0":
        return true
    let c0: char = charAt(v, 0)
    if c0 == 'f' || c0 == 'F' || c0 == 'n' || c0 == 'N':
        return true
    return false

fn isSystemModulePath(modulePath: str): bool =
    return isSystemPath(modulePath)

fn modsymAddUnique(items: seq[str]*, itemSet: hashsets.HashSetStr*, name: str) =
    if name == nil:
        return
    if strIsEmpty name || streq(name, "_"):
        return
    if hashsets.hashSetStrHas(*itemSet, name):
        return
    addPtr[str](items, name)
    hashsets.hashSetStrAdd(itemSet, name)

fn modulePathLess(a: str, b: str): bool =
    if strIsEmpty a:
        return false
    if strIsEmpty b:
        return true
    let startA: int32 = modulePathKeyStart(a)
    let startB: int32 = modulePathKeyStart(b)
    let lenA: int32 = modulePathKeyLen(a, startA)
    let lenB: int32 = modulePathKeyLen(b, startB)
    var i: int32 = 0
    var minLen: int32 = lenB
    if lenA < lenB:
        minLen = lenA
    while i < minLen:
        let ca: char = charAt(a, startA + i)
        let cb: char = charAt(b, startB + i)
        if ca < cb:
            return true
        if ca > cb:
            return false
        i = i + 1
    return lenA < lenB

fn cgenFnDefOwnerModulePath(n: Node): str =
    if n == nil:
        return ""
    if !strIsEmpty(n.strVal):
        return n.strVal
    # Some synthesized/system intrinsics do not carry a source module path.
    # Treat them as owned by the bootstrap system module.
    return "stdlib/bootstrap/system.cheng"

fn cgenBuildFnDefOwnerMap(defs: seq[Node]) =
    cgenFnDefOwnerIndex = hashmaps.hashMapStrIntInit(512)
    cgenFnDefOwnerValues = newSeqWithCap[str](0, 256)
    var i: int32 = 0
    while i < defs.len:
        let n: Node = get[Node](defs, i)
        if n != nil && fnHasBody(n) && cFnSigShouldEmit(n):
            let cName: str = fnCName n
            if !strIsEmpty cName:
                let modPath: str = cgenFnDefOwnerModulePath n
                if !strIsEmpty modPath:
                    var found: bool = false
                    let idxPlus1: int32 = hashmaps.hashMapStrIntGet(cgenFnDefOwnerIndex, cName, &found)
                    if !found || idxPlus1 <= 0 || idxPlus1 > cgenFnDefOwnerValues.len:
                        addPtr[str](&cgenFnDefOwnerValues, modPath)
                        let storedIdx: int32 = cgenFnDefOwnerValues.len
                        hashmaps.hashMapStrIntPut(&cgenFnDefOwnerIndex, cName, storedIdx)
                    else:
                        let curOwner: str = get[str](cgenFnDefOwnerValues, idxPlus1 - 1)
                        if modulePathLess(modPath, curOwner):
                            setPtr[str](&cgenFnDefOwnerValues, idxPlus1 - 1, modPath)
        i = i + 1
    cgenFnDefOwnerBuilt = true

fn cgenFnDefOwnerForName(cName: str): str =
    if !cgenFnDefOwnerBuilt || strIsEmpty cName:
        return ""
    var found: bool = false
    let idxPlus1: int32 = hashmaps.hashMapStrIntGet(cgenFnDefOwnerIndex, cName, &found)
    if !found || idxPlus1 <= 0 || idxPlus1 > cgenFnDefOwnerValues.len:
        return ""
    return get[str](cgenFnDefOwnerValues, idxPlus1 - 1)

fn modsymFnOwned(n: Node, modulePath: str): bool =
    if n == nil:
        return false
    if shouldSkipSystem(n.strVal, modulePath):
        return false
    if strIsEmpty(modulePath):
        return true
    # When emitting C modules, multiple source modules can define the same
    # flattened C symbol name. Pick a stable owner module for each emitted
    # symbol so that linking does not fail with duplicate definitions.
    let cName: str = fnCName n
    let owner: str = cgenFnDefOwnerForName cName
    if !strIsEmpty owner && !modulePathMatches(owner, modulePath):
        return false
    let forceSystem: bool = isSystemModulePath(modulePath) && isSystemIntrinsicFn(n)
    if !modulePathMatches(n.strVal, modulePath):
        if !forceSystem:
            if !strIsEmpty(n.strVal) || !isSystemModulePath(modulePath):
                return false
    return true

fn modsymGlobalOwned(n: Node, modulePath: str): bool =
    if n == nil:
        return false
    if shouldSkipSystem(n.strVal, modulePath):
        return false
    if strIsEmpty(modulePath):
        return true
    return (!strIsEmpty(n.strVal) && modulePathMatches(n.strVal, modulePath)) || (strIsEmpty(n.strVal) && isSystemPath(modulePath))

fn modsymCollectFromStmt(stmt: Node, modulePath: str, funcs: seq[str]*, funcSet: hashsets.HashSetStr*, globals: seq[str]*, globalSet: hashsets.HashSetStr*) =
    if stmt == nil:
        return
    if stmt.kind == nkStmtList || stmt.kind == nkModule || stmt.kind == nkIf || stmt.kind == nkWhen || stmt.kind == nkCase:
        var i: int32 = 0
        while i < kidCount stmt:
            modsymCollectFromStmt(kid(stmt, i), modulePath, funcs, funcSet, globals, globalSet)
            i = i + 1
        return
    if stmt.kind == nkFnDecl || stmt.kind == nkIteratorDecl:
        if modsymFnOwned(stmt, modulePath) && fnHasBody(stmt):
            let nameStr: str = fnCName stmt
            modsymAddUnique(funcs, funcSet, nameStr)
        return
    if stmt.kind == nkLet || stmt.kind == nkVar || stmt.kind == nkConst:
        if modsymGlobalOwned(stmt, modulePath):
            let nameNode: Node = cgenVarNameNode stmt
            if nameNode != nil:
                let nameStr: str = cgenStripSpaces nameNode.ident
                modsymAddUnique(globals, globalSet, nameStr)
        return

fn collectModuleSymbols(root: Node, modulePath: str, funcs: seq[str]*, funcSet: hashsets.HashSetStr*, globals: seq[str]*, globalSet: hashsets.HashSetStr*) =
    if root == nil:
        return
    modsymCollectFromStmt(root, modulePath, funcs, funcSet, globals, globalSet)

fn writeModuleModsym(root: Node, modulePath: str): bool =
    var modsymOut: str = cgenModsymOutOverride
    if modsymOut == nil || len modsymOut == 0:
        modsymOut = cgenGetenv "CHENG_C_MODSYM_OUT"
    if strIsEmpty modsymOut:
        return true
    if strIsEmpty modulePath:
        cgenAddError(root.pos, "module symbol output requires CHENG_C_MODULE")
        return false
    var funcs: seq[str] = newSeqWithCap[str](0, 64)
    var globals: seq[str] = newSeqWithCap[str](0, 64)
    var funcSet: hashsets.HashSetStr = hashsets.hashSetStrInit(128)
    var globalSet: hashsets.HashSetStr = hashsets.hashSetStrInit(128)
    collectModuleSymbols(root, modulePath, &funcs, &funcSet, &globals, &globalSet)
    var payload: str = "# cheng modsym v1\n"
    payload = payload + "module=" + modulePath + "\n"
    var i: int32 = 0
    while i < funcs.len:
        payload = payload + "func " + get[str](funcs, i) + "\n"
        i = i + 1
    i = 0
    while i < globals.len:
        payload = payload + "global " + get[str](globals, i) + "\n"
        i = i + 1
    writeFile(modsymOut, payload)
    return true

fn escapeCString(w: CWriter*, s: str) =
    cwWriteChar(w, '"')
    var i: int32 = 0
    while i < len s:
        let c: char = charAt(s, i)
        case c
        of '\n':
            cwWrite(w, "\\n")
        of '\r':
            cwWrite(w, "\\r")
        of '\t':
            cwWrite(w, "\\t")
        of '\\':
            cwWrite(w, "\\\\")
        of '"':
            cwWrite(w, "\\\"")
        else:
            let v: int32 = int32(c)
            if v < 32 || v > 126:
                cwWrite(w, "\\x")
                cwWriteChar(w, hexDigitUpper(v / 16))
                cwWriteChar(w, hexDigitUpper(v % 16))
            else:
                cwWriteChar(w, c)
        i = i + 1
    cwWriteChar(w, '"')

fn escapeCChar(w: CWriter*, s: str) =
    cwWriteChar(w, '\'')
    if s != nil && len s > 0:
        let c: char = charAt(s, 0)
        case c
        of '\n':
            cwWrite(w, "\\n")
        of '\r':
            cwWrite(w, "\\r")
        of '\t':
            cwWrite(w, "\\t")
        of '\\':
            cwWrite(w, "\\\\")
        of '\'':
            cwWrite(w, "\\'")
        else:
            let v: int32 = int32(c)
            if v < 32 || v > 126:
                cwWrite(w, "\\x")
                cwWriteChar(w, hexDigitUpper(v / 16))
                cwWriteChar(w, hexDigitUpper(v % 16))
            else:
                cwWriteChar(w, c)
    else:
        cwWriteChar(w, '0')
    cwWriteChar(w, '\'')
