# c_codegen.cheng
# Stage1: minimal AST -> C emitter (direct C backend).
import std/strings
import std/os
import std/seqs
import std/hashmaps
import std/hashsets
import std/monotimes
import cheng/stage1/ast
import cheng/stage1/diagnostics
import cheng/stage1/ownership

@importc("getenv")
fn cgenGetenv(name: cstring): str

var cgenModsymOutOverride: str = ""

fn cgenSetModsymOut(path: str) =
    cgenModsymOutOverride = path

fn cgenEnvFlag(name: str): bool =
    let v: str = cgenGetenv name
    if v == nil:
        return false
    let s: str = v
    if s ==  "1":
        return true
    if s ==  "0":
        return false
    if len s <= 0:
        return false
    let c0: char = charAt(s, 0)
    if c0 ==  't' || c0 ==  'T' || c0 ==  'y' || c0 ==  'Y':
        return true
    return false

fn cgenLegacyCallsEnabled(): bool =
    if cgenEnvFlag "CHENG_LEGACY_CALLS":
        return true
    return cgenEnvFlag "CHENG_STAGE1_LEGACY_CALLS"

fn cgenProfileEnabled(): bool =
    if cgenEnvFlag "CHENG_STAGE1_PROFILE":
        return true
    return cgenEnvFlag "CHENG_STAGE1_CGEN_PROFILE"

fn cgenAutoTypeEnabled(): bool =
    if cgenEnvFlag "CHENG_C_AUTO_TYPE":
        return true
    return cgenEnvFlag "CHENG_STAGE1_C_AUTO_TYPE"

fn cgenMmOff(): bool =
    let mm: str = cgenGetenv "CHENG_MM"
    if mm == nil || len mm == 0:
        return false
    if mm == "off" || mm == "none" || mm == "0":
        return true
    return false

fn cgenOrcEnabled(): bool =
    return !cgenMmOff()

fn cgenStrNeedsRetain(expr: Node): bool =
    if expr == nil || expr.kind == nkEmpty:
        return false
    ownershipClassifyExpr(expr)
    return ownershipMustRetainFlag(expr)

var cgenScopeLocalStarts: seq[int32] = newSeqWithCap[int32](0, 16)
var cgenScopeLocalNames: seq[str] = newSeqWithCap[str](0, 256)
var cgenScopeDeferStarts: seq[int32] = newSeqWithCap[int32](0, 16)
var cgenScopeDeferBodies: seq[Node] = newSeqWithCap[Node](0, 64)
var cgenParamNames: seq[str] = newSeqWithCap[str](0, 32)

fn cgenParamReset() =
    cgenParamNames.len = 0

fn cgenParamAdd(name: str) =
    if name == nil || len name == 0:
        return
    addPtr[str](&cgenParamNames, name)

fn cgenIsParam(name: str): bool =
    if name == nil || len name == 0:
        return false
    var i: int32 = 0
    while i < cgenParamNames.len:
        if get[str](cgenParamNames, i) == name:
            return true
        i = i + 1
    return false

fn cgenScopeReset() =
    cgenScopeLocalStarts.len = 0
    cgenScopeLocalNames.len = 0
    cgenScopeDeferStarts.len = 0
    cgenScopeDeferBodies.len = 0

fn cgenScopePush() =
    addPtr[int32](&cgenScopeLocalStarts, cgenScopeLocalNames.len)
    addPtr[int32](&cgenScopeDeferStarts, cgenScopeDeferBodies.len)

fn cgenScopePopWithoutEmit() =
    if cgenScopeLocalStarts.len <= 0 || cgenScopeDeferStarts.len <= 0:
        return
    let localStart: int32 = get[int32](cgenScopeLocalStarts, cgenScopeLocalStarts.len - 1)
    let deferStart: int32 = get[int32](cgenScopeDeferStarts, cgenScopeDeferStarts.len - 1)
    if localStart >= 0 && localStart <= cgenScopeLocalNames.len:
        cgenScopeLocalNames.len = localStart
    if deferStart >= 0 && deferStart <= cgenScopeDeferBodies.len:
        cgenScopeDeferBodies.len = deferStart
    cgenScopeLocalStarts.len = cgenScopeLocalStarts.len - 1
    cgenScopeDeferStarts.len = cgenScopeDeferStarts.len - 1

fn cgenScopeAddDefer(body: Node) =
    if body == nil:
        return
    if cgenScopeDeferStarts.len <= 0:
        return
    addPtr[Node](&cgenScopeDeferBodies, body)

fn cgenScopeTrackLocal(name: str, ty: Node) =
    if !inFn || !cgenOrcEnabled():
        return
    if cgenScopeLocalStarts.len <= 0:
        return
    if name == nil || len name == 0 || name == "_":
        return
    if cgenIsParam name:
        return
    if !cgenIsStringTypeNode(ty):
        return
    let localStart: int32 = get[int32](cgenScopeLocalStarts, cgenScopeLocalStarts.len - 1)
    var i: int32 = localStart
    while i < cgenScopeLocalNames.len:
        if get[str](cgenScopeLocalNames, i) == name:
            return
        i = i + 1
    addPtr[str](&cgenScopeLocalNames, name)

fn cgen_zeroPos(): SourcePos =
    var pos: SourcePos
    return pos

type
    ByteBuffer =
        len: int32
        cap: int32
        data: void*

fn initByteBuffer(cap: int32): ByteBuffer =
    var b: ByteBuffer
    b.len = 0
    b.cap = cap
    if cap > 0:
        b.data = alloc cap
    else:
        b.data = nil
    return b

fn ensureCap(b: ByteBuffer*, extra: int32) =
    if b == nil:
        return
    var need: int32 = b->len + extra + 1
    if need <= b->cap:
        return
    var newCap: int32 = b->cap * 2
    if newCap < 256:
        newCap = 256
    while newCap < need:
        newCap = newCap * 2
    b->data = realloc(b->data, newCap)
    b->cap = newCap

fn bufAddByte(b: ByteBuffer*, c: int8) =
    ensureCap(b, 1)
    var p: void* = ptr_add(b->data, b->len)
    *int8*(p) = c
    b->len = b->len + 1

fn bufAddChar(b: ByteBuffer*, c: char) =
    bufAddByte(b, int8(c))

fn bufAddStr(b: ByteBuffer*, s: str) =
    let n: int32 = len s
    if n <= 0:
        return
    ensureCap(b, n)
    var dst: void* = ptr_add(b->data, b->len)
    copyMem(dst, s, n)
    b->len = b->len + n

fn toString(b: ByteBuffer*): str =
    if b == nil:
        return ""
    ensureCap(b, 0)
    var p: void* = ptr_add(b->data, b->len)
    *int8*(p) = 0
    return str(b->data)

fn int64ToStr(x: int64): str =
    if x == 0:
        return "0"
    var v: int64 = x
    var neg: bool = false
    if v < 0:
        neg = true
        v = 0 - v
    var digits: int32 = 0
    var temp: int64 = v
    while temp > 0:
        digits = digits + 1
        temp = temp / 10
    var size: int32 = digits
    if neg:
        size = size + 1
    let p: void* = alloc(size + 1)
    setMem(ptr_add(p, size), 0, 1)
    var idx: int32 = size - 1
    while v > 0:
        let digit64: int64 = v % 10
        let digit: int32 = int32(digit64)
        *int8*(ptr_add(p, idx)) = int8(48) + digit
        v = v / 10
        idx = idx - 1
    if neg:
        *int8*(p) = int8('-')
    return str(p)

fn hexDigitUpper(x: int32): char =
    if x < 10:
        return chr 48 + x
    return chr 55 + x

type
    CWriter =
        buf: ByteBuffer
        indent: int32
        indentStr: str
        lastWasNewline: bool
        file: File
        flushThreshold: int32

fn initCWriterWithCap(cap: int32): CWriter =
    var w: CWriter
    w.buf = initByteBuffer cap
    w.indent = 0
    w.indentStr = ""
    w.lastWasNewline = true
    w.file = nil
    w.flushThreshold = 0
    return w

fn initCWriter(): CWriter =
    return initCWriterWithCap(65536)

fn cwWrite(w: CWriter*, s: str) =
    if w == nil:
        return
    var startNs: int64 = 0
    if cgenProfOn:
        startNs = cheng_monotime_ns()
    bufAddStr(&w->buf, s)
    if len s > 0:
        w->lastWasNewline =(charAt(s, len s - 1) == '\n')
    cwMaybeFlush w
    if cgenProfOn:
        cgenProfWriteNs = cgenProfWriteNs + (cheng_monotime_ns() - startNs)
        cgenProfWriteCalls = cgenProfWriteCalls + 1
        cgenProfWriteBytes = cgenProfWriteBytes + int64(len s)

fn cwWriteChar(w: CWriter*, c: char) =
    if w == nil:
        return
    var startNs: int64 = 0
    if cgenProfOn:
        startNs = cheng_monotime_ns()
    bufAddChar(&w->buf, c)
    w->lastWasNewline =(c == '\n')
    cwMaybeFlush w
    if cgenProfOn:
        cgenProfWriteCharNs = cgenProfWriteCharNs + (cheng_monotime_ns() - startNs)
        cgenProfWriteCharCalls = cgenProfWriteCharCalls + 1

fn cwIndent(w: CWriter*) =
    if w == nil:
        return
    if ! w->lastWasNewline:
        return
    var startNs: int64 = 0
    if cgenProfOn:
        startNs = cheng_monotime_ns()
    if len w->indentStr > 0:
        bufAddStr(&w->buf, w->indentStr)
    w->lastWasNewline = false
    cwMaybeFlush w
    if cgenProfOn:
        cgenProfIndentNs = cgenProfIndentNs + (cheng_monotime_ns() - startNs)
        cgenProfIndentCalls = cgenProfIndentCalls + 1

fn cwAttachFile(w: CWriter*, f: File, flushThreshold: int32) =
    if w == nil:
        return
    w->file = f
    w->flushThreshold = flushThreshold

fn cwFlush(w: CWriter*) =
    if w == nil:
        return
    if w->file == nil:
        return
    if w->buf.len <= 0:
        return
    var startNs: int64 = 0
    if cgenProfOn:
        startNs = cheng_monotime_ns()
    let payload: str = toString(&w->buf)
    write(w->file, payload)
    w->buf.len = 0
    if cgenProfOn:
        cgenProfFlushNs = cgenProfFlushNs + (cheng_monotime_ns() - startNs)
        cgenProfFlushCalls = cgenProfFlushCalls + 1

fn cwMaybeFlush(w: CWriter*) =
    if w == nil:
        return
    if w->file == nil:
        return
    if w->flushThreshold <= 0:
        return
    if w->buf.len >= w->flushThreshold:
        cwFlush w

fn cwNewline(w: CWriter*) =
    if w == nil:
        return
    cwWriteChar(w, '\n')

fn cwWriteLine(w: CWriter*, s: str) =
    cwIndent w
    cwWrite(w, s)
    cwNewline w

fn cwIndentPush(w: CWriter*) =
    if w == nil:
        return
    w->indent = w->indent + 1
    w->indentStr = w->indentStr + "  "

fn cwIndentPop(w: CWriter*) =
    if w == nil:
        return
    if w->indent > 0:
        w->indent = w->indent - 1
        let n: int32 = len w->indentStr
        if n >= 2:
            w->indentStr = sliceRange(w->indentStr, 0, n - 2)
        else:
            w->indentStr = ""

fn finishC(w: CWriter*): str =
    if w == nil:
        return ""
    if w->file != nil:
        cwFlush w
        return ""
    return toString(&w->buf)

