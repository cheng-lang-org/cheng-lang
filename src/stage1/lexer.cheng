# lexer.cheng
# Stage1 lexer (ported from stage0/lexer).
import std/strings
import std/seqs
import std/rawmem_support

fn lex_memRelease(p: void*) =
    memRelease(p)
fn lex_memRetain(p: void*) =
    memRetain(p)
fn lex_memScopeEscape(p: void*) =
    memScopeEscape(p)
import stage1/token
import stage1/diagnostics

type
    LexResult =
        tokens: Token[]
        diagnostics: Diagnostic[]

fn lexAppendPtr(seqInst: var ptr[], val: ptr) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        cheng__seqGrowToRaw(&seqInst.buffer, &seqInst.cap, needLen, int32(sizeof ptr))
    seqInst.len = needLen
    seqInst[idx] = val

fn lexAppendDiagnostic(seqInst: var Diagnostic[], val: Diagnostic) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        cheng__seqGrowToRaw(&seqInst.buffer, &seqInst.cap, needLen, int32(sizeof Diagnostic))
    seqInst.len = needLen
    seqInst[idx] = val

fn lexAppendStr(seqInst: var str[], val: str) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        cheng__seqGrowToRaw(&seqInst.buffer, &seqInst.cap, needLen, int32(sizeof str))
    seqInst.len = needLen
    seqInst[idx] = val

fn lexAppendI32(seqInst: var int32[], val: int32) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        cheng__seqGrowToRaw(&seqInst.buffer, &seqInst.cap, needLen, int32(sizeof int32))
    seqInst.len = needLen
    seqInst[idx] = val

fn lexAppendToken(seqInst: var Token[], val: Token) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        cheng__seqGrowToRaw(&seqInst.buffer, &seqInst.cap, needLen, int32(sizeof Token))
    seqInst.len = needLen
    let off64: int64 = int64(idx) * sizeof Token
    let dst: Token* = Token*(rawmemPtrAdd(seqInst.buffer, int32(off64)))
    if dst == nil:
        return
    dst->kind = val.kind
    dst->lexeme = val.lexeme
    dst->strPrefix = val.strPrefix
    dst->line = val.line
    dst->col = val.col

fn lexAppendNewToken(seqInst: var Token[], kind: TokenKind, lexeme: str, line: int32, col: int32, strPrefix: char) =
    var tok: Token
    tokenInit(&tok, kind, lexeme, line, col, strPrefix)
    lexAppendToken(seqInst, tok)

fn lexAppendNewToken(seqInst: var Token[], kind: TokenKind, lexeme: str, line: int32, col: int32) =
    var tok: Token
    tokenInit(&tok, kind, lexeme, line, col)
    lexAppendToken(seqInst, tok)

var
    lexStringPool: ptr[]
    lexStringPoolReady: bool

fn initLexStringPool() =
    if lexStringPoolReady:
        return
    freeSeq[ptr](lexStringPool)
    lexStringPool.buffer = nil
    lexStringPool.len = 0
    lexStringPool.cap = 0
    lexStringPoolReady = true

fn trackLexString(p: void*) =
    if astRefIsNil(p):
        return
    initLexStringPool()
    lex_memScopeEscape p
    let pooled: ptr = ptr(p)
    lexAppendPtr(lexStringPool, pooled)

fn trackLexStringStr(s: str) =
    trackLexString(ptr(s))

fn releaseLexStrings() =
    if ! lexStringPoolReady:
        return
    for i in 0..<lexStringPool.len:
        let p: void* = lexStringPool[i]
        if astRefNonNil(p):
            lex_memRelease p
    freeSeq[ptr](lexStringPool)
    lexStringPoolReady = false

type
    ScanResult =
        tok: Token
        nextPos: int32

fn addLexDiag(diags: var Diagnostic[], filename: str, line: int32, col: int32, msg: str) =
    var d: Diagnostic
    d.severity = svError
    d.filename = filename
    d.line = line
    d.col = col
    d.message = msg
    lexAppendDiagnostic(diags, d)

fn isDigit(c: char): bool =
    if c < '0':
        return false
    if c > '9':
        return false
    return true

fn isAlphaAscii(c: char): bool =
    if c >= 'a':
        if c <= 'z':
            return true
    if c >= 'A':
        if c <= 'Z':
            return true
    return false

fn isAlphaNum(c: char): bool =
    if isAlphaAscii c:
        return true
    if isDigit c:
        return true
    return false

fn isHexDigit(c: char): bool =
    if isDigit c:
        return true
    if c >= 'a':
        if c <= 'f':
            return true
    if c >= 'A':
        if c <= 'F':
            return true
    return false

fn sliceRangeInto(s: str, start: int32, stop: int32, out: str* = nil): bool =
    if len(s) == 0:
        if out != nil:
            *out = ""
        return true
    var a: int32 = start
    var b: int32 = stop
    if a < 0:
        a = 0
    let n: int32 = len s
    if b >= n:
        b = n - 1
    if b < a:
        if out != nil:
            *out = ""
        return true
    let count: int32 = b - a + 1
    let p: void* = alloc(count + 1)
    if p == nil:
        if out != nil:
            *out = ""
        return true
    let outText: str = str(p)
    for i in 0..<count:
        outText[i] = s[a + i]
    outText[count] = char(0)
    if out != nil:
        *out = outText
    return true

fn sliceRange(s: str, start: int32, stop: int32): str =
    var out: str = ""
    let _ok: bool = sliceRangeInto(s, start, stop, &out)
    return out

fn lexOwnedRangeCopy(s: str, start: int32, count: int32): str =
    if count <= 0:
        return ""
    return sliceRange(s, start, start + count - 1)

fn sliceRangeLexInto(s: str, start: int32, stop: int32, out: str* = nil): bool =
    var outValue: str = ""
    let _ok: bool = sliceRangeInto(s, start, stop, &outValue)
    let outStr: str = outValue
    if len(outStr) > 0:
        trackLexStringStr(outStr)
    if out != nil:
        *out = outStr
    return true

fn sliceRangeLex(s: str, start: int32, stop: int32): str =
    var out: str = ""
    let _ok: bool = sliceRangeLexInto(s, start, stop, &out)
    return out

fn trimTrailingCRInto(s: str, out: str* = nil): bool =
    let n: int32 = len s
    if n <= 0:
        if out != nil:
            *out = s
        return true
    if s[n - 1] == '\r':
        var trimmed: str = ""
        let _sliceOk: bool = sliceRangeLexInto(s, 0, n - 2, &trimmed)
        if out != nil:
            *out = trimmed
        return true
    if out != nil:
        *out = s
    return true

fn trimTrailingCR(s: str): str =
    var out: str = ""
    let _ok: bool = trimTrailingCRInto(s, &out)
    return out

fn splitLinesInto(text: str, out: str[]* = nil): bool =
    var lines: str[] = []
    if len(text) == 0:
        if out != nil:
            *out = lines
        return true
    let n: int32 = len text
    if n == 0:
        if out != nil:
            *out = lines
        return true
    var start: int32 = 0
    for i in 0..<n:
        let c: char = text[i]
        if c == '\n':
            var lineRaw: str = ""
            var lineTrimmed: str = ""
            let _sliceOk: bool = sliceRangeLexInto(text, start, i - 1, &lineRaw)
            let _trimOk: bool = trimTrailingCRInto(lineRaw, &lineTrimmed)
            lexAppendStr(lines, lineTrimmed)
            start = i + 1
    if start <= n - 1:
        var lineRaw: str = ""
        var lineTrimmed: str = ""
        let _sliceOk: bool = sliceRangeLexInto(text, start, n - 1, &lineRaw)
        let _trimOk: bool = trimTrailingCRInto(lineRaw, &lineTrimmed)
        lexAppendStr(lines, lineTrimmed)
    elif start == n:
        lexAppendStr(lines, "")
    if out != nil:
        *out = lines
    return true

fn splitLines(text: str): str[] =
    var out: str[] = []
    let _ok: bool = splitLinesInto(text, &out)
    return out

fn isKeyword(s: str): bool =
    let n: int32 = len s
    if n == 2:
        let c0: char = s[0]
        let c1: char = s[1]
        if c0 == 'f' && c1 == 'n': return true
        if c0 == 'i' && c1 == 'f': return true
        if c0 == 'a' && c1 == 's': return true
        if c0 == 'i' && c1 == 'n': return true
        if c0 == 'o' && c1 == 'f': return true
        if c0 == 'i' && c1 == 's': return true
        return false
    if n == 3:
        let c0: char = s[0]
        let c1: char = s[1]
        let c2: char = s[2]
        if c0 == 'l' && c1 == 'e' && c2 == 't': return true
        if c0 == 'v' && c1 == 'a' && c2 == 'r': return true
        if c0 == 'm' && c1 == 'u' && c2 == 't': return true
        if c0 == 'f' && c1 == 'o' && c2 == 'r': return true
        if c0 == 'n' && c1 == 'i' && c2 == 'l': return true
        if c0 == 'r' && c1 == 'e' && c2 == 'f': return true
        if c0 == 's' && c1 == 'e' && c2 == 't': return true
        if c0 == 's' && c1 == 't' && c2 == 'r': return true
        return false
    if n == 4:
        let c0: char = s[0]
        let c1: char = s[1]
        let c2: char = s[2]
        let c3: char = s[3]
        if c0 == 't' && c1 == 'y' && c2 == 'p' && c3 == 'e': return true
        if c0 == 'e' && c1 == 'l' && c2 == 'i' && c3 == 'f': return true
        if c0 == 'e' && c1 == 'l' && c2 == 's' && c3 == 'e': return true
        if c0 == 'w' && c1 == 'h' && c2 == 'e' && c3 == 'n': return true
        if c0 == 'c' && c1 == 'a' && c2 == 's' && c3 == 'e': return true
        if c0 == 't' && c1 == 'r' && c2 == 'u' && c3 == 'e': return true
        if c0 == 'e' && c1 == 'n' && c2 == 'u' && c3 == 'm': return true
        return false
    if n == 5:
        let c0: char = s[0]
        let c1: char = s[1]
        let c2: char = s[2]
        let c3: char = s[3]
        let c4: char = s[4]
        if c0 == 'c' && c1 == 'o' && c2 == 'n' && c3 == 's' && c4 == 't': return true
        if c0 == 't' && c1 == 'r' && c2 == 'a' && c3 == 'i' && c4 == 't': return true
        if c0 == 'm' && c1 == 'a' && c2 == 'c' && c3 == 'r' && c4 == 'o': return true
        if c0 == 'a' && c1 == 's' && c2 == 'y' && c3 == 'n' && c4 == 'c': return true
        if c0 == 'w' && c1 == 'h' && c2 == 'i' && c3 == 'l' && c4 == 'e': return true
        if c0 == 'b' && c1 == 'r' && c2 == 'e' && c3 == 'a' && c4 == 'k': return true
        if c0 == 'y' && c1 == 'i' && c2 == 'e' && c3 == 'l' && c4 == 'd': return true
        if c0 == 'd' && c1 == 'e' && c2 == 'f' && c3 == 'e' && c4 == 'r': return true
        if c0 == 'a' && c1 == 'w' && c2 == 'a' && c3 == 'i' && c4 == 't': return true
        if c0 == 'b' && c1 == 'l' && c2 == 'o' && c3 == 'c' && c4 == 'k': return true
        if c0 == 'w' && c1 == 'h' && c2 == 'e' && c3 == 'r' && c4 == 'e': return true
        if c0 == 'f' && c1 == 'a' && c2 == 'l' && c3 == 's' && c4 == 'e': return true
        if c0 == 't' && c1 == 'u' && c2 == 'p' && c3 == 'l' && c4 == 'e': return true
        if c0 == 'n' && c1 == 'o' && c2 == 't' && c3 == 'i' && c4 == 'n': return true
        return false
    if n == 6:
        let c0: char = s[0]
        let c1: char = s[1]
        let c2: char = s[2]
        let c3: char = s[3]
        let c4: char = s[4]
        let c5: char = s[5]
        if c0 == 'm' && c1 == 'o' && c2 == 'd' && c3 == 'u' && c4 == 'l' && c5 == 'e': return true
        if c0 == 'r' && c1 == 'e' && c2 == 't' && c3 == 'u' && c4 == 'r' && c5 == 'n': return true
        if c0 == 'i' && c1 == 'm' && c2 == 'p' && c3 == 'o' && c4 == 'r' && c5 == 't': return true
        return false
    if n == 7:
        let c0: char = s[0]
        let c1: char = s[1]
        let c2: char = s[2]
        let c3: char = s[3]
        let c4: char = s[4]
        let c5: char = s[5]
        let c6: char = s[6]
        if c0 == 'c' && c1 == 'o' && c2 == 'n' && c3 == 'c' && c4 == 'e' && c5 == 'p' && c6 == 't': return true
        return false
    if n == 8:
        let c0: char = s[0]
        let c1: char = s[1]
        let c2: char = s[2]
        let c3: char = s[3]
        let c4: char = s[4]
        let c5: char = s[5]
        let c6: char = s[6]
        let c7: char = s[7]
        if c0 == 'i' && c1 == 't' && c2 == 'e' && c3 == 'r' && c4 == 'a' && c5 == 't' && c6 == 'o' && c7 == 'r': return true
        if c0 == 't' && c1 == 'e' && c2 == 'm' && c3 == 'p' && c4 == 'l' && c5 == 'a' && c6 == 't' && c7 == 'e': return true
        if c0 == 'c' && c1 == 'o' && c2 == 'n' && c3 == 't' && c4 == 'i' && c5 == 'n' && c6 == 'u' && c7 == 'e': return true
        return false
    return false

fn isKeywordRange(text: str, start: int32, count: int32): bool =
    if count == 2:
        let c0: char = text[start]
        let c1: char = text[start + 1]
        if c0 == 'f' && c1 == 'n': return true
        if c0 == 'i' && c1 == 'f': return true
        if c0 == 'a' && c1 == 's': return true
        if c0 == 'i' && c1 == 'n': return true
        if c0 == 'o' && c1 == 'f': return true
        if c0 == 'i' && c1 == 's': return true
        return false
    if count == 3:
        let c0: char = text[start]
        let c1: char = text[start + 1]
        let c2: char = text[start + 2]
        if c0 == 'l' && c1 == 'e' && c2 == 't': return true
        if c0 == 'v' && c1 == 'a' && c2 == 'r': return true
        if c0 == 'm' && c1 == 'u' && c2 == 't': return true
        if c0 == 'f' && c1 == 'o' && c2 == 'r': return true
        if c0 == 'n' && c1 == 'i' && c2 == 'l': return true
        if c0 == 'r' && c1 == 'e' && c2 == 'f': return true
        if c0 == 's' && c1 == 'e' && c2 == 't': return true
        if c0 == 's' && c1 == 't' && c2 == 'r': return true
        return false
    if count == 4:
        let c0: char = text[start]
        let c1: char = text[start + 1]
        let c2: char = text[start + 2]
        let c3: char = text[start + 3]
        if c0 == 't' && c1 == 'y' && c2 == 'p' && c3 == 'e': return true
        if c0 == 'e' && c1 == 'l' && c2 == 'i' && c3 == 'f': return true
        if c0 == 'e' && c1 == 'l' && c2 == 's' && c3 == 'e': return true
        if c0 == 'w' && c1 == 'h' && c2 == 'e' && c3 == 'n': return true
        if c0 == 'c' && c1 == 'a' && c2 == 's' && c3 == 'e': return true
        if c0 == 't' && c1 == 'r' && c2 == 'u' && c3 == 'e': return true
        if c0 == 'e' && c1 == 'n' && c2 == 'u' && c3 == 'm': return true
        return false
    if count == 5:
        let c0: char = text[start]
        let c1: char = text[start + 1]
        let c2: char = text[start + 2]
        let c3: char = text[start + 3]
        let c4: char = text[start + 4]
        if c0 == 'c' && c1 == 'o' && c2 == 'n' && c3 == 's' && c4 == 't': return true
        if c0 == 't' && c1 == 'r' && c2 == 'a' && c3 == 'i' && c4 == 't': return true
        if c0 == 'm' && c1 == 'a' && c2 == 'c' && c3 == 'r' && c4 == 'o': return true
        if c0 == 'a' && c1 == 's' && c2 == 'y' && c3 == 'n' && c4 == 'c': return true
        if c0 == 'w' && c1 == 'h' && c2 == 'i' && c3 == 'l' && c4 == 'e': return true
        if c0 == 'b' && c1 == 'r' && c2 == 'e' && c3 == 'a' && c4 == 'k': return true
        if c0 == 'y' && c1 == 'i' && c2 == 'e' && c3 == 'l' && c4 == 'd': return true
        if c0 == 'd' && c1 == 'e' && c2 == 'f' && c3 == 'e' && c4 == 'r': return true
        if c0 == 'a' && c1 == 'w' && c2 == 'a' && c3 == 'i' && c4 == 't': return true
        if c0 == 'b' && c1 == 'l' && c2 == 'o' && c3 == 'c' && c4 == 'k': return true
        if c0 == 'w' && c1 == 'h' && c2 == 'e' && c3 == 'r' && c4 == 'e': return true
        if c0 == 'f' && c1 == 'a' && c2 == 'l' && c3 == 's' && c4 == 'e': return true
        if c0 == 't' && c1 == 'u' && c2 == 'p' && c3 == 'l' && c4 == 'e': return true
        if c0 == 'n' && c1 == 'o' && c2 == 't' && c3 == 'i' && c4 == 'n': return true
        return false
    if count == 6:
        let c0: char = text[start]
        let c1: char = text[start + 1]
        let c2: char = text[start + 2]
        let c3: char = text[start + 3]
        let c4: char = text[start + 4]
        let c5: char = text[start + 5]
        if c0 == 'm' && c1 == 'o' && c2 == 'd' && c3 == 'u' && c4 == 'l' && c5 == 'e': return true
        if c0 == 'r' && c1 == 'e' && c2 == 't' && c3 == 'u' && c4 == 'r' && c5 == 'n': return true
        if c0 == 'i' && c1 == 'm' && c2 == 'p' && c3 == 'o' && c4 == 'r' && c5 == 't': return true
        return false
    if count == 7:
        let c0: char = text[start]
        let c1: char = text[start + 1]
        let c2: char = text[start + 2]
        let c3: char = text[start + 3]
        let c4: char = text[start + 4]
        let c5: char = text[start + 5]
        let c6: char = text[start + 6]
        if c0 == 'c' && c1 == 'o' && c2 == 'n' && c3 == 'c' && c4 == 'e' && c5 == 'p' && c6 == 't': return true
        return false
    if count == 8:
        let c0: char = text[start]
        let c1: char = text[start + 1]
        let c2: char = text[start + 2]
        let c3: char = text[start + 3]
        let c4: char = text[start + 4]
        let c5: char = text[start + 5]
        let c6: char = text[start + 6]
        let c7: char = text[start + 7]
        if c0 == 'i' && c1 == 't' && c2 == 'e' && c3 == 'r' && c4 == 'a' && c5 == 't' && c6 == 'o' && c7 == 'r':
            return true
        if c0 == 't' && c1 == 'e' && c2 == 'm' && c3 == 'p' && c4 == 'l' && c5 == 'a' && c6 == 't' && c7 == 'e':
            return true
        if c0 == 'c' && c1 == 'o' && c2 == 'n' && c3 == 't' && c4 == 'i' && c5 == 'n' && c6 == 'u' && c7 == 'e':
            return true
        return false
    return false

fn isBlockStartKeyword(s: str): bool =
    if (s ==  "if"):
        return true
    if (s ==  "elif"):
        return true
    if (s ==  "else"):
        return true
    if (s ==  "for"):
        return true
    if (s ==  "while"):
        return true
    if (s ==  "case"):
        return true
    if (s ==  "of"):
        return true
    if (s ==  "when"):
        return true
    if (s ==  "block"):
        return true
    return false

fn isBlockContinueKeyword(s: str): bool =
    if (s ==  "elif"):
        return true
    if (s ==  "else"):
        return true
    if (s ==  "of"):
        return true
    return false

fn isBlockExprKeyword(s: str): bool =
    if (s ==  "if"):
        return true
    if (s ==  "fn"):
        return true
    if (s ==  "iterator"):
        return true
    return false

fn splitLineSpansInto(text: str, startsOut: int32[]* = nil, stopsOut: int32[]* = nil): bool =
    var starts: int32[] = []
    var stops: int32[] = []
    if len(text) == 0:
        if startsOut != nil:
            *startsOut = starts
        if stopsOut != nil:
            *stopsOut = stops
        return true
    let n: int32 = len text
    var start: int32 = 0
    for i in 0..<n:
        let c: char = text[i]
        if c == '\n':
            var stop: int32 = i - 1
            if stop >= start && text[stop] == '\r':
                stop = stop - 1
            lexAppendI32(starts, start)
            lexAppendI32(stops, stop)
            start = i + 1
    if start <= n - 1:
        var stop: int32 = n - 1
        if stop >= start && text[stop] == '\r':
            stop = stop - 1
        lexAppendI32(starts, start)
        lexAppendI32(stops, stop)
    elif start == n:
        lexAppendI32(starts, start)
        lexAppendI32(stops, start - 1)
    if startsOut != nil:
        *startsOut = starts
    if stopsOut != nil:
        *stopsOut = stops
    return true

fn lineTextAtInto(text: str, starts: int32[], stops: int32[], idx: int32, out: str* = nil): bool =
    if idx < 0 || idx >= starts.len || idx >= stops.len:
        if out != nil:
            *out = ""
        return true
    let start: int32 = starts[idx]
    let stop: int32 = stops[idx]
    if stop < start:
        if out != nil:
            *out = ""
        return true
    var outText: str = ""
    let _ok: bool = sliceRangeInto(text, start, stop, &outText)
    if out != nil:
        *out = outText
    return true

fn lineTextAt(text: str, starts: int32[], stops: int32[], idx: int32): str =
    var out: str = ""
    let _ok: bool = lineTextAtInto(text, starts, stops, idx, &out)
    return out

fn lineSpanLen(starts: int32[], stops: int32[], idx: int32): int32 =
    if idx < 0 || idx >= starts.len || idx >= stops.len:
        return 0
    if stops[idx] < starts[idx]:
        return 0
    return (stops[idx] - starts[idx]) + 1

fn nextLineIsIndented(text: str, starts: int32[], stops: int32[], startIdx: int32, baseIndent: int32): bool =
    for idx in startIdx..<starts.len:
        let lineStartAbs: int32 = starts[idx]
        let lineLen: int32 = lineSpanLen(starts, stops, idx)
        var pos: int32 = 0
        for __for_guard_pos in 0..<lineLen:
            if !(pos < lineLen):
                break
            if text[lineStartAbs + pos] != ' ':
                break
            pos = pos + 1
        if pos >= lineLen:
            continue
        if text[lineStartAbs + pos] == '#':
            continue
        return pos > baseIndent
    return false

fn nextLineStartsBlockExpr(text: str, starts: int32[], stops: int32[], startIdx: int32): bool =
    for idx in startIdx..<starts.len:
        let lineStartAbs: int32 = starts[idx]
        let lineLen: int32 = lineSpanLen(starts, stops, idx)
        var pos: int32 = 0
        for __for_guard_pos in 0..<lineLen:
            if !(pos < lineLen):
                break
            if text[lineStartAbs + pos] != ' ':
                break
            pos = pos + 1
        if pos >= lineLen:
            continue
        if text[lineStartAbs + pos] == '#':
            continue
        let ch: char = text[lineStartAbs + pos]
        if ! (isAlphaAscii ch || ch == '_'):
            return false
        var j: int32 = pos
        for __for_guard_j in 0..<lineLen:
            if !(j < lineLen):
                break
            let cj: char = text[lineStartAbs + j]
            if isAlphaNum cj || cj == '_':
                j = j + 1
            else:
                break
        let word: str = sliceRange(text, lineStartAbs + pos, lineStartAbs + j - 1)
        return isBlockExprKeyword word
    return false

fn lineStartsContinueKeyword(text: str, lineStartAbs: int32, lineLen: int32): bool =
    var pos: int32 = 0
    for __for_guard_pos in 0..<lineLen:
        if !(pos < lineLen):
            break
        if text[lineStartAbs + pos] != ' ':
            break
        pos = pos + 1
    if pos >= lineLen:
        return false
    if text[lineStartAbs + pos] == '#':
        return false
    let ch: char = text[lineStartAbs + pos]
    if ! (isAlphaAscii ch || ch == '_'):
        return false
    var j: int32 = pos
    for __for_guard_j in 0..<lineLen:
        if !(j < lineLen):
            break
        let cj: char = text[lineStartAbs + j]
        if isAlphaNum cj || cj == '_':
            j = j + 1
        else:
            break
    let word: str = sliceRange(text, lineStartAbs + pos, lineStartAbs + j - 1)
    return isBlockContinueKeyword word

fn lexNumberLineInto(content: str, lineStartAbs: int32, lineLen: int32, startPos: int32, line: int32, filename: str, diags: var Diagnostic[], out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    var i: int32 = startPos
    var lexeme: str = ""
    if i + 1 < lineLen:
        if content[lineStartAbs + i] == '0':
            let c1: char = content[lineStartAbs + i + 1]
            var isRadix: bool = false
            if c1 == 'x' || c1 == 'X' || c1 == 'b' || c1 == 'B' || c1 == 'o' || c1 == 'O':
                isRadix = true
            if isRadix:
                i = i + 2
                for __for_guard_i in 0..<lineLen:
                    if !(i < lineLen):
                        break
                    let c: char = content[lineStartAbs + i]
                    if isAlphaNum c || c == '_':
                        i = i + 1
                        continue
                    break
                scanRes.tok.kind = tkNumber
                tokenSetLexemeRange(&scanRes.tok, content, lineStartAbs + startPos, i - startPos)
                scanRes.tok.strPrefix = char(0)
                scanRes.tok.line = line
                scanRes.tok.col = startPos + 1
                scanRes.nextPos = i
                if out != nil:
                    *out = scanRes
                return true
    var hasDot: bool = false
    for __for_guard_i in 0..<lineLen:
        if !(i < lineLen):
            break
        let c: char = content[lineStartAbs + i]
        if isDigit c || c == '_':
            i = i + 1
            continue
        if c == '.':
            if hasDot:
                break
            var isRange: bool = false
            if i + 1 < lineLen && content[lineStartAbs + i + 1] == '.':
                isRange = true
            if isRange:
                break
            hasDot = true
            i = i + 1
            continue
        break
    scanRes.tok.kind = tkNumber
    tokenSetLexemeRange(&scanRes.tok, content, lineStartAbs + startPos, i - startPos)
    scanRes.tok.strPrefix = char(0)
    scanRes.tok.line = line
    scanRes.tok.col = startPos + 1
    scanRes.nextPos = i
    if out != nil:
        *out = scanRes
    return true

fn lexIdentLineInto(content: str, lineStartAbs: int32, lineLen: int32, startPos: int32, line: int32, out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    var i: int32 = startPos
    for __for_guard_i in 0..<lineLen:
        if !(i < lineLen):
            break
        let c: char = content[lineStartAbs + i]
        if isAlphaNum c || c == '_':
            i = i + 1
            continue
        break
    let count: int32 = i - startPos
    var kind: TokenKind = tkIdent
    if isKeywordRange(content, lineStartAbs + startPos, count):
        kind = tkKeyword
    scanRes.tok.kind = kind
    tokenSetLexemeRange(&scanRes.tok, content, lineStartAbs + startPos, count)
    scanRes.tok.strPrefix = char(0)
    scanRes.tok.line = line
    scanRes.tok.col = startPos + 1
    scanRes.nextPos = i
    if out != nil:
        *out = scanRes
    return true

fn lexCharLineInto(content: str, lineStartAbs: int32, lineLen: int32, startPos: int32, line: int32, filename: str, diags: var Diagnostic[], out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    var i: int32 = startPos + 1
    for __for_guard_i in 0..<lineLen:
        if !(i < lineLen):
            break
        if content[lineStartAbs + i] == chr 39:
            break
        let c: char = content[lineStartAbs + i]
        if c == chr 92 && i + 1 < lineLen:
            i = i + 2
            continue
        i = i + 1
    var lexeme: str = ""
    if i > startPos + 1:
        lexeme = sliceRange(content, lineStartAbs + startPos + 1, lineStartAbs + i - 1)
    if i >= lineLen:
        addLexDiag(diags, filename, line, startPos + 1, "Unterminated character literal")
        tokenInit(&scanRes.tok, tkChar, lexeme, line, startPos + 1)
        scanRes.nextPos = i
        if out != nil:
            *out = scanRes
        return true
    var okLen: bool = false
    if len(lexeme) == 1:
        okLen = true
    elif len(lexeme) == 2:
        if lexeme[0] == chr 92:
            okLen = true
    elif len(lexeme) == 4:
        if lexeme[0] == chr 92 && lexeme[1] == 'x':
            let a: char = lexeme[2]
            let b: char = lexeme[3]
            if isHexDigit(a) && isHexDigit(b):
                okLen = true
    if !okLen:
        addLexDiag(diags, filename, line, startPos + 1, "Character literal must contain exactly one character")
    trackLexStringStr(lexeme)
    tokenInit(&scanRes.tok, tkChar, lexeme, line, startPos + 1)
    scanRes.nextPos = i + 1
    if out != nil:
        *out = scanRes
    return true

fn lexStringLineInto(content: str, lineStartAbs: int32, lineLen: int32, startPos: int32, line: int32, filename: str, diags: var Diagnostic[], out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    var i: int32 = startPos
    var prefix: char = chr(0)
    if i + 1 < lineLen:
        let c0: char = content[lineStartAbs + i]
        let c1: char = content[lineStartAbs + i + 1]
        if c1 == '"':
            if c0 == 'r' || c0 == 'f':
                prefix = c0
                i = i + 1
    if i + 2 < lineLen:
        if content[lineStartAbs + i] == '"' && content[lineStartAbs + i + 1] == '"' && content[lineStartAbs + i + 2] == '"':
            let contentStart: int32 = i + 3
            i = i + 3
            for __for_guard_i in 0..<lineLen:
                if !(i + 2 < lineLen):
                    break
                if content[lineStartAbs + i] == '"' && content[lineStartAbs + i + 1] == '"' && content[lineStartAbs + i + 2] == '"':
                    break
                i = i + 1
            var lexeme: str = ""
            if i > contentStart:
                lexeme = sliceRange(content, lineStartAbs + contentStart, lineStartAbs + i - 1)
            if i + 2 >= lineLen:
                addLexDiag(diags, filename, line, startPos + 1, "Unterminated string literal")
                trackLexStringStr(lexeme)
                tokenInit(&scanRes.tok, tkString, lexeme, line, startPos + 1, prefix)
                scanRes.nextPos = lineLen
                if out != nil:
                    *out = scanRes
                return true
            trackLexStringStr(lexeme)
            tokenInit(&scanRes.tok, tkString, lexeme, line, startPos + 1, prefix)
            scanRes.nextPos = i + 3
            if out != nil:
                *out = scanRes
            return true
    if content[lineStartAbs + i] == '"':
        i = i + 1
    let contentStart2: int32 = i
    for __for_guard_i in 0..<lineLen:
        if !(i < lineLen):
            break
        if content[lineStartAbs + i] == '"':
            break
        let c: char = content[lineStartAbs + i]
        if c == chr 92 && i + 1 < lineLen:
            i = i + 2
            continue
        i = i + 1
    var lexeme: str = ""
    if i > contentStart2:
        lexeme = sliceRange(content, lineStartAbs + contentStart2, lineStartAbs + i - 1)
    if i >= lineLen:
        addLexDiag(diags, filename, line, startPos + 1, "Unterminated string literal")
        trackLexStringStr(lexeme)
        tokenInit(&scanRes.tok, tkString, lexeme, line, startPos + 1, prefix)
        scanRes.nextPos = i
        if out != nil:
            *out = scanRes
        return true
    trackLexStringStr(lexeme)
    tokenInit(&scanRes.tok, tkString, lexeme, line, startPos + 1, prefix)
    scanRes.nextPos = i + 1
    if out != nil:
        *out = scanRes
    return true

fn matchSymbolLineInto(content: str, lineStartAbs: int32, lineLen: int32, pos: int32, out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    var i: int32 = pos
    if i + 2 < lineLen:
        if content[lineStartAbs + i] == '.' && content[lineStartAbs + i + 1] == '.' && content[lineStartAbs + i + 2] == '<':
            tokenInit(&scanRes.tok, tkSymbol, "..<", 0, 0)
            scanRes.nextPos = i + 3
            if out != nil:
                *out = scanRes
            return true
    if i + 1 < lineLen:
        let c0: char = content[lineStartAbs + i]
        let c1: char = content[lineStartAbs + i + 1]
        if c0 == '=':
            if c1 == '>':
                tokenInit(&scanRes.tok, tkSymbol, "=>", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
            if c1 == '=':
                tokenInit(&scanRes.tok, tkSymbol, "==", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '-':
            if c1 == '>':
                tokenInit(&scanRes.tok, tkSymbol, "->", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
            if c1 == '-':
                tokenInit(&scanRes.tok, tkSymbol, "--", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '!':
            if c1 == '=':
                tokenInit(&scanRes.tok, tkSymbol, "!=", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '+':
            if c1 == '+':
                tokenInit(&scanRes.tok, tkSymbol, "++", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '&':
            if c1 == '&':
                tokenInit(&scanRes.tok, tkSymbol, "&&", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '|':
            if c1 == '|':
                tokenInit(&scanRes.tok, tkSymbol, "||", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '<':
            if c1 == '<':
                tokenInit(&scanRes.tok, tkSymbol, "<<", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
            if c1 == '=':
                tokenInit(&scanRes.tok, tkSymbol, "<=", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '>':
            if c1 == '>':
                tokenInit(&scanRes.tok, tkSymbol, ">>", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
            if c1 == '=':
                tokenInit(&scanRes.tok, tkSymbol, ">=", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '.':
            if c1 == '.':
                tokenInit(&scanRes.tok, tkSymbol, "..", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
    let c: char = content[lineStartAbs + i]
    if c == '(':
        tokenInit(&scanRes.tok, tkSymbol, "(", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ')':
        tokenInit(&scanRes.tok, tkSymbol, ")", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '[':
        tokenInit(&scanRes.tok, tkSymbol, "[", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ']':
        tokenInit(&scanRes.tok, tkSymbol, "]", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '{':
        tokenInit(&scanRes.tok, tkSymbol, "{", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '}':
        tokenInit(&scanRes.tok, tkSymbol, "}", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ',':
        tokenInit(&scanRes.tok, tkSymbol, ",", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ':':
        tokenInit(&scanRes.tok, tkSymbol, ":", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ';':
        tokenInit(&scanRes.tok, tkSymbol, ";", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '.':
        tokenInit(&scanRes.tok, tkSymbol, ".", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '=':
        tokenInit(&scanRes.tok, tkSymbol, "=", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '+':
        tokenInit(&scanRes.tok, tkSymbol, "+", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '-':
        tokenInit(&scanRes.tok, tkSymbol, "-", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '*':
        tokenInit(&scanRes.tok, tkSymbol, "*", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '/':
        tokenInit(&scanRes.tok, tkSymbol, "/", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '%':
        tokenInit(&scanRes.tok, tkSymbol, "%", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '<':
        tokenInit(&scanRes.tok, tkSymbol, "<", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '>':
        tokenInit(&scanRes.tok, tkSymbol, ">", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '&':
        tokenInit(&scanRes.tok, tkSymbol, "&", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '|':
        tokenInit(&scanRes.tok, tkSymbol, "|", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '^':
        tokenInit(&scanRes.tok, tkSymbol, "^", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '~':
        tokenInit(&scanRes.tok, tkSymbol, "~", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '!':
        tokenInit(&scanRes.tok, tkSymbol, "!", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '$':
        tokenInit(&scanRes.tok, tkSymbol, "$", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '?':
        tokenInit(&scanRes.tok, tkSymbol, "?", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '@':
        tokenInit(&scanRes.tok, tkSymbol, "@", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    tokenInit(&scanRes.tok, tkSymbol, "", 0, 0)
    scanRes.nextPos = i
    if out != nil:
        *out = scanRes
    return true

fn emitIndentTokens(tokens: var Token[], stack: var int32[], newIndent: int32, line: int32, filename: str, diags: var Diagnostic[]) =
    var current: int32 = 0
    if stack.len > 0:
        current = stack[stack.len - 1]
    if newIndent > current:
        lexAppendI32(stack, newIndent)
        lexAppendNewToken(tokens, tkIndent, "", line, 1)
    elif newIndent < current:
        while stack.len > 0:
            let top: int32 = stack[stack.len - 1]
            if top <= newIndent:
                break
            stack.len = stack.len - 1
            lexAppendNewToken(tokens, tkDedent, "", line, 1)
        if stack.len == 0:
            addLexDiag(diags, filename, line, 1, "Indentation level mismatch")
            lexAppendI32(stack, newIndent)
            lexAppendNewToken(tokens, tkIndent, "", line, 1)
        else:
            let top2: int32 = stack[stack.len - 1]
            if top2 != newIndent:
                addLexDiag(diags, filename, line, 1, "Indentation level mismatch")
                lexAppendI32(stack, newIndent)
                lexAppendNewToken(tokens, tkIndent, "", line, 1)

fn isContinuationToken(tok: Token): bool =
    if tok.kind == tkSymbol:
        if (tokenLexeme(tok) ==  "="):
            return true
        if (tokenLexeme(tok) ==  "+"):
            return true
        if (tokenLexeme(tok) ==  "++"):
            return true
        if (tokenLexeme(tok) ==  "-"):
            return true
        if (tokenLexeme(tok) ==  "--"):
            return true
        if (tokenLexeme(tok) ==  "/"):
            return true
        if (tokenLexeme(tok) ==  "%"):
            return true
        if (tokenLexeme(tok) ==  "&"):
            return true
        if (tokenLexeme(tok) ==  "|"):
            return true
        if (tokenLexeme(tok) ==  "^"):
            return true
        if (tokenLexeme(tok) ==  ","):
            return true
        if (tokenLexeme(tok) ==  "."):
            return true
        if (tokenLexeme(tok) ==  "->"):
            return true
        if (tokenLexeme(tok) ==  ".."):
            return true
        if (tokenLexeme(tok) ==  "..<"):
            return true
        if (tokenLexeme(tok) ==  "=="):
            return true
        if (tokenLexeme(tok) ==  "!="):
            return true
        if (tokenLexeme(tok) ==  "<"):
            return true
        if (tokenLexeme(tok) ==  ">"):
            return true
        if (tokenLexeme(tok) ==  "<="):
            return true
        if (tokenLexeme(tok) ==  ">="):
            return true
        if (tokenLexeme(tok) ==  "<<"):
            return true
        if (tokenLexeme(tok) ==  ">>"):
            return true
        if (tokenLexeme(tok) ==  "&&"):
            return true
        if (tokenLexeme(tok) ==  "||"):
            return true
        return false
    if tok.kind == tkKeyword:
        if (tokenLexeme(tok) ==  "in"):
            return true
        if (tokenLexeme(tok) ==  "notin"):
            return true
        if (tokenLexeme(tok) ==  "is"):
            return true
        return false
    return false

fn isDefKeyword(tok: Token): bool =
    if tok.kind != tkKeyword:
        return false
    if (tokenLexeme(tok) ==  "fn"):
        return true
    if (tokenLexeme(tok) ==  "iterator"):
        return true
    if (tokenLexeme(tok) ==  "macro"):
        return true
    if (tokenLexeme(tok) ==  "template"):
        return true
    if (tokenLexeme(tok) ==  "type"):
        return true
    if (tokenLexeme(tok) ==  "concept"):
        return true
    if (tokenLexeme(tok) ==  "trait"):
        return true
    return false

fn lexNumberInto(content: str, start: int32, line: int32, filename: str, diags: var Diagnostic[], out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    var i: int32 = start
    let n: int32 = len content
    var lexeme: str = ""
    if i + 1 < n:
        if content[i] == '0':
            let c1: char = content[i + 1]
            var isRadix: bool = false
            if c1 == 'x':
                isRadix = true
            elif c1 == 'X':
                isRadix = true
            elif c1 == 'b':
                isRadix = true
            elif c1 == 'B':
                isRadix = true
            elif c1 == 'o':
                isRadix = true
            elif c1 == 'O':
                isRadix = true
            if isRadix:
                i = i + 2
                for __for_guard_i in 0..<n:
                    if !(i < n):
                        break
                    let c: char = content[i]
                    if isAlphaNum c:
                        i = i + 1
                        continue
                    if c == '_':
                        i = i + 1
                        continue
                    break
                let count: int32 = i - start
                tokenInitRange(&scanRes.tok, tkNumber, content, start, count, line, start + 1)
                scanRes.nextPos = i
                if out != nil:
                    *out = scanRes
                return true
    var hasDot: bool = false
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        let c: char = content[i]
        if isDigit c:
            i = i + 1
            continue
        if c == '_':
            i = i + 1
            continue
        if c == '.':
            if hasDot:
                break
            var isRange: bool = false
            if i + 1 < n:
                if content[i + 1] == '.':
                    isRange = true
            if isRange:
                break
            hasDot = true
            i = i + 1
            continue
        break
    let count2: int32 = i - start
    tokenInitRange(&scanRes.tok, tkNumber, content, start, count2, line, start + 1)
    scanRes.nextPos = i
    if out != nil:
        *out = scanRes
    return true

fn lexNumber(content: str, start: int32, line: int32, filename: str, diags: var Diagnostic[]): ScanResult =
    var scanRes: ScanResult
    let _ok: bool = lexNumberInto(content, start, line, filename, diags, &scanRes)
    return scanRes

fn lexIdentInto(content: str, start: int32, line: int32, out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    var i: int32 = start
    let n: int32 = len content
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        let c: char = content[i]
        if isAlphaNum c:
            i = i + 1
            continue
        if c == '_':
            i = i + 1
            continue
        break
    let count: int32 = i - start
    var kind: TokenKind = tkIdent
    if isKeywordRange(content, start, count):
        kind = tkKeyword
    tokenInitRange(&scanRes.tok, kind, content, start, count, line, start + 1)
    scanRes.nextPos = i
    if out != nil:
        *out = scanRes
    return true

fn lexIdent(content: str, start: int32, line: int32): ScanResult =
    var scanRes: ScanResult
    let _ok: bool = lexIdentInto(content, start, line, &scanRes)
    return scanRes

fn lexCharInto(content: str, start: int32, line: int32, filename: str, diags: var Diagnostic[], out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    let n: int32 = len content
    var i: int32 = start + 1
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        if content[i] == chr 39:
            break
        let c: char = content[i]
        if c == chr 92:
            if i + 1 < n:
                i = i + 2
                continue
        i = i + 1
    var lexeme: str = ""
    if i > start + 1:
        lexeme = sliceRange(content, start + 1, i - 1)
    if i >= n:
        addLexDiag(diags, filename, line, start + 1, "Unterminated character literal")
        tokenInit(&scanRes.tok, tkChar, lexeme, line, start + 1)
        scanRes.nextPos = i
        if out != nil:
            *out = scanRes
        return true
    var okLen: bool = false
    if len lexeme == 1:
        okLen = true
    elif len lexeme == 2:
        if lexeme[0] == chr 92:
            okLen = true
    elif len lexeme == 4:
        if lexeme[0] == chr 92:
            if lexeme[1] == 'x':
                let a: char = lexeme[2]
                let b: char = lexeme[3]
                if isHexDigit a:
                    if isHexDigit b:
                        okLen = true
    if ! okLen:
        addLexDiag(diags, filename, line, start + 1, "Character literal must contain exactly one character")
    trackLexStringStr(lexeme)
    tokenInit(&scanRes.tok, tkChar, lexeme, line, start + 1)
    scanRes.nextPos = i + 1
    if out != nil:
        *out = scanRes
    return true

fn lexChar(content: str, start: int32, line: int32, filename: str, diags: var Diagnostic[]): ScanResult =
    var scanRes: ScanResult
    let _ok: bool = lexCharInto(content, start, line, filename, diags, &scanRes)
    return scanRes

fn lexStringInto(content: str, start: int32, line: int32, filename: str, diags: var Diagnostic[], out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    let n: int32 = len content
    var i: int32 = start
    var prefix: char = chr 0
    if i + 1 < n:
        let c0: char = content[i]
        let c1: char = content[i + 1]
        if c1 == '"':
            if c0 == 'r':
                prefix = c0
                i = i + 1
            elif c0 == 'f':
                prefix = c0
                i = i + 1
    if i + 2 < n:
        if content[i] == '"':
            if content[i + 1] == '"':
                if content[i + 2] == '"':
                    let contentStart: int32 = i + 3
                    i = i + 3
                    for __for_guard_i in 0..<n:
                        if !(i + 2 < n):
                            break
                        if content[i] == '"':
                            if content[i + 1] == '"':
                                if content[i + 2] == '"':
                                    break
                        i = i + 1
                    var lexeme: str = ""
                    if i > contentStart:
                        lexeme = sliceRange(content, contentStart, i - 1)
                    if i + 2 >= n:
                        addLexDiag(diags, filename, line, start + 1, "Unterminated string literal")
                        trackLexStringStr(lexeme)
                        tokenInit(&scanRes.tok, tkString, lexeme, line, start + 1, prefix)
                        scanRes.nextPos = n
                        if out != nil:
                            *out = scanRes
                        return true
                    trackLexStringStr(lexeme)
                    tokenInit(&scanRes.tok, tkString, lexeme, line, start + 1, prefix)
                    scanRes.nextPos = i + 3
                    if out != nil:
                        *out = scanRes
                    return true
    if content[i] == '"':
        i = i + 1
    let contentStart2: int32 = i
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        if content[i] == '"':
            break
        let c: char = content[i]
        if c == chr 92:
            if i + 1 < n:
                i = i + 2
                continue
        i = i + 1
    var lexeme: str = ""
    if i > contentStart2:
        lexeme = sliceRange(content, contentStart2, i - 1)
    if i >= n:
        addLexDiag(diags, filename, line, start + 1, "Unterminated string literal")
        trackLexStringStr(lexeme)
        tokenInit(&scanRes.tok, tkString, lexeme, line, start + 1, prefix)
        scanRes.nextPos = i
        if out != nil:
            *out = scanRes
        return true
    trackLexStringStr(lexeme)
    tokenInit(&scanRes.tok, tkString, lexeme, line, start + 1, prefix)
    scanRes.nextPos = i + 1
    if out != nil:
        *out = scanRes
    return true

fn lexString(content: str, start: int32, line: int32, filename: str, diags: var Diagnostic[]): ScanResult =
    var scanRes: ScanResult
    let _ok: bool = lexStringInto(content, start, line, filename, diags, &scanRes)
    return scanRes

fn matchSymbolInto(lineStr: str, pos: int32, out: ScanResult* = nil): bool =
    var scanRes: ScanResult
    var i: int32 = pos
    let lineLen: int32 = len lineStr
    if i + 2 < lineLen:
        if lineStr[i] == '.':
            if lineStr[i + 1] == '.':
                if lineStr[i + 2] == '<':
                    tokenInit(&scanRes.tok, tkSymbol, "..<", 0, 0)
                    scanRes.nextPos = i + 3
                    if out != nil:
                        *out = scanRes
                    return true
    if i + 1 < lineLen:
        let c0: char = lineStr[i]
        let c1: char = lineStr[i + 1]
        if c0 == '=':
            if c1 == '>':
                tokenInit(&scanRes.tok, tkSymbol, "=>", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
            if c1 == '=':
                tokenInit(&scanRes.tok, tkSymbol, "==", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '-':
            if c1 == '>':
                tokenInit(&scanRes.tok, tkSymbol, "->", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
            if c1 == '-':
                tokenInit(&scanRes.tok, tkSymbol, "--", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '!':
            if c1 == '=':
                tokenInit(&scanRes.tok, tkSymbol, "!=", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '+':
            if c1 == '+':
                tokenInit(&scanRes.tok, tkSymbol, "++", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '&':
            if c1 == '&':
                tokenInit(&scanRes.tok, tkSymbol, "&&", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '|':
            if c1 == '|':
                tokenInit(&scanRes.tok, tkSymbol, "||", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '<':
            if c1 == '<':
                tokenInit(&scanRes.tok, tkSymbol, "<<", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
            if c1 == '=':
                tokenInit(&scanRes.tok, tkSymbol, "<=", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '>':
            if c1 == '>':
                tokenInit(&scanRes.tok, tkSymbol, ">>", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
            if c1 == '=':
                tokenInit(&scanRes.tok, tkSymbol, ">=", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
        if c0 == '.':
            if c1 == '.':
                tokenInit(&scanRes.tok, tkSymbol, "..", 0, 0)
                scanRes.nextPos = i + 2
                if out != nil:
                    *out = scanRes
                return true
    let c: char = lineStr[i]
    if c == '(':
        tokenInit(&scanRes.tok, tkSymbol, "(", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ')':
        tokenInit(&scanRes.tok, tkSymbol, ")", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '[':
        tokenInit(&scanRes.tok, tkSymbol, "[", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ']':
        tokenInit(&scanRes.tok, tkSymbol, "]", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '{':
        tokenInit(&scanRes.tok, tkSymbol, "{", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '}':
        tokenInit(&scanRes.tok, tkSymbol, "}", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ',':
        tokenInit(&scanRes.tok, tkSymbol, ",", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ':':
        tokenInit(&scanRes.tok, tkSymbol, ":", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == ';':
        tokenInit(&scanRes.tok, tkSymbol, ";", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '.':
        tokenInit(&scanRes.tok, tkSymbol, ".", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '=':
        tokenInit(&scanRes.tok, tkSymbol, "=", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '+':
        tokenInit(&scanRes.tok, tkSymbol, "+", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '-':
        tokenInit(&scanRes.tok, tkSymbol, "-", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '*':
        tokenInit(&scanRes.tok, tkSymbol, "*", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '/':
        tokenInit(&scanRes.tok, tkSymbol, "/", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '%':
        tokenInit(&scanRes.tok, tkSymbol, "%", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '<':
        tokenInit(&scanRes.tok, tkSymbol, "<", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '>':
        tokenInit(&scanRes.tok, tkSymbol, ">", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '&':
        tokenInit(&scanRes.tok, tkSymbol, "&", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '|':
        tokenInit(&scanRes.tok, tkSymbol, "|", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '^':
        tokenInit(&scanRes.tok, tkSymbol, "^", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '~':
        tokenInit(&scanRes.tok, tkSymbol, "~", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '!':
        tokenInit(&scanRes.tok, tkSymbol, "!", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '$':
        tokenInit(&scanRes.tok, tkSymbol, "$", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '?':
        tokenInit(&scanRes.tok, tkSymbol, "?", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    if c == '@':
        tokenInit(&scanRes.tok, tkSymbol, "@", 0, 0)
        scanRes.nextPos = i + 1
        if out != nil:
            *out = scanRes
        return true
    tokenInit(&scanRes.tok, tkSymbol, "", 0, 0)
    scanRes.nextPos = i
    if out != nil:
        *out = scanRes
    return true

fn matchSymbol(lineStr: str, pos: int32): ScanResult =
    var scanRes: ScanResult
    let _ok: bool = matchSymbolInto(lineStr, pos, &scanRes)
    return scanRes

fn lexInto(content: str, filename: str = "stdin", tokensOut: Token[]* = nil, diagsOut: Diagnostic[]* = nil): bool =
    tokenResetTextPool()
    var tokens: Token[] = []
    var diags: Diagnostic[] = []
    let dbgLexState: bool = os.getEnvDefault("BACKEND_DEBUG_LEX_STATE", "") == "1"
    var indentStack: int32[] = []
    lexAppendI32(indentStack, int32(0))
    var lineStarts: int32[] = []
    var lineStops: int32[] = []
    let _splitOk: bool = splitLineSpansInto(content, &lineStarts, &lineStops)
    if dbgLexState:
        if lineStarts.len > 0:
            os.writeLine(os.get_stderr(), "[lex] lines_nonzero=1")
        else:
            os.writeLine(os.get_stderr(), "[lex] lines_nonzero=0")
        if lineStarts.len > 0 && lineStops.len > 0:
            let line0NonEmpty: bool = lineStops[0] >= lineStarts[0]
            if line0NonEmpty:
                os.writeLine(os.get_stderr(), "[lex] line0_nonempty=1")
            else:
                os.writeLine(os.get_stderr(), "[lex] line0_nonempty=0")
            if line0NonEmpty:
                if content[lineStarts[0]] == 'f':
                    os.writeLine(os.get_stderr(), "[lex] line0_first_f=1")
                else:
                    os.writeLine(os.get_stderr(), "[lex] line0_first_f=0")
        os.c_fflush os.get_stderr()
    var parenDepth: int32 = 0
    var lineContinues: bool = false
    var defContinues: bool = false
    var parenIndentActive: bool = false
    var parenIndentBase: int32 = 0
    var parenIndentParenDepth: int32 = 0
    var parenIndentStack: int32[] = []
    lexAppendI32(parenIndentStack, int32(0))
    var exprIndentPending: bool = false
    var exprIndentActive: bool = false
    var exprIndentBase: int32 = 0
    var exprIndentStack: int32[] = []
    lexAppendI32(exprIndentStack, int32(0))
    var typeIndentPending: bool = false
    var typeIndentBase: int32 = 0
    var typeIndentStack: int32[] = []
    var scannedAnyToken: bool = false
    var sawActiveLine: bool = false
    var sawIdentStart: bool = false
    var sawDigitStart: bool = false
    var sawStringStart: bool = false
    var sawSymbolAdvance: bool = false

    for lineIdx in 0..<lineStarts.len:
        let lineStartAbs: int32 = lineStarts[lineIdx]
        let lineLen: int32 = lineSpanLen(lineStarts, lineStops, lineIdx)
        let lineNum: int32 = lineIdx + 1
        var pos: int32 = 0
        var spaceCount: int32 = 0
        for __for_guard_pos in 0..<lineLen:
            if !(pos < lineLen):
                break
            if content[lineStartAbs + pos] != ' ':
                break
            spaceCount = spaceCount + 1
            pos = pos + 1
        if pos >= lineLen:
            continue
        if pos < lineLen:
            if content[lineStartAbs + pos] == '#':
                continue
        sawActiveLine = true
        if pos < lineLen:
            if content[lineStartAbs + pos] == '\t':
                addLexDiag(diags, filename, lineNum, pos + 1, "Tab indentation is not allowed")
        if exprIndentActive && spaceCount <= exprIndentBase && ! lineStartsContinueKeyword(content, lineStartAbs, lineLen):
            while exprIndentStack.len > 1:
                exprIndentStack.len = exprIndentStack.len - 1
                lexAppendNewToken(tokens, tkDedent, "", lineNum, 1)
            exprIndentActive = false
            exprIndentBase = 0
            exprIndentStack.len = 1
        var parenContinuation: bool = false
        if parenIndentActive:
            if parenDepth > parenIndentParenDepth:
                parenContinuation = true
        else:
            if parenDepth > 0:
                parenContinuation = true
        var continuation: bool = false
        if lineContinues:
            continuation = true
        if parenContinuation:
            continuation = true
        var inTypeBlock: bool = false
        if ! continuation:
            while typeIndentStack.len > 0 && spaceCount < typeIndentStack[typeIndentStack.len - 1]:
                typeIndentStack.len = typeIndentStack.len - 1
            if typeIndentPending:
                if spaceCount > typeIndentBase:
                    lexAppendI32(typeIndentStack, spaceCount)
                typeIndentPending = false
            if typeIndentStack.len > 0 && spaceCount == typeIndentStack[typeIndentStack.len - 1]:
                inTypeBlock = true
            if exprIndentPending:
                exprIndentActive = true
                exprIndentBase = spaceCount
                exprIndentStack = []
                lexAppendI32(exprIndentStack, int32(0))
                exprIndentPending = false
            elif exprIndentActive:
                var relIndent: int32 = spaceCount - exprIndentBase
                if relIndent < 0:
                    relIndent = 0
                emitIndentTokens(tokens, exprIndentStack, relIndent, lineNum, filename, diags)
            elif parenIndentActive:
                var relIndent: int32 = spaceCount - parenIndentBase
                if relIndent < 0:
                    relIndent = 0
                emitIndentTokens(tokens, parenIndentStack, relIndent, lineNum, filename, diags)
            else:
                emitIndentTokens(tokens, indentStack, spaceCount, lineNum, filename, diags)

        var lineHasTokens: bool = false
        var lineHasDef: bool = false
        var lineStartsBlock: bool = false
        var lineStartsContinuation: bool = false
        var lineStartsCase: bool = false
        var lineTokenCount: int32 = 0
        var lineFirstTok: Token
        tokenInit(&lineFirstTok, tkEof, "", lineNum, 0)
        var lastTok: Token
        tokenInit(&lastTok, tkEof, "", lineNum, 0)
        let __for_guard_start_pos_lx1 = pos
        for __for_guard_pos_lx1 in __for_guard_start_pos_lx1..<lineLen:
            if ! (pos < lineLen):
                break
            let ch: char = content[lineStartAbs + pos]
            if ch == ' ':
                pos = pos + 1
                continue
            if ch == '#':
                break
            var isStringStart: bool = false
            if ch == '"':
                isStringStart = true
            elif ch == 'r':
                if pos + 1 < lineLen:
                    let nextCh: char = content[lineStartAbs + pos + 1]
                    if nextCh == '"':
                        isStringStart = true
            elif ch == 'f':
                if pos + 1 < lineLen:
                    let nextCh: char = content[lineStartAbs + pos + 1]
                    if nextCh == '"':
                        isStringStart = true
            if isStringStart:
                sawStringStart = true
                var res: ScanResult
                let _ok: bool = lexStringLineInto(content, lineStartAbs, lineLen, pos, lineNum, filename, diags, &res)
                lexAppendToken(tokens, res.tok)
                if lineTokenCount == 0:
                    lineFirstTok = res.tok
                lineTokenCount = lineTokenCount + 1
                pos = res.nextPos
                if ! lineHasTokens:
                    if res.tok.kind == tkKeyword:
                        if isBlockStartKeyword tokenLexeme(res.tok):
                            lineStartsBlock = true
                        if isBlockContinueKeyword tokenLexeme(res.tok):
                            lineStartsContinuation = true
                lastTok = res.tok
                lineHasTokens = true
                continue
            var isIdentStart: bool = false
            if isAlphaAscii ch:
                isIdentStart = true
            elif ch == '_':
                isIdentStart = true
            if isIdentStart:
                sawIdentStart = true
                var res: ScanResult
                let _ok: bool = lexIdentLineInto(content, lineStartAbs, lineLen, pos, lineNum, &res)
                lexAppendToken(tokens, res.tok)
                if lineTokenCount == 0:
                    lineFirstTok = res.tok
                lineTokenCount = lineTokenCount + 1
                pos = res.nextPos
                if ! lineHasTokens:
                    if res.tok.kind == tkKeyword:
                        if isBlockStartKeyword tokenLexeme(res.tok):
                            lineStartsBlock = true
                        if isBlockContinueKeyword tokenLexeme(res.tok):
                            lineStartsContinuation = true
                        if (tokenLexeme(res.tok) ==  "case"):
                            lineStartsCase = true
                if isDefKeyword res.tok:
                    lineHasDef = true
                lastTok = res.tok
                lineHasTokens = true
                continue
            if isDigit ch:
                sawDigitStart = true
                var res: ScanResult
                let _ok: bool = lexNumberLineInto(content, lineStartAbs, lineLen, pos, lineNum, filename, diags, &res)
                lexAppendToken(tokens, res.tok)
                if lineTokenCount == 0:
                    lineFirstTok = res.tok
                lineTokenCount = lineTokenCount + 1
                pos = res.nextPos
                if ! lineHasTokens:
                    if res.tok.kind == tkKeyword:
                        if isBlockStartKeyword tokenLexeme(res.tok):
                            lineStartsBlock = true
                        if isBlockContinueKeyword tokenLexeme(res.tok):
                            lineStartsContinuation = true
                lastTok = res.tok
                lineHasTokens = true
                continue
            if ch == chr 39:
                var res: ScanResult
                let _ok: bool = lexCharLineInto(content, lineStartAbs, lineLen, pos, lineNum, filename, diags, &res)
                lexAppendToken(tokens, res.tok)
                if lineTokenCount == 0:
                    lineFirstTok = res.tok
                lineTokenCount = lineTokenCount + 1
                pos = res.nextPos
                if ! lineHasTokens:
                    if res.tok.kind == tkKeyword:
                        if isBlockStartKeyword tokenLexeme(res.tok):
                            lineStartsBlock = true
                        if isBlockContinueKeyword tokenLexeme(res.tok):
                            lineStartsContinuation = true
                lastTok = res.tok
                lineHasTokens = true
                continue
            if ch == '`':
                var i: int32 = pos + 1
                var lexeme: str = ""
                let __for_guard_start_i_1 = i
                for __for_guard_i_1 in __for_guard_start_i_1..<lineLen:
                    if ! (i < lineLen):
                        break
                    if content[lineStartAbs + i] == '`':
                        break
                    i = i + 1
                if i < lineLen:
                    let count: int32 = i - (pos + 1)
                    if count > 0:
                        lexeme = lexOwnedRangeCopy(content, lineStartAbs + pos + 1, count)
                    i = i + 1
                    trackLexStringStr(lexeme)
                    var tok: Token
                    tokenInit(&tok, tkIdent, lexeme, lineNum, pos + 1)
                    lexAppendToken(tokens, tok)
                    if lineTokenCount == 0:
                        lineFirstTok = tok
                    lineTokenCount = lineTokenCount + 1
                    pos = i
                    if ! lineHasTokens:
                        if tok.kind == tkKeyword:
                            if isBlockStartKeyword tokenLexeme(tok):
                                lineStartsBlock = true
                            if isBlockContinueKeyword tokenLexeme(tok):
                                lineStartsContinuation = true
                    lastTok = tok
                    lineHasTokens = true
                    continue
                addLexDiag(diags, filename, lineNum, pos + 1, "Unterminated backtick identifier")
                pos = i
                continue
            var symRes: ScanResult
            let _ok: bool = matchSymbolLineInto(content, lineStartAbs, lineLen, pos, &symRes)
            if symRes.nextPos > pos:
                sawSymbolAdvance = true
                var tok: Token = symRes.tok
                tok.line = lineNum
                tok.col = pos + 1
                lexAppendToken(tokens, tok)
                if lineTokenCount == 0:
                    lineFirstTok = tok
                lineTokenCount = lineTokenCount + 1
                var isOpen: bool = false
                if (tokenLexeme(tok) ==  "("):
                    isOpen = true
                elif (tokenLexeme(tok) ==  "["):
                    isOpen = true
                elif (tokenLexeme(tok) ==  "{"):
                    isOpen = true
                if isOpen:
                    parenDepth = parenDepth + 1
                else:
                    var isClose: bool = false
                    if (tokenLexeme(tok) ==  ")"):
                        isClose = true
                    elif (tokenLexeme(tok) ==  "]"):
                        isClose = true
                    elif (tokenLexeme(tok) ==  "}"):
                        isClose = true
                    if isClose:
                        if parenDepth > 0:
                            parenDepth = parenDepth - 1
                pos = symRes.nextPos
                lastTok = tok
                lineHasTokens = true
                continue
            addLexDiag(diags, filename, lineNum, pos + 1, "Unrecognized character '" + charToStr ch + "'")
            pos = pos + 1

        if lineHasTokens:
            scannedAnyToken = true
            if inTypeBlock:
                lineHasDef = true
            var defActive: bool = false
            if lineHasDef:
                defActive = true
            if defContinues:
                defActive = true
            var opensBlock: bool = false
            var startsBlockExpr: bool = false
            if lastTok.kind == tkSymbol:
                if (tokenLexeme(lastTok) ==  ":"):
                    if lineStartsBlock:
                        opensBlock = true
                elif (tokenLexeme(lastTok) ==  "="):
                    if defActive:
                        opensBlock = true
                    if (! defActive) && (nextLineStartsBlockExpr(content, lineStarts, lineStops, lineIdx + 1) || nextLineIsIndented(content, lineStarts, lineStops, lineIdx + 1, spaceCount)):
                        startsBlockExpr = true
                        opensBlock = true
            if lineStartsCase:
                opensBlock = true
            var parenContinuationNow: bool = false
            if parenIndentActive:
                if parenDepth > parenIndentParenDepth:
                    parenContinuationNow = true
            else:
                if parenDepth > 0:
                    parenContinuationNow = true
            var lineContinuesNow: bool = false
            if parenContinuationNow:
                lineContinuesNow = true
            if isContinuationToken lastTok:
                lineContinuesNow = true
            if lastTok.kind == tkSymbol &&(tokenLexeme(lastTok) ==  "="):
                lineContinuesNow = false
            if opensBlock:
                lineContinuesNow = false
            if ! lineContinuesNow:
                lexAppendNewToken(tokens, tkNewline, "", lineNum, lineLen + 1)
            lineContinues = lineContinuesNow
            if lineTokenCount == 1 && lineFirstTok.kind == tkKeyword && tokenLexeme(lineFirstTok) ==  "type" && ! lineContinuesNow:
                typeIndentPending = true
                typeIndentBase = spaceCount
            defContinues = false
            if defActive:
                if lineContinuesNow:
                    defContinues = true
            if ! parenIndentActive:
                if parenDepth > 0:
                    if opensBlock:
                        parenIndentActive = true
                        parenIndentBase = spaceCount
                        parenIndentParenDepth = parenDepth
                        parenIndentStack = []
                        lexAppendI32(parenIndentStack, int32(0))
            if startsBlockExpr:
                exprIndentPending = true
            if parenIndentActive:
                if parenDepth <= parenIndentParenDepth:
                    let relIndent: int32 = spaceCount - parenIndentBase
                    var closeParenIndent: bool = false
                    if relIndent <= 0:
                        if ! lineStartsContinuation:
                            if ! opensBlock:
                                closeParenIndent = true
                    if closeParenIndent:
                        parenIndentActive = false
                        parenIndentBase = 0
                        parenIndentParenDepth = 0
                        parenIndentStack.len = 1

    while exprIndentStack.len > 1:
        exprIndentStack.len = exprIndentStack.len - 1
        lexAppendNewToken(tokens, tkDedent, "", lineStarts.len + 1, 1)
    while parenIndentStack.len > 1:
        parenIndentStack.len = parenIndentStack.len - 1
        lexAppendNewToken(tokens, tkDedent, "", lineStarts.len + 1, 1)
    while indentStack.len > 1:
        indentStack.len = indentStack.len - 1
        lexAppendNewToken(tokens, tkDedent, "", lineStarts.len + 1, 1)
    lexAppendNewToken(tokens, tkEof, "", lineStarts.len + 1, 1)
    if dbgLexState:
        if scannedAnyToken:
            os.writeLine(os.get_stderr(), "[lex] scanned_any_token=1")
        else:
            os.writeLine(os.get_stderr(), "[lex] scanned_any_token=0")
        if tokens.len > 1:
            os.writeLine(os.get_stderr(), "[lex] tokens_gt1=1")
        else:
            os.writeLine(os.get_stderr(), "[lex] tokens_gt1=0")
        if sawActiveLine:
            os.writeLine(os.get_stderr(), "[lex] active_line=1")
        else:
            os.writeLine(os.get_stderr(), "[lex] active_line=0")
        if sawIdentStart:
            os.writeLine(os.get_stderr(), "[lex] ident_start=1")
        else:
            os.writeLine(os.get_stderr(), "[lex] ident_start=0")
        if sawDigitStart:
            os.writeLine(os.get_stderr(), "[lex] digit_start=1")
        else:
            os.writeLine(os.get_stderr(), "[lex] digit_start=0")
        if sawStringStart:
            os.writeLine(os.get_stderr(), "[lex] string_start=1")
        else:
            os.writeLine(os.get_stderr(), "[lex] string_start=0")
        if sawSymbolAdvance:
            os.writeLine(os.get_stderr(), "[lex] symbol_advance=1")
        else:
            os.writeLine(os.get_stderr(), "[lex] symbol_advance=0")
        os.c_fflush os.get_stderr()
    if os.getEnvDefault("BACKEND_DEBUG_LEX_TOKENS", "") == "1":
        let dbgFile: os.File = os.get_stderr()
        var ti: int32 = 0
        while ti < tokens.len && ti < 12:
            let tok: Token = tokens[ti]
            os.write(dbgFile, "[lex-tok] ")
            os.write(dbgFile, kindName(tok.kind))
            os.write(dbgFile, " '")
            os.write(dbgFile, tokenLexeme(tok))
            os.writeLine(dbgFile, "'")
            ti = ti + 1
        os.c_fflush dbgFile

    if tokensOut != nil:
        *tokensOut = tokens
    if diagsOut != nil:
        *diagsOut = diags
    return true

fn lex(content: str, filename: str = "stdin"): LexResult =
    var tokens: Token[] = []
    var diags: Diagnostic[] = []
    let _ok: bool = lexInto(content, filename, &tokens, &diags)
    var res: LexResult
    res.tokens = tokens
    res.diagnostics = diags
    return res

fn lexTokens(content: str, filename: str = "stdin"): Token[] =
    var tokens: Token[] = []
    var diags: Diagnostic[] = []
    let _ok: bool = lexInto(content, filename, &tokens, &diags)
    let _diags: Diagnostic[] = diags
    return tokens
