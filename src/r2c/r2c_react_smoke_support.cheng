import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_surface_main as r2csurface
import std/strutils as strutil

type
    R2cReactSmokeContext =
        root: str
        outDir: str
        repo: str
        driver: str
        stage3: str
        controllerExe: str
        nativeEnv: str[]

    R2cReactSmokeCodegenPaths =
        outDir: str
        reportPath: str
        summaryPath: str
        manifestPath: str
        routeCatalogPath: str
        tsxAstPath: str

    R2cReactSmokeBundlePaths =
        outDir: str
        reportPath: str
        summaryPath: str
        bundleJsonPath: str
        sessionPath: str
        staticSummaryPath: str
        hostContractPath: str
        assetManifestPath: str
        tailwindManifestPath: str

fn R2cReactSmokeRoot(): str =
    var root = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    return root

fn R2cReactSmokeRepo(): str =
    var repo = "/Users/lbcheng/UniMaker/React.js"
    let repoEnv = os.GetEnv("R2C_REACT_REPO")
    if len(repoEnv) > 0:
        repo = repoEnv
    return repo

fn R2cReactSmokeNativeEnv(stage3: str): str[] =
    var out: str[]
    add(out, strutil.Join(["R2C_REACT_TOOLING_BIN=", stage3], ""))
    add(out, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(out, "CHENG_PROGRESS=1")
    add(out, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")
    add(out, "CHENG_COMPILE_TIMEOUT_SEC=300")
    return out

fn R2cReactSmokeControllerCompileEnv(): str[] =
    var out: str[]
    add(out, "BACKEND_INCREMENTAL=0")
    add(out, "BACKEND_MULTI_MODULE_CACHE=0")
    add(out, "CHENG_DISABLE_PRIMARY_OBJECT_CACHE=1")
    add(out, "BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0")
    add(out, "BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0")
    add(out, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(out, "CHENG_PROGRESS=1")
    add(out, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")
    add(out, "CHENG_COMPILE_TIMEOUT_SEC=300")
    return out

fn R2cReactSmokeControllerArgs(subcommand: str,
                                 tail: str[]): str[] =
    var out: str[]
    add(out, subcommand)
    for i in 0..<tail.len:
        add(out, tail[i])
    return out

fn R2cReactSmokeWriteTinyPng(path: str) =
    let payload: uint8[] = [
        uint8(137), uint8(80), uint8(78), uint8(71), uint8(13), uint8(10), uint8(26), uint8(10),
        uint8(0), uint8(0), uint8(0), uint8(13), uint8(73), uint8(72), uint8(68), uint8(82),
        uint8(0), uint8(0), uint8(0), uint8(1), uint8(0), uint8(0), uint8(0), uint8(1),
        uint8(8), uint8(4), uint8(0), uint8(0), uint8(0), uint8(181), uint8(28), uint8(12),
        uint8(2), uint8(0), uint8(0), uint8(0), uint8(11), uint8(73), uint8(68), uint8(65),
        uint8(84), uint8(120), uint8(218), uint8(99), uint8(252), uint8(255), uint8(31), uint8(0),
        uint8(3), uint8(3), uint8(2), uint8(0), uint8(239), uint8(154), uint8(93), uint8(251),
        uint8(0), uint8(0), uint8(0), uint8(0), uint8(73), uint8(69), uint8(78), uint8(68),
        uint8(174), uint8(66), uint8(96), uint8(130)
    ]
    os.WriteFileBytes(path, payload)

fn R2cReactSmokeSetup(outRel: str,
                        compileLabel: str,
                        assertPrefix: str): R2cReactSmokeContext =
    let root = R2cReactSmokeRoot()
    let outDir = chengpath.PathAbsolute(root, outRel)
    assert(chengpath.MkdirP(root, outDir), strutil.Join([assertPrefix, ": mkdir"], ""))
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let stage3 = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    assert(chengpath.FileExistsNonEmpty(root, driver), strutil.Join([assertPrefix, ": backend_driver exists"], ""))
    assert(chengpath.FileExistsNonEmpty(root, stage3), strutil.Join([assertPrefix, ": stage3 exists"], ""))
    let repo = R2cReactSmokeRepo()
    assert(os.DirExists(repo), strutil.Join([assertPrefix, ": React.js repo exists"], ""))
    let controllerEnv = os.GetEnv("R2C_REACT_CONTROLLER_EXE")
    let allowControllerCompile = os.GetEnv("R2C_REACT_ALLOW_CONTROLLER_COMPILE") == "1"
    var controllerExe = ""
    if len(controllerEnv) > 0:
        controllerExe = chengpath.PathAbsolute(root, controllerEnv)
    elif allowControllerCompile:
        controllerExe = os.JoinPath(outDir, "r2c_react_controller_smoke")
    else:
        assert(false, strutil.Join([assertPrefix, ": set R2C_REACT_CONTROLLER_EXE or R2C_REACT_ALLOW_CONTROLLER_COMPILE=1"], ""))
    if allowControllerCompile && len(controllerEnv) <= 0:
        let controllerSource = chengpath.PathAbsolute(root, "src/r2c/r2c_react.cheng")
        let controllerCompileLog = strutil.Join([controllerExe, ".compile.log"], "")
        let controllerCompileReport = strutil.Join([controllerExe, ".report.txt"], "")
        if chengpath.PathFileExists(controllerExe):
            os.RemoveFile(controllerExe)
        if chengpath.PathFileExists(strutil.Join([controllerExe, ".map"], "")):
            os.RemoveFile(strutil.Join([controllerExe, ".map"], ""))
        if chengpath.PathFileExists(controllerCompileLog):
            os.RemoveFile(controllerCompileLog)
        if chengpath.PathFileExists(controllerCompileReport):
            os.RemoveFile(controllerCompileReport)
        var controllerCompileArgs: str[]
        add(controllerCompileArgs, "system-link-exec")
        add(controllerCompileArgs, strutil.Join(["--root:", root], ""))
        add(controllerCompileArgs, strutil.Join(["--in:", controllerSource], ""))
        add(controllerCompileArgs, "--emit:exe")
        add(controllerCompileArgs, "--target:arm64-apple-darwin")
        add(controllerCompileArgs, strutil.Join(["--out:", controllerExe], ""))
        add(controllerCompileArgs, strutil.Join(["--report-out:", controllerCompileReport], ""))
        let controllerCompileRun = hostops.RunFileLogged(root,
                                                           compileLabel,
                                                           driver,
                                                           controllerCompileArgs,
                                                           R2cReactSmokeControllerCompileEnv(),
                                                           root,
                                                           420,
                                                           controllerCompileLog)
        assert(hostops.LoggedRunOk(controllerCompileRun), strutil.Join([assertPrefix, ": controller compile rc"], ""))
        assert(chengpath.FileExistsNonEmpty(root, controllerCompileReport), strutil.Join([assertPrefix, ": controller compile report"], ""))
    assert(chengpath.FileExistsNonEmpty(root, controllerExe), strutil.Join([assertPrefix, ": controller exe"], ""))
    let statusPath = os.JoinPath(outDir, "r2c_react_status_report_v1.json")
    let statusLog = os.JoinPath(outDir, "r2c_react_status.log")
    if chengpath.PathFileExists(statusPath):
        os.RemoveFile(statusPath)
    if chengpath.PathFileExists(statusLog):
        os.RemoveFile(statusLog)
    let statusRun = hostops.RunFileLogged(root,
                                            strutil.Join([compileLabel, "_status"], ""),
                                            controllerExe,
                                            ["status", "--out", statusPath],
                                            R2cReactSmokeNativeEnv(stage3),
                                            root,
                                            120,
                                            statusLog)
    assert(hostops.LoggedRunOk(statusRun), strutil.Join([assertPrefix, ": controller status rc"], ""))
    assert(chengpath.FileExistsNonEmpty(root, statusPath), strutil.Join([assertPrefix, ": controller status report"], ""))
    return R2cReactSmokeContext(root: root,
                                  outDir: outDir,
                                  repo: repo,
                                  driver: driver,
                                  stage3: stage3,
                                  controllerExe: controllerExe,
                                  nativeEnv: R2cReactSmokeNativeEnv(stage3))

fn R2cReactSmokeRunCodegen(ctx: R2cReactSmokeContext,
                             runLabel: str,
                             assertPrefix: str): R2cReactSmokeCodegenPaths =
    let codegenOutDir = chengpath.PathJoin(ctx.outDir, "codegen_surface")
    let codegenLog = chengpath.PathJoin(ctx.outDir, "r2c_codegen_surface.log")
    if chengpath.PathFileExists(codegenLog):
        os.RemoveFile(codegenLog)
    let codegenRun = hostops.RunFileLogged(ctx.root,
                                             runLabel,
                                             ctx.controllerExe,
                                             R2cReactSmokeControllerArgs("codegen-surface",
                                                                         ["--repo", ctx.repo,
                                                                          "--out-dir", codegenOutDir]),
                                             ctx.nativeEnv,
                                             ctx.root,
                                             420,
                                             codegenLog)
    assert(hostops.LoggedRunOk(codegenRun), strutil.Join([assertPrefix, ": codegen surface rc"], ""))
    assert(chengpath.PathFileExists(codegenLog), strutil.Join([assertPrefix, ": codegen surface log"], ""))
    assert(chengpath.TextContains(codegenRun.output, "codegen_surface_report_v1.json"),
           strutil.Join([assertPrefix, ": codegen surface report output"], ""))
    let reportPath = os.JoinPath(codegenOutDir, "codegen_surface_report_v1.json")
    let summaryPath = os.JoinPath(codegenOutDir, "codegen_surface.summary.env")
    let manifestPath = os.JoinPath(codegenOutDir, "cheng_codegen_v1.json")
    let routeCatalogPath = os.JoinPath(codegenOutDir, "cheng_codegen_route_catalog_v1.json")
    let tsxAstPath = os.JoinPath(codegenOutDir, "tsx_ast_v1.json")
    assert(chengpath.FileExistsNonEmpty(ctx.root, reportPath), strutil.Join([assertPrefix, ": codegen report"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, summaryPath), strutil.Join([assertPrefix, ": codegen summary"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, manifestPath), strutil.Join([assertPrefix, ": codegen manifest"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, routeCatalogPath), strutil.Join([assertPrefix, ": codegen route catalog"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, tsxAstPath), strutil.Join([assertPrefix, ": codegen tsx ast"], ""))
    return R2cReactSmokeCodegenPaths(outDir: codegenOutDir,
                                      reportPath: reportPath,
                                      summaryPath: summaryPath,
                                      manifestPath: manifestPath,
                                      routeCatalogPath: routeCatalogPath,
                                      tsxAstPath: tsxAstPath)

fn R2cReactSmokeBundlePathsFor(ctx: R2cReactSmokeContext,
                                 outName: str): R2cReactSmokeBundlePaths =
    let outDir = chengpath.PathJoin(ctx.outDir, outName)
    return R2cReactSmokeBundlePaths(
        outDir: outDir,
        reportPath: os.JoinPath(outDir, "native_gui_bundle_report_v1.json"),
        summaryPath: os.JoinPath(outDir, "native_gui_bundle.summary.env"),
        bundleJsonPath: os.JoinPath(outDir, "native_gui_bundle_v1.json"),
        sessionPath: os.JoinPath(outDir, "native_gui_session_v1.json"),
        staticSummaryPath: os.JoinPath(outDir, "static_surface.summary.env"),
        hostContractPath: os.JoinPath(outDir, "unimaker_host_v1.json"),
        assetManifestPath: os.JoinPath(outDir, "asset_manifest_v1.json"),
        tailwindManifestPath: os.JoinPath(outDir, "tailwind_style_manifest_v1.json"))

fn R2cReactSmokeRunBundle(ctx: R2cReactSmokeContext,
                            codegen: R2cReactSmokeCodegenPaths,
                            routeState: str,
                            outName: str,
                            logName: str,
                            runLabel: str,
                            assertPrefix: str): R2cReactSmokeBundlePaths =
    let paths = R2cReactSmokeBundlePathsFor(ctx, outName)
    let bundleLog = chengpath.PathJoin(ctx.outDir, logName)
    if chengpath.PathFileExists(bundleLog):
        os.RemoveFile(bundleLog)
    assert(chengpath.MkdirP(ctx.root, paths.outDir), strutil.Join([assertPrefix, ": bundle mkdir"], ""))
    var staticAssetRoots: str[]
    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    assert(r2csurface.r2cRunStaticSurface(ctx.repo,
                                            paths.outDir,
                                            codegen.tsxAstPath,
                                            paths.staticSummaryPath,
                                            staticAssetRoots,
                                            staticSurface),
           strutil.Join([assertPrefix, ": static surface rc"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, paths.staticSummaryPath), strutil.Join([assertPrefix, ": static surface summary"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, paths.hostContractPath), strutil.Join([assertPrefix, ": bundle host contract"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, paths.assetManifestPath), strutil.Join([assertPrefix, ": bundle asset manifest"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, paths.tailwindManifestPath), strutil.Join([assertPrefix, ": bundle tailwind manifest"], ""))
    let bundleRun = hostops.RunFileLogged(ctx.root,
                                            runLabel,
                                            ctx.controllerExe,
                                            R2cReactSmokeControllerArgs("native-gui-bundle",
                                                                        ["--repo", ctx.repo,
                                                                         "--route-state", routeState,
                                                                         "--out-dir", paths.outDir,
                                                                         "--codegen-manifest", codegen.manifestPath,
                                                                         "--host-contract", paths.hostContractPath,
                                                                         "--asset-manifest", paths.assetManifestPath,
                                                                         "--tailwind-manifest", paths.tailwindManifestPath,
                                                                         "--route-catalog", codegen.routeCatalogPath,
                                                                         "--tsx-ast", codegen.tsxAstPath,
                                                                         "--summary-out", paths.summaryPath]),
                                            ctx.nativeEnv,
                                            ctx.root,
                                            420,
                                            bundleLog)
    assert(hostops.LoggedRunOk(bundleRun), strutil.Join([assertPrefix, ": native gui bundle rc"], ""))
    assert(chengpath.PathFileExists(bundleLog), strutil.Join([assertPrefix, ": native gui bundle log"], ""))
    assert(chengpath.TextContains(bundleRun.output, "native_gui_bundle_report_v1.json"),
           strutil.Join([assertPrefix, ": native gui bundle report output"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, paths.reportPath), strutil.Join([assertPrefix, ": native gui report"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, paths.summaryPath), strutil.Join([assertPrefix, ": native gui summary"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, paths.bundleJsonPath), strutil.Join([assertPrefix, ": native gui bundle json"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, paths.sessionPath), strutil.Join([assertPrefix, ": native gui session json"], ""))
    let summaryText = chengpath.ReadTextFile("", paths.summaryPath)
    assert(chengpath.TextContains(summaryText, strutil.Join(["native_gui_route_state=", routeState], "")),
           strutil.Join([assertPrefix, ": route state"], ""))
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_bundle_ready=true"),
           strutil.Join([assertPrefix, ": runtime bundle ready"], ""))
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_contract_ready=true"),
           strutil.Join([assertPrefix, ": runtime contract ready"], ""))
    return paths

fn R2cReactSmokeRunNativeGui(ctx: R2cReactSmokeContext,
                               bundle: R2cReactSmokeBundlePaths,
                               routeState: str,
                               outName: str,
                               assertPrefix: str): str =
    let runOutDir = chengpath.PathJoin(ctx.outDir, outName)
    let runLog = chengpath.PathJoin(ctx.outDir, "r2c_native_gui_run.log")
    if chengpath.PathFileExists(runLog):
        os.RemoveFile(runLog)
    let runReportPath = os.JoinPath(runOutDir, "native_gui_run_report_v1.json")
    let runSummaryPath = os.JoinPath(runOutDir, "native_gui_run.summary.env")
    let runScreenshotPath = os.JoinPath(runOutDir, "native_gui_session.png")
    assert(chengpath.MkdirP(ctx.root, runOutDir), strutil.Join([assertPrefix, ": run mkdir"], ""))
    let runRun = hostops.RunFileLogged(ctx.root,
                                         "r2c_native_gui_run_smoke",
                                         ctx.controllerExe,
                                         R2cReactSmokeControllerArgs("run-native-gui",
                                                                     ["--repo", ctx.repo,
                                                                      "--out-dir", runOutDir,
                                                                      "--bundle-path", bundle.bundleJsonPath,
                                                                      "--session-path", bundle.sessionPath,
                                                                      "--route-state", routeState,
                                                                      "--auto-close-ms", "600",
                                                                      "--summary-out", runSummaryPath]),
                                         ctx.nativeEnv,
                                         ctx.root,
                                         420,
                                         runLog)
    assert(hostops.LoggedRunOk(runRun), strutil.Join([assertPrefix, ": native gui run rc"], ""))
    assert(chengpath.PathFileExists(runLog), strutil.Join([assertPrefix, ": native gui run log"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, runReportPath), strutil.Join([assertPrefix, ": native gui run report"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, runSummaryPath), strutil.Join([assertPrefix, ": native gui run summary"], ""))
    assert(chengpath.FileExistsNonEmpty(ctx.root, runScreenshotPath), strutil.Join([assertPrefix, ": native gui run screenshot"], ""))
    assert(chengpath.TextContains(runRun.output, "native_gui_run_report_v1.json"),
           strutil.Join([assertPrefix, ": native gui run output path"], ""))
    let runSummaryText = chengpath.ReadTextFile("", runSummaryPath)
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_bundle_ready=true"),
           strutil.Join([assertPrefix, ": runtime bundle ready"], ""))
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_contract_ready=true"),
           strutil.Join([assertPrefix, ": runtime contract ready"], ""))
    assert(chengpath.TextContains(runSummaryText, strutil.Join(["native_gui_runtime_bundle_route_state=", routeState], "")),
           strutil.Join([assertPrefix, ": runtime bundle route state"], ""))
    return runSummaryText
