import std/strings
import cheng/core/tooling/path as chengpath

type
    R2cReactStatusContract =
        workspaceRoot: str
        experimentalRoot: str
        legacyPrototypePath: str
        tsxFrontendHelper: str
        staticSurfaceHelper: str
        semanticSurfaceHelper: str
        codegenSurfaceHelper: str
        execSurfaceHelper: str
        truthRuntimeHelper: str
        nativeGuiBundleHelper: str
        nativeGuiBundleFinalizer: str
        nativeGuiRuntimeHelper: str
        nativeGuiRuntimeMode: str
        nativeGuiRunHelper: str
        nativeGuiLayoutPayloadFinalizer: str
        nativeGuiLayoutItemCatalogMode: str
        nativeGuiLayoutItemCatalogPayloadProfile: str
        renderCompareHelper: str
        nativeGuiReplayHitInspectorHelper: str
        execRouteMatrixHelper: str
        truthRouteHelper: str
        truthCompareHelper: str
        truthCompareMatrixHelper: str
        nativeGuiHostSource: str
        nativeGuiHostSourceKind: str
        nativeGuiHostHelpers: str[]
        legacyShellWrapper: str
        legacyShellWrappers: str[]
        legacyWrapperRequired: bool
        legacyPrototypeRequired: bool
        compileNonChengBlockers: str[]
        guiRuntimeNonChengBlockers: str[]
        truthRuntimeNonChengBlockers: str[]
        optionalNonChengHelpers: str[]
        remainingNonChengBlockers: str[]
        activeNodeHelpers: str[]
        thinNodeHelpers: str[]
        retiredNodeHelpers: str[]
        standaloneNodeHelpers: str[]
        commands: str[]

fn R2cReactStatusJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    var out = quote
    let total: int32 = strings.Len(text)
    var i: int32
    while i < total:
        let ch = text[i]
        if ch == char(34):
            out = out + "\\" + quote
        elif ch == '\\':
            out = out + "\\\\"
        elif ch == char(10):
            out = out + "\\n"
        elif ch == char(13):
            out = out + "\\r"
        elif ch == char(9):
            out = out + "\\t"
        else:
            out = out + strings.CharToStr(ch)
        i = i + 1
    out = out + quote
    return out

fn R2cReactStatusJsonArray(items: str[]): str =
    var out = "["
    for i in 0..<items.len:
        if i > 0:
            out = out + ", "
        out = out + R2cReactStatusJsonQuote(items[i])
    out = out + "]"
    return out

fn R2cReactStatusBoolText(value: bool): str =
    if value:
        return "true"
    return "false"

fn R2cReactStatusAppendUnique(items: var str[],
                                  item: str) =
    for i in 0..<items.len:
        if items[i] == item:
            return
    add(items, item)

fn R2cReactStatusContract(workspaceRootRaw: str): R2cReactStatusContract =
    let workspaceRoot = workspaceRootRaw
    let experimentalRoot = chengpath.PathAbsolute(workspaceRoot, "tools/r2c/experimental")
    var out: R2cReactStatusContract
    out.workspaceRoot = workspaceRoot
    out.experimentalRoot = experimentalRoot
    out.legacyPrototypePath = ""
    out.tsxFrontendHelper = "cheng.tsx_frontend_seed_v1"
    out.staticSurfaceHelper = ""
    out.semanticSurfaceHelper = ""
    out.codegenSurfaceHelper = "cheng.codegen_surface_seed_v1"
    out.execSurfaceHelper = ""
    out.truthRuntimeHelper = "cheng.capture_truth_import_v1"
    out.nativeGuiBundleHelper = "cheng.native_gui_bundle_seed_v1"
    out.nativeGuiBundleFinalizer = "cheng_controller_native_gui_bundle_finalizer_v1"
    out.nativeGuiRuntimeHelper = ""
    out.nativeGuiRuntimeMode = "cheng_controller_compiled_json_v1"
    out.nativeGuiRunHelper = ""
    out.nativeGuiLayoutPayloadFinalizer = "cheng_controller_layout_payload_finalizer_v1"
    out.nativeGuiLayoutItemCatalogMode = "cheng_streamed_typed_layout_items_v1"
    out.nativeGuiLayoutItemCatalogPayloadProfile = "cheng_runtime_layout_item_payload_v1"
    out.renderCompareHelper = "cheng.render_compare_direct_png_v1"
    out.nativeGuiReplayHitInspectorHelper = ""
    out.execRouteMatrixHelper = "cheng.exec_route_matrix_seed_v1"
    out.truthRouteHelper = "cheng.truth_route_seed_v1"
    out.truthCompareHelper = ""
    out.truthCompareMatrixHelper = ""
    out.nativeGuiHostSource = ""
    out.nativeGuiHostSourceKind = "cheng_native_session_runner"
    out.nativeGuiHostHelpers = []
    out.legacyShellWrapper = ""
    out.legacyShellWrappers = []
    out.legacyWrapperRequired = false
    out.legacyPrototypeRequired = false
    out.compileNonChengBlockers = []
    out.guiRuntimeNonChengBlockers = []
    out.truthRuntimeNonChengBlockers = []
    out.optionalNonChengHelpers = []
    out.remainingNonChengBlockers = []
    for i in 0..<out.compileNonChengBlockers.len:
        R2cReactStatusAppendUnique(out.remainingNonChengBlockers, out.compileNonChengBlockers[i])
    for i in 0..<out.guiRuntimeNonChengBlockers.len:
        R2cReactStatusAppendUnique(out.remainingNonChengBlockers, out.guiRuntimeNonChengBlockers[i])
    for i in 0..<out.truthRuntimeNonChengBlockers.len:
        R2cReactStatusAppendUnique(out.remainingNonChengBlockers, out.truthRuntimeNonChengBlockers[i])
    for i in 0..<out.optionalNonChengHelpers.len:
        R2cReactStatusAppendUnique(out.remainingNonChengBlockers, out.optionalNonChengHelpers[i])
    out.activeNodeHelpers = []
    out.thinNodeHelpers = []
    out.retiredNodeHelpers = [
        "native_gui_run_helper",
        "native_gui_runtime_helper",
        "native_gui_replay_hit_inspector_helper",
        "semantic_surface_helper",
        "static_surface_helper",
        "exec_surface_helper",
        "truth_compare_helper",
        "truth_compare_matrix_helper",
        "truth_route_helper",
        "exec_route_matrix_helper",
        "tsx_frontend_helper",
        "render_compare_helper",
        "truth_runtime_helper"
    ]
    out.standaloneNodeHelpers = []
    out.commands = [
        "status",
        "frontend",
        "static-surface",
        "semantic-surface",
        "codegen-surface",
        "exec-surface",
        "native-gui-bundle",
        "run-native-gui",
        "render-compare",
        "render-compare-matrix",
        "replay-hit-inspector",
        "exec-route-matrix",
        "compile",
        "discover-truth-routes",
        "capture-truth",
        "compare-truth",
        "compare-truth-matrix"
    ]
    return out

fn R2cReactPureChengCompileReady(contract: R2cReactStatusContract): bool =
    return contract.compileNonChengBlockers.len == 0

fn R2cReactPureChengGuiRuntimeReady(contract: R2cReactStatusContract): bool =
    return contract.guiRuntimeNonChengBlockers.len == 0

fn R2cReactPureChengTruthRuntimeReady(contract: R2cReactStatusContract): bool =
    return contract.truthRuntimeNonChengBlockers.len == 0

fn R2cReactPureChengGuiReady(contract: R2cReactStatusContract): bool =
    return R2cReactPureChengCompileReady(contract) &&
           R2cReactPureChengGuiRuntimeReady(contract) &&
           R2cReactPureChengTruthRuntimeReady(contract)

fn R2cReactStatusReportText(workspaceRootRaw: str): str =
    let contract = R2cReactStatusContract(workspaceRootRaw)
    var report = "{\n"
    report = report + "  \"format\": \"status_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"workspace_root\": " + R2cReactStatusJsonQuote(contract.workspaceRoot) + ",\n"
    report = report + "  \"experimental_root\": " + R2cReactStatusJsonQuote(contract.experimentalRoot) + ",\n"
    report = report + "  \"node_program\": \"\",\n"
    report = report + "  \"legacy_prototype_path\": " + R2cReactStatusJsonQuote(contract.legacyPrototypePath) + ",\n"
    report = report + "  \"tsx_frontend_helper\": " + R2cReactStatusJsonQuote(contract.tsxFrontendHelper) + ",\n"
    report = report + "  \"static_surface_helper\": " + R2cReactStatusJsonQuote(contract.staticSurfaceHelper) + ",\n"
    report = report + "  \"semantic_surface_helper\": " + R2cReactStatusJsonQuote(contract.semanticSurfaceHelper) + ",\n"
    report = report + "  \"codegen_surface_helper\": " + R2cReactStatusJsonQuote(contract.codegenSurfaceHelper) + ",\n"
    report = report + "  \"exec_surface_helper\": " + R2cReactStatusJsonQuote(contract.execSurfaceHelper) + ",\n"
    report = report + "  \"truth_runtime_helper\": " + R2cReactStatusJsonQuote(contract.truthRuntimeHelper) + ",\n"
    report = report + "  \"native_gui_bundle_helper\": " + R2cReactStatusJsonQuote(contract.nativeGuiBundleHelper) + ",\n"
    report = report + "  \"native_gui_bundle_finalizer\": " + R2cReactStatusJsonQuote(contract.nativeGuiBundleFinalizer) + ",\n"
    report = report + "  \"native_gui_runtime_helper\": " + R2cReactStatusJsonQuote(contract.nativeGuiRuntimeHelper) + ",\n"
    report = report + "  \"native_gui_runtime_mode\": " + R2cReactStatusJsonQuote(contract.nativeGuiRuntimeMode) + ",\n"
    report = report + "  \"native_gui_run_helper\": " + R2cReactStatusJsonQuote(contract.nativeGuiRunHelper) + ",\n"
    report = report + "  \"native_gui_layout_payload_finalizer\": " + R2cReactStatusJsonQuote(contract.nativeGuiLayoutPayloadFinalizer) + ",\n"
    report = report + "  \"native_gui_layout_item_catalog_mode\": " + R2cReactStatusJsonQuote(contract.nativeGuiLayoutItemCatalogMode) + ",\n"
    report = report + "  \"native_gui_layout_item_catalog_payload_profile\": " + R2cReactStatusJsonQuote(contract.nativeGuiLayoutItemCatalogPayloadProfile) + ",\n"
    report = report + "  \"render_compare_helper\": " + R2cReactStatusJsonQuote(contract.renderCompareHelper) + ",\n"
    report = report + "  \"native_gui_replay_hit_inspector_helper\": " + R2cReactStatusJsonQuote(contract.nativeGuiReplayHitInspectorHelper) + ",\n"
    report = report + "  \"exec_route_matrix_helper\": " + R2cReactStatusJsonQuote(contract.execRouteMatrixHelper) + ",\n"
    report = report + "  \"truth_route_helper\": " + R2cReactStatusJsonQuote(contract.truthRouteHelper) + ",\n"
    report = report + "  \"truth_compare_helper\": " + R2cReactStatusJsonQuote(contract.truthCompareHelper) + ",\n"
    report = report + "  \"truth_compare_matrix_helper\": " + R2cReactStatusJsonQuote(contract.truthCompareMatrixHelper) + ",\n"
    report = report + "  \"node_helper_surface_mode\": \"cheng_controller_min_surface_v1\",\n"
    report = report + "  \"native_gui_host_source\": " + R2cReactStatusJsonQuote(contract.nativeGuiHostSource) + ",\n"
    report = report + "  \"native_gui_host_source_kind\": " + R2cReactStatusJsonQuote(contract.nativeGuiHostSourceKind) + ",\n"
    report = report + "  \"native_gui_host_helper_count\": " + intToStr(contract.nativeGuiHostHelpers.len) + ",\n"
    report = report + "  \"native_gui_host_helpers\": " + R2cReactStatusJsonArray(contract.nativeGuiHostHelpers) + ",\n"
    report = report + "  \"legacy_shell_wrapper\": " + R2cReactStatusJsonQuote(contract.legacyShellWrapper) + ",\n"
    report = report + "  \"legacy_shell_wrapper_count\": " + intToStr(contract.legacyShellWrappers.len) + ",\n"
    report = report + "  \"legacy_shell_wrappers\": " + R2cReactStatusJsonArray(contract.legacyShellWrappers) + ",\n"
    report = report + "  \"legacy_wrapper_required\": " + R2cReactStatusBoolText(contract.legacyWrapperRequired) + ",\n"
    report = report + "  \"legacy_prototype_required\": " + R2cReactStatusBoolText(contract.legacyPrototypeRequired) + ",\n"
    report = report + "  \"pure_cheng_compile_ready\": " + R2cReactStatusBoolText(R2cReactPureChengCompileReady(contract)) + ",\n"
    report = report + "  \"pure_cheng_gui_runtime_ready\": " + R2cReactStatusBoolText(R2cReactPureChengGuiRuntimeReady(contract)) + ",\n"
    report = report + "  \"pure_cheng_truth_runtime_ready\": " + R2cReactStatusBoolText(R2cReactPureChengTruthRuntimeReady(contract)) + ",\n"
    report = report + "  \"pure_cheng_gui_ready\": " + R2cReactStatusBoolText(R2cReactPureChengGuiReady(contract)) + ",\n"
    report = report + "  \"compile_non_cheng_blocker_count\": " + intToStr(contract.compileNonChengBlockers.len) + ",\n"
    report = report + "  \"compile_non_cheng_blockers\": " + R2cReactStatusJsonArray(contract.compileNonChengBlockers) + ",\n"
    report = report + "  \"gui_runtime_non_cheng_blocker_count\": " + intToStr(contract.guiRuntimeNonChengBlockers.len) + ",\n"
    report = report + "  \"gui_runtime_non_cheng_blockers\": " + R2cReactStatusJsonArray(contract.guiRuntimeNonChengBlockers) + ",\n"
    report = report + "  \"truth_runtime_non_cheng_blocker_count\": " + intToStr(contract.truthRuntimeNonChengBlockers.len) + ",\n"
    report = report + "  \"truth_runtime_non_cheng_blockers\": " + R2cReactStatusJsonArray(contract.truthRuntimeNonChengBlockers) + ",\n"
    report = report + "  \"optional_non_cheng_helper_count\": " + intToStr(contract.optionalNonChengHelpers.len) + ",\n"
    report = report + "  \"optional_non_cheng_helpers\": " + R2cReactStatusJsonArray(contract.optionalNonChengHelpers) + ",\n"
    report = report + "  \"remaining_non_cheng_blocker_count\": " + intToStr(contract.remainingNonChengBlockers.len) + ",\n"
    report = report + "  \"remaining_non_cheng_blockers\": " + R2cReactStatusJsonArray(contract.remainingNonChengBlockers) + ",\n"
    report = report + "  \"active_node_helper_count\": " + intToStr(contract.activeNodeHelpers.len) + ",\n"
    report = report + "  \"thin_node_helper_count\": " + intToStr(contract.thinNodeHelpers.len) + ",\n"
    report = report + "  \"retired_node_helper_count\": " + intToStr(contract.retiredNodeHelpers.len) + ",\n"
    report = report + "  \"retired_node_helpers\": " + R2cReactStatusJsonArray(contract.retiredNodeHelpers) + ",\n"
    report = report + "  \"standalone_node_helper_count\": " + intToStr(contract.standaloneNodeHelpers.len) + ",\n"
    report = report + "  \"standalone_node_helpers\": " + R2cReactStatusJsonArray(contract.standaloneNodeHelpers) + ",\n"
    report = report + "  \"active_node_helpers\": " + R2cReactStatusJsonArray(contract.activeNodeHelpers) + ",\n"
    report = report + "  \"thin_node_helpers\": " + R2cReactStatusJsonArray(contract.thinNodeHelpers) + ",\n"
    report = report + "  \"commands\": " + R2cReactStatusJsonArray(contract.commands) + "\n"
    report = report + "}\n"
    return report

fn R2cReactWriteStatusReport(reportPath: str,
                                 workspaceRootRaw: str): bool =
    let report = R2cReactStatusReportText(workspaceRootRaw)
    return chengpath.WriteTextFile("", reportPath, report)

