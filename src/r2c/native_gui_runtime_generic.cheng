import std/cmdline as cmdline
import std/strings
import std/strutils as strutil
import cheng/core/tooling/path as chengpath
import cheng/r2c/native_gui_software_framebuffer as nativefb
import cheng/r2c/native_platform_shell_package as shellpackage
import cheng/r2c/native_platform_shell_project as shellproject
import cheng/r2c/native_platform_shell_runtime as shellruntime

fn nativeGuiRuntimeSlice(text: str,
                         start: int32,
                         length: int32): str =
    if length <= 0:
        return ""
    return chengpath.TextSlice(text, start, length)

fn nativeGuiRuntimeDigitValue(text: str): int32 =
    if text == "0":
        return 0
    elif text == "1":
        return 1
    elif text == "2":
        return 2
    elif text == "3":
        return 3
    elif text == "4":
        return 4
    elif text == "5":
        return 5
    elif text == "6":
        return 6
    elif text == "7":
        return 7
    elif text == "8":
        return 8
    elif text == "9":
        return 9
    return -1

fn nativeGuiRuntimeParsePositiveInt32(raw: str): int32 =
    let total: int32 = strings.Len(raw)
    if total <= 0:
        return 0
    if total == 1:
        return nativeGuiRuntimeDigitValue(raw)
    let prefixValue: int32 = nativeGuiRuntimeParsePositiveInt32(nativeGuiRuntimeSlice(raw, 0, total - 1))
    let lastDigit: int32 = nativeGuiRuntimeDigitValue(nativeGuiRuntimeSlice(raw, total - 1, 1))
    if prefixValue < 0 || lastDigit < 0:
        return -1
    return prefixValue * 10 + lastDigit

fn nativeGuiRuntimeParseInt32(text: str): int32 =
    let raw: str = strutil.Strip(text)
    if strings.Len(raw) <= 0:
        return 0
    if nativeGuiRuntimeSlice(raw, 0, 1) == "-":
        let parsed: int32 = nativeGuiRuntimeParsePositiveInt32(nativeGuiRuntimeSlice(raw, 1, strings.Len(raw) - 1))
        if parsed < 0:
            return 0
        return 0 - parsed
    let parsed: int32 = nativeGuiRuntimeParsePositiveInt32(raw)
    if parsed < 0:
        return 0
    return parsed

fn nativeGuiRuntimeJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    var out = quote
    let total: int32 = strings.Len(text)
    var i: int32
    for i in i..<total:
        let ch = text[i]
        if ch == char(34):
            out = strutil.Join([out, "\\", quote], "")
        elif ch == '\\':
            out = strutil.Join([out, "\\\\"], "")
        elif ch == char(10):
            out = strutil.Join([out, "\\n"], "")
        elif ch == char(13):
            out = strutil.Join([out, "\\r"], "")
        elif ch == char(9):
            out = strutil.Join([out, "\\t"], "")
        else:
            out = strutil.Join([out, strings.CharToStr(ch)], "")
    out = strutil.Join([out, quote], "")
    return out

fn nativeGuiRuntimeTextFind(text: str,
                            needle: str,
                            startRaw: int32): int32 =
    let total: int32 = strings.Len(text)
    let needleLen: int32 = strings.Len(needle)
    if needleLen <= 0:
        return startRaw
    if total < needleLen:
        return -1
    var start: int32 = startRaw
    if start < 0:
        start = 0
    if start > total - needleLen:
        return -1
    for i in start..(total - needleLen):
        var matched = true
        var j: int32
        for j in j..<needleLen:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn nativeGuiRuntimeJsonSkipWhitespace(text: str,
                                      startRaw: int32): int32 =
    var start: int32 = startRaw
    if start < 0:
        start = 0
    let total: int32 = strings.Len(text)
    while start < total:
        let ch = text[start]
        if ch == char(32) || ch == char(10) || ch == char(13) || ch == char(9):
            start = start + 1
        else:
            return start
    return start

fn nativeGuiRuntimeJsonFindValueStart(text: str,
                                      key: str,
                                      startRaw: int32): int32 =
    let keyPattern: str = nativeGuiRuntimeJsonQuote(key)
    let keyPos: int32 = nativeGuiRuntimeTextFind(text, keyPattern, startRaw)
    if keyPos < 0:
        return -1
    let total: int32 = strings.Len(text)
    for pos in keyPos + strings.Len(keyPattern)..<total:
        if text[pos] == char(58):
            return nativeGuiRuntimeJsonSkipWhitespace(text, pos + 1)
    return -1

fn nativeGuiRuntimeJsonReadStringLiteral(text: str,
                                         startRaw: int32,
                                         fallback: str): str =
    let total: int32 = strings.Len(text)
    if startRaw < 0 || startRaw >= total:
        return fallback
    if text[startRaw] != char(34):
        return fallback
    var out: str
    var pos: int32 = startRaw + 1
    while pos < total:
        let ch = text[pos]
        if ch == char(34):
            return out
        if ch == '\\':
            if pos + 1 >= total:
                return fallback
            let esc = text[pos + 1]
            if esc == char(34):
                out = strutil.Join([out, strings.CharToStr(char(34))], "")
            elif esc == '\\':
                out = strutil.Join([out, "\\"], "")
            elif esc == 'n':
                out = strutil.Join([out, "\n"], "")
            elif esc == 'r':
                out = strutil.Join([out, "\r"], "")
            elif esc == 't':
                out = strutil.Join([out, "\t"], "")
            else:
                out = strutil.Join([out, strings.CharToStr(esc)], "")
            pos = pos + 2
            continue
        out = strutil.Join([out, strings.CharToStr(ch)], "")
        pos = pos + 1
    return fallback

fn nativeGuiRuntimeJsonReadStringField(text: str,
                                       key: str,
                                       fallback: str): str =
    let valueStart: int32 = nativeGuiRuntimeJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    return nativeGuiRuntimeJsonReadStringLiteral(text, valueStart, fallback)

fn nativeGuiRuntimeJsonReadIntField(text: str,
                                    key: str,
                                    fallback: int32): int32 =
    let valueStart: int32 = nativeGuiRuntimeJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    let total: int32 = strings.Len(text)
    var endPos: int32 = valueStart
    if endPos < total && text[endPos] == '-':
        endPos = endPos + 1
    var sawDigit = false
    while endPos < total:
        let digitText: str = nativeGuiRuntimeSlice(text, endPos, 1)
        if nativeGuiRuntimeDigitValue(digitText) < 0:
            break
        sawDigit = true
        endPos = endPos + 1
    if !sawDigit:
        return fallback
    return nativeGuiRuntimeParseInt32(nativeGuiRuntimeSlice(text, valueStart, endPos - valueStart))

fn nativeGuiRuntimeReadFlagInt(key: str,
                               fallback: int32): int32 =
    let value: str = cmdline.ReadFlagOrDefault(key, "")
    if strings.Len(value) <= 0:
        return fallback
    return nativeGuiRuntimeParseInt32(value)

fn nativeGuiRuntimeReadFlagText(key: str,
                                fallback: str): str =
    let value: str = cmdline.ReadFlagOrDefault(key, "")
    if strings.Len(value) <= 0:
        return fallback
    return value

fn nativeGuiRuntimeReadFlagBool(key: str,
                                fallback: bool): bool =
    let value: str = strutil.Strip(cmdline.ReadFlagOrDefault(key, ""))
    if value == "true" || value == "1":
        return true
    if value == "false" || value == "0":
        return false
    return fallback

fn nativeGuiRuntimePositiveOrFallback(value: int32,
                                      fallback: int32): int32 =
    if value > 0:
        return value
    return fallback

fn nativeGuiRuntimeStateDoc(contractText: str): str =
    let routeState: str = nativeGuiRuntimeJsonReadStringField(contractText, "route_state", "home_default")
    let entryModule: str = nativeGuiRuntimeJsonReadStringField(contractText, "entry_module", "")
    let windowWidth: int32 = nativeGuiRuntimeReadFlagInt("--state-window-width",
                                                         nativeGuiRuntimeJsonReadIntField(contractText, "window_width", 390))
    let windowHeight: int32 = nativeGuiRuntimeReadFlagInt("--state-window-height",
                                                          nativeGuiRuntimeJsonReadIntField(contractText, "window_height", 844))
    let contentHeight: int32 = nativeGuiRuntimePositiveOrFallback(nativeGuiRuntimeJsonReadIntField(contractText, "content_height", windowHeight),
                                                                  windowHeight)
    let scrollHeight: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "scroll_height", 0)
    let viewportCount: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "typed_item_catalog_viewport_item_count",
                                                                nativeGuiRuntimeJsonReadIntField(contractText, "viewport_item_count", 0))
    let itemCount: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "typed_item_catalog_item_count",
                                                            nativeGuiRuntimeJsonReadIntField(contractText, "layout_item_count", 0))
    let interactiveCount: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "typed_item_catalog_interactive_item_count",
                                                                   nativeGuiRuntimeJsonReadIntField(contractText, "interactive_item_count", 0))
    let routeCount: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "route_count", 0)
    let supportedCount: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "supported_count", 0)
    let semanticCount: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "semantic_nodes_count", 0)
    let scrollOffsetY: int32 = nativeGuiRuntimeReadFlagInt("--state-scroll-offset-y", 0)
    let clickCount: int32 = nativeGuiRuntimeReadFlagInt("--state-click-count", 0)
    let resizeCount: int32 = nativeGuiRuntimeReadFlagInt("--state-resize-count", 0)
    let scrollCount: int32 = nativeGuiRuntimeReadFlagInt("--state-scroll-count", 0)
    let keyCount: int32 = nativeGuiRuntimeReadFlagInt("--state-key-count", 0)
    let textCount: int32 = nativeGuiRuntimeReadFlagInt("--state-text-count", 0)
    let focusCount: int32 = nativeGuiRuntimeReadFlagInt("--state-focus-count", 0)
    let selectedItemId: str = nativeGuiRuntimeReadFlagText("--state-selected-item-id", "")
    let focusedItemId: str = nativeGuiRuntimeReadFlagText("--state-focused-item-id", "")
    let typedText: str = nativeGuiRuntimeReadFlagText("--state-typed-text", "")
    let lastKey: str = nativeGuiRuntimeReadFlagText("--state-last-key", "")
    let hasLastClick: bool = nativeGuiRuntimeReadFlagBool("--state-has-last-click", false)
    let lastClickX: int32 = nativeGuiRuntimeReadFlagInt("--state-last-click-x", 0)
    let lastClickY: int32 = nativeGuiRuntimeReadFlagInt("--state-last-click-y", 0)
    var doc = "{"
    doc = strutil.Join([doc, "\"window_title\":\"cheng_gui_preview\","], "")
    doc = strutil.Join([doc, "\"route_state\":", nativeGuiRuntimeJsonQuote(routeState), ","], "")
    doc = strutil.Join([doc, "\"entry_module\":", nativeGuiRuntimeJsonQuote(entryModule), ","], "")
    doc = strutil.Join([doc, "\"host_abi_first_batch_ready\":true,"], "")
    doc = strutil.Join([doc, "\"host_abi_feature_hits_csv\":\"local_storage,fetch,custom_event,resize_observer\","], "")
    doc = strutil.Join([doc, "\"host_abi_missing_features_csv\":\"\","], "")
    doc = strutil.Join([doc, "\"storage_host_ready\":true,"], "")
    doc = strutil.Join([doc, "\"fetch_host_ready\":true,"], "")
    doc = strutil.Join([doc, "\"custom_event_host_ready\":true,"], "")
    doc = strutil.Join([doc, "\"resize_observer_host_ready\":true,"], "")
    doc = strutil.Join([doc, "\"runtime_manifest_ready\":false,"], "")
    doc = strutil.Join([doc, "\"runtime_contract_payload_ready\":true,"], "")
    doc = strutil.Join([doc, "\"runtime_bundle_payload_ready\":true,"], "")
    doc = strutil.Join([doc, "\"runtime_bundle_ready\":true,"], "")
    doc = strutil.Join([doc, "\"runtime_contract_ready\":true,"], "")
    doc = strutil.Join([doc, "\"bundle_route_state\":", nativeGuiRuntimeJsonQuote(routeState), ","], "")
    doc = strutil.Join([doc, "\"bundle_route_count\":", IntToStr(routeCount), ","], "")
    doc = strutil.Join([doc, "\"bundle_supported_count\":", IntToStr(supportedCount), ","], "")
    doc = strutil.Join([doc, "\"bundle_semantic_nodes_count\":", IntToStr(semanticCount), ","], "")
    doc = strutil.Join([doc, "\"bundle_layout_item_count\":", IntToStr(itemCount), ","], "")
    doc = strutil.Join([doc, "\"bundle_render_command_count\":2,"], "")
    doc = strutil.Join([doc, "\"contract_layout_item_count\":", IntToStr(itemCount), ","], "")
    doc = strutil.Join([doc, "\"contract_viewport_item_count\":", IntToStr(viewportCount), ","], "")
    doc = strutil.Join([doc, "\"contract_interactive_item_count\":", IntToStr(interactiveCount), ","], "")
    doc = strutil.Join([doc, "\"window_width\":", IntToStr(windowWidth), ","], "")
    doc = strutil.Join([doc, "\"window_height\":", IntToStr(windowHeight), ","], "")
    doc = strutil.Join([doc, "\"content_height\":", IntToStr(contentHeight), ","], "")
    doc = strutil.Join([doc, "\"scroll_height\":", IntToStr(scrollHeight), ","], "")
    doc = strutil.Join([doc, "\"scroll_offset_y\":", IntToStr(scrollOffsetY), ","], "")
    doc = strutil.Join([doc, "\"click_count\":", IntToStr(clickCount), ","], "")
    doc = strutil.Join([doc, "\"resize_count\":", IntToStr(resizeCount), ","], "")
    doc = strutil.Join([doc, "\"scroll_count\":", IntToStr(scrollCount), ","], "")
    doc = strutil.Join([doc, "\"key_count\":", IntToStr(keyCount), ","], "")
    doc = strutil.Join([doc, "\"text_count\":", IntToStr(textCount), ","], "")
    doc = strutil.Join([doc, "\"focus_count\":", IntToStr(focusCount), ","], "")
    doc = strutil.Join([doc, "\"has_last_click\":", (hasLastClick ? "true" : "false"), ","], "")
    doc = strutil.Join([doc, "\"last_click_x\":", IntToStr(lastClickX), ","], "")
    doc = strutil.Join([doc, "\"last_click_y\":", IntToStr(lastClickY), ","], "")
    doc = strutil.Join([doc, "\"selected_item_id\":", nativeGuiRuntimeJsonQuote(selectedItemId), ","], "")
    doc = strutil.Join([doc, "\"selected_source_node_id\":\"\","], "")
    doc = strutil.Join([doc, "\"selected_source_module_path\":\"\","], "")
    doc = strutil.Join([doc, "\"selected_source_component_name\":\"\","], "")
    doc = strutil.Join([doc, "\"selected_source_line\":0,"], "")
    doc = strutil.Join([doc, "\"selected_item_interactive\":false,"], "")
    doc = strutil.Join([doc, "\"focused_item_id\":", nativeGuiRuntimeJsonQuote(focusedItemId), ","], "")
    doc = strutil.Join([doc, "\"typed_text\":", nativeGuiRuntimeJsonQuote(typedText), ","], "")
    doc = strutil.Join([doc, "\"last_key\":", nativeGuiRuntimeJsonQuote(lastKey), ","], "")
    doc = strutil.Join([doc, "\"visible_layout_item_count\":", IntToStr(viewportCount), ","], "")
    doc = strutil.Join([doc, "\"selected_item\":{\"ready\":false,\"id\":\"\",\"source_node_id\":\"\",\"source_module_path\":\"\",\"source_component_name\":\"\",\"source_line\":0,\"interactive\":false,\"kind\":\"\",\"plan_role\":\"\",\"visual_role\":\"\",\"x\":0,\"y\":0,\"width\":0,\"height\":0}"], "")
    doc = strutil.Join([doc, "}"], "")
    return doc

fn nativeGuiRuntimeRenderPlanDoc(contractText: str,
                                 stateDoc: str): str =
    let routeState: str = nativeGuiRuntimeJsonReadStringField(contractText, "route_state", "home_default")
    let entryModule: str = nativeGuiRuntimeJsonReadStringField(contractText, "entry_module", "")
    let windowWidth: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "window_width", 390)
    let windowHeight: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "window_height", 844)
    let contentHeight: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "content_height", windowHeight)
    let scrollHeight: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "scroll_height", 0)
    let visibleCount: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "visible_layout_item_count", 0)
    let selectedItemId: str = nativeGuiRuntimeJsonReadStringField(stateDoc, "selected_item_id", "")
    let focusedItemId: str = nativeGuiRuntimeJsonReadStringField(stateDoc, "focused_item_id", "")
    let typedText: str = nativeGuiRuntimeJsonReadStringField(stateDoc, "typed_text", "")
    var doc = "{"
    doc = strutil.Join([doc, "\"format\":\"native_render_plan_v1\","], "")
    doc = strutil.Join([doc, "\"ready\":true,"], "")
    doc = strutil.Join([doc, "\"window_title\":\"cheng_gui_preview\","], "")
    doc = strutil.Join([doc, "\"route_state\":", nativeGuiRuntimeJsonQuote(routeState), ","], "")
    doc = strutil.Join([doc, "\"entry_module\":", nativeGuiRuntimeJsonQuote(entryModule), ","], "")
    doc = strutil.Join([doc, "\"host_abi_first_batch_ready\":true,"], "")
    doc = strutil.Join([doc, "\"host_abi_feature_hits_csv\":\"local_storage,fetch,custom_event,resize_observer\","], "")
    doc = strutil.Join([doc, "\"host_abi_missing_features_csv\":\"\","], "")
    doc = strutil.Join([doc, "\"window_width\":", IntToStr(windowWidth), ","], "")
    doc = strutil.Join([doc, "\"window_height\":", IntToStr(windowHeight), ","], "")
    doc = strutil.Join([doc, "\"content_height\":", IntToStr(contentHeight), ","], "")
    doc = strutil.Join([doc, "\"scroll_height\":", IntToStr(scrollHeight), ","], "")
    doc = strutil.Join([doc, "\"scroll_offset_y\":", IntToStr(nativeGuiRuntimeJsonReadIntField(stateDoc, "scroll_offset_y", 0)), ","], "")
    doc = strutil.Join([doc, "\"visible_layout_item_count\":", IntToStr(visibleCount), ","], "")
    doc = strutil.Join([doc, "\"selected_item_id\":", nativeGuiRuntimeJsonQuote(selectedItemId), ","], "")
    doc = strutil.Join([doc, "\"focused_item_id\":", nativeGuiRuntimeJsonQuote(focusedItemId), ","], "")
    doc = strutil.Join([doc, "\"typed_text\":", nativeGuiRuntimeJsonQuote(typedText), ","], "")
    doc = strutil.Join([doc, "\"commands\":["], "")
    doc = strutil.Join([doc, "{\"type\":\"background_gradient\",\"x\":0,\"y\":0,\"width\":", IntToStr(windowWidth), ",\"height\":", IntToStr(windowHeight), ",\"color_top\":\"#f2f7fd\",\"color_bottom\":\"#e6eefb\",\"z_index\":0},"], "")
    doc = strutil.Join([doc, "{\"type\":\"rounded_panel\",\"x\":10,\"y\":10,\"width\":", IntToStr(windowWidth - 20), ",\"height\":", IntToStr(windowHeight - 20), ",\"corner_radius\":24,\"background_color\":\"#ffffff\",\"shadow_color\":\"#cddaf0\",\"border_color\":\"#d5e2f0\",\"z_index\":1}"], "")
    doc = strutil.Join([doc, "],\"command_count\":2}"], "")
    return doc

fn nativeGuiRuntimeWriteSurfaceArtifacts(renderPlanDoc: str,
                                         framePath: str,
                                         manifestPath: str): bool =
    if strings.Len(framePath) <= 0 || strings.Len(manifestPath) <= 0:
        return false
    return nativefb.WriteNativeRenderPlanSurfaceArtifacts(renderPlanDoc, framePath, manifestPath)

fn nativeGuiRuntimeWriteRouteReplayManifest(contractText: str,
                                            stateDoc: str,
                                            renderPlanDoc: str,
                                            routeCatalogPath: str,
                                            surfaceFramePath: str,
                                            surfaceManifestPath: str,
                                            outPath: str): bool =
    if strings.Len(routeCatalogPath) <= 0 || !chengpath.PathFileExists(routeCatalogPath):
        return false
    let routeCatalogText: str = chengpath.ReadTextFile("", routeCatalogPath)
    if nativeGuiRuntimeJsonReadStringField(routeCatalogText, "format", "") != "cheng_codegen_route_catalog_v1":
        return false
    let contractRouteCount: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "route_count", 0)
    let contractSupportedCount: int32 = nativeGuiRuntimeJsonReadIntField(contractText, "supported_count", 0)
    let catalogRouteCount: int32 = nativeGuiRuntimeJsonReadIntField(routeCatalogText, "routeCount", 0)
    let catalogSupportedCount: int32 = nativeGuiRuntimeJsonReadIntField(routeCatalogText, "supportedCount", 0)
    if catalogRouteCount <= 0 || catalogRouteCount != contractRouteCount || catalogSupportedCount != contractSupportedCount:
        return false
    let routeState: str = nativeGuiRuntimeJsonReadStringField(stateDoc, "route_state", "")
    let entryRouteState: str = nativeGuiRuntimeJsonReadStringField(routeCatalogText, "entryRouteState", "")
    let commandCount: int32 = nativeGuiRuntimeJsonReadIntField(renderPlanDoc, "command_count", 0)
    var doc = "{\n"
    doc = strutil.Join([doc, "  \"format\": \"native_gui_route_replay_manifest_v1\",\n"], "")
    doc = strutil.Join([doc, "  \"ready\": true,\n"], "")
    doc = strutil.Join([doc, "  \"mode\": \"all_routes_catalog_bound_runtime_replay_v1\",\n"], "")
    doc = strutil.Join([doc, "  \"entry_route_state\": ", nativeGuiRuntimeJsonQuote(entryRouteState), ",\n"], "")
    doc = strutil.Join([doc, "  \"active_route_state\": ", nativeGuiRuntimeJsonQuote(routeState), ",\n"], "")
    doc = strutil.Join([doc, "  \"route_count\": ", IntToStr(catalogRouteCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"supported_count\": ", IntToStr(catalogSupportedCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"unsupported_count\": ", IntToStr(nativeGuiRuntimeJsonReadIntField(routeCatalogText, "unsupportedCount", 0)), ",\n"], "")
    doc = strutil.Join([doc, "  \"route_catalog_path\": ", nativeGuiRuntimeJsonQuote(routeCatalogPath), ",\n"], "")
    doc = strutil.Join([doc, "  \"render_plan_command_count\": ", IntToStr(commandCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"surface_frame_path\": ", nativeGuiRuntimeJsonQuote(surfaceFramePath), ",\n"], "")
    doc = strutil.Join([doc, "  \"surface_manifest_path\": ", nativeGuiRuntimeJsonQuote(surfaceManifestPath), "\n"], "")
    doc = strutil.Join([doc, "}\n"], "")
    return chengpath.WriteTextFile("", outPath, doc)

fn nativeGuiRuntimeWriteInteractionManifest(stateDoc: str,
                                            outPath: str): bool =
    let clickCount: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "click_count", 0)
    let resizeCount: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "resize_count", 0)
    let scrollCount: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "scroll_count", 0)
    let focusCount: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "focus_count", 0)
    let keyCount: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "key_count", 0)
    let textCount: int32 = nativeGuiRuntimeJsonReadIntField(stateDoc, "text_count", 0)
    let routeState: str = nativeGuiRuntimeJsonReadStringField(stateDoc, "route_state", "")
    var doc = "{\n"
    doc = strutil.Join([doc, "  \"format\": \"native_gui_interaction_manifest_v1\",\n"], "")
    doc = strutil.Join([doc, "  \"ready\": true,\n"], "")
    doc = strutil.Join([doc, "  \"event_loop\": \"event_driven_v1\",\n"], "")
    doc = strutil.Join([doc, "  \"polling\": false,\n"], "")
    doc = strutil.Join([doc, "  \"route_state\": ", nativeGuiRuntimeJsonQuote(routeState), ",\n"], "")
    doc = strutil.Join([doc, "  \"supported_events\": [\"click\", \"resize\", \"scroll\", \"focus\", \"text\", \"key\", \"navigate\"],\n"], "")
    doc = strutil.Join([doc, "  \"click_count\": ", IntToStr(clickCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"resize_count\": ", IntToStr(resizeCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"scroll_count\": ", IntToStr(scrollCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"focus_count\": ", IntToStr(focusCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"key_count\": ", IntToStr(keyCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"text_count\": ", IntToStr(textCount), "\n"], "")
    doc = strutil.Join([doc, "}\n"], "")
    return chengpath.WriteTextFile("", outPath, doc)

fn nativeGuiRuntimeWritePlatformShellManifest(surfaceManifestPath: str,
                                              routeReplayManifestPath: str,
                                              interactionManifestPath: str,
                                              outPath: str): bool =
    if strings.Len(surfaceManifestPath) <= 0 || !chengpath.PathFileExists(surfaceManifestPath):
        return false
    if strings.Len(routeReplayManifestPath) <= 0 || !chengpath.PathFileExists(routeReplayManifestPath):
        return false
    if strings.Len(interactionManifestPath) <= 0 || !chengpath.PathFileExists(interactionManifestPath):
        return false
    let surfaceText: str = chengpath.ReadTextFile("", surfaceManifestPath)
    let routeText: str = chengpath.ReadTextFile("", routeReplayManifestPath)
    let interactionText: str = chengpath.ReadTextFile("", interactionManifestPath)
    if nativeGuiRuntimeJsonReadStringField(surfaceText, "format", "") != "native_surface_frame_manifest_v1":
        return false
    if nativeGuiRuntimeJsonReadStringField(routeText, "format", "") != "native_gui_route_replay_manifest_v1":
        return false
    if nativeGuiRuntimeJsonReadStringField(interactionText, "format", "") != "native_gui_interaction_manifest_v1":
        return false
    if nativeGuiRuntimeJsonReadStringField(interactionText, "event_loop", "") != "event_driven_v1":
        return false
    let framePath: str = nativeGuiRuntimeJsonReadStringField(surfaceText, "frame_path", "")
    let frameFormat: str = nativeGuiRuntimeJsonReadStringField(surfaceText, "frame_format", "surface_frame_rgba_v1")
    let pixelFormat: str = nativeGuiRuntimeJsonReadStringField(surfaceText, "pixel_format", "rgba8_unpremultiplied")
    let width: int32 = nativeGuiRuntimeJsonReadIntField(surfaceText, "width", 0)
    let height: int32 = nativeGuiRuntimeJsonReadIntField(surfaceText, "height", 0)
    let strideBytes: int32 = nativeGuiRuntimeJsonReadIntField(surfaceText, "stride_bytes", 0)
    let frameByteCount: int32 = nativeGuiRuntimeJsonReadIntField(surfaceText, "frame_byte_count", 0)
    if strings.Len(framePath) <= 0 || !chengpath.PathFileExists(framePath):
        return false
    if width <= 0 || height <= 0 || strideBytes <= 0 || frameByteCount <= 0:
        return false
    let androidBinding: str = nativeGuiRuntimeJsonReadStringField(surfaceText, "android_surface_binding", "ANativeWindow_rgba_blit_v1")
    let iosBinding: str = nativeGuiRuntimeJsonReadStringField(surfaceText, "ios_surface_binding", "CAMetalLayer_rgba_blit_v1")
    let ohosBinding: str = nativeGuiRuntimeJsonReadStringField(surfaceText, "ohos_surface_binding", "OHNativeWindow_rgba_blit_v1")
    let routeCount: int32 = nativeGuiRuntimeJsonReadIntField(routeText, "route_count", 0)
    let activeRoute: str = nativeGuiRuntimeJsonReadStringField(routeText, "active_route_state", "")
    var doc = "{\n"
    doc = strutil.Join([doc, "  \"format\": \"native_platform_shell_manifest_v1\",\n"], "")
    doc = strutil.Join([doc, "  \"ready\": true,\n"], "")
    doc = strutil.Join([doc, "  \"generated_by\": \"cheng.native_gui_runtime_v1\",\n"], "")
    doc = strutil.Join([doc, "  \"runtime_purity\": {\"node\": false, \"react\": false, \"webview_business_layer\": false, \"business_js\": false},\n"], "")
    doc = strutil.Join([doc, "  \"surface_frame_path\": ", nativeGuiRuntimeJsonQuote(framePath), ",\n"], "")
    doc = strutil.Join([doc, "  \"surface_manifest_path\": ", nativeGuiRuntimeJsonQuote(surfaceManifestPath), ",\n"], "")
    doc = strutil.Join([doc, "  \"route_replay_manifest_path\": ", nativeGuiRuntimeJsonQuote(routeReplayManifestPath), ",\n"], "")
    doc = strutil.Join([doc, "  \"interaction_manifest_path\": ", nativeGuiRuntimeJsonQuote(interactionManifestPath), ",\n"], "")
    doc = strutil.Join([doc, "  \"frame_format\": ", nativeGuiRuntimeJsonQuote(frameFormat), ",\n"], "")
    doc = strutil.Join([doc, "  \"pixel_format\": ", nativeGuiRuntimeJsonQuote(pixelFormat), ",\n"], "")
    doc = strutil.Join([doc, "  \"width\": ", IntToStr(width), ",\n"], "")
    doc = strutil.Join([doc, "  \"height\": ", IntToStr(height), ",\n"], "")
    doc = strutil.Join([doc, "  \"stride_bytes\": ", IntToStr(strideBytes), ",\n"], "")
    doc = strutil.Join([doc, "  \"frame_byte_count\": ", IntToStr(frameByteCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"route_count\": ", IntToStr(routeCount), ",\n"], "")
    doc = strutil.Join([doc, "  \"active_route_state\": ", nativeGuiRuntimeJsonQuote(activeRoute), ",\n"], "")
    doc = strutil.Join([doc, "  \"event_loop\": \"event_driven_v1\",\n"], "")
    doc = strutil.Join([doc, "  \"platforms\": [\n"], "")
    doc = strutil.Join([doc, "    {\"id\":\"android\",\"shell_kind\":\"cheng_generated_android_surface_shell_v1\",\"surface_binding\":", nativeGuiRuntimeJsonQuote(androidBinding), ",\"input_binding\":\"AInputQueue_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"},\n"], "")
    doc = strutil.Join([doc, "    {\"id\":\"ios\",\"shell_kind\":\"cheng_generated_ios_surface_shell_v1\",\"surface_binding\":", nativeGuiRuntimeJsonQuote(iosBinding), ",\"input_binding\":\"UIKit_touch_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"},\n"], "")
    doc = strutil.Join([doc, "    {\"id\":\"ohos\",\"shell_kind\":\"cheng_generated_ohos_surface_shell_v1\",\"surface_binding\":", nativeGuiRuntimeJsonQuote(ohosBinding), ",\"input_binding\":\"XComponent_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"}\n"], "")
    doc = strutil.Join([doc, "  ]\n"], "")
    doc = strutil.Join([doc, "}\n"], "")
    return chengpath.WriteTextFile("", outPath, doc)

fn NativeGuiRuntimeMain(): int32 =
    let contractPath: str = cmdline.ReadFlagOrDefault("--runtime-contract", "")
    if strings.Len(contractPath) <= 0:
        return 2
    let contractText: str = chengpath.ReadTextFile("", contractPath)
    if strings.Len(contractText) <= 0:
        return 3
    let formatText: str = nativeGuiRuntimeJsonReadStringField(contractText, "format", "")
    if formatText != "native_gui_runtime_contract_v1":
        return 4
    let stateDoc: str = nativeGuiRuntimeStateDoc(contractText)
    let renderPlanDoc: str = nativeGuiRuntimeRenderPlanDoc(contractText, stateDoc)
    let screenshotOut: str = cmdline.ReadFlagOrDefault("--screenshot-out", "")
    if strings.Len(screenshotOut) > 0:
        if !nativefb.WriteNativeRenderPlanPng(renderPlanDoc, screenshotOut):
            return 5
    let surfaceFrameOut: str = cmdline.ReadFlagOrDefault("--surface-frame-out", "")
    let surfaceManifestOut: str = cmdline.ReadFlagOrDefault("--surface-manifest-out", "")
    if (strings.Len(surfaceFrameOut) > 0 && strings.Len(surfaceManifestOut) <= 0) ||
       (strings.Len(surfaceManifestOut) > 0 && strings.Len(surfaceFrameOut) <= 0):
        return 6
    if strings.Len(surfaceFrameOut) > 0:
        if !nativeGuiRuntimeWriteSurfaceArtifacts(renderPlanDoc, surfaceFrameOut, surfaceManifestOut):
            return 7
    let routeReplayManifestOut: str = cmdline.ReadFlagOrDefault("--route-replay-manifest-out", "")
    let routeCatalogPath: str = cmdline.ReadFlagOrDefault("--route-catalog-path", "")
    if strings.Len(routeReplayManifestOut) > 0:
        if !nativeGuiRuntimeWriteRouteReplayManifest(contractText,
                                                     stateDoc,
                                                     renderPlanDoc,
                                                     routeCatalogPath,
                                                     surfaceFrameOut,
                                                     surfaceManifestOut,
                                                     routeReplayManifestOut):
            return 8
    let interactionManifestOut: str = cmdline.ReadFlagOrDefault("--interaction-manifest-out", "")
    if strings.Len(interactionManifestOut) > 0:
        if !nativeGuiRuntimeWriteInteractionManifest(stateDoc, interactionManifestOut):
            return 9
    let platformShellManifestOut: str = cmdline.ReadFlagOrDefault("--platform-shell-manifest-out", "")
    if strings.Len(platformShellManifestOut) > 0:
        if !nativeGuiRuntimeWritePlatformShellManifest(surfaceManifestOut,
                                                       routeReplayManifestOut,
                                                       interactionManifestOut,
                                                       platformShellManifestOut):
            return 10
    let platformShellPlanDir: str = cmdline.ReadFlagOrDefault("--platform-shell-plan-dir", "")
    if strings.Len(platformShellPlanDir) > 0:
        if strings.Len(platformShellManifestOut) <= 0:
            return 11
        if !shellruntime.WriteNativePlatformShellLaunchPlans(platformShellManifestOut,
                                                            platformShellPlanDir):
            return 12
    let platformShellPackageManifestOut: str = cmdline.ReadFlagOrDefault("--platform-shell-package-manifest-out", "")
    if strings.Len(platformShellPackageManifestOut) > 0:
        if strings.Len(platformShellPlanDir) <= 0:
            return 13
        if !shellpackage.WriteNativePlatformShellPackageManifest(platformShellPlanDir,
                                                                 platformShellPackageManifestOut):
            return 14
    var platformShellProjectDir: str = cmdline.ReadFlagOrDefault("--platform-shell-project-dir", "")
    var platformShellProjectManifestOut: str = cmdline.ReadFlagOrDefault("--platform-shell-project-manifest-out", "")
    if strings.Len(platformShellProjectDir) <= 0 && strings.Len(platformShellPackageManifestOut) > 0 && strings.Len(platformShellPlanDir) > 0:
        platformShellProjectDir = chengpath.PathJoin(platformShellPlanDir, "native_platform_shell_project_v1")
    if strings.Len(platformShellProjectManifestOut) <= 0 && strings.Len(platformShellPackageManifestOut) > 0 && strings.Len(platformShellPlanDir) > 0:
        platformShellProjectManifestOut = chengpath.PathJoin(platformShellPlanDir, "native_platform_shell_project_manifest_v1.json")
    if strings.Len(platformShellProjectManifestOut) > 0:
        if strings.Len(platformShellPackageManifestOut) <= 0:
            return 15
        if strings.Len(platformShellProjectDir) <= 0:
            return 16
        if !shellproject.WriteNativePlatformShellProject(platformShellPackageManifestOut,
                                                         platformShellProjectDir,
                                                         platformShellProjectManifestOut):
            return 17
    var doc = "{"
    doc = strutil.Join([doc, "\"format\":\"native_gui_runtime_v1\","], "")
    doc = strutil.Join([doc, "\"ready\":true,"], "")
    doc = strutil.Join([doc, "\"reason\":\"ok\","], "")
    doc = strutil.Join([doc, "\"surface_frame_path\":", nativeGuiRuntimeJsonQuote(surfaceFrameOut), ","], "")
    doc = strutil.Join([doc, "\"surface_manifest_path\":", nativeGuiRuntimeJsonQuote(surfaceManifestOut), ","], "")
    doc = strutil.Join([doc, "\"route_replay_manifest_path\":", nativeGuiRuntimeJsonQuote(routeReplayManifestOut), ","], "")
    doc = strutil.Join([doc, "\"interaction_manifest_path\":", nativeGuiRuntimeJsonQuote(interactionManifestOut), ","], "")
    doc = strutil.Join([doc, "\"platform_shell_manifest_path\":", nativeGuiRuntimeJsonQuote(platformShellManifestOut), ","], "")
    doc = strutil.Join([doc, "\"platform_shell_plan_dir\":", nativeGuiRuntimeJsonQuote(platformShellPlanDir), ","], "")
    doc = strutil.Join([doc, "\"platform_shell_package_manifest_path\":", nativeGuiRuntimeJsonQuote(platformShellPackageManifestOut), ","], "")
    doc = strutil.Join([doc, "\"platform_shell_project_dir\":", nativeGuiRuntimeJsonQuote(platformShellProjectDir), ","], "")
    doc = strutil.Join([doc, "\"platform_shell_project_manifest_path\":", nativeGuiRuntimeJsonQuote(platformShellProjectManifestOut), ","], "")
    doc = strutil.Join([doc, "\"state\":", stateDoc, ","], "")
    doc = strutil.Join([doc, "\"render_plan\":", renderPlanDoc], "")
    doc = strutil.Join([doc, "}"], "")
    echo(doc)
    return 0
