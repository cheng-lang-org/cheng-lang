fn r2cControllerStaticSurface(root: str,
                              args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let tsxAstFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--tsx-ast", ""))
    let runtimeRoots: str[] = r2cControllerCollectCmdlineFlagValues("--runtime-root")
    let assetRoots: str[] = r2cControllerCollectCmdlineFlagValues("--asset-root")
    let repo: str = v3path.V3PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = v3path.V3PathAbsolute(repo, outDirFlag)
    var tsxAstPath: str = os.JoinPath(outDir, "tsx_ast_v1.json")
    if strings.Len(tsxAstFlag) > 0:
        tsxAstPath = v3path.V3PathAbsolute(repo, tsxAstFlag)
    let experimentalRoot: str = r2cControllerExperimentalRoot(effectiveRoot)
    let tsxHelper: str = os.JoinPath(experimentalRoot, "r2c-react-ts-frontend.mjs")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    let frontendLogPath: str = os.JoinPath(outDir, "tsx_frontend.log")
    let summaryPath: str = os.JoinPath(outDir, "static_surface.summary.env")
    let logPath: str = os.JoinPath(outDir, "static_surface.log")
    let reportPath: str = os.JoinPath(outDir, "static_surface_report_v1.json")
    let moduleInventoryPath: str = os.JoinPath(outDir, "module_inventory_v1.json")
    var moduleCount: int32
    var assetCount: int32
    var tailwindTokenCount: int32
    var requiredHostGroupCount: int32
    var requiredHostGroupsCsv = ""
    var typescriptVersion = ""
    var frontendRan = false
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)
    if !os.DirExists(repo):
        r2cControllerPrintErr("r2c-react: missing repo: " + repo)
        return 1
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk

    if strings.Len(tsxAstFlag) <= 0:
        frontendRan = true
        var frontendArgs: str[]
        add(frontendArgs, "--repo")
        add(frontendArgs, repo)
        add(frontendArgs, "--out")
        add(frontendArgs, tsxAstPath)
        add(frontendArgs, "--summary-out")
        add(frontendArgs, tsxSummaryPath)
        for i in 0..<runtimeRoots.len:
            add(frontendArgs, "--runtime-root")
            add(frontendArgs, runtimeRoots[i])
        if !r2cControllerRunNodeHelper(effectiveRoot, tsxHelper, frontendArgs, frontendLogPath, helperExitCode, helperOutput):
            r2cControllerPrintErr("r2c-react: tsx frontend helper failed")
            if strings.Len(helperOutput) > 0:
                r2cControllerPrintErr(helperOutput)
            if helperExitCode != 0:
                return helperExitCode
            return 1
        moduleCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(tsxSummaryPath, "module_count", "0"))
        typescriptVersion = r2cControllerReadSummaryValue(tsxSummaryPath, "typescript_version", "")

    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    if !r2csurface.r2cRunStaticSurface(repo, outDir, tsxAstPath, summaryPath, assetRoots, staticSurface):
        r2cControllerPrintErr("r2c-react: static surface failed")
        if strings.Len(staticSurface.message) > 0:
            r2cControllerPrintErr(staticSurface.message)
        return 1
    if moduleCount <= 0:
        moduleCount = staticSurface.moduleCount
    assetCount = staticSurface.assetCount
    tailwindTokenCount = staticSurface.tailwindTokenCount
    requiredHostGroupCount = staticSurface.requiredHostGroupCount
    requiredHostGroupsCsv = staticSurface.requiredHostGroupsCsv
    if strings.Len(staticSurface.typescriptVersion) > 0:
        typescriptVersion = staticSurface.typescriptVersion

    var logText = ""
    logText = logText + "controller=static-surface\n"
    logText = logText + "repo_root=" + repo + "\n"
    logText = logText + "out_dir=" + outDir + "\n"
    logText = logText + "tsx_ast_path=" + tsxAstPath + "\n"
    logText = logText + "frontend_ran=" + r2cControllerJsonBool(frontendRan) + "\n"
    logText = logText + "summary_path=" + summaryPath + "\n"
    if !v3path.V3WriteTextFile("", logPath, logText):
        r2cControllerPrintErr("r2c-react: static surface failed to write log: " + logPath)
        return 1

    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"static-surface\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote("") + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(logPath) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(moduleInventoryPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"module_inventory_v1\",\n"
    report = report + "  \"module_count\": " + intToStr(moduleCount) + ",\n"
    report = report + "  \"route_count\": 0,\n"
    report = report + "  \"semantic_nodes_count\": 0,\n"
    report = report + "  \"asset_count\": " + intToStr(assetCount) + ",\n"
    report = report + "  \"tailwind_token_count\": " + intToStr(tailwindTokenCount) + ",\n"
    report = report + "  \"required_host_group_count\": " + intToStr(requiredHostGroupCount) + ",\n"
    report = report + "  \"required_host_groups\": " + r2cControllerJsonArrayFromCsv(requiredHostGroupsCsv) + ",\n"
    report = report + "  \"rsg_node_count\": 0,\n"
    report = report + "  \"rsg_edge_count\": 0,\n"
    report = report + "  \"blocker_count\": 0,\n"
    report = report + "  \"blocked\": false,\n"
    report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(typescriptVersion) + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerSemanticSurface(root: str,
                                args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let tsxAstFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--tsx-ast", ""))
    let runtimeRoots: str[] = r2cControllerCollectCmdlineFlagValues("--runtime-root")
    let repo: str = v3path.V3PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = v3path.V3PathAbsolute(repo, outDirFlag)
    var tsxAstPath: str = os.JoinPath(outDir, "tsx_ast_v1.json")
    if strings.Len(tsxAstFlag) > 0:
        tsxAstPath = v3path.V3PathAbsolute(repo, tsxAstFlag)
    let experimentalRoot: str = r2cControllerExperimentalRoot(effectiveRoot)
    let tsxHelper: str = os.JoinPath(experimentalRoot, "r2c-react-ts-frontend.mjs")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    let frontendLogPath: str = os.JoinPath(outDir, "tsx_frontend.log")
    let summaryPath: str = os.JoinPath(outDir, "semantic_surface.summary.env")
    let logPath: str = os.JoinPath(outDir, "semantic_surface.log")
    let reportPath: str = os.JoinPath(outDir, "semantic_surface_report_v1.json")
    let rsgPath: str = os.JoinPath(outDir, "rsg_v1.json")
    let blockerReportPath: str = os.JoinPath(outDir, "compile_blockers_v1.json")
    var moduleCount: int32
    var rsgNodeCount: int32
    var rsgEdgeCount: int32
    var blockerCount: int32
    var blocked = false
    var typescriptVersion = ""
    var frontendRan = false
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)
    if !os.DirExists(repo):
        r2cControllerPrintErr("r2c-react: missing repo: " + repo)
        return 1
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk

    if strings.Len(tsxAstFlag) <= 0:
        frontendRan = true
        var frontendArgs: str[]
        add(frontendArgs, "--repo")
        add(frontendArgs, repo)
        add(frontendArgs, "--out")
        add(frontendArgs, tsxAstPath)
        add(frontendArgs, "--summary-out")
        add(frontendArgs, tsxSummaryPath)
        for i in 0..<runtimeRoots.len:
            add(frontendArgs, "--runtime-root")
            add(frontendArgs, runtimeRoots[i])
        if !r2cControllerRunNodeHelper(effectiveRoot, tsxHelper, frontendArgs, frontendLogPath, helperExitCode, helperOutput):
            r2cControllerPrintErr("r2c-react: tsx frontend helper failed")
            if strings.Len(helperOutput) > 0:
                r2cControllerPrintErr(helperOutput)
            if helperExitCode != 0:
                return helperExitCode
            return 1
        moduleCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(tsxSummaryPath, "module_count", "0"))
        typescriptVersion = r2cControllerReadSummaryValue(tsxSummaryPath, "typescript_version", "")

    var semanticSurface: r2csurface.R2cSemanticSurfaceRunResult
    if !r2csurface.r2cRunSemanticSurface(repo, outDir, tsxAstPath, summaryPath, semanticSurface):
        r2cControllerPrintErr("r2c-react: semantic surface failed")
        if strings.Len(semanticSurface.message) > 0:
            r2cControllerPrintErr(semanticSurface.message)
        return 1
    if moduleCount <= 0:
        moduleCount = semanticSurface.moduleCount
    rsgNodeCount = semanticSurface.rsgNodeCount
    rsgEdgeCount = semanticSurface.rsgEdgeCount
    blockerCount = semanticSurface.blockerCount
    blocked = semanticSurface.blocked
    if strings.Len(semanticSurface.typescriptVersion) > 0:
        typescriptVersion = semanticSurface.typescriptVersion

    var logText = ""
    logText = logText + "controller=semantic-surface\n"
    logText = logText + "repo_root=" + repo + "\n"
    logText = logText + "out_dir=" + outDir + "\n"
    logText = logText + "tsx_ast_path=" + tsxAstPath + "\n"
    logText = logText + "frontend_ran=" + r2cControllerJsonBool(frontendRan) + "\n"
    logText = logText + "summary_path=" + summaryPath + "\n"
    logText = logText + "entry_module=" + semanticSurface.entryModule + "\n"
    if !v3path.V3WriteTextFile("", logPath, logText):
        r2cControllerPrintErr("r2c-react: semantic surface failed to write log: " + logPath)
        return 1

    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"semantic-surface\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote("") + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(logPath) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(rsgPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"rsg_v1\",\n"
    report = report + "  \"module_count\": " + intToStr(moduleCount) + ",\n"
    report = report + "  \"route_count\": 0,\n"
    report = report + "  \"semantic_nodes_count\": 0,\n"
    report = report + "  \"asset_count\": 0,\n"
    report = report + "  \"tailwind_token_count\": 0,\n"
    report = report + "  \"required_host_group_count\": 0,\n"
    report = report + "  \"required_host_groups\": [],\n"
    report = report + "  \"rsg_node_count\": " + intToStr(rsgNodeCount) + ",\n"
    report = report + "  \"rsg_edge_count\": " + intToStr(rsgEdgeCount) + ",\n"
    report = report + "  \"blocker_count\": " + intToStr(blockerCount) + ",\n"
    report = report + "  \"blocked\": " + r2cControllerJsonBool(blocked) + ",\n"
    report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(typescriptVersion) + ",\n"
    report = report + "  \"entry_module\": " + r2cControllerJsonQuote(semanticSurface.entryModule) + ",\n"
    report = report + "  \"blocker_report_path\": " + r2cControllerJsonQuote(blockerReportPath) + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerCaptureTruth(root: str,
                             args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let routeState: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--route", ""))
    if strings.Len(routeState) <= 0:
        r2cControllerPrintErr("r2c-react: capture-truth missing --route")
        return 1
    let repo: str = v3path.V3PathAbsolute(effectiveRoot, repoBase)
    let defaultOutDir: str = v3path.V3PathAbsolute(repo, "build/r2c_react_cheng/truth/" + routeState)
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", defaultOutDir))
    let baseUrl: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--base-url", ""))
    let chromePath: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--chrome", ""))
    let width: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--width", ""))
    let height: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--height", ""))
    let truthFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-flag", ""))
    let debugPort: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--debug-port", ""))
    let waitMs: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--wait-ms", ""))
    let outDir: str = v3path.V3PathAbsolute(repo, outDirFlag)
    let experimentalRoot: str = r2cControllerExperimentalRoot(effectiveRoot)
    let helperScript: str = os.JoinPath(experimentalRoot, "r2c-react-truth-runtime.mjs")
    let summaryPath: str = os.JoinPath(outDir, routeState + ".summary.env")
    let reportPath: str = os.JoinPath(outDir, "capture_truth_report_v1.json")
    let logPath: str = os.JoinPath(outDir, "truth_runtime.log")
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)
    if !os.DirExists(repo):
        r2cControllerPrintErr("r2c-react: missing repo: " + repo)
        return 1
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk

    var helperArgs: str[]
    add(helperArgs, "--route")
    add(helperArgs, routeState)
    add(helperArgs, "--out-dir")
    add(helperArgs, outDir)
    add(helperArgs, "--summary-out")
    add(helperArgs, summaryPath)
    if strings.Len(baseUrl) > 0:
        add(helperArgs, "--base-url")
        add(helperArgs, baseUrl)
    if strings.Len(chromePath) > 0:
        add(helperArgs, "--chrome")
        add(helperArgs, chromePath)
    if strings.Len(width) > 0:
        add(helperArgs, "--width")
        add(helperArgs, width)
    if strings.Len(height) > 0:
        add(helperArgs, "--height")
        add(helperArgs, height)
    if strings.Len(truthFlag) > 0:
        add(helperArgs, "--truth-flag")
        add(helperArgs, truthFlag)
    if strings.Len(debugPort) > 0:
        add(helperArgs, "--debug-port")
        add(helperArgs, debugPort)
    if strings.Len(waitMs) > 0:
        add(helperArgs, "--wait-ms")
        add(helperArgs, waitMs)
    if !r2cControllerRunNodeHelper(effectiveRoot, helperScript, helperArgs, logPath, helperExitCode, helperOutput):
        r2cControllerPrintErr("r2c-react: truth runtime helper failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1

    let truthTracePath: str = r2cControllerReadSummaryValue(summaryPath, "truth_trace_path", "")
    let truthTraceFormat: str = r2cControllerReadSummaryValue(summaryPath, "truth_trace_format", "truth_trace_v2")
    let truthTraceStateCountText: str = r2cControllerReadSummaryValue(summaryPath, "truth_trace_state_count", "1")
    let runtimeStatePath: str = r2cControllerReadSummaryValue(summaryPath, "runtime_state_path", "")
    let domPath: str = r2cControllerReadSummaryValue(summaryPath, "dom_path", "")
    let semanticNodesPath: str = r2cControllerReadSummaryValue(summaryPath, "semantic_nodes_path", "")
    let metaPath: str = r2cControllerReadSummaryValue(summaryPath, "runtime_meta_path", "")
    let domHash: str = r2cControllerReadSummaryValue(summaryPath, "dom_hash", "")
    let pathname: str = r2cControllerReadSummaryValue(summaryPath, "pathname", "")
    let searchText: str = r2cControllerReadSummaryValue(summaryPath, "search", "")
    let hashText: str = r2cControllerReadSummaryValue(summaryPath, "hash", "")
    let semanticNodesCountText: str = r2cControllerReadSummaryValue(summaryPath, "semantic_nodes_count", "0")
    let documentNodesCountText: str = r2cControllerReadSummaryValue(summaryPath, "document_nodes_count", "0")

    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"capture-truth\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"node_program\": \"node\",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote(helperScript) + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(logPath) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(truthTracePath) + ",\n"
    report = report + "  \"primary_artifact_format\": " + r2cControllerJsonQuote(truthTraceFormat) + ",\n"
    report = report + "  \"module_count\": 0,\n"
    report = report + "  \"route_count\": " + truthTraceStateCountText + ",\n"
    report = report + "  \"semantic_nodes_count\": " + semanticNodesCountText + ",\n"
    report = report + "  \"asset_count\": 0,\n"
    report = report + "  \"tailwind_token_count\": 0,\n"
    report = report + "  \"required_host_group_count\": 0,\n"
    report = report + "  \"required_host_groups\": [],\n"
    report = report + "  \"rsg_node_count\": 0,\n"
    report = report + "  \"rsg_edge_count\": 0,\n"
    report = report + "  \"blocker_count\": 0,\n"
    report = report + "  \"blocked\": false,\n"
    report = report + "  \"typescript_version\": \"\",\n"
    report = report + "  \"truth_route\": " + r2cControllerJsonQuote(routeState) + ",\n"
    report = report + "  \"truth_trace_path\": " + r2cControllerJsonQuote(truthTracePath) + ",\n"
    report = report + "  \"truth_trace_format\": " + r2cControllerJsonQuote(truthTraceFormat) + ",\n"
    report = report + "  \"runtime_state_path\": " + r2cControllerJsonQuote(runtimeStatePath) + ",\n"
    report = report + "  \"dom_path\": " + r2cControllerJsonQuote(domPath) + ",\n"
    report = report + "  \"semantic_nodes_path\": " + r2cControllerJsonQuote(semanticNodesPath) + ",\n"
    report = report + "  \"runtime_meta_path\": " + r2cControllerJsonQuote(metaPath) + ",\n"
    report = report + "  \"dom_hash\": " + r2cControllerJsonQuote(domHash) + ",\n"
    report = report + "  \"document_nodes_count\": " + documentNodesCountText + ",\n"
    report = report + "  \"pathname\": " + r2cControllerJsonQuote(pathname) + ",\n"
    report = report + "  \"search\": " + r2cControllerJsonQuote(searchText) + ",\n"
    report = report + "  \"hash\": " + r2cControllerJsonQuote(hashText) + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerCompareTruthCompat(root: str,
                                   args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let execSnapshotRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--exec-snapshot", ""))
    let truthTraceRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-trace", ""))
    let codegenManifestRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--codegen-manifest", ""))
    let truthState: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-state", ""))
    let nativeGuiSummaryRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--native-gui-summary", ""))
    if strings.Len(execSnapshotRaw) <= 0 || strings.Len(truthTraceRaw) <= 0:
        r2cControllerPrintErr("r2c-react: compare-truth missing --exec-snapshot or --truth-trace")
        return 1
    let execSnapshotPath: str = v3path.V3PathAbsolute(currentDir, execSnapshotRaw)
    let truthTracePath: str = v3path.V3PathAbsolute(currentDir, truthTraceRaw)
    if !v3path.V3PathFileExists(execSnapshotPath):
        r2cControllerPrintErr("r2c-react: missing exec snapshot: " + execSnapshotPath)
        return 1
    if !v3path.V3PathFileExists(truthTracePath):
        r2cControllerPrintErr("r2c-react: missing truth trace: " + truthTracePath)
        return 1
    var codegenManifestPath = ""
    if strings.Len(codegenManifestRaw) > 0:
        codegenManifestPath = v3path.V3PathAbsolute(currentDir, codegenManifestRaw)
        if !v3path.V3PathFileExists(codegenManifestPath):
            r2cControllerPrintErr("r2c-react: missing codegen manifest: " + codegenManifestPath)
            return 1
    let outRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out",
                                                                     os.JoinPath(v3path.V3PathParentDir(execSnapshotPath),
                                                                                 "truth_compare_v1.json")))
    let truthComparePath: str = v3path.V3PathAbsolute(currentDir, outRaw)
    let outDir: str = v3path.V3PathParentDir(truthComparePath)
    var nativeGuiSummaryPath = ""
    if strings.Len(nativeGuiSummaryRaw) > 0:
        nativeGuiSummaryPath = v3path.V3PathAbsolute(currentDir, nativeGuiSummaryRaw)
        if !v3path.V3PathFileExists(nativeGuiSummaryPath):
            r2cControllerPrintErr("r2c-react: missing native gui summary: " + nativeGuiSummaryPath)
            return 1
    else:
        let defaultNativeGuiSummaryPath: str = os.JoinPath(v3path.V3PathParentDir(execSnapshotPath), "native_gui_run.summary.env")
        if v3path.V3PathFileExists(defaultNativeGuiSummaryPath):
            nativeGuiSummaryPath = defaultNativeGuiSummaryPath
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk
    let experimentalRoot: str = r2cControllerExperimentalRoot(effectiveRoot)
    let summaryPath: str = os.JoinPath(outDir, "truth_compare.summary.env")
    let reportPath: str = os.JoinPath(outDir, "compare_truth_report_v1.json")
    if !r2cControllerWriteCompareTruthDirect(execSnapshotPath,
                                             truthTracePath,
                                             truthState,
                                             truthComparePath,
                                             summaryPath,
                                             nativeGuiSummaryPath):
        r2cControllerPrintErr("r2c-react: compare-truth failed")
        return 2
    let semanticNodesCountText: str = r2cControllerReadSummaryValue(summaryPath, "exec_semantic_nodes_count", "0")
    let execSnapshotSemanticNodesCountText: str = r2cControllerReadSummaryValue(summaryPath, "exec_snapshot_semantic_nodes_count", semanticNodesCountText)
    let truthSemanticNodesCountText: str = r2cControllerReadSummaryValue(summaryPath, "truth_semantic_nodes_count", "0")
    let truthTraceSemanticNodesCountText: str = r2cControllerReadSummaryValue(summaryPath, "truth_trace_semantic_nodes_count", truthSemanticNodesCountText)
    let semanticNodeCountCompareBasis: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_count_compare_basis", "")
    let truthCompareOkText: str = r2cControllerReadSummaryValue(summaryPath, "truth_compare_ok", "")
    let truthCompareReason: str = r2cControllerReadSummaryValue(summaryPath, "truth_compare_reason", "")
    let execLayoutSurfacePath: str = r2cControllerReadSummaryValue(summaryPath, "exec_layout_surface_path", "")
    let truthSemanticNodesPath: str = r2cControllerReadSummaryValue(summaryPath, "truth_semantic_nodes_path", "")
    let semanticNodeDiffReadyText: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_diff_ready", "")
    let semanticNodeDiffPath: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_diff_path", "")
    let semanticNodeDiffBasis: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_diff_basis", "")
    let semanticNodeDiffExecNodeCountText: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_diff_exec_node_count", "0")
    let semanticNodeDiffTruthNodeCountText: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_diff_truth_node_count", "0")
    let semanticNodeDiffSharedCountText: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_diff_shared_count", "0")
    let semanticNodeDiffExecOnlyCountText: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_diff_exec_only_count", "0")
    let semanticNodeDiffTruthOnlyCountText: str = r2cControllerReadSummaryValue(summaryPath, "semantic_node_diff_truth_only_count", "0")
    let nativeGuiSummaryReadyText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_summary_ready", "")
    let nativeGuiSummaryResolvedPath: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_summary_path", nativeGuiSummaryPath)
    let nativeGuiRouteState: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_route_state", "")
    let nativeGuiScreenshotPath: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_screenshot_path", "")
    let nativeGuiRuntimeBundleReadyText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_ready", "")
    let nativeGuiRuntimeContractReadyText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_contract_ready", "")
    let nativeGuiRuntimeBundleRouteState: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_route_state", "")
    let nativeGuiRuntimeBundleRouteCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_route_count", "0")
    let nativeGuiRuntimeBundleSupportedCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_supported_count", "0")
    let nativeGuiRuntimeBundleSemanticNodesCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_semantic_nodes_count", "0")
    let nativeGuiRuntimeBundleLayoutItemCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_layout_item_count", "0")
    let nativeGuiRuntimeBundleRenderCommandCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_render_command_count", "0")
    let nativeGuiRuntimeContractLayoutItemCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_contract_layout_item_count", "0")
    let nativeGuiRuntimeContractViewportItemCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_contract_viewport_item_count", "0")
    let nativeGuiRuntimeContractInteractiveItemCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_contract_interactive_item_count", "0")
    let nativeGuiNativeLayoutPlanItemCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_native_layout_plan_item_count", "0")
    let nativeGuiRenderPlanCommandCountText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_render_plan_command_count", "0")
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"compare-truth\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"exec_snapshot_path\": " + r2cControllerJsonQuote(execSnapshotPath) + ",\n"
    report = report + "  \"truth_trace_path\": " + r2cControllerJsonQuote(truthTracePath) + ",\n"
    report = report + "  \"truth_state\": " + r2cControllerJsonQuote(truthState) + ",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote("") + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote("") + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(truthComparePath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"truth_compare_v1\",\n"
    report = report + "  \"route_count\": 1,\n"
    report = report + "  \"semantic_nodes_count\": " + semanticNodesCountText + ",\n"
    report = report + "  \"semantic_node_count_compare_basis\": " + r2cControllerJsonQuote(semanticNodeCountCompareBasis) + ",\n"
    report = report + "  \"exec_snapshot_semantic_nodes_count\": " + execSnapshotSemanticNodesCountText + ",\n"
    report = report + "  \"truth_semantic_nodes_count\": " + truthSemanticNodesCountText + ",\n"
    report = report + "  \"truth_trace_semantic_nodes_count\": " + truthTraceSemanticNodesCountText + ",\n"
    report = report + "  \"exec_layout_surface_path\": " + r2cControllerJsonQuote(execLayoutSurfacePath) + ",\n"
    report = report + "  \"truth_semantic_nodes_path\": " + r2cControllerJsonQuote(truthSemanticNodesPath) + ",\n"
    if semanticNodeDiffReadyText == "true" || semanticNodeDiffReadyText == "false":
        report = report + "  \"semantic_node_diff_ready\": " + semanticNodeDiffReadyText + ",\n"
    else:
        report = report + "  \"semantic_node_diff_ready\": null,\n"
    report = report + "  \"semantic_node_diff_path\": " + r2cControllerJsonQuote(semanticNodeDiffPath) + ",\n"
    report = report + "  \"semantic_node_diff_basis\": " + r2cControllerJsonQuote(semanticNodeDiffBasis) + ",\n"
    report = report + "  \"semantic_node_diff_exec_node_count\": " + semanticNodeDiffExecNodeCountText + ",\n"
    report = report + "  \"semantic_node_diff_truth_node_count\": " + semanticNodeDiffTruthNodeCountText + ",\n"
    report = report + "  \"semantic_node_diff_shared_count\": " + semanticNodeDiffSharedCountText + ",\n"
    report = report + "  \"semantic_node_diff_exec_only_count\": " + semanticNodeDiffExecOnlyCountText + ",\n"
    report = report + "  \"semantic_node_diff_truth_only_count\": " + semanticNodeDiffTruthOnlyCountText + ",\n"
    if nativeGuiSummaryReadyText == "true" || nativeGuiSummaryReadyText == "false":
        report = report + "  \"native_gui_summary_ready\": " + nativeGuiSummaryReadyText + ",\n"
    else:
        report = report + "  \"native_gui_summary_ready\": null,\n"
    report = report + "  \"native_gui_summary_path\": " + r2cControllerJsonQuote(nativeGuiSummaryResolvedPath) + ",\n"
    report = report + "  \"native_gui_route_state\": " + r2cControllerJsonQuote(nativeGuiRouteState) + ",\n"
    report = report + "  \"native_gui_screenshot_path\": " + r2cControllerJsonQuote(nativeGuiScreenshotPath) + ",\n"
    if nativeGuiRuntimeBundleReadyText == "true" || nativeGuiRuntimeBundleReadyText == "false":
        report = report + "  \"native_gui_runtime_bundle_ready\": " + nativeGuiRuntimeBundleReadyText + ",\n"
    else:
        report = report + "  \"native_gui_runtime_bundle_ready\": null,\n"
    if nativeGuiRuntimeContractReadyText == "true" || nativeGuiRuntimeContractReadyText == "false":
        report = report + "  \"native_gui_runtime_contract_ready\": " + nativeGuiRuntimeContractReadyText + ",\n"
    else:
        report = report + "  \"native_gui_runtime_contract_ready\": null,\n"
    report = report + "  \"native_gui_runtime_bundle_route_state\": " + r2cControllerJsonQuote(nativeGuiRuntimeBundleRouteState) + ",\n"
    report = report + "  \"native_gui_runtime_bundle_route_count\": " + nativeGuiRuntimeBundleRouteCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_supported_count\": " + nativeGuiRuntimeBundleSupportedCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_semantic_nodes_count\": " + nativeGuiRuntimeBundleSemanticNodesCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_layout_item_count\": " + nativeGuiRuntimeBundleLayoutItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_render_command_count\": " + nativeGuiRuntimeBundleRenderCommandCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_layout_item_count\": " + nativeGuiRuntimeContractLayoutItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_viewport_item_count\": " + nativeGuiRuntimeContractViewportItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_interactive_item_count\": " + nativeGuiRuntimeContractInteractiveItemCountText + ",\n"
    report = report + "  \"native_gui_native_layout_plan_item_count\": " + nativeGuiNativeLayoutPlanItemCountText + ",\n"
    report = report + "  \"native_gui_render_plan_command_count\": " + nativeGuiRenderPlanCommandCountText + ",\n"
    if truthCompareOkText == "true" || truthCompareOkText == "false":
        report = report + "  \"truth_compare_ok\": " + truthCompareOkText + ",\n"
    else:
        report = report + "  \"truth_compare_ok\": null,\n"
    report = report + "  \"truth_compare_reason\": " + r2cControllerJsonQuote(truthCompareReason) + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerExecRouteMatrix(root: str,
                                args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let tsxAstRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--tsx-ast", ""))
    let routeCatalogRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--route-catalog", ""))
    let execSnapshotRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--exec-snapshot", ""))
    let truthRoutesRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-routes-file", ""))
    let codegenManifestRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--codegen-manifest", ""))
    let truthTraceRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-trace", ""))
    if (strings.Len(routeCatalogRaw) <= 0 && strings.Len(tsxAstRaw) <= 0) ||
       strings.Len(execSnapshotRaw) <= 0 ||
       strings.Len(truthRoutesRaw) <= 0:
        r2cControllerPrintErr("r2c-react: exec-route-matrix missing (--route-catalog or --tsx-ast), --exec-snapshot, or --truth-routes-file")
        return 1
    var tsxAstPath = ""
    if strings.Len(tsxAstRaw) > 0:
        tsxAstPath = v3path.V3PathAbsolute(currentDir, tsxAstRaw)
        if !v3path.V3PathFileExists(tsxAstPath):
            r2cControllerPrintErr("r2c-react: missing tsx ast: " + tsxAstPath)
            return 1
    var routeCatalogPath = ""
    if strings.Len(routeCatalogRaw) > 0:
        routeCatalogPath = v3path.V3PathAbsolute(currentDir, routeCatalogRaw)
        if !v3path.V3PathFileExists(routeCatalogPath):
            r2cControllerPrintErr("r2c-react: missing route catalog: " + routeCatalogPath)
            return 1
    let execSnapshotPath: str = v3path.V3PathAbsolute(currentDir, execSnapshotRaw)
    let truthRoutesPath: str = v3path.V3PathAbsolute(currentDir, truthRoutesRaw)
    if !v3path.V3PathFileExists(execSnapshotPath):
        r2cControllerPrintErr("r2c-react: missing exec snapshot: " + execSnapshotPath)
        return 1
    if !v3path.V3PathFileExists(truthRoutesPath):
        r2cControllerPrintErr("r2c-react: missing truth routes: " + truthRoutesPath)
        return 1
    var codegenManifestPath = ""
    if strings.Len(codegenManifestRaw) > 0:
        codegenManifestPath = v3path.V3PathAbsolute(currentDir, codegenManifestRaw)
        if !v3path.V3PathFileExists(codegenManifestPath):
            r2cControllerPrintErr("r2c-react: missing codegen manifest: " + codegenManifestPath)
            return 1
    var truthTracePath = ""
    if strings.Len(truthTraceRaw) > 0:
        truthTracePath = v3path.V3PathAbsolute(currentDir, truthTraceRaw)
        if !v3path.V3PathFileExists(truthTracePath):
            r2cControllerPrintErr("r2c-react: missing truth trace: " + truthTracePath)
            return 1
    let outRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out",
                                                                     os.JoinPath(v3path.V3PathParentDir(execSnapshotPath),
                                                                                 "cheng_codegen_exec_route_matrix_v1.json")))
    let execRouteMatrixPath: str = v3path.V3PathAbsolute(currentDir, outRaw)
    let outDir: str = v3path.V3PathParentDir(execRouteMatrixPath)
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk
    let experimentalRoot: str = r2cControllerExperimentalRoot(effectiveRoot)
    let helperScript: str = os.JoinPath(experimentalRoot, "r2c-react-exec-route-matrix.mjs")
    let summaryPath: str = os.JoinPath(outDir, "exec_route_matrix.summary.env")
    let logPath: str = os.JoinPath(outDir, "exec_route_matrix.log")
    let reportPath: str = os.JoinPath(outDir, "exec_route_matrix_report_v1.json")
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)
    var helperArgs: str[]
    add(helperArgs, "--exec-snapshot")
    add(helperArgs, execSnapshotPath)
    add(helperArgs, "--truth-routes-file")
    add(helperArgs, truthRoutesPath)
    add(helperArgs, "--out")
    add(helperArgs, execRouteMatrixPath)
    add(helperArgs, "--summary-out")
    add(helperArgs, summaryPath)
    if strings.Len(routeCatalogPath) > 0:
        add(helperArgs, "--route-catalog")
        add(helperArgs, routeCatalogPath)
    else:
        add(helperArgs, "--tsx-ast")
        add(helperArgs, tsxAstPath)
    if strings.Len(codegenManifestPath) > 0:
        add(helperArgs, "--codegen-manifest")
        add(helperArgs, codegenManifestPath)
    if strings.Len(truthTracePath) > 0:
        add(helperArgs, "--truth-trace")
        add(helperArgs, truthTracePath)
    if !r2cControllerRunNodeHelper(effectiveRoot,
                                   helperScript,
                                   helperArgs,
                                   logPath,
                                   helperExitCode,
                                   helperOutput):
        r2cControllerPrintErr("r2c-react: exec-route-matrix failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1
    let routeCountText: str = r2cControllerReadSummaryValue(summaryPath, "route_count", "0")
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"exec-route-matrix\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"exec_snapshot_path\": " + r2cControllerJsonQuote(execSnapshotPath) + ",\n"
    report = report + "  \"truth_routes_path\": " + r2cControllerJsonQuote(truthRoutesPath) + ",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote(helperScript) + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(logPath) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(execRouteMatrixPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"cheng_codegen_exec_route_matrix_v1\",\n"
    report = report + "  \"route_count\": " + routeCountText + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerCompareTruthMatrixCompat(root: str,
                                         args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let execRouteMatrixRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--exec-route-matrix", ""))
    let truthTraceRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-trace", ""))
    let codegenManifestRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--codegen-manifest", ""))
    if strings.Len(execRouteMatrixRaw) <= 0 || strings.Len(truthTraceRaw) <= 0:
        r2cControllerPrintErr("r2c-react: compare-truth-matrix missing --exec-route-matrix or --truth-trace")
        return 1
    let execRouteMatrixPath: str = v3path.V3PathAbsolute(currentDir, execRouteMatrixRaw)
    let truthTracePath: str = v3path.V3PathAbsolute(currentDir, truthTraceRaw)
    if !v3path.V3PathFileExists(execRouteMatrixPath):
        r2cControllerPrintErr("r2c-react: missing exec route matrix: " + execRouteMatrixPath)
        return 1
    if !v3path.V3PathFileExists(truthTracePath):
        r2cControllerPrintErr("r2c-react: missing truth trace: " + truthTracePath)
        return 1
    var codegenManifestPath = ""
    if strings.Len(codegenManifestRaw) > 0:
        codegenManifestPath = v3path.V3PathAbsolute(currentDir, codegenManifestRaw)
        if !v3path.V3PathFileExists(codegenManifestPath):
            r2cControllerPrintErr("r2c-react: missing codegen manifest: " + codegenManifestPath)
            return 1
    let outRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out",
                                                                     os.JoinPath(v3path.V3PathParentDir(execRouteMatrixPath),
                                                                                 "truth_compare_matrix_v1.json")))
    let truthCompareMatrixPath: str = v3path.V3PathAbsolute(currentDir, outRaw)
    let outDir: str = v3path.V3PathParentDir(truthCompareMatrixPath)
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk
    let experimentalRoot: str = r2cControllerExperimentalRoot(effectiveRoot)
    let summaryPath: str = os.JoinPath(outDir, "truth_compare_matrix.summary.env")
    let reportPath: str = os.JoinPath(outDir, "compare_truth_matrix_report_v1.json")
    if !r2cControllerWriteTruthCompareMatrixArtifacts(execRouteMatrixPath,
                                                      truthTracePath,
                                                      truthCompareMatrixPath,
                                                      summaryPath):
        r2cControllerPrintErr("r2c-react: compare-truth-matrix failed")
        return 2
    let routeCountText: str = r2cControllerReadSummaryValue(summaryPath, "route_count", "0")
    let truthCompareMatrixOkText: str = r2cControllerReadSummaryValue(summaryPath, "truth_compare_matrix_ok", "")
    let truthCompareMatrixReason: str = r2cControllerReadSummaryValue(summaryPath, "truth_compare_matrix_reason", "")
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"compare-truth-matrix\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"exec_route_matrix_path\": " + r2cControllerJsonQuote(execRouteMatrixPath) + ",\n"
    report = report + "  \"truth_trace_path\": " + r2cControllerJsonQuote(truthTracePath) + ",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote("") + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote("") + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(truthCompareMatrixPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"truth_compare_matrix_v1\",\n"
    report = report + "  \"route_count\": " + routeCountText + ",\n"
    if truthCompareMatrixOkText == "true" || truthCompareMatrixOkText == "false":
        report = report + "  \"truth_compare_matrix_ok\": " + truthCompareMatrixOkText + ",\n"
    else:
        report = report + "  \"truth_compare_matrix_ok\": null,\n"
    report = report + "  \"truth_compare_matrix_reason\": " + r2cControllerJsonQuote(truthCompareMatrixReason) + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerTruthCompare(root: str,
                             args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let execSnapshotRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--exec-snapshot", ""))
    let codegenManifestRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--codegen-manifest", ""))
    let routeCatalogRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--route-catalog", ""))
    let truthTraceRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-trace", ""))
    let truthState: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-state", ""))
    let truthRoutesFileRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-routes-file", ""))
    let nativeGuiSummaryRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--native-gui-summary", ""))
    let truthRoutesDiscover: bool = cmdline.HasFlag("--truth-routes-discover")
    let runtimeRoots: str[] = r2cControllerCollectCmdlineFlagValues("--runtime-root")
    let repo: str = v3path.V3PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = v3path.V3PathAbsolute(repo, outDirFlag)
    var execSnapshotPath: str = os.JoinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    var codegenManifestPath: str = os.JoinPath(outDir, "cheng_codegen_v1.json")
    var routeCatalogPath: str = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    if strings.Len(execSnapshotRaw) > 0:
        execSnapshotPath = v3path.V3PathAbsolute(repo, execSnapshotRaw)
    if strings.Len(codegenManifestRaw) > 0:
        codegenManifestPath = v3path.V3PathAbsolute(repo, codegenManifestRaw)
    if strings.Len(routeCatalogRaw) > 0:
        routeCatalogPath = v3path.V3PathAbsolute(repo, routeCatalogRaw)
    if strings.Len(truthTraceRaw) <= 0:
        r2cControllerPrintErr("r2c-react: missing --truth-trace")
        return 2
    let truthTracePath: str = v3path.V3PathAbsolute(repo, truthTraceRaw)
    if !v3path.V3PathFileExists(execSnapshotPath):
        r2cControllerPrintErr("r2c-react: missing exec snapshot: " + execSnapshotPath)
        return 1
    if !v3path.V3PathFileExists(truthTracePath):
        r2cControllerPrintErr("r2c-react: missing truth trace: " + truthTracePath)
        return 1
    if strings.Len(codegenManifestPath) > 0:
        if !v3path.V3PathFileExists(codegenManifestPath):
            r2cControllerPrintErr("r2c-react: missing codegen manifest: " + codegenManifestPath)
            return 1
    if truthRoutesDiscover:
        if !v3path.V3PathFileExists(routeCatalogPath):
            r2cControllerPrintErr("r2c-react: missing route catalog: " + routeCatalogPath)
            return 1
    elif strings.Len(truthRoutesFileRaw) > 0:
        if !v3path.V3PathFileExists(routeCatalogPath):
            r2cControllerPrintErr("r2c-react: missing route catalog: " + routeCatalogPath)
            return 1
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk
    let experimentalRoot: str = r2cControllerExperimentalRoot(effectiveRoot)
    let truthRoutesHelper: str = os.JoinPath(experimentalRoot, "r2c-react-discover-truth-routes.mjs")
    let execRouteMatrixHelper: str = os.JoinPath(experimentalRoot, "r2c-react-exec-route-matrix.mjs")
    let truthRoutesSummaryPath: str = os.JoinPath(outDir, "truth_routes_v1.summary.env")
    let execRouteMatrixSummaryPath: str = os.JoinPath(outDir, "exec_route_matrix.summary.env")
    let truthCompareSummaryPath: str = os.JoinPath(outDir, "truth_compare.summary.env")
    let truthCompareMatrixSummaryPath: str = os.JoinPath(outDir, "truth_compare_matrix.summary.env")
    let reportPath: str = os.JoinPath(outDir, "truth_compare_report_v1.json")
    let truthRoutesLogPath: str = os.JoinPath(outDir, "truth_routes.log")
    let execRouteMatrixLogPath: str = os.JoinPath(outDir, "exec_route_matrix.log")
    var truthRoutesPath: str = os.JoinPath(outDir, "truth_routes_v1.json")
    var execRouteMatrixPath: str = os.JoinPath(outDir, "cheng_codegen_exec_route_matrix_v1.json")
    var truthComparePath: str = os.JoinPath(outDir, "truth_compare_v1.json")
    var truthCompareMatrixPath: str = os.JoinPath(outDir, "truth_compare_matrix_v1.json")
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)
    var routeCount: int32 = 1
    var primaryArtifactPath: str = truthComparePath
    var primaryArtifactFormat: str = "truth_compare_v1"
    var finalHelperSummaryPath: str = truthCompareSummaryPath
    var finalHelperLogPath: str
    var finalTruthCompareMatrixSummaryPath: str
    var nativeGuiSummaryPath = ""
    if strings.Len(nativeGuiSummaryRaw) > 0:
        nativeGuiSummaryPath = v3path.V3PathAbsolute(repo, nativeGuiSummaryRaw)
        if !v3path.V3PathFileExists(nativeGuiSummaryPath):
            r2cControllerPrintErr("r2c-react: missing native gui summary: " + nativeGuiSummaryPath)
            return 1
    else:
        let defaultNativeGuiSummaryPath: str = os.JoinPath(outDir, "native_gui_run.summary.env")
        if v3path.V3PathFileExists(defaultNativeGuiSummaryPath):
            nativeGuiSummaryPath = defaultNativeGuiSummaryPath
    var hasTruthRoutesInput: bool = truthRoutesDiscover
    if !hasTruthRoutesInput:
        if strings.Len(truthRoutesFileRaw) > 0:
            hasTruthRoutesInput = true

    if !r2cControllerWriteCompareTruthDirect(execSnapshotPath,
                                             truthTracePath,
                                             truthState,
                                             truthComparePath,
                                             truthCompareSummaryPath,
                                             nativeGuiSummaryPath):
        r2cControllerPrintErr("r2c-react: truth compare failed")
        return 2

    truthComparePath = r2cControllerReadSummaryValue(truthCompareSummaryPath, "truth_compare_path", truthComparePath)

    if truthRoutesDiscover:
        var truthRoutesArgs: str[]
        add(truthRoutesArgs, "--repo")
        add(truthRoutesArgs, repo)
        add(truthRoutesArgs, "--out")
        add(truthRoutesArgs, truthRoutesPath)
        add(truthRoutesArgs, "--summary-out")
        add(truthRoutesArgs, truthRoutesSummaryPath)
        for i in 0..<runtimeRoots.len:
            add(truthRoutesArgs, "--runtime-root")
            add(truthRoutesArgs, runtimeRoots[i])
        if !r2cControllerRunNodeHelper(effectiveRoot,
                                       truthRoutesHelper,
                                       truthRoutesArgs,
                                       truthRoutesLogPath,
                                       helperExitCode,
                                       helperOutput):
            r2cControllerPrintErr("r2c-react: truth route helper failed")
            if strings.Len(helperOutput) > 0:
                r2cControllerPrintErr(helperOutput)
            if helperExitCode != 0:
                return helperExitCode
            return 1
    elif strings.Len(truthRoutesFileRaw) > 0:
        truthRoutesPath = v3path.V3PathAbsolute(repo, truthRoutesFileRaw)
        if !v3path.V3PathFileExists(truthRoutesPath):
            r2cControllerPrintErr("r2c-react: missing truth routes: " + truthRoutesPath)
            return 1

    if hasTruthRoutesInput:
        var execRouteMatrixArgs: str[]
        add(execRouteMatrixArgs, "--route-catalog")
        add(execRouteMatrixArgs, routeCatalogPath)
        add(execRouteMatrixArgs, "--exec-snapshot")
        add(execRouteMatrixArgs, execSnapshotPath)
        add(execRouteMatrixArgs, "--truth-routes-file")
        add(execRouteMatrixArgs, truthRoutesPath)
        add(execRouteMatrixArgs, "--codegen-manifest")
        add(execRouteMatrixArgs, codegenManifestPath)
        add(execRouteMatrixArgs, "--truth-trace")
        add(execRouteMatrixArgs, truthTracePath)
        add(execRouteMatrixArgs, "--out")
        add(execRouteMatrixArgs, execRouteMatrixPath)
        add(execRouteMatrixArgs, "--summary-out")
        add(execRouteMatrixArgs, execRouteMatrixSummaryPath)
        if !r2cControllerRunNodeHelper(effectiveRoot,
                                       execRouteMatrixHelper,
                                       execRouteMatrixArgs,
                                       execRouteMatrixLogPath,
                                       helperExitCode,
                                       helperOutput):
            r2cControllerPrintErr("r2c-react: exec route matrix helper failed")
            if strings.Len(helperOutput) > 0:
                r2cControllerPrintErr(helperOutput)
            if helperExitCode != 0:
                return helperExitCode
            return 1

        routeCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(execRouteMatrixSummaryPath, "route_count", "0"))
        execRouteMatrixPath = r2cControllerReadSummaryValue(execRouteMatrixSummaryPath, "exec_route_matrix_path", execRouteMatrixPath)

        if !r2cControllerWriteTruthCompareMatrixArtifacts(execRouteMatrixPath,
                                                          truthTracePath,
                                                          truthCompareMatrixPath,
                                                          truthCompareMatrixSummaryPath):
            r2cControllerPrintErr("r2c-react: truth compare matrix failed")
            return 2

        truthCompareMatrixPath = r2cControllerReadSummaryValue(truthCompareMatrixSummaryPath,
                                                               "truth_compare_matrix_path",
                                                               truthCompareMatrixPath)
        routeCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(truthCompareMatrixSummaryPath,
                                                                           "route_count",
                                                                           intToStr(routeCount)))
        primaryArtifactPath = truthCompareMatrixPath
        primaryArtifactFormat = "truth_compare_matrix_v1"
        finalHelperSummaryPath = truthCompareMatrixSummaryPath
        finalHelperLogPath = execRouteMatrixLogPath
        finalTruthCompareMatrixSummaryPath = truthCompareMatrixSummaryPath

    let truthCompareOkText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "truth_compare_ok", "")
    let truthCompareReason: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "truth_compare_reason", "")
    let nativeGuiSummaryReadyText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_summary_ready", "")
    let nativeGuiSummaryResolvedPath: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_summary_path", nativeGuiSummaryPath)
    let nativeGuiRouteState: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_route_state", "")
    let nativeGuiScreenshotPath: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_screenshot_path", "")
    let nativeGuiRuntimeBundleReadyText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_bundle_ready", "")
    let nativeGuiRuntimeContractReadyText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_contract_ready", "")
    let nativeGuiRuntimeBundleRouteState: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_bundle_route_state", "")
    let nativeGuiRuntimeBundleRouteCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_bundle_route_count", "0")
    let nativeGuiRuntimeBundleSupportedCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_bundle_supported_count", "0")
    let nativeGuiRuntimeBundleSemanticNodesCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_bundle_semantic_nodes_count", "0")
    let nativeGuiRuntimeBundleLayoutItemCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_bundle_layout_item_count", "0")
    let nativeGuiRuntimeBundleRenderCommandCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_bundle_render_command_count", "0")
    let nativeGuiRuntimeContractLayoutItemCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_contract_layout_item_count", "0")
    let nativeGuiRuntimeContractViewportItemCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_contract_viewport_item_count", "0")
    let nativeGuiRuntimeContractInteractiveItemCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_runtime_contract_interactive_item_count", "0")
    let nativeGuiNativeLayoutPlanItemCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_native_layout_plan_item_count", "0")
    let nativeGuiRenderPlanCommandCountText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "native_gui_render_plan_command_count", "0")
    let truthCompareMatrixOkText: str = r2cControllerReadSummaryValue(finalTruthCompareMatrixSummaryPath,
                                                                      "truth_compare_matrix_ok",
                                                                      "")
    let truthCompareMatrixReason: str = r2cControllerReadSummaryValue(finalTruthCompareMatrixSummaryPath,
                                                                      "truth_compare_matrix_reason",
                                                                      "")
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"truth-compare\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"exec_snapshot_path\": " + r2cControllerJsonQuote(execSnapshotPath) + ",\n"
    report = report + "  \"truth_trace_path\": " + r2cControllerJsonQuote(truthTracePath) + ",\n"
    report = report + "  \"truth_state\": " + r2cControllerJsonQuote(truthState) + ",\n"
    report = report + "  \"truth_routes_path\": " + r2cControllerJsonQuote(truthRoutesPath) + ",\n"
    report = report + "  \"exec_route_matrix_path\": " + r2cControllerJsonQuote(execRouteMatrixPath) + ",\n"
    report = report + "  \"truth_compare_summary_path\": " + r2cControllerJsonQuote(truthCompareSummaryPath) + ",\n"
    report = report + "  \"truth_compare_matrix_summary_path\": " + r2cControllerJsonQuote(finalTruthCompareMatrixSummaryPath) + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(finalHelperSummaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(finalHelperLogPath) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(primaryArtifactPath) + ",\n"
    report = report + "  \"primary_artifact_format\": " + r2cControllerJsonQuote(primaryArtifactFormat) + ",\n"
    report = report + "  \"route_count\": " + intToStr(routeCount) + ",\n"
    if nativeGuiSummaryReadyText == "true" || nativeGuiSummaryReadyText == "false":
        report = report + "  \"native_gui_summary_ready\": " + nativeGuiSummaryReadyText + ",\n"
    else:
        report = report + "  \"native_gui_summary_ready\": null,\n"
    report = report + "  \"native_gui_summary_path\": " + r2cControllerJsonQuote(nativeGuiSummaryResolvedPath) + ",\n"
    report = report + "  \"native_gui_route_state\": " + r2cControllerJsonQuote(nativeGuiRouteState) + ",\n"
    report = report + "  \"native_gui_screenshot_path\": " + r2cControllerJsonQuote(nativeGuiScreenshotPath) + ",\n"
    if nativeGuiRuntimeBundleReadyText == "true" || nativeGuiRuntimeBundleReadyText == "false":
        report = report + "  \"native_gui_runtime_bundle_ready\": " + nativeGuiRuntimeBundleReadyText + ",\n"
    else:
        report = report + "  \"native_gui_runtime_bundle_ready\": null,\n"
    if nativeGuiRuntimeContractReadyText == "true" || nativeGuiRuntimeContractReadyText == "false":
        report = report + "  \"native_gui_runtime_contract_ready\": " + nativeGuiRuntimeContractReadyText + ",\n"
    else:
        report = report + "  \"native_gui_runtime_contract_ready\": null,\n"
    report = report + "  \"native_gui_runtime_bundle_route_state\": " + r2cControllerJsonQuote(nativeGuiRuntimeBundleRouteState) + ",\n"
    report = report + "  \"native_gui_runtime_bundle_route_count\": " + nativeGuiRuntimeBundleRouteCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_supported_count\": " + nativeGuiRuntimeBundleSupportedCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_semantic_nodes_count\": " + nativeGuiRuntimeBundleSemanticNodesCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_layout_item_count\": " + nativeGuiRuntimeBundleLayoutItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_render_command_count\": " + nativeGuiRuntimeBundleRenderCommandCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_layout_item_count\": " + nativeGuiRuntimeContractLayoutItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_viewport_item_count\": " + nativeGuiRuntimeContractViewportItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_interactive_item_count\": " + nativeGuiRuntimeContractInteractiveItemCountText + ",\n"
    report = report + "  \"native_gui_native_layout_plan_item_count\": " + nativeGuiNativeLayoutPlanItemCountText + ",\n"
    report = report + "  \"native_gui_render_plan_command_count\": " + nativeGuiRenderPlanCommandCountText + ",\n"
    if truthCompareOkText == "true" || truthCompareOkText == "false":
        report = report + "  \"truth_compare_ok\": " + truthCompareOkText + ",\n"
    else:
        report = report + "  \"truth_compare_ok\": null,\n"
    report = report + "  \"truth_compare_reason\": " + r2cControllerJsonQuote(truthCompareReason) + ",\n"
    if truthCompareMatrixOkText == "true" || truthCompareMatrixOkText == "false":
        report = report + "  \"truth_compare_matrix_ok\": " + truthCompareMatrixOkText + ",\n"
    else:
        report = report + "  \"truth_compare_matrix_ok\": null,\n"
    report = report + "  \"truth_compare_matrix_reason\": " + r2cControllerJsonQuote(truthCompareMatrixReason) + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerNativeGuiBundle(root: str,
                                args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let routeStateFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--route-state", ""))
    let repo: str = v3path.V3PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = v3path.V3PathAbsolute(repo, outDirFlag)
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk
    let experimentalRoot: str = v3path.V3PathAbsolute(effectiveRoot, "tools/r2c/experimental")
    let tsxHelper: str = os.JoinPath(experimentalRoot, "r2c-react-ts-frontend.mjs")
    let codegenHelper: str = os.JoinPath(experimentalRoot, "r2c-react-codegen-surface.mjs")
    let nativeGuiBundleHelper: str = os.JoinPath(experimentalRoot, "r2c-react-native-gui-bundle.mjs")
    let tsxAstPath: str = os.JoinPath(outDir, "tsx_ast_v1.json")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    let staticSummaryPath: str = os.JoinPath(outDir, "static_surface.summary.env")
    let codegenSummaryPath: str = os.JoinPath(outDir, "codegen_surface.summary.env")
    let nativeGuiBundleSummaryPath: str = os.JoinPath(outDir, "native_gui_bundle.summary.env")
    let reportPath: str = os.JoinPath(outDir, "native_gui_bundle_report_v1.json")
    var codegenManifestPath: str = os.JoinPath(outDir, "cheng_codegen_v1.json")
    var routeCatalogPath: str = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    var execSnapshotPath: str = os.JoinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    var nativeGuiBundlePath: str = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    let nativeGuiHostContractPath: str = os.JoinPath(outDir, "unimaker_host_v1.json")
    let nativeGuiAssetManifestPath: str = os.JoinPath(outDir, "asset_manifest_v1.json")
    let nativeGuiTailwindManifestPath: str = os.JoinPath(outDir, "tailwind_style_manifest_v1.json")
    var moduleCount: int32
    var routeCount: int32
    var semanticNodesCount: int32
    var assetCount: int32
    var tailwindTokenCount: int32
    var requiredHostGroupCount: int32
    var requiredHostGroupsCsv = ""
    var typescriptVersion = ""
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)

    var frontendArgs: str[]
    add(frontendArgs, "--repo")
    add(frontendArgs, repo)
    add(frontendArgs, "--out")
    add(frontendArgs, tsxAstPath)
    add(frontendArgs, "--summary-out")
    add(frontendArgs, tsxSummaryPath)
    let frontendLogPath: str = os.JoinPath(outDir, "tsx_frontend.log")
    if !r2cControllerRunNodeHelper(effectiveRoot, tsxHelper, frontendArgs, frontendLogPath, helperExitCode, helperOutput):
        r2cControllerPrintErr("r2c-react: tsx frontend helper failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1

    moduleCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(tsxSummaryPath, "module_count", "0"))
    typescriptVersion = r2cControllerReadSummaryValue(tsxSummaryPath, "typescript_version", "")

    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    if !r2csurface.r2cRunStaticSurface(repo, outDir, tsxAstPath, staticSummaryPath, [], staticSurface):
        r2cControllerPrintErr("r2c-react: static surface failed")
        if strings.Len(staticSurface.message) > 0:
            r2cControllerPrintErr(staticSurface.message)
        return 1
    assetCount = staticSurface.assetCount
    tailwindTokenCount = staticSurface.tailwindTokenCount
    requiredHostGroupCount = staticSurface.requiredHostGroupCount
    requiredHostGroupsCsv = staticSurface.requiredHostGroupsCsv
    typescriptVersion = staticSurface.typescriptVersion

    var codegenArgs: str[]
    add(codegenArgs, "--repo")
    add(codegenArgs, repo)
    add(codegenArgs, "--out-dir")
    add(codegenArgs, outDir)
    add(codegenArgs, "--tsx-ast")
    add(codegenArgs, tsxAstPath)
    add(codegenArgs, "--summary-out")
    add(codegenArgs, codegenSummaryPath)
    let codegenLogPath: str = os.JoinPath(outDir, "codegen_surface.log")
    if !r2cControllerRunNodeHelper(effectiveRoot, codegenHelper, codegenArgs, codegenLogPath, helperExitCode, helperOutput):
        r2cControllerPrintErr("r2c-react: codegen surface helper failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1

    codegenManifestPath = r2cControllerReadSummaryValue(codegenSummaryPath, "codegen_manifest_path", codegenManifestPath)
    routeCatalogPath = r2cControllerReadSummaryValue(codegenSummaryPath, "route_catalog_path", routeCatalogPath)
    routeCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(codegenSummaryPath, "route_count", "0"))
    typescriptVersion = r2cControllerReadSummaryValue(codegenSummaryPath, "typescript_version", typescriptVersion)

    var nativeGuiBundleArgs: str[]
    add(nativeGuiBundleArgs, "--repo")
    add(nativeGuiBundleArgs, repo)
    add(nativeGuiBundleArgs, "--out-dir")
    add(nativeGuiBundleArgs, outDir)
    add(nativeGuiBundleArgs, "--codegen-manifest")
    add(nativeGuiBundleArgs, codegenManifestPath)
    add(nativeGuiBundleArgs, "--exec-snapshot")
    add(nativeGuiBundleArgs, execSnapshotPath)
    add(nativeGuiBundleArgs, "--host-contract")
    add(nativeGuiBundleArgs, nativeGuiHostContractPath)
    add(nativeGuiBundleArgs, "--asset-manifest")
    add(nativeGuiBundleArgs, nativeGuiAssetManifestPath)
    add(nativeGuiBundleArgs, "--tailwind-manifest")
    add(nativeGuiBundleArgs, nativeGuiTailwindManifestPath)
    add(nativeGuiBundleArgs, "--route-catalog")
    add(nativeGuiBundleArgs, routeCatalogPath)
    add(nativeGuiBundleArgs, "--out")
    add(nativeGuiBundleArgs, nativeGuiBundlePath)
    add(nativeGuiBundleArgs, "--summary-out")
    add(nativeGuiBundleArgs, nativeGuiBundleSummaryPath)
    if strings.Len(routeStateFlag) > 0:
        add(nativeGuiBundleArgs, "--route-state")
        add(nativeGuiBundleArgs, routeStateFlag)
    let nativeGuiBundleLogPath: str = os.JoinPath(outDir, "native_gui_bundle.log")
    if !r2cControllerRunNodeHelper(effectiveRoot, nativeGuiBundleHelper, nativeGuiBundleArgs, nativeGuiBundleLogPath, helperExitCode, helperOutput):
        r2cControllerPrintErr("r2c-react: native gui bundle helper failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1

    nativeGuiBundlePath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_bundle_path", nativeGuiBundlePath)
    semanticNodesCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "initial_semantic_nodes_count", "0"))
    execSnapshotPath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_exec_snapshot_path", execSnapshotPath)
    routeCatalogPath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_route_catalog_path", routeCatalogPath)
    let launcherModule: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_launcher_module", "")
    let hostReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_host_ready", "")
    let rendererReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_renderer_ready", "")
    let sessionPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_path", "")
    let sessionPreviewReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_preview_ready", "")
    let sessionPreviewMode: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_preview_mode", "")
    let routeState: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_route_state", routeStateFlag)
    let layoutSurfacePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_path", "")
    let layoutSurfaceReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_ready", "")
    let layoutSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_node_count", "0")
    let layoutSurfaceSourceModule: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_source_module", "")
    let layoutSurfaceSourceComponent: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_source_component", "")
    let layoutSurfaceStrategy: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_strategy", "")
    let layoutSurfaceComponentExpansionCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_component_expansion_count", "0")
    let layoutSurfaceParsedModuleCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_parsed_module_count", "0")
    let layoutSurfaceStyledNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_styled_node_count", "0")
    let layoutSurfaceInteractiveNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_interactive_node_count", "0")
    let styleLayoutSurfacePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_path", "")
    let styleLayoutSurfaceReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_ready", "")
    let styleLayoutSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_node_count", "0")
    let styleLayoutOverlayNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_overlay_node_count", "0")
    let styleLayoutSurfaceSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_surface_node_count", "0")
    let styleLayoutSurfaceControlNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_control_node_count", "0")
    let nativeLayoutPlanPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_path", "")
    let nativeLayoutPlanReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_ready", "")
    let nativeLayoutPlanPolicySource: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_policy_source", "")
    let nativeLayoutPlanItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_item_count", "0")
    let nativeLayoutPlanViewportItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_viewport_item_count", "0")
    let nativeLayoutPlanClippedItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_clipped_item_count", "0")
    let nativeLayoutPlanInteractiveItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_interactive_item_count", "0")
    let nativeLayoutPlanSourceBackedItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_source_backed_item_count", "0")
    let nativeLayoutPlanScrollHeightText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_scroll_height", "0")
    let nativeRenderPlanPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_render_plan_path", "")
    var nativeRenderPlanReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_render_plan_ready", "")
    var nativeRenderPlanCommandCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_render_plan_command_count", "0")
    var nativeRenderPlanVisibleLayoutItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_render_plan_visible_layout_item_count", "0")
    let nativeRuntimePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_path", "")
    var nativeRuntimeReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_ready", "")
    let nativeRuntimeStatePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_state_path", "")
    let nativeRuntimeExePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_exe_path", "")
    let nativeRuntimeLauncherExePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_launcher_exe_path", "")
    let nativeRuntimeCompiledExePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_compiled_exe_path", "")
    let nativeRuntimeContractPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_path", "")
    let nativeRuntimeMode: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_mode", "")
    var nativeRuntimeBundleReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_ready", "")
    var nativeRuntimeContractReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_ready", "")
    var nativeRuntimeBundleRouteState: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_route_state", routeState)
    var nativeRuntimeBundleRouteCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_route_count", "0")
    var nativeRuntimeBundleSupportedCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_supported_count", "0")
    var nativeRuntimeBundleSemanticNodesCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_semantic_nodes_count", "0")
    var nativeRuntimeBundleLayoutItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_layout_item_count", "0")
    var nativeRuntimeBundleRenderCommandCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_render_command_count", "0")
    var nativeRuntimeContractLayoutItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_layout_item_count", "0")
    var nativeRuntimeContractViewportItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_viewport_item_count", "0")
    var nativeRuntimeContractInteractiveItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_interactive_item_count", "0")
    let reportModuleCountText: str = r2cControllerReadSummaryValue(codegenSummaryPath, "module_count", r2cControllerReadSummaryValue(tsxSummaryPath, "module_count", "0"))
    let reportRouteCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "route_count", r2cControllerReadSummaryValue(codegenSummaryPath, "route_count", "0"))
    let reportSupportedCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "supported_count", nativeRuntimeBundleSupportedCountText)
    let reportUnsupportedCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "unsupported_count", "0")
    let reportSemanticNodesCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "initial_semantic_nodes_count", "0")
    let reportAssetCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "asset_count", r2cControllerReadSummaryValue(staticSummaryPath, "asset_count", "0"))
