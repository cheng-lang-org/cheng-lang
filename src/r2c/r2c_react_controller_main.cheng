fn r2cControllerByteBufferAlloc(length: int32): binbytes.ByteBuffer =
    var out: binbytes.ByteBuffer
    out.len = length
    if length > 0:
        out.data = alloc(length)
        rawmem.RawmemSet(out.data, 0, length)
    return out

fn r2cControllerByteBufferView(buf: binbytes.ByteBuffer): rawbytes.Bytes =
    var out: rawbytes.Bytes
    out.data = buf.data
    out.len = buf.len
    return out

fn r2cControllerByteBufferSha256Hex(buf: binbytes.ByteBuffer): str =
    if buf.data == nil || buf.len <= 0:
        return ""
    let view: rawbytes.Bytes = r2cControllerByteBufferView(buf)
    let digest: rawbytes.Bytes = sha256.sha256Digest(view)
    return rawbytes.BytesToHex(digest)

fn r2cControllerPngReadU32BE(buf: binbytes.ByteBuffer,
                             offset: int32): int32 =
    if offset < 0 || offset + 4 > buf.len:
        return -1
    let b0: int64 = int64(binbytes.BufByteAt(buf, offset))
    let b1: int64 = int64(binbytes.BufByteAt(buf, offset + 1))
    let b2: int64 = int64(binbytes.BufByteAt(buf, offset + 2))
    let b3: int64 = int64(binbytes.BufByteAt(buf, offset + 3))
    let value: int64 = (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
    if value > int64(2147483647):
        return -1
    return int32(value)

fn r2cControllerPngChunkType(buf: binbytes.ByteBuffer,
                             offset: int32): str =
    if offset < 0 || offset + 4 > buf.len:
        return ""
    var out = ""
    for i in 0..<4:
        out = out + strings.CharToStr(char(binbytes.BufByteAt(buf, offset + i)))
    return out

fn r2cControllerPngSignatureOk(buf: binbytes.ByteBuffer): bool =
    if buf.len < 8:
        return false
    return binbytes.BufByteAt(buf, 0) == 0x89 &&
           binbytes.BufByteAt(buf, 1) == 0x50 &&
           binbytes.BufByteAt(buf, 2) == 0x4e &&
           binbytes.BufByteAt(buf, 3) == 0x47 &&
           binbytes.BufByteAt(buf, 4) == 0x0d &&
           binbytes.BufByteAt(buf, 5) == 0x0a &&
           binbytes.BufByteAt(buf, 6) == 0x1a &&
           binbytes.BufByteAt(buf, 7) == 0x0a

fn r2cControllerPngAppendRange(dst: var binbytes.ByteBuffer,
                               src: binbytes.ByteBuffer,
                               start: int32,
                               count: int32): bool =
    if count <= 0:
        return true
    if start < 0 || start + count > src.len:
        return false
    let oldLen: int32 = dst.len
    let newLen: int32 = oldLen + count
    var merged: binbytes.ByteBuffer = r2cControllerByteBufferAlloc(newLen)
    if merged.data == nil:
        return false
    if oldLen > 0 && dst.data != nil:
        rawmem.RawmemCopy(merged.data, dst.data, oldLen)
    rawmem.RawmemCopy(rawmem.RawmemPtrAdd(merged.data, oldLen),
                      rawmem.RawmemPtrAdd(src.data, start),
                      count)
    if dst.data != nil:
        binbytes.FreeByteBuffer(dst)
    dst = merged
    return true

fn r2cControllerPngBytesPerPixel(colorType: int32): int32 =
    if colorType == 0:
        return 1
    if colorType == 2:
        return 3
    if colorType == 4:
        return 2
    if colorType == 6:
        return 4
    return 0

fn r2cControllerPngPaeth(left: int32,
                         up: int32,
                         upLeft: int32): int32 =
    let p: int32 = left + up - upLeft
    var pa: int32 = p - left
    if pa < 0:
        pa = 0 - pa
    var pb: int32 = p - up
    if pb < 0:
        pb = 0 - pb
    var pc: int32 = p - upLeft
    if pc < 0:
        pc = 0 - pc
    if pa <= pb && pa <= pc:
        return left
    if pb <= pc:
        return up
    return upLeft

fn r2cControllerPngDecodeRows(path: str,
                              inflated: binbytes.ByteBuffer,
                              width: int32,
                              height: int32,
                              colorType: int32,
                              bytesPerPixel: int32,
                              out: var R2cPngImage): bool =
    let rowBytes: int32 = width * bytesPerPixel
    let pixelBytes: int32 = width * height * 4
    var pixels: binbytes.ByteBuffer = r2cControllerByteBufferAlloc(pixelBytes)
    var previous: binbytes.ByteBuffer = r2cControllerByteBufferAlloc(rowBytes)
    var current: binbytes.ByteBuffer = r2cControllerByteBufferAlloc(rowBytes)
    if pixelBytes > 0 && pixels.data == nil:
        out.reason = "png_alloc_pixels_failed:" + path
        return false
    if rowBytes > 0 && (previous.data == nil || current.data == nil):
        out.reason = "png_alloc_rows_failed:" + path
        return false
    var inOffset: int32
    for y in 0..<height:
        if inOffset >= inflated.len:
            out.reason = "png_inflated_truncated:" + path
            return false
        let filterType: int32 = binbytes.BufByteAt(inflated, inOffset)
        inOffset = inOffset + 1
        for x in 0..<rowBytes:
            if inOffset >= inflated.len:
                out.reason = "png_row_truncated:" + path
                return false
            let rawValue: int32 = binbytes.BufByteAt(inflated, inOffset)
            inOffset = inOffset + 1
            let left: int32 = x >= bytesPerPixel ? binbytes.BufByteAt(current, x - bytesPerPixel) : 0
            let up: int32 = binbytes.BufByteAt(previous, x)
            let upLeft: int32 = x >= bytesPerPixel ? binbytes.BufByteAt(previous, x - bytesPerPixel) : 0
            var value: int32 = rawValue
            if filterType == 1:
                value = (rawValue + left) & 255
            elif filterType == 2:
                value = (rawValue + up) & 255
            elif filterType == 3:
                value = (rawValue + ((left + up) / 2)) & 255
            elif filterType == 4:
                value = (rawValue + r2cControllerPngPaeth(left, up, upLeft)) & 255
            elif filterType != 0:
                out.reason = "png_filter_unsupported:" + intToStr(filterType)
                return false
            binbytes.BufSetByte(current, x, value)
        for x in 0..<width:
            let dst: int32 = (y * width + x) * 4
            if colorType == 0:
                let gray: int32 = binbytes.BufByteAt(current, x)
                binbytes.BufSetByte(pixels, dst, gray)
                binbytes.BufSetByte(pixels, dst + 1, gray)
                binbytes.BufSetByte(pixels, dst + 2, gray)
                binbytes.BufSetByte(pixels, dst + 3, 255)
            elif colorType == 2:
                let src: int32 = x * 3
                binbytes.BufSetByte(pixels, dst, binbytes.BufByteAt(current, src))
                binbytes.BufSetByte(pixels, dst + 1, binbytes.BufByteAt(current, src + 1))
                binbytes.BufSetByte(pixels, dst + 2, binbytes.BufByteAt(current, src + 2))
                binbytes.BufSetByte(pixels, dst + 3, 255)
            elif colorType == 4:
                let src: int32 = x * 2
                let gray: int32 = binbytes.BufByteAt(current, src)
                binbytes.BufSetByte(pixels, dst, gray)
                binbytes.BufSetByte(pixels, dst + 1, gray)
                binbytes.BufSetByte(pixels, dst + 2, gray)
                binbytes.BufSetByte(pixels, dst + 3, binbytes.BufByteAt(current, src + 1))
            else:
                let src: int32 = x * 4
                binbytes.BufSetByte(pixels, dst, binbytes.BufByteAt(current, src))
                binbytes.BufSetByte(pixels, dst + 1, binbytes.BufByteAt(current, src + 1))
                binbytes.BufSetByte(pixels, dst + 2, binbytes.BufByteAt(current, src + 2))
                binbytes.BufSetByte(pixels, dst + 3, binbytes.BufByteAt(current, src + 3))
        rawmem.RawmemCopy(previous.data, current.data, rowBytes)
    binbytes.FreeByteBuffer(previous)
    binbytes.FreeByteBuffer(current)
    out.ok = true
    out.reason = "ok"
    out.pixels = pixels
    out.width = width
    out.height = height
    out.pixelSha256 = r2cControllerByteBufferSha256Hex(pixels)
    return true

fn r2cControllerDecodePng(path: str): R2cPngImage =
    var out: R2cPngImage
    out.path = path
    var fileBytes: binbytes.ByteBuffer = binbytes.ReadFileBytes(path)
    out.fileSize = fileBytes.len
    if fileBytes.data == nil || fileBytes.len <= 0:
        out.reason = "png_file_empty:" + path
        return out
    out.fileSha256 = r2cControllerByteBufferSha256Hex(fileBytes)
    if !r2cControllerPngSignatureOk(fileBytes):
        out.reason = "png_signature_mismatch:" + path
        binbytes.FreeByteBuffer(fileBytes)
        return out
    var width: int32
    var height: int32
    var bitDepth: int32
    var colorType: int32
    var compression: int32
    var filterMethod: int32
    var interlace: int32
    var idat: binbytes.ByteBuffer
    var offset: int32 = 8
    while offset + 12 <= fileBytes.len:
        let chunkLen: int32 = r2cControllerPngReadU32BE(fileBytes, offset)
        let chunkType: str = r2cControllerPngChunkType(fileBytes, offset + 4)
        let dataStart: int32 = offset + 8
        let dataEnd: int32 = dataStart + chunkLen
        let nextOffset: int32 = dataEnd + 4
        if chunkLen < 0 || dataEnd < dataStart || nextOffset > fileBytes.len:
            out.reason = "png_chunk_range_invalid:" + path
            binbytes.FreeByteBuffer(fileBytes)
            binbytes.FreeByteBuffer(idat)
            return out
        if chunkType == "IHDR":
            width = r2cControllerPngReadU32BE(fileBytes, dataStart)
            height = r2cControllerPngReadU32BE(fileBytes, dataStart + 4)
            bitDepth = binbytes.BufByteAt(fileBytes, dataStart + 8)
            colorType = binbytes.BufByteAt(fileBytes, dataStart + 9)
            compression = binbytes.BufByteAt(fileBytes, dataStart + 10)
            filterMethod = binbytes.BufByteAt(fileBytes, dataStart + 11)
            interlace = binbytes.BufByteAt(fileBytes, dataStart + 12)
        elif chunkType == "IDAT":
            if !r2cControllerPngAppendRange(idat, fileBytes, dataStart, chunkLen):
                out.reason = "png_idat_append_failed:" + path
                binbytes.FreeByteBuffer(fileBytes)
                binbytes.FreeByteBuffer(idat)
                return out
        elif chunkType == "IEND":
            break
        offset = nextOffset
    if width <= 0 || height <= 0:
        out.reason = "png_missing_ihdr:" + path
        binbytes.FreeByteBuffer(fileBytes)
        binbytes.FreeByteBuffer(idat)
        return out
    if bitDepth != 8 || compression != 0 || filterMethod != 0 || interlace != 0:
        out.reason = "png_format_unsupported:" + intToStr(bitDepth) + ":" + intToStr(compression) + ":" + intToStr(filterMethod) + ":" + intToStr(interlace)
        binbytes.FreeByteBuffer(fileBytes)
        binbytes.FreeByteBuffer(idat)
        return out
    let bytesPerPixel: int32 = r2cControllerPngBytesPerPixel(colorType)
    if bytesPerPixel <= 0:
        out.reason = "png_color_type_unsupported:" + intToStr(colorType)
        binbytes.FreeByteBuffer(fileBytes)
        binbytes.FreeByteBuffer(idat)
        return out
    let expectedInflated: int32 = (width * bytesPerPixel + 1) * height
    if expectedInflated <= 0 || expectedInflated > 268435456:
        out.reason = "png_size_unsupported:" + intToStr(width) + "x" + intToStr(height)
        binbytes.FreeByteBuffer(fileBytes)
        binbytes.FreeByteBuffer(idat)
        return out
    let inflateRes: Result[binbytes.ByteBuffer] = zlib.WowZlibInflate(idat, 0, idat.len, expectedInflated)
    if IsErr(inflateRes):
        out.reason = "png_inflate_failed:" + Error(inflateRes)
        binbytes.FreeByteBuffer(fileBytes)
        binbytes.FreeByteBuffer(idat)
        return out
    var inflated: binbytes.ByteBuffer = Value(inflateRes)
    if !r2cControllerPngDecodeRows(path, inflated, width, height, colorType, bytesPerPixel, out):
        binbytes.FreeByteBuffer(fileBytes)
        binbytes.FreeByteBuffer(idat)
        binbytes.FreeByteBuffer(inflated)
        return out
    binbytes.FreeByteBuffer(fileBytes)
    binbytes.FreeByteBuffer(idat)
    binbytes.FreeByteBuffer(inflated)
    return out

fn r2cControllerPngDiffRatioText(diffPixelCount: int32,
                                 pixelCount: int32): str =
    if pixelCount <= 0:
        return "0"
    if diffPixelCount <= 0:
        return "0"
    let scaled: int32 = (diffPixelCount * 1000000) / pixelCount
    let whole: int32 = scaled / 1000000
    var frac: str = intToStr(scaled % 1000000)
    while strings.Len(frac) < 6:
        frac = "0" + frac
    return intToStr(whole) + "." + frac

fn r2cControllerComparePngImages(left: R2cPngImage,
                                 right: R2cPngImage): R2cPngCompare =
    var out: R2cPngCompare
    out.width = left.width
    out.height = left.height
    out.otherWidth = right.width
    out.otherHeight = right.height
    out.firstDiffJson = "null"
    if !left.ok:
        out.reason = left.reason
        return out
    if !right.ok:
        out.reason = right.reason
        return out
    if left.width != right.width || left.height != right.height:
        out.reason = "dimension_mismatch"
        out.diffRatioText = "1"
        out.maxChannelDelta = 255
        return out
    out.pixelCount = left.width * left.height
    var index: int32
    while index < left.pixels.len:
        var different = false
        for channel in 0..<4:
            let leftValue: int32 = binbytes.BufByteAt(left.pixels, index + channel)
            let rightValue: int32 = binbytes.BufByteAt(right.pixels, index + channel)
            var delta: int32 = leftValue - rightValue
            if delta < 0:
                delta = 0 - delta
            out.totalAbsDelta = out.totalAbsDelta + delta
            if delta > 0:
                different = true
            if delta > out.maxChannelDelta:
                out.maxChannelDelta = delta
        if different:
            out.diffPixelCount = out.diffPixelCount + 1
            if out.firstDiffJson == "null":
                let pixelIndex: int32 = index / 4
                out.firstDiffJson = "{"
                out.firstDiffJson = out.firstDiffJson + "\"x\":" + intToStr(pixelIndex % left.width)
                out.firstDiffJson = out.firstDiffJson + ",\"y\":" + intToStr(pixelIndex / left.width)
                out.firstDiffJson = out.firstDiffJson + "}"
        index = index + 4
    out.ok = out.diffPixelCount == 0
    out.reason = out.ok ? "ok" : "pixel_mismatch"
    out.diffRatioText = r2cControllerPngDiffRatioText(out.diffPixelCount, out.pixelCount)
    return out

fn r2cControllerRenderCompareDirectEnabled(nativeSummaryFlag: str,
                                           truthSummaryFlag: str,
                                           nativeScreenshotFlag: str,
                                           truthScreenshotFlag: str): bool =
    return strings.Len(nativeSummaryFlag) > 0 ||
           strings.Len(truthSummaryFlag) > 0 ||
           strings.Len(nativeScreenshotFlag) > 0 ||
           strings.Len(truthScreenshotFlag) > 0

fn r2cControllerRenderCompareDirectRequire(nativeSummaryPath: str,
                                           truthSummaryPath: str,
                                           nativeScreenshotPath: str,
                                           truthScreenshotPath: str): bool =
    if strings.Len(nativeSummaryPath) <= 0:
        r2cControllerPrintErr("r2c-react: render-compare direct mode missing --native-summary")
        return false
    if strings.Len(truthSummaryPath) <= 0:
        r2cControllerPrintErr("r2c-react: render-compare direct mode missing --truth-summary")
        return false
    if strings.Len(nativeScreenshotPath) <= 0:
        r2cControllerPrintErr("r2c-react: render-compare direct mode missing --native-screenshot")
        return false
    if strings.Len(truthScreenshotPath) <= 0:
        r2cControllerPrintErr("r2c-react: render-compare direct mode missing --truth-screenshot")
        return false
    if !chengpath.PathFileExists(nativeSummaryPath):
        r2cControllerPrintErr("r2c-react: render-compare missing native summary: " + nativeSummaryPath)
        return false
    if !chengpath.PathFileExists(truthSummaryPath):
        r2cControllerPrintErr("r2c-react: render-compare missing truth summary: " + truthSummaryPath)
        return false
    if !chengpath.PathFileExists(nativeScreenshotPath):
        r2cControllerPrintErr("r2c-react: render-compare missing native screenshot: " + nativeScreenshotPath)
        return false
    if !chengpath.PathFileExists(truthScreenshotPath):
        r2cControllerPrintErr("r2c-react: render-compare missing truth screenshot: " + truthScreenshotPath)
        return false
    return true

fn r2cControllerRenderCompareWriteDirectReport(repo: str,
                                               outDir: str,
                                               routeState: str,
                                               summaryPath: str,
                                               reportPath: str,
                                               nativeSummaryPath: str,
                                               truthSummaryPath: str,
                                               nativeScreenshotPath: str,
                                               truthScreenshotPath: str,
                                               nativePng: R2cPngImage,
                                               truthPng: R2cPngImage,
                                               compare: R2cPngCompare): bool =
    let nativeRuntimeBundleSemanticNodesCountText: str = r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_semantic_nodes_count", "0")
    let truthSemanticNodesCountText: str = r2cControllerReadSummaryValue(truthSummaryPath, "semantic_nodes_count", "0")
    let semanticDelta: int32 = r2cControllerParseInt32(nativeRuntimeBundleSemanticNodesCountText) - r2cControllerParseInt32(truthSemanticNodesCountText)
    let nativeRouteState: str = r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_route_state", "")
    let routeStateMatch: bool = nativeRouteState == routeState
    let nativeWindowWidthText: str = r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_window_width", intToStr(nativePng.width))
    let nativeWindowHeightText: str = r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_window_height", intToStr(nativePng.height))
    let truthTracePath: str = r2cControllerReadSummaryValue(truthSummaryPath, "truth_trace_path", "")
    let truthTraceFormat: str = r2cControllerReadSummaryValue(truthSummaryPath, "truth_trace_format", "")
    let truthDomHash: str = r2cControllerReadSummaryValue(truthSummaryPath, "dom_hash", "")
    let truthScreenshotSha256: str = r2cControllerReadSummaryValue(truthSummaryPath, "screenshot_sha256", truthPng.fileSha256)
    var report = "{\n"
    report = report + "  \"format\": \"render_compare_v1\",\n"
    report = report + "  \"ok\": " + r2cControllerJsonBool(compare.ok) + ",\n"
    report = report + "  \"reason\": " + r2cControllerJsonQuote(compare.reason) + ",\n"
    report = report + "  \"direct_mode\": true,\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(r2cControllerRoot()) + ",\n"
    report = report + "  \"route_state\": " + r2cControllerJsonQuote(routeState) + ",\n"
    report = report + "  \"stage3_path\": \"\",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"native_gui_summary_ready\": true,\n"
    report = report + "  \"native_gui_summary_path\": " + r2cControllerJsonQuote(nativeSummaryPath) + ",\n"
    report = report + "  \"truth_summary_path\": " + r2cControllerJsonQuote(truthSummaryPath) + ",\n"
    report = report + "  \"native_gui_route_state\": " + r2cControllerJsonQuote(nativeRouteState) + ",\n"
    report = report + "  \"native_gui_screenshot_path\": " + r2cControllerJsonQuote(nativeScreenshotPath) + ",\n"
    report = report + "  \"native_gui_runtime_bundle_ready\": " + r2cControllerJsonBoolTextOrFalse(r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_ready", "")) + ",\n"
    report = report + "  \"native_gui_runtime_contract_ready\": " + r2cControllerJsonBoolTextOrFalse(r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_contract_ready", "")) + ",\n"
    report = report + "  \"native_gui_runtime_bundle_route_state\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_route_state", "")) + ",\n"
    report = report + "  \"native_gui_runtime_bundle_semantic_nodes_count\": " + nativeRuntimeBundleSemanticNodesCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_layout_item_count\": " + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_layout_item_count", "0") + ",\n"
    report = report + "  \"native_gui_runtime_bundle_render_command_count\": " + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_render_command_count", "0") + ",\n"
    report = report + "  \"native_gui_runtime_contract_interactive_item_count\": " + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_contract_interactive_item_count", "0") + ",\n"
    report = report + "  \"native_gui_native_layout_plan_item_count\": " + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_native_layout_plan_item_count", "0") + ",\n"
    report = report + "  \"native_gui_render_plan_command_count\": " + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_render_plan_command_count", "0") + ",\n"
    report = report + "  \"truth_trace_path\": " + r2cControllerJsonQuote(truthTracePath) + ",\n"
    report = report + "  \"truth_trace_format\": " + r2cControllerJsonQuote(truthTraceFormat) + ",\n"
    report = report + "  \"truth_screenshot_path\": " + r2cControllerJsonQuote(truthScreenshotPath) + ",\n"
    report = report + "  \"truth_semantic_nodes_count\": " + truthSemanticNodesCountText + ",\n"
    report = report + "  \"truth_document_nodes_count\": " + r2cControllerReadSummaryValue(truthSummaryPath, "document_nodes_count", "0") + ",\n"
    report = report + "  \"truth_dom_hash\": " + r2cControllerJsonQuote(truthDomHash) + ",\n"
    report = report + "  \"truth_screenshot_sha256\": " + r2cControllerJsonQuote(truthScreenshotSha256) + ",\n"
    report = report + "  \"route_state_match\": " + r2cControllerJsonBool(routeStateMatch) + ",\n"
    report = report + "  \"semantic_nodes_count_delta\": " + intToStr(semanticDelta) + ",\n"
    report = report + "  \"native_window_width\": " + nativeWindowWidthText + ",\n"
    report = report + "  \"native_window_height\": " + nativeWindowHeightText + ",\n"
    report = report + "  \"truth_window_width\": " + intToStr(truthPng.width) + ",\n"
    report = report + "  \"truth_window_height\": " + intToStr(truthPng.height) + ",\n"
    report = report + "  \"native_screenshot_path\": " + r2cControllerJsonQuote(nativeScreenshotPath) + ",\n"
    report = report + "  \"native_file_sha256\": " + r2cControllerJsonQuote(nativePng.fileSha256) + ",\n"
    report = report + "  \"truth_file_sha256\": " + r2cControllerJsonQuote(truthPng.fileSha256) + ",\n"
    report = report + "  \"native_pixel_sha256\": " + r2cControllerJsonQuote(nativePng.pixelSha256) + ",\n"
    report = report + "  \"truth_pixel_sha256\": " + r2cControllerJsonQuote(truthPng.pixelSha256) + ",\n"
    report = report + "  \"pixel_count\": " + intToStr(compare.pixelCount) + ",\n"
    report = report + "  \"diff_pixel_count\": " + intToStr(compare.diffPixelCount) + ",\n"
    report = report + "  \"diff_ratio\": " + compare.diffRatioText + ",\n"
    report = report + "  \"max_channel_delta\": " + intToStr(compare.maxChannelDelta) + ",\n"
    report = report + "  \"total_abs_delta\": " + intToStr(compare.totalAbsDelta) + ",\n"
    report = report + "  \"first_diff\": " + compare.firstDiffJson + "\n"
    report = report + "}\n"
    if !chengpath.WriteTextFile("", reportPath, report):
        return false
    var summary = ""
    summary = summary + "ok=" + r2cControllerJsonBool(compare.ok) + "\n"
    summary = summary + "reason=" + compare.reason + "\n"
    summary = summary + "direct_mode=true\n"
    summary = summary + "route_state=" + routeState + "\n"
    summary = summary + "route_state_match=" + r2cControllerJsonBool(routeStateMatch) + "\n"
    summary = summary + "native_gui_summary_path=" + nativeSummaryPath + "\n"
    summary = summary + "truth_summary_path=" + truthSummaryPath + "\n"
    summary = summary + "native_screenshot_path=" + nativeScreenshotPath + "\n"
    summary = summary + "truth_screenshot_path=" + truthScreenshotPath + "\n"
    summary = summary + "native_gui_runtime_bundle_ready=" + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_ready", "") + "\n"
    summary = summary + "native_gui_runtime_contract_ready=" + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_contract_ready", "") + "\n"
    summary = summary + "native_gui_runtime_bundle_route_state=" + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_route_state", "") + "\n"
    summary = summary + "native_gui_runtime_bundle_semantic_nodes_count=" + nativeRuntimeBundleSemanticNodesCountText + "\n"
    summary = summary + "native_gui_runtime_bundle_layout_item_count=" + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_layout_item_count", "0") + "\n"
    summary = summary + "native_gui_runtime_bundle_render_command_count=" + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_bundle_render_command_count", "0") + "\n"
    summary = summary + "native_gui_runtime_contract_interactive_item_count=" + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_runtime_contract_interactive_item_count", "0") + "\n"
    summary = summary + "native_gui_native_layout_plan_item_count=" + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_native_layout_plan_item_count", "0") + "\n"
    summary = summary + "native_gui_render_plan_command_count=" + r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_render_plan_command_count", "0") + "\n"
    summary = summary + "truth_trace_path=" + truthTracePath + "\n"
    summary = summary + "truth_trace_format=" + truthTraceFormat + "\n"
    summary = summary + "truth_semantic_nodes_count=" + truthSemanticNodesCountText + "\n"
    summary = summary + "truth_document_nodes_count=" + r2cControllerReadSummaryValue(truthSummaryPath, "document_nodes_count", "0") + "\n"
    summary = summary + "truth_dom_hash=" + truthDomHash + "\n"
    summary = summary + "truth_screenshot_sha256=" + truthScreenshotSha256 + "\n"
    summary = summary + "semantic_nodes_count_delta=" + intToStr(semanticDelta) + "\n"
    summary = summary + "native_window_width=" + nativeWindowWidthText + "\n"
    summary = summary + "native_window_height=" + nativeWindowHeightText + "\n"
    summary = summary + "pixel_count=" + intToStr(compare.pixelCount) + "\n"
    summary = summary + "diff_pixel_count=" + intToStr(compare.diffPixelCount) + "\n"
    summary = summary + "diff_ratio=" + compare.diffRatioText + "\n"
    summary = summary + "max_channel_delta=" + intToStr(compare.maxChannelDelta) + "\n"
    summary = summary + "total_abs_delta=" + intToStr(compare.totalAbsDelta) + "\n"
    summary = summary + "report_path=" + reportPath + "\n"
    return chengpath.WriteTextFile("", summaryPath, summary)

fn r2cControllerRenderCompareDirectRun(repo: str,
                                       outDir: str,
                                       routeState: str,
                                       summaryPath: str,
                                       reportPath: str,
                                       nativeSummaryPath: str,
                                       truthSummaryPath: str,
                                       nativeScreenshotPath: str,
                                       truthScreenshotPath: str): int32 =
    if !r2cControllerRenderCompareDirectRequire(nativeSummaryPath, truthSummaryPath, nativeScreenshotPath, truthScreenshotPath):
        return 1
    var nativePng: R2cPngImage = r2cControllerDecodePng(nativeScreenshotPath)
    if !nativePng.ok:
        r2cControllerPrintErr("r2c-react: native png decode failed: " + nativePng.reason)
        return 1
    var truthPng: R2cPngImage = r2cControllerDecodePng(truthScreenshotPath)
    if !truthPng.ok:
        r2cControllerPrintErr("r2c-react: truth png decode failed: " + truthPng.reason)
        binbytes.FreeByteBuffer(nativePng.pixels)
        return 1
    let compare: R2cPngCompare = r2cControllerComparePngImages(nativePng, truthPng)
    if !r2cControllerRenderCompareWriteDirectReport(repo,
                                                    outDir,
                                                    routeState,
                                                    summaryPath,
                                                    reportPath,
                                                    nativeSummaryPath,
                                                    truthSummaryPath,
                                                    nativeScreenshotPath,
                                                    truthScreenshotPath,
                                                    nativePng,
                                                    truthPng,
                                                    compare):
        r2cControllerPrintErr("r2c-react: render-compare failed to write direct report: " + reportPath)
        binbytes.FreeByteBuffer(nativePng.pixels)
        binbytes.FreeByteBuffer(truthPng.pixels)
        return 1
    binbytes.FreeByteBuffer(nativePng.pixels)
    binbytes.FreeByteBuffer(truthPng.pixels)
    if !compare.ok:
        return 3
    return 0

fn r2cControllerRenderCompare(root: str,
                              args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let routeFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--route", cmdline.ReadFlagOrDefault("--route-state", "")))
    if strings.Len(routeFlag) <= 0:
        r2cControllerPrintErr("r2c-react: render-compare missing --route")
        return 1
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let summaryOutFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--summary-out", ""))
    let outFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out", ""))
    let baseUrl: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--base-url", ""))
    let toolingBin: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--tooling-bin", ""))
    let autoCloseMs: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--auto-close-ms", ""))
    let resizeSpec: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--resize", ""))
    let waitMs: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--wait-ms", ""))
    let browserWidth: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--browser-width", ""))
    let browserHeight: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--browser-height", ""))
    let nativeSummaryFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--native-summary", ""))
    let truthSummaryFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-summary", ""))
    let nativeScreenshotFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--native-screenshot", ""))
    let truthScreenshotFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-screenshot", ""))
    let repo: str = chengpath.PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = os.JoinPath(chengpath.PathAbsolute(repo, "build/r2c_react_render_compare"), routeFlag)
    if strings.Len(outDirFlag) > 0:
        outDir = chengpath.PathAbsolute(repo, outDirFlag)
    let scratchOk: bool = chengpath.MkdirP("", outDir)
    scratchOk
    var summaryPath: str = os.JoinPath(outDir, "render_compare.summary.env")
    var reportPath: str = os.JoinPath(outDir, "render_compare_report_v1.json")
    if strings.Len(summaryOutFlag) > 0:
        summaryPath = chengpath.PathAbsolute(outDir, summaryOutFlag)
    if strings.Len(outFlag) > 0:
        reportPath = chengpath.PathAbsolute(outDir, outFlag)

    if !r2cControllerRenderCompareDirectEnabled(nativeSummaryFlag, truthSummaryFlag, nativeScreenshotFlag, truthScreenshotFlag):
        r2cControllerPrintErr("r2c-react: render-compare now requires direct native/truth artifacts; run native-gui-bundle/run-native-gui and capture-truth explicitly, then pass --native-summary --truth-summary --native-screenshot --truth-screenshot")
        return 1

    let nativeSummaryPath: str = chengpath.PathAbsolute(outDir, nativeSummaryFlag)
    let truthSummaryPath: str = chengpath.PathAbsolute(outDir, truthSummaryFlag)
    let nativeScreenshotPath: str = chengpath.PathAbsolute(outDir, nativeScreenshotFlag)
    let truthScreenshotPath: str = chengpath.PathAbsolute(outDir, truthScreenshotFlag)
    let directRc: int32 = r2cControllerRenderCompareDirectRun(repo,
                                                              outDir,
                                                              routeFlag,
                                                              summaryPath,
                                                              reportPath,
                                                              nativeSummaryPath,
                                                              truthSummaryPath,
                                                              nativeScreenshotPath,
                                                              truthScreenshotPath)
    if chengpath.PathFileExists(reportPath):
        r2cControllerPrintLine(reportPath)
    return directRc

fn r2cControllerRenderCompareMatrixReason(directCompareFailedCount: int32,
                                          notOkCount: int32,
                                          routeStateMismatchCount: int32,
                                          pixelMismatchCount: int32,
                                          semanticDeltaCount: int32): str =
    if directCompareFailedCount > 0:
        return "direct_compare_failed"
    if routeStateMismatchCount > 0:
        return "route_state_mismatch"
    if pixelMismatchCount > 0:
        return "pixel_mismatch"
    if semanticDeltaCount > 0:
        return "semantic_node_count_delta"
    if notOkCount > 0:
        return "compare_failed"
    return "ok"

fn r2cControllerRenderCompareMatrix(root: str,
                                    args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let matrixFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--matrix", cmdline.ReadFlagOrDefault("--render-compare-matrix", "")))
    if strings.Len(matrixFlag) <= 0:
        r2cControllerPrintErr("r2c-react: render-compare-matrix missing --matrix")
        return 1
    let repo: str = chengpath.PathAbsolute(effectiveRoot, repoBase)
    let matrixPath: str = chengpath.PathAbsolute(currentDir, matrixFlag)
    if !chengpath.PathFileExists(matrixPath):
        r2cControllerPrintErr("r2c-react: render-compare-matrix missing matrix: " + matrixPath)
        return 1
    let matrixDir: str = chengpath.PathParentDir(matrixPath)
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    var outDir: str = os.JoinPath(matrixDir, "render_compare_matrix")
    if strings.Len(outDirFlag) > 0:
        outDir = chengpath.PathAbsolute(repo, outDirFlag)
    let scratchOk: bool = chengpath.MkdirP("", outDir)
    scratchOk
    let outFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out", ""))
    let summaryOutFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--summary-out", ""))
    var matrixOutPath: str = os.JoinPath(outDir, "render_compare_matrix_v1.json")
    var matrixSummaryPath: str = os.JoinPath(outDir, "render_compare_matrix.summary.env")
    if strings.Len(outFlag) > 0:
        matrixOutPath = chengpath.PathAbsolute(outDir, outFlag)
    if strings.Len(summaryOutFlag) > 0:
        matrixSummaryPath = chengpath.PathAbsolute(outDir, summaryOutFlag)
    let controllerReportPath: str = os.JoinPath(outDir, "render_compare_matrix_report_v1.json")
    let matrixText: str = chengpath.ReadTextFile("", matrixPath)
    let entriesRaw: str = r2cControllerJsonReadArrayFieldRaw(matrixText, "entries", "")
    if strings.Len(entriesRaw) <= 0:
        r2cControllerPrintErr("r2c-react: render-compare-matrix missing entries[]")
        return 1
    var entriesJson = "["
    var wroteEntry = false
    var routeCount: int32
    var okCount: int32
    var notOkCount: int32
    var directCompareFailedCount: int32
    var routeStateMismatchCount: int32
    var pixelMismatchCount: int32
    var semanticDeltaCount: int32
    var entryRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(entriesRaw, cursor, entryRaw, nextPos):
        cursor = nextPos
        routeCount = routeCount + 1
        let routeState: str = r2cControllerJsonReadStringFieldFirst(entryRaw, "route", "route_state", "routeId", "")
        let nativeSummaryPath: str = r2cControllerPathFromMatrixEntry(matrixDir, entryRaw, "native_summary", "nativeSummaryPath", "native_summary_path")
        let truthSummaryPath: str = r2cControllerPathFromMatrixEntry(matrixDir, entryRaw, "truth_summary", "truthSummaryPath", "truth_summary_path")
        let nativeScreenshotPath: str = r2cControllerPathFromMatrixEntry(matrixDir, entryRaw, "native_screenshot", "nativeScreenshotPath", "native_screenshot_path")
        let truthScreenshotPath: str = r2cControllerPathFromMatrixEntry(matrixDir, entryRaw, "truth_screenshot", "truthScreenshotPath", "truth_screenshot_path")
        if strings.Len(routeState) <= 0:
            r2cControllerPrintErr("r2c-react: render-compare-matrix entry missing route")
            return 1
        if strings.Len(nativeSummaryPath) <= 0 || !chengpath.PathFileExists(nativeSummaryPath):
            r2cControllerPrintErr("r2c-react: render-compare-matrix missing native summary for route: " + routeState)
            return 1
        if strings.Len(truthSummaryPath) <= 0 || !chengpath.PathFileExists(truthSummaryPath):
            r2cControllerPrintErr("r2c-react: render-compare-matrix missing truth summary for route: " + routeState)
            return 1
        if strings.Len(nativeScreenshotPath) <= 0 || !chengpath.PathFileExists(nativeScreenshotPath):
            r2cControllerPrintErr("r2c-react: render-compare-matrix missing native screenshot for route: " + routeState)
            return 1
        if strings.Len(truthScreenshotPath) <= 0 || !chengpath.PathFileExists(truthScreenshotPath):
            r2cControllerPrintErr("r2c-react: render-compare-matrix missing truth screenshot for route: " + routeState)
            return 1
        if strings.Len(r2cControllerReadSummaryValue(nativeSummaryPath, "native_gui_route_state", "")) <= 0:
            r2cControllerPrintErr("r2c-react: render-compare-matrix native summary missing route state for route: " + routeState)
            return 1
        if strings.Len(r2cControllerReadSummaryValue(truthSummaryPath, "truth_trace_format", "")) <= 0:
            r2cControllerPrintErr("r2c-react: render-compare-matrix truth summary missing trace format for route: " + routeState)
            return 1
        let routeOutDir: str = os.JoinPath(outDir, routeState)
        let routeMkdirOk: bool = chengpath.MkdirP("", routeOutDir)
        routeMkdirOk
        let routeReportPath: str = os.JoinPath(routeOutDir, "render_compare_report_v1.json")
        let routeSummaryPath: str = os.JoinPath(routeOutDir, "render_compare.summary.env")
        var entryReason = "ok"
        let directRc: int32 = r2cControllerRenderCompareDirectRun(repo,
                                                                  routeOutDir,
                                                                  routeState,
                                                                  routeSummaryPath,
                                                                  routeReportPath,
                                                                  nativeSummaryPath,
                                                                  truthSummaryPath,
                                                                  nativeScreenshotPath,
                                                                  truthScreenshotPath)
        let summaryReady: bool = chengpath.PathFileExists(routeSummaryPath)
        if directRc != 0 && !summaryReady:
            directCompareFailedCount = directCompareFailedCount + 1
            entryReason = "direct_compare_failed"
        let okText: str = r2cControllerReadSummaryValue(routeSummaryPath, "ok", "false")
        let reasonText: str = r2cControllerReadSummaryValue(routeSummaryPath, "reason", entryReason)
        let routeStateMatchText: str = r2cControllerReadSummaryValue(routeSummaryPath, "route_state_match", "")
        let diffPixelCountText: str = r2cControllerReadSummaryValue(routeSummaryPath, "diff_pixel_count", "0")
        let semanticDeltaText: str = r2cControllerReadSummaryValue(routeSummaryPath, "semantic_nodes_count_delta", "0")
        let pixelCountText: str = r2cControllerReadSummaryValue(routeSummaryPath, "pixel_count", "0")
        let nativeSemanticCountText: str = r2cControllerReadSummaryValue(routeSummaryPath, "native_gui_runtime_bundle_semantic_nodes_count", "0")
        let truthSemanticCountText: str = r2cControllerReadSummaryValue(routeSummaryPath, "truth_semantic_nodes_count", "0")
        if okText == "true":
            okCount = okCount + 1
        else:
            notOkCount = notOkCount + 1
            if entryReason == "ok":
                entryReason = reasonText
        if routeStateMatchText == "false":
            routeStateMismatchCount = routeStateMismatchCount + 1
        if r2cControllerParseInt32(diffPixelCountText) > 0:
            pixelMismatchCount = pixelMismatchCount + 1
        if r2cControllerParseInt32(semanticDeltaText) != 0:
            semanticDeltaCount = semanticDeltaCount + 1
        if wroteEntry:
            entriesJson = entriesJson + ",\n"
        entriesJson = entriesJson + "    {\n"
        entriesJson = entriesJson + "      \"route_state\": " + r2cControllerJsonQuote(routeState) + ",\n"
        entriesJson = entriesJson + "      \"ok\": " + r2cControllerJsonBoolTextOrNull(okText) + ",\n"
        entriesJson = entriesJson + "      \"reason\": " + r2cControllerJsonQuote(reasonText) + ",\n"
        entriesJson = entriesJson + "      \"route_state_match\": " + r2cControllerJsonBoolTextOrNull(routeStateMatchText) + ",\n"
        entriesJson = entriesJson + "      \"native_summary_path\": " + r2cControllerJsonQuote(nativeSummaryPath) + ",\n"
        entriesJson = entriesJson + "      \"truth_summary_path\": " + r2cControllerJsonQuote(truthSummaryPath) + ",\n"
        entriesJson = entriesJson + "      \"native_screenshot_path\": " + r2cControllerJsonQuote(nativeScreenshotPath) + ",\n"
        entriesJson = entriesJson + "      \"truth_screenshot_path\": " + r2cControllerJsonQuote(truthScreenshotPath) + ",\n"
        entriesJson = entriesJson + "      \"route_report_path\": " + r2cControllerJsonQuote(routeReportPath) + ",\n"
        entriesJson = entriesJson + "      \"route_summary_path\": " + r2cControllerJsonQuote(routeSummaryPath) + ",\n"
        entriesJson = entriesJson + "      \"pixel_count\": " + pixelCountText + ",\n"
        entriesJson = entriesJson + "      \"diff_pixel_count\": " + diffPixelCountText + ",\n"
        entriesJson = entriesJson + "      \"native_semantic_nodes_count\": " + nativeSemanticCountText + ",\n"
        entriesJson = entriesJson + "      \"truth_semantic_nodes_count\": " + truthSemanticCountText + ",\n"
        entriesJson = entriesJson + "      \"semantic_nodes_count_delta\": " + semanticDeltaText + "\n"
        entriesJson = entriesJson + "    }"
        wroteEntry = true
    entriesJson = entriesJson + "\n  ]"
    let finalReason: str = r2cControllerRenderCompareMatrixReason(directCompareFailedCount,
                                                                  notOkCount,
                                                                  routeStateMismatchCount,
                                                                  pixelMismatchCount,
                                                                  semanticDeltaCount)
    let finalOk: bool = finalReason == "ok"
    var matrixDoc = "{\n"
    matrixDoc = matrixDoc + "  \"format\": \"render_compare_matrix_v1\",\n"
    matrixDoc = matrixDoc + "  \"ok\": " + r2cControllerJsonBool(finalOk) + ",\n"
    matrixDoc = matrixDoc + "  \"reason\": " + r2cControllerJsonQuote(finalReason) + ",\n"
    matrixDoc = matrixDoc + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    matrixDoc = matrixDoc + "  \"matrix_path\": " + r2cControllerJsonQuote(matrixPath) + ",\n"
    matrixDoc = matrixDoc + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    matrixDoc = matrixDoc + "  \"route_count\": " + intToStr(routeCount) + ",\n"
    matrixDoc = matrixDoc + "  \"ok_count\": " + intToStr(okCount) + ",\n"
    matrixDoc = matrixDoc + "  \"not_ok_count\": " + intToStr(notOkCount) + ",\n"
    matrixDoc = matrixDoc + "  \"direct_compare_failed_count\": " + intToStr(directCompareFailedCount) + ",\n"
    matrixDoc = matrixDoc + "  \"route_state_mismatch_count\": " + intToStr(routeStateMismatchCount) + ",\n"
    matrixDoc = matrixDoc + "  \"pixel_mismatch_count\": " + intToStr(pixelMismatchCount) + ",\n"
    matrixDoc = matrixDoc + "  \"semantic_delta_count\": " + intToStr(semanticDeltaCount) + ",\n"
    matrixDoc = matrixDoc + "  \"entries\": " + entriesJson + ",\n"
    matrixDoc = matrixDoc + "  \"out_path\": " + r2cControllerJsonQuote(matrixOutPath) + "\n"
    matrixDoc = matrixDoc + "}\n"
    if !chengpath.WriteTextFile("", matrixOutPath, matrixDoc):
        r2cControllerPrintErr("r2c-react: render-compare-matrix write json failed")
        return 1
    var summaryText = ""
    summaryText = summaryText + "render_compare_matrix_ok=" + r2cControllerJsonBool(finalOk) + "\n"
    summaryText = summaryText + "render_compare_matrix_reason=" + finalReason + "\n"
    summaryText = summaryText + "render_compare_matrix_path=" + matrixOutPath + "\n"
    summaryText = summaryText + "route_count=" + intToStr(routeCount) + "\n"
    summaryText = summaryText + "ok_count=" + intToStr(okCount) + "\n"
    summaryText = summaryText + "not_ok_count=" + intToStr(notOkCount) + "\n"
    summaryText = summaryText + "direct_compare_failed_count=" + intToStr(directCompareFailedCount) + "\n"
    summaryText = summaryText + "route_state_mismatch_count=" + intToStr(routeStateMismatchCount) + "\n"
    summaryText = summaryText + "pixel_mismatch_count=" + intToStr(pixelMismatchCount) + "\n"
    summaryText = summaryText + "semantic_delta_count=" + intToStr(semanticDeltaCount) + "\n"
    if !chengpath.WriteTextFile("", matrixSummaryPath, summaryText):
        r2cControllerPrintErr("r2c-react: render-compare-matrix write summary failed")
        return 1
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"render-compare-matrix\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"helper_script\": \"\",\n"
    report = report + "  \"compare_engine\": \"cheng.render_compare_direct_png_v1\",\n"
    report = report + "  \"compare_summary_path\": " + r2cControllerJsonQuote(matrixSummaryPath) + ",\n"
    report = report + "  \"compare_log_path\": \"\",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(matrixOutPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"render_compare_matrix_v1\",\n"
    report = report + "  \"route_count\": " + intToStr(routeCount) + ",\n"
    report = report + "  \"ok_count\": " + intToStr(okCount) + ",\n"
    report = report + "  \"render_compare_matrix_ok\": " + r2cControllerJsonBool(finalOk) + ",\n"
    report = report + "  \"render_compare_matrix_reason\": " + r2cControllerJsonQuote(finalReason) + "\n"
    report = report + "}\n"
    if !chengpath.WriteTextFile("", controllerReportPath, report):
        r2cControllerPrintErr("r2c-react: render-compare-matrix write report failed")
        return 1
    r2cControllerPrintLine(controllerReportPath)
    return 0

fn r2cControllerNativeGuiRuntime(root: str,
                                 args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let runtimeContractFlag: str = r2cControllerReadFlag(args, "--runtime-contract", "")
    if strings.Len(runtimeContractFlag) <= 0:
        r2cControllerPrintErr("r2c-react: native-gui-runtime missing --runtime-contract")
        return 1
    let runtimeContractPath: str = chengpath.PathAbsolute(effectiveRoot, runtimeContractFlag)
    if !chengpath.PathFileExists(runtimeContractPath):
        r2cControllerPrintErr("r2c-react: native-gui-runtime missing runtime contract: " + runtimeContractPath)
        return 1
    let runtimeDirDefault: str = chengpath.PathParentDir(runtimeContractPath)
    let runtimeExePath: str = chengpath.PathJoin(runtimeDirDefault, "native_gui_runtime_compiled_main")
    if !chengpath.PathFileExists(runtimeExePath):
        r2cControllerPrintErr("r2c-react: native-gui-runtime missing compiled runtime exe: " + runtimeExePath)
        return 1
    var runtimeArgs: str[]
    add(runtimeArgs, "--runtime-contract")
    add(runtimeArgs, runtimeContractPath)
    let filteredRuntimeArgs: str[] = r2cControllerFilterNativeGuiRuntimeArgs(args)
    for i in 0..<filteredRuntimeArgs.len:
        add(runtimeArgs, filteredRuntimeArgs[i])
    let runtimeDir: str = chengpath.PathParentDir(runtimeContractPath)
    let runtimeOutputPath: str = os.JoinPath(runtimeDir, "native_gui_runtime_direct_v1.json")
    let runtimeLogPath: str = os.JoinPath(runtimeDir, "native_gui_runtime_direct.log")
    var runtimeExitCode: int32
    var runtimeOutput: str
    os.OsSetEmpty(runtimeOutput)
    let runtimeOk = r2cproc.r2cProcessRunFileLogged(effectiveRoot,
                                                    "r2c-react native-gui-runtime",
                                                    runtimeExePath,
                                                    runtimeArgs,
                                                    runtimeDir,
                                                    runtimeLogPath,
                                                    runtimeExitCode,
                                                    runtimeOutput)
    if !chengpath.WriteTextFile("", runtimeOutputPath, runtimeOutput):
        r2cControllerPrintErr("r2c-react: failed to write native runtime output: " + runtimeOutputPath)
        return 1
    if !runtimeOk:
        if strings.Len(runtimeOutput) > 0:
            r2cControllerPrintErr(runtimeOutput)
        r2cControllerPrintErr("r2c-react: native gui runtime failed")
        if runtimeExitCode != 0:
            return runtimeExitCode
        return 1
    if strings.Len(runtimeOutput) <= 0:
        r2cControllerPrintErr("r2c-react: native-gui-runtime empty stdout: " + runtimeExePath)
        return 1
    r2cControllerPrintLine(runtimeOutput)
    return 0

fn r2cControllerReplayHitInspector(root: str,
                                   args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let inspectorStateFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--inspector-state", ""))
    if strings.Len(inspectorStateFlag) <= 0:
        r2cControllerPrintErr("r2c-react: replay-hit-inspector missing --inspector-state")
        return 1
    let outFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out", ""))
    let openSource: bool = cmdline.HasFlag("--open-source")
    let inspectorStatePath: str = chengpath.PathAbsolute(effectiveRoot, inspectorStateFlag)
    if !chengpath.PathFileExists(inspectorStatePath):
        r2cControllerPrintErr("r2c-react: replay-hit-inspector missing inspector state: " + inspectorStatePath)
        return 1
    let outDirBase: str = chengpath.PathParentDir(inspectorStatePath)
    var outDir: str = outDirBase
    var replayPath: str = os.JoinPath(outDir, "native_gui_inspector_replay_v1.json")
    if strings.Len(outFlag) > 0:
        replayPath = chengpath.PathAbsolute(effectiveRoot, outFlag)
        outDir = chengpath.PathParentDir(replayPath)
    var scratchOk: bool = chengpath.MkdirP("", outDir)
    scratchOk
    let summaryPath: str = os.JoinPath(outDir, "native_gui_inspector_replay.summary.env")
    let logPath: str = os.JoinPath(outDir, "native_gui_inspector_replay.log")
    let openSourceLogPath: str = os.JoinPath(outDir, "native_gui_inspector_replay.open_source.log")
    let reportPath: str = os.JoinPath(outDir, "native_gui_inspector_replay_report_v1.json")
    let stateText: str = chengpath.ReadTextFile("", inspectorStatePath)
    if strings.Len(stateText) <= 0:
        r2cControllerPrintErr("r2c-react: replay-hit-inspector empty inspector state: " + inspectorStatePath)
        return 1
    let stateFormat: str = r2cControllerJsonReadStringField(stateText, "format", "")
    if stateFormat != "native_gui_inspector_state_v1":
        r2cControllerPrintErr("r2c-react: replay-hit-inspector format mismatch: " + stateFormat)
        return 1

    let windowText: str = r2cControllerJsonReadObjectFieldRaw(stateText, "window", "{}")
    let hitText: str = r2cControllerJsonReadObjectFieldRaw(stateText, "hit", "{}")
    let panelText: str = r2cControllerJsonReadObjectFieldRaw(stateText, "panel", "{}")
    let sourceJumpJson: str = r2cControllerJsonReadObjectFieldRaw(
        stateText,
        "source_jump",
        "{\"enabled\":false,\"attempted\":false,\"ok\":false,\"target_path\":\"\",\"target_line\":0,\"command\":\"\",\"error\":\"\"}"
    )
    let panelLinesJson: str = r2cControllerJsonReadArrayFieldRaw(panelText, "lines", "[]")

    let inspectorStateReady: bool = r2cControllerJsonReadBoolField(stateText, "ready", false)
    let stateReason: str = r2cControllerJsonReadStringField(stateText, "reason", "")
    let replayOk: bool = inspectorStateReady
    var replayReason: str = "ok"
    if !replayOk:
        replayReason = stateReason
        if strings.Len(replayReason) <= 0:
            replayReason = "inspector_not_ready"
    let repoRoot: str = r2cControllerJsonReadStringField(stateText, "repo_root", "")
    let routeState: str = r2cControllerJsonReadStringField(windowText, "route_state", "")
    let entryModule: str = r2cControllerJsonReadStringField(windowText, "entry_module", "")
    let hitItemId: str = r2cControllerJsonReadStringField(hitText, "item_id", "")
    let hitSourceModulePath: str = r2cControllerJsonReadStringField(hitText, "source_module_path", "")
    let hitSourceComponentName: str = r2cControllerJsonReadStringField(hitText, "source_component_name", "")
    let hitSourceLine: int32 = r2cControllerJsonReadIntField(hitText, "source_line", 0)
    let panelTitle: str = r2cControllerJsonReadStringField(panelText, "title", "")
    let panelLineCount: int32 = r2cControllerJsonCountStringArrayItems(panelLinesJson)

    let sourceJumpEnabled: bool = r2cControllerJsonReadBoolField(sourceJumpJson, "enabled", false)
    let sourceJumpAttempted: bool = r2cControllerJsonReadBoolField(sourceJumpJson, "attempted", false)
    let sourceJumpOk: bool = r2cControllerJsonReadBoolField(sourceJumpJson, "ok", false)
    let sourceJumpTargetPath: str = r2cControllerJsonReadStringField(sourceJumpJson, "target_path", "")
    let sourceJumpTargetLine: int32 = r2cControllerJsonReadIntField(sourceJumpJson, "target_line", 0)
    let sourceJumpCommand: str = r2cControllerJsonReadStringField(sourceJumpJson, "command", "")
    let sourceJumpError: str = r2cControllerJsonReadStringField(sourceJumpJson, "error", "")

    var replaySourceOpen = R2cReplaySourceOpenResult(targetPath: sourceJumpTargetPath,
                                                     targetLine: sourceJumpTargetLine)
    if openSource:
        replaySourceOpen = r2cControllerReplaySourceOpen(effectiveRoot,
                                                         repoRoot,
                                                         hitSourceModulePath,
                                                         hitSourceLine,
                                                         sourceJumpTargetPath,
                                                         sourceJumpTargetLine,
                                                         openSourceLogPath)

    var replayText = "{\n"
    replayText = replayText + "  \"format\": \"native_gui_inspector_replay_v1\",\n"
    replayText = replayText + "  \"ok\": " + r2cControllerJsonBool(replayOk) + ",\n"
    replayText = replayText + "  \"reason\": " + r2cControllerJsonQuote(replayReason) + ",\n"
    replayText = replayText + "  \"inspector_state_path\": " + r2cControllerJsonQuote(inspectorStatePath) + ",\n"
    replayText = replayText + "  \"repo_root\": " + r2cControllerJsonQuote(repoRoot) + ",\n"
    replayText = replayText + "  \"route_state\": " + r2cControllerJsonQuote(routeState) + ",\n"
    replayText = replayText + "  \"entry_module\": " + r2cControllerJsonQuote(entryModule) + ",\n"
    replayText = replayText + "  \"hit_item_id\": " + r2cControllerJsonQuote(hitItemId) + ",\n"
    replayText = replayText + "  \"hit_source_module_path\": " + r2cControllerJsonQuote(hitSourceModulePath) + ",\n"
    replayText = replayText + "  \"hit_source_component_name\": " + r2cControllerJsonQuote(hitSourceComponentName) + ",\n"
    replayText = replayText + "  \"hit_source_line\": " + intToStr(hitSourceLine) + ",\n"
    replayText = replayText + "  \"panel_title\": " + r2cControllerJsonQuote(panelTitle) + ",\n"
    replayText = replayText + "  \"panel_line_count\": " + intToStr(panelLineCount) + ",\n"
    replayText = replayText + "  \"panel_lines\": " + panelLinesJson + ",\n"
    replayText = replayText + "  \"source_jump\": " + sourceJumpJson + ",\n"
    replayText = replayText + "  \"replay_source_open\": {\n"
    replayText = replayText + "    \"requested\": " + r2cControllerJsonBool(replaySourceOpen.requested) + ",\n"
    replayText = replayText + "    \"ok\": " + r2cControllerJsonBool(replaySourceOpen.ok) + ",\n"
    replayText = replayText + "    \"target_path\": " + r2cControllerJsonQuote(replaySourceOpen.targetPath) + ",\n"
    replayText = replayText + "    \"target_line\": " + intToStr(replaySourceOpen.targetLine) + ",\n"
    replayText = replayText + "    \"command\": " + r2cControllerJsonQuote(replaySourceOpen.command) + ",\n"
    replayText = replayText + "    \"error\": " + r2cControllerJsonQuote(replaySourceOpen.error) + "\n"
    replayText = replayText + "  }\n"
    replayText = replayText + "}\n"

    if !chengpath.WriteTextFile("", replayPath, replayText):
        r2cControllerPrintErr("r2c-react: replay-hit-inspector failed to write replay doc: " + replayPath)
        return 1

    var summary = ""
    summary = summary + "native_gui_inspector_state_path=" + inspectorStatePath + "\n"
    summary = summary + "native_gui_inspector_state_ready=" + r2cControllerJsonBool(inspectorStateReady) + "\n"
    summary = summary + "native_gui_inspector_replay_path=" + replayPath + "\n"
    summary = summary + "native_gui_inspector_replay_ready=" + r2cControllerJsonBool(replayOk) + "\n"
    summary = summary + "native_gui_inspector_replay_panel_title=" + panelTitle + "\n"
    summary = summary + "native_gui_inspector_replay_panel_line_count=" + intToStr(panelLineCount) + "\n"
    summary = summary + "native_gui_replay_source_open_requested=" + r2cControllerJsonBool(replaySourceOpen.requested) + "\n"
    summary = summary + "native_gui_replay_source_open_ok=" + r2cControllerJsonBool(replaySourceOpen.ok) + "\n"
    summary = summary + "native_gui_replay_source_open_target_path=" + replaySourceOpen.targetPath + "\n"
    summary = summary + "native_gui_replay_source_open_target_line=" + intToStr(replaySourceOpen.targetLine) + "\n"
    summary = summary + "native_gui_replay_source_open_command=" + replaySourceOpen.command + "\n"
    summary = summary + "native_gui_replay_source_open_error=" + replaySourceOpen.error + "\n"
    summary = summary + "native_gui_hit_item_id=" + hitItemId + "\n"
    summary = summary + "native_gui_hit_source_module_path=" + hitSourceModulePath + "\n"
    summary = summary + "native_gui_hit_source_component_name=" + hitSourceComponentName + "\n"
    summary = summary + "native_gui_hit_source_line=" + intToStr(hitSourceLine) + "\n"
    if !chengpath.WriteTextFile("", summaryPath, summary):
        r2cControllerPrintErr("r2c-react: replay-hit-inspector failed to write summary: " + summaryPath)
        return 1

    var logText = ""
    logText = logText + "controller=replay-hit-inspector\n"
    logText = logText + "inspector_state_path=" + inspectorStatePath + "\n"
    logText = logText + "replay_path=" + replayPath + "\n"
    logText = logText + "summary_path=" + summaryPath + "\n"
    logText = logText + "open_source_requested=" + r2cControllerJsonBool(openSource) + "\n"
    logText = logText + "replay_source_open_requested=" + r2cControllerJsonBool(replaySourceOpen.requested) + "\n"
    logText = logText + "replay_source_open_ok=" + r2cControllerJsonBool(replaySourceOpen.ok) + "\n"
    logText = logText + "replay_source_open_target_path=" + replaySourceOpen.targetPath + "\n"
    logText = logText + "replay_source_open_target_line=" + intToStr(replaySourceOpen.targetLine) + "\n"
    logText = logText + "replay_source_open_command=" + replaySourceOpen.command + "\n"
    logText = logText + "replay_source_open_error=" + replaySourceOpen.error + "\n"
    if openSource:
        logText = logText + "replay_source_open_log_path=" + openSourceLogPath + "\n"
    if !chengpath.WriteTextFile("", logPath, logText):
        r2cControllerPrintErr("r2c-react: replay-hit-inspector failed to write log: " + logPath)
        return 1

    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"replay-hit-inspector\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(replayPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"native_gui_inspector_replay_v1\",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote("") + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(logPath) + ",\n"
    report = report + "  \"native_gui_inspector_state_path\": " + r2cControllerJsonQuote(inspectorStatePath) + ",\n"
    report = report + "  \"native_gui_inspector_state_ready\": " + r2cControllerJsonBool(inspectorStateReady) + ",\n"
    report = report + "  \"native_gui_inspector_replay_path\": " + r2cControllerJsonQuote(replayPath) + ",\n"
    report = report + "  \"native_gui_inspector_replay_ready\": " + r2cControllerJsonBool(replayOk) + ",\n"
    report = report + "  \"native_gui_inspector_replay_panel_title\": " + r2cControllerJsonQuote(panelTitle) + ",\n"
    report = report + "  \"native_gui_inspector_replay_panel_line_count\": " + intToStr(panelLineCount) + ",\n"
    report = report + "  \"native_gui_hit_item_id\": " + r2cControllerJsonQuote(hitItemId) + ",\n"
    report = report + "  \"native_gui_hit_source_module_path\": " + r2cControllerJsonQuote(hitSourceModulePath) + ",\n"
    report = report + "  \"native_gui_hit_source_component_name\": " + r2cControllerJsonQuote(hitSourceComponentName) + ",\n"
    report = report + "  \"native_gui_hit_source_line\": " + intToStr(hitSourceLine) + ",\n"
    report = report + "  \"native_gui_replay_source_open_requested\": " + r2cControllerJsonBool(replaySourceOpen.requested) + ",\n"
    report = report + "  \"native_gui_replay_source_open_ok\": " + r2cControllerJsonBool(replaySourceOpen.ok) + ",\n"
    report = report + "  \"native_gui_replay_source_open_target_path\": " + r2cControllerJsonQuote(replaySourceOpen.targetPath) + ",\n"
    report = report + "  \"native_gui_replay_source_open_target_line\": " + intToStr(replaySourceOpen.targetLine) + ",\n"
    report = report + "  \"native_gui_replay_source_open_command\": " + r2cControllerJsonQuote(replaySourceOpen.command) + ",\n"
    report = report + "  \"native_gui_replay_source_open_error\": " + r2cControllerJsonQuote(replaySourceOpen.error) + "\n"
    report = report + "}\n"
    if !chengpath.WriteTextFile("", reportPath, report):
        r2cControllerPrintErr("r2c-react: replay-hit-inspector failed to write report: " + reportPath)
        return 1
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerHelp() =
    r2cControllerPrintLine("usage: cheng r2c-react <subcommand> [args]")
    r2cControllerPrintLine("subcommands: help, status, frontend, static-surface, semantic-surface, codegen-surface, discover-truth-routes, capture-truth, truth-compare, compare-truth, exec-route-matrix, compare-truth-matrix, native-gui-bundle, native-gui-runtime, run-native-gui, replay-hit-inspector, compile")
    r2cControllerPrintLine("frontend flags: --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]")
    r2cControllerPrintLine("static-surface flags: --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--runtime-root <dir> ...] [--asset-root <dir> ...]")
    r2cControllerPrintLine("semantic-surface flags: --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--runtime-root <dir> ...]")
    r2cControllerPrintLine("discover-truth-routes flags: --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]")
    r2cControllerPrintLine("capture-truth flags: --repo <path> --route <state> [--out-dir <dir>] (--truth-summary <file> | --truth-trace <file> [--runtime-state <file>] [--dom <file>] [--semantic-nodes <file>] [--runtime-meta <file>] [--screenshot <file>])")
    r2cControllerPrintLine("compare-truth flags: --exec-snapshot <file> --truth-trace <file> [--codegen-manifest <file>] [--truth-state <state>] [--native-gui-summary <file>] [--out <file>]")
    r2cControllerPrintLine("exec-route-matrix flags: (--route-catalog <file> | --tsx-ast <file>) --exec-snapshot <file> --truth-routes-file <file> [--codegen-manifest <file>] [--truth-trace <file>] [--out <file>]")
    r2cControllerPrintLine("compare-truth-matrix flags: --exec-route-matrix <file> --truth-trace <file> [--codegen-manifest <file>] [--out <file>]")
    r2cControllerPrintLine("native-gui-runtime flags: --runtime-contract <file> [--state-* ...] [--event-* ...]")
    r2cControllerPrintLine("run-native-gui flags: --click x,y --resize WxH --scroll-y <n> --wait-after-click-ms <n> --focus-item-id <id> --type-text <text> --send-key <key> --inspector-state-out <file> --open-source-on-click")
    r2cControllerPrintLine("replay-hit-inspector flags: --inspector-state <file> --out <file> --open-source")

fn R2cReactControllerMain(root: str,
                          args: str[]): int32 =
    if args.len <= 0:
        r2cControllerHelp()
        return 0
    let cmd: str = args[0]
    var tail: str[]
    for i in 1..<args.len:
        add(tail, args[i])
    if cmd == "help" || cmd == "--help" || cmd == "-h":
        r2cControllerHelp()
        return 0
    if cmd == "status":
        return r2cControllerStatus(root, tail)
    if cmd == "frontend":
        return r2cControllerFrontend(root, tail)
    if cmd == "static-surface":
        return r2cControllerStaticSurface(root, tail)
    if cmd == "semantic-surface":
        return r2cControllerSemanticSurface(root, tail)
    if cmd == "codegen-surface":
        return r2cControllerCodegenSurface(root, tail)
    if cmd == "discover-truth-routes":
        return r2cControllerDiscoverTruthRoutes(root, tail)
    if cmd == "capture-truth":
        return r2cControllerCaptureTruth(root, tail)
    if cmd == "truth-compare":
        return r2cControllerTruthCompare(root, tail)
    if cmd == "compare-truth":
        return r2cControllerCompareTruthCompat(root, tail)
    if cmd == "exec-route-matrix":
        return r2cControllerExecRouteMatrix(root, tail)
    if cmd == "compare-truth-matrix":
        return r2cControllerCompareTruthMatrixCompat(root, tail)
    if cmd == "native-gui-bundle":
        return r2cControllerNativeGuiBundle(root, tail)
    if cmd == "native-gui-runtime":
        return r2cControllerNativeGuiRuntime(root, tail)
    if cmd == "run-native-gui":
        return r2cControllerRunNativeGui(root, tail)
    if cmd == "render-compare":
        r2cControllerPrintErr("r2c-react: render-compare moved out of the GUI controller mainline")
        return 2
    if cmd == "render-compare-matrix":
        r2cControllerPrintErr("r2c-react: render-compare-matrix moved out of the GUI controller mainline")
        return 2
    if cmd == "replay-hit-inspector":
        return r2cControllerReplayHitInspector(root, tail)
    if cmd == "compile":
        return r2cControllerCompile(root, tail)
    r2cControllerPrintErr("r2c-react: unknown subcommand: " + cmd)
    return 2

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.CaptureCmdLine(argc, argv)
    let rootDir: str = r2cControllerRoot()
    let count: int32 = r2cControllerParamCountBridge()
    let args: str[] = r2cControllerCollectArgsFrom(1, count)
    return R2cReactControllerMain(rootDir, args)
