        requested: bool
        ok: bool
        targetPath: str
        targetLine: int32
        command: str
        error: str

    R2cTruthSnapshotMatch =
        found: bool
        matchedIndex: int32
        stateId: str
        routeId: str
        semanticNodesPath: str
        renderReadyKnown: bool
        renderReady: bool
        semanticNodesCountKnown: bool
        semanticNodesCount: int32

    R2cSemanticNodeDoc =
        nodeId: str
        pathText: str
        key: str
        keyFallback1: str
        keyFallback2: str
        nodeKind: str
        tag: str
        label: str
        classPreview: str
        detailText: str
        textPreview: str
        depth: int32
        modulePath: str
        componentName: str
        line: int32

    R2cNativeLayoutTypedItem =
        scope: str
        index: int32
        itemId: str
        kind: str
        planRole: str
        layer: str
        zIndex: int32
        x: int32
        y: int32
        width: int32
        height: int32
        text: str
        detailText: str
        visibleInViewport: bool
        synthetic: bool
        interactive: bool
        sourceBacked: bool
        stretchX: bool
        stretchY: bool
        column: int32
        columnSpan: int32
        visualRole: str
        density: str
        prominence: str
        accentTone: str
        backgroundColor: str
        borderColor: str
        textColor: str
        detailColor: str
        fontSize: int32
        fontWeight: str
        cornerRadius: int32
        textLength: int32
        sourceNodeId: str
        sourceModulePath: str
        sourceComponentName: str
        sourceLine: int32

    R2cTruthCompareEval =
        ok: bool
        reason: str
        truthTraceFormat: str
        truthState: str
        matchedSnapshotIndex: int32
        execRouteState: str
        execRenderReady: bool
        execSemanticNodesLoaded: bool
        execSnapshotSemanticNodesCount: int32
        execSemanticNodesCount: int32
        execLayoutSurfacePath: str
        truthRouteState: str
        truthRouteId: str
        truthSemanticNodesPath: str
        truthRenderReady: bool
        truthSemanticNodesLoaded: bool
        truthSemanticNodesCountKnown: bool
        truthTraceSemanticNodesCount: int32
        truthSemanticNodesCount: int32
        semanticNodeCountCompareBasis: str
        semanticNodeDiffReady: bool
        semanticNodeDiffPath: str
        semanticNodeDiffBasis: str
        semanticNodeDiffExecNodeCount: int32
        semanticNodeDiffTruthNodeCount: int32
        semanticNodeDiffSharedCount: int32
        semanticNodeDiffExecOnlyCount: int32
        semanticNodeDiffTruthOnlyCount: int32
        missingTruthFieldsCsv: str
        missingTruthFieldsCount: int32
        mismatchCount: int32
        mismatchRouteState: bool
        mismatchRouteStateExecValue: str
        mismatchRouteStateTruthValue: str
        mismatchRenderReady: bool
        mismatchRenderReadyExecValue: str
        mismatchRenderReadyTruthValue: str
        mismatchSemanticNodesLoaded: bool
        mismatchSemanticNodesLoadedExecValue: str
        mismatchSemanticNodesLoadedTruthValue: str
        mismatchSemanticNodesCount: bool
        mismatchSemanticNodesCountExecValue: str
        mismatchSemanticNodesCountTruthValue: str

    R2cTruthCompareNativeGuiSummary =
        ready: bool
        summaryPath: str
        routeState: str
        screenshotPath: str
        runtimeBundleReady: bool
        runtimeContractReady: bool
        runtimeBundleRouteState: str
        runtimeBundleRouteCount: int32
        runtimeBundleSupportedCount: int32
        runtimeBundleSemanticNodesCount: int32
        runtimeBundleLayoutItemCount: int32
        runtimeBundleRenderCommandCount: int32
        runtimeContractLayoutItemCount: int32
        runtimeContractViewportItemCount: int32
        runtimeContractInteractiveItemCount: int32
        nativeLayoutPlanItemCount: int32
        renderPlanCommandCount: int32

fn r2cControllerPrintLine(text: str) =
    os.WriteLine(r2cControllerStdoutBridge(), text)

fn r2cControllerPrintErr(text: str) =
    os.WriteLine(r2cControllerStderrBridge(), text)

fn r2cControllerRoot(): str =
    let envRoot: str = os.GetEnv("CHENG_ROOT")
    if strings.Len(envRoot) > 0:
        return envRoot
    return "."

fn r2cControllerEffectiveRoot(root: str): str =
    if strings.Len(root) > 0:
        return root
    return r2cControllerRoot()

fn r2cControllerSlice(text: str,
                      start: int32,
                      length: int32): str =
    if length <= 0:
        return ""
    return v3path.V3TextSlice(text, start, length)

fn r2cControllerCollectArgsFrom(startIndex: int32,
                                count: int32): str[] =
    var out: str[]
    if startIndex > count:
        return out
    for i in startIndex..count:
        let raw: str = cmdline.ParamStr(i)
        add(out, r2cControllerSlice(raw, 0, strings.Len(raw)))
    return out

fn r2cControllerReadFlag(args: str[],
                         key: str,
                         defaultValue: str): str =
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.StartsWith(arg, key + ":"):
            return strings.DropPrefix(arg, key + ":")
        if strutil.StartsWith(arg, key + "="):
            return strings.DropPrefix(arg, key + "=")
        if arg == key:
            if i + 1 < args.len:
                return args[i + 1]
    return defaultValue

fn r2cControllerOwnText(text: str): str =
    return r2cControllerSlice(text, 0, strings.Len(text))

fn r2cControllerHasFlag(args: str[],
                        key: str): bool =
    for i in 0..<args.len:
        if args[i] == key:
            return true
    return false

fn r2cControllerCollectFlagValues(args: str[],
                                  key: str): str[] =
    var out: str[]
    var skipNext = false
    for i in 0..<args.len:
        if skipNext:
            skipNext = false
            continue
        let arg: str = args[i]
        if strutil.StartsWith(arg, key + ":"):
            add(out, strings.DropPrefix(arg, key + ":"))
            continue
        if strutil.StartsWith(arg, key + "="):
            add(out, strings.DropPrefix(arg, key + "="))
            continue
        if arg == key:
            if i + 1 < args.len:
                add(out, args[i + 1])
                skipNext = true
    return out

fn r2cControllerCollectCmdlineFlagValues(key: str): str[] =
    var out: str[]
    let count: int32 = r2cControllerParamCountBridge()
    var skipNext = false
    for i in 1..count:
        if skipNext:
            skipNext = false
            continue
        let arg: str = cmdline.ParamStr(i)
        if arg == key:
            if i + 1 <= count:
                add(out, r2cControllerOwnText(cmdline.ParamStr(i + 1)))
                skipNext = true
            continue
        if v3path.V3TextStartsWith(arg, key + ":"):
            add(out, strings.DropPrefix(arg, key + ":"))
            continue
        if v3path.V3TextStartsWith(arg, key + "="):
            add(out, strings.DropPrefix(arg, key + "="))
    return out

fn r2cControllerExperimentalRoot(root: str): str =
    return v3path.V3PathAbsolute(root, "tools/r2c/experimental")

fn r2cControllerDefaultOutDir(repo: str): str =
    return v3path.V3PathAbsolute(repo, "build/r2c_react_cheng")

fn r2cControllerRunNodeHelper(root: str,
                              scriptPath: str,
                              helperArgs: str[],
                              logPath: str,
                              exitCodeOut: var int32,
                              outputOut: var str): bool =
    var argv: str[]
    add(argv, scriptPath)
    for i in 0..<helperArgs.len:
        add(argv, helperArgs[i])
    return r2cproc.r2cProcessRunProgramLogged(root,
                                              "r2c-react node helper",
                                              "node",
                                              argv,
                                              root,
                                              logPath,
                                              exitCodeOut,
                                              outputOut)

fn r2cControllerFilterNativeGuiRuntimeArgs(args: str[]): str[] =
    var out: str[]
    var skipNext = false
    for i in 0..<args.len:
        if skipNext:
            skipNext = false
            continue
        let arg: str = args[i]
        if arg == "--runtime-contract" || arg == "--runtime-contract-path" || arg == "--compiled-runtime-exe":
            if i + 1 < args.len:
                skipNext = true
            continue
        let isInlineContractEq: bool = strutil.StartsWith(arg, "--runtime-contract=")
        let isInlineContractColon: bool = strutil.StartsWith(arg, "--runtime-contract:")
        let isInlineContractPathEq: bool = strutil.StartsWith(arg, "--runtime-contract-path=")
        let isInlineContractPathColon: bool = strutil.StartsWith(arg, "--runtime-contract-path:")
        let isInlineRuntimeExeEq: bool = strutil.StartsWith(arg, "--compiled-runtime-exe=")
        let isInlineRuntimeExeColon: bool = strutil.StartsWith(arg, "--compiled-runtime-exe:")
        if isInlineContractEq || isInlineContractColon || isInlineContractPathEq:
            continue
        if isInlineContractPathColon || isInlineRuntimeExeEq || isInlineRuntimeExeColon:
            continue
        add(out, arg)
    return out

fn r2cControllerReadSummaryValue(summaryPath: str,
                                 key: str,
                                 defaultValue: str): str =
    if !v3path.V3PathFileExists(summaryPath):
        return defaultValue
    let text: str = v3path.V3ReadTextFile("", summaryPath)
    let total: int32 = strings.Len(text)
    let prefix: str = key + "="
    let prefixLen: int32 = strings.Len(prefix)
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif text[i] == '\n':
            endHit = true
        if !endHit:
            continue
        let lineLen: int32 = i - start
        if lineLen >= prefixLen:
            let line: str = r2cControllerSlice(text, start, lineLen)
            let head: str = r2cControllerSlice(line, 0, prefixLen)
            if head == prefix:
                return r2cControllerSlice(line, prefixLen, strings.Len(line) - prefixLen)
        start = i + 1
    return defaultValue

fn r2cControllerDigitValue(text: str): int32 =
    if text == "0":
        return 0
    elif text == "1":
        return 1
    elif text == "2":
        return 2
    elif text == "3":
        return 3
    elif text == "4":
        return 4
    elif text == "5":
        return 5
    elif text == "6":
        return 6
    elif text == "7":
        return 7
    elif text == "8":
        return 8
    elif text == "9":
        return 9
    return -1

fn r2cControllerParsePositiveInt32Raw(raw: str): int32 =
    let total: int32 = strings.Len(raw)
    if total <= 0:
        return 0
    if total == 1:
        return r2cControllerDigitValue(raw)
    let prefixValue: int32 = r2cControllerParsePositiveInt32Raw(r2cControllerSlice(raw, 0, total - 1))
    let lastDigit: int32 = r2cControllerDigitValue(r2cControllerSlice(raw, total - 1, 1))
    if prefixValue < 0 || lastDigit < 0:
        return -1
    return prefixValue * 10 + lastDigit

fn r2cControllerParseInt32(text: str): int32 =
    let raw: str = text
    if strings.Len(raw) <= 0:
        return 0
    if r2cControllerSlice(raw, 0, 1) == "-":
        let negParsed: int32 = r2cControllerParsePositiveInt32Raw(r2cControllerSlice(raw, 1, strings.Len(raw) - 1))
        if negParsed < 0:
            return 0
        return 0 - negParsed
    let parsed: int32 = r2cControllerParsePositiveInt32Raw(raw)
    if parsed < 0:
        return 0
    return parsed

fn r2cControllerJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    var out = quote
    let total: int32 = strings.Len(text)
    var i: int32
    while i < total:
        let ch = text[i]
        if ch == char(34):
            out = out + "\\" + quote
        elif ch == '\\':
            out = out + "\\\\"
        elif ch == char(10):
            out = out + "\\n"
        elif ch == char(13):
            out = out + "\\r"
        elif ch == char(9):
            out = out + "\\t"
        else:
            out = out + strings.CharToStr(ch)
        i = i + 1
    out = out + quote
    return out

fn r2cControllerJsonBool(value: bool): str =
    if value:
        return "true"
    return "false"

fn r2cControllerJsonBoolTextOrNull(textRaw: str): str =
    let text: str = strutil.Strip(textRaw)
    if text == "true" || text == "false":
        return text
    return "null"

fn r2cControllerJsonBoolTextOrFalse(textRaw: str): str =
    let text: str = strutil.Strip(textRaw)
    if text == "true" || text == "false":
        return text
    return "false"

fn r2cControllerJsonIntTextOrNull(textRaw: str): str =
    let text: str = strutil.Strip(textRaw)
    if strings.Len(text) <= 0:
        return "null"
    return intToStr(r2cControllerParseInt32(text))

fn r2cControllerJsonReadStringFieldFirst(doc: str,
                                         keyA: str,
                                         keyB: str,
                                         keyC: str,
                                         defaultValue: str): str =
    let valueA: str = r2cControllerJsonReadStringField(doc, keyA, "")
    if strings.Len(valueA) > 0:
        return valueA
    let valueB: str = r2cControllerJsonReadStringField(doc, keyB, "")
    if strings.Len(valueB) > 0:
        return valueB
    let valueC: str = r2cControllerJsonReadStringField(doc, keyC, "")
    if strings.Len(valueC) > 0:
        return valueC
    return defaultValue

fn r2cControllerPathFromMatrixEntry(baseDir: str,
                                    entryRaw: str,
                                    keyA: str,
                                    keyB: str,
                                    keyC: str): str =
    let raw: str = r2cControllerJsonReadStringFieldFirst(entryRaw, keyA, keyB, keyC, "")
    if strings.Len(raw) <= 0:
        return ""
    return v3path.V3PathAbsolute(baseDir, raw)

fn r2cControllerTextFind(text: str,
                         needle: str,
                         startRaw: int32): int32 =
    let total: int32 = strings.Len(text)
    let needleLen: int32 = strings.Len(needle)
    if needleLen <= 0:
        return startRaw
    if total < needleLen:
        return -1
    var start: int32 = startRaw
    if start < 0:
        start = 0
    if start > total - needleLen:
        return -1
    for i in start..(total - needleLen):
        var matched = true
        var j: int32
        while j < needleLen:
            if text[i + j] != needle[j]:
                matched = false
                break
            j = j + 1
        if matched:
            return i
    return -1

fn r2cControllerJsonSkipWhitespace(text: str,
                                   startRaw: int32): int32 =
    var start: int32 = startRaw
    if start < 0:
        start = 0
    let total: int32 = strings.Len(text)
    while start < total:
        let ch = text[start]
        if ch == char(32):
            start = start + 1
        elif ch == char(10):
            start = start + 1
        elif ch == char(13):
            start = start + 1
        elif ch == char(9):
            start = start + 1
        else:
            return start
    return start

fn r2cControllerJsonFindValueStart(text: str,
                                   key: str,
                                   startRaw: int32): int32 =
    let keyPattern: str = r2cControllerJsonQuote(key)
    let keyPos: int32 = r2cControllerTextFind(text, keyPattern, startRaw)
    if keyPos < 0:
        return -1
    let total: int32 = strings.Len(text)
    var pos: int32 = keyPos + strings.Len(keyPattern)
    while pos < total:
        let ch = text[pos]
        if ch == char(58):
            return r2cControllerJsonSkipWhitespace(text, pos + 1)
        pos = pos + 1
    return -1

fn r2cControllerJsonHasField(text: str,
                             key: str): bool =
    return r2cControllerJsonFindValueStart(text, key, 0) >= 0

fn r2cControllerJsonReadStringLiteralAdvance(text: str,
                                             startRaw: int32,
                                             out: var str,
                                             nextPos: var int32): bool =
    out = ""
    nextPos = startRaw
    let total: int32 = strings.Len(text)
    if startRaw < 0 || startRaw >= total:
        return false
    if text[startRaw] != char(34):
        return false
    var pos: int32 = startRaw + 1
    while pos < total:
        let ch = text[pos]
        if ch == char(34):
            nextPos = pos + 1
            return true
        if ch == '\\':
            if pos + 1 >= total:
                return false
            let esc = text[pos + 1]
            if esc == char(34):
                out = out + strings.CharToStr(char(34))
            elif esc == '\\':
                out = out + "\\"
            elif esc == 'n':
                out = out + "\n"
            elif esc == 'r':
                out = out + "\r"
            elif esc == 't':
                out = out + "\t"
            else:
                out = out + strings.CharToStr(esc)
            pos = pos + 2
            continue
        out = out + strings.CharToStr(ch)
        pos = pos + 1
    return false

fn r2cControllerJsonReadStringField(text: str,
                                    key: str,
                                    fallback: str): str =
    let valueStart: int32 = r2cControllerJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    var out: str
    var nextPos: int32
    if !r2cControllerJsonReadStringLiteralAdvance(text, valueStart, out, nextPos):
        return fallback
    return out

fn r2cControllerJsonReadBoolField(text: str,
                                  key: str,
                                  fallback: bool): bool =
    let valueStart: int32 = r2cControllerJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    if r2cControllerTextFind(text, "true", valueStart) == valueStart:
        return true
    if r2cControllerTextFind(text, "false", valueStart) == valueStart:
        return false
    return fallback

fn r2cControllerJsonReadIntField(text: str,
                                 key: str,
                                 fallback: int32): int32 =
    let valueStart: int32 = r2cControllerJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    let total: int32 = strings.Len(text)
    var endPos: int32 = valueStart
    if endPos < total:
        if text[endPos] == '-':
            endPos = endPos + 1
    var sawDigit = false
    while endPos < total:
        let digitText: str = r2cControllerSlice(text, endPos, 1)
        if r2cControllerDigitValue(digitText) < 0:
            break
        sawDigit = true
        endPos = endPos + 1
    if !sawDigit:
        return fallback
    return r2cControllerParseInt32(r2cControllerSlice(text, valueStart, endPos - valueStart))

fn r2cControllerJsonFindBalancedEnd(text: str,
                                    startRaw: int32,
                                    openCh: char,
                                    closeCh: char): int32 =
    let total: int32 = strings.Len(text)
    if startRaw < 0 || startRaw >= total:
        return -1
    if text[startRaw] != openCh:
        return -1
    var depth: int32
    var inString = false
    var escaped = false
    for i in startRaw..<total:
        let ch = text[i]
        if inString:
            if escaped:
                escaped = false
            elif ch == '\\':
                escaped = true
            elif ch == char(34):
                inString = false
            continue
        if ch == char(34):
            inString = true
            continue
        if ch == openCh:
            depth = depth + 1
            continue
        if ch == closeCh:
            depth = depth - 1
            if depth == 0:
                return i
    return -1

fn r2cControllerJsonReadObjectFieldRaw(text: str,
                                       key: str,
                                       fallback: str): str =
    let valueStart: int32 = r2cControllerJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    let endPos: int32 = r2cControllerJsonFindBalancedEnd(text, valueStart, char(123), char(125))
    if endPos < valueStart:
        return fallback
    return r2cControllerSlice(text, valueStart, endPos - valueStart + 1)

fn r2cControllerJsonReadArrayFieldRaw(text: str,
                                      key: str,
                                      fallback: str): str =
    let valueStart: int32 = r2cControllerJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    let endPos: int32 = r2cControllerJsonFindBalancedEnd(text, valueStart, char(91), char(93))
    if endPos < valueStart:
        return fallback
    return r2cControllerSlice(text, valueStart, endPos - valueStart + 1)

fn r2cControllerJsonArrayNextObjectRaw(arrayText: str,
                                       startRaw: int32,
                                       itemRaw: var str,
                                       nextPos: var int32): bool =
    itemRaw = ""
    let total: int32 = strings.Len(arrayText)
    var pos: int32 = startRaw
    if pos < 0:
        pos = 0
    pos = r2cControllerJsonSkipWhitespace(arrayText, pos)
    if pos < total:
        if arrayText[pos] == char(91):
            pos = r2cControllerJsonSkipWhitespace(arrayText, pos + 1)
    if pos < total:
        if arrayText[pos] == ',':
            pos = r2cControllerJsonSkipWhitespace(arrayText, pos + 1)
    var arrayEnd: bool
    if pos >= total:
        arrayEnd = true
    elif arrayText[pos] == char(93):
        arrayEnd = true
    if arrayEnd:
        nextPos = total
        return false
    if arrayText[pos] != char(123):
        nextPos = pos
        return false
    let endPos: int32 = r2cControllerJsonFindBalancedEnd(arrayText, pos, char(123), char(125))
    if endPos < pos:
        nextPos = pos
        return false
    itemRaw = r2cControllerSlice(arrayText, pos, endPos - pos + 1)
    nextPos = endPos + 1
    return true

fn r2cControllerNativeLayoutRequireField(itemRaw: str,
                                         key: str,
                                         scope: str,
                                         index: int32,
                                         sourcePath: str): bool =
    if r2cControllerJsonHasField(itemRaw, key):
        return true
    r2cControllerPrintErr("r2c-react: native layout typed item missing " + key + " scope=" + scope + " index=" + intToStr(index) + " source=" + sourcePath)
    return false

fn r2cControllerReadNativeLayoutTypedItem(itemRaw: str,
                                          scope: str,
                                          index: int32,
                                          sourcePath: str,
                                          out: var R2cNativeLayoutTypedItem): bool =
    if !r2cControllerNativeLayoutRequireField(itemRaw, "id", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "kind", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "plan_role", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "layer", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "z_index", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "visible_in_viewport", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "synthetic", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "x", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "y", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "width", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "height", scope, index, sourcePath):
        return false
    if !r2cControllerNativeLayoutRequireField(itemRaw, "text", scope, index, sourcePath):
        return false
    out.scope = scope
    out.index = index
    out.itemId = r2cControllerJsonReadStringField(itemRaw, "id", "")
    out.kind = r2cControllerJsonReadStringField(itemRaw, "kind", "")
    out.planRole = r2cControllerJsonReadStringField(itemRaw, "plan_role", "")
    out.layer = r2cControllerJsonReadStringField(itemRaw, "layer", "")
    out.zIndex = r2cControllerJsonReadIntField(itemRaw, "z_index", 0)
    out.x = r2cControllerJsonReadIntField(itemRaw, "x", 0)
    out.y = r2cControllerJsonReadIntField(itemRaw, "y", 0)
    out.width = r2cControllerJsonReadIntField(itemRaw, "width", 0)
    out.height = r2cControllerJsonReadIntField(itemRaw, "height", 0)
    if strings.Len(out.itemId) <= 0:
        r2cControllerPrintErr("r2c-react: native layout typed item empty id scope=" + scope + " index=" + intToStr(index) + " source=" + sourcePath)
        return false
    if strings.Len(out.kind) <= 0:
        r2cControllerPrintErr("r2c-react: native layout typed item empty kind scope=" + scope + " index=" + intToStr(index) + " source=" + sourcePath)
        return false
    if out.width <= 0:
        r2cControllerPrintErr("r2c-react: native layout typed item invalid width scope=" + scope + " index=" + intToStr(index) + " source=" + sourcePath)
        return false
    if out.height <= 0:
        r2cControllerPrintErr("r2c-react: native layout typed item invalid height scope=" + scope + " index=" + intToStr(index) + " source=" + sourcePath)
        return false
    out.text = r2cControllerJsonReadStringField(itemRaw, "text", "")
    out.detailText = r2cControllerJsonReadStringField(itemRaw, "detail_text", "")
    out.visibleInViewport = r2cControllerJsonReadBoolField(itemRaw, "visible_in_viewport", false)
    out.synthetic = r2cControllerJsonReadBoolField(itemRaw, "synthetic", false)
    out.interactive = r2cControllerJsonReadBoolField(itemRaw, "interactive", false)
    out.sourceBacked = r2cControllerJsonReadBoolField(itemRaw, "source_backed", false)
    out.stretchX = r2cControllerJsonReadBoolField(itemRaw, "stretch_x", false)
    out.stretchY = r2cControllerJsonReadBoolField(itemRaw, "stretch_y", false)
    out.column = r2cControllerJsonReadIntField(itemRaw, "column", 0)
    out.columnSpan = r2cControllerJsonReadIntField(itemRaw, "column_span", 0)
    out.visualRole = r2cControllerJsonReadStringField(itemRaw, "visual_role", "")
    out.density = r2cControllerJsonReadStringField(itemRaw, "density", "")
    out.prominence = r2cControllerJsonReadStringField(itemRaw, "prominence", "")
    out.accentTone = r2cControllerJsonReadStringField(itemRaw, "accent_tone", "")
    out.backgroundColor = r2cControllerJsonReadStringField(itemRaw, "background_color", "")
    out.borderColor = r2cControllerJsonReadStringField(itemRaw, "border_color", "")
    out.textColor = r2cControllerJsonReadStringField(itemRaw, "text_color", "")
    out.detailColor = r2cControllerJsonReadStringField(itemRaw, "detail_color", "")
    out.fontSize = r2cControllerJsonReadIntField(itemRaw, "font_size", 0)
    out.fontWeight = r2cControllerJsonReadStringField(itemRaw, "font_weight", "")
    out.cornerRadius = r2cControllerJsonReadIntField(itemRaw, "corner_radius", 0)
    out.sourceNodeId = r2cControllerJsonReadStringField(itemRaw, "source_node_id", "")
    out.sourceModulePath = r2cControllerJsonReadStringField(itemRaw, "source_module_path", "")
    out.sourceComponentName = r2cControllerJsonReadStringField(itemRaw, "source_component_name", "")
    out.sourceLine = r2cControllerJsonReadIntField(itemRaw, "source_line", 0)
    out.textLength = strings.Len(out.text)
    if strings.Len(out.sourceNodeId) > 0:
        out.sourceBacked = true
    elif strings.Len(out.sourceModulePath) > 0:
        out.sourceBacked = true
    elif strings.Len(out.sourceComponentName) > 0:
        out.sourceBacked = true
    return true

fn r2cControllerNativeLayoutTypedItemJson(item: R2cNativeLayoutTypedItem): str =
    var line = "    {"
    line = line + "\"scope\":" + r2cControllerJsonQuote(item.scope) + ","
    line = line + "\"index\":" + intToStr(item.index) + ","
    line = line + "\"id\":" + r2cControllerJsonQuote(item.itemId) + ","
    line = line + "\"kind\":" + r2cControllerJsonQuote(item.kind) + ","
    line = line + "\"plan_role\":" + r2cControllerJsonQuote(item.planRole) + ","
    line = line + "\"layer\":" + r2cControllerJsonQuote(item.layer) + ","
    line = line + "\"z_index\":" + intToStr(item.zIndex) + ","
    line = line + "\"x\":" + intToStr(item.x) + ","
    line = line + "\"y\":" + intToStr(item.y) + ","
    line = line + "\"width\":" + intToStr(item.width) + ","
    line = line + "\"height\":" + intToStr(item.height) + ","
    line = line + "\"text\":" + r2cControllerJsonQuote(item.text) + ","
    line = line + "\"detail_text\":" + r2cControllerJsonQuote(item.detailText) + ","
    line = line + "\"visible_in_viewport\":" + r2cControllerJsonBool(item.visibleInViewport) + ","
    line = line + "\"synthetic\":" + r2cControllerJsonBool(item.synthetic) + ","
    line = line + "\"interactive\":" + r2cControllerJsonBool(item.interactive) + ","
    line = line + "\"source_backed\":" + r2cControllerJsonBool(item.sourceBacked) + ","
    line = line + "\"stretch_x\":" + r2cControllerJsonBool(item.stretchX) + ","
    line = line + "\"stretch_y\":" + r2cControllerJsonBool(item.stretchY) + ","
    line = line + "\"column\":" + intToStr(item.column) + ","
    line = line + "\"column_span\":" + intToStr(item.columnSpan) + ","
    line = line + "\"visual_role\":" + r2cControllerJsonQuote(item.visualRole) + ","
    line = line + "\"density\":" + r2cControllerJsonQuote(item.density) + ","
    line = line + "\"prominence\":" + r2cControllerJsonQuote(item.prominence) + ","
    line = line + "\"accent_tone\":" + r2cControllerJsonQuote(item.accentTone) + ","
    line = line + "\"background_color\":" + r2cControllerJsonQuote(item.backgroundColor) + ","
    line = line + "\"border_color\":" + r2cControllerJsonQuote(item.borderColor) + ","
    line = line + "\"text_color\":" + r2cControllerJsonQuote(item.textColor) + ","
    line = line + "\"detail_color\":" + r2cControllerJsonQuote(item.detailColor) + ","
    line = line + "\"font_size\":" + intToStr(item.fontSize) + ","
    line = line + "\"font_weight\":" + r2cControllerJsonQuote(item.fontWeight) + ","
    line = line + "\"corner_radius\":" + intToStr(item.cornerRadius) + ","
    line = line + "\"text_length\":" + intToStr(item.textLength) + ","
    line = line + "\"source_node_id\":" + r2cControllerJsonQuote(item.sourceNodeId) + ","
    line = line + "\"source_module_path\":" + r2cControllerJsonQuote(item.sourceModulePath) + ","
    line = line + "\"source_component_name\":" + r2cControllerJsonQuote(item.sourceComponentName) + ","
    line = line + "\"source_line\":" + intToStr(item.sourceLine)
    line = line + "}"
    return line

fn r2cControllerNativeLayoutTypedItemsArrayJson(fieldName: str,
                                                scope: str,
                                                sourcePath: str,
                                                arrayText: str,
                                                expectedCount: int32,
                                                outCount: var int32,
                                                outInteractiveCount: var int32,
                                                outSourceBackedCount: var int32,
                                                outTextPayloadCount: var int32,
                                                outStylePayloadCount: var int32,
                                                outOk: var bool): str =
    outCount = 0
    outInteractiveCount = 0
    outSourceBackedCount = 0
    outTextPayloadCount = 0
    outStylePayloadCount = 0
    outOk = true
    var out = "  " + r2cControllerJsonQuote(fieldName) + ": [\n"
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(arrayText, cursor, itemRaw, nextPos):
        cursor = nextPos
        var item: R2cNativeLayoutTypedItem
        if !r2cControllerReadNativeLayoutTypedItem(itemRaw, scope, outCount, sourcePath, item):
            outOk = false
            return out
        if outCount > 0:
            out = out + ",\n"
        out = out + r2cControllerNativeLayoutTypedItemJson(item) + "\n"
        outCount = outCount + 1
        if item.interactive:
            outInteractiveCount = outInteractiveCount + 1
        if item.sourceBacked:
            outSourceBackedCount = outSourceBackedCount + 1
        var hasTextPayload: bool
        if item.textLength > 0:
            hasTextPayload = true
        elif strings.Len(item.detailText) > 0:
            hasTextPayload = true
        if hasTextPayload:
            outTextPayloadCount = outTextPayloadCount + 1
        if strings.Len(item.backgroundColor) > 0 || strings.Len(item.borderColor) > 0 || strings.Len(item.textColor) > 0 || strings.Len(item.detailColor) > 0:
            outStylePayloadCount = outStylePayloadCount + 1
        elif strings.Len(item.visualRole) > 0 || strings.Len(item.density) > 0 || strings.Len(item.prominence) > 0 || strings.Len(item.accentTone) > 0:
            outStylePayloadCount = outStylePayloadCount + 1
        elif item.fontSize > 0 || strings.Len(item.fontWeight) > 0 || item.cornerRadius > 0:
            outStylePayloadCount = outStylePayloadCount + 1
    out = out + "  ]"
    if outCount != expectedCount:
        r2cControllerPrintErr("r2c-react: native layout typed catalog count mismatch scope=" + scope + " expected=" + intToStr(expectedCount) + " actual=" + intToStr(outCount) + " source=" + sourcePath)
        outOk = false
    return out

fn r2cControllerWriteNativeLayoutTypedCatalog(catalogPath: str,
                                              sourcePath: str,
                                              routeState: str,
                                              itemsRaw: str,
                                              viewportItemsRaw: str,
                                              expectedItemCount: int32,
                                              expectedViewportItemCount: int32,
                                              expectedInteractiveItemCount: int32,
                                              expectedSourceBackedItemCount: int32,
                                              outItemCount: var int32,
                                              outViewportItemCount: var int32,
                                              outInteractiveItemCount: var int32,
                                              outSourceBackedItemCount: var int32,
                                              outTextPayloadItemCount: var int32,
                                              outStylePayloadItemCount: var int32,
                                              outViewportTextPayloadItemCount: var int32,
                                              outViewportStylePayloadItemCount: var int32): bool =
    var catalog = "{\n"
    catalog = catalog + "  \"format\": \"native_layout_item_catalog_v1\",\n"
    catalog = catalog + "  \"controller\": \"cheng.live_controller\",\n"
    catalog = catalog + "  \"publish_mode\": \"cheng_streamed_typed_layout_items_v1\",\n"
    catalog = catalog + "  \"payload_profile\": \"cheng_runtime_layout_item_payload_v1\",\n"
    catalog = catalog + "  \"text_payload_ready\": true,\n"
    catalog = catalog + "  \"style_payload_ready\": true,\n"
    catalog = catalog + "  \"route_state\": " + r2cControllerJsonQuote(routeState) + ",\n"
    catalog = catalog + "  \"source_native_layout_plan_path\": " + r2cControllerJsonQuote(sourcePath) + ",\n"
    catalog = catalog + "  \"item_count\": " + intToStr(expectedItemCount) + ",\n"
    catalog = catalog + "  \"viewport_item_count\": " + intToStr(expectedViewportItemCount) + ",\n"
    var viewportInteractiveCount: int32
    var viewportSourceBackedCount: int32
    var itemsTextPayloadCount: int32
    var itemsStylePayloadCount: int32
    var itemsOk: bool
    let itemsJson: str = r2cControllerNativeLayoutTypedItemsArrayJson("items",
                                                                      "items",
                                                                      sourcePath,
                                                                      itemsRaw,
                                                                      expectedItemCount,
                                                                      outItemCount,
                                                                      outInteractiveItemCount,
                                                                      outSourceBackedItemCount,
                                                                      itemsTextPayloadCount,
                                                                      itemsStylePayloadCount,
                                                                      itemsOk)
    if !itemsOk:
        return false
    outTextPayloadItemCount = itemsTextPayloadCount
    outStylePayloadItemCount = itemsStylePayloadCount
    var viewportTextPayloadCount: int32
    var viewportStylePayloadCount: int32
    var viewportItemsOk: bool
    let viewportItemsJson: str = r2cControllerNativeLayoutTypedItemsArrayJson("viewport_items",
                                                                              "viewport_items",
                                                                              sourcePath,
                                                                              viewportItemsRaw,
                                                                              expectedViewportItemCount,
                                                                              outViewportItemCount,
                                                                              viewportInteractiveCount,
                                                                              viewportSourceBackedCount,
                                                                              viewportTextPayloadCount,
                                                                              viewportStylePayloadCount,
                                                                              viewportItemsOk)
    if !viewportItemsOk:
        return false
    outViewportTextPayloadItemCount = viewportTextPayloadCount
    outViewportStylePayloadItemCount = viewportStylePayloadCount
    catalog = catalog + "  \"text_payload_item_count\": " + intToStr(outTextPayloadItemCount) + ",\n"
    catalog = catalog + "  \"style_payload_item_count\": " + intToStr(outStylePayloadItemCount) + ",\n"
    catalog = catalog + "  \"viewport_text_payload_item_count\": " + intToStr(outViewportTextPayloadItemCount) + ",\n"
    catalog = catalog + "  \"viewport_style_payload_item_count\": " + intToStr(outViewportStylePayloadItemCount) + ",\n"
    catalog = catalog + itemsJson + ",\n"
    catalog = catalog + viewportItemsJson + "\n"
    catalog = catalog + "}\n"
    if outInteractiveItemCount != expectedInteractiveItemCount:
        r2cControllerPrintErr("r2c-react: native layout typed catalog interactive count mismatch expected=" + intToStr(expectedInteractiveItemCount) + " actual=" + intToStr(outInteractiveItemCount) + " source=" + sourcePath)
        return false
    if outSourceBackedItemCount != expectedSourceBackedItemCount:
        r2cControllerPrintErr("r2c-react: native layout typed catalog source-backed count mismatch expected=" + intToStr(expectedSourceBackedItemCount) + " actual=" + intToStr(outSourceBackedItemCount) + " source=" + sourcePath)
        return false
    if !v3path.V3WriteTextFile("", catalogPath, catalog):
        r2cControllerPrintErr("r2c-react: native layout typed catalog write failed: " + catalogPath)
        return false
    return true

fn r2cControllerCsvAppend(csvText: str,
                          item: str): str =
    if strings.Len(item) <= 0:
        return csvText
    if strings.Len(csvText) <= 0:
        return item
    return csvText + "," + item

fn r2cControllerJsonStringifyStringValue(value: str): str =
    return value

fn r2cControllerJsonStringifyBoolValue(value: bool): str =
    return r2cControllerJsonBool(value)

fn r2cControllerEnsureTrailingNewline(textRaw: str): str =
    let text: str = textRaw
    if strings.Len(text) <= 0:
        return "\n"
    let lastIndex: int32 = strings.Len(text) - 1
    if text[lastIndex] == '\n':
        return text
    return text + "\n"

fn r2cControllerSummaryLineHasKey(line: str,
                                  key: str): bool =
    let prefix: str = key + "="
    let prefixLen: int32 = strings.Len(prefix)
    if strings.Len(line) < prefixLen:
        return false
    return r2cControllerSlice(line, 0, prefixLen) == prefix

fn r2cControllerSummaryLineMatchesAny(line: str,
                                      keys: str[]): bool =
    for i in 0..<keys.len:
        if r2cControllerSummaryLineHasKey(line, keys[i]):
            return true
    return false

fn r2cControllerSummaryStripKeys(text: str,
                                 keys: str[]): str =
    if keys.len <= 0:
        return text
    let total: int32 = strings.Len(text)
    var out: str
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif text[i] == '\n':
            endHit = true
        if !endHit:
            continue
        let lineLen: int32 = i - start
        let line: str = r2cControllerSlice(text, start, lineLen)
        if !r2cControllerSummaryLineMatchesAny(line, keys):
            out = out + line + "\n"
        start = i + 1
    return out

fn r2cControllerJsonAppendRootFields(docRaw: str,
                                     fieldsDoc: str): str =
    let doc: str = strutil.Strip(docRaw)
    let total: int32 = strings.Len(doc)
    if total <= 0:
        return ""
    if doc[total - 1] != char(125):
        return ""
    let body: str = r2cControllerSlice(doc, 0, total - 1)
    return body + ",\n" + fieldsDoc + "\n}\n"

fn r2cControllerWriteRuntimeContractWithTypedCatalog(contractPath: str,
                                                     typedCatalogPath: str,
                                                     itemCountText: str,
                                                     viewportItemCountText: str,
                                                     interactiveItemCountText: str,
                                                     sourceBackedItemCountText: str): bool =
    if strings.Len(contractPath) <= 0:
        r2cControllerPrintErr("r2c-react: runtime contract path missing")
        return false
    if !v3path.V3PathFileExists(contractPath):
        r2cControllerPrintErr("r2c-react: runtime contract missing: " + contractPath)
        return false
    let contractText: str = v3path.V3ReadTextFile("", contractPath)
    if r2cControllerJsonReadStringField(contractText, "format", "") != "native_gui_runtime_contract_v1":
        r2cControllerPrintErr("r2c-react: runtime contract format mismatch: " + contractPath)
        return false
    var fieldsDoc = "  \"runtime_item_source_mode\": \"typed_item_catalog_contract_v1\",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_path\": " + r2cControllerJsonQuote(typedCatalogPath) + ",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_ready\": true,\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_format\": \"native_layout_item_catalog_v1\",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_publish_mode\": \"cheng_streamed_typed_layout_items_v1\",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_payload_profile\": \"cheng_runtime_layout_item_payload_v1\",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_text_payload_ready\": true,\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_style_payload_ready\": true,\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_item_count\": " + itemCountText + ",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_viewport_item_count\": " + viewportItemCountText + ",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_interactive_item_count\": " + interactiveItemCountText + ",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog_source_backed_item_count\": " + sourceBackedItemCountText + ",\n"
    fieldsDoc = fieldsDoc + "  \"typed_item_catalog\": {\n"
    fieldsDoc = fieldsDoc + "    \"path\": " + r2cControllerJsonQuote(typedCatalogPath) + ",\n"
    fieldsDoc = fieldsDoc + "    \"ready\": true,\n"
    fieldsDoc = fieldsDoc + "    \"format\": \"native_layout_item_catalog_v1\",\n"
    fieldsDoc = fieldsDoc + "    \"publish_mode\": \"cheng_streamed_typed_layout_items_v1\",\n"
    fieldsDoc = fieldsDoc + "    \"payload_profile\": \"cheng_runtime_layout_item_payload_v1\",\n"
    fieldsDoc = fieldsDoc + "    \"text_payload_ready\": true,\n"
    fieldsDoc = fieldsDoc + "    \"style_payload_ready\": true,\n"
    fieldsDoc = fieldsDoc + "    \"item_count\": " + itemCountText + ",\n"
    fieldsDoc = fieldsDoc + "    \"viewport_item_count\": " + viewportItemCountText + ",\n"
    fieldsDoc = fieldsDoc + "    \"interactive_item_count\": " + interactiveItemCountText + ",\n"
    fieldsDoc = fieldsDoc + "    \"source_backed_item_count\": " + sourceBackedItemCountText + "\n"
    fieldsDoc = fieldsDoc + "  }"
    let nextText: str = r2cControllerJsonAppendRootFields(contractText, fieldsDoc)
    if strings.Len(nextText) <= 0:
        r2cControllerPrintErr("r2c-react: runtime contract append failed: " + contractPath)
        return false
    if !v3path.V3WriteTextFile("", contractPath, nextText):
        r2cControllerPrintErr("r2c-react: runtime contract write failed: " + contractPath)
        return false
    return true

fn r2cControllerWritePayloadSourceCopy(copyPath: str,
                                       sourcePath: str,
                                       sourceText: str,
                                       label: str): bool =
    if strings.Len(copyPath) <= 0:
        r2cControllerPrintErr("r2c-react: " + label + " source copy path missing")
        return false
    if !v3path.V3WriteTextFile("", copyPath, r2cControllerEnsureTrailingNewline(sourceText)):
        r2cControllerPrintErr("r2c-react: " + label + " source copy write failed: " + copyPath + " source=" + sourcePath)
        return false
    return true

fn r2cControllerRepublishStyleLayoutSurfacePayload(styleLayoutSurfacePath: str,
                                                   sourcePayloadPath: str,
                                                   layoutSurfacePath: str,
                                                   routeState: str,
                                                   sourceModulePath: str,
                                                   sourceComponentName: str,
                                                   nodePayloadHelper: str,
                                                   sourceText: str,
                                                   readyText: str,
                                                   nodeCountText: str,
                                                   overlayNodeCountText: str,
                                                   surfaceNodeCountText: str,
                                                   controlNodeCountText: str): bool =
    let visualRoleHistogramRaw: str = r2cControllerJsonReadObjectFieldRaw(sourceText, "visual_role_histogram", "")
    if strings.Len(visualRoleHistogramRaw) <= 0:
        r2cControllerPrintErr("r2c-react: style layout payload missing visual_role_histogram: " + sourcePayloadPath)
        return false
    let layoutRoleHistogramRaw: str = r2cControllerJsonReadObjectFieldRaw(sourceText, "layout_role_histogram", "")
    if strings.Len(layoutRoleHistogramRaw) <= 0:
        r2cControllerPrintErr("r2c-react: style layout payload missing layout_role_histogram: " + sourcePayloadPath)
        return false
    let densityHistogramRaw: str = r2cControllerJsonReadObjectFieldRaw(sourceText, "density_histogram", "")
    if strings.Len(densityHistogramRaw) <= 0:
        r2cControllerPrintErr("r2c-react: style layout payload missing density_histogram: " + sourcePayloadPath)
        return false
    let nodesRaw: str = r2cControllerJsonReadArrayFieldRaw(sourceText, "nodes", "")
    if strings.Len(nodesRaw) <= 0:
        r2cControllerPrintErr("r2c-react: style layout payload missing nodes[]: " + sourcePayloadPath)
        return false
    var doc = "{\n"
    doc = doc + "  \"format\": \"style_layout_surface_v1\",\n"
    doc = doc + "  \"controller\": \"cheng.live_controller\",\n"
    doc = doc + "  \"finalizer\": \"cheng_controller_layout_payload_finalizer_v1\",\n"
    doc = doc + "  \"publish_mode\": \"cheng_controller_republished_payload_v1\",\n"
    doc = doc + "  \"node_payload_helper\": " + r2cControllerJsonQuote(nodePayloadHelper) + ",\n"
    doc = doc + "  \"source_payload_path\": " + r2cControllerJsonQuote(sourcePayloadPath) + ",\n"
    doc = doc + "  \"source_layout_surface_path\": " + r2cControllerJsonQuote(layoutSurfacePath) + ",\n"
    doc = doc + "  \"route_state\": " + r2cControllerJsonQuote(routeState) + ",\n"
    doc = doc + "  \"source_module_path\": " + r2cControllerJsonQuote(sourceModulePath) + ",\n"
    doc = doc + "  \"source_component_name\": " + r2cControllerJsonQuote(sourceComponentName) + ",\n"
    doc = doc + "  \"ready\": " + r2cControllerJsonBoolTextOrFalse(readyText) + ",\n"
    doc = doc + "  \"node_count\": " + nodeCountText + ",\n"
    doc = doc + "  \"overlay_node_count\": " + overlayNodeCountText + ",\n"
    doc = doc + "  \"surface_node_count\": " + surfaceNodeCountText + ",\n"
    doc = doc + "  \"control_node_count\": " + controlNodeCountText + ",\n"
    doc = doc + "  \"visual_role_histogram\": " + visualRoleHistogramRaw + ",\n"
    doc = doc + "  \"layout_role_histogram\": " + layoutRoleHistogramRaw + ",\n"
    doc = doc + "  \"density_histogram\": " + densityHistogramRaw + ",\n"
    doc = doc + "  \"nodes\": " + nodesRaw + "\n"
    doc = doc + "}\n"
    if !v3path.V3WriteTextFile("", styleLayoutSurfacePath, doc):
        r2cControllerPrintErr("r2c-react: style layout payload republish failed: " + styleLayoutSurfacePath)
        return false
    return true

fn r2cControllerRepublishNativeLayoutPlanPayload(nativeLayoutPlanPath: str,
                                                 sourcePayloadPath: str,
                                                 layoutSurfacePath: str,
                                                 styleLayoutSurfacePath: str,
                                                 typedCatalogPath: str,
                                                 routeState: str,
                                                 nodePayloadHelper: str,
                                                 sourceText: str,
                                                 readyText: str,
                                                 layoutPolicySource: str,
                                                 windowWidthText: str,
                                                 windowHeightText: str,
                                                 contentStartYText: str,
                                                 contentHeightText: str,
                                                 scrollHeightText: str,
                                                 itemCountText: str,
                                                 viewportItemCountText: str,
                                                 clippedItemCountText: str,
                                                 overlayItemCountText: str,
                                                 interactiveItemCountText: str,
                                                 sourceBackedItemCountText: str,
                                                 columnCountText: str,
                                                 layoutPolicyRaw: str,
                                                 itemsRaw: str,
                                                 viewportItemsRaw: str): bool =
    let entryModule: str = r2cControllerJsonReadStringField(sourceText, "entry_module", "")
    if strings.Len(entryModule) <= 0:
        r2cControllerPrintErr("r2c-react: native layout payload missing entry_module: " + sourcePayloadPath)
        return false
    var doc = "{\n"
    doc = doc + "  \"format\": \"native_layout_plan_v1\",\n"
    doc = doc + "  \"controller\": \"cheng.live_controller\",\n"
    doc = doc + "  \"finalizer\": \"cheng_controller_layout_payload_finalizer_v1\",\n"
    doc = doc + "  \"publish_mode\": \"cheng_controller_republished_payload_v1\",\n"
    doc = doc + "  \"node_payload_helper\": " + r2cControllerJsonQuote(nodePayloadHelper) + ",\n"
    doc = doc + "  \"source_payload_path\": " + r2cControllerJsonQuote(sourcePayloadPath) + ",\n"
    doc = doc + "  \"typed_item_catalog_path\": " + r2cControllerJsonQuote(typedCatalogPath) + ",\n"
    doc = doc + "  \"typed_item_catalog_ready\": true,\n"
    doc = doc + "  \"typed_item_catalog_publish_mode\": \"cheng_streamed_typed_layout_items_v1\",\n"
    doc = doc + "  \"typed_item_catalog_payload_profile\": \"cheng_runtime_layout_item_payload_v1\",\n"
    doc = doc + "  \"route_state\": " + r2cControllerJsonQuote(routeState) + ",\n"
    doc = doc + "  \"entry_module\": " + r2cControllerJsonQuote(entryModule) + ",\n"
    doc = doc + "  \"layout_policy_source\": " + r2cControllerJsonQuote(layoutPolicySource) + ",\n"
    doc = doc + "  \"source_layout_surface_path\": " + r2cControllerJsonQuote(layoutSurfacePath) + ",\n"
    doc = doc + "  \"source_style_layout_surface_path\": " + r2cControllerJsonQuote(styleLayoutSurfacePath) + ",\n"
    doc = doc + "  \"ready\": " + r2cControllerJsonBoolTextOrFalse(readyText) + ",\n"
    doc = doc + "  \"window_width\": " + windowWidthText + ",\n"
    doc = doc + "  \"window_height\": " + windowHeightText + ",\n"
    doc = doc + "  \"content_start_y\": " + contentStartYText + ",\n"
    doc = doc + "  \"content_height\": " + contentHeightText + ",\n"
    doc = doc + "  \"scroll_height\": " + scrollHeightText + ",\n"
    doc = doc + "  \"item_count\": " + itemCountText + ",\n"
    doc = doc + "  \"viewport_item_count\": " + viewportItemCountText + ",\n"
    doc = doc + "  \"clipped_item_count\": " + clippedItemCountText + ",\n"
    doc = doc + "  \"overlay_item_count\": " + overlayItemCountText + ",\n"
    doc = doc + "  \"interactive_item_count\": " + interactiveItemCountText + ",\n"
    doc = doc + "  \"source_backed_item_count\": " + sourceBackedItemCountText + ",\n"
    doc = doc + "  \"column_count\": " + columnCountText + ",\n"
    doc = doc + "  \"layout_policy\": " + layoutPolicyRaw + ",\n"
    doc = doc + "  \"items\": " + itemsRaw + ",\n"
    doc = doc + "  \"viewport_items\": " + viewportItemsRaw + "\n"
    doc = doc + "}\n"
    if !v3path.V3WriteTextFile("", nativeLayoutPlanPath, doc):
        r2cControllerPrintErr("r2c-react: native layout payload republish failed: " + nativeLayoutPlanPath)
        return false
    return true

fn r2cControllerRunCompiledRuntimeLogged(root: str,
                                         runtimeExePath: str,
                                         runtimeContractPath: str,
                                         logPath: str,
                                         exitCodeOut: var int32,
                                         outputOut: var str): bool =
    var argv: str[]
    add(argv, "--runtime-contract")
    add(argv, runtimeContractPath)
    return r2cproc.r2cProcessRunFileLogged(root,
                                           "r2c-react compiled runtime",
                                           runtimeExePath,
                                           argv,
                                           root,
                                           logPath,
                                           exitCodeOut,
                                           outputOut)

fn r2cControllerJsonStringifyIntValue(value: int32): str =
    return intToStr(value)

fn r2cControllerSemanticNodeKind(kindRaw: str): str =
    if kindRaw == "tree_element" || kindRaw == "element":
        return "element"
    if kindRaw == "tree_button" || kindRaw == "tree_input" || kindRaw == "tree_link" || kindRaw == "tree_media":
        return "element"
    if kindRaw == "tree_text" || kindRaw == "text":
        return "text"
    if kindRaw == "tree_component" || kindRaw == "component":
        return "component"
    if kindRaw == "tree_component_ref" || kindRaw == "component_ref":
        return "component_ref"
    if kindRaw == "tree_branch" || kindRaw == "branch":
        return "branch"
    if kindRaw == "tree_repeat" || kindRaw == "repeat":
        return "repeat"
    if kindRaw == "tree_fragment" || kindRaw == "fragment":
        return "fragment"
    return kindRaw

fn r2cControllerSemanticNodeIncluded(nodeKind: str): bool =
    if nodeKind == "component" || nodeKind == "component_ref":
        return false
    if nodeKind == "branch" || nodeKind == "repeat" || nodeKind == "fragment":
        return false
    return true

fn r2cControllerSemanticNodeKey(nodeKind: str,
                                tag: str,
                                label: str,
                                classPreview: str,
                                textPreview: str): str =
    if nodeKind == "element":
        if strings.Len(classPreview) > 0:
            return "element|" + tag + "|" + classPreview
        return "element|" + tag
    if nodeKind == "text":
        if strings.Len(textPreview) > 0:
            return "text|" + textPreview
        return "text|" + label
    if nodeKind == "branch":
        return "branch|" + label
    if nodeKind == "component":
        return "component|" + tag + "|" + label
    return nodeKind + "|" + tag + "|" + label

fn r2cControllerSemanticNodeFallbackKey1(nodeKind: str,
                                         tag: str,
                                         label: str,
                                         textPreview: str): str =
    if nodeKind == "element":
        if strings.Len(textPreview) > 0:
            return "element|" + tag + "|text:" + textPreview
    return ""

fn r2cControllerSemanticNodeFallbackKey2(nodeKind: str,
                                         tag: str): str =
    if nodeKind == "element":
        return "element|" + tag
    return ""

fn r2cControllerSemanticNodeAllowsTagFallback(node: R2cSemanticNodeDoc): bool =
    if strings.Len(node.keyFallback2) <= 0:
        return false
    if node.key != node.keyFallback2:
        return false
    if strings.Len(node.classPreview) > 0:
        return false
    if strings.Len(node.textPreview) > 0:
        return false
    return true

fn r2cControllerSemanticNodeKeysMatch(left: R2cSemanticNodeDoc,
                                      right: R2cSemanticNodeDoc): bool =
    if strings.Len(left.key) > 0 && left.key == right.key:
        return true
    if strings.Len(left.keyFallback1) > 0:
        if left.keyFallback1 == right.key || left.keyFallback1 == right.keyFallback1:
            return true
    if strings.Len(right.keyFallback1) > 0:
        if left.key == right.keyFallback1:
            return true
    if r2cControllerSemanticNodeAllowsTagFallback(left) && r2cControllerSemanticNodeAllowsTagFallback(right):
        if left.keyFallback2 == right.keyFallback2:
            return true
    return false

fn r2cControllerJsonReadExecSemanticNode(nodeRaw: str,
                                         out: var R2cSemanticNodeDoc): bool =
    out.nodeId = r2cControllerJsonReadStringField(nodeRaw, "id", "")
    out.pathText = ""
    out.nodeKind = r2cControllerSemanticNodeKind(r2cControllerJsonReadStringField(nodeRaw, "kind", ""))
    if !r2cControllerSemanticNodeIncluded(out.nodeKind):
        return false
    out.tag = r2cControllerJsonReadStringField(nodeRaw, "tag", "")
    out.label = r2cControllerJsonReadStringField(nodeRaw, "label", "")
    out.classPreview = r2cControllerJsonReadStringField(nodeRaw, "class_preview", "")
    out.detailText = r2cControllerJsonReadStringField(nodeRaw, "detail_text", "")
    out.textPreview = ""
    out.depth = r2cControllerJsonReadIntField(nodeRaw, "depth", 0)
    out.modulePath = r2cControllerJsonReadStringField(nodeRaw, "module_path", "")
    out.componentName = r2cControllerJsonReadStringField(nodeRaw, "component_name", "")
    out.line = r2cControllerJsonReadIntField(nodeRaw, "line", 0)
    if out.nodeKind == "text":
        out.textPreview = out.label
    else:
        out.textPreview = r2cControllerJsonReadStringField(nodeRaw, "text_preview", "")
    out.key = r2cControllerSemanticNodeKey(out.nodeKind,
                                           out.tag,
                                           out.label,
                                           out.classPreview,
                                           out.textPreview)
    out.keyFallback1 = r2cControllerSemanticNodeFallbackKey1(out.nodeKind,
                                                             out.tag,
                                                             out.label,
                                                             out.textPreview)
    out.keyFallback2 = r2cControllerSemanticNodeFallbackKey2(out.nodeKind,
                                                             out.tag)
    return true

fn r2cControllerJsonReadTruthSemanticNode(nodeRaw: str,
                                          out: var R2cSemanticNodeDoc): bool =
    out.nodeId = ""
    out.pathText = r2cControllerJsonReadStringField(nodeRaw, "path", "")
    out.nodeKind = r2cControllerSemanticNodeKind(r2cControllerJsonReadStringField(nodeRaw, "kind", ""))
    if !r2cControllerSemanticNodeIncluded(out.nodeKind):
        return false
    out.tag = r2cControllerJsonReadStringField(nodeRaw, "tag", "")
    out.label = r2cControllerJsonReadStringField(nodeRaw, "label", "")
    out.classPreview = r2cControllerJsonReadStringField(nodeRaw, "classPreview", "")
    if strings.Len(out.classPreview) <= 0:
        out.classPreview = r2cControllerJsonReadStringField(nodeRaw, "class_preview", "")
    out.detailText = ""
    out.textPreview = r2cControllerJsonReadStringField(nodeRaw, "textPreview", "")
    if strings.Len(out.textPreview) <= 0:
        out.textPreview = r2cControllerJsonReadStringField(nodeRaw, "text_preview", "")
    out.depth = r2cControllerJsonReadIntField(nodeRaw, "depth", 0)
    out.modulePath = ""
    out.componentName = ""
    out.line = 0
    out.key = r2cControllerSemanticNodeKey(out.nodeKind,
                                           out.tag,
                                           out.label,
                                           out.classPreview,
                                           out.textPreview)
    out.keyFallback1 = r2cControllerSemanticNodeFallbackKey1(out.nodeKind,
                                                             out.tag,
                                                             out.label,
                                                             out.textPreview)
    out.keyFallback2 = r2cControllerSemanticNodeFallbackKey2(out.nodeKind,
                                                             out.tag)
    return true

fn r2cControllerLoadExecSemanticNodes(layoutSurfacePath: str,
                                      out: var R2cSemanticNodeDoc[]): bool =
    out = []
    let docText: str = v3path.V3ReadTextFile("", layoutSurfacePath)
    if r2cControllerJsonReadStringField(docText, "format", "") != "layout_surface_v1":
        return false
    let nodesRaw: str = r2cControllerJsonReadArrayFieldRaw(docText, "nodes", "")
    if strings.Len(nodesRaw) <= 0:
        return true
    var nodeRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(nodesRaw, cursor, nodeRaw, nextPos):
        cursor = nextPos
        var node: R2cSemanticNodeDoc
        if r2cControllerJsonReadExecSemanticNode(nodeRaw, node):
            add(out, node)
    return true

fn r2cControllerLoadTruthSemanticNodes(truthSemanticNodesPath: str,
                                       out: var R2cSemanticNodeDoc[]): bool =
    out = []
    let docText: str = v3path.V3ReadTextFile("", truthSemanticNodesPath)
    if r2cControllerJsonReadStringField(docText, "format", "") != "semantic_dom_nodes_v1":
        return false
    let nodesRaw: str = r2cControllerJsonReadArrayFieldRaw(docText, "nodes", "")
    if strings.Len(nodesRaw) <= 0:
        return true
    var nodeRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(nodesRaw, cursor, nodeRaw, nextPos):
        cursor = nextPos
        var node: R2cSemanticNodeDoc
        if r2cControllerJsonReadTruthSemanticNode(nodeRaw, node):
            add(out, node)
    return true

fn r2cControllerSemanticNodeJson(node: R2cSemanticNodeDoc): str =
    var out = "{"
    out = out + "\"node_id\":" + r2cControllerJsonQuote(node.nodeId) + ","
    out = out + "\"path\":" + r2cControllerJsonQuote(node.pathText) + ","
    out = out + "\"key\":" + r2cControllerJsonQuote(node.key) + ","
    out = out + "\"kind\":" + r2cControllerJsonQuote(node.nodeKind) + ","
    out = out + "\"tag\":" + r2cControllerJsonQuote(node.tag) + ","
    out = out + "\"label\":" + r2cControllerJsonQuote(node.label) + ","
    out = out + "\"class_preview\":" + r2cControllerJsonQuote(node.classPreview) + ","
    out = out + "\"detail_text\":" + r2cControllerJsonQuote(node.detailText) + ","
    out = out + "\"text_preview\":" + r2cControllerJsonQuote(node.textPreview) + ","
    out = out + "\"depth\":" + intToStr(node.depth) + ","
    out = out + "\"module_path\":" + r2cControllerJsonQuote(node.modulePath) + ","
    out = out + "\"component_name\":" + r2cControllerJsonQuote(node.componentName) + ","
    out = out + "\"line\":" + intToStr(node.line)
    out = out + "}"
    return out

fn r2cControllerSemanticNodeJsonArray(nodes: R2cSemanticNodeDoc[]): str =
    var out = "["
    for i in 0..<nodes.len:
        if i > 0:
            out = out + ", "
        out = out + r2cControllerSemanticNodeJson(nodes[i])
    out = out + "]"
    return out

fn r2cControllerWriteSemanticNodeDiff(execSnapshotPath: str,
                                      truthSemanticNodesPath: str,
                                      semanticNodeDiffPath: str,
                                      compare: var R2cTruthCompareEval): bool =
    compare.semanticNodeDiffReady = false
    compare.semanticNodeDiffPath = semanticNodeDiffPath
    compare.semanticNodeDiffBasis = ""
    compare.semanticNodeDiffExecNodeCount = 0
    compare.semanticNodeDiffTruthNodeCount = 0
    compare.semanticNodeDiffSharedCount = 0
    compare.semanticNodeDiffExecOnlyCount = 0
    compare.semanticNodeDiffTruthOnlyCount = 0
    compare.execLayoutSurfacePath = ""
    if strings.Len(truthSemanticNodesPath) <= 0:
        return true
    let execDir: str = v3path.V3PathParentDir(execSnapshotPath)
    let execLayoutSurfacePath: str = os.JoinPath(execDir, "layout_surface_v1.json")
    compare.execLayoutSurfacePath = execLayoutSurfacePath
    if !v3path.V3PathFileExists(execLayoutSurfacePath) || !v3path.V3PathFileExists(truthSemanticNodesPath):
        return true
    var execNodes: R2cSemanticNodeDoc[]
    var truthNodes: R2cSemanticNodeDoc[]
    if !r2cControllerLoadExecSemanticNodes(execLayoutSurfacePath, execNodes):
        return false
    if !r2cControllerLoadTruthSemanticNodes(truthSemanticNodesPath, truthNodes):
        return false
    compare.semanticNodeDiffBasis = "exec_layout_surface_vs_truth_dom"
    compare.semanticNodeDiffExecNodeCount = execNodes.len
    compare.semanticNodeDiffTruthNodeCount = truthNodes.len
    var truthMatched: bool[]
    for i in 0..<truthNodes.len:
        add(truthMatched, false)
    var execOnly: R2cSemanticNodeDoc[]
    var truthOnly: R2cSemanticNodeDoc[]
    for i in 0..<execNodes.len:
        let execNode = execNodes[i]
        var matchedIndex: int32 = -1
        for j in 0..<truthNodes.len:
            if truthMatched[j]:
                continue
            if r2cControllerSemanticNodeKeysMatch(execNode, truthNodes[j]):
                matchedIndex = j
                break
        if matchedIndex >= 0:
            truthMatched[matchedIndex] = true
            compare.semanticNodeDiffSharedCount = compare.semanticNodeDiffSharedCount + 1
        else:
            compare.semanticNodeDiffExecOnlyCount = compare.semanticNodeDiffExecOnlyCount + 1
            if execOnly.len < 48:
                add(execOnly, execNode)
    for i in 0..<truthNodes.len:
        if truthMatched[i]:
            continue
        compare.semanticNodeDiffTruthOnlyCount = compare.semanticNodeDiffTruthOnlyCount + 1
        if truthOnly.len < 48:
            add(truthOnly, truthNodes[i])
    var diffDoc = "{\n"
    diffDoc = diffDoc + "  \"format\": \"semantic_node_diff_v1\",\n"
    diffDoc = diffDoc + "  \"ready\": true,\n"
    diffDoc = diffDoc + "  \"compare_basis\": " + r2cControllerJsonQuote(compare.semanticNodeDiffBasis) + ",\n"
    diffDoc = diffDoc + "  \"exec_snapshot_path\": " + r2cControllerJsonQuote(execSnapshotPath) + ",\n"
    diffDoc = diffDoc + "  \"exec_layout_surface_path\": " + r2cControllerJsonQuote(execLayoutSurfacePath) + ",\n"
    diffDoc = diffDoc + "  \"truth_semantic_nodes_path\": " + r2cControllerJsonQuote(truthSemanticNodesPath) + ",\n"
    diffDoc = diffDoc + "  \"exec_snapshot_semantic_nodes_count\": " + intToStr(compare.execSnapshotSemanticNodesCount) + ",\n"
    diffDoc = diffDoc + "  \"exec_layout_surface_node_count\": " + intToStr(compare.semanticNodeDiffExecNodeCount) + ",\n"
    diffDoc = diffDoc + "  \"truth_semantic_nodes_count\": " + intToStr(compare.semanticNodeDiffTruthNodeCount) + ",\n"
    diffDoc = diffDoc + "  \"shared_count\": " + intToStr(compare.semanticNodeDiffSharedCount) + ",\n"
    diffDoc = diffDoc + "  \"exec_only_count\": " + intToStr(compare.semanticNodeDiffExecOnlyCount) + ",\n"
    diffDoc = diffDoc + "  \"truth_only_count\": " + intToStr(compare.semanticNodeDiffTruthOnlyCount) + ",\n"
    diffDoc = diffDoc + "  \"exec_only_nodes\": " + r2cControllerSemanticNodeJsonArray(execOnly) + ",\n"
    diffDoc = diffDoc + "  \"truth_only_nodes\": " + r2cControllerSemanticNodeJsonArray(truthOnly) + "\n"
    diffDoc = diffDoc + "}\n"
    if !v3path.V3WriteTextFile("", semanticNodeDiffPath, diffDoc):
        return false
    compare.semanticNodeDiffReady = true
    return true

fn r2cControllerRefreshSemanticNodeCompareStatus(compare: var R2cTruthCompareEval) =
    if !compare.truthSemanticNodesCountKnown:
        return
    if compare.mismatchSemanticNodesLoaded && compare.mismatchCount > 0:
        compare.mismatchCount = compare.mismatchCount - 1
    compare.mismatchSemanticNodesLoaded = false
    compare.mismatchSemanticNodesLoadedExecValue = ""
    compare.mismatchSemanticNodesLoadedTruthValue = ""
    compare.execSemanticNodesLoaded = compare.execSemanticNodesCount > 0
    compare.truthSemanticNodesLoaded = compare.truthSemanticNodesCount > 0
    if compare.execSemanticNodesLoaded != compare.truthSemanticNodesLoaded:
        compare.mismatchSemanticNodesLoaded = true
        compare.mismatchSemanticNodesLoadedExecValue = r2cControllerJsonStringifyBoolValue(compare.execSemanticNodesLoaded)
        compare.mismatchSemanticNodesLoadedTruthValue = r2cControllerJsonStringifyBoolValue(compare.truthSemanticNodesLoaded)
        compare.mismatchCount = compare.mismatchCount + 1
    if compare.mismatchSemanticNodesCount && compare.mismatchCount > 0:
        compare.mismatchCount = compare.mismatchCount - 1
    compare.mismatchSemanticNodesCount = false
    compare.mismatchSemanticNodesCountExecValue = ""
    compare.mismatchSemanticNodesCountTruthValue = ""
    if compare.execSemanticNodesCount != compare.truthSemanticNodesCount:
        compare.mismatchSemanticNodesCount = true
        compare.mismatchSemanticNodesCountExecValue = r2cControllerJsonStringifyIntValue(compare.execSemanticNodesCount)
        compare.mismatchSemanticNodesCountTruthValue = r2cControllerJsonStringifyIntValue(compare.truthSemanticNodesCount)
        compare.mismatchCount = compare.mismatchCount + 1
    if compare.missingTruthFieldsCount > 0:
        compare.ok = false
        compare.reason = "missing_truth_fields"
    elif compare.mismatchCount > 0:
        compare.ok = false
        compare.reason = "mismatch"
    else:
        compare.ok = true
        compare.reason = "ok"

fn r2cControllerFindTruthSnapshotMatch(truthDocText: str,
                                       targetState: str,
                                       out: var R2cTruthSnapshotMatch): bool =
    out.matchedIndex = -1
    let snapshotsRaw: str = r2cControllerJsonReadArrayFieldRaw(truthDocText, "snapshots", "")
    if strings.Len(snapshotsRaw) <= 0:
        return false
    var entryRaw: str
    var cursor: int32
    var nextPos: int32
    var index: int32
    while r2cControllerJsonArrayNextObjectRaw(snapshotsRaw, cursor, entryRaw, nextPos):
        cursor = nextPos
        var stateId: str = r2cControllerJsonReadStringField(entryRaw, "stateId", "")
        if strings.Len(stateId) <= 0:
            stateId = r2cControllerJsonReadStringField(entryRaw, "state_id", "")
        var routeId = ""
        let routeRaw: str = r2cControllerJsonReadObjectFieldRaw(entryRaw, "route", "")
        if strings.Len(routeRaw) > 0:
            routeId = r2cControllerJsonReadStringField(routeRaw, "routeId", "")
            if strings.Len(routeId) <= 0:
                routeId = r2cControllerJsonReadStringField(routeRaw, "route_id", "")
        var semanticNodesPath = r2cControllerJsonReadStringField(entryRaw, "semanticNodesPath", "")
        if strings.Len(semanticNodesPath) <= 0:
            semanticNodesPath = r2cControllerJsonReadStringField(entryRaw, "semantic_nodes_path", "")
        var renderReadyKnown = false
        var renderReady = false
        if r2cControllerJsonHasField(entryRaw, "renderReady"):
            renderReadyKnown = true
            renderReady = r2cControllerJsonReadBoolField(entryRaw, "renderReady", false)
        elif r2cControllerJsonHasField(entryRaw, "render_ready"):
            renderReadyKnown = true
            renderReady = r2cControllerJsonReadBoolField(entryRaw, "render_ready", false)
        var semanticNodesCountKnown = false
        var semanticNodesCount: int32
        if r2cControllerJsonHasField(entryRaw, "semanticNodesCount"):
            semanticNodesCountKnown = true
            semanticNodesCount = r2cControllerJsonReadIntField(entryRaw, "semanticNodesCount", 0)
        elif r2cControllerJsonHasField(entryRaw, "semantic_nodes_count"):
            semanticNodesCountKnown = true
            semanticNodesCount = r2cControllerJsonReadIntField(entryRaw, "semantic_nodes_count", 0)
        if stateId == targetState || (strings.Len(stateId) <= 0 && routeId == targetState):
            out.found = true
            out.matchedIndex = index
            out.stateId = stateId
            out.routeId = routeId
            out.semanticNodesPath = semanticNodesPath
            out.renderReadyKnown = renderReadyKnown
            out.renderReady = renderReady
            out.semanticNodesCountKnown = semanticNodesCountKnown
            out.semanticNodesCount = semanticNodesCount
            return true
        index = index + 1
    return true

fn r2cControllerEvaluateTruthCompare(execSnapshotText: str,
                                     truthDocText: str,
                                     requestedTruthState: str,
                                     out: var R2cTruthCompareEval): bool =
    out.truthTraceFormat = r2cControllerJsonReadStringField(truthDocText, "format", "")
    if out.truthTraceFormat != "truth_trace_v2" && out.truthTraceFormat != "r2c-truth-trace-v1":
        return false
    let snapshotsRaw: str = r2cControllerJsonReadArrayFieldRaw(truthDocText, "snapshots", "")
    if strings.Len(snapshotsRaw) <= 0:
        return false
    out.execRouteState = r2cControllerJsonReadStringField(execSnapshotText, "route_state", "")
    out.execRenderReady = r2cControllerJsonReadBoolField(execSnapshotText, "render_ready", false)
    out.execSemanticNodesLoaded = r2cControllerJsonReadBoolField(execSnapshotText, "semantic_nodes_loaded", false)
    out.execSnapshotSemanticNodesCount = r2cControllerJsonReadIntField(execSnapshotText, "semantic_nodes_count", 0)
    out.execSemanticNodesCount = out.execSnapshotSemanticNodesCount
    out.semanticNodeCountCompareBasis = "exec_snapshot_vs_truth_trace"
    out.truthState = requestedTruthState
    if strings.Len(out.truthState) <= 0:
        out.truthState = out.execRouteState
    var matched: R2cTruthSnapshotMatch
    if !r2cControllerFindTruthSnapshotMatch(truthDocText, out.truthState, matched):
        return false
    out.matchedSnapshotIndex = matched.matchedIndex
    if !matched.found:
        out.reason = "missing_truth_state"
        return true
    out.truthRouteState = matched.stateId
    out.truthRouteId = matched.routeId
    out.truthSemanticNodesPath = matched.semanticNodesPath
    out.truthRenderReady = matched.renderReady
    out.truthSemanticNodesCountKnown = matched.semanticNodesCountKnown
    out.truthTraceSemanticNodesCount = matched.semanticNodesCount
    out.truthSemanticNodesCount = out.truthTraceSemanticNodesCount
    if matched.semanticNodesCountKnown:
        out.truthSemanticNodesLoaded = matched.semanticNodesCount > 0
    if strings.Len(out.truthRouteState) <= 0:
        out.missingTruthFieldsCsv = r2cControllerCsvAppend(out.missingTruthFieldsCsv, "route_state")
        out.missingTruthFieldsCount = out.missingTruthFieldsCount + 1
    elif out.execRouteState != out.truthRouteState:
        out.mismatchRouteState = true
        out.mismatchRouteStateExecValue = r2cControllerJsonStringifyStringValue(out.execRouteState)
        out.mismatchRouteStateTruthValue = r2cControllerJsonStringifyStringValue(out.truthRouteState)
        out.mismatchCount = out.mismatchCount + 1
    if !matched.renderReadyKnown:
        out.missingTruthFieldsCsv = r2cControllerCsvAppend(out.missingTruthFieldsCsv, "render_ready")
        out.missingTruthFieldsCount = out.missingTruthFieldsCount + 1
    elif out.execRenderReady != out.truthRenderReady:
        out.mismatchRenderReady = true
        out.mismatchRenderReadyExecValue = r2cControllerJsonStringifyBoolValue(out.execRenderReady)
        out.mismatchRenderReadyTruthValue = r2cControllerJsonStringifyBoolValue(out.truthRenderReady)
        out.mismatchCount = out.mismatchCount + 1
    if !matched.semanticNodesCountKnown:
        out.missingTruthFieldsCsv = r2cControllerCsvAppend(out.missingTruthFieldsCsv, "semantic_nodes_loaded")
        out.missingTruthFieldsCount = out.missingTruthFieldsCount + 1
        out.missingTruthFieldsCsv = r2cControllerCsvAppend(out.missingTruthFieldsCsv, "semantic_nodes_count")
        out.missingTruthFieldsCount = out.missingTruthFieldsCount + 1
    else:
        if out.execSemanticNodesLoaded != out.truthSemanticNodesLoaded:
            out.mismatchSemanticNodesLoaded = true
            out.mismatchSemanticNodesLoadedExecValue = r2cControllerJsonStringifyBoolValue(out.execSemanticNodesLoaded)
            out.mismatchSemanticNodesLoadedTruthValue = r2cControllerJsonStringifyBoolValue(out.truthSemanticNodesLoaded)
            out.mismatchCount = out.mismatchCount + 1
        if out.execSemanticNodesCount != out.truthSemanticNodesCount:
            out.mismatchSemanticNodesCount = true
            out.mismatchSemanticNodesCountExecValue = r2cControllerJsonStringifyIntValue(out.execSemanticNodesCount)
            out.mismatchSemanticNodesCountTruthValue = r2cControllerJsonStringifyIntValue(out.truthSemanticNodesCount)
            out.mismatchCount = out.mismatchCount + 1
    if out.missingTruthFieldsCount > 0:
        out.reason = "missing_truth_fields"
        return true
    if out.mismatchCount > 0:
        out.reason = "mismatch"
        return true
    out.ok = true
    out.reason = "ok"
    return true

fn r2cControllerTruthCompareMismatchesJson(compare: R2cTruthCompareEval): str =
    var out = "["
    var wrote = false
    if compare.mismatchRouteState:
        out = out + "{\"field\":\"route_state\",\"exec_value\":" + r2cControllerJsonQuote(compare.mismatchRouteStateExecValue) + ",\"truth_value\":" + r2cControllerJsonQuote(compare.mismatchRouteStateTruthValue) + "}"
        wrote = true
    if compare.mismatchRenderReady:
        if wrote:
            out = out + ", "
        out = out + "{\"field\":\"render_ready\",\"exec_value\":" + r2cControllerJsonQuote(compare.mismatchRenderReadyExecValue) + ",\"truth_value\":" + r2cControllerJsonQuote(compare.mismatchRenderReadyTruthValue) + "}"
        wrote = true
    if compare.mismatchSemanticNodesLoaded:
        if wrote:
            out = out + ", "
        out = out + "{\"field\":\"semantic_nodes_loaded\",\"exec_value\":" + r2cControllerJsonQuote(compare.mismatchSemanticNodesLoadedExecValue) + ",\"truth_value\":" + r2cControllerJsonQuote(compare.mismatchSemanticNodesLoadedTruthValue) + "}"
        wrote = true
    if compare.mismatchSemanticNodesCount:
        if wrote:
            out = out + ", "
        out = out + "{\"field\":\"semantic_nodes_count\",\"exec_value\":" + r2cControllerJsonQuote(compare.mismatchSemanticNodesCountExecValue) + ",\"truth_value\":" + r2cControllerJsonQuote(compare.mismatchSemanticNodesCountTruthValue) + "}"
    out = out + "]"
    return out

fn r2cControllerLoadTruthCompareNativeGuiSummary(summaryPathRaw: str,
                                                 out: var R2cTruthCompareNativeGuiSummary): bool =
    let summaryPath: str = strutil.Strip(summaryPathRaw)
    out.summaryPath = summaryPath
    if strings.Len(summaryPath) <= 0:
        return true
    if !v3path.V3PathFileExists(summaryPath):
        return false
    out.ready = true
    out.routeState = r2cControllerReadSummaryValue(summaryPath, "native_gui_route_state", "")
    out.screenshotPath = r2cControllerReadSummaryValue(summaryPath, "native_gui_screenshot_path", "")
    out.runtimeBundleReady = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_ready", "") == "true"
    out.runtimeContractReady = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_contract_ready", "") == "true"
    out.runtimeBundleRouteState = r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_route_state", "")
    out.runtimeBundleRouteCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_route_count", "0"))
    out.runtimeBundleSupportedCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_supported_count", "0"))
    out.runtimeBundleSemanticNodesCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_semantic_nodes_count", "0"))
    out.runtimeBundleLayoutItemCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_layout_item_count", "0"))
    out.runtimeBundleRenderCommandCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_bundle_render_command_count", "0"))
    out.runtimeContractLayoutItemCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_contract_layout_item_count", "0"))
    out.runtimeContractViewportItemCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_contract_viewport_item_count", "0"))
    out.runtimeContractInteractiveItemCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_runtime_contract_interactive_item_count", "0"))
    out.nativeLayoutPlanItemCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_native_layout_plan_item_count", "0"))
    out.renderPlanCommandCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(summaryPath, "native_gui_render_plan_command_count", "0"))
    return true

fn r2cControllerWriteTruthCompareArtifacts(truthComparePath: str,
                                           summaryPath: str,
                                           execSnapshotPath: str,
                                           truthTracePath: str,
                                           compare: R2cTruthCompareEval,
                                           nativeGuiSummary: R2cTruthCompareNativeGuiSummary): bool =
    let missingTruthFieldsJson: str = r2cControllerJsonArrayFromCsv(compare.missingTruthFieldsCsv)
    let mismatchesJson: str = r2cControllerTruthCompareMismatchesJson(compare)
    var compareDoc = "{\n"
    compareDoc = compareDoc + "  \"format\": \"truth_compare_v1\",\n"
    compareDoc = compareDoc + "  \"ok\": " + r2cControllerJsonBool(compare.ok) + ",\n"
    compareDoc = compareDoc + "  \"reason\": " + r2cControllerJsonQuote(compare.reason) + ",\n"
    compareDoc = compareDoc + "  \"truth_trace_path\": " + r2cControllerJsonQuote(truthTracePath) + ",\n"
    compareDoc = compareDoc + "  \"truth_trace_format\": " + r2cControllerJsonQuote(compare.truthTraceFormat) + ",\n"
    compareDoc = compareDoc + "  \"truth_state\": " + r2cControllerJsonQuote(compare.truthState) + ",\n"
    compareDoc = compareDoc + "  \"matched_snapshot_index\": " + intToStr(compare.matchedSnapshotIndex) + ",\n"
    compareDoc = compareDoc + "  \"exec_snapshot_path\": " + r2cControllerJsonQuote(execSnapshotPath) + ",\n"
    compareDoc = compareDoc + "  \"out_path\": " + r2cControllerJsonQuote(truthComparePath) + ",\n"
    compareDoc = compareDoc + "  \"exec_layout_surface_path\": " + r2cControllerJsonQuote(compare.execLayoutSurfacePath) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_count_compare_basis\": " + r2cControllerJsonQuote(compare.semanticNodeCountCompareBasis) + ",\n"
    compareDoc = compareDoc + "  \"exec_route_state\": " + r2cControllerJsonQuote(compare.execRouteState) + ",\n"
    compareDoc = compareDoc + "  \"exec_render_ready\": " + r2cControllerJsonBool(compare.execRenderReady) + ",\n"
    compareDoc = compareDoc + "  \"exec_semantic_nodes_loaded\": " + r2cControllerJsonBool(compare.execSemanticNodesLoaded) + ",\n"
    compareDoc = compareDoc + "  \"exec_snapshot_semantic_nodes_count\": " + intToStr(compare.execSnapshotSemanticNodesCount) + ",\n"
    compareDoc = compareDoc + "  \"exec_semantic_nodes_count\": " + intToStr(compare.execSemanticNodesCount) + ",\n"
    compareDoc = compareDoc + "  \"truth_semantic_nodes_path\": " + r2cControllerJsonQuote(compare.truthSemanticNodesPath) + ",\n"
    compareDoc = compareDoc + "  \"truth_route_state\": " + r2cControllerJsonQuote(compare.truthRouteState) + ",\n"
    compareDoc = compareDoc + "  \"truth_route_id\": " + r2cControllerJsonQuote(compare.truthRouteId) + ",\n"
    compareDoc = compareDoc + "  \"truth_render_ready\": " + r2cControllerJsonBool(compare.truthRenderReady) + ",\n"
    compareDoc = compareDoc + "  \"truth_semantic_nodes_loaded\": " + r2cControllerJsonBool(compare.truthSemanticNodesLoaded) + ",\n"
    compareDoc = compareDoc + "  \"truth_trace_semantic_nodes_count\": " + intToStr(compare.truthTraceSemanticNodesCount) + ",\n"
    compareDoc = compareDoc + "  \"truth_semantic_nodes_count\": " + intToStr(compare.truthSemanticNodesCount) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_diff_ready\": " + r2cControllerJsonBool(compare.semanticNodeDiffReady) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_diff_path\": " + r2cControllerJsonQuote(compare.semanticNodeDiffPath) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_diff_basis\": " + r2cControllerJsonQuote(compare.semanticNodeDiffBasis) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_diff_exec_node_count\": " + intToStr(compare.semanticNodeDiffExecNodeCount) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_diff_truth_node_count\": " + intToStr(compare.semanticNodeDiffTruthNodeCount) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_diff_shared_count\": " + intToStr(compare.semanticNodeDiffSharedCount) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_diff_exec_only_count\": " + intToStr(compare.semanticNodeDiffExecOnlyCount) + ",\n"
    compareDoc = compareDoc + "  \"semantic_node_diff_truth_only_count\": " + intToStr(compare.semanticNodeDiffTruthOnlyCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_summary_ready\": " + r2cControllerJsonBool(nativeGuiSummary.ready) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_summary_path\": " + r2cControllerJsonQuote(nativeGuiSummary.summaryPath) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_route_state\": " + r2cControllerJsonQuote(nativeGuiSummary.routeState) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_screenshot_path\": " + r2cControllerJsonQuote(nativeGuiSummary.screenshotPath) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_bundle_ready\": " + r2cControllerJsonBool(nativeGuiSummary.runtimeBundleReady) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_contract_ready\": " + r2cControllerJsonBool(nativeGuiSummary.runtimeContractReady) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_bundle_route_state\": " + r2cControllerJsonQuote(nativeGuiSummary.runtimeBundleRouteState) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_bundle_route_count\": " + intToStr(nativeGuiSummary.runtimeBundleRouteCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_bundle_supported_count\": " + intToStr(nativeGuiSummary.runtimeBundleSupportedCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_bundle_semantic_nodes_count\": " + intToStr(nativeGuiSummary.runtimeBundleSemanticNodesCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_bundle_layout_item_count\": " + intToStr(nativeGuiSummary.runtimeBundleLayoutItemCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_bundle_render_command_count\": " + intToStr(nativeGuiSummary.runtimeBundleRenderCommandCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_contract_layout_item_count\": " + intToStr(nativeGuiSummary.runtimeContractLayoutItemCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_contract_viewport_item_count\": " + intToStr(nativeGuiSummary.runtimeContractViewportItemCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_runtime_contract_interactive_item_count\": " + intToStr(nativeGuiSummary.runtimeContractInteractiveItemCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_native_layout_plan_item_count\": " + intToStr(nativeGuiSummary.nativeLayoutPlanItemCount) + ",\n"
    compareDoc = compareDoc + "  \"native_gui_render_plan_command_count\": " + intToStr(nativeGuiSummary.renderPlanCommandCount) + ",\n"
    compareDoc = compareDoc + "  \"missing_truth_fields\": " + missingTruthFieldsJson + ",\n"
    compareDoc = compareDoc + "  \"mismatches\": " + mismatchesJson + "\n"
    compareDoc = compareDoc + "}\n"
    if !v3path.V3WriteTextFile("", truthComparePath, compareDoc):
        return false
    var summaryText = ""
    summaryText = summaryText + "truth_compare_ok=" + r2cControllerJsonBool(compare.ok) + "\n"
    summaryText = summaryText + "truth_compare_reason=" + compare.reason + "\n"
    summaryText = summaryText + "truth_compare_path=" + truthComparePath + "\n"
    summaryText = summaryText + "truth_state=" + compare.truthState + "\n"
    summaryText = summaryText + "matched_snapshot_index=" + intToStr(compare.matchedSnapshotIndex) + "\n"
    summaryText = summaryText + "mismatch_count=" + intToStr(compare.mismatchCount) + "\n"
    summaryText = summaryText + "missing_truth_fields_count=" + intToStr(compare.missingTruthFieldsCount) + "\n"
    summaryText = summaryText + "semantic_node_count_compare_basis=" + compare.semanticNodeCountCompareBasis + "\n"
    summaryText = summaryText + "exec_snapshot_semantic_nodes_count=" + intToStr(compare.execSnapshotSemanticNodesCount) + "\n"
    summaryText = summaryText + "exec_semantic_nodes_count=" + intToStr(compare.execSemanticNodesCount) + "\n"
    summaryText = summaryText + "truth_trace_semantic_nodes_count=" + intToStr(compare.truthTraceSemanticNodesCount) + "\n"
    summaryText = summaryText + "truth_semantic_nodes_count=" + intToStr(compare.truthSemanticNodesCount) + "\n"
    summaryText = summaryText + "exec_layout_surface_path=" + compare.execLayoutSurfacePath + "\n"
    summaryText = summaryText + "truth_semantic_nodes_path=" + compare.truthSemanticNodesPath + "\n"
    summaryText = summaryText + "semantic_node_diff_ready=" + r2cControllerJsonBool(compare.semanticNodeDiffReady) + "\n"
    summaryText = summaryText + "semantic_node_diff_path=" + compare.semanticNodeDiffPath + "\n"
    summaryText = summaryText + "semantic_node_diff_basis=" + compare.semanticNodeDiffBasis + "\n"
    summaryText = summaryText + "semantic_node_diff_exec_node_count=" + intToStr(compare.semanticNodeDiffExecNodeCount) + "\n"
    summaryText = summaryText + "semantic_node_diff_truth_node_count=" + intToStr(compare.semanticNodeDiffTruthNodeCount) + "\n"
    summaryText = summaryText + "semantic_node_diff_shared_count=" + intToStr(compare.semanticNodeDiffSharedCount) + "\n"
    summaryText = summaryText + "semantic_node_diff_exec_only_count=" + intToStr(compare.semanticNodeDiffExecOnlyCount) + "\n"
    summaryText = summaryText + "semantic_node_diff_truth_only_count=" + intToStr(compare.semanticNodeDiffTruthOnlyCount) + "\n"
    summaryText = summaryText + "native_gui_summary_ready=" + r2cControllerJsonBool(nativeGuiSummary.ready) + "\n"
    summaryText = summaryText + "native_gui_summary_path=" + nativeGuiSummary.summaryPath + "\n"
    summaryText = summaryText + "native_gui_route_state=" + nativeGuiSummary.routeState + "\n"
    summaryText = summaryText + "native_gui_screenshot_path=" + nativeGuiSummary.screenshotPath + "\n"
    summaryText = summaryText + "native_gui_runtime_bundle_ready=" + r2cControllerJsonBool(nativeGuiSummary.runtimeBundleReady) + "\n"
    summaryText = summaryText + "native_gui_runtime_contract_ready=" + r2cControllerJsonBool(nativeGuiSummary.runtimeContractReady) + "\n"
    summaryText = summaryText + "native_gui_runtime_bundle_route_state=" + nativeGuiSummary.runtimeBundleRouteState + "\n"
    summaryText = summaryText + "native_gui_runtime_bundle_route_count=" + intToStr(nativeGuiSummary.runtimeBundleRouteCount) + "\n"
    summaryText = summaryText + "native_gui_runtime_bundle_supported_count=" + intToStr(nativeGuiSummary.runtimeBundleSupportedCount) + "\n"
    summaryText = summaryText + "native_gui_runtime_bundle_semantic_nodes_count=" + intToStr(nativeGuiSummary.runtimeBundleSemanticNodesCount) + "\n"
    summaryText = summaryText + "native_gui_runtime_bundle_layout_item_count=" + intToStr(nativeGuiSummary.runtimeBundleLayoutItemCount) + "\n"
    summaryText = summaryText + "native_gui_runtime_bundle_render_command_count=" + intToStr(nativeGuiSummary.runtimeBundleRenderCommandCount) + "\n"
    summaryText = summaryText + "native_gui_runtime_contract_layout_item_count=" + intToStr(nativeGuiSummary.runtimeContractLayoutItemCount) + "\n"
    summaryText = summaryText + "native_gui_runtime_contract_viewport_item_count=" + intToStr(nativeGuiSummary.runtimeContractViewportItemCount) + "\n"
    summaryText = summaryText + "native_gui_runtime_contract_interactive_item_count=" + intToStr(nativeGuiSummary.runtimeContractInteractiveItemCount) + "\n"
    summaryText = summaryText + "native_gui_native_layout_plan_item_count=" + intToStr(nativeGuiSummary.nativeLayoutPlanItemCount) + "\n"
    summaryText = summaryText + "native_gui_render_plan_command_count=" + intToStr(nativeGuiSummary.renderPlanCommandCount) + "\n"
    return v3path.V3WriteTextFile("", summaryPath, summaryText)

fn r2cControllerWriteCompareTruthDirect(execSnapshotPath: str,
                                        truthTracePath: str,
                                        truthState: str,
                                        truthComparePath: str,
                                        summaryPath: str,
                                        nativeGuiSummaryPath: str): bool =
    if !v3path.V3PathFileExists(execSnapshotPath) || !v3path.V3PathFileExists(truthTracePath):
        r2cControllerPrintErr("r2c-react: compare-truth direct missing input")
        return false
    let execSnapshotText: str = v3path.V3ReadTextFile("", execSnapshotPath)
    let truthDocText: str = v3path.V3ReadTextFile("", truthTracePath)
    let formatStart: int32 = r2cControllerJsonFindValueStart(truthDocText, "format", 0)
    let snapshotsStart: int32 = r2cControllerJsonFindValueStart(truthDocText, "snapshots", 0)
    let truthTraceFormat: str = r2cControllerJsonReadStringField(truthDocText, "format", "")
    let snapshotsRaw: str = r2cControllerJsonReadArrayFieldRaw(truthDocText, "snapshots", "")
    var nativeGuiSummary: R2cTruthCompareNativeGuiSummary
    if !r2cControllerLoadTruthCompareNativeGuiSummary(nativeGuiSummaryPath, nativeGuiSummary):
        r2cControllerPrintErr("r2c-react: compare-truth missing native gui summary: " + nativeGuiSummaryPath)
        return false
    var compare: R2cTruthCompareEval
    if !r2cControllerEvaluateTruthCompare(execSnapshotText, truthDocText, truthState, compare):
        r2cControllerPrintErr("r2c-react: compare-truth eval rejected truth_bytes=" + intToStr(strings.Len(truthDocText)) + " format_start=" + intToStr(formatStart) + " snapshots_start=" + intToStr(snapshotsStart) + " trace format=" + truthTraceFormat + " snapshots_bytes=" + intToStr(strings.Len(snapshotsRaw)))
        return false
    if strings.Len(compare.truthSemanticNodesPath) <= 0:
        var inferredTruthState: str = truthState
        if strings.Len(inferredTruthState) <= 0:
            inferredTruthState = compare.execRouteState
        let inferredTruthSemanticNodesPath: str = os.JoinPath(v3path.V3PathParentDir(truthTracePath),
                                                              inferredTruthState + ".semantic_dom_nodes_v1.json")
        if v3path.V3PathFileExists(inferredTruthSemanticNodesPath):
            compare.truthSemanticNodesPath = inferredTruthSemanticNodesPath
    let semanticNodeDiffPath: str = os.JoinPath(v3path.V3PathParentDir(truthComparePath), "semantic_node_diff_v1.json")
    if !r2cControllerWriteSemanticNodeDiff(execSnapshotPath,
                                           compare.truthSemanticNodesPath,
                                           semanticNodeDiffPath,
                                           compare):
        r2cControllerPrintErr("r2c-react: compare-truth semantic diff failed")
        return false
    if compare.semanticNodeDiffReady:
        compare.semanticNodeCountCompareBasis = compare.semanticNodeDiffBasis
        compare.execSemanticNodesCount = compare.semanticNodeDiffExecNodeCount
        compare.truthSemanticNodesCount = compare.semanticNodeDiffTruthNodeCount
        r2cControllerRefreshSemanticNodeCompareStatus(compare)
    if !r2cControllerWriteTruthCompareArtifacts(truthComparePath,
                                                summaryPath,
                                                execSnapshotPath,
                                                truthTracePath,
                                                compare,
                                                nativeGuiSummary):
        r2cControllerPrintErr("r2c-react: compare-truth write artifacts failed")
        return false
    return true

fn r2cControllerTruthCompareMatrixReason(unsupportedCount: int32,
                                         mismatchCount: int32,
                                         missingTruthStateCount: int32,
                                         missingTruthFieldCount: int32): str =
    if unsupportedCount > 0:
        return "unsupported_exec_routes"
    if missingTruthStateCount > 0:
        return "missing_truth_states"
    if missingTruthFieldCount > 0:
        return "missing_truth_fields"
    if mismatchCount > 0:
        return "mismatch"
    return "ok"

fn r2cControllerWriteTruthCompareMatrixArtifacts(execRouteMatrixPath: str,
                                                 truthTracePath: str,
                                                 truthCompareMatrixPath: str,
                                                 summaryPath: str): bool =
    if !v3path.V3PathFileExists(execRouteMatrixPath) || !v3path.V3PathFileExists(truthTracePath):
        r2cControllerPrintErr("r2c-react: compare-truth-matrix direct missing input")
        return false
    let execRouteMatrixText: str = v3path.V3ReadTextFile("", execRouteMatrixPath)
    let truthDocText: str = v3path.V3ReadTextFile("", truthTracePath)
    let truthTraceFormat: str = r2cControllerJsonReadStringField(truthDocText, "format", "")
    if truthTraceFormat != "truth_trace_v2" && truthTraceFormat != "r2c-truth-trace-v1":
        r2cControllerPrintErr("r2c-react: compare-truth-matrix unsupported trace format: " + truthTraceFormat)
        return false
    if strings.Len(r2cControllerJsonReadArrayFieldRaw(truthDocText, "snapshots", "")) <= 0:
        r2cControllerPrintErr("r2c-react: compare-truth-matrix missing snapshots[]")
        return false
    let entriesRaw: str = r2cControllerJsonReadArrayFieldRaw(execRouteMatrixText, "entries", "")
    if strings.Len(entriesRaw) <= 0:
        r2cControllerPrintErr("r2c-react: compare-truth-matrix missing entries[]")
        return false
    var entriesJson = "["
    var wroteEntry = false
    var routeCount: int32
    var okCount: int32
    var unsupportedCount: int32
    var mismatchCount: int32
    var missingTruthStateCount: int32
    var missingTruthFieldCount: int32
    var entryRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(entriesRaw, cursor, entryRaw, nextPos):
        cursor = nextPos
        routeCount = routeCount + 1
        let routeId: str = r2cControllerJsonReadStringField(entryRaw, "routeId", "")
        let supported: bool = r2cControllerJsonReadBoolField(entryRaw, "supported", false)
        let snapshotPath: str = r2cControllerJsonReadStringField(entryRaw, "snapshotPath", "")
        let execReason: str = r2cControllerJsonReadStringField(entryRaw, "reason", "")
        let snapshotRaw: str = r2cControllerJsonReadObjectFieldRaw(entryRaw, "snapshot", "{}")
        let execRouteState: str = r2cControllerJsonReadStringField(snapshotRaw, "route_state", "")
        let execSemanticNodesCount: int32 = r2cControllerJsonReadIntField(snapshotRaw, "semantic_nodes_count", 0)
        var entryOk = false
        var entryReason = execReason
        var matchedSnapshotIndex: int32 = -1
        var truthRouteState = ""
        var truthSemanticNodesCount: int32
        var missingTruthFieldsCsv = ""
        var mismatchesJson = "[]"
        if !supported:
            unsupportedCount = unsupportedCount + 1
            if strings.Len(entryReason) <= 0:
                entryReason = "unsupported_exec_route"
        else:
            var compare: R2cTruthCompareEval
            if !r2cControllerEvaluateTruthCompare(snapshotRaw, truthDocText, routeId, compare):
                r2cControllerPrintErr("r2c-react: compare-truth-matrix eval failed for route: " + routeId)
                return false
            entryOk = compare.ok
            entryReason = compare.reason
            matchedSnapshotIndex = compare.matchedSnapshotIndex
            truthRouteState = compare.truthRouteState
            truthSemanticNodesCount = compare.truthSemanticNodesCount
            missingTruthFieldsCsv = compare.missingTruthFieldsCsv
            mismatchesJson = r2cControllerTruthCompareMismatchesJson(compare)
            execSemanticNodesCount = compare.execSemanticNodesCount
            if compare.ok:
                okCount = okCount + 1
            elif compare.reason == "missing_truth_state":
                missingTruthStateCount = missingTruthStateCount + 1
            elif compare.reason == "missing_truth_fields":
                missingTruthFieldCount = missingTruthFieldCount + 1
            elif compare.reason == "mismatch":
                mismatchCount = mismatchCount + 1
        if wroteEntry:
            entriesJson = entriesJson + ",\n"
        entriesJson = entriesJson + "    {\n"
        entriesJson = entriesJson + "      \"routeId\": " + r2cControllerJsonQuote(routeId) + ",\n"
        entriesJson = entriesJson + "      \"supported\": " + r2cControllerJsonBool(supported) + ",\n"
        entriesJson = entriesJson + "      \"ok\": " + r2cControllerJsonBool(entryOk) + ",\n"
        entriesJson = entriesJson + "      \"reason\": " + r2cControllerJsonQuote(entryReason) + ",\n"
        entriesJson = entriesJson + "      \"matchedSnapshotIndex\": " + intToStr(matchedSnapshotIndex) + ",\n"
        entriesJson = entriesJson + "      \"snapshotPath\": " + r2cControllerJsonQuote(snapshotPath) + ",\n"
        entriesJson = entriesJson + "      \"execRouteState\": " + r2cControllerJsonQuote(execRouteState) + ",\n"
        entriesJson = entriesJson + "      \"truthRouteState\": " + r2cControllerJsonQuote(truthRouteState) + ",\n"
        entriesJson = entriesJson + "      \"execSemanticNodesCount\": " + intToStr(execSemanticNodesCount) + ",\n"
        entriesJson = entriesJson + "      \"truthSemanticNodesCount\": " + intToStr(truthSemanticNodesCount) + ",\n"
        entriesJson = entriesJson + "      \"missingTruthFields\": " + r2cControllerJsonArrayFromCsv(missingTruthFieldsCsv) + ",\n"
        entriesJson = entriesJson + "      \"mismatches\": " + mismatchesJson + "\n"
        entriesJson = entriesJson + "    }"
        wroteEntry = true
    entriesJson = entriesJson + "\n  ]"
    let finalOk: bool = unsupportedCount == 0 &&
                        mismatchCount == 0 &&
                        missingTruthStateCount == 0 &&
                        missingTruthFieldCount == 0
    let finalReason: str = r2cControllerTruthCompareMatrixReason(unsupportedCount,
                                                                 mismatchCount,
                                                                 missingTruthStateCount,
                                                                 missingTruthFieldCount)
    var matrixDoc = "{\n"
    matrixDoc = matrixDoc + "  \"format\": \"truth_compare_matrix_v1\",\n"
    matrixDoc = matrixDoc + "  \"ok\": " + r2cControllerJsonBool(finalOk) + ",\n"
    matrixDoc = matrixDoc + "  \"reason\": " + r2cControllerJsonQuote(finalReason) + ",\n"
    matrixDoc = matrixDoc + "  \"truthTracePath\": " + r2cControllerJsonQuote(truthTracePath) + ",\n"
    matrixDoc = matrixDoc + "  \"truthTraceFormat\": " + r2cControllerJsonQuote(truthTraceFormat) + ",\n"
    matrixDoc = matrixDoc + "  \"routeCount\": " + intToStr(routeCount) + ",\n"
    matrixDoc = matrixDoc + "  \"okCount\": " + intToStr(okCount) + ",\n"
    matrixDoc = matrixDoc + "  \"unsupportedCount\": " + intToStr(unsupportedCount) + ",\n"
    matrixDoc = matrixDoc + "  \"mismatchCount\": " + intToStr(mismatchCount) + ",\n"
    matrixDoc = matrixDoc + "  \"missingTruthStateCount\": " + intToStr(missingTruthStateCount) + ",\n"
    matrixDoc = matrixDoc + "  \"missingTruthFieldCount\": " + intToStr(missingTruthFieldCount) + ",\n"
    matrixDoc = matrixDoc + "  \"entries\": " + entriesJson + ",\n"
    matrixDoc = matrixDoc + "  \"outPath\": " + r2cControllerJsonQuote(truthCompareMatrixPath) + "\n"
    matrixDoc = matrixDoc + "}\n"
    if !v3path.V3WriteTextFile("", truthCompareMatrixPath, matrixDoc):
        r2cControllerPrintErr("r2c-react: compare-truth-matrix write json failed")
        return false
    var summaryText = ""
    summaryText = summaryText + "truth_compare_matrix_ok=" + r2cControllerJsonBool(finalOk) + "\n"
    summaryText = summaryText + "truth_compare_matrix_reason=" + finalReason + "\n"
    summaryText = summaryText + "truth_compare_matrix_path=" + truthCompareMatrixPath + "\n"
    summaryText = summaryText + "route_count=" + intToStr(routeCount) + "\n"
    summaryText = summaryText + "ok_count=" + intToStr(okCount) + "\n"
    summaryText = summaryText + "unsupported_count=" + intToStr(unsupportedCount) + "\n"
    summaryText = summaryText + "mismatch_count=" + intToStr(mismatchCount) + "\n"
    summaryText = summaryText + "missing_truth_state_count=" + intToStr(missingTruthStateCount) + "\n"
    summaryText = summaryText + "missing_truth_field_count=" + intToStr(missingTruthFieldCount) + "\n"
    if !v3path.V3WriteTextFile("", summaryPath, summaryText):
        r2cControllerPrintErr("r2c-react: compare-truth-matrix write summary failed")
        return false
    return true

fn r2cControllerJsonCountStringArrayItems(arrayText: str): int32 =
    let total: int32 = strings.Len(arrayText)
    if total <= 0:
        return 0
    var count: int32
    var pos: int32
    var inString = false
    var escaped = false
    while pos < total:
        let ch = arrayText[pos]
        if inString:
            if escaped:
                escaped = false
            elif ch == char(92):
                escaped = true
            elif ch == char(34):
                inString = false
        else:
            if ch == char(34):
                inString = true
                count = count + 1
        pos = pos + 1
    return count

fn r2cControllerJsonArrayFromCsv(csvText: str): str =
    let total: int32 = strings.Len(csvText)
    if total <= 0:
        return "[]"
    var out = "["
    var wrote = false
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif csvText[i] == ',':
            endHit = true
        if !endHit:
            continue
        let itemLen: int32 = i - start
        if itemLen > 0:
            let item: str = r2cControllerSlice(csvText, start, itemLen)
            if wrote:
                out = out + ", "
            out = out + r2cControllerJsonQuote(item)
            wrote = true
        start = i + 1
    out = out + "]"
    return out

fn r2cControllerSummaryAppendLine(summaryText: var str,
                                  key: str,
                                  value: str) =
    summaryText = summaryText + key + "=" + value + "\n"

fn r2cControllerLoggedCommandMetadata(label: str,
                                      filePath: str,
                                      argv: str[],
                                      exitCode: int32,
                                      output: str): str =
    var text = ""
    text = text + "label=" + label + "\n"
    text = text + "file=" + filePath + "\n"
    text = text + "exit=" + intToStr(exitCode) + "\n"
    for i in 0..<argv.len:
        text = text + "arg_" + intToStr(i) + "=" + argv[i] + "\n"
    let outputText: str = r2cControllerEnsureTrailingNewline(output)
    if strings.Len(outputText) > 0:
        text = text + outputText
    return text

fn r2cControllerJsonScopeOrSelf(docText: str,
                                objectKey: str): str =
    if strings.Len(objectKey) <= 0:
        return docText
    return r2cControllerJsonReadObjectFieldRaw(docText, objectKey, "")

fn r2cControllerSummaryValueOrDocString(summaryPath: str,
                                        key: str,
                                        docText: str,
                                        objectKey: str,
                                        fieldKey: str,
                                        fallback: str): str =
    let summaryValue: str = r2cControllerReadSummaryValue(summaryPath, key, "")
    if strings.Len(summaryValue) > 0:
        return summaryValue
    let scopeText: str = r2cControllerJsonScopeOrSelf(docText, objectKey)
    if strings.Len(scopeText) > 0:
        if r2cControllerJsonHasField(scopeText, fieldKey):
            return r2cControllerJsonReadStringField(scopeText, fieldKey, "")
    return fallback

fn r2cControllerSummaryValueOrDocBoolText(summaryPath: str,
                                          key: str,
                                          docText: str,
                                          objectKey: str,
                                          fieldKey: str,
                                          fallbackText: str): str =
    let summaryValue: str = r2cControllerReadSummaryValue(summaryPath, key, "")
    if summaryValue == "true" || summaryValue == "false":
        return summaryValue
    let scopeText: str = r2cControllerJsonScopeOrSelf(docText, objectKey)
    if strings.Len(scopeText) > 0:
        if r2cControllerJsonHasField(scopeText, fieldKey):
            return r2cControllerJsonBool(r2cControllerJsonReadBoolField(scopeText, fieldKey, false))
    return fallbackText

fn r2cControllerSummaryValueOrDocIntText(summaryPath: str,
                                         key: str,
                                         docText: str,
                                         objectKey: str,
                                         fieldKey: str,
                                         fallbackText: str): str =
    let summaryValue: str = r2cControllerReadSummaryValue(summaryPath, key, "")
    if strings.Len(summaryValue) > 0:
        return summaryValue
    let scopeText: str = r2cControllerJsonScopeOrSelf(docText, objectKey)
    if strings.Len(scopeText) > 0:
        if r2cControllerJsonHasField(scopeText, fieldKey):
            return intToStr(r2cControllerJsonReadIntField(scopeText, fieldKey, 0))
    return fallbackText

fn r2cControllerJsonFindObjectByStringField(arrayText: str,
                                            fieldKey: str,
                                            targetValue: str,
                                            itemRaw: var str): bool =
    itemRaw = ""
    if strings.Len(targetValue) <= 0:
        return false
    var cursor: int32
    var nextCursor: int32
    var candidateRaw: str
    while r2cControllerJsonArrayNextObjectRaw(arrayText, cursor, candidateRaw, nextCursor):
        let candidateValue: str = r2cControllerJsonReadStringField(candidateRaw, fieldKey, "")
        if candidateValue == targetValue:
            itemRaw = candidateRaw
            return true
        cursor = nextCursor
    return false

fn r2cControllerJsonRawOrNull(raw: str): str =
    if strings.Len(raw) <= 0:
        return "null"
    return raw

fn r2cControllerRunNativeGuiResolvedTargetPath(repoRoot: str,
                                               hitSourceModulePath: str,
                                               sourceJumpTargetPath: str): str =
    if strings.Len(sourceJumpTargetPath) > 0:
        return sourceJumpTargetPath
    if strings.Len(repoRoot) > 0 && strings.Len(hitSourceModulePath) > 0:
        return v3path.V3PathAbsolute(repoRoot, hitSourceModulePath)
    return ""

fn r2cControllerRunNativeGuiResolvedTargetLine(hitSourceLineText: str,
                                               sourceJumpTargetLineText: str): int32 =
    var targetLine: int32 = r2cControllerParseInt32(sourceJumpTargetLineText)
    if targetLine > 0:
        return targetLine
    targetLine = r2cControllerParseInt32(hitSourceLineText)
    if targetLine > 0:
        return targetLine
    return 1

fn r2cControllerWriteNativeGuiRunHitInspector(summaryPath: str,
                                              sessionPath: str,
                                              outPath: str,
                                              readyOut: var bool): bool =
    readyOut = false
    if !v3path.V3PathFileExists(sessionPath):
        r2cControllerPrintErr("r2c-react: native gui hit inspector missing session: " + sessionPath)
        return false
    let sessionText: str = v3path.V3ReadTextFile("", sessionPath)
    let nativeLayoutPlanText: str = r2cControllerJsonReadObjectFieldRaw(sessionText, "native_layout_plan", "")
    let layoutSurfaceText: str = r2cControllerJsonReadObjectFieldRaw(sessionText, "layout_surface", "")
    let styleLayoutSurfaceText: str = r2cControllerJsonReadObjectFieldRaw(sessionText, "style_layout_surface", "")
    let layoutItemsText: str = r2cControllerJsonReadArrayFieldRaw(nativeLayoutPlanText, "items", "[]")
    let layoutNodesText: str = r2cControllerJsonReadArrayFieldRaw(layoutSurfaceText, "nodes", "[]")
    let styleNodesText: str = r2cControllerJsonReadArrayFieldRaw(styleLayoutSurfaceText, "nodes", "[]")
    let hitItemId: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_item_id", "")
    let hitSourceNodeIdSummary: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_source_node_id", "")
    var layoutItemRaw: str
    let layoutItemFound: bool = r2cControllerJsonFindObjectByStringField(layoutItemsText, "id", hitItemId, layoutItemRaw)
    var sourceNodeId: str = hitSourceNodeIdSummary
    if strings.Len(sourceNodeId) <= 0 && layoutItemFound:
        sourceNodeId = r2cControllerJsonReadStringField(layoutItemRaw, "source_node_id", "")
    var sourceNodeRaw: str
    let sourceNodeFound: bool = r2cControllerJsonFindObjectByStringField(layoutNodesText, "id", sourceNodeId, sourceNodeRaw)
    sourceNodeFound
    var styleNodeRaw: str
    let styleNodeFound: bool = r2cControllerJsonFindObjectByStringField(styleNodesText, "node_id", sourceNodeId, styleNodeRaw)
    styleNodeFound
    var reason: str = "ok"
    if strings.Len(hitItemId) <= 0:
        reason = "no_hit_item"
    elif !layoutItemFound:
        reason = "layout_item_missing"
    readyOut = layoutItemFound
    let scrollOffsetYText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_scroll_offset_y", "")
    let lastClickXText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_last_click_x", "")
    let lastClickYText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_last_click_y", "")
    let hitSourceLineText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_source_line", "0")
    let hitItemInteractiveText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_item_interactive", "")
    let sourceJumpEnabledText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_enabled", "")
    let sourceJumpAttemptedText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_attempted", "")
    let sourceJumpOkText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_ok", "")
    let sourceJumpTargetPath: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_target_path", "")
    let sourceJumpTargetLineText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_target_line", "0")
    let sourceJumpCommand: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_command", "")
    let sourceJumpError: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_error", "")
    var doc = "{\n"
    doc = doc + "  \"format\": \"native_gui_hit_inspector_v1\",\n"
    doc = doc + "  \"ready\": " + r2cControllerJsonBool(readyOut) + ",\n"
    doc = doc + "  \"reason\": " + r2cControllerJsonQuote(reason) + ",\n"
    doc = doc + "  \"route_state\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_route_state", "")) + ",\n"
    doc = doc + "  \"entry_module\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_entry_module", "")) + ",\n"
    doc = doc + "  \"native_layout_plan_policy_source\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_native_layout_plan_policy_source", "")) + ",\n"
    if strings.Len(scrollOffsetYText) > 0:
        doc = doc + "  \"scroll_offset_y\": " + scrollOffsetYText + ",\n"
    else:
        doc = doc + "  \"scroll_offset_y\": null,\n"
    doc = doc + "  \"click_count\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_click_count", "0") + ",\n"
    if strings.Len(lastClickXText) > 0:
        doc = doc + "  \"last_click_x\": " + lastClickXText + ",\n"
    else:
        doc = doc + "  \"last_click_x\": null,\n"
    if strings.Len(lastClickYText) > 0:
        doc = doc + "  \"last_click_y\": " + lastClickYText + ",\n"
    else:
        doc = doc + "  \"last_click_y\": null,\n"
    doc = doc + "  \"hit_item_id\": " + r2cControllerJsonQuote(hitItemId) + ",\n"
    doc = doc + "  \"hit_source_node_id\": " + r2cControllerJsonQuote(sourceNodeId) + ",\n"
    doc = doc + "  \"hit_source_module_path\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_source_module_path", "")) + ",\n"
    doc = doc + "  \"hit_source_component_name\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_source_component_name", "")) + ",\n"
    doc = doc + "  \"hit_source_line\": " + r2cControllerJsonIntTextOrNull(hitSourceLineText) + ",\n"
    doc = doc + "  \"hit_item_interactive\": " + r2cControllerJsonBoolTextOrFalse(hitItemInteractiveText) + ",\n"
    doc = doc + "  \"source_jump\": {\n"
    doc = doc + "    \"enabled\": " + r2cControllerJsonBoolTextOrFalse(sourceJumpEnabledText) + ",\n"
    doc = doc + "    \"attempted\": " + r2cControllerJsonBoolTextOrFalse(sourceJumpAttemptedText) + ",\n"
    doc = doc + "    \"ok\": " + r2cControllerJsonBoolTextOrFalse(sourceJumpOkText) + ",\n"
    doc = doc + "    \"target_path\": " + r2cControllerJsonQuote(sourceJumpTargetPath) + ",\n"
    doc = doc + "    \"target_line\": " + r2cControllerJsonIntTextOrNull(sourceJumpTargetLineText) + ",\n"
    doc = doc + "    \"command\": " + r2cControllerJsonQuote(sourceJumpCommand) + ",\n"
    doc = doc + "    \"error\": " + r2cControllerJsonQuote(sourceJumpError) + "\n"
    doc = doc + "  },\n"
    doc = doc + "  \"layout_item\": " + r2cControllerJsonRawOrNull(layoutItemRaw) + ",\n"
    doc = doc + "  \"source_node\": " + r2cControllerJsonRawOrNull(sourceNodeRaw) + ",\n"
    doc = doc + "  \"style_node\": " + r2cControllerJsonRawOrNull(styleNodeRaw) + "\n"
    doc = doc + "}\n"
    if !v3path.V3WriteTextFile("", outPath, doc):
        r2cControllerPrintErr("r2c-react: native gui hit inspector write failed: " + outPath)
        return false
    return true

fn r2cControllerWriteNativeGuiRunInspectorState(repoRoot: str,
                                                bundlePath: str,
                                                sessionPath: str,
                                                screenshotPath: str,
                                                summaryPath: str,
                                                hitInspectorPath: str,
                                                outPath: str,
                                                readyOut: var bool): bool =
    readyOut = false
    if !v3path.V3PathFileExists(sessionPath):
        r2cControllerPrintErr("r2c-react: native gui inspector state missing session: " + sessionPath)
        return false
    let sessionText: str = v3path.V3ReadTextFile("", sessionPath)
    let sessionPreviewMode: str = r2cControllerJsonReadStringField(sessionText, "preview_mode", "")
    let inspectorReadyText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_inspector_ready", "")
    let hitInspectorReadyText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_inspector_ready", "")
    readyOut = inspectorReadyText == "true"
    var reason: str = "hit_missing"
    if readyOut:
        reason = "ok"
    elif hitInspectorReadyText == "true":
        reason = "panel_missing"
    let hitSourceModulePath: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_source_module_path", "")
    let hitSourceLineText: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_source_line", "0")
    let sourceJumpTargetPathRaw: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_target_path", "")
    let sourceJumpTargetLineTextRaw: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_target_line", "0")
    let resolvedTargetPath: str = r2cControllerRunNativeGuiResolvedTargetPath(repoRoot, hitSourceModulePath, sourceJumpTargetPathRaw)
    let resolvedTargetLine: int32 = r2cControllerRunNativeGuiResolvedTargetLine(hitSourceLineText, sourceJumpTargetLineTextRaw)
    let panelLinesJson: str = r2cControllerReadSummaryValue(summaryPath, "native_gui_inspector_lines_json", "[]")
    var hitInspectorJson: str = "null"
    if v3path.V3PathFileExists(hitInspectorPath):
        hitInspectorJson = r2cControllerEnsureTrailingNewline(v3path.V3ReadTextFile("", hitInspectorPath))
        hitInspectorJson = strutil.Strip(hitInspectorJson)
        if strings.Len(hitInspectorJson) <= 0:
            hitInspectorJson = "null"
    var doc = "{\n"
    doc = doc + "  \"format\": \"native_gui_inspector_state_v1\",\n"
    doc = doc + "  \"ready\": " + r2cControllerJsonBool(readyOut) + ",\n"
    doc = doc + "  \"reason\": " + r2cControllerJsonQuote(reason) + ",\n"
    doc = doc + "  \"repo_root\": " + r2cControllerJsonQuote(repoRoot) + ",\n"
    doc = doc + "  \"bundle_path\": " + r2cControllerJsonQuote(bundlePath) + ",\n"
    doc = doc + "  \"session_path\": " + r2cControllerJsonQuote(sessionPath) + ",\n"
    doc = doc + "  \"screenshot_path\": " + r2cControllerJsonQuote(screenshotPath) + ",\n"
    doc = doc + "  \"hit_inspector_path\": " + r2cControllerJsonQuote(hitInspectorPath) + ",\n"
    doc = doc + "  \"window\": {\n"
    doc = doc + "    \"title\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_window_title", "")) + ",\n"
    doc = doc + "    \"width\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_window_width", "0") + ",\n"
    doc = doc + "    \"height\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_window_height", "0") + ",\n"
    doc = doc + "    \"route_state\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_route_state", "")) + ",\n"
    doc = doc + "    \"entry_module\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_entry_module", "")) + ",\n"
    if strings.Len(r2cControllerReadSummaryValue(summaryPath, "native_gui_scroll_offset_y", "")) > 0:
        doc = doc + "    \"scroll_offset_y\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_scroll_offset_y", "") + ",\n"
    else:
        doc = doc + "    \"scroll_offset_y\": null,\n"
    doc = doc + "    \"click_count\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_click_count", "0") + ",\n"
    doc = doc + "    \"resize_count\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_resize_count", "0") + ",\n"
    doc = doc + "    \"scroll_count\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_scroll_count", "0") + ",\n"
    if strings.Len(r2cControllerReadSummaryValue(summaryPath, "native_gui_last_click_x", "")) > 0:
        doc = doc + "    \"last_click_x\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_last_click_x", "") + ",\n"
    else:
        doc = doc + "    \"last_click_x\": null,\n"
    if strings.Len(r2cControllerReadSummaryValue(summaryPath, "native_gui_last_click_y", "")) > 0:
        doc = doc + "    \"last_click_y\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_last_click_y", "") + "\n"
    else:
        doc = doc + "    \"last_click_y\": null\n"
    doc = doc + "  },\n"
    doc = doc + "  \"hit\": {\n"
    doc = doc + "    \"item_id\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_item_id", "")) + ",\n"
    doc = doc + "    \"source_node_id\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_source_node_id", "")) + ",\n"
    doc = doc + "    \"source_module_path\": " + r2cControllerJsonQuote(hitSourceModulePath) + ",\n"
    doc = doc + "    \"source_component_name\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_source_component_name", "")) + ",\n"
    doc = doc + "    \"source_line\": " + r2cControllerJsonIntTextOrNull(hitSourceLineText) + ",\n"
    doc = doc + "    \"item_interactive\": " + r2cControllerJsonBoolTextOrFalse(r2cControllerReadSummaryValue(summaryPath, "native_gui_hit_item_interactive", "")) + "\n"
    doc = doc + "  },\n"
    doc = doc + "  \"panel\": {\n"
    doc = doc + "    \"ready\": " + r2cControllerJsonBoolTextOrFalse(inspectorReadyText) + ",\n"
    doc = doc + "    \"title\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_inspector_title", "")) + ",\n"
    doc = doc + "    \"frame\": {\n"
    doc = doc + "      \"x\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_inspector_panel_x", "0") + ",\n"
    doc = doc + "      \"y\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_inspector_panel_y", "0") + ",\n"
    doc = doc + "      \"width\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_inspector_panel_width", "0") + ",\n"
    doc = doc + "      \"height\": " + r2cControllerReadSummaryValue(summaryPath, "native_gui_inspector_panel_height", "0") + "\n"
    doc = doc + "    },\n"
    doc = doc + "    \"lines\": " + panelLinesJson + "\n"
    doc = doc + "  },\n"
    doc = doc + "  \"source_jump\": {\n"
    doc = doc + "    \"enabled\": " + r2cControllerJsonBoolTextOrFalse(r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_enabled", "")) + ",\n"
    doc = doc + "    \"attempted\": " + r2cControllerJsonBoolTextOrFalse(r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_attempted", "")) + ",\n"
    doc = doc + "    \"ok\": " + r2cControllerJsonBoolTextOrFalse(r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_ok", "")) + ",\n"
    doc = doc + "    \"target_path\": " + r2cControllerJsonQuote(resolvedTargetPath) + ",\n"
    doc = doc + "    \"target_line\": " + intToStr(resolvedTargetLine) + ",\n"
    doc = doc + "    \"command\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_command", "")) + ",\n"
    doc = doc + "    \"error\": " + r2cControllerJsonQuote(r2cControllerReadSummaryValue(summaryPath, "native_gui_source_jump_error", "")) + "\n"
    doc = doc + "  },\n"
    doc = doc + "  \"hit_inspector\": " + hitInspectorJson + ",\n"
    doc = doc + "  \"session_preview_mode\": " + r2cControllerJsonQuote(sessionPreviewMode) + "\n"
    doc = doc + "}\n"
    if !v3path.V3WriteTextFile("", outPath, doc):
        r2cControllerPrintErr("r2c-react: native gui inspector state write failed: " + outPath)
        return false
    return true

fn r2cControllerShellQuoteSimple(text: str): str =
    return "'" + text + "'"

fn r2cControllerReplaySourceOpen(root: str,
                                 repoRoot: str,
                                 hitSourceModulePath: str,
                                 hitSourceLine: int32,
                                 sourceJumpTargetPath: str,
                                 sourceJumpTargetLine: int32,
                                 openLogPath: str): R2cReplaySourceOpenResult =
    var result: R2cReplaySourceOpenResult
    var targetPath: str = sourceJumpTargetPath
    var targetLine: int32 = sourceJumpTargetLine
    if strings.Len(targetPath) <= 0:
        if strings.Len(repoRoot) > 0 && strings.Len(hitSourceModulePath) > 0:
            targetPath = v3path.V3PathAbsolute(repoRoot, hitSourceModulePath)
    if targetLine <= 0:
        targetLine = hitSourceLine
        if targetLine <= 0:
            targetLine = 1
    result.targetPath = targetPath
    result.targetLine = targetLine
    if strings.Len(targetPath) <= 0:
        result.error = "missing_target_path"
        return result
    if !v3path.V3PathFileExists(targetPath):
        result.error = "source_file_missing:" + targetPath
        return result
    result.requested = true
    var command = "/usr/bin/xed"
    command = command + " " + r2cControllerShellQuoteSimple("--background")
    command = command + " " + r2cControllerShellQuoteSimple("--line")
    command = command + " " + r2cControllerShellQuoteSimple(intToStr(targetLine))
    command = command + " " + r2cControllerShellQuoteSimple(targetPath)
    result.command = command
    var argv: str[]
    add(argv, "--background")
    add(argv, "--line")
    add(argv, intToStr(targetLine))
    add(argv, targetPath)
    var exitCode: int32
    var output: str
    os.OsSetEmpty(output)
    let runOk = r2cproc.r2cProcessRunProgramLogged(root,
                                                   "r2c-react replay-hit-inspector open-source",
                                                   "/usr/bin/xed",
                                                   argv,
                                                   root,
                                                   openLogPath,
                                                   exitCode,
                                                   output)
    if runOk:
        result.ok = true
        return result
    let trimmed: str = strutil.Strip(output)
    if strings.Len(trimmed) > 0:
        result.error = trimmed
        return result
    result.error = "xed_exit_" + intToStr(exitCode)
    return result

fn r2cControllerWriteCompileReport(reportPath: str,
                                   root: str,
                                   repo: str,
                                   outDir: str,
                                   helperScript: str,
                                   helperSummaryPath: str,
                                   helperLogPath: str,
                                   primaryArtifactPath: str,
                                   primaryArtifactFormat: str,
                                   ok: bool,
                                   reason: str,
                                   moduleCount: int32,
                                   routeCount: int32,
                                   semanticNodesCount: int32,
                                   typescriptVersion: str,
                                   assetCount: int32,
                                   tailwindTokenCount: int32,
                                   requiredHostGroupCount: int32,
                                   requiredHostGroupsCsv: str,
                                   rsgNodeCount: int32,
                                   rsgEdgeCount: int32,
                                   blockerCount: int32,
                                   blocked: bool,
                                   truthCompareSummaryPath: str,
                                   truthCompareMatrixSummaryPath: str): bool =
    let truthCompareOkText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "truth_compare_ok", "")
    let truthCompareReason: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "truth_compare_reason", "")
    let truthCompareMatrixOkText: str = r2cControllerReadSummaryValue(truthCompareMatrixSummaryPath, "truth_compare_matrix_ok", "")
    let truthCompareMatrixReason: str = r2cControllerReadSummaryValue(truthCompareMatrixSummaryPath, "truth_compare_matrix_reason", "")
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"compile\",\n"
    report = report + "  \"ok\": " + r2cControllerJsonBool(ok) + ",\n"
    report = report + "  \"reason\": " + r2cControllerJsonQuote(reason) + ",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(root) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(r2cControllerExperimentalRoot(root)) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"node_program\": \"node\",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote(helperScript) + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(helperSummaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(helperLogPath) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(primaryArtifactPath) + ",\n"
    report = report + "  \"primary_artifact_format\": " + r2cControllerJsonQuote(primaryArtifactFormat) + ",\n"
    report = report + "  \"module_count\": " + intToStr(moduleCount) + ",\n"
    report = report + "  \"route_count\": " + intToStr(routeCount) + ",\n"
    report = report + "  \"semantic_nodes_count\": " + intToStr(semanticNodesCount) + ",\n"
    report = report + "  \"asset_count\": " + intToStr(assetCount) + ",\n"
    report = report + "  \"tailwind_token_count\": " + intToStr(tailwindTokenCount) + ",\n"
    report = report + "  \"required_host_group_count\": " + intToStr(requiredHostGroupCount) + ",\n"
    report = report + "  \"required_host_groups\": " + r2cControllerJsonArrayFromCsv(requiredHostGroupsCsv) + ",\n"
    report = report + "  \"rsg_node_count\": " + intToStr(rsgNodeCount) + ",\n"
    report = report + "  \"rsg_edge_count\": " + intToStr(rsgEdgeCount) + ",\n"
    report = report + "  \"blocker_count\": " + intToStr(blockerCount) + ",\n"
    report = report + "  \"blocked\": " + r2cControllerJsonBool(blocked) + ",\n"
    report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(typescriptVersion) + ",\n"
    if truthCompareOkText == "true" || truthCompareOkText == "false":
        report = report + "  \"truth_compare_ok\": " + truthCompareOkText + ",\n"
    else:
        report = report + "  \"truth_compare_ok\": null,\n"
    report = report + "  \"truth_compare_reason\": " + r2cControllerJsonQuote(truthCompareReason) + ",\n"
    if truthCompareMatrixOkText == "true" || truthCompareMatrixOkText == "false":
        report = report + "  \"truth_compare_matrix_ok\": " + truthCompareMatrixOkText + ",\n"
    else:
        report = report + "  \"truth_compare_matrix_ok\": null,\n"
    report = report + "  \"truth_compare_matrix_reason\": " + r2cControllerJsonQuote(truthCompareMatrixReason) + "\n"
    report = report + "}\n"
    return v3path.V3WriteTextFile("", reportPath, report)

fn r2cControllerWriteStatusReport(reportPath: str,
                                  root: str): bool =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    return r2cstatus.v3R2cReactV3WriteStatusReport(reportPath, effectiveRoot)

fn r2cControllerCompile(root: str,
                        args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let truthTraceRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-trace", ""))
    let truthState: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-state", ""))
    let truthRoutesFileRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-routes-file", ""))
    let truthRoutesDiscover: bool = cmdline.HasFlag("--truth-routes-discover")
    let repo: str = v3path.V3PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = v3path.V3PathAbsolute(repo, outDirFlag)
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk
    let runtimeRoots: str[]
    let assetRoots: str[]
    let experimentalRoot: str = v3path.V3PathAbsolute(effectiveRoot, "tools/r2c/experimental")
    let tsxHelper: str = os.JoinPath(experimentalRoot, "r2c-react-ts-frontend.mjs")
    let codegenHelper: str = os.JoinPath(experimentalRoot, "r2c-react-codegen-surface.mjs")
    let nativeGuiBundleHelper: str = os.JoinPath(experimentalRoot, "r2c-react-native-gui-bundle.mjs")
    let tsxAstPath: str = os.JoinPath(outDir, "tsx_ast_v1.json")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    let staticSummaryPath: str = os.JoinPath(outDir, "static_surface.summary.env")
    let semanticSummaryPath: str = os.JoinPath(outDir, "semantic_surface.summary.env")
    let codegenSummaryPath: str = os.JoinPath(outDir, "codegen_surface.summary.env")
    let nativeGuiBundleSummaryPath: str = os.JoinPath(outDir, "native_gui_bundle.summary.env")
    let execRouteMatrixSummaryPath: str = os.JoinPath(outDir, "exec_route_matrix.summary.env")
    let truthCompareSummaryPath: str = os.JoinPath(outDir, "truth_compare.summary.env")
    let truthCompareMatrixSummaryPath: str = os.JoinPath(outDir, "truth_compare_matrix.summary.env")
    let reportPath: str = os.JoinPath(outDir, "compile_report_v1.json")
    var moduleInventoryPath: str = os.JoinPath(outDir, "module_inventory_v1.json")
    var rsgPath: str = os.JoinPath(outDir, "rsg_v1.json")
    var codegenManifestPath: str = os.JoinPath(outDir, "cheng_codegen_v1.json")
    var routeCatalogPath: str = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    var execSnapshotPath: str = os.JoinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    var nativeGuiBundlePath: str = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    var truthTracePath = ""
    var moduleCount: int32
    var routeCount: int32
    var execSemanticNodesCount: int32
    var assetCount: int32
    var tailwindTokenCount: int32
    var requiredHostGroupCount: int32
    var requiredHostGroupsCsv = ""
    var rsgNodeCount: int32
    var rsgEdgeCount: int32
    var blockerCount: int32
    var blocked = false
    var typescriptVersion = ""
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)

    var frontendArgs: str[]
    add(frontendArgs, "--repo")
    add(frontendArgs, repo)
    add(frontendArgs, "--out")
    add(frontendArgs, tsxAstPath)
    add(frontendArgs, "--summary-out")
    add(frontendArgs, tsxSummaryPath)
    for i in 0..<runtimeRoots.len:
        add(frontendArgs, "--runtime-root")
        add(frontendArgs, runtimeRoots[i])
    let frontendLogPath: str = os.JoinPath(outDir, "tsx_frontend.log")
    if !r2cControllerRunNodeHelper(effectiveRoot, tsxHelper, frontendArgs, frontendLogPath, helperExitCode, helperOutput):
        r2cControllerPrintErr("r2c-react: tsx frontend helper failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1

    moduleCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(tsxSummaryPath, "module_count", "0"))
    typescriptVersion = r2cControllerReadSummaryValue(tsxSummaryPath, "typescript_version", "")

    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    if !r2csurface.r2cRunStaticSurface(repo, outDir, tsxAstPath, staticSummaryPath, assetRoots, staticSurface):
        r2cControllerPrintErr("r2c-react: static surface failed")
        if strings.Len(staticSurface.message) > 0:
            r2cControllerPrintErr(staticSurface.message)
        return 1
    assetCount = staticSurface.assetCount
    tailwindTokenCount = staticSurface.tailwindTokenCount
    requiredHostGroupCount = staticSurface.requiredHostGroupCount
    requiredHostGroupsCsv = staticSurface.requiredHostGroupsCsv
    moduleInventoryPath = os.JoinPath(outDir, "module_inventory_v1.json")

    var semanticSurface: r2csurface.R2cSemanticSurfaceRunResult
    if !r2csurface.r2cRunSemanticSurface(repo, outDir, tsxAstPath, semanticSummaryPath, semanticSurface):
        r2cControllerPrintErr("r2c-react: semantic surface failed")
        if strings.Len(semanticSurface.message) > 0:
            r2cControllerPrintErr(semanticSurface.message)
        return 1
    rsgNodeCount = semanticSurface.rsgNodeCount
    rsgEdgeCount = semanticSurface.rsgEdgeCount
    blockerCount = semanticSurface.blockerCount
    blocked = semanticSurface.blocked
    rsgPath = os.JoinPath(outDir, "rsg_v1.json")

    var codegenArgs: str[]
    add(codegenArgs, "--repo")
    add(codegenArgs, repo)
    add(codegenArgs, "--out-dir")
    add(codegenArgs, outDir)
    add(codegenArgs, "--tsx-ast")
    add(codegenArgs, tsxAstPath)
    add(codegenArgs, "--summary-out")
    add(codegenArgs, codegenSummaryPath)
    if strings.Len(truthTraceRaw) > 0:
        truthTracePath = v3path.V3PathAbsolute(repo, truthTraceRaw)
        if !v3path.V3PathFileExists(truthTracePath):
            r2cControllerPrintErr("r2c-react: missing truth trace: " + truthTracePath)
            return 1
        add(codegenArgs, "--truth-trace")
        add(codegenArgs, truthTracePath)
    let codegenLogPath: str = os.JoinPath(outDir, "codegen_surface.log")
    if !r2cControllerRunNodeHelper(effectiveRoot, codegenHelper, codegenArgs, codegenLogPath, helperExitCode, helperOutput):
        r2cControllerPrintErr("r2c-react: codegen surface helper failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1

    codegenManifestPath = os.JoinPath(outDir, "cheng_codegen_v1.json")
    routeCatalogPath = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")

    var nativeGuiBundleArgs: str[]
    add(nativeGuiBundleArgs, "--repo")
    add(nativeGuiBundleArgs, repo)
    add(nativeGuiBundleArgs, "--out-dir")
    add(nativeGuiBundleArgs, outDir)
    add(nativeGuiBundleArgs, "--codegen-manifest")
    add(nativeGuiBundleArgs, codegenManifestPath)
    add(nativeGuiBundleArgs, "--exec-snapshot")
    add(nativeGuiBundleArgs, execSnapshotPath)
    add(nativeGuiBundleArgs, "--host-contract")
    add(nativeGuiBundleArgs, os.JoinPath(outDir, "unimaker_host_v1.json"))
    add(nativeGuiBundleArgs, "--asset-manifest")
    add(nativeGuiBundleArgs, os.JoinPath(outDir, "asset_manifest_v1.json"))
    add(nativeGuiBundleArgs, "--tailwind-manifest")
    add(nativeGuiBundleArgs, os.JoinPath(outDir, "tailwind_style_manifest_v1.json"))
    add(nativeGuiBundleArgs, "--route-catalog")
    add(nativeGuiBundleArgs, routeCatalogPath)
    add(nativeGuiBundleArgs, "--out")
    add(nativeGuiBundleArgs, nativeGuiBundlePath)
    add(nativeGuiBundleArgs, "--summary-out")
    add(nativeGuiBundleArgs, nativeGuiBundleSummaryPath)
    let nativeGuiBundleLogPath: str = os.JoinPath(outDir, "native_gui_bundle.log")
    if !r2cControllerRunNodeHelper(effectiveRoot, nativeGuiBundleHelper, nativeGuiBundleArgs, nativeGuiBundleLogPath, helperExitCode, helperOutput):
        r2cControllerPrintErr("r2c-react: native gui bundle helper failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1

    nativeGuiBundlePath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_bundle_path", nativeGuiBundlePath)
    execSemanticNodesCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "initial_semantic_nodes_count", "0"))
    execSnapshotPath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_exec_snapshot_path", execSnapshotPath)
    routeCatalogPath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_route_catalog_path", routeCatalogPath)

    if strings.Len(truthTraceRaw) <= 0:
        r2cControllerPrintErr("r2c-react: missing --truth-trace")
        return 2
    let truthCompareControllerPath: str = v3path.V3PathAbsolute(effectiveRoot, "artifacts/bootstrap/cheng.stage3")
    if !v3path.V3PathFileExists(truthCompareControllerPath):
        r2cControllerPrintErr("r2c-react: missing stage3 controller for truth compare: " + truthCompareControllerPath)
        return 2
    let truthCompareControllerLogPath: str = os.JoinPath(outDir, "truth_compare_controller.log")
    var truthCompareControllerArgs: str[]
    add(truthCompareControllerArgs, "r2c-react")
    add(truthCompareControllerArgs, "truth-compare")
    add(truthCompareControllerArgs, "--repo")
    add(truthCompareControllerArgs, repo)
    add(truthCompareControllerArgs, "--out-dir")
    add(truthCompareControllerArgs, outDir)
    add(truthCompareControllerArgs, "--exec-snapshot")
    add(truthCompareControllerArgs, execSnapshotPath)
    add(truthCompareControllerArgs, "--codegen-manifest")
    add(truthCompareControllerArgs, codegenManifestPath)
    add(truthCompareControllerArgs, "--route-catalog")
    add(truthCompareControllerArgs, routeCatalogPath)
    add(truthCompareControllerArgs, "--truth-trace")
    add(truthCompareControllerArgs, truthTracePath)
    if strings.Len(truthState) > 0:
        add(truthCompareControllerArgs, "--truth-state")
        add(truthCompareControllerArgs, truthState)
    if strings.Len(truthRoutesFileRaw) > 0:
        add(truthCompareControllerArgs, "--truth-routes-file")
        add(truthCompareControllerArgs, truthRoutesFileRaw)
    if truthRoutesDiscover:
        add(truthCompareControllerArgs, "--truth-routes-discover")
    for i in 0..<runtimeRoots.len:
        add(truthCompareControllerArgs, "--runtime-root")
        add(truthCompareControllerArgs, runtimeRoots[i])
    if !r2cproc.r2cProcessRunProgramLogged(effectiveRoot,
                                           "r2c-react cheng controller",
                                           truthCompareControllerPath,
                                           truthCompareControllerArgs,
                                           effectiveRoot,
                                           truthCompareControllerLogPath,
                                           helperExitCode,
                                           helperOutput):
        r2cControllerPrintErr("r2c-react: truth compare controller failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        return 2

    routeCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(truthCompareMatrixSummaryPath,
                                                                       "route_count",
                                                                       r2cControllerReadSummaryValue(execRouteMatrixSummaryPath, "route_count", "1")))

    let truthCompareOkText: str = r2cControllerReadSummaryValue(truthCompareSummaryPath, "truth_compare_ok", "")
    let truthCompareMatrixOkText: str = r2cControllerReadSummaryValue(truthCompareMatrixSummaryPath, "truth_compare_matrix_ok", "")
    let nativeGuiLauncherModule: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_launcher_module", "")
    let nativeGuiHostReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_host_ready", "")
    let nativeGuiRendererReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_renderer_ready", "")
    let nativeGuiSessionPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_path", "")
    let nativeGuiSessionPreviewReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_preview_ready", "")
    let nativeGuiSessionPreviewMode: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_preview_mode", "")
    let nativeGuiLayoutSurfacePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_path", "")
    let nativeGuiLayoutSurfaceReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_ready", "")
    let nativeGuiLayoutSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_node_count", "0")
    let nativeGuiLayoutSurfaceSourceModule: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_source_module", "")
    let nativeGuiLayoutSurfaceSourceComponent: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_source_component", "")
    let nativeGuiLayoutSurfaceStrategy: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_strategy", "")
    let nativeGuiLayoutSurfaceComponentExpansionCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_component_expansion_count", "0")
    let nativeGuiLayoutSurfaceParsedModuleCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_parsed_module_count", "0")
    let nativeGuiLayoutSurfaceStyledNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_styled_node_count", "0")
    let nativeGuiLayoutSurfaceInteractiveNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_interactive_node_count", "0")
    let nativeGuiStyleLayoutSurfacePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_path", "")
    let nativeGuiStyleLayoutSurfaceReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_ready", "")
    let nativeGuiStyleLayoutSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_node_count", "0")
    let nativeGuiStyleLayoutOverlayNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_overlay_node_count", "0")
    let nativeGuiStyleLayoutSurfaceSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_surface_node_count", "0")
    let nativeGuiStyleLayoutSurfaceControlNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_control_node_count", "0")
    let nativeGuiNativeLayoutPlanPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_path", "")
    let nativeGuiNativeLayoutPlanReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_ready", "")
    let nativeGuiNativeLayoutPlanPolicySource: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_policy_source", "")
    let nativeGuiNativeLayoutPlanItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_item_count", "0")
    let nativeGuiNativeLayoutPlanViewportItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_viewport_item_count", "0")
    let nativeGuiNativeLayoutPlanClippedItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_clipped_item_count", "0")
    let nativeGuiNativeLayoutPlanInteractiveItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_interactive_item_count", "0")
    let nativeGuiNativeLayoutPlanSourceBackedItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_source_backed_item_count", "0")
    let nativeGuiNativeLayoutPlanScrollHeightText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_scroll_height", "0")
    var finalRouteCountText: str = intToStr(routeCount)
    var hasTruthRoutesInput: bool = truthRoutesDiscover
    if !hasTruthRoutesInput:
        if strings.Len(truthRoutesFileRaw) > 0:
            hasTruthRoutesInput = true
    if v3path.V3PathFileExists(truthCompareMatrixSummaryPath):
        finalRouteCountText = r2cControllerReadSummaryValue(truthCompareMatrixSummaryPath, "route_count", finalRouteCountText)
    elif hasTruthRoutesInput:
        finalRouteCountText = r2cControllerReadSummaryValue(execRouteMatrixSummaryPath, "route_count", finalRouteCountText)
    if strings.Len(finalRouteCountText) <= 0:
        finalRouteCountText = "0"
    var finalReport = "{\n"
    finalReport = finalReport + "  \"format\": \"controller_report_v1\",\n"
    finalReport = finalReport + "  \"controller\": \"cheng.live_controller\",\n"
    finalReport = finalReport + "  \"command\": \"compile\",\n"
    finalReport = finalReport + "  \"ok\": true,\n"
    finalReport = finalReport + "  \"reason\": \"ok\",\n"
    finalReport = finalReport + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    finalReport = finalReport + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    finalReport = finalReport + "  \"native_gui_bundle_path\": " + r2cControllerJsonQuote(nativeGuiBundlePath) + ",\n"
    finalReport = finalReport + "  \"native_gui_launcher_module\": " + r2cControllerJsonQuote(nativeGuiLauncherModule) + ",\n"
    finalReport = finalReport + "  \"native_gui_session_path\": " + r2cControllerJsonQuote(nativeGuiSessionPath) + ",\n"
    finalReport = finalReport + "  \"native_gui_session_preview_mode\": " + r2cControllerJsonQuote(nativeGuiSessionPreviewMode) + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_path\": " + r2cControllerJsonQuote(nativeGuiLayoutSurfacePath) + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_node_count\": " + nativeGuiLayoutSurfaceNodeCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_source_module\": " + r2cControllerJsonQuote(nativeGuiLayoutSurfaceSourceModule) + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_source_component\": " + r2cControllerJsonQuote(nativeGuiLayoutSurfaceSourceComponent) + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_strategy\": " + r2cControllerJsonQuote(nativeGuiLayoutSurfaceStrategy) + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_component_expansion_count\": " + nativeGuiLayoutSurfaceComponentExpansionCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_parsed_module_count\": " + nativeGuiLayoutSurfaceParsedModuleCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_styled_node_count\": " + nativeGuiLayoutSurfaceStyledNodeCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_layout_surface_interactive_node_count\": " + nativeGuiLayoutSurfaceInteractiveNodeCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_style_layout_surface_path\": " + r2cControllerJsonQuote(nativeGuiStyleLayoutSurfacePath) + ",\n"
    finalReport = finalReport + "  \"native_gui_style_layout_surface_node_count\": " + nativeGuiStyleLayoutSurfaceNodeCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_style_layout_overlay_node_count\": " + nativeGuiStyleLayoutOverlayNodeCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_style_layout_surface_surface_node_count\": " + nativeGuiStyleLayoutSurfaceSurfaceNodeCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_style_layout_surface_control_node_count\": " + nativeGuiStyleLayoutSurfaceControlNodeCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_native_layout_plan_path\": " + r2cControllerJsonQuote(nativeGuiNativeLayoutPlanPath) + ",\n"
    finalReport = finalReport + "  \"native_gui_native_layout_plan_policy_source\": " + r2cControllerJsonQuote(nativeGuiNativeLayoutPlanPolicySource) + ",\n"
    finalReport = finalReport + "  \"native_gui_native_layout_plan_item_count\": " + nativeGuiNativeLayoutPlanItemCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_native_layout_plan_viewport_item_count\": " + nativeGuiNativeLayoutPlanViewportItemCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_native_layout_plan_clipped_item_count\": " + nativeGuiNativeLayoutPlanClippedItemCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_native_layout_plan_interactive_item_count\": " + nativeGuiNativeLayoutPlanInteractiveItemCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_native_layout_plan_source_backed_item_count\": " + nativeGuiNativeLayoutPlanSourceBackedItemCountText + ",\n"
    finalReport = finalReport + "  \"native_gui_native_layout_plan_scroll_height\": " + nativeGuiNativeLayoutPlanScrollHeightText + ",\n"
    finalReport = finalReport + "  \"route_count\": " + finalRouteCountText + ",\n"
    if nativeGuiHostReadyText == "true" || nativeGuiHostReadyText == "false":
        finalReport = finalReport + "  \"native_gui_host_ready\": " + nativeGuiHostReadyText + ",\n"
    else:
        finalReport = finalReport + "  \"native_gui_host_ready\": null,\n"
    if nativeGuiRendererReadyText == "true" || nativeGuiRendererReadyText == "false":
        finalReport = finalReport + "  \"native_gui_renderer_ready\": " + nativeGuiRendererReadyText + ",\n"
    else:
        finalReport = finalReport + "  \"native_gui_renderer_ready\": null,\n"
    if nativeGuiSessionPreviewReadyText == "true" || nativeGuiSessionPreviewReadyText == "false":
        finalReport = finalReport + "  \"native_gui_session_preview_ready\": " + nativeGuiSessionPreviewReadyText + ",\n"
    else:
        finalReport = finalReport + "  \"native_gui_session_preview_ready\": null,\n"
    if nativeGuiLayoutSurfaceReadyText == "true" || nativeGuiLayoutSurfaceReadyText == "false":
        finalReport = finalReport + "  \"native_gui_layout_surface_ready\": " + nativeGuiLayoutSurfaceReadyText + ",\n"
    else:
        finalReport = finalReport + "  \"native_gui_layout_surface_ready\": null,\n"
    if nativeGuiStyleLayoutSurfaceReadyText == "true" || nativeGuiStyleLayoutSurfaceReadyText == "false":
        finalReport = finalReport + "  \"native_gui_style_layout_surface_ready\": " + nativeGuiStyleLayoutSurfaceReadyText + ",\n"
    else:
        finalReport = finalReport + "  \"native_gui_style_layout_surface_ready\": null,\n"
    if nativeGuiNativeLayoutPlanReadyText == "true" || nativeGuiNativeLayoutPlanReadyText == "false":
        finalReport = finalReport + "  \"native_gui_native_layout_plan_ready\": " + nativeGuiNativeLayoutPlanReadyText + ",\n"
    else:
        finalReport = finalReport + "  \"native_gui_native_layout_plan_ready\": null,\n"
    if truthCompareOkText == "true" || truthCompareOkText == "false":
        finalReport = finalReport + "  \"truth_compare_ok\": " + truthCompareOkText + ",\n"
    else:
        finalReport = finalReport + "  \"truth_compare_ok\": null,\n"
    if truthCompareMatrixOkText == "true" || truthCompareMatrixOkText == "false":
        finalReport = finalReport + "  \"truth_compare_matrix_ok\": " + truthCompareMatrixOkText + "\n"
    else:
        finalReport = finalReport + "  \"truth_compare_matrix_ok\": null\n"
    finalReport = finalReport + "}\n"
    v3path.V3WriteTextFile("", reportPath, finalReport)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerStatus(root: str,
                       args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let outPathRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out", ""))
    if strings.Len(outPathRaw) > 0:
        let outPath: str = v3path.V3PathAbsolute(effectiveRoot, outPathRaw)
        if !r2cControllerWriteStatusReport(outPath, effectiveRoot):
            r2cControllerPrintErr("r2c-react: failed to write status report")
            return 1
        r2cControllerPrintLine(outPath)
        return 0
    let outPath: str = os.JoinPath(effectiveRoot, "artifacts/r2c_react_status_report_v1.json")
    if !r2cControllerWriteStatusReport(outPath, effectiveRoot):
        r2cControllerPrintErr("r2c-react: failed to write status report")
        return 1
    let body: str = v3path.V3ReadTextFile("", outPath)
    r2cControllerPrintLine(body)
    return 0

fn r2cControllerCodegenSurface(root: str,
                               args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let tsxAstFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--tsx-ast", ""))
    let truthTraceRaw: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--truth-trace", ""))
    let runtimeRoots: str[] = r2cControllerCollectCmdlineFlagValues("--runtime-root")
    let repo: str = v3path.V3PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = v3path.V3PathAbsolute(repo, outDirFlag)
    var tsxAstPath: str = os.JoinPath(outDir, "tsx_ast_v1.json")
    if strings.Len(tsxAstFlag) > 0:
        tsxAstPath = v3path.V3PathAbsolute(repo, tsxAstFlag)
    let experimentalRoot: str = v3path.V3PathAbsolute(effectiveRoot, "tools/r2c/experimental")
    let tsxHelper: str = os.JoinPath(experimentalRoot, "r2c-react-ts-frontend.mjs")
    let codegenHelper: str = os.JoinPath(experimentalRoot, "r2c-react-codegen-surface.mjs")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    let codegenSummaryPath: str = os.JoinPath(outDir, "codegen_surface.summary.env")
    let reportPath: str = os.JoinPath(outDir, "codegen_surface_report_v1.json")
    let frontendLogPath: str = os.JoinPath(outDir, "tsx_frontend.log")
    let codegenLogPath: str = os.JoinPath(outDir, "codegen_surface.log")
    var codegenManifestPath: str = os.JoinPath(outDir, "cheng_codegen_v1.json")
    var routeCount: int32
    var moduleCount: int32
    var typescriptVersion = ""
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)
    if !os.DirExists(repo):
        r2cControllerPrintErr("r2c-react: missing repo: " + repo)
        return 1
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk

    if !v3path.V3PathFileExists(tsxAstPath):
        var frontendArgs: str[]
        add(frontendArgs, "--repo")
        add(frontendArgs, repo)
        add(frontendArgs, "--out")
        add(frontendArgs, tsxAstPath)
        add(frontendArgs, "--summary-out")
        add(frontendArgs, tsxSummaryPath)
        for i in 0..<runtimeRoots.len:
            add(frontendArgs, "--runtime-root")
            add(frontendArgs, runtimeRoots[i])
        if !r2cControllerRunNodeHelper(effectiveRoot, tsxHelper, frontendArgs, frontendLogPath, helperExitCode, helperOutput):
            r2cControllerPrintErr("r2c-react: tsx frontend helper failed")
            if strings.Len(helperOutput) > 0:
                r2cControllerPrintErr(helperOutput)
            if helperExitCode != 0:
                return helperExitCode
            return 1

    var codegenArgs: str[]
    add(codegenArgs, "--repo")
    add(codegenArgs, repo)
    add(codegenArgs, "--out-dir")
    add(codegenArgs, outDir)
    add(codegenArgs, "--tsx-ast")
    add(codegenArgs, tsxAstPath)
    add(codegenArgs, "--summary-out")
    add(codegenArgs, codegenSummaryPath)
    for i in 0..<runtimeRoots.len:
        add(codegenArgs, "--runtime-root")
        add(codegenArgs, runtimeRoots[i])
    if strings.Len(truthTraceRaw) > 0:
        let truthTracePath: str = v3path.V3PathAbsolute(repo, truthTraceRaw)
        if !v3path.V3PathFileExists(truthTracePath):
            r2cControllerPrintErr("r2c-react: missing truth trace: " + truthTracePath)
            return 1
        add(codegenArgs, "--truth-trace")
        add(codegenArgs, truthTracePath)
    if !r2cControllerRunNodeHelper(effectiveRoot, codegenHelper, codegenArgs, codegenLogPath, helperExitCode, helperOutput):
        r2cControllerPrintErr("r2c-react: codegen surface helper failed")
        if strings.Len(helperOutput) > 0:
            r2cControllerPrintErr(helperOutput)
        if helperExitCode != 0:
            return helperExitCode
        return 1

    moduleCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(codegenSummaryPath, "module_count", "0"))
    routeCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(codegenSummaryPath, "route_count", "0"))
    typescriptVersion = r2cControllerReadSummaryValue(codegenSummaryPath, "typescript_version", "")
    codegenManifestPath = r2cControllerReadSummaryValue(codegenSummaryPath, "codegen_manifest_path", codegenManifestPath)

    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"codegen-surface\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"node_program\": \"node\",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote(codegenHelper) + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(codegenSummaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(codegenLogPath) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(codegenManifestPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"cheng_codegen_v1\",\n"
    report = report + "  \"module_count\": " + intToStr(moduleCount) + ",\n"
    report = report + "  \"route_count\": " + intToStr(routeCount) + ",\n"
    report = report + "  \"semantic_nodes_count\": 0,\n"
    report = report + "  \"asset_count\": 0,\n"
    report = report + "  \"tailwind_token_count\": 0,\n"
    report = report + "  \"required_host_group_count\": 0,\n"
    report = report + "  \"required_host_groups\": [],\n"
    report = report + "  \"rsg_node_count\": 0,\n"
    report = report + "  \"rsg_edge_count\": 0,\n"
    report = report + "  \"blocker_count\": 0,\n"
    report = report + "  \"blocked\": false,\n"
    report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(typescriptVersion) + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerDiscoverTruthRoutes(root: str,
                                    args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
