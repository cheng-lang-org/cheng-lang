    report = report + "  \"native_gui_runtime_contract_ready\": " + r2cControllerJsonBoolTextOrNull(nativeRuntimeContractReadyText) + "\n"
    report = report + "}\n"
    chengpath.WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerWriteTinyPng(path: str): bool =
    let payload: uint8[] = [
        uint8(137), uint8(80), uint8(78), uint8(71), uint8(13), uint8(10), uint8(26), uint8(10),
        uint8(0), uint8(0), uint8(0), uint8(13), uint8(73), uint8(72), uint8(68), uint8(82),
        uint8(0), uint8(0), uint8(0), uint8(1), uint8(0), uint8(0), uint8(0), uint8(1),
        uint8(8), uint8(4), uint8(0), uint8(0), uint8(0), uint8(181), uint8(28), uint8(12),
        uint8(2), uint8(0), uint8(0), uint8(0), uint8(11), uint8(73), uint8(68), uint8(65),
        uint8(84), uint8(120), uint8(218), uint8(99), uint8(252), uint8(255), uint8(31), uint8(0),
        uint8(3), uint8(3), uint8(2), uint8(0), uint8(239), uint8(154), uint8(93), uint8(251),
        uint8(0), uint8(0), uint8(0), uint8(0), uint8(73), uint8(69), uint8(78), uint8(68),
        uint8(174), uint8(66), uint8(96), uint8(130)
    ]
    os.WriteFileBytes(path, payload)
    return chengpath.PathFileExists(path)

fn r2cControllerIsSignedIntText(textRaw: str): bool =
    let text: str = strutil.Strip(textRaw)
    let total: int32 = strings.Len(text)
    if total <= 0:
        return false
    var start: int32
    if text[0] == '-':
        if total == 1:
            return false
        start = 1
    for i in start..<total:
        if r2cControllerDigitValue(r2cControllerSlice(text, i, 1)) < 0:
            return false
    return true

fn r2cControllerParsePairSpec(specRaw: str,
                              sepA: char,
                              sepB: char,
                              label: str,
                              outA: var int32,
                              outB: var int32): bool =
    let spec: str = strutil.Strip(specRaw)
    var sepPos: int32 = r2cControllerTextFind(spec, strings.CharToStr(sepA), 0)
    if sepPos < 0 && sepA != sepB:
        sepPos = r2cControllerTextFind(spec, strings.CharToStr(sepB), 0)
    if sepPos <= 0 || sepPos >= strings.Len(spec) - 1:
        r2cControllerPrintErr("r2c-react: invalid " + label + " pair: " + specRaw)
        return false
    let left: str = strutil.Strip(r2cControllerSlice(spec, 0, sepPos))
    let right: str = strutil.Strip(r2cControllerSlice(spec, sepPos + 1, strings.Len(spec) - sepPos - 1))
    if !r2cControllerIsSignedIntText(left) || !r2cControllerIsSignedIntText(right):
        r2cControllerPrintErr("r2c-react: invalid " + label + " integer pair: " + specRaw)
        return false
    outA = r2cControllerParseInt32(left)
    outB = r2cControllerParseInt32(right)
    return true

fn r2cControllerRunNativeGuiFirstInspectableItem(sessionText: str,
                                                 outItemRaw: var str): bool =
    outItemRaw = ""
    let nativeLayoutPlanText: str = r2cControllerJsonReadObjectFieldRaw(sessionText, "native_layout_plan", "")
    let layoutItemsText: str = r2cControllerJsonReadArrayFieldRaw(nativeLayoutPlanText, "items", "[]")
    var cursor: int32
    var nextCursor: int32
    var itemRaw: str
    while r2cControllerJsonArrayNextObjectRaw(layoutItemsText, cursor, itemRaw, nextCursor):
        cursor = nextCursor
        let itemId: str = r2cControllerJsonReadStringField(itemRaw, "id", "")
        if strings.Len(itemId) <= 0 || itemId == "root":
            continue
        let sourceModulePath: str = r2cControllerJsonReadStringField(itemRaw, "source_module_path", "")
        let sourceComponentName: str = r2cControllerJsonReadStringField(itemRaw, "source_component_name", "")
        let sourceLine: int32 = r2cControllerJsonReadIntField(itemRaw, "source_line", 0)
        if strings.Len(sourceModulePath) > 0 || strings.Len(sourceComponentName) > 0 || sourceLine > 0:
            outItemRaw = itemRaw
            return true
    return false

fn r2cControllerRunNativeGuiBuildRuntimeArgs(clickSpec: str,
                                             resizeSpec: str,
                                             scrollY: str,
                                             focusItemId: str,
                                             typeText: str,
                                             sendKey: str,
                                             selectedItemId: str,
                                             outArgs: var str[]): bool =
    outArgs = []
    var windowWidth: int32 = 390
    var windowHeight: int32 = 844
    var clickCount: int32
    var resizeCount: int32
    var scrollCount: int32
    var focusCount: int32
    var keyCount: int32
    var textCount: int32
    var lastClickX: int32
    var lastClickY: int32
    var scrollOffsetY: int32
    var hasLastClick = false
    if strings.Len(resizeSpec) > 0:
        if !r2cControllerParsePairSpec(resizeSpec, 'x', 'X', "resize", windowWidth, windowHeight):
            return false
        if windowWidth <= 0 || windowHeight <= 0:
            r2cControllerPrintErr("r2c-react: invalid resize dimensions: " + resizeSpec)
            return false
        resizeCount = 1
    if strings.Len(clickSpec) > 0:
        if !r2cControllerParsePairSpec(clickSpec, char(44), char(44), "click", lastClickX, lastClickY):
            return false
        clickCount = 1
        hasLastClick = true
    if strings.Len(scrollY) > 0:
        if !r2cControllerIsSignedIntText(scrollY):
            r2cControllerPrintErr("r2c-react: invalid scroll-y integer: " + scrollY)
            return false
        scrollOffsetY = r2cControllerParseInt32(scrollY)
        scrollCount = 1
    if strings.Len(focusItemId) > 0:
        focusCount = 1
    if strings.Len(typeText) > 0:
        textCount = 1
    if strings.Len(sendKey) > 0:
        keyCount = 1
    add(outArgs, "--state-window-width")
    add(outArgs, intToStr(windowWidth))
    add(outArgs, "--state-window-height")
    add(outArgs, intToStr(windowHeight))
    add(outArgs, "--state-scroll-offset-y")
    add(outArgs, intToStr(scrollOffsetY))
    add(outArgs, "--state-click-count")
    add(outArgs, intToStr(clickCount))
    add(outArgs, "--state-resize-count")
    add(outArgs, intToStr(resizeCount))
    add(outArgs, "--state-scroll-count")
    add(outArgs, intToStr(scrollCount))
    add(outArgs, "--state-focus-count")
    add(outArgs, intToStr(focusCount))
    add(outArgs, "--state-key-count")
    add(outArgs, intToStr(keyCount))
    add(outArgs, "--state-text-count")
    add(outArgs, intToStr(textCount))
    add(outArgs, "--state-has-last-click")
    add(outArgs, r2cControllerJsonBool(hasLastClick))
    add(outArgs, "--state-last-click-x")
    add(outArgs, intToStr(lastClickX))
    add(outArgs, "--state-last-click-y")
    add(outArgs, intToStr(lastClickY))
    add(outArgs, "--state-selected-item-id")
    add(outArgs, selectedItemId)
    add(outArgs, "--state-focused-item-id")
    if strings.Len(focusItemId) > 0:
        add(outArgs, focusItemId)
    else:
        add(outArgs, "")
    add(outArgs, "--state-typed-text")
    add(outArgs, typeText)
    add(outArgs, "--state-last-key")
    add(outArgs, sendKey)
    return true

fn r2cControllerRunNativeGuiChengSessionRunner(effectiveRoot: str,
                                               repo: str,
                                               outDir: str,
                                               sessionPath: str,
                                               nativeGuiBundleSummaryPath: str,
                                               screenshotPath: str,
                                               nativeGuiRunLogPath: str,
                                               nativeGuiHostRunFieldsPath: str,
                                               runtimeRenderPlanPath: str,
                                               runtimeStateCapturePath: str,
                                               clickSpec: str,
                                               resizeSpec: str,
                                               scrollY: str,
                                               focusItemId: str,
                                               typeText: str,
                                               sendKey: str,
                                               autoCloseMs: str,
                                               waitAfterClickMs: str,
                                               openSourceOnClick: bool): int32 =
    let sessionDocTextForRunner: str = chengpath.ReadTextFile("", sessionPath)
    var selectedItemRaw: str
    let selectedItemFound: bool = r2cControllerRunNativeGuiFirstInspectableItem(sessionDocTextForRunner, selectedItemRaw)
    let selectedItemId: str = selectedItemFound ? r2cControllerJsonReadStringField(selectedItemRaw, "id", "") : ""
    let selectedSourceNodeId: str = selectedItemFound ? r2cControllerJsonReadStringField(selectedItemRaw, "source_node_id", "") : ""
    let selectedSourceModulePath: str = selectedItemFound ? r2cControllerJsonReadStringField(selectedItemRaw, "source_module_path", "") : ""
    let selectedSourceComponentName: str = selectedItemFound ? r2cControllerJsonReadStringField(selectedItemRaw, "source_component_name", "") : ""
    let selectedSourceLineText: str = selectedItemFound ? intToStr(r2cControllerJsonReadIntField(selectedItemRaw, "source_line", 0)) : "0"
    let selectedItemInteractiveText: str = selectedItemFound ? r2cControllerJsonBool(r2cControllerJsonReadBoolField(selectedItemRaw, "interactive", false)) : "false"
    let nativeRuntimeCompiledExePathForRunner: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_compiled_exe_path", "")
    let nativeRuntimeContractPathForRunner: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_path", "")
    if strings.Len(nativeRuntimeCompiledExePathForRunner) <= 0 || !chengpath.PathFileExists(nativeRuntimeCompiledExePathForRunner):
        r2cControllerPrintErr("r2c-react: native gui Cheng session runner missing compiled runtime: " + nativeRuntimeCompiledExePathForRunner)
        return 1
    if strings.Len(nativeRuntimeContractPathForRunner) <= 0 || !chengpath.PathFileExists(nativeRuntimeContractPathForRunner):
        r2cControllerPrintErr("r2c-react: native gui Cheng session runner missing runtime contract: " + nativeRuntimeContractPathForRunner)
        return 1
    let routeCatalogPathForRunner: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_route_catalog_path", "")
    if strings.Len(routeCatalogPathForRunner) <= 0 || !chengpath.PathFileExists(routeCatalogPathForRunner):
        r2cControllerPrintErr("r2c-react: native gui Cheng session runner missing route catalog: " + routeCatalogPathForRunner)
        return 1
    let nativeSurfaceFramePath: str = os.JoinPath(outDir, "native_surface_frame_rgba_v1.rgba")
    let nativeSurfaceManifestPath: str = os.JoinPath(outDir, "native_surface_frame_manifest_v1.json")
    let nativeRouteReplayManifestPath: str = os.JoinPath(outDir, "native_gui_route_replay_manifest_v1.json")
    let nativeInteractionManifestPath: str = os.JoinPath(outDir, "native_gui_interaction_manifest_v1.json")
    let nativePlatformShellManifestPath: str = os.JoinPath(outDir, "native_platform_shell_manifest_v1.json")
    let nativePlatformShellAndroidLaunchPath: str = os.JoinPath(outDir, "native_platform_shell_android_launch_v1.json")
    let nativePlatformShellIosLaunchPath: str = os.JoinPath(outDir, "native_platform_shell_ios_launch_v1.json")
    let nativePlatformShellOhosLaunchPath: str = os.JoinPath(outDir, "native_platform_shell_ohos_launch_v1.json")
    let nativePlatformShellLaunchSummaryPath: str = os.JoinPath(outDir, "native_platform_shell_launch.summary.env")
    let nativePlatformShellPackageManifestPath: str = os.JoinPath(outDir, "native_platform_shell_package_manifest_v1.json")
    var runtimeArgs: str[]
    if !r2cControllerRunNativeGuiBuildRuntimeArgs(clickSpec,
                                                  resizeSpec,
                                                  scrollY,
                                                  focusItemId,
                                                  typeText,
                                                  sendKey,
                                                  selectedItemId,
                                                  runtimeArgs):
        return 1
    add(runtimeArgs, "--screenshot-out")
    add(runtimeArgs, screenshotPath)
    add(runtimeArgs, "--surface-frame-out")
    add(runtimeArgs, nativeSurfaceFramePath)
    add(runtimeArgs, "--surface-manifest-out")
    add(runtimeArgs, nativeSurfaceManifestPath)
    add(runtimeArgs, "--route-catalog-path")
    add(runtimeArgs, routeCatalogPathForRunner)
    add(runtimeArgs, "--route-replay-manifest-out")
    add(runtimeArgs, nativeRouteReplayManifestPath)
    add(runtimeArgs, "--interaction-manifest-out")
    add(runtimeArgs, nativeInteractionManifestPath)
    add(runtimeArgs, "--platform-shell-manifest-out")
    add(runtimeArgs, nativePlatformShellManifestPath)
    add(runtimeArgs, "--platform-shell-plan-dir")
    add(runtimeArgs, outDir)
    add(runtimeArgs, "--platform-shell-package-manifest-out")
    add(runtimeArgs, nativePlatformShellPackageManifestPath)
    var runtimeRunExitCode: int32
    var runtimeRunOutput: str
    if !r2cControllerRunCompiledRuntimeLoggedWithArgs(effectiveRoot,
                                                      nativeRuntimeCompiledExePathForRunner,
                                                      nativeRuntimeContractPathForRunner,
                                                      runtimeArgs,
                                                      nativeGuiRunLogPath,
                                                      runtimeRunExitCode,
                                                      runtimeRunOutput):
        r2cControllerPrintErr("r2c-react: native gui Cheng session runner failed")
        if strings.Len(runtimeRunOutput) > 0:
            r2cControllerPrintErr(runtimeRunOutput)
        if runtimeRunExitCode != 0:
            return runtimeRunExitCode
        return 1
    let runtimeDocTextForRunner: str = r2cControllerEnsureTrailingNewline(runtimeRunOutput)
    if r2cControllerJsonReadStringField(runtimeDocTextForRunner, "format", "") != "native_gui_runtime_v1":
        r2cControllerPrintErr("r2c-react: native gui Cheng session runner runtime format mismatch")
        return 1
    let runtimeStateRawForRunner: str = r2cControllerJsonReadObjectFieldRaw(runtimeDocTextForRunner, "state", "")
    let runtimeRenderPlanRawForRunner: str = r2cControllerJsonReadObjectFieldRaw(runtimeDocTextForRunner, "render_plan", "")
    if strings.Len(runtimeStateRawForRunner) <= 0 || strings.Len(runtimeRenderPlanRawForRunner) <= 0:
        r2cControllerPrintErr("r2c-react: native gui Cheng session runner runtime payload incomplete")
        return 1
    if !chengpath.WriteTextFile("", runtimeStateCapturePath, r2cControllerEnsureTrailingNewline(runtimeStateRawForRunner)):
        r2cControllerPrintErr("r2c-react: native gui runtime state write failed: " + runtimeStateCapturePath)
        return 1
    if !chengpath.WriteTextFile("", runtimeRenderPlanPath, r2cControllerEnsureTrailingNewline(runtimeRenderPlanRawForRunner)):
        r2cControllerPrintErr("r2c-react: native gui render plan write failed: " + runtimeRenderPlanPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", screenshotPath):
        r2cControllerPrintErr("r2c-react: native gui software framebuffer output missing: " + screenshotPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativeSurfaceFramePath):
        r2cControllerPrintErr("r2c-react: native gui surface frame output missing: " + nativeSurfaceFramePath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativeSurfaceManifestPath):
        r2cControllerPrintErr("r2c-react: native gui surface manifest output missing: " + nativeSurfaceManifestPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativeRouteReplayManifestPath):
        r2cControllerPrintErr("r2c-react: native gui route replay manifest output missing: " + nativeRouteReplayManifestPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativeInteractionManifestPath):
        r2cControllerPrintErr("r2c-react: native gui interaction manifest output missing: " + nativeInteractionManifestPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativePlatformShellManifestPath):
        r2cControllerPrintErr("r2c-react: native gui platform shell manifest output missing: " + nativePlatformShellManifestPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativePlatformShellAndroidLaunchPath):
        r2cControllerPrintErr("r2c-react: native gui android platform shell launch plan missing: " + nativePlatformShellAndroidLaunchPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativePlatformShellIosLaunchPath):
        r2cControllerPrintErr("r2c-react: native gui ios platform shell launch plan missing: " + nativePlatformShellIosLaunchPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativePlatformShellOhosLaunchPath):
        r2cControllerPrintErr("r2c-react: native gui ohos platform shell launch plan missing: " + nativePlatformShellOhosLaunchPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativePlatformShellLaunchSummaryPath):
        r2cControllerPrintErr("r2c-react: native gui platform shell launch summary missing: " + nativePlatformShellLaunchSummaryPath)
        return 1
    if !chengpath.FileExistsNonEmpty("", nativePlatformShellPackageManifestPath):
        r2cControllerPrintErr("r2c-react: native gui platform shell package manifest missing: " + nativePlatformShellPackageManifestPath)
        return 1
    let runtimeWindowTitle: str = r2cControllerJsonReadStringField(runtimeStateRawForRunner, "window_title", "cheng_gui_preview")
    let runtimeEntryModule: str = r2cControllerJsonReadStringField(runtimeStateRawForRunner, "entry_module", "")
    let runtimeRouteState: str = r2cControllerJsonReadStringField(runtimeStateRawForRunner, "route_state", "")
    let runtimeLayoutItemCountText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "bundle_layout_item_count", 0))
    let runtimeVisibleItemCountText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "visible_layout_item_count", 0))
    let runtimeClickCountText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "click_count", 0))
    let runtimeResizeCountText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "resize_count", 0))
    let runtimeScrollCountText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "scroll_count", 0))
    let runtimeFocusCountText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "focus_count", 0))
    let runtimeKeyCountText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "key_count", 0))
    let runtimeTextCountText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "text_count", 0))
    let runtimeScrollOffsetText: str = intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "scroll_offset_y", 0))
    let runtimeLastClickXText: str = r2cControllerJsonReadBoolField(runtimeStateRawForRunner, "has_last_click", false) ? intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "last_click_x", 0)) : ""
    let runtimeLastClickYText: str = r2cControllerJsonReadBoolField(runtimeStateRawForRunner, "has_last_click", false) ? intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "last_click_y", 0)) : ""
    let runtimeFocusedItemId: str = r2cControllerJsonReadStringField(runtimeStateRawForRunner, "focused_item_id", "")
    let runtimeTypedText: str = r2cControllerJsonReadStringField(runtimeStateRawForRunner, "typed_text", "")
    let runtimeLastKey: str = r2cControllerJsonReadStringField(runtimeStateRawForRunner, "last_key", "")
    var sourceJumpResult: R2cReplaySourceOpenResult
    if openSourceOnClick && r2cControllerParseInt32(runtimeClickCountText) > 0:
        sourceJumpResult = r2cControllerReplaySourceOpen(effectiveRoot,
                                                         repo,
                                                         selectedSourceModulePath,
                                                         r2cControllerParseInt32(selectedSourceLineText),
                                                         "",
                                                         0,
                                                         os.JoinPath(outDir, "native_gui_source_jump.log"))
    let sourceJumpEnabledText: str = r2cControllerJsonBool(openSourceOnClick)
    let sourceJumpAttemptedText: str = r2cControllerJsonBool(sourceJumpResult.requested)
    let sourceJumpOkText: str = r2cControllerJsonBool(sourceJumpResult.ok)
    let sourceJumpTargetPathText: str = sourceJumpResult.targetPath
    let sourceJumpTargetLineText: str = sourceJumpResult.targetLine > 0 ? intToStr(sourceJumpResult.targetLine) : "0"
    let inspectorReadyText: str = r2cControllerJsonBool(selectedItemFound)
    var inspectorLinesJsonText: str = "[]"
    if selectedItemFound:
        inspectorLinesJsonText = "[{\"label\":\"item\",\"value\":" + r2cControllerJsonQuote(selectedItemId) + "},{\"label\":\"source\",\"value\":" + r2cControllerJsonQuote(selectedSourceModulePath) + "}]"
    var nativeGuiHostRunFieldsText = ""
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "format", "native_gui_run_v1")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "window_opened", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "screenshot_written", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "window_title", runtimeWindowTitle)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "entry_module", runtimeEntryModule)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "route_state", runtimeRouteState)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "layout_item_count", runtimeLayoutItemCountText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "visible_layout_item_count", runtimeVisibleItemCountText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "click_count", runtimeClickCountText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "resize_count", runtimeResizeCountText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "scroll_count", runtimeScrollCountText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "key_count", runtimeKeyCountText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "text_count", runtimeTextCountText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "focus_count", runtimeFocusCountText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "last_click_x", runtimeLastClickXText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "last_click_y", runtimeLastClickYText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "scroll_offset_y", runtimeScrollOffsetText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "focused_item_id", runtimeFocusedItemId)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "typed_text", runtimeTypedText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "last_key", runtimeLastKey)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "hit_item_id", selectedItemId)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "hit_source_node_id", selectedSourceNodeId)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "hit_source_module_path", selectedSourceModulePath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "hit_source_component_name", selectedSourceComponentName)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "hit_source_line", selectedSourceLineText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "hit_item_interactive", selectedItemInteractiveText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "inspector_ready", inspectorReadyText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "inspector_title", selectedItemId)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "inspector_panel_x", "12")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "inspector_panel_y", "12")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "inspector_panel_width", "366")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "inspector_panel_height", "160")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "inspector_lines_json", inspectorLinesJsonText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "source_jump_enabled", sourceJumpEnabledText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "source_jump_attempted", sourceJumpAttemptedText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "source_jump_ok", sourceJumpOkText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "source_jump_target_path", sourceJumpTargetPathText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "source_jump_target_line", sourceJumpTargetLineText)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "source_jump_command", sourceJumpResult.command)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "source_jump_error", sourceJumpResult.error)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "runtime_ready", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "runtime_error", "")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "render_plan_ready", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "framebuffer_renderer", "cheng.software_raster_png_v1")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "framebuffer_path", screenshotPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_surface_frame_format", "surface_frame_rgba_v1")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_surface_frame_renderer", "cheng.software_raster_rgba_v1")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_surface_frame_path", nativeSurfaceFramePath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_surface_manifest_path", nativeSurfaceManifestPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_route_replay_manifest_path", nativeRouteReplayManifestPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_route_replay_manifest_ready", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_interaction_manifest_path", nativeInteractionManifestPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_interaction_manifest_ready", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_manifest_path", nativePlatformShellManifestPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_manifest_ready", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_android_launch_path", nativePlatformShellAndroidLaunchPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_ios_launch_path", nativePlatformShellIosLaunchPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_ohos_launch_path", nativePlatformShellOhosLaunchPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_launch_summary_path", nativePlatformShellLaunchSummaryPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_launch_ready", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_package_manifest_path", nativePlatformShellPackageManifestPath)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_shell_package_ready", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_mobile_surface_blit_ready", "true")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "native_platform_surface_bindings", "android:ANativeWindow_rgba_blit_v1,ios:CAMetalLayer_rgba_blit_v1,ohos:OHNativeWindow_rgba_blit_v1")
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "auto_close_ms", autoCloseMs)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "wait_after_click_ms", waitAfterClickMs)
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "render_plan_command_count", intToStr(r2cControllerJsonReadIntField(runtimeRenderPlanRawForRunner, "command_count", 0)))
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "window_width", intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "window_width", 390)))
    r2cControllerSummaryAppendLine(nativeGuiHostRunFieldsText, "window_height", intToStr(r2cControllerJsonReadIntField(runtimeStateRawForRunner, "window_height", 844)))
    if !chengpath.WriteTextFile("", nativeGuiHostRunFieldsPath, nativeGuiHostRunFieldsText):
        r2cControllerPrintErr("r2c-react: native gui Cheng session runner fields write failed: " + nativeGuiHostRunFieldsPath)
        return 1
    var nativeGuiRunLogText = "mode=cheng.native_gui_session_runner_v1\n"
    nativeGuiRunLogText = nativeGuiRunLogText + "runtime_exe=" + nativeRuntimeCompiledExePathForRunner + "\n"
    nativeGuiRunLogText = nativeGuiRunLogText + "runtime_contract=" + nativeRuntimeContractPathForRunner + "\n"
    nativeGuiRunLogText = nativeGuiRunLogText + "runtime_returncode=" + intToStr(runtimeRunExitCode) + "\n"
    nativeGuiRunLogText = nativeGuiRunLogText + "runtime_log_path=" + nativeGuiRunLogPath + "\n"
    if !chengpath.FileExistsNonEmpty(effectiveRoot, nativeGuiRunLogPath):
        if !chengpath.WriteTextFile("", nativeGuiRunLogPath, nativeGuiRunLogText):
            r2cControllerPrintErr("r2c-react: native gui Cheng session runner log write failed: " + nativeGuiRunLogPath)
            return 1
    if r2cControllerReadSummaryValue(nativeGuiHostRunFieldsPath, "format", "") != "native_gui_run_v1":
        r2cControllerPrintErr("r2c-react: native gui Cheng session runner format mismatch: " + nativeGuiHostRunFieldsPath)
        return 1
    return 0

fn r2cControllerRunNativeGui(root: str,
                             args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let sessionFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--session-path", ""))
    let bundleFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--bundle-path", ""))
    let screenshotFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--screenshot-out", ""))
    let autoCloseMs: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--auto-close-ms", "1200"))
    let clickSpec: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--click", ""))
    let resizeSpec: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--resize", ""))
    let scrollY: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--scroll-y", ""))
    let waitAfterClickMs: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--wait-after-click-ms", ""))
    let summaryOutFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--summary-out", ""))
    let focusItemId: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--focus-item-id", ""))
    let typeText: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--type-text", ""))
    let sendKey: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--send-key", ""))
    let routeStateFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--route-state", ""))
    let inspectorStateFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--inspector-state-out", ""))
    let openSourceOnClick: bool = cmdline.HasFlag("--open-source-on-click")
    let repo: str = chengpath.PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = chengpath.PathAbsolute(repo, outDirFlag)
    var scratchOk: bool = chengpath.MkdirP("", outDir)
    scratchOk
    let nativeGuiHostSourcePath = ""
    var nativeGuiBundleSummaryPath: str = os.JoinPath(outDir, "native_gui_bundle.summary.env")
    var nativeGuiRunSummaryPath: str = os.JoinPath(outDir, "native_gui_run.summary.env")
    let reportPath: str = os.JoinPath(outDir, "native_gui_run_report_v1.json")
    let codegenSummaryPath: str = os.JoinPath(outDir, "codegen_surface.summary.env")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    var sessionPath: str = os.JoinPath(outDir, "native_gui_session_v1.json")
    var bundlePath: str = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    var screenshotPath: str = os.JoinPath(outDir, "native_gui_session.png")
    var inspectorStatePath: str = os.JoinPath(outDir, "native_gui_inspector_state_v1.json")
    if strings.Len(sessionFlag) > 0:
        sessionPath = chengpath.PathAbsolute(outDir, sessionFlag)
    if strings.Len(bundleFlag) > 0:
        bundlePath = chengpath.PathAbsolute(outDir, bundleFlag)
        let bundleDir: str = chengpath.PathParentDir(bundlePath)
        if strings.Len(bundleDir) > 0:
            nativeGuiBundleSummaryPath = os.JoinPath(bundleDir, "native_gui_bundle.summary.env")
    if strings.Len(screenshotFlag) > 0:
        screenshotPath = chengpath.PathAbsolute(outDir, screenshotFlag)
    if strings.Len(inspectorStateFlag) > 0:
        inspectorStatePath = chengpath.PathAbsolute(outDir, inspectorStateFlag)
    if strings.Len(summaryOutFlag) > 0:
        nativeGuiRunSummaryPath = chengpath.PathAbsolute(outDir, summaryOutFlag)
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)
    let bundleControllerPath: str = chengpath.PathAbsolute(effectiveRoot, "artifacts/bootstrap/cheng.stage3")
    let bundleControllerLogPath: str = os.JoinPath(outDir, "native_gui_run.bundle_controller.log")
    let hasExplicitSession: bool = strings.Len(sessionFlag) > 0
    let hasExplicitBundle: bool = strings.Len(bundleFlag) > 0
    let useExplicitArtifacts: bool = hasExplicitSession &&
                                     hasExplicitBundle &&
                                     chengpath.PathFileExists(sessionPath) &&
                                     chengpath.PathFileExists(bundlePath)
    if !useExplicitArtifacts:
        if !chengpath.PathFileExists(bundleControllerPath):
            r2cControllerPrintErr("r2c-react: missing stage3 controller for run-native-gui bundle: " + bundleControllerPath)
            return 1
        var bundleControllerArgs: str[]
        add(bundleControllerArgs, "r2c-react")
        add(bundleControllerArgs, "native-gui-bundle")
        add(bundleControllerArgs, "--repo")
        add(bundleControllerArgs, repo)
        add(bundleControllerArgs, "--out-dir")
        add(bundleControllerArgs, outDir)
        if strings.Len(routeStateFlag) > 0:
            add(bundleControllerArgs, "--route-state")
            add(bundleControllerArgs, routeStateFlag)
        if !r2cproc.r2cProcessRunProgramLogged(effectiveRoot,
                                               "r2c-react native-gui-bundle controller",
                                               bundleControllerPath,
                                               bundleControllerArgs,
                                               effectiveRoot,
                                               bundleControllerLogPath,
                                               helperExitCode,
                                               helperOutput):
            r2cControllerPrintErr("r2c-react: native gui bundle controller failed")
            if strings.Len(helperOutput) > 0:
                r2cControllerPrintErr(helperOutput)
            if helperExitCode != 0:
                return helperExitCode
            return 1
        sessionPath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_path", sessionPath)
        bundlePath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_bundle_path", bundlePath)
    if !chengpath.PathFileExists(sessionPath):
        r2cControllerPrintErr("r2c-react: native gui run missing session: " + sessionPath)
        return 1
    if !chengpath.PathFileExists(bundlePath):
        r2cControllerPrintErr("r2c-react: native gui run missing bundle: " + bundlePath)
        return 1

    let nativeGuiHostExePath = ""
    let nativeGuiHostCompileLogPath = ""
    let nativeGuiRunLogPath: str = os.JoinPath(outDir, "native_gui_run.log")
    let nativeGuiHostRunFieldsPath: str = os.JoinPath(outDir, "native_gui_host_run.stdout.env")
    let runtimeRenderPlanPath: str = os.JoinPath(outDir, "native_render_plan_runtime_v1.json")
    let runtimeStateCapturePath: str = os.JoinPath(outDir, "native_gui_runtime_state_runtime_v1.json")
    let hitInspectorPath: str = os.JoinPath(outDir, "native_gui_hit_inspector_v1.json")
    let sessionRunnerExitCode: int32 = r2cControllerRunNativeGuiChengSessionRunner(effectiveRoot,
                                                                                   repo,
                                                                                   outDir,
                                                                                   sessionPath,
                                                                                   nativeGuiBundleSummaryPath,
                                                                                   screenshotPath,
                                                                                   nativeGuiRunLogPath,
                                                                                   nativeGuiHostRunFieldsPath,
                                                                                   runtimeRenderPlanPath,
                                                                                   runtimeStateCapturePath,
                                                                                   clickSpec,
                                                                                   resizeSpec,
                                                                                   scrollY,
                                                                                   focusItemId,
                                                                                   typeText,
                                                                                   sendKey,
                                                                                   autoCloseMs,
                                                                                   waitAfterClickMs,
                                                                                   openSourceOnClick)
    if sessionRunnerExitCode != 0:
        return sessionRunnerExitCode

    let bundleDocTextRaw: str = chengpath.ReadTextFile("", bundlePath)
    let bundleLayoutSurfaceTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "layout_surface", "")
    let bundleStyleLayoutSurfaceTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "style_layout_surface", "")
    let bundleNativeLayoutPlanTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "native_layout_plan", "")
    let bundleNativeRenderPlanTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "native_render_plan", "")
    let bundleNativeRuntimeTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "native_runtime", "")
    let bundleSessionPreviewTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "session_preview", "")
    let sessionDocTextRaw: str = chengpath.ReadTextFile("", sessionPath)
    let runtimeStateDocTextRaw: str = chengpath.PathFileExists(runtimeStateCapturePath) ? chengpath.ReadTextFile("", runtimeStateCapturePath) : ""
    let screenshotWrittenText: str = (r2cControllerReadSummaryValue(nativeGuiHostRunFieldsPath, "screenshot_written", "") == "true" &&
                                      chengpath.PathFileExists(screenshotPath)) ? "true" : "false"
    let renderPlanReadyTextBuilt: str = (r2cControllerReadSummaryValue(nativeGuiHostRunFieldsPath, "render_plan_ready", "") == "true" &&
                                         chengpath.PathFileExists(runtimeRenderPlanPath)) ? "true" : "false"

    var runtimeManifestReadyTextBuilt: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_manifest_ready", "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_manifest_ready"):
        runtimeManifestReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_manifest_ready", false))
    var runtimeContractPayloadReadyTextBuilt: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_payload_ready", "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_contract_payload_ready"):
        runtimeContractPayloadReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_contract_payload_ready", false))
    var runtimeBundlePayloadReadyTextBuilt: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_payload_ready", "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_bundle_payload_ready"):
        runtimeBundlePayloadReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_bundle_payload_ready", false))
    var runtimeBundleReadyTextBuilt: str = r2cControllerSummaryValueOrDocBoolText(nativeGuiBundleSummaryPath,
                                                                                 "native_gui_runtime_bundle_ready",
                                                                                 bundleNativeRuntimeTextRaw,
                                                                                 "",
                                                                                 "runtime_bundle_ready",
                                                                                 "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_bundle_ready"):
        runtimeBundleReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_bundle_ready", false))
    var runtimeContractReadyTextBuilt: str = r2cControllerSummaryValueOrDocBoolText(nativeGuiBundleSummaryPath,
                                                                                    "native_gui_runtime_contract_ready",
                                                                                    bundleNativeRuntimeTextRaw,
                                                                                    "",
