    report = report + "  \"native_gui_native_layout_plan_scroll_height\": " + nativeLayoutPlanScrollHeightText + ",\n"
    report = report + "  \"native_gui_render_plan_path\": " + r2cControllerJsonQuote(nativeRenderPlanPath) + ",\n"
    report = report + "  \"native_gui_render_plan_command_count\": " + nativeRenderPlanCommandCountText + ",\n"
    report = report + "  \"native_gui_render_plan_visible_layout_item_count\": " + nativeRenderPlanVisibleLayoutItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_path\": " + r2cControllerJsonQuote(nativeRuntimePath) + ",\n"
    report = report + "  \"native_gui_runtime_state_path\": " + r2cControllerJsonQuote(nativeRuntimeStatePath) + ",\n"
    report = report + "  \"native_gui_runtime_exe_path\": " + r2cControllerJsonQuote(nativeRuntimeExePath) + ",\n"
    report = report + "  \"native_gui_runtime_launcher_exe_path\": " + r2cControllerJsonQuote(nativeRuntimeLauncherExePath) + ",\n"
    report = report + "  \"native_gui_runtime_compiled_exe_path\": " + r2cControllerJsonQuote(nativeRuntimeCompiledExePath) + ",\n"
    report = report + "  \"native_gui_runtime_contract_path\": " + r2cControllerJsonQuote(nativeRuntimeContractPath) + ",\n"
    report = report + "  \"native_gui_runtime_mode\": " + r2cControllerJsonQuote(nativeRuntimeMode) + ",\n"
    report = report + "  \"native_gui_runtime_item_source_mode\": \"typed_item_catalog_contract_v1\",\n"
    report = report + "  \"native_gui_runtime_typed_item_catalog_path\": " + nativeLayoutItemCatalogPathJson + ",\n"
    report = report + "  \"native_gui_runtime_typed_item_catalog_ready\": true,\n"
    report = report + "  \"native_gui_runtime_typed_item_catalog_payload_profile\": \"cheng_runtime_layout_item_payload_v1\",\n"
    report = report + "  \"native_gui_runtime_typed_item_catalog_item_count\": " + nativeLayoutCatalogItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_typed_item_catalog_viewport_item_count\": " + nativeLayoutCatalogViewportItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_route_state\": " + r2cControllerJsonQuote(nativeRuntimeBundleRouteState) + ",\n"
    report = report + "  \"native_gui_runtime_bundle_route_count\": " + nativeRuntimeBundleRouteCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_supported_count\": " + nativeRuntimeBundleSupportedCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_semantic_nodes_count\": " + nativeRuntimeBundleSemanticNodesCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_layout_item_count\": " + nativeRuntimeBundleLayoutItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_bundle_render_command_count\": " + nativeRuntimeBundleRenderCommandCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_layout_item_count\": " + nativeRuntimeContractLayoutItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_viewport_item_count\": " + nativeRuntimeContractViewportItemCountText + ",\n"
    report = report + "  \"native_gui_runtime_contract_interactive_item_count\": " + nativeRuntimeContractInteractiveItemCountText + ",\n"
    report = report + "  \"native_gui_host_abi_feature_hits\": " + r2cControllerJsonArrayFromCsv(hostAbiFeatureHitsCsv) + ",\n"
    report = report + "  \"native_gui_host_abi_first_batch_features\": " + r2cControllerJsonArrayFromCsv(hostAbiFirstBatchFeaturesCsv) + ",\n"
    report = report + "  \"native_gui_host_abi_first_batch_missing_features\": " + r2cControllerJsonArrayFromCsv(hostAbiFirstBatchMissingFeaturesCsv) + ",\n"
    if hostAbiFirstBatchReadyText == "true" || hostAbiFirstBatchReadyText == "false":
        report = report + "  \"native_gui_host_abi_first_batch_ready\": " + hostAbiFirstBatchReadyText + ",\n"
    else:
        report = report + "  \"native_gui_host_abi_first_batch_ready\": null,\n"
    if hostReadyText == "true" || hostReadyText == "false":
        report = report + "  \"native_gui_host_ready\": " + hostReadyText + ",\n"
    else:
        report = report + "  \"native_gui_host_ready\": null,\n"
    if rendererReadyText == "true" || rendererReadyText == "false":
        report = report + "  \"native_gui_renderer_ready\": " + rendererReadyText + ",\n"
    else:
        report = report + "  \"native_gui_renderer_ready\": null,\n"
    if sessionPreviewReadyText == "true" || sessionPreviewReadyText == "false":
        report = report + "  \"native_gui_session_preview_ready\": " + sessionPreviewReadyText + ",\n"
    else:
        report = report + "  \"native_gui_session_preview_ready\": null,\n"
    if layoutSurfaceReadyText == "true" || layoutSurfaceReadyText == "false":
        report = report + "  \"native_gui_layout_surface_ready\": " + layoutSurfaceReadyText + ",\n"
    else:
        report = report + "  \"native_gui_layout_surface_ready\": null,\n"
    if styleLayoutSurfaceReadyText == "true" || styleLayoutSurfaceReadyText == "false":
        report = report + "  \"native_gui_style_layout_surface_ready\": " + styleLayoutSurfaceReadyText + ",\n"
    else:
        report = report + "  \"native_gui_style_layout_surface_ready\": null,\n"
    if nativeLayoutPlanReadyText == "true" || nativeLayoutPlanReadyText == "false":
        report = report + "  \"native_gui_native_layout_plan_ready\": " + nativeLayoutPlanReadyText + ",\n"
    else:
        report = report + "  \"native_gui_native_layout_plan_ready\": null,\n"
    report = report + "  \"native_gui_render_plan_ready\": " + r2cControllerJsonBoolTextOrNull(nativeRenderPlanReadyText) + ",\n"
    report = report + "  \"native_gui_runtime_ready\": " + r2cControllerJsonBoolTextOrNull(nativeRuntimeReadyText) + ",\n"
    report = report + "  \"native_gui_runtime_bundle_ready\": " + r2cControllerJsonBoolTextOrNull(nativeRuntimeBundleReadyText) + ",\n"
    report = report + "  \"native_gui_runtime_contract_ready\": " + r2cControllerJsonBoolTextOrNull(nativeRuntimeContractReadyText) + "\n"
    report = report + "}\n"
    v3path.V3WriteTextFile("", reportPath, report)
    r2cControllerPrintLine(reportPath)
    return 0

fn r2cControllerRunNativeGui(root: str,
                             args: str[]): int32 =
    args
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let sessionFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--session-path", ""))
    let bundleFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--bundle-path", ""))
    let screenshotFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--screenshot-out", ""))
    let autoCloseMs: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--auto-close-ms", "1200"))
    let clickSpec: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--click", ""))
    let resizeSpec: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--resize", ""))
    let scrollY: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--scroll-y", ""))
    let waitAfterClickMs: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--wait-after-click-ms", ""))
    let focusItemId: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--focus-item-id", ""))
    let typeText: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--type-text", ""))
    let sendKey: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--send-key", ""))
    let routeStateFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--route-state", ""))
    let inspectorStateFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--inspector-state-out", ""))
    let openSourceOnClick: bool = cmdline.HasFlag("--open-source-on-click")
    let repo: str = v3path.V3PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = v3path.V3PathAbsolute(repo, outDirFlag)
    var scratchOk: bool = v3path.V3MkdirP("", outDir)
    scratchOk
    let experimentalRoot: str = v3path.V3PathAbsolute(effectiveRoot, "tools/r2c/experimental")
    let nativeGuiHostSourcePath: str = os.JoinPath(experimentalRoot, "native_gui_host_macos.m")
    let nativeGuiBundleSummaryPath: str = os.JoinPath(outDir, "native_gui_bundle.summary.env")
    let nativeGuiRunSummaryPath: str = os.JoinPath(outDir, "native_gui_run.summary.env")
    let reportPath: str = os.JoinPath(outDir, "native_gui_run_report_v1.json")
    let codegenSummaryPath: str = os.JoinPath(outDir, "codegen_surface.summary.env")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    var sessionPath: str = os.JoinPath(outDir, "native_gui_session_v1.json")
    var bundlePath: str = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    var screenshotPath: str = os.JoinPath(outDir, "native_gui_session.png")
    var inspectorStatePath: str = os.JoinPath(outDir, "native_gui_inspector_state_v1.json")
    if strings.Len(sessionFlag) > 0:
        sessionPath = v3path.V3PathAbsolute(outDir, sessionFlag)
    if strings.Len(bundleFlag) > 0:
        bundlePath = v3path.V3PathAbsolute(outDir, bundleFlag)
    if strings.Len(screenshotFlag) > 0:
        screenshotPath = v3path.V3PathAbsolute(outDir, screenshotFlag)
    if strings.Len(inspectorStateFlag) > 0:
        inspectorStatePath = v3path.V3PathAbsolute(outDir, inspectorStateFlag)
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)
    let bundleControllerPath: str = v3path.V3PathAbsolute(effectiveRoot, "artifacts/bootstrap/cheng.stage3")
    let bundleControllerLogPath: str = os.JoinPath(outDir, "native_gui_run.bundle_controller.log")
    let hasExplicitSession: bool = strings.Len(sessionFlag) > 0
    let hasExplicitBundle: bool = strings.Len(bundleFlag) > 0
    let useExplicitArtifacts: bool = hasExplicitSession &&
                                     hasExplicitBundle &&
                                     v3path.V3PathFileExists(sessionPath) &&
                                     v3path.V3PathFileExists(bundlePath)
    if !useExplicitArtifacts:
        if !v3path.V3PathFileExists(bundleControllerPath):
            r2cControllerPrintErr("r2c-react: missing stage3 controller for run-native-gui bundle: " + bundleControllerPath)
            return 1
        var bundleControllerArgs: str[]
        add(bundleControllerArgs, "r2c-react")
        add(bundleControllerArgs, "native-gui-bundle")
        add(bundleControllerArgs, "--repo")
        add(bundleControllerArgs, repo)
        add(bundleControllerArgs, "--out-dir")
        add(bundleControllerArgs, outDir)
        if strings.Len(routeStateFlag) > 0:
            add(bundleControllerArgs, "--route-state")
            add(bundleControllerArgs, routeStateFlag)
        if !r2cproc.r2cProcessRunProgramLogged(effectiveRoot,
                                               "r2c-react native-gui-bundle controller",
                                               bundleControllerPath,
                                               bundleControllerArgs,
                                               effectiveRoot,
                                               bundleControllerLogPath,
                                               helperExitCode,
                                               helperOutput):
            r2cControllerPrintErr("r2c-react: native gui bundle controller failed")
            if strings.Len(helperOutput) > 0:
                r2cControllerPrintErr(helperOutput)
            if helperExitCode != 0:
                return helperExitCode
            return 1
        sessionPath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_path", sessionPath)
        bundlePath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_bundle_path", bundlePath)
    if !v3path.V3PathFileExists(sessionPath):
        r2cControllerPrintErr("r2c-react: native gui run missing session: " + sessionPath)
        return 1
    if !v3path.V3PathFileExists(bundlePath):
        r2cControllerPrintErr("r2c-react: native gui run missing bundle: " + bundlePath)
        return 1

    if !v3path.V3PathFileExists(nativeGuiHostSourcePath):
        r2cControllerPrintErr("r2c-react: native gui host source missing: " + nativeGuiHostSourcePath)
        return 1

    let nativeGuiHostExePath: str = os.JoinPath(outDir, "native_gui_host_macos")
    let nativeGuiHostCompileLogPath: str = os.JoinPath(outDir, "native_gui_host_macos.compile.log")
    let nativeGuiRunLogPath: str = os.JoinPath(outDir, "native_gui_run.log")
    let nativeGuiHostRunFieldsPath: str = os.JoinPath(outDir, "native_gui_host_run.stdout.env")
    let runtimeRenderPlanPath: str = os.JoinPath(outDir, "native_render_plan_runtime_v1.json")
    let runtimeStateCapturePath: str = os.JoinPath(outDir, "native_gui_runtime_state_runtime_v1.json")
    let hitInspectorPath: str = os.JoinPath(outDir, "native_gui_hit_inspector_v1.json")
    if v3path.V3PathFileExists(nativeGuiHostExePath):
        os.RemoveFile(nativeGuiHostExePath)

    var nativeGuiHostCompileArgs: str[]
    add(nativeGuiHostCompileArgs, "--sdk")
    add(nativeGuiHostCompileArgs, "macosx")
    add(nativeGuiHostCompileArgs, "clang")
    add(nativeGuiHostCompileArgs, "-fobjc-arc")
    add(nativeGuiHostCompileArgs, "-fmodules")
    add(nativeGuiHostCompileArgs, "-framework")
    add(nativeGuiHostCompileArgs, "Cocoa")
    add(nativeGuiHostCompileArgs, nativeGuiHostSourcePath)
    add(nativeGuiHostCompileArgs, "-o")
    add(nativeGuiHostCompileArgs, nativeGuiHostExePath)
    var nativeGuiHostCompileRun = hostops.v3RunProgramLogged(effectiveRoot,
                                                             "r2c_native_gui_host_compile",
                                                             "xcrun",
                                                             nativeGuiHostCompileArgs,
                                                             [],
                                                             effectiveRoot,
                                                             120,
                                                             nativeGuiHostCompileLogPath)
    if nativeGuiHostCompileRun.exitCode == 127:
        nativeGuiHostCompileArgs = [
            "-fobjc-arc",
            "-fmodules",
            "-framework",
            "Cocoa",
            nativeGuiHostSourcePath,
            "-o",
            nativeGuiHostExePath
        ]
        nativeGuiHostCompileRun = hostops.v3RunProgramLogged(effectiveRoot,
                                                             "r2c_native_gui_host_compile",
                                                             "clang",
                                                             nativeGuiHostCompileArgs,
                                                             [],
                                                             effectiveRoot,
                                                             120,
                                                             nativeGuiHostCompileLogPath)
    if !hostops.v3LoggedRunOk(nativeGuiHostCompileRun):
        r2cControllerPrintErr("r2c-react: native gui host compile failed: " + hostops.v3LoggedRunSummary(nativeGuiHostCompileRun))
        if strings.Len(nativeGuiHostCompileRun.output) > 0:
            r2cControllerPrintErr(nativeGuiHostCompileRun.output)
        return nativeGuiHostCompileRun.exitCode
    let nativeGuiHostCompileLogText: str = r2cControllerLoggedCommandMetadata("r2c_native_gui_host_compile",
                                                                              nativeGuiHostCompileRun.filePath,
                                                                              nativeGuiHostCompileArgs,
                                                                              nativeGuiHostCompileRun.exitCode,
                                                                              nativeGuiHostCompileRun.output)
    if !v3path.V3FileExistsNonEmpty(effectiveRoot, nativeGuiHostCompileLogPath):
        if !v3path.V3WriteTextFile("", nativeGuiHostCompileLogPath, nativeGuiHostCompileLogText):
            r2cControllerPrintErr("r2c-react: native gui host compile log write failed: " + nativeGuiHostCompileLogPath)
            return 1
    if !v3path.V3PathFileExists(nativeGuiHostExePath):
        r2cControllerPrintErr("r2c-react: native gui host compile missing exe: " + nativeGuiHostExePath)
        return 1

    var nativeGuiHostRunArgs: str[]
    add(nativeGuiHostRunArgs, "--session")
    add(nativeGuiHostRunArgs, sessionPath)
    add(nativeGuiHostRunArgs, "--repo-root")
    add(nativeGuiHostRunArgs, repo)
    add(nativeGuiHostRunArgs, "--auto-close-ms")
    add(nativeGuiHostRunArgs, autoCloseMs)
    add(nativeGuiHostRunArgs, "--screenshot-out")
    add(nativeGuiHostRunArgs, screenshotPath)
    add(nativeGuiHostRunArgs, "--render-plan-out")
    add(nativeGuiHostRunArgs, runtimeRenderPlanPath)
    add(nativeGuiHostRunArgs, "--runtime-state-out")
    add(nativeGuiHostRunArgs, runtimeStateCapturePath)
    if strings.Len(clickSpec) > 0:
        add(nativeGuiHostRunArgs, "--click")
        add(nativeGuiHostRunArgs, clickSpec)
    if strings.Len(resizeSpec) > 0:
        add(nativeGuiHostRunArgs, "--resize")
        add(nativeGuiHostRunArgs, resizeSpec)
    if strings.Len(scrollY) > 0:
        add(nativeGuiHostRunArgs, "--scroll-y")
        add(nativeGuiHostRunArgs, scrollY)
    if strings.Len(waitAfterClickMs) > 0:
        add(nativeGuiHostRunArgs, "--wait-after-click-ms")
        add(nativeGuiHostRunArgs, waitAfterClickMs)
    if strings.Len(focusItemId) > 0:
        add(nativeGuiHostRunArgs, "--focus-item-id")
        add(nativeGuiHostRunArgs, focusItemId)
    if strings.Len(typeText) > 0:
        add(nativeGuiHostRunArgs, "--type-text")
        add(nativeGuiHostRunArgs, typeText)
    if strings.Len(sendKey) > 0:
        add(nativeGuiHostRunArgs, "--send-key")
        add(nativeGuiHostRunArgs, sendKey)
    if openSourceOnClick:
        add(nativeGuiHostRunArgs, "--open-source-on-click")
    var nativeGuiHostRunTimeoutSec: int32 = 30
    let autoCloseMsValue: int32 = r2cControllerParseInt32(autoCloseMs)
    let nativeGuiHostRunTimeoutCandidate: int32 = (autoCloseMsValue / 1000) + 15
    if nativeGuiHostRunTimeoutCandidate > nativeGuiHostRunTimeoutSec:
        nativeGuiHostRunTimeoutSec = nativeGuiHostRunTimeoutCandidate
    let nativeGuiHostRun = hostops.v3RunFileLogged(effectiveRoot,
                                                   "r2c_native_gui_host_run",
                                                   nativeGuiHostExePath,
                                                   nativeGuiHostRunArgs,
                                                   [],
                                                   effectiveRoot,
                                                   nativeGuiHostRunTimeoutSec,
                                                   nativeGuiRunLogPath)
    if !v3path.V3WriteTextFile("", nativeGuiHostRunFieldsPath, r2cControllerEnsureTrailingNewline(nativeGuiHostRun.output)):
        r2cControllerPrintErr("r2c-react: native gui host stdout write failed: " + nativeGuiHostRunFieldsPath)
        return 1
    if !hostops.v3LoggedRunOk(nativeGuiHostRun):
        r2cControllerPrintErr("r2c-react: native gui host run failed: " + hostops.v3LoggedRunSummary(nativeGuiHostRun))
        if strings.Len(nativeGuiHostRun.output) > 0:
            r2cControllerPrintErr(nativeGuiHostRun.output)
        return nativeGuiHostRun.exitCode
    if r2cControllerReadSummaryValue(nativeGuiHostRunFieldsPath, "format", "") != "native_gui_run_v1":
        r2cControllerPrintErr("r2c-react: native gui host run format mismatch: " + nativeGuiHostRunFieldsPath)
        return 1

    let bundleDocTextRaw: str = v3path.V3ReadTextFile("", bundlePath)
    let bundleLayoutSurfaceTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "layout_surface", "")
    let bundleStyleLayoutSurfaceTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "style_layout_surface", "")
    let bundleNativeLayoutPlanTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "native_layout_plan", "")
    let bundleNativeRenderPlanTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "native_render_plan", "")
    let bundleNativeRuntimeTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "native_runtime", "")
    let bundleSessionPreviewTextRaw: str = r2cControllerJsonReadObjectFieldRaw(bundleDocTextRaw, "session_preview", "")
    let sessionDocTextRaw: str = v3path.V3ReadTextFile("", sessionPath)
    let runtimeStateDocTextRaw: str = v3path.V3PathFileExists(runtimeStateCapturePath) ? v3path.V3ReadTextFile("", runtimeStateCapturePath) : ""
    let screenshotWrittenText: str = (r2cControllerReadSummaryValue(nativeGuiHostRunFieldsPath, "screenshot_written", "") == "true" &&
                                      v3path.V3PathFileExists(screenshotPath)) ? "true" : "false"
    let renderPlanReadyTextBuilt: str = (r2cControllerReadSummaryValue(nativeGuiHostRunFieldsPath, "render_plan_ready", "") == "true" &&
                                         v3path.V3PathFileExists(runtimeRenderPlanPath)) ? "true" : "false"

    var runtimeManifestReadyTextBuilt: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_manifest_ready", "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_manifest_ready"):
        runtimeManifestReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_manifest_ready", false))
    var runtimeContractPayloadReadyTextBuilt: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_payload_ready", "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_contract_payload_ready"):
        runtimeContractPayloadReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_contract_payload_ready", false))
    var runtimeBundlePayloadReadyTextBuilt: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_payload_ready", "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_bundle_payload_ready"):
        runtimeBundlePayloadReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_bundle_payload_ready", false))
    var runtimeBundleReadyTextBuilt: str = r2cControllerSummaryValueOrDocBoolText(nativeGuiBundleSummaryPath,
                                                                                 "native_gui_runtime_bundle_ready",
                                                                                 bundleNativeRuntimeTextRaw,
                                                                                 "",
                                                                                 "runtime_bundle_ready",
                                                                                 "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_bundle_ready"):
        runtimeBundleReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_bundle_ready", false))
    var runtimeContractReadyTextBuilt: str = r2cControllerSummaryValueOrDocBoolText(nativeGuiBundleSummaryPath,
                                                                                    "native_gui_runtime_contract_ready",
                                                                                    bundleNativeRuntimeTextRaw,
                                                                                    "",
                                                                                    "runtime_contract_ready",
                                                                                    "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "runtime_contract_ready"):
        runtimeContractReadyTextBuilt = r2cControllerJsonBool(r2cControllerJsonReadBoolField(runtimeStateDocTextRaw, "runtime_contract_ready", false))
    var runtimeBundleRouteStateBuilt: str = r2cControllerSummaryValueOrDocString(nativeGuiBundleSummaryPath,
                                                                                 "native_gui_runtime_bundle_route_state",
                                                                                 bundleNativeRuntimeTextRaw,
                                                                                 "",
                                                                                 "runtime_bundle_route_state",
                                                                                 "")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "bundle_route_state"):
        runtimeBundleRouteStateBuilt = r2cControllerJsonReadStringField(runtimeStateDocTextRaw, "bundle_route_state", "")
    var runtimeBundleRouteCountTextBuilt: str = r2cControllerSummaryValueOrDocIntText(nativeGuiBundleSummaryPath,
                                                                                      "native_gui_runtime_bundle_route_count",
                                                                                      bundleNativeRuntimeTextRaw,
                                                                                      "",
                                                                                      "runtime_bundle_route_count",
                                                                                      "0")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "bundle_route_count"):
        runtimeBundleRouteCountTextBuilt = intToStr(r2cControllerJsonReadIntField(runtimeStateDocTextRaw, "bundle_route_count", 0))
    var runtimeBundleSupportedCountTextBuilt: str = r2cControllerSummaryValueOrDocIntText(nativeGuiBundleSummaryPath,
                                                                                          "native_gui_runtime_bundle_supported_count",
                                                                                          bundleNativeRuntimeTextRaw,
                                                                                          "",
                                                                                          "runtime_bundle_supported_count",
                                                                                          "0")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "bundle_supported_count"):
        runtimeBundleSupportedCountTextBuilt = intToStr(r2cControllerJsonReadIntField(runtimeStateDocTextRaw, "bundle_supported_count", 0))
    var runtimeBundleSemanticNodesCountTextBuilt: str = r2cControllerSummaryValueOrDocIntText(nativeGuiBundleSummaryPath,
                                                                                              "native_gui_runtime_bundle_semantic_nodes_count",
                                                                                              bundleNativeRuntimeTextRaw,
                                                                                              "",
                                                                                              "runtime_bundle_semantic_nodes_count",
                                                                                              "0")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "bundle_semantic_nodes_count"):
        runtimeBundleSemanticNodesCountTextBuilt = intToStr(r2cControllerJsonReadIntField(runtimeStateDocTextRaw, "bundle_semantic_nodes_count", 0))
    var runtimeBundleLayoutItemCountTextBuilt: str = r2cControllerSummaryValueOrDocIntText(nativeGuiBundleSummaryPath,
                                                                                           "native_gui_runtime_bundle_layout_item_count",
                                                                                           bundleNativeRuntimeTextRaw,
                                                                                           "",
                                                                                           "runtime_bundle_layout_item_count",
                                                                                           "0")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "bundle_layout_item_count"):
        runtimeBundleLayoutItemCountTextBuilt = intToStr(r2cControllerJsonReadIntField(runtimeStateDocTextRaw, "bundle_layout_item_count", 0))
    var runtimeBundleRenderCommandCountTextBuilt: str = r2cControllerSummaryValueOrDocIntText(nativeGuiBundleSummaryPath,
                                                                                              "native_gui_runtime_bundle_render_command_count",
                                                                                              bundleNativeRuntimeTextRaw,
                                                                                              "",
                                                                                              "runtime_bundle_render_command_count",
                                                                                              "0")
    if r2cControllerJsonHasField(runtimeStateDocTextRaw, "bundle_render_command_count"):
        runtimeBundleRenderCommandCountTextBuilt = intToStr(r2cControllerJsonReadIntField(runtimeStateDocTextRaw, "bundle_render_command_count", 0))
    var runtimeContractLayoutItemCountTextBuilt: str = r2cControllerSummaryValueOrDocIntText(nativeGuiBundleSummaryPath,
                                                                                             "native_gui_runtime_contract_layout_item_count",
