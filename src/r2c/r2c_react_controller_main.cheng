    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + r2cControllerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"node_program\": \"node\",\n"
    report = report + "  \"helper_script\": " + r2cControllerJsonQuote(helperScript) + ",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": " + r2cControllerJsonQuote(logPath) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(artifactPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"truth_routes_v1\",\n"
    report = report + "  \"module_count\": 0,\n"
    report = report + "  \"route_count\": " + intToStr(routeCount) + ",\n"
    report = report + "  \"semantic_nodes_count\": 0,\n"
    report = report + "  \"asset_count\": 0,\n"
    report = report + "  \"tailwind_token_count\": 0,\n"
    report = report + "  \"required_host_group_count\": 0,\n"
    report = report + "  \"required_host_groups\": [],\n"
    report = report + "  \"rsg_node_count\": 0,\n"
    report = report + "  \"rsg_edge_count\": 0,\n"
    report = report + "  \"blocker_count\": 0,\n"
    report = report + "  \"blocked\": false,\n"
    report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(typescriptVersion) + "\n"
