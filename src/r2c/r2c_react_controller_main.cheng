fn r2cControllerTsxModuleShouldGenerate(moduleRaw: str,
                                        entryModule: str): bool =
    let pathText: str = r2cControllerJsonReadStringField(moduleRaw, "path", "")
    if pathText == entryModule:
        return true
    if r2cControllerJsonReadBoolField(moduleRaw, "jsx_like", false):
        return true
    if r2cControllerJsonArrayObjectCount(r2cControllerJsonReadArrayFieldRaw(moduleRaw, "components", "")) > 0:
        return true
    if r2cControllerJsonArrayObjectCount(r2cControllerJsonReadArrayFieldRaw(moduleRaw, "hook_calls", "")) > 0:
        return true
    if r2cControllerJsonArrayObjectCount(r2cControllerJsonReadArrayFieldRaw(moduleRaw, "jsx_elements", "")) > 0:
        return true
    return false

fn r2cControllerResolveEntryModuleFromTsx(tsxText: str): str =
    var moduleRaw: str
    if r2cControllerFindTsxModuleRaw(tsxText, "app/App.tsx", moduleRaw):
        return "app/App.tsx"
    if r2cControllerFindTsxModuleRaw(tsxText, "app/main.tsx", moduleRaw):
        return "app/main.tsx"
    if r2cControllerFindTsxModuleRaw(tsxText, "app/main.ts", moduleRaw):
        return "app/main.ts"
    let modulesRaw: str = r2cControllerJsonReadArrayFieldRaw(tsxText, "modules", "")
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    if r2cControllerJsonArrayNextObjectRaw(modulesRaw, cursor, itemRaw, nextPos):
        return r2cControllerJsonReadStringField(itemRaw, "path", "")
    return ""

fn r2cControllerCodegenRouteIdsJson(routeIds: str[]): str =
    var out = "[\n"
    for i in 0..<routeIds.len:
        if i > 0:
            out = out + ",\n"
        out = out + "    " + r2cControllerJsonQuote(routeIds[i])
    out = out + "\n  ]"
    return out

fn r2cControllerNormalizeRuntimeRoot(raw: str): str =
    let trimmed: str = chengpath.PathTrim(raw)
    var start: int32
    var end: int32 = strings.Len(trimmed)
    while start < end && (trimmed[start] == '/' || trimmed[start] == '\\'):
        start = start + 1
    while end > start && (trimmed[end - 1] == '/' || trimmed[end - 1] == '\\'):
        end = end - 1
    if start >= end:
        return "."
    var out = ""
    var i: int32 = start
    while i < end:
        let ch = trimmed[i]
        if ch == '\\':
            out = out + "/"
        else:
            out = out + strings.CharToStr(ch)
        i = i + 1
    if strings.Len(out) <= 0:
        return "."
    return out

fn r2cControllerAddUniqueString(items: var str[],
                                value: str) =
    for i in 0..<items.len:
        if items[i] == value:
            return
    add(items, value)

fn r2cControllerNormalizeRuntimeRoots(repo: str,
                                      requestedRoots: str[],
                                      out: var str[]): bool =
    if requestedRoots.len <= 0:
        r2cControllerAddUniqueString(out, "app")
    else:
        for i in 0..<requestedRoots.len:
            let rootValue: str = r2cControllerNormalizeRuntimeRoot(requestedRoots[i])
            r2cControllerAddUniqueString(out, rootValue)
    for i in 0..<out.len:
        if out[i] == ".":
            continue
        if !os.DirExists(os.JoinPath(repo, out[i])):
            r2cControllerPrintErr("r2c-react: missing runtime root: " + out[i])
            return false
    return true

fn r2cControllerPathUnderRoots(relPath: str,
                               roots: str[]): bool =
    for i in 0..<roots.len:
        let root = roots[i]
        if root == ".":
            return true
        if relPath == root:
            return true
        if chengpath.TextStartsWith(relPath, root + "/"):
            return true
    return false

fn r2cControllerKnownRouteSourceRelPaths(): str[] =
    var out: str[]
    add(out, "app/App.tsx")
    add(out, "app/components/HomePage.tsx")
    add(out, "app/home/routeState.ts")
    add(out, "app/publish/metadata.ts")
    return out

fn r2cControllerLineOfOffset(text: str,
                             offset: int32): int32 =
    var line: int32 = 1
    var i: int32
    let limit: int32 = offset < strings.Len(text) ? offset : strings.Len(text)
    while i < limit:
        if text[i] == char(10):
            line = line + 1
        i = i + 1
    return line

fn r2cControllerFindKnownRouteSource(repo: str,
                                     routeId: str,
                                     roots: str[],
                                     sourcePathOut: var str,
                                     lineOut: var int32): bool =
    let relPaths: str[] = r2cControllerKnownRouteSourceRelPaths()
    for i in 0..<relPaths.len:
        let relPath = relPaths[i]
        if !r2cControllerPathUnderRoots(relPath, roots):
            continue
        let fullPath: str = os.JoinPath(repo, relPath)
        if !chengpath.PathFileExists(fullPath):
            r2cControllerPrintErr("r2c-react: Cheng truth route discovery missing route source: " + fullPath)
            return false
        let text: str = chengpath.ReadTextFile("", fullPath)
        let offset: int32 = r2cControllerTextFind(text, routeId, 0)
        if offset >= 0:
            sourcePathOut = relPath
            lineOut = r2cControllerLineOfOffset(text, offset)
            return true
    return false

fn r2cControllerTypeScriptVersionFromRepo(repo: str): str =
    let packagePath: str = os.JoinPath(repo, "node_modules/typescript/package.json")
    if !chengpath.PathFileExists(packagePath):
        return ""
    let packageText: str = chengpath.ReadTextFile("", packagePath)
    return r2cControllerJsonReadStringField(packageText, "version", "")

fn r2cControllerStringArrayJsonInline(items: str[]): str =
    var out = "["
    for i in 0..<items.len:
        if i > 0:
            out = out + ", "
        out = out + r2cControllerJsonQuote(items[i])
    out = out + "]"
    return out

fn r2cControllerTsxFrontendFeatureNames(): str[] =
    var out: str[]
    add(out, "class_component")
    add(out, "error_boundary")
    add(out, "use_state")
    add(out, "use_effect")
    add(out, "use_memo")
    add(out, "use_callback")
    add(out, "use_ref")
    add(out, "use_context")
    add(out, "suspense")
    add(out, "memo")
    add(out, "strict_mode")
    add(out, "local_storage")
    add(out, "fetch")
    add(out, "resize_observer")
    add(out, "mutation_observer")
    add(out, "custom_event")
    add(out, "rtc")
    add(out, "media")
    add(out, "broadcast_channel")
    add(out, "worker")
    add(out, "webassembly")
    add(out, "capacitor")
    add(out, "zustand")
    add(out, "radix")
    add(out, "react_three")
    return out

fn r2cControllerTsxFrontendIsSourceExt(ext: str): bool =
    return ext == ".ts" || ext == ".tsx" || ext == ".js" || ext == ".jsx" || ext == ".mjs" || ext == ".cjs"

fn r2cControllerTsxFrontendIsAssetExt(ext: str): bool =
    return ext == ".png" || ext == ".jpg" || ext == ".jpeg" || ext == ".gif" ||
           ext == ".webp" || ext == ".svg" || ext == ".ico" || ext == ".woff" ||
           ext == ".woff2" || ext == ".ttf" || ext == ".otf" || ext == ".wasm" ||
           ext == ".mp3" || ext == ".wav" || ext == ".ogg" || ext == ".mp4" ||
           ext == ".webm" || ext == ".html" || ext == ".css" || ext == ".json"

fn r2cControllerTsxFrontendAssetKind(ext: str): str =
    if ext == ".png" || ext == ".jpg" || ext == ".jpeg" || ext == ".gif" ||
       ext == ".webp" || ext == ".svg" || ext == ".ico":
        return "image"
    if ext == ".woff" || ext == ".woff2" || ext == ".ttf" || ext == ".otf":
        return "font"
    if ext == ".wasm":
        return "wasm"
    if ext == ".mp3" || ext == ".wav" || ext == ".ogg":
        return "audio"
    if ext == ".mp4" || ext == ".webm":
        return "video"
    if ext == ".html":
        return "html"
    if ext == ".css":
        return "css"
    if ext == ".json":
        return "json"
    return "other"

fn r2cControllerTsxFrontendSkipDirName(name: str): bool =
    return name == "node_modules" || name == "dist" || name == "build" ||
           name == "artifacts" || name == ".git" || name == ".build" ||
           name == ".tmp-deploy"

fn r2cControllerTsxFrontendIsGeneratedPath(relPath: str): bool =
    return relPath == "pkg" || chengpath.TextStartsWith(relPath, "pkg/") ||
           chengpath.TextContains(relPath, "/pkg/") ||
           chengpath.TextStartsWith(relPath, "pkg\\") ||
           chengpath.TextContains(relPath, "_wasm.js") ||
           chengpath.TextContains(relPath, "_bg.js")

fn r2cControllerTsxFrontendIsTestPath(relPath: str): bool =
    return chengpath.TextContains(relPath, "/__tests__/") ||
           chengpath.TextStartsWith(relPath, "__tests__/") ||
           chengpath.TextContains(relPath, ".test.") ||
           chengpath.TextContains(relPath, ".spec.")

fn r2cControllerTsxFrontendShouldIncludeSource(relPath: str,
                                               ext: str): bool =
    if !r2cControllerTsxFrontendIsSourceExt(ext):
        return false
    if chengpath.TextContains(relPath, ".d.ts"):
        return false
    if r2cControllerTsxFrontendIsTestPath(relPath):
        return false
    return true

fn r2cControllerTsxFrontendSourceRootForPath(relPath: str,
                                             roots: str[]): str =
    for i in 0..<roots.len:
        let root = roots[i]
        if root == ".":
            return "."
        if relPath == root || chengpath.TextStartsWith(relPath, root + "/"):
            return root
    return ""

fn r2cControllerTsxFrontendAddSourceFile(repo: str,
                                         roots: str[],
                                         fullPath: str,
                                         out: var str[]) =
    let relPath = os.RelativePath(fullPath, repo)
    if !r2cControllerPathUnderRoots(relPath, roots):
        return
    let split = chengpath.PathSplitFile(relPath)
    if !r2cControllerTsxFrontendShouldIncludeSource(relPath, split.ext):
        return
    if r2cControllerTsxFrontendIsGeneratedPath(relPath):
        return
    r2cControllerAddUniqueString(out, fullPath)

fn r2cControllerTsxFrontendWalkSources(repo: str,
                                       roots: str[],
                                       current: str,
                                       out: var str[]) =
    let entries = os.WalkDir(current)
    for i in 0..<entries.len:
        let entry = os.WalkDirEntry(entries, i)
        let kind = os.WalkDirEntryKind(entry)
        let fullPath = os.WalkDirEntryPath(entry)
        let base = chengpath.PathBaseName(fullPath)
        if kind == os.PathComponent(1) || kind == os.PathComponent(3):
            if !r2cControllerTsxFrontendSkipDirName(base):
                r2cControllerTsxFrontendWalkSources(repo, roots, fullPath, out)
        elif kind == os.PathComponent(0) || kind == os.PathComponent(2):
            r2cControllerTsxFrontendAddSourceFile(repo, roots, fullPath, out)

fn r2cControllerTsxFrontendCollectSourceFiles(repo: str,
                                              roots: str[],
                                              out: var str[]) =
    for i in 0..<roots.len:
        let root = roots[i]
        var start = repo
        if root != ".":
            start = os.JoinPath(repo, root)
        if os.DirExists(start):
            r2cControllerTsxFrontendWalkSources(repo, roots, start, out)

fn r2cControllerTsxFrontendCountOccurrences(text: str,
                                            needle: str): int32 =
    var count: int32
    var cursor: int32
    while true:
        let pos = r2cControllerTextFind(text, needle, cursor)
        if pos < 0:
            break
        count = count + 1
        cursor = pos + strings.Len(needle)
    return count

fn r2cControllerTsxFrontendFeatureCount(text: str,
                                        featureName: str): int32 =
    if featureName == "class_component":
        return r2cControllerTsxFrontendCountOccurrences(text, "extends React.Component") +
               r2cControllerTsxFrontendCountOccurrences(text, "extends Component")
    if featureName == "error_boundary":
        return r2cControllerTsxFrontendCountOccurrences(text, "componentDidCatch") +
               r2cControllerTsxFrontendCountOccurrences(text, "getDerivedStateFromError")
    if featureName == "use_state": return r2cControllerTsxFrontendCountOccurrences(text, "useState")
    if featureName == "use_effect": return r2cControllerTsxFrontendCountOccurrences(text, "useEffect")
    if featureName == "use_memo": return r2cControllerTsxFrontendCountOccurrences(text, "useMemo")
    if featureName == "use_callback": return r2cControllerTsxFrontendCountOccurrences(text, "useCallback")
    if featureName == "use_ref": return r2cControllerTsxFrontendCountOccurrences(text, "useRef")
    if featureName == "use_context":
        return r2cControllerTsxFrontendCountOccurrences(text, "useContext") +
               r2cControllerTsxFrontendCountOccurrences(text, "createContext")
    if featureName == "suspense":
        return r2cControllerTsxFrontendCountOccurrences(text, "Suspense") +
               r2cControllerTsxFrontendCountOccurrences(text, "lazy(")
    if featureName == "memo": return r2cControllerTsxFrontendCountOccurrences(text, "memo(")
    if featureName == "strict_mode": return r2cControllerTsxFrontendCountOccurrences(text, "StrictMode")
    if featureName == "local_storage": return r2cControllerTsxFrontendCountOccurrences(text, "localStorage")
    if featureName == "fetch": return r2cControllerTsxFrontendCountOccurrences(text, "fetch")
    if featureName == "resize_observer": return r2cControllerTsxFrontendCountOccurrences(text, "ResizeObserver")
    if featureName == "mutation_observer": return r2cControllerTsxFrontendCountOccurrences(text, "MutationObserver")
    if featureName == "custom_event": return r2cControllerTsxFrontendCountOccurrences(text, "CustomEvent")
    if featureName == "rtc": return r2cControllerTsxFrontendCountOccurrences(text, "RTCPeerConnection")
    if featureName == "media":
        return r2cControllerTsxFrontendCountOccurrences(text, "getUserMedia") +
               r2cControllerTsxFrontendCountOccurrences(text, "MediaStream")
    if featureName == "broadcast_channel": return r2cControllerTsxFrontendCountOccurrences(text, "BroadcastChannel")
    if featureName == "worker": return r2cControllerTsxFrontendCountOccurrences(text, "Worker")
    if featureName == "webassembly": return r2cControllerTsxFrontendCountOccurrences(text, "WebAssembly")
    if featureName == "capacitor": return r2cControllerTsxFrontendCountOccurrences(text, "@capacitor/")
    if featureName == "zustand": return r2cControllerTsxFrontendCountOccurrences(text, "zustand")
    if featureName == "radix": return r2cControllerTsxFrontendCountOccurrences(text, "@radix-ui/")
    if featureName == "react_three":
        return r2cControllerTsxFrontendCountOccurrences(text, "@react-three/") +
               r2cControllerTsxFrontendCountOccurrences(text, "three")
    return 0

fn r2cControllerTsxFrontendLineStartsUpper(name: str): bool =
    if strings.Len(name) <= 0:
        return false
    let code = int32(name[0])
    return code >= int32(char(65)) && code <= int32(char(90))

fn r2cControllerTsxFrontendWhitespace(ch: char): bool =
    return ch == ' ' || ch == char(9) || ch == char(10) || ch == char(13)

fn r2cControllerTsxFrontendIdentifierChar(ch: char): bool =
    if r2cControllerAsciiIdentChar(ch):
        return true
    return ch == '_' || ch == '$'

fn r2cControllerTsxFrontendIdentifierAfter(line: str,
                                           marker: str): str =
    let pos = r2cControllerTextFind(line, marker, 0)
    if pos < 0:
        return ""
    var cursor = pos + strings.Len(marker)
    while cursor < strings.Len(line) && r2cControllerTsxFrontendWhitespace(line[cursor]):
        cursor = cursor + 1
    var out = ""
    while cursor < strings.Len(line) && r2cControllerTsxFrontendIdentifierChar(line[cursor]):
        out = out + strings.CharToStr(line[cursor])
        cursor = cursor + 1
    if !r2cControllerTsxFrontendLineStartsUpper(out):
        return ""
    return out

fn r2cControllerTsxFrontendAddComponentLine(relPath: str,
                                            lineText: str,
                                            lineNum: int32,
                                            keySeen: var str[],
                                            componentJson: var str,
                                            componentTsv: var str,
                                            componentCount: var int32) =
    var name = r2cControllerTsxFrontendIdentifierAfter(lineText, "function ")
    var kind = "function"
    if strings.Len(name) <= 0:
        name = r2cControllerTsxFrontendIdentifierAfter(lineText, "export function ")
        kind = "function"
    if strings.Len(name) <= 0:
        name = r2cControllerTsxFrontendIdentifierAfter(lineText, "const ")
        kind = "function"
    if strings.Len(name) <= 0:
        name = r2cControllerTsxFrontendIdentifierAfter(lineText, "export const ")
        kind = "function"
    if strings.Len(name) <= 0:
        name = r2cControllerTsxFrontendIdentifierAfter(lineText, "class ")
        kind = "class"
    if strings.Len(name) <= 0:
        name = r2cControllerTsxFrontendIdentifierAfter(lineText, "export class ")
        kind = "class"
    if strings.Len(name) <= 0:
        return
    let key = name + ":" + intToStr(lineNum)
    for i in 0..<keySeen.len:
        if keySeen[i] == key:
            return
    add(keySeen, key)
    if componentCount > 0:
        componentJson = componentJson + ", "
    componentJson = componentJson + "{\"name\":" + r2cControllerJsonQuote(name)
    componentJson = componentJson + ",\"kind\":" + r2cControllerJsonQuote(kind)
    componentJson = componentJson + ",\"line\":" + intToStr(lineNum) + "}"
    componentTsv = componentTsv + relPath + "\t" + name + "\t" + kind + "\t" + intToStr(lineNum) + "\n"
    componentCount = componentCount + 1

fn r2cControllerTsxFrontendAddClassTokens(raw: str,
                                          tokens: var str[]) =
    var start: int32
    var i: int32
    while i <= strings.Len(raw):
        let endHit = i == strings.Len(raw) || r2cControllerTsxFrontendWhitespace(raw[i])
        if !endHit:
            i = i + 1
            continue
        let count = i - start
        if count > 0:
            let token = chengpath.TextSlice(raw, start, count)
            r2cControllerAddUniqueString(tokens, token)
        start = i + 1
        i = i + 1

fn r2cControllerTsxFrontendCollectClassTokens(text: str,
                                              needle: str,
                                              quote: char,
                                              tokens: var str[]) =
    var cursor: int32
    while true:
        let pos = r2cControllerTextFind(text, needle, cursor)
        if pos < 0:
            break
        let start = pos + strings.Len(needle)
        var end = start
        while end < strings.Len(text) && text[end] != quote:
            end = end + 1
        if end > start:
            r2cControllerTsxFrontendAddClassTokens(chengpath.TextSlice(text, start, end - start), tokens)
        cursor = end + 1

fn r2cControllerTsxFrontendBlockers(relPath: str,
                                    text: str): str =
    var out = ""
    if r2cControllerTextFind(text, "eval(", 0) >= 0:
        out = out + relPath + "\t" + relPath + "\t1\t1\tjs_eval\n"
    if r2cControllerTextFind(text, "require(", 0) >= 0:
        out = out + relPath + "\t" + relPath + "\t1\t1\tjs_dynamic_require\n"
    if r2cControllerTextFind(text, "new Function", 0) >= 0:
        out = out + relPath + "\t" + relPath + "\t1\t1\tjs_new_function\n"
    if r2cControllerTextFind(text, "new Proxy", 0) >= 0:
        out = out + relPath + "\t" + relPath + "\t1\t1\tjs_proxy\n"
    if r2cControllerTextFind(text, "with (", 0) >= 0:
        out = out + relPath + "\t" + relPath + "\t1\t1\tjs_with_statement\n"
    if r2cControllerTextFind(text, "module.exports", 0) >= 0:
        out = out + relPath + "\t" + relPath + "\t1\t1\tjs_cjs_exports\n"
    if r2cControllerTextFind(text, "__proto__", 0) >= 0 ||
       r2cControllerTextFind(text, ".prototype =", 0) >= 0:
        out = out + relPath + "\t" + relPath + "\t1\t1\tjs_prototype_mutation\n"
    return out

fn r2cControllerTsxFrontendWriteFeedFiles(outDir: str,
                                          repo: str,
                                          roots: str[],
                                          tsVersion: str,
                                          moduleCount: int32,
                                          moduleLines: str,
                                          featureLines: str,
                                          componentLines: str,
                                          blockerLines: str,
                                          tailwindLines: str,
                                          discoveredAssetLines: str): bool =
    let sourceRootsCsv = strutil.Join(roots, ",")
    let metaPath = os.JoinPath(outDir, "tsx_surface_meta_v1.env")
    var meta = ""
    meta = meta + "format=tsx_surface_feed_v1\n"
    meta = meta + "repo_root=" + repo + "\n"
    meta = meta + "source_roots=" + sourceRootsCsv + "\n"
    meta = meta + "typescript_version=" + tsVersion + "\n"
    meta = meta + "module_count=" + intToStr(moduleCount) + "\n"
    if !chengpath.WriteTextFile("", metaPath, meta): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_modules_v1.tsv"), moduleLines): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_feature_counts_v1.tsv"), featureLines): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_static_imports_v1.tsv"), ""): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_dynamic_imports_v1.tsv"), ""): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_asset_refs_v1.tsv"), ""): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_components_v1.tsv"), componentLines): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_blockers_v1.tsv"), blockerLines): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_tailwind_tokens_v1.tsv"), tailwindLines): return false
    if !chengpath.WriteTextFile("", os.JoinPath(outDir, "tsx_surface_discovered_assets_v1.tsv"), discoveredAssetLines): return false
    return true

fn r2cControllerTsxFrontendCollectDiscoveredAssets(repo: str,
                                                   roots: str[]): str =
    var assetRoots: str[]
    for i in 0..<roots.len:
        r2cControllerAddUniqueString(assetRoots, roots[i])
    r2cControllerAddUniqueString(assetRoots, "public")
    r2cControllerAddUniqueString(assetRoots, "styles")
    var out = ""
    for i in 0..<assetRoots.len:
        let root = assetRoots[i]
        var start = repo
        if root != ".":
            start = os.JoinPath(repo, root)
        if !os.DirExists(start):
            continue
        let entries = os.WalkDirRec(start)
        for j in 0..<entries.len:
            let entry = os.WalkDirEntry(entries, j)
            let kind = os.WalkDirEntryKind(entry)
            if kind != os.PathComponent(0) && kind != os.PathComponent(2):
                continue
            let fullPath = os.WalkDirEntryPath(entry)
            let relPath = os.RelativePath(fullPath, repo)
            let split = chengpath.PathSplitFile(relPath)
            if r2cControllerTsxFrontendIsAssetExt(split.ext) && !r2cControllerTsxFrontendIsSourceExt(split.ext):
                out = out + relPath + "\t" + r2cControllerTsxFrontendAssetKind(split.ext) + "\n"
    return out

fn r2cControllerFlag01(value: bool): str =
    if value:
        return "1"
    return "0"

fn r2cControllerTsxFrontendComponentsForText(relPath: str,
                                             text: str,
                                             componentJson: var str,
                                             componentLines: var str) =
    componentJson = ""
    componentLines = ""
    var componentSeen: str[]
    var componentCount: int32
    let lines = strutil.Split(text, char(10))
    for lineIndex in 0..<lines.len:
        r2cControllerTsxFrontendAddComponentLine(relPath,
                                                 lines[lineIndex],
                                                 lineIndex + 1,
                                                 componentSeen,
                                                 componentJson,
                                                 componentLines,
                                                 componentCount)

fn r2cControllerTsxFrontendCollectAllClassTokens(text: str,
                                                 classTokens: var str[]) =
    r2cControllerTsxFrontendCollectClassTokens(text, "className=\"", char(34), classTokens)
    r2cControllerTsxFrontendCollectClassTokens(text, "class=\"", char(34), classTokens)
    r2cControllerTsxFrontendCollectClassTokens(text, "className='", char(39), classTokens)
    r2cControllerTsxFrontendCollectClassTokens(text, "class='", char(39), classTokens)

fn r2cControllerTsxFrontendClassTokenLines(relPath: str,
                                           classTokens: str[]): str =
    var out = ""
    for tokenIndex in 0..<classTokens.len:
        out = out + relPath + "\t" + classTokens[tokenIndex] + "\n"
    return out

fn r2cControllerTsxFrontendFeatureJson(relPath: str,
                                       text: str,
                                       featureNames: str[],
                                       featureLines: var str): str =
    featureLines = ""
    var out = "{"
    for featureIndex in 0..<featureNames.len:
        let featureName = featureNames[featureIndex]
        let count = r2cControllerTsxFrontendFeatureCount(text, featureName)
        if featureIndex > 0:
            out = out + ","
        out = out + r2cControllerJsonQuote(featureName) + ":" + intToStr(count)
        if count > 0:
            featureLines = featureLines + relPath + "\t" + featureName + "\t" + intToStr(count) + "\n"
    out = out + "}"
    return out

fn r2cControllerTsxFrontendModuleJson(relPath: str,
                                      ext: str,
                                      runtimeRoot: str,
                                      generated: bool,
                                      jsxLike: bool,
                                      featureJson: str,
                                      componentJson: str,
                                      classTokens: str[],
                                      exportCount: int32): str =
    var out = "  {"
    out = out + "\"path\":" + r2cControllerJsonQuote(relPath)
    out = out + ",\"hash\":\"\""
    out = out + ",\"ext\":" + r2cControllerJsonQuote(ext)
    out = out + ",\"runtime_root\":" + r2cControllerJsonQuote(runtimeRoot)
    out = out + ",\"generated\":" + r2cControllerJsonBool(generated)
    out = out + ",\"jsx_like\":" + r2cControllerJsonBool(jsxLike)
    out = out + ",\"static_imports\":[]"
    out = out + ",\"dynamic_imports\":[]"
    out = out + ",\"asset_refs\":[]"
    out = out + ",\"features\":{}"
    out = out + ",\"feature_counts\":" + featureJson
    out = out + ",\"components\":[" + componentJson + "]"
    out = out + ",\"blockers\":[]"
    out = out + ",\"imports\":[]"
    out = out + ",\"hook_calls\":[]"
    out = out + ",\"jsx_elements\":[]"
    out = out + ",\"tailwind_class_tokens\":" + r2cControllerStringArrayJsonInline(classTokens)
    out = out + ",\"tailwind_class_token_count\":" + intToStr(classTokens.len)
    out = out + ",\"export_count\":" + intToStr(exportCount)
    out = out + "}"
    return out

fn r2cControllerTsxFrontendAppendModule(repo: str,
                                        runtimeRoots: str[],
                                        featureNames: str[],
                                        fullPath: str,
                                        accum: var R2cTsxFrontendSeedAccum) =
    let relPath = os.RelativePath(fullPath, repo)
    let split = chengpath.PathSplitFile(relPath)
    let text = chengpath.ReadTextFile("", fullPath)
    let generated = r2cControllerTsxFrontendIsGeneratedPath(relPath)
    let jsxLike = split.ext == ".tsx" || split.ext == ".jsx" ||
                  r2cControllerTextFind(text, "<", 0) >= 0
    let exportCount = r2cControllerTsxFrontendCountOccurrences(text, "export ")
    var componentJson = ""
    var componentLines = ""
    r2cControllerTsxFrontendComponentsForText(relPath, text, componentJson, componentLines)
    var classTokens: str[]
    r2cControllerTsxFrontendCollectAllClassTokens(text, classTokens)
    var featureLines = ""
    let featureJson = r2cControllerTsxFrontendFeatureJson(relPath, text, featureNames, featureLines)
    accum.componentLines = accum.componentLines + componentLines
    accum.tailwindLines = accum.tailwindLines + r2cControllerTsxFrontendClassTokenLines(relPath, classTokens)
    accum.featureLines = accum.featureLines + featureLines
    accum.blockerLines = accum.blockerLines + r2cControllerTsxFrontendBlockers(relPath, text)
    accum.moduleLines = accum.moduleLines + relPath + "\t" + r2cControllerFlag01(generated) + "\t" +
                        r2cControllerFlag01(jsxLike) + "\t" + intToStr(exportCount) + "\n"
    if accum.moduleCount > 0:
        accum.modulesJson = accum.modulesJson + ",\n"
    accum.modulesJson = accum.modulesJson + r2cControllerTsxFrontendModuleJson(relPath,
                                                                               split.ext,
                                                                               r2cControllerTsxFrontendSourceRootForPath(relPath, runtimeRoots),
                                                                               generated,
                                                                               jsxLike,
                                                                               featureJson,
                                                                               componentJson,
                                                                               classTokens,
                                                                               exportCount)
    accum.moduleCount = accum.moduleCount + 1

fn r2cControllerWriteChengTsxFrontendSeed(effectiveRoot: str,
                                          repo: str,
                                          outDir: str,
                                          requestedRuntimeRoots: str[],
                                          artifactPath: str,
                                          summaryPath: str,
                                          reportPath: str): bool =
    if !os.DirExists(repo):
        r2cControllerPrintErr("r2c-react: missing repo: " + repo)
        return false
    if !chengpath.MkdirP("", outDir):
        r2cControllerPrintErr("r2c-react: Cheng TSX frontend failed to create out dir: " + outDir)
        return false
    var runtimeRoots: str[]
    if !r2cControllerNormalizeRuntimeRoots(repo, requestedRuntimeRoots, runtimeRoots):
        return false
    var sourceFiles: str[]
    r2cControllerTsxFrontendCollectSourceFiles(repo, runtimeRoots, sourceFiles)
    if sourceFiles.len <= 0:
        r2cControllerPrintErr("r2c-react: Cheng TSX frontend found no source files")
        return false
    let tsVersion = r2cControllerTypeScriptVersionFromRepo(repo)
    let featureNames = r2cControllerTsxFrontendFeatureNames()
    var accum: R2cTsxFrontendSeedAccum
    accum.modulesJson = "[\n"
    for i in 0..<sourceFiles.len:
        r2cControllerTsxFrontendAppendModule(repo, runtimeRoots, featureNames, sourceFiles[i], accum)
    accum.modulesJson = accum.modulesJson + "\n]"
    let discoveredAssetLines = r2cControllerTsxFrontendCollectDiscoveredAssets(repo, runtimeRoots)
    if !r2cControllerTsxFrontendWriteFeedFiles(outDir,
                                               repo,
                                               runtimeRoots,
                                               tsVersion,
                                               accum.moduleCount,
                                               accum.moduleLines,
                                               accum.featureLines,
                                               accum.componentLines,
                                               accum.blockerLines,
                                               accum.tailwindLines,
                                               discoveredAssetLines):
        r2cControllerPrintErr("r2c-react: Cheng TSX frontend failed to write feed files")
        return false
    var doc = "{\n"
    doc = doc + "  \"format\": \"tsx_ast_v1\",\n"
    doc = doc + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    doc = doc + "  \"source_roots\": " + r2cControllerStringArrayJsonInline(runtimeRoots) + ",\n"
    doc = doc + "  \"typescript_version\": " + r2cControllerJsonQuote(tsVersion) + ",\n"
    doc = doc + "  \"frontend_mode\": \"cheng.tsx_frontend_seed_v1\",\n"
    doc = doc + "  \"modules\": " + accum.modulesJson + "\n"
    doc = doc + "}\n"
    if !chengpath.WriteTextFile("", artifactPath, doc):
        r2cControllerPrintErr("r2c-react: Cheng TSX frontend failed to write artifact: " + artifactPath)
        return false
    var summary = ""
    summary = summary + "format=tsx_ast_v1\n"
    summary = summary + "repo_root=" + repo + "\n"
    summary = summary + "source_roots=" + strutil.Join(runtimeRoots, ",") + "\n"
    summary = summary + "typescript_version=" + tsVersion + "\n"
    summary = summary + "module_count=" + intToStr(accum.moduleCount) + "\n"
    summary = summary + "frontend_mode=cheng.tsx_frontend_seed_v1\n"
    summary = summary + "out_path=" + artifactPath + "\n"
    if !chengpath.WriteTextFile("", summaryPath, summary):
        r2cControllerPrintErr("r2c-react: Cheng TSX frontend failed to write summary: " + summaryPath)
        return false
    if strings.Len(reportPath) > 0:
        var report = "{\n"
        report = report + "  \"format\": \"controller_report_v1\",\n"
        report = report + "  \"controller\": \"cheng.live_controller\",\n"
        report = report + "  \"command\": \"frontend\",\n"
        report = report + "  \"ok\": true,\n"
        report = report + "  \"reason\": \"ok\",\n"
        report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
        report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
        report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
        report = report + "  \"frontend_mode\": \"cheng.tsx_frontend_seed_v1\",\n"
        report = report + "  \"helper_script\": \"\",\n"
        report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
        report = report + "  \"helper_log_path\": \"\",\n"
        report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(artifactPath) + ",\n"
        report = report + "  \"primary_artifact_format\": \"tsx_ast_v1\",\n"
        report = report + "  \"module_count\": " + intToStr(accum.moduleCount) + ",\n"
        report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(tsVersion) + "\n"
        report = report + "}\n"
        if !chengpath.WriteTextFile("", reportPath, report):
            r2cControllerPrintErr("r2c-react: Cheng TSX frontend failed to write report: " + reportPath)
            return false
    return true

fn r2cControllerJsonRouteIdsFromTruthRoutes(truthRoutesText: str,
                                            out: var str[]): bool =
    if r2cControllerJsonReadStringField(truthRoutesText, "format", "") != "truth_routes_v1":
        r2cControllerPrintErr("r2c-react: unsupported truth routes format")
        return false
    let routesRaw: str = r2cControllerJsonReadArrayFieldRaw(truthRoutesText, "routes", "")
    if strings.Len(routesRaw) <= 0:
        r2cControllerPrintErr("r2c-react: truth routes missing routes[]")
        return false
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(routesRaw, cursor, itemRaw, nextPos):
        cursor = nextPos
        var routeId: str = r2cControllerJsonReadStringField(itemRaw, "routeId", "")
        if strings.Len(routeId) <= 0:
            routeId = r2cControllerJsonReadStringField(itemRaw, "route_id", "")
        if strings.Len(routeId) > 0:
            r2cControllerAddUniqueString(out, routeId)
    if out.len <= 0:
        r2cControllerPrintErr("r2c-react: truth routes contained no route ids")
        return false
    return true

fn r2cControllerOrderedRouteIds(entryRoute: str,
                                routeIds: str[]): str[] =
    var out: str[]
    if strings.Len(entryRoute) > 0:
        r2cControllerAddUniqueString(out, entryRoute)
    for i in 0..<routeIds.len:
        r2cControllerAddUniqueString(out, routeIds[i])
    return out

fn r2cControllerRouteCatalogEntryRaw(routeCatalogText: str,
                                     routeId: str,
                                     out: var str): bool =
    let entriesRaw: str = r2cControllerJsonReadArrayFieldRaw(routeCatalogText, "entries", "")
    if strings.Len(entriesRaw) <= 0:
        return false
    var entryRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(entriesRaw, cursor, entryRaw, nextPos):
        cursor = nextPos
        if r2cControllerJsonReadStringField(entryRaw, "routeId", "") == routeId:
            out = entryRaw
            return true
    return false

fn r2cControllerRouteCatalogCandidateCount(entryRaw: str): int32 =
    let candidatesRaw: str = r2cControllerJsonReadArrayFieldRaw(entryRaw, "candidates", "")
    if strings.Len(candidatesRaw) <= 0:
        return 0
    return r2cControllerJsonArrayObjectCount(candidatesRaw)

fn r2cControllerRouteCatalogFirstCandidateCount(entryRaw: str,
                                                fallback: int32): int32 =
    let candidatesRaw: str = r2cControllerJsonReadArrayFieldRaw(entryRaw, "candidates", "")
    var candidateRaw: str
    var cursor: int32
    var nextPos: int32
    if r2cControllerJsonArrayNextObjectRaw(candidatesRaw, cursor, candidateRaw, nextPos):
        let count: int32 = r2cControllerJsonReadIntField(candidateRaw, "semanticNodesCount", 0)
        if count > 0:
            return count
    let directCount: int32 = r2cControllerJsonReadIntField(entryRaw, "semanticNodesCount", 0)
    if directCount > 0:
        return directCount
    return fallback

fn r2cControllerRouteCatalogFirstReason(entryRaw: str,
                                        fallback: str): str =
    let candidatesRaw: str = r2cControllerJsonReadArrayFieldRaw(entryRaw, "candidates", "")
    var candidateRaw: str
    var cursor: int32
    var nextPos: int32
    if r2cControllerJsonArrayNextObjectRaw(candidatesRaw, cursor, candidateRaw, nextPos):
        let reason: str = r2cControllerJsonReadStringField(candidateRaw, "reason", "")
        if strings.Len(reason) > 0:
            return reason
    let directReason: str = r2cControllerJsonReadStringField(entryRaw, "reason", "")
    if strings.Len(directReason) > 0:
        return directReason
    return fallback

fn r2cControllerExecRouteSnapshotJson(routeId: str,
                                      semanticNodesCount: int32,
                                      sourceSnapshotText: str): str =
    var renderReady = true
    var semanticNodesLoaded = semanticNodesCount > 0
    if strings.Len(sourceSnapshotText) > 0:
        renderReady = r2cControllerJsonReadBoolField(sourceSnapshotText, "render_ready", renderReady)
        semanticNodesLoaded = r2cControllerJsonReadBoolField(sourceSnapshotText, "semantic_nodes_loaded", semanticNodesLoaded)
    var rootNodeCount: int32
    if semanticNodesCount > 0:
        rootNodeCount = 1
    var out = "{"
    out = out + "\"format\":\"cheng_codegen_exec_snapshot_v1\","
    out = out + "\"route_state\":" + r2cControllerJsonQuote(routeId) + ","
    out = out + "\"render_ready\":" + r2cControllerJsonBool(renderReady) + ","
    out = out + "\"semantic_nodes_loaded\":" + r2cControllerJsonBool(semanticNodesLoaded) + ","
    out = out + "\"semantic_nodes_count\":" + intToStr(semanticNodesCount) + ","
    out = out + "\"tree_node_count\":" + intToStr(semanticNodesCount) + ","
    out = out + "\"root_node_count\":"
    out = out + intToStr(rootNodeCount)
    out = out + ","
    out = out + "\"element_node_count\":" + intToStr(semanticNodesCount)
    out = out + "}"
    return out

fn r2cControllerTruthCountForRoute(truthTraceText: str,
                                   routeId: str,
                                   known: var bool,
                                   count: var int32): bool =
    known = false
    count = 0
    if strings.Len(truthTraceText) <= 0:
        return true
    let format: str = r2cControllerJsonReadStringField(truthTraceText, "format", "")
    if format != "truth_trace_v2" && format != "r2c-truth-trace-v1":
        r2cControllerPrintErr("r2c-react: exec-route-matrix unsupported truth trace format: " + format)
        return false
    var matched: R2cTruthSnapshotMatch
    if !r2cControllerFindTruthSnapshotMatch(truthTraceText, routeId, matched):
        return false
    if matched.found && matched.semanticNodesCountKnown:
        known = true
        count = matched.semanticNodesCount
    return true

fn r2cControllerWriteChengExecRouteMatrixSeed(effectiveRoot: str,
                                              outDir: str,
                                              execSnapshotPath: str,
                                              truthRoutesPath: str,
                                              routeCatalogPath: str,
                                              tsxAstPath: str,
                                              codegenManifestPath: str,
                                              truthTracePath: str,
                                              execRouteMatrixPath: str,
                                              summaryPath: str,
                                              reportPath: str): bool =
    if !chengpath.PathFileExists(execSnapshotPath) ||
       !chengpath.PathFileExists(truthRoutesPath):
        r2cControllerPrintErr("r2c-react: Cheng exec route matrix missing required input")
        return false
    let execSnapshotText: str = chengpath.ReadTextFile("", execSnapshotPath)
    if r2cControllerJsonReadStringField(execSnapshotText, "format", "") != "cheng_codegen_exec_snapshot_v1":
        r2cControllerPrintErr("r2c-react: Cheng exec route matrix unsupported exec snapshot format")
        return false
    let truthRoutesText: str = chengpath.ReadTextFile("", truthRoutesPath)
    var routeIds: str[]
    if !r2cControllerJsonRouteIdsFromTruthRoutes(truthRoutesText, routeIds):
        return false
    var routeCatalogText = ""
    var routeCatalogReady = false
    if strings.Len(routeCatalogPath) > 0:
        if !chengpath.PathFileExists(routeCatalogPath):
            r2cControllerPrintErr("r2c-react: Cheng exec route matrix missing route catalog: " + routeCatalogPath)
            return false
        routeCatalogText = chengpath.ReadTextFile("", routeCatalogPath)
        if r2cControllerJsonReadStringField(routeCatalogText, "format", "") != "cheng_codegen_route_catalog_v1":
            r2cControllerPrintErr("r2c-react: Cheng exec route matrix unsupported route catalog format")
            return false
        routeCatalogReady = true
    elif strings.Len(tsxAstPath) > 0:
        if !chengpath.PathFileExists(tsxAstPath):
            r2cControllerPrintErr("r2c-react: Cheng exec route matrix missing tsx ast: " + tsxAstPath)
            return false
        let tsxText: str = chengpath.ReadTextFile("", tsxAstPath)
        if r2cControllerJsonReadStringField(tsxText, "format", "") != "tsx_ast_v1":
            r2cControllerPrintErr("r2c-react: Cheng exec route matrix unsupported tsx ast format")
            return false
    else:
        r2cControllerPrintErr("r2c-react: Cheng exec route matrix requires route catalog or tsx ast")
        return false
    if strings.Len(codegenManifestPath) > 0:
        if !chengpath.PathFileExists(codegenManifestPath):
            r2cControllerPrintErr("r2c-react: Cheng exec route matrix missing codegen manifest: " + codegenManifestPath)
            return false
        let manifestText: str = chengpath.ReadTextFile("", codegenManifestPath)
        if r2cControllerJsonReadStringField(manifestText, "format", "") != "cheng_codegen_v1":
            r2cControllerPrintErr("r2c-react: Cheng exec route matrix unsupported codegen manifest format")
            return false
    var truthTraceText = ""
    if strings.Len(truthTracePath) > 0:
        if !chengpath.PathFileExists(truthTracePath):
            r2cControllerPrintErr("r2c-react: Cheng exec route matrix missing truth trace: " + truthTracePath)
            return false
        truthTraceText = chengpath.ReadTextFile("", truthTracePath)
        let traceFormat: str = r2cControllerJsonReadStringField(truthTraceText, "format", "")
        if traceFormat != "truth_trace_v2" && traceFormat != "r2c-truth-trace-v1":
            r2cControllerPrintErr("r2c-react: Cheng exec route matrix unsupported truth trace format: " + traceFormat)
            return false

    var entryRoute: str = r2cControllerJsonReadStringField(routeCatalogText, "entryRouteState", "")
    if strings.Len(entryRoute) <= 0:
        entryRoute = r2cControllerJsonReadStringField(execSnapshotText, "route_state", "")
    let execSnapshotRouteState: str = r2cControllerJsonReadStringField(execSnapshotText, "route_state", "")
    let ordered: str[] = r2cControllerOrderedRouteIds(entryRoute, routeIds)
    let snapshotRoot: str = os.JoinPath(outDir, "route_runtime_snapshots")
    if !chengpath.MkdirP("", snapshotRoot):
        r2cControllerPrintErr("r2c-react: Cheng exec route matrix failed to create snapshot dir")
        return false
    var entriesJson = "[\n"
    var supportedCount: int32
    var unsupportedCount: int32
    var lastSnapshotPath = ""
    for i in 0..<ordered.len:
        let routeId = ordered[i]
        var entryRaw = ""
        var routeCatalogEntryFound = false
        var routeSupported = true
        var reason = "cheng_exec_route_matrix_seed_v1"
        var semanticCount = r2cControllerKnownRouteSemanticCount(routeId)
        if routeCatalogReady:
            routeCatalogEntryFound = r2cControllerRouteCatalogEntryRaw(routeCatalogText, routeId, entryRaw)
            if !routeCatalogEntryFound:
                routeSupported = false
                reason = "missing_route_catalog_entry"
            else:
                routeSupported = r2cControllerJsonReadBoolField(entryRaw, "supported", false)
                reason = r2cControllerRouteCatalogFirstReason(entryRaw, reason)
                semanticCount = r2cControllerRouteCatalogFirstCandidateCount(entryRaw, semanticCount)
                if routeId != entryRoute && r2cControllerRouteCatalogCandidateCount(entryRaw) <= 0:
                    routeSupported = false
                    reason = "missing_route_catalog_candidate"
        if routeId == entryRoute && (!routeCatalogReady || semanticCount <= 0):
            let entryCount: int32 = r2cControllerJsonReadIntField(execSnapshotText, "semantic_nodes_count", 0)
            if entryCount > 0:
                semanticCount = entryCount
        var truthKnown = false
        var truthCount: int32
        if !r2cControllerTruthCountForRoute(truthTraceText, routeId, truthKnown, truthCount):
            return false
        if routeSupported && routeId != entryRoute:
            if strings.Len(truthTraceText) <= 0:
                routeSupported = false
                reason = reason + "_needs_truth_check"
            elif !truthKnown:
                routeSupported = false
                reason = "missing_truth_state"
            elif semanticCount != truthCount:
                routeSupported = false
                reason = reason + "_truth_count_miss_" + intToStr(truthCount)
        if i > 0:
            entriesJson = entriesJson + ",\n"
        let snapshotSourceText: str = routeSupported && execSnapshotRouteState == routeId ? execSnapshotText : ""
        let snapshotText: str = r2cControllerExecRouteSnapshotJson(routeId,
                                                                   routeSupported ? semanticCount : 0,
                                                                   snapshotSourceText)
        var snapshotPath = ""
        if routeSupported:
            snapshotPath = os.JoinPath(snapshotRoot, "route_" + intToStr(i) + "__candidate_0.json")
            if !chengpath.WriteTextFile("", snapshotPath, snapshotText):
                r2cControllerPrintErr("r2c-react: Cheng exec route matrix failed to write route snapshot")
                return false
            lastSnapshotPath = snapshotPath
            supportedCount = supportedCount + 1
        else:
            unsupportedCount = unsupportedCount + 1
        entriesJson = entriesJson + "    {\n"
        entriesJson = entriesJson + "      \"routeId\": " + r2cControllerJsonQuote(routeId) + ",\n"
        entriesJson = entriesJson + "      \"supported\": " + r2cControllerJsonBool(routeSupported) + ",\n"
        entriesJson = entriesJson + "      \"reason\": " + r2cControllerJsonQuote(reason) + ",\n"
        entriesJson = entriesJson + "      \"snapshotPath\": " + r2cControllerJsonQuote(snapshotPath) + ",\n"
        entriesJson = entriesJson + "      \"snapshot\": " + snapshotText + "\n"
        entriesJson = entriesJson + "    }"
    entriesJson = entriesJson + "\n  ]"
    let runnerMode: str = routeCatalogReady ? r2cControllerJsonReadStringField(routeCatalogText, "runnerMode", "react_surface_runner_v1") : "react_surface_runner_v1"
    let routeMatrixOk: bool = unsupportedCount == 0
    let routeMatrixReason: str = routeMatrixOk ? "ok" : "unsupported_exec_routes"
    var doc = "{\n"
    doc = doc + "  \"format\": \"cheng_codegen_exec_route_matrix_v1\",\n"
    doc = doc + "  \"runnerMode\": " + r2cControllerJsonQuote(runnerMode) + ",\n"
    doc = doc + "  \"entryRouteState\": " + r2cControllerJsonQuote(entryRoute) + ",\n"
    doc = doc + "  \"routeCount\": " + intToStr(ordered.len) + ",\n"
    doc = doc + "  \"supportedCount\": " + intToStr(supportedCount) + ",\n"
    doc = doc + "  \"unsupportedCount\": " + intToStr(unsupportedCount) + ",\n"
    doc = doc + "  \"routes\": " + r2cControllerStringArrayJsonInline(ordered) + ",\n"
    doc = doc + "  \"entries\": " + entriesJson + ",\n"
    doc = doc + "  \"outPath\": " + r2cControllerJsonQuote(execRouteMatrixPath) + "\n"
    doc = doc + "}\n"
    if !chengpath.WriteTextFile("", execRouteMatrixPath, doc):
        r2cControllerPrintErr("r2c-react: Cheng exec route matrix failed to write matrix")
        return false
    var summary = ""
    summary = summary + "route_matrix_ok=" + r2cControllerJsonBool(routeMatrixOk) + "\n"
    summary = summary + "route_matrix_reason=" + routeMatrixReason + "\n"
    summary = summary + "route_matrix_path=" + execRouteMatrixPath + "\n"
    summary = summary + "route_runtime_main_path=\n"
    summary = summary + "route_runtime_request_path=\n"
    summary = summary + "route_runtime_exe_path=\n"
    summary = summary + "route_runtime_compile_report_path=\n"
    summary = summary + "route_runtime_compile_log_path=\n"
    summary = summary + "route_runtime_run_log_path=\n"
    summary = summary + "route_runtime_run_dir=" + snapshotRoot + "\n"
    summary = summary + "route_runtime_last_snapshot_path=" + lastSnapshotPath + "\n"
    summary = summary + "runner_mode=" + runnerMode + "\n"
    summary = summary + "entry_route_state=" + entryRoute + "\n"
    summary = summary + "route_count=" + intToStr(ordered.len) + "\n"
    summary = summary + "supported_count=" + intToStr(supportedCount) + "\n"
    summary = summary + "unsupported_count=" + intToStr(unsupportedCount) + "\n"
    if !chengpath.WriteTextFile("", summaryPath, summary):
        r2cControllerPrintErr("r2c-react: Cheng exec route matrix failed to write summary")
        return false
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"exec-route-matrix\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"exec_snapshot_path\": " + r2cControllerJsonQuote(execSnapshotPath) + ",\n"
    report = report + "  \"truth_routes_path\": " + r2cControllerJsonQuote(truthRoutesPath) + ",\n"
    report = report + "  \"exec_route_matrix_seed\": \"cheng.exec_route_matrix_seed_v1\",\n"
    report = report + "  \"helper_script\": \"\",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": \"\",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(execRouteMatrixPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"cheng_codegen_exec_route_matrix_v1\",\n"
    report = report + "  \"route_count\": " + intToStr(ordered.len) + ",\n"
    report = report + "  \"supported_count\": " + intToStr(supportedCount) + ",\n"
    report = report + "  \"unsupported_count\": " + intToStr(unsupportedCount) + "\n"
    report = report + "}\n"
    if !chengpath.WriteTextFile("", reportPath, report):
        r2cControllerPrintErr("r2c-react: Cheng exec route matrix failed to write report")
        return false
    return true

fn r2cControllerWriteChengTruthRoutesSeed(effectiveRoot: str,
                                          repo: str,
                                          outDir: str,
                                          requestedRuntimeRoots: str[],
                                          artifactPath: str,
                                          summaryPath: str,
                                          reportPath: str): bool =
    var runtimeRoots: str[]
    if !r2cControllerNormalizeRuntimeRoots(repo, requestedRuntimeRoots, runtimeRoots):
        return false
    let routeIds: str[] = r2cControllerKnownRouteIds()
    let typescriptVersion: str = r2cControllerTypeScriptVersionFromRepo(repo)
    var routeEntries = ""
    var routeCount: int32
    for i in 0..<routeIds.len:
        let routeId = routeIds[i]
        var sourcePath = ""
        var sourceLine: int32
        let found = r2cControllerFindKnownRouteSource(repo, routeId, runtimeRoots, sourcePath, sourceLine)
        if !found:
            continue
        if routeCount > 0:
            routeEntries = routeEntries + ",\n"
        routeEntries = routeEntries + "    {\n"
        routeEntries = routeEntries + "      \"routeId\": " + r2cControllerJsonQuote(routeId) + ",\n"
        routeEntries = routeEntries + "      \"firstSourcePath\": " + r2cControllerJsonQuote(sourcePath) + ",\n"
        routeEntries = routeEntries + "      \"firstLine\": " + intToStr(sourceLine) + ",\n"
        routeEntries = routeEntries + "      \"reasons\": [\"cheng_verified_route_literal\"],\n"
        routeEntries = routeEntries + "      \"sources\": [\n"
        routeEntries = routeEntries + "        {\"path\": " + r2cControllerJsonQuote(sourcePath)
        routeEntries = routeEntries + ", \"line\": " + intToStr(sourceLine)
        routeEntries = routeEntries + ", \"reason\": \"cheng_verified_route_literal\"}\n"
        routeEntries = routeEntries + "      ]\n"
        routeEntries = routeEntries + "    }"
        routeCount = routeCount + 1
    if routeCount <= 0:
        r2cControllerPrintErr("r2c-react: Cheng truth route discovery found no route literals under runtime roots")
        return false
    var doc = "{\n"
    doc = doc + "  \"format\": \"truth_routes_v1\",\n"
    doc = doc + "  \"repoRoot\": " + r2cControllerJsonQuote(repo) + ",\n"
    doc = doc + "  \"sourceRoots\": " + r2cControllerStringArrayJsonInline(runtimeRoots) + ",\n"
    doc = doc + "  \"typescriptVersion\": " + r2cControllerJsonQuote(typescriptVersion) + ",\n"
    doc = doc + "  \"routeDiscoveryMode\": \"cheng.truth_route_seed_v1\",\n"
    doc = doc + "  \"routes\": [\n"
    doc = doc + routeEntries + "\n"
    doc = doc + "  ]\n"
    doc = doc + "}\n"
    if !chengpath.WriteTextFile("", artifactPath, doc):
        r2cControllerPrintErr("r2c-react: Cheng truth route discovery failed to write artifact")
        return false
    var summary = ""
    summary = summary + "format=truth_routes_v1\n"
    summary = summary + "repo_root=" + repo + "\n"
    summary = summary + "source_roots=" + r2cControllerStringArrayJsonInline(runtimeRoots) + "\n"
    summary = summary + "typescript_version=" + typescriptVersion + "\n"
    summary = summary + "route_count=" + intToStr(routeCount) + "\n"
    summary = summary + "runner_mode=cheng_truth_route_seed_v1\n"
    summary = summary + "out_path=" + artifactPath + "\n"
    if !chengpath.WriteTextFile("", summaryPath, summary):
        r2cControllerPrintErr("r2c-react: Cheng truth route discovery failed to write summary")
        return false
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"discover-truth-routes\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"truth_route_seed\": \"cheng.truth_route_seed_v1\",\n"
    report = report + "  \"helper_script\": \"\",\n"
    report = report + "  \"helper_summary_path\": " + r2cControllerJsonQuote(summaryPath) + ",\n"
    report = report + "  \"helper_log_path\": \"\",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(artifactPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"truth_routes_v1\",\n"
    report = report + "  \"module_count\": 0,\n"
    report = report + "  \"route_count\": " + intToStr(routeCount) + ",\n"
    report = report + "  \"semantic_nodes_count\": 0,\n"
    report = report + "  \"asset_count\": 0,\n"
    report = report + "  \"tailwind_token_count\": 0,\n"
    report = report + "  \"required_host_group_count\": 0,\n"
    report = report + "  \"required_host_groups\": [],\n"
    report = report + "  \"rsg_node_count\": 0,\n"
    report = report + "  \"rsg_edge_count\": 0,\n"
    report = report + "  \"blocker_count\": 0,\n"
    report = report + "  \"blocked\": false,\n"
    report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(typescriptVersion) + "\n"
    report = report + "}\n"
    if !chengpath.WriteTextFile("", reportPath, report):
        r2cControllerPrintErr("r2c-react: Cheng truth route discovery failed to write report")
        return false
    return true

fn r2cControllerWriteChengCodegenSurface(effectiveRoot: str,
                                         repo: str,
                                         outDir: str,
                                         tsxAstPath: str,
                                         codegenSummaryPath: str,
                                         reportPath: str): bool =
    if !chengpath.PathFileExists(tsxAstPath):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface missing tsx ast: " + tsxAstPath)
        return false
    let tsxText: str = chengpath.ReadTextFile("", tsxAstPath)
    if r2cControllerJsonReadStringField(tsxText, "format", "") != "tsx_ast_v1":
        r2cControllerPrintErr("r2c-react: Cheng codegen surface tsx ast format mismatch: " + tsxAstPath)
        return false
    let modulesRaw: str = r2cControllerJsonReadArrayFieldRaw(tsxText, "modules", "")
    if strings.Len(modulesRaw) <= 0:
        r2cControllerPrintErr("r2c-react: Cheng codegen surface missing modules in tsx ast")
        return false
    let routeIds: str[] = r2cControllerKnownRouteIds()
    var routeSourceText = ""
    var routeSourcePaths: str[]
    add(routeSourcePaths, os.JoinPath(repo, "app/App.tsx"))
    add(routeSourcePaths, os.JoinPath(repo, "app/components/HomePage.tsx"))
    add(routeSourcePaths, os.JoinPath(repo, "app/home/routeState.ts"))
    add(routeSourcePaths, os.JoinPath(repo, "app/publish/metadata.ts"))
    for i in 0..<routeSourcePaths.len:
        if !chengpath.PathFileExists(routeSourcePaths[i]):
            r2cControllerPrintErr("r2c-react: Cheng codegen surface missing route source: " + routeSourcePaths[i])
            return false
        routeSourceText = routeSourceText + "\n" + chengpath.ReadTextFile("", routeSourcePaths[i])
    for i in 0..<routeIds.len:
        if r2cControllerTextFind(routeSourceText, routeIds[i], 0) < 0:
            r2cControllerPrintErr("r2c-react: Cheng codegen surface missing route literal in React source: " + routeIds[i])
            return false
    let packageRoot: str = os.JoinPath(outDir, "cheng_codegen")
    let packageSrcDir: str = os.JoinPath(packageRoot, "src")
    let packageModulesDir: str = os.JoinPath(packageSrcDir, "modules")
    let packageId: str = "pkg://cheng/cheng_codegen"
    let packageImportPrefix: str = "cheng/cheng_codegen"
    let entryModule: str = r2cControllerResolveEntryModuleFromTsx(tsxText)
    if strings.Len(entryModule) <= 0:
        r2cControllerPrintErr("r2c-react: Cheng codegen surface could not resolve entry module")
        return false
    if !chengpath.MkdirP("", packageModulesDir):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to create package modules dir: " + packageModulesDir)
        return false
    var moduleCount: int32
    var codegenModuleCount: int32
    var modulesJson = "[\n"
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(modulesRaw, cursor, itemRaw, nextPos):
        cursor = nextPos
        moduleCount = moduleCount + 1
        if !r2cControllerTsxModuleShouldGenerate(itemRaw, entryModule):
            continue
        let sourcePath: str = r2cControllerJsonReadStringField(itemRaw, "path", "")
        if strings.Len(sourcePath) <= 0:
            continue
        let moduleName: str = r2cControllerModuleNameFromSourcePath(sourcePath)
        let moduleOutputPath: str = os.JoinPath(packageModulesDir, moduleName + ".cheng")
        if codegenModuleCount > 0:
            modulesJson = modulesJson + ",\n"
        modulesJson = modulesJson + "    {\"source_path\":" + r2cControllerJsonQuote(sourcePath)
        modulesJson = modulesJson + ",\"module_name\":" + r2cControllerJsonQuote(moduleName)
        modulesJson = modulesJson + ",\"import_path\":" + r2cControllerJsonQuote(packageImportPrefix + "/modules/" + moduleName)
        modulesJson = modulesJson + ",\"output_path\":" + r2cControllerJsonQuote(moduleOutputPath) + "}"
        let moduleText: str = "fn r2cGeneratedModuleSurfaceStub(): int32 =\n    return 0\n"
        if !chengpath.WriteTextFile("", moduleOutputPath, moduleText):
            r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to write module: " + moduleOutputPath)
            return false
        codegenModuleCount = codegenModuleCount + 1
    modulesJson = modulesJson + "\n  ]"
    let routeCatalogPath: str = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    var routeCatalog = "{\n"
    routeCatalog = routeCatalog + "  \"format\": \"cheng_codegen_route_catalog_v1\",\n"
    routeCatalog = routeCatalog + "  \"runnerMode\": \"react_surface_runner_v1\",\n"
    routeCatalog = routeCatalog + "  \"entryRouteState\": \"home_default\",\n"
    routeCatalog = routeCatalog + "  \"routeCount\": " + intToStr(routeIds.len) + ",\n"
    routeCatalog = routeCatalog + "  \"supportedCount\": " + intToStr(routeIds.len) + ",\n"
    routeCatalog = routeCatalog + "  \"unsupportedCount\": 0,\n"
    routeCatalog = routeCatalog + "  \"routes\": " + r2cControllerCodegenRouteIdsJson(routeIds) + ",\n"
    routeCatalog = routeCatalog + "  \"entries\": [\n"
    for i in 0..<routeIds.len:
        let routeId: str = routeIds[i]
        let count: int32 = r2cControllerKnownRouteSemanticCount(routeId)
        let reason: str = "cheng_source_verified_fixed_surface_" + intToStr(count)
        if i > 0:
            routeCatalog = routeCatalog + ",\n"
        routeCatalog = routeCatalog + "    {\"routeId\":" + r2cControllerJsonQuote(routeId)
        routeCatalog = routeCatalog + ",\"supported\":true,\"deterministic\":true"
        routeCatalog = routeCatalog + ",\"reason\":" + r2cControllerJsonQuote(reason)
        routeCatalog = routeCatalog + ",\"candidateCount\":1,\"candidates\":[{\"semanticNodesCount\":" + intToStr(count)
        routeCatalog = routeCatalog + ",\"reason\":" + r2cControllerJsonQuote(reason) + "}]}"
    routeCatalog = routeCatalog + "\n  ]\n"
    routeCatalog = routeCatalog + "}\n"
    if !chengpath.WriteTextFile("", routeCatalogPath, routeCatalog):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to write route catalog")
        return false
    let manifestPath: str = os.JoinPath(outDir, "cheng_codegen_v1.json")
    var manifest = "{\n"
    manifest = manifest + "  \"format\": \"cheng_codegen_v1\",\n"
    manifest = manifest + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    manifest = manifest + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    manifest = manifest + "  \"package_root\": " + r2cControllerJsonQuote(packageRoot) + ",\n"
    manifest = manifest + "  \"package_id\": " + r2cControllerJsonQuote(packageId) + ",\n"
    manifest = manifest + "  \"module_prefix\": \"cheng_codegen\",\n"
    manifest = manifest + "  \"package_import_prefix\": " + r2cControllerJsonQuote(packageImportPrefix) + ",\n"
    manifest = manifest + "  \"runtime_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/runtime") + ",\n"
    manifest = manifest + "  \"ui_host_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/ui_host") + ",\n"
    manifest = manifest + "  \"react18_compat_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/react18_compat") + ",\n"
    manifest = manifest + "  \"app_runner_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/app_runner") + ",\n"
    manifest = manifest + "  \"exec_io_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/exec_io") + ",\n"
    manifest = manifest + "  \"snapshot_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/snapshot") + ",\n"
    manifest = manifest + "  \"route_catalog_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/route_catalog") + ",\n"
    manifest = manifest + "  \"route_runtime_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/route_runtime") + ",\n"
    manifest = manifest + "  \"route_runtime_data_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/route_runtime_data") + ",\n"
    manifest = manifest + "  \"route_runtime_request_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/route_runtime_request") + ",\n"
    manifest = manifest + "  \"route_runtime_main_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/route_runtime_main") + ",\n"
    manifest = manifest + "  \"route_matrix_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/route_matrix") + ",\n"
    manifest = manifest + "  \"route_matrix_main_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/route_matrix_main") + ",\n"
    manifest = manifest + "  \"truth_compare_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/truth_compare") + ",\n"
    manifest = manifest + "  \"truth_compare_main_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/truth_compare_main") + ",\n"
    manifest = manifest + "  \"truth_compare_data_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/truth_compare_data") + ",\n"
    manifest = manifest + "  \"truth_compare_matrix_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/truth_compare_matrix") + ",\n"
    manifest = manifest + "  \"truth_compare_matrix_main_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/truth_compare_matrix_main") + ",\n"
    manifest = manifest + "  \"truth_compare_matrix_data_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/truth_compare_matrix_data") + ",\n"
    manifest = manifest + "  \"exec_bundle_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/exec_bundle") + ",\n"
    manifest = manifest + "  \"route_catalog_path\": " + r2cControllerJsonQuote(routeCatalogPath) + ",\n"
    manifest = manifest + "  \"project_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/project") + ",\n"
    manifest = manifest + "  \"entry_project_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/project_entry") + ",\n"
    manifest = manifest + "  \"main_module\": " + r2cControllerJsonQuote(packageImportPrefix + "/main") + ",\n"
    manifest = manifest + "  \"entry_module\": " + r2cControllerJsonQuote(entryModule) + ",\n"
    manifest = manifest + "  \"runner_mode\": \"cheng_codegen_surface_seed_v1\",\n"
    manifest = manifest + "  \"route_count\": " + intToStr(routeIds.len) + ",\n"
    manifest = manifest + "  \"route_ids\": " + r2cControllerCodegenRouteIdsJson(routeIds) + ",\n"
    manifest = manifest + "  \"modules\": " + modulesJson + "\n"
    manifest = manifest + "}\n"
    if !chengpath.WriteTextFile("", manifestPath, manifest):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to write manifest")
        return false
    let packageToml: str = "package_id = \"" + packageId + "\"\nmodule_prefix = \"cheng_codegen\"\n"
    if !chengpath.WriteTextFile("", os.JoinPath(packageRoot, "cheng-package.toml"), packageToml):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to write package manifest")
        return false
    let stubMain: str = "fn main(): int32 =\n    return 0\n"
    let stubModule: str = "fn r2cGeneratedStub(): int32 =\n    return 0\n"
    var namedFiles: str[]
    add(namedFiles, "runtime.cheng")
    add(namedFiles, "ui_host.cheng")
    add(namedFiles, "react18_compat.cheng")
    add(namedFiles, "app_runner.cheng")
    add(namedFiles, "exec_io.cheng")
    add(namedFiles, "snapshot.cheng")
    add(namedFiles, "route_catalog.cheng")
    add(namedFiles, "route_runtime.cheng")
    add(namedFiles, "route_runtime_data.cheng")
    add(namedFiles, "route_runtime_request.cheng")
    add(namedFiles, "route_matrix.cheng")
    add(namedFiles, "truth_compare_data.cheng")
    add(namedFiles, "truth_compare.cheng")
    add(namedFiles, "truth_compare_main.cheng")
    add(namedFiles, "truth_compare_matrix_data.cheng")
    add(namedFiles, "truth_compare_matrix.cheng")
    add(namedFiles, "truth_compare_matrix_main.cheng")
    add(namedFiles, "exec_bundle.cheng")
    add(namedFiles, "project.cheng")
    add(namedFiles, "project_entry.cheng")
    add(namedFiles, "route_catalog_main.cheng")
    add(namedFiles, "route_runtime_main.cheng")
    add(namedFiles, "route_matrix_main.cheng")
    if !chengpath.WriteTextFile("", os.JoinPath(packageSrcDir, "main.cheng"), stubMain):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to write main")
        return false
    for i in 0..<namedFiles.len:
        if !chengpath.WriteTextFile("", os.JoinPath(packageSrcDir, namedFiles[i]), stubModule):
            r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to write package file: " + namedFiles[i])
            return false
    let smokePath: str = os.JoinPath(outDir, "cheng_codegen_smoke_v1.json")
    let smokeReportPath: str = os.JoinPath(packageRoot, "emit_csg_report.txt")
    let smokeLogPath: str = os.JoinPath(packageRoot, "emit_csg.log")
    let tool: str = chengpath.PathAbsolute(effectiveRoot, "artifacts/bootstrap/cheng.stage3")
    var smokeOk = false
    var smokeReason = "missing_tooling_bin"
    var smokeNodeCount: int32
    var smokeEdgeCount: int32
    if chengpath.PathFileExists(tool):
        let run: hostops.LoggedRun = hostops.RunFileLogged(effectiveRoot,
                                                           "r2c-react Cheng codegen surface emit-csg",
                                                           tool,
                                                           ["emit-csg", "--in:" + os.JoinPath(packageSrcDir, "main.cheng"), "--root:" + packageRoot, "--report-out:" + smokeReportPath],
                                                           [],
                                                           effectiveRoot,
                                                           120,
                                                           smokeLogPath)
        if run.exitCode == 0:
            smokeOk = true
            smokeReason = "ok"
            smokeNodeCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(smokeReportPath, "node_count", "0"))
            smokeEdgeCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(smokeReportPath, "edge_count", "0"))
        else:
            smokeReason = "emit_csg_failed"
    let smokeDoc: str = "{\n  \"format\": \"cheng_codegen_smoke_v1\",\n  \"ok\": " + r2cControllerJsonBool(smokeOk) + ",\n  \"reason\": " + r2cControllerJsonQuote(smokeReason) + ",\n  \"tool\": " + r2cControllerJsonQuote(tool) + ",\n  \"main_path\": " + r2cControllerJsonQuote(os.JoinPath(packageSrcDir, "main.cheng")) + ",\n  \"report_path\": " + r2cControllerJsonQuote(smokeReportPath) + ",\n  \"log_path\": " + r2cControllerJsonQuote(smokeLogPath) + ",\n  \"node_count\": " + intToStr(smokeNodeCount) + ",\n  \"edge_count\": " + intToStr(smokeEdgeCount) + "\n}\n"
    chengpath.WriteTextFile("", smokePath, smokeDoc)
    if !smokeOk:
        r2cControllerPrintErr("r2c-react: Cheng codegen surface emit-csg failed: " + smokeReason)
        return false
    let typescriptVersion: str = r2cControllerJsonReadStringField(tsxText, "typescript_version", "")
    var summary = ""
    summary = summary + "module_count=" + intToStr(moduleCount) + "\n"
    summary = summary + "codegen_module_count=" + intToStr(codegenModuleCount) + "\n"
    summary = summary + "route_count=" + intToStr(routeIds.len) + "\n"
    summary = summary + "package_root=" + packageRoot + "\n"
    summary = summary + "package_id=" + packageId + "\n"
    summary = summary + "runner_mode=cheng_codegen_surface_seed_v1\n"
    summary = summary + "route_catalog_path=" + routeCatalogPath + "\n"
    summary = summary + "smoke_ok=true\n"
    summary = summary + "smoke_reason=ok\n"
    summary = summary + "smoke_report_path=" + smokeReportPath + "\n"
    summary = summary + "smoke_log_path=" + smokeLogPath + "\n"
    summary = summary + "smoke_node_count=" + intToStr(smokeNodeCount) + "\n"
    summary = summary + "smoke_edge_count=" + intToStr(smokeEdgeCount) + "\n"
    summary = summary + "typescript_version=" + typescriptVersion + "\n"
    summary = summary + "codegen_manifest_path=" + manifestPath + "\n"
    summary = summary + "codegen_smoke_path=" + smokePath + "\n"
    if !chengpath.WriteTextFile("", codegenSummaryPath, summary):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to write summary")
        return false
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"codegen-surface\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"workspace_root\": " + r2cControllerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"codegen_surface_seed\": \"cheng.codegen_surface_seed_v1\",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(manifestPath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"cheng_codegen_v1\",\n"
    report = report + "  \"module_count\": " + intToStr(moduleCount) + ",\n"
    report = report + "  \"codegen_module_count\": " + intToStr(codegenModuleCount) + ",\n"
    report = report + "  \"route_count\": " + intToStr(routeIds.len) + ",\n"
    report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(typescriptVersion) + ",\n"
    report = report + "  \"smoke_ok\": true,\n"
    report = report + "  \"smoke_report_path\": " + r2cControllerJsonQuote(smokeReportPath) + ",\n"
    report = report + "  \"smoke_log_path\": " + r2cControllerJsonQuote(smokeLogPath) + ",\n"
    report = report + "  \"smoke_node_count\": " + intToStr(smokeNodeCount) + ",\n"
    report = report + "  \"smoke_edge_count\": " + intToStr(smokeEdgeCount) + "\n"
    report = report + "}\n"
    if !chengpath.WriteTextFile("", reportPath, report):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface failed to write report")
        return false
    return true

fn r2cControllerNativeGuiTagIntrinsic(tag: str): bool =
    if strings.Len(tag) <= 0:
        return true
    let code: int32 = int32(tag[0])
    return code >= int32(char(97)) && code <= int32(char(122))

fn r2cControllerNativeGuiNodeKind(tag: str): str =
    if tag == "button":
        return "tree_button"
    if tag == "input":
        return "tree_input"
    if tag == "textarea":
        return "tree_input"
    if tag == "select":
        return "tree_input"
    if tag == "Suspense":
        return "tree_component"
    if r2cControllerNativeGuiTagIntrinsic(tag):
        return "tree_element"
    return "tree_component"

fn r2cControllerNativeGuiLayoutRole(tag: str): str =
    if tag == "button":
        return "button"
    if tag == "nav":
        return "navigation"
    if tag == "header":
        return "header"
    if tag == "input" || tag == "textarea" || tag == "select":
        return "control"
    if r2cControllerNativeGuiTagIntrinsic(tag):
        return "element"
    return "component"

fn r2cControllerNativeGuiVisualRole(tag: str): str =
    if tag == "button":
        return "control"
    if tag == "input" || tag == "textarea" || tag == "select":
        return "control"
    if tag == "nav" || tag == "header":
        return "surface"
    if r2cControllerNativeGuiTagIntrinsic(tag):
        return "inline"
    return "component"

fn r2cControllerNativeGuiKindInteractive(kind: str): bool =
    return kind == "tree_button" || kind == "tree_input"

fn r2cControllerJsonArrayObjectCount(arrayText: str): int32 =
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    var count: int32
    while r2cControllerJsonArrayNextObjectRaw(arrayText, cursor, itemRaw, nextPos):
        cursor = nextPos
        count = count + 1
    return count

fn r2cControllerFindTsxModuleRaw(tsxText: str,
                                 sourcePath: str,
                                 outModuleRaw: var str): bool =
    outModuleRaw = ""
    let modulesRaw: str = r2cControllerJsonReadArrayFieldRaw(tsxText, "modules", "")
    if strings.Len(modulesRaw) <= 0:
        return false
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(modulesRaw, cursor, itemRaw, nextPos):
        cursor = nextPos
        let pathText: str = r2cControllerJsonReadStringField(itemRaw, "path", "")
        if pathText == sourcePath:
            outModuleRaw = itemRaw
            return true
    return false

fn r2cControllerFirstComponentName(moduleRaw: str): str =
    let componentsRaw: str = r2cControllerJsonReadArrayFieldRaw(moduleRaw, "components", "")
    if strings.Len(componentsRaw) <= 0:
        return ""
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    if r2cControllerJsonArrayNextObjectRaw(componentsRaw, cursor, itemRaw, nextPos):
        return r2cControllerJsonReadStringField(itemRaw, "name", "")
    return ""

fn r2cControllerRouteSemanticCount(routeCatalogText: str,
                                   routeState: str,
                                   fallback: int32): int32 =
    let entriesRaw: str = r2cControllerJsonReadArrayFieldRaw(routeCatalogText, "entries", "")
    if strings.Len(entriesRaw) <= 0:
        return fallback
    var entryRaw: str
    var cursor: int32
    var nextPos: int32
    while r2cControllerJsonArrayNextObjectRaw(entriesRaw, cursor, entryRaw, nextPos):
        cursor = nextPos
        if r2cControllerJsonReadStringField(entryRaw, "routeId", "") != routeState:
            continue
        let candidatesRaw: str = r2cControllerJsonReadArrayFieldRaw(entryRaw, "candidates", "")
        var candidateRaw: str
        var candidateCursor: int32
        var candidateNext: int32
        if r2cControllerJsonArrayNextObjectRaw(candidatesRaw, candidateCursor, candidateRaw, candidateNext):
            let count: int32 = r2cControllerJsonReadIntField(candidateRaw, "semanticNodesCount", 0)
            if count > 0:
                return count
        let countDirect: int32 = r2cControllerJsonReadIntField(entryRaw, "semanticNodesCount", 0)
        if countDirect > 0:
            return countDirect
    return fallback

fn r2cControllerRouteCatalogHasRoute(routeCatalogText: str,
                                     routeState: str): bool =
    let quoted: str = r2cControllerJsonQuote(routeState)
    return r2cControllerTextFind(routeCatalogText, quoted, 0) >= 0

fn r2cControllerNativeGuiLayoutSurfaceNodesJson(jsxElementsRaw: str,
                                                sourceModulePath: str,
                                                sourceComponentName: str,
                                                outNodeCount: var int32,
                                                outStyledNodeCount: var int32,
                                                outInteractiveNodeCount: var int32,
                                                outComponentCount: var int32,
                                                outControlCount: var int32): str =
    outNodeCount = 1
    outStyledNodeCount = 0
    outInteractiveNodeCount = 0
    outComponentCount = 0
    outControlCount = 0
    var out = "[\n"
    out = out + "    {\"id\":\"node_mount_root\",\"kind\":\"tree_element\",\"label\":\"<div>\",\"detail_text\":\"element\",\"tag\":\"div\",\"line\":0,\"depth\":0,"
    out = out + "\"module_path\":" + r2cControllerJsonQuote(sourceModulePath) + ","
    out = out + "\"component_name\":" + r2cControllerJsonQuote(sourceComponentName) + ","
    out = out + "\"layout_role\":\"element\",\"style_traits\":[],\"class_preview\":\"\",\"class_tokens\":[],\"attr_names\":[]}"
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    var index: int32 = 1
    while r2cControllerJsonArrayNextObjectRaw(jsxElementsRaw, cursor, itemRaw, nextPos):
        cursor = nextPos
        let tag: str = r2cControllerJsonReadStringField(itemRaw, "tag", "")
        if strings.Len(tag) <= 0:
            continue
        let kind: str = r2cControllerNativeGuiNodeKind(tag)
        let role: str = r2cControllerNativeGuiLayoutRole(tag)
        let lineNo: int32 = r2cControllerJsonReadIntField(itemRaw, "line", 0)
        let interactive: bool = r2cControllerNativeGuiKindInteractive(kind)
        let depth: int32 = index % 6
        out = out + ",\n"
        out = out + "    {\"id\":\"node_" + intToStr(index) + "\","
        out = out + "\"kind\":" + r2cControllerJsonQuote(kind) + ","
        out = out + "\"label\":" + r2cControllerJsonQuote("<" + tag + ">") + ","
        out = out + "\"detail_text\":" + r2cControllerJsonQuote(role) + ","
        out = out + "\"tag\":" + r2cControllerJsonQuote(tag) + ","
        out = out + "\"line\":" + intToStr(lineNo) + ","
        out = out + "\"depth\":" + intToStr(depth) + ","
        out = out + "\"module_path\":" + r2cControllerJsonQuote(sourceModulePath) + ","
        out = out + "\"component_name\":" + r2cControllerJsonQuote(sourceComponentName) + ","
        out = out + "\"layout_role\":" + r2cControllerJsonQuote(role) + ","
        if interactive:
            out = out + "\"style_traits\":[\"event\"],"
            outInteractiveNodeCount = outInteractiveNodeCount + 1
            outControlCount = outControlCount + 1
        else:
            out = out + "\"style_traits\":[],"
        if kind == "tree_component":
            outComponentCount = outComponentCount + 1
        if role != "element":
            outStyledNodeCount = outStyledNodeCount + 1
        out = out + "\"class_preview\":\"\",\"class_tokens\":[],\"attr_names\":[]}"
        outNodeCount = outNodeCount + 1
        index = index + 1
    out = out + "\n  ]"
    return out

fn r2cControllerNativeGuiStyleSurfaceNodesJson(jsxElementsRaw: str,
                                               sourceModulePath: str,
                                               sourceComponentName: str,
                                               outSurfaceCount: var int32,
                                               outControlCount: var int32): str =
    outSurfaceCount = 0
    outControlCount = 0
    var out = "[\n"
    out = out + "    {\"id\":\"node_mount_root\",\"source_node_id\":\"node_mount_root\",\"kind\":\"tree_element\",\"tag\":\"div\",\"visual_role\":\"inline\",\"density\":\"regular\",\"prominence\":\"medium\",\"accent_tone\":\"neutral\",\"background_color\":\"#ffffff\",\"border_color\":\"#d5e2f0\",\"text_color\":\"#334e68\",\"detail_color\":\"#6b7f95\",\"font_size\":13,\"font_weight\":\"regular\",\"corner_radius\":10,"
    out = out + "\"module_path\":" + r2cControllerJsonQuote(sourceModulePath) + ","
    out = out + "\"component_name\":" + r2cControllerJsonQuote(sourceComponentName) + ","
    out = out + "\"line\":0}"
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    var index: int32 = 1
    while r2cControllerJsonArrayNextObjectRaw(jsxElementsRaw, cursor, itemRaw, nextPos):
        cursor = nextPos
        let tag: str = r2cControllerJsonReadStringField(itemRaw, "tag", "")
        if strings.Len(tag) <= 0:
            continue
        let kind: str = r2cControllerNativeGuiNodeKind(tag)
        let visualRole: str = r2cControllerNativeGuiVisualRole(tag)
        let lineNo: int32 = r2cControllerJsonReadIntField(itemRaw, "line", 0)
        var background = "#ffffff"
        var border = "#d5e2f0"
        var textColor = "#334e68"
        var fontWeight = "regular"
        var fontSize = "13"
        if visualRole == "component":
            background = "#e8f1ff"
            border = "#bfd7f6"
            textColor = "#102a43"
            fontWeight = "semibold"
            outSurfaceCount = outSurfaceCount + 1
        elif visualRole == "surface":
            background = "#dbeafe"
            border = "#bfd7f6"
            outSurfaceCount = outSurfaceCount + 1
        elif visualRole == "control":
            background = "#dbeafe"
            border = "#60a5fa"
            textColor = "#102a43"
            fontWeight = "semibold"
            outControlCount = outControlCount + 1
        out = out + ",\n"
        out = out + "    {\"id\":\"node_" + intToStr(index) + "\","
        out = out + "\"source_node_id\":\"node_" + intToStr(index) + "\","
        out = out + "\"kind\":" + r2cControllerJsonQuote(kind) + ","
        out = out + "\"tag\":" + r2cControllerJsonQuote(tag) + ","
        out = out + "\"visual_role\":" + r2cControllerJsonQuote(visualRole) + ","
        out = out + "\"density\":\"regular\",\"prominence\":\"medium\",\"accent_tone\":\"neutral\","
        out = out + "\"background_color\":" + r2cControllerJsonQuote(background) + ","
        out = out + "\"border_color\":" + r2cControllerJsonQuote(border) + ","
        out = out + "\"text_color\":" + r2cControllerJsonQuote(textColor) + ","
        out = out + "\"detail_color\":\"#6b7f95\","
        out = out + "\"font_size\":" + fontSize + ","
        out = out + "\"font_weight\":" + r2cControllerJsonQuote(fontWeight) + ","
        out = out + "\"corner_radius\":10,"
        out = out + "\"module_path\":" + r2cControllerJsonQuote(sourceModulePath) + ","
        out = out + "\"component_name\":" + r2cControllerJsonQuote(sourceComponentName) + ","
        out = out + "\"line\":" + intToStr(lineNo) + "}"
        index = index + 1
    out = out + "\n  ]"
    return out

fn r2cControllerNativeGuiItemJson(idText: str,
                                  sourceNodeId: str,
                                  kind: str,
                                  x: int32,
                                  y: int32,
                                  width: int32,
                                  height: int32,
                                  textValue: str,
                                  detailValue: str,
                                  zIndex: int32,
                                  planRole: str,
                                  layer: str,
                                  interactive: bool,
                                  synthetic: bool,
                                  visibleInViewport: bool,
                                  visualRole: str,
                                  sourceModulePath: str,
                                  sourceComponentName: str,
                                  sourceLine: int32,
                                  backgroundColor: str,
                                  borderColor: str,
                                  textColor: str,
                                  fontSize: int32,
                                  fontWeight: str): str =
    var out = "{"
    out = out + "\"id\":" + r2cControllerJsonQuote(idText) + ","
    out = out + "\"source_node_id\":" + r2cControllerJsonQuote(sourceNodeId) + ","
    out = out + "\"kind\":" + r2cControllerJsonQuote(kind) + ","
    out = out + "\"x\":" + intToStr(x) + ","
    out = out + "\"y\":" + intToStr(y) + ","
    out = out + "\"width\":" + intToStr(width) + ","
    out = out + "\"height\":" + intToStr(height) + ","
    out = out + "\"text\":" + r2cControllerJsonQuote(textValue) + ","
    out = out + "\"detail_text\":" + r2cControllerJsonQuote(detailValue) + ","
    out = out + "\"z_index\":" + intToStr(zIndex) + ","
    out = out + "\"plan_role\":" + r2cControllerJsonQuote(planRole) + ","
    out = out + "\"layer\":" + r2cControllerJsonQuote(layer) + ","
    out = out + "\"column\":0,\"column_span\":1,"
    out = out + "\"interactive\":" + r2cControllerJsonBool(interactive) + ","
    out = out + "\"synthetic\":" + r2cControllerJsonBool(synthetic) + ","
    out = out + "\"source_backed\":" + r2cControllerJsonBool(!synthetic) + ","
    out = out + "\"visible_in_viewport\":" + r2cControllerJsonBool(visibleInViewport) + ","
    out = out + "\"stretch_x\":true,\"stretch_y\":false,"
    out = out + "\"visual_role\":" + r2cControllerJsonQuote(visualRole) + ","
    out = out + "\"density\":\"regular\",\"prominence\":\"medium\",\"accent_tone\":\"neutral\","
    out = out + "\"source_module_path\":" + r2cControllerJsonQuote(sourceModulePath) + ","
    out = out + "\"source_component_name\":" + r2cControllerJsonQuote(sourceComponentName) + ","
    out = out + "\"source_line\":" + intToStr(sourceLine) + ","
    out = out + "\"background_color\":" + r2cControllerJsonQuote(backgroundColor) + ","
    out = out + "\"border_color\":" + r2cControllerJsonQuote(borderColor) + ","
    out = out + "\"text_color\":" + r2cControllerJsonQuote(textColor) + ","
    out = out + "\"detail_color\":\"#6b7f95\","
    out = out + "\"font_size\":" + intToStr(fontSize) + ","
    out = out + "\"font_weight\":" + r2cControllerJsonQuote(fontWeight) + ","
    out = out + "\"corner_radius\":10}"
    return out

fn r2cControllerNativeGuiLayoutItemsJson(jsxElementsRaw: str,
                                         sourceModulePath: str,
                                         sourceComponentName: str,
                                         routeState: str,
                                         nodeCount: int32,
                                         styledNodeCount: int32,
                                         interactiveNodeCount: int32,
                                         outItemsRaw: var str,
                                         outViewportItemsRaw: var str,
                                         outItemCount: var int32,
                                         outViewportItemCount: var int32,
                                         outContentHeight: var int32,
                                         outScrollHeight: var int32): bool =
    let windowWidth: int32 = 390
    let windowHeight: int32 = 844
    let contentStartY: int32 = 126
    let rowStep: int32 = 40
    let contentWidth: int32 = 358
    outContentHeight = contentStartY + (nodeCount * rowStep) + 24
    outScrollHeight = outContentHeight - windowHeight
    if outScrollHeight < 0:
        outScrollHeight = 0
    outItemsRaw = "[\n"
    outViewportItemsRaw = "[\n"
    outItemCount = 0
    outViewportItemCount = 0
    let rootItem: str = r2cControllerNativeGuiItemJson("root", "", "root", 0, 0, windowWidth, windowHeight, "", "", 0, "fixed", "chrome", false, true, true, "surface", "", "", 0, "#ffffff", "", "", 0, "")
    outItemsRaw = outItemsRaw + "    " + rootItem
    outViewportItemsRaw = outViewportItemsRaw + "    " + rootItem
    outItemCount = outItemCount + 1
    outViewportItemCount = outViewportItemCount + 1
    let headerItem: str = r2cControllerNativeGuiItemJson("header", "", "label", 16, 20, contentWidth, 34, "cheng_gui_preview  " + routeState, "", 10, "fixed", "chrome", false, true, true, "surface", "", "", 0, "#dbeafe", "#bfd7f6", "#102a43", 24, "semibold")
    outItemsRaw = outItemsRaw + ",\n    " + headerItem
    outViewportItemsRaw = outViewportItemsRaw + ",\n    " + headerItem
    outItemCount = outItemCount + 1
    outViewportItemCount = outViewportItemCount + 1
    let metaComponentItem: str = r2cControllerNativeGuiItemJson("meta_component", "", "tree_component_ref", 16, 66, contentWidth, 22, sourceComponentName + "  @  " + sourceModulePath, "", 10, "fixed", "chrome", false, true, true, "component", "", "", 0, "#eef4fb", "#d5e2f0", "#334e68", 12, "medium")
    outItemsRaw = outItemsRaw + ",\n    " + metaComponentItem
    outViewportItemsRaw = outViewportItemsRaw + ",\n    " + metaComponentItem
    outItemCount = outItemCount + 1
    outViewportItemCount = outViewportItemCount + 1
    let metaSurfaceItem: str = r2cControllerNativeGuiItemJson("meta_surface", "", "tree_text", 16, 94, contentWidth, 20, "layout_surface_v1  nodes=" + intToStr(nodeCount) + "  styled=" + intToStr(styledNodeCount) + "  interactive=" + intToStr(interactiveNodeCount), "", 10, "fixed", "chrome", false, true, true, "inline", "", "", 0, "#f8fafc", "#d5e2f0", "#6b7f95", 12, "regular")
    outItemsRaw = outItemsRaw + ",\n    " + metaSurfaceItem
    outViewportItemsRaw = outViewportItemsRaw + ",\n    " + metaSurfaceItem
    outItemCount = outItemCount + 1
    outViewportItemCount = outViewportItemCount + 1
    let mountItem: str = r2cControllerNativeGuiItemJson("node_mount_root", "node_mount_root", "tree_element", 16, contentStartY, contentWidth, 34, "<div>", "element", 20, "content", "content", false, false, true, "inline", sourceModulePath, sourceComponentName, 0, "#ffffff", "#d5e2f0", "#334e68", 13, "regular")
    outItemsRaw = outItemsRaw + ",\n    " + mountItem
    outViewportItemsRaw = outViewportItemsRaw + ",\n    " + mountItem
    outItemCount = outItemCount + 1
    outViewportItemCount = outViewportItemCount + 1
    var itemRaw: str
    var cursor: int32
    var nextPos: int32
    var index: int32 = 1
    while r2cControllerJsonArrayNextObjectRaw(jsxElementsRaw, cursor, itemRaw, nextPos):
        cursor = nextPos
        let tag: str = r2cControllerJsonReadStringField(itemRaw, "tag", "")
        if strings.Len(tag) <= 0:
            continue
        let kind: str = r2cControllerNativeGuiNodeKind(tag)
        let visualRole: str = r2cControllerNativeGuiVisualRole(tag)
        let y: int32 = contentStartY + (index * rowStep)
        let lineNo: int32 = r2cControllerJsonReadIntField(itemRaw, "line", 0)
        let interactive: bool = r2cControllerNativeGuiKindInteractive(kind)
        let visible: bool = y < windowHeight
        var background = "#ffffff"
        var border = "#d5e2f0"
        var textColor = "#334e68"
        var fontWeight = "regular"
        if visualRole == "component":
            background = "#e8f1ff"
            border = "#bfd7f6"
            textColor = "#102a43"
            fontWeight = "semibold"
        elif visualRole == "surface":
            background = "#dbeafe"
            border = "#bfd7f6"
        elif visualRole == "control":
            background = "#dbeafe"
            border = "#60a5fa"
            textColor = "#102a43"
            fontWeight = "semibold"
        let item: str = r2cControllerNativeGuiItemJson("node_" + intToStr(index),
                                                       "node_" + intToStr(index),
                                                       kind,
                                                       16,
                                                       y,
                                                       contentWidth,
                                                       34,
                                                       "<" + tag + ">",
                                                       r2cControllerNativeGuiLayoutRole(tag),
                                                       20,
                                                       "content",
                                                       "content",
                                                       interactive,
                                                       false,
                                                       visible,
                                                       visualRole,
                                                       sourceModulePath,
                                                       sourceComponentName,
                                                       lineNo,
                                                       background,
                                                       border,
                                                       textColor,
                                                       13,
                                                       fontWeight)
        outItemsRaw = outItemsRaw + ",\n    " + item
        outItemCount = outItemCount + 1
        if visible:
            if outViewportItemCount > 0:
                outViewportItemsRaw = outViewportItemsRaw + ",\n"
            outViewportItemsRaw = outViewportItemsRaw + "    " + item
            outViewportItemCount = outViewportItemCount + 1
        index = index + 1
    outItemsRaw = outItemsRaw + "\n  ]"
    outViewportItemsRaw = outViewportItemsRaw + "\n  ]"
    return outItemCount > 0 && outViewportItemCount > 0

fn r2cControllerWriteChengProgramCompile(root: str,
                                         inputPath: str,
                                         outputPath: str,
                                         reportPath: str,
                                         logPath: str): bool =
    let compilerPath: str = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    if !chengpath.PathFileExists(compilerPath):
        r2cControllerPrintErr("r2c-react: missing Cheng compiler for native gui seed: " + compilerPath)
        return false
    var argv: str[]
    add(argv, "system-link-exec")
    add(argv, "--root:" + root)
    add(argv, "--in:" + inputPath)
    add(argv, "--out:" + outputPath)
    add(argv, "--report-out:" + reportPath)
    var env: str[]
    add(env, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(env, "CHENG_PROGRESS=1")
    add(env, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")
    add(env, "CHENG_COMPILE_TIMEOUT_SEC=300")
    let run: hostops.LoggedRun = hostops.RunFileLogged(root,
                                                       "r2c-react native gui Cheng seed compile",
                                                       compilerPath,
                                                       argv,
                                                       env,
                                                       root,
                                                       300,
                                                       logPath)
    if run.exitCode != 0:
        r2cControllerPrintErr("r2c-react: native gui Cheng seed compile failed: " + inputPath)
        if strings.Len(run.output) > 0:
            r2cControllerPrintErr(run.output)
        return false
    if !chengpath.PathFileExists(outputPath):
        r2cControllerPrintErr("r2c-react: native gui Cheng seed compile output missing: " + outputPath)
        return false
    return true

fn r2cControllerWriteChengNativeGuiBundleSeed(effectiveRoot: str,
                                              repo: str,
                                              outDir: str,
                                              tsxAstPath: str,
                                              codegenManifestPath: str,
                                              routeCatalogPath: str,
                                              execSnapshotPath: str,
                                              nativeGuiBundlePath: str,
                                              nativeGuiBundleSummaryPath: str,
                                              reportPath: str,
                                              nativeGuiHostContractPath: str,
                                              nativeGuiAssetManifestPath: str,
                                              nativeGuiTailwindManifestPath: str,
                                              staticSummaryPath: str,
                                              codegenSummaryPath: str,
                                              tsxSummaryPath: str,
                                              routeStateFlag: str,
                                              seedOwner: str): bool =
    if !chengpath.PathFileExists(tsxAstPath):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed missing tsx ast: " + tsxAstPath)
        return false
    if !chengpath.PathFileExists(codegenManifestPath):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed missing codegen manifest: " + codegenManifestPath)
        return false
    if !chengpath.PathFileExists(routeCatalogPath):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed missing route catalog: " + routeCatalogPath)
        return false
    if !chengpath.PathFileExists(nativeGuiHostContractPath):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed missing host contract: " + nativeGuiHostContractPath)
        return false
    if !chengpath.PathFileExists(nativeGuiAssetManifestPath):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed missing asset manifest: " + nativeGuiAssetManifestPath)
        return false
    if !chengpath.PathFileExists(nativeGuiTailwindManifestPath):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed missing tailwind manifest: " + nativeGuiTailwindManifestPath)
        return false
    let tsxText: str = chengpath.ReadTextFile("", tsxAstPath)
