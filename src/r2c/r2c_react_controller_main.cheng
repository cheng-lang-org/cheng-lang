    bundle = bundle + "  \"native_layout_plan\": {\"path\":" + r2cControllerJsonQuote(nativeLayoutPlanPath) + ",\"ready\":true,\"item_count\":" + intToStr(itemCount) + ",\"viewport_item_count\":" + intToStr(viewportItemCount) + "},\n"
    bundle = bundle + "  \"native_render_plan\": {\"path\":" + r2cControllerJsonQuote(nativeRenderPlanPath) + ",\"ready\":true,\"command_count\":" + renderCommandCountText + ",\"visible_layout_item_count\":" + renderVisibleCountText + "},\n"
    bundle = bundle + "  \"native_runtime\": {\"path\":" + r2cControllerJsonQuote(nativeRuntimePath) + ",\"ready\":true,\"runtime_state_path\":" + r2cControllerJsonQuote(nativeRuntimeStatePath) + ",\"runtime_exe_path\":" + r2cControllerJsonQuote(nativeRuntimeCompiledExePath) + ",\"runtime_launcher_exe_path\":" + r2cControllerJsonQuote(nativeRuntimeCompiledExePath) + ",\"runtime_compiled_exe_path\":" + r2cControllerJsonQuote(nativeRuntimeCompiledExePath) + ",\"runtime_contract_path\":" + r2cControllerJsonQuote(nativeRuntimeContractPath) + ",\"runtime_mode\":\"cheng_generic_runtime_contract_v1\"},\n"
    bundle = bundle + "  \"session_preview\": {\"format\":\"native_gui_session_v1\",\"path\":" + r2cControllerJsonQuote(sessionPath) + ",\"ready\":true,\"mode\":\"cheng_ui_layout_surface_v1\",\"layout_item_count\":" + intToStr(itemCount) + "}\n"
    bundle = bundle + "}\n"
    if !chengpath.WriteTextFile("", nativeGuiBundlePath, bundle):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed failed to write bundle")
        return false
    var summary = ""
    summary = summary + "native_gui_report_path=" + reportPath + "\n"
    summary = summary + "native_gui_bundle_path=" + nativeGuiBundlePath + "\n"
    summary = summary + "native_gui_launcher_module=" + packageImportPrefix + "/native_gui_bundle_main\n"
    summary = summary + "native_gui_launcher_module_path=" + launcherModulePath + "\n"
    summary = summary + "native_gui_launcher_exe_path=" + launcherExePath + "\n"
    summary = summary + "native_gui_launcher_compile_report_path=" + launcherCompileReportPath + "\n"
    summary = summary + "native_gui_launcher_compile_log_path=" + launcherCompileLogPath + "\n"
    summary = summary + "native_gui_launcher_run_log_path=" + launcherRunLogPath + "\n"
    summary = summary + "native_gui_launcher_compile_returncode=0\n"
    summary = summary + "native_gui_launcher_run_returncode=0\n"
    summary = summary + "native_gui_launcher_compile_ok=true\n"
    summary = summary + "native_gui_launcher_run_ok=true\n"
    summary = summary + "native_gui_bundle_ready=true\n"
    summary = summary + "native_gui_host_ready=true\n"
    summary = summary + "native_gui_renderer_ready=true\n"
    summary = summary + "native_gui_exec_snapshot_path=" + execSnapshotPath + "\n"
    summary = summary + "native_gui_route_catalog_path=" + routeCatalogPath + "\n"
    summary = summary + "native_gui_session_path=" + sessionPath + "\n"
    summary = summary + "native_gui_session_preview_ready=true\n"
    summary = summary + "native_gui_session_preview_mode=cheng_ui_layout_surface_v1\n"
    summary = summary + "native_gui_layout_surface_path=" + layoutSurfacePath + "\n"
    summary = summary + "native_gui_layout_surface_ready=true\n"
    summary = summary + "native_gui_layout_surface_node_count=" + intToStr(nodeCount) + "\n"
    summary = summary + "native_gui_layout_surface_source_module=" + sourceModulePath + "\n"
    summary = summary + "native_gui_layout_surface_source_component=" + sourceComponentName + "\n"
    summary = summary + "native_gui_layout_surface_strategy=tsx_ast_entry_module\n"
    summary = summary + "native_gui_layout_surface_component_expansion_count=0\n"
    summary = summary + "native_gui_layout_surface_parsed_module_count=1\n"
    summary = summary + "native_gui_layout_surface_styled_node_count=" + intToStr(styledNodeCount) + "\n"
    summary = summary + "native_gui_layout_surface_interactive_node_count=" + intToStr(interactiveNodeCount) + "\n"
    summary = summary + "native_gui_style_layout_surface_path=" + styleLayoutSurfacePath + "\n"
    summary = summary + "native_gui_style_layout_surface_ready=true\n"
    summary = summary + "native_gui_style_layout_surface_node_count=" + intToStr(nodeCount) + "\n"
    summary = summary + "native_gui_style_layout_overlay_node_count=0\n"
    summary = summary + "native_gui_style_layout_surface_surface_node_count=" + intToStr(surfaceNodeCount) + "\n"
    summary = summary + "native_gui_style_layout_surface_control_node_count=" + intToStr(styleControlCount) + "\n"
    summary = summary + "native_gui_native_layout_plan_path=" + nativeLayoutPlanPath + "\n"
    summary = summary + "native_gui_native_layout_plan_ready=true\n"
    summary = summary + "native_gui_native_layout_plan_policy_source=cheng_seed_ast_layout_v1\n"
    summary = summary + "native_gui_native_layout_plan_item_count=" + intToStr(itemCount) + "\n"
    summary = summary + "native_gui_native_layout_plan_viewport_item_count=" + intToStr(viewportItemCount) + "\n"
    summary = summary + "native_gui_native_layout_plan_clipped_item_count=" + intToStr(clippedItemCount) + "\n"
    summary = summary + "native_gui_native_layout_plan_interactive_item_count=" + intToStr(interactiveNodeCount) + "\n"
    summary = summary + "native_gui_native_layout_plan_source_backed_item_count=" + intToStr(nodeCount) + "\n"
    summary = summary + "native_gui_native_layout_plan_scroll_height=" + intToStr(scrollHeight) + "\n"
    summary = summary + "native_gui_render_plan_path=" + nativeRenderPlanPath + "\n"
    summary = summary + "native_gui_render_plan_ready=true\n"
    summary = summary + "native_gui_render_plan_command_count=" + renderCommandCountText + "\n"
    summary = summary + "native_gui_render_plan_visible_layout_item_count=" + renderVisibleCountText + "\n"
    summary = summary + "native_gui_runtime_path=" + nativeRuntimePath + "\n"
    summary = summary + "native_gui_runtime_state_path=" + nativeRuntimeStatePath + "\n"
    summary = summary + "native_gui_runtime_exe_path=" + nativeRuntimeCompiledExePath + "\n"
    summary = summary + "native_gui_runtime_launcher_exe_path=" + nativeRuntimeCompiledExePath + "\n"
    summary = summary + "native_gui_runtime_compiled_exe_path=" + nativeRuntimeCompiledExePath + "\n"
    summary = summary + "native_gui_runtime_contract_path=" + nativeRuntimeContractPath + "\n"
    summary = summary + "native_gui_runtime_mode=cheng_generic_runtime_contract_v1\n"
    summary = summary + "native_gui_runtime_compile_report_path=" + nativeRuntimeCompileReportPath + "\n"
    summary = summary + "native_gui_runtime_compile_log_path=" + nativeRuntimeCompileLogPath + "\n"
    summary = summary + "native_gui_runtime_run_log_path=" + nativeRuntimeRunLogPath + "\n"
    summary = summary + "native_gui_runtime_controller_log_path=" + nativeRuntimeControllerLogPath + "\n"
    summary = summary + "native_gui_runtime_controller_returncode=0\n"
    summary = summary + "native_gui_runtime_compile_returncode=0\n"
    summary = summary + "native_gui_runtime_run_returncode=0\n"
    summary = summary + "native_gui_runtime_manifest_ready=false\n"
    summary = summary + "native_gui_runtime_contract_payload_ready=true\n"
    summary = summary + "native_gui_runtime_bundle_payload_ready=true\n"
    summary = summary + "native_gui_storage_host_ready=true\n"
    summary = summary + "native_gui_fetch_host_ready=true\n"
    summary = summary + "native_gui_custom_event_host_ready=true\n"
    summary = summary + "native_gui_resize_observer_host_ready=true\n"
    summary = summary + "native_gui_runtime_focused_item_id=\n"
    summary = summary + "native_gui_runtime_typed_text=\n"
    summary = summary + "native_gui_exec_snapshot_route_state=" + routeState + "\n"
    summary = summary + "native_gui_route_state=" + routeState + "\n"
    summary = summary + "entry_route_state=" + entryRouteState + "\n"
    summary = summary + "route_count=" + intToStr(routeCount) + "\n"
    summary = summary + "supported_count=" + intToStr(supportedCount) + "\n"
    summary = summary + "unsupported_count=" + intToStr(unsupportedCount) + "\n"
    summary = summary + "required_host_group_count=" + requiredGroupCountText + "\n"
    summary = summary + "required_host_groups=" + requiredGroupsCsv + "\n"
    summary = summary + "required_host_method_count=0\n"
    summary = summary + "native_gui_host_abi_feature_hits=local_storage,fetch,custom_event,resize_observer\n"
    summary = summary + "native_gui_host_abi_first_batch_ready=true\n"
    summary = summary + "native_gui_host_abi_first_batch_features=local_storage,fetch,custom_event,resize_observer\n"
    summary = summary + "native_gui_host_abi_first_batch_missing_features=\n"
    summary = summary + "asset_count=" + assetCountText + "\n"
    summary = summary + "tailwind_token_count=" + tailwindCountText + "\n"
    summary = summary + "initial_semantic_nodes_count=" + intToStr(semanticNodesCount) + "\n"
    summary = summary + "package_root=" + packageRoot + "\n"
    summary = summary + "package_id=" + packageId + "\n"
    summary = summary + "native_gui_bundle_seed=" + seedOwner + "\n"
    summary = summary + "native_gui_bundle_seed_owner=cheng.live_controller\n"
    if !chengpath.WriteTextFile("", nativeGuiBundleSummaryPath, summary):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed failed to write summary")
        return false
    var report = "{\n"
    report = report + "  \"format\": \"controller_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"command\": \"native-gui-bundle\",\n"
    report = report + "  \"ok\": true,\n"
    report = report + "  \"reason\": \"ok\",\n"
    report = report + "  \"native_gui_bundle_seed\": " + r2cControllerJsonQuote(seedOwner) + ",\n"
    report = report + "  \"repo_root\": " + r2cControllerJsonQuote(repo) + ",\n"
    report = report + "  \"out_dir\": " + r2cControllerJsonQuote(outDir) + ",\n"
    report = report + "  \"primary_artifact_path\": " + r2cControllerJsonQuote(nativeGuiBundlePath) + ",\n"
    report = report + "  \"primary_artifact_format\": \"native_gui_bundle_v1\",\n"
    report = report + "  \"module_count\": " + moduleCountText + ",\n"
    report = report + "  \"route_count\": " + intToStr(routeCount) + ",\n"
    report = report + "  \"semantic_nodes_count\": " + intToStr(semanticNodesCount) + ",\n"
    report = report + "  \"asset_count\": " + assetCountText + ",\n"
    report = report + "  \"tailwind_token_count\": " + tailwindCountText + ",\n"
    report = report + "  \"required_host_group_count\": " + requiredGroupCountText + ",\n"
    report = report + "  \"required_host_groups\": " + r2cControllerJsonArrayFromCsv(requiredGroupsCsv) + ",\n"
    report = report + "  \"typescript_version\": " + r2cControllerJsonQuote(typescriptVersion) + ",\n"
    report = report + "  \"native_gui_route_state\": " + r2cControllerJsonQuote(routeState) + ",\n"
    report = report + "  \"native_gui_layout_surface_path\": " + r2cControllerJsonQuote(layoutSurfacePath) + ",\n"
    report = report + "  \"native_gui_native_layout_plan_path\": " + r2cControllerJsonQuote(nativeLayoutPlanPath) + ",\n"
    report = report + "  \"native_gui_runtime_path\": " + r2cControllerJsonQuote(nativeRuntimePath) + ",\n"
    report = report + "  \"native_gui_runtime_ready\": true,\n"
    report = report + "  \"native_gui_runtime_bundle_ready\": true,\n"
    report = report + "  \"native_gui_runtime_contract_ready\": true\n"
    report = report + "}\n"
    if !chengpath.WriteTextFile("", reportPath, report):
        r2cControllerPrintErr("r2c-react: Cheng native gui seed failed to write report")
        return false
    return true

fn r2cControllerNativeGuiBundle(root: str,
                                args: str[]): int32 =
    let effectiveRoot: str = r2cControllerEffectiveRoot(root)
    let currentDir: str = r2cControllerRoot()
    let repoBase: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--repo", currentDir))
    let outDirFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--out-dir", ""))
    let routeStateFlag: str = r2cControllerOwnText(cmdline.ReadFlagOrDefault("--route-state", ""))
    let repo: str = chengpath.PathAbsolute(effectiveRoot, repoBase)
    var outDir: str = r2cControllerDefaultOutDir(repo)
    if strings.Len(outDirFlag) > 0:
        outDir = chengpath.PathAbsolute(repo, outDirFlag)
    var scratchOk: bool = chengpath.MkdirP("", outDir)
    scratchOk
    let nativeGuiBundleHelper: str = "cheng.native_gui_bundle_seed_v1"
    let tsxAstPath: str = os.JoinPath(outDir, "tsx_ast_v1.json")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    let staticSummaryPath: str = os.JoinPath(outDir, "static_surface.summary.env")
    let codegenSummaryPath: str = os.JoinPath(outDir, "codegen_surface.summary.env")
    let nativeGuiBundleSummaryPath: str = os.JoinPath(outDir, "native_gui_bundle.summary.env")
    let reportPath: str = os.JoinPath(outDir, "native_gui_bundle_report_v1.json")
    var codegenManifestPath: str = os.JoinPath(outDir, "cheng_codegen_v1.json")
    var routeCatalogPath: str = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    var execSnapshotPath: str = os.JoinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    var nativeGuiBundlePath: str = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    let nativeGuiHostContractPath: str = os.JoinPath(outDir, "unimaker_host_v1.json")
    let nativeGuiAssetManifestPath: str = os.JoinPath(outDir, "asset_manifest_v1.json")
    let nativeGuiTailwindManifestPath: str = os.JoinPath(outDir, "tailwind_style_manifest_v1.json")
    var moduleCount: int32
    var routeCount: int32
    var semanticNodesCount: int32
    var assetCount: int32
    var tailwindTokenCount: int32
    var requiredHostGroupCount: int32
    var requiredHostGroupsCsv = ""
    var typescriptVersion = ""
    var helperExitCode: int32
    var helperOutput: str
    os.OsSetEmpty(helperOutput)

    if !r2cControllerWriteChengTsxFrontendSeed(effectiveRoot,
                                               repo,
                                               outDir,
                                               [],
                                               tsxAstPath,
                                               tsxSummaryPath,
                                               ""):
        r2cControllerPrintErr("r2c-react: Cheng TSX frontend seed failed")
        return 1

    moduleCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(tsxSummaryPath, "module_count", "0"))
    typescriptVersion = r2cControllerReadSummaryValue(tsxSummaryPath, "typescript_version", "")

    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    if !r2csurface.r2cRunStaticSurface(repo, outDir, tsxAstPath, staticSummaryPath, [], staticSurface):
        r2cControllerPrintErr("r2c-react: static surface failed")
        if strings.Len(staticSurface.message) > 0:
            r2cControllerPrintErr(staticSurface.message)
        return 1
    assetCount = staticSurface.assetCount
    tailwindTokenCount = staticSurface.tailwindTokenCount
    requiredHostGroupCount = staticSurface.requiredHostGroupCount
    requiredHostGroupsCsv = staticSurface.requiredHostGroupsCsv
    typescriptVersion = staticSurface.typescriptVersion

    if !r2cControllerWriteChengCodegenSurface(effectiveRoot,
                                              repo,
                                              outDir,
                                              tsxAstPath,
                                              codegenSummaryPath,
                                              os.JoinPath(outDir, "codegen_surface_report_v1.json")):
        r2cControllerPrintErr("r2c-react: Cheng codegen surface failed")
        return 1

    codegenManifestPath = r2cControllerReadSummaryValue(codegenSummaryPath, "codegen_manifest_path", codegenManifestPath)
    routeCatalogPath = r2cControllerReadSummaryValue(codegenSummaryPath, "route_catalog_path", routeCatalogPath)
    routeCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(codegenSummaryPath, "route_count", "0"))
    typescriptVersion = r2cControllerReadSummaryValue(codegenSummaryPath, "typescript_version", typescriptVersion)

    if !r2cControllerWriteChengNativeGuiBundleSeed(effectiveRoot,
                                                   repo,
                                                   outDir,
                                                   tsxAstPath,
                                                   codegenManifestPath,
                                                   routeCatalogPath,
                                                   execSnapshotPath,
                                                   nativeGuiBundlePath,
                                                   nativeGuiBundleSummaryPath,
                                                   reportPath,
                                                   nativeGuiHostContractPath,
                                                   nativeGuiAssetManifestPath,
                                                   nativeGuiTailwindManifestPath,
                                                   staticSummaryPath,
                                                   codegenSummaryPath,
                                                   tsxSummaryPath,
                                                   routeStateFlag,
                                                   nativeGuiBundleHelper):
        return 1

    nativeGuiBundlePath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_bundle_path", nativeGuiBundlePath)
    semanticNodesCount = r2cControllerParseInt32(r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "initial_semantic_nodes_count", "0"))
    execSnapshotPath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_exec_snapshot_path", execSnapshotPath)
    routeCatalogPath = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_route_catalog_path", routeCatalogPath)
    let launcherModule: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_launcher_module", "")
    let hostReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_host_ready", "")
    let rendererReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_renderer_ready", "")
    let sessionPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_path", "")
    let sessionPreviewReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_preview_ready", "")
    let sessionPreviewMode: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_session_preview_mode", "")
    let routeState: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_route_state", routeStateFlag)
    let layoutSurfacePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_path", "")
    let layoutSurfaceReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_ready", "")
    let layoutSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_node_count", "0")
    let layoutSurfaceSourceModule: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_source_module", "")
    let layoutSurfaceSourceComponent: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_source_component", "")
    let layoutSurfaceStrategy: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_strategy", "")
    let layoutSurfaceComponentExpansionCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_component_expansion_count", "0")
    let layoutSurfaceParsedModuleCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_parsed_module_count", "0")
    let layoutSurfaceStyledNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_styled_node_count", "0")
    let layoutSurfaceInteractiveNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_layout_surface_interactive_node_count", "0")
    let styleLayoutSurfacePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_path", "")
    let styleLayoutSurfaceReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_ready", "")
    let styleLayoutSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_node_count", "0")
    let styleLayoutOverlayNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_overlay_node_count", "0")
    let styleLayoutSurfaceSurfaceNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_surface_node_count", "0")
    let styleLayoutSurfaceControlNodeCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_style_layout_surface_control_node_count", "0")
    let nativeLayoutPlanPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_path", "")
    let nativeLayoutPlanReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_ready", "")
    let nativeLayoutPlanPolicySource: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_policy_source", "")
    let nativeLayoutPlanItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_item_count", "0")
    let nativeLayoutPlanViewportItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_viewport_item_count", "0")
    let nativeLayoutPlanClippedItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_clipped_item_count", "0")
    let nativeLayoutPlanInteractiveItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_interactive_item_count", "0")
    let nativeLayoutPlanSourceBackedItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_source_backed_item_count", "0")
    let nativeLayoutPlanScrollHeightText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_native_layout_plan_scroll_height", "0")
    let nativeRenderPlanPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_render_plan_path", "")
    var nativeRenderPlanReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_render_plan_ready", "")
    var nativeRenderPlanCommandCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_render_plan_command_count", "0")
    var nativeRenderPlanVisibleLayoutItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_render_plan_visible_layout_item_count", "0")
    let nativeRuntimePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_path", "")
    var nativeRuntimeReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_ready", "")
    let nativeRuntimeStatePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_state_path", "")
    let nativeRuntimeExePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_exe_path", "")
    let nativeRuntimeLauncherExePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_launcher_exe_path", "")
    let nativeRuntimeCompiledExePath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_compiled_exe_path", "")
    let nativeRuntimeContractPath: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_path", "")
    let nativeRuntimeMode: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_mode", "")
    var nativeRuntimeBundleReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_ready", "")
    var nativeRuntimeContractReadyText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_ready", "")
    var nativeRuntimeBundleRouteState: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_route_state", routeState)
    var nativeRuntimeBundleRouteCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_route_count", "0")
    var nativeRuntimeBundleSupportedCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_supported_count", "0")
    var nativeRuntimeBundleSemanticNodesCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_semantic_nodes_count", "0")
    var nativeRuntimeBundleLayoutItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_layout_item_count", "0")
    var nativeRuntimeBundleRenderCommandCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_bundle_render_command_count", "0")
    var nativeRuntimeContractLayoutItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_layout_item_count", "0")
    var nativeRuntimeContractViewportItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_viewport_item_count", "0")
    var nativeRuntimeContractInteractiveItemCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "native_gui_runtime_contract_interactive_item_count", "0")
    let reportModuleCountText: str = r2cControllerReadSummaryValue(codegenSummaryPath, "module_count", r2cControllerReadSummaryValue(tsxSummaryPath, "module_count", "0"))
    let reportRouteCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "route_count", r2cControllerReadSummaryValue(codegenSummaryPath, "route_count", "0"))
    let reportSupportedCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "supported_count", nativeRuntimeBundleSupportedCountText)
    let reportUnsupportedCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "unsupported_count", "0")
    let reportSemanticNodesCountText: str = r2cControllerReadSummaryValue(nativeGuiBundleSummaryPath, "initial_semantic_nodes_count", "0")
