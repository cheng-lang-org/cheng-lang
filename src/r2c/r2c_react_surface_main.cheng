import std/os
import std/strings
import std/strutils as strutil
import cheng/core/tooling/path as chengpath

@importc("get_stderr")
fn r2cSurfaceStderrBridge(): os.File

type
    R2cStaticSurfaceRunResult =
        ok: bool
        message: str
        moduleCount: int32
        assetCount: int32
        tailwindTokenCount: int32
        requiredHostGroupCount: int32
        requiredHostGroupsCsv: str
        typescriptVersion: str

    R2cSemanticSurfaceRunResult =
        ok: bool
        message: str
        moduleCount: int32
        rsgNodeCount: int32
        rsgEdgeCount: int32
        blockerCount: int32
        blocked: bool
        typescriptVersion: str
        entryModule: str

    R2cRsgBuilder =
        nodeIds: str[]
        nodeKinds: str[]
        nodeLabels: str[]
        nodeCapabilities: str[]
        nodeSourcePaths: str[]
        nodeSourceSpans: str[]
        edgeFromIds: str[]
        edgeToIds: str[]
        edgeKinds: str[]
        edgeLabels: str[]

fn r2cSurfaceBoolText(value: bool): str =
    if value:
        return "true"
    return "false"

fn r2cSurfaceDigitValue(text: str): int32 =
    if text == "0":
        return 0
    elif text == "1":
        return 1
    elif text == "2":
        return 2
    elif text == "3":
        return 3
    elif text == "4":
        return 4
    elif text == "5":
        return 5
    elif text == "6":
        return 6
    elif text == "7":
        return 7
    elif text == "8":
        return 8
    elif text == "9":
        return 9
    return -1

fn r2cSurfaceParsePositiveInt32Raw(raw: str): int32 =
    let total: int32 = strings.Len(raw)
    if total <= 0:
        return 0
    if total == 1:
        return r2cSurfaceDigitValue(raw)
    let prefixValue: int32 = r2cSurfaceParsePositiveInt32Raw(r2cSurfaceSlice(raw, 0, total - 1))
    let lastDigit: int32 = r2cSurfaceDigitValue(r2cSurfaceSlice(raw, total - 1, 1))
    if prefixValue < 0 || lastDigit < 0:
        return -1
    return prefixValue * 10 + lastDigit

fn r2cSurfaceParseInt32(text: str): int32 =
    let raw: str = text
    if strings.Len(raw) <= 0:
        return 0
    if r2cSurfaceSlice(raw, 0, 1) == "-":
        let parsedNeg: int32 = r2cSurfaceParsePositiveInt32Raw(r2cSurfaceSlice(raw, 1, strings.Len(raw) - 1))
        if parsedNeg < 0:
            return 0
        return 0 - parsedNeg
    let parsed: int32 = r2cSurfaceParsePositiveInt32Raw(raw)
    if parsed < 0:
        return 0
    return parsed

fn r2cSurfaceJsonEscape(text: str): str =
    return text

fn r2cSurfaceJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    return strutil.Join([quote, r2cSurfaceJsonEscape(text), quote], "")

fn r2cSurfaceSlice(text: str,
                   start: int32,
                   length: int32): str =
    if length <= 0:
        return ""
    return chengpath.TextSlice(text, start, length)

fn r2cSurfacePrintErr(text: str) =
    os.WriteLine(r2cSurfaceStderrBridge(), text)

fn r2cSurfaceDebug(phase: str) =
    if os.GetEnv("R2C_REACT_SURFACE_DEBUG") == "1":
        r2cSurfacePrintErr(strutil.Join(["[r2c-surface] ", phase], ""))

fn r2cSurfaceAddUnique(values: var str[], valueRaw: str) =
    let value: str = strutil.Strip(valueRaw)
    if strings.Len(value) <= 0:
        return
    for i in 0..<values.len:
        if values[i] == value:
            return
    add(values, value)

fn r2cSurfaceCsvAddUnique(csvText: str, valueRaw: str): str =
    let value: str = strutil.Strip(valueRaw)
    if strings.Len(value) <= 0:
        return csvText
    if strings.Len(csvText) <= 0:
        return value
    let total: int32 = strings.Len(csvText)
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif csvText[i] == ',':
            endHit = true
        if !endHit:
            continue
        let itemLen: int32 = i - start
        if itemLen > 0:
            let item: str = r2cSurfaceSlice(csvText, start, itemLen)
            if item == value:
                return csvText
        start = i + 1
    return strutil.Join([csvText, ",", value], "")

fn r2cSurfaceJsonArrayFromCsv(csvText: str): str =
    if strings.Len(csvText) <= 0:
        return "[]"
    var out = "["
    var wrote = false
    let total: int32 = strings.Len(csvText)
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif csvText[i] == ',':
            endHit = true
        if !endHit:
            continue
        let itemLen: int32 = i - start
        if itemLen > 0:
            let item: str = r2cSurfaceSlice(csvText, start, itemLen)
            if wrote:
                out = strutil.Join([out, ", "], "")
            out = strutil.Join([out, r2cSurfaceJsonQuote(item)], "")
            wrote = true
        start = i + 1
    out = strutil.Join([out, "]"], "")
    return out

fn r2cSurfaceReadLines(pathText: str, out: var str[]) =
    out = []
    if !chengpath.PathFileExists(pathText):
        return
    let text: str = chengpath.ReadTextFile("", pathText)
    let total: int32 = strings.Len(text)
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif text[i] == '\n':
            endHit = true
        if !endHit:
            continue
        let rawLen: int32 = i - start
        var line: str
        if rawLen > 0:
            line = r2cSurfaceSlice(text, start, rawLen)
        if strings.Len(line) > 0:
            if line[strings.Len(line) - 1] == '\r':
                line = r2cSurfaceSlice(line, 0, strings.Len(line) - 1)
        if strings.Len(strutil.Strip(line)) > 0:
            add(out, line)
        start = i + 1

fn r2cSurfaceEnvValue(lines: str[], key: str, fallback: str): str =
    for i in 0..<lines.len:
        let line: str = lines[i]
        let total: int32 = strings.Len(line)
        for j in 0..<total:
            if line[j] != '=':
                continue
            let name: str = r2cSurfaceSlice(line, 0, j)
            if name == key:
                return r2cSurfaceSlice(line, j + 1, total - j - 1)
            break
    return fallback

fn r2cSurfaceSplitCsv(textRaw: str, out: var str[]) =
    out = []
    let text: str = strutil.Strip(textRaw)
    if strings.Len(text) <= 0:
        return
    let total: int32 = strings.Len(text)
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif text[i] == ',':
            endHit = true
        if !endHit:
            continue
        let itemLen: int32 = i - start
        if itemLen > 0:
            add(out, r2cSurfaceSlice(text, start, itemLen))
        start = i + 1

fn r2cSurfaceField(line: str, index: int32): str =
    let total: int32 = strings.Len(line)
    var current: int32
    var start: int32
    for i in 0..total:
        var endHit = false
        if i == total:
            endHit = true
        elif line[i] == '\t':
            endHit = true
        if !endHit:
            continue
        if current == index:
            return r2cSurfaceSlice(line, start, i - start)
        current = current + 1
        start = i + 1
    return ""

fn r2cSurfaceNormalizeRootValue(valueRaw: str): str =
    var value: str = strutil.Strip(valueRaw)
    if value == "" || value == ".":
        return "."
    while strings.Len(value) > 0:
        if value[0] != '/' && value[0] != '\\':
            break
        value = r2cSurfaceSlice(value, 1, strings.Len(value) - 1)
    while strings.Len(value) > 0:
        let last: int32 = strings.Len(value) - 1
        if value[last] != '/' && value[last] != '\\':
            break
        value = r2cSurfaceSlice(value, 0, last)
    if strings.Len(value) <= 0:
        return "."
    return value

fn r2cSurfacePathUnderRoots(relPath: str, roots: str[]): bool =
    for i in 0..<roots.len:
        let root: str = roots[i]
        if root == ".":
            return true
        if relPath == root:
            return true
        if chengpath.TextStartsWith(relPath, strutil.Join([root, "/"], "")):
            return true
    return false

fn r2cSurfaceNormalizeAssetRoots(repo: str,
                                 requested: str[],
                                 fallback: str[],
                                 rootsOut: var str[],
                                 errorOut: var str): bool =
    rootsOut = []
    errorOut = ""
    var picks: str[]
    if requested.len > 0:
        for i in 0..<requested.len:
            add(picks, requested[i])
    else:
        for i in 0..<fallback.len:
            add(picks, fallback[i])
    for i in 0..<picks.len:
        let normalized: str = r2cSurfaceNormalizeRootValue(picks[i])
        if normalized != ".":
            let fullPath: str = os.JoinPath(repo, normalized)
            if !os.DirExists(fullPath):
                if requested.len > 0:
                    errorOut = strutil.Join(["missing asset root: ", normalized], "")
                    return false
                continue
        r2cSurfaceAddUnique(rootsOut, normalized)
    if rootsOut.len <= 0:
        add(rootsOut, ".")
    return true

fn r2cSurfaceFeatureCount(featureModulePaths: str[],
                          featureNames: str[],
                          featureCounts: int32[],
                          modulePath: str,
                          featureName: str): int32 =
    for i in 0..<featureModulePaths.len:
        if featureModulePaths[i] == modulePath && featureNames[i] == featureName:
            return featureCounts[i]
    return 0

fn r2cSurfaceFeatureHitTotal(featureNames: str[],
                             featureCounts: int32[],
                             featureName: str): int32 =
    var total: int32
    for i in 0..<featureNames.len:
        if featureNames[i] == featureName:
            total = total + featureCounts[i]
    return total

fn r2cSurfaceHasPair(first: str[], second: str[], left: str, right: str): bool =
    for i in 0..<first.len:
        if first[i] == left && second[i] == right:
            return true
    return false

fn r2cSurfaceResolveEntryModule(modulePaths: str[]): str =
    let preferred: str[] = [
        "app/App.tsx",
        "app/main.tsx",
        "app/main.ts",
        "app/index.tsx",
        "app/index.ts"
    ]
    for i in 0..<preferred.len:
        for j in 0..<modulePaths.len:
            if modulePaths[j] == preferred[i]:
                return preferred[i]
    if modulePaths.len > 0:
        return modulePaths[0]
    return ""

fn r2cSurfaceAsyncFeatureTotal(featureModulePaths: str[],
                               featureNames: str[],
                               featureCounts: int32[],
                               modulePath: str): int32 =
    return r2cSurfaceFeatureCount(featureModulePaths, featureNames, featureCounts, modulePath, "fetch") +
           r2cSurfaceFeatureCount(featureModulePaths, featureNames, featureCounts, modulePath, "worker") +
           r2cSurfaceFeatureCount(featureModulePaths, featureNames, featureCounts, modulePath, "webassembly") +
           r2cSurfaceFeatureCount(featureModulePaths, featureNames, featureCounts, modulePath, "rtc") +
           r2cSurfaceFeatureCount(featureModulePaths, featureNames, featureCounts, modulePath, "media")

fn r2cSurfaceWriteSummaryStatic(path: str,
                                values: R2cStaticSurfaceRunResult,
                                moduleInventoryPath: str,
                                hostContractPath: str,
                                assetManifestPath: str,
                                tailwindManifestPath: str): bool =
    var out = ""
    out = strutil.Join([out, "module_count=", IntToStr(values.moduleCount), "\n"], "")
    out = strutil.Join([out, "asset_count=", IntToStr(values.assetCount), "\n"], "")
    out = strutil.Join([out, "tailwind_token_count=", IntToStr(values.tailwindTokenCount), "\n"], "")
    out = strutil.Join([out, "required_host_group_count=", IntToStr(values.requiredHostGroupCount), "\n"], "")
    out = strutil.Join([out, "required_host_groups=", values.requiredHostGroupsCsv, "\n"], "")
    out = strutil.Join([out, "typescript_version=", values.typescriptVersion, "\n"], "")
    out = strutil.Join([out, "module_inventory_path=", moduleInventoryPath, "\n"], "")
    out = strutil.Join([out, "host_contract_path=", hostContractPath, "\n"], "")
    out = strutil.Join([out, "asset_manifest_path=", assetManifestPath, "\n"], "")
    out = strutil.Join([out, "tailwind_manifest_path=", tailwindManifestPath, "\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceWriteSummarySemantic(path: str,
                                  values: R2cSemanticSurfaceRunResult,
                                  rsgPath: str,
                                  blockerPath: str): bool =
    var out = ""
    out = strutil.Join([out, "module_count=", IntToStr(values.moduleCount), "\n"], "")
    out = strutil.Join([out, "rsg_node_count=", IntToStr(values.rsgNodeCount), "\n"], "")
    out = strutil.Join([out, "rsg_edge_count=", IntToStr(values.rsgEdgeCount), "\n"], "")
    out = strutil.Join([out, "blocker_count=", IntToStr(values.blockerCount), "\n"], "")
    out = strutil.Join([out, "blocked=", r2cSurfaceBoolText(values.blocked), "\n"], "")
    out = strutil.Join([out, "typescript_version=", values.typescriptVersion, "\n"], "")
    out = strutil.Join([out, "entry_module=", values.entryModule, "\n"], "")
    out = strutil.Join([out, "rsg_path=", rsgPath, "\n"], "")
    out = strutil.Join([out, "blocker_report_path=", blockerPath, "\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceWriteModuleInventory(path: str,
                                  repo: str,
                                  sourceRoots: str[],
                                  modulePaths: str[],
                                  moduleGenerated: int32[],
                                  moduleJsxLike: int32[],
                                  moduleExportCounts: int32[]): bool =
    let sourceRootsJson: str = r2cSurfaceJsonArrayFromCsv(strutil.Join(sourceRoots, ","))
    var out = ""
    out = strutil.Join([out, "{\n"], "")
    out = strutil.Join([out, "  \"format\": \"module_inventory_v1\",\n"], "")
    out = strutil.Join([out, "  \"repo_root\": ", r2cSurfaceJsonQuote(repo), ",\n"], "")
    out = strutil.Join([out, "  \"source_roots\": ", sourceRootsJson, ",\n"], "")
    out = strutil.Join([out, "  \"modules\": [\n"], "")
    for i in 0..<modulePaths.len:
        let pathJson: str = r2cSurfaceJsonQuote(modulePaths[i])
        let generatedText: str = r2cSurfaceBoolText(moduleGenerated[i] != 0)
        let jsxLikeText: str = r2cSurfaceBoolText(moduleJsxLike[i] != 0)
        let exportCountText: str = IntToStr(moduleExportCounts[i])
        if i > 0:
            out = strutil.Join([out, ",\n"], "")
        out = strutil.Join([out, "    {"], "")
        out = strutil.Join([out, "\"path\": ", pathJson, ", "], "")
        out = strutil.Join([out, "\"generated\": ", generatedText, ", "], "")
        out = strutil.Join([out, "\"jsx_like\": ", jsxLikeText, ", "], "")
        out = strutil.Join([out, "\"export_count\": ", exportCountText], "")
        out = strutil.Join([out, "}"], "")
    out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, "  ]\n"], "")
    out = strutil.Join([out, "}\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceWriteHostContract(path: str,
                               featureHitNames: str[],
                               requiredGroups: str[]): bool =
    let hostGroups: str[] = ["StorageHost", "NetHost", "RtcHost", "MediaHost", "PlatformHost", "SceneHost", "WindowHost"]
    let hostMethodsCsv: str[] = [
        "getItem,setItem,removeItem,clear",
        "fetch,historyPush,historyReplace,workerSpawn,wasmInstantiate",
        "peerConnectionOpen,peerConnectionClose,readStats,openDataChannel",
        "getUserMedia,attachAudio,setTrackEnabled",
        "readEnv,serviceWorkerUpdate,capacitorInvoke,emitCustomEvent",
        "createScene,createMesh,setCamera,stepPhysics",
        "createWindow,requestFrame,dispatchInput,invalidateLayout"
    ]
    var requiredCsv = strutil.Join(requiredGroups, ",")
    var featureCsv = strutil.Join(featureHitNames, ",")
    var out = ""
    out = strutil.Join([out, "{\n"], "")
    out = strutil.Join([out, "  \"format\": \"unimaker_host_v1\",\n"], "")
    out = strutil.Join([out, "  \"name\": \"unimaker_host_v1\",\n"], "")
    out = strutil.Join([out, "  \"methods\": [\n"], "")
    var wrote = false
    for i in 0..<hostGroups.len:
        var methodNames: str[]
        r2cSurfaceSplitCsv(hostMethodsCsv[i], methodNames)
        var required = false
        for j in 0..<requiredGroups.len:
            if requiredGroups[j] == hostGroups[i]:
                required = true
                break
        for j in 0..<methodNames.len:
            if wrote:
                out = strutil.Join([out, ",\n"], "")
            out = strutil.Join([out, "    {"], "")
            out = strutil.Join([out, "\"group\": ", r2cSurfaceJsonQuote(hostGroups[i]), ", "], "")
            out = strutil.Join([out, "\"name\": ", r2cSurfaceJsonQuote(methodNames[j]), ", "], "")
            out = strutil.Join([out, "\"signature\": \"opaque\", "], "")
            out = strutil.Join([out, "\"required\": ", r2cSurfaceBoolText(required)], "")
            out = strutil.Join([out, "}"], "")
            wrote = true
    out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, "  ],\n"], "")
    out = strutil.Join([out, "  \"required_groups\": ", r2cSurfaceJsonArrayFromCsv(requiredCsv), ",\n"], "")
    out = strutil.Join([out, "  \"feature_hits\": ", r2cSurfaceJsonArrayFromCsv(featureCsv), "\n"], "")
    out = strutil.Join([out, "}\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceWriteTailwindManifest(path: str,
                                   repo: str,
                                   tokenNames: str[],
                                   tokenSourcesCsv: str[],
                                   tokenCounts: int32[]): bool =
    var out = ""
    out = strutil.Join([out, "{\n"], "")
    out = strutil.Join([out, "  \"format\": \"tailwind_style_manifest_v1\",\n"], "")
    out = strutil.Join([out, "  \"repo_root\": ", r2cSurfaceJsonQuote(repo), ",\n"], "")
    out = strutil.Join([out, "  \"tokens\": [\n"], "")
    for i in 0..<tokenNames.len:
        let tokenJson: str = r2cSurfaceJsonQuote(tokenNames[i])
        let sourcesJson: str = r2cSurfaceJsonArrayFromCsv(tokenSourcesCsv[i])
        let countText: str = IntToStr(tokenCounts[i])
        if i > 0:
            out = strutil.Join([out, ",\n"], "")
        out = strutil.Join([out, "    {"], "")
        out = strutil.Join([out, "\"token\": ", tokenJson, ", "], "")
        out = strutil.Join([out, "\"sources\": ", sourcesJson, ", "], "")
        out = strutil.Join([out, "\"count\": ", countText], "")
        out = strutil.Join([out, "}"], "")
    out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, "  ]\n"], "")
    out = strutil.Join([out, "}\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceWriteAssetManifest(path: str,
                                repo: str,
                                assetRoots: str[],
                                entryPaths: str[],
                                entryKinds: str[],
                                entrySourceModules: str[],
                                entryImportModes: str[]): bool =
    let assetRootsJson: str = r2cSurfaceJsonArrayFromCsv(strutil.Join(assetRoots, ","))
    var out = ""
    out = strutil.Join([out, "{\n"], "")
    out = strutil.Join([out, "  \"format\": \"asset_manifest_v1\",\n"], "")
    out = strutil.Join([out, "  \"repo_root\": ", r2cSurfaceJsonQuote(repo), ",\n"], "")
    out = strutil.Join([out, "  \"asset_roots\": ", assetRootsJson, ",\n"], "")
    out = strutil.Join([out, "  \"entries\": [\n"], "")
    for i in 0..<entryPaths.len:
        let pathJson: str = r2cSurfaceJsonQuote(entryPaths[i])
        let kindJson: str = r2cSurfaceJsonQuote(entryKinds[i])
        let sourceModuleJson: str = r2cSurfaceJsonQuote(entrySourceModules[i])
        let importModeJson: str = r2cSurfaceJsonQuote(entryImportModes[i])
        if i > 0:
            out = strutil.Join([out, ",\n"], "")
        out = strutil.Join([out, "    {"], "")
        out = strutil.Join([out, "\"path\": ", pathJson, ", "], "")
        out = strutil.Join([out, "\"kind\": ", kindJson, ", "], "")
        out = strutil.Join([out, "\"source_module\": ", sourceModuleJson, ", "], "")
        out = strutil.Join([out, "\"import_mode\": ", importModeJson, ", "], "")
        out = strutil.Join([out, "\"content_hash\": \"\""], "")
        out = strutil.Join([out, "}"], "")
    out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, "  ]\n"], "")
    out = strutil.Join([out, "}\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceWriteRsg(path: str,
                      repo: str,
                      entryModule: str,
                      builder: var R2cRsgBuilder): bool =
    var out = ""
    out = strutil.Join([out, "{\n"], "")
    out = strutil.Join([out, "  \"format\": \"rsg_v1\",\n"], "")
    out = strutil.Join([out, "  \"repo_root\": "], "")
    out = strutil.Join([out, r2cSurfaceJsonQuote(repo)], "")
    out = strutil.Join([out, ",\n"], "")
    out = strutil.Join([out, "  \"entry_module\": "], "")
    out = strutil.Join([out, r2cSurfaceJsonQuote(entryModule)], "")
    out = strutil.Join([out, ",\n"], "")
    out = strutil.Join([out, "  \"nodes\": [\n"], "")
    for i in 0..<builder.nodeIds.len:
        let idJson: str = r2cSurfaceJsonQuote(builder.nodeIds[i])
        let kindJson: str = r2cSurfaceJsonQuote(builder.nodeKinds[i])
        let labelJson: str = r2cSurfaceJsonQuote(builder.nodeLabels[i])
        let capabilityJson: str = r2cSurfaceJsonQuote(builder.nodeCapabilities[i])
        let sourcePathJson: str = r2cSurfaceJsonQuote(builder.nodeSourcePaths[i])
        let sourceSpanJson: str = r2cSurfaceJsonQuote(builder.nodeSourceSpans[i])
        if i > 0:
            out = strutil.Join([out, ",\n"], "")
        out = strutil.Join([out, "    {"], "")
        out = strutil.Join([out, "\"id\": "], "")
        out = strutil.Join([out, idJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"kind\": "], "")
        out = strutil.Join([out, kindJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"label\": "], "")
        out = strutil.Join([out, labelJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"capability\": "], "")
        out = strutil.Join([out, capabilityJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"sourcePath\": "], "")
        out = strutil.Join([out, sourcePathJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"sourceSpan\": "], "")
        out = strutil.Join([out, sourceSpanJson], "")
        out = strutil.Join([out, "}"], "")
    out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, "  ],\n"], "")
    out = strutil.Join([out, "  \"edges\": [\n"], "")
    for i in 0..<builder.edgeFromIds.len:
        let fromIdJson: str = r2cSurfaceJsonQuote(builder.edgeFromIds[i])
        let toIdJson: str = r2cSurfaceJsonQuote(builder.edgeToIds[i])
        let kindJson: str = r2cSurfaceJsonQuote(builder.edgeKinds[i])
        let labelJson: str = r2cSurfaceJsonQuote(builder.edgeLabels[i])
        if i > 0:
            out = strutil.Join([out, ",\n"], "")
        out = strutil.Join([out, "    {"], "")
        out = strutil.Join([out, "\"fromId\": "], "")
        out = strutil.Join([out, fromIdJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"toId\": "], "")
        out = strutil.Join([out, toIdJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"kind\": "], "")
        out = strutil.Join([out, kindJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"label\": "], "")
        out = strutil.Join([out, labelJson], "")
        out = strutil.Join([out, "}"], "")
    out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, "  ]\n"], "")
    out = strutil.Join([out, "}\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceWriteBlockerReport(path: str,
                                repo: str,
                                sourceRoots: str[],
                                blockerFiles: str[],
                                blockerLines: int32[],
                                blockerColumns: int32[],
                                blockerCodes: str[]): bool =
    let sourceRootsJson: str = r2cSurfaceJsonArrayFromCsv(strutil.Join(sourceRoots, ","))
    var out = ""
    out = strutil.Join([out, "{\n"], "")
    out = strutil.Join([out, "  \"format\": \"compile_blockers_v1\",\n"], "")
    out = strutil.Join([out, "  \"repo_root\": "], "")
    out = strutil.Join([out, r2cSurfaceJsonQuote(repo)], "")
    out = strutil.Join([out, ",\n"], "")
    out = strutil.Join([out, "  \"source_roots\": "], "")
    out = strutil.Join([out, sourceRootsJson], "")
    out = strutil.Join([out, ",\n"], "")
    out = strutil.Join([out, "  \"blockers\": [\n"], "")
    for i in 0..<blockerFiles.len:
        let fileJson: str = r2cSurfaceJsonQuote(blockerFiles[i])
        let lineText: str = IntToStr(blockerLines[i])
        let columnText: str = IntToStr(blockerColumns[i])
        let codeJson: str = r2cSurfaceJsonQuote(blockerCodes[i])
        if i > 0:
            out = strutil.Join([out, ",\n"], "")
        out = strutil.Join([out, "    {"], "")
        out = strutil.Join([out, "\"file\": "], "")
        out = strutil.Join([out, fileJson], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"line\": "], "")
        out = strutil.Join([out, lineText], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"column\": "], "")
        out = strutil.Join([out, columnText], "")
        out = strutil.Join([out, ", "], "")
        out = strutil.Join([out, "\"code\": "], "")
        out = strutil.Join([out, codeJson], "")
        out = strutil.Join([out, "}"], "")
    out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, "  ]\n"], "")
    out = strutil.Join([out, "}\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceWriteSemanticReport(path: str,
                                 repo: str,
                                 outDir: str,
                                 tsxAstPath: str,
                                 rsgPath: str,
                                 blockerPath: str,
                                 values: R2cSemanticSurfaceRunResult): bool =
    var out = ""
    out = strutil.Join([out, "{\n"], "")
    out = strutil.Join([out, "  \"format\": \"semantic_surface_report_v1\",\n"], "")
    out = strutil.Join([out, "  \"repo_root\": ", r2cSurfaceJsonQuote(repo), ",\n"], "")
    out = strutil.Join([out, "  \"out_dir\": ", r2cSurfaceJsonQuote(outDir), ",\n"], "")
    out = strutil.Join([out, "  \"tsx_ast_path\": ", r2cSurfaceJsonQuote(tsxAstPath), ",\n"], "")
    out = strutil.Join([out, "  \"rsg_path\": ", r2cSurfaceJsonQuote(rsgPath), ",\n"], "")
    out = strutil.Join([out, "  \"blocker_report_path\": ", r2cSurfaceJsonQuote(blockerPath), ",\n"], "")
    out = strutil.Join([out, "  \"module_count\": ", IntToStr(values.moduleCount), ",\n"], "")
    out = strutil.Join([out, "  \"rsg_node_count\": ", IntToStr(values.rsgNodeCount), ",\n"], "")
    out = strutil.Join([out, "  \"rsg_edge_count\": ", IntToStr(values.rsgEdgeCount), ",\n"], "")
    out = strutil.Join([out, "  \"blocker_count\": ", IntToStr(values.blockerCount), ",\n"], "")
    out = strutil.Join([out, "  \"blocked\": ", r2cSurfaceBoolText(values.blocked), ",\n"], "")
    out = strutil.Join([out, "  \"typescript_version\": ", r2cSurfaceJsonQuote(values.typescriptVersion), "\n"], "")
    out = strutil.Join([out, "}\n"], "")
    return chengpath.WriteTextFile("", path, out)

fn r2cSurfaceAddRsgNode(builder: var R2cRsgBuilder,
                        id: str,
                        nodeType: str,
                        label: str,
                        capability: str,
                        sourcePath: str,
                        sourceSpan: str) =
    for i in 0..<builder.nodeIds.len:
        if builder.nodeIds[i] == id:
            return
    add(builder.nodeIds, id)
    add(builder.nodeKinds, nodeType)
    add(builder.nodeLabels, label)
    add(builder.nodeCapabilities, capability)
    add(builder.nodeSourcePaths, sourcePath)
    add(builder.nodeSourceSpans, sourceSpan)

fn r2cSurfaceAddRsgEdge(builder: var R2cRsgBuilder,
                        fromId: str,
                        toId: str,
                        edgeType: str,
                        label: str) =
    for i in 0..<builder.edgeFromIds.len:
        if builder.edgeFromIds[i] == fromId && builder.edgeToIds[i] == toId && builder.edgeKinds[i] == edgeType && builder.edgeLabels[i] == label:
            return
    add(builder.edgeFromIds, fromId)
    add(builder.edgeToIds, toId)
    add(builder.edgeKinds, edgeType)
    add(builder.edgeLabels, label)

fn r2cRunStaticSurface(repo: str,
                       outDir: str,
                       tsxAstPath: str,
                       summaryPath: str,
                       requestedAssetRoots: str[],
                       resultOut: var R2cStaticSurfaceRunResult): bool =
    r2cSurfaceDebug("static:start")
    resultOut.ok = false
    resultOut.message = ""
    resultOut.moduleCount = 0
    resultOut.assetCount = 0
    resultOut.tailwindTokenCount = 0
    resultOut.requiredHostGroupCount = 0
    resultOut.requiredHostGroupsCsv = ""
    resultOut.typescriptVersion = ""
    let feedDir: str = os.ParentDir(outDir)
    var actualFeedDir: str = outDir
    if !chengpath.PathFileExists(os.JoinPath(outDir, "tsx_surface_meta_v1.env")):
        actualFeedDir = os.ParentDir(tsxAstPath)
    let metaPath: str = os.JoinPath(actualFeedDir, "tsx_surface_meta_v1.env")
    let modulesPath: str = os.JoinPath(actualFeedDir, "tsx_surface_modules_v1.tsv")
    let featureCountsPath: str = os.JoinPath(actualFeedDir, "tsx_surface_feature_counts_v1.tsv")
    let dynamicImportsPath: str = os.JoinPath(actualFeedDir, "tsx_surface_dynamic_imports_v1.tsv")
    let assetRefsPath: str = os.JoinPath(actualFeedDir, "tsx_surface_asset_refs_v1.tsv")
    let tailwindTokensPath: str = os.JoinPath(actualFeedDir, "tsx_surface_tailwind_tokens_v1.tsv")
    let discoveredAssetsPath: str = os.JoinPath(actualFeedDir, "tsx_surface_discovered_assets_v1.tsv")
    let moduleInventoryPath: str = os.JoinPath(outDir, "module_inventory_v1.json")
    let hostContractPath: str = os.JoinPath(outDir, "unimaker_host_v1.json")
    let assetManifestPath: str = os.JoinPath(outDir, "asset_manifest_v1.json")
    let tailwindManifestPath: str = os.JoinPath(outDir, "tailwind_style_manifest_v1.json")
    let _ = feedDir
    if !chengpath.PathFileExists(metaPath):
        resultOut.message = strutil.Join(["missing frontend surface feed: ", metaPath], "")
        return false
    r2cSurfaceDebug("static:meta")
    var metaLines: str[]
    r2cSurfaceReadLines(metaPath, metaLines)
    r2cSurfaceDebug("static:meta_lines")
    var sourceRoots: str[]
    r2cSurfaceSplitCsv(r2cSurfaceEnvValue(metaLines, "source_roots", ""), sourceRoots)
    resultOut.typescriptVersion = r2cSurfaceEnvValue(metaLines, "typescript_version", "")
    r2cSurfaceDebug("static:meta_values")

    var fallbackAssetRoots: str[]
    for i in 0..<sourceRoots.len:
        r2cSurfaceAddUnique(fallbackAssetRoots, sourceRoots[i])
    r2cSurfaceAddUnique(fallbackAssetRoots, "app")
    r2cSurfaceAddUnique(fallbackAssetRoots, "public")
    r2cSurfaceAddUnique(fallbackAssetRoots, "styles")
    r2cSurfaceDebug("static:fallback_asset_roots")
    var assetRoots: str[]
    var assetRootError = ""
    r2cSurfaceDebug("static:normalize_asset_roots")
    if !r2cSurfaceNormalizeAssetRoots(repo, requestedAssetRoots, fallbackAssetRoots, assetRoots, assetRootError):
        resultOut.message = assetRootError
        return false
    r2cSurfaceDebug("static:asset_roots")

    var moduleLines: str[]
    var featureCountLines: str[]
    var dynamicImportLines: str[]
    var assetRefLines: str[]
    var tailwindLines: str[]
    var discoveredAssetLines: str[]
    r2cSurfaceReadLines(modulesPath, moduleLines)
    r2cSurfaceReadLines(featureCountsPath, featureCountLines)
    r2cSurfaceReadLines(dynamicImportsPath, dynamicImportLines)
    r2cSurfaceReadLines(assetRefsPath, assetRefLines)
    r2cSurfaceReadLines(tailwindTokensPath, tailwindLines)
    r2cSurfaceReadLines(discoveredAssetsPath, discoveredAssetLines)
    r2cSurfaceDebug("static:feeds_loaded")

    var modulePaths: str[]
    var moduleGenerated: int32[]
    var moduleJsxLike: int32[]
    var moduleExportCounts: int32[]
    for i in 0..<moduleLines.len:
        let modulePath: str = r2cSurfaceField(moduleLines[i], 0)
        if strings.Len(modulePath) <= 0:
            continue
        add(modulePaths, modulePath)
        add(moduleGenerated, r2cSurfaceParseInt32(r2cSurfaceField(moduleLines[i], 1)))
        add(moduleJsxLike, r2cSurfaceParseInt32(r2cSurfaceField(moduleLines[i], 2)))
        add(moduleExportCounts, r2cSurfaceParseInt32(r2cSurfaceField(moduleLines[i], 3)))
    resultOut.moduleCount = int32(modulePaths.len)
    r2cSurfaceDebug("static:modules")

    var featureModulePaths: str[]
    var featureNames: str[]
    var featureCounts: int32[]
    var featureHitNames: str[]
    for i in 0..<featureCountLines.len:
        let modulePath: str = r2cSurfaceField(featureCountLines[i], 0)
        let featureName: str = r2cSurfaceField(featureCountLines[i], 1)
        let count: int32 = r2cSurfaceParseInt32(r2cSurfaceField(featureCountLines[i], 2))
        if strings.Len(modulePath) <= 0 || strings.Len(featureName) <= 0 || count <= 0:
            continue
        add(featureModulePaths, modulePath)
        add(featureNames, featureName)
        add(featureCounts, count)
        r2cSurfaceAddUnique(featureHitNames, featureName)
    var requiredGroups: str[]
    if r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "local_storage") > 0:
        add(requiredGroups, "StorageHost")
    if r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "fetch") > 0 ||
       r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "broadcast_channel") > 0 ||
       r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "worker") > 0 ||
       r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "webassembly") > 0:
        add(requiredGroups, "NetHost")
    if r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "rtc") > 0:
        add(requiredGroups, "RtcHost")
    if r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "media") > 0:
        add(requiredGroups, "MediaHost")
    if r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "capacitor") > 0 ||
       r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "custom_event") > 0 ||
       r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "resize_observer") > 0 ||
       r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "mutation_observer") > 0:
        add(requiredGroups, "PlatformHost")
    if r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "react_three") > 0:
        add(requiredGroups, "SceneHost")
    if r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "strict_mode") > 0 ||
       r2cSurfaceFeatureHitTotal(featureNames, featureCounts, "suspense") > 0:
        add(requiredGroups, "WindowHost")
    resultOut.requiredHostGroupCount = int32(requiredGroups.len)
    resultOut.requiredHostGroupsCsv = strutil.Join(requiredGroups, ",")
    r2cSurfaceDebug("static:features")

    var tokenNames: str[]
    var tokenSourcesCsv: str[]
    var tokenCounts: int32[]
    for i in 0..<tailwindLines.len:
        let modulePath: str = r2cSurfaceField(tailwindLines[i], 0)
        let token: str = r2cSurfaceField(tailwindLines[i], 1)
        if strings.Len(modulePath) <= 0 || strings.Len(token) <= 0:
            continue
        var found: int32 = -1
        for j in 0..<tokenNames.len:
            if tokenNames[j] == token:
                found = j
                break
        if found < 0:
            add(tokenNames, token)
            add(tokenSourcesCsv, modulePath)
            add(tokenCounts, 1)
        else:
            tokenSourcesCsv[found] = r2cSurfaceCsvAddUnique(tokenSourcesCsv[found], modulePath)
            tokenCounts[found] = tokenCounts[found] + 1
    resultOut.tailwindTokenCount = int32(tokenNames.len)
    r2cSurfaceDebug("static:tailwind")

    var dynamicImportModulePaths: str[]
    var dynamicImportValues: str[]
    for i in 0..<dynamicImportLines.len:
        let modulePath: str = r2cSurfaceField(dynamicImportLines[i], 0)
        let importPath: str = r2cSurfaceField(dynamicImportLines[i], 1)
        if strings.Len(modulePath) <= 0 || strings.Len(importPath) <= 0:
            continue
        add(dynamicImportModulePaths, modulePath)
        add(dynamicImportValues, importPath)
    r2cSurfaceDebug("static:dynamic_imports")
    var knownAssetPaths: str[]
    var seenAssetKeys: str[]
    var entryPaths: str[]
    var entryKinds: str[]
    var entrySourceModules: str[]
    var entryImportModes: str[]
    for i in 0..<assetRefLines.len:
        let modulePath: str = r2cSurfaceField(assetRefLines[i], 0)
        let assetPath: str = r2cSurfaceField(assetRefLines[i], 1)
        let assetKind: str = r2cSurfaceField(assetRefLines[i], 2)
        let dedupeKey: str = strutil.Join([modulePath, "\n", assetPath], "")
        if strings.Len(modulePath) <= 0 || strings.Len(assetPath) <= 0:
            continue
        var seen = false
        for j in 0..<seenAssetKeys.len:
            if seenAssetKeys[j] == dedupeKey:
                seen = true
                break
        if seen:
            continue
        add(seenAssetKeys, dedupeKey)
        r2cSurfaceAddUnique(knownAssetPaths, assetPath)
        add(entryPaths, assetPath)
        add(entryKinds, assetKind)
        add(entrySourceModules, modulePath)
        if r2cSurfaceHasPair(dynamicImportModulePaths, dynamicImportValues, modulePath, assetPath):
            add(entryImportModes, "dynamic")
        else:
            add(entryImportModes, "static")
    for i in 0..<discoveredAssetLines.len:
        let assetPath: str = r2cSurfaceField(discoveredAssetLines[i], 0)
        let assetKind: str = r2cSurfaceField(discoveredAssetLines[i], 1)
        if strings.Len(assetPath) <= 0 || !r2cSurfacePathUnderRoots(assetPath, assetRoots):
            continue
        var known = false
        for j in 0..<knownAssetPaths.len:
            if knownAssetPaths[j] == assetPath:
                known = true
                break
        if known:
            continue
        add(entryPaths, assetPath)
        add(entryKinds, assetKind)
        add(entrySourceModules, "")
       add(entryImportModes, "discovered")
    resultOut.assetCount = int32(entryPaths.len)
    r2cSurfaceDebug("static:assets")

    r2cSurfaceDebug("static:write_module_inventory")
    if !r2cSurfaceWriteModuleInventory(moduleInventoryPath, repo, sourceRoots, modulePaths, moduleGenerated, moduleJsxLike, moduleExportCounts):
        resultOut.message = "failed to write module inventory"
        return false
    r2cSurfaceDebug("static:write_host_contract")
    if !r2cSurfaceWriteHostContract(hostContractPath, featureHitNames, requiredGroups):
        resultOut.message = "failed to write host contract"
        return false
    r2cSurfaceDebug("static:write_asset_manifest")
    if !r2cSurfaceWriteAssetManifest(assetManifestPath, repo, assetRoots, entryPaths, entryKinds, entrySourceModules, entryImportModes):
        resultOut.message = "failed to write asset manifest"
        return false
    r2cSurfaceDebug("static:write_tailwind_manifest")
    if !r2cSurfaceWriteTailwindManifest(tailwindManifestPath, repo, tokenNames, tokenSourcesCsv, tokenCounts):
        resultOut.message = "failed to write tailwind manifest"
        return false
    r2cSurfaceDebug("static:write_summary")
    if !r2cSurfaceWriteSummaryStatic(summaryPath, resultOut, moduleInventoryPath, hostContractPath, assetManifestPath, tailwindManifestPath):
        resultOut.message = "failed to write static summary"
        return false
    r2cSurfaceDebug("static:done")
    resultOut.ok = true
    return true

fn r2cRunSemanticSurface(repo: str,
                         outDir: str,
                         tsxAstPath: str,
                         summaryPath: str,
                         resultOut: var R2cSemanticSurfaceRunResult): bool =
    r2cSurfaceDebug("semantic:start")
    resultOut.ok = false
    resultOut.message = ""
    resultOut.moduleCount = 0
    resultOut.rsgNodeCount = 0
    resultOut.rsgEdgeCount = 0
    resultOut.blockerCount = 0
    resultOut.blocked = false
    resultOut.typescriptVersion = ""
    resultOut.entryModule = ""
    var actualFeedDir: str = outDir
    if !chengpath.PathFileExists(os.JoinPath(outDir, "tsx_surface_meta_v1.env")):
        actualFeedDir = os.ParentDir(tsxAstPath)
    let metaPath: str = os.JoinPath(actualFeedDir, "tsx_surface_meta_v1.env")
    let modulesPath: str = os.JoinPath(actualFeedDir, "tsx_surface_modules_v1.tsv")
    let featureCountsPath: str = os.JoinPath(actualFeedDir, "tsx_surface_feature_counts_v1.tsv")
    let staticImportsPath: str = os.JoinPath(actualFeedDir, "tsx_surface_static_imports_v1.tsv")
    let dynamicImportsPath: str = os.JoinPath(actualFeedDir, "tsx_surface_dynamic_imports_v1.tsv")
    let componentsPath: str = os.JoinPath(actualFeedDir, "tsx_surface_components_v1.tsv")
    let blockersPath: str = os.JoinPath(actualFeedDir, "tsx_surface_blockers_v1.tsv")
    let tailwindTokensPath: str = os.JoinPath(actualFeedDir, "tsx_surface_tailwind_tokens_v1.tsv")
    let rsgPath: str = os.JoinPath(outDir, "rsg_v1.json")
    let blockerPath: str = os.JoinPath(outDir, "compile_blockers_v1.json")
    let reportPath: str = os.JoinPath(outDir, "semantic_surface_report_v1.json")
    if !chengpath.PathFileExists(metaPath):
        resultOut.message = strutil.Join(["missing frontend surface feed: ", metaPath], "")
        return false

    var metaLines: str[]
    var moduleLines: str[]
    var featureCountLines: str[]
    var staticImportLines: str[]
    var dynamicImportLines: str[]
    var componentLines: str[]
    var blockerLines: str[]
    var tailwindLines: str[]
    r2cSurfaceReadLines(metaPath, metaLines)
    r2cSurfaceReadLines(modulesPath, moduleLines)
    r2cSurfaceReadLines(featureCountsPath, featureCountLines)
    r2cSurfaceReadLines(staticImportsPath, staticImportLines)
    r2cSurfaceReadLines(dynamicImportsPath, dynamicImportLines)
    r2cSurfaceReadLines(componentsPath, componentLines)
    r2cSurfaceReadLines(blockersPath, blockerLines)
    r2cSurfaceReadLines(tailwindTokensPath, tailwindLines)
    r2cSurfaceDebug("semantic:feeds_loaded")
    resultOut.typescriptVersion = r2cSurfaceEnvValue(metaLines, "typescript_version", "")
    var sourceRoots: str[]
    r2cSurfaceSplitCsv(r2cSurfaceEnvValue(metaLines, "source_roots", ""), sourceRoots)

    var modulePaths: str[]
    var moduleJsxLike: int32[]
    for i in 0..<moduleLines.len:
        let modulePath: str = r2cSurfaceField(moduleLines[i], 0)
        if strings.Len(modulePath) <= 0:
            continue
        add(modulePaths, modulePath)
        add(moduleJsxLike, r2cSurfaceParseInt32(r2cSurfaceField(moduleLines[i], 2)))
    resultOut.moduleCount = int32(modulePaths.len)
    resultOut.entryModule = r2cSurfaceResolveEntryModule(modulePaths)
    r2cSurfaceDebug("semantic:modules")

    var featureModulePaths: str[]
    var featureNames: str[]
    var featureCounts: int32[]
    for i in 0..<featureCountLines.len:
        let modulePath: str = r2cSurfaceField(featureCountLines[i], 0)
        let featureName: str = r2cSurfaceField(featureCountLines[i], 1)
        let count: int32 = r2cSurfaceParseInt32(r2cSurfaceField(featureCountLines[i], 2))
        if strings.Len(modulePath) <= 0 || strings.Len(featureName) <= 0 || count <= 0:
            continue
        add(featureModulePaths, modulePath)
        add(featureNames, featureName)
        add(featureCounts, count)
    var componentModulePaths: str[]
    var componentNames: str[]
    var componentKinds: str[]
    var componentLinesOut: int32[]
    for i in 0..<componentLines.len:
        let modulePath: str = r2cSurfaceField(componentLines[i], 0)
        let name: str = r2cSurfaceField(componentLines[i], 1)
        let nodeType: str = r2cSurfaceField(componentLines[i], 2)
        let lineValue: int32 = r2cSurfaceParseInt32(r2cSurfaceField(componentLines[i], 3))
        if strings.Len(modulePath) <= 0 || strings.Len(name) <= 0:
            continue
        add(componentModulePaths, modulePath)
        add(componentNames, name)
        add(componentKinds, nodeType)
        add(componentLinesOut, lineValue)
    var blockerFiles: str[]
    var blockerLineNums: int32[]
    var blockerColumns: int32[]
    var blockerCodes: str[]
    for i in 0..<blockerLines.len:
        let fileText: str = r2cSurfaceField(blockerLines[i], 1)
        if strings.Len(fileText) <= 0:
            continue
        add(blockerFiles, fileText)
        add(blockerLineNums, r2cSurfaceParseInt32(r2cSurfaceField(blockerLines[i], 2)))
        add(blockerColumns, r2cSurfaceParseInt32(r2cSurfaceField(blockerLines[i], 3)))
        add(blockerCodes, r2cSurfaceField(blockerLines[i], 4))
    resultOut.blockerCount = int32(blockerFiles.len)
    resultOut.blocked = blockerFiles.len > 0
    r2cSurfaceDebug("semantic:blockers")

    var tailwindModulePaths: str[]
    for i in 0..<tailwindLines.len:
        let modulePath: str = r2cSurfaceField(tailwindLines[i], 0)
        let token: str = r2cSurfaceField(tailwindLines[i], 1)
        if strings.Len(modulePath) > 0 && strings.Len(token) > 0:
            add(tailwindModulePaths, modulePath)
    var rsgBuilder: R2cRsgBuilder
    rsgBuilder.nodeIds = []
    rsgBuilder.nodeKinds = []
    rsgBuilder.nodeLabels = []
    rsgBuilder.nodeCapabilities = []
    rsgBuilder.nodeSourcePaths = []
    rsgBuilder.nodeSourceSpans = []
    rsgBuilder.edgeFromIds = []
    rsgBuilder.edgeToIds = []
    rsgBuilder.edgeKinds = []
    rsgBuilder.edgeLabels = []
    r2cSurfaceDebug("semantic:graph_init")

    for i in 0..<modulePaths.len:
        let modulePath: str = modulePaths[i]
        r2cSurfaceDebug(strutil.Join(["semantic:module:", modulePath], ""))
        let moduleId: str = strutil.Join(["module:", modulePath], "")
        r2cSurfaceDebug(strutil.Join(["semantic:module_node:", modulePath], ""))
        r2cSurfaceAddRsgNode(rsgBuilder, moduleId, "rsgModule", modulePath, "module", modulePath, "module")
        r2cSurfaceDebug(strutil.Join(["semantic:module_node_done:", modulePath], ""))
        for j in 0..<staticImportLines.len:
            if r2cSurfaceField(staticImportLines[j], 0) != modulePath:
                continue
            let importPath: str = r2cSurfaceField(staticImportLines[j], 1)
            let importId: str = strutil.Join(["import:", modulePath, ":", importPath], "")
            r2cSurfaceAddRsgNode(rsgBuilder, importId, "rsgImport", importPath, "module", modulePath, "import")
            r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, importId, "rsgDependsOn", "static_import")
        for j in 0..<dynamicImportLines.len:
            if r2cSurfaceField(dynamicImportLines[j], 0) != modulePath:
                continue
            let importPath: str = r2cSurfaceField(dynamicImportLines[j], 1)
            let lazyId: str = strutil.Join(["lazy:", modulePath, ":", importPath], "")
            r2cSurfaceAddRsgNode(rsgBuilder, lazyId, "rsgLazyModule", importPath, "async", modulePath, "dynamic_import")
            r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, lazyId, "rsgSchedules", "dynamic_import")
        for j in 0..<componentModulePaths.len:
            if componentModulePaths[j] != modulePath:
                continue
            let componentId: str = strutil.Join(["component:", componentKinds[j], ":", modulePath, ":", componentNames[j]], "")
            var componentKind = "rsgComponentFunction"
            if componentKinds[j] == "class":
                componentKind = "rsgComponentClass"
            r2cSurfaceAddRsgNode(rsgBuilder, componentId, componentKind, componentNames[j], "react_component", modulePath, strutil.Join(["line:", IntToStr(componentLinesOut[j])], ""))
            r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, componentId, "rsgOwns", "component")
        r2cSurfaceDebug(strutil.Join(["semantic:components_done:", modulePath], ""))
        let hookFeatures: str[] = ["use_state", "use_ref", "use_memo", "use_callback", "use_effect", "use_context", "suspense", "error_boundary"]
        let hookPrefixes: str[] = ["hook:state", "hook:ref", "hook:memo", "hook:callback", "effect", "context", "suspense", "boundary"]
        let hookKinds: str[] = ["rsgHookSlot", "rsgHookSlot", "rsgHookSlot", "rsgHookSlot", "rsgEffect", "rsgContext", "rsgSuspenseBoundary", "rsgErrorBoundary"]
        let hookLabels: str[] = ["useState", "useRef", "useMemo", "useCallback", "useEffect", "context", "Suspense", "ErrorBoundary"]
        let hookCaps: str[] = ["state", "ref", "memo", "callback", "effect", "context", "async", "error"]
        let hookEdgeKinds: str[] = ["rsgOwns", "rsgOwns", "rsgOwns", "rsgCaptures", "rsgSchedules", "rsgReads", "rsgSchedules", "rsgThrowsTo"]
        let hookEdgeLabels: str[] = ["hook", "hook", "hook", "hook", "effect", "context", "suspense", "error_boundary"]
        for j in 0..<hookFeatures.len:
            let count: int32 = r2cSurfaceFeatureCount(featureModulePaths, featureNames, featureCounts, modulePath, hookFeatures[j])
            for k in 0..<count:
                let nodeId: str = strutil.Join([hookPrefixes[j], ":", modulePath, ":", IntToStr(k + 1)], "")
                let label: str = strutil.Join([hookLabels[j], "#", IntToStr(k + 1)], "")
                r2cSurfaceAddRsgNode(rsgBuilder, nodeId, hookKinds[j], label, hookCaps[j], modulePath, "surface")
                r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, nodeId, hookEdgeKinds[j], hookEdgeLabels[j])
        r2cSurfaceDebug(strutil.Join(["semantic:hooks_done:", modulePath], ""))
        var tailwindCount: int32
        for j in 0..<tailwindModulePaths.len:
            if tailwindModulePaths[j] == modulePath:
                tailwindCount = tailwindCount + 1
        if tailwindCount > 0:
            let nodeId: str = strutil.Join(["style:", modulePath], "")
            r2cSurfaceAddRsgNode(rsgBuilder, nodeId, "rsgStyleBlock", strutil.Join(["className[", IntToStr(tailwindCount), "]"], ""), "style", modulePath, "surface")
            r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, nodeId, "rsgStyles", "tailwind")
        if moduleJsxLike[i] != 0:
            let nodeId: str = strutil.Join(["layout:", modulePath], "")
            r2cSurfaceAddRsgNode(rsgBuilder, nodeId, "rsgLayoutNode", "jsx_surface", "layout", modulePath, "surface")
            r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, nodeId, "rsgLayouts", "jsx")
        let customEventCount: int32 = r2cSurfaceFeatureCount(featureModulePaths, featureNames, featureCounts, modulePath, "custom_event")
        if customEventCount > 0:
            let nodeId: str = strutil.Join(["event:", modulePath, ":custom"], "")
            r2cSurfaceAddRsgNode(rsgBuilder, nodeId, "rsgEventHandler", strutil.Join(["CustomEvent[", IntToStr(customEventCount), "]"], ""), "event", modulePath, "surface")
            r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, nodeId, "rsgHandles", "custom_event")
        let hostFeatures: str[] = ["local_storage", "fetch", "broadcast_channel", "worker", "webassembly", "rtc", "media", "capacitor", "custom_event", "resize_observer", "mutation_observer", "react_three"]
        let hostGroups: str[] = ["StorageHost", "NetHost", "NetHost", "NetHost", "NetHost", "RtcHost", "MediaHost", "PlatformHost", "PlatformHost", "PlatformHost", "PlatformHost", "SceneHost"]
        let hostLabels: str[] = ["localStorage", "fetch", "BroadcastChannel", "Worker", "WebAssembly", "RTCPeerConnection", "getUserMedia", "Capacitor", "CustomEvent", "ResizeObserver", "MutationObserver", "react-three"]
        for j in 0..<hostFeatures.len:
            let count: int32 = r2cSurfaceFeatureCount(featureModulePaths, featureNames, featureCounts, modulePath, hostFeatures[j])
            if count <= 0:
                continue
            let nodeId: str = strutil.Join(["host:", modulePath, ":", hostFeatures[j]], "")
            r2cSurfaceAddRsgNode(rsgBuilder, nodeId, "rsgHostCall", strutil.Join([hostLabels[j], "[", IntToStr(count), "]"], ""), hostGroups[j], modulePath, "surface")
            r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, nodeId, "rsgCalls", hostFeatures[j])
        let asyncCount: int32 = r2cSurfaceAsyncFeatureTotal(featureModulePaths, featureNames, featureCounts, modulePath)
        if asyncCount > 0:
            let nodeId: str = strutil.Join(["async:", modulePath], "")
            r2cSurfaceAddRsgNode(rsgBuilder, nodeId, "rsgAsyncTask", strutil.Join(["async[", IntToStr(asyncCount), "]"], ""), "async", modulePath, "surface")
            r2cSurfaceAddRsgEdge(rsgBuilder, moduleId, nodeId, "rsgSchedules", "async")
        r2cSurfaceDebug(strutil.Join(["semantic:module_done:", modulePath], ""))

    resultOut.rsgNodeCount = int32(rsgBuilder.nodeIds.len)
    resultOut.rsgEdgeCount = int32(rsgBuilder.edgeFromIds.len)
    r2cSurfaceDebug("semantic:write_rsg")
    if !r2cSurfaceWriteRsg(rsgPath, repo, resultOut.entryModule, rsgBuilder):
        resultOut.message = "failed to write rsg"
        return false
    r2cSurfaceDebug("semantic:write_blockers")
    if !r2cSurfaceWriteBlockerReport(blockerPath, repo, sourceRoots, blockerFiles, blockerLineNums, blockerColumns, blockerCodes):
        resultOut.message = "failed to write blocker report"
        return false
    r2cSurfaceDebug("semantic:write_report")
    if !r2cSurfaceWriteSemanticReport(reportPath, repo, outDir, tsxAstPath, rsgPath, blockerPath, resultOut):
        resultOut.message = "failed to write semantic report"
        return false
    r2cSurfaceDebug("semantic:write_summary")
    if !r2cSurfaceWriteSummarySemantic(summaryPath, resultOut, rsgPath, blockerPath):
        resultOut.message = "failed to write semantic summary"
        return false
    r2cSurfaceDebug("semantic:done")
    resultOut.ok = true
    return true
