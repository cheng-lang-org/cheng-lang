import std/strings
import std/strutils as strutil
import cheng/core/tooling/path as chengpath
import cheng/r2c/native_platform_shell_package as shellpackage

fn nativeProjectSlice(text: str,
                      start: int32,
                      length: int32): str =
    if length <= 0:
        return ""
    return chengpath.TextSlice(text, start, length)

fn nativeProjectDigitValue(text: str): int32 =
    if text == "0":
        return 0
    elif text == "1":
        return 1
    elif text == "2":
        return 2
    elif text == "3":
        return 3
    elif text == "4":
        return 4
    elif text == "5":
        return 5
    elif text == "6":
        return 6
    elif text == "7":
        return 7
    elif text == "8":
        return 8
    elif text == "9":
        return 9
    return -1

fn nativeProjectParsePositiveInt32(raw: str): int32 =
    let total: int32 = strings.Len(raw)
    if total <= 0:
        return 0
    var out: int32
    for i in 0..<total:
        let digit: int32 = nativeProjectDigitValue(nativeProjectSlice(raw, i, 1))
        if digit < 0:
            return -1
        out = (out * 10) + digit
    return out

fn nativeProjectParseInt32(text: str): int32 =
    let raw: str = strutil.Strip(text)
    if strings.Len(raw) <= 0:
        return 0
    if raw[0] == '-':
        let parsed: int32 = nativeProjectParsePositiveInt32(nativeProjectSlice(raw, 1, strings.Len(raw) - 1))
        if parsed < 0:
            return 0
        return 0 - parsed
    let parsed: int32 = nativeProjectParsePositiveInt32(raw)
    if parsed < 0:
        return 0
    return parsed

fn nativeProjectJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    var out = quote
    let total: int32 = strings.Len(text)
    for i in 0..<total:
        let ch = text[i]
        if ch == char(34):
            out = out + "\\" + quote
        elif ch == '\\':
            out = out + "\\\\"
        elif ch == char(10):
            out = out + "\\n"
        elif ch == char(13):
            out = out + "\\r"
        elif ch == char(9):
            out = out + "\\t"
        else:
            out = out + strings.CharToStr(ch)
    out = out + quote
    return out

fn nativeProjectTextFind(text: str,
                         needle: str,
                         startRaw: int32): int32 =
    let total: int32 = strings.Len(text)
    let needleLen: int32 = strings.Len(needle)
    if needleLen <= 0:
        return startRaw
    if total < needleLen:
        return -1
    var start: int32 = startRaw
    if start < 0:
        start = 0
    if start > total - needleLen:
        return -1
    for i in start..(total - needleLen):
        var matched = true
        for j in 0..<needleLen:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn nativeProjectJsonSkipWhitespace(text: str,
                                   startRaw: int32): int32 =
    var pos: int32 = startRaw
    if pos < 0:
        pos = 0
    let total: int32 = strings.Len(text)
    while pos < total:
        let ch = text[pos]
        if ch == char(32) || ch == char(10) || ch == char(13) || ch == char(9):
            pos = pos + 1
        else:
            return pos
    return pos

fn nativeProjectJsonFindValueStart(text: str,
                                   key: str,
                                   startRaw: int32): int32 =
    let keyPattern: str = nativeProjectJsonQuote(key)
    let keyPos: int32 = nativeProjectTextFind(text, keyPattern, startRaw)
    if keyPos < 0:
        return -1
    var pos: int32 = keyPos + strings.Len(keyPattern)
    let total: int32 = strings.Len(text)
    while pos < total:
        if text[pos] == char(58):
            return nativeProjectJsonSkipWhitespace(text, pos + 1)
        pos = pos + 1
    return -1

fn nativeProjectJsonReadStringLiteral(text: str,
                                      startRaw: int32,
                                      fallback: str): str =
    let total: int32 = strings.Len(text)
    if startRaw < 0 || startRaw >= total || text[startRaw] != char(34):
        return fallback
    var out: str
    var pos: int32 = startRaw + 1
    while pos < total:
        let ch = text[pos]
        if ch == char(34):
            return out
        if ch == '\\':
            if pos + 1 >= total:
                return fallback
            let esc = text[pos + 1]
            if esc == char(34):
                out = out + strings.CharToStr(char(34))
            elif esc == '\\':
                out = out + "\\"
            elif esc == 'n':
                out = out + "\n"
            elif esc == 'r':
                out = out + "\r"
            elif esc == 't':
                out = out + "\t"
            else:
                out = out + strings.CharToStr(esc)
            pos = pos + 2
            continue
        out = out + strings.CharToStr(ch)
        pos = pos + 1
    return fallback

fn nativeProjectJsonReadStringField(text: str,
                                    key: str,
                                    fallback: str): str =
    let valueStart: int32 = nativeProjectJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    return nativeProjectJsonReadStringLiteral(text, valueStart, fallback)

fn nativeProjectJsonReadIntField(text: str,
                                 key: str,
                                 fallback: int32): int32 =
    let valueStart: int32 = nativeProjectJsonFindValueStart(text, key, 0)
    if valueStart < 0:
        return fallback
    let total: int32 = strings.Len(text)
    var endPos: int32 = valueStart
    if endPos < total && text[endPos] == '-':
        endPos = endPos + 1
    var sawDigit = false
    while endPos < total:
        if nativeProjectDigitValue(nativeProjectSlice(text, endPos, 1)) < 0:
            break
        sawDigit = true
        endPos = endPos + 1
    if !sawDigit:
        return fallback
    return nativeProjectParseInt32(nativeProjectSlice(text, valueStart, endPos - valueStart))

fn nativeProjectPlatformText(packageManifestPath: str,
                             packageText: str,
                             platformId: str,
                             projectKind: str,
                             shellKind: str,
                             surfaceBinding: str,
                             inputBinding: str,
                             launchPlanPath: str,
                             platformDir: str): str =
    let framePath: str = nativeProjectJsonReadStringField(packageText, "frame_path", "")
    let frameFormat: str = nativeProjectJsonReadStringField(packageText, "frame_format", "surface_frame_rgba_v1")
    let pixelFormat: str = nativeProjectJsonReadStringField(packageText, "pixel_format", "rgba8_unpremultiplied")
    let width: int32 = nativeProjectJsonReadIntField(packageText, "width", 0)
    let height: int32 = nativeProjectJsonReadIntField(packageText, "height", 0)
    let strideBytes: int32 = nativeProjectJsonReadIntField(packageText, "stride_bytes", 0)
    let frameByteCount: int32 = nativeProjectJsonReadIntField(packageText, "frame_byte_count", 0)
    var doc = "{\n"
    doc = doc + "  \"format\": \"native_platform_shell_platform_project_v1\",\n"
    doc = doc + "  \"ready\": true,\n"
    doc = doc + "  \"platform\": " + nativeProjectJsonQuote(platformId) + ",\n"
    doc = doc + "  \"project_kind\": " + nativeProjectJsonQuote(projectKind) + ",\n"
    doc = doc + "  \"shell_kind\": " + nativeProjectJsonQuote(shellKind) + ",\n"
    doc = doc + "  \"generated_by\": \"cheng.native_platform_shell_project_v1\",\n"
    doc = doc + "  \"runtime_purity\": {\"node\": false, \"react\": false, \"webview_business_layer\": false, \"business_js\": false},\n"
    doc = doc + "  \"event_loop\": \"event_driven_v1\",\n"
    doc = doc + "  \"polling\": false,\n"
    doc = doc + "  \"project_dir\": " + nativeProjectJsonQuote(platformDir) + ",\n"
    doc = doc + "  \"package_manifest_path\": " + nativeProjectJsonQuote(packageManifestPath) + ",\n"
    doc = doc + "  \"launch_plan_path\": " + nativeProjectJsonQuote(launchPlanPath) + ",\n"
    doc = doc + "  \"frame_path\": " + nativeProjectJsonQuote(framePath) + ",\n"
    doc = doc + "  \"frame_format\": " + nativeProjectJsonQuote(frameFormat) + ",\n"
    doc = doc + "  \"pixel_format\": " + nativeProjectJsonQuote(pixelFormat) + ",\n"
    doc = doc + "  \"width\": " + intToStr(width) + ",\n"
    doc = doc + "  \"height\": " + intToStr(height) + ",\n"
    doc = doc + "  \"stride_bytes\": " + intToStr(strideBytes) + ",\n"
    doc = doc + "  \"frame_byte_count\": " + intToStr(frameByteCount) + ",\n"
    doc = doc + "  \"surface_binding\": " + nativeProjectJsonQuote(surfaceBinding) + ",\n"
    doc = doc + "  \"input_binding\": " + nativeProjectJsonQuote(inputBinding) + ",\n"
    doc = doc + "  \"surface_contract\": \"rgba8_stride_copy_v1\",\n"
    doc = doc + "  \"entry_contract\": \"cheng_event_driven_native_surface_shell_v1\",\n"
    doc = doc + "  \"business_js\": false\n"
    doc = doc + "}\n"
    return doc

