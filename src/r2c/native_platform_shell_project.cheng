fn NativePlatformShellProjectManifestValid(manifestText: str): bool =
    if nativeProjectJsonReadStringField(manifestText, "format", "") != "native_platform_shell_project_manifest_v1":
        return false
    if nativeProjectJsonReadStringField(manifestText, "project_kind", "") != "cheng_generated_native_surface_shell_project_v1":
        return false
    if nativeProjectJsonReadStringField(manifestText, "event_loop", "") != "event_driven_v1":
        return false
    if nativeProjectJsonReadIntField(manifestText, "platform_count", 0) != 3:
        return false
    if !strutil.Contains(manifestText, "\"node\": false"):
        return false
    if !strutil.Contains(manifestText, "\"react\": false"):
        return false
    if !strutil.Contains(manifestText, "\"webview_business_layer\": false"):
        return false
    if !strutil.Contains(manifestText, "\"business_js\": false"):
        return false
    if !strutil.Contains(manifestText, "\"project_dir\":"):
        return false
    if !strutil.Contains(manifestText, "\"entry_manifest_path\":"):
        return false
    if !strutil.Contains(manifestText, "\"install_manifest_path\":"):
        return false
    if !strutil.Contains(manifestText, "\"files_manifest_path\":"):
        return false
    if !strutil.Contains(manifestText, "\"build_inputs_manifest_path\":"):
        return false
    if !strutil.Contains(manifestText, "\"packaging_plan_manifest_path\":"):
        return false
    if nativeProjectJsonReadIntField(manifestText, "install_package_count", 0) != 3:
        return false
    if nativeProjectJsonReadIntField(manifestText, "platform_file_count", 0) != 6:
        return false
    if nativeProjectJsonReadIntField(manifestText, "build_input_count", 0) != 3:
        return false
    if nativeProjectJsonReadIntField(manifestText, "packaging_plan_count", 0) != 3:
        return false
    if !strutil.Contains(manifestText, "\"id\":\"android\""):
        return false
    if !strutil.Contains(manifestText, "\"id\":\"ios\""):
        return false
    if !strutil.Contains(manifestText, "\"id\":\"ohos\""):
        return false
    if !strutil.Contains(manifestText, "\"target_triple\":\"aarch64-linux-android\""):
        return false
    if !strutil.Contains(manifestText, "\"target_triple\":\"arm64-apple-ios\""):
        return false
    if !strutil.Contains(manifestText, "\"target_triple\":\"aarch64-linux-ohos\""):
        return false
    if !strutil.Contains(manifestText, "\"packaging_plan_path\":"):
        return false
    return true

fn NativePlatformShellFilesManifestValid(manifestText: str): bool =
    if nativeProjectJsonReadStringField(manifestText, "format", "") != "native_platform_shell_files_manifest_v1":
        return false
    if nativeProjectJsonReadStringField(manifestText, "event_loop", "") != "event_driven_v1":
        return false
    if nativeProjectJsonReadIntField(manifestText, "platform_file_count", 0) != 6:
        return false
    if !strutil.Contains(manifestText, "\"node\": false"):
        return false
    if !strutil.Contains(manifestText, "\"react\": false"):
        return false
    if !strutil.Contains(manifestText, "\"webview_business_layer\": false"):
        return false
    if !strutil.Contains(manifestText, "\"business_js\": false"):
        return false
    if !strutil.Contains(manifestText, "\"language\":\"cheng\""):
        return false
    if !strutil.Contains(manifestText, "\"surface_binding\":\"ANativeWindow_rgba_blit_v1\""):
        return false
    if !strutil.Contains(manifestText, "\"surface_binding\":\"CAMetalLayer_rgba_blit_v1\""):
        return false
    if !strutil.Contains(manifestText, "\"surface_binding\":\"OHNativeWindow_rgba_blit_v1\""):
        return false
    return true

