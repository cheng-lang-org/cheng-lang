    if nativeProjectJsonReadStringField(manifestText, "format", "") != "native_platform_shell_install_manifest_v1":
        return false
    if nativeProjectJsonReadStringField(manifestText, "event_loop", "") != "event_driven_v1":
        return false
    if nativeProjectJsonReadIntField(manifestText, "install_package_count", 0) != 3:
        return false
    if !strutil.Contains(manifestText, "\"node\": false"):
        return false
    if !strutil.Contains(manifestText, "\"react\": false"):
        return false
    if !strutil.Contains(manifestText, "\"webview_business_layer\": false"):
        return false
    if !strutil.Contains(manifestText, "\"business_js\": false"):
        return false
    if !strutil.Contains(manifestText, "\"c_dependency\": false"):
        return false
    if !strutil.Contains(manifestText, "\"script_dependency\": false"):
        return false
    if !strutil.Contains(manifestText, "\"package_kind\":\"android_native_surface_app_manifest_v1\""):
        return false
    if !strutil.Contains(manifestText, "\"package_kind\":\"ios_native_surface_app_manifest_v1\""):
        return false
    if !strutil.Contains(manifestText, "\"package_kind\":\"ohos_native_surface_app_manifest_v1\""):
        return false
    return true

