    let androidPackagingPlanPath: str = chengpath.PathJoin(androidDir, "android_packaging_plan_v1.json")
    let iosPackagingPlanPath: str = chengpath.PathJoin(iosDir, "ios_packaging_plan_v1.json")
    let ohosPackagingPlanPath: str = chengpath.PathJoin(ohosDir, "ohos_packaging_plan_v1.json")
    var doc = "{\n"
    doc = doc + "  \"format\": \"native_platform_shell_project_manifest_v1\",\n"
    doc = doc + "  \"ready\": true,\n"
    doc = doc + "  \"generated_by\": \"cheng.native_platform_shell_project_v1\",\n"
    doc = doc + "  \"project_kind\": \"cheng_generated_native_surface_shell_project_v1\",\n"
    doc = doc + "  \"runtime_purity\": {\"node\": false, \"react\": false, \"webview_business_layer\": false, \"business_js\": false},\n"
    doc = doc + "  \"event_loop\": \"event_driven_v1\",\n"
    doc = doc + "  \"platform_count\": 3,\n"
    doc = doc + "  \"package_manifest_path\": " + nativeProjectJsonQuote(packageManifestPath) + ",\n"
    doc = doc + "  \"project_dir\": " + nativeProjectJsonQuote(projectDir) + ",\n"
    doc = doc + "  \"summary_path\": " + nativeProjectJsonQuote(summaryPath) + ",\n"
    doc = doc + "  \"entry_manifest_path\": " + nativeProjectJsonQuote(entryManifestPath) + ",\n"
    doc = doc + "  \"install_manifest_path\": " + nativeProjectJsonQuote(installManifestPath) + ",\n"
    doc = doc + "  \"files_manifest_path\": " + nativeProjectJsonQuote(filesManifestPath) + ",\n"
    doc = doc + "  \"build_inputs_manifest_path\": " + nativeProjectJsonQuote(buildInputsManifestPath) + ",\n"
    doc = doc + "  \"packaging_plan_manifest_path\": " + nativeProjectJsonQuote(packagingPlanManifestPath) + ",\n"
    doc = doc + "  \"install_package_count\": 3,\n"
    doc = doc + "  \"platform_file_count\": 6,\n"
    doc = doc + "  \"build_input_count\": 3,\n"
    doc = doc + "  \"packaging_plan_count\": 3,\n"
    doc = doc + "  \"frame_path\": " + nativeProjectJsonQuote(framePath) + ",\n"
    doc = doc + "  \"frame_byte_count\": " + intToStr(frameByteCount) + ",\n"
    doc = doc + "  \"platforms\": [\n"
    doc = doc + "    {\"id\":\"android\",\"target_triple\":\"aarch64-linux-android\",\"project_dir\":" + nativeProjectJsonQuote(androidDir) + ",\"project_path\":" + nativeProjectJsonQuote(androidProjectPath) + ",\"entry_path\":" + nativeProjectJsonQuote(androidEntryPath) + ",\"install_package_path\":" + nativeProjectJsonQuote(androidInstallPackagePath) + ",\"platform_manifest_path\":" + nativeProjectJsonQuote(androidPlatformManifestPath) + ",\"shell_source_path\":" + nativeProjectJsonQuote(androidShellSourcePath) + ",\"build_input_path\":" + nativeProjectJsonQuote(androidBuildInputPath) + ",\"packaging_plan_path\":" + nativeProjectJsonQuote(androidPackagingPlanPath) + ",\"surface_binding\":\"ANativeWindow_rgba_blit_v1\",\"input_binding\":\"AInputQueue_event_driven_v1\"},\n"
    doc = doc + "    {\"id\":\"ios\",\"target_triple\":\"arm64-apple-ios\",\"project_dir\":" + nativeProjectJsonQuote(iosDir) + ",\"project_path\":" + nativeProjectJsonQuote(iosProjectPath) + ",\"entry_path\":" + nativeProjectJsonQuote(iosEntryPath) + ",\"install_package_path\":" + nativeProjectJsonQuote(iosInstallPackagePath) + ",\"platform_manifest_path\":" + nativeProjectJsonQuote(iosInfoPlistPath) + ",\"shell_source_path\":" + nativeProjectJsonQuote(iosShellSourcePath) + ",\"build_input_path\":" + nativeProjectJsonQuote(iosBuildInputPath) + ",\"packaging_plan_path\":" + nativeProjectJsonQuote(iosPackagingPlanPath) + ",\"surface_binding\":\"CAMetalLayer_rgba_blit_v1\",\"input_binding\":\"UIKit_touch_event_driven_v1\"},\n"
    doc = doc + "    {\"id\":\"ohos\",\"target_triple\":\"aarch64-linux-ohos\",\"project_dir\":" + nativeProjectJsonQuote(ohosDir) + ",\"project_path\":" + nativeProjectJsonQuote(ohosProjectPath) + ",\"entry_path\":" + nativeProjectJsonQuote(ohosEntryPath) + ",\"install_package_path\":" + nativeProjectJsonQuote(ohosInstallPackagePath) + ",\"platform_manifest_path\":" + nativeProjectJsonQuote(ohosModulePath) + ",\"shell_source_path\":" + nativeProjectJsonQuote(ohosShellSourcePath) + ",\"build_input_path\":" + nativeProjectJsonQuote(ohosBuildInputPath) + ",\"packaging_plan_path\":" + nativeProjectJsonQuote(ohosPackagingPlanPath) + ",\"surface_binding\":\"OHNativeWindow_rgba_blit_v1\",\"input_binding\":\"XComponent_event_driven_v1\"}\n"
    doc = doc + "  ]\n"
