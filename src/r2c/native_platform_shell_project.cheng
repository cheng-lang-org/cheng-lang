fn WriteNativePlatformShellProject(packageManifestPath: str,
                                   projectDir: str,
                                   projectManifestOut: str): bool =
    if strings.Len(packageManifestPath) <= 0 || !chengpath.FileExistsNonEmpty("", packageManifestPath):
        return false
    if strings.Len(projectDir) <= 0 || strings.Len(projectManifestOut) <= 0:
        return false
    if !chengpath.MkdirP("", projectDir):
        return false
    let packageText: str = chengpath.ReadTextFile("", packageManifestPath)
    if !shellpackage.NativePlatformShellPackageManifestValid(packageText):
        return false
    let androidDir: str = chengpath.PathJoin(projectDir, "android")
    let iosDir: str = chengpath.PathJoin(projectDir, "ios")
    let ohosDir: str = chengpath.PathJoin(projectDir, "ohos")
    if !chengpath.MkdirP("", androidDir):
        return false
    if !chengpath.MkdirP("", iosDir):
        return false
    if !chengpath.MkdirP("", ohosDir):
        return false
    let androidProjectPath: str = chengpath.PathJoin(androidDir, "native_surface_shell_project_v1.json")
    let iosProjectPath: str = chengpath.PathJoin(iosDir, "native_surface_shell_project_v1.json")
    let ohosProjectPath: str = chengpath.PathJoin(ohosDir, "native_surface_shell_project_v1.json")
    let androidEntryPath: str = chengpath.PathJoin(androidDir, "native_surface_shell_entry_v1.json")
    let iosEntryPath: str = chengpath.PathJoin(iosDir, "native_surface_shell_entry_v1.json")
    let ohosEntryPath: str = chengpath.PathJoin(ohosDir, "native_surface_shell_entry_v1.json")
    let entryManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_entry_manifest_v1.json")
    let androidInstallPackagePath: str = chengpath.PathJoin(androidDir, "android_package_manifest_v1.json")
    let iosInstallPackagePath: str = chengpath.PathJoin(iosDir, "ios_package_manifest_v1.json")
    let ohosInstallPackagePath: str = chengpath.PathJoin(ohosDir, "ohos_package_manifest_v1.json")
    let installManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_install_manifest_v1.json")
    let androidPlatformManifestPath: str = chengpath.PathJoin(androidDir, "AndroidManifest.xml")
    let androidShellSourcePath: str = chengpath.PathJoin(androidDir, "ChengNativeSurfaceActivity.cheng")
    let iosInfoPlistPath: str = chengpath.PathJoin(iosDir, "Info.plist")
    let iosShellSourcePath: str = chengpath.PathJoin(iosDir, "ChengNativeSurfaceViewController.cheng")
    let ohosModulePath: str = chengpath.PathJoin(ohosDir, "module.json5")
    let ohosShellSourcePath: str = chengpath.PathJoin(ohosDir, "ChengNativeSurfaceAbility.cheng")
    let filesManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_files_manifest_v1.json")
    let buildInputsManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_build_inputs_manifest_v1.json")
    let androidBuildInputPath: str = chengpath.PathJoin(androidDir, "android_build_input_v1.json")
    let iosBuildInputPath: str = chengpath.PathJoin(iosDir, "ios_build_input_v1.json")
    let ohosBuildInputPath: str = chengpath.PathJoin(ohosDir, "ohos_build_input_v1.json")
    let packagingPlanManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_packaging_plan_manifest_v1.json")
    let androidPackagingPlanPath: str = chengpath.PathJoin(androidDir, "android_packaging_plan_v1.json")
    let iosPackagingPlanPath: str = chengpath.PathJoin(iosDir, "ios_packaging_plan_v1.json")
    let ohosPackagingPlanPath: str = chengpath.PathJoin(ohosDir, "ohos_packaging_plan_v1.json")
    let summaryPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_project.summary.env")
    let androidLaunchPath: str = nativeProjectJsonReadStringField(packageText, "android_launch_plan_path", "")
    let iosLaunchPath: str = nativeProjectJsonReadStringField(packageText, "ios_launch_plan_path", "")
    let ohosLaunchPath: str = nativeProjectJsonReadStringField(packageText, "ohos_launch_plan_path", "")
    let androidDoc: str = nativeProjectPlatformText(packageManifestPath,
                                                    packageText,
                                                    "android",
                                                    "cheng_generated_android_native_surface_project_v1",
                                                    "cheng_generated_android_surface_shell_v1",
                                                    "ANativeWindow_rgba_blit_v1",
                                                    "AInputQueue_event_driven_v1",
                                                    androidLaunchPath,
                                                    androidDir)
    let iosDoc: str = nativeProjectPlatformText(packageManifestPath,
                                                packageText,
                                                "ios",
                                                "cheng_generated_ios_native_surface_project_v1",
                                                "cheng_generated_ios_surface_shell_v1",
                                                "CAMetalLayer_rgba_blit_v1",
                                                "UIKit_touch_event_driven_v1",
                                                iosLaunchPath,
                                                iosDir)
    let ohosDoc: str = nativeProjectPlatformText(packageManifestPath,
                                                 packageText,
                                                 "ohos",
