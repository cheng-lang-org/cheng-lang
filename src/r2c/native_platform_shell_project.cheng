fn nativeProjectAndroidManifestText(packageId: str): str =
    var doc = "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n"
    doc = doc + "<manifest xmlns:android=\"http://schemas.android.com/apk/res/android\" package=\"" + packageId + "\">\n"
    doc = doc + "  <application android:label=\"UniMaker Cheng\" android:hardwareAccelerated=\"true\" android:usesCleartextTraffic=\"false\">\n"
    doc = doc + "    <activity android:name=\".ChengNativeSurfaceActivity\" android:exported=\"true\" android:screenOrientation=\"portrait\">\n"
    doc = doc + "      <intent-filter>\n"
    doc = doc + "        <action android:name=\"android.intent.action.MAIN\" />\n"
    doc = doc + "        <category android:name=\"android.intent.category.LAUNCHER\" />\n"
    doc = doc + "      </intent-filter>\n"
    doc = doc + "    </activity>\n"
    doc = doc + "  </application>\n"
    doc = doc + "</manifest>\n"
    return doc

fn nativeProjectAndroidShellSourceText(packageId: str,
                                       framePath: str): str =
    var doc: str
    doc = doc + "const ChengNativeSurfaceShellPlatform: str = \"android\"\n"
    doc = doc + "const ChengNativeSurfaceShellPackageId: str = \"" + packageId + "\"\n"
    doc = doc + "const ChengNativeSurfaceShellEntrySymbol: str = \"ChengNativeSurfaceShellMain\"\n"
    doc = doc + "const ChengNativeSurfaceShellSurfaceBinding: str = \"ANativeWindow_rgba_blit_v1\"\n"
    doc = doc + "const ChengNativeSurfaceShellInputBinding: str = \"AInputQueue_event_driven_v1\"\n"
    doc = doc + "const ChengNativeSurfaceShellFramePath: str = \"" + framePath + "\"\n\n"
    doc = doc + "fn ChengNativeSurfaceActivityContract(): str =\n"
    doc = doc + "    return \"platform=android,event_loop=event_driven_v1,polling=false,webview_business_layer=false,business_js=false\"\n"
    return doc

fn nativeProjectIosInfoPlistText(packageId: str): str =
    var doc = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
    doc = doc + "<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n"
    doc = doc + "<plist version=\"1.0\">\n"
    doc = doc + "<dict>\n"
    doc = doc + "  <key>CFBundleIdentifier</key>\n"
    doc = doc + "  <string>" + packageId + "</string>\n"
    doc = doc + "  <key>CFBundleName</key>\n"
    doc = doc + "  <string>UniMaker Cheng</string>\n"
    doc = doc + "  <key>UILaunchStoryboardName</key>\n"
    doc = doc + "  <string>LaunchScreen</string>\n"
    doc = doc + "</dict>\n"
    doc = doc + "</plist>\n"
    return doc

fn nativeProjectIosShellSourceText(packageId: str,
                                   framePath: str): str =
    var doc: str
    doc = doc + "const ChengNativeSurfaceShellPlatform: str = \"ios\"\n"
