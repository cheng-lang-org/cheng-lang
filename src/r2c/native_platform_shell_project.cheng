fn WriteNativePlatformShellProject(packageManifestPath: str,
                                   projectDir: str,
                                   projectManifestOut: str): bool =
    if strings.Len(packageManifestPath) <= 0 || !chengpath.FileExistsNonEmpty("", packageManifestPath):
        return false
    if strings.Len(projectDir) <= 0 || strings.Len(projectManifestOut) <= 0:
        return false
    if !chengpath.MkdirP("", projectDir):
        return false
    let packageText: str = chengpath.ReadTextFile("", packageManifestPath)
    if !shellpackage.NativePlatformShellPackageManifestValid(packageText):
        return false
    let androidDir: str = chengpath.PathJoin(projectDir, "android")
    let iosDir: str = chengpath.PathJoin(projectDir, "ios")
    let ohosDir: str = chengpath.PathJoin(projectDir, "ohos")
    if !chengpath.MkdirP("", androidDir):
        return false
    if !chengpath.MkdirP("", iosDir):
        return false
    if !chengpath.MkdirP("", ohosDir):
        return false
    let androidProjectPath: str = chengpath.PathJoin(androidDir, "native_surface_shell_project_v1.json")
    let iosProjectPath: str = chengpath.PathJoin(iosDir, "native_surface_shell_project_v1.json")
    let ohosProjectPath: str = chengpath.PathJoin(ohosDir, "native_surface_shell_project_v1.json")
    let androidEntryPath: str = chengpath.PathJoin(androidDir, "native_surface_shell_entry_v1.json")
    let iosEntryPath: str = chengpath.PathJoin(iosDir, "native_surface_shell_entry_v1.json")
    let ohosEntryPath: str = chengpath.PathJoin(ohosDir, "native_surface_shell_entry_v1.json")
    let entryManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_entry_manifest_v1.json")
    let androidInstallPackagePath: str = chengpath.PathJoin(androidDir, "android_package_manifest_v1.json")
    let iosInstallPackagePath: str = chengpath.PathJoin(iosDir, "ios_package_manifest_v1.json")
    let ohosInstallPackagePath: str = chengpath.PathJoin(ohosDir, "ohos_package_manifest_v1.json")
    let installManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_install_manifest_v1.json")
    let androidPlatformManifestPath: str = chengpath.PathJoin(androidDir, "AndroidManifest.xml")
    let androidShellSourcePath: str = chengpath.PathJoin(androidDir, "ChengNativeSurfaceActivity.cheng")
    let iosInfoPlistPath: str = chengpath.PathJoin(iosDir, "Info.plist")
    let iosShellSourcePath: str = chengpath.PathJoin(iosDir, "ChengNativeSurfaceViewController.cheng")
    let ohosModulePath: str = chengpath.PathJoin(ohosDir, "module.json5")
    let ohosShellSourcePath: str = chengpath.PathJoin(ohosDir, "ChengNativeSurfaceAbility.cheng")
    let filesManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_files_manifest_v1.json")
    let buildInputsManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_build_inputs_manifest_v1.json")
    let androidBuildInputPath: str = chengpath.PathJoin(androidDir, "android_build_input_v1.json")
    let iosBuildInputPath: str = chengpath.PathJoin(iosDir, "ios_build_input_v1.json")
    let ohosBuildInputPath: str = chengpath.PathJoin(ohosDir, "ohos_build_input_v1.json")
    let packagingPlanManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_packaging_plan_manifest_v1.json")
    let androidPackagingPlanPath: str = chengpath.PathJoin(androidDir, "android_packaging_plan_v1.json")
    let iosPackagingPlanPath: str = chengpath.PathJoin(iosDir, "ios_packaging_plan_v1.json")
    let ohosPackagingPlanPath: str = chengpath.PathJoin(ohosDir, "ohos_packaging_plan_v1.json")
    let summaryPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_project.summary.env")
    let androidLaunchPath: str = nativeProjectJsonReadStringField(packageText, "android_launch_plan_path", "")
    let iosLaunchPath: str = nativeProjectJsonReadStringField(packageText, "ios_launch_plan_path", "")
    let ohosLaunchPath: str = nativeProjectJsonReadStringField(packageText, "ohos_launch_plan_path", "")
    let androidDoc: str = nativeProjectPlatformText(packageManifestPath,
                                                    packageText,
                                                    "android",
                                                    "cheng_generated_android_native_surface_project_v1",
                                                    "cheng_generated_android_surface_shell_v1",
                                                    "ANativeWindow_rgba_blit_v1",
                                                    "AInputQueue_event_driven_v1",
                                                    androidLaunchPath,
                                                    androidDir)
    let iosDoc: str = nativeProjectPlatformText(packageManifestPath,
                                                packageText,
                                                "ios",
                                                "cheng_generated_ios_native_surface_project_v1",
                                                "cheng_generated_ios_surface_shell_v1",
                                                "CAMetalLayer_rgba_blit_v1",
                                                "UIKit_touch_event_driven_v1",
                                                iosLaunchPath,
                                                iosDir)
    let ohosDoc: str = nativeProjectPlatformText(packageManifestPath,
                                                 packageText,
                                                 "ohos",
                                                 "cheng_generated_ohos_native_surface_project_v1",
                                                 "cheng_generated_ohos_surface_shell_v1",
                                                 "OHNativeWindow_rgba_blit_v1",
                                                 "XComponent_event_driven_v1",
                                                 ohosLaunchPath,
                                                 ohosDir)
    if !chengpath.WriteTextFile("", androidProjectPath, androidDoc):
        return false
    if !chengpath.WriteTextFile("", iosProjectPath, iosDoc):
        return false
    if !chengpath.WriteTextFile("", ohosProjectPath, ohosDoc):
        return false
    let androidEntryDoc: str = nativeProjectEntryText(packageManifestPath,
                                                      androidProjectPath,
                                                      "android",
                                                      "cheng_android_native_surface_entry_v1",
                                                      "cheng_generated_android_surface_shell_v1",
                                                      "ANativeWindow_rgba_blit_v1",
                                                      "AInputQueue_event_driven_v1",
                                                      androidDir,
                                                      packageText)
    let iosEntryDoc: str = nativeProjectEntryText(packageManifestPath,
                                                  iosProjectPath,
                                                  "ios",
                                                  "cheng_ios_native_surface_entry_v1",
                                                  "cheng_generated_ios_surface_shell_v1",
                                                  "CAMetalLayer_rgba_blit_v1",
                                                  "UIKit_touch_event_driven_v1",
                                                  iosDir,
                                                  packageText)
    let ohosEntryDoc: str = nativeProjectEntryText(packageManifestPath,
                                                   ohosProjectPath,
                                                   "ohos",
                                                   "cheng_ohos_native_surface_entry_v1",
                                                   "cheng_generated_ohos_surface_shell_v1",
                                                   "OHNativeWindow_rgba_blit_v1",
                                                   "XComponent_event_driven_v1",
                                                   ohosDir,
                                                   packageText)
    if !chengpath.WriteTextFile("", androidEntryPath, androidEntryDoc):
        return false
    if !chengpath.WriteTextFile("", iosEntryPath, iosEntryDoc):
        return false
    if !chengpath.WriteTextFile("", ohosEntryPath, ohosEntryDoc):
        return false
    let androidInstallDoc: str = nativeProjectInstallPackageText(packageManifestPath,
                                                                 androidProjectPath,
                                                                 androidEntryPath,
                                                                 "android",
                                                                 "android_native_surface_app_manifest_v1",
                                                                 "cheng_generated_android_surface_app_v1",
                                                                 "org.cheng.unimaker.nativegui",
                                                                 "ChengNativeSurfaceActivity",
                                                                 "ANativeWindow_rgba_blit_v1",
                                                                 "AInputQueue_event_driven_v1",
                                                                 androidDir,
                                                                 packageText)
    let iosInstallDoc: str = nativeProjectInstallPackageText(packageManifestPath,
                                                             iosProjectPath,
                                                             iosEntryPath,
                                                             "ios",
                                                             "ios_native_surface_app_manifest_v1",
                                                             "cheng_generated_ios_surface_app_v1",
                                                             "org.cheng.unimaker.nativegui",
                                                             "ChengNativeSurfaceViewController",
                                                             "CAMetalLayer_rgba_blit_v1",
                                                             "UIKit_touch_event_driven_v1",
                                                             iosDir,
                                                             packageText)
    let ohosInstallDoc: str = nativeProjectInstallPackageText(packageManifestPath,
                                                              ohosProjectPath,
                                                              ohosEntryPath,
                                                              "ohos",
                                                              "ohos_native_surface_app_manifest_v1",
                                                              "cheng_generated_ohos_surface_app_v1",
                                                              "org.cheng.unimaker.nativegui",
                                                              "ChengNativeSurfaceAbility",
                                                              "OHNativeWindow_rgba_blit_v1",
                                                              "XComponent_event_driven_v1",
                                                              ohosDir,
                                                              packageText)
    if !chengpath.WriteTextFile("", androidInstallPackagePath, androidInstallDoc):
        return false
    if !chengpath.WriteTextFile("", iosInstallPackagePath, iosInstallDoc):
        return false
    if !chengpath.WriteTextFile("", ohosInstallPackagePath, ohosInstallDoc):
        return false
    let framePath: str = nativeProjectJsonReadStringField(packageText, "frame_path", "")
    let packageId: str = "org.cheng.unimaker.nativegui"
    if !chengpath.WriteTextFile("", androidPlatformManifestPath, nativeProjectAndroidManifestText(packageId)):
        return false
    if !chengpath.WriteTextFile("", androidShellSourcePath, nativeProjectAndroidShellSourceText(packageId, framePath)):
        return false
    if !chengpath.WriteTextFile("", iosInfoPlistPath, nativeProjectIosInfoPlistText(packageId)):
        return false
    if !chengpath.WriteTextFile("", iosShellSourcePath, nativeProjectIosShellSourceText(packageId, framePath)):
        return false
    if !chengpath.WriteTextFile("", ohosModulePath, nativeProjectOhosModuleText(packageId)):
        return false
    if !chengpath.WriteTextFile("", ohosShellSourcePath, nativeProjectOhosShellSourceText(packageId, framePath)):
        return false
    let filesManifestDoc: str = nativeProjectFilesManifestText(projectManifestOut,
                                                               androidPlatformManifestPath,
                                                               androidShellSourcePath,
                                                               iosInfoPlistPath,
                                                               iosShellSourcePath,
                                                               ohosModulePath,
                                                               ohosShellSourcePath)
    if !NativePlatformShellFilesManifestValid(filesManifestDoc):
        return false
    if !chengpath.WriteTextFile("", filesManifestPath, filesManifestDoc):
        return false
    if !chengpath.WriteTextFile("", entryManifestPath,
                                nativeProjectEntryManifestText(projectManifestOut,
                                                               androidEntryPath,
                                                               iosEntryPath,
                                                               ohosEntryPath)):
        return false
    let installManifestDoc: str = nativeProjectInstallManifestText(projectManifestOut,
                                                                   androidInstallPackagePath,
                                                                   iosInstallPackagePath,
                                                                   ohosInstallPackagePath)
    if !NativePlatformShellInstallManifestValid(installManifestDoc):
        return false
    if !chengpath.WriteTextFile("", installManifestPath, installManifestDoc):
        return false
    let androidBuildInputDoc: str = nativeProjectBuildInputText(packageManifestPath,
                                                                projectManifestOut,
                                                                androidProjectPath,
                                                                entryManifestPath,
                                                                androidEntryPath,
                                                                installManifestPath,
                                                                androidInstallPackagePath,
                                                                filesManifestPath,
                                                                androidPlatformManifestPath,
                                                                androidShellSourcePath,
                                                                "android",
                                                                "aarch64-linux-android",
                                                                "apk_or_aab_input_contract_v1",
                                                                packageId,
                                                                "android_package_id",
                                                                "ChengNativeSurfaceActivity",
                                                                "ANativeWindow_rgba_blit_v1",
                                                                "AInputQueue_event_driven_v1",
                                                                chengpath.PathJoin(androidDir, "build/outputs/unimaker-cheng-native.apk"),
                                                                packageText)
    let iosBuildInputDoc: str = nativeProjectBuildInputText(packageManifestPath,
                                                            projectManifestOut,
                                                            iosProjectPath,
                                                            entryManifestPath,
                                                            iosEntryPath,
                                                            installManifestPath,
                                                            iosInstallPackagePath,
                                                            filesManifestPath,
                                                            iosInfoPlistPath,
                                                            iosShellSourcePath,
                                                            "ios",
                                                            "arm64-apple-ios",
                                                            "ipa_or_app_bundle_input_contract_v1",
                                                            packageId,
                                                            "ios_bundle_id",
                                                            "ChengNativeSurfaceViewController",
                                                            "CAMetalLayer_rgba_blit_v1",
                                                            "UIKit_touch_event_driven_v1",
                                                            chengpath.PathJoin(iosDir, "build/UniMakerCheng.app"),
                                                            packageText)
    let ohosBuildInputDoc: str = nativeProjectBuildInputText(packageManifestPath,
                                                             projectManifestOut,
                                                             ohosProjectPath,
                                                             entryManifestPath,
                                                             ohosEntryPath,
                                                             installManifestPath,
                                                             ohosInstallPackagePath,
                                                             filesManifestPath,
                                                             ohosModulePath,
                                                             ohosShellSourcePath,
                                                             "ohos",
                                                             "aarch64-linux-ohos",
                                                             "hap_input_contract_v1",
                                                             packageId,
                                                             "ohos_bundle_name",
                                                             "ChengNativeSurfaceAbility",
                                                             "OHNativeWindow_rgba_blit_v1",
                                                             "XComponent_event_driven_v1",
                                                             chengpath.PathJoin(ohosDir, "build/UniMakerCheng.hap"),
                                                             packageText)
    if !chengpath.WriteTextFile("", androidBuildInputPath, androidBuildInputDoc):
        return false
    if !chengpath.WriteTextFile("", iosBuildInputPath, iosBuildInputDoc):
        return false
    if !chengpath.WriteTextFile("", ohosBuildInputPath, ohosBuildInputDoc):
        return false
    let buildInputsManifestDoc: str = nativeProjectBuildInputsManifestText(packageManifestPath,
                                                                           projectManifestOut,
                                                                           androidBuildInputPath,
                                                                           iosBuildInputPath,
                                                                           ohosBuildInputPath)
    if !NativePlatformShellBuildInputsManifestValid(buildInputsManifestDoc):
        return false
    if !chengpath.WriteTextFile("", buildInputsManifestPath, buildInputsManifestDoc):
        return false
    if !chengpath.WriteTextFile("", androidPackagingPlanPath,
                                nativeProjectPackagingPlanText(androidBuildInputPath,
                                                               "android",
                                                               "aarch64-linux-android",
                                                               "apk_or_aab_input_contract_v1",
                                                               "android_package_id",
                                                               "ANativeWindow_rgba_blit_v1",
                                                               "AInputQueue_event_driven_v1",
                                                               chengpath.PathJoin(androidDir, "build/outputs/unimaker-cheng-native.apk"))):
        return false
    if !chengpath.WriteTextFile("", iosPackagingPlanPath,
                                nativeProjectPackagingPlanText(iosBuildInputPath,
                                                               "ios",
                                                               "arm64-apple-ios",
                                                               "ipa_or_app_bundle_input_contract_v1",
                                                               "ios_bundle_id",
                                                               "CAMetalLayer_rgba_blit_v1",
                                                               "UIKit_touch_event_driven_v1",
                                                               chengpath.PathJoin(iosDir, "build/UniMakerCheng.app"))):
        return false
    if !chengpath.WriteTextFile("", ohosPackagingPlanPath,
                                nativeProjectPackagingPlanText(ohosBuildInputPath,
                                                               "ohos",
                                                               "aarch64-linux-ohos",
                                                               "hap_input_contract_v1",
                                                               "ohos_bundle_name",
                                                               "OHNativeWindow_rgba_blit_v1",
                                                               "XComponent_event_driven_v1",
                                                               chengpath.PathJoin(ohosDir, "build/UniMakerCheng.hap"))):
        return false
    let packagingPlanManifestDoc: str = nativeProjectPackagingPlanManifestText(projectManifestOut,
                                                                               buildInputsManifestPath,
                                                                               androidPackagingPlanPath,
                                                                               iosPackagingPlanPath,
                                                                               ohosPackagingPlanPath)
    if !NativePlatformShellPackagingPlanManifestValid(packagingPlanManifestDoc):
        return false
    if !chengpath.WriteTextFile("", packagingPlanManifestPath, packagingPlanManifestDoc):
        return false
    if !chengpath.WriteTextFile("", summaryPath,
                                nativeProjectSummaryText(projectManifestOut,
                                                         androidProjectPath,
                                                         iosProjectPath,
                                                         ohosProjectPath,
                                                         entryManifestPath,
                                                         installManifestPath,
                                                         androidInstallPackagePath,
                                                         iosInstallPackagePath,
                                                         ohosInstallPackagePath,
                                                         filesManifestPath,
                                                         androidPlatformManifestPath,
                                                         androidShellSourcePath,
                                                         iosInfoPlistPath,
                                                         iosShellSourcePath,
                                                         ohosModulePath,
                                                         ohosShellSourcePath,
                                                         buildInputsManifestPath,
                                                         androidBuildInputPath,
                                                         iosBuildInputPath,
                                                         ohosBuildInputPath,
                                                         packagingPlanManifestPath,
                                                         androidPackagingPlanPath,
                                                         iosPackagingPlanPath,
                                                         ohosPackagingPlanPath)):
        return false
    let projectDoc: str = nativeProjectManifestText(packageManifestPath,
                                                    projectDir,
                                                    androidDir,
                                                    iosDir,
                                                    ohosDir,
                                                    androidProjectPath,
                                                    iosProjectPath,
                                                    ohosProjectPath,
                                                    entryManifestPath,
                                                    androidEntryPath,
                                                    iosEntryPath,
                                                    ohosEntryPath,
                                                    installManifestPath,
                                                    androidInstallPackagePath,
                                                    iosInstallPackagePath,
                                                    ohosInstallPackagePath,
                                                    filesManifestPath,
                                                    androidPlatformManifestPath,
                                                    androidShellSourcePath,
                                                    iosInfoPlistPath,
                                                    iosShellSourcePath,
                                                    ohosModulePath,
                                                    ohosShellSourcePath,
                                                    buildInputsManifestPath,
                                                    androidBuildInputPath,
                                                    iosBuildInputPath,
                                                    ohosBuildInputPath,
                                                    summaryPath,
                                                    packageText)
    if !NativePlatformShellProjectManifestValid(projectDoc):
        return false
    if !chengpath.WriteTextFile("", projectManifestOut, projectDoc):
        return false
    if !chengpath.FileExistsNonEmpty("", androidProjectPath):
        return false
    if !chengpath.FileExistsNonEmpty("", iosProjectPath):
        return false
    if !chengpath.FileExistsNonEmpty("", ohosProjectPath):
        return false
    if !chengpath.FileExistsNonEmpty("", androidEntryPath):
        return false
    if !chengpath.FileExistsNonEmpty("", iosEntryPath):
        return false
    if !chengpath.FileExistsNonEmpty("", ohosEntryPath):
        return false
    if !chengpath.FileExistsNonEmpty("", entryManifestPath):
        return false
    if !chengpath.FileExistsNonEmpty("", androidInstallPackagePath):
        return false
    if !chengpath.FileExistsNonEmpty("", iosInstallPackagePath):
        return false
    if !chengpath.FileExistsNonEmpty("", ohosInstallPackagePath):
        return false
    if !chengpath.FileExistsNonEmpty("", installManifestPath):
        return false
    if !chengpath.FileExistsNonEmpty("", androidPlatformManifestPath):
        return false
    if !chengpath.FileExistsNonEmpty("", androidShellSourcePath):
        return false
    if !chengpath.FileExistsNonEmpty("", iosInfoPlistPath):
        return false
    if !chengpath.FileExistsNonEmpty("", iosShellSourcePath):
        return false
    if !chengpath.FileExistsNonEmpty("", ohosModulePath):
        return false
    if !chengpath.FileExistsNonEmpty("", ohosShellSourcePath):
        return false
    if !chengpath.FileExistsNonEmpty("", filesManifestPath):
        return false
    if !chengpath.FileExistsNonEmpty("", androidBuildInputPath):
        return false
    if !chengpath.FileExistsNonEmpty("", iosBuildInputPath):
        return false
    if !chengpath.FileExistsNonEmpty("", ohosBuildInputPath):
        return false
    if !chengpath.FileExistsNonEmpty("", buildInputsManifestPath):
        return false
    if !chengpath.FileExistsNonEmpty("", androidPackagingPlanPath):
        return false
    if !chengpath.FileExistsNonEmpty("", iosPackagingPlanPath):
        return false
    if !chengpath.FileExistsNonEmpty("", ohosPackagingPlanPath):
        return false
    if !chengpath.FileExistsNonEmpty("", packagingPlanManifestPath):
        return false
    if !chengpath.FileExistsNonEmpty("", summaryPath):
        return false
    return chengpath.FileExistsNonEmpty("", projectManifestOut)
