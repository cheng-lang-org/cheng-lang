fn NativePlatformShellPackagingPlanManifestValid(manifestText: str): bool =
    if nativeProjectJsonReadStringField(manifestText, "format", "") != "native_platform_shell_packaging_plan_manifest_v1":
        return false
    if nativeProjectJsonReadStringField(manifestText, "event_loop", "") != "event_driven_v1":
        return false
    if nativeProjectJsonReadIntField(manifestText, "packaging_plan_count", 0) != 3:
