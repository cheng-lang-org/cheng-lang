fn nativeProjectManifestText(packageManifestPath: str,
                             projectDir: str,
                             androidDir: str,
                             iosDir: str,
                             ohosDir: str,
                             androidProjectPath: str,
                             iosProjectPath: str,
                             ohosProjectPath: str,
                             entryManifestPath: str,
                             androidEntryPath: str,
                             iosEntryPath: str,
                             ohosEntryPath: str,
                             installManifestPath: str,
                             androidInstallPackagePath: str,
                             iosInstallPackagePath: str,
                             ohosInstallPackagePath: str,
                             filesManifestPath: str,
                             androidPlatformManifestPath: str,
                             androidShellSourcePath: str,
                             iosInfoPlistPath: str,
                             iosShellSourcePath: str,
                             ohosModulePath: str,
                             ohosShellSourcePath: str,
                             buildInputsManifestPath: str,
                             androidBuildInputPath: str,
                             iosBuildInputPath: str,
                             ohosBuildInputPath: str,
                             summaryPath: str,
                             packageText: str): str =
    let framePath: str = nativeProjectJsonReadStringField(packageText, "frame_path", "")
    let frameByteCount: int32 = nativeProjectJsonReadIntField(packageText, "frame_byte_count", 0)
    let packagingPlanManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_packaging_plan_manifest_v1.json")
    let androidPackagingPlanPath: str = chengpath.PathJoin(androidDir, "android_packaging_plan_v1.json")
    let iosPackagingPlanPath: str = chengpath.PathJoin(iosDir, "ios_packaging_plan_v1.json")
    let ohosPackagingPlanPath: str = chengpath.PathJoin(ohosDir, "ohos_packaging_plan_v1.json")
    return Fmt"""
    {{
      "format": "native_platform_shell_project_manifest_v1",
      "ready": true,
      "generated_by": "cheng.native_platform_shell_project_v1",
      "project_kind": "cheng_generated_native_surface_shell_project_v1",
      "runtime_purity": {{"node": false, "react": false, "webview_business_layer": false, "business_js": false}},
      "event_loop": "event_driven_v1",
      "platform_count": 3,
      "package_manifest_path": {nativeProjectJsonQuote(packageManifestPath)},
      "project_dir": {nativeProjectJsonQuote(projectDir)},
      "summary_path": {nativeProjectJsonQuote(summaryPath)},
      "entry_manifest_path": {nativeProjectJsonQuote(entryManifestPath)},
      "install_manifest_path": {nativeProjectJsonQuote(installManifestPath)},
      "files_manifest_path": {nativeProjectJsonQuote(filesManifestPath)},
      "build_inputs_manifest_path": {nativeProjectJsonQuote(buildInputsManifestPath)},
      "packaging_plan_manifest_path": {nativeProjectJsonQuote(packagingPlanManifestPath)},
      "install_package_count": 3,
      "platform_file_count": 6,
      "build_input_count": 3,
      "packaging_plan_count": 3,
      "frame_path": {nativeProjectJsonQuote(framePath)},
      "frame_byte_count": {IntToStr(frameByteCount)},
      "platforms": [
        {{"id":"android","target_triple":"aarch64-linux-android","project_dir":{nativeProjectJsonQuote(androidDir)},"project_path":{nativeProjectJsonQuote(androidProjectPath)},"entry_path":{nativeProjectJsonQuote(androidEntryPath)},"install_package_path":{nativeProjectJsonQuote(androidInstallPackagePath)},"platform_manifest_path":{nativeProjectJsonQuote(androidPlatformManifestPath)},"shell_source_path":{nativeProjectJsonQuote(androidShellSourcePath)},"build_input_path":{nativeProjectJsonQuote(androidBuildInputPath)},"packaging_plan_path":{nativeProjectJsonQuote(androidPackagingPlanPath)},"surface_binding":"ANativeWindow_rgba_blit_v1","input_binding":"AInputQueue_event_driven_v1"}},
        {{"id":"ios","target_triple":"arm64-apple-ios","project_dir":{nativeProjectJsonQuote(iosDir)},"project_path":{nativeProjectJsonQuote(iosProjectPath)},"entry_path":{nativeProjectJsonQuote(iosEntryPath)},"install_package_path":{nativeProjectJsonQuote(iosInstallPackagePath)},"platform_manifest_path":{nativeProjectJsonQuote(iosInfoPlistPath)},"shell_source_path":{nativeProjectJsonQuote(iosShellSourcePath)},"build_input_path":{nativeProjectJsonQuote(iosBuildInputPath)},"packaging_plan_path":{nativeProjectJsonQuote(iosPackagingPlanPath)},"surface_binding":"CAMetalLayer_rgba_blit_v1","input_binding":"UIKit_touch_event_driven_v1"}},
        {{"id":"ohos","target_triple":"aarch64-linux-ohos","project_dir":{nativeProjectJsonQuote(ohosDir)},"project_path":{nativeProjectJsonQuote(ohosProjectPath)},"entry_path":{nativeProjectJsonQuote(ohosEntryPath)},"install_package_path":{nativeProjectJsonQuote(ohosInstallPackagePath)},"platform_manifest_path":{nativeProjectJsonQuote(ohosModulePath)},"shell_source_path":{nativeProjectJsonQuote(ohosShellSourcePath)},"build_input_path":{nativeProjectJsonQuote(ohosBuildInputPath)},"packaging_plan_path":{nativeProjectJsonQuote(ohosPackagingPlanPath)},"surface_binding":"OHNativeWindow_rgba_blit_v1","input_binding":"XComponent_event_driven_v1"}}
      ]
    }}

    """

fn NativePlatformShellProjectManifestValid(manifestText: str): bool =
    if nativeProjectJsonReadStringField(manifestText, "format", "") != "native_platform_shell_project_manifest_v1":
        return false
    if nativeProjectJsonReadStringField(manifestText, "project_kind", "") != "cheng_generated_native_surface_shell_project_v1":
        return false
    if nativeProjectJsonReadStringField(manifestText, "event_loop", "") != "event_driven_v1":
        return false
    if nativeProjectJsonReadIntField(manifestText, "platform_count", 0) != 3:
        return false
    if !strutil.Contains(manifestText, "\"node\": false"):
        return false
    if !strutil.Contains(manifestText, "\"react\": false"):
        return false
    if !strutil.Contains(manifestText, "\"webview_business_layer\": false"):
        return false
    if !strutil.Contains(manifestText, "\"business_js\": false"):
        return false
    if !strutil.Contains(manifestText, "\"project_dir\":"):
        return false
    if !strutil.Contains(manifestText, "\"entry_manifest_path\":"):
        return false
    if !strutil.Contains(manifestText, "\"install_manifest_path\":"):
        return false
    if !strutil.Contains(manifestText, "\"files_manifest_path\":"):
        return false
    if !strutil.Contains(manifestText, "\"build_inputs_manifest_path\":"):
        return false
    if !strutil.Contains(manifestText, "\"packaging_plan_manifest_path\":"):
        return false
    if nativeProjectJsonReadIntField(manifestText, "install_package_count", 0) != 3:
        return false
    if nativeProjectJsonReadIntField(manifestText, "platform_file_count", 0) != 6:
        return false
    if nativeProjectJsonReadIntField(manifestText, "build_input_count", 0) != 3:
        return false
    if nativeProjectJsonReadIntField(manifestText, "packaging_plan_count", 0) != 3:
        return false
    if !strutil.Contains(manifestText, "\"id\":\"android\""):
        return false
    if !strutil.Contains(manifestText, "\"id\":\"ios\""):
        return false
    if !strutil.Contains(manifestText, "\"id\":\"ohos\""):
        return false
    if !strutil.Contains(manifestText, "\"target_triple\":\"aarch64-linux-android\""):
        return false
    if !strutil.Contains(manifestText, "\"target_triple\":\"arm64-apple-ios\""):
        return false
    if !strutil.Contains(manifestText, "\"target_triple\":\"aarch64-linux-ohos\""):
        return false
    if !strutil.Contains(manifestText, "\"packaging_plan_path\":"):
        return false
    return true

