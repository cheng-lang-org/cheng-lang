    if !strutil.Contains(manifestText, "\"platform_identifier_kind\":\"android_package_id\""):
        return false
    if !strutil.Contains(manifestText, "\"platform_identifier_kind\":\"ios_bundle_id\""):
        return false
    if !strutil.Contains(manifestText, "\"platform_identifier_kind\":\"ohos_bundle_name\""):
        return false
