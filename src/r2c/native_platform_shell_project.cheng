fn nativeProjectManifestText(packageManifestPath: str,
                             projectDir: str,
                             androidDir: str,
                             iosDir: str,
                             ohosDir: str,
                             androidProjectPath: str,
                             iosProjectPath: str,
                             ohosProjectPath: str,
                             entryManifestPath: str,
                             androidEntryPath: str,
                             iosEntryPath: str,
                             ohosEntryPath: str,
                             installManifestPath: str,
                             androidInstallPackagePath: str,
                             iosInstallPackagePath: str,
                             ohosInstallPackagePath: str,
                             filesManifestPath: str,
                             androidPlatformManifestPath: str,
                             androidShellSourcePath: str,
                             iosInfoPlistPath: str,
                             iosShellSourcePath: str,
                             ohosModulePath: str,
                             ohosShellSourcePath: str,
                             buildInputsManifestPath: str,
                             androidBuildInputPath: str,
                             iosBuildInputPath: str,
                             ohosBuildInputPath: str,
                             summaryPath: str,
                             packageText: str): str =
    let framePath: str = nativeProjectJsonReadStringField(packageText, "frame_path", "")
    let frameByteCount: int32 = nativeProjectJsonReadIntField(packageText, "frame_byte_count", 0)
