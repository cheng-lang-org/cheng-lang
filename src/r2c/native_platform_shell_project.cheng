                                  androidEntryPath: str,
                                  iosEntryPath: str,
                                  ohosEntryPath: str): str =
    var doc = "{\n"
    doc = doc + "  \"format\": \"native_platform_shell_entry_manifest_v1\",\n"
    doc = doc + "  \"ready\": true,\n"
    doc = doc + "  \"generated_by\": \"cheng.native_platform_shell_project_v1\",\n"
    doc = doc + "  \"runtime_purity\": {\"node\": false, \"react\": false, \"webview_business_layer\": false, \"business_js\": false},\n"
    doc = doc + "  \"event_loop\": \"event_driven_v1\",\n"
    doc = doc + "  \"platform_count\": 3,\n"
    doc = doc + "  \"project_manifest_path\": " + nativeProjectJsonQuote(projectManifestPath) + ",\n"
    doc = doc + "  \"platforms\": [\n"
    doc = doc + "    {\"id\":\"android\",\"entry_path\":" + nativeProjectJsonQuote(androidEntryPath) + ",\"entry_symbol\":\"ChengNativeSurfaceShellMain\",\"surface_binding\":\"ANativeWindow_rgba_blit_v1\",\"input_binding\":\"AInputQueue_event_driven_v1\"},\n"
    doc = doc + "    {\"id\":\"ios\",\"entry_path\":" + nativeProjectJsonQuote(iosEntryPath) + ",\"entry_symbol\":\"ChengNativeSurfaceShellMain\",\"surface_binding\":\"CAMetalLayer_rgba_blit_v1\",\"input_binding\":\"UIKit_touch_event_driven_v1\"},\n"
    doc = doc + "    {\"id\":\"ohos\",\"entry_path\":" + nativeProjectJsonQuote(ohosEntryPath) + ",\"entry_symbol\":\"ChengNativeSurfaceShellMain\",\"surface_binding\":\"OHNativeWindow_rgba_blit_v1\",\"input_binding\":\"XComponent_event_driven_v1\"}\n"
    doc = doc + "  ]\n"
    doc = doc + "}\n"
    return doc

