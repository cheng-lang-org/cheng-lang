    out = out + "install_manifest_path=" + installManifestPath + "\n"
    out = out + "android_install_package_path=" + androidInstallPackagePath + "\n"
    out = out + "ios_install_package_path=" + iosInstallPackagePath + "\n"
    out = out + "ohos_install_package_path=" + ohosInstallPackagePath + "\n"
    out = out + "files_manifest_path=" + filesManifestPath + "\n"
    out = out + "android_platform_manifest_path=" + androidPlatformManifestPath + "\n"
    out = out + "android_shell_source_path=" + androidShellSourcePath + "\n"
    out = out + "ios_info_plist_path=" + iosInfoPlistPath + "\n"
    out = out + "ios_shell_source_path=" + iosShellSourcePath + "\n"
    out = out + "ohos_module_path=" + ohosModulePath + "\n"
    out = out + "ohos_shell_source_path=" + ohosShellSourcePath + "\n"
    out = out + "build_inputs_manifest_path=" + buildInputsManifestPath + "\n"
    out = out + "android_build_input_path=" + androidBuildInputPath + "\n"
    out = out + "ios_build_input_path=" + iosBuildInputPath + "\n"
    out = out + "ohos_build_input_path=" + ohosBuildInputPath + "\n"
    out = out + "packaging_plan_manifest_path=" + packagingPlanManifestPath + "\n"
    out = out + "android_packaging_plan_path=" + androidPackagingPlanPath + "\n"
    out = out + "ios_packaging_plan_path=" + iosPackagingPlanPath + "\n"
    out = out + "ohos_packaging_plan_path=" + ohosPackagingPlanPath + "\n"
    return out

