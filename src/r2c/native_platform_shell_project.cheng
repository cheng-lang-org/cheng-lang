    out = out + "runtime_purity=node:false,react:false,webview_business_layer:false,business_js:false\n"
    out = out + "event_loop=event_driven_v1\n"
    out = out + "project_manifest_path=" + projectManifestPath + "\n"
    out = out + "android_project_path=" + androidProjectPath + "\n"
    out = out + "ios_project_path=" + iosProjectPath + "\n"
    out = out + "ohos_project_path=" + ohosProjectPath + "\n"
