import backend/tooling/backend_driver_uir_module_shared

fn driverUirOptLevel(): int32 =
    return driverModuleOptLevel()

fn driverUirBuildEmitObjFromFileStage1Target(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    let module_raw: ptr = driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)
    return driverUirEmitObjFromRetainedModule(module_raw, target_raw, out_raw)
