import std/system_c
import std/result
import backend/uir/uir_codegen
import backend/uir/uir_types
import backend/uir/uir_internal/uir_core_builder

type
    DriverUirSidecarByteBuf = uint8[]

@importc("driver_c_write_exact_file")
fn driver_c_write_exact_file(path: cstring, buffer: ptr, len: int32): int32
@importc("getenv")
fn driver_c_getenv(name: cstring): cstring
@importc("memRetain")
fn driver_sidecar_memRetain(p: ptr)
@importc("memRelease")
fn driver_sidecar_memRelease(p: ptr)
@importc("ptr_add")
fn driver_sidecar_ptr_add(p: ptr, off: int32): ptr

fn driverSidecarStrViewUnsafe(data: ptr, len: int32): str =
    var out: str
    out.data = data
    out.len = len
    out.store_id = 0
    out.flags = 0
    return out

fn driverSidecarBorrowCString(raw: cstring): str =
    if raw == nil:
        return ""
    let n: int32 = c_strlen(raw)
    if n <= 0:
        return ""
    return driverSidecarStrViewUnsafe(ptr(raw), n)

fn driverSidecarParseNonNegativeIntRaw(raw: cstring, defaultValue: int32): int32 =
    if raw == nil:
        return defaultValue
    var i: int32 = 0
    var v: int64 = 0
    while true:
        let ch: char = *(ptr(driver_sidecar_ptr_add(ptr(raw), i)))
        if ch == '\0':
            break
        if ch < '0' || ch > '9':
            return defaultValue
        v = v * int64(10) + int64(int32(ch) - int32('0'))
        if v > int64(2147483647):
            return int32(2147483647)
        i = i + 1
    if i <= 0:
        return defaultValue
    return int32(v)

fn driverSidecarOptLevel(): int32 =
    return driverSidecarParseNonNegativeIntRaw(driver_c_getenv("BACKEND_OPT_LEVEL"), 0)

fn driverSidecarBuildModuleStage1TargetRetained(path_raw: cstring, target_raw: cstring): ptr =
    if path_raw == nil:
        return nil
    let path: str = driverSidecarBorrowCString(path_raw)
    if len(path) == 0:
        return nil
    let target: str = driverSidecarBorrowCString(target_raw)
    let module: UirModule = uirCoreBuildModuleFromFileStage1OrPanic(path, target)
    if module == nil:
        return nil
    let modulePtr: ptr = ptr(module)
    if modulePtr == nil:
        return nil
    driver_sidecar_memRetain(modulePtr)
    return modulePtr

fn driverSidecarEmitObjFromRetainedModule(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    if module_raw == nil:
        return -11
    if out_raw == nil:
        return -12
    let outPath: str = driverSidecarBorrowCString(out_raw)
    if len(outPath) == 0:
        return -12
    let target: str = driverSidecarBorrowCString(target_raw)
    let module: UirModule = UirModule(module_raw)
    var rc: int32 = 0
    let objRes: Result[DriverUirSidecarByteBuf] =
        uirEmitObjFromModule(module, driverSidecarOptLevel(), target, "", false, false, 0, "autovec")
    if !IsOk[DriverUirSidecarByteBuf](objRes):
        rc = -10
    else:
        let obj: uint8[] = objRes.value
        if len(obj) <= 0:
            rc = -13
        elif obj.buffer == nil:
            rc = -14
        else:
            rc = driver_c_write_exact_file(out_raw, obj.buffer, obj.len)
    driver_sidecar_memRelease(module_raw)
    return rc
