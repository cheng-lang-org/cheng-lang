import backend/tooling/backend_driver_uir_module_shared
import backend/tooling/backend_driver_uir_shared
import backend/tooling/backend_driver_uir_exports_keepalive
import backend/uir/uir_types

fn driverUirSidecarKeepalive(): int32 =
    return backendDriverUirExportsKeepalive()

@exportc("uirBuildModuleFromFileStage1TargetOrPanic")
fn driver_export_uirBuildModuleFromFileStage1TargetOrPanic(path_raw: cstring, target_raw: cstring): ptr =
    return driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("uirCoreBuildModuleFromFileStage1OrPanic")
fn driver_export_uirCoreBuildModuleFromFileStage1OrPanic(path_raw: cstring, target_raw: cstring): ptr =
    return driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_buildModuleFromFileStage1TargetRetained")
fn driver_buildModuleFromFileStage1TargetRetained(path_raw: cstring, target_raw: cstring): ptr =
    return driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_export_buildModuleFromFileStage1TargetRetained")
fn driver_export_buildModuleFromFileStage1TargetRetained(path_raw: cstring, target_raw: cstring): ptr =
    return driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("uirBuildModuleFromFileStage1OrPanic")
fn driver_export_uirBuildModuleFromFileStage1OrPanic(path_raw: cstring): ptr =
    return driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_export_uirBuildModuleFromFileStage1OrPanic")
fn driver_export_uirBuildModuleFromFileStage1OrPanicAlias(path_raw: cstring): ptr =
    return driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_buildActiveModulePtrs")
fn driver_buildActiveModulePtrs(path_raw: cstring, target_raw: cstring): ptr =
    return driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_export_buildActiveModulePtrs")
fn driver_export_buildActiveModulePtrs(path_raw: cstring, target_raw: cstring): ptr =
    return driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_buildModuleFromFileStage1Retained")
fn driver_buildModuleFromFileStage1Retained(path_raw: cstring): ptr =
    return driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_export_buildModuleFromFileStage1Retained")
fn driver_export_buildModuleFromFileStage1Retained(path_raw: cstring): ptr =
    return driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_emit_obj_from_module_default_impl")
fn driver_emit_obj_from_module_default_impl(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirEmitObjFromRetainedModule(module_raw, target_raw, out_raw)

@exportc("driver_export_emit_obj_from_module_default_impl")
fn driver_export_emit_obj_from_module_default_impl(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirEmitObjFromRetainedModule(module_raw, target_raw, out_raw)

@exportc("uirEmitObjFromModuleOrPanic")
fn driver_export_uirEmitObjFromModuleOrPanic(module_raw: ptr, optLevel: int32,
                                             target_raw: cstring, objWriter_raw: cstring,
                                             validateModule: int32,
                                             uirSimdEnabled: int32, uirSimdMaxWidth: int32,
                                             uirSimdPolicy_raw: cstring): uint8[] =
    return driverUirEmitObjBytesFromRetainedModule(module_raw, optLevel, target_raw, objWriter_raw,
                                                   validateModule, uirSimdEnabled, uirSimdMaxWidth,
                                                   uirSimdPolicy_raw)

@exportc("driver_build_emit_obj_from_file_stage1_target_impl")
fn driver_build_emit_obj_from_file_stage1_target_impl(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirBuildEmitObjFromFileStage1Target(path_raw, target_raw, out_raw)

@exportc("driver_export_build_emit_obj_from_file_stage1_target_impl")
fn driver_export_build_emit_obj_from_file_stage1_target_impl(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirBuildEmitObjFromFileStage1Target(path_raw, target_raw, out_raw)

fn main(): int32 =
    let _keepalive: int32 = driverUirSidecarKeepalive()
    return _keepalive - _keepalive
