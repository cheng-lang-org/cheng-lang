import backend/tooling/backend_driver_uir_shared
import backend/uir/uir_types

@importc("driver_c_backend_usage")
fn driver_c_backend_usage(_dummy: int32): int32

@importc("driver_c_help_requested")
fn driver_c_help_requested(_dummy: int32): int32

@importc("driver_c_run_default")
fn driver_c_run_default(_dummy: int32): int32

fn proofDriverExportsKeepalive(): int32 =
    if driver_c_help_requested(0) < 0:
        let _m0: ptr = uirBuildModuleFromFileStage1TargetOrPanic(nil, nil)
        let _m1: ptr = uirCoreBuildModuleFromFileStage1OrPanic(nil, nil)
        let _m2: ptr = driver_buildModuleFromFileStage1TargetRetained(nil, nil)
        let _m3: ptr = uirBuildModuleFromFileStage1OrPanic(nil)
        let _m4: ptr = driver_buildActiveModulePtrs(nil, nil)
        let _m5: ptr = driver_buildModuleFromFileStage1Retained(nil)
        let _m6: ptr = driver_export_buildModuleFromFileStage1TargetRetained(nil, nil)
        let _m7: ptr = driver_export_uirBuildModuleFromFileStage1TargetOrPanic(nil, nil)
        let _m8: ptr = driver_export_uirBuildModuleFromFileStage1OrPanic(nil)
        let _m9: ptr = driver_export_buildModuleFromFileStage1Retained(nil)
        let _rc0: int32 = driver_emit_obj_from_module_default_impl(nil, nil, nil)
        let _rc2: int32 = driver_export_build_emit_obj_from_file_stage1_target_impl(nil, nil, nil)
        let _obj0: uint8[] = uirEmitObjFromModuleOrPanic(nil, 0, nil, nil, 0, 0, 0, nil)
        let _rc1: int32 = driver_build_emit_obj_from_file_stage1_target_impl(nil, nil, nil)
        let _pin: int32 = len(_obj0) + _rc0 + _rc1 + _rc2 + int32(uint64(_m0)) + int32(uint64(_m1)) +
                          int32(uint64(_m2)) + int32(uint64(_m3)) + int32(uint64(_m4)) +
                          int32(uint64(_m5)) + int32(uint64(_m6)) + int32(uint64(_m7)) +
                          int32(uint64(_m8)) + int32(uint64(_m9))
        return _pin
    return 0

@exportc("uirBuildModuleFromFileStage1TargetOrPanic")
fn uirBuildModuleFromFileStage1TargetOrPanic(path_raw: cstring, target_raw: cstring): ptr =
    driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("uirCoreBuildModuleFromFileStage1OrPanic")
fn uirCoreBuildModuleFromFileStage1OrPanic(path_raw: cstring, target_raw: cstring): ptr =
    driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_buildModuleFromFileStage1TargetRetained")
fn driver_buildModuleFromFileStage1TargetRetained(path_raw: cstring, target_raw: cstring): ptr =
    driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_export_buildModuleFromFileStage1TargetRetained")
fn driver_export_buildModuleFromFileStage1TargetRetained(path_raw: cstring, target_raw: cstring): ptr =
    driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_export_uirBuildModuleFromFileStage1TargetOrPanic")
fn driver_export_uirBuildModuleFromFileStage1TargetOrPanic(path_raw: cstring, target_raw: cstring): ptr =
    driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("uirBuildModuleFromFileStage1OrPanic")
fn uirBuildModuleFromFileStage1OrPanic(path_raw: cstring): ptr =
    driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_export_uirBuildModuleFromFileStage1OrPanic")
fn driver_export_uirBuildModuleFromFileStage1OrPanic(path_raw: cstring): ptr =
    driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_buildActiveModulePtrs")
fn driver_buildActiveModulePtrs(path_raw: cstring, target_raw: cstring): ptr =
    driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_buildModuleFromFileStage1Retained")
fn driver_buildModuleFromFileStage1Retained(path_raw: cstring): ptr =
    driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_export_buildModuleFromFileStage1Retained")
fn driver_export_buildModuleFromFileStage1Retained(path_raw: cstring): ptr =
    driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_emit_obj_from_module_default_impl")
fn driver_emit_obj_from_module_default_impl(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirEmitObjFromRetainedModule(module_raw, target_raw, out_raw)

@exportc("uirEmitObjFromModuleOrPanic")
fn uirEmitObjFromModuleOrPanic(module_raw: ptr, optLevel: int32,
                               target_raw: cstring, objWriter_raw: cstring,
                               validateModule: int32,
                               uirSimdEnabled: int32, uirSimdMaxWidth: int32,
                               uirSimdPolicy_raw: cstring): uint8[] =
    return driverUirEmitObjBytesFromRetainedModule(module_raw, optLevel, target_raw, objWriter_raw,
                                                   validateModule, uirSimdEnabled, uirSimdMaxWidth,
                                                   uirSimdPolicy_raw)

@exportc("driver_build_emit_obj_from_file_stage1_target_impl")
fn driver_build_emit_obj_from_file_stage1_target_impl(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirBuildEmitObjFromFileStage1Target(path_raw, target_raw, out_raw)

@exportc("driver_export_build_emit_obj_from_file_stage1_target_impl")
fn driver_export_build_emit_obj_from_file_stage1_target_impl(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirBuildEmitObjFromFileStage1Target(path_raw, target_raw, out_raw)

@exportc("backendMain")
fn backendMain(): int32 =
    let _proofKeepalive: int32 = proofDriverExportsKeepalive()
    if driver_c_help_requested(0) != 0:
        return driver_c_backend_usage(0)
    return driver_c_run_default(0)

fn main(): int32 =
    return backendMain()
