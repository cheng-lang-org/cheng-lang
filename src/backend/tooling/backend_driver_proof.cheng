import backend/tooling/backend_driver_uir_shared

@importc("driver_c_backend_usage")
fn driver_c_backend_usage(_dummy: int32): int32

@importc("driver_c_help_requested")
fn driver_c_help_requested(_dummy: int32): int32

@importc("driver_c_run_default")
fn driver_c_run_default(_dummy: int32): int32

@exportc("driver_export_prefer_sidecar_builds")
fn driver_export_prefer_sidecar_builds(_dummy: int32): int32 =
    # Proof/bootstrap stage0 is a thin Cheng host wrapper. Force the C host to
    # use the exported direct-build entry below; that entry invokes the strict
    # published Cheng sidecar compiler contract explicitly.
    return 0

@exportc("driver_export_build_emit_obj_from_file_stage1_target_impl")
fn driver_export_build_emit_obj_from_file_stage1_target_impl(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirBuildEmitObjFromFileStage1Target(path_raw, target_raw, out_raw)

@exportc("backendMain")
fn backendMain(): int32 =
    if driver_c_help_requested(0) != 0:
        return driver_c_backend_usage(0)
    return driver_c_run_default(0)

fn main(): int32 =
    return backendMain()
