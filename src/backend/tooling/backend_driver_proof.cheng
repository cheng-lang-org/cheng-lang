import backend/tooling/backend_driver_uir_proof_direct_build

@importc("driver_c_backend_usage")
fn driver_c_backend_usage(_dummy: int32): int32

@importc("driver_c_help_requested")
fn driver_c_help_requested(_dummy: int32): int32

@importc("driver_c_run_default")
fn driver_c_run_default(_dummy: int32): int32

@exportc("driver_export_prefer_sidecar_builds")
fn driver_export_prefer_sidecar_builds(_dummy: int32): int32 =
    return 0

@exportc("driver_export_build_emit_obj_from_file_stage1_target_impl")
fn driver_export_build_emit_obj_from_file_stage1_target_impl(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    return driverProofBuildEmitObjFromFileStage1Target(path_raw, target_raw, out_raw)

fn proofDriverExportsKeepalive(): int32 =
    if false:
        let _proofRc: int32 = driver_export_build_emit_obj_from_file_stage1_target_impl(nil, nil, nil)
        let _preferSidecar: int32 = driver_export_prefer_sidecar_builds(0)
        return _proofRc + _preferSidecar + 1
    return 0

@exportc("backendMain")
fn backendMain(): int32 =
    let _proofKeepalive: int32 = proofDriverExportsKeepalive()
    if driver_c_help_requested(0) != 0:
        return driver_c_backend_usage(0) + (_proofKeepalive - _proofKeepalive)
    return driver_c_run_default(0) + (_proofKeepalive - _proofKeepalive)

fn main(): int32 =
    return backendMain()
