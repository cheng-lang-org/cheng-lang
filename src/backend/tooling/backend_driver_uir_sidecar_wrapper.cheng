import backend/tooling/backend_driver_uir_sidecar_direct_build

fn backendDriverUirSidecarWrapperKeepalive(): int32 =
    if false:
        let _mod0: ptr = driver_buildActiveModulePtrs(nil, nil)
        let _mod1: ptr = driver_export_buildActiveModulePtrs(nil, nil)
        let _rc0: int32 = driver_emit_obj_from_module_default_impl(nil, nil, nil)
        let _rc1: int32 = driver_export_emit_obj_from_module_default_impl(nil, nil, nil)
        if _mod0 != nil || _mod1 != nil || _rc0 == 0 || _rc1 == 0:
            return 1
    return 0

@exportc("driver_buildActiveModulePtrs")
fn driver_buildActiveModulePtrs(input_raw: cstring, target_raw: cstring): ptr =
    return driverSidecarBuildModuleStage1TargetRetained(input_raw, target_raw)

@exportc("driver_export_buildActiveModulePtrs")
fn driver_export_buildActiveModulePtrs(input_raw: cstring, target_raw: cstring): ptr =
    return driverSidecarBuildModuleStage1TargetRetained(input_raw, target_raw)

@exportc("driver_emit_obj_from_module_default_impl")
fn driver_emit_obj_from_module_default_impl(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    return driverSidecarEmitObjFromRetainedModule(module_raw, target_raw, out_raw)

@exportc("driver_export_emit_obj_from_module_default_impl")
fn driver_export_emit_obj_from_module_default_impl(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    return driverSidecarEmitObjFromRetainedModule(module_raw, target_raw, out_raw)

fn main(): int32 =
    let _keepalive: int32 = backendDriverUirSidecarWrapperKeepalive()
    return _keepalive - _keepalive
