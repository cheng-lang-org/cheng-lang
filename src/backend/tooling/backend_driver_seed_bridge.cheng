@exportc("backendMain")
fn backendMain(): int32 =
    let _keepalive: int32 = backendDriverSeedBridgeExportsKeepalive()
    if driver_c_help_requested(0) != 0:
        return driver_c_backend_usage(0) + (_keepalive - _keepalive)
    return driver_c_run_default(0) + (_keepalive - _keepalive)

fn main(): int32 =
    return backendMain()
