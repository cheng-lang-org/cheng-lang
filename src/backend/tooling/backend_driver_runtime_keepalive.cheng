type
    cstring = ptr

@importc("cheng_seq_string_register_compat")
fn backendDriverSeqStringRegisterCompat(seqPtr: ptr)

@importc("cheng_seq_string_buffer_register_compat")
fn backendDriverSeqStringBufferRegisterCompat(buffer: ptr)

@importc("cheng_str_bridge_load_into")
fn backendDriverStrBridgeLoadInto(outRaw: ptr, srcRaw: ptr)

@importc("cheng_str_param_to_cstring_compat")
fn backendDriverStrParamToCStringCompat(raw: str): cstring

@importc("cheng_cstrlen")
fn backendDriverCStringLen(raw: cstring): int32

@importc("cheng_strlen")
fn backendDriverStrLen(raw: cstring): int32

fn backendDriverRuntimeCompatKeepalive(): int32 =
    backendDriverSeqStringRegisterCompat(nil)
    backendDriverSeqStringBufferRegisterCompat(nil)
    backendDriverStrBridgeLoadInto(nil, nil)
    let text: cstring = backendDriverStrParamToCStringCompat("")
    if text == nil:
        return 0
    return 1 + backendDriverCStringLen(text) + backendDriverStrLen(text)

@exportc("backendDriverRuntimeCompatKeepaliveExport")
fn backendDriverRuntimeCompatKeepaliveExport(): int32 =
    return backendDriverRuntimeCompatKeepalive()
