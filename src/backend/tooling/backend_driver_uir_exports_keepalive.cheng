    let keepaliveRaw: cstring =
        backendDriverUirKeepaliveGetenv(strToCStringTemp("CHENG_DRIVER_EXPORT_KEEPALIVE"))
    if keepaliveRaw != nil:
        let _m0: ptr = driver_export_uirBuildModuleFromFileStage1TargetOrPanic(nil, nil)
        let _m1: ptr = driver_export_uirCoreBuildModuleFromFileStage1OrPanic(nil, nil)
        let _m2: ptr = driver_export_buildModuleFromFileStage1TargetRetained(nil, nil)
