import std/os
import std/system
import backend/tooling/backend_driver_uir_exports

fn backendDriverUirExportsKeepalive(): int32 =
    # Keep the stage1 module/export surface reachable from the thin-shell
    # driver so selfhost-built candidates do not dead-strip these entrypoints.
    if os.getEnvDefault("BACKEND_DRIVER_EXPORT_KEEPALIVE_PROBE", "") == "__probe__":
        let module0: void* = driver_export_uirBuildModuleFromFileStage1OrPanic(nil)
        let module1: void* = driver_export_uirBuildModuleFromFileStage1TargetOrPanic(nil, nil)
        let handle0: void* = driver_export_buildModuleFromFileStage1Retained(nil)
        let handle1: void* = driver_export_buildModuleFromFileStage1TargetRetained(nil, nil)
        let rc: int32 = driver_export_emit_obj_from_module_default_impl(nil, nil, nil)
        if module0 != nil:
            memRelease(module0)
        if module1 != nil:
            memRelease(module1)
        if handle0 != nil:
            memRelease(handle0)
        if handle1 != nil:
            memRelease(handle1)
        return rc
    return 0
