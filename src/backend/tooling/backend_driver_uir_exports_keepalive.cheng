import std/system
import backend/tooling/backend_driver_uir_exports

fn backendDriverUirExportsKeepalive(): int32 =
    # Keep the exported UIR builder/codegen wrappers reachable from the thin
    # shell driver so direct stage1/module build paths and sidecar bundle
    # flat-namespace lookups can resolve them from the host binary.
    let _m0: ptr = driver_export_uirBuildModuleFromFileStage1TargetOrPanic(nil, nil)
    let _m1: ptr = driver_export_uirCoreBuildModuleFromFileStage1OrPanic(nil, nil)
    let _m2: ptr = driver_export_buildModuleFromFileStage1TargetRetained(nil, nil)
    let _m3: ptr = driver_export_uirBuildModuleFromFileStage1OrPanic(nil)
    let _m4: ptr = driver_export_buildActiveModulePtrs(nil, nil)
    let _m5: ptr = driver_export_buildModuleFromFileStage1Retained(nil)
    let _rc0: int32 = driver_export_emit_obj_from_module_default_impl(nil, nil, nil)
    let _obj0: uint8[] = driver_export_uirEmitObjFromModuleOrPanic(nil, 0, nil, nil, 0, 0, 0, nil)
    let _rc1: int32 = driver_export_build_emit_obj_from_file_stage1_target_impl(nil, nil, nil)
    return _rc0 + _rc1 + len(_obj0) + int32(uint64(_m0)) + int32(uint64(_m1)) +
           int32(uint64(_m2)) + int32(uint64(_m3)) + int32(uint64(_m4)) + int32(uint64(_m5))

@exportc("backendDriverUirExportsKeepaliveExport")
fn backendDriverUirExportsKeepaliveExport(): int32 =
    return backendDriverUirExportsKeepalive()
