import backend/tooling/backend_driver_uir_shared

@exportc("uirBuildModuleFromFileStage1TargetOrPanic")
fn driver_export_uirBuildModuleFromFileStage1TargetOrPanic(path_raw: cstring, target_raw: cstring): ptr =
    driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("driver_buildModuleFromFileStage1TargetRetained")
fn driver_export_buildModuleFromFileStage1TargetRetained(path_raw: cstring, target_raw: cstring): ptr =
    driverUirBuildModuleStage1TargetRetained(path_raw, target_raw)

@exportc("uirBuildModuleFromFileStage1OrPanic")
fn driver_export_uirBuildModuleFromFileStage1OrPanic(path_raw: cstring): ptr =
    driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_buildModuleFromFileStage1Retained")
fn driver_export_buildModuleFromFileStage1Retained(path_raw: cstring): ptr =
    driverUirBuildModuleStage1Retained(path_raw)

@exportc("driver_emit_obj_from_module_default_impl")
fn driver_export_emit_obj_from_module_default_impl(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirEmitObjFromRetainedModule(module_raw, target_raw, out_raw)

@exportc("driver_build_emit_obj_from_file_stage1_target_impl")
fn driver_export_build_emit_obj_from_file_stage1_target_impl(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirBuildEmitObjFromFileStage1Target(path_raw, target_raw, out_raw)
