fn driver_activeLinkerSymtabAll(): bool =
    return driver_parseLinkerSymtabAll(driver_envDefault("BACKEND_LINKER_SYMTAB", ""))

fn driver_buildActiveModule(inputPath: str, target: str): UirModule =
    driver_bootMark(21)
    let stableInput: str = driver_trimAsciiSpace(inputPath)
    let stableTarget: str = driver_trimAsciiSpace(target)
    driver_debugInputTrace("build_input", stableInput)
    if len(stableInput) == 0:
        driver_panic("backend_driver: BACKEND_INPUT required")
    return uir_builder.uirBuildModuleFromFileStage1TargetOrPanic(stableInput, stableTarget)

fn driver_buildActiveModuleNative(): UirModule =
    return driver_buildActiveModule(driver_activeInputPath(), driver_activeTarget())

fn driver_buildActiveModulePtrs(inputRaw: void*, targetRaw: void*): void* =
    return void*(driver_buildActiveModule(driver_copy_cstring_owned(inputRaw),
                                          driver_copy_cstring_owned(targetRaw)))

fn driver_debugBuildModuleDumpPtrs(inputRaw: void*, targetRaw: void*): int32 =
    let inputPath: str = driver_copy_cstring_owned(inputRaw)
    let target: str = driver_copy_cstring_owned(targetRaw)
    let module: UirModule = driver_buildActiveModule(inputPath, target)
    driver_writeErrLine(uirCoreFormat(module))
    return 0

fn driver_debugBuildModuleDumpToFilePtrs(inputRaw: void*, targetRaw: void*, outRaw: void*): int32 =
    let inputPath: str = driver_copy_cstring_owned(inputRaw)
    let target: str = driver_copy_cstring_owned(targetRaw)
    let outPath: str = driver_copy_cstring_owned(outRaw)
    let module: UirModule = driver_buildActiveModule(inputPath, target)
    os.writeFile(outPath, uirCoreFormat(module))
    return 0

fn driver_debugFindFuncByName(module: UirModule, funcName: str): UirFunc =
    if void*(module) == nil:
        return nil
    for i in 0..<uir_types.uirModuleFuncsLen(module):
        let f: UirFunc = uir_types.uirModuleFuncAt(module, i)
        if void*(f) == nil:
            continue
        if driver_strEq(uir_types.uirFuncNameOf(f), funcName) || driver_strEq(uir_types.uirFuncLinkNameOf(f), funcName):
            return f
    return nil

fn driver_debugFuncBlockCountPtrs(inputRaw: void*, targetRaw: void*, funcRaw: void*): int32 =
    let inputPath: str = driver_copy_cstring_owned(inputRaw)
    let target: str = driver_copy_cstring_owned(targetRaw)
    let funcName: str = driver_copy_cstring_owned(funcRaw)
    let module: UirModule = driver_buildActiveModule(inputPath, target)
    let f: UirFunc = driver_debugFindFuncByName(module, funcName)
    if void*(f) == nil:
        return -1
    return uir_types.uirFuncBlocksLen(f)

fn driver_debugFuncBlockStmtCountPtrs(inputRaw: void*, targetRaw: void*, funcRaw: void*, blockIndex: int32): int32 =
    let inputPath: str = driver_copy_cstring_owned(inputRaw)
    let target: str = driver_copy_cstring_owned(targetRaw)
    let funcName: str = driver_copy_cstring_owned(funcRaw)
    let module: UirModule = driver_buildActiveModule(inputPath, target)
    let f: UirFunc = driver_debugFindFuncByName(module, funcName)
    if void*(f) == nil:
        return -1
    if blockIndex < 0 || blockIndex >= uir_types.uirFuncBlocksLen(f):
        return -2
    let blk: UirLowerBlock = uir_types.uirFuncBlockAt(f, blockIndex)
    return uir_types.uirBlockStmtsLen(blk)

fn driver_debugFuncBlockTermKindPtrs(inputRaw: void*, targetRaw: void*, funcRaw: void*, blockIndex: int32): int32 =
    let inputPath: str = driver_copy_cstring_owned(inputRaw)
    let target: str = driver_copy_cstring_owned(targetRaw)
    let funcName: str = driver_copy_cstring_owned(funcRaw)
    let module: UirModule = driver_buildActiveModule(inputPath, target)
    let f: UirFunc = driver_debugFindFuncByName(module, funcName)
    if void*(f) == nil:
        return -1
    if blockIndex < 0 || blockIndex >= uir_types.uirFuncBlocksLen(f):
        return -2
    let blk: UirLowerBlock = uir_types.uirFuncBlockAt(f, blockIndex)
    return int32(uir_types.uirTermKindOf(uir_types.uirBlockTermOf(blk)))

fn driver_debugModuleFuncBlockCountByIndexPtrs(inputRaw: void*, targetRaw: void*, funcIndex: int32): int32 =
    let inputPath: str = driver_copy_cstring_owned(inputRaw)
    let target: str = driver_copy_cstring_owned(targetRaw)
    let module: UirModule = driver_buildActiveModule(inputPath, target)
    if void*(module) == nil:
