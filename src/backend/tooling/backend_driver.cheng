# Backend MVP driver: build MIR -> LIR -> relocatable obj (AArch64/x86_64 subset).
import std/[system, cmdline, seqs, strings, os, result, hashmaps, monotimes, bytes]
import cheng/[stage1/frontend_lib,
              backend/mir/mir_types, backend/mir/mir_builder, backend/mir/mir_opt,
              backend/isel/aarch64_isel, backend/isel/riscv64_isel, backend/isel/x86_64_isel,
              backend/regalloc/linear_scan,
              backend/obj/elf_writer, backend/obj/elf_writer_riscv64, backend/obj/elf_writer_x86_64,
              backend/obj/macho_writer, backend/obj/macho_writer_x86_64,
              backend/obj/coff_writer, backend/obj/coff_writer_x86_64,
              backend/obj/macho_linker, backend/obj/macho_linker_x86_64,
              backend/obj/elf_linker, backend/obj/elf_linker_riscv64,
              backend/obj/coff_linker]

@importc("fork")
fn driver_c_fork(): int64
@importc("waitpid")
fn driver_c_waitpid(pid: int64, status: int32*, options: int32): int64

fn driver_strHasPrefix(s: str, prefix: str): bool =
    if s == nil || prefix == nil:
        return false
    let n: int32 = len s
    let m: int32 = len prefix
    if m == 0:
        return true
    if n < m:
        return false
    for i in 0..<m:
        if s[i] != prefix[i]:
            return false
    return true

fn driver_strHasSuffix(s: str, suffix: str): bool =
    if s == nil || suffix == nil:
        return false
    let n: int32 = len s
    let m: int32 = len suffix
    if m == 0:
        return true
    if n < m:
        return false
    for i in 0..<m:
        if s[n - m + i] != suffix[i]:
            return false
    return true

fn driver_strContains(hay: str, needle: str): bool =
    if hay == nil || needle == nil:
        return false
    let n: int32 = len hay
    let m: int32 = len needle
    if m == 0:
        return true
    if m > n:
        return false
    for i in 0..n - m:
        for j in 0..<m:
            if !(hay[i + j] == needle[j]):
                break
        if j == m:
            return true
    return false

fn driver_isSpaceChar(c: char): bool =
    return c == ' ' || c == '\t' || c == '\n' || c == '\r'

fn driver_strIsEmpty(s: str): bool =
    if s == nil:
        return true
    return s[0] == char(0)

fn driver_strNonEmpty(s: str): bool =
    return !driver_strIsEmpty(s)

fn driver_strSliceEq(s: str, start: int32, endExclusive: int32, needle: str): bool =
    if s == nil || needle == nil:
        return false
    if start < 0 || endExclusive < start:
        return false
    let n: int32 = endExclusive - start
    if n != len needle:
        return false
    for i in 0..<n:
        if s[start + i] != needle[i]:
            return false
    return true

fn driver_flagsHasToken(flags: str, token: str): bool =
    if flags == nil || token == nil:
        return false
    let n: int32 = len flags
    var i: int32 = 0
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        for __for_guard_i_ws in 0..<n:
            if !(i < n && driver_isSpaceChar(flags[i])):
                break
            i = i + 1
        if i >= n:
            break
        for j in i..<n:
            if !(! driver_isSpaceChar(flags[j])):
                break
        if driver_strSliceEq(flags, i, j, token):
            return true
        i = j
    return false

fn driver_flagsAppendToken(flags: str, token: str): str =
    if driver_strIsEmpty(token):
        return flags
    if driver_flagsHasToken(flags, token):
        return flags
    if driver_strIsEmpty(flags):
        return token
    return flags + " " + token

fn driver_strStripPrefix(s: str, prefix: str): str =
    if ! driver_strHasPrefix(s, prefix):
        return ""
    let off: int32 = len prefix
    return str(ptr_add(void*(s), off))

fn driver_joinDir(dir: str, name: str): str =
    var dirLocal: str = dir
    var nameLocal: str = name
    if dirLocal == nil || len(dirLocal) == 0:
        if nameLocal == nil || len(nameLocal) == 0:
            return ""
        return "" + nameLocal
    return dirLocal + "/" + nameLocal

fn driver_shellQuote(s: str): str =
    if s == nil:
        return "\"\""
    return "\"" + s + "\""

fn driver_runCmd(command: str) =
    let opts: uint64 = os.processOptionMask(os.poStdErrToStdOut) |
                       os.processOptionMask(os.poUsePath) |
                       os.processOptionMask(os.poEvalCommand)
    let res: os.ExecCmdResult = os.execCmdEx(command, opts, "")
    if res.exitCode != 0:
        panic("" + res.output)

fn driver_panicResult(res: Result[T]) =
    let msg: str = ErrorFormat(ErrorInfoOf[T](res))
    panic(msg)

fn driver_parseInt32Default(s: str, defaultValue: int32): int32 =
    if driver_strIsEmpty(s):
        return defaultValue
    let sLen: int32 = len s
    var neg: bool = false
    var i: int32 = 0
    if s[0] == '-':
        neg = true
        i = 1
    if i >= sLen:
        return defaultValue
    var v: int64 = 0
    for __for_guard_i in 0..<sLen:
        if !(i < sLen):
            break
        let c: char = s[i]
        if c < '0' || c > '9':
            return defaultValue
        v = v * 10 + int64(int32(c) - int32('0'))
        i = i + 1
    if neg:
        v = 0 - v
    return int32(v)

fn driver_parseBoolDefault(raw: str, defaultValue: bool): bool =
    let s: str = lowerAscii(driver_trimAsciiSpace(raw))
    if driver_strIsEmpty(s):
        return defaultValue
    if driver_strEq(s, "1"):
        return true
    if driver_strEq(s, "true"):
        return true
    if driver_strEq(s, "yes"):
        return true
    if driver_strEq(s, "on"):
        return true
    if driver_strEq(s, "0"):
        return false
    if driver_strEq(s, "false"):
        return false
    if driver_strEq(s, "no"):
        return false
    if driver_strEq(s, "off"):
        return false
    return defaultValue

fn driver_parseLinkerSymtabAll(raw: str): bool =
    let s: str = lowerAscii(driver_trimAsciiSpace(raw))
    if driver_strIsEmpty(s):
        return false
    if driver_strEq(s, "0"):
        return false
    if driver_strEq(s, "minimal"):
        return false
    if driver_strEq(s, "min"):
        return false
    if driver_strEq(s, "1"):
        return true
    if driver_strEq(s, "all"):
        return true
    if driver_strEq(s, "full"):
        return true
    panic("backend_driver: invalid CHENG_BACKEND_LINKER_SYMTAB (expected minimal|all): " + raw)

fn driver_envBoolDefault(name: str, defaultValue: bool): bool =
    return driver_parseBoolDefault(os.getEnvDefault(name, ""), defaultValue)

fn driver_envIsTrue(name: str): bool =
    return driver_envBoolDefault(name, false)

fn driver_strEq(a: str, b: str): bool =
    if a == nil && b == nil:
        return true
    if a == nil || b == nil:
        return false
    let na: int32 = len(a)
    let nb: int32 = len(b)
    if na != nb:
        return false
    for i in 0..<na:
        if a[i] != b[i]:
            return false
    return true

fn driver_allocByteReader(buf: bytes.ByteBuffer): bytes.ByteReader* =
    # Bootstrap note: some seed compilers fail to resolve `sizeof Mod.Type`.
    var tmp: bytes.ByteReader
    let sizeBytes: int32 = int32(sizeof tmp)
    let p: void* = alloc sizeBytes
    zeroMem(p, int(sizeBytes))
    let r: bytes.ByteReader* = bytes.ByteReader*(p)
    r->buf = buf
    r->pos = 0
    return r

type
    DriverProfileState =
        startNs: int64
        lastNs: int64
        enabled: bool

fn driver_profileInit(enabled: bool): DriverProfileState =
    var st: DriverProfileState
    st.enabled = enabled
    let mt0: monotimes.MonoTime = monotimes.getMonoTime()
    let nowNs: int64 = mt0.ns
    st.startNs = nowNs
    st.lastNs = nowNs
    return st

fn driver_profileStep(st: var DriverProfileState, label: str) =
    if ! st.enabled:
        return
    let mt1: monotimes.MonoTime = monotimes.getMonoTime()
    let nowNs: int64 = mt1.ns
    let stepMs: int64 = (nowNs - st.lastNs) / 1000000
    let totalMs: int64 = (nowNs - st.startNs) / 1000000
    st.lastNs = nowNs
    let stepText: str = frontend_lib.stage1_int64ToStr(stepMs)
    let totalText: str = frontend_lib.stage1_int64ToStr(totalMs)
    let f: os.File = os.get_stderr()
    os.write(f, "backend_profile\t")
    os.write(f, label)
    os.write(f, "\tstep_ms=")
    os.write(f, stepText)
    os.write(f, "\ttotal_ms=")
    os.writeLine(f, totalText)
    os.c_fflush f

fn driver_trimAsciiSpace(s: str): str =
    if driver_strIsEmpty(s):
        return ""
    let n: int32 = len s
    for start in 0..<n:
        if !(driver_isSpaceChar(s[start])):
            break
    var stop: int32 = n
    let __for_start_stop = stop
    for __for_rev_stop in 0..<(__for_start_stop - (start)):
        stop = __for_start_stop - __for_rev_stop
        if !(driver_isSpaceChar(s[stop - 1])):
            break
    if stop <= start:
        return ""
    if start == 0 && stop == n:
        return s
    return os.sliceStr(s, start, stop - 1)

fn driver_execCmdTrimmed(command: str): str =
    let opts: uint64 = os.processOptionMask(os.poStdErrToStdOut) |
                       os.processOptionMask(os.poUsePath) |
                       os.processOptionMask(os.poEvalCommand)
    let res: os.ExecCmdResult = os.execCmdEx(command, opts, "")
    if res.exitCode != 0:
        return ""
    return driver_trimAsciiSpace(res.output)

fn driver_detectHostTargetAuto(): str =
    let hostOs: str = driver_execCmdTrimmed("uname -s")
    let hostArch: str = driver_execCmdTrimmed("uname -m")
    if driver_strEq(hostOs, "Darwin"):
        if driver_strEq(hostArch, "arm64") || driver_strEq(hostArch, "aarch64"):
            return "arm64-apple-darwin"
        if driver_strEq(hostArch, "x86_64") || driver_strEq(hostArch, "amd64"):
            return "x86_64-apple-darwin"
        return ""
    if driver_strEq(hostOs, "Linux"):
        if driver_strEq(hostArch, "arm64") || driver_strEq(hostArch, "aarch64"):
            return "aarch64-unknown-linux-gnu"
        if driver_strEq(hostArch, "riscv64"):
            return "riscv64-unknown-linux-gnu"
        if driver_strEq(hostArch, "x86_64") || driver_strEq(hostArch, "amd64"):
            return "x86_64-unknown-linux-gnu"
        return ""
    if driver_strHasPrefix(hostOs, "MINGW") || driver_strHasPrefix(hostOs, "MSYS") || driver_strHasPrefix(hostOs, "CYGWIN"):
        if driver_strEq(hostArch, "arm64") || driver_strEq(hostArch, "aarch64"):
            return "aarch64-pc-windows-msvc"
        if driver_strEq(hostArch, "x86_64") || driver_strEq(hostArch, "amd64"):
            return "x86_64-pc-windows-msvc"
        return ""
    return ""

fn driver_detectHostJobsAuto(): int32 =
    var jobs: int32 = driver_parseInt32Default(driver_execCmdTrimmed("getconf _NPROCESSORS_ONLN 2>/dev/null"), 0)
    if jobs <= 0:
        jobs = driver_parseInt32Default(driver_execCmdTrimmed("nproc 2>/dev/null"), 0)
    if jobs <= 0:
        jobs = driver_parseInt32Default(driver_execCmdTrimmed("sysctl -n hw.logicalcpu 2>/dev/null"), 0)
    if jobs <= 0:
        jobs = driver_parseInt32Default(driver_execCmdTrimmed("sysctl -n hw.ncpu 2>/dev/null"), 0)
    if jobs <= 0:
        jobs = 4
    return jobs

fn driver_bool01(v: bool): str =
    return v ? "1" : "0"

fn driver_isPathLikeExe(s: str): bool =
    if driver_strIsEmpty(s):
        return false
    return driver_strContains(s, "/") || driver_strContains(s, "\\")

fn driver_resolveSelfExeForParallel(raw: str): str =
    var rawLocal: str = raw
    if rawLocal == nil || len(rawLocal) == 0:
        return ""
    if driver_isPathLikeExe(rawLocal):
        let abs: str = os.absolutePath(rawLocal)
        if frontend_lib.stage1_fileExists(abs):
            return abs
        if frontend_lib.stage1_fileExists(rawLocal):
            return rawLocal
        return ""
    return rawLocal

fn driver_fileStateStamp(path: str): str =
    if driver_strIsEmpty(path):
        return "file=<empty>\n"
    if driver_strEq(path, "<shared>"):
        return "shared_unit=" + path + "\n"
    if ! frontend_lib.stage1_fileExists(path):
        return "missing=" + path + "\n"
    let mtime: int64 = os.fileMtime(path)
    let size: int64 = os.fileSize(path)
    return "file=" + path +
           "\tmtime=" + frontend_lib.stage1_int64ToStr(mtime) +
           "\tsize=" + frontend_lib.stage1_int64ToStr(size) + "\n"

fn driver_buildModuleSourcesStamp(unitFiles: str[]): str =
    var out: str = ""
    for i in 0..<unitFiles.len:
        out = out + driver_fileStateStamp(unitFiles[i])
    return out

fn driver_hashCombine64(seed: int64, value: int64): int64 =
    let h: uint64 = uint64(seed) * uint64(1099511628211)
    return int64(h ^ uint64(value))

fn driver_buildUnitFileStateHashes(unitFiles: str[]): int64[] =
    var out: int64[]
    for i in 0..<unitFiles.len:
        let stamp: str = driver_fileStateStamp(unitFiles[i])
        add(out, mirFnv1a64(stamp))
    return out

fn driver_selfCompilerStamp(): str =
    let overrideId: str = os.getEnvDefault("CHENG_BACKEND_COMPILER_ID", "")
    if driver_strNonEmpty(overrideId):
        return "compiler_id=" + overrideId + "\n"
    let raw: str = os.getEnvDefault("CHENG_BACKEND_SELF_EXE", "")
    let resolved: str = driver_resolveSelfExeForParallel(raw)
    if driver_strNonEmpty(resolved) && frontend_lib.stage1_fileExists(resolved):
        return "compiler=" + resolved +
               "\tmtime=" + frontend_lib.stage1_int64ToStr(os.fileMtime(resolved)) +
               "\tsize=" + frontend_lib.stage1_int64ToStr(os.fileSize(resolved)) + "\n"
    if driver_strNonEmpty(raw):
        return "compiler=" + raw + "\n"
    return "compiler=<unknown>\n"

fn driver_buildObjCompileStamp(target: str, frontend: str, objWriter: str, inputPath: str,
                               allowNoMain: bool, wholeProgram: bool,
                               skipGlobalInit: bool, multiLto: bool, abi: str, compilerStamp: str): str =
    let opt2Raw: str = os.getEnvDefault("CHENG_BACKEND_OPT2", "")
    let optRaw: str = os.getEnvDefault("CHENG_BACKEND_OPT", "")
    let optLevelRaw: str = os.getEnvDefault("CHENG_BACKEND_OPT_LEVEL", "")
    let ssaRaw: str = os.getEnvDefault("CHENG_BACKEND_SSA", "")
    let validateRaw: str = os.getEnvDefault("CHENG_BACKEND_VALIDATE", "")
    let intBitsRaw: str = os.getEnvDefault("CHENG_INTBITS", "")
    let mmRaw: str = os.getEnvDefault("CHENG_MM", "")
    let mmStrictRaw: str = os.getEnvDefault("CHENG_MM_STRICT", "")
    let noRealRaw: str = os.getEnvDefault("CHENG_BACKEND_NO_REAL", "")
    let stdNoPtrRaw: str = os.getEnvDefault("CHENG_STAGE1_STD_NO_POINTERS", "")
    let stdNoPtrStrictRaw: str = os.getEnvDefault("CHENG_STAGE1_STD_NO_POINTERS_STRICT", "")
    return "target=" + target + "\n" +
           "frontend=" + frontend + "\n" +
           "obj_writer=" + objWriter + "\n" +
           "input=" + inputPath + "\n" +
           "allow_no_main=" + driver_bool01(allowNoMain) + "\n" +
           "whole_program=" + driver_bool01(wholeProgram) + "\n" +
           "skip_global_init=" + driver_bool01(skipGlobalInit) + "\n" +
           "multi_lto=" + driver_bool01(multiLto) + "\n" +
           "abi=" + abi + "\n" +
           "opt2=" + opt2Raw + "\n" +
           "opt=" + optRaw + "\n" +
           "opt_level=" + optLevelRaw + "\n" +
           "ssa=" + ssaRaw + "\n" +
           "validate=" + validateRaw + "\n" +
           "intbits=" + intBitsRaw + "\n" +
           "mm=" + mmRaw + "\n" +
           "mm_strict=" + mmStrictRaw + "\n" +
           "std_no_pointers=" + stdNoPtrRaw + "\n" +
           "std_no_pointers_strict=" + stdNoPtrStrictRaw + "\n" +
           "no_real=" + noRealRaw + "\n" +
           compilerStamp

fn driver_buildLinkStamp(target: str, linker: str, linkerSymtabAll: bool, ldCmd: str, cflags: str, ldflags: str,
                         runtimeObj: str, runtimeC: str, noRuntimeC: bool): str =
    var out: str = ""
    out = out + "target=" + target + "\n"
    out = out + "linker=" + linker + "\n"
    out = out + "linker_symtab_all=" + driver_bool01(linkerSymtabAll) + "\n"
    out = out + "ld=" + ldCmd + "\n"
    out = out + "cflags=" + cflags + "\n"
    out = out + "ldflags=" + ldflags + "\n"
    out = out + "no_runtime_c=" + driver_bool01(noRuntimeC) + "\n"
    out = out + driver_fileStateStamp(runtimeObj)
    if !noRuntimeC:
        out = out + driver_fileStateStamp(runtimeC)
    return out

type
    DriverSeqInt32 = int32[]
    DriverSeqSeqInt32 = DriverSeqInt32[]
    DriverSeqU64 = uint64[]
    DriverSeqSeqU64 = DriverSeqU64[]

fn driver_addRowInt32(rows: var DriverSeqSeqInt32, row: int32[]) =
    add(rows, row)

fn driver_addRowU64(rows: var DriverSeqSeqU64, row: uint64[]) =
    add(rows, row)

fn driver_getRowInt32(rows: DriverSeqSeqInt32, i: int32): int32[] =
    let slot: int32[]* = int32[]*(ptr_add(rows.buffer, i * sizeof int32[]))
    return *slot

fn driver_setRowInt32(rows: var DriverSeqSeqInt32, i: int32, row: int32[]) =
    let slot: int32[]* = int32[]*(ptr_add(rows.buffer, i * sizeof int32[]))
    *slot = row

fn driver_getRowU64(rows: DriverSeqSeqU64, i: int32): uint64[] =
    let slot: uint64[]* = uint64[]*(ptr_add(rows.buffer, i * sizeof uint64[]))
    return *slot

fn driver_setRowU64(rows: var DriverSeqSeqU64, i: int32, row: uint64[]) =
    let slot: uint64[]* = uint64[]*(ptr_add(rows.buffer, i * sizeof uint64[]))
    *slot = row

fn driver_newSeq2DInt(n: int32): DriverSeqSeqInt32 =
    var out: DriverSeqSeqInt32
    var empty: int32[]
    for i in 0..<n:
        driver_addRowInt32(out, empty)
    return out

fn driver_newSeq2DU64(rows: int32, words: int32): DriverSeqSeqU64 =
    var out: DriverSeqSeqU64
    for i in 0..<rows:
        var row: uint64[words]
        row.len = words
        driver_addRowU64(out, row)
    return out

fn driver_setDepBit(depBits: DriverSeqSeqU64*, fromIdx: int32, toIdx: int32): bool =
    if depBits == nil || fromIdx < 0 || toIdx < 0:
        return false
    if fromIdx >= depBits->len:
        return false
    var row: uint64[] = driver_getRowU64(*depBits, fromIdx)
    let wordIdx: int32 = toIdx / 64
    if wordIdx < 0 || wordIdx >= row.len:
        return false
    let bit: int32 = toIdx % 64
    let mask: uint64 = uint64(1) << uint64(bit)
    let cur: uint64 = row[wordIdx]
    if (cur & mask) != uint64(0):
        return false
    row[wordIdx] = cur | mask
    driver_setRowU64(*depBits, fromIdx, row)
    return true

fn driver_collectExprUnitDeps(expr: MirExpr, ownerUnit: int32, depBits: DriverSeqSeqU64*,
                              fnOwners: hashmaps.HashMapStrInt,
                              globalOwners: hashmaps.HashMapStrInt) =
    if expr == nil:
        return
    if expr.kind == meCall:
        if driver_strNonEmpty(expr.callee):
            var foundFn: bool = false
            let depFn: int32 = hashmaps.hashMapStrIntGetEx(fnOwners, expr.callee, foundFn)
            if foundFn && depFn >= 0 && depFn != ownerUnit:
                driver_setDepBit(depBits, ownerUnit, depFn)
        for ai in 0..<expr.args.len:
            driver_collectExprUnitDeps(expr.args[ai], ownerUnit, depBits, fnOwners, globalOwners)
        return
    if expr.kind == meGlobalAddr:
        if driver_strNonEmpty(expr.globalName):
            var foundGlobal: bool = false
            let depGlobal: int32 = hashmaps.hashMapStrIntGetEx(globalOwners, expr.globalName, foundGlobal)
            if foundGlobal && depGlobal >= 0 && depGlobal != ownerUnit:
                driver_setDepBit(depBits, ownerUnit, depGlobal)
        return
    if expr.kind == meBin || expr.kind == meCmp:
        driver_collectExprUnitDeps(expr.lhs, ownerUnit, depBits, fnOwners, globalOwners)
        driver_collectExprUnitDeps(expr.rhs, ownerUnit, depBits, fnOwners, globalOwners)
        return
    if expr.kind == meCast:
        driver_collectExprUnitDeps(expr.castExpr, ownerUnit, depBits, fnOwners, globalOwners)
        return
    if expr.kind == meAddr || expr.kind == meLoad:
        driver_collectExprUnitDeps(expr.addrExpr, ownerUnit, depBits, fnOwners, globalOwners)
        return

fn driver_collectFuncUnitDeps(f: MirFunc, ownerUnit: int32, depBits: DriverSeqSeqU64*,
                              fnOwners: hashmaps.HashMapStrInt,
                              globalOwners: hashmaps.HashMapStrInt) =
    if f == nil:
        return
    for bi in 0..<f.blocks.len:
        let block: MirBlock = f.blocks[bi]
        if block != nil:
            for si in 0..<block.stmts.len:
                let st: MirStmt = block.stmts[si]
                driver_collectExprUnitDeps(st.expr, ownerUnit, depBits, fnOwners, globalOwners)
                driver_collectExprUnitDeps(st.addrExpr, ownerUnit, depBits, fnOwners, globalOwners)
            driver_collectExprUnitDeps(block.term.retExpr, ownerUnit, depBits, fnOwners, globalOwners)
            driver_collectExprUnitDeps(block.term.condExpr, ownerUnit, depBits, fnOwners, globalOwners)

fn driver_callNameSetAdd(names: var hashmaps.HashMapStrInt, callee: str) =
    if driver_strIsEmpty(callee):
        return
    var snap: hashmaps.HashMapStrInt
    snap.keys = names.keys
    snap.vals = names.vals
    snap.states = names.states
    snap.mask = names.mask
    snap.used = names.used
    if snap[callee] != 0:
        return
    hashmaps.hashMapStrIntPut(names, callee, 1)

fn driver_collectExprCallNames(expr: MirExpr, names: var hashmaps.HashMapStrInt) =
    if expr == nil:
        return
    if expr.kind == meCall:
        driver_callNameSetAdd(names, expr.callee)
        for ai in 0..<expr.args.len:
            driver_collectExprCallNames(expr.args[ai], names)
        return
    if expr.kind == meBin || expr.kind == meCmp:
        driver_collectExprCallNames(expr.lhs, names)
        driver_collectExprCallNames(expr.rhs, names)
        return
    if expr.kind == meCast:
        driver_collectExprCallNames(expr.castExpr, names)
        return
    if expr.kind == meAddr || expr.kind == meLoad:
        driver_collectExprCallNames(expr.addrExpr, names)
        return

fn driver_collectFuncCallNames(f: MirFunc, names: var hashmaps.HashMapStrInt) =
    if f == nil:
        return
    for bi in 0..<f.blocks.len:
        let block: MirBlock = f.blocks[bi]
        if block != nil:
            for si in 0..<block.stmts.len:
                let st: MirStmt = block.stmts[si]
                driver_collectExprCallNames(st.expr, names)
                driver_collectExprCallNames(st.addrExpr, names)
            driver_collectExprCallNames(block.term.retExpr, names)
            driver_collectExprCallNames(block.term.condExpr, names)

fn driver_collectExprGlobalNames(expr: MirExpr, names: var hashmaps.HashMapStrInt) =
    if expr == nil:
        return
    if expr.kind == meGlobalAddr:
        driver_callNameSetAdd(names, expr.globalName)
        return
    if expr.kind == meCall:
        for ai in 0..<expr.args.len:
            driver_collectExprGlobalNames(expr.args[ai], names)
        return
    if expr.kind == meBin || expr.kind == meCmp:
        driver_collectExprGlobalNames(expr.lhs, names)
        driver_collectExprGlobalNames(expr.rhs, names)
        return
    if expr.kind == meCast:
        driver_collectExprGlobalNames(expr.castExpr, names)
        return
    if expr.kind == meAddr || expr.kind == meLoad:
        driver_collectExprGlobalNames(expr.addrExpr, names)
        return

fn driver_collectFuncGlobalNames(f: MirFunc, names: var hashmaps.HashMapStrInt) =
    if f == nil:
        return
    for bi in 0..<f.blocks.len:
        let block: MirBlock = f.blocks[bi]
        if block != nil:
            for si in 0..<block.stmts.len:
                let st: MirStmt = block.stmts[si]
                driver_collectExprGlobalNames(st.expr, names)
                driver_collectExprGlobalNames(st.addrExpr, names)
            driver_collectExprGlobalNames(block.term.retExpr, names)
            driver_collectExprGlobalNames(block.term.condExpr, names)

fn driver_buildUnitDependencyGraph(module: MirModule, unitFiles: str[]): DriverSeqSeqInt32 =
    let n: int32 = unitFiles.len
    var deps: DriverSeqSeqInt32 = driver_newSeq2DInt(n)
    if module == nil || n == 0:
        return deps
    let words: int32 =(n + 63) / 64
    var depBits: DriverSeqSeqU64 = driver_newSeq2DU64(n, words)
    var unitIndex: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(n * 2 + 8)
    for unitIdx in 0..<n:
        hashmaps.hashMapStrIntPut(unitIndex, unitFiles[unitIdx], unitIdx)

    var fnOwners: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(module.funcs.len * 2 + 8)
    for i in 0..<module.funcs.len:
        let f: MirFunc = module.funcs[i]
        if f != nil && ! f.isExtern && driver_strNonEmpty(f.name):
            let ownerKey: str = driver_unitOwnerKey(f.originFile)
            var foundOwner: bool = false
            let ownerIdx: int32 = hashmaps.hashMapStrIntGetEx(unitIndex, ownerKey, foundOwner)
            if foundOwner:
                var exists: bool = false
                let _seenFnOwner: int32 = hashmaps.hashMapStrIntGetEx(fnOwners, f.name, exists)
                if ! exists:
                    hashmaps.hashMapStrIntPut(fnOwners, f.name, ownerIdx)

    var globalOwners: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(module.globals.len * 2 + 8)
    for i in 0..<module.globals.len:
        let g: MirGlobal = module.globals[i]
        if driver_strNonEmpty(g.name):
            let ownerKey2: str = driver_unitOwnerKey(g.originFile)
            var foundOwner2: bool = false
            let ownerIdx2: int32 = hashmaps.hashMapStrIntGetEx(unitIndex, ownerKey2, foundOwner2)
            if foundOwner2:
                var exists2: bool = false
                let _seenGlobalOwner: int32 = hashmaps.hashMapStrIntGetEx(globalOwners, g.name, exists2)
                if ! exists2:
                    hashmaps.hashMapStrIntPut(globalOwners, g.name, ownerIdx2)

    for i in 0..<module.funcs.len:
        let f2: MirFunc = module.funcs[i]
        if f2 != nil && ! f2.isExtern:
            let ownerKey3: str = driver_unitOwnerKey(f2.originFile)
            var foundOwner3: bool = false
            let ownerIdx3: int32 = hashmaps.hashMapStrIntGetEx(unitIndex, ownerKey3, foundOwner3)
            if foundOwner3:
                driver_collectFuncUnitDeps(f2, ownerIdx3, &depBits, fnOwners, globalOwners)
    for ui in 0..<n:
        var rowOut: int32[]
        let rowBits: uint64[] = driver_getRowU64(depBits, ui)
        for wi in 0..<rowBits.len:
            let word: uint64 = rowBits[wi]
            if word != uint64(0):
                for bi in 0..<64:
                    let idx: int32 = wi * 64 + bi
                    if idx >= n:
                        break
                    let mask: uint64 = uint64(1) << uint64(bi)
                    if (word & mask) != uint64(0):
                        add(rowOut, idx)
        driver_setRowInt32(deps, ui, rowOut)
    return deps

fn driver_buildUnitListStamp(unitFiles: str[]): str =
    var out: str = ""
    for i in 0..<unitFiles.len:
        out = out + unitFiles[i] + "\n"
    return out

fn driver_fnv1a64Update(h0: uint64, s0: str): uint64 =
    var h: uint64 = h0
    let s: str = (s0 != nil) ? s0 : ""
    for i in 0..<len(s):
        let c: char = s[i]
        h = h ^ uint64(int64(c) & int64(0xFF))
        h = h * uint64(1099511628211)
    return h

fn driver_fnv1a64UpdateChar(h0: uint64, c: char): uint64 =
    var h: uint64 = h0
    h = h ^ uint64(int64(c) & int64(0xFF))
    h = h * uint64(1099511628211)
    return h

fn driver_hashUnitList(unitFiles: str[]): int64 =
    var h: uint64 = uint64(1469598103934665603)
    for i in 0..<unitFiles.len:
        h = driver_fnv1a64Update(h, unitFiles[i])
        h = driver_fnv1a64UpdateChar(h, '\n')
    return int64(h)

fn driver_buildUnitDepClosureBits(unitDeps: DriverSeqSeqInt32, unitCount: int32): DriverSeqSeqU64 =
    if unitCount <= 0:
        var outNil: DriverSeqSeqU64
        return outNil
    let words: int32 = (unitCount + 63) / 64
    var closure: DriverSeqSeqU64 = driver_newSeq2DU64(unitCount, words)
    var revDeps: DriverSeqSeqInt32 = driver_newSeq2DInt(unitCount)
    for ui in 0..<unitCount:
        driver_setDepBit(&closure, ui, ui)
        if ui >= 0 && ui < unitDeps.len:
            let rowDeps: int32[] = driver_getRowInt32(unitDeps, ui)
            for di in 0..<rowDeps.len:
                let depIdx: int32 = rowDeps[di]
                if depIdx >= 0 && depIdx < unitCount:
                    driver_setDepBit(&closure, ui, depIdx)
                    var revRow: int32[] = driver_getRowInt32(revDeps, depIdx)
                    add(revRow, ui)
                    driver_setRowInt32(revDeps, depIdx, revRow)

    var queue: int32[]
    queue.cap = unitCount
    var queued: bool[]
    queued.cap = unitCount
    for ui in 0..<unitCount:
        add(queue, ui)
        add(queued, true)
    for qi in 0..<queue.len:
        let node: int32 = queue[qi]
        if node < 0 || node >= unitCount:
            continue
        queued[node] = false
        let nodeBits: uint64[] = driver_getRowU64(closure, node)
        let parents: int32[] = driver_getRowInt32(revDeps, node)
        for pi in 0..<parents.len:
            let parentIdx: int32 = parents[pi]
            if parentIdx >= 0 && parentIdx < unitCount:
                var parentBits: uint64[] = driver_getRowU64(closure, parentIdx)
                var changed: bool = false
                for wi in 0..<words:
                    let cur: uint64 = parentBits[wi]
                    let merged: uint64 = cur | nodeBits[wi]
                    if merged != cur:
                        parentBits[wi] = merged
                        changed = true
                if changed:
                    driver_setRowU64(closure, parentIdx, parentBits)
                    if ! queued[parentIdx]:
                        add(queue, parentIdx)
                        queued[parentIdx] = true
    return closure

fn driver_buildUnitDepClosureStamp(unitIdx: int32, unitFiles: str[], unitClosureBits: DriverSeqSeqU64,
                                   unitStateHashes: int64[], compileStampHash: int64): str =
    if unitIdx < 0 || unitIdx >= unitFiles.len:
        return ""
    let unitFile: str = unitFiles[unitIdx]
    var hash: int64 = driver_hashCombine64(compileStampHash, mirFnv1a64(unitFile))
    if unitIdx < 0 || unitIdx >= unitClosureBits.len:
        let fallbackHash: int64 = mirFnv1a64(driver_fileStateStamp(unitFile))
        hash = driver_hashCombine64(hash, fallbackHash)
        return "unit=" + unitFile + "\nclosure_hash=" + mirU64ToHex(hash) + "\n"
    let n: int32 = unitFiles.len
    let rowBits: uint64[] = driver_getRowU64(unitClosureBits, unitIdx)
    for wi in 0..<rowBits.len:
        let word: uint64 = rowBits[wi]
        if word != uint64(0):
            for bi in 0..<64:
                let idx: int32 = wi * 64 + bi
                if idx >= n:
                    break
                let mask: uint64 = uint64(1) << uint64(bi)
                if (word & mask) != uint64(0):
                    if idx >= 0 && idx < unitStateHashes.len:
                        hash = driver_hashCombine64(hash, unitStateHashes[idx])
                    elif idx >= 0 && idx < unitFiles.len:
                        hash = driver_hashCombine64(hash,
                                                    mirFnv1a64(driver_fileStateStamp(unitFiles[idx])))
    return "unit=" + unitFile + "\nclosure_hash=" + mirU64ToHex(hash) + "\n"

fn driver_parallelWorkerCount(pendingUnitsLen: int32, jobs: int32): int32 =
    if pendingUnitsLen <= 0:
        return 0
    var workerCount: int32 = int32(jobs)
    if workerCount <= 0:
        workerCount = 1
    let minBatchUnits: int32 = driver_parseInt32Default(
        os.getEnvDefault("CHENG_BACKEND_MULTI_MIN_BATCH_UNITS", ""), 8)
    if minBatchUnits > 1:
        var maxWorkersByBatch: int32 = pendingUnitsLen / minBatchUnits
        if (pendingUnitsLen % minBatchUnits) != 0:
            maxWorkersByBatch = maxWorkersByBatch + 1
        if maxWorkersByBatch <= 0:
            maxWorkersByBatch = 1
        if workerCount > maxWorkersByBatch:
            workerCount = maxWorkersByBatch
    if workerCount > pendingUnitsLen:
        workerCount = pendingUnitsLen
    if workerCount <= 0:
        workerCount = 1
    return workerCount

fn driver_runParallelUnitBatches(selfExe: str, inputPath: str, target: str, frontend: str, objWriter: str,
                                 moduleCachePath: str,
                                 allowNoMain: bool, wholeProgram: bool, skipGlobalInit: bool,
                                 objDir: str, pendingUnits: str[], pendingObjs: str[], jobs: int32) =
    if pendingUnits.len == 0:
        return
    let workerCount: int32 = driver_parallelWorkerCount(pendingUnits.len, jobs)
    var batchLines: str[]
    for wi in 0..<workerCount:
        add(batchLines, "")
    for pi in 0..<pendingUnits.len:
        let bucket: int32 = pi % workerCount
        let line: str = pendingObjs[pi] + "\t" + pendingUnits[pi] + "\n"
        batchLines[bucket] = batchLines[bucket] + line

    let allowNoMainArg: str = allowNoMain ? " --allow-no-main" : " --no-allow-no-main"
    let wholeProgramArg: str = wholeProgram ? " --whole-program" : " --no-whole-program"
    let skipGlobalInitArg: str = skipGlobalInit ? " --skip-global-init" : " --no-skip-global-init"
    let parallelBuildFlags: str = allowNoMainArg + wholeProgramArg + skipGlobalInitArg

    var runCmd: str = "set -eu\n" +
                      "pids=\"\"\n"
    for wi in 0..<workerCount:
        let rows: str = batchLines[wi]
        if driver_strNonEmpty(rows):
            let batchPath: str = objDir + "/.build.batch." + intToStr(wi) + ".tsv"
            os.writeFile(batchPath, rows)
            var cmd: str = driver_shellQuote(selfExe) +
                           " --emit=obj --target=" + driver_shellQuote(target) +
                           " --frontend=" + driver_shellQuote(frontend)
            if driver_strNonEmpty(objWriter):
                cmd = cmd + " --obj-writer=" + driver_shellQuote(objWriter)
            if driver_strNonEmpty(moduleCachePath):
                cmd = cmd + " --module-cache=" + driver_shellQuote(moduleCachePath)
            cmd = cmd + " --unit-batch-file=" + driver_shellQuote(batchPath) +
                  parallelBuildFlags + " " + driver_shellQuote(inputPath)
            runCmd = runCmd + cmd + " &\n" +
                             "pids=\"$pids $!\"\n"
    runCmd = runCmd + "for pid in $pids; do\n" +
                      "  wait \"$pid\"\n" +
                      "done\n"
    driver_runCmd(runCmd)

fn driver_lockOwnerPid(): str =
    let pid: str = driver_execCmdTrimmed("sh -c 'echo $PPID'")
    if driver_strIsEmpty(pid):
        return "0"
    return pid

fn driver_acquireDirLock(lockDir: str, ownerPid: str) =
    if driver_strIsEmpty(lockDir):
        return
    let owner: str = (driver_strIsEmpty(ownerPid)) ? "0" : ownerPid
    let lockCmd: str = "set -eu\n" +
                       "lock_dir=" + driver_shellQuote(lockDir) + "\n" +
                       "owner_pid=" + driver_shellQuote(owner) + "\n" +
                       "owner_file=\"$lock_dir/owner.pid\"\n" +
                       "waits=0\n" +
                       "while ! mkdir \"$lock_dir\" 2>/dev/null; do\n" +
                       "  if [ -f \"$owner_file\" ]; then\n" +
                       "    owner=$(cat \"$owner_file\" 2>/dev/null || true)\n" +
                       "    if [ -n \"$owner\" ] && ! kill -0 \"$owner\" 2>/dev/null; then\n" +
                       "      rm -rf \"$lock_dir\" 2>/dev/null || true\n" +
                       "      continue\n" +
                       "    fi\n" +
                       "  fi\n" +
                       "  waits=$((waits + 1))\n" +
                       "  if [ \"$waits\" -ge 2400 ]; then\n" +
                       "    echo \"backend_driver: timeout waiting for lock: $lock_dir\" >&2\n" +
                       "    exit 1\n" +
                       "  fi\n" +
                       "  sleep 0.05\n" +
                       "done\n" +
                       "printf '%s\\n' \"$owner_pid\" > \"$owner_file\"\n"
    driver_runCmd(lockCmd)

fn driver_releaseDirLock(lockDir: str, ownerPid: str) =
    if driver_strIsEmpty(lockDir):
        return
    let owner: str = (driver_strIsEmpty(ownerPid)) ? "0" : ownerPid
    let unlockCmd: str = "set +e\n" +
                         "lock_dir=" + driver_shellQuote(lockDir) + "\n" +
                         "owner_pid=" + driver_shellQuote(owner) + "\n" +
                         "owner_file=\"$lock_dir/owner.pid\"\n" +
                         "if [ -f \"$owner_file\" ]; then\n" +
                         "  owner=$(cat \"$owner_file\" 2>/dev/null || true)\n" +
                         "  if [ \"$owner\" = \"$owner_pid\" ]; then\n" +
                         "    rm -rf \"$lock_dir\" 2>/dev/null || true\n" +
                         "  fi\n" +
                         "fi\n"
    driver_runCmd(unlockCmd)

fn driver_targetIsAndroid(target: str): bool =
    if driver_strIsEmpty(target):
        return false
    return driver_strContains(target, "android")

fn driver_targetIsDarwin(target: str): bool =
    if driver_strIsEmpty(target):
        return true
    return driver_strContains(target, "apple") || driver_strContains(target, "darwin") || driver_strContains(target, "ios")

fn driver_targetIsWindows(target: str): bool =
    if driver_strIsEmpty(target):
        return false
    return driver_strContains(target, "windows") || driver_strContains(target, "msvc")

fn driver_targetIsLinux(target: str): bool =
    if driver_strIsEmpty(target):
        return false
    if driver_targetIsAndroid(target):
        return false
    return driver_strContains(target, "linux")

fn driver_targetIsAarch64(target: str): bool =
    if driver_strIsEmpty(target):
        return true
    return driver_strContains(target, "aarch64") || driver_strContains(target, "arm64")

fn driver_targetIsX86_64(target: str): bool =
    if driver_strIsEmpty(target):
        return false
    return driver_strContains(target, "x86_64") || driver_strContains(target, "amd64")

fn driver_targetIsRiscv64(target: str): bool =
    if driver_strIsEmpty(target):
        return false
    return driver_strContains(target, "riscv64")

fn driver_defaultAndroidSdkRoot(): str =
    let sdk: str = os.getEnvDefault("ANDROID_SDK_ROOT", os.getEnvDefault("ANDROID_HOME", ""))
    if driver_strNonEmpty(sdk) && os.dirExists(sdk):
        return sdk
    let home: str = os.getEnvDefault("HOME", "")
    if driver_strIsEmpty(home):
        return ""
    # Android Studio default SDK locations.
    let mac: str = os.joinPath(home, "Library/Android/sdk")
    if os.dirExists(mac):
        return mac
    let linux: str = os.joinPath(home, "Android/Sdk")
    if os.dirExists(linux):
        return linux
    return ""

fn driver_defaultAndroidNdkRoot(): str =
    let ndk: str = os.getEnvDefault("ANDROID_NDK_HOME",
                                    os.getEnvDefault("ANDROID_NDK_ROOT", ""))
    if driver_strNonEmpty(ndk) && os.dirExists(ndk):
        return ndk
    let sdk: str = driver_defaultAndroidSdkRoot()
    if driver_strIsEmpty(sdk):
        return ""
    let bundle: str = os.joinPath(sdk, "ndk-bundle")
    if os.dirExists(bundle):
        return bundle
    let ndkBase: str = os.joinPath(sdk, "ndk")
    if ! os.dirExists(ndkBase):
        return ""
    let entries: os.seq_WalkDirEntry = os.walkDir(ndkBase)
    var bestPath: str = ""
    var bestName: str = ""
    for i in 0..<entries.len:
        let e: os.WalkDirEntry = os.os_get_WalkDirEntry(entries, i)
        if e.kind == os.pcDir:
            let name: str = os.extractFilename(e.path)
            if driver_strIsEmpty(bestPath):
                bestPath = e.path
                bestName = name
            elif mirStrCmp(name, bestName) > 0:
                bestPath = e.path
                bestName = name
    return bestPath

fn driver_defaultAndroidNdkClang(api: int32): str =
    let ndk: str = driver_defaultAndroidNdkRoot()
    if driver_strIsEmpty(ndk):
        return ""
    let prebuiltRoot: str = os.joinPath(ndk, "toolchains/llvm/prebuilt")
    var candidates: str[]
    add(candidates, "darwin-arm64")
    add(candidates, "darwin-x86_64")
    add(candidates, "linux-x86_64")
    add(candidates, "linux-arm64")
    add(candidates, "linux-aarch64")
    add(candidates, "windows-x86_64")
    add(candidates, "windows-x64")
    var prebuilt: str = ""
    for i in 0..<candidates.len:
        let candidate: str = candidates[i]
        let p: str = os.joinPath(prebuiltRoot, candidate)
        if os.dirExists(p):
            prebuilt = p
            break
    if driver_strIsEmpty(prebuilt):
        return ""
    let binDir: str = os.joinPath(prebuilt, "bin")
    let name: str = "aarch64-linux-android" + intToStr(api) + "-clang"
    let path: str = os.joinPath(binDir, name)
    if frontend_lib.stage1_fileExists(path):
        return path
    return ""

fn driver_seqContainsStr(items: str[], value: str): bool =
    for i in 0..<items.len:
        if (items[i] == value):
            return true
    return false

fn driver_mapAddUniqueStr(items: var str[], seen: var hashmaps.HashMapStrInt, value: str) =
    if driver_strIsEmpty(value):
        return
    var snap: hashmaps.HashMapStrInt
    snap.keys = seen.keys
    snap.vals = seen.vals
    snap.states = seen.states
    snap.mask = seen.mask
    snap.used = seen.used
    if snap[value] != 0:
        return
    hashmaps.hashMapStrIntPut(seen, value, 1)
    add(items, value)

fn driverSeqStrElemPtr(buffer: void*, len0: int32, idx: int32): void* =
    if idx < 0 || idx >= len0:
        panic "backend_driver: seq index out of bounds"
    let off64: int64 = int64(idx) * sizeof str
    return ptr_add(buffer, int32(off64))

fn driverReadStrPtr(items: str[]*, idx: int32): str =
    if items == nil:
        panic "backend_driver: nil seq pointer"
    let p: str* = str*(driverSeqStrElemPtr(items->buffer, items->len, idx))
    return *p

fn driverWriteStrPtr(items: str[]*, idx: int32, val: str) =
    if items == nil:
        panic "backend_driver: nil seq pointer"
    let p: str* = str*(driverSeqStrElemPtr(items->buffer, items->len, idx))
    *p = val

fn driver_sortStringsStable(items: str[]*) =
    if items == nil:
        return
    for i in 1..<items->len:
        let key: str = driverReadStrPtr(items, i)
        var j: int32 = i - 1
        let __for_start_j = j
        for __for_rev_j in 0..(__for_start_j - (0)):
            j = __for_start_j - __for_rev_j
            if !(mirStrCmp(driverReadStrPtr(items, j), key) > 0):
                break
            driverWriteStrPtr(items, j + 1, driverReadStrPtr(items, j))
        driverWriteStrPtr(items, j + 1, key)

fn driver_sharedUnitFile(): str =
    return "<shared>"

fn driver_unitOwnerKey(originFile: str): str =
    if driver_strNonEmpty(originFile):
        return originFile
    return driver_sharedUnitFile()

fn driver_isSharedUnitFile(filePath: str): bool =
    return (filePath == driver_sharedUnitFile())

fn driver_collectUnitFiles(module: MirModule): str[] =
    var out: str[]
    if module == nil:
        return out
    var seen: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(module.funcs.len + module.globals.len + 16)
    var hasShared: bool = false
    for i in 0..<module.funcs.len:
        let f: MirFunc = module.funcs[i]
        if f != nil && ! f.isExtern:
            if driver_strNonEmpty(f.originFile):
                driver_mapAddUniqueStr(out, seen, f.originFile)
            else:
                hasShared = true
    for i in 0..<module.globals.len:
        let g: MirGlobal = module.globals[i]
        if driver_strNonEmpty(g.originFile):
            driver_mapAddUniqueStr(out, seen, g.originFile)
        else:
            hasShared = true
    if hasShared:
        driver_mapAddUniqueStr(out, seen, driver_sharedUnitFile())
    driver_sortStringsStable(&out)
    return out

fn driver_cloneExternFunc(f: MirFunc): MirFunc =
    if f == nil:
        return nil
    let stub: MirFunc = mirNewFunc(f.name, f.retType)
    stub.linkName = f.linkName
    stub.originFile = f.originFile
    stub.isExtern = true
    for pi in 0..<f.params.len:
        add(stub.params, f.params[pi])
    return stub

type
    DriverUnitIndex = ref
        unitFiles: str[]
        unitIndex: hashmaps.HashMapStrInt
        # Only non-extern (definition) items are indexed here.
        unitFuncIdx: DriverSeqSeqInt32
        unitGlobalIdx: DriverSeqSeqInt32
        nameToFuncIdx: hashmaps.HashMapStrInt

fn driver_buildUnitIndex(full: MirModule, unitFiles: str[]): DriverUnitIndex =
    let dbg: bool = driver_envIsTrue("CHENG_BACKEND_DEBUG_UNIT_INDEX")
    if dbg:
        let nfiles: int32 = unitFiles.len
        let nfuncs: int32 = (full != nil) ? full.funcs.len : 0
        let nglobs: int32 = (full != nil) ? full.globals.len : 0
        let f: os.File = os.get_stderr()
        os.writeLine(f, "backend_driver: unit_index start files=" + intToStr(nfiles) +
                       " funcs=" + intToStr(nfuncs) +
                       " globals=" + intToStr(nglobs))
        os.c_fflush f
    var out: DriverUnitIndex
    new out
    out.unitFiles = unitFiles
    var unitIndexMap: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(unitFiles.len * 2 + 8)
    out.unitFuncIdx = driver_newSeq2DInt(unitFiles.len)
    out.unitGlobalIdx = driver_newSeq2DInt(unitFiles.len)
    var nameToFuncIdxMap: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit((full != nil) ? (full.funcs.len * 2 + 8) : 16)

    for ui in 0..<unitFiles.len:
        hashmaps.hashMapStrIntPut(unitIndexMap, unitFiles[ui], ui)
    out.unitIndex = unitIndexMap
    if dbg:
        let f: os.File = os.get_stderr()
        os.writeLine(f, "backend_driver: unit_index map_ready")
        os.c_fflush f

    if full == nil:
        return out

    for fi in 0..<full.funcs.len:
        let f: MirFunc = full.funcs[fi]
        let fname: str = (f != nil) ? f.name : nil
        var fnameLen: int32 = 0
        if dbg:
            let fptr: int64 = int64(uint64(void*(f)))
            let nptr: int64 = int64(uint64(void*(fname)))
            let fdbg: os.File = os.get_stderr()
            os.writeLine(fdbg, "backend_driver: unit_index func i=" + intToStr(fi) +
                               " f_nil=" + driver_bool01(f == nil) +
                               " name_nil=" + driver_bool01(fname == nil) +
                               " f_ptr=0x" + mirU64ToHex(fptr) +
                               " name_ptr=0x" + mirU64ToHex(nptr))
            os.c_fflush fdbg
        if fname != nil:
            if dbg:
                let fdbg2: os.File = os.get_stderr()
                os.writeLine(fdbg2, "backend_driver: unit_index func i=" + intToStr(fi) + " name_len_start")
                os.c_fflush fdbg2
            fnameLen = len(fname)
            if dbg:
                let fdbg3: os.File = os.get_stderr()
                os.writeLine(fdbg3, "backend_driver: unit_index func i=" + intToStr(fi) + " name_len=" + intToStr(fnameLen))
                os.c_fflush fdbg3
        if fname != nil && fnameLen > 0:
            var exists: bool = false
            if dbg:
                let m0: hashmaps.HashMapStrInt = nameToFuncIdxMap
                let mask0: int64 = int64(m0.mask)
                let used0: int32 = m0.used
                let keysLen0: int32 = m0.keys.len
                let keysCap0: int32 = m0.keys.cap
                let valsLen0: int32 = m0.vals.len
                let valsCap0: int32 = m0.vals.cap
                let keysBuf0: int64 = int64(uint64(void*(m0.keys.buffer)))
                let valsBuf0: int64 = int64(uint64(void*(m0.vals.buffer)))
                let fdbg3b: os.File = os.get_stderr()
                os.writeLine(fdbg3b, "backend_driver: unit_index func i=" + intToStr(fi) +
                                     " name_to_func mask=0x" + mirU64ToHex(mask0) +
                                     " used=" + intToStr(used0) +
                                     " keys.len=" + intToStr(keysLen0) +
                                     " keys.cap=" + intToStr(keysCap0) +
                                     " keys.buf=0x" + mirU64ToHex(keysBuf0) +
                                     " vals.len=" + intToStr(valsLen0) +
                                     " vals.cap=" + intToStr(valsCap0) +
                                     " vals.buf=0x" + mirU64ToHex(valsBuf0))
                os.c_fflush fdbg3b
                for ki0 in 0..<4:
                    if !(ki0 < m0.keys.len):
                        break
                    let keys0: str[] = m0.keys
                    let cur0: str = keys0[ki0]
                    let curp0: int64 = int64(uint64(void*(cur0)))
                    let fdbgKeys: os.File = os.get_stderr()
                    os.writeLine(fdbgKeys, "backend_driver: unit_index func i=" + intToStr(fi) +
                                               " name_to_func keys[" + intToStr(ki0) + "]=0x" + mirU64ToHex(curp0))
                    os.c_fflush fdbgKeys
                let fdbg4: os.File = os.get_stderr()
                os.writeLine(fdbg4, "backend_driver: unit_index func i=" + intToStr(fi) + " probe_get_literal_start")
                os.c_fflush fdbg4
                var probeFound: bool = false
                let _probeVal: int32 = hashmaps.hashMapStrIntGetEx(nameToFuncIdxMap, "k1", probeFound)
                let fdbg5: os.File = os.get_stderr()
                os.writeLine(fdbg5, "backend_driver: unit_index func i=" + intToStr(fi) + " probe_get_literal_ok")
                os.c_fflush fdbg5
                let fdbg6: os.File = os.get_stderr()
                os.writeLine(fdbg6, "backend_driver: unit_index func i=" + intToStr(fi) + " get_name_start")
                os.c_fflush fdbg6
            let _seenNameToFunc: int32 = hashmaps.hashMapStrIntGetEx(nameToFuncIdxMap, fname, exists)
            if dbg:
                let fdbg7: os.File = os.get_stderr()
                os.writeLine(fdbg7, "backend_driver: unit_index func i=" + intToStr(fi) + " get_name_ok exists=" + driver_bool01(exists))
                os.c_fflush fdbg7
            if ! exists:
                hashmaps.hashMapStrIntPut(nameToFuncIdxMap, fname, fi)
    out.nameToFuncIdx = nameToFuncIdxMap
    if dbg:
        let f: os.File = os.get_stderr()
        os.writeLine(f, "backend_driver: unit_index name_to_func_ready")
        os.c_fflush f

    for gi in 0..<full.globals.len:
        let g: MirGlobal = full.globals[gi]
        let ownerKey: str = driver_unitOwnerKey(g.originFile)
        var foundOwner: bool = false
        let ownerIdx: int32 = hashmaps.hashMapStrIntGetEx(unitIndexMap, ownerKey, foundOwner)
        if foundOwner && ownerIdx >= 0 && ownerIdx < out.unitGlobalIdx.len:
            var row: int32[] = driver_getRowInt32(out.unitGlobalIdx, ownerIdx)
            add(row, gi)
            driver_setRowInt32(out.unitGlobalIdx, ownerIdx, row)
    if dbg:
        let f: os.File = os.get_stderr()
        os.writeLine(f, "backend_driver: unit_index globals_ready")
        os.c_fflush f

    for fi in 0..<full.funcs.len:
        let f2: MirFunc = full.funcs[fi]
        if f2 != nil && !f2.isExtern:
            let ownerKey2: str = driver_unitOwnerKey(f2.originFile)
            var foundOwner2: bool = false
            let ownerIdx2: int32 = hashmaps.hashMapStrIntGetEx(unitIndexMap, ownerKey2, foundOwner2)
            if foundOwner2 && ownerIdx2 >= 0 && ownerIdx2 < out.unitFuncIdx.len:
                var row2: int32[] = driver_getRowInt32(out.unitFuncIdx, ownerIdx2)
                add(row2, fi)
                driver_setRowInt32(out.unitFuncIdx, ownerIdx2, row2)
    if dbg:
        let f: os.File = os.get_stderr()
        os.writeLine(f, "backend_driver: unit_index funcs_ready")
        os.c_fflush f

    return out

type
    DriverModuleCache = ref
        # Stored as raw pointer to avoid MVP frontend type-decl dependency on `MirModule`.
        module: void*
        unitFiles: str[]
        unitFuncIdx: DriverSeqSeqInt32
        unitGlobalIdx: DriverSeqSeqInt32
        nameToFuncIdx: hashmaps.HashMapStrInt

type
    DriverCacheStrTab = ref
        items: str[]
        index: hashmaps.HashMapStrInt

fn driver_cacheStrTabInit(cap0: int32): DriverCacheStrTab =
    var tab: DriverCacheStrTab
    new tab
    tab.items = []
    var indexMap: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit((cap0 > 0) ? cap0 : 16)
    # Index 0 is always empty string.
    add(tab.items, "")
    hashmaps.hashMapStrIntPut(indexMap, "", 0)
    tab.index = indexMap
    return tab

fn driver_cacheStrTabIndex(tab: DriverCacheStrTab, s: str): int32 =
    if tab == nil:
        return 0
    if driver_strIsEmpty(s):
        return 0
    var found: bool = false
    var indexMap: hashmaps.HashMapStrInt = tab.index
    let idx: int32 = hashmaps.hashMapStrIntGetEx(indexMap, s, found)
    if found:
        return idx
    let newIdx: int32 = tab.items.len
    add(tab.items, s)
    hashmaps.hashMapStrIntPut(indexMap, s, newIdx)
    tab.index = indexMap
    return newIdx

fn driver_cacheCollectExprStrings(expr: MirExpr, tab: DriverCacheStrTab) =
    if expr == nil || tab == nil:
        return
    if driver_strNonEmpty(expr.callee):
        driver_cacheStrTabIndex(tab, expr.callee)
    if driver_strNonEmpty(expr.globalName):
        driver_cacheStrTabIndex(tab, expr.globalName)
    if expr.lhs != nil:
        driver_cacheCollectExprStrings(expr.lhs, tab)
    if expr.rhs != nil:
        driver_cacheCollectExprStrings(expr.rhs, tab)
    if expr.castExpr != nil:
        driver_cacheCollectExprStrings(expr.castExpr, tab)
    if expr.addrExpr != nil:
        driver_cacheCollectExprStrings(expr.addrExpr, tab)
    for i in 0..<expr.args.len:
        let a: MirExpr = expr.args[i]
        if a != nil:
            driver_cacheCollectExprStrings(a, tab)

fn driver_cacheCollectTermStrings(term: MirTerm, tab: DriverCacheStrTab) =
    if tab == nil:
        return
    if driver_strNonEmpty(term.target):
        driver_cacheStrTabIndex(tab, term.target)
    if driver_strNonEmpty(term.targetTrue):
        driver_cacheStrTabIndex(tab, term.targetTrue)
    if driver_strNonEmpty(term.targetFalse):
        driver_cacheStrTabIndex(tab, term.targetFalse)
    if term.retExpr != nil:
        driver_cacheCollectExprStrings(term.retExpr, tab)
    if term.condExpr != nil:
        driver_cacheCollectExprStrings(term.condExpr, tab)

fn driver_cacheCollectFuncStrings(f: MirFunc, tab: DriverCacheStrTab) =
    if f == nil || tab == nil:
        return
    driver_cacheStrTabIndex(tab, f.name)
    driver_cacheStrTabIndex(tab, f.linkName)
    driver_cacheStrTabIndex(tab, f.originFile)
    driver_cacheStrTabIndex(tab, f.retTypeKey)
    for pi in 0..<f.params.len:
        let p: MirParam = f.params[pi]
        driver_cacheStrTabIndex(tab, p.name)
        driver_cacheStrTabIndex(tab, p.typeKey)
    for oi in 0..<f.objLocals.len:
        let ol: MirObjLocal = f.objLocals[oi]
        driver_cacheStrTabIndex(tab, ol.objTypeName)
        driver_cacheStrTabIndex(tab, ol.typeKey)
    for bi in 0..<f.blocks.len:
        let b: MirBlock = f.blocks[bi]
        if b != nil:
            driver_cacheStrTabIndex(tab, b.label)
            for si in 0..<b.stmts.len:
                let s: MirStmt = b.stmts[si]
                driver_cacheStrTabIndex(tab, s.name)
                if s.expr != nil:
                    driver_cacheCollectExprStrings(s.expr, tab)
                if s.addrExpr != nil:
                    driver_cacheCollectExprStrings(s.addrExpr, tab)
            driver_cacheCollectTermStrings(b.term, tab)

fn driver_cacheCollectModuleStrings(module: MirModule, idx: DriverUnitIndex, tab: DriverCacheStrTab) =
    if module == nil || tab == nil:
        return
    driver_cacheStrTabIndex(tab, module.target)
    for fi in 0..<module.funcs.len:
        driver_cacheCollectFuncStrings(module.funcs[fi], tab)
    for ci in 0..<module.cstrs.len:
        let c: MirCString = module.cstrs[ci]
        driver_cacheStrTabIndex(tab, c.label)
        driver_cacheStrTabIndex(tab, c.value)
    for gi in 0..<module.globals.len:
        let g: MirGlobal = module.globals[gi]
        driver_cacheStrTabIndex(tab, g.name)
        driver_cacheStrTabIndex(tab, g.originFile)
    for ai in 0..<module.typeAliases.len:
        let a: MirTypeAlias = module.typeAliases[ai]
        driver_cacheStrTabIndex(tab, a.name)
    for ti in 0..<module.objTypes.len:
        let ot: MirObjType = module.objTypes[ti]
        driver_cacheStrTabIndex(tab, ot.name)
        for fi2 in 0..<ot.fields.len:
            let f2: MirObjField = ot.fields[fi2]
            driver_cacheStrTabIndex(tab, f2.name)
    if idx != nil:
        for ui in 0..<idx.unitFiles.len:
            driver_cacheStrTabIndex(tab, idx.unitFiles[ui])
        let keys: str[] = idx.nameToFuncIdx.keys
        for si2 in 0..<keys.len:
            let k: str = keys[si2]
            if driver_strNonEmpty(k):
                driver_cacheStrTabIndex(tab, k)

fn driver_bufAddU8Ptr(buf: uint8[]*, v: uint8) =
    if buf == nil:
        return
    add(buf, v)

fn driver_cacheBufU8(buf: uint8[]*, v: int32) =
    if buf == nil:
        return
    driver_bufAddU8Ptr(buf, uint8(v & 255))

fn driver_cacheBufU32(buf: uint8[]*, v: uint32) =
    driver_cacheBufU8(buf, int32(v & uint32(255)))
    driver_cacheBufU8(buf, int32((v >> 8) & uint32(255)))
    driver_cacheBufU8(buf, int32((v >> 16) & uint32(255)))
    driver_cacheBufU8(buf, int32((v >> 24) & uint32(255)))

fn driver_cacheBufU64(buf: uint8[]*, v: uint64) =
    driver_cacheBufU32(buf, uint32(v & uint64(0xFFFFFFFF)))
    driver_cacheBufU32(buf, uint32((v >> 32) & uint64(0xFFFFFFFF)))

fn driver_cacheBufI32(buf: uint8[]*, v: int32) =
    driver_cacheBufU32(buf, uint32(v))

fn driver_cacheBufI64(buf: uint8[]*, v: int64) =
    driver_cacheBufU64(buf, uint64(v))

fn driver_cacheBufBool(buf: uint8[]*, b: bool) =
    driver_cacheBufU8(buf, b ? 1 : 0)

fn driver_cacheAppendBytes(buf: uint8[]*, data: void*, count: int32) =
    if buf == nil || data == nil || count <= 0:
        return
    let oldLen: int32 = buf->len
    buf->cap = oldLen + count
    buf->len = oldLen + count
    if buf->buffer == nil:
        panic "backend_driver: out of memory while building module cache"
    copyMem(ptr_add(buf->buffer, oldLen), data, count)

fn driver_cacheBufStrBytes(buf: uint8[]*, s: str) =
    let n: int32 = driver_strIsEmpty(s) ? 0 : len(s)
    driver_cacheBufU32(buf, uint32(n))
    if n > 0:
        driver_cacheAppendBytes(buf, void*(s), n)

fn driver_cacheBufStrIdx(buf: uint8[]*, tab: DriverCacheStrTab, s: str) =
    let idx: int32 = driver_cacheStrTabIndex(tab, s)
    driver_cacheBufU32(buf, uint32(idx))

fn driver_cacheBufType(buf: uint8[]*, ty: MirType) =
    driver_cacheBufU8(buf, int32(ty.kind) & 255)
    driver_cacheBufBool(buf, ty.isUnsigned)

fn driver_cacheBufExpr(buf: uint8[]*, tab: DriverCacheStrTab, expr: MirExpr) =
    if expr == nil:
        driver_cacheBufU8(buf, 0)
        return
    driver_cacheBufU8(buf, 1)
    driver_cacheBufU8(buf, int32(expr.kind) & 255)
    driver_cacheBufI64(buf, expr.value)
    driver_cacheBufU8(buf, int32(expr.binOp) & 255)
    driver_cacheBufU8(buf, int32(expr.cmpOp) & 255)
    driver_cacheBufExpr(buf, tab, expr.lhs)
    driver_cacheBufExpr(buf, tab, expr.rhs)
    driver_cacheBufI32(buf, expr.localIndex)
    driver_cacheBufStrIdx(buf, tab, expr.callee)
    driver_cacheBufU32(buf, uint32(expr.args.len))
    for ai in 0..<expr.args.len:
        driver_cacheBufExpr(buf, tab, expr.args[ai])
    driver_cacheBufType(buf, expr.castType)
    driver_cacheBufExpr(buf, tab, expr.castExpr)
    driver_cacheBufExpr(buf, tab, expr.addrExpr)
    driver_cacheBufType(buf, expr.loadType)
    driver_cacheBufStrIdx(buf, tab, expr.globalName)

fn driver_cacheBufStmt(buf: uint8[]*, tab: DriverCacheStrTab, stmt: MirStmt) =
    driver_cacheBufU8(buf, int32(stmt.kind) & 255)
    driver_cacheBufStrIdx(buf, tab, stmt.name)
    driver_cacheBufI32(buf, stmt.slot)
    driver_cacheBufExpr(buf, tab, stmt.expr)
    driver_cacheBufI32(buf, stmt.paramIndex)
    driver_cacheBufExpr(buf, tab, stmt.addrExpr)
    driver_cacheBufType(buf, stmt.storeType)

fn driver_cacheBufTerm(buf: uint8[]*, tab: DriverCacheStrTab, term: MirTerm) =
    driver_cacheBufU8(buf, int32(term.kind) & 255)
    driver_cacheBufExpr(buf, tab, term.retExpr)
    driver_cacheBufExpr(buf, tab, term.condExpr)
    driver_cacheBufStrIdx(buf, tab, term.target)
    driver_cacheBufStrIdx(buf, tab, term.targetTrue)
    driver_cacheBufStrIdx(buf, tab, term.targetFalse)

fn driver_cacheBufBlock(buf: uint8[]*, tab: DriverCacheStrTab, block: MirBlock) =
    if block == nil:
        driver_cacheBufU8(buf, 0)
        return
    driver_cacheBufU8(buf, 1)
    driver_cacheBufStrIdx(buf, tab, block.label)
    driver_cacheBufU32(buf, uint32(block.stmts.len))
    for si in 0..<block.stmts.len:
        driver_cacheBufStmt(buf, tab, block.stmts[si])
    driver_cacheBufTerm(buf, tab, block.term)

fn driver_cacheBufFunc(buf: uint8[]*, tab: DriverCacheStrTab, f: MirFunc) =
    if f == nil:
        driver_cacheBufU8(buf, 0)
        return
    driver_cacheBufU8(buf, 1)
    driver_cacheBufStrIdx(buf, tab, f.name)
    driver_cacheBufStrIdx(buf, tab, f.linkName)
    driver_cacheBufStrIdx(buf, tab, f.originFile)
    driver_cacheBufBool(buf, f.isExtern)
    driver_cacheBufType(buf, f.retType)
    driver_cacheBufStrIdx(buf, tab, f.retTypeKey)
    driver_cacheBufU32(buf, uint32(f.params.len))
    for pi in 0..<f.params.len:
        let p: MirParam = f.params[pi]
        driver_cacheBufStrIdx(buf, tab, p.name)
        driver_cacheBufI32(buf, p.slot)
        driver_cacheBufType(buf, p.ty)
        driver_cacheBufStrIdx(buf, tab, p.typeKey)
    driver_cacheBufU32(buf, uint32(f.localTypes.len))
    for li in 0..<f.localTypes.len:
        driver_cacheBufType(buf, f.localTypes[li])
    driver_cacheBufU32(buf, uint32(f.objLocals.len))
    for oi in 0..<f.objLocals.len:
        let ol: MirObjLocal = f.objLocals[oi]
        driver_cacheBufI32(buf, ol.slot)
        driver_cacheBufStrIdx(buf, tab, ol.objTypeName)
        driver_cacheBufStrIdx(buf, tab, ol.typeKey)
        driver_cacheBufI32(buf, ol.frameOff)
    driver_cacheBufI32(buf, f.objFrameSize)
    driver_cacheBufU32(buf, uint32(f.blocks.len))
    for bi in 0..<f.blocks.len:
        driver_cacheBufBlock(buf, tab, f.blocks[bi])

fn driver_cacheBufModule(buf: uint8[]*, tab: DriverCacheStrTab, module: MirModule) =
    if module == nil:
        driver_cacheBufU8(buf, 0)
        return
    driver_cacheBufU8(buf, 1)
    driver_cacheBufStrIdx(buf, tab, module.target)
    driver_cacheBufU32(buf, uint32(module.funcs.len))
    for fi in 0..<module.funcs.len:
        driver_cacheBufFunc(buf, tab, module.funcs[fi])
    driver_cacheBufU32(buf, uint32(module.cstrs.len))
    for ci in 0..<module.cstrs.len:
        let c: MirCString = module.cstrs[ci]
        driver_cacheBufStrIdx(buf, tab, c.label)
        driver_cacheBufStrIdx(buf, tab, c.value)
    driver_cacheBufU32(buf, uint32(module.globals.len))
    for gi in 0..<module.globals.len:
        let g: MirGlobal = module.globals[gi]
        driver_cacheBufStrIdx(buf, tab, g.name)
        driver_cacheBufType(buf, g.ty)
        driver_cacheBufI64(buf, g.init)
        driver_cacheBufBool(buf, g.hasInit)
        driver_cacheBufStrIdx(buf, tab, g.originFile)
    driver_cacheBufU32(buf, uint32(module.typeAliases.len))
    for ai in 0..<module.typeAliases.len:
        let a: MirTypeAlias = module.typeAliases[ai]
        driver_cacheBufStrIdx(buf, tab, a.name)
        driver_cacheBufType(buf, a.ty)
    driver_cacheBufU32(buf, uint32(module.objTypes.len))
    for ti in 0..<module.objTypes.len:
        let ot: MirObjType = module.objTypes[ti]
        driver_cacheBufStrIdx(buf, tab, ot.name)
        driver_cacheBufI32(buf, ot.size)
        driver_cacheBufI32(buf, ot.alignPow2)
        driver_cacheBufU32(buf, uint32(ot.fields.len))
        for fi2 in 0..<ot.fields.len:
            let f2: MirObjField = ot.fields[fi2]
            driver_cacheBufStrIdx(buf, tab, f2.name)
            driver_cacheBufType(buf, f2.ty)
            driver_cacheBufI32(buf, f2.offset)

fn driver_cacheBufUnitIndex(buf: uint8[]*, tab: DriverCacheStrTab, idx: DriverUnitIndex) =
    if idx == nil:
        driver_cacheBufU8(buf, 0)
        return
    driver_cacheBufU8(buf, 1)
    driver_cacheBufU32(buf, uint32(idx.unitFiles.len))
    for ui in 0..<idx.unitFiles.len:
        driver_cacheBufStrIdx(buf, tab, idx.unitFiles[ui])
    driver_cacheBufU32(buf, uint32(idx.unitFuncIdx.len))
    for ui in 0..<idx.unitFuncIdx.len:
        let row: int32[] = driver_getRowInt32(idx.unitFuncIdx, ui)
        driver_cacheBufU32(buf, uint32(row.len))
        for j in 0..<row.len:
            driver_cacheBufI32(buf, row[j])
    driver_cacheBufU32(buf, uint32(idx.unitGlobalIdx.len))
    for ui in 0..<idx.unitGlobalIdx.len:
        let row2: int32[] = driver_getRowInt32(idx.unitGlobalIdx, ui)
        driver_cacheBufU32(buf, uint32(row2.len))
        for k in 0..<row2.len:
            driver_cacheBufI32(buf, row2[k])
    # nameToFuncIdx pairs
    let nameToFuncIdx: hashmaps.HashMapStrInt = idx.nameToFuncIdx
    driver_cacheBufU32(buf, uint32(nameToFuncIdx.used))
    let keys: str[] = nameToFuncIdx.keys
    let vals: int32[] = nameToFuncIdx.vals
    for si in 0..<keys.len:
        let key: str = keys[si]
        if key != nil:
            driver_cacheBufStrIdx(buf, tab, key)
            driver_cacheBufI32(buf, vals[si])

fn driver_writeModuleCache(path: str, module: MirModule, idx: DriverUnitIndex,
                           compileStampHash: int64, unitStateHashes: int64[]): bool =
    if driver_strIsEmpty(path) || module == nil || idx == nil:
        return false
    var tab: DriverCacheStrTab = driver_cacheStrTabInit(module.funcs.len * 4 + module.globals.len * 2 + 64)
    driver_cacheCollectModuleStrings(module, idx, tab)
    var out: uint8[]    # Header
    driver_cacheBufU8(&out, int32('C'))
    driver_cacheBufU8(&out, int32('H'))
    driver_cacheBufU8(&out, int32('M'))
    driver_cacheBufU8(&out, int32('C'))
    driver_cacheBufU32(&out, uint32(2))
    driver_cacheBufI64(&out, compileStampHash)
    driver_cacheBufU32(&out, uint32(idx.unitFiles.len))
    for ui in 0..<idx.unitFiles.len:
        let fp: str = idx.unitFiles[ui]
        driver_cacheBufStrBytes(&out, fp)
        if ui >= 0 && ui < unitStateHashes.len:
            driver_cacheBufI64(&out, unitStateHashes[ui])
        else:
            driver_cacheBufI64(&out, mirFnv1a64(driver_fileStateStamp(fp)))
    driver_cacheBufU32(&out, uint32(tab.items.len))
    for si in 0..<tab.items.len:
        driver_cacheBufStrBytes(&out, tab.items[si])
    driver_cacheBufModule(&out, tab, module)
    driver_cacheBufUnitIndex(&out, tab, idx)
    os.writeFileBytes(path, out)
    return frontend_lib.stage1_fileExists(path) && os.fileSize(path) > 0

type
    DriverCacheReader =
        r: bytes.ByteReader*
        ok: bool

fn driver_cacheReaderInit(buf: bytes.ByteBuffer): DriverCacheReader =
    DriverCacheReader(r: driver_allocByteReader(buf), ok: true)

fn driver_cacheReadU8(cr: DriverCacheReader*): int32 =
    if cr == nil || !cr->ok || cr->r == nil:
        return 0
    # Avoid deep `->` chains for stage0 seed bootstrap.
    let r: bytes.ByteReader* = cr->r
    let pos0: int32 = r->pos
    if pos0 + 1 > r->buf.len:
        cr->ok = false
        return 0
    let p: void* = ptr_add(r->buf.data, pos0)
    let p8: uint8* = uint8*(p)
    # Defensive: `uint8` may be represented as signed on some backends.
    let v: int32 = int32(*p8) & 255
    r->pos = pos0 + 1
    return v

fn driver_cacheReadU32(cr: DriverCacheReader*): uint32 =
    let b0: uint32 = uint32(driver_cacheReadU8(cr))
    let b1: uint32 = uint32(driver_cacheReadU8(cr))
    let b2: uint32 = uint32(driver_cacheReadU8(cr))
    let b3: uint32 = uint32(driver_cacheReadU8(cr))
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn driver_cacheReadU64(cr: DriverCacheReader*): uint64 =
    # Ensure zero-extension even if `uint32` is represented as signed.
    let lo: uint64 = uint64(driver_cacheReadU32(cr)) & uint64(0xFFFFFFFF)
    let hi: uint64 = uint64(driver_cacheReadU32(cr)) & uint64(0xFFFFFFFF)
    return lo | (hi << 32)

fn driver_cacheReadI32(cr: DriverCacheReader*): int32 =
    return int32(driver_cacheReadU32(cr))

fn driver_cacheReadI64(cr: DriverCacheReader*): int64 =
    return int64(driver_cacheReadU64(cr))

fn driver_cacheReadBool(cr: DriverCacheReader*): bool =
    return driver_cacheReadU8(cr) != 0

fn driver_cacheReadStringBytes(cr: DriverCacheReader*, n: int32): str =
    if cr == nil || !cr->ok || cr->r == nil:
        return ""
    if n < 0:
        cr->ok = false
        return ""
    let r: bytes.ByteReader* = cr->r
    let pos0: int32 = r->pos
    if pos0 + n > r->buf.len:
        cr->ok = false
        return ""
    let s: str = newString(n)
    if n > 0:
        copyMem(void*(s), ptr_add(r->buf.data, pos0), n)
    r->pos = pos0 + n
    return s

fn driver_cacheReadStringTable(cr: DriverCacheReader*): str[] =
    if cr == nil:
        var outNil: str[]
        return outNil
    let countU: uint32 = driver_cacheReadU32(cr)
    let count: int32 = int32(countU)
    if count <= 0 || count > 200000000:
        cr->ok = false
        var outBad: str[]
        return outBad
    var out: str[count]
    out.len = int(count)
    for i in 0..<count:
        let n: int32 = int32(driver_cacheReadU32(cr))
        let s: str = driver_cacheReadStringBytes(cr, n)
        out[i] = s
    return out

fn driver_cacheGetStr(strings: str[], idx: int32): str =
    if idx <= 0:
        return ""
    if idx < 0 || idx >= strings.len:
        return ""
    return strings[idx]

fn driver_cacheReadType(cr: DriverCacheReader*): MirType =
    var t: MirType
    t.kind = MirTypeKind(driver_cacheReadU8(cr))
    t.isUnsigned = driver_cacheReadBool(cr)
    return t

fn driver_cacheReadExpr(cr: DriverCacheReader*, strings: str[]): MirExpr =
    if driver_cacheReadU8(cr) == 0:
        return nil
    var e: MirExpr
    new e
    e.kind = MirExprKind(driver_cacheReadU8(cr))
    e.value = driver_cacheReadI64(cr)
    e.binOp = MirBinOp(driver_cacheReadU8(cr))
    e.cmpOp = MirCmpOp(driver_cacheReadU8(cr))
    e.lhs = driver_cacheReadExpr(cr, strings)
    e.rhs = driver_cacheReadExpr(cr, strings)
    e.localIndex = driver_cacheReadI32(cr)
    e.callee = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    let argc: int32 = int32(driver_cacheReadU32(cr))
    e.args = []
    for i in 0..<argc:
        add(e.args, driver_cacheReadExpr(cr, strings))
    e.castType = driver_cacheReadType(cr)
    e.castExpr = driver_cacheReadExpr(cr, strings)
    e.addrExpr = driver_cacheReadExpr(cr, strings)
    e.loadType = driver_cacheReadType(cr)
    e.globalName = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    return e

fn driver_cacheReadStmt(cr: DriverCacheReader*, strings: str[]): MirStmt =
    var s: MirStmt
    s.kind = MirStmtKind(driver_cacheReadU8(cr))
    s.name = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    s.slot = driver_cacheReadI32(cr)
    s.expr = driver_cacheReadExpr(cr, strings)
    s.paramIndex = driver_cacheReadI32(cr)
    s.addrExpr = driver_cacheReadExpr(cr, strings)
    s.storeType = driver_cacheReadType(cr)
    return s

fn driver_cacheReadTerm(cr: DriverCacheReader*, strings: str[]): MirTerm =
    var t: MirTerm
    t.kind = MirTermKind(driver_cacheReadU8(cr))
    t.retExpr = driver_cacheReadExpr(cr, strings)
    t.condExpr = driver_cacheReadExpr(cr, strings)
    t.target = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    t.targetTrue = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    t.targetFalse = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    return t

fn driver_cacheReadBlock(cr: DriverCacheReader*, strings: str[]): MirBlock =
    if driver_cacheReadU8(cr) == 0:
        return nil
    var b: MirBlock
    new b
    b.label = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    let n: int32 = int32(driver_cacheReadU32(cr))
    b.stmts = []
    for i in 0..<n:
        add(b.stmts, driver_cacheReadStmt(cr, strings))
    b.term = driver_cacheReadTerm(cr, strings)
    return b

fn driver_cacheReadFunc(cr: DriverCacheReader*, strings: str[]): MirFunc =
    if driver_cacheReadU8(cr) == 0:
        return nil
    var f: MirFunc
    new f
    f.name = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    f.linkName = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    f.originFile = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    f.isExtern = driver_cacheReadBool(cr)
    f.retType = driver_cacheReadType(cr)
    f.retTypeKey = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    let pn: int32 = int32(driver_cacheReadU32(cr))
    f.params = []
    for i in 0..<pn:
        var p: MirParam
        p.name = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        p.slot = driver_cacheReadI32(cr)
        p.ty = driver_cacheReadType(cr)
        p.typeKey = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        add(f.params, p)
    let ln: int32 = int32(driver_cacheReadU32(cr))
    f.localTypes = []
    for li in 0..<ln:
        add(f.localTypes, driver_cacheReadType(cr))
    let on: int32 = int32(driver_cacheReadU32(cr))
    f.objLocals = []
    for oi in 0..<on:
        var ol: MirObjLocal
        ol.slot = driver_cacheReadI32(cr)
        ol.objTypeName = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        ol.typeKey = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        ol.frameOff = driver_cacheReadI32(cr)
        add(f.objLocals, ol)
    f.objFrameSize = driver_cacheReadI32(cr)
    let bn: int32 = int32(driver_cacheReadU32(cr))
    f.blocks = []
    for bi in 0..<bn:
        add(f.blocks, driver_cacheReadBlock(cr, strings))
    return f

fn driver_cacheReadModule(cr: DriverCacheReader*, strings: str[]): MirModule =
    if driver_cacheReadU8(cr) == 0:
        return nil
    let target: str = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
    let module: MirModule = mirNewModule(target)
    let fnCount: int32 = int32(driver_cacheReadU32(cr))
    for i in 0..<fnCount:
        add(module.funcs, driver_cacheReadFunc(cr, strings))
    let cCount: int32 = int32(driver_cacheReadU32(cr))
    for ci in 0..<cCount:
        var c: MirCString
        c.label = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        c.value = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        add(module.cstrs, c)
    let gCount: int32 = int32(driver_cacheReadU32(cr))
    for gi in 0..<gCount:
        var g: MirGlobal
        g.name = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        g.ty = driver_cacheReadType(cr)
        g.init = driver_cacheReadI64(cr)
        g.hasInit = driver_cacheReadBool(cr)
        g.originFile = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        add(module.globals, g)
    let aCount: int32 = int32(driver_cacheReadU32(cr))
    for ai in 0..<aCount:
        var a: MirTypeAlias
        a.name = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        a.ty = driver_cacheReadType(cr)
        add(module.typeAliases, a)
    let tCount: int32 = int32(driver_cacheReadU32(cr))
    for ti in 0..<tCount:
        var ot: MirObjType
        ot.name = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        ot.size = driver_cacheReadI32(cr)
        ot.alignPow2 = driver_cacheReadI32(cr)
        ot.fields = []
        let fieldCount: int32 = int32(driver_cacheReadU32(cr))
        for j in 0..<fieldCount:
            var f2: MirObjField
            f2.name = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
            f2.ty = driver_cacheReadType(cr)
            f2.offset = driver_cacheReadI32(cr)
            add(ot.fields, f2)
        add(module.objTypes, ot)
    return module

fn driver_cacheReadUnitIndex(cr: DriverCacheReader*, strings: str[], module: MirModule): DriverUnitIndex =
    if driver_cacheReadU8(cr) == 0:
        return nil
    let fileCount: int32 = int32(driver_cacheReadU32(cr))
    var unitFiles: str[]
    for i in 0..<fileCount:
        add(unitFiles, driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr))))
    let funcRows: int32 = int32(driver_cacheReadU32(cr))
    var unitFuncIdx: DriverSeqSeqInt32
    for fi in 0..<funcRows:
        let n: int32 = int32(driver_cacheReadU32(cr))
        var row: int32[]
        for j in 0..<n:
            add(row, driver_cacheReadI32(cr))
        driver_addRowInt32(unitFuncIdx, row)
    let globalRows: int32 = int32(driver_cacheReadU32(cr))
    var unitGlobalIdx: DriverSeqSeqInt32
    for gi in 0..<globalRows:
        let n2: int32 = int32(driver_cacheReadU32(cr))
        var row2: int32[]
        for j2 in 0..<n2:
            add(row2, driver_cacheReadI32(cr))
        driver_addRowInt32(unitGlobalIdx, row2)
    let pairs: int32 = int32(driver_cacheReadU32(cr))
    var nameToFuncIdx: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(pairs * 2 + 8)
    for pi in 0..<pairs:
        let k: str = driver_cacheGetStr(strings, int32(driver_cacheReadU32(cr)))
        let v: int32 = driver_cacheReadI32(cr)
        if driver_strNonEmpty(k):
            hashmaps.hashMapStrIntPut(nameToFuncIdx, k, v)
    var out: DriverUnitIndex
    new out
    out.unitFiles = unitFiles
    var unitIndexMap: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(unitFiles.len * 2 + 8)
    for i in 0..<unitFiles.len:
        hashmaps.hashMapStrIntPut(unitIndexMap, unitFiles[i], i)
    out.unitIndex = unitIndexMap
    out.unitFuncIdx = unitFuncIdx
    out.unitGlobalIdx = unitGlobalIdx
    out.nameToFuncIdx = nameToFuncIdx
    return out

fn driver_loadModuleCache(path: str, expectedCompileStampHash: int64): Result[DriverModuleCache] =
    if driver_strIsEmpty(path) || !frontend_lib.stage1_fileExists(path):
        return Err[DriverModuleCache]("missing cache file: " + path)
    let fileBytes: bytes.ByteBuffer = bytes.readFileBytes(path)
    if fileBytes.data == nil || fileBytes.len <= 0:
        return Err[DriverModuleCache]("failed to read cache file: " + path)
    var cr: DriverCacheReader = driver_cacheReaderInit(fileBytes)
    let m0: int32 = driver_cacheReadU8(&cr)
    let m1: int32 = driver_cacheReadU8(&cr)
    let m2: int32 = driver_cacheReadU8(&cr)
    let m3: int32 = driver_cacheReadU8(&cr)
    if !(m0 == int32('C') && m1 == int32('H') && m2 == int32('M') && m3 == int32('C')):
        if fileBytes.data != nil:
            dealloc fileBytes.data
        return Err[DriverModuleCache]("invalid module cache (bad magic): " + path)
    let ver: uint32 = driver_cacheReadU32(&cr)
    if ver != uint32(2):
        if fileBytes.data != nil:
            dealloc fileBytes.data
        return Err[DriverModuleCache]("invalid module cache (version): " + path)
    let compileStampHash: int64 = driver_cacheReadI64(&cr)
    if expectedCompileStampHash != int64(0) && compileStampHash != expectedCompileStampHash:
        if fileBytes.data != nil:
            dealloc fileBytes.data
        return Err[DriverModuleCache]("stale module cache (compile_stamp): " + path +
                                      " expected=" + frontend_lib.stage1_int64ToStr(expectedCompileStampHash) +
                                      " got=" + frontend_lib.stage1_int64ToStr(compileStampHash))
    let unitFileCount: int32 = int32(driver_cacheReadU32(&cr))
    var headerUnitFiles: str[]
    var headerUnitHashes: int64[]
    var ui: int32 = 0
    while cr.ok && ui < unitFileCount:
        let n: int32 = int32(driver_cacheReadU32(&cr))
        let fp: str = driver_cacheReadStringBytes(&cr, n)
        let h: int64 = driver_cacheReadI64(&cr)
        add(headerUnitFiles, fp)
        add(headerUnitHashes, h)
        ui = ui + 1
    if cr.ok && headerUnitFiles.len > 0:
        let curHashes: int64[] = driver_buildUnitFileStateHashes(headerUnitFiles)
        if curHashes.len != headerUnitHashes.len:
            if fileBytes.data != nil:
                dealloc fileBytes.data
            return Err[DriverModuleCache]("stale module cache (unit_list): " + path)
        else:
            ui = 0
            let __for_start_ui_1 = ui
            for __for_ui_1 in __for_start_ui_1..<curHashes.len:
                ui = __for_ui_1
                if curHashes[ui] != headerUnitHashes[ui]:
                    if fileBytes.data != nil:
                        dealloc fileBytes.data
                    return Err[DriverModuleCache]("stale module cache (sources): " + path)
                ui = ui + 1
    let strings: str[] = driver_cacheReadStringTable(&cr)
    let module: MirModule = driver_cacheReadModule(&cr, strings)
    let idx: DriverUnitIndex = driver_cacheReadUnitIndex(&cr, strings, module)
    if fileBytes.data != nil:
        dealloc fileBytes.data
    if !cr.ok || module == nil || idx == nil:
        return Err[DriverModuleCache]("invalid module cache (corrupt): " + path)
    var out: DriverModuleCache
    new out
    out.module = void*(module)
    out.unitFiles = idx.unitFiles
    out.unitFuncIdx = idx.unitFuncIdx
    out.unitGlobalIdx = idx.unitGlobalIdx
    out.nameToFuncIdx = idx.nameToFuncIdx
    return Ok[DriverModuleCache](out)

fn driver_moduleCacheToUnitIndex(cache: DriverModuleCache): DriverUnitIndex =
    if cache == nil:
        return nil
    var out: DriverUnitIndex
    new out
    out.unitFiles = cache.unitFiles
    var unitIndexMap: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(cache.unitFiles.len * 2 + 8)
    for i in 0..<cache.unitFiles.len:
        hashmaps.hashMapStrIntPut(unitIndexMap, cache.unitFiles[i], i)
    out.unitIndex = unitIndexMap
    out.unitFuncIdx = cache.unitFuncIdx
    out.unitGlobalIdx = cache.unitGlobalIdx
    out.nameToFuncIdx = cache.nameToFuncIdx
    return out

fn driver_buildUnitModuleFromIndex(full: MirModule, filePath: str, unitIdx: int32, idx: DriverUnitIndex): MirModule =
    let unit: MirModule = mirNewModule(full.target)
    unit.typeAliases = full.typeAliases
    unit.objTypes = full.objTypes
    let includeShared: bool = driver_isSharedUnitFile(filePath)

    if idx != nil && unitIdx >= 0 && unitIdx < idx.unitGlobalIdx.len:
        let globalsIdx: int32[] = driver_getRowInt32(idx.unitGlobalIdx, unitIdx)
        for gi in 0..<globalsIdx.len:
            let gIdx: int32 = globalsIdx[gi]
            if gIdx >= 0 && gIdx < full.globals.len:
                add(unit.globals, full.globals[gIdx])

    var funcsIdx: int32[]
    if idx != nil && unitIdx >= 0 && unitIdx < idx.unitFuncIdx.len:
        funcsIdx = driver_getRowInt32(idx.unitFuncIdx, unitIdx)

    var neededExternNames: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(funcsIdx.len * 8 + 16)
    var neededGlobalNames: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(funcsIdx.len * 8 + 16)

    for fi in 0..<funcsIdx.len:
        let fIdx: int32 = funcsIdx[fi]
        if fIdx >= 0 && fIdx < full.funcs.len:
            let f: MirFunc = full.funcs[fIdx]
            if f != nil && !f.isExtern:
                mirAddFunc(unit, f)
                driver_collectFuncCallNames(f, neededExternNames)
                driver_collectFuncGlobalNames(f, neededGlobalNames)

    for ci in 0..<full.cstrs.len:
        let c: MirCString = full.cstrs[ci]
        var useCstr: bool = false
        if driver_strNonEmpty(c.label):
            let _seenCstr0: int32 = hashmaps.hashMapStrIntGetEx(neededGlobalNames, c.label, useCstr)
        if useCstr:
            add(unit.cstrs, c)

    var needExternByIdx: bool[full.funcs.len]
    needExternByIdx.len = full.funcs.len
    var si: int32 = 0
    while idx != nil && si < neededExternNames.keys.len:
        let callee: str = neededExternNames.keys[si]
        if driver_strNonEmpty(callee):
            var foundSrc: bool = false
            let srcIdx: int32 = hashmaps.hashMapStrIntGetEx(idx.nameToFuncIdx, callee, foundSrc)
            if foundSrc && srcIdx >= 0 && srcIdx < needExternByIdx.len:
                let srcFunc: MirFunc = full.funcs[srcIdx]
                if srcFunc != nil:
                    if srcFunc.isExtern:
                        needExternByIdx[srcIdx] = true
                    else:
                        let ownSrc: bool = (srcFunc.originFile == filePath)
                        let sharedSrc: bool = includeShared && (driver_strIsEmpty(srcFunc.originFile))
                        if ! (ownSrc || sharedSrc):
                            needExternByIdx[srcIdx] = true
        si = si + 1

    fi = 0
    let __for_start_fi_2 = fi
    for __for_fi_2 in __for_start_fi_2..<needExternByIdx.len:
        fi = __for_fi_2
        if needExternByIdx[fi]:
            let srcFunc2: MirFunc = full.funcs[fi]
            if srcFunc2 != nil:
                mirAddFunc(unit, driver_cloneExternFunc(srcFunc2))
        fi = fi + 1

    return unit

fn driver_buildUnitModule(full: MirModule, filePath: str): MirModule =
    let unit: MirModule = mirNewModule(full.target)
    unit.typeAliases = full.typeAliases
    unit.objTypes = full.objTypes
    let includeShared: bool = driver_isSharedUnitFile(filePath)
    var neededExternNames: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(full.funcs.len * 2 + 8)
    var neededGlobalNames: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(full.cstrs.len * 2 + 8)
    var nameToFuncIdx: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(full.funcs.len * 2 + 8)

    for gi in 0..<full.globals.len:
        let g: MirGlobal = full.globals[gi]
        let ownGlobal: bool = (g.originFile == filePath)
        let sharedGlobal: bool = includeShared && (driver_strIsEmpty(g.originFile))
        if ownGlobal || sharedGlobal:
            add(unit.globals, g)

    for fi in 0..<full.funcs.len:
        let f: MirFunc = full.funcs[fi]
        if f != nil:
            if driver_strNonEmpty(f.name):
                var nameExists: bool = false
                let _seenFuncName: int32 = hashmaps.hashMapStrIntGetEx(nameToFuncIdx, f.name, nameExists)
                if ! nameExists:
                    hashmaps.hashMapStrIntPut(nameToFuncIdx, f.name, fi)
            if ! f.isExtern:
                let ownFunc: bool = (f.originFile == filePath)
                let sharedFunc: bool = includeShared && (driver_strIsEmpty(f.originFile))
                if ownFunc || sharedFunc:
                    mirAddFunc(unit, f)
                    driver_collectFuncCallNames(f, neededExternNames)
                    driver_collectFuncGlobalNames(f, neededGlobalNames)

    for ci in 0..<full.cstrs.len:
        let c: MirCString = full.cstrs[ci]
        var useCstr: bool = false
        if driver_strNonEmpty(c.label):
            let _seenCstr1: int32 = hashmaps.hashMapStrIntGetEx(neededGlobalNames, c.label, useCstr)
        if useCstr:
            add(unit.cstrs, c)

    var needExternByIdx: bool[full.funcs.len]
    needExternByIdx.len = full.funcs.len
    for si in 0..<neededExternNames.keys.len:
        let callee: str = neededExternNames.keys[si]
        if driver_strNonEmpty(callee):
            var foundSrc: bool = false
            let srcIdx: int32 = hashmaps.hashMapStrIntGetEx(nameToFuncIdx, callee, foundSrc)
            if foundSrc && srcIdx >= 0 && srcIdx < needExternByIdx.len:
                let srcFunc: MirFunc = full.funcs[srcIdx]
                if srcFunc != nil:
                    if srcFunc.isExtern:
                        needExternByIdx[srcIdx] = true
                    else:
                        let ownSrc: bool = (srcFunc.originFile == filePath)
                        let sharedSrc: bool = includeShared && (driver_strIsEmpty(srcFunc.originFile))
                        if ! (ownSrc || sharedSrc):
                            needExternByIdx[srcIdx] = true

    for fi2 in 0..<needExternByIdx.len:
        if needExternByIdx[fi2]:
            let srcFunc2: MirFunc = full.funcs[fi2]
            if srcFunc2 != nil:
                mirAddFunc(unit, driver_cloneExternFunc(srcFunc2))

    return unit

fn driver_isDeclOnlyExternName(name: str): bool =
    if driver_strIsEmpty(name):
        return false
    if driver_strHasPrefix(name, "SystemFunction") ||
       driver_strHasPrefix(name, "ExternFunction"):
        return true
    if driver_strHasPrefix(name, "cheng_") ||
       driver_strHasPrefix(name, "async") ||
       driver_strHasPrefix(name, "chan") ||
       driver_strHasPrefix(name, "sched"):
        return true
    if driver_strEq(name, "__addr") || driver_strEq(name, "_addr"):
        return true
    if driver_strEq(name, "get_stderr") || driver_strEq(name, "get_stdout") || driver_strEq(name, "get_stdin"):
        return true
    return false

fn driver_promoteDeclOnlyExternFuncs(module: MirModule): int32 =
    if module == nil:
        return 0
    let debugPromote: bool = driver_envIsTrue("CHENG_BACKEND_VALIDATE_DEBUG")
    let dbg: os.File = os.get_stderr()
    var calledByBody: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(module.funcs.len * 4 + 8)
    for fi in 0..<module.funcs.len:
        let funcWithBody: MirFunc = module.funcs[fi]
        if funcWithBody != nil && !funcWithBody.isExtern && funcWithBody.blocks.len > 0:
            driver_collectFuncCallNames(funcWithBody, calledByBody)
    var patched: int32 = 0
    for i in 0..<module.funcs.len:
        let f: MirFunc = module.funcs[i]
        if f == nil:
            continue
        var called: bool = false
        if driver_strNonEmpty(f.name):
            let _seenCalledByBody: int32 = hashmaps.hashMapStrIntGetEx(calledByBody, f.name, called)
        if debugPromote && !f.isExtern && f.blocks.len == 0:
            os.writeLine(dbg, "backend_driver: decl-only candidate name=" + f.name +
                          " link=" + (f.linkName == nil ? "" : f.linkName) +
                          " called=" + (called ? "1" : "0"))
        if f.isExtern || f.blocks.len > 0:
            continue
        let shouldPromote: bool = driver_isDeclOnlyExternName(f.name) || !called
        if shouldPromote:
            f.isExtern = true
            patched = patched + 1
    return patched

fn driver_moduleToLir(module: MirModule): LirModule =
    let opt2: bool = driver_strEq(os.getEnvDefault("CHENG_BACKEND_OPT2", ""), "1")
    let optDefault: int32 = opt2 ? 2 : (driver_strEq(os.getEnvDefault("CHENG_BACKEND_OPT", ""), "1") ? 1 : 0)
    let optLevel: int32 = driver_parseInt32Default(os.getEnvDefault("CHENG_BACKEND_OPT_LEVEL", ""), optDefault)
    if optLevel >= 1:
        mirOptimizeModule(module)
    let patchedExternDecls: int32 = driver_promoteDeclOnlyExternFuncs(module)
    if patchedExternDecls > 0 && driver_envIsTrue("CHENG_BACKEND_VALIDATE_DEBUG"):
        let f: os.File = os.get_stderr()
        os.writeLine(f, "backend_driver: promoted decl-only funcs to extern: " + intToStr(patchedExternDecls))
    if driver_strEq(os.getEnvDefault("CHENG_BACKEND_VALIDATE", ""), "1"):
        let vRes: Result[bool] = mirValidateModule(module)
        if ! IsOk[bool](vRes):
            driver_panicResult[bool](vRes)
    var lirRes: Result[LirModule]
    if driver_targetIsX86_64(module.target):
        lirRes = x86_64LowerModule(module)
    elif driver_targetIsRiscv64(module.target):
        lirRes = riscv64LowerModule(module)
    else:
        lirRes = aarch64LowerModule(module)
    if ! IsOk[LirModule](lirRes):
        driver_panicResult[LirModule](lirRes)
    let lir: LirModule = linearScanAssign(Value[LirModule](lirRes))
    return lir

fn driver_emitObjFromLir(lir: LirModule, target: str, objWriter: str): Result[uint8[]] =
    let dbgEmitPipe2: bool = driver_envIsTrue("CHENG_BACKEND_DEBUG_EMIT_PIPE")
    var dbgFile2: os.File = nil
    if dbgEmitPipe2:
        dbgFile2 = os.get_stderr()
        os.writeLine(dbgFile2, "[backend] emit_obj: enter")
        os.c_fflush dbgFile2
    var objRes: Result[uint8[]]
    if dbgEmitPipe2:
        os.writeLine(dbgFile2, "[backend] emit_obj: check_target")
        os.c_fflush dbgFile2
    if driver_targetIsX86_64(target):
        if dbgEmitPipe2:
            os.writeLine(dbgFile2, "[backend] emit_obj: target=x86_64")
            os.c_fflush dbgFile2
        var writer: str = objWriter
        if driver_strIsEmpty(writer):
            if driver_targetIsDarwin(target):
                writer = "macho"
            elif driver_targetIsWindows(target):
                writer = "coff"
            else:
                writer = "elf"
        if driver_strEq(writer, "macho"):
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: x86 writer=macho")
                os.c_fflush dbgFile2
            if !driver_targetIsDarwin(target):
                panic("backend_driver: x86_64 macho writer requires darwin target: " + target)
            objRes = machoWriteX86_64RelocatableObj(lir)
        elif driver_strEq(writer, "elf"):
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: x86 writer=elf")
                os.c_fflush dbgFile2
            if driver_targetIsDarwin(target) || driver_targetIsWindows(target):
                panic("backend_driver: x86_64 elf writer requires non-darwin, non-windows target: " + target)
            objRes = elfWriteX86_64RelocatableObj(lir)
        elif driver_strEq(writer, "coff"):
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: x86 writer=coff")
                os.c_fflush dbgFile2
            if !driver_targetIsWindows(target):
                panic("backend_driver: x86_64 coff writer requires windows target: " + target)
            objRes = coffWriteX86_64RelocatableObj(lir)
        else:
            panic("backend_driver: unsupported CHENG_BACKEND_OBJ_WRITER for x86_64: " + writer)
    elif driver_targetIsRiscv64(target):
        if dbgEmitPipe2:
            os.writeLine(dbgFile2, "[backend] emit_obj: target=riscv64")
            os.c_fflush dbgFile2
        if driver_strEq(objWriter, "elf") || driver_strIsEmpty(objWriter):
            if driver_targetIsDarwin(target) || driver_targetIsWindows(target):
                panic("backend_driver: riscv64 elf writer requires non-darwin, non-windows target: " + target)
            objRes = elfWriteRiscv64RelocatableObj(lir)
        else:
            panic("backend_driver: unsupported CHENG_BACKEND_OBJ_WRITER for riscv64: " + objWriter)
    else:
        if dbgEmitPipe2:
            os.writeLine(dbgFile2, "[backend] emit_obj: target=aarch64-like")
            os.c_fflush dbgFile2
        if driver_strEq(objWriter, "elf"):
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: aarch64 writer=elf")
                os.c_fflush dbgFile2
            objRes = elfWriteAarch64RelocatableObj(lir)
        elif driver_strEq(objWriter, "macho"):
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: aarch64 writer=macho")
                os.c_fflush dbgFile2
            objRes = machoWriteAarch64RelocatableObj(lir)
        elif driver_strEq(objWriter, "coff"):
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: aarch64 writer=coff")
                os.c_fflush dbgFile2
            objRes = coffWriteAarch64RelocatableObj(lir)
        elif driver_targetIsDarwin(target):
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: aarch64 auto=macho")
                os.c_fflush dbgFile2
            objRes = machoWriteAarch64RelocatableObj(lir)
        elif driver_targetIsWindows(target):
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: aarch64 auto=coff")
                os.c_fflush dbgFile2
            objRes = coffWriteAarch64RelocatableObj(lir)
        else:
            if dbgEmitPipe2:
                os.writeLine(dbgFile2, "[backend] emit_obj: aarch64 auto=elf")
                os.c_fflush dbgFile2
            objRes = elfWriteAarch64RelocatableObj(lir)
    if dbgEmitPipe2:
        os.writeLine(dbgFile2, "[backend] emit_obj: leave")
        os.c_fflush dbgFile2
    return objRes

fn driver_ensureParentDir(path: str) =
    if driver_strIsEmpty(path):
        return
    let parts: SplitFileResult = os.splitFile(path)
    if driver_strIsEmpty(parts.dir):
        return
    if ! os.dirExists(parts.dir):
        os.createDir(parts.dir)
    if ! os.dirExists(parts.dir):
        panic("backend_driver: failed to create output dir: " + parts.dir)

fn driver_emitObjFromModule(module: MirModule, target: str, objWriter: str, outPath: str) =
    driver_ensureParentDir(outPath)
    let dbgEmitPipe: bool = driver_envIsTrue("CHENG_BACKEND_DEBUG_EMIT_PIPE")
    var dbgFile: os.File = nil
    if dbgEmitPipe:
        dbgFile = os.get_stderr()
        os.writeLine(dbgFile, "[backend] emit: lir_start")
        os.c_fflush dbgFile
    let lir: LirModule = driver_moduleToLir(module)
    if dbgEmitPipe:
        os.writeLine(dbgFile, "[backend] emit: lir_done")
        os.c_fflush dbgFile
        os.writeLine(dbgFile, "[backend] emit: obj_start")
        os.c_fflush dbgFile
    let objRes: Result[uint8[]] = driver_emitObjFromLir(lir, target, objWriter)
    if dbgEmitPipe:
        os.writeLine(dbgFile, "[backend] emit: obj_done")
        os.c_fflush dbgFile
    if ! IsOk[uint8[]](objRes):
        driver_panicResult[uint8[]](objRes)
    let dbgObjMagic: bool = driver_envIsTrue("CHENG_BACKEND_DEBUG_OBJ_MAGIC")
    if dbgObjMagic:
        let dbgObj: uint8[] = Value[uint8[]](objRes)
        let fDbgObj: os.File = os.get_stderr()
        var b0: int32 = -1
        var b1: int32 = -1
        var b2: int32 = -1
        var b3: int32 = -1
        if dbgObj.len > 0:
            b0 = int32(dbgObj[0])
        if dbgObj.len > 1:
            b1 = int32(dbgObj[1])
        if dbgObj.len > 2:
            b2 = int32(dbgObj[2])
        if dbgObj.len > 3:
            b3 = int32(dbgObj[3])
        os.writeLine(fDbgObj, "backend_driver: obj_magic len=" + intToStr(dbgObj.len) +
                     " b0=" + intToStr(b0) + " b1=" + intToStr(b1) +
                     " b2=" + intToStr(b2) + " b3=" + intToStr(b3))
        os.c_fflush fDbgObj
    if dbgEmitPipe:
        os.writeLine(dbgFile, "[backend] emit: write_start")
        os.c_fflush dbgFile
    os.writeFileBytes(outPath, Value[uint8[]](objRes))
    if dbgEmitPipe:
        os.writeLine(dbgFile, "[backend] emit: write_done")
        os.c_fflush dbgFile
    if ! frontend_lib.stage1_fileExists(outPath):
        panic("backend_driver: failed to write object file: " + outPath)

fn driver_runParallelUnitBatchesFork(full: MirModule, unitIndex: DriverUnitIndex, target: str, objWriter: str,
                                     pendingUnits: str[], pendingObjs: str[], jobs: int32) =
    if full == nil || unitIndex == nil || pendingUnits.len == 0:
        return
    let workerCount: int32 = driver_parallelWorkerCount(pendingUnits.len, jobs)
    if workerCount <= 1:
        return

    var buckets: DriverSeqSeqInt32
    var empty: int32[]
    for wi in 0..<workerCount:
        driver_addRowInt32(buckets, empty)
    for pi in 0..<pendingUnits.len:
        let bucket: int32 = pi % workerCount
        var row: int32[] = driver_getRowInt32(buckets, bucket)
        add(row, pi)
        driver_setRowInt32(buckets, bucket, row)

    var pids: int64[]
    for wi in 0..<workerCount:
        let row2: int32[] = driver_getRowInt32(buckets, wi)
        if row2.len > 0:
            let pid: int64 = driver_c_fork()
            if pid == 0:
                for ri in 0..<row2.len:
                    let idx: int32 = row2[ri]
                    if idx >= 0 && idx < pendingUnits.len && idx < pendingObjs.len:
                        let fp: str = pendingUnits[idx]
                        let objPath: str = pendingObjs[idx]
                        var found: bool = false
                        let unitIdx: int32 = hashmaps.hashMapStrIntGetEx(unitIndex.unitIndex, fp, found)
                        if !found:
                            panic("backend_driver: unit file not found in module: " + fp)
                        let u: MirModule = driver_buildUnitModuleFromIndex(full, fp, unitIdx, unitIndex)
                        u.target = target
                        driver_emitObjFromModule(u, target, objWriter, objPath)
                system.exit 0
            if pid < 0:
                panic "backend_driver: fork failed"
            add(pids, pid)

    var status: int32 = 0
    for pi2 in 0..<pids.len:
        let pid2: int64 = pids[pi2]
        status = 0
        let waited: int64 = driver_c_waitpid(pid2, &status, 0)
        if waited != pid2:
            panic "backend_driver: waitpid failed"
        if (status & 127) != 0:
            panic "backend_driver: fork worker terminated by signal"
        let code: int32 = status >> 8
        if code != 0:
            panic("backend_driver: fork worker failed: exit_code=" + intToStr(code))

fn driver_moduleHasOwnSymbols(module: MirModule, filePath: str): bool =
    if module == nil || driver_strIsEmpty(filePath):
        return false
    let includeShared: bool = driver_isSharedUnitFile(filePath)
    for i in 0..<module.funcs.len:
        let f: MirFunc = module.funcs[i]
        if f != nil && !f.isExtern:
            if (f.originFile == filePath):
                return true
            if includeShared && (driver_strIsEmpty(f.originFile)):
                return true
    for i in 0..<module.globals.len:
        let g: MirGlobal = module.globals[i]
        if (g.originFile == filePath):
            return true
        if includeShared && (driver_strIsEmpty(g.originFile)):
            return true
    return false

fn driver_resolveUnitFile(module: MirModule, requested: str): str =
    if driver_strIsEmpty(requested):
        return ""
    let files: str[] = driver_collectUnitFiles(module)
    return driver_resolveUnitFileFromList(files, requested)

fn driver_resolveUnitFileFromList(unitFiles: str[], requested: str): str =
    if driver_strIsEmpty(requested):
        return ""
    if driver_seqContainsStr(unitFiles, requested):
        return requested
    let reqBase: str = os.extractFilename(requested)
    let reqTail: str = "/" + requested
    var found: str = ""
    for i in 0..<unitFiles.len:
        let cand: str = unitFiles[i]
        if (cand == requested):
            return cand
        if driver_strHasSuffix(cand, reqTail):
            return cand
        if (os.extractFilename(cand) == reqBase):
            if driver_strIsEmpty(found):
                found = cand
            else:
                panic("backend_driver: ambiguous unit file: " + requested)
    if driver_strNonEmpty(found):
        return found
    return ""

fn driver_linkExeObjects(objPaths: str[], target: str, linker: str, linkerSymtabAll: bool,
                         ldCmd: str, cflags: str, ldflags: str,
                         outputPath: str, runtimeObj: str, runtimeC: str, noRuntimeC: bool) =
    if objPaths.len == 0:
        panic "backend_driver: no object files to link"
    if driver_strEq(linker, "self"):
        var linkObjs: str[]
        for i in 0..<objPaths.len:
            add(linkObjs, objPaths[i])
        if len(runtimeObj) > 0:
            if ! frontend_lib.stage1_fileExists(runtimeObj):
                panic("backend_driver: runtime obj not found: " + runtimeObj)
            add(linkObjs, runtimeObj)
        elif ! noRuntimeC && frontend_lib.stage1_fileExists(runtimeC):
            panic("backend_driver: self linker requires CHENG_BACKEND_RUNTIME_OBJ (runtime C unsupported): " + runtimeC)
        if driver_targetIsDarwin(target) && driver_targetIsAarch64(target):
            let linkRes: Result[bool] = machoLinkExeAarch64(linkObjs, outputPath, linkerSymtabAll)
            if ! IsOk[bool](linkRes):
                driver_panicResult[bool](linkRes)
            driver_runCmd("chmod +x " + driver_shellQuote(outputPath))
            if !driver_strEq(os.getEnvDefault("CHENG_BACKEND_CODESIGN", "1"), "0"):
                driver_runCmd("codesign -s - " + driver_shellQuote(outputPath))
            return
        if driver_targetIsDarwin(target) && driver_targetIsX86_64(target):
            let linkRes: Result[bool] = machoLinkExeX86_64(linkObjs, outputPath, linkerSymtabAll)
            if ! IsOk[bool](linkRes):
                driver_panicResult[bool](linkRes)
            driver_runCmd("chmod +x " + driver_shellQuote(outputPath))
            if !driver_strEq(os.getEnvDefault("CHENG_BACKEND_CODESIGN", "1"), "0"):
                driver_runCmd("codesign -s - " + driver_shellQuote(outputPath))
            return
        if driver_targetIsWindows(target) && driver_targetIsAarch64(target):
            let linkRes: Result[bool] = coffLinkExeAarch64(linkObjs, outputPath, target)
            if ! IsOk[bool](linkRes):
                driver_panicResult[bool](linkRes)
            return
        if !driver_targetIsWindows(target) && !driver_targetIsDarwin(target) && driver_targetIsRiscv64(target):
            let linkRes: Result[bool] = elfLinkExeRiscv64(linkObjs, outputPath, target)
            if ! IsOk[bool](linkRes):
                driver_panicResult[bool](linkRes)
            driver_runCmd("chmod +x " + driver_shellQuote(outputPath))
            return
        if !driver_targetIsWindows(target) && driver_targetIsAarch64(target):
            let linkRes: Result[bool] = elfLinkExeAarch64(linkObjs, outputPath, target)
            if ! IsOk[bool](linkRes):
                driver_panicResult[bool](linkRes)
            driver_runCmd("chmod +x " + driver_shellQuote(outputPath))
            return
        panic("backend_driver: self linker unsupported target: " + target)

    var linkCmd: str = ldCmd
    for i2 in 0..<objPaths.len:
        linkCmd = linkCmd + " " + driver_shellQuote(objPaths[i2])
    if len(runtimeObj) > 0:
        if ! frontend_lib.stage1_fileExists(runtimeObj):
            panic("backend_driver: runtime obj not found: " + runtimeObj)
        linkCmd = linkCmd + " " + driver_shellQuote(runtimeObj)
    elif ! noRuntimeC && frontend_lib.stage1_fileExists(runtimeC):
        linkCmd = linkCmd + " " + driver_shellQuote(runtimeC)
    if len(cflags) > 0:
        linkCmd = linkCmd + " " + cflags
    linkCmd = linkCmd + " -o " + driver_shellQuote(outputPath)
    if len(ldflags) > 0:
        linkCmd = linkCmd + " " + ldflags
    driver_runCmd(linkCmd)

fn driver_loadObjectList(path: str): str[] =
    var out: str[]
    if driver_strIsEmpty(path):
        return out
    if ! frontend_lib.stage1_fileExists(path):
        panic("backend_driver: object list not found: " + path)
    let content: str = os.readFile(path)
    if driver_strIsEmpty(content):
        return out
    let n: int32 = len(content)
    var start: int32 = 0
    for i in 0..n:
        if i == n || content[i] == '\n':
            if i > start:
                let lineRaw: str = os.sliceStr(content, start, i - 1)
                let line: str = driver_trimAsciiSpace(lineRaw)
                if driver_strNonEmpty(line):
                    if line[0] != '#':
                        add(out, line)
            start = i + 1
    return out

fn driver_loadUnitBatchPairs(path: str): str[] =
    var out: str[]
    if driver_strIsEmpty(path):
        return out
    if ! frontend_lib.stage1_fileExists(path):
        panic("backend_driver: unit batch file not found: " + path)
    let content: str = os.readFile(path)
    if driver_strIsEmpty(content):
        return out
    let n: int32 = len(content)
    var start: int32 = 0
    for i in 0..n:
        if i == n || content[i] == '\n':
            if i > start:
                let rawLine: str = os.sliceStr(content, start, i - 1)
                let line: str = driver_trimAsciiSpace(rawLine)
                if driver_strNonEmpty(line):
                    if line[0] != '#':
                        let ln: int32 = len(line)
                        var tabPos: int32 = -1
                        for ti in 0..<ln:
                            if line[ti] == '\t':
                                tabPos = ti
                                break
                        if tabPos <= 0 || tabPos >= ln - 1:
                            panic("backend_driver: invalid batch line (expect '<obj>\\t<unit>'): " + line)
                        let objPathRaw: str = os.sliceStr(line, 0, tabPos - 1)
                        let unitRaw: str = os.sliceStr(line, tabPos + 1, ln - 1)
                        let objPath: str = driver_trimAsciiSpace(objPathRaw)
                        let unitPath: str = driver_trimAsciiSpace(unitRaw)
                        if driver_strIsEmpty(objPath) || driver_strIsEmpty(unitPath):
                            panic("backend_driver: invalid batch line (empty obj/unit): " + line)
                        add(out, objPath)
                        add(out, unitPath)
            start = i + 1
    return out

fn driver_pruneObjDirArtifacts(objDir: str, keepObjPath: str, keepStampPath: str) =
    if driver_strIsEmpty(objDir):
        return
    let pruneCmd: str = "set +e\n" +
                        "obj_dir=" + driver_shellQuote(objDir) + "\n" +
                        "keep_obj=" + driver_shellQuote(keepObjPath) + "\n" +
                        "keep_stamp=" + driver_shellQuote(keepStampPath) + "\n" +
                        "for f in \"$obj_dir\"/*.o \"$obj_dir\"/*.o.stamp; do\n" +
                        "  [ -f \"$f\" ] || continue\n" +
                        "  if [ \"$f\" = \"$keep_obj\" ] || [ \"$f\" = \"$keep_stamp\" ]; then\n" +
                        "    continue\n" +
                        "  fi\n" +
                        "  rm -f \"$f\"\n" +
                        "done\n"
    driver_runCmd(pruneCmd)

fn backendMain(): int32 =
    var profile: DriverProfileState = driver_profileInit(driver_envBoolDefault("CHENG_BACKEND_PROFILE", false))
    var inputPath: str = os.getEnvDefault("CHENG_BACKEND_INPUT", "")
    var outputPath: str = os.getEnvDefault("CHENG_BACKEND_OUTPUT", "")
    var emitMode: str = os.getEnvDefault("CHENG_BACKEND_EMIT", "obj")
    var target: str = os.getEnvDefault("CHENG_BACKEND_TARGET", "auto")
    var frontend: str = os.getEnvDefault("CHENG_BACKEND_FRONTEND", "mvp")
    var ccCmd: str = os.getEnvDefault("CHENG_BACKEND_CC", "cc")
    var ccExplicit: bool = false
    if len(os.getEnvDefault("CHENG_BACKEND_CC", "")) > 0:
        ccExplicit = true
    var ldCmd: str = os.getEnvDefault("CHENG_BACKEND_LD", "")
    var ldExplicit: bool = false
    if len(os.getEnvDefault("CHENG_BACKEND_LD", "")) > 0:
        ldExplicit = true
    var cflags: str = os.getEnvDefault("CHENG_BACKEND_CFLAGS", "")
    var ldflags: str = os.getEnvDefault("CHENG_BACKEND_LDFLAGS", "")
    var linker: str = os.getEnvDefault("CHENG_BACKEND_LINKER", "")
    var linkerSymtab: str = os.getEnvDefault("CHENG_BACKEND_LINKER_SYMTAB", "")
    var objWriter: str = os.getEnvDefault("CHENG_BACKEND_OBJ_WRITER", "")
    let elfProfile: str = os.getEnvDefault("CHENG_BACKEND_ELF_PROFILE", "")
    if linker == nil:
        linker = ""
    var multi: bool = driver_envBoolDefault("CHENG_BACKEND_MULTI", true)
    var multiLto: bool = driver_envBoolDefault("CHENG_BACKEND_MULTI_LTO", false)
    var incremental: bool = driver_envBoolDefault("CHENG_BACKEND_INCREMENTAL", true)
    var jobs: int32 = driver_parseInt32Default(os.getEnvDefault("CHENG_BACKEND_JOBS", ""), 0)
    var unitFile: str = os.getEnvDefault("CHENG_BACKEND_UNIT_FILE", "")
    var unitBatchFile: str = os.getEnvDefault("CHENG_BACKEND_UNIT_BATCH_FILE", "")
    var moduleCachePath: str = os.getEnvDefault("CHENG_BACKEND_MODULE_CACHE", "")
    var linkObjsFile: str = os.getEnvDefault("CHENG_BACKEND_LINK_OBJS", "")
    var allowNoMain: bool = driver_envBoolDefault("CHENG_BACKEND_ALLOW_NO_MAIN", false)
    var wholeProgram: bool = driver_envBoolDefault("CHENG_BACKEND_WHOLE_PROGRAM", true)
    var skipGlobalInit: bool = driver_envBoolDefault("CHENG_BACKEND_SKIP_GLOBAL_INIT", false)
    var runtimeObj: str = os.getEnvDefault("CHENG_BACKEND_RUNTIME_OBJ", "")
    var runtimeC: str = os.getEnvDefault("CHENG_BACKEND_RUNTIME_C", "src/runtime/native/system_helpers.c")
    var noRuntimeC: bool = driver_envBoolDefault("CHENG_BACKEND_NO_RUNTIME_C", false)
    var androidApi: int32 = driver_parseInt32Default(os.getEnvDefault("CHENG_ANDROID_API", ""), 21)
    var abi: str = lowerAscii(driver_trimAsciiSpace(os.getEnvDefault("CHENG_ABI", "")))
    if driver_strIsEmpty(abi):
        abi = "v1"
    elif !driver_strEq(abi, "v1") && !driver_strEq(abi, "v2_noptr"):
        panic("backend_driver: unsupported CHENG_ABI (expected v1 or v2_noptr): " + abi)
    if len(inputPath) == 0:
        inputPath = os.getEnvDefault("CHENG_BACKEND_INPUT", "")
    if len(outputPath) == 0:
        outputPath = os.getEnvDefault("CHENG_BACKEND_OUTPUT", "")
    driver_profileStep(profile, "parse_args")
    if driver_strIsEmpty(emitMode):
        emitMode = "obj"
    if driver_strIsEmpty(target) || driver_strEq(target, "auto"):
        target = driver_detectHostTargetAuto()
    if driver_strIsEmpty(target):
        panic("backend_driver: auto target detect failed; pass --target=<triple> or set CHENG_BACKEND_TARGET")
    if !driver_strEq(emitMode, "obj") && !driver_strEq(emitMode, "exe"):
        panic "backend_driver: invalid emit mode"

    if driver_strEq(emitMode, "exe") && driver_strEq(elfProfile, "nolibc"):
        if !(driver_strEq(linker, "self") &&
             driver_targetIsAarch64(target) &&
             driver_targetIsLinux(target) &&
             !driver_targetIsDarwin(target) &&
             !driver_targetIsWindows(target)):
            panic("backend_driver: CHENG_BACKEND_ELF_PROFILE=nolibc requires self-link on linux aarch64 target: " + target)

    let intBitsRaw: str = os.getEnvDefault("CHENG_INTBITS", "")
    if driver_strNonEmpty(intBitsRaw):
        let intBits: int32 = driver_parseInt32Default(intBitsRaw, -1)
        if intBits != 32 && intBits != 64:
            panic "backend_driver: unsupported CHENG_INTBITS (expected 32 or 64)"

    if !driver_targetIsAarch64(target) && !driver_targetIsX86_64(target) && !driver_targetIsRiscv64(target):
        panic("backend_driver: unsupported CHENG_BACKEND_TARGET (expected aarch64/arm64, x86_64, or riscv64): " + target)

    if driver_targetIsAndroid(target):
        if !ccExplicit && driver_strEq(ccCmd, "cc"):
            let ndkCc: str = driver_defaultAndroidNdkClang(androidApi)
            if driver_strNonEmpty(ndkCc):
                ccCmd = ndkCc
        if !ldExplicit && (driver_strIsEmpty(ldCmd)):
            ldCmd = ccCmd
        if len(cflags) == 0:
            cflags = "-fPIE"
        if len(ldflags) == 0:
            ldflags = "-fPIE -pie"
        ldflags = driver_flagsAppendToken(ldflags, "-lm")

    if driver_targetIsDarwin(target) && driver_targetIsX86_64(target):
        # Ensure the system toolchain links the right arch on Apple Silicon.
        cflags = driver_flagsAppendToken(cflags, "-arch")
        cflags = driver_flagsAppendToken(cflags, "x86_64")
    if driver_strIsEmpty(ldCmd):
        ldCmd = ccCmd
    if jobs <= 0:
        jobs = driver_detectHostJobsAuto()
    if jobs <= 0:
        jobs = 1
    driver_profileStep(profile, "config")

    let linkerSymtabAll: bool = driver_parseLinkerSymtabAll(linkerSymtab)

    # Fork-parallel avoids subprocesses rebuilding the full module. When fork
    # is disabled/unavailable, default to enabling module-cache so parallel
    # workers can reuse the parent-built module instead of rebuilding it.
    let forkDefault: bool = driver_strEq(frontend, "stage1")
    let allowForkParallel0: bool = driver_envBoolDefault("CHENG_BACKEND_MULTI_FORK", forkDefault)

    let compileStamp0: str = driver_buildObjCompileStamp(target, frontend, objWriter, inputPath,
                                                         allowNoMain, wholeProgram,
                                                         skipGlobalInit, multiLto, abi, driver_selfCompilerStamp())
    let compileStampHash0: int64 = mirFnv1a64(compileStamp0)

    if len(outputPath) == 0:
        if len(inputPath) == 0:
            panic "backend_driver: output path required"
        let parts: SplitFileResult = os.splitFile(inputPath)
        let base = driver_joinDir(parts.dir, parts.name)
        if driver_strEq(emitMode, "obj"):
            outputPath = base + ".o"
        else:
            outputPath = base
    let outParts: SplitFileResult = os.splitFile(outputPath)
    let outBase = driver_joinDir(outParts.dir, outParts.name)

    let moduleCacheDefault0: bool = driver_strEq(frontend, "stage1") || !allowForkParallel0
    let moduleCacheEnabled0: bool = driver_envBoolDefault("CHENG_BACKEND_MULTI_MODULE_CACHE", moduleCacheDefault0)
    if driver_strIsEmpty(moduleCachePath) && moduleCacheEnabled0 &&
       driver_strEq(emitMode, "exe") && multi:
        moduleCachePath = outBase + ".objs/.build.module.cache"

    if driver_strNonEmpty(linkObjsFile):
        if !driver_strEq(emitMode, "exe"):
            panic "backend_driver: CHENG_BACKEND_LINK_OBJS requires emit=exe"
        let objPathsFromList: str[] = driver_loadObjectList(linkObjsFile)
        if objPathsFromList.len == 0:
            panic("backend_driver: object list is empty: " + linkObjsFile)
        driver_profileStep(profile, "link_objs.load_list")
        driver_linkExeObjects(objPathsFromList, target, linker, linkerSymtabAll, ldCmd, cflags, ldflags,
                              outputPath, runtimeObj, runtimeC, noRuntimeC)
        driver_profileStep(profile, "link_objs.link")
        return 0

    var cache: DriverModuleCache = nil
    if driver_strNonEmpty(moduleCachePath):
        let cacheRes: Result[DriverModuleCache] = driver_loadModuleCache(moduleCachePath, compileStampHash0)
        if IsOk[DriverModuleCache](cacheRes):
            cache = Value[DriverModuleCache](cacheRes)
        else:
            if driver_envIsTrue("CHENG_BACKEND_MODULE_CACHE_DEBUG"):
                let f: os.File = os.get_stderr()
                let msg: str = ErrorFormat(ErrorInfoOf[DriverModuleCache](cacheRes))
                os.writeLine(f, "backend_driver: module cache miss: " + msg)
            elif driver_strNonEmpty(unitBatchFile) || driver_strNonEmpty(unitFile):
                let f: os.File = os.get_stderr()
                os.writeLine(f, "backend_driver: warning: failed to load module cache (fallback to build): " + moduleCachePath)
    driver_profileStep(profile, "module_cache.load")

    var moduleRes: Result[MirModule]
    if cache != nil:
        moduleRes = Ok[MirModule](MirModule(cache.module))
    elif len(inputPath) == 0:
        let demo: MirModule = mirDemoModule()
        moduleRes = Ok[MirModule](demo)
    else:
        if driver_strEq(frontend, "stage1"):
            moduleRes = mirBuildModuleFromFileStage1(inputPath)
        else:
            moduleRes = mirBuildModuleFromFile(inputPath)

    if ! IsOk[MirModule](moduleRes):
        driver_panicResult[MirModule](moduleRes)
    let mod: MirModule = Value[MirModule](moduleRes)
    if driver_strNonEmpty(target):
        mod.target = target
    if cache != nil:
        driver_profileStep(profile, "module_cache.loaded")
    else:
        driver_profileStep(profile, "build_module")

    if driver_strNonEmpty(unitBatchFile):
        panic "backend_driver: CHENG_BACKEND_UNIT_BATCH_FILE is disabled in bootstrap-compatible mode"

    if driver_strNonEmpty(unitFile):
        panic "backend_driver: CHENG_BACKEND_UNIT_FILE is disabled in bootstrap-compatible mode"

    if driver_strEq(emitMode, "exe") && multi:
        multi = false
    let objPath: str = driver_strEq(emitMode, "obj") ? outputPath : (outBase + ".o")
    driver_emitObjFromModule(mod, target, objWriter, objPath)
    driver_profileStep(profile, "single.emit_obj")
    if driver_strEq(emitMode, "exe"):
        var linkObjs2: str[]
        add(linkObjs2, objPath)
        driver_linkExeObjects(linkObjs2, target, linker, linkerSymtabAll, ldCmd, cflags, ldflags,
                              outputPath, runtimeObj, runtimeC, noRuntimeC)
        driver_profileStep(profile, "single.link")
    return 0

fn main(argc: int32, argv: str*): int32 =
    cmdline.__cheng_setCmdLine(argc, void*(argv))
    # Debug: stage0-compat built stage1 may crash in early runtime paths; allow a minimal
    # allocator/seq smoke to isolate miscompiles.
    if driver_strEq(os.getEnvDefault("CHENG_BACKEND_SELFTEST", ""), "1"):
        let f: os.File = os.get_stderr()
        os.writeLine(f, "selftest: seq<int32>")
        os.c_fflush f
        var xs: int32[]
        add(xs, 1)
        add(xs, 2)
        if xs.len != 2 || xs[0] != 1 || xs[1] != 2:
            panic "selftest: seq<int32> failed"

        os.writeLine(f, "selftest: seq<str>")
        os.c_fflush f
        var ss: str[]
        add(ss, "a")
        add(ss, "b")
        if ss.len != 2 || !driver_strEq(ss[0], "a") || !driver_strEq(ss[1], "b"):
            panic "selftest: seq<str> failed"

        os.writeLine(f, "selftest: seq<uint8>")
        os.c_fflush f
        var bs: uint8[]
        add(bs, uint8(0xCF))
        add(bs, uint8(0xFA))
        if bs.len != 2 || int32(bs[0]) != 207 || int32(bs[1]) != 250:
            panic "selftest: seq<uint8> failed"

        os.writeLine(f, "selftest: result<seq<uint8>>")
        os.c_fflush f
        let rb: Result[uint8[]] = Ok[uint8[]](bs)
        if !IsOk[uint8[]](rb):
            panic "selftest: result<seq<uint8>> not ok"
        let rv: uint8[] = Value[uint8[]](rb)
        if rv.len != 2 || int32(rv[0]) != 207 || int32(rv[1]) != 250:
            panic "selftest: result<seq<uint8>> value copy failed"

        os.writeLine(f, "selftest: seq<ptr>")
        os.c_fflush f
        var ps: ptr[]
        let marker: str = "ptr_ok"
        add(ps, void*(marker))
        if ps.len != 1:
            panic "selftest: seq<ptr> len failed"
        if str(ps[0]) != "ptr_ok":
            panic "selftest: seq<ptr> value failed"

        os.writeLine(f, "selftest: hashmap<str,int32>")
        os.c_fflush f
        os.writeLine(f, "selftest: hashmap.init")
        os.c_fflush f
        var m: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(16)
        os.writeLine(f, "selftest: hashmap.put")
        os.c_fflush f
        hashmaps.hashMapStrIntPut(m, "k1", 7)
        os.writeLine(f, "selftest: hashmap.get")
        os.c_fflush f
        var found: bool = false
        let v: int32 = hashmaps.hashMapStrIntGetEx(m, "k1", found)
        if !found || v != 7:
            panic "selftest: hashmap failed"

        os.writeLine(f, "selftest: seq<seq<int32>>")
        os.c_fflush f
        var rows: DriverSeqSeqInt32 = driver_newSeq2DInt(3)
        if rows.len != 3:
            panic "selftest: seq<seq<int32>> init failed"
        var r0: int32[] = driver_getRowInt32(rows, 0)
        add(r0, 9)
        driver_setRowInt32(rows, 0, r0)
        # Ensure nested-seq stores retain the inner buffer (no UAF after clearing the local copy).
        r0 = []
        let r0b: int32[] = driver_getRowInt32(rows, 0)
        if r0b.len != 1 || r0b[0] != 9:
            panic "selftest: seq<seq<int32>> update failed"
        let r1: int32[] = driver_getRowInt32(rows, 1)
        if r1.len != 0:
            panic "selftest: seq<seq<int32>> row alias"

        os.writeLine(f, "selftest: hashmap.value_copy")
        os.c_fflush f
        var mp: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(16)
        hashmaps.hashMapStrIntPut(mp, "k1", 7)
        var found2: bool = false
        let v2: int32 = hashmaps.hashMapStrIntGetEx(mp, "k1", found2)
        if !found2 || v2 != 7:
            panic "selftest: hashmap.value_copy failed"

        os.writeLine(f, "selftest: ok")
        os.c_fflush f
        return 0
    return backendMain()
