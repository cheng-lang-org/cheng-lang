                                           driver_copy_cstring_owned(targetRaw),
                                           driver_copy_cstring_owned(outputRaw),
                                           driver_copy_cstring_owned(linkerRaw))

fn driver_backendEmitIsObj(): bool =
    if driver_c_env_nonempty("BACKEND_EMIT") == 0:
        return false
    if driver_c_env_eq("BACKEND_EMIT", "exe") != 0:
        return false
    if driver_c_env_eq("BACKEND_EMIT", "obj") != 0:
        if driver_c_env_bool("BACKEND_INTERNAL_ALLOW_EMIT_OBJ", 0) != 0:
            return true
    driver_panic("backend_driver: invalid emit mode (expected exe)")
    return false

fn driver_backendEmitObjCore(mod: UirModule, outputPath: str, target: str): int32 =
    driver_bootMark(1)
    let rc: int32 = driver_emitObjFromModuleDefault(mod, target, outputPath)
    driver_bootMark(2)
    return rc

fn driver_backendFinishEmitObj(outputPath: str): int32 =
    return driver_c_finish_emit_obj(outputPath)

fn driver_backendTmpObjPath(outputPath: str): str =
    return outputPath + ".tmp.linkobj"

fn driver_backendEmitTmpLinkObj(mod: UirModule, outputPath: str, target: str): str =
    let objPath: str = driver_backendTmpObjPath(outputPath)
    driver_bootMark(3)
    if driver_emitObjFromModuleDefault(mod, target, objPath) != 0:
        driver_exit(1)
    driver_bootMark(4)
    return objPath

fn driver_backendLinkTmpObjDefault(outputPath: str, objPath: str, target: str, linker: str): int32 =
    var linkObjs2: str[]
    seqAdd(linkObjs2, objPath)
    return driver_linkExeObjects(linkObjs2, target, linker, false, "cc", "", "",
                                 outputPath, "", "src/runtime/native/system_helpers.c", false, "dict")

fn driver_backendLinkTmpObj(outputPath: str, objPath: str, target: str, linker: str): int32 =
    let runtimeObj: str = driver_activeRuntimeObj()
    let runtimeC: str = driver_activeRuntimeC()
    let noRuntimeC: bool = driver_activeNoRuntimeC()
    let ccCmd: str = driver_activeCcCmd()
    let ldCmd: str = driver_activeLdCmd(ccCmd)
    let cflags: str = driver_activeCFlags()
    let ldflags: str = driver_activeLdFlags()
    let linkerSymtabAll: bool = driver_activeLinkerSymtabAll()
    let genericMode: str = "dict"
    var linkObjs2: str[]
    seqAdd(linkObjs2, objPath)
    return driver_linkExeObjects(linkObjs2, target, linker, linkerSymtabAll, ldCmd, cflags, ldflags,
                                 outputPath, runtimeObj, runtimeC, noRuntimeC, genericMode)

fn driver_backendCleanupTmpLinkObj(objPath: str): int32 =
    if !driver_envBoolDefault("BACKEND_KEEP_TMP_LINKOBJ", false):
        driver_runCmd("rm -f " + driver_shellQuote(objPath))
    return 0

fn driver_backendFinishSingleLink(outputPath: str, objPath: str): int32 =
    return driver_c_finish_single_link(outputPath, objPath)

fn driver_backendRunObjEmit(inputPath: str, target: str, outputPath: str): int32 =
    let module: UirModule = driver_buildActiveModule(inputPath, target)
    let emitRc: int32 = driver_backendEmitObjCore(module, outputPath, target)
    if emitRc != 0:
        return emitRc
    return driver_backendFinishEmitObj(outputPath)

fn driver_backendRunObjMode(target: str): int32 =
    let resolvedTarget: str = target
    let inputPath: str = driver_activeInputPath()
    let outputPath: str = driver_activeOutputPath(inputPath)
    return driver_backendRunObjEmit(inputPath, resolvedTarget, outputPath)

fn driver_backendRunExeFinish(outputPath: str, target: str, linker: str, objPath: str): int32 =
    driver_bootMark(6)
    let _linker: str = linker
    if driver_c_link_tmp_obj_system(outputPath, objPath, target) != 0:
        return 1
    driver_bootMark(7)
    return driver_backendFinishSingleLink(outputPath, objPath)

fn driver_backendRunExeLink(inputPath: str, target: str, outputPath: str, linker: str): int32 =
    driver_debugBootLine("[drv]exe_link_enter")
    let module: UirModule = driver_buildActiveModule(inputPath, target)
    driver_debugBootLine("[drv]exe_link_built")
    let objPath: str = driver_backendEmitTmpLinkObj(module, outputPath, target)
    driver_debugBootLine("[drv]exe_link_obj")
    let linkRc: int32 = driver_backendLinkTmpObj(outputPath, objPath, target, linker)
    if linkRc != 0:
        return linkRc
    driver_debugBootLine("[drv]exe_link_linked")
    return driver_backendFinishSingleLink(outputPath, objPath)

fn driver_backendRunExeMode(target: str): int32 =
    let resolvedTarget: str = target
    let inputPath: str = driver_activeInputPath()
    let outputPath: str = driver_activeOutputPath(inputPath)
    let linker: str = driver_activeLinker()
    return driver_backendRunExeLink(inputPath, resolvedTarget, outputPath, linker)

fn driver_backendResolveInputPath(): str =
    let cliInput: str = driver_trimAsciiSpace(driver_copy_cstring_owned(driver_c_cli_input_copy()))
    driver_debugInputTrace("cli_input", cliInput)
    if driver_strNonEmpty(cliInput):
        return cliInput
    let cliFallback: str = driver_trimAsciiSpace(driver_cliInputPath())
    if driver_strNonEmpty(cliFallback):
        return cliFallback
    let envInput: str = driver_trimAsciiSpace(os.getEnvDefault("BACKEND_INPUT", ""))
    driver_debugInputTrace("env_nonempty", driver_strNonEmpty(envInput) ? "1" : "0")
    if driver_strNonEmpty(envInput):
        driver_debugInputTrace("env_input", envInput)
        return envInput
    let envInputCompat: str = driver_trimAsciiSpace(driver_copy_cstring_owned(driver_c_getenv_copy("BACKEND_INPUT")))
    if driver_strNonEmpty(envInputCompat):
        driver_debugInputTrace("env_input_compat", envInputCompat)
        return envInputCompat
    let activeRaw: void* = driver_c_active_input_path()
    driver_debugInputRawTrace("active_input", activeRaw)
    let activeInput: str = driver_trimAsciiSpace(driver_cstringToStr(activeRaw))
    driver_debugInputTrace("active_input", activeInput)
    return activeInput

fn driver_backendResolveTarget(): str =
    let cliTarget: str = driver_trimAsciiSpace(driver_copy_cstring_owned(driver_c_cli_target_copy()))
    var raw: str = driver_lowerAscii(driver_trimAsciiSpace(cliTarget))
    if driver_strIsEmpty(raw):
        raw = driver_lowerAscii(driver_trimAsciiSpace(driver_cliTarget()))
    if driver_strIsEmpty(raw):
        raw = driver_lowerAscii(driver_trimAsciiSpace(os.getEnvDefault("BACKEND_TARGET", "")))
    if driver_strIsEmpty(raw):
        raw = driver_lowerAscii(driver_trimAsciiSpace(driver_copy_cstring_owned(driver_c_getenv_copy("BACKEND_TARGET"))))
    if driver_strNonEmpty(raw):
        if driver_strEq(raw, "arm64-apple-darwin") ||
           driver_strEq(raw, "aarch64-apple-darwin") ||
           driver_strEq(raw, "arm64-darwin") ||
           driver_strEq(raw, "aarch64-darwin") ||
           driver_strEq(raw, "darwin_arm64") ||
           driver_strEq(raw, "darwin_aarch64"):
            return "arm64-apple-darwin"
        if driver_strEq(raw, "auto") || driver_strEq(raw, "native") || driver_strEq(raw, "host"):
            let detected: str = driver_detectHostTargetAuto()
            if driver_strIsEmpty(detected):
                driver_panic("backend_driver: auto target detect failed; pass --target=<triple> or set BACKEND_TARGET")
            return detected
        return raw
    let activeTarget: str = driver_trimAsciiSpace(driver_c_active_target())
    if driver_strNonEmpty(activeTarget):
        return activeTarget
    let detected: str = driver_detectHostTargetAuto()
    if driver_strNonEmpty(detected):
        return detected
    return "arm64-apple-darwin"

fn driver_backendResolveOutputPath(inputPath: str): str =
    let cliOutput: str = driver_trimAsciiSpace(driver_copy_cstring_owned(driver_c_cli_output_copy()))
    if driver_strNonEmpty(cliOutput):
        return cliOutput
    let cliFallback: str = driver_trimAsciiSpace(driver_cliOutputPath())
    if driver_strNonEmpty(cliFallback):
        return cliFallback
    let envOutput: str = driver_trimAsciiSpace(os.getEnvDefault("BACKEND_OUTPUT", ""))
    if driver_strNonEmpty(envOutput):
        return envOutput
    let envOutputCompat: str = driver_trimAsciiSpace(driver_copy_cstring_owned(driver_c_getenv_copy("BACKEND_OUTPUT")))
    if driver_strNonEmpty(envOutputCompat):
        return envOutputCompat
    return driver_trimAsciiSpace(driver_cstringToStr(driver_c_active_output_path(inputPath)))

fn driver_backendResolveLinker(): str =
    var cliLinker: str = driver_lowerAscii(driver_trimAsciiSpace(driver_copy_cstring_owned(driver_c_cli_linker_copy())))
    if driver_strIsEmpty(cliLinker):
        cliLinker = driver_lowerAscii(driver_trimAsciiSpace(driver_cliLinker()))
    if driver_strIsEmpty(cliLinker):
        cliLinker = driver_lowerAscii(driver_trimAsciiSpace(os.getEnvDefault("BACKEND_LINKER", "")))
    if driver_strIsEmpty(cliLinker):
        cliLinker = driver_lowerAscii(driver_trimAsciiSpace(driver_copy_cstring_owned(driver_c_getenv_copy("BACKEND_LINKER"))))
    if driver_strEq(cliLinker, "system"):
        return "system"
    if driver_strEq(cliLinker, "self"):
        return "self"
    if driver_strNonEmpty(cliLinker):
        driver_panic("backend_driver: invalid BACKEND_LINKER (expected self|system): " + cliLinker)
    return driver_trimAsciiSpace(driver_c_active_linker())

fn driver_backendRun(): int32 =
    driver_debugBootLine("[drv]run_enter")
    driver_bootMark(20)
    let target: str = driver_activeTarget()
    if driver_strIsEmpty(target):
        driver_panic("backend_driver: empty target")
    if driver_backendEmitIsObj():
        return driver_backendRunObjMode(target)
    return driver_backendRunExeMode(target)

fn backendMainNative(): int32 =
    driver_debugBootLine("[drv]native_enter")
    return driver_backendRun()
fn backendMain(): int32 =
    driver_debugBootLine("[drv]backend_enter")
    return backendMainNative()

fn main(): int32 =
    if driver_c_help_requested() != 0:
        return driver_c_backend_usage()
    driver_debugBootLine("[drv]main_enter")
    return backendMain()
