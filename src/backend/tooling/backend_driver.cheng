fn driver_backendBuildActiveObjNative(): int32 =
    return driver_c_build_active_obj_default()

fn driver_backendBuildActiveExeNative(): int32 =
    return driver_c_build_active_exe_default()

fn driver_backendBuildActiveObjNativePtrs(inputRaw: void*, targetRaw: void*, outputRaw: void*): int32 =
    return driver_c_build_emit_obj_default(driver_copy_cstring_owned(inputRaw),
                                           driver_copy_cstring_owned(targetRaw),
                                           driver_copy_cstring_owned(outputRaw))

fn driver_backendBuildActiveExeNativePtrs(inputRaw: void*, targetRaw: void*, outputRaw: void*, linkerRaw: void*): int32 =
