import backend/tooling/backend_driver_uir_shared

@exportc("driver_buildActiveModulePtrs")
fn driver_buildActiveModulePtrs(input_raw: cstring, target_raw: cstring): ptr =
    return driverUirBuildModuleStage1TargetRetained(input_raw, target_raw)

@exportc("driver_export_buildActiveModulePtrs")
fn driver_export_buildActiveModulePtrs(input_raw: cstring, target_raw: cstring): ptr =
    return driverUirBuildModuleStage1TargetRetained(input_raw, target_raw)

@exportc("driver_emit_obj_from_module_default_impl")
fn driver_emit_obj_from_module_default_impl(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirEmitObjFromRetainedModule(module_raw, target_raw, out_raw)

@exportc("driver_export_emit_obj_from_module_default_impl")
fn driver_export_emit_obj_from_module_default_impl(module_raw: ptr, target_raw: cstring, out_raw: cstring): int32 =
    return driverUirEmitObjFromRetainedModule(module_raw, target_raw, out_raw)
