import std/system_c
import std/result
import backend/uir/uir_codegen
import backend/uir/uir_types
import backend/uir/uir_internal/uir_core_builder

type
    DriverUirProofByteBuf = uint8[]

@importc("driver_c_write_exact_file")
fn driver_c_write_exact_file(path: cstring, buffer: ptr, len: int32): int32
@importc("getenv")
fn driver_c_getenv(name: cstring): cstring
@importc("ptr_add")
fn driver_c_ptr_add(p: ptr, off: int32): ptr

fn driverProofStrViewUnsafe(data: ptr, len: int32): str =
    var out: str
    out.data = data
    out.len = len
    out.store_id = 0
    out.flags = 0
    return out

fn driverProofBorrowCString(raw: cstring): str =
    if raw == nil:
        return ""
    let n: int32 = c_strlen(raw)
    if n <= 0:
        return ""
    return driverProofStrViewUnsafe(ptr(raw), n)

fn driverProofParseNonNegativeIntRaw(raw: cstring, defaultValue: int32): int32 =
    if raw == nil:
        return defaultValue
    var i: int32 = 0
    var v: int64 = 0
    while true:
        let ch: char = *(ptr(driver_c_ptr_add(ptr(raw), i)))
        if ch == '\0':
            break
        if ch < '0' || ch > '9':
            return defaultValue
        v = v * int64(10) + int64(int32(ch) - int32('0'))
        if v > int64(2147483647):
            return int32(2147483647)
        i = i + 1
    if i <= 0:
        return defaultValue
    return int32(v)

fn driverProofOptLevel(): int32 =
    return driverProofParseNonNegativeIntRaw(driver_c_getenv("BACKEND_OPT_LEVEL"), 0)

fn driverProofBuildEmitObjFromFileStage1Target(path_raw: cstring, target_raw: cstring, out_raw: cstring): int32 =
    if path_raw == nil:
        return -11
    if out_raw == nil:
        return -12
    let path: str = driverProofBorrowCString(path_raw)
    let outPath: str = driverProofBorrowCString(out_raw)
    if len(path) == 0:
        return -11
    if len(outPath) == 0:
        return -12
    let target: str = driverProofBorrowCString(target_raw)
    let module: UirModule = uirCoreBuildModuleFromFileStage1OrPanic(path, target)
    if module == nil:
        return -11
    let objRes: Result[DriverUirProofByteBuf] =
        uirEmitObjFromModule(module, driverProofOptLevel(), target, "", false, false, 0, "autovec")
    if !IsOk[DriverUirProofByteBuf](objRes):
        return -10
    let obj: uint8[] = objRes.value
    if len(obj) <= 0:
        return -13
    if obj.buffer == nil:
        return -14
    return driver_c_write_exact_file(out_raw, obj.buffer, obj.len)
