# backend/c/c_emitter_func.cheng
import std/result
import backend/uir/uir_types
import backend/c/c_emitter_types
import backend/c/c_emitter_stmt

fn cEmitParamNameUnique(base0: str, used: str[]): str =
    var base: str = base0
    if len(base) == 0:
        base = "p"
    var out: str = base
    var suffix: int32 = 0
    while true:
        var exists: bool = false
        for i in 0..<used.len:
            if used[i] == out:
                exists = true
                break
        if !exists:
            return out
        suffix = suffix + 1
        out = base + "_" + intToStr(suffix)

fn cEmitBuildParamNames(func: UirFunc): str[] =
    var out: str[]
    for i in 0..<uirFuncParamsLen(func):
        let p: UirParam = uirFuncParamAt(func, i)
        let nmRaw: str = p.name
        let nmSeed: str = cEmitSanitizeIdent(nmRaw, "p" + intToStr(i))
        let nm: str = cEmitParamNameUnique(nmSeed, out)
        add(out, nm)
    return out

fn cEmitFuncName(func: UirFunc, nameMap: CEmitNameMap): str =
    let raw: str = uirFuncNameOf(func)
    let mapped: str = cEmitNameMapGet(nameMap, cEmitFnKey(raw), "")
    if len(mapped) > 0:
        return mapped
    return cEmitSanitizeIdent(raw, "f")

fn cEmitFuncSignature(func: UirFunc, nameMap: CEmitNameMap): str =
    let retTy: str = cEmitTypeName(uirFuncRetTypeOf(func))
    let fnName: str = cEmitFuncName(func, nameMap)
    let paramNames: str[] = cEmitBuildParamNames(func)
    var sig: str = retTy + " " + fnName + "("
    if paramNames.len == 0:
        sig = sig + "void"
    for i in 0..<paramNames.len:
        if i > 0:
            sig = sig + ", "
        let p: UirParam = uirFuncParamAt(func, i)
        sig = sig + cEmitTypeName(p.ty) + " " + paramNames[i]
    sig = sig + ")"
    return sig

fn cEmitFuncPrototype(func: UirFunc, nameMap: CEmitNameMap): Result[str] =
    let sig: str = cEmitFuncSignature(func, nameMap)
    if uirFuncIsExtern(func):
        return Ok[str]("extern " + sig + ";\n")
    return Ok[str](sig + ";\n")

fn cEmitFuncDefinition(func: UirFunc, nameMap: CEmitNameMap): Result[str] =
    if uirFuncIsExtern(func):
        return Ok[str]("")
    let sig: str = cEmitFuncSignature(func, nameMap)
    let paramNames: str[] = cEmitBuildParamNames(func)
    var out: str = sig + " {\n"
    let localCount: int32 = uirFuncLocalTypesLen(func)
    for li in 0..<localCount:
        let ty: UirLowerType = uirFuncLocalTypeAt(func, li)
        if ty.kind == mtVoid:
            continue
        let cty: str = cEmitTypeName(ty)
        out = out + "  " + cty + " l" + intToStr(li) + " = ((" + cty + ")(0));\n"
    let blockCount: int32 = uirFuncBlocksLen(func)
    if blockCount <= 0:
        let retTy: UirLowerType = uirFuncRetTypeOf(func)
        if retTy.kind == mtVoid:
            out = out + "  return;\n}\n"
        else:
            out = out + "  return ((" + cEmitTypeName(retTy) + ")(0));\n}\n"
        return Ok[str](out)
    out = out + "  goto B0;\n"
    var labels: str[]
    for bi0 in 0..<blockCount:
        let b0: UirLowerBlock = uirFuncBlockAt(func, bi0)
        add(labels, uirBlockLabelOf(b0))
    for bi in 0..<blockCount:
        let blk: UirLowerBlock = uirFuncBlockAt(func, bi)
        out = out + "B" + intToStr(bi) + ":\n"
        for si in 0..<uirBlockStmtsLen(blk):
            let stmt: UirStmt = uirBlockStmtAt(blk, si)
            let sRes: Result[str] = cEmitStmt(func, stmt, nameMap, paramNames)
            if !IsOk[str](sRes):
                return sRes
            out = out + sRes.value
        let tRes: Result[str] = cEmitTerm(func, blk, labels, nameMap)
        if !IsOk[str](tRes):
            return tRes
        out = out + tRes.value
    out = out + "}\n"
    return Ok[str](out)
