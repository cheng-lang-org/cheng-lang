import std/strings
import std/seqs
import std/strutils

fn objCStringHexNibble(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'f':
        return 10 + int32(c) - int32('a')
    if c >= 'A' && c <= 'F':
        return 10 + int32(c) - int32('A')
    return -1

fn objCStringTempPrefix(): str =
    return "L_cheng_str_"

fn objCStringStripLeadingUnderscore(name0: str): str =
    if len(name0) > 0 && name0[0] == '_':
        return strings.sliceBytes(name0, 1, len(name0) - 1)
    return name0

fn objCStringPrependUnderscore(name: str): str =
    var parts: str[]
    seqs.add(parts, "_")
    seqs.add(parts, name)
    return strutils.join(parts, "")

fn objCStringCanonicalTempLabel(name0: str): str =
    if len(name0) == 0:
        return ""
    let prefix: str = objCStringTempPrefix()
    let name: str = objCStringStripLeadingUnderscore(name0)
    if len(name) != len(prefix) + 16:
        return ""
    for i in 0..<len(prefix):
        if name[i] != prefix[i]:
            return ""
    var parts: str[]
    seqs.add(parts, prefix)
    for i in len(prefix)..<len(name):
        let nib: int32 = objCStringHexNibble(name[i])
        if nib < 0:
            return ""
        if nib < 10:
            seqs.add(parts, charToStr(char(int8(int32('0') + nib))))
        else:
            seqs.add(parts, charToStr(char(int8(int32('a') + (nib - 10)))))
    return strutils.join(parts, "")

fn objCStringSeqContainsStr(items: var str[], value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn objCStringMachoSymbolAlias(rawName: str, canonical: str): str =
    if len(rawName) == 0 || len(canonical) == 0:
        return ""
    let underscored: str = objCStringPrependUnderscore(canonical)
    if rawName == canonical:
        return underscored
    if rawName == underscored:
        return canonical
    return ""

fn objCStringMissingSelectorRelocErr(kind: str, rawName: str): str =
    let canonical: str = objCStringCanonicalTempLabel(rawName)
    if len(canonical) > 0:
        return kind + ": selector missing canonical cstring for reloc " +
               rawName + " (canonical=" + canonical + ")"
    return kind + ": selector missing cstring for reloc " + rawName
