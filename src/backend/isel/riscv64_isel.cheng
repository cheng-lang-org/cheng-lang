# RISC-V64 instruction selection: MIR -> LIR (MVP).
# Reuse the existing AArch64-oriented MIR lowering because the produced LIR
# ops are architecture-neutral and encoded by the target object writer.
import std/result
import cheng/backend/mir/mir_types
import cheng/backend/lir/lir_types
import cheng/backend/isel/aarch64_isel

fn riscv64LowerModule(module: MirModule): Result[LirModule] =
    return aarch64LowerModule(module)
