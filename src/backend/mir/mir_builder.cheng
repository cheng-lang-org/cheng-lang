    mir_globalIndex_cache_len: int32
    mir_globalIndex_cache_ready: bool = false

fn backendSkipGlobalInit(): bool =
    return envIsTrue "CHENG_BACKEND_SKIP_GLOBAL_INIT"

fn backendAllowNoMainByEmit(): bool =
    let emitMode: str = lowerAscii(backendStripSpaces(os.getEnvDefault("CHENG_BACKEND_EMIT", "")))
    if emitMode == "obj" || emitMode == "object" || emitMode == "o":
        return true
    let outPath: str = backendStripSpaces(os.getEnvDefault("CHENG_BACKEND_OUTPUT", ""))
    if outPath != nil && len(outPath) >= 2 && outPath[len(outPath) - 2] == '.' && outPath[len(outPath) - 1] == 'o':
        return true
    if outPath != nil && len(outPath) >= 4 &&
       outPath[len(outPath) - 4] == '.' &&
       (outPath[len(outPath) - 3] == 'o' || outPath[len(outPath) - 3] == 'O') &&
       (outPath[len(outPath) - 2] == 'b' || outPath[len(outPath) - 2] == 'B') &&
       (outPath[len(outPath) - 1] == 'j' || outPath[len(outPath) - 1] == 'J'):
        return true
    return false

fn mirIsOne(raw: str): bool =
    return raw != nil && len(raw) == 1 && raw[0] == char('1')

fn mirGenericModeNormalized(): str =
    let raw0: str = lowerAscii(backendStripSpaces(getEnv "CHENG_GENERIC_MODE"))
    if raw0 == nil || len(raw0) == 0:
        return "hybrid"
    return raw0

fn mirDictHelperClosureEnabled(): bool =
    let mode: str = mirGenericModeNormalized()
    return mode == "dict" || mode == "dictionary"

fn mirShouldSkipMonoPass(): bool =
    let mode: str = mirGenericModeNormalized()
    if mode == "dict" || mode == "dictionary":
        # Dict mode keeps mono off by default for compile-time stability; helper
        # closure happens in MIR lowering. Local env can opt back into mono.
        let forceMonoDict: bool = envIsTrue "CHENG_STAGE1_FORCE_MONO_DICT"
        let skipDictRaw: str = backendStripSpaces(getEnv "CHENG_STAGE1_SKIP_MONO_DICT")
        var skipDict: bool = true
        if skipDictRaw != nil && len(skipDictRaw) > 0:
            skipDict = mirIsOne(skipDictRaw)
        if forceMonoDict:
            skipDict = false
        if os.getEnvDefault("CHENG_BACKEND_DEBUG_STAGE1_PIPE", "") == "1":
            let f: os.File = os.get_stderr()
            os.writeLine(f, "[backend] stage1: skip_mono mode=" + mode +
                         " skip_dict=" + (skipDict ? "1" : "0"))
            os.c_fflush f
        if skipDict:
            return true
        return false
    return false

fn mirIsOrcMode(mm: str): bool =
    return mm != nil && len(mm) == 3 &&
           mm[0] == char('o') && mm[1] == char('r') && mm[2] == char('c')

fn mirEnsurePolicyDiag(diags: var Diagnostic[], filePath: str, msg: str) =
    if hasError(diags):
        return
    var d: Diagnostic
    d.severity = svError
    d.filename = filePath
    d.line = 1
    d.col = 1
    d.message = msg
    add(diags, d)

fn mirFileLikelyHasPointerSyntax(path: str): bool =
    if path == nil || len(path) == 0:
        return false
    let content: str = stage1_readFile(path)
    if content == nil || len(content) == 0:
        return false
    if strContains(content, "ptr_add(") || strContains(content, "load_ptr(") || strContains(content, "store_ptr("):
        return true
    if strContains(content, "alloc(") || strContains(content, "dealloc("):
        return true
    if strContains(content, "ptr[") || strContains(content, "ref["):
        return true
    var colonSeen: bool = false
    var sawAssign: bool = false
    for i in 0..<len(content):
        let ch: char = content[i]
        if ch == '\n' || ch == '\r':
            colonSeen = false
            sawAssign = false
            continue
        if ch == ':':
            colonSeen = true
            sawAssign = false
            continue
        if ch == '=':
            sawAssign = true
            continue
        if ch == '*' && colonSeen && !sawAssign:
            return true
    return false

fn mirHasDefaultSpawnCall(content: str): bool =
    if content == nil || len(content) < 6:
        return false
    let n: int32 = len(content)
    for i in 0..(n - 6):
        if content[i] == 's' &&
           content[i + 1] == 'p' &&
           content[i + 2] == 'a' &&
           content[i + 3] == 'w' &&
           content[i + 4] == 'n' &&
           content[i + 5] == '(':
            if i > 0:
                let prev: char = content[i - 1]
                if prev == '.' || prev == '_' ||
                   (prev >= 'a' && prev <= 'z') ||
                   (prev >= 'A' && prev <= 'Z') ||
                   (prev >= '0' && prev <= '9'):
                    continue
            return true
    return false

fn mirFileLikelyUsesRawSpawn(path: str): bool =
    if path == nil || len(path) == 0:
        return false
    let content: str = stage1_readFile(path)
    if content == nil || len(content) == 0:
        return false
    if !mirHasDefaultSpawnCall(content):
        return false
    if strContains(content, "void*") || strContains(content, "void *"):
        return true
    if strContains(content, "fn_ptr") || strContains(content, "fnPtr"):
        return true
    return false

fn mirPathLooksStdModule(path: str): bool =
    if path == nil || len(path) == 0:
        return false
    if strContains(path, "src/std/") || strContains(path, "src\\std\\"):
        return true
    return false

fn mirStdNoPointerEnabled(): bool =
    let stdNoPtrEnv: str = getEnv "CHENG_STAGE1_STD_NO_POINTERS"
    if mirIsOne(stdNoPtrEnv):
        return true
    if stdNoPtrEnv == "0":
        return false
    let abiEnv: str = getEnv "CHENG_ABI"
    return abiEnv == "v2_noptr"

fn mirStage1StdNoPointerPrecheck(root: Node, inPath: str, diags: var Diagnostic[]): bool =
    if !mirStdNoPointerEnabled():
        return false
    var ctx: SemCtx
    initSemCtxInPlace(ctx)
    ctx.diags = diags
    ctx.filename = inPath
    var hits: int32 = semCheckStdNoPointerPolicy(ctx, root)
    # Heuristic fallback must honor std policy exemptions; otherwise internal
    # bridge modules (explicitly exempt) are rejected in strict bootstrap.
    if hits <= 0 &&
       mirPathLooksStdModule(inPath) &&
       !semIsStdPointerPolicyExempt(inPath) &&
       mirFileLikelyHasPointerSyntax(inPath):
        hits = 1
    diags = ctx.diags
    if hits > 0:
        mirEnsurePolicyDiag(diags, inPath, "std policy: pointer types are forbidden in standard library")
    return hits > 0

fn mirStage1NoPointerNonCAbiPrecheck(root: Node, inPath: str, diags: var Diagnostic[]): bool =
    let nonCAbiNoPtrEnv: str = getEnv "CHENG_STAGE1_NO_POINTERS_NON_C_ABI"
    if !mirIsOne(nonCAbiNoPtrEnv):
        return false
    var ctx: SemCtx
    initSemCtxInPlace(ctx)
    ctx.diags = diags
    ctx.filename = inPath
    var hits: int32 = semCheckNoPointerNonCAbiPolicy(ctx, root)
    # Heuristic fallback must use the same scope gate as semantic checks.
    # Otherwise compiler-internal modules are flagged even when
    # CHENG_STAGE1_NO_POINTERS_NON_C_ABI_INTERNAL=0.
    if hits <= 0 &&
       semPointerPolicyShouldCheckNonCAbi(inPath) &&
       mirFileLikelyHasPointerSyntax(inPath):
        hits = 1
    diags = ctx.diags
    if hits > 0:
        mirEnsurePolicyDiag(diags, inPath, "no-pointer policy: pointer types are forbidden outside C ABI modules")
    return hits > 0

fn mirCalleeCandidatesReset() =
    mirCalleeCandidates = hashmaps.hashMapStrSeqIntInit(2048)
    mirCalleeCandidatesReady = true

fn mirCalleeCandidatesGet(mod: MirModule, baseName: str): int32[] =
    var out: int32[]
    if mod == nil || baseName == nil || len(baseName) == 0:
        return out
    if !mirCalleeCandidatesReady:
        mirCalleeCandidatesReset()
    var found: bool = false
    let cached: int32[] = hashmaps.hashMapStrSeqIntGet(mirCalleeCandidates, baseName, &found)
    if found:
        if cached.len > 0:
            let meta: int32 = cached[cached.len - 1]
            if meta < 0:
                let cachedLen: int32 = -1 - meta
                if cachedLen == mod.funcs.len:
                    return cached
        # Cache entry missing/stale metadata: rebuild.

    out.cap = 8
    let baseSym: str = backendSanitizeLinkName(baseName)
    let overloadPrefix: str = baseSym + mirFuncSigMarker()
    let dupPrefix: str = baseSym + "__cheng_mod_"
    let instPrefix: str = baseSym + "_"
    for i in 0..<mod.funcs.len:
        let f: MirFunc = mbRead(mod.funcs, i)
        if f == nil || f.name == nil:
            continue
        if (f.name == baseName) ||
           mirStrStartsWith(f.name, overloadPrefix) ||
           mirStrStartsWith(f.name, dupPrefix):
            add(out, i)
            continue
        if mirStrStartsWith(f.name, instPrefix):
            # Avoid double-counting "__cheng_sig_" / "__cheng_mod_" candidates; both start with `baseSym + "_"`.
            if mirStrStartsWith(f.name, overloadPrefix) || mirStrStartsWith(f.name, dupPrefix):
                continue
            # Skip names that start with a second underscore (e.g. `echo__cheng_sig_*`).
            if len(f.name) > len(instPrefix) && f.name[len(instPrefix)] == '_':
                continue
            add(out, i)

    # Cache version marker (negative sentinel): -1 - mod.funcs.len
    add(out, -1 - mod.funcs.len)
    hashmaps.hashMapStrSeqIntPutSeq(&mirCalleeCandidates, baseName, out)
    return out

type
    MirProfileState = ref
        enabled: bool
        startNs: int64
        lastNs: int64

fn mirProfileInit(): MirProfileState =
    let enabled: bool = envIsTrue "CHENG_MIR_PROFILE"
    if !enabled:
        return nil
    var p: MirProfileState
    new p
    p.enabled = true
    p.startNs = cheng_monotime_ns()
    p.lastNs = p.startNs
    return p

fn mirProfileStep(p: MirProfileState, name: str) =
    if p == nil || !p.enabled:
        return
    let now: int64 = cheng_monotime_ns()
    let stepMs: int64 = (now - p.lastNs) / 1000000
    let totalMs: int64 = (now - p.startNs) / 1000000
    p.lastNs = now
    # Write directly to stderr to avoid fork-buffer duplication.
    let f: os.File = os.get_stderr()
    os.write(f, "mir_profile\t")
    os.write(f, name)
    os.write(f, "\tstep_ms=")
    os.write(f, int64ToStr(stepMs))
    os.write(f, "\ttotal_ms=")
    os.writeLine(f, int64ToStr(totalMs))
    os.c_fflush f

fn mirGlobalObjTypesReset() =
    mirGlobalObjTypeIndex = hashmaps.hashMapStrIntInit(256)
    mirGlobalObjTypeNames.len = 0
    mirGlobalObjTypeNames.cap = 128
    mirGlobalObjTypeReady = true

fn mirGlobalTypeKeysReset() =
    mirGlobalTypeKeyIndex = hashmaps.hashMapStrIntInit(256)
    mirGlobalTypeKeyNames.len = 0
    mirGlobalTypeKeyNames.cap = 128
    mirGlobalTypeKeyReady = true

fn mirInlineObjFieldTypesReset() =
    mirInlineObjFieldTypeIndex = hashmaps.hashMapStrIntInit(512)
    mirInlineObjFieldTypeNames.len = 0
    mirInlineObjFieldTypeNames.cap = 256
    mirInlineObjFieldTypeReady = true

fn mirObjFieldTypeKeysReset() =
    mirObjFieldTypeKeyIndex = hashmaps.hashMapStrIntInit(1024)
    mirObjFieldTypeKeyNames.len = 0
    mirObjFieldTypeKeyNames.cap = 512
    mirObjFieldTypeKeyReady = true

fn mirTupleFieldIndicesReset() =
    mirTupleFieldIndex = hashmaps.hashMapStrIntInit(1024)
    mirTupleFieldIndexReady = true

fn mirObjAliasesReset() =
    mirObjAliasIndex = hashmaps.hashMapStrIntInit(512)
    mirObjAliasNames.len = 0
    mirObjAliasNames.cap = 256
    mirObjAliasReady = true

fn mirHashMapStrIntGetCompat(m: hashmaps.HashMapStrInt, key: str, found: var bool): int32 =
    if key == nil || len(key) == 0 || m.mask == 0:
        found = false
        return -1
    if m.states.len <= 0 || m.keys.len <= 0 || m.vals.len <= 0:
        found = false
        return -1
    var mask: int32 = int32(m.mask)
    if mask < 0:
        found = false
        return -1
    if mask >= m.states.len || mask >= m.keys.len || mask >= m.vals.len:
        let cap0: int32 = m.states.len
        if m.keys.len < cap0 || m.vals.len < cap0:
            found = false
            return -1
        mask = cap0 - 1
    if mask < 0:
        found = false
        return -1
    var probe: int32 = int32(hashmaps.hashMapHash64StrMeta(key) & uint64(mask))
    var scanned: int32 = 0
    let __for_start_scanned_compat = scanned
    for __for_scanned_compat in __for_start_scanned_compat..mask:
        scanned = __for_scanned_compat
        let st: uint8 = m.states[probe]
        if st == uint8(0):
            found = false
            return -1
        if hashmaps.hashMapStrEq(m.keys[probe], key):
            found = true
            return m.vals[probe]
        probe = (probe + 1) & mask
        scanned = scanned + 1
    found = false
    return -1

fn mirInlineObjFieldTypePut(parentType: str, fieldName: str, objTypeName: str) =
    if parentType == nil || len(parentType) == 0 || fieldName == nil || len(fieldName) == 0 || objTypeName == nil || len(objTypeName) == 0:
        return
    if (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1") && parentType == "ProtoBuffer" && fieldName == "out":
        echo("[backend] debugOverloadDot: put inline field parent='ProtoBuffer' field='out' objType='" + objTypeName + "'")
    if !mirInlineObjFieldTypeReady:
        mirInlineObjFieldTypesReset()
    let key: str = parentType + "::" + fieldName
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirInlineObjFieldTypeIndex, key, found)
    if idx >= 0 && idx < mirInlineObjFieldTypeNames.len:
        mbWriteStr(&mirInlineObjFieldTypeNames, idx, objTypeName)
        return
    if found:
        if idx >= 0 && idx < mirInlineObjFieldTypeNames.len:
            mbWriteStr(&mirInlineObjFieldTypeNames, idx, objTypeName)
        return
    let newIdx: int32 = mirInlineObjFieldTypeNames.len
    add(mirInlineObjFieldTypeNames, objTypeName)
    hashmaps.hashMapStrIntPut(mirInlineObjFieldTypeIndex, key, newIdx)

fn mirInlineObjFieldTypeGet(parentType: str, fieldName: str): str =
    if parentType == nil || len(parentType) == 0 || fieldName == nil || len(fieldName) == 0 || !mirInlineObjFieldTypeReady:
        return ""
    let key: str = parentType + "::" + fieldName
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirInlineObjFieldTypeIndex, key, found)
    if idx < 0 || idx >= mirInlineObjFieldTypeNames.len:
        return ""
    return mbRead(mirInlineObjFieldTypeNames, idx)

fn mirObjFieldTypeKeyPut(parentType: str, fieldName: str, fieldTypeKey: str) =
    if parentType == nil || len(parentType) == 0 || fieldName == nil || len(fieldName) == 0 || fieldTypeKey == nil || len(fieldTypeKey) == 0:
        return
    if !mirObjFieldTypeKeyReady:
        mirObjFieldTypeKeysReset()
    let key: str = parentType + "::" + fieldName
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirObjFieldTypeKeyIndex, key, found)
    if idx >= 0 && idx < mirObjFieldTypeKeyNames.len:
        mbWriteStr(&mirObjFieldTypeKeyNames, idx, fieldTypeKey)
        return
    if found:
        if idx >= 0 && idx < mirObjFieldTypeKeyNames.len:
            mbWriteStr(&mirObjFieldTypeKeyNames, idx, fieldTypeKey)
        return
    let newIdx: int32 = mirObjFieldTypeKeyNames.len
    add(mirObjFieldTypeKeyNames, fieldTypeKey)
    hashmaps.hashMapStrIntPut(mirObjFieldTypeKeyIndex, key, newIdx)

fn mirObjFieldTypeKeyGet(parentType: str, fieldName: str): str =
    if parentType == nil || len(parentType) == 0 || fieldName == nil || len(fieldName) == 0 || !mirObjFieldTypeKeyReady:
        return ""
    let key: str = parentType + "::" + fieldName
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirObjFieldTypeKeyIndex, key, found)
    if (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1") && parentType == "ProtoBuffer" && fieldName == "out":
        let foundCompat: bool = idx >= 0
        echo("[backend] debugOverloadDot: keyGetCompat key='" + key + "' found=" + (foundCompat ? "1" : "0") +
             " idx=" + intToStr(idx) + " namesLen=" + intToStr(mirObjFieldTypeKeyNames.len))
    if idx < 0 || idx >= mirObjFieldTypeKeyNames.len:
        return ""
    return mbRead(mirObjFieldTypeKeyNames, idx)

fn mirTupleFieldIndexPut(tupleKey: str, fieldName: str, idx0: int32) =
    if tupleKey == nil || len(tupleKey) == 0 || fieldName == nil || len(fieldName) == 0 || idx0 < 0:
        return
    if !mirTupleFieldIndexReady:
        mirTupleFieldIndicesReset()
    let key: str = tupleKey + "::" + fieldName
    var found: bool = false
    let existing: int32 = mirHashMapStrIntGetCompat(mirTupleFieldIndex, key, found)
    if existing >= 0:
        # Structural tuple types may share the same key without field labels. If a label maps to
        # different indices, treat it as ambiguous.
        if existing != idx0 && existing != -2:
            hashmaps.hashMapStrIntPut(mirTupleFieldIndex, key, -2)
        return
    hashmaps.hashMapStrIntPut(mirTupleFieldIndex, key, idx0)

fn mirTupleFieldIndexGet(tupleKey: str, fieldName: str): int32 =
    if tupleKey == nil || len(tupleKey) == 0 || fieldName == nil || len(fieldName) == 0 || !mirTupleFieldIndexReady:
        return -1
    let key: str = tupleKey + "::" + fieldName
    var found: bool = false
    let v: int32 = mirHashMapStrIntGetCompat(mirTupleFieldIndex, key, found)
    if v < 0:
        return -1
    return v

fn mirGlobalObjTypePut(name: str, objTypeName: str) =
    if name == nil || len(name) == 0 || objTypeName == nil || len(objTypeName) == 0:
        return
    if !mirGlobalObjTypeReady:
        mirGlobalObjTypesReset()
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirGlobalObjTypeIndex, name, found)
    if idx >= 0 && idx < mirGlobalObjTypeNames.len:
        mbWriteStr(&mirGlobalObjTypeNames, idx, objTypeName)
        return
    if found:
        if idx >= 0 && idx < mirGlobalObjTypeNames.len:
            mbWriteStr(&mirGlobalObjTypeNames, idx, objTypeName)
        return
    let newIdx: int32 = mirGlobalObjTypeNames.len
    add(mirGlobalObjTypeNames, objTypeName)
    hashmaps.hashMapStrIntPut(mirGlobalObjTypeIndex, name, newIdx)

fn mirGlobalObjTypeGet(name: str): str =
    if name == nil || len(name) == 0 || !mirGlobalObjTypeReady:
        return ""
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirGlobalObjTypeIndex, name, found)
    if idx < 0 || idx >= mirGlobalObjTypeNames.len:
        return ""
    return mbRead(mirGlobalObjTypeNames, idx)

fn mirGlobalTypeKeyPut(name: str, typeKey0: str) =
    if name == nil || len(name) == 0 || typeKey0 == nil || len(typeKey0) == 0:
        return
    if !mirGlobalTypeKeyReady:
        mirGlobalTypeKeysReset()
    let typeKey: str = backendStripSpaces(typeKey0)
    if typeKey == nil || len(typeKey) == 0:
        return
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirGlobalTypeKeyIndex, name, found)
    if idx >= 0 && idx < mirGlobalTypeKeyNames.len:
        mbWriteStr(&mirGlobalTypeKeyNames, idx, typeKey)
        return
    if found:
        if idx >= 0 && idx < mirGlobalTypeKeyNames.len:
            mbWriteStr(&mirGlobalTypeKeyNames, idx, typeKey)
        return
    let newIdx: int32 = mirGlobalTypeKeyNames.len
    add(mirGlobalTypeKeyNames, typeKey)
    hashmaps.hashMapStrIntPut(mirGlobalTypeKeyIndex, name, newIdx)

fn mirGlobalTypeKeyGet(name: str): str =
    if name == nil || len(name) == 0 || !mirGlobalTypeKeyReady:
        return ""
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirGlobalTypeKeyIndex, name, found)
    if idx < 0 || idx >= mirGlobalTypeKeyNames.len:
        return ""
    return mbRead(mirGlobalTypeKeyNames, idx)

fn mirObjAliasPut(aliasName0: str, targetName0: str) =
    if aliasName0 == nil || len(aliasName0) == 0 || targetName0 == nil || len(targetName0) == 0:
        return
    if !mirObjAliasReady:
        mirObjAliasesReset()
    let aliasName: str = backendStripSpaces(aliasName0)
    let targetName: str = backendStripSpaces(targetName0)
    if aliasName == nil || len(aliasName) == 0 || targetName == nil || len(targetName) == 0:
        return
    if (aliasName == targetName):
        return
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirObjAliasIndex, aliasName, found)
    if idx >= 0 && idx < mirObjAliasNames.len:
        mbWriteStr(&mirObjAliasNames, idx, targetName)
        return
    if found:
        if idx >= 0 && idx < mirObjAliasNames.len:
            mbWriteStr(&mirObjAliasNames, idx, targetName)
        return
    let newIdx: int32 = mirObjAliasNames.len
    add(mirObjAliasNames, targetName)
    hashmaps.hashMapStrIntPut(mirObjAliasIndex, aliasName, newIdx)

fn mirObjAliasGet(aliasName0: str): str =
    if aliasName0 == nil || len(aliasName0) == 0 || !mirObjAliasReady:
        return ""
    let aliasName: str = backendStripSpaces(aliasName0)
    if aliasName == nil || len(aliasName) == 0:
        return ""
    var found: bool = false
    let idx: int32 = mirHashMapStrIntGetCompat(mirObjAliasIndex, aliasName, found)
    if idx < 0 || idx >= mirObjAliasNames.len:
        return ""
    return mbRead(mirObjAliasNames, idx)

fn mirObjAliasCanon(name0: str): str =
    if name0 == nil || len(name0) == 0:
        return ""
    if !mirObjAliasReady:
        return name0
    var cur: str = name0
    for i in 0..<8:
        let next: str = mirObjAliasGet(cur)
        if next == nil || len(next) == 0 || (next == cur):
            return cur
        cur = next
    return cur

fn mirObjLayoutName(module: MirModule, name0: str): str =
    if name0 == nil || len(name0) == 0:
        return ""
    let name: str = name0
    if module != nil:
        if mirStrStartsWith(name, "seq_") && mirHasObjType(module, "seq"):
            return "seq"
        if mirStrStartsWith(name, "seq_fixed_") && mirHasObjType(module, "seq"):
            return "seq"
        if mirStrStartsWith(name, "Table_") && mirHasObjType(module, "Table"):
            return "Table"
    return name

fn mirModuleIdForFile(filePath0: str): str =
    let filePath: str = (filePath0 != nil) ? filePath0 : ""
    if len(filePath) == 0:
        return "0000000000000000"
    return mirU64ToHex(mirFnv1a64(filePath))

fn mirDupFnBasesReset() =
    mirDupFnBases = hashsets.hashSetStrInit(256)
    mirDupFnBasesReady = true

fn mirDupFnBasesHas(baseName: str): bool =
    if !mirDupFnBasesReady:
        return false
    if baseName == nil || len(baseName) == 0:
        return false
    return hashsets.hashSetStrHas(mirDupFnBases, baseName)

fn mirMaybeMangleDupFnBase(baseName0: str, originFile0: str): str =
    let baseName: str = (baseName0 != nil) ? baseName0 : ""
    if len(baseName) == 0:
        return ""
    if (baseName == "main"):
        return baseName
    if !mirDupFnBasesHas(baseName):
        return baseName
    let originFile: str = (originFile0 != nil) ? originFile0 : ""
    return baseName + "__cheng_mod_" + mirModuleIdForFile(originFile)

fn mirCollectGenericParamNames(generics: Node): str[] =
    var out: str[4]
    if generics == nil || generics.kind == nkEmpty:
        return out
    for i in 0..<kidCount(generics):
        let n0: Node = kid(generics, i)
        if n0 == nil || n0.kind == nkEmpty:
            continue
        var nameNode: Node = nil
        if n0.kind == nkIdentDefs && kidCount(n0) > 0:
            nameNode = kid(n0, 0)
        elif n0.kind == nkIdent || n0.kind == nkSymbol:
            nameNode = n0
        elif kidCount(n0) > 0:
            nameNode = kid(n0, 0)
        if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol):
            let nm: str = backendStripSpaces(plainName(nameNode))
            if nm != nil && len(nm) > 0:
                add(out, nm)
    return out

fn mirTypeNodeHasGenericParam(typeNode0: Node, genericNames: str[]): bool =
    if typeNode0 == nil || genericNames.len == 0:
        return false
    var stack: Node[16]
    add(stack, typeNode0)
    while stack.len > 0:
        let n: Node = mbRead(stack, stack.len - 1)
        stack.len = stack.len - 1
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkIdent || n.kind == nkSymbol:
            let nm: str = backendStripSpaces(plainName(n))
            if nm != nil && len(nm) > 0:
                for gi in 0..<genericNames.len:
                    if (nm == mbRead(genericNames, gi)):
                        return true
        for ki in 0..<kidCount(n):
            add(stack, kid(n, ki))
    return false

fn mirFuncSigHasUnresolvedGenerics(fnNode: Node): bool =
    if fnNode == nil || kidCount(fnNode) <= 4:
        return false
    let genNode: Node = kid(fnNode, 4)
    if genNode == nil || genNode.kind == nkEmpty || kidCount(genNode) == 0:
        return false
    let genNames: str[] = mirCollectGenericParamNames(genNode)
    if genNames.len == 0:
        return false
    let retNode: Node = (kidCount(fnNode) > 2) ? kid(fnNode, 2) : nil
    if retNode != nil && retNode.kind != nkEmpty:
        if mirTypeNodeHasGenericParam(retNode, genNames):
            return true
    let paramsNode: Node = (kidCount(fnNode) > 1) ? kid(fnNode, 1) : nil
    if paramsNode != nil && paramsNode.kind == nkFormalParams:
        for pi in 0..<kidCount(paramsNode):
            let defs: Node = kid(paramsNode, pi)
            if defs != nil && defs.kind == nkIdentDefs && kidCount(defs) > 1:
                let tn: Node = kid(defs, 1)
                if tn != nil && tn.kind != nkEmpty:
                    if mirTypeNodeHasGenericParam(tn, genNames):
                        return true
    return false

fn mirComputeDuplicateFnBases(root: Node, overloaded: hashsets.HashSetStr* = nil): hashsets.HashSetStr =
    var dup: hashsets.HashSetStr = hashsets.hashSetStrInit(256)
    if root == nil:
        return dup
    var seenNames: str[]
    var seenCounts: int32[]
    var queue: Node[]
    add(queue, root)
    while queue.len > 0:
        let n: Node = mbRead(queue, queue.len - 1)
        queue.len = queue.len - 1
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkStmtList || n.kind == nkModule:
            for i in 0..<kidCount(n):
                add(queue, kid(n, i))
            continue
        if n.kind != nkFnDecl && n.kind != nkIteratorDecl:
            continue
        if kidCount(n) > 3:
            let body: Node = kid(n, 3)
            # Forward decls (no body, no importc) should not count as duplicates.
            if body == nil || body.kind == nkEmpty:
                continue
        if mirFuncSigHasUnresolvedGenerics(n):
            continue
        let nameNode: Node = kid(n, 0)
        if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
            continue
        let rawName: str = backendStripSpaces(plainName(nameNode))
        if rawName == nil || len(rawName) == 0 || (rawName == "main"):
            continue
        if overloaded != nil && hashsets.hashSetStrHas(*overloaded, rawName):
            continue
        var idx: int32 = -1
        for ci in 0..<seenNames.len:
            if seenNames[ci] == rawName:
                idx = ci
                break
        if idx < 0:
            add(seenNames, rawName)
            add(seenCounts, 1)
        else:
            let next: int32 = seenCounts[idx] + 1
            seenCounts[idx] = next
            if next > 1:
                hashsets.hashSetStrAdd(dup, rawName)
    return dup

fn mirDupGlobalNamesReset() =
    mirDupGlobalNames = hashsets.hashSetStrInit(256)
    mirDupGlobalNamesReady = true

fn mirDupGlobalNamesHas(baseName: str): bool =
    if !mirDupGlobalNamesReady:
        return false
    if baseName == nil || len(baseName) == 0:
        return false
    return hashsets.hashSetStrHas(mirDupGlobalNames, baseName)

fn mirMaybeMangleDupGlobalName(baseName0: str, originFile0: str): str =
    let baseName: str = (baseName0 != nil) ? baseName0 : ""
    if len(baseName) == 0:
        return ""
    if !mirDupGlobalNamesHas(baseName):
        return baseName
    let originFile: str = (originFile0 != nil) ? originFile0 : ""
    return baseName + "__cheng_mod_" + mirModuleIdForFile(originFile)

fn mirComputeDuplicateGlobalNames(root: Node): hashsets.HashSetStr =
    var dup: hashsets.HashSetStr = hashsets.hashSetStrInit(256)
    if root == nil:
        return dup
    var seenNames: str[]
    var seenCounts: int32[]
    var queue: Node[]
    add(queue, root)
    while queue.len > 0:
        let n: Node = mbRead(queue, queue.len - 1)
        queue.len = queue.len - 1
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkStmtList || n.kind == nkModule:
            for i in 0..<kidCount(n):
                add(queue, kid(n, i))
            continue
        if n.kind != nkVar && n.kind != nkLet && n.kind != nkConst:
            continue
        var pat: Node = nil
        if kidCount(n) > 0:
            pat = kid(n, 0)
        var nameNode: Node = pat
        if pat != nil && pat.kind == nkPattern && kidCount(pat) > 0:
            nameNode = kid(pat, 0)
        if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
            continue
        let rawName: str = backendStripSpaces(plainName(nameNode))
        if rawName == nil || len(rawName) == 0:
            continue
        var idx: int32 = -1
        for ci in 0..<seenNames.len:
            if seenNames[ci] == rawName:
                idx = ci
                break
        if idx < 0:
            add(seenNames, rawName)
            add(seenCounts, 1)
        else:
            let next: int32 = seenCounts[idx] + 1
            seenCounts[idx] = next
            if next > 1:
                hashsets.hashSetStrAdd(dup, rawName)
    return dup

fn blockBuilderNew(env: LocalEnv, module: MirModule, func: MirFunc): BlockBuilder =
    var b: BlockBuilder
    new b
    b.env = env
    b.module = module
    b.func = func
    b.currentLabel = "entry"
    b.currentStmts = []
    b.labelCounter = 0
    b.objCursor = 0
    b.loopStack = []
    b.deferStack = []
    return b

fn blockBuilderNextLabel(b: BlockBuilder, prefix: str): str =
    let id: int32 = b.labelCounter
    b.labelCounter = b.labelCounter + 1
    return prefix + intToStr(id)

fn blockBuilderStart(b: BlockBuilder, label: str) =
    b.currentLabel = label
    b.currentStmts = []

fn blockBuilderFinish(b: BlockBuilder, term: MirTerm) =
    # Copy stmt buffer so finished blocks don't alias the builder's scratch seq.
    # (Without this, later appends can realloc/free the shared buffer.)
    var stmtsCopy: MirStmt[]
    if b.currentStmts.len > 0:
        stmtsCopy.cap = b.currentStmts.len
        for si in 0..<b.currentStmts.len:
            add(stmtsCopy, mbRead(b.currentStmts, si))
    let blk: MirBlock = mirBlockWithStmts(b.currentLabel, stmtsCopy, term)
    let dbgFunc: MirFunc = b.func
    let dbgName: str = (dbgFunc != nil) ? dbgFunc.name : ""
    if (os.getEnvDefault("CHENG_BACKEND_DEBUG_MIR_FINISH", "") == dbgName):
        let curLen: int32 = b.currentStmts.len
        let blkLen: int32 = blk.stmts.len
        echo("[backend] dbgFinish: fn=" + dbgName + " label=" + b.currentLabel +
             " cur.len=" + intToStr(curLen) + " blk.len=" + intToStr(blkLen))
        if curLen > 0:
            let s0: MirStmt = mbRead(b.currentStmts, 0)
            echo("[backend] dbgFinish: cur0.kind=" + intToStr(int32(s0.kind)) +
                 " slot=" + intToStr(s0.slot))
        if blkLen > 0:
            let s1: MirStmt = mbRead(blk.stmts, 0)
            echo("[backend] dbgFinish: blk0.kind=" + intToStr(int32(s1.kind)) +
                 " slot=" + intToStr(s1.slot))
    mirAddBlock(b.func, blk)
    b.currentLabel = ""
    b.currentStmts = []

fn blockBuilderPushLoop(b: BlockBuilder, breakLabel: str, continueLabel: str) =
    var ctx: LoopContext
    new ctx
    ctx.breakLabel = breakLabel
    ctx.continueLabel = continueLabel
    ctx.deferDepth = b.deferStack.len
    add(b.loopStack, ctx)

fn blockBuilderPopLoop(b: BlockBuilder): LoopContext =
    if b.loopStack.len == 0:
        return nil
    let idx: int32 = b.loopStack.len - 1
    let ctx: LoopContext = mbRead(b.loopStack, idx)
    b.loopStack.len = idx
    return ctx

fn blockBuilderPeekLoop(b: BlockBuilder): LoopContext =
    if b.loopStack.len == 0:
        return nil
    return mbRead(b.loopStack, b.loopStack.len - 1)

fn blockBuilderPushDefer(b: BlockBuilder) =
    if b == nil:
        return
    var frame: DeferFrame
    new frame
    frame.bodies = []
    add(b.deferStack, frame)

fn blockBuilderPopDefer(b: BlockBuilder): DeferFrame =
    if b == nil || b.deferStack.len == 0:
        return nil
    let idx: int32 = b.deferStack.len - 1
    let frame: DeferFrame = mbRead(b.deferStack, idx)
    b.deferStack.len = idx
    return frame

fn blockBuilderPeekDefer(b: BlockBuilder): DeferFrame =
    if b == nil || b.deferStack.len == 0:
        return nil
    return mbRead(b.deferStack, b.deferStack.len - 1)

fn emitDeferFrames(b: BlockBuilder, frames: DeferFrame[]): Result[bool] =
    if frames.buffer == nil || frames.len == 0:
        return Ok[bool](false)
    for fi in 0..<frames.len:
        let frame: DeferFrame = mbRead(frames, fi)
        if frame != nil && frame.bodies.buffer != nil:
            let __for_start_bi = frame.bodies.len - 1
            for __for_rev_bi in 0..(__for_start_bi - (0)):
                let bi = __for_start_bi - __for_rev_bi
                let body: Node = mbRead(frame.bodies, bi)
                if body == nil || body.kind != nkStmtList:
                    return Err[bool]("mir_builder: invalid defer body")
                let bodyRes: Result[bool] = lowerStmtList(b, body)
                if !IsOk[bool](bodyRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](bodyRes))
                if Value[bool](bodyRes):
                    return Err[bool]("mir_builder: defer body terminated")
    return Ok[bool](false)

fn blockBuilderEmitDefers(b: BlockBuilder, minDepth: int32): Result[bool] =
    if b == nil:
        return Ok[bool](false)
    var md: int32 = minDepth
    if md < 0:
        md = 0
    if md >= b.deferStack.len:
        return Ok[bool](false)
    var frames: DeferFrame[]
    let __for_start_i = b.deferStack.len - 1
    for __for_rev_i in 0..(__for_start_i - (md)):
        let i = __for_start_i - __for_rev_i
        add(frames, mbRead(b.deferStack, i))
    return emitDeferFrames(b, frames)

fn blockBuilderNextTemp(b: BlockBuilder, prefix: str): str =
    return blockBuilderNextLabel(b, prefix)

fn isControlExpr(n: Node): bool =
    var node: Node = n
    while node != nil && node.kind == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if node == nil:
        return false
    if node.kind == nkIf:
        return true
    if node.kind == nkCase:
        return true
    if node.kind == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        if op == "&&" || op == "||":
            return true
    return false

fn isImplicitReturnExpr(n: Node): bool =
    if n == nil:
        return false
    var node: Node = n
    while node != nil && node.kind == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if node == nil:
        return false
    case node.kind
    of nkCall, nkInfix, nkPrefix, nkPostfix, nkDotExpr, nkBracketExpr,
       nkCurlyExpr, nkTupleLit, nkSeqLit, nkTableLit,
       nkIdent, nkSymbol,
       nkIntLit, nkFloatLit, nkStrLit, nkCharLit, nkBoolLit, nkNilLit:
        return true
    return false

fn mirAddStrPtr(items: str[]*, value: str) =
    if items == nil:
        return
    add(items, value)

fn mbSeqElemPtr(buffer: void*, len0: int32, idx: int32, elemSize: int32): void* =
    if idx < 0 || idx >= len0:
        panic "mir_builder: seq index out of bounds"
    let off64: int64 = int64(idx) * int64(elemSize)
    return ptr_add(buffer, int32(off64))

fn mbRead[T](seqInst: T[], idx: int32): T =
    let p: T* = T*(mbSeqElemPtr(seqInst.buffer, seqInst.len, idx, sizeof T))
    return *p

fn mbWrite[T](seqInst: T[]*, idx: int32, val: T) =
    if seqInst == nil:
        panic "mir_builder: nil seq pointer"
    let p: T* = T*(mbSeqElemPtr(seqInst->buffer, seqInst->len, idx, sizeof T))
    *p = val

fn mbWriteBool(seqInst: bool[]*, idx: int32, val: bool) =
    if seqInst == nil:
        panic "mir_builder: nil seq pointer"
    let p: bool* = bool*(mbSeqElemPtr(seqInst->buffer, seqInst->len, idx, sizeof bool))
    *p = val

fn mbWriteStr(seqInst: str[]*, idx: int32, val: str) =
    if seqInst == nil:
        panic "mir_builder: nil seq pointer"
    let p: str* = str*(mbSeqElemPtr(seqInst->buffer, seqInst->len, idx, sizeof str))
    *p = val

fn mbWriteObjLocal(seqInst: MirObjLocal[]*, idx: int32, val: MirObjLocal) =
    if seqInst == nil:
        panic "mir_builder: nil seq pointer"
    let p: MirObjLocal* = MirObjLocal*(mbSeqElemPtr(seqInst->buffer, seqInst->len, idx, sizeof MirObjLocal))
    *p = val

fn mbWriteObjType(seqInst: MirObjType[]*, idx: int32, val: MirObjType) =
    if seqInst == nil:
        panic "mir_builder: nil seq pointer"
    let p: MirObjType* = MirObjType*(mbSeqElemPtr(seqInst->buffer, seqInst->len, idx, sizeof MirObjType))
    *p = val

fn mbWriteGlobal(seqInst: MirGlobal[]*, idx: int32, val: MirGlobal) =
    if seqInst == nil:
        panic "mir_builder: nil seq pointer"
    let p: MirGlobal* = MirGlobal*(mbSeqElemPtr(seqInst->buffer, seqInst->len, idx, sizeof MirGlobal))
    *p = val

fn mbWriteFunc(seqInst: MirFunc[]*, idx: int32, val: MirFunc) =
    if seqInst == nil:
        panic "mir_builder: nil seq pointer"
    let p: MirFunc* = MirFunc*(mbSeqElemPtr(seqInst->buffer, seqInst->len, idx, sizeof MirFunc))
    *p = val

fn localEnvNew(): LocalEnv =
    var env: LocalEnv
    new env
    env.names = []
    env.types = []
    env.typeKeys = []
    env.callTargets = []
    env.active = []
    env.scopeMarks = []
    env.nameIndex = hashmaps.hashMapStrIntInit(64)
    env.prevSlots = []
    return env

fn localEnvPushScope(env: LocalEnv) =
    if env == nil:
        return
    add(env.scopeMarks, env.names.len)

fn localEnvPopScope(env: LocalEnv) =
    if env == nil || env.scopeMarks.len == 0:
        return
    let mark: int32 = mbRead(env.scopeMarks, env.scopeMarks.len - 1)
    env.scopeMarks.len = env.scopeMarks.len - 1
    if mark < 0:
        return
    let __for_start_slot = env.names.len - 1
    for __for_rev_slot in 0..(__for_start_slot - (mark)):
        let slot = __for_start_slot - __for_rev_slot
        if slot >= 0 && slot < env.names.len && slot < env.prevSlots.len:
            let nm: str = mbRead(env.names, slot)
            let prev: int32 = mbRead(env.prevSlots, slot)
            let restore: int32 = (prev >= 0) ? (prev + 1) : 0
            hashmaps.hashMapStrIntPut(env.nameIndex, nm, restore)
    for i in mark..<env.active.len:
        mbWriteBool(&env.active, i, false)

fn localIndex(env: LocalEnv, name: str): int32 =
    if env == nil:
        return -1
    if name == nil || len(name) == 0:
        return -1
    let query: str = backendStripSpacesMaybe(name)
    if query == nil || len(query) == 0:
        return -1
    let idxPlus1: int32 = hashmaps.hashMapStrIntGet(env.nameIndex, query)
    if idxPlus1 <= 0:
        return -1
    let idx: int32 = idxPlus1 - 1
    if env.active.len == env.names.len && idx < env.active.len && !mbRead(env.active, idx):
        return -1
    return idx

fn localAdd(env: LocalEnv, name: str, ty: MirType): int32 =
    if env == nil:
        return -1
    let nm: str = backendStripSpaces(name)
    if (getEnv "CHENG_BACKEND_DEBUG_LET" == "1") && (nm == "snapRes"):
        let mark: int32 = (env.scopeMarks.len > 0) ? mbRead(env.scopeMarks, env.scopeMarks.len - 1) : -1
        echo("[backend] debugLocalAdd: name='snapRes' slot=" + intToStr(env.names.len) +
             " scopeMarks=" + intToStr(env.scopeMarks.len) + " topMark=" + intToStr(mark))
    trackLexString void*(nm)
    let prevPlus1: int32 = hashmaps.hashMapStrIntGet(env.nameIndex, nm)
    let prevSlot: int32 = (prevPlus1 > 0) ? (prevPlus1 - 1) : -1
    add(env.names, nm)
    add(env.types, ty)
    add(env.typeKeys, "")
    add(env.callTargets, "")
    add(env.active, true)
    add(env.prevSlots, prevSlot)
    hashmaps.hashMapStrIntPut(env.nameIndex, nm, env.names.len)
    return env.names.len - 1

fn localType(env: LocalEnv, idx: int32): MirType =
    if env == nil || idx < 0 || idx >= env.types.len:
        return mirTypeI32()
    return mbRead(env.types, idx)

fn localTypeKey(env: LocalEnv, idx: int32): str =
    if env == nil || idx < 0 || idx >= env.typeKeys.len:
        return ""
    return mbRead(env.typeKeys, idx)

fn localCallTarget(env: LocalEnv, idx: int32): str =
    if env == nil || idx < 0 || idx >= env.callTargets.len:
        return ""
    return mbRead(env.callTargets, idx)

fn localSetTypeKey(env: LocalEnv, idx: int32, key: str) =
    if env == nil || key == nil || len(key) == 0:
        return
    if idx < 0 || idx >= env.typeKeys.len:
        return
    trackLexString void*(key)
    mbWriteStr(&env.typeKeys, idx, key)

fn localSetCallTarget(env: LocalEnv, idx: int32, target: str) =
    if env == nil || target == nil || len(target) == 0:
        return
    if idx < 0 || idx >= env.callTargets.len:
        return
    trackLexString void*(target)
    mbWriteStr(&env.callTargets, idx, target)

fn alignUpPow2(value: int32, alignPow2: int32): int32 =
    if alignPow2 <= 0:
        return value
    let align: int32 = 1 << alignPow2
    let rem: int32 = value % align
    if rem == 0:
        return value
    return value + (align - rem)

fn funcFindObjLocal(func: MirFunc, slot: int32): int32 =
    if func == nil:
        return -1
    for i in 0..<func.objLocals.len:
        let ol: MirObjLocal = mbRead(func.objLocals, i)
        if ol.slot == slot:
            return i
    return -1

fn funcObjTypeName(func: MirFunc, slot: int32): str =
    let idx: int32 = funcFindObjLocal(func, slot)
    if idx < 0:
        return ""
    let ol: MirObjLocal = mbRead(func.objLocals, idx)
    return ol.objTypeName

fn funcObjTypeKey(func: MirFunc, slot: int32): str =
    let idx: int32 = funcFindObjLocal(func, slot)
    if idx < 0:
        return ""
    let ol: MirObjLocal = mbRead(func.objLocals, idx)
    if ol.typeKey != nil && len(ol.typeKey) > 0:
        return ol.typeKey
    return ol.objTypeName

fn funcSetObjTypeKey(func: MirFunc, slot: int32, typeKey: str) =
    if func == nil || typeKey == nil || len(typeKey) == 0:
        return
    let idx: int32 = funcFindObjLocal(func, slot)
    if idx < 0:
        return
    var ol: MirObjLocal = mbRead(func.objLocals, idx)
    ol.typeKey = typeKey
    mbWriteObjLocal(&func.objLocals, idx, ol)

fn typeNodeObjTypeName(module: MirModule, typeNode: Node): str =
    if module == nil || typeNode == nil:
        return ""
    if typeNode.kind == nkVarTy && kidCount(typeNode) > 0:
        return typeNodeObjTypeName(module, kid(typeNode, 0))
    if (typeNode.kind == nkRefTy || typeNode.kind == nkPtrTy) && kidCount(typeNode) > 0:
        return typeNodeObjTypeName(module, kid(typeNode, 0))
    if typeNode.kind == nkDotExpr && kidCount(typeNode) > 1:
        return typeNodeObjTypeName(module, kid(typeNode, 1))
    if typeNode.kind == nkTupleTy:
        let key: str = typeKey(typeNode)
        # Record tuple field labels (if any) so `t.foo` can resolve to `fN` fields.
        if len(key) > 0:
            for ti in 0..<kidCount(typeNode):
                let elemNode0: Node = kid(typeNode, ti)
                var elemTypeNode0: Node = elemNode0
                var fieldLabel0: str = ""
                if elemNode0 != nil && elemNode0.kind == nkIdentDefs:
                    if kidCount(elemNode0) > 0:
                        let nameNode0: Node = kid(elemNode0, 0)
                        if nameNode0 != nil && (nameNode0.kind == nkIdent || nameNode0.kind == nkSymbol):
                            fieldLabel0 = backendStripSpaces(plainName(nameNode0))
                    if kidCount(elemNode0) > 1:
                        elemTypeNode0 = kid(elemNode0, 1)
                var elemTypeKey0: str = ""
                if elemTypeNode0 != nil && elemTypeNode0.kind == nkDotExpr && kidCount(elemTypeNode0) > 1:
                    elemTypeKey0 = typeKey(kid(elemTypeNode0, 1))
                else:
                    elemTypeKey0 = typeKey(elemTypeNode0)
                if len(elemTypeKey0) == 0 && elemTypeNode0 != nil:
                    elemTypeKey0 = backendStripSpaces(plainName(elemTypeNode0))
                let fName0: str = "f" + intToStr(ti)
                if len(elemTypeKey0) > 0:
                    mirObjFieldTypeKeyPut(key, fName0, elemTypeKey0)
                    if len(fieldLabel0) > 0:
                        mirObjFieldTypeKeyPut(key, fieldLabel0, elemTypeKey0)
                if len(fieldLabel0) > 0:
                    mirTupleFieldIndexPut(key, fieldLabel0, ti)
        if len(key) > 0 && ! mirHasObjType(module, key):
            var fields: MirObjField[]
            var offset: int32 = 0
            var maxAlignPow2: int32 = 0
            for i in 0..<kidCount(typeNode):
                let elemNode: Node = kid(typeNode, i)
                var elemTypeNode: Node = elemNode
                if elemNode != nil && elemNode.kind == nkIdentDefs && kidCount(elemNode) > 1:
                    elemTypeNode = kid(elemNode, 1)
                if elemTypeNode == nil || elemTypeNode.kind == nkEmpty:
                    return ""
                let elemTy: MirType = mirTypeFromNodeWithModule(module, elemTypeNode)
                let fieldSize: int32 = mirTypeSize(elemTy)
                if fieldSize <= 0:
                    return ""
                let alignPow2: int32 = mirTypeAlignPow2(elemTy)
                if alignPow2 > maxAlignPow2:
                    maxAlignPow2 = alignPow2
                offset = alignUpPow2(offset, alignPow2)
                var f: MirObjField
                f.name = "f" + intToStr(i)
                f.ty = elemTy
                f.offset = offset
                add(fields, f)
                offset = offset + fieldSize
            var ot: MirObjType
            ot.name = key
            ot.alignPow2 = maxAlignPow2
            ot.size = alignUpPow2(offset, maxAlignPow2)
            ot.fields = fields
            mirAddObjType(module, ot)
        if len(key) > 0 && mirHasObjType(module, key):
            return key
        return ""
    if typeNode.kind == nkIdent || typeNode.kind == nkSymbol:
        let nm: str = backendStripSpaces(plainName(typeNode))
        if mirHasObjType(module, nm):
            return nm
        let canon: str = mirObjAliasCanon(nm)
        if canon != nil && len(canon) > 0 && !(canon == nm) && mirHasObjType(module, canon):
            return canon
        # Seq instantiations often appear as flattened idents (e.g. `seq_str`).
        # They share the builtin `seq` layout.
        if mirStrStartsWith(nm, "seq_") && mirHasObjType(module, "seq"):
            return "seq"
        if mirStrStartsWith(nm, "seq_fixed_") && mirHasObjType(module, "seq"):
            return "seq"
        # stdlib `tables.Table[V]` has a stable layout; instantiations share builtin `Table`.
        if mirStrStartsWith(nm, "Table_") && mirHasObjType(module, "Table"):
            return "Table"
        if mirStrStartsWith(nm, "SeqUninit_") && ensureSeqUninitObjType(module, nm):
            return nm
        if mirStrStartsWith(nm, "Option_") && ensureOptionObjType(module, nm):
            return nm
        if mirStrStartsWith(nm, "Result_") && ensureResultObjType(module, nm):
            return nm
        if mirStrStartsWith(nm, "__cheng_tables_Entry_"):
            if ensureTablesEntryObjType(module, nm):
                return nm
        return ""
    if typeNode.kind == nkBracketExpr && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if base != nil:
            let nm3: str = backendStripSpaces(plainName(base))
            if (nm3 == "seq") && mirHasObjType(module, "seq"):
                return "seq"
            if (nm3 == "seq_fixed") && mirHasObjType(module, "seq"):
                return "seq"
            if (nm3 == "Table") && mirHasObjType(module, "Table"):
                return "Table"
            var instArgs: Node[4]
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if a != nil && a.kind != nkEmpty:
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm3, instArgs)
                if (nm3 == "array"):
                    if ensureArrayObjTypeFromTypeExpr(module, typeNode, instName):
                        return instName
                if (nm3 == "SeqUninit") && ensureSeqUninitObjType(module, instName):
                    return instName
                if (nm3 == "Option") && ensureOptionObjType(module, instName):
                    return instName
                if (nm3 == "Result") && ensureResultObjType(module, instName):
                    return instName
                if mirHasObjType(module, instName):
                    return instName
                if (nm3 == "__cheng_tables_Entry") && ensureTablesEntryObjType(module, instName):
                    return instName
                # Default type parameters: stage1 may canonicalize to a longer instantiated name.
                # If there's exactly one object type with this prefix, use it.
                let prefix: str = instName + "_"
                var foundName: str = ""
                var foundCount: int32 = 0
                for oi in 0..<module.objTypes.len:
                    let ot: MirObjType = module.objTypes[oi]
                    if ot.name != nil && mirStrStartsWith(ot.name, prefix):
                        foundName = ot.name
                        foundCount = foundCount + 1
                        if foundCount > 1:
                            break
                if foundCount == 1 && len(foundName) > 0 && mirHasObjType(module, foundName):
                    return foundName
    return ""

fn typeNodeIsObjValue(module: MirModule, typeNode: Node): bool =
    if module == nil || typeNode == nil:
        return false
    if typeNode.kind == nkVarTy && kidCount(typeNode) > 0:
        return typeNodeIsObjValue(module, kid(typeNode, 0))
    if typeNode.kind == nkDotExpr && kidCount(typeNode) > 1:
        return typeNodeIsObjValue(module, kid(typeNode, 1))
    if typeNode.kind == nkTupleTy:
        let nm: str = typeNodeObjTypeName(module, typeNode)
        return len(nm) > 0
    if typeNode.kind == nkIdent || typeNode.kind == nkSymbol:
        let nm: str = backendStripSpaces(plainName(typeNode))
        if mirHasObjType(module, nm):
            # Ref-like types are represented as pointer aliases + object layout.
            let aliasTy: MirType = mirTryGetTypeAlias(module, nm)
            if aliasTy.kind != mtVoid:
                return false
            if typeNode != nil && typeNode.typeCacheValid && typeNode.typeCache != nil:
                let tc: Node = typeNode.typeCache
                if tc.kind == nkRefTy || tc.kind == nkPtrTy:
                    return false
            return true
        if mirStrStartsWith(nm, "seq_") && mirHasObjType(module, "seq"):
            return true
        if mirStrStartsWith(nm, "seq_fixed_") && mirHasObjType(module, "seq"):
            return true
        if mirStrStartsWith(nm, "Table_") && mirHasObjType(module, "Table"):
            return true
        if mirStrStartsWith(nm, "SeqUninit_") && ensureSeqUninitObjType(module, nm):
            return true
        if mirStrStartsWith(nm, "Option_") && ensureOptionObjType(module, nm):
            return true
        if mirStrStartsWith(nm, "Result_") && ensureResultObjType(module, nm):
            return true
        if mirStrStartsWith(nm, "__cheng_tables_Entry_"):
            return ensureTablesEntryObjType(module, nm)
        return false
    if typeNode.kind == nkBracketExpr && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if base != nil:
            let nm2: str = backendStripSpaces(plainName(base))
            if (nm2 == "seq") && mirHasObjType(module, "seq"):
                return true
            if (nm2 == "seq_fixed") && mirHasObjType(module, "seq"):
                return true
            if (nm2 == "Table") && mirHasObjType(module, "Table"):
                return true
            var instArgs: Node[4]
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if a != nil && a.kind != nkEmpty:
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm2, instArgs)
                if (nm2 == "array") && ensureArrayObjTypeFromTypeExpr(module, typeNode, instName):
                    return true
                if (nm2 == "SeqUninit") && ensureSeqUninitObjType(module, instName):
                    return true
                if (nm2 == "Option") && ensureOptionObjType(module, instName):
                    return true
                if (nm2 == "Result") && ensureResultObjType(module, instName):
                    return true
                if mirHasObjType(module, instName):
                    return true
                if (nm2 == "__cheng_tables_Entry") && ensureTablesEntryObjType(module, instName):
                    return true
                return false
    return false

fn ensureBuiltinObjTypes(module: MirModule) =
    if module == nil:
        return
    if ! mirHasObjType(module, "seq"):
        var fields: MirObjField[]
        var f0: MirObjField
        f0.name = "len"
        f0.ty = mirTypeI32()
        f0.offset = 0
        add(fields, f0)
        var f1: MirObjField
        f1.name = "cap"
        f1.ty = mirTypeI32()
        f1.offset = 4
        add(fields, f1)
        var f2: MirObjField
        f2.name = "buffer"
        f2.ty = mirTypeI64()
        f2.offset = 8
        add(fields, f2)
        var ot: MirObjType
        ot.name = "seq"
        ot.size = 16
        ot.alignPow2 = 3
        ot.fields = fields
        mirAddObjType(module, ot)
    if ! mirHasObjType(module, "Table"):
        # stdlib `tables.Table[V]` (generic) has a stable layout independent of V:
        #   keys: seq[str]      (inlined as keys.len/cap/buffer)
        #   vals: seq[V]        (inlined as vals.len/cap/buffer)
        #   states: seq[uint8]  (inlined as states.len/cap/buffer)
        #   len: int32
        var fields2: MirObjField[]
        var f0: MirObjField
        f0.name = "keys.len"
        f0.ty = mirTypeI32()
        f0.offset = 0
        add(fields2, f0)
        var f1: MirObjField
        f1.name = "keys.cap"
        f1.ty = mirTypeI32()
        f1.offset = 4
        add(fields2, f1)
        var f2: MirObjField
        f2.name = "keys.buffer"
        f2.ty = mirTypeI64()
        f2.offset = 8
        add(fields2, f2)
        var f3: MirObjField
        f3.name = "vals.len"
        f3.ty = mirTypeI32()
        f3.offset = 16
        add(fields2, f3)
        var f4: MirObjField
        f4.name = "vals.cap"
        f4.ty = mirTypeI32()
        f4.offset = 20
        add(fields2, f4)
        var f5: MirObjField
        f5.name = "vals.buffer"
        f5.ty = mirTypeI64()
        f5.offset = 24
        add(fields2, f5)
        var f6: MirObjField
        f6.name = "states.len"
        f6.ty = mirTypeI32()
        f6.offset = 32
        add(fields2, f6)
        var f7: MirObjField
        f7.name = "states.cap"
        f7.ty = mirTypeI32()
        f7.offset = 36
        add(fields2, f7)
        var f8: MirObjField
        f8.name = "states.buffer"
        f8.ty = mirTypeI64()
        f8.offset = 40
        add(fields2, f8)
        var f9: MirObjField
        f9.name = "len"
        f9.ty = mirTypeI32()
        f9.offset = 48
        add(fields2, f9)
        var ot2: MirObjType
        ot2.name = "Table"
        ot2.size = 56
        ot2.alignPow2 = 3
        ot2.fields = fields2
        mirAddObjType(module, ot2)

fn ensureTablesEntryObjType(module: MirModule, entryName: str): bool =
    if module == nil || entryName == nil || len(entryName) == 0:
        return false
    if mirHasObjType(module, entryName):
        return true
    let prefix: str = "__cheng_tables_Entry_"
    if ! mirStrStartsWith(entryName, prefix):
        return false
    let valKey: str = str(ptr_add(void*(entryName), len(prefix)))
    if valKey == nil || len(valKey) == 0:
        return false
    # Entry layout: `{ key: str, val: V }`
    let pos: SourcePos = zeroPos()
    let valTypeNode: Node = newIdent(valKey, pos)
    let valTy: MirType = mirTypeFromNodeWithModule(module, valTypeNode)
    let valSize: int32 = mirTypeSize(valTy)
    if valSize <= 0:
        return false
    let valAlignPow2: int32 = mirTypeAlignPow2(valTy)
    var fields: MirObjField[]
    var f0: MirObjField
    f0.name = "key"
    f0.ty = mirTypeI64()
    f0.offset = 0
    add(fields, f0)
    var offset: int32 = 8
    offset = alignUpPow2(offset, valAlignPow2)
    var f1: MirObjField
    f1.name = "val"
    f1.ty = valTy
    f1.offset = offset
    add(fields, f1)
    var maxAlignPow2: int32 = 3
    if valAlignPow2 > maxAlignPow2:
        maxAlignPow2 = valAlignPow2
    let size: int32 = alignUpPow2(offset + valSize, maxAlignPow2)
    var ot: MirObjType
    ot.name = entryName
    ot.alignPow2 = maxAlignPow2
    ot.size = size
    ot.fields = fields
    mirAddObjType(module, ot)
    return true

fn ensureOptionObjType(module: MirModule, optionName: str): bool =
    if module == nil || optionName == nil || len(optionName) == 0:
        return false
    if mirHasObjType(module, optionName):
        return true
    let prefix: str = "Option_"
    if !mirStrStartsWith(optionName, prefix):
        return false
    let valKey: str = str(ptr_add(void*(optionName), len(prefix)))
    if valKey == nil || len(valKey) == 0:
        return false
    var hasObjVal: bool = mirHasObjType(module, valKey)
    if !hasObjVal:
        let valCanon0: str = mirObjAliasCanon(valKey)
        if valCanon0 != nil && len(valCanon0) > 0 && mirHasObjType(module, valCanon0):
            hasObjVal = true
    if !isBuiltinTypeName(valKey) && !hasObjVal:
        let aliasTyCheck: MirType = mirTryGetTypeAlias(module, valKey)
        if aliasTyCheck.kind == mtVoid:
            return false
    var fields: MirObjField[]
    var f0: MirObjField
    f0.name = "has"
    f0.ty = mirTypeU8()
    f0.offset = 0
    add(fields, f0)
    var maxAlignPow2: int32 = 0
    var offset: int32 = 1
    if mirHasObjType(module, valKey):
        let inner: MirObjType = mirGetObjType(module, valKey)
        if inner.size <= 0 || inner.fields.len == 0:
            return false
        let alignPow2: int32 = inner.alignPow2
        if alignPow2 > maxAlignPow2:
            maxAlignPow2 = alignPow2
        offset = alignUpPow2(offset, alignPow2)
        for fi in 0..<inner.fields.len:
            let innerF: MirObjField = inner.fields[fi]
            var f: MirObjField
            f.name = "value." + innerF.name
            f.ty = innerF.ty
            f.offset = offset + innerF.offset
            add(fields, f)
        offset = offset + inner.size
        mirInlineObjFieldTypePut(optionName, "value", valKey)
    else:
        let pos: SourcePos = zeroPos()
        let valTypeNode: Node = newIdent(valKey, pos)
        let valTy: MirType = mirTypeFromNodeWithModule(module, valTypeNode)
        let valSize: int32 = mirTypeSize(valTy)
        if valSize <= 0:
            return false
        let valAlignPow2: int32 = mirTypeAlignPow2(valTy)
        if valAlignPow2 > maxAlignPow2:
            maxAlignPow2 = valAlignPow2
        offset = alignUpPow2(offset, valAlignPow2)
        var f1: MirObjField
        f1.name = "value"
        f1.ty = valTy
        f1.offset = offset
        add(fields, f1)
        offset = offset + valSize
    var ot: MirObjType
    ot.name = optionName
    ot.alignPow2 = maxAlignPow2
    ot.size = alignUpPow2(offset, maxAlignPow2)
    ot.fields = fields
    mirAddObjType(module, ot)
    return true

fn ensureResultObjType(module: MirModule, resultName: str): bool =
    if module == nil || resultName == nil || len(resultName) == 0:
        return false
    if mirHasObjType(module, resultName):
        return true
    let prefix: str = "Result_"
    if !mirStrStartsWith(resultName, prefix):
        return false
    let valKey: str = str(ptr_add(void*(resultName), len(prefix)))
    if valKey == nil || len(valKey) == 0:
        return false
    var hasObjVal: bool = mirHasObjType(module, valKey)
    if !hasObjVal:
        let valCanon0: str = mirObjAliasCanon(valKey)
        if valCanon0 != nil && len(valCanon0) > 0 && mirHasObjType(module, valCanon0):
            hasObjVal = true

    var errObjName: str = "ErrorInfo"
    if !mirHasObjType(module, errObjName):
        let errCanon: str = mirObjAliasCanon(errObjName)
        if errCanon != nil && len(errCanon) > 0 && mirHasObjType(module, errCanon):
            errObjName = errCanon
    if !mirHasObjType(module, errObjName):
        return false
    let errObj: MirObjType = mirGetObjType(module, errObjName)
    if errObj.size <= 0 || errObj.fields.len == 0:
        return false

    var fields: MirObjField[]
    var maxAlignPow2: int32 = 0
    var offset: int32 = 0

    var f0: MirObjField
    f0.name = "ok"
    f0.ty = mirTypeU8()
    f0.offset = 0
    add(fields, f0)
    let okAlign: int32 = mirTypeAlignPow2(f0.ty)
    if okAlign > maxAlignPow2:
        maxAlignPow2 = okAlign
    offset = 1

    var valObjName: str = ""
    if hasObjVal && mirHasObjType(module, valKey):
        valObjName = valKey
    elif hasObjVal:
        let valCanon: str = mirObjAliasCanon(valKey)
        if valCanon != nil && len(valCanon) > 0 && mirHasObjType(module, valCanon):
            valObjName = valCanon
    let valAliasTy: MirType = mirTryGetTypeAlias(module, valKey)
    let inlineValObj: bool = valObjName != nil && len(valObjName) > 0 && valAliasTy.kind == mtVoid
    mirObjFieldTypeKeyPut(resultName, "value", valKey)
    if inlineValObj:
        let inner: MirObjType = mirGetObjType(module, valObjName)
        if inner.size <= 0 || inner.fields.len == 0:
            return false
        let alignPow2: int32 = inner.alignPow2
        if alignPow2 > maxAlignPow2:
            maxAlignPow2 = alignPow2
        offset = alignUpPow2(offset, alignPow2)
        for fi in 0..<inner.fields.len:
            let innerF: MirObjField = inner.fields[fi]
            var f: MirObjField
            f.name = "value." + innerF.name
            f.ty = innerF.ty
            f.offset = offset + innerF.offset
            add(fields, f)
        offset = offset + inner.size
        mirInlineObjFieldTypePut(resultName, "value", valObjName)
    else:
        var valTy: MirType
        if valAliasTy.kind != mtVoid:
            valTy = valAliasTy
        else:
            valTy = mirTypeFromTypeKeyName(valKey)
        let valSize: int32 = mirTypeSize(valTy)
        if valSize <= 0:
            return false
        let valAlignPow2: int32 = mirTypeAlignPow2(valTy)
        if valAlignPow2 > maxAlignPow2:
            maxAlignPow2 = valAlignPow2
        offset = alignUpPow2(offset, valAlignPow2)
        var f1: MirObjField
        f1.name = "value"
        f1.ty = valTy
        f1.offset = offset
        add(fields, f1)
        offset = offset + valSize

    mirObjFieldTypeKeyPut(resultName, "err", errObjName)
    let errAlignPow2: int32 = errObj.alignPow2
    if errAlignPow2 > maxAlignPow2:
        maxAlignPow2 = errAlignPow2
    offset = alignUpPow2(offset, errAlignPow2)
    for ei in 0..<errObj.fields.len:
        let errF: MirObjField = errObj.fields[ei]
        var ef: MirObjField
        ef.name = "err." + errF.name
        ef.ty = errF.ty
        ef.offset = offset + errF.offset
        add(fields, ef)
    offset = offset + errObj.size
    mirInlineObjFieldTypePut(resultName, "err", errObjName)

    var ot: MirObjType
    ot.name = resultName
    ot.alignPow2 = maxAlignPow2
    ot.size = alignUpPow2(offset, maxAlignPow2)
    ot.fields = fields
    mirAddObjType(module, ot)
    return true

fn tryResolveArrayCount(module: MirModule, n0: Node): int32 =
    if module == nil || n0 == nil:
        return -1
    var n: Node = n0
    while n != nil && n.kind == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if n == nil:
        return -1
    if n.kind == nkIntLit:
        return int32(n.intVal)
    if n.kind == nkIdent || n.kind == nkSymbol:
        let nm: str = backendStripSpaces(plainName(n))
        let gi: int32 = moduleGlobalIndex(module, nm)
        if gi >= 0:
            let g: MirGlobal = module.globals[gi]
            if g.hasInit:
                return int32(g.init)
    return -1

fn ensureArrayObjTypeFromElemKey(module: MirModule, arrName: str, elemKey0: str, count: int32): bool =
    if module == nil || arrName == nil || len(arrName) == 0 || elemKey0 == nil || len(elemKey0) == 0 || count <= 0:
        return false
    if mirHasObjType(module, arrName):
        return true
    let elemKey: str = backendStripSpaces(elemKey0)
    if elemKey == nil || len(elemKey) == 0:
        return false
    let elemObjName: str = mirObjTypeFromTypeKey(module, elemKey)
    var elemTy: MirType = mirTypeFromTypeKeyName(elemKey)
    if elemObjName != nil && len(elemObjName) > 0:
        if !mirHasObjType(module, elemObjName):
            return false
        elemTy = mirTypeI64()
    else:
        let aliasTy: MirType = mirTryGetTypeAlias(module, elemKey)
        if !isBuiltinTypeName(elemKey) && aliasTy.kind == mtVoid:
            return false
        if aliasTy.kind != mtVoid:
            elemTy = aliasTy
    let elemSize: int32 = mirTypeSize(elemTy)
    if elemSize <= 0:
        return false
    let elemAlignPow2: int32 = mirTypeAlignPow2(elemTy)
    let stride: int32 = alignUpPow2(elemSize, elemAlignPow2)
    if stride <= 0:
        return false
    var fields: MirObjField[]
    var off: int32 = 0
    for i in 0..<count:
        var f: MirObjField
        f.name = "e" + intToStr(i)
        f.ty = elemTy
        f.offset = off
        add(fields, f)
        off = off + stride
    var ot: MirObjType
    ot.name = arrName
    ot.alignPow2 = elemAlignPow2
    ot.size = alignUpPow2(off, elemAlignPow2)
    ot.fields = fields
    mirAddObjType(module, ot)
    return true

fn ensureSeqUninitObjType(module: MirModule, seqName0: str): bool =
    if module == nil || seqName0 == nil || len(seqName0) == 0:
        return false
    let seqName: str = backendStripSpaces(seqName0)
    if seqName == nil || len(seqName) == 0 || !mirStrStartsWith(seqName, "SeqUninit_"):
        return false
    if mirHasObjType(module, seqName):
        return true
    let elemKey: str = str(ptr_add(void*(seqName), 10))
    if elemKey == nil || len(elemKey) == 0:
        return false
    let seqCap: int32 = 256
    let itemsObjName: str = "array_" + intToStr(seqCap) + "_" + elemKey
    if !ensureArrayObjTypeFromElemKey(module, itemsObjName, elemKey, seqCap):
        return false
    let itemsObj: MirObjType = mirGetObjType(module, itemsObjName)
    if itemsObj.name == nil || len(itemsObj.name) == 0 || itemsObj.size <= 0:
        return false

    var fields: MirObjField[]
    var maxAlignPow2: int32 = 0

    let countTy: MirType = mirTypeI32()
    let countAlignPow2: int32 = mirTypeAlignPow2(countTy)
    var countField: MirObjField
    countField.name = "count"
    countField.ty = countTy
    countField.offset = 0
    add(fields, countField)
    mirObjFieldTypeKeyPut(seqName, "count", "int32")
    if countAlignPow2 > maxAlignPow2:
        maxAlignPow2 = countAlignPow2

    let itemsAlignPow2: int32 = itemsObj.alignPow2
    if itemsAlignPow2 > maxAlignPow2:
        maxAlignPow2 = itemsAlignPow2
    let itemsBaseOff: int32 = alignUpPow2(4, itemsAlignPow2)
    for fi in 0..<itemsObj.fields.len:
        let innerF: MirObjField = itemsObj.fields[fi]
        var f: MirObjField
        f.name = "items." + innerF.name
        f.ty = innerF.ty
        f.offset = itemsBaseOff + innerF.offset
        add(fields, f)
    mirObjFieldTypeKeyPut(seqName, "items", itemsObjName)
    mirInlineObjFieldTypePut(seqName, "items", itemsObjName)

    var ot: MirObjType
    ot.name = seqName
    ot.alignPow2 = maxAlignPow2
    ot.size = alignUpPow2(itemsBaseOff + itemsObj.size, maxAlignPow2)
    ot.fields = fields
    mirAddObjType(module, ot)
    return true

fn ensureArrayObjTypeFromTypeExpr(module: MirModule, arrType: Node, arrName: str): bool =
    if module == nil || arrType == nil || arrName == nil || len(arrName) == 0:
        return false
    if mirHasObjType(module, arrName):
        return true
    if arrType.kind != nkBracketExpr || kidCount(arrType) < 3:
        return false
    let base: Node = kid(arrType, 0)
    if base == nil || (base.kind != nkIdent && base.kind != nkSymbol):
        return false
    let baseName: str = backendStripSpaces(plainName(base))
    if !(baseName == "array"):
        return false
    let arg1: Node = kid(arrType, 1)
    let arg2: Node = kid(arrType, 2)
    if arg1 == nil || arg2 == nil || arg1.kind == nkEmpty || arg2.kind == nkEmpty:
        return false

    let c1: int32 = tryResolveArrayCount(module, arg1)
    let c2: int32 = tryResolveArrayCount(module, arg2)
    var count: int32 = -1
    var elemTypeNode: Node = nil
    if c1 > 0 && c2 <= 0:
        count = c1
        elemTypeNode = arg2
    elif c2 > 0 && c1 <= 0:
        count = c2
        elemTypeNode = arg1
    elif c1 > 0 && c2 > 0:
        # Ambiguous; prefer `array[Count, ElemType]`.
        count = c1
        elemTypeNode = arg2
    if count <= 0 || elemTypeNode == nil || elemTypeNode.kind == nkEmpty:
        return false

    # If element type isn't resolved yet, defer array layout creation so we don't
    # lock in an incorrect element representation (e.g. unknown object types default to i32).
    if elemTypeNode.kind == nkIdent || elemTypeNode.kind == nkSymbol:
        let elemName: str = backendStripSpaces(plainName(elemTypeNode))
        if len(elemName) > 0 && !isBuiltinTypeName(elemName):
            if !mirHasObjType(module, elemName):
                let aliasTy: MirType = mirTryGetTypeAlias(module, elemName)
                if aliasTy.kind == mtVoid:
                    return false

    var elemTy: MirType = mirTypeFromNodeWithModule(module, elemTypeNode)
    let elemObjName: str = typeNodeObjTypeName(module, elemTypeNode)
    if len(elemObjName) > 0 && typeNodeIsObjValue(module, elemTypeNode):
        elemTy = mirTypeI64()
    let elemSize: int32 = mirTypeSize(elemTy)
    if elemSize <= 0:
        return false
    let elemAlignPow2: int32 = mirTypeAlignPow2(elemTy)
    let stride: int32 = alignUpPow2(elemSize, elemAlignPow2)
    if stride <= 0:
        return false
    var fields: MirObjField[]
    var off: int32 = 0
    for i in 0..<count:
        var f: MirObjField
        f.name = "e" + intToStr(i)
        f.ty = elemTy
        f.offset = off
        add(fields, f)
        off = off + stride
    var ot: MirObjType
    ot.name = arrName
    ot.alignPow2 = elemAlignPow2
    ot.size = alignUpPow2(off, elemAlignPow2)
    ot.fields = fields
    mirAddObjType(module, ot)
    return true

fn mirCallCalleeName(callNode: Node): str =
    if callNode == nil || callNode.kind != nkCall || kidCount(callNode) == 0:
        return ""
    let callee: Node = kid(callNode, 0)
    if callee == nil:
        return ""
    if callee.kind == nkIdent || callee.kind == nkSymbol:
        return backendStripSpaces(plainName(callee))
    if callee.kind == nkDotExpr && kidCount(callee) > 1:
        let member: Node = kid(callee, 1)
        if member != nil && (member.kind == nkIdent || member.kind == nkSymbol):
            return backendStripSpaces(plainName(member))
        if member != nil && member.kind == nkBracketExpr && kidCount(member) > 0:
            let base2: Node = kid(member, 0)
            if base2 != nil && (base2.kind == nkIdent || base2.kind == nkSymbol):
                return backendStripSpaces(plainName(base2))
    if callee.kind == nkBracketExpr && kidCount(callee) > 0:
        let base: Node = kid(callee, 0)
        if base != nil && (base.kind == nkIdent || base.kind == nkSymbol):
            return backendStripSpaces(plainName(base))
    return ""

fn mirNodeIsTypeArgInCallNoEnv(module: MirModule, n: Node): bool =
    if module == nil || n == nil:
        return false
    case n.kind
    of nkPtrTy, nkRefTy, nkVarTy, nkFnTy, nkTupleTy, nkSetTy, nkBracketExpr:
        return true
    of nkIdent, nkSymbol:
        let nm: str = backendStripSpaces(plainName(n))
        if nm == nil || len(nm) == 0:
            return false
        if isBuiltinTypeName(nm):
            return true
        return mirFindTypeAlias(module, nm) >= 0 || mirFindObjType(module, nm) >= 0
    return false

fn mirCallNameForReachability(module: MirModule, callNode: Node): str =
    if callNode == nil || callNode.kind != nkCall || kidCount(callNode) == 0:
        return ""
    let callee: Node = kid(callNode, 0)
    if callee == nil:
        return ""
    var name: str = ""
    var typeArgs: Node[4]
    if callee.kind == nkIdent || callee.kind == nkSymbol:
        name = backendStripSpaces(plainName(callee))
    elif callee.kind == nkBracketExpr && kidCount(callee) > 0:
        let base: Node = kid(callee, 0)
        name = backendStripSpaces(plainName(base))
        for ti in 1..<kidCount(callee):
            let t: Node = kid(callee, ti)
            if t != nil && t.kind != nkEmpty:
                add(typeArgs, t)
    elif callee.kind == nkDotExpr && kidCount(callee) > 1:
        let member: Node = kid(callee, 1)
        if member != nil && member.kind == nkBracketExpr && kidCount(member) > 0:
            let base2: Node = kid(member, 0)
            name = backendStripSpaces(plainName(base2))
            for ti2 in 1..<kidCount(member):
                let t2: Node = kid(member, ti2)
                if t2 != nil && t2.kind != nkEmpty:
                    add(typeArgs, t2)
        else:
            name = backendStripSpaces(plainName(member))

    if name == nil || len(name) == 0:
        return ""
    if module != nil && typeArgs.len > 0:
        return mangleInstance(name, typeArgs)
    return name

fn mirCollectCallsDeep(module: MirModule, n: Node, out: str[]*) =
    if n == nil || out == nil:
        return
    if n.kind == nkComprehension:
        # Comprehensions lower to a loop that appends via `add`.
        mirAddStrPtr(out, "add")
    if n.kind == nkIdent || n.kind == nkSymbol:
        let nm: str = backendStripSpaces(plainName(n))
        if len(nm) > 0:
            mirAddStrPtr(out, nm)
    if n.kind == nkBracketExpr && kidCount(n) == 2:
        # Bracket syntax can target user-defined `[]` / `[]=` operators, which may be pruned by
        # reachability if we only follow explicit `nkCall` nodes.
        mirAddStrPtr(out, "[]")
    if (n.kind == nkAsgn || n.kind == nkFastAsgn) && kidCount(n) >= 2:
        let lhs0: Node = kid(n, 0)
        if lhs0 != nil && lhs0.kind == nkBracketExpr && kidCount(lhs0) == 2:
            mirAddStrPtr(out, "[]=")
        elif lhs0 != nil && (lhs0.kind == nkIdent || lhs0.kind == nkSymbol):
            # Simple assignments can target user-defined `=` operators.
            mirAddStrPtr(out, "=")
    if n.kind == nkCall:
        let name: str = mirCallNameForReachability(module, n)
        if len(name) > 0:
            mirAddStrPtr(out, name)
        if (name == "__addr") && kidCount(n) >= 2:
            var arg0: Node = kid(n, 1)
            if arg0 != nil && arg0.kind == nkCallArg && kidCount(arg0) > 1:
                arg0 = kid(arg0, 1)
            if arg0 != nil && (arg0.kind == nkIdent || arg0.kind == nkSymbol):
                let target: str = backendStripSpaces(plainName(arg0))
                if len(target) > 0:
                    mirAddStrPtr(out, target)
    for i in 0..<kidCount(n):
        mirCollectCallsDeep(module, kid(n, i), out)

fn mirIndexFnDecls(root: Node, outMap: hashmaps.HashMapStrSeqInt*, outNodes: Node[]*) =
    if root == nil || outMap == nil || outNodes == nil:
        return
    for i in 0..<kidCount(root):
        let n: Node = kid(root, i)
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkStmtList || n.kind == nkModule:
            mirIndexFnDecls(n, outMap, outNodes)
            continue
        if (n.kind == nkFnDecl || n.kind == nkIteratorDecl) && kidCount(n) > 0:
            let nameNode: Node = kid(n, 0)
            if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol):
                let nm: str = backendStripSpaces(plainName(nameNode))
                let idx: int32 = outNodes->len
                add(outNodes, n)
                hashmaps.hashMapStrSeqIntAdd(outMap, nm, idx)
                let sigOff: int32 = mirStrIndexOf(nm, mirFuncSigMarker())
                if sigOff > 0:
                    let base: str = mirStrTake(nm, sigOff)
                    if base != nil && len(base) > 0 && !(base == nm):
                        hashmaps.hashMapStrSeqIntAdd(outMap, base, idx)
                let modOff: int32 = mirStrIndexOf(nm, "__cheng_mod_")
                if modOff > 0:
                    let base2: str = mirStrTake(nm, modOff)
                    if base2 != nil && len(base2) > 0 && !(base2 == nm):
                        hashmaps.hashMapStrSeqIntAdd(outMap, base2, idx)

fn mirReachDeclIdxs(index: hashmaps.HashMapStrSeqInt, nodes: Node[], name: str, foundOut: bool* = nil): int32[] =
    var found: bool = false
    let idxs: int32[] = hashmaps.hashMapStrSeqIntGet(index, name, &found)
    if found && idxs.len > 0:
        if foundOut != nil:
            *foundOut = true
        return idxs
    var out: int32[]
    for i in 0..<nodes.len:
        let declNode: Node = nodes[i]
        if declNode == nil || kidCount(declNode) <= 0:
            continue
        let declNameNode: Node = kid(declNode, 0)
        if declNameNode == nil || (declNameNode.kind != nkIdent && declNameNode.kind != nkSymbol):
            continue
        let declName: str = backendStripSpaces(plainName(declNameNode))
        if declName == name:
            add(out, i)
    if foundOut != nil:
        *foundOut = out.len > 0
    return out

fn mirComputeReachableFns(module: MirModule, root: Node): hashsets.HashSetStr =
    let rootKids0: int32 = kidCount(root)
    let rootKids: int32 = (rootKids0 > 0) ? rootKids0 : 1
    let workCap: int32 = rootKids * 2 + 256
    var index: hashmaps.HashMapStrSeqInt = hashmaps.hashMapStrSeqIntInit(workCap)
    var nodes: Node[workCap]
    mirIndexFnDecls(root, &index, &nodes)

    var reachable: hashsets.HashSetStr = hashsets.hashSetStrInit(workCap)
    var queue: str[]
    queue.cap = workCap
    hashsets.hashSetStrAdd(reachable, "main")
    add(queue, "main")

    # Global initializers run before `main`, so their callees must be treated as reachable even
    # if they are not referenced from the function call graph rooted at `main`.
    var initWork: Node[]
    initWork.cap = workCap
    add(initWork, root)
    while initWork.len > 0:
        let n: Node = initWork[initWork.len - 1]
        initWork.len = initWork.len - 1
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkFnDecl || n.kind == nkIteratorDecl:
            continue
        if n.kind == nkLet || n.kind == nkVar || n.kind == nkConst:
            var callees: str[64]
            mirCollectCallsDeep(module, n, &callees)
            for ci in 0..<callees.len:
                let nm: str = callees[ci]
                var inProgram: bool = false
                let calleeIdxs: int32[] = mirReachDeclIdxs(index, nodes, nm, &inProgram)
                if inProgram && calleeIdxs.len > 0:
                    for ki in 0..<calleeIdxs.len:
                        let k: int32 = calleeIdxs[ki]
                        if k >= 0 && k < nodes.len:
                            let declNode: Node = nodes[k]
                            let declNameNode: Node = (declNode != nil && kidCount(declNode) > 0) ? kid(declNode, 0) : nil
                            if declNameNode != nil && (declNameNode.kind == nkIdent || declNameNode.kind == nkSymbol):
                                let declName: str = backendStripSpaces(plainName(declNameNode))
                                if len(declName) > 0 && !hashsets.hashSetStrHas(reachable, declName):
                                    hashsets.hashSetStrAdd(reachable, declName)
                                    add(queue, declName)
        for i in 0..<kidCount(n):
            add(initWork, kid(n, i))

    for qi in 0..<queue.len:
        let cur: str = queue[qi]
        var found: bool = false
        let idxs: int32[] = hashmaps.hashMapStrSeqIntGet(index, cur, &found)
        if !found || idxs.len == 0:
            continue
        for ni in 0..<idxs.len:
            let idx: int32 = idxs[ni]
            if idx < 0 || idx >= nodes.len:
                continue
            let fnNode: Node = nodes[idx]
            var callees: str[64]
            mirCollectCallsDeep(module, fnNode, &callees)
            for ci in 0..<callees.len:
                let nm: str = callees[ci]
                var inProgram: bool = false
                let calleeIdxs: int32[] = mirReachDeclIdxs(index, nodes, nm, &inProgram)
                if inProgram && calleeIdxs.len > 0:
                    for ki in 0..<calleeIdxs.len:
                        let k: int32 = calleeIdxs[ki]
                        if k >= 0 && k < nodes.len:
                            let declNode: Node = nodes[k]
                            let declNameNode: Node = (declNode != nil && kidCount(declNode) > 0) ? kid(declNode, 0) : nil
                            if declNameNode != nil && (declNameNode.kind == nkIdent || declNameNode.kind == nkSymbol):
                                let declName: str = backendStripSpaces(plainName(declNameNode))
                                if len(declName) > 0 && !hashsets.hashSetStrHas(reachable, declName):
                                    hashsets.hashSetStrAdd(reachable, declName)
                                    add(queue, declName)
    return reachable

fn mirFuncSigMarker(): str =
    return "__cheng_sig_"

fn mirFuncSigInput(retKey0: str, paramKeys: str[]): str =
    var retKey: str = retKey0
    if retKey == nil:
        retKey = ""
    var out: str = retKey + "|"
    for i in 0..<paramKeys.len:
        let pk0: str = paramKeys[i]
        let pk: str = (pk0 != nil) ? pk0 : ""
        out = out + pk + ";"
    return out

fn mirFuncSigId(retKey: str, paramKeys: str[]): str =
    return mirU64ToHex(mirFnv1a64(mirFuncSigInput(retKey, paramKeys)))

fn mirMangleOverloadName(baseSym: str, retKey: str, paramKeys: str[]): str =
    return baseSym + mirFuncSigMarker() + mirFuncSigId(retKey, paramKeys)

fn mirComputeOverloadedFnBases(root: Node): hashsets.HashSetStr =
    # Stage1 monomorphize may emit multiple functions with the same base name (e.g. `len`)
    # but different signatures. The MIR module requires globally-unique function symbols,
    # so we precompute which base names are overloaded.
    var overloaded: hashsets.HashSetStr = hashsets.hashSetStrInit(256)
    var seenNames: str[]
    var firstSigs: str[]

    var queue: Node[256]
    add(queue, root)
    while queue.len > 0:
        let n: Node = queue[queue.len - 1]
        queue.len = queue.len - 1
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkStmtList || n.kind == nkModule:
            for i in 0..<kidCount(n):
                add(queue, kid(n, i))
            continue
        if (n.kind != nkFnDecl && n.kind != nkIteratorDecl) || kidCount(n) == 0:
            continue
        if mirFuncSigHasUnresolvedGenerics(n):
            continue
        let nameNode: Node = kid(n, 0)
        if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
            continue
        let rawName: str = backendStripSpaces(plainName(nameNode))
        let baseId: str = rawName
        if baseId == nil || len(baseId) == 0:
            continue

        let paramsNode: Node = kid(n, 1)
        var paramKeys: str[]
        if paramsNode != nil && paramsNode.kind == nkFormalParams:
            for pi in 0..<kidCount(paramsNode):
                let defs: Node = kid(paramsNode, pi)
                if defs != nil && defs.kind == nkIdentDefs && kidCount(defs) > 1:
                    let tn: Node = kid(defs, 1)
                    let pk: str = (tn != nil) ? typeKey(tn) : ""
                    add(paramKeys, pk)

        let retNode: Node = kid(n, 2)
        var retKey: str = ""
        if retNode != nil && retNode.kind != nkEmpty:
            retKey = typeKey(retNode)
        let sigId: str = mirFuncSigId(retKey, paramKeys)

        var prevIdx: int32 = -1
        for si in 0..<seenNames.len:
            if seenNames[si] == baseId:
                prevIdx = si
                break
        if prevIdx < 0:
            add(seenNames, baseId)
            add(firstSigs, sigId)
            continue
        if prevIdx < firstSigs.len:
            let prevSig: str = firstSigs[prevIdx]
            if !(prevSig == sigId):
                hashsets.hashSetStrAdd(overloaded, baseId)
    return overloaded

fn mirMaybeEnqueueMissingRoutine(mod: MirModule, declIndex: hashmaps.HashMapStrInt,
                                 seen: hashsets.HashSetStr*, queue: str[]*, name0: str) =
    if mod == nil || seen == nil || queue == nil || name0 == nil || len(name0) == 0:
        return
    trackLexString void*(name0)
    var foundDecl: bool = false
    let _declIdx: int32 = mirHashMapStrIntGetCompat(declIndex, name0, foundDecl)
    if !foundDecl || _declIdx < 0:
        return
    if moduleHasFunc(mod, name0):
        return
    if hashsets.hashSetStrHas(*seen, name0):
        return
    hashsets.hashSetStrAdd(seen, name0)
    add(queue, name0)

fn mirMaybeEnqueueFromExpr(mod: MirModule, declIndex: hashmaps.HashMapStrInt,
                           seen: hashsets.HashSetStr*, queue: str[]*, e: MirExpr) =
    if e == nil:
        return
    case e.kind
    of meCall:
        mirMaybeEnqueueMissingRoutine(mod, declIndex, seen, queue, e.callee)
        for i in 0..<e.args.len:
            mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, e.args[i])
    of meGlobalAddr:
        mirMaybeEnqueueMissingRoutine(mod, declIndex, seen, queue, e.globalName)
    of meBin, meCmp:
        mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, e.lhs)
        mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, e.rhs)
    of meCast:
        mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, e.castExpr)
    of meLoad:
        mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, e.addrExpr)
    else:
        return

fn mirMaybeEnqueueFromStmt(mod: MirModule, declIndex: hashmaps.HashMapStrInt,
                           seen: hashsets.HashSetStr*, queue: str[]*, s: MirStmt) =
    if s.expr != nil:
        mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, s.expr)
    if s.addrExpr != nil:
        mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, s.addrExpr)

fn mirMaybeEnqueueFromTerm(mod: MirModule, declIndex: hashmaps.HashMapStrInt,
                           seen: hashsets.HashSetStr*, queue: str[]*, t: MirTerm) =
    if t.kind == mtRet:
        mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, t.retExpr)
    elif t.kind == mtCbr:
        mirMaybeEnqueueFromExpr(mod, declIndex, seen, queue, t.condExpr)

fn mirMaybeEnqueueFromFunc(mod: MirModule, declIndex: hashmaps.HashMapStrInt,
                           seen: hashsets.HashSetStr*, queue: str[]*, f: MirFunc) =
    if f == nil:
        return
    for bi in 0..<f.blocks.len:
        let blk: MirBlock = f.blocks[bi]
        if blk != nil:
            for si in 0..<blk.stmts.len:
                let stmt: MirStmt = blk.stmts[si]
                mirMaybeEnqueueFromStmt(mod, declIndex, seen, queue, stmt)
            mirMaybeEnqueueFromTerm(mod, declIndex, seen, queue, blk.term)

fn mirIndexFnDeclsMangled(root: Node, overloaded: hashsets.HashSetStr*,
                          outMap: hashmaps.HashMapStrInt*, outNodes: Node[]*) =
    if root == nil || outMap == nil || outNodes == nil:
        return
    for i in 0..<kidCount(root):
        let n: Node = kid(root, i)
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkStmtList || n.kind == nkModule:
            mirIndexFnDeclsMangled(n, overloaded, outMap, outNodes)
            continue
        if n.kind != nkFnDecl && n.kind != nkIteratorDecl:
            continue
        if mirFuncSigHasUnresolvedGenerics(n):
            continue
        let nameNode: Node = kid(n, 0)
        if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
            continue
        let rawName: str = backendStripSpaces(plainName(nameNode))
        let fp: str = (n.strVal != nil && len(n.strVal) > 0) ? n.strVal : (root.strVal != nil ? root.strVal : "")
        let symName: str = mirMaybeMangleDupFnBase(rawName, fp)
        let baseSym: str = backendSanitizeLinkName(symName)

        let paramsNode: Node = kid(n, 1)
        var paramKeys: str[]
        if paramsNode != nil && paramsNode.kind == nkFormalParams:
            for pi in 0..<kidCount(paramsNode):
                let defs: Node = kid(paramsNode, pi)
                if defs != nil && defs.kind == nkIdentDefs && kidCount(defs) > 1:
                    let tn: Node = kid(defs, 1)
                    let pk: str = (tn != nil) ? typeKey(tn) : ""
                    add(paramKeys, pk)

        let retNode: Node = kid(n, 2)
        var retKey: str = ""
        if retNode != nil && retNode.kind != nkEmpty:
            retKey = typeKey(retNode)

        var name: str = symName
        if rawName != nil && !(rawName == "main") && overloaded != nil && hashsets.hashSetStrHas(*overloaded, rawName):
            name = mirMangleOverloadName(baseSym, retKey, paramKeys)

        let idx: int32 = outNodes->len
        add(outNodes, n)
        hashmaps.hashMapStrIntPut(outMap, name, idx)

fn mirBuildMissingRoutinesFromMir(mod: MirModule, root: Node, overloaded: hashsets.HashSetStr* = nil): Result[bool] =
    if mod == nil || root == nil:
        return Ok[bool](false)
    var declIndex: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(1024)
    var declNodes: Node[512]
    mirIndexFnDeclsMangled(root, overloaded, &declIndex, &declNodes)

    var existingFuncs: hashsets.HashSetStr = hashsets.hashSetStrInit(mod.funcs.len * 2 + 8)
    for fi0 in 0..<mod.funcs.len:
        let f0: MirFunc = mod.funcs[fi0]
        if f0 != nil && f0.name != nil && len(f0.name) > 0:
            hashsets.hashSetStrAdd(existingFuncs, f0.name)

    var seen: hashsets.HashSetStr = hashsets.hashSetStrInit(256)
    var queue: str[256]
    for fi in 0..<mod.funcs.len:
        let f0: MirFunc = mod.funcs[fi]
        mirMaybeEnqueueFromFunc(mod, declIndex, &seen, &queue, f0)

    var builtAny: bool = false
    for qi in 0..<queue.len:
        let nm: str = queue[qi]
        if nm == nil || len(nm) == 0:
            continue
        if hashsets.hashSetStrHas(existingFuncs, nm):
            continue
        var found: bool = false
        let idx: int32 = mirHashMapStrIntGetCompat(declIndex, nm, found)
        if !found || idx < 0 || idx >= declNodes.len:
            continue
        let n: Node = declNodes[idx]
        if n == nil:
            continue
        if mirFuncSigHasUnresolvedGenerics(n):
            continue
        let fp: str = (n.strVal != nil && len(n.strVal) > 0) ? n.strVal : (root.strVal != nil ? root.strVal : "")
        let fRes: Result[MirFunc] = mirBuildFunc(mod, n, fp, overloaded)
        if ! IsOk[MirFunc](fRes):
            return ErrInfo[bool](ErrorInfoOf[MirFunc](fRes))
        let f: MirFunc = Value[MirFunc](fRes)
        if f == nil:
            continue
        if moduleHasFunc(mod, f.name) || moduleHasGlobal(mod, f.name) ||
           mirFindTypeAlias(mod, f.name) >= 0 || mirFindObjType(mod, f.name) >= 0:
            var sameFile: bool = false
            for di in 0..<mod.funcs.len:
                let ex: MirFunc = mod.funcs[di]
                if ex != nil && (ex.name == f.name) && (ex.originFile == f.originFile):
                    sameFile = true
                    break
            if sameFile:
                continue
            return Err[bool]("mir_builder: duplicate function name: " + f.name)
        mirAddFunc(mod, f)
        hashsets.hashSetStrAdd(existingFuncs, f.name)
        builtAny = true
        mirMaybeEnqueueFromFunc(mod, declIndex, &seen, &queue, f)
    return Ok[bool](builtAny)

fn nodeIsTypeArgInCall(b: BlockBuilder, n: Node): bool =
    if b == nil || n == nil:
        return false
    case n.kind
    of nkPtrTy, nkRefTy, nkVarTy, nkFnTy, nkTupleTy, nkSetTy, nkBracketExpr:
        return true
    of nkIdent, nkSymbol:
        let nm: str = backendStripSpaces(plainName(n))
        if localIndex(b.env, nm) >= 0:
            return false
        if moduleGlobalIndex(b.module, nm) >= 0:
            return false
        if nm == "int8" || nm == "uint8" || nm == "i8" || nm == "u8" ||
           nm == "int16" || nm == "uint16" || nm == "i16" || nm == "u16" ||
           nm == "int32" || nm == "uint32" || nm == "i32" || nm == "u32" ||
           nm == "int64" || nm == "uint64" || nm == "i64" || nm == "u64" ||
           nm == "int" || nm == "uint" ||
           nm == "float32" || nm == "float64" || nm == "float" ||
           nm == "bool" || nm == "char" || nm == "str" || nm == "void" || nm == "cstring":
            return true
        return mirFindTypeAlias(b.module, nm) >= 0 || mirFindObjType(b.module, nm) >= 0
    return false

fn mirTypeKindName(t: MirType): str =
    if t.kind == mtVoid:
        return "void"
    if t.kind == mtF64:
        return "f64"
    if t.kind == mtF32:
        return "f32"
    if t.kind == mtI64:
        return t.isUnsigned ? "u64" : "i64"
    if t.kind == mtI32:
        return t.isUnsigned ? "u32" : "i32"
    if t.kind == mtI16:
        return t.isUnsigned ? "u16" : "i16"
    if t.kind == mtI8:
        return t.isUnsigned ? "u8" : "i8"
    return "i32"

fn backendStripSpaces(s: str): str =
    if s == nil:
        return ""
    let n: int32 = len s
    if n == 0:
        return ""
    var hasWs: bool = false
    for i in 0..<n:
        let c: char = s[i]
        if c == ' ' || c == '\t' || c == '\n' || c == '\r':
            hasWs = true
            break
    if !hasWs:
        return s
    let p: void* = alloc(n + 1)
    var outIdx: int32 = 0
    for i in 0..<n:
        let c: char = s[i]
        if c != ' ' && c != '\t' && c != '\n' && c != '\r':
            let dst: void* = ptr_add(p, outIdx)
            var pc: char* = char*(dst)
            *pc = c
            outIdx = outIdx + 1
    setMem(ptr_add(p, outIdx), 0, 1)
    trackLexString p
    return str(p)

fn backendStripSpacesMaybe(s: str): str =
    return backendStripSpaces(s)

fn backendIsSafeLinkName(name: str): bool =
    if name == nil:
        return false
    let n: int32 = len(name)
    if n == 0:
        return false
    let c0: char = name[0]
    let v0: int32 = int32(int64(c0) & 0xFF)
    if ! ((v0 >= 65 && v0 <= 90) || (v0 >= 97 && v0 <= 122) || v0 == 95):
        return false
    for i in 0..<n:
        let c: char = name[i]
        let v: int32 = int32(int64(c) & 0xFF)
        if (v >= 65 && v <= 90) || (v >= 97 && v <= 122) ||
           (v >= 48 && v <= 57) || v == 95:
            continue
        return false
    return true

fn backendHexDigitLower(v: int32): char =
    if v < 10:
        return char(int8(48 + v))
    return char(int8(97 + (v - 10)))

fn backendHexByteLower(v: int32): str =
    let hi: int32 = (v / 16) & 15
    let lo: int32 = v & 15
    return charToStr(backendHexDigitLower(hi)) + charToStr(backendHexDigitLower(lo))

fn backendSanitizeLinkName(raw: str): str =
    if raw == nil:
        return ""
    let name: str = backendStripSpaces(raw)
    if backendIsSafeLinkName(name):
        return name
    if name == nil:
        return "__cheng_anon"
    let nameLen: int32 = len(name)
    if nameLen == 0:
        return "__cheng_anon"
    var out: str = "__cheng_sym"
    for i in 0..<nameLen:
        let c: char = name[i]
        let v: int32 = int32(int64(c) & 0xFF)
        out = out + "_" + backendHexByteLower(v)
    return out

fn mirStrStartsWith(s: str, prefix: str): bool =
    if s == nil || prefix == nil:
        return false
    var i: int32 = 0
    while true:
        let pc: char = prefix[i]
        if pc == char(0):
            return true
        let sc: char = s[i]
        if sc == char(0):
            return false
        if sc != pc:
            return false
        i = i + 1

fn mirStripLeadingUnderscores(raw: str): str =
    if raw == nil:
        return ""
    let n: int32 = len(raw)
    if n <= 0:
        return ""
    var i: int32 = 0
    while i < n && raw[i] == '_':
        i = i + 1
    if i <= 0:
        return raw
    if i >= n:
        return ""
    return str(ptr_add(void*(raw), i))

fn mirInferCtorSuffixFromTypeCache(b: BlockBuilder, callNode: Node, objPrefix: str): str =
    if b == nil || b.module == nil || callNode == nil || objPrefix == nil || len(objPrefix) == 0:
        return ""
    if callNode.typeCacheValid && callNode.typeCache != nil:
        let tc: Node = callNode.typeCache
        let objName0: str = typeNodeObjTypeName(b.module, tc)
        if objName0 != nil && mirStrStartsWith(objName0, objPrefix):
            let suffix0: str = str(ptr_add(void*(objName0), len(objPrefix)))
            if suffix0 != nil && len(suffix0) > 0:
                return suffix0
        let key0: str = typeKey(tc)
        if key0 != nil && mirStrStartsWith(key0, objPrefix):
            let suffix1: str = str(ptr_add(void*(key0), len(objPrefix)))
            if suffix1 != nil && len(suffix1) > 0:
                return suffix1
    return ""

fn mirTypeKeyStripIterWrappers(typeKey0: str): str =
    var key: str = backendStripSpaces(typeKey0)
    if key == nil:
        return ""
    while true:
        if mirStrStartsWith(key, "ref_"):
            key = str(ptr_add(void*(key), 4))
            continue
        if mirStrStartsWith(key, "var_ref_"):
            key = str(ptr_add(void*(key), 8))
            continue
        if mirStrStartsWith(key, "var_"):
            key = str(ptr_add(void*(key), 4))
            continue
        if mirStrStartsWith(key, "ptr_"):
            key = str(ptr_add(void*(key), 4))
            continue
        break
    return key

fn mirTypeKeyFromNodeLoose(typeNode0: Node): str =
    var typeNode: Node = typeNode0
    while typeNode != nil && typeNode.kind == nkPar && kidCount(typeNode) > 0:
        typeNode = kid(typeNode, 0)
    if typeNode == nil:
        return ""
    if typeNode.kind == nkDotExpr && kidCount(typeNode) > 1:
        let rhs: Node = kid(typeNode, 1)
        let rhsKey: str = mirTypeKeyFromNodeLoose(rhs)
        if rhsKey != nil && len(rhsKey) > 0:
            return rhsKey
    let key: str = backendStripSpaces(typeKey(typeNode))
    if key != nil && len(key) > 0 && !(key == "node"):
        return key
    let nm: str = backendStripSpaces(plainName(typeNode))
    if nm != nil && len(nm) > 0:
        return nm
    return ""

fn mirTypeKeyBaseName(typeKey0: str): str =
    let key: str = backendStripSpaces(typeKey0)
    if key == nil || len(key) == 0:
        return ""
    let __for_start_i = len(key) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if key[i] == '.':
            return str(ptr_add(void*(key), i + 1))
    return key

fn mirTypeKeyIsTableIter(typeKey0: str): bool =
    let key: str = mirTypeKeyBaseName(mirTypeKeyStripIterWrappers(typeKey0))
    return (key == "Table") || mirStrStartsWith(key, "Table_")

fn mirTypeKeyTableValKey(typeKey0: str): str =
    let key: str = mirTypeKeyBaseName(mirTypeKeyStripIterWrappers(typeKey0))
    if mirStrStartsWith(key, "Table_"):
        return str(ptr_add(void*(key), 6))
    return ""

fn mirHashMapIterFlavorFromTypeKey(typeKey0: str): int32 =
    let key: str = mirTypeKeyBaseName(mirTypeKeyStripIterWrappers(typeKey0))
    if (key == "HashMapStrInt"):
        return 1
    if (key == "HashMapStrSeqInt"):
        return 2
    if (key == "HashMapPtrInt"):
        return 3
    let __for_start_i = len(key) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if key[i] == '_':
            let suffix: str = str(ptr_add(void*(key), i + 1))
            if (suffix == "HashMapStrInt"):
                return 1
            if (suffix == "HashMapStrSeqInt"):
                return 2
            if (suffix == "HashMapPtrInt"):
                return 3
    return 0

fn mirStrIndexOf(s: str, sub: str): int32 =
    if s == nil || sub == nil:
        return -1
    let n: int32 = len(s)
    let m: int32 = len(sub)
    if m == 0:
        return 0
    if m > n:
        return -1
    for i in 0..n - m:
        for j in 0..<m:
            if !(s[i + j] == sub[j]):
                break
        if j == m:
            return i
    return -1

fn mirStrTake(s: str, count: int32): str =
    if s == nil || count <= 0:
        return ""
    let n: int32 = len(s)
    var k: int32 = count
    if k > n:
        k = n
    let p: void* = alloc(k + 1)
    if k > 0:
        copyMem(p, s, k)
    setMem(ptr_add(p, k), 0, 1)
    trackLexString p
    return str(p)

fn backendOpName(n: Node): str =
    if n == nil:
        return ""
    return backendStripSpaces(n.ident)

fn mirIntBitsDefault32(): int32 =
    # Backend MVP supports CHENG_INTBITS=32/64 only.
    let raw: str = backendStripSpaces(os.getEnv("CHENG_INTBITS"))
    if (raw == "64"):
        return 64
    return 32

fn mirTypeFromNode(n: Node): MirType =
    if n == nil || n.kind == nkEmpty:
        return mirTypeI32()
    if n.kind == nkPtrTy || n.kind == nkRefTy || n.kind == nkFnTy || n.kind == nkSetTy || n.kind == nkVarTy || n.kind == nkTupleTy:
        return mirTypeI64()
    # Stage1 often stores token idents with surrounding spaces.
    let name: str = backendStripSpaces(plainName(n))
    if name == "void":
        return mirTypeVoid()
    if name == "tuple" || mirStrStartsWith(name, "tuple_"):
        return mirTypeI64()
    if name == "float64" || name == "float":
        return mirTypeF64()
    if name == "float32":
        return mirTypeF32()
    if name == "bool":
        return mirTypeU8()
    if name == "char":
        return mirTypeU8()
    if name == "int8" || name == "i8":
        return mirTypeI8()
    if name == "uint8" || name == "u8":
        return mirTypeU8()
    if name == "int16" || name == "i16":
        return mirTypeI16()
    if name == "uint16" || name == "u16":
        return mirTypeU16()
    if name == "int" || name == "NI":
        let bits: int32 = mirIntBitsDefault32()
        if bits == 64:
            return mirTypeI64()
        return mirTypeI32()
    if name == "uint" || name == "NU":
        let bits2: int32 = mirIntBitsDefault32()
        if bits2 == 64:
            return mirTypeU64()
        return mirTypeU32()
    if name == "int64" || name == "i64":
        return mirTypeI64()
    if name == "uint64" || name == "u64":
        return mirTypeU64()
    if name == "int32" || name == "i32":
        return mirTypeI32()
    if name == "uint32" || name == "u32":
        return mirTypeU32()
    if mirStrStartsWith(name, "set_"):
        return mirTypeU64()
    if mirStrStartsWith(name, "seq_"):
        return mirTypeI64()
    if name == "str" || name == "string" || name == "cstring" || name == "void*" || name == "ptr":
        return mirTypeI64()
    return mirTypeI32()

fn mirTypeFromTypeKeyName(key0: str): MirType =
    if key0 == nil || len(key0) == 0:
        return mirTypeI64()
    let key: str = backendStripSpaces(key0)
    if key == "void":
        return mirTypeVoid()
    if key == "float64" || key == "float":
        return mirTypeF64()
    if key == "float32":
        return mirTypeF32()
    if key == "bool" || key == "char":
        return mirTypeU8()
    if key == "int8" || key == "i8":
        return mirTypeI8()
    if key == "uint8" || key == "u8":
        return mirTypeU8()
    if key == "int16" || key == "i16":
        return mirTypeI16()
    if key == "uint16" || key == "u16":
        return mirTypeU16()
    if key == "int32" || key == "i32":
        return mirTypeI32()
    if key == "uint32" || key == "u32":
        return mirTypeU32()
    if key == "int64" || key == "i64":
        return mirTypeI64()
    if key == "uint64" || key == "u64":
        return mirTypeU64()
    if key == "int" || key == "NI":
        let bits: int32 = mirIntBitsDefault32()
        return (bits == 64) ? mirTypeI64() : mirTypeI32()
    if key == "uint" || key == "NU":
        let bits2: int32 = mirIntBitsDefault32()
        return (bits2 == 64) ? mirTypeU64() : mirTypeU32()
    if key == "str" || key == "string" || key == "cstring" || key == "void*" || key == "ptr":
        return mirTypeI64()
    if mirStrStartsWith(key, "ptr_") || mirStrStartsWith(key, "ref_") || mirStrStartsWith(key, "fn_"):
        return mirTypeI64()
    if mirStrStartsWith(key, "seq_") || mirStrStartsWith(key, "seq_fixed_") || mirStrStartsWith(key, "Table_"):
        return mirTypeI64()
    if mirStrStartsWith(key, "set_"):
        return mirTypeU64()
    return mirTypeI64()

fn mirLooksLikeTypeParamName(name0: str): bool =
    let name: str = backendStripSpaces(name0)
    if name == nil || len(name) != 1:
        return false
    let c: char = name[0]
    return c >= 'A' && c <= 'Z'

fn mirSizeOfTypeNode(module: MirModule, typeNode: Node): Result[int32] =
    if typeNode == nil || typeNode.kind == nkEmpty:
        return Err[int32]("mir_builder: sizeof expects a type/expression")
    if typeNode.kind == nkPtrTy || typeNode.kind == nkRefTy || typeNode.kind == nkFnTy || typeNode.kind == nkVarTy:
        return Ok[int32](8)
    if typeNode.kind == nkTupleTy:
        let nm: str = typeNodeObjTypeName(module, typeNode)
        if len(nm) > 0 && module != nil && mirHasObjType(module, nm):
            let ot: MirObjType = mirGetObjType(module, nm)
            return Ok[int32](ot.size)
        return Err[int32]("mir_builder: sizeof unknown tuple type")
    if typeNode.kind == nkIdent || typeNode.kind == nkSymbol:
        let nm: str = backendStripSpaces(plainName(typeNode))
        if nm == "bool" || nm == "char" || nm == "int8" || nm == "uint8" || nm == "i8" || nm == "u8":
            return Ok[int32](1)
        if nm == "int16" || nm == "uint16" || nm == "i16" || nm == "u16":
            return Ok[int32](2)
        if nm == "int32" || nm == "uint32" || nm == "i32" || nm == "u32" || nm == "float32":
            return Ok[int32](4)
        if nm == "int" || nm == "uint" || nm == "NI" || nm == "NU":
            let bits: int32 = mirIntBitsDefault32()
            if bits == 64:
                return Ok[int32](8)
            return Ok[int32](4)
        if nm == "int64" || nm == "uint64" || nm == "i64" || nm == "u64" || nm == "float64":
            return Ok[int32](8)
        if nm == "str" || nm == "string" || nm == "cstring" || nm == "void*" || nm == "ptr":
            return Ok[int32](8)
        if mirStrStartsWith(nm, "ptr_") || mirStrStartsWith(nm, "ref_") || mirStrStartsWith(nm, "fn_"):
            return Ok[int32](8)
        if mirStrStartsWith(nm, "seq_") || mirStrStartsWith(nm, "seq_fixed_") || mirStrStartsWith(nm, "Table_"):
            return Ok[int32](8)
        if mirStrStartsWith(nm, "set_"):
            return Ok[int32](8)
        if nm == "void":
            return Ok[int32](0)
        if module != nil:
            let aliasTy: MirType = mirTryGetTypeAlias(module, nm)
            if aliasTy.kind == mtF64:
                return Ok[int32](8)
            if aliasTy.kind == mtF32:
                return Ok[int32](4)
            if aliasTy.kind == mtI64:
                return Ok[int32](8)
            if aliasTy.kind == mtI32:
                return Ok[int32](4)
            if aliasTy.kind == mtI16:
                return Ok[int32](2)
            if aliasTy.kind == mtI8:
                return Ok[int32](1)
        if module != nil && mirHasObjType(module, nm):
            let ot2: MirObjType = mirGetObjType(module, nm)
            return Ok[int32](ot2.size)
        # Skip-mono gate compiles keep some generic helpers uninstantiated.
        # Treat single-letter generic params (`T`/`V`/`K`) as pointer-sized.
        if mirShouldSkipMonoPass() && mirLooksLikeTypeParamName(nm):
            return Ok[int32](8)
        let line2: str = intToStr(typeNode.pos.line)
        let col2: str = intToStr(typeNode.pos.col)
        return Err[int32]("mir_builder: sizeof unknown type '" + nm + "' @" + line2 + ":" + col2)
    if typeNode.kind == nkBracketExpr && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if base != nil && (base.kind == nkIdent || base.kind == nkSymbol):
            let nm2: str = backendStripSpaces(plainName(base))
            if nm2 == "seq" && module != nil && mirHasObjType(module, "seq"):
                let ot3: MirObjType = mirGetObjType(module, "seq")
                return Ok[int32](ot3.size)
            if module != nil && mirHasObjType(module, nm2):
                let ot4: MirObjType = mirGetObjType(module, nm2)
                return Ok[int32](ot4.size)
            var instArgs: Node[4]
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if a != nil && a.kind != nkEmpty:
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm2, instArgs)
                if module != nil && mirHasObjType(module, instName):
                    let ot5: MirObjType = mirGetObjType(module, instName)
                    return Ok[int32](ot5.size)
    let k: str = intToStr(int32(typeNode.kind))
    let line: str = intToStr(typeNode.pos.line)
    let col: str = intToStr(typeNode.pos.col)
    return Err[int32]("mir_builder: sizeof unsupported type (nk#" + k + " @" + line + ":" + col + ")")

fn mirTypeFromNodeWithModule(module: MirModule, n: Node): MirType =
    let ty: MirType = mirTypeFromNode(n)
    if module == nil || n == nil:
        return ty
    if n.kind == nkIdent || n.kind == nkSymbol:
        let name: str = backendStripSpaces(plainName(n))
        let aliasTy: MirType = mirTryGetTypeAlias(module, name)
        if aliasTy.kind != mtVoid:
            return aliasTy
    return ty

fn inferExprType(env: LocalEnv, n: Node, fallback: MirType): MirType =
    if n == nil:
        return fallback
    var node: Node = n
    while node != nil && node.kind == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if node == nil:
        return fallback
    if node.kind == nkStrLit:
        return mirTypeI64()
    if node.kind == nkFloatLit:
        return mirTypeF64()
    if node.kind == nkCharLit:
        return mirTypeU8()
    if node.kind == nkBoolLit:
        return mirTypeU8()
    if node.kind == nkIdent || node.kind == nkSymbol:
        let idx: int32 = localIndex(env, plainName(node))
        if idx >= 0:
            return localType(env, idx)
        return fallback
    if node.kind == nkCall && kidCount(node) > 0:
        let calleeNode: Node = kid(node, 0)
        let name: str = backendStripSpaces(plainName(calleeNode))
        if name == "__addr":
            return mirTypeI64()
        if name == "uint64" || name == "u64":
            return mirTypeU64()
        if name == "int64" || name == "i64":
            return mirTypeI64()
        if name == "uint32" || name == "u32":
            return mirTypeU32()
        if name == "int32" || name == "i32":
            return mirTypeI32()
        return fallback
    if node.kind == nkPrefix && kidCount(node) > 1:
        return inferExprType(env, kid(node, 1), fallback)
    if node.kind == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        let lt: MirType = inferExprType(env, kid(node, 1), fallback)
        let rt: MirType = inferExprType(env, kid(node, 2), fallback)
        if op == "<<" || op == ">>":
            return lt
        if lt.kind == mtF64 || rt.kind == mtF64:
            return mirTypeF64()
        if lt.kind == mtF32 || rt.kind == mtF32:
            return mirTypeF32()
        if lt.kind == mtI64 || rt.kind == mtI64:
            var out: MirType = mirTypeI64()
            out.isUnsigned = (lt.kind == mtI64 && lt.isUnsigned) || (rt.kind == mtI64 && rt.isUnsigned)
            return out
        var out2: MirType = mirTypeI32()
        out2.isUnsigned = lt.isUnsigned || rt.isUnsigned
        return out2
    return fallback

fn mir_buildGlobalIndexCache(module: MirModule) =
    if module == nil:
        mir_globalIndex_cache_module = nil
        mir_globalIndex_cache_ready = false
        mir_globalIndex_cache_len = 0
        return
    mir_globalIndex_cache_module = module
    mir_globalIndex_cache = hashmaps.hashMapStrIntInit(module.globals.len * 2 + 8)
    for i in 0..<module.globals.len:
        let g: MirGlobal = module.globals[i]
        if g.name != nil && len(g.name) > 0:
            hashmaps.hashMapStrIntPut(mir_globalIndex_cache, g.name, i)
    mir_globalIndex_cache_len = module.globals.len
    mir_globalIndex_cache_ready = true

fn mir_ensureGlobalIndexCache(module: MirModule) =
    if module == nil:
        mir_globalIndex_cache_module = nil
        mir_globalIndex_cache_ready = false
        mir_globalIndex_cache_len = 0
        return
    if module.globals.len < 32:
        return
    if mir_globalIndex_cache_module != module || !mir_globalIndex_cache_ready:
        mir_buildGlobalIndexCache(module)
        return
    if mir_globalIndex_cache_len > module.globals.len:
        mir_buildGlobalIndexCache(module)
        return
    if mir_globalIndex_cache_len < module.globals.len:
        for i in mir_globalIndex_cache_len..<module.globals.len:
            let g: MirGlobal = module.globals[i]
            if g.name != nil && len(g.name) > 0:
                hashmaps.hashMapStrIntPut(mir_globalIndex_cache, g.name, i)
        mir_globalIndex_cache_len = module.globals.len

fn moduleGlobalIndex(module: MirModule, name: str): int32 =
    if module == nil || name == nil:
        return -1
    if module.globals.len >= 32:
        mir_ensureGlobalIndexCache(module)
        if mir_globalIndex_cache_ready && mir_globalIndex_cache_module == module:
            var found: bool = false
            let idx: int32 = mirHashMapStrIntGetCompat(mir_globalIndex_cache, name, found)
            if found && idx >= 0 && idx < module.globals.len:
                let g0: MirGlobal = module.globals[idx]
                if (g0.name == name):
                    return idx
    for i in 0..<module.globals.len:
        let g: MirGlobal = module.globals[i]
        if (g.name == name):
            if mir_globalIndex_cache_ready && mir_globalIndex_cache_module == module:
                hashmaps.hashMapStrIntPut(mir_globalIndex_cache, name, i)
            return i
    return -1

fn moduleGlobalType(module: MirModule, name: str, fallback: MirType): MirType =
    let idx: int32 = moduleGlobalIndex(module, name)
    if idx < 0:
        return fallback
    let g: MirGlobal = module.globals[idx]
    return g.ty

fn inferExprTypeWithGlobals(env: LocalEnv, module: MirModule, func: MirFunc, n: Node, fallback: MirType): MirType =
    if n == nil:
        return fallback
    var node: Node = n
    while node != nil && node.kind == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if node == nil:
        return fallback
    if node.kind == nkStrLit:
        return mirTypeI64()
    if node.kind == nkFloatLit:
        return mirTypeF64()
    if node.kind == nkCall:
        let name: str = mirCallNameForReachability(module, node)
        if name != nil && len(name) > 0 && module != nil:
            let exact: MirFunc = moduleFindFunc(module, name)
            if exact != nil:
                return exact.retType
            let unique: MirFunc = moduleFindFuncByBaseUnique(module, name)
            if unique != nil:
                return unique.retType
    if node.kind == nkDotExpr && kidCount(node) > 1:
        let base: Node = kid(node, 0)
        let field: Node = kid(node, 1)
        if base != nil && (base.kind == nkIdent || base.kind == nkSymbol) &&
           field != nil && (field.kind == nkIdent || field.kind == nkSymbol):
            let baseName: str = plainName(base)
            let slot: int32 = localIndex(env, baseName)
            if slot >= 0:
                let objTypeName: str = funcObjTypeName(func, slot)
                if len(objTypeName) > 0:
                    let ot: MirObjType = mirGetObjType(module, objTypeName)
                    let fieldName: str = backendStripSpaces(plainName(field))
                    for fi in 0..<ot.fields.len:
                        let f: MirObjField = ot.fields[fi]
                        if (f.name == fieldName):
                            return f.ty
        return fallback
    if node.kind == nkIdent || node.kind == nkSymbol:
        let name: str = plainName(node)
        let idx: int32 = localIndex(env, name)
        if idx >= 0:
            return localType(env, idx)
        let gidx: int32 = moduleGlobalIndex(module, name)
        if gidx >= 0:
            let g2: MirGlobal = module.globals[gidx]
            return g2.ty
        if moduleHasFuncByBase(module, name):
            return mirTypeI64()
        return fallback
    return inferExprType(env, node, fallback)

fn isAddrCall(n: Node): bool =
    if n == nil || n.kind != nkCall || kidCount(n) == 0:
        return false
    let calleeNode: Node = kid(n, 0)
    let name: str = backendStripSpaces(plainName(calleeNode))
    return name == "__addr"

fn funcSetObjLocal(func: MirFunc, slot: int32, objTypeName: str, frameOff: int32) =
    if func == nil || objTypeName == nil || len(objTypeName) == 0:
        return
    let idx: int32 = funcFindObjLocal(func, slot)
    var ol: MirObjLocal
    ol.slot = slot
    ol.objTypeName = objTypeName
    ol.typeKey = objTypeName
    ol.frameOff = frameOff
    if idx >= 0:
        mbWriteObjLocal(&func.objLocals, idx, ol)
        return
    add(func.objLocals, ol)

fn allocObjValueLocal(b: BlockBuilder, slot: int32, objTypeName: str): Result[bool] =
    if b == nil || b.module == nil || b.func == nil:
        return Err[bool]("mir_builder: object alloc missing builder/module")
    if (getEnv "CHENG_BACKEND_DEBUG_OBJLOCAL" == "1") && (objTypeName == "Node"):
        let bf0: MirFunc = b.func
        echo("[backend] debug: allocObjValueLocal Node slot=" + intToStr(slot) +
             " fn=" + bf0.name + " file=" + bf0.originFile)
    let idx: int32 = mirFindObjType(b.module, objTypeName)
    if idx < 0:
        return Err[bool]("mir_builder: unknown object type")
    let mod: MirModule = b.module
    let ot: MirObjType = mod.objTypes[idx]
    if ot.size <= 0:
        return Err[bool]("mir_builder: invalid object size")
    let off: int32 = alignUpPow2(b.objCursor, ot.alignPow2)
    b.objCursor = off + ot.size
    let fref: MirFunc = b.func
    if b.objCursor > fref.objFrameSize:
        fref.objFrameSize = b.objCursor
    funcSetObjLocal(b.func, slot, objTypeName, off)
    return Ok[bool](true)

fn emitObjDefaultInit(b: BlockBuilder, slot: int32, objTypeName: str): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: object init missing builder/module")
    let idx: int32 = mirFindObjType(b.module, objTypeName)
    if idx < 0:
        return Err[bool]("mir_builder: unknown object type")
    let mod: MirModule = b.module
    let ot: MirObjType = mod.objTypes[idx]
    for fi in 0..<ot.fields.len:
        let f: MirObjField = ot.fields[fi]
        let basePtr: MirExpr = mirLocal(slot)
        var addr: MirExpr = basePtr
        if f.offset != 0:
            addr = mirBin(mbAdd, basePtr, mirConstI64(int64(f.offset)))
        add(b.currentStmts, mirStmtStore(addr, mirConstI64(0), f.ty))
    let seqFixedRes: Result[bool] = emitObjInlineSeqFixedReserveInitToPtr(b, mirLocal(slot), objTypeName, ot)
    if !IsOk[bool](seqFixedRes):
        return ErrInfo[bool](ErrorInfoOf[bool](seqFixedRes))
    return Ok[bool](false)

type
    SeqFixedInit =
        elemType: Node
        capExpr: Node

fn seqFixedParseCapDigits(raw0: str): int32 =
    let raw: str = backendStripSpaces(raw0)
    if raw == nil || len(raw) == 0:
        return -1
    var cap: int32 = 0
    for i in 0..<len(raw):
        let c: char = raw[i]
        if c < '0' || c > '9':
            return -1
        cap = cap * 10 + int32(c) - int32('0')
    return cap

fn seqFixedInitInfoFromTypeKey(typeKey0: str): SeqFixedInit =
    var out: SeqFixedInit
    let typeKey: str = backendStripSpaces(typeKey0)
    if typeKey == nil || len(typeKey) == 0 || !mirStrStartsWith(typeKey, "seq_fixed_"):
        return out
    let tail: str = str(ptr_add(void*(typeKey), 10))
    if tail == nil || len(tail) == 0:
        return out
    var split: int32 = -1
    let __for_start_i = len(tail) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if tail[i] == '_':
            split = i
            break
    if split <= 0 || split >= len(tail) - 1:
        return out
    let elemKey: str = mirStrTake(tail, split)
    let capTok: str = str(ptr_add(void*(tail), split + 1))
    if elemKey == nil || len(elemKey) == 0 || capTok == nil || len(capTok) == 0:
        return out
    let pos: SourcePos = zeroPos()
    out.elemType = newIdent(elemKey, pos)
    let capDigits: int32 = seqFixedParseCapDigits(capTok)
    if capDigits > 0:
        out.capExpr = newIntLit(int64(capDigits), pos)
    else:
        out.capExpr = newIdent(capTok, pos)
    return out

fn emitObjInlineSeqFixedReserveInitToPtr(b: BlockBuilder, dstBasePtr: MirExpr, objTypeName: str, ot: MirObjType): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: object inline seq_fixed init missing builder/module")
    var seenBases: str[]
    for fi in 0..<ot.fields.len:
        let f: MirObjField = ot.fields[fi]
        let dotAt: int32 = mirStrIndexOf(f.name, ".")
        if dotAt <= 0:
            continue
        let baseName: str = mirStrTake(f.name, dotAt)
        if baseName == nil || len(baseName) == 0:
            continue
        var seen: bool = false
        for si in 0..<seenBases.len:
            if seenBases[si] == baseName:
                seen = true
                break
        if seen:
            continue
        add(seenBases, baseName)

        let typeKey: str = backendStripSpaces(mirObjFieldTypeKeyGet(objTypeName, baseName))
        if (getEnv "CHENG_BACKEND_DEBUG_SEQFIXED_INIT" == "1") && objTypeName == "PeerAttributes":
            echo("[backend] debugSeqFixedInit: obj=" + objTypeName +
                 " base=" + baseName + " key='" + typeKey + "'")
        let sfi: SeqFixedInit = seqFixedInitInfoFromTypeKey(typeKey)
        if sfi.elemType == nil || sfi.capExpr == nil:
            continue

        var baseOff: int32 = -1
        let lenField: str = baseName + ".len"
        for ofi in 0..<ot.fields.len:
            let of: MirObjField = ot.fields[ofi]
            if of.name == lenField:
                baseOff = of.offset
                break
        if baseOff < 0:
            continue

        var seqBase: MirExpr = dstBasePtr
        if baseOff != 0:
            seqBase = mirBin(mbAdd, dstBasePtr, mirConstI64(int64(baseOff)))
        let seqInitRes: Result[bool] = emitSeqFixedReserveInitToPtr(b, seqBase, sfi)
        if !IsOk[bool](seqInitRes):
            if (getEnv "CHENG_BACKEND_DEBUG_SEQFIXED_INIT" == "1"):
                echo("[backend] debugSeqFixedInit: skip obj=" + objTypeName +
                     " base=" + baseName + " reason='emitSeqFixedReserveInitToPtr failed'")
            continue
    return Ok[bool](false)

fn seqFixedInitInfo(typeNode0: Node): SeqFixedInit =
    var out: SeqFixedInit
    if typeNode0 == nil:
        return out
    var t: Node = typeNode0
    while t != nil && t.kind == nkPar && kidCount(t) > 0:
        t = kid(t, 0)
    while t != nil && t.kind == nkVarTy && kidCount(t) > 0:
        t = kid(t, 0)
        while t != nil && t.kind == nkPar && kidCount(t) > 0:
            t = kid(t, 0)
    if t != nil && t.kind == nkDotExpr && kidCount(t) > 1:
        t = kid(t, 1)
    if t == nil || t.kind != nkBracketExpr || kidCount(t) < 3:
        return out
    let base: Node = kid(t, 0)
    if base == nil || (base.kind != nkIdent && base.kind != nkSymbol):
        return out
    let nm: str = backendStripSpaces(plainName(base))
    if !(nm == "seq_fixed"):
        return out
    out.elemType = kid(t, 1)
    out.capExpr = kid(t, 2)
    return out

fn emitSeqFixedReserveInitToPtr(b: BlockBuilder, dstBasePtr: MirExpr, info: SeqFixedInit): Result[bool] =
    if b == nil || b.module == nil || b.func == nil:
        return Err[bool]("mir_builder: seq_fixed init missing builder/module")
    # Stage0 compatibility: avoid chained dot access through a ref-typed field.
    let elemTypeNode: Node = info.elemType
    let capExprNode: Node = info.capExpr
    if elemTypeNode == nil || capExprNode == nil || capExprNode.kind == nkEmpty:
        return Ok[bool](false)
    # IMPORTANT: element type may be an object type (e.g. `T[]` -> `seq[T]`),
    # so we must compute its byte size via the type-node sizeof logic rather
    # than scalar `mirTypeSize`.
    let elemSizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemTypeNode)
    if !IsOk[int32](elemSizeRes):
        return ErrInfo[bool](ErrorInfoOf[int32](elemSizeRes))
    let elemSize: int32 = Value[int32](elemSizeRes)
    if elemSize <= 0:
        return Err[bool]("mir_builder: seq_fixed init unknown elem size")

    let capRes0: Result[MirExpr] = lowerExprValue(b, capExprNode, mirTypeI32())
    if !IsOk[MirExpr](capRes0):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](capRes0))
    let capTmp: str = blockBuilderNextTemp(b, "__seq_fixed_cap")
    let capSlot: int32 = localAdd(b.env, capTmp, mirTypeI32())
    mirSetLocalType(b.func, capSlot, mirTypeI32())
    add(b.currentStmts, mirStmtLet(capTmp, capSlot, Value[MirExpr](capRes0)))
    let capVal: MirExpr = mirLocal(capSlot)

    let reserveLabel: str = blockBuilderNextLabel(b, "seq_fixed_reserve")
    let joinLabel: str = blockBuilderNextLabel(b, "seq_fixed_join")
    let cond: MirExpr = mirCmp(mcGt, capVal, mirConstI64(0))
    blockBuilderFinish(b, mirTermCbr(cond, reserveLabel, joinLabel))

    blockBuilderStart(b, reserveLabel)
    # cap field: offset 4 (i32)
    let capAddr: MirExpr = mirBin(mbAdd, dstBasePtr, mirConstI64(4))
    add(b.currentStmts, mirStmtStore(capAddr, capVal, mirTypeI32()))

    let capI64: MirExpr = mirCast(mirTypeI64(), capVal)
    let bytes: MirExpr = mirBin(mbMul, capI64, mirConstI64(int64(elemSize)))

    var reallocArgs: MirExpr[]
    add(reallocArgs, mirConstI64(0))
    add(reallocArgs, bytes)
    let bufTmp: str = blockBuilderNextTemp(b, "__seq_fixed_buf")
    let bufSlot: int32 = localAdd(b.env, bufTmp, mirTypeI64())
    mirSetLocalType(b.func, bufSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(bufTmp, bufSlot, mirCall("realloc", reallocArgs)))
    let bufVal: MirExpr = mirLocal(bufSlot)

    # buffer field: offset 8 (i64)
    let bufAddr: MirExpr = mirBin(mbAdd, dstBasePtr, mirConstI64(8))
    add(b.currentStmts, mirStmtStore(bufAddr, bufVal, mirTypeI64()))

    let zeroLabel: str = blockBuilderNextLabel(b, "seq_fixed_zero")
    let bufOk: MirExpr = mirCmp(mcNe, bufVal, mirConstI64(0))
    blockBuilderFinish(b, mirTermCbr(bufOk, zeroLabel, joinLabel))

    blockBuilderStart(b, zeroLabel)
    var zeroArgs: MirExpr[]
    add(zeroArgs, bufVal)
    add(zeroArgs, bytes)
    add(b.currentStmts, mirStmtExpr(mirCall("zeroMem", zeroArgs)))
    blockBuilderFinish(b, mirTermBr(joinLabel))

    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn emitObjDefaultInitPtrs(b: BlockBuilder, dstBasePtr: MirExpr, objTypeName: str): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: object init missing builder/module")
    let idx: int32 = mirFindObjType(b.module, objTypeName)
    if idx < 0:
        return Err[bool]("mir_builder: unknown object type")
    let mod: MirModule = b.module
    let ot: MirObjType = mod.objTypes[idx]
    for fi in 0..<ot.fields.len:
        let f: MirObjField = ot.fields[fi]
        var addr: MirExpr = dstBasePtr
        if f.offset != 0:
            addr = mirBin(mbAdd, dstBasePtr, mirConstI64(int64(f.offset)))
        add(b.currentStmts, mirStmtStore(addr, mirConstI64(0), f.ty))
    let seqFixedRes: Result[bool] = emitObjInlineSeqFixedReserveInitToPtr(b, dstBasePtr, objTypeName, ot)
    if !IsOk[bool](seqFixedRes):
        return ErrInfo[bool](ErrorInfoOf[bool](seqFixedRes))
    return Ok[bool](false)

fn emitObjCopyPtrs(b: BlockBuilder, dstBasePtr: MirExpr, objTypeName: str, srcBasePtr: MirExpr): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: object copy missing builder/module")
    let idx: int32 = mirFindObjType(b.module, objTypeName)
    if idx < 0:
        return Err[bool]("mir_builder: unknown object type")
    let mod: MirModule = b.module
    let ot: MirObjType = mod.objTypes[idx]
    for fi in 0..<ot.fields.len:
        let f: MirObjField = ot.fields[fi]
        var dstAddr: MirExpr = dstBasePtr
        var srcAddr: MirExpr = srcBasePtr
        if f.offset != 0:
            let off: MirExpr = mirConstI64(int64(f.offset))
            dstAddr = mirBin(mbAdd, dstBasePtr, off)
            srcAddr = mirBin(mbAdd, srcBasePtr, off)
        let val: MirExpr = mirLoad(srcAddr, f.ty)
        add(b.currentStmts, mirStmtStore(dstAddr, val, f.ty))
    return Ok[bool](false)

fn emitObjCopy(b: BlockBuilder, dstSlot: int32, objTypeName: str, srcSlot: int32): Result[bool] =
    let dstBasePtr: MirExpr = mirLocal(dstSlot)
    let srcBasePtr: MirExpr = mirLocal(srcSlot)
    return emitObjCopyPtrs(b, dstBasePtr, objTypeName, srcBasePtr)

fn emitTupleLitToPtr(b: BlockBuilder, dstBasePtr: MirExpr, objTypeName: str, lit: Node): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: tuple store missing builder/module")
    if lit == nil || lit.kind != nkTupleLit:
        return Err[bool]("mir_builder: invalid tuple literal")
    if objTypeName == nil || len(objTypeName) == 0 || ! mirHasObjType(b.module, objTypeName):
        return Err[bool]("mir_builder: unknown tuple type")
    let ot: MirObjType = mirGetObjType(b.module, objTypeName)
    for i in 0..<kidCount(lit):
        var elemNode: Node = kid(lit, i)
        if elemNode != nil && elemNode.kind == nkCallArg && kidCount(elemNode) > 1:
            elemNode = kid(elemNode, 1)
        let fieldName: str = "f" + intToStr(i)
        var found: bool = false
        for fi in 0..<ot.fields.len:
            let f: MirObjField = ot.fields[fi]
            if (f.name == fieldName):
                found = true
                let valRes: Result[MirExpr] = lowerExprValue(b, elemNode, f.ty)
                if ! IsOk[MirExpr](valRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes))
                var addr: MirExpr = dstBasePtr
                if f.offset != 0:
                    addr = mirBin(mbAdd, dstBasePtr, mirConstI64(int64(f.offset)))
                add(b.currentStmts, mirStmtStore(addr, Value[MirExpr](valRes), f.ty))
                break
        if ! found:
            return Err[bool]("mir_builder: tuple store field missing")
    return Ok[bool](false)

fn emitSeqLitToPtr(b: BlockBuilder, dstBasePtr: MirExpr, seqTypeKey: str, lit: Node): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: seq store missing builder/module")
    if lit == nil || lit.kind != nkSeqLit:
        return Err[bool]("mir_builder: invalid seq literal")
    if seqTypeKey == nil || len(seqTypeKey) == 0:
        return Err[bool]("mir_builder: seq store missing type key")
    if ! mirStrStartsWith(seqTypeKey, "seq_"):
        return Err[bool]("mir_builder: seq store unsupported type key")

    let elemKey: str = str(ptr_add(void*(seqTypeKey), 4))
    let elemTypeNode: Node = newIdent(elemKey, lit.pos)
    let sizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemTypeNode)
    if ! IsOk[int32](sizeRes):
        return ErrInfo[bool](ErrorInfoOf[int32](sizeRes))
    let elemSize: int32 = Value[int32](sizeRes)
    let elemMirTy: MirType = mirTypeFromNodeWithModule(b.module, elemTypeNode)

    let count: int32 = kidCount(lit)
    let seqObj: str = "seq"
    let seqOt: MirObjType = mirGetObjType(b.module, seqObj)
    var lenOff: int32 = -1
    var capOff: int32 = -1
    var bufOff: int32 = -1
    for fi in 0..<seqOt.fields.len:
        let f: MirObjField = seqOt.fields[fi]
        if (f.name == "len"):
            lenOff = f.offset
        elif (f.name == "cap"):
            capOff = f.offset
        elif (f.name == "buffer"):
            bufOff = f.offset
    if lenOff < 0 || capOff < 0 || bufOff < 0:
        return Err[bool]("mir_builder: seq layout mismatch")

    let lenAddr: MirExpr = (lenOff == 0) ? dstBasePtr : mirBin(mbAdd, dstBasePtr, mirConstI64(int64(lenOff)))
    let capAddr: MirExpr = (capOff == 0) ? dstBasePtr : mirBin(mbAdd, dstBasePtr, mirConstI64(int64(capOff)))
    let bufAddr: MirExpr = (bufOff == 0) ? dstBasePtr : mirBin(mbAdd, dstBasePtr, mirConstI64(int64(bufOff)))
    add(b.currentStmts, mirStmtStore(lenAddr, mirConstI64(int64(count)), mirTypeI32()))
    add(b.currentStmts, mirStmtStore(capAddr, mirConstI64(int64(count)), mirTypeI32()))

    var bufPtr: MirExpr = mirConstI64(0)
    if count > 0 && elemSize > 0:
        let bytes: int64 = int64(count) * int64(elemSize)
        var allocArgs: MirExpr[]
        add(allocArgs, mirConstI64(bytes))
        let allocCall: MirExpr = mirCall("alloc", allocArgs)
        let bufName: str = blockBuilderNextTemp(b, "__seq_buf")
        let bufSlot: int32 = localAdd(b.env, bufName, mirTypeI64())
        mirSetLocalType(b.func, bufSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(bufName, bufSlot, allocCall))
        bufPtr = mirLocal(bufSlot)
    add(b.currentStmts, mirStmtStore(bufAddr, bufPtr, mirTypeI64()))

    if count > 0 && elemSize > 0:
        for i in 0..<count:
            var elemNode: Node = kid(lit, i)
            if elemNode != nil && elemNode.kind == nkCallArg && kidCount(elemNode) > 1:
                elemNode = kid(elemNode, 1)
            let valRes: Result[MirExpr] = lowerExprValue(b, elemNode, elemMirTy)
            if ! IsOk[MirExpr](valRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes))
            let off: int64 = int64(i) * int64(elemSize)
            let addr: MirExpr = (off == 0) ? bufPtr : mirBin(mbAdd, bufPtr, mirConstI64(off))
            add(b.currentStmts, mirStmtStore(addr, Value[MirExpr](valRes), elemMirTy))

    return Ok[bool](false)

fn emitSeqComprehensionToPtr(b: BlockBuilder, dstName: str, dstBasePtr: MirExpr, seqTypeKey: str, comp0: Node): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: comprehension store missing builder/module")
    if dstBasePtr == nil:
        return Err[bool]("mir_builder: comprehension store missing dst ptr")
    if seqTypeKey == nil || len(seqTypeKey) == 0 || !mirStrStartsWith(seqTypeKey, "seq_"):
        return Err[bool]("mir_builder: comprehension store expects seq type key")
    if comp0 == nil:
        return Err[bool]("mir_builder: invalid comprehension")
    var comp: Node = comp0
    while comp != nil && comp.kind == nkPar && kidCount(comp) > 0:
        comp = kid(comp, 0)
    if comp == nil || comp.kind != nkComprehension:
        return Err[bool]("mir_builder: invalid comprehension")

    # Initialize destination as an empty seq.
    var emptyLit: Node = newNode(nkSeqLit, comp.pos)
    let initRes: Result[bool] = emitSeqLitToPtr(b, dstBasePtr, seqTypeKey, emptyLit)
    if !IsOk[bool](initRes):
        return ErrInfo[bool](ErrorInfoOf[bool](initRes))

    # Decode comprehension layout:
    # kid0=pattern, kid1=iterExpr, kid2=cond (nkEmpty when absent), kid3=bodyExpr
    var pat: Node = nil
    var iterExpr: Node = nil
    var cond: Node = nil
    var body: Node = nil
    if kidCount(comp) > 0:
        pat = kid(comp, 0)
    if kidCount(comp) > 1:
        iterExpr = kid(comp, 1)
    if kidCount(comp) == 3:
        body = kid(comp, 2)
    elif kidCount(comp) > 3:
        cond = kid(comp, 2)
        body = kid(comp, 3)
    if iterExpr == nil:
        return Err[bool]("mir_builder: comprehension missing iterator")

    # Build: add(__addr(dstName), body)
    var addrCall: Node = newNode(nkCall, comp.pos)
    addrCall.callStyle = CallStyleParen
    addSon(addrCall, newIdent("__addr", comp.pos))
    addSon(addrCall, newIdent(dstName, comp.pos))

    var addCall: Node = newNode(nkCall, comp.pos)
    addCall.callStyle = CallStyleParen
    addSon(addCall, newIdent("add", comp.pos))
    addSon(addCall, addrCall)
    if body != nil:
        addSon(addCall, body)
    else:
        addSon(addCall, newNode(nkEmpty, comp.pos))

    var loopBody: Node = newNode(nkStmtList, comp.pos)
    if cond != nil && cond.kind != nkEmpty:
        var thenList: Node = newNode(nkStmtList, comp.pos)
        addSon(thenList, addCall)
        var ifNode: Node = newNode(nkIf, comp.pos)
        addSon(ifNode, cond)
        addSon(ifNode, thenList)
        addSon(loopBody, ifNode)
    else:
        addSon(loopBody, addCall)

    var forNode: Node = newNode(nkFor, comp.pos)
    if pat != nil:
        addSon(forNode, pat)
    else:
        addSon(forNode, newIdent("_", comp.pos))
    addSon(forNode, iterExpr)
    addSon(forNode, loopBody)
    return lowerForStmt(b, forNode)

fn inferInlineObjFieldTypeName(module: MirModule, parent: MirObjType, fieldName: str, baseOff: int32): str =
    # Match a nested/inlined field by layout against known object types.
    # Example: `Table.keys.*`/`Table.vals.*`/`Table.states.*` matches
    # builtin `seq` (len/cap/buffer) at baseOff.
    if module == nil || fieldName == nil || len(fieldName) == 0 || baseOff < 0:
        return ""
    let mapped: str = mirInlineObjFieldTypeGet(parent.name, fieldName)
    if len(mapped) > 0:
        if (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1") && parent.name == "ProtoBuffer" && fieldName == "out":
            echo("[backend] debugOverloadDot: inferInline mapped parent='ProtoBuffer' field='out' mapped='" + mapped + "'")
        return mapped
    # Prefer declared field type keys over structural matching to avoid
    # aliasing to an unrelated object type with the same flattened layout.
    let declaredKey: str = mirObjFieldTypeKeyGet(parent.name, fieldName)
    if (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1") && parent.name == "ProtoBuffer" && fieldName == "out":
        let lookupKeyDbg: str = parent.name + "::" + fieldName
        var scanFound: bool = false
        if mirObjFieldTypeKeyIndex.keys.len > 0:
            for si in 0..<mirObjFieldTypeKeyIndex.keys.len:
                if mirObjFieldTypeKeyIndex.states[si] != uint8(1):
                    continue
                let kk: str = mirObjFieldTypeKeyIndex.keys[si]
                if kk == lookupKeyDbg:
                    scanFound = true
                    let vi: int32 = mirObjFieldTypeKeyIndex.vals[si]
                    var vv: str = ""
                    if vi >= 0 && vi < mirObjFieldTypeKeyNames.len:
                        vv = mbRead(mirObjFieldTypeKeyNames, vi)
                    echo("[backend] debugOverloadDot: scan fieldKeyMap key='" + lookupKeyDbg + "' slot=" +
                         intToStr(si) + " valIdx=" + intToStr(vi) + " val='" + vv + "'")
                    break
        if !scanFound:
            echo("[backend] debugOverloadDot: scan fieldKeyMap key='" + lookupKeyDbg + "' missing")
        echo("[backend] debugOverloadDot: lookupKey len=" + intToStr(len(lookupKeyDbg)) +
             " parentLen=" + intToStr(len(parent.name)) + " fieldLen=" + intToStr(len(fieldName)))
        echo("[backend] debugOverloadDot: inferInline declaredKey parent='ProtoBuffer' field='out' key='" + declaredKey + "'")
    if declaredKey != nil && len(declaredKey) > 0:
        let declaredObj: str = mirObjTypeFromTypeKey(module, declaredKey)
        if (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1") && parent.name == "ProtoBuffer" && fieldName == "out":
            echo("[backend] debugOverloadDot: inferInline declaredObj parent='ProtoBuffer' field='out' obj='" + declaredObj + "'")
        if declaredObj != nil && len(declaredObj) > 0:
            mirInlineObjFieldTypePut(parent.name, fieldName, declaredObj)
            return declaredObj
    let prefix: str = fieldName + "."
    for ti in 0..<module.objTypes.len:
        let cand: MirObjType = module.objTypes[ti]
        if cand.name == nil || len(cand.name) == 0 || cand.fields.len == 0:
            continue
        var ok: bool = true
        for ci in 0..<cand.fields.len:
            let cf: MirObjField = cand.fields[ci]
            let wantName: str = prefix + cf.name
            let wantOff: int32 = baseOff + cf.offset
            var found: bool = false
            for pi in 0..<parent.fields.len:
                let pf: MirObjField = parent.fields[pi]
                if (pf.name == wantName) && pf.offset == wantOff && pf.ty.kind == cf.ty.kind:
                    found = true
                    break
            if !found:
                ok = false
                break
        if ok:
            return cand.name
    return ""

fn mirObjTypeFromTypeKey(module: MirModule, typeKey0: str): str =
    if module == nil || typeKey0 == nil || len(typeKey0) == 0:
        return ""
    var key: str = mirTypeKeyStripIterWrappers(typeKey0)
    if key == nil || len(key) == 0:
        return ""
    let canon: str = mirObjAliasCanon(key)
    if canon != nil && len(canon) > 0:
        key = canon
    if mirHasObjType(module, key):
        return key
    if mirStrStartsWith(key, "Option_") && ensureOptionObjType(module, key):
        return key
    if mirStrStartsWith(key, "Result_") && ensureResultObjType(module, key):
        return key
    if mirStrStartsWith(key, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, key):
        return key
    let layout0: str = mirPtrBaseObjTypeName(module, key)
    if layout0 != nil && len(layout0) > 0:
        return layout0
    let base: str = mirTypeKeyBaseName(key)
    if base != nil && len(base) > 0 && !(base == key):
        var baseName: str = base
        let baseCanon: str = mirObjAliasCanon(baseName)
        if baseCanon != nil && len(baseCanon) > 0:
            baseName = baseCanon
        if mirHasObjType(module, baseName):
            return baseName
        if mirStrStartsWith(baseName, "Option_") && ensureOptionObjType(module, baseName):
            return baseName
        if mirStrStartsWith(baseName, "Result_") && ensureResultObjType(module, baseName):
            return baseName
        if mirStrStartsWith(baseName, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, baseName):
            return baseName
        let layout1: str = mirPtrBaseObjTypeName(module, baseName)
        if layout1 != nil && len(layout1) > 0:
            return layout1
    return ""

fn mirInferValueCallInnerKey(b: BlockBuilder, callNode: Node): str =
    if b == nil || callNode == nil || callNode.kind != nkCall || kidCount(callNode) <= 1:
        return ""
    let dbgValueInner: bool = (getEnv "CHENG_BACKEND_DEBUG_VALUE_CALLSITE" == "1")
    let calleeName0: str = mirCallCalleeName(callNode)
    let valueLikeCall0: bool = (calleeName0 == "Value") ||
        mirStrStartsWith(calleeName0, "Value_") ||
        mirStrStartsWith(calleeName0, "Value__")
    if dbgValueInner:
        let line0: str = intToStr(callNode.pos.line)
        let col0: str = intToStr(callNode.pos.col)
        echo("[backend] debugValueInner: callee='" + calleeName0 + "' valueLike=" +
             (valueLikeCall0 ? "1" : "0") + " @" + line0 + ":" + col0)
    # Relaxed fallback: some stage1 paths keep callee names qualified/mangled.
    # For unary calls whose first arg is `Result_*`, still recover the inner value key.
    if !valueLikeCall0 && kidCount(callNode) != 2:
        return ""
    var arg0: Node = kid(callNode, 1)
    if arg0 != nil && arg0.kind == nkCallArg && kidCount(arg0) > 1:
        arg0 = kid(arg0, 1)
    var argKey0: str = caseInferExprTypeKey(b, arg0)
    if argKey0 == nil || len(argKey0) == 0:
        argKey0 = mirInferNodeTypeKeyForOverload(b, arg0)
    if (argKey0 == nil || len(argKey0) == 0) && arg0 != nil &&
       arg0.typeCacheValid && arg0.typeCache != nil:
        argKey0 = typeKey(arg0.typeCache)
        if argKey0 == nil || len(argKey0) == 0:
            argKey0 = mirTypeKeyFromNodeLoose(arg0.typeCache)
    if (argKey0 == nil || len(argKey0) == 0) && arg0 != nil && (arg0.kind == nkIdent || arg0.kind == nkSymbol):
        let nm0: str = backendStripSpaces(plainName(arg0))
        let slot0: int32 = localIndex(b.env, nm0)
        if slot0 >= 0:
            argKey0 = localTypeKey(b.env, slot0)
        if (argKey0 == nil || len(argKey0) == 0) && b.module != nil:
            argKey0 = mirGlobalTypeKeyByBaseUnique(b.module, nm0)
    if argKey0 != nil && len(argKey0) > 0:
        if mirStrStartsWith(argKey0, "var_ref_"):
            argKey0 = str(ptr_add(void*(argKey0), 8))
        elif mirStrStartsWith(argKey0, "var_"):
            argKey0 = str(ptr_add(void*(argKey0), 4))
        if mirStrStartsWith(argKey0, "ref_"):
            argKey0 = str(ptr_add(void*(argKey0), 4))
        if mirStrStartsWith(argKey0, "ptr_"):
            argKey0 = str(ptr_add(void*(argKey0), 4))
    if argKey0 != nil && mirStrStartsWith(argKey0, "Result_"):
        let valKey0: str = str(ptr_add(void*(argKey0), 7))
        if dbgValueInner:
            echo("[backend] debugValueInner: argKey='" + argKey0 + "' valKey='" + valKey0 + "'")
        if valKey0 != nil && len(valKey0) > 0:
            return valKey0
    if b.module != nil && argKey0 != nil && len(argKey0) > 0:
        let objName0: str = mirObjTypeFromTypeKey(b.module, argKey0)
        if objName0 != nil && len(objName0) > 0:
            let valueKey0: str = mirObjFieldTypeKeyGet(objName0, "value")
            if valueKey0 != nil && len(valueKey0) > 0:
                return valueKey0
    return ""

fn mirResolveGlobalObjTypeName(b: BlockBuilder, baseName0: str): str =
    if b == nil || b.module == nil || baseName0 == nil || len(baseName0) == 0:
        return ""
    let mod0: MirModule = b.module
    let debugDot: bool = (getEnv "CHENG_BACKEND_DEBUG_DOT" == "1")
    let baseName: str = backendStripSpaces(baseName0)
    if baseName == nil || len(baseName) == 0:
        return ""
    let obj0: str = mirGlobalObjTypeGet(baseName)
    if obj0 != nil && len(obj0) > 0:
        return obj0
    let key0: str = mirGlobalTypeKeyGet(baseName)
    let obj1: str = mirObjTypeFromTypeKey(mod0, key0)
    if obj1 != nil && len(obj1) > 0:
        return obj1
    let gi0: int32 = moduleGlobalIndex(mod0, baseName)
    if debugDot:
        echo("[backend] debugDot: globalObjProbe base='" + baseName + "' obj0='" + obj0 +
             "' key0='" + key0 + "' obj1='" + obj1 + "' gi0=" + intToStr(gi0))
    let globals0: MirGlobal[] = mod0.globals
    if gi0 >= 0 && gi0 < globals0.len:
        let g0: MirGlobal = globals0[gi0]
        let gObj0: str = mirGlobalObjTypeGet(g0.name)
        if gObj0 != nil && len(gObj0) > 0:
            return gObj0
        let gKey0: str = mirGlobalTypeKeyGet(g0.name)
        let gObj1: str = mirObjTypeFromTypeKey(mod0, gKey0)
        if debugDot:
            echo("[backend] debugDot: globalObjProbe exact g.name='" + g0.name +
                 "' gObj0='" + gObj0 + "' gKey0='" + gKey0 + "' gObj1='" + gObj1 +
                 "' g.origin='" + g0.originFile + "' g.ty=nk#" + intToStr(int32(g0.ty.kind)) + "'")
        if gObj1 != nil && len(gObj1) > 0:
            return gObj1
    if b.func != nil && mirDupGlobalNamesHas(baseName):
        let f0: MirFunc = b.func
        let sym0: str = mirMaybeMangleDupGlobalName(baseName, f0.originFile)
        if debugDot:
            echo("[backend] debugDot: globalObjProbe dup base='" + baseName + "' sym0='" + sym0 + "'")
        if sym0 != nil && len(sym0) > 0 && !(sym0 == baseName):
            let mObj0: str = mirGlobalObjTypeGet(sym0)
            if mObj0 != nil && len(mObj0) > 0:
                return mObj0
            let mKey0: str = mirGlobalTypeKeyGet(sym0)
            let mObj1: str = mirObjTypeFromTypeKey(mod0, mKey0)
            if debugDot:
                echo("[backend] debugDot: globalObjProbe dup sym0='" + sym0 +
                     "' mObj0='" + mObj0 + "' mKey0='" + mKey0 + "' mObj1='" + mObj1 + "'")
            if mObj1 != nil && len(mObj1) > 0:
                return mObj1
            let mGi0: int32 = moduleGlobalIndex(mod0, sym0)
            if mGi0 >= 0 && mGi0 < globals0.len:
                let mg0: MirGlobal = globals0[mGi0]
                let mgObj0: str = mirGlobalObjTypeGet(mg0.name)
                if mgObj0 != nil && len(mgObj0) > 0:
                    return mgObj0
                let mgKey0: str = mirGlobalTypeKeyGet(mg0.name)
                let mgObj1: str = mirObjTypeFromTypeKey(mod0, mgKey0)
                if debugDot:
                    echo("[backend] debugDot: globalObjProbe dup-index mg.name='" + mg0.name +
                         "' mgObj0='" + mgObj0 + "' mgKey0='" + mgKey0 + "' mgObj1='" + mgObj1 + "'")
                if mgObj1 != nil && len(mgObj1) > 0:
                    return mgObj1
    let uniqGi: int32 = moduleFindGlobalIndexByBaseUnique(mod0, baseName)
    if uniqGi >= 0 && uniqGi < globals0.len:
        let ug: MirGlobal = globals0[uniqGi]
        let uObj0: str = mirGlobalObjTypeGet(ug.name)
        if uObj0 != nil && len(uObj0) > 0:
            return uObj0
        let uKey0: str = mirGlobalTypeKeyGet(ug.name)
        let uObj1: str = mirObjTypeFromTypeKey(mod0, uKey0)
        if uObj1 != nil && len(uObj1) > 0:
            return uObj1
    let uniqKey: str = mirGlobalTypeKeyByBaseUnique(mod0, baseName)
    let uniqObj: str = mirObjTypeFromTypeKey(mod0, uniqKey)
    if debugDot:
        echo("[backend] debugDot: globalObjProbe uniq base='" + baseName +
             "' uniqGi=" + intToStr(uniqGi) + " uniqKey='" + uniqKey + "' uniqObj='" + uniqObj + "'")
    if uniqObj != nil && len(uniqObj) > 0:
        return uniqObj
    return ""

fn lowerDotAccess(b: BlockBuilder, dotNode: Node): Result[DotAccess] =
    if b == nil || dotNode == nil || dotNode.kind != nkDotExpr || kidCount(dotNode) < 2:
        return Err[DotAccess]("mir_builder: invalid dot expr")
    let debugDot: bool = (getEnv "CHENG_BACKEND_DEBUG_DOT" == "1")
    var base: Node = kid(dotNode, 0)
    let field: Node = kid(dotNode, 1)
    while base != nil && base.kind == nkPar && kidCount(base) > 0:
        base = kid(base, 0)
    if field == nil || (field.kind != nkIdent && field.kind != nkSymbol):
        return Err[DotAccess]("mir_builder: dot field expects identifier")
    var basePtrRes: Result[MirExpr]
    var baseName: str = ""
    var objTypeName: str = ""
    if base != nil && (base.kind == nkIdent || base.kind == nkSymbol):
        baseName = backendStripSpaces(plainName(base))
        let slot: int32 = localIndex(b.env, baseName)
        if slot >= 0:
            objTypeName = funcObjTypeName(b.func, slot)
            if len(objTypeName) > 0:
                basePtrRes = Ok[MirExpr](mirLocal(slot))
            else:
                # Stage0/early stage1 pipelines may lack typeCache on locals; fall back to local type keys.
                var key: str = localTypeKey(b.env, slot)
                if mirStrStartsWith(key, "ref_"):
                    key = str(ptr_add(void*(key), 4))
                elif mirStrStartsWith(key, "var_ref_"):
                    key = str(ptr_add(void*(key), 8))
                elif mirStrStartsWith(key, "var_"):
                    key = str(ptr_add(void*(key), 4))
                if key != nil && len(key) > 0:
                    let objFromKey0: str = mirObjTypeFromTypeKey(b.module, key)
                    if objFromKey0 != nil && len(objFromKey0) > 0:
                        objTypeName = objFromKey0
                        basePtrRes = Ok[MirExpr](mirLocal(slot))
                    let canon: str = mirObjAliasCanon(key)
                    if canon != nil && len(canon) > 0:
                        key = canon
                    if mirHasObjType(b.module, key):
                        objTypeName = key
                        basePtrRes = Ok[MirExpr](mirLocal(slot))
                    elif mirStrStartsWith(key, "ptr_"):
                        var innerKey: str = str(ptr_add(void*(key), 4))
                        let innerCanon: str = mirObjAliasCanon(innerKey)
                        if innerCanon != nil && len(innerCanon) > 0:
                            innerKey = innerCanon
                        if innerKey != nil && len(innerKey) > 0:
                            if mirHasObjType(b.module, innerKey):
                                objTypeName = innerKey
                                basePtrRes = Ok[MirExpr](mirLocal(slot))
                            elif mirStrStartsWith(innerKey, "seq_") && mirHasObjType(b.module, "seq"):
                                objTypeName = "seq"
                                basePtrRes = Ok[MirExpr](mirLocal(slot))
                            elif mirStrStartsWith(innerKey, "seq_fixed_") && mirHasObjType(b.module, "seq"):
                                objTypeName = "seq"
                                basePtrRes = Ok[MirExpr](mirLocal(slot))
                            elif mirStrStartsWith(innerKey, "Table_") && mirHasObjType(b.module, "Table"):
                                objTypeName = "Table"
                                basePtrRes = Ok[MirExpr](mirLocal(slot))
                    elif mirStrStartsWith(key, "seq_") && mirHasObjType(b.module, "seq"):
                        objTypeName = "seq"
                        basePtrRes = Ok[MirExpr](mirLocal(slot))
                    elif mirStrStartsWith(key, "seq_fixed_") && mirHasObjType(b.module, "seq"):
                        objTypeName = "seq"
                        basePtrRes = Ok[MirExpr](mirLocal(slot))
                    elif mirStrStartsWith(key, "Table_") && mirHasObjType(b.module, "Table"):
                        objTypeName = "Table"
                        basePtrRes = Ok[MirExpr](mirLocal(slot))
    if len(objTypeName) == 0:
        if base != nil && base.kind == nkBracketExpr && kidCount(base) == 2:
            let base0: Node = kid(base, 0)
            if base0 != nil && base0.typeCacheValid && base0.typeCache != nil:
                var t0: Node = base0.typeCache
                while t0 != nil && t0.kind == nkPar && kidCount(t0) > 0:
                    t0 = kid(t0, 0)
                if t0 != nil && t0.kind == nkVarTy && kidCount(t0) > 0:
                    t0 = kid(t0, 0)
                if t0 != nil && (t0.kind == nkRefTy || t0.kind == nkPtrTy) && kidCount(t0) > 0:
                    t0 = kid(t0, 0)
                if t0 != nil && t0.kind == nkBracketExpr && kidCount(t0) > 0:
                    let tyBase: Node = kid(t0, 0)
                    if tyBase != nil && (tyBase.kind == nkIdent || tyBase.kind == nkSymbol):
                        let tyName: str = backendStripSpaces(plainName(tyBase))
                        if (tyName == "array") && kidCount(t0) >= 3:
                            let arg1: Node = kid(t0, 1)
                            let arg2: Node = kid(t0, 2)
                            let c1: int32 = tryResolveArrayCount(b.module, arg1)
                            let c2: int32 = tryResolveArrayCount(b.module, arg2)
                            var elemTypeNode: Node = nil
                            if c1 > 0 && c2 <= 0:
                                elemTypeNode = arg2
                            elif c2 > 0 && c1 <= 0:
                                elemTypeNode = arg1
                            elif c1 > 0 && c2 > 0:
                                # Ambiguous; prefer `array[Count, ElemType]`.
                                elemTypeNode = arg2
                            if elemTypeNode != nil && elemTypeNode.kind != nkEmpty:
                                objTypeName = typeNodeObjTypeName(b.module, elemTypeNode)
                        elif (tyName == "seq") && kidCount(t0) >= 2:
                            let elemTypeNode2: Node = kid(t0, 1)
                            if elemTypeNode2 != nil && elemTypeNode2.kind != nkEmpty:
                                objTypeName = typeNodeObjTypeName(b.module, elemTypeNode2)
                        elif (tyName == "seq_fixed") && kidCount(t0) >= 2:
                            let elemTypeNode3: Node = kid(t0, 1)
                            if elemTypeNode3 != nil && elemTypeNode3.kind != nkEmpty:
                                objTypeName = typeNodeObjTypeName(b.module, elemTypeNode3)
            if len(objTypeName) == 0:
                var key0: str = ""
                if base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol):
                    let slot0Name: str = backendStripSpaces(plainName(base0))
                    let slot0: int32 = localIndex(b.env, slot0Name)
                    if slot0 >= 0:
                        key0 = localTypeKey(b.env, slot0)
                if key0 == nil || len(key0) == 0:
                    key0 = exprTypeKeyShallow(b, base0)
                if (key0 == nil || len(key0) == 0) && base0 != nil && base0.kind == nkDotExpr:
                    let da0Res: Result[DotAccess] = lowerDotAccess(b, base0)
                    if IsOk[DotAccess](da0Res):
                        let da0: DotAccess = Value[DotAccess](da0Res)
                        if da0.fieldTy.kind == mtVoid && da0.objTypeName != nil && len(da0.objTypeName) > 0:
                            key0 = da0.objTypeName
                if (key0 == nil || len(key0) == 0) && base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol):
                    let base0Name: str = backendStripSpaces(plainName(base0))
                    let gObj0: str = mirResolveGlobalObjTypeName(b, base0Name)
                    if len(gObj0) > 0:
                        key0 = gObj0
                if base0 != nil && key0 != nil && len(key0) > 0 && (key0 == "seq" || key0 == "Table"):
                    let refinedKey: str = caseInferExprTypeKey(b, base0)
                    if refinedKey != nil && len(refinedKey) > 0 && !(refinedKey == key0):
                        key0 = refinedKey
                if len(objTypeName) == 0 && base0 != nil && base0.kind == nkDotExpr && kidCount(base0) > 1 &&
                   key0 != nil && len(key0) > 0 && (key0 == "seq" || key0 == "Table"):
                    let parentNode0: Node = kid(base0, 0)
                    let memberNode0: Node = kid(base0, 1)
                    let memberName0: str = backendStripSpaces(plainName(memberNode0))
                    var parentKey0: str = caseInferExprTypeKey(b, parentNode0)
                    if parentKey0 != nil && len(parentKey0) > 0:
                        if mirStrStartsWith(parentKey0, "ref_"):
                            parentKey0 = str(ptr_add(void*(parentKey0), 4))
                        elif mirStrStartsWith(parentKey0, "var_ref_"):
                            parentKey0 = str(ptr_add(void*(parentKey0), 8))
                        elif mirStrStartsWith(parentKey0, "var_"):
                            parentKey0 = str(ptr_add(void*(parentKey0), 4))
                        if mirStrStartsWith(parentKey0, "ptr_"):
                            parentKey0 = str(ptr_add(void*(parentKey0), 4))
                    var parentObj0: str = mirObjTypeFromTypeKey(b.module, parentKey0)
                    if len(parentObj0) == 0 && parentNode0 != nil && (parentNode0.kind == nkIdent || parentNode0.kind == nkSymbol):
                        let parentName0: str = backendStripSpaces(plainName(parentNode0))
                        parentObj0 = mirResolveGlobalObjTypeName(b, parentName0)
                    if len(parentObj0) > 0 && memberName0 != nil && len(memberName0) > 0:
                        let fieldKey1: str = backendStripSpaces(mirObjFieldTypeKeyGet(parentObj0, memberName0))
                        if fieldKey1 != nil && len(fieldKey1) > 0:
                            key0 = fieldKey1
                if key0 != nil && len(key0) > 0:
                    var key: str = key0
                    if mirStrStartsWith(key, "ref_"):
                        key = str(ptr_add(void*(key), 4))
                    elif mirStrStartsWith(key, "var_ref_"):
                        key = str(ptr_add(void*(key), 8))
                    elif mirStrStartsWith(key, "var_"):
                        key = str(ptr_add(void*(key), 4))
                    if mirStrStartsWith(key, "ptr_"):
                        key = str(ptr_add(void*(key), 4))
                    if key != nil && len(key) > 0:
                        let keyCanon0: str = mirObjAliasCanon(key)
                        if keyCanon0 != nil && len(keyCanon0) > 0:
                            key = keyCanon0
                        if mirHasObjType(b.module, key):
                            objTypeName = key
                        if mirStrStartsWith(key, "seq_"):
                            var elemKey: str = str(ptr_add(void*(key), 4))
                            if elemKey != nil && len(elemKey) > 0:
                                if mirStrStartsWith(elemKey, "var_ref_"):
                                    elemKey = str(ptr_add(void*(elemKey), 8))
                                elif mirStrStartsWith(elemKey, "var_"):
                                    elemKey = str(ptr_add(void*(elemKey), 4))
                                if mirStrStartsWith(elemKey, "ref_") || mirStrStartsWith(elemKey, "ptr_"):
                                    elemKey = str(ptr_add(void*(elemKey), 4))
                                if mirHasObjType(b.module, elemKey):
                                    objTypeName = elemKey
                                elif mirStrStartsWith(elemKey, "seq_") && mirHasObjType(b.module, "seq"):
                                    objTypeName = "seq"
                                elif mirStrStartsWith(elemKey, "seq_fixed_") && mirHasObjType(b.module, "seq"):
                                    objTypeName = "seq"
                                elif mirStrStartsWith(elemKey, "Table_") && mirHasObjType(b.module, "Table"):
                                    objTypeName = "Table"
                        elif mirStrStartsWith(key, "seq_fixed_") && mirHasObjType(b.module, "seq"):
                            objTypeName = "seq"
                        elif mirStrStartsWith(key, "Table_") && mirHasObjType(b.module, "Table"):
                            objTypeName = "Table"
                        elif mirStrStartsWith(key, "array_") && b.module != nil:
                            for i0 in 6..<len(key):
                                if key[i0] == '_':
                                    let suffix: str = str(ptr_add(void*(key), i0 + 1))
                                    if suffix != nil && len(suffix) > 0:
                                        if mirHasObjType(b.module, suffix):
                                            objTypeName = suffix
                                            break
                                        elif mirStrStartsWith(suffix, "seq_") && mirHasObjType(b.module, "seq"):
                                            objTypeName = "seq"
                                            break
                                        elif mirStrStartsWith(suffix, "seq_fixed_") && mirHasObjType(b.module, "seq"):
                                            objTypeName = "seq"
                                            break
                                        elif mirStrStartsWith(suffix, "Table_") && mirHasObjType(b.module, "Table"):
                                            objTypeName = "Table"
                                            break
                if debugDot && len(objTypeName) == 0:
                    var bKind: int32 = -1
                    if base0 != nil:
                        bKind = int32(base0.kind)
                    let lineD: str = intToStr(dotNode.pos.line)
                    let colD: str = intToStr(dotNode.pos.col)
                    echo("[backend] debugDot: bracket-dot missing objTypeName key0='" + key0 +
                        "' base0Kind=nk#" + intToStr(bKind) + " @" + lineD + ":" + colD)
        if baseName != nil && len(baseName) > 0:
            let gObj: str = mirResolveGlobalObjTypeName(b, baseName)
            if len(gObj) > 0:
                objTypeName = gObj
        if base != nil && base.kind == nkDotExpr:
            let da0Res: Result[DotAccess] = lowerDotAccess(b, base)
            if IsOk[DotAccess](da0Res):
                let da0: DotAccess = Value[DotAccess](da0Res)
                if da0.fieldTy.kind == mtVoid:
                    if len(da0.objTypeName) > 0:
                        objTypeName = da0.objTypeName
                    basePtrRes = Ok[MirExpr](da0.addr)
        if base != nil && base.typeCacheValid && base.typeCache != nil:
            objTypeName = typeNodeObjTypeName(b.module, base.typeCache)
        if len(objTypeName) == 0 && base != nil && base.kind == nkCall && b.module != nil:
            let callName: str = mirCallNameForReachability(b.module, base)
            if debugDot:
                echo("[backend] debugDot: call-dot callName='" + callName + "'")
            if callName != nil && len(callName) > 0:
                var callee0: MirFunc = moduleFindFunc(b.module, callName)
                if callee0 == nil:
                    callee0 = moduleFindFuncByBaseUnique(b.module, callName)
                if callee0 != nil && callee0.retTypeKey != nil && len(callee0.retTypeKey) > 0:
                    var key: str = callee0.retTypeKey
                    if mirStrStartsWith(key, "ref_"):
                        key = str(ptr_add(void*(key), 4))
                    elif mirStrStartsWith(key, "var_ref_"):
                        key = str(ptr_add(void*(key), 8))
                    elif mirStrStartsWith(key, "var_"):
                        key = str(ptr_add(void*(key), 4))
                    if mirStrStartsWith(key, "ptr_"):
                        key = str(ptr_add(void*(key), 4))
                    objTypeName = mirPtrBaseObjTypeName(b.module, key)
                    if debugDot:
                        echo("[backend] debugDot: call-dot callee retTypeKey='" + callee0.retTypeKey +
                             "' objTypeFromRet='" + objTypeName + "'")
            if len(objTypeName) == 0 && kidCount(base) > 1:
                let valKey0: str = mirInferValueCallInnerKey(b, base)
                if debugDot:
                    echo("[backend] debugDot: call-dot valKey='" + valKey0 + "'")
                if valKey0 != nil && len(valKey0) > 0:
                    objTypeName = mirObjTypeFromTypeKey(b.module, valKey0)
                    if debugDot:
                        echo("[backend] debugDot: call-dot objTypeFromVal='" + objTypeName + "'")
            if len(objTypeName) == 0:
                let callKey2: str = caseInferExprTypeKey(b, base)
                if debugDot:
                    echo("[backend] debugDot: call-dot callExprKey='" + callKey2 + "'")
                if callKey2 != nil && len(callKey2) > 0:
                    objTypeName = mirObjTypeFromTypeKey(b.module, callKey2)
                    if debugDot:
                        echo("[backend] debugDot: call-dot objTypeFromExprKey='" + objTypeName + "'")
        if len(objTypeName) == 0 && base != nil && (base.kind == nkHiddenDeref || base.kind == nkDerefExpr) &&
           kidCount(base) > 0:
            let inner: Node = kid(base, 0)
            if inner != nil && inner.typeCacheValid && inner.typeCache != nil:
                objTypeName = typeNodeObjTypeName(b.module, inner.typeCache)
            elif inner != nil && (inner.kind == nkIdent || inner.kind == nkSymbol):
                let slot2: int32 = localIndex(b.env, plainName(inner))
                if slot2 >= 0:
                    objTypeName = funcObjTypeName(b.func, slot2)
                    if len(objTypeName) == 0:
                        var key2: str = localTypeKey(b.env, slot2)
                        if mirStrStartsWith(key2, "ref_"):
                            key2 = str(ptr_add(void*(key2), 4))
                        elif mirStrStartsWith(key2, "var_ref_"):
                            key2 = str(ptr_add(void*(key2), 8))
                        if mirStrStartsWith(key2, "ptr_"):
                            let innerKey2: str = str(ptr_add(void*(key2), 4))
                            if innerKey2 != nil && len(innerKey2) > 0:
                                if mirHasObjType(b.module, innerKey2):
                                    objTypeName = innerKey2
                                elif mirStrStartsWith(innerKey2, "seq_") && mirHasObjType(b.module, "seq"):
                                    objTypeName = "seq"
                                elif mirStrStartsWith(innerKey2, "seq_fixed_") && mirHasObjType(b.module, "seq"):
                                    objTypeName = "seq"
                                elif mirStrStartsWith(innerKey2, "Table_") && mirHasObjType(b.module, "Table"):
                                    objTypeName = "Table"
            if len(objTypeName) == 0 && inner != nil && b.module != nil:
                var key3: str = backendStripSpaces(exprTypeKeyShallow(b, inner))
                if mirStrStartsWith(key3, "ref_"):
                    key3 = str(ptr_add(void*(key3), 4))
                elif mirStrStartsWith(key3, "var_ref_"):
                    key3 = str(ptr_add(void*(key3), 8))
                elif mirStrStartsWith(key3, "var_"):
                    key3 = str(ptr_add(void*(key3), 4))
                if mirStrStartsWith(key3, "ptr_"):
                    key3 = str(ptr_add(void*(key3), 4))
                key3 = mirObjAliasCanon(key3)
                objTypeName = mirPtrBaseObjTypeName(b.module, key3)
        basePtrRes = lowerExprValue(b, base, mirTypeI64())
    if len(objTypeName) == 0 || ! IsOk[MirExpr](basePtrRes):
        var fnName: str = ""
        var fp: str = ""
        if b != nil && b.func != nil:
            let f0: MirFunc = b.func
            fnName = f0.name
            fp = f0.originFile
        if debugDot:
            var bKind2: int32 = -1
            if base != nil:
                bKind2 = int32(base.kind)
            let okPtr: bool = IsOk[MirExpr](basePtrRes)
            let okPtrStr: str = okPtr ? "1" : "0"
            let modNil: str = (b == nil || b.module == nil) ? "1" : "0"
            echo("[backend] debugDot: dotFail objTypeName='" + objTypeName + "' baseKind=nk#" +
                intToStr(bKind2) + " basePtrOk=" + okPtrStr + " moduleNil=" + modNil)
            if baseName != nil && len(baseName) > 0 && b != nil && b.env != nil:
                let dbgSlot: int32 = localIndex(b.env, baseName)
                var dbgMsg: str = "[backend] debugDot: baseName='" + baseName + "' slot=" + intToStr(dbgSlot)
                if dbgSlot >= 0 && b.func != nil:
                    let fObj: str = funcObjTypeName(b.func, dbgSlot)
                    let fKey: str = funcObjTypeKey(b.func, dbgSlot)
                    let lKey: str = localTypeKey(b.env, dbgSlot)
                    var lKey0: str = lKey
                    if mirStrStartsWith(lKey0, "ref_"):
                        lKey0 = str(ptr_add(void*(lKey0), 4))
                    elif mirStrStartsWith(lKey0, "var_ref_"):
                        lKey0 = str(ptr_add(void*(lKey0), 8))
                    elif mirStrStartsWith(lKey0, "var_"):
                        lKey0 = str(ptr_add(void*(lKey0), 4))
                    dbgMsg = dbgMsg + " funcObjTypeName='" + fObj + "' funcObjTypeKey='" + fKey +
                        "' localTypeKey='" + lKey + "' localTypeKeyStrip='" + lKey0 + "'"
                    let hasObj: bool = lKey0 != nil && len(lKey0) > 0 && mirHasObjType(b.module, lKey0)
                    dbgMsg = dbgMsg + " hasObj=" + (hasObj ? "1" : "0")
                    if !hasObj && b.module != nil && lKey0 != nil && len(lKey0) > 0:
                        let modDbg: MirModule = b.module
                        let objsDbg: MirObjType[] = modDbg.objTypes
                        let pref0: str = lKey0 + "_"
                        var shown0: int32 = 0
                        for oi0 in 0..<objsDbg.len:
                            let ot0: MirObjType = objsDbg[oi0]
                            if ot0.name == nil || len(ot0.name) == 0:
                                continue
                            if ot0.name == lKey0 || mirStrStartsWith(ot0.name, pref0):
                                echo("[backend] debugDot: localKeyCandidate key='" + lKey0 +
                                     "' cand='" + ot0.name + "'")
                                shown0 = shown0 + 1
                                if shown0 >= 6:
                                    break
                echo dbgMsg
                let altName: str = baseName + "Res"
                let altSlot: int32 = localIndex(b.env, altName)
                if altSlot >= 0:
                    let altKey: str = localTypeKey(b.env, altSlot)
                    echo("[backend] debugDot: altName='" + altName + "' slot=" + intToStr(altSlot) +
                         " localTypeKey='" + altKey + "'")
            if base != nil && base.typeCacheValid && base.typeCache != nil:
                let tc: Node = base.typeCache
                let tcKind2: str = intToStr(int32(tc.kind))
                let tcName: str = backendStripSpaces(plainName(tc))
                let tcKey: str = typeKey(tc)
                let tcObj: str = typeNodeObjTypeName(b.module, tc)
                echo("[backend] debugDot: base.typeCache kind=nk#" + tcKind2 + " name='" + tcName +
                    "' key='" + tcKey + "' objTypeName='" + tcObj + "'")
            if !okPtr:
                echo("[backend] debugDot: dotFail basePtrErr=" + Error(basePtrRes))
        let line: str = intToStr(dotNode.pos.line)
        let col: str = intToStr(dotNode.pos.col)
        let msg: str = "mir_builder: dot base is not an object/ref: " + baseName +
                       " (fn=" + fnName + " " + fp + ":" + line + ":" + col + ")"
        return Err[DotAccess](msg)
    let ot: MirObjType = mirGetObjType(b.module, objTypeName)
    if ot.name == nil || len(ot.name) == 0:
        return Err[DotAccess]("mir_builder: unknown object type")
    let fieldName: str = backendStripSpaces(plainName(field))
    for fi in 0..<ot.fields.len:
        let f: MirObjField = ot.fields[fi]
        if (f.name == fieldName):
            let basePtr: MirExpr = Value[MirExpr](basePtrRes)
            var addr: MirExpr = basePtr
            if f.offset != 0:
                addr = mirBin(mbAdd, basePtr, mirConstI64(int64(f.offset)))
            var da: DotAccess
            da.addr = addr
            da.fieldTy = f.ty
            da.objTypeName = ""
            return Ok[DotAccess](da)
    if ((objTypeName == "tuple") || mirStrStartsWith(objTypeName, "tuple_")):
        var ti: int32 = mirTupleFieldIndexGet(objTypeName, fieldName)
        if ti < 0 && base != nil && base.typeCacheValid && base.typeCache != nil:
            var tc: Node = base.typeCache
            while tc != nil && tc.kind == nkPar && kidCount(tc) > 0:
                tc = kid(tc, 0)
            if tc != nil && tc.kind == nkVarTy && kidCount(tc) > 0:
                tc = kid(tc, 0)
            if tc != nil && (tc.kind == nkRefTy || tc.kind == nkPtrTy) && kidCount(tc) > 0:
                tc = kid(tc, 0)
            if tc != nil && tc.kind == nkTupleTy:
                for tj in 0..<kidCount(tc):
                    let elem: Node = kid(tc, tj)
                    if elem != nil && elem.kind == nkIdentDefs && kidCount(elem) > 0:
                        let nameNode: Node = kid(elem, 0)
                        if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol):
                            let lbl: str = backendStripSpaces(plainName(nameNode))
                            if len(lbl) > 0 && (lbl == fieldName):
                                ti = tj
                                mirTupleFieldIndexPut(objTypeName, fieldName, tj)
                                break
        if ti == -2:
            return Err[DotAccess]("mir_builder: ambiguous tuple field '" + fieldName + "' for type '" + objTypeName + "'")
        if ti >= 0:
            let altFieldName: str = "f" + intToStr(ti)
            for fi2 in 0..<ot.fields.len:
                let f2: MirObjField = ot.fields[fi2]
                if (f2.name == altFieldName):
                    let basePtr2: MirExpr = Value[MirExpr](basePtrRes)
                    var addr2: MirExpr = basePtr2
                    if f2.offset != 0:
                        addr2 = mirBin(mbAdd, basePtr2, mirConstI64(int64(f2.offset)))
                    var da2: DotAccess
                    da2.addr = addr2
                    da2.fieldTy = f2.ty
                    da2.objTypeName = ""
                    return Ok[DotAccess](da2)
    let prefix: str = fieldName + "."
    var baseOff: int32 = -1
    for fj in 0..<ot.fields.len:
        let f2: MirObjField = ot.fields[fj]
        if mirStrStartsWith(f2.name, prefix):
            if baseOff < 0 || f2.offset < baseOff:
                baseOff = f2.offset
    if baseOff >= 0:
        let basePtr: MirExpr = Value[MirExpr](basePtrRes)
        var addr: MirExpr = basePtr
        if baseOff != 0:
            addr = mirBin(mbAdd, basePtr, mirConstI64(int64(baseOff)))
        var da: DotAccess
        da.addr = addr
        # Composite (inlined) object field: treat as an address-only value.
        da.fieldTy = mirTypeVoid()
        da.objTypeName = inferInlineObjFieldTypeName(b.module, ot, fieldName, baseOff)
        return Ok[DotAccess](da)
    var fnName2: str = ""
    var fp2: str = ""
    if b != nil && b.func != nil:
        let f1: MirFunc = b.func
        fnName2 = f1.name
        fp2 = f1.originFile
    let line2: str = intToStr(dotNode.pos.line)
    let col2: str = intToStr(dotNode.pos.col)
    let msg2: str = "mir_builder: unknown object field '" + fieldName + "' for type '" + objTypeName +
                    "' (fn=" + fnName2 + " " + fp2 + ":" + line2 + ":" + col2 + ")"
    return Err[DotAccess](msg2)

fn lowerCallWithLeadingArg(b: BlockBuilder, callNode: Node, lead: MirExpr): Result[MirExpr] =
    if b == nil || callNode == nil || callNode.kind != nkCall || kidCount(callNode) == 0:
        return Err[MirExpr]("mir_builder: expected call")
    let calleeNode: Node = kid(callNode, 0)
    if calleeNode == nil:
        return Err[MirExpr]("mir_builder: call expects callee")
    var name: str = ""
    var typeArgs: Node[]
    if calleeNode.kind == nkBracketExpr && kidCount(calleeNode) > 0:
        let base: Node = kid(calleeNode, 0)
        name = backendStripSpaces(plainName(base))
        for ti in 1..<kidCount(calleeNode):
            let t: Node = kid(calleeNode, ti)
            if t != nil && t.kind != nkEmpty:
                add(typeArgs, t)
    elif calleeNode.kind == nkDotExpr && kidCount(calleeNode) > 1:
        let member: Node = kid(calleeNode, 1)
        if member != nil && member.kind == nkBracketExpr && kidCount(member) > 0:
            let base2: Node = kid(member, 0)
            name = backendStripSpaces(plainName(base2))
            for ti2 in 1..<kidCount(member):
                let t2: Node = kid(member, ti2)
                if t2 != nil && t2.kind != nkEmpty:
                    add(typeArgs, t2)
        else:
            name = backendStripSpaces(plainName(member))
    else:
        if calleeNode.kind != nkIdent && calleeNode.kind != nkSymbol:
            var fnName: str = ""
            var fp: str = ""
            if b.func != nil:
                let f0: MirFunc = b.func
                fnName = f0.name
                fp = f0.originFile
            let line: str = intToStr(callNode.pos.line)
            let col: str = intToStr(callNode.pos.col)
            let k: str = intToStr(int32(calleeNode.kind))
            return Err[MirExpr]("mir_builder: call expects identifier callee (kind=nk#" + k +
                                " fn=" + fnName + " " + fp + ":" + line + ":" + col + ")")
        name = backendStripSpaces(plainName(calleeNode))
    let localCalleeIdx: int32 = localIndex(b.env, name)
    if localCalleeIdx >= 0:
        let target: str = localCallTarget(b.env, localCalleeIdx)
        if target != nil && len(target) > 0:
            name = target

    var valueNodes: Node[]
    for ai in 1..<kidCount(callNode):
        let raw: Node = kid(callNode, ai)
        add(valueNodes, raw)

    if name == "Value" && valueNodes.len == 1 && b.module != nil:
        var srcNode0: Node = valueNodes[0]
        if srcNode0 != nil && srcNode0.kind == nkCallArg:
            if kidCount(srcNode0) > 1:
                srcNode0 = kid(srcNode0, 1)
            elif kidCount(srcNode0) > 0:
                srcNode0 = kid(srcNode0, 0)
        if srcNode0 != nil:
            let srcRes0: Result[MirExpr] = lowerExprValue(b, srcNode0, mirTypeI64())
            if IsOk[MirExpr](srcRes0):
                var srcPtr0: MirExpr = Value[MirExpr](srcRes0)
                var srcKey0: str = mirInferNodeTypeKeyForOverload(b, srcNode0)
                if mirStrStartsWith(srcKey0, "ref_"):
                    srcKey0 = str(ptr_add(void*(srcKey0), 4))
                elif mirStrStartsWith(srcKey0, "var_ref_"):
                    srcKey0 = str(ptr_add(void*(srcKey0), 8))
                elif mirStrStartsWith(srcKey0, "var_"):
                    srcKey0 = str(ptr_add(void*(srcKey0), 4))
                if mirStrStartsWith(srcKey0, "ptr_"):
                    srcKey0 = str(ptr_add(void*(srcKey0), 4))
                var valueOff0: int32 = -1
                let srcObj0: str = mirObjTypeFromTypeKey(b.module, srcKey0)
                if srcObj0 != nil && len(srcObj0) > 0 && mirHasObjType(b.module, srcObj0):
                    let srcOt0: MirObjType = mirGetObjType(b.module, srcObj0)
                    for sfi in 0..<srcOt0.fields.len:
                        let sf0: MirObjField = srcOt0.fields[sfi]
                        if (sf0.name == "value") || mirStrStartsWith(sf0.name, "value."):
                            if valueOff0 < 0 || sf0.offset < valueOff0:
                                valueOff0 = sf0.offset
                if valueOff0 < 0 && mirStrStartsWith(srcKey0, "Result_"):
                    valueOff0 = 0
                if valueOff0 > 0:
                    srcPtr0 = mirBin(mbAdd, srcPtr0, mirConstI64(int64(valueOff0)))
                var dstObj0: str = ""
                if callNode.typeCacheValid && callNode.typeCache != nil:
                    dstObj0 = typeNodeObjTypeName(b.module, callNode.typeCache)
                if (dstObj0 == nil || len(dstObj0) == 0) && b != nil && b.func != nil &&
                   lead != nil && lead.kind == meLocal:
                    let leadSlot0: int32 = lead.localIndex
                    if leadSlot0 >= 0 && funcFindObjLocal(b.func, leadSlot0) >= 0:
                        dstObj0 = funcObjTypeName(b.func, leadSlot0)
                if dstObj0 != nil && len(dstObj0) > 0:
                    let copyRes0: Result[bool] = emitObjCopyPtrs(b, lead, dstObj0, srcPtr0)
                    if !IsOk[bool](copyRes0):
                        return ErrInfo[MirExpr](ErrorInfoOf[bool](copyRes0))
                    if getEnv "CHENG_BACKEND_DEBUG_VALUE_LOWER" == "1":
                        var fnDbg1: str = ""
                        if b != nil && b.func != nil:
                            let fDbg1: MirFunc = b.func
                            fnDbg1 = fDbg1.name
                        echo("[backend] debugValueLower: fn=" + fnDbg1 + " dstObj=" + dstObj0)
                    return Ok[MirExpr](lead)

    var callName: str = name
    if typeArgs.len > 0:
        callName = mangleInstance(name, typeArgs)
    let helperCallNameL: str = mirStripLeadingUnderscores(callName)

    if mirDictHelperClosureEnabled() && b.module != nil:
        if kidCount(callNode) == 2:
            var ctorKindL: int32 = 0
            var resultSuffixL: str = ""
            if mirStrStartsWith(helperCallNameL, "Ok_"):
                ctorKindL = 1
                resultSuffixL = str(ptr_add(void*(helperCallNameL), 3))
            elif mirStrStartsWith(helperCallNameL, "Err_"):
                ctorKindL = 2
                resultSuffixL = str(ptr_add(void*(helperCallNameL), 4))
            elif mirStrStartsWith(helperCallNameL, "ErrInfo_"):
                ctorKindL = 3
                resultSuffixL = str(ptr_add(void*(helperCallNameL), 8))
            if ctorKindL <= 0:
                if helperCallNameL == "Ok":
                    ctorKindL = 1
                elif helperCallNameL == "Err":
                    ctorKindL = 2
                elif helperCallNameL == "ErrInfo":
                    ctorKindL = 3
                if ctorKindL > 0:
                    resultSuffixL = mirInferCtorSuffixFromTypeCache(b, callNode, "Result_")
            if ctorKindL > 0 && resultSuffixL != nil && len(resultSuffixL) > 0:
                let resultObjNameL: str = "Result_" + resultSuffixL
                if !mirHasObjType(b.module, resultObjNameL):
                    let _ensResultL: bool = ensureResultObjType(b.module, resultObjNameL)
                if mirHasObjType(b.module, resultObjNameL):
                    var payloadNodeL: Node = kid(callNode, 1)
                    if payloadNodeL != nil && payloadNodeL.kind == nkCallArg:
                        if kidCount(payloadNodeL) > 1:
                            payloadNodeL = kid(payloadNodeL, 1)
                        elif kidCount(payloadNodeL) > 0:
                            payloadNodeL = kid(payloadNodeL, 0)
                    var payloadExprL: Node = payloadNodeL
                    if ctorKindL == 2:
                        var errCtorL: Node = newNode(nkCall, callNode.pos)
                        addSon(errCtorL, newIdent("ErrorInfo", callNode.pos))
                        var errCodeArgL: Node = newNode(nkCallArg, callNode.pos)
                        addSon(errCodeArgL, newIdent("code", callNode.pos))
                        addSon(errCodeArgL, newIntLit(0, callNode.pos))
                        addSon(errCtorL, errCodeArgL)
                        var errMsgArgL: Node = newNode(nkCallArg, callNode.pos)
                        addSon(errMsgArgL, newIdent("msg", callNode.pos))
                        addSon(errMsgArgL, payloadNodeL)
                        addSon(errCtorL, errMsgArgL)
                        payloadExprL = errCtorL

                    var ctorCallL: Node = newNode(nkCall, callNode.pos)
                    addSon(ctorCallL, newIdent(resultObjNameL, callNode.pos))
                    var okArgL: Node = newNode(nkCallArg, callNode.pos)
                    addSon(okArgL, newIdent("ok", callNode.pos))
                    if ctorKindL == 1:
                        addSon(okArgL, newBoolLit(true, callNode.pos))
                    else:
                        addSon(okArgL, newBoolLit(false, callNode.pos))
                    addSon(ctorCallL, okArgL)
                    var payloadArgL: Node = newNode(nkCallArg, callNode.pos)
                    if ctorKindL == 1:
                        addSon(payloadArgL, newIdent("value", callNode.pos))
                    else:
                        addSon(payloadArgL, newIdent("err", callNode.pos))
                    addSon(payloadArgL, payloadExprL)
                    addSon(ctorCallL, payloadArgL)
                    let ctorResL: Result[MirExpr] = lowerObjConstructorCall(b, ctorCallL, resultObjNameL)
                    if !IsOk[MirExpr](ctorResL):
                        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](ctorResL))
                    let copyResL: Result[bool] = emitObjCopyPtrs(b, lead, resultObjNameL, Value[MirExpr](ctorResL))
                    if !IsOk[bool](copyResL):
                        return ErrInfo[MirExpr](ErrorInfoOf[bool](copyResL))
                    return Ok[MirExpr](lead)

        var optionCtorKindL: int32 = 0
        var optionSuffixL: str = ""
        if kidCount(callNode) == 2 && mirStrStartsWith(helperCallNameL, "Some_"):
            optionCtorKindL = 1
            optionSuffixL = str(ptr_add(void*(helperCallNameL), 5))
        elif kidCount(callNode) == 1 && mirStrStartsWith(helperCallNameL, "None_"):
            optionCtorKindL = 2
            optionSuffixL = str(ptr_add(void*(helperCallNameL), 5))
        if optionCtorKindL <= 0:
            if kidCount(callNode) == 2 && helperCallNameL == "Some":
                optionCtorKindL = 1
                optionSuffixL = mirInferCtorSuffixFromTypeCache(b, callNode, "Option_")
            elif kidCount(callNode) == 1 && helperCallNameL == "None":
                optionCtorKindL = 2
                optionSuffixL = mirInferCtorSuffixFromTypeCache(b, callNode, "Option_")
        if optionCtorKindL > 0 && optionSuffixL != nil && len(optionSuffixL) > 0:
            let optionObjNameL: str = "Option_" + optionSuffixL
            if !mirHasObjType(b.module, optionObjNameL):
                let _ensOptionL: bool = ensureOptionObjType(b.module, optionObjNameL)
