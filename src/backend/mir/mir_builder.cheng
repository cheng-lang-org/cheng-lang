                        # pointer itself (no extra indirection). Ref-like aliases still use an
                        # extra indirection and must be loaded.
                        let aliasTy0: MirType = mirTryGetTypeAlias(b.module, baseKey)
                        wantLoad = aliasTy0.kind != mtVoid
                    elif ((baseKey == "seq") || mirStrStartsWith(baseKey, "seq_") || mirStrStartsWith(baseKey, "seq_fixed_")) &&
                         mirHasObjType(b.module, "seq"):
                        wantLoad = false
                    elif ((baseKey == "Table") || mirStrStartsWith(baseKey, "Table_")) && mirHasObjType(b.module, "Table"):
                        wantLoad = false
                    if wantLoad:
                        let baseTy: MirType = mirTypeFromTypeKeyName(baseKey)
                        let loaded: MirExpr = mirLoad(mirLocal(idx), baseTy)
                        if wantType.kind != baseTy.kind || wantType.isUnsigned != baseTy.isUnsigned:
                            return Ok[MirExpr](mirCast(wantType, loaded))
                        return Ok[MirExpr](loaded)
