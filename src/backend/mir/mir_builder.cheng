                                       " (obj=" + ol.objTypeName + " want=" + wantNm +
                                       " fn=" + fref.name + " " + fp + ":" + line + ":" + col + ")"
                        return Err[MirExpr](msg)
            return Ok[MirExpr](mirLocal(idx))
        let mod: MirModule = b.module
        var gi: int32 = moduleGlobalIndex(mod, nm)
        if gi < 0 && b.func != nil && mirDupGlobalNamesHas(nm):
