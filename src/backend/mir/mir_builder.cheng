                        if outTy1.kind == mtVoid:
                            let innerKey1: str = mirInferValueCallInnerKey(b, node)
                            if innerKey1 != nil && len(innerKey1) > 0:
                                outTy1 = mirTypeFromNodeWithModule(b.module, newIdent(innerKey1, node.pos))
                        if outTy1.kind == mtVoid:
                            outTy1 = mirTypeI64()
                        return Ok[MirExpr](mirLoad(valueAddr1, outTy1))

        # Indirect call: callee is a function pointer expression (stored in a local/field).
        if b.module != nil:
            var isIndirect: bool = false
            var callee1: Node = calleeNode
            while callee1 != nil && callee1.kind == nkPar && kidCount(callee1) > 0:
                callee1 = kid(callee1, 0)
            if callee1 != nil && (callee1.kind == nkIdent || callee1.kind == nkSymbol):
                let nm1: str = plainName(callee1)
                if localIndex(b.env, nm1) >= 0:
                    isIndirect = true
            elif callee1 != nil && callee1.kind == nkDotExpr && kidCount(callee1) > 1:
                var base1: Node = kid(callee1, 0)
                while base1 != nil && base1.kind == nkPar && kidCount(base1) > 0:
                    base1 = kid(base1, 0)
                var baseKey1: str = caseInferExprTypeKey(b, base1)
                if mirStrStartsWith(baseKey1, "ref_"):
                    baseKey1 = str(ptr_add(void*(baseKey1), 4))
                elif mirStrStartsWith(baseKey1, "var_ref_"):
                    baseKey1 = str(ptr_add(void*(baseKey1), 8))
                elif mirStrStartsWith(baseKey1, "var_"):
                    baseKey1 = str(ptr_add(void*(baseKey1), 4))
                if baseKey1 != nil && len(baseKey1) > 0:
                    let canon1: str = mirObjAliasCanon(baseKey1)
                    if canon1 != nil && len(canon1) > 0:
                        baseKey1 = canon1
                if mirStrStartsWith(baseKey1, "ptr_"):
                    baseKey1 = str(ptr_add(void*(baseKey1), 4))
                if (baseKey1 != nil && len(baseKey1) > 0 && mirHasObjType(b.module, baseKey1)) ||
                   (mirStrStartsWith(baseKey1, "seq_") && mirHasObjType(b.module, "seq")) ||
                   (mirStrStartsWith(baseKey1, "seq_fixed_") && mirHasObjType(b.module, "seq")) ||
                   (mirStrStartsWith(baseKey1, "Table_") && mirHasObjType(b.module, "Table")):
                    isIndirect = true
            if !isIndirect:
                var calleeKey: str = caseInferExprTypeKey(b, callee1)
                if mirStrStartsWith(calleeKey, "ref_"):
                    calleeKey = str(ptr_add(void*(calleeKey), 4))
                elif mirStrStartsWith(calleeKey, "var_ref_"):
                    calleeKey = str(ptr_add(void*(calleeKey), 8))
                elif mirStrStartsWith(calleeKey, "var_"):
                    calleeKey = str(ptr_add(void*(calleeKey), 4))
                if mirStrStartsWith(calleeKey, "ptr_"):
                    calleeKey = str(ptr_add(void*(calleeKey), 4))
                if mirStrStartsWith(calleeKey, "fn") || mirStrStartsWith(calleeKey, "fn_"):
                    isIndirect = true
            if isIndirect:
                let dbgIndirect1: bool = (getEnv "CHENG_BACKEND_DEBUG_INDIRECT" == "1")
                if dbgIndirect1:
                    let dbgName1: str = getEnv "CHENG_BACKEND_DEBUG_INDIRECT_NAME"
                    var calleeNm1: str = ""
                    if callee1 != nil && (callee1.kind == nkIdent || callee1.kind == nkSymbol):
                        calleeNm1 = backendStripSpaces(plainName(callee1))
                    elif callee1 != nil && callee1.kind == nkDotExpr && kidCount(callee1) > 1:
                        let mem1: Node = kid(callee1, 1)
                        if mem1 != nil && (mem1.kind == nkIdent || mem1.kind == nkSymbol):
                            calleeNm1 = backendStripSpaces(plainName(mem1))
                    if dbgName1 == nil || len(dbgName1) == 0 || (calleeNm1 == dbgName1):
                        var fn1: str = ""
                        var fp1: str = ""
                        if b != nil && b.func != nil:
                            let f1: MirFunc = b.func
                            fn1 = f1.name
                            fp1 = f1.originFile
                        let line1: str = intToStr(node.pos.line)
                        let col1: str = intToStr(node.pos.col)
                        echo("[backend] debugIndirect: callee='" + calleeNm1 + "' isIndirect=1 fn=" + fn1 +
                             " " + fp1 + ":" + line1 + ":" + col1)
                let fnPtrRes: Result[MirExpr] = lowerExprValue(b, calleeNode, mirTypeI64())
                if !IsOk[MirExpr](fnPtrRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](fnPtrRes))
                var indArgs: MirExpr[]
                add(indArgs, Value[MirExpr](fnPtrRes))
                for xi in 0..<argNodes.len:
                    let argNode2: Node = argNodes[xi]
                    let argRes: Result[MirExpr] = lowerExprValue(b, argNode2, mirTypeI64())
                    if !IsOk[MirExpr](argRes):
                        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](argRes))
                    add(indArgs, Value[MirExpr](argRes))
                let indName: str = "__cheng_call_indirect_" + intToStr(indArgs.len - 1)
                return Ok[MirExpr](mirCall(indName, indArgs))

        let modSig: MirModule = b.module
        if modSig != nil && !(name == "Value" && argNodes.len == 1):
            let hintSig: str = mirInferCallRetKeyHint(node)
            let calleeSig: MirFunc = mirResolveCalleeFuncBestEffort(b, callName0, argNodes, hintSig)
            if calleeSig != nil && calleeSig.params.len > 0:
                let pFirstSig: MirParam = calleeSig.params[0]
                if (pFirstSig.name == "__ret"):
                    let retObjName: str = funcObjTypeName(calleeSig, pFirstSig.slot)
                    if len(retObjName) > 0:
                        let tmpName: str = blockBuilderNextTemp(b, "__callret")
                        let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
                        mirSetLocalType(b.func, tmpSlot, mirTypeI64())
                        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, retObjName)
                        if ! IsOk[bool](allocRes):
                            return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))
                        return lowerCallWithLeadingArg(b, node, mirLocal(tmpSlot))

        # builtin: len(x) for str/seq/Table (cannot rely on overload resolution because `len`
        # can also be user-defined for custom types).
        if name == "len" && typeArgs.len == 0 && argNodes.len == 1:
            let arg0: Node = argNodes[0]
            var k0: str = caseInferExprTypeKey(b, arg0)
            if len(k0) == 0 && arg0 != nil && (arg0.kind == nkIdent || arg0.kind == nkSymbol):
                let nm0: str = plainName(arg0)
                let slot0: int32 = localIndex(b.env, nm0)
                if slot0 >= 0 && b.func != nil:
                    let olIdx0: int32 = funcFindObjLocal(b.func, slot0)
                    if olIdx0 >= 0:
                        k0 = funcObjTypeName(b.func, slot0)
                    else:
                        let ty0: MirType = localType(b.env, slot0)
                        if ty0.kind == mtI64:
                            k0 = "str"

            # str/cstring
            if (k0 == "str") || (k0 == "string") || (k0 == "cstring") || (arg0 != nil && arg0.kind == nkStrLit):
                let valRes0: Result[MirExpr] = lowerExprValue(b, arg0, mirTypeI64())
                if !IsOk[MirExpr](valRes0):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes0))
                let lenName0: str = blockBuilderNextTemp(b, "__len_str")
                let lenSlot0: int32 = localAdd(b.env, lenName0, mirTypeI32())
                mirSetLocalType(b.func, lenSlot0, mirTypeI32())
                var args0: MirExpr[]
                add(args0, Value[MirExpr](valRes0))
                add(b.currentStmts, mirStmtLet(lenName0, lenSlot0, mirCall("cheng_strlen", args0)))
                return Ok[MirExpr](mirLocal(lenSlot0))

            # seq[T]
            if b.module != nil && mirHasObjType(b.module, "seq") &&
               ((k0 == "seq") || mirStrStartsWith(k0, "seq_") || mirStrStartsWith(k0, "seq_fixed_")):
                let seqRes0: Result[MirExpr] = lowerExprValue(b, arg0, mirTypeI64())
                if !IsOk[MirExpr](seqRes0):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](seqRes0))
                let seqName0: str = blockBuilderNextTemp(b, "__len_seq")
                let seqSlot0: int32 = localAdd(b.env, seqName0, mirTypeI64())
                mirSetLocalType(b.func, seqSlot0, mirTypeI64())
                add(b.currentStmts, mirStmtLet(seqName0, seqSlot0, Value[MirExpr](seqRes0)))
                let seqPtr0: MirExpr = mirLocal(seqSlot0)

                let seqOt0: MirObjType = mirGetObjType(b.module, "seq")
                var lenOff0: int32 = -1
                for fi0 in 0..<seqOt0.fields.len:
                    let f0: MirObjField = seqOt0.fields[fi0]
                    if (f0.name == "len"):
                        lenOff0 = f0.offset
                        break
                if lenOff0 < 0:
                    return Err[MirExpr]("mir_builder: seq layout mismatch")

                let lenAddr0: MirExpr = (lenOff0 == 0) ? seqPtr0 : mirBin(mbAdd, seqPtr0, mirConstI64(int64(lenOff0)))
                let lenName1: str = blockBuilderNextTemp(b, "__len")
                let lenSlot1: int32 = localAdd(b.env, lenName1, mirTypeI32())
                mirSetLocalType(b.func, lenSlot1, mirTypeI32())
                add(b.currentStmts, mirStmtLet(lenName1, lenSlot1, mirLoad(lenAddr0, mirTypeI32())))
                return Ok[MirExpr](mirLocal(lenSlot1))

            # tables.Table[V]
            if b.module != nil && mirHasObjType(b.module, "Table") &&
               ((k0 == "Table") || mirStrStartsWith(k0, "Table_")):
                let tabRes0: Result[MirExpr] = lowerExprValue(b, arg0, mirTypeI64())
                if !IsOk[MirExpr](tabRes0):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](tabRes0))
                let tabName0: str = blockBuilderNextTemp(b, "__len_table")
                let tabSlot0: int32 = localAdd(b.env, tabName0, mirTypeI64())
                mirSetLocalType(b.func, tabSlot0, mirTypeI64())
                add(b.currentStmts, mirStmtLet(tabName0, tabSlot0, Value[MirExpr](tabRes0)))
                let tabPtr0: MirExpr = mirLocal(tabSlot0)

                let tabOt0: MirObjType = mirGetObjType(b.module, "Table")
                var lenOff1: int32 = -1
                for fj0 in 0..<tabOt0.fields.len:
                    let f1: MirObjField = tabOt0.fields[fj0]
                    if (f1.name == "len"):
                        lenOff1 = f1.offset
                        break
                if lenOff1 < 0:
                    return Err[MirExpr]("mir_builder: Table layout mismatch")

                let lenAddr1: MirExpr = (lenOff1 == 0) ? tabPtr0 : mirBin(mbAdd, tabPtr0, mirConstI64(int64(lenOff1)))
                let lenName2: str = blockBuilderNextTemp(b, "__len")
                let lenSlot2: int32 = localAdd(b.env, lenName2, mirTypeI32())
                mirSetLocalType(b.func, lenSlot2, mirTypeI32())
                add(b.currentStmts, mirStmtLet(lenName2, lenSlot2, mirLoad(lenAddr1, mirTypeI32())))
                return Ok[MirExpr](mirLocal(lenSlot2))

        # Fallback: infer object-return calls from the callee signature when typeCache is missing
        # or doesn't indicate an object value.
        if b.module != nil &&
           (!node.typeCacheValid || node.typeCache == nil || !typeNodeIsObjValue(b.module, node.typeCache)):
            var callName2: str = name
            if typeArgs.len > 0:
                callName2 = mangleInstance(name, typeArgs)
            let callee0: MirFunc = mirResolveCalleeFuncBestEffort(b, callName2, argNodes, "")
            if callee0 != nil && callee0.params.len > 0:
                let p0: MirParam = callee0.params[0]
                if (p0.name == "__ret"):
                    let objNm: str = funcObjTypeName(callee0, p0.slot)
                    if len(objNm) > 0:
                        let tmpName: str = blockBuilderNextTemp(b, "__callret")
                        let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
                        mirSetLocalType(b.func, tmpSlot, mirTypeI64())
                        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objNm)
                        if ! IsOk[bool](allocRes):
                            return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))
                        let kret: str = funcObjTypeKey(callee0, p0.slot)
                        if len(kret) > 0:
                            funcSetObjTypeKey(b.func, tmpSlot, kret)
                        return lowerCallWithLeadingArg(b, node, mirLocal(tmpSlot))

        var callName: str = name
        if typeArgs.len > 0:
            callName = mangleInstance(name, typeArgs)
        var calleeFunc: MirFunc = nil
        var callInternal: str = callName
        let mod2: MirModule = b.module
        if mod2 != nil:
            let hint: str = mirInferCallRetKeyHint(node)
            let cand: MirFunc = mirResolveCalleeFuncBestEffort(b, callName, argNodes, hint)
            if cand != nil:
                calleeFunc = cand
                callInternal = cand.name
            elif moduleHasFuncByBase(mod2, callName):
                let calleeRes: Result[MirFunc] = mirResolveCalleeFunc(b, node, callName, argNodes)
                if !IsOk[MirFunc](calleeRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirFunc](calleeRes))
                calleeFunc = Value[MirFunc](calleeRes)
                callInternal = calleeFunc.name
        if name == "Value" && argNodes.len == 1:
            let valueArg0: Node = argNodes[0]
            if valueArg0 != nil:
                let valueBaseRes: Result[MirExpr] = lowerExprValue(b, valueArg0, mirTypeI64())
                if IsOk[MirExpr](valueBaseRes):
                    var valueAddr0: MirExpr = Value[MirExpr](valueBaseRes)
                    if mod2 != nil:
                        var valueArgKey0: str = mirInferNodeTypeKeyForOverload(b, valueArg0)
                        if mirStrStartsWith(valueArgKey0, "ref_"):
                            valueArgKey0 = str(ptr_add(void*(valueArgKey0), 4))
                        elif mirStrStartsWith(valueArgKey0, "var_ref_"):
                            valueArgKey0 = str(ptr_add(void*(valueArgKey0), 8))
                        elif mirStrStartsWith(valueArgKey0, "var_"):
                            valueArgKey0 = str(ptr_add(void*(valueArgKey0), 4))
                        if mirStrStartsWith(valueArgKey0, "ptr_"):
                            valueArgKey0 = str(ptr_add(void*(valueArgKey0), 4))
                        let valueObj0: str = mirObjTypeFromTypeKey(mod2, valueArgKey0)
                        if valueObj0 != nil && len(valueObj0) > 0 && mirHasObjType(mod2, valueObj0):
                            let valueOt0: MirObjType = mirGetObjType(mod2, valueObj0)
                            var valueOff0: int32 = -1
                            for vfi in 0..<valueOt0.fields.len:
                                let vf0: MirObjField = valueOt0.fields[vfi]
                                if (vf0.name == "value") || mirStrStartsWith(vf0.name, "value."):
                                    valueOff0 = vf0.offset
                                    break
                            if valueOff0 > 0:
                                valueAddr0 = mirBin(mbAdd, valueAddr0, mirConstI64(int64(valueOff0)))
                    var valueOutTy0: MirType = wantType
                    if valueOutTy0.kind == mtVoid && mod2 != nil:
                        let valueInnerKey0: str = mirInferValueCallInnerKey(b, node)
                        if valueInnerKey0 != nil && len(valueInnerKey0) > 0:
                            valueOutTy0 = mirTypeFromNodeWithModule(mod2, newIdent(valueInnerKey0, node.pos))
                    if valueOutTy0.kind == mtVoid:
                        valueOutTy0 = mirTypeI64()
                    if getEnv "CHENG_BACKEND_DEBUG_VALUE_LOWER" == "1":
                        var fnDbg0: str = ""
                        if b != nil && b.func != nil:
                            let fDbg0: MirFunc = b.func
                            fnDbg0 = fDbg0.name
                        echo("[backend] debugValueLower: fn=" + fnDbg0 + " valueOutTy=" + mirTypeKindName(valueOutTy0))
                    return Ok[MirExpr](mirLoad(valueAddr0, valueOutTy0))

        var args: MirExpr[]
        let dbgVarCallRaw: str = getEnv "CHENG_BACKEND_DEBUG_VARCALL"
        var dbgVarCall: bool = (dbgVarCallRaw == "1")
        let dbgVarCallName: str = getEnv "CHENG_BACKEND_DEBUG_VARCALL_NAME"
        if dbgVarCall && dbgVarCallName != nil && len(dbgVarCallName) > 0:
            dbgVarCall = (callName == dbgVarCallName)
        for ai2 in 0..<argNodes.len:
            let argNode: Node = argNodes[ai2]
            let dbgSpawn: bool = (getEnv "CHENG_BACKEND_DEBUG_SPAWN" == "1")
            if dbgSpawn && name == "spawn":
                var kindStr: str = "nil"
                if argNode != nil:
                    kindStr = intToStr(int32(argNode.kind))
                echo("[backend] debugSpawn: arg#" + intToStr(ai2 + 1) + " kind=nk#" + kindStr)
            var wantVarAddr: bool = false
            var pi2: int32 = ai2
            var dbgParamKey: str = ""
            if calleeFunc != nil && calleeFunc.params.len > 0:
                let pFirst: MirParam = calleeFunc.params[0]
                if (pFirst.name == "__ret"):
                    pi2 = ai2 + 1
            if calleeFunc != nil && pi2 >= 0 && pi2 < calleeFunc.params.len:
                let p0: MirParam = calleeFunc.params[pi2]
                dbgParamKey = p0.typeKey
                if mirStrStartsWith(p0.typeKey, "var_"):
                    let baseKey: str = str(ptr_add(void*(p0.typeKey), 4))
                    if baseKey == nil || len(baseKey) == 0 || mod2 == nil:
                        wantVarAddr = true
                    elif mirHasObjType(mod2, baseKey):
                        # Ref-like types have an object layout but are represented as pointer aliases.
                        # `var RefType` expects a pointer-to-pointer (i.e. take the slot address).
                        let aliasTy0: MirType = mirTryGetTypeAlias(mod2, baseKey)
                        wantVarAddr = aliasTy0.kind != mtVoid
                    elif mirStrStartsWith(baseKey, "seq_") && mirHasObjType(mod2, "seq"):
                        wantVarAddr = false
                    else:
                        wantVarAddr = true
                elif (p0.typeKey == "var"):
                    wantVarAddr = true
            if dbgVarCall:
                var calleeDbg: str = ""
                if calleeFunc != nil:
                    calleeDbg = calleeFunc.name
                echo("[backend] debugVarCall: call=" + callName +
                     " callee=" + calleeDbg +
                     " argIdx=" + intToStr(ai2) +
                     " paramKey=" + dbgParamKey +
                     " wantVarAddr=" + (wantVarAddr ? "1" : "0"))
            if wantVarAddr:
                let addrRes: Result[MirExpr] = lowerVarArgAddr(b, argNode)
                if !IsOk[MirExpr](addrRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](addrRes))
                add(args, Value[MirExpr](addrRes))
            elif (ai2 == 0) && (name == "spawn"):
                let fnRes: Result[MirExpr] = lowerSpawnEntryArg(b, argNode)
                if !IsOk[MirExpr](fnRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](fnRes))
                add(args, Value[MirExpr](fnRes))
            else:
                # Call argument lowering should not depend on the call's return type.
                let argRes: Result[MirExpr] = lowerExprValue(b, argNode, mirTypeI64())
                if !IsOk[MirExpr](argRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](argRes))
                add(args, Value[MirExpr](argRes))
        let valueLikeCall1: bool = (callInternal == "Value") || (callName == "Value") ||
            (calleeFunc != nil && calleeFunc.linkName != nil && (calleeFunc.linkName == "Value"))
        if valueLikeCall1 && args.len >= 1:
            var valueAddr1: MirExpr = args[0]
            if mod2 != nil && argNodes.len > 0 && argNodes[0] != nil:
                var valueArgKey1: str = mirInferNodeTypeKeyForOverload(b, argNodes[0])
                if mirStrStartsWith(valueArgKey1, "ref_"):
                    valueArgKey1 = str(ptr_add(void*(valueArgKey1), 4))
                elif mirStrStartsWith(valueArgKey1, "var_ref_"):
                    valueArgKey1 = str(ptr_add(void*(valueArgKey1), 8))
                elif mirStrStartsWith(valueArgKey1, "var_"):
                    valueArgKey1 = str(ptr_add(void*(valueArgKey1), 4))
                if mirStrStartsWith(valueArgKey1, "ptr_"):
                    valueArgKey1 = str(ptr_add(void*(valueArgKey1), 4))
                var valueOff1: int32 = -1
                let valueObj1: str = mirObjTypeFromTypeKey(mod2, valueArgKey1)
                if valueObj1 != nil && len(valueObj1) > 0 && mirHasObjType(mod2, valueObj1):
                    let valueOt1: MirObjType = mirGetObjType(mod2, valueObj1)
                    for vfi1 in 0..<valueOt1.fields.len:
                        let vf1: MirObjField = valueOt1.fields[vfi1]
                        if (vf1.name == "value") || mirStrStartsWith(vf1.name, "value."):
                            if valueOff1 < 0 || vf1.offset < valueOff1:
                                valueOff1 = vf1.offset
                if valueOff1 < 0 && mirStrStartsWith(valueArgKey1, "Result_"):
                    valueOff1 = 0
                if valueOff1 > 0:
                    valueAddr1 = mirBin(mbAdd, valueAddr1, mirConstI64(int64(valueOff1)))
            var outTy1: MirType = wantType
            if outTy1.kind == mtVoid && mod2 != nil:
                let innerKey2: str = mirInferValueCallInnerKey(b, node)
                if innerKey2 != nil && len(innerKey2) > 0:
                    outTy1 = mirTypeFromNodeWithModule(mod2, newIdent(innerKey2, node.pos))
            if outTy1.kind == mtVoid:
                outTy1 = mirTypeI64()
            return Ok[MirExpr](mirLoad(valueAddr1, outTy1))
        return Ok[MirExpr](mirCall(callInternal, args))
    if node.kind == nkPrefix && kidCount(node) > 1:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        let rhs: Node = kid(node, 1)
        if op == "$":
            var argNodes0: Node[1]
            add(argNodes0, rhs)
            var callInternal0: str = "$"
            let mod2: MirModule = b.module
            if mod2 != nil:
                let cand: MirFunc = mirResolveCalleeFuncBestEffort(b, "$", argNodes0, "str")
                if cand != nil:
                    callInternal0 = cand.name
                elif moduleHasFuncByBase(mod2, "$"):
                    let calleeRes: Result[MirFunc] = mirResolveCalleeFunc(b, node, "$", argNodes0)
                    if !IsOk[MirFunc](calleeRes):
                        return ErrInfo[MirExpr](ErrorInfoOf[MirFunc](calleeRes))
                    let callee: MirFunc = Value[MirFunc](calleeRes)
                    callInternal0 = callee.name
            let rhsRes0: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI64())
            if !IsOk[MirExpr](rhsRes0):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsRes0))
            var args0: MirExpr[]
            add(args0, Value[MirExpr](rhsRes0))
            return Ok[MirExpr](mirCall(callInternal0, args0))
        if op == "-":
            var k: str = exprTypeKeyShallow(b, node)
            if len(k) == 0:
                k = exprTypeKeyShallow(b, rhs)
            if isFloat64Key(k):
                let rhsBitsRes: Result[MirExpr] = lowerToF64Bits(b, rhs)
                if ! IsOk[MirExpr](rhsBitsRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsBitsRes))
                var args: MirExpr[]
                add(args, Value[MirExpr](rhsBitsRes))
                return Ok[MirExpr](mirCast(mirTypeF64(), mirCall("cheng_f64_neg_bits", args)))
            let rhsRes: Result[MirExpr] = lowerExprValue(b, rhs, wantType)
            if ! IsOk[MirExpr](rhsRes):
                return rhsRes
            let zero: MirExpr = mirConstI64(0)
            return Ok[MirExpr](mirBin(mbSub, zero, Value[MirExpr](rhsRes)))
        if op == "+":
            return lowerExprValue(b, rhs, wantType)
        if op == "~":
            let rhsRes2: Result[MirExpr] = lowerExprValue(b, rhs, wantType)
            if ! IsOk[MirExpr](rhsRes2):
                return rhsRes2
            let allBits: MirExpr = mirConstI64(-1)
            return Ok[MirExpr](mirBin(mbXor, Value[MirExpr](rhsRes2), allBits))
        if op == "!":
            let rhsRes3: Result[MirExpr] = lowerExprValue(b, rhs, wantType)
            if ! IsOk[MirExpr](rhsRes3):
                return rhsRes3
            let zero2: MirExpr = mirConstI64(0)
            return Ok[MirExpr](mirCmp(mcEq, Value[MirExpr](rhsRes3), zero2))
    if node.kind == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        let lhsNode: Node = kid(node, 1)
        let rhsNode: Node = kid(node, 2)
        if op == "in" || op == "notin":
            return lowerInExpr(b, lhsNode, rhsNode, op == "notin")
        if op == "+" || op == "==" || op == "!=":
            let lk: str = caseInferExprTypeKey(b, lhsNode)
            let rk: str = caseInferExprTypeKey(b, rhsNode)
            let selfK: str = exprTypeKeyShallow(b, node)
            if isStringKey(selfK) || isStringKey(lk) || isStringKey(rk) || lhsNode.kind == nkStrLit || rhsNode.kind == nkStrLit:
                let lhsResS: Result[MirExpr] = lowerExprValue(b, lhsNode, mirTypeI64())
                if ! IsOk[MirExpr](lhsResS):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](lhsResS))
                let rhsResS: Result[MirExpr] = lowerExprValue(b, rhsNode, mirTypeI64())
                if ! IsOk[MirExpr](rhsResS):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsResS))
                let lhsS: MirExpr = Value[MirExpr](lhsResS)
                let rhsS: MirExpr = Value[MirExpr](rhsResS)
                var argsS: MirExpr[]
                add(argsS, lhsS)
                add(argsS, rhsS)
                if op == "+":
                    return Ok[MirExpr](mirCall(backendSanitizeLinkName("+"), argsS))
                let eqCall: MirExpr = mirCall("__cheng_str_eq", argsS)
                if op == "==":
                    return Ok[MirExpr](eqCall)
                return Ok[MirExpr](mirCmp(mcEq, eqCall, mirConstI64(0)))
            if (op == "==" || op == "!=") && (mirObjAliasCanon(lk) == "Bytes") && (mirObjAliasCanon(rk) == "Bytes"):
                let lhsResB: Result[MirExpr] = lowerExprValue(b, lhsNode, mirTypeI64())
                if ! IsOk[MirExpr](lhsResB):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](lhsResB))
                let rhsResB: Result[MirExpr] = lowerExprValue(b, rhsNode, mirTypeI64())
                if ! IsOk[MirExpr](rhsResB):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsResB))
                let lhsB: MirExpr = Value[MirExpr](lhsResB)
                let rhsB: MirExpr = Value[MirExpr](rhsResB)
                var argsB: MirExpr[]
                add(argsB, lhsB)
                add(argsB, rhsB)
                let eqCall: MirExpr = mirCall("bytesEqual", argsB)
                if op == "==":
                    return Ok[MirExpr](eqCall)
                return Ok[MirExpr](mirCmp(mcEq, eqCall, mirConstI64(0)))
        var kInfix: str = exprTypeKeyShallow(b, node)
        if len(kInfix) == 0:
            kInfix = exprTypeKeyShallow(b, lhsNode)
        if len(kInfix) == 0:
            kInfix = exprTypeKeyShallow(b, rhsNode)
        let lhsInferTy: MirType = inferExprTypeWithGlobals(b.env, b.module, b.func, lhsNode, mirTypeI32())
        let rhsInferTy: MirType = inferExprTypeWithGlobals(b.env, b.module, b.func, rhsNode, mirTypeI32())
        let inferF64: bool = lhsInferTy.kind == mtF64 || rhsInferTy.kind == mtF64
        let inferF32: bool = lhsInferTy.kind == mtF32 || rhsInferTy.kind == mtF32
        if (isFloat32Key(kInfix) || (inferF32 && !inferF64)):
            let lhsBits32Res: Result[MirExpr] = lowerToF32Bits(b, lhsNode)
            if !IsOk[MirExpr](lhsBits32Res):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](lhsBits32Res))
            let rhsBits32Res: Result[MirExpr] = lowerToF32Bits(b, rhsNode)
            if !IsOk[MirExpr](rhsBits32Res):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsBits32Res))
            let lhsBits32: MirExpr = Value[MirExpr](lhsBits32Res)
            let rhsBits32: MirExpr = Value[MirExpr](rhsBits32Res)
            if op == "==":
                return Ok[MirExpr](mirCmp(mcEq, lhsBits32, rhsBits32))
            if op == "!=":
                return Ok[MirExpr](mirCmp(mcNe, lhsBits32, rhsBits32))

            var lhsUpArgs: MirExpr[]
            add(lhsUpArgs, lhsBits32)
            let lhsBits64: MirExpr = mirCall("cheng_f32_bits_to_f64_bits", lhsUpArgs)
            var rhsUpArgs: MirExpr[]
            add(rhsUpArgs, rhsBits32)
            let rhsBits64: MirExpr = mirCall("cheng_f32_bits_to_f64_bits", rhsUpArgs)
            var args32: MirExpr[]
            add(args32, lhsBits64)
            add(args32, rhsBits64)
            if op == "+":
                var downArgs0: MirExpr[]
                add(downArgs0, mirCall("cheng_f64_add_bits", args32))
                return Ok[MirExpr](mirCast(mirTypeF32(), mirCall("cheng_f64_bits_to_f32_bits", downArgs0)))
            if op == "-":
                var downArgs1: MirExpr[]
                add(downArgs1, mirCall("cheng_f64_sub_bits", args32))
                return Ok[MirExpr](mirCast(mirTypeF32(), mirCall("cheng_f64_bits_to_f32_bits", downArgs1)))
            if op == "*":
                var downArgs2: MirExpr[]
                add(downArgs2, mirCall("cheng_f64_mul_bits", args32))
                return Ok[MirExpr](mirCast(mirTypeF32(), mirCall("cheng_f64_bits_to_f32_bits", downArgs2)))
            if op == "/":
                var downArgs3: MirExpr[]
                add(downArgs3, mirCall("cheng_f64_div_bits", args32))
                return Ok[MirExpr](mirCast(mirTypeF32(), mirCall("cheng_f64_bits_to_f32_bits", downArgs3)))
            if op == "<":
                return Ok[MirExpr](mirCall("cheng_f64_lt_bits", args32))
            if op == "<=":
                return Ok[MirExpr](mirCall("cheng_f64_le_bits", args32))
            if op == ">":
                return Ok[MirExpr](mirCall("cheng_f64_gt_bits", args32))
            if op == ">=":
                return Ok[MirExpr](mirCall("cheng_f64_ge_bits", args32))
            let lineF32: str = intToStr(node.pos.line)
            let colF32: str = intToStr(node.pos.col)
            return Err[MirExpr]("mir_builder: unsupported float32 infix op '" + op + "' @" + lineF32 + ":" + colF32)
        if isFloat64Key(kInfix) || inferF64:
            let lhsBitsRes: Result[MirExpr] = lowerToF64Bits(b, lhsNode)
            if ! IsOk[MirExpr](lhsBitsRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](lhsBitsRes))
            let rhsBitsRes: Result[MirExpr] = lowerToF64Bits(b, rhsNode)
            if ! IsOk[MirExpr](rhsBitsRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsBitsRes))
            let lhsBits: MirExpr = Value[MirExpr](lhsBitsRes)
            let rhsBits: MirExpr = Value[MirExpr](rhsBitsRes)
            if op == "==":
                return Ok[MirExpr](mirCmp(mcEq, lhsBits, rhsBits))
            if op == "!=":
                return Ok[MirExpr](mirCmp(mcNe, lhsBits, rhsBits))
            var args2: MirExpr[]
            add(args2, lhsBits)
            add(args2, rhsBits)
            if op == "+":
                return Ok[MirExpr](mirCast(mirTypeF64(), mirCall("cheng_f64_add_bits", args2)))
            if op == "-":
                return Ok[MirExpr](mirCast(mirTypeF64(), mirCall("cheng_f64_sub_bits", args2)))
            if op == "*":
                return Ok[MirExpr](mirCast(mirTypeF64(), mirCall("cheng_f64_mul_bits", args2)))
            if op == "/":
                return Ok[MirExpr](mirCast(mirTypeF64(), mirCall("cheng_f64_div_bits", args2)))
            if op == "<":
                return Ok[MirExpr](mirCall("cheng_f64_lt_bits", args2))
            if op == "<=":
                return Ok[MirExpr](mirCall("cheng_f64_le_bits", args2))
            if op == ">":
                return Ok[MirExpr](mirCall("cheng_f64_gt_bits", args2))
            if op == ">=":
                return Ok[MirExpr](mirCall("cheng_f64_ge_bits", args2))
            let lineF: str = intToStr(node.pos.line)
            let colF: str = intToStr(node.pos.col)
            return Err[MirExpr]("mir_builder: unsupported float infix op '" + op + "' @" + lineF + ":" + colF)
        let lhsRes: Result[MirExpr] = lowerExprValue(b, lhsNode, wantType)
        if ! IsOk[MirExpr](lhsRes):
            return lhsRes
        let rhsRes: Result[MirExpr] = lowerExprValue(b, rhsNode, wantType)
        if ! IsOk[MirExpr](rhsRes):
            return rhsRes
        let lhs: MirExpr = Value[MirExpr](lhsRes)
        let rhs: MirExpr = Value[MirExpr](rhsRes)
        if op == "+":
            return Ok[MirExpr](mirBin(mbAdd, lhs, rhs))
        if op == "-":
            return Ok[MirExpr](mirBin(mbSub, lhs, rhs))
        if op == "*":
            return Ok[MirExpr](mirBin(mbMul, lhs, rhs))
        if op == "/":
            return Ok[MirExpr](mirBin(mbSdiv, lhs, rhs))
        if op == "%":
            return Ok[MirExpr](mirBin(mbSmod, lhs, rhs))
        if op == "&":
            return Ok[MirExpr](mirBin(mbAnd, lhs, rhs))
        if op == "|":
            return Ok[MirExpr](mirBin(mbOr, lhs, rhs))
        if op == "^":
            return Ok[MirExpr](mirBin(mbXor, lhs, rhs))
        if op == "<<":
            return Ok[MirExpr](mirBin(mbShl, lhs, rhs))
        if op == ">>":
            return Ok[MirExpr](mirBin(mbShr, lhs, rhs))
        if op == "==":
            return Ok[MirExpr](mirCmp(mcEq, lhs, rhs))
        if op == "!=":
            return Ok[MirExpr](mirCmp(mcNe, lhs, rhs))
        if op == "<":
            return Ok[MirExpr](mirCmp(mcLt, lhs, rhs))
        if op == "<=":
            return Ok[MirExpr](mirCmp(mcLe, lhs, rhs))
        if op == ">":
            return Ok[MirExpr](mirCmp(mcGt, lhs, rhs))
        if op == ">=":
            return Ok[MirExpr](mirCmp(mcGe, lhs, rhs))
        var fnName: str = ""
        var fp: str = ""
        if b != nil && b.func != nil:
            let f2: MirFunc = b.func
            fnName = f2.name
            fp = f2.originFile
        let line: str = intToStr(node.pos.line)
        let col: str = intToStr(node.pos.col)
        return Err[MirExpr]("mir_builder: unsupported infix op '" + op + "' (fn=" + fnName +
                            " " + fp + ":" + line + ":" + col + ")")
    var fnName2: str = ""
    var fp2: str = ""
    if b != nil && b.func != nil:
        let f2: MirFunc = b.func
        fnName2 = f2.name
        fp2 = f2.originFile
    let k2: str = intToStr(int32(node.kind))
    let line2: str = intToStr(node.pos.line)
    let col2: str = intToStr(node.pos.col)
    return Err[MirExpr]("mir_builder: unsupported expr kind (nk#" + k2 +
                        " fn=" + fnName2 + " " + fp2 + ":" + line2 + ":" + col2 + ")")

fn mirBuildExpr(env: LocalEnv, n: Node): Result[MirExpr] =
    if n == nil:
        return Err[MirExpr]("mir_builder: nil expr")
    if n.kind == nkCallArg:
        if kidCount(n) > 0:
            return mirBuildExpr(env, kid(n, kidCount(n) - 1))
        return Err[MirExpr]("mir_builder: invalid call arg expr")
    if n.kind == nkIntLit:
        return Ok[MirExpr](mirConstI64(n.intVal))
    if n.kind == nkFloatLit:
        if n.strVal != nil && len(n.strVal) > 0:
            return Ok[MirExpr](mirConstI64(cheng_parse_f64_bits(n.strVal)))
        return Ok[MirExpr](mirConstI64(0))
    if n.kind == nkBoolLit:
        let name: str = backendStripSpaces(n.ident)
        if name == "true":
            return Ok[MirExpr](mirConstI64(1))
        return Ok[MirExpr](mirConstI64(0))
    if n.kind == nkCharLit:
        if n.strVal != nil && len(n.strVal) > 0:
            let c: char = n.strVal[0]
            return Ok[MirExpr](mirConstI64(int64(c)))
        return Ok[MirExpr](mirConstI64(0))
    if n.kind == nkNilLit:
        return Ok[MirExpr](mirConstI64(0))
    if n.kind == nkIdent || n.kind == nkSymbol:
        let nm: str = plainName(n)
        let idx: int32 = localIndex(env, nm)
        if idx < 0:
            return Err[MirExpr]("mir_builder: unknown local")
        return Ok[MirExpr](mirLocal(idx))
    if n.kind == nkPar && kidCount(n) > 0:
        return mirBuildExpr(env, kid(n, 0))
    if n.kind == nkCall && kidCount(n) > 0:
        let calleeNode: Node = kid(n, 0)
        if calleeNode == nil ||(calleeNode.kind != nkIdent && calleeNode.kind != nkSymbol):
            return Err[MirExpr]("mir_builder: call expects identifier callee")
        let name: str = backendStripSpaces(plainName(calleeNode))
        if kidCount(n) == 2 &&
           (name == "int64" || name == "i64" || name == "uint64" || name == "u64" ||
            name == "int32" || name == "i32" || name == "uint32" || name == "u32" ||
            name == "int" || name == "uint" || name == "NI" || name == "NU"):
            let argNode0: Node = kid(n, 1)
            var castArg: Node = argNode0
            if argNode0 != nil && argNode0.kind == nkCallArg && kidCount(argNode0) > 1:
                castArg = kid(argNode0, 1)
            let castRes: Result[MirExpr] = mirBuildExpr(env, castArg)
            if ! IsOk[MirExpr](castRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](castRes))
            let castType: MirType = mirTypeFromNodeWithModule(nil, calleeNode)
            return Ok[MirExpr](mirCast(castType, Value[MirExpr](castRes)))
        var args: MirExpr[]
        for ai in 1..<kidCount(n):
            var argNode: Node = kid(n, ai)
            if argNode != nil && argNode.kind == nkCallArg && kidCount(argNode) > 1:
                argNode = kid(argNode, 1)
            let argRes: Result[MirExpr] = mirBuildExpr(env, argNode)
            if ! IsOk[MirExpr](argRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](argRes))
            add(args, Value[MirExpr](argRes))
        return Ok[MirExpr](mirCall(name, args))
    if n.kind == nkPrefix && kidCount(n) > 1:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        let rhs: Node = kid(n, 1)
        if op == "-":
            let rhsRes: Result[MirExpr] = mirBuildExpr(env, rhs)
            if ! IsOk[MirExpr](rhsRes):
                return rhsRes
            let zero: MirExpr = mirConstI64(0)
            return Ok[MirExpr](mirBin(mbSub, zero, Value[MirExpr](rhsRes)))
        if op == "+":
            return mirBuildExpr(env, rhs)
        if op == "~":
            let rhsRes2: Result[MirExpr] = mirBuildExpr(env, rhs)
            if ! IsOk[MirExpr](rhsRes2):
                return rhsRes2
            let allBits: MirExpr = mirConstI64(-1)
            return Ok[MirExpr](mirBin(mbXor, Value[MirExpr](rhsRes2), allBits))
        if op == "!":
            let rhsRes3: Result[MirExpr] = mirBuildExpr(env, rhs)
            if ! IsOk[MirExpr](rhsRes3):
                return rhsRes3
            let zero2: MirExpr = mirConstI64(0)
            return Ok[MirExpr](mirCmp(mcEq, Value[MirExpr](rhsRes3), zero2))
    if n.kind == nkInfix && kidCount(n) >= 3:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        let lhsNode: Node = kid(n, 1)
        let rhsNode: Node = kid(n, 2)
        let lhsRes: Result[MirExpr] = mirBuildExpr(env, lhsNode)
        if ! IsOk[MirExpr](lhsRes):
            return lhsRes
        let rhsRes: Result[MirExpr] = mirBuildExpr(env, rhsNode)
        if ! IsOk[MirExpr](rhsRes):
            return rhsRes
        let lhs: MirExpr = Value[MirExpr](lhsRes)
        let rhs: MirExpr = Value[MirExpr](rhsRes)
        if op == "+":
            return Ok[MirExpr](mirBin(mbAdd, lhs, rhs))
        if op == "-":
            return Ok[MirExpr](mirBin(mbSub, lhs, rhs))
        if op == "*":
            return Ok[MirExpr](mirBin(mbMul, lhs, rhs))
        if op == "/":
            return Ok[MirExpr](mirBin(mbSdiv, lhs, rhs))
        if op == "%":
            return Ok[MirExpr](mirBin(mbSmod, lhs, rhs))
        if op == "&":
            return Ok[MirExpr](mirBin(mbAnd, lhs, rhs))
        if op == "|":
            return Ok[MirExpr](mirBin(mbOr, lhs, rhs))
        if op == "^":
            return Ok[MirExpr](mirBin(mbXor, lhs, rhs))
        if op == "<<":
            return Ok[MirExpr](mirBin(mbShl, lhs, rhs))
        if op == ">>":
            return Ok[MirExpr](mirBin(mbShr, lhs, rhs))
        if op == "&&":
            let lhsNz: MirExpr = mirCmp(mcNe, lhs, mirConstI64(0))
            let rhsNz: MirExpr = mirCmp(mcNe, rhs, mirConstI64(0))
            return Ok[MirExpr](mirBin(mbAnd, lhsNz, rhsNz))
        if op == "||":
            let lhsNz2: MirExpr = mirCmp(mcNe, lhs, mirConstI64(0))
            let rhsNz2: MirExpr = mirCmp(mcNe, rhs, mirConstI64(0))
            return Ok[MirExpr](mirBin(mbOr, lhsNz2, rhsNz2))
        if op == "==":
            return Ok[MirExpr](mirCmp(mcEq, lhs, rhs))
        if op == "!=":
            return Ok[MirExpr](mirCmp(mcNe, lhs, rhs))
        if op == "<":
            return Ok[MirExpr](mirCmp(mcLt, lhs, rhs))
        if op == "<=":
            return Ok[MirExpr](mirCmp(mcLe, lhs, rhs))
        if op == ">":
            return Ok[MirExpr](mirCmp(mcGt, lhs, rhs))
        if op == ">=":
            return Ok[MirExpr](mirCmp(mcGe, lhs, rhs))
        let line4: str = intToStr(n.pos.line)
        let col4: str = intToStr(n.pos.col)
        return Err[MirExpr]("mir_builder: unsupported infix op '" + op + "' @" + line4 + ":" + col4)
    let k3: str = intToStr(int32(n.kind))
    let line3: str = intToStr(n.pos.line)
    let col3: str = intToStr(n.pos.col)
    return Err[MirExpr]("mir_builder: unsupported expr kind (nk#" + k3 + " @" + line3 + ":" + col3 + ")")

fn mirExprFromIfBranch(b: BlockBuilder, n: Node, wantType: MirType): Result[MirExpr] =
    if n == nil:
        return Err[MirExpr]("mir_builder: nil if branch")
    if n.kind == nkStmtList:
        if kidCount(n) != 1:
            return Err[MirExpr]("mir_builder: if expr branch expects single expr")
        return lowerExprValue(b, kid(n, 0), wantType)
    return lowerExprValue(b, n, wantType)

fn lowerIfAssign(b: BlockBuilder, ifNode: Node, name: str, slot: int32): Result[bool] =
    if ifNode == nil || ifNode.kind != nkIf:
        return Err[bool]("mir_builder: invalid if expr")
    let total: int32 = kidCount(ifNode)
    if total < 3:
        return Err[bool]("mir_builder: if expr expects condition and else")
    let hasElse: bool = (total % 2) == 1
    if ! hasElse:
        return Err[bool]("mir_builder: if expr requires else")
    let slotType: MirType = localType(b.env, slot)
    let condCount: int32 = (total - 1) / 2
    let joinLabel: str = blockBuilderNextLabel(b, "if_join")
    var elseLabel: str = ""
    for ci in 0..<condCount:
        let condNode: Node = kid(ifNode, ci * 2)
        let thenNode: Node = kid(ifNode, ci * 2 + 1)
        let thenLabel: str = blockBuilderNextLabel(b, "if_then")
        let isLast: bool = ci == condCount - 1
        var falseLabel: str = ""
        var nextCondLabel: str = ""
        if isLast:
            elseLabel = blockBuilderNextLabel(b, "if_else")
            falseLabel = elseLabel
        else:
            nextCondLabel = blockBuilderNextLabel(b, "if_cond")
            falseLabel = nextCondLabel
        let condRes: Result[bool] = lowerCondBranch(b, condNode, thenLabel, falseLabel)
        if ! IsOk[bool](condRes):
            return ErrInfo[bool](ErrorInfoOf[bool](condRes))
        blockBuilderStart(b, thenLabel)
        let thenRes: Result[MirExpr] = mirExprFromIfBranch(b, thenNode, slotType)
        if ! IsOk[MirExpr](thenRes):
            return ErrInfo[bool](ErrorInfoOf[MirExpr](thenRes))
        add(b.currentStmts, mirStmtAssign(name, slot, Value[MirExpr](thenRes)))
        blockBuilderFinish(b, mirTermBr(joinLabel))
        if ! isLast:
            blockBuilderStart(b, nextCondLabel)
    let elseNode: Node = kid(ifNode, total - 1)
    blockBuilderStart(b, elseLabel)
    let elseRes: Result[MirExpr] = mirExprFromIfBranch(b, elseNode, slotType)
    if ! IsOk[MirExpr](elseRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](elseRes))
    add(b.currentStmts, mirStmtAssign(name, slot, Value[MirExpr](elseRes)))
    blockBuilderFinish(b, mirTermBr(joinLabel))
    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn lowerIfAssignObjValue(b: BlockBuilder, ifNode: Node, name: str, slot: int32): Result[bool] =
    if ifNode == nil || ifNode.kind != nkIf:
        return Err[bool]("mir_builder: invalid if expr")
    let total: int32 = kidCount(ifNode)
    if total < 3:
        return Err[bool]("mir_builder: if expr expects condition and else")
    let hasElse: bool = (total % 2) == 1
    if ! hasElse:
        return Err[bool]("mir_builder: if expr requires else")
    let condCount: int32 = (total - 1) / 2
    let joinLabel: str = blockBuilderNextLabel(b, "if_join")
    var elseLabel: str = ""
    for ci in 0..<condCount:
        let condNode: Node = kid(ifNode, ci * 2)
        var thenExpr: Node = kid(ifNode, ci * 2 + 1)
        if thenExpr != nil && thenExpr.kind == nkStmtList:
            if kidCount(thenExpr) != 1:
                return Err[bool]("mir_builder: if expr branch expects single expr")
            thenExpr = kid(thenExpr, 0)
        let thenLabel: str = blockBuilderNextLabel(b, "if_then")
        let isLast: bool = ci == condCount - 1
        var falseLabel: str = ""
        var nextCondLabel: str = ""
        if isLast:
            elseLabel = blockBuilderNextLabel(b, "if_else")
            falseLabel = elseLabel
        else:
            nextCondLabel = blockBuilderNextLabel(b, "if_cond")
            falseLabel = nextCondLabel
        let condRes: Result[bool] = lowerCondBranch(b, condNode, thenLabel, falseLabel)
        if ! IsOk[bool](condRes):
            return ErrInfo[bool](ErrorInfoOf[bool](condRes))
        blockBuilderStart(b, thenLabel)
        let thenAssignRes: Result[bool] = lowerAssignValue(b, thenExpr, name, slot)
        if !IsOk[bool](thenAssignRes):
            return ErrInfo[bool](ErrorInfoOf[bool](thenAssignRes))
        blockBuilderFinish(b, mirTermBr(joinLabel))
        if ! isLast:
            blockBuilderStart(b, nextCondLabel)
    var elseExpr: Node = kid(ifNode, total - 1)
    if elseExpr != nil && elseExpr.kind == nkStmtList:
        if kidCount(elseExpr) != 1:
            return Err[bool]("mir_builder: if expr branch expects single expr")
        elseExpr = kid(elseExpr, 0)
    blockBuilderStart(b, elseLabel)
    let elseAssignRes: Result[bool] = lowerAssignValue(b, elseExpr, name, slot)
    if !IsOk[bool](elseAssignRes):
        return ErrInfo[bool](ErrorInfoOf[bool](elseAssignRes))
    blockBuilderFinish(b, mirTermBr(joinLabel))
    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn lowerIfStmt(b: BlockBuilder, ifNode: Node): Result[bool] =
    if ifNode == nil || ifNode.kind != nkIf:
        return Err[bool]("mir_builder: invalid if stmt")
    let total: int32 = kidCount(ifNode)
    if total < 2:
        return Err[bool]("mir_builder: if expects branches")
    let hasElse: bool = (total % 2) == 1
    let condCount: int32 = total / 2
    let joinLabel: str = blockBuilderNextLabel(b, "if_join")
    var needsJoin: bool = false
    var allTerminated: bool = true
    var elseLabel: str = ""
    for ci in 0..<condCount:
        let condNode: Node = kid(ifNode, ci * 2)
        var thenNode: Node = kid(ifNode, ci * 2 + 1)
        if thenNode != nil && thenNode.kind != nkStmtList:
            var wrap: Node = newNode(nkStmtList, thenNode.pos)
            addSon(wrap, thenNode)
            thenNode = wrap
        if thenNode == nil || thenNode.kind != nkStmtList:
            return Err[bool]("mir_builder: if stmt expects stmt list")
        let thenLabel: str = blockBuilderNextLabel(b, "if_then")
        let isLast: bool = ci == condCount - 1
        var falseLabel: str = ""
        var nextCondLabel: str = ""
        if isLast:
            if hasElse:
                elseLabel = blockBuilderNextLabel(b, "if_else")
                falseLabel = elseLabel
            else:
                falseLabel = joinLabel
                needsJoin = true
                allTerminated = false
        else:
            nextCondLabel = blockBuilderNextLabel(b, "if_cond")
            falseLabel = nextCondLabel
        let condRes: Result[bool] = lowerCondBranch(b, condNode, thenLabel, falseLabel)
        if ! IsOk[bool](condRes):
            return ErrInfo[bool](ErrorInfoOf[bool](condRes))
        blockBuilderStart(b, thenLabel)
        let thenTermRes: Result[bool] = lowerStmtList(b, thenNode)
        if ! IsOk[bool](thenTermRes):
            return ErrInfo[bool](ErrorInfoOf[bool](thenTermRes))
        let thenTerminated: bool = Value[bool](thenTermRes)
        if ! thenTerminated:
            allTerminated = false
            needsJoin = true
            blockBuilderFinish(b, mirTermBr(joinLabel))
        if ! isLast:
            blockBuilderStart(b, nextCondLabel)
    if hasElse:
        var elseNode: Node = kid(ifNode, total - 1)
        if elseNode != nil && elseNode.kind != nkStmtList:
            var wrap2: Node = newNode(nkStmtList, elseNode.pos)
            addSon(wrap2, elseNode)
            elseNode = wrap2
        if elseNode == nil || elseNode.kind != nkStmtList:
            return Err[bool]("mir_builder: if else expects stmt list")
        blockBuilderStart(b, elseLabel)
        let elseTermRes: Result[bool] = lowerStmtList(b, elseNode)
        if ! IsOk[bool](elseTermRes):
            return ErrInfo[bool](ErrorInfoOf[bool](elseTermRes))
        let elseTerminated: bool = Value[bool](elseTermRes)
        if ! elseTerminated:
            allTerminated = false
            needsJoin = true
            blockBuilderFinish(b, mirTermBr(joinLabel))
    if needsJoin:
        blockBuilderStart(b, joinLabel)
        return Ok[bool](false)
    if allTerminated:
        return Ok[bool](true)
    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn nodeIsTrueLiteral(n0: Node): bool =
    if n0 == nil:
        return false
    var n: Node = n0
    while n != nil && n.kind == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if n == nil:
        return false
    if n.kind == nkBoolLit:
        let v: str = backendStripSpaces(n.ident)
        return (v == "true")
    return false

fn nodeHasBreakAtLoopDepth(n: Node, loopDepth: int32): bool =
    if n == nil:
        return false
    if n.kind == nkBreak:
        return loopDepth == 0
    var childDepth: int32 = loopDepth
    if n.kind == nkWhile || n.kind == nkFor:
        childDepth = loopDepth + 1
    for i in 0..<kidCount(n):
        if nodeHasBreakAtLoopDepth(kid(n, i), childDepth):
            return true
    return false

fn lowerWhileStmt(b: BlockBuilder, whileNode: Node): Result[bool] =
    if whileNode == nil || whileNode.kind != nkWhile:
        return Err[bool]("mir_builder: invalid while")
    if kidCount(whileNode) < 2:
        return Err[bool]("mir_builder: while expects cond/body")
    let isInfinite: bool = nodeIsTrueLiteral(kid(whileNode, 0)) &&
                           ! nodeHasBreakAtLoopDepth(kid(whileNode, 1), 0)
    let condLabel: str = blockBuilderNextLabel(b, "while_cond")
    let bodyLabel: str = blockBuilderNextLabel(b, "while_body")
    let endLabel: str = blockBuilderNextLabel(b, "while_end")
    blockBuilderFinish(b, mirTermBr(condLabel))
    blockBuilderStart(b, condLabel)
    let condRes: Result[bool] = lowerCondBranch(b, kid(whileNode, 0), bodyLabel, endLabel)
    if ! IsOk[bool](condRes):
        return ErrInfo[bool](ErrorInfoOf[bool](condRes))
    blockBuilderStart(b, bodyLabel)
    blockBuilderPushLoop(b, endLabel, condLabel)
    let bodyNode: Node = kid(whileNode, 1)
    if bodyNode == nil || bodyNode.kind != nkStmtList:
        return Err[bool]("mir_builder: while expects stmt list body")
    if (getEnv "CHENG_BACKEND_DEBUG_SCOPE" == "1") && b != nil && b.func != nil:
        let fDbg: MirFunc = b.func
        if (fDbg.name == "verifyLockAgainstRegistry"):
            echo("[backend] debugWhileBody: fn=" + fDbg.name + " kids=" + intToStr(kidCount(bodyNode)) +
                 " @" + intToStr(bodyNode.pos.line) + ":" + intToStr(bodyNode.pos.col))
            for di in 0..<kidCount(bodyNode):
                let st: Node = kid(bodyNode, di)
                let sk: str = (st != nil) ? intToStr(int32(st.kind)) : "nil"
                let sl: str = (st != nil) ? intToStr(st.pos.line) : "0"
                let sc: str = (st != nil) ? intToStr(st.pos.col) : "0"
                var sn: str = ""
                if st != nil && (st.kind == nkLet || st.kind == nkVar) && kidCount(st) > 0:
                    sn = plainName(kid(st, 0))
                echo("[backend] debugWhileStmt: i=" + intToStr(di) + " kind=nk#" + sk + " @" + sl + ":" + sc + " name=" + sn)
    let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
    blockBuilderPopLoop(b)
    if ! IsOk[bool](bodyTermRes):
        return ErrInfo[bool](ErrorInfoOf[bool](bodyTermRes))
    let bodyTerminated: bool = Value[bool](bodyTermRes)
    if ! bodyTerminated:
        blockBuilderFinish(b, mirTermBr(condLabel))
    if isInfinite:
        # Ensure the unused false-branch label exists for CFG integrity.
        blockBuilderStart(b, endLabel)
        blockBuilderFinish(b, mirTermBr(endLabel))
        return Ok[bool](true)
    blockBuilderStart(b, endLabel)
    return Ok[bool](false)

fn lowerCondBranch(b: BlockBuilder, condNode: Node, tLabel: str, fLabel: str): Result[bool] =
    if condNode == nil:
        return Err[bool]("mir_builder: nil cond")
    var node: Node = condNode
    while node != nil && node.kind == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if node != nil && node.kind == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        if op == "&&" || op == "||":
            let lhsNode: Node = kid(node, 1)
            let rhsNode: Node = kid(node, 2)
            let lhsRes: Result[MirExpr] = lowerExprValue(b, lhsNode, mirTypeI32())
            if ! IsOk[MirExpr](lhsRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](lhsRes))
            if op == "&&":
                let rhsLabel: str = blockBuilderNextLabel(b, "and_rhs")
                blockBuilderFinish(b, mirTermCbr(Value[MirExpr](lhsRes), rhsLabel, fLabel))
                blockBuilderStart(b, rhsLabel)
                let rhsRes: Result[MirExpr] = lowerExprValue(b, rhsNode, mirTypeI32())
                if ! IsOk[MirExpr](rhsRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](rhsRes))
                blockBuilderFinish(b, mirTermCbr(Value[MirExpr](rhsRes), tLabel, fLabel))
                return Ok[bool](true)
            else:
                let rhsLabel2: str = blockBuilderNextLabel(b, "or_rhs")
                blockBuilderFinish(b, mirTermCbr(Value[MirExpr](lhsRes), tLabel, rhsLabel2))
                blockBuilderStart(b, rhsLabel2)
                let rhsRes2: Result[MirExpr] = lowerExprValue(b, rhsNode, mirTypeI32())
                if ! IsOk[MirExpr](rhsRes2):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](rhsRes2))
                blockBuilderFinish(b, mirTermCbr(Value[MirExpr](rhsRes2), tLabel, fLabel))
                return Ok[bool](true)
    let condRes: Result[MirExpr] = lowerExprValue(b, node, mirTypeI32())
    if ! IsOk[MirExpr](condRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](condRes))
    blockBuilderFinish(b, mirTermCbr(Value[MirExpr](condRes), tLabel, fLabel))
    return Ok[bool](true)

fn lowerBoolAssign(b: BlockBuilder, exprNode: Node, name: str, slot: int32): Result[bool] =
    let trueLabel: str = blockBuilderNextLabel(b, "bool_true")
    let falseLabel: str = blockBuilderNextLabel(b, "bool_false")
    let joinLabel: str = blockBuilderNextLabel(b, "bool_join")
    let condRes: Result[bool] = lowerCondBranch(b, exprNode, trueLabel, falseLabel)
    if ! IsOk[bool](condRes):
        return ErrInfo[bool](ErrorInfoOf[bool](condRes))
    blockBuilderStart(b, trueLabel)
    add(b.currentStmts, mirStmtAssign(name, slot, mirConstI64(1)))
    blockBuilderFinish(b, mirTermBr(joinLabel))
    blockBuilderStart(b, falseLabel)
    add(b.currentStmts, mirStmtAssign(name, slot, mirConstI64(0)))
    blockBuilderFinish(b, mirTermBr(joinLabel))
    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn lowerAssignValue(b: BlockBuilder, exprNode: Node, name: str, slot: int32): Result[bool] =
    let objLocalIdx: int32 = funcFindObjLocal(b.func, slot)
    if objLocalIdx >= 0:
        let fref: MirFunc = b.func
        let dstOl: MirObjLocal = fref.objLocals[objLocalIdx]
        let objTypeName: str = dstOl.objTypeName
        let dstPtr: MirExpr = mirLocal(slot)
        let aliasTy: MirType = mirTryGetTypeAlias(b.module, objTypeName)
        if (getEnv "CHENG_BACKEND_DEBUG_ALIAS" == "1") && (objTypeName == "Node"):
            let mTmp: MirModule = b.module
            echo("[backend] debug: alias Node kind=" + intToStr(int32(aliasTy.kind)) +
                 " aliases=" + intToStr(mTmp.typeAliases.len) +
                 " objs=" + intToStr(mTmp.objTypes.len))
        if aliasTy.kind != mtVoid:
            if exprNode == nil || exprNode.kind == nkEmpty:
                add(b.currentStmts, mirStmtAssign(name, slot, mirConstI64(0)))
                return Ok[bool](false)
            let rhsRes: Result[MirExpr] = lowerExprValue(b, exprNode, aliasTy)
            if ! IsOk[MirExpr](rhsRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](rhsRes))
            add(b.currentStmts, mirStmtAssign(name, slot, Value[MirExpr](rhsRes)))
            return Ok[bool](false)
        if dstOl.frameOff < 0:
            # Pointer-like locals (e.g. `T*`, `ref T`) are tracked as objLocals for layout info,
            # but they do not own object storage. Assign them like scalar pointer slots.
            let slotKeyPtr: str = localTypeKey(b.env, slot)
            if slotKeyPtr != nil && len(slotKeyPtr) > 0 && mirStrStartsWith(slotKeyPtr, "var_") &&
               !mirStrStartsWith(slotKeyPtr, "var_ref_"):
                let dstPtrVar: MirExpr = mirLocal(slot)
                if exprNode == nil || exprNode.kind == nkEmpty:
                    let initVarRes: Result[bool] = emitObjDefaultInitPtrs(b, dstPtrVar, objTypeName)
                    if !IsOk[bool](initVarRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](initVarRes))
                    return Ok[bool](false)
                var nodeVarPtr: Node = exprNode
                while nodeVarPtr != nil && nodeVarPtr.kind == nkPar && kidCount(nodeVarPtr) > 0:
                    nodeVarPtr = kid(nodeVarPtr, 0)
                if nodeVarPtr != nil && nodeVarPtr.kind == nkCall:
                    let callVarRes: Result[MirExpr] = lowerCallWithLeadingArg(b, nodeVarPtr, dstPtrVar)
                    if !IsOk[MirExpr](callVarRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](callVarRes))
                    return Ok[bool](false)
                let srcVarPtrRes: Result[MirExpr] = lowerExprValue(b, exprNode, mirTypeI64())
                if !IsOk[MirExpr](srcVarPtrRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](srcVarPtrRes))
                let copyVarPtrRes: Result[bool] = emitObjCopyPtrs(b, dstPtrVar, objTypeName, Value[MirExpr](srcVarPtrRes))
                if !IsOk[bool](copyVarPtrRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](copyVarPtrRes))
                return Ok[bool](false)
            if exprNode == nil || exprNode.kind == nkEmpty:
                add(b.currentStmts, mirStmtAssign(name, slot, mirConstI64(0)))
                return Ok[bool](false)
            var node2: Node = exprNode
            while node2 != nil && node2.kind == nkPar && kidCount(node2) > 0:
                node2 = kid(node2, 0)
            if node2 != nil && node2.kind == nkCase:
                let caseRes: Result[bool] = lowerCaseAssign(b, node2, name, slot)
                if !IsOk[bool](caseRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](caseRes))
                return caseRes
            if node2 != nil && node2.kind == nkIf:
                let ifRes: Result[bool] = lowerIfAssign(b, node2, name, slot)
                if ! IsOk[bool](ifRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](ifRes))
                return Ok[bool](false)
            if node2 != nil && node2.kind == nkInfix && kidCount(node2) >= 3:
                let opNode: Node = kid(node2, 0)
                let op: str = backendOpName(opNode)
                if op == "&&" || op == "||":
                    let boolRes: Result[bool] = lowerBoolAssign(b, node2, name, slot)
                    if ! IsOk[bool](boolRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](boolRes))
                    return Ok[bool](false)
            let slotType0: MirType = localType(b.env, slot)
            let rhsRes0: Result[MirExpr] = lowerExprValue(b, exprNode, slotType0)
            if ! IsOk[MirExpr](rhsRes0):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](rhsRes0))
            add(b.currentStmts, mirStmtAssign(name, slot, Value[MirExpr](rhsRes0)))
            return Ok[bool](false)
        if exprNode == nil || exprNode.kind == nkEmpty:
            let initRes: Result[bool] = emitObjDefaultInitPtrs(b, dstPtr, objTypeName)
            if ! IsOk[bool](initRes):
                return ErrInfo[bool](ErrorInfoOf[bool](initRes))
            return Ok[bool](false)
        var node: Node = exprNode
        while node != nil && node.kind == nkPar && kidCount(node) > 0:
            node = kid(node, 0)
        if node != nil && (node.kind == nkIdent || node.kind == nkSymbol):
            let srcName: str = plainName(node)
            let srcSlot: int32 = localIndex(b.env, srcName)
            if srcSlot >= 0:
                let srcObjLocalIdx: int32 = funcFindObjLocal(b.func, srcSlot)
                if srcObjLocalIdx >= 0:
                    let srcOl: MirObjLocal = fref.objLocals[srcObjLocalIdx]
                    let dstLayout: str = mirObjLayoutName(b.module, objTypeName)
                    let srcLayout: str = mirObjLayoutName(b.module, srcOl.objTypeName)
                    if ! (srcLayout == dstLayout):
                        let line: str = intToStr(node.pos.line)
                        let col: str = intToStr(node.pos.col)
                        return Err[bool]("mir_builder: object copy type mismatch dst=" + objTypeName +
                                         " src=" + srcOl.objTypeName +
                                         " (dstName=" + name + " srcName=" + srcName +
                                         " fn=" + fref.name + " " + fref.originFile + ":" + line + ":" + col + ")")
                    let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, mirLocal(srcSlot))
                    if ! IsOk[bool](copyRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](copyRes))
                    return Ok[bool](false)
            if srcSlot < 0:
                var gSym: str = srcName
                let mod0: MirModule = b.module
                var gi: int32 = moduleGlobalIndex(mod0, gSym)
                if gi < 0 && b.func != nil && mirDupGlobalNamesHas(srcName):
                    let f2: MirFunc = b.func
                    let g2: str = mirMaybeMangleDupGlobalName(srcName, f2.originFile)
                    if g2 != nil && len(g2) > 0:
                        gSym = g2
                        gi = moduleGlobalIndex(mod0, gSym)
                if gi < 0 && mirDupGlobalNamesHas(srcName):
                    let gi2: int32 = moduleFindGlobalIndexByBaseUnique(mod0, srcName)
                    if mod0 != nil && gi2 >= 0 && gi2 < mod0.globals.len:
                        let g2: MirGlobal = mod0.globals[gi2]
                        if g2.name != nil && len(g2.name) > 0:
                            gSym = g2.name
                            gi = gi2
                if gi >= 0:
                    let gObj: str = mirGlobalObjTypeGet(gSym)
                    if len(gObj) > 0:
                        if ! (gObj == objTypeName):
                            return Err[bool]("mir_builder: object copy global type mismatch")
                        let srcPtr: MirExpr = mirLoad(mirGlobalAddr(gSym), mirTypeI64())
                        let copyRes2: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, srcPtr)
                        if ! IsOk[bool](copyRes2):
                            return ErrInfo[bool](ErrorInfoOf[bool](copyRes2))
                        return Ok[bool](false)
        if node != nil && node.kind == nkCall:
            if node.typeCacheValid && node.typeCache != nil:
                let callObj: str = typeNodeObjTypeName(b.module, node.typeCache)
                if len(callObj) > 0 && ! (callObj == objTypeName):
                    return Err[bool]("mir_builder: object call return type mismatch")
            let callRes: Result[MirExpr] = lowerCallWithLeadingArg(b, node, dstPtr)
            if ! IsOk[MirExpr](callRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](callRes))
            return Ok[bool](false)
        if node != nil && node.kind == nkDotExpr:
            let srcRes: Result[MirExpr] = lowerExprValue(b, node, mirTypeI64())
            if !IsOk[MirExpr](srcRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
            let tmpName: str = "__obj_src"
            let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
            mirSetLocalType(b.func, tmpSlot, mirTypeI64())
            add(b.currentStmts, mirStmtLet(tmpName, tmpSlot, Value[MirExpr](srcRes)))
            let copyRes3: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, mirLocal(tmpSlot))
            if !IsOk[bool](copyRes3):
                return ErrInfo[bool](ErrorInfoOf[bool](copyRes3))
            return Ok[bool](false)
        if node != nil && node.kind == nkTupleLit:
            let litRes: Result[bool] = emitTupleLitToPtr(b, dstPtr, objTypeName, node)
            if ! IsOk[bool](litRes):
                return ErrInfo[bool](ErrorInfoOf[bool](litRes))
            return Ok[bool](false)
        if node != nil && node.kind == nkSeqLit && mirStrStartsWith(dstOl.typeKey, "seq_"):
            let key: str = dstOl.typeKey
            let litRes2: Result[bool] = emitSeqLitToPtr(b, dstPtr, key, node)
            if ! IsOk[bool](litRes2):
                return ErrInfo[bool](ErrorInfoOf[bool](litRes2))
            return Ok[bool](false)
        if node != nil && node.kind == nkComprehension && mirStrStartsWith(dstOl.typeKey, "seq_"):
            let key2: str = dstOl.typeKey
            let compRes: Result[bool] = emitSeqComprehensionToPtr(b, name, dstPtr, key2, node)
            if !IsOk[bool](compRes):
                return ErrInfo[bool](ErrorInfoOf[bool](compRes))
            return compRes
        if node != nil && node.kind == nkBracketExpr && kidCount(node) == 2 && mirStrStartsWith(dstOl.typeKey, "seq_"):
            var idx0: Node = kid(node, 1)
            while idx0 != nil && idx0.kind == nkPar && kidCount(idx0) > 0:
                idx0 = kid(idx0, 0)
            if idx0 != nil && idx0.kind == nkInfix && kidCount(idx0) >= 3:
                let opNode: Node = kid(idx0, 0)
                let op: str = backendOpName(opNode)
                if op == ".." || op == "..<":
                    let base0: Node = kid(node, 0)
                    var baseKey: str = ""
                    if base0 != nil && base0.typeCacheValid && base0.typeCache != nil:
                        baseKey = typeKey base0.typeCache
                    if len(baseKey) == 0 && base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol):
                        let nm: str = plainName(base0)
                        let slot0: int32 = localIndex(b.env, nm)
                        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                            baseKey = funcObjTypeKey(b.func, slot0)
                    if len(baseKey) > 0 && mirStrStartsWith(baseKey, "seq_") && !(baseKey == dstOl.typeKey):
                        return Err[bool]("mir_builder: seq slice type mismatch")

                    let baseRes: Result[MirExpr] = lowerExprValue(b, base0, mirTypeI64())
                    if !IsOk[MirExpr](baseRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](baseRes))
                    let startRes: Result[MirExpr] = lowerExprValue(b, kid(idx0, 1), mirTypeI64())
                    if !IsOk[MirExpr](startRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](startRes))
                    let stopRes: Result[MirExpr] = lowerExprValue(b, kid(idx0, 2), mirTypeI64())
                    if !IsOk[MirExpr](stopRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](stopRes))
                    let exclusive: MirExpr = (op == "..<") ? mirConstI64(1) : mirConstI64(0)
                    let start32: MirExpr = mirCast(mirTypeI32(), Value[MirExpr](startRes))
                    let stop32: MirExpr = mirCast(mirTypeI32(), Value[MirExpr](stopRes))

                    let elemKey: str = str(ptr_add(void*(dstOl.typeKey), 4))
                    let typeArg0: Node = newIdent(elemKey, node.pos)
                    var typeArgs2: Node[]
                    add(typeArgs2, typeArg0)
                    let callName2: str = mangleInstance("__cheng_slice_vec", typeArgs2)
                    var args2: MirExpr[]
                    add(args2, dstPtr)
                    add(args2, Value[MirExpr](baseRes))
                    add(args2, start32)
                    add(args2, stop32)
                    add(args2, exclusive)
                    add(b.currentStmts, mirStmtExpr(mirCall(callName2, args2)))
                    return Ok[bool](false)
        if node != nil && node.typeCacheValid && node.typeCache != nil:
            let rhsObj: str = typeNodeObjTypeName(b.module, node.typeCache)
            if len(rhsObj) > 0 && typeNodeIsObjValue(b.module, node.typeCache):
                if !(rhsObj == objTypeName):
                    return Err[bool]("mir_builder: object value assignment type mismatch")
                let srcRes: Result[MirExpr] = lowerExprValue(b, node, mirTypeI64())
                if !IsOk[MirExpr](srcRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
                let tmpName: str = "__obj_src"
                let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
                mirSetLocalType(b.func, tmpSlot, mirTypeI64())
                add(b.currentStmts, mirStmtLet(tmpName, tmpSlot, Value[MirExpr](srcRes)))
                let copyRes3: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, mirLocal(tmpSlot))
                if !IsOk[bool](copyRes3):
                    return ErrInfo[bool](ErrorInfoOf[bool](copyRes3))
                return Ok[bool](false)
        if node != nil && node.kind == nkBracketExpr && kidCount(node) == 2:
            let srcRes: Result[MirExpr] = lowerExprValue(b, node, mirTypeI64())
            if !IsOk[MirExpr](srcRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
            let tmpName: str = "__obj_src"
            let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
            mirSetLocalType(b.func, tmpSlot, mirTypeI64())
            add(b.currentStmts, mirStmtLet(tmpName, tmpSlot, Value[MirExpr](srcRes)))
            let copyRes3: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, mirLocal(tmpSlot))
            if !IsOk[bool](copyRes3):
                return ErrInfo[bool](ErrorInfoOf[bool](copyRes3))
            return Ok[bool](false)
        if node != nil && (node.kind == nkInfix || node.kind == nkPrefix || node.kind == nkPostfix):
            let srcRes4: Result[MirExpr] = lowerExprValue(b, node, mirTypeI64())
            if !IsOk[MirExpr](srcRes4):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes4))
            let tmpName4: str = "__obj_src"
            let tmpSlot4: int32 = localAdd(b.env, tmpName4, mirTypeI64())
            mirSetLocalType(b.func, tmpSlot4, mirTypeI64())
            add(b.currentStmts, mirStmtLet(tmpName4, tmpSlot4, Value[MirExpr](srcRes4)))
            let srcObjLocalIdx4: int32 = funcFindObjLocal(b.func, tmpSlot4)
            if srcObjLocalIdx4 >= 0:
                let srcOl4: MirObjLocal = fref.objLocals[srcObjLocalIdx4]
                let dstLayout4: str = mirObjLayoutName(b.module, objTypeName)
                let srcLayout4: str = mirObjLayoutName(b.module, srcOl4.objTypeName)
                if ! (srcLayout4 == dstLayout4):
                    return Err[bool]("mir_builder: object value assignment type mismatch")
                let copyRes4: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, mirLocal(tmpSlot4))
                if !IsOk[bool](copyRes4):
                    return ErrInfo[bool](ErrorInfoOf[bool](copyRes4))
                return Ok[bool](false)
        var fnName: str = ""
        var fp: str = ""
        if b != nil && b.func != nil:
            let f0: MirFunc = b.func
            fnName = f0.name
            fp = f0.originFile
        let line: str = (exprNode != nil) ? intToStr(exprNode.pos.line) : "0"
        let col: str = (exprNode != nil) ? intToStr(exprNode.pos.col) : "0"
        let k: str = (node != nil) ? intToStr(int32(node.kind)) : "0"
        var tcObj: str = ""
        var tcKind: str = "0"
        if node != nil && node.typeCacheValid && node.typeCache != nil:
            let tc0: Node = node.typeCache
            tcObj = typeNodeObjTypeName(b.module, tc0)
            tcKind = intToStr(int32(tc0.kind))
        return Err[bool]("mir_builder: object value assignment not supported: " + name +
                         " (obj=" + objTypeName + " rhsKind=nk#" + k +
                         " tcObj=" + tcObj + " tcKind=nk#" + tcKind +
                         " fn=" + fnName + " " + fp + ":" + line + ":" + col + ")")
    let slotKey0: str = localTypeKey(b.env, slot)
    if slotKey0 != nil && len(slotKey0) > 0 &&
       (mirStrStartsWith(slotKey0, "var_") || mirStrStartsWith(slotKey0, "var_ref_") || (slotKey0 == "var")):
        var baseKey0: str = slotKey0
        if mirStrStartsWith(baseKey0, "var_ref_"):
            baseKey0 = str(ptr_add(void*(baseKey0), 8))
        elif mirStrStartsWith(baseKey0, "var_"):
            baseKey0 = str(ptr_add(void*(baseKey0), 4))
        var storeThroughAddr: bool = true
        if baseKey0 != nil && len(baseKey0) > 0 && b.module != nil:
            if mirHasObjType(b.module, baseKey0):
                let aliasTy0: MirType = mirTryGetTypeAlias(b.module, baseKey0)
                storeThroughAddr = aliasTy0.kind != mtVoid
            elif mirStrStartsWith(baseKey0, "seq_") && mirHasObjType(b.module, "seq"):
                storeThroughAddr = false
        if storeThroughAddr:
            var storeTy0: MirType = mirTypeI64()
            if baseKey0 != nil && len(baseKey0) > 0:
                if mirStrStartsWith(baseKey0, "ptr_") || mirStrStartsWith(baseKey0, "ref_") ||
                   mirStrStartsWith(baseKey0, "var_") || mirStrStartsWith(baseKey0, "var_ref_") ||
                   (baseKey0 == "ptr") || (baseKey0 == "ref") || (baseKey0 == "var"):
                    storeTy0 = mirTypeI64()
                else:
                    storeTy0 = mirTypeFromTypeKeyName(baseKey0)
                    if storeTy0.kind == mtVoid:
                        storeTy0 = mirTypeI64()
            if exprNode == nil || exprNode.kind == nkEmpty:
                add(b.currentStmts, mirStmtStore(mirLocal(slot), mirConstI64(0), storeTy0))
                return Ok[bool](false)
            let rhsVarRes: Result[MirExpr] = lowerExprValue(b, exprNode, storeTy0)
            if !IsOk[MirExpr](rhsVarRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](rhsVarRes))
            add(b.currentStmts, mirStmtStore(mirLocal(slot), Value[MirExpr](rhsVarRes), storeTy0))
            return Ok[bool](false)
        # Object-value `var` assignment must write through the pointed storage.
        # Rebinding the local pointer slot drops the caller-visible update.
        var dstObjType: str = ""
        if baseKey0 != nil && len(baseKey0) > 0 && b.module != nil:
            dstObjType = mirObjTypeFromTypeKey(b.module, baseKey0)
            if (dstObjType == nil || len(dstObjType) == 0) &&
               (baseKey0 == "seq" || mirStrStartsWith(baseKey0, "seq_") || mirStrStartsWith(baseKey0, "seq_fixed_")) &&
               mirHasObjType(b.module, "seq"):
                dstObjType = "seq"
            if (dstObjType == nil || len(dstObjType) == 0) &&
               (baseKey0 == "Table" || mirStrStartsWith(baseKey0, "Table_")) &&
               mirHasObjType(b.module, "Table"):
                dstObjType = "Table"
        if dstObjType != nil && len(dstObjType) > 0:
            let dstPtr0: MirExpr = mirLocal(slot)
            if exprNode == nil || exprNode.kind == nkEmpty:
                let initRes0: Result[bool] = emitObjDefaultInitPtrs(b, dstPtr0, dstObjType)
                if !IsOk[bool](initRes0):
                    return ErrInfo[bool](ErrorInfoOf[bool](initRes0))
                return Ok[bool](false)
            var nodeVar0: Node = exprNode
            while nodeVar0 != nil && nodeVar0.kind == nkPar && kidCount(nodeVar0) > 0:
                nodeVar0 = kid(nodeVar0, 0)
            if nodeVar0 != nil && nodeVar0.kind == nkCall:
                let callRes0: Result[MirExpr] = lowerCallWithLeadingArg(b, nodeVar0, dstPtr0)
                if !IsOk[MirExpr](callRes0):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](callRes0))
                return Ok[bool](false)
            let srcVarRes: Result[MirExpr] = lowerExprValue(b, exprNode, mirTypeI64())
            if !IsOk[MirExpr](srcVarRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](srcVarRes))
            let copyVarRes: Result[bool] = emitObjCopyPtrs(b, dstPtr0, dstObjType, Value[MirExpr](srcVarRes))
            if !IsOk[bool](copyVarRes):
                return ErrInfo[bool](ErrorInfoOf[bool](copyVarRes))
            return Ok[bool](false)
    if exprNode == nil || exprNode.kind == nkEmpty:
        add(b.currentStmts, mirStmtAssign(name, slot, mirConstI64(0)))
        return Ok[bool](false)
    var node: Node = exprNode
    while node != nil && node.kind == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if node != nil && node.kind == nkCase:
        let caseRes: Result[bool] = lowerCaseAssign(b, node, name, slot)
        if !IsOk[bool](caseRes):
            return ErrInfo[bool](ErrorInfoOf[bool](caseRes))
        return caseRes
    if node != nil && node.kind == nkIf:
        let ifRes: Result[bool] = lowerIfAssign(b, node, name, slot)
        if ! IsOk[bool](ifRes):
            return ErrInfo[bool](ErrorInfoOf[bool](ifRes))
        return Ok[bool](false)
    if node != nil && node.kind == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        if op == "&&" || op == "||":
            let boolRes: Result[bool] = lowerBoolAssign(b, node, name, slot)
            if ! IsOk[bool](boolRes):
                return ErrInfo[bool](ErrorInfoOf[bool](boolRes))
            return Ok[bool](false)
    let slotType: MirType = localType(b.env, slot)
    let rhsRes: Result[MirExpr] = lowerExprValue(b, exprNode, slotType)
    if ! IsOk[MirExpr](rhsRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](rhsRes))
    add(b.currentStmts, mirStmtAssign(name, slot, Value[MirExpr](rhsRes)))
    return Ok[bool](false)

fn lowerForStmt(b: BlockBuilder, forNode: Node): Result[bool] =
    if forNode == nil || forNode.kind != nkFor:
        return Err[bool]("mir_builder: invalid for")
    if kidCount(forNode) < 3:
        return Err[bool]("mir_builder: for expects pattern/iter/body")
    let iterExpr: Node = kid(forNode, 1)
    let bodyRaw: Node = kid(forNode, 2)

    # Parse patterns:
    # - Single: `for v in xs:`
    # - Tuple: `for i, v in xs:` (parser represents it as nkTupleLit of patterns)
    var patNames: str[2]
    var patTypes: Node[2]
    let patNode: Node = kid(forNode, 0)
    if patNode != nil && patNode.kind == nkTupleLit:
        for pi in 0..<kidCount(patNode):
            let p: Node = kid(patNode, pi)
            var nameNode: Node = p
            var typeNode: Node = nil
            if p != nil && p.kind == nkPattern && kidCount(p) > 0:
                nameNode = kid(p, 0)
                if kidCount(p) > 1:
                    typeNode = kid(p, 1)
            if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
                return Err[bool]("mir_builder: for expects identifier patterns")
            add(patNames, plainName(nameNode))
            add(patTypes, typeNode)
    else:
        var nameNode: Node = patNode
        var typeNode: Node = nil
        if patNode != nil && patNode.kind == nkPattern && kidCount(patNode) > 0:
            nameNode = kid(patNode, 0)
            if kidCount(patNode) > 1:
                typeNode = kid(patNode, 1)
        if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
            return Err[bool]("mir_builder: for expects identifier pattern")
        add(patNames, plainName(nameNode))
        add(patTypes, typeNode)
    if patNames.len <= 0:
        return Err[bool]("mir_builder: for expects pattern")
    if patNames.len > 2:
        return Err[bool]("mir_builder: for supports up to 2 patterns")

    var bodyNode: Node = bodyRaw
    if bodyNode != nil && bodyNode.kind != nkStmtList:
        var wrapBody: Node = newNode(nkStmtList, bodyNode.pos)
        addSon(wrapBody, bodyNode)
        bodyNode = wrapBody
    if bodyNode == nil || bodyNode.kind != nkStmtList:
        return Err[bool]("mir_builder: for expects stmt list body")

    # 1) Range loops: `for i in a..b` / `a..<b`
    if iterExpr != nil && iterExpr.kind == nkInfix && kidCount(iterExpr) >= 3:
        let opNode: Node = kid(iterExpr, 0)
        let op: str = backendOpName(opNode)
        if op == ".." || op == "..<":
            if patNames.len != 1:
                return Err[bool]("mir_builder: range for expects single pattern")
            let varName: str = patNames[0]
            let varTypeNode: Node = patTypes[0]
            let varType: MirType = mirTypeFromNodeWithModule(b.module, varTypeNode)
            let slot: int32 = localAdd(b.env, varName, varType)
            mirSetLocalType(b.func, slot, varType)

            let startNode: Node = kid(iterExpr, 1)
            let endNode: Node = kid(iterExpr, 2)
            let startRes: Result[MirExpr] = lowerExprValue(b, startNode, varType)
            if ! IsOk[MirExpr](startRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](startRes))
            add(b.currentStmts, mirStmtVar(varName, slot, Value[MirExpr](startRes)))

            let endName: str = blockBuilderNextTemp(b, "__for_end")
            let endSlot: int32 = localAdd(b.env, endName, varType)
            mirSetLocalType(b.func, endSlot, varType)
            let endRes: Result[MirExpr] = lowerExprValue(b, endNode, varType)
            if ! IsOk[MirExpr](endRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](endRes))
            add(b.currentStmts, mirStmtVar(endName, endSlot, Value[MirExpr](endRes)))

            let condLabel: str = blockBuilderNextLabel(b, "for_cond")
            let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
            let incLabel: str = blockBuilderNextLabel(b, "for_inc")
            let endLabel: str = blockBuilderNextLabel(b, "for_end")
            blockBuilderFinish(b, mirTermBr(condLabel))

            blockBuilderStart(b, condLabel)
            var condExpr: MirExpr
            if op == "..":
                condExpr = mirCmp(mcLe, mirLocal(slot), mirLocal(endSlot))
            else:
                condExpr = mirCmp(mcLt, mirLocal(slot), mirLocal(endSlot))
            blockBuilderFinish(b, mirTermCbr(condExpr, bodyLabel, endLabel))

            blockBuilderStart(b, bodyLabel)
            blockBuilderPushLoop(b, endLabel, incLabel)
            let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
            blockBuilderPopLoop(b)
            if ! IsOk[bool](bodyTermRes):
                return ErrInfo[bool](ErrorInfoOf[bool](bodyTermRes))
            let bodyTerminated: bool = Value[bool](bodyTermRes)
            if ! bodyTerminated:
                blockBuilderFinish(b, mirTermBr(incLabel))

            blockBuilderStart(b, incLabel)
            let incExpr: MirExpr = mirBin(mbAdd, mirLocal(slot), mirConstI64(1))
            add(b.currentStmts, mirStmtAssign(varName, slot, incExpr))
            blockBuilderFinish(b, mirTermBr(condLabel))

            blockBuilderStart(b, endLabel)
            return Ok[bool](false)

    # 2) Iterable loops: `for v in seq/str/Table/HashMap`
    var iterKey: str = ""
    if iterExpr != nil && iterExpr.typeCacheValid && iterExpr.typeCache != nil:
        iterKey = typeKey iterExpr.typeCache
    if (len(iterKey) == 0 || (iterKey == "node")) && iterExpr != nil && (iterExpr.kind == nkIdent || iterExpr.kind == nkSymbol):
        let nm: str = plainName(iterExpr)
        let slot0: int32 = localIndex(b.env, nm)
        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
            iterKey = funcObjTypeKey(b.func, slot0)
        elif slot0 >= 0:
            iterKey = localTypeKey(b.env, slot0)
    if (len(iterKey) == 0 || (iterKey == "node")) && iterExpr != nil && iterExpr.kind == nkSeqLit:
        # For seq literals, stage1 sometimes clears typeCache. Infer a best-effort element type.
        if kidCount(iterExpr) > 0:
            var elemKey: str = "int32"
            for ii in 0..<kidCount(iterExpr):
                var e: Node = kid(iterExpr, ii)
                if e != nil && e.kind == nkCallArg && kidCount(e) > 1:
                    e = kid(e, 1)
                if e != nil && e.kind == nkIntLit:
                    if e.intVal > 2147483647 || e.intVal < (-2147483647 - 1):
                        elemKey = "int64"
                elif e != nil && e.typeCacheValid && e.typeCache != nil:
                    let ek: str = typeKey e.typeCache
                    if len(ek) > 0:
                        elemKey = ek
            if elemKey != nil && len(elemKey) > 0:
                iterKey = "seq_" + elemKey
    if (len(iterKey) == 0 || (iterKey == "node")) && iterExpr != nil && iterExpr.kind == nkStrLit:
        iterKey = "str"
    if (len(iterKey) == 0 || (iterKey == "node")) && iterExpr != nil && iterExpr.kind == nkBracketExpr && kidCount(iterExpr) == 2:
        # Slices preserve the base container type key, e.g. `s[1..<3]` is still `str`.
        let base0: Node = kid(iterExpr, 0)
        var baseKey: str = ""
        if base0 != nil && base0.typeCacheValid && base0.typeCache != nil:
            baseKey = typeKey base0.typeCache
        if len(baseKey) == 0 && base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol):
            let nm: str = plainName(base0)
            let slot0: int32 = localIndex(b.env, nm)
            if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                baseKey = funcObjTypeKey(b.func, slot0)
            elif slot0 >= 0:
                baseKey = localTypeKey(b.env, slot0)
        if len(baseKey) == 0 && base0 != nil && base0.kind == nkStrLit:
            baseKey = "str"
        if len(baseKey) > 0:
            iterKey = baseKey
    if (len(iterKey) == 0 || (iterKey == "node")) && iterExpr != nil:
        iterKey = caseInferExprTypeKey(b, iterExpr)
    if (len(iterKey) == 0 || (iterKey == "node")) && iterExpr != nil:
        iterKey = exprTypeKeyShallow(b, iterExpr)
    if (len(iterKey) == 0 || (iterKey == "node")) && iterExpr != nil &&
       iterExpr.typeCacheValid && iterExpr.typeCache != nil:
        let looseKey: str = mirTypeKeyFromNodeLoose(iterExpr.typeCache)
        if looseKey != nil && len(looseKey) > 0:
            iterKey = looseKey

    iterKey = mirTypeKeyStripIterWrappers(iterKey)
    var iterKeyBase: str = mirTypeKeyBaseName(iterKey)
    if iterKeyBase == nil || len(iterKeyBase) == 0:
        iterKeyBase = iterKey

    if mirStrStartsWith(iterKeyBase, "seq_"):
        var iterPtr: MirExpr
        let iterSeqKey: str = iterKeyBase
        if iterExpr != nil && iterExpr.kind == nkSeqLit && !(iterExpr.typeCacheValid && iterExpr.typeCache != nil):
            let lit: Node = iterExpr
            let seqSlotName: str = blockBuilderNextTemp(b, "__for_seq")
            let seqSlot: int32 = localAdd(b.env, seqSlotName, mirTypeI64())
            mirSetLocalType(b.func, seqSlot, mirTypeI64())
            let allocRes: Result[bool] = allocObjValueLocal(b, seqSlot, "seq")
            if ! IsOk[bool](allocRes):
                return ErrInfo[bool](ErrorInfoOf[bool](allocRes))
            funcSetObjTypeKey(b.func, seqSlot, iterSeqKey)
            let litRes: Result[bool] = emitSeqLitToPtr(b, mirLocal(seqSlot), iterSeqKey, lit)
            if ! IsOk[bool](litRes):
                return ErrInfo[bool](ErrorInfoOf[bool](litRes))
            iterPtr = mirLocal(seqSlot)
        else:
            let iterRes: Result[MirExpr] = lowerExprValue(b, iterExpr, mirTypeI64())
            if ! IsOk[MirExpr](iterRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](iterRes))
            let iterTmpName: str = blockBuilderNextTemp(b, "__for_iter")
            let iterTmpSlot: int32 = localAdd(b.env, iterTmpName, mirTypeI64())
            mirSetLocalType(b.func, iterTmpSlot, mirTypeI64())
            add(b.currentStmts, mirStmtLet(iterTmpName, iterTmpSlot, Value[MirExpr](iterRes)))
            iterPtr = mirLocal(iterTmpSlot)

        let elemKey: str = str(ptr_add(void*(iterSeqKey), 4))
        if elemKey == nil || len(elemKey) == 0:
            return Err[bool]("mir_builder: for seq missing element type")
        let elemTypeNode: Node = newIdent(elemKey, forNode.pos)
        let elemTy: MirType = mirTypeFromNodeWithModule(b.module, elemTypeNode)
        let sizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemTypeNode)
        if ! IsOk[int32](sizeRes):
            return ErrInfo[bool](ErrorInfoOf[int32](sizeRes))
        let elemSize: int32 = Value[int32](sizeRes)

        let seqOt: MirObjType = mirGetObjType(b.module, "seq")
        var lenOff: int32 = -1
        var bufOff: int32 = -1
        for fi in 0..<seqOt.fields.len:
            let f: MirObjField = seqOt.fields[fi]
            if (f.name == "len"):
                lenOff = f.offset
            elif (f.name == "buffer"):
                bufOff = f.offset
        if lenOff < 0 || bufOff < 0:
            return Err[bool]("mir_builder: seq layout mismatch")

        let lenAddr: MirExpr = (lenOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(lenOff)))
        let bufAddr: MirExpr = (bufOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(bufOff)))

        let lenName: str = blockBuilderNextTemp(b, "__for_len")
        let lenSlot: int32 = localAdd(b.env, lenName, mirTypeI32())
        mirSetLocalType(b.func, lenSlot, mirTypeI32())
        add(b.currentStmts, mirStmtLet(lenName, lenSlot, mirLoad(lenAddr, mirTypeI32())))

        let bufName: str = blockBuilderNextTemp(b, "__for_buf")
        let bufSlot: int32 = localAdd(b.env, bufName, mirTypeI64())
        mirSetLocalType(b.func, bufSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(bufName, bufSlot, mirLoad(bufAddr, mirTypeI64())))

        var idxName: str = blockBuilderNextTemp(b, "__for_i")
        var valName: str = patNames[0]
        if patNames.len == 2:
            idxName = patNames[0]
            valName = patNames[1]

        let idxSlot: int32 = localAdd(b.env, idxName, mirTypeI32())
        mirSetLocalType(b.func, idxSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(idxName, idxSlot, mirConstI64(0)))

        let valSlot: int32 = localAdd(b.env, valName, elemTy)
        mirSetLocalType(b.func, valSlot, elemTy)
        add(b.currentStmts, mirStmtVar(valName, valSlot, mirConstI64(0)))

        let condLabel: str = blockBuilderNextLabel(b, "for_cond")
        let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
        let incLabel: str = blockBuilderNextLabel(b, "for_inc")
        let endLabel: str = blockBuilderNextLabel(b, "for_end")
        blockBuilderFinish(b, mirTermBr(condLabel))

        blockBuilderStart(b, condLabel)
        let condExpr: MirExpr = mirCmp(mcLt, mirLocal(idxSlot), mirLocal(lenSlot))
        blockBuilderFinish(b, mirTermCbr(condExpr, bodyLabel, endLabel))

        blockBuilderStart(b, bodyLabel)
        # Load element: *(buffer + i*elemSize)
        let idx64: MirExpr = mirCast(mirTypeI64(), mirLocal(idxSlot))
        let step: MirExpr = mirConstI64(int64(elemSize))
        let off: MirExpr = (elemSize == 1) ? idx64 : mirBin(mbMul, idx64, step)
        let addr: MirExpr = (elemSize == 0) ? mirLocal(bufSlot) : mirBin(mbAdd, mirLocal(bufSlot), off)
        let elemVal: MirExpr = mirLoad(addr, elemTy)
        add(b.currentStmts, mirStmtAssign(valName, valSlot, elemVal))

        blockBuilderPushLoop(b, endLabel, incLabel)
        let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
        blockBuilderPopLoop(b)
        if ! IsOk[bool](bodyTermRes):
            return ErrInfo[bool](ErrorInfoOf[bool](bodyTermRes))
        let bodyTerminated: bool = Value[bool](bodyTermRes)
        if ! bodyTerminated:
            blockBuilderFinish(b, mirTermBr(incLabel))

        blockBuilderStart(b, incLabel)
        let incExpr: MirExpr = mirBin(mbAdd, mirLocal(idxSlot), mirConstI64(1))
        add(b.currentStmts, mirStmtAssign(idxName, idxSlot, incExpr))
        blockBuilderFinish(b, mirTermBr(condLabel))

        blockBuilderStart(b, endLabel)
        return Ok[bool](false)

    if (iterKeyBase == "str") || (iterKeyBase == "string") || (iterKeyBase == "cstring"):
        let iterRes: Result[MirExpr] = lowerExprValue(b, iterExpr, mirTypeI64())
        if ! IsOk[MirExpr](iterRes):
            return ErrInfo[bool](ErrorInfoOf[MirExpr](iterRes))
        let iterTmpName: str = blockBuilderNextTemp(b, "__for_iter")
        let iterTmpSlot: int32 = localAdd(b.env, iterTmpName, mirTypeI64())
        mirSetLocalType(b.func, iterTmpSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(iterTmpName, iterTmpSlot, Value[MirExpr](iterRes)))
        let iterPtr: MirExpr = mirLocal(iterTmpSlot)

        # String iteration: index-by-byte over a C string, returns char(i32) masked to 0..255.
        let lenName: str = blockBuilderNextTemp(b, "__for_strlen")
        let lenSlot: int32 = localAdd(b.env, lenName, mirTypeI32())
        mirSetLocalType(b.func, lenSlot, mirTypeI32())
        var strlenArgs: MirExpr[]
        add(strlenArgs, iterPtr)
        add(b.currentStmts, mirStmtLet(lenName, lenSlot, mirCall("cheng_strlen", strlenArgs)))

        var idxName: str = blockBuilderNextTemp(b, "__for_i")
        var chName: str = patNames[0]
        if patNames.len == 2:
            idxName = patNames[0]
            chName = patNames[1]

        let idxSlot: int32 = localAdd(b.env, idxName, mirTypeI32())
        mirSetLocalType(b.func, idxSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(idxName, idxSlot, mirConstI64(0)))

        let chSlot: int32 = localAdd(b.env, chName, mirTypeI32())
        mirSetLocalType(b.func, chSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(chName, chSlot, mirConstI64(0)))

        let condLabel: str = blockBuilderNextLabel(b, "for_cond")
        let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
        let incLabel: str = blockBuilderNextLabel(b, "for_inc")
        let endLabel: str = blockBuilderNextLabel(b, "for_end")
        blockBuilderFinish(b, mirTermBr(condLabel))

        blockBuilderStart(b, condLabel)
        let condExpr: MirExpr = mirCmp(mcLt, mirLocal(idxSlot), mirLocal(lenSlot))
        blockBuilderFinish(b, mirTermCbr(condExpr, bodyLabel, endLabel))

        blockBuilderStart(b, bodyLabel)
        let idx64: MirExpr = mirCast(mirTypeI64(), mirLocal(idxSlot))
        let addr: MirExpr = mirBin(mbAdd, iterPtr, idx64)
        let raw: MirExpr = mirLoad(addr, mirTypeI32())
        let chVal: MirExpr = mirBin(mbAnd, raw, mirConstI64(255))
        add(b.currentStmts, mirStmtAssign(chName, chSlot, chVal))

        blockBuilderPushLoop(b, endLabel, incLabel)
        let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
        blockBuilderPopLoop(b)
        if ! IsOk[bool](bodyTermRes):
            return ErrInfo[bool](ErrorInfoOf[bool](bodyTermRes))
        let bodyTerminated: bool = Value[bool](bodyTermRes)
        if ! bodyTerminated:
            blockBuilderFinish(b, mirTermBr(incLabel))

        blockBuilderStart(b, incLabel)
        let incExpr: MirExpr = mirBin(mbAdd, mirLocal(idxSlot), mirConstI64(1))
        add(b.currentStmts, mirStmtAssign(idxName, idxSlot, incExpr))
        blockBuilderFinish(b, mirTermBr(condLabel))

        blockBuilderStart(b, endLabel)
        return Ok[bool](false)

    if mirTypeKeyIsTableIter(iterKey):
        let iterRes: Result[MirExpr] = lowerExprValue(b, iterExpr, mirTypeI64())
        if ! IsOk[MirExpr](iterRes):
            return ErrInfo[bool](ErrorInfoOf[MirExpr](iterRes))
        let iterTmpName: str = blockBuilderNextTemp(b, "__for_iter")
        let iterTmpSlot: int32 = localAdd(b.env, iterTmpName, mirTypeI64())
        mirSetLocalType(b.func, iterTmpSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(iterTmpName, iterTmpSlot, Value[MirExpr](iterRes)))
        let iterPtr: MirExpr = mirLocal(iterTmpSlot)

        # Inline table iteration: scan `states` and yield matching `keys`/`vals`.
        var tblObjName: str = ""
        if b.module != nil:
            tblObjName = mirPtrBaseObjTypeName(b.module, iterKey)
        if len(tblObjName) == 0:
            tblObjName = iterKeyBase
        if iterExpr != nil && (iterExpr.kind == nkIdent || iterExpr.kind == nkSymbol):
            let nm: str = plainName(iterExpr)
            let slot0: int32 = localIndex(b.env, nm)
            if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                let objNm: str = funcObjTypeName(b.func, slot0)
                if len(objNm) > 0:
                    tblObjName = objNm

        if b.module != nil:
            let resolved: str = mirPtrBaseObjTypeName(b.module, tblObjName)
            if len(resolved) > 0:
                tblObjName = resolved
        if b.module == nil || tblObjName == nil || len(tblObjName) == 0 || ! mirHasObjType(b.module, tblObjName):
            return Err[bool]("mir_builder: unknown Table object type")
        let tblOt: MirObjType = mirGetObjType(b.module, tblObjName)
        var keysLenOff: int32 = -1
        var keysBufOff: int32 = -1
        var valsBufOff: int32 = -1
        var statesBufOff: int32 = -1
        for fi2 in 0..<tblOt.fields.len:
            let f: MirObjField = tblOt.fields[fi2]
            if (f.name == "keys.len"):
                keysLenOff = f.offset
            elif (f.name == "keys.buffer"):
                keysBufOff = f.offset
            elif (f.name == "vals.buffer"):
                valsBufOff = f.offset
            elif (f.name == "states.buffer"):
                statesBufOff = f.offset
        if keysLenOff < 0 || keysBufOff < 0 || valsBufOff < 0 || statesBufOff < 0:
            return Err[bool]("mir_builder: Table layout mismatch")

        let capName: str = blockBuilderNextTemp(b, "__tbl_cap")
        let capSlot: int32 = localAdd(b.env, capName, mirTypeI32())
        mirSetLocalType(b.func, capSlot, mirTypeI32())
        let capAddr: MirExpr = (keysLenOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(keysLenOff)))
        add(b.currentStmts, mirStmtLet(capName, capSlot, mirLoad(capAddr, mirTypeI32())))

        let keysBufName: str = blockBuilderNextTemp(b, "__tbl_kbuf")
        let keysBufSlot: int32 = localAdd(b.env, keysBufName, mirTypeI64())
        mirSetLocalType(b.func, keysBufSlot, mirTypeI64())
        let keysBufAddr: MirExpr = (keysBufOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(keysBufOff)))
        add(b.currentStmts, mirStmtLet(keysBufName, keysBufSlot, mirLoad(keysBufAddr, mirTypeI64())))

        let valsBufName: str = blockBuilderNextTemp(b, "__tbl_vbuf")
        let valsBufSlot: int32 = localAdd(b.env, valsBufName, mirTypeI64())
        mirSetLocalType(b.func, valsBufSlot, mirTypeI64())
        let valsBufAddr: MirExpr = (valsBufOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(valsBufOff)))
        add(b.currentStmts, mirStmtLet(valsBufName, valsBufSlot, mirLoad(valsBufAddr, mirTypeI64())))

        let statesBufName: str = blockBuilderNextTemp(b, "__tbl_sbuf")
        let statesBufSlot: int32 = localAdd(b.env, statesBufName, mirTypeI64())
        mirSetLocalType(b.func, statesBufSlot, mirTypeI64())
        let statesBufAddr: MirExpr = (statesBufOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(statesBufOff)))
        add(b.currentStmts, mirStmtLet(statesBufName, statesBufSlot, mirLoad(statesBufAddr, mirTypeI64())))

        let keyName: str = patNames[0]
        let keySlot: int32 = localAdd(b.env, keyName, mirTypeI64())
        mirSetLocalType(b.func, keySlot, mirTypeI64())
        add(b.currentStmts, mirStmtVar(keyName, keySlot, mirConstI64(0)))

        var hasVal: bool = false
        var valName: str = ""
        var valSlot: int32 = -1
        var valTy: MirType = mirTypeI64()
        var valSize: int32 = 8
        if patNames.len == 2:
            hasVal = true
            valName = patNames[1]
            var valKey: str = mirTypeKeyTableValKey(iterKey)
            if (valKey == nil || len(valKey) == 0) && iterExpr != nil && iterExpr.typeCacheValid && iterExpr.typeCache != nil:
                valKey = mirTypeKeyTableValKey(typeKey(iterExpr.typeCache))
            if valKey != nil && len(valKey) > 0:
                let valTypeNode: Node = newIdent(valKey, forNode.pos)
                let valTy2: MirType = mirTypeFromNodeWithModule(b.module, valTypeNode)
                if valTy2.kind != mtVoid:
                    valTy = valTy2
                    let valSize2: int32 = mirTypeSize(valTy)
                    if valSize2 > 0:
                        valSize = valSize2
            valSlot = localAdd(b.env, valName, valTy)
            mirSetLocalType(b.func, valSlot, valTy)
            add(b.currentStmts, mirStmtVar(valName, valSlot, mirConstI64(0)))

        let idxName: str = blockBuilderNextTemp(b, "__tbl_i")
        let idxSlot: int32 = localAdd(b.env, idxName, mirTypeI32())
        mirSetLocalType(b.func, idxSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(idxName, idxSlot, mirConstI64(0)))

        let curIdxName: str = blockBuilderNextTemp(b, "__tbl_cur_i")
        let curIdxSlot: int32 = localAdd(b.env, curIdxName, mirTypeI32())
        mirSetLocalType(b.func, curIdxSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(curIdxName, curIdxSlot, mirConstI64(0)))

        let scanLabel: str = blockBuilderNextLabel(b, "for_scan")
        let loadLabel: str = blockBuilderNextLabel(b, "for_load")
        let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
        let endLabel: str = blockBuilderNextLabel(b, "for_end")
        blockBuilderFinish(b, mirTermBr(scanLabel))

        blockBuilderStart(b, scanLabel)
        let scanCond: MirExpr = mirCmp(mcLt, mirLocal(idxSlot), mirLocal(capSlot))
        blockBuilderFinish(b, mirTermCbr(scanCond, loadLabel, endLabel))

        blockBuilderStart(b, loadLabel)
        add(b.currentStmts, mirStmtAssign(curIdxName, curIdxSlot, mirLocal(idxSlot)))
        let curIdx64: MirExpr = mirCast(mirTypeI64(), mirLocal(curIdxSlot))
        let stAddr: MirExpr = mirBin(mbAdd, mirLocal(statesBufSlot), curIdx64)
        let stVal: MirExpr = mirLoad(stAddr, mirTypeU8())
        let incExpr: MirExpr = mirBin(mbAdd, mirLocal(idxSlot), mirConstI64(1))
        add(b.currentStmts, mirStmtAssign(idxName, idxSlot, incExpr))
        let isUsed: MirExpr = mirCmp(mcNe, stVal, mirConstI64(0))
        blockBuilderFinish(b, mirTermCbr(isUsed, bodyLabel, scanLabel))

        blockBuilderStart(b, bodyLabel)
        let keyOff2: MirExpr = mirBin(mbMul, curIdx64, mirConstI64(8))
        let keyAddr2: MirExpr = mirBin(mbAdd, mirLocal(keysBufSlot), keyOff2)
        let keyVal: MirExpr = mirLoad(keyAddr2, mirTypeI64())
        add(b.currentStmts, mirStmtAssign(keyName, keySlot, keyVal))
        if hasVal:
            let valOff2: MirExpr = mirBin(mbMul, curIdx64, mirConstI64(int64(valSize)))
            let valAddr2: MirExpr = mirBin(mbAdd, mirLocal(valsBufSlot), valOff2)
            let valVal: MirExpr = mirLoad(valAddr2, valTy)
            add(b.currentStmts, mirStmtAssign(valName, valSlot, valVal))

        blockBuilderPushLoop(b, endLabel, scanLabel)
        let bodyTermRes2: Result[bool] = lowerStmtList(b, bodyNode)
        blockBuilderPopLoop(b)
        if ! IsOk[bool](bodyTermRes2):
            return ErrInfo[bool](ErrorInfoOf[bool](bodyTermRes2))
        let bodyTerminated2: bool = Value[bool](bodyTermRes2)
        if ! bodyTerminated2:
            blockBuilderFinish(b, mirTermBr(scanLabel))

        blockBuilderStart(b, endLabel)
        return Ok[bool](false)

    let mapFlavor0: int32 = mirHashMapIterFlavorFromTypeKey(iterKey)
    if mapFlavor0 != 0:
        let iterRes: Result[MirExpr] = lowerExprValue(b, iterExpr, mirTypeI64())
        if ! IsOk[MirExpr](iterRes):
            return ErrInfo[bool](ErrorInfoOf[MirExpr](iterRes))
        let iterTmpName: str = blockBuilderNextTemp(b, "__for_iter")
        let iterTmpSlot: int32 = localAdd(b.env, iterTmpName, mirTypeI64())
        mirSetLocalType(b.func, iterTmpSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(iterTmpName, iterTmpSlot, Value[MirExpr](iterRes)))
        let iterPtr: MirExpr = mirLocal(iterTmpSlot)

        var mapObjName: str = ""
        if b.module != nil:
            mapObjName = mirPtrBaseObjTypeName(b.module, iterKey)
        if iterExpr != nil && (iterExpr.kind == nkIdent || iterExpr.kind == nkSymbol):
            let nm: str = plainName(iterExpr)
            let slot0: int32 = localIndex(b.env, nm)
            if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                let objNm: str = funcObjTypeName(b.func, slot0)
                if len(objNm) > 0:
                    mapObjName = objNm
        if b.module != nil:
            let resolved: str = mirPtrBaseObjTypeName(b.module, mapObjName)
            if len(resolved) > 0:
                mapObjName = resolved

        var mapFlavor: int32 = mapFlavor0
        if mapFlavor == 0:
            mapFlavor = mirHashMapIterFlavorFromTypeKey(mapObjName)
        if mapFlavor == 0:
            return Err[bool]("mir_builder: unsupported HashMap iter type")

        var keysLenOff: int32 = -1
        var keysBufOff: int32 = -1
        var valsBufOff: int32 = -1
        let hasMapObjLayout: bool = b.module != nil && mapObjName != nil && len(mapObjName) > 0 &&
                                    mirHasObjType(b.module, mapObjName)
        if hasMapObjLayout:
            let mapOt: MirObjType = mirGetObjType(b.module, mapObjName)
            for fiMap in 0..<mapOt.fields.len:
                let f: MirObjField = mapOt.fields[fiMap]
                if (f.name == "keys.len"):
                    keysLenOff = f.offset
                elif (f.name == "keys.buffer"):
                    keysBufOff = f.offset
                elif (f.name == "vals.buffer"):
                    valsBufOff = f.offset
        if keysLenOff < 0 || keysBufOff < 0 || valsBufOff < 0:
            # Fallback to std/hashmaps stable layout:
            # HashMap* = { keys: seq, vals: seq, ... }.
            keysLenOff = 0
            keysBufOff = 8
            valsBufOff = 24

        let capName: str = blockBuilderNextTemp(b, "__map_cap")
        let capSlot: int32 = localAdd(b.env, capName, mirTypeI32())
        mirSetLocalType(b.func, capSlot, mirTypeI32())
        let capAddr: MirExpr = (keysLenOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(keysLenOff)))
        add(b.currentStmts, mirStmtLet(capName, capSlot, mirLoad(capAddr, mirTypeI32())))

        let keysBufName: str = blockBuilderNextTemp(b, "__map_kbuf")
        let keysBufSlot: int32 = localAdd(b.env, keysBufName, mirTypeI64())
        mirSetLocalType(b.func, keysBufSlot, mirTypeI64())
        let keysBufAddr: MirExpr = (keysBufOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(keysBufOff)))
        add(b.currentStmts, mirStmtLet(keysBufName, keysBufSlot, mirLoad(keysBufAddr, mirTypeI64())))

        let valsBufName: str = blockBuilderNextTemp(b, "__map_vbuf")
        let valsBufSlot: int32 = localAdd(b.env, valsBufName, mirTypeI64())
        mirSetLocalType(b.func, valsBufSlot, mirTypeI64())
        let valsBufAddr: MirExpr = (valsBufOff == 0) ? iterPtr : mirBin(mbAdd, iterPtr, mirConstI64(int64(valsBufOff)))
        add(b.currentStmts, mirStmtLet(valsBufName, valsBufSlot, mirLoad(valsBufAddr, mirTypeI64())))

        let keyName: str = patNames[0]
        let keySlot: int32 = localAdd(b.env, keyName, mirTypeI64())
        mirSetLocalType(b.func, keySlot, mirTypeI64())
        add(b.currentStmts, mirStmtVar(keyName, keySlot, mirConstI64(0)))

        var hasVal: bool = false
        var valName: str = ""
        var valSlot: int32 = -1
        var valTy: MirType = mirTypeI32()
        var valSize: int32 = 4
        if patNames.len == 2:
            hasVal = true
            valName = patNames[1]
            if mapFlavor == 2:
                valTy = mirTypeI64()
                let valTyNode: Node = newIdent("seq_int32", forNode.pos)
                valTy = mirTypeFromNodeWithModule(b.module, valTyNode)
                let valSizeRes: Result[int32] = mirSizeOfTypeNode(b.module, valTyNode)
                if IsOk[int32](valSizeRes):
                    valSize = Value[int32](valSizeRes)
                else:
                    valSize = 8
            valSlot = localAdd(b.env, valName, valTy)
            mirSetLocalType(b.func, valSlot, valTy)
            add(b.currentStmts, mirStmtVar(valName, valSlot, mirConstI64(0)))

        let idxName: str = blockBuilderNextTemp(b, "__map_i")
        let idxSlot: int32 = localAdd(b.env, idxName, mirTypeI32())
        mirSetLocalType(b.func, idxSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(idxName, idxSlot, mirConstI64(0)))

        let condLabel: str = blockBuilderNextLabel(b, "for_cond")
        let loadLabel: str = blockBuilderNextLabel(b, "for_load")
        let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
        let incLabel: str = blockBuilderNextLabel(b, "for_inc")
        let endLabel: str = blockBuilderNextLabel(b, "for_end")
        blockBuilderFinish(b, mirTermBr(condLabel))

        blockBuilderStart(b, condLabel)
        let condExpr: MirExpr = mirCmp(mcLt, mirLocal(idxSlot), mirLocal(capSlot))
        blockBuilderFinish(b, mirTermCbr(condExpr, loadLabel, endLabel))

        blockBuilderStart(b, loadLabel)
        let idx64: MirExpr = mirCast(mirTypeI64(), mirLocal(idxSlot))
        let keyOff: MirExpr = mirBin(mbMul, idx64, mirConstI64(8))
        let keyAddr: MirExpr = mirBin(mbAdd, mirLocal(keysBufSlot), keyOff)
        let keyVal: MirExpr = mirLoad(keyAddr, mirTypeI64())
        add(b.currentStmts, mirStmtAssign(keyName, keySlot, keyVal))
        let hasEntry: MirExpr = mirCmp(mcNe, mirLocal(keySlot), mirConstI64(0))
        blockBuilderFinish(b, mirTermCbr(hasEntry, bodyLabel, incLabel))

        blockBuilderStart(b, bodyLabel)
        if hasVal:
            let stepExpr: MirExpr = mirConstI64(int64(valSize))
            let valOff: MirExpr = (valSize == 1) ? idx64 : mirBin(mbMul, idx64, stepExpr)
            let valAddr: MirExpr = mirBin(mbAdd, mirLocal(valsBufSlot), valOff)
            let valVal: MirExpr = mirLoad(valAddr, valTy)
            add(b.currentStmts, mirStmtAssign(valName, valSlot, valVal))

        blockBuilderPushLoop(b, endLabel, incLabel)
        let bodyTermRes3: Result[bool] = lowerStmtList(b, bodyNode)
        blockBuilderPopLoop(b)
        if ! IsOk[bool](bodyTermRes3):
            return ErrInfo[bool](ErrorInfoOf[bool](bodyTermRes3))
        let bodyTerminated3: bool = Value[bool](bodyTermRes3)
        if ! bodyTerminated3:
            blockBuilderFinish(b, mirTermBr(incLabel))

        blockBuilderStart(b, incLabel)
        let incExpr2: MirExpr = mirBin(mbAdd, mirLocal(idxSlot), mirConstI64(1))
        add(b.currentStmts, mirStmtAssign(idxName, idxSlot, incExpr2))
        blockBuilderFinish(b, mirTermBr(condLabel))

        blockBuilderStart(b, endLabel)
        return Ok[bool](false)

    let k: str = (iterExpr != nil) ? intToStr(int32(iterExpr.kind)) : "0"
    let line: str = (iterExpr != nil) ? intToStr(iterExpr.pos.line) : "0"
    let col: str = (iterExpr != nil) ? intToStr(iterExpr.pos.col) : "0"
    let keyDbg: str = iterKey
    var extra: str = ""
    if iterExpr != nil && iterExpr.kind == nkInfix && kidCount(iterExpr) > 0:
        extra = " op=" + backendOpName(kid(iterExpr, 0))
    return Err[bool]("mir_builder: for unsupported iter expression (kind=nk#" + k + " @" + line + ":" + col + " key='" + keyDbg + "'" + extra + ")")

fn casePatternCore(p0: Node): Node =
    var p: Node = p0
    while p != nil && p.kind == nkPar && kidCount(p) > 0:
        p = kid(p, 0)
    if p != nil && p.kind == nkPattern && kidCount(p) > 0:
        p = kid(p, 0)
        while p != nil && p.kind == nkPar && kidCount(p) > 0:
            p = kid(p, 0)
    return p

fn casePatternTypeNode(p0: Node): Node =
    var p: Node = p0
    while p != nil && p.kind == nkPar && kidCount(p) > 0:
        p = kid(p, 0)
    if p != nil && p.kind == nkPattern && kidCount(p) > 1:
        return kid(p, 1)
    return nil

fn casePatternIsWildcard(p0: Node): bool =
    let core: Node = casePatternCore(p0)
    if core != nil && (core.kind == nkIdent || core.kind == nkSymbol):
        return (plainName(core) == "_")
    return false

fn caseInferExprTypeKey(b: BlockBuilder, n0: Node): str =
    if b == nil:
        return ""
    var n: Node = n0
    while n != nil && n.kind == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if n == nil:
        return ""
    if n.kind == nkBracketExpr && kidCount(n) == 2:
        let baseNode: Node = kid(n, 0)
        var idxNode: Node = kid(n, 1)
        while idxNode != nil && idxNode.kind == nkPar && kidCount(idxNode) > 0:
            idxNode = kid(idxNode, 0)
        if idxNode != nil && idxNode.kind == nkCallArg:
            if kidCount(idxNode) > 1:
                idxNode = kid(idxNode, 1)
            elif kidCount(idxNode) > 0:
                idxNode = kid(idxNode, 0)
        let debugBracketInfer: bool = (getEnv "CHENG_BACKEND_DEBUG_BRACKET_INFER" == "1")
        var dbgTarget: bool = false
        if debugBracketInfer:
            if baseNode != nil && (baseNode.kind == nkIdent || baseNode.kind == nkSymbol) && (plainName(baseNode) == "root"):
                if idxNode != nil && idxNode.kind == nkStrLit && (idxNode.strVal == "source_addrs"):
                    dbgTarget = true
            if dbgTarget:
                echo("[backend] debugBracketInfer: root['source_addrs'] start")
        if idxNode != nil && idxNode.kind == nkInfix && kidCount(idxNode) >= 3:
            let opNode: Node = kid(idxNode, 0)
            let op: str = backendOpName(opNode)
            if op == ".." || op == "..<":
                let bk0: str = caseInferExprTypeKey(b, baseNode)
                if isStringKey(bk0) || (baseNode != nil && baseNode.kind == nkStrLit):
                    return "str"
                if mirStrStartsWith(bk0, "seq_") || mirStrStartsWith(bk0, "seq_fixed_"):
                    return bk0
        var baseKey: str = caseInferExprTypeKey(b, baseNode)
        if dbgTarget:
            echo("[backend] debugBracketInfer: baseKey='" + baseKey + "' idxKind=nk#" +
                ((idxNode != nil) ? intToStr(int32(idxNode.kind)) : "-1"))
        if baseKey != nil && len(baseKey) > 0:
            if mirStrStartsWith(baseKey, "ref_"):
                baseKey = str(ptr_add(void*(baseKey), 4))
            elif mirStrStartsWith(baseKey, "var_ref_"):
                baseKey = str(ptr_add(void*(baseKey), 8))
            elif mirStrStartsWith(baseKey, "var_"):
                baseKey = str(ptr_add(void*(baseKey), 4))
            if mirStrStartsWith(baseKey, "ptr_"):
                baseKey = str(ptr_add(void*(baseKey), 4))
            if mirStrStartsWith(baseKey, "seq_"):
                return str(ptr_add(void*(baseKey), 4))
            if isStringKey(baseKey) || (baseNode != nil && baseNode.kind == nkStrLit):
                return "char"
        if b.module != nil:
            var argNodes: Node[]
            add(argNodes, baseNode)
            add(argNodes, idxNode)
            var hintSig: str = ""
            if n.typeCacheValid && n.typeCache != nil:
                hintSig = typeKey n.typeCache
            let callee0: MirFunc = mirResolveCalleeFuncBestEffort(b, "[]", argNodes, hintSig)
            if dbgTarget:
                let calleeName: str = (callee0 != nil) ? callee0.name : ""
                echo("[backend] debugBracketInfer: resolve '[]' hint='" + hintSig + "' callee='" + calleeName + "'")
            if callee0 != nil:
                var outKey: str = ""
                if callee0.params.len > 0:
                    let p0: MirParam = callee0.params[0]
                    if (p0.name == "__ret"):
                        outKey = funcObjTypeKey(callee0, p0.slot)
                if len(outKey) == 0 && callee0.retTypeKey != nil && len(callee0.retTypeKey) > 0:
                    outKey = callee0.retTypeKey
                if len(outKey) > 0:
                    if dbgTarget:
                        echo("[backend] debugBracketInfer: outKey='" + outKey + "'")
                    return outKey
    if n.kind == nkInfix && kidCount(n) >= 3:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        if op == "+":
            let lhsNode: Node = kid(n, 1)
            let rhsNode: Node = kid(n, 2)
            let lk: str = caseInferExprTypeKey(b, lhsNode)
            let rk: str = caseInferExprTypeKey(b, rhsNode)
            if isStringKey(lk) || isStringKey(rk) || lhsNode.kind == nkStrLit || rhsNode.kind == nkStrLit:
                return "str"
    if n.typeCacheValid && n.typeCache != nil:
        return typeKey n.typeCache
    if n.kind == nkStrLit:
        return "str"
    if n.kind == nkIdent || n.kind == nkSymbol:
        let nm: str = plainName(n)
        let slot0: int32 = localIndex(b.env, nm)
        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
            return funcObjTypeKey(b.func, slot0)
        if slot0 >= 0:
            return localTypeKey(b.env, slot0)
        if mirDupGlobalNamesHas(nm) && b.func != nil:
            let f0: MirFunc = b.func
            let sym0: str = mirMaybeMangleDupGlobalName(nm, f0.originFile)
            let gk1: str = mirGlobalTypeKeyGet(sym0)
            if gk1 != nil && len(gk1) > 0:
                return gk1
        let gk0: str = mirGlobalTypeKeyByBaseUnique(b.module, nm)
        if gk0 != nil && len(gk0) > 0:
            return gk0
        return ""
    if n.kind == nkDotExpr && kidCount(n) > 1:
        let baseNode: Node = kid(n, 0)
        let fieldNode: Node = kid(n, 1)
        let fieldName: str = backendStripSpaces(plainName(fieldNode))
        var parentKey: str = caseInferExprTypeKey(b, baseNode)
        if parentKey != nil && len(parentKey) > 0 && len(fieldName) > 0:
            if mirStrStartsWith(parentKey, "ref_"):
                parentKey = str(ptr_add(void*(parentKey), 4))
            elif mirStrStartsWith(parentKey, "var_ref_"):
                parentKey = str(ptr_add(void*(parentKey), 8))
            elif mirStrStartsWith(parentKey, "var_"):
                parentKey = str(ptr_add(void*(parentKey), 4))
            var fieldKey: str = mirObjFieldTypeKeyGet(parentKey, fieldName)
            if len(fieldKey) == 0 && ((parentKey == "tuple") || mirStrStartsWith(parentKey, "tuple_")):
                let ti: int32 = mirTupleFieldIndexGet(parentKey, fieldName)
                if ti >= 0:
                    let altFieldName: str = "f" + intToStr(ti)
                    fieldKey = mirObjFieldTypeKeyGet(parentKey, altFieldName)
            if len(fieldKey) == 0:
                var pk: str = parentKey
                if mirStrStartsWith(pk, "ptr_"):
                    pk = str(ptr_add(void*(pk), 4))
                if pk != nil && len(pk) > 0 && !(pk == parentKey):
                    fieldKey = mirObjFieldTypeKeyGet(pk, fieldName)
            if len(fieldKey) == 0 && b.module != nil:
                if mirStrStartsWith(parentKey, "seq_") && mirHasObjType(b.module, "seq"):
                    fieldKey = mirObjFieldTypeKeyGet("seq", fieldName)
                elif mirStrStartsWith(parentKey, "seq_fixed_") && mirHasObjType(b.module, "seq"):
                    fieldKey = mirObjFieldTypeKeyGet("seq", fieldName)
                elif mirStrStartsWith(parentKey, "Table_") && mirHasObjType(b.module, "Table"):
                    fieldKey = mirObjFieldTypeKeyGet("Table", fieldName)
            if len(fieldKey) > 0:
                return fieldKey

    if n.kind == nkCall && b.module != nil && kidCount(n) > 0:
        let calleeNode: Node = kid(n, 0)
        var name: str = ""
        var typeArgs: Node[]
        if calleeNode != nil && calleeNode.kind == nkBracketExpr && kidCount(calleeNode) > 0:
            let base: Node = kid(calleeNode, 0)
            name = backendStripSpaces(plainName(base))
            for ti in 1..<kidCount(calleeNode):
                let t: Node = kid(calleeNode, ti)
                if t != nil && t.kind != nkEmpty:
                    add(typeArgs, t)
        else:
            name = backendStripSpaces(plainName(calleeNode))
        var callName: str = name
        if typeArgs.len > 0:
            callName = mangleInstance(name, typeArgs)
        var argNodes: Node[]
        for ai in 1..<kidCount(n):
            var argNode: Node = kid(n, ai)
            if argNode != nil && argNode.kind == nkCallArg:
                if kidCount(argNode) > 1:
                    argNode = kid(argNode, 1)
                elif kidCount(argNode) > 0:
                    argNode = kid(argNode, 0)
            add(argNodes, argNode)
        let callee0: MirFunc = mirResolveCalleeFuncBestEffort(b, callName, argNodes, "")
        var outKey: str = ""
        if callee0 != nil:
            if callee0.params.len > 0:
                let p0: MirParam = callee0.params[0]
                if (p0.name == "__ret"):
                    outKey = funcObjTypeKey(callee0, p0.slot)
            if len(outKey) == 0 && callee0.retTypeKey != nil && len(callee0.retTypeKey) > 0:
                outKey = callee0.retTypeKey
        if len(outKey) == 0 && (callName == "Value") && argNodes.len == 1 && b.module != nil:
            let arg0: Node = argNodes[0]
            var parentKey: str = caseInferExprTypeKey(b, arg0)
            if parentKey != nil && len(parentKey) > 0:
                if mirStrStartsWith(parentKey, "ref_"):
                    parentKey = str(ptr_add(void*(parentKey), 4))
                elif mirStrStartsWith(parentKey, "var_ref_"):
                    parentKey = str(ptr_add(void*(parentKey), 8))
                elif mirStrStartsWith(parentKey, "var_"):
                    parentKey = str(ptr_add(void*(parentKey), 4))
                var fieldKey: str = mirObjFieldTypeKeyGet(parentKey, "value")
                if len(fieldKey) == 0:
                    var pk: str = parentKey
                    if mirStrStartsWith(pk, "ptr_"):
                        pk = str(ptr_add(void*(pk), 4))
                    if pk != nil && len(pk) > 0 && !(pk == parentKey):
                        fieldKey = mirObjFieldTypeKeyGet(pk, "value")
                if len(fieldKey) > 0:
                    outKey = fieldKey
        if len(outKey) == 0 && (callName == "Value"):
            let innerKey: str = mirInferValueCallInnerKey(b, n)
            if innerKey != nil && len(innerKey) > 0:
                outKey = innerKey
        if (getEnv "CHENG_BACKEND_DEBUG_TYPEKEY_CALL" == "1") && (callName == "Value"):
            var a0k: str = ""
            if argNodes.len > 0:
                a0k = mirInferNodeTypeKeyForOverload(b, argNodes[0])
            var calleeName: str = ""
            var calleeFile: str = ""
            if callee0 != nil:
                calleeName = callee0.name
                calleeFile = callee0.originFile
            echo("[backend] debugTypeKeyCall: callName='" + callName + "' arg0Key='" + a0k +
                "' callee='" + calleeName + "' file='" + calleeFile + "' retKey='" + outKey + "'")
        if len(outKey) > 0:
            return outKey
    if n.kind == nkTupleLit:
        var tupleTy: Node = newNode(nkTupleTy, n.pos)
        for i in 0..<kidCount(n):
            var elem: Node = kid(n, i)
            if elem != nil && elem.kind == nkCallArg && kidCount(elem) > 1:
                elem = kid(elem, 1)
            var ek: str = ""
            if elem != nil && elem.typeCacheValid && elem.typeCache != nil:
                ek = typeKey elem.typeCache
            if len(ek) == 0:
                ek = "int64"
            addSon(tupleTy, newIdent(ek, n.pos))
        return typeKey(tupleTy)
    if n.kind == nkSeqLit:
        if kidCount(n) > 0:
            var elemKey: str = "int32"
            for ii in 0..<kidCount(n):
                var e: Node = kid(n, ii)
                if e != nil && e.kind == nkCallArg && kidCount(e) > 1:
                    e = kid(e, 1)
                if e != nil && e.kind == nkIntLit:
                    if e.intVal > 2147483647 || e.intVal < (-2147483647 - 1):
                        elemKey = "int64"
                elif e != nil && e.typeCacheValid && e.typeCache != nil:
                    let ek: str = typeKey e.typeCache
                    if len(ek) > 0:
                        elemKey = ek
            if len(elemKey) > 0:
                return "seq_" + elemKey
    return ""

fn caseComputeSetBits(pat0: Node): Result[int64] =
    var pat: Node = pat0
    while pat != nil && pat.kind == nkPar && kidCount(pat) > 0:
        pat = kid(pat, 0)
    if pat == nil || pat.kind != nkCurly:
        return Err[int64]("mir_builder: case set pattern expects {}")
    var bits: int64 = 0
    for i in 0..<kidCount(pat):
        var item: Node = kid(pat, i)
        while item != nil && item.kind == nkPar && kidCount(item) > 0:
            item = kid(item, 0)
        if item == nil:
            continue
        var startVal: int64 = 0
        var endVal: int64 = 0
        var hasRange: bool = false
        var exclusive: bool = false
        if item.kind == nkInfix && kidCount(item) >= 3:
            let opNode: Node = kid(item, 0)
            let op: str = backendOpName(opNode)
            if op == ".." || op == "..<":
                hasRange = true
                exclusive = op == "..<"
                let lhs: Node = kid(item, 1)
                let rhs: Node = kid(item, 2)
                if lhs == nil || lhs.kind != nkIntLit || rhs == nil || rhs.kind != nkIntLit:
                    return Err[int64]("mir_builder: case set range expects int literals")
                startVal = lhs.intVal
                endVal = rhs.intVal
        if !hasRange:
            if item.kind != nkIntLit:
                return Err[int64]("mir_builder: case set pattern expects int literals")
            startVal = item.intVal
            endVal = item.intVal
        if exclusive:
            endVal = endVal - 1
        for v in startVal..endVal:
            if v < 0 || v >= 64:
                return Err[int64]("mir_builder: case set pattern out of 0..63")
            bits = bits | (int64(1) << v)
    return Ok[int64](bits)

fn caseMatchTuplePattern(b: BlockBuilder, pat: Node, selPtr: MirExpr, selKey: str): Result[MirExpr] =
    if b == nil || b.module == nil:
        return Err[MirExpr]("mir_builder: case tuple match missing module")
    if pat == nil || pat.kind != nkTupleLit:
        return Err[MirExpr]("mir_builder: case tuple match expects tuple literal")
    var tupleObj: str = ""
    if selKey != nil && len(selKey) > 0 && mirHasObjType(b.module, selKey):
        tupleObj = selKey
    if len(tupleObj) == 0:
        var tupleTy: Node = newNode(nkTupleTy, pat.pos)
        for i in 0..<kidCount(pat):
            let elemPat: Node = kid(pat, i)
            var tyNode: Node = casePatternTypeNode(elemPat)
            if tyNode == nil || tyNode.kind == nkEmpty:
                tyNode = newIdent("int64", pat.pos)
            addSon(tupleTy, tyNode)
        tupleObj = typeNodeObjTypeName(b.module, tupleTy)
    if len(tupleObj) == 0 || !mirHasObjType(b.module, tupleObj):
        return Err[MirExpr]("mir_builder: unknown tuple object type")
    let ot: MirObjType = mirGetObjType(b.module, tupleObj)
    if ot.fields.len < kidCount(pat):
        return Err[MirExpr]("mir_builder: tuple pattern length mismatch")
    var out: MirExpr = mirConstI64(1)
    for i2 in 0..<kidCount(pat):
        let elemPat2: Node = kid(pat, i2)
        if casePatternIsWildcard(elemPat2):
            continue
        let core: Node = casePatternCore(elemPat2)
        if core != nil && (core.kind == nkIdent || core.kind == nkSymbol):
            let tn: Node = casePatternTypeNode(elemPat2)
            if tn != nil && tn.kind != nkEmpty && !(plainName(core) == "_"):
                continue
        let f: MirObjField = ot.fields[i2]
        var addr: MirExpr = selPtr
        if f.offset != 0:
            addr = mirBin(mbAdd, selPtr, mirConstI64(int64(f.offset)))
        let loaded: MirExpr = mirLoad(addr, f.ty)
        let loaded64: MirExpr = mirCast(mirTypeI64(), loaded)
        let litRes: Result[MirExpr] = lowerExprValue(b, elemPat2, mirTypeI64())
        if !IsOk[MirExpr](litRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](litRes))
        let cond: MirExpr = mirCmp(mcEq, loaded64, Value[MirExpr](litRes))
        out = mirBin(mbAnd, out, cond)
    return Ok[MirExpr](out)

fn caseMatchSeqPattern(b: BlockBuilder, pat: Node, selPtr: MirExpr, selKey: str): Result[MirExpr] =
    if b == nil || b.module == nil:
        return Err[MirExpr]("mir_builder: case seq match missing module")
    if pat == nil || pat.kind != nkSeqLit:
        return Err[MirExpr]("mir_builder: case seq match expects seq literal")
    if selKey == nil || !mirStrStartsWith(selKey, "seq_"):
        return Err[MirExpr]("mir_builder: case seq match missing selector type")
    let elemKey: str = str(ptr_add(void*(selKey), 4))
    if elemKey == nil || len(elemKey) == 0:
        return Err[MirExpr]("mir_builder: case seq match missing element type")
    let elemTypeNode: Node = newIdent(elemKey, pat.pos)
    let elemTy: MirType = mirTypeFromNodeWithModule(b.module, elemTypeNode)
    let sizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemTypeNode)
    if !IsOk[int32](sizeRes):
        return ErrInfo[MirExpr](ErrorInfoOf[int32](sizeRes))
    let elemSize: int32 = Value[int32](sizeRes)

    let seqOt: MirObjType = mirGetObjType(b.module, "seq")
    var lenOff: int32 = -1
    var bufOff: int32 = -1
    for fi in 0..<seqOt.fields.len:
        let f: MirObjField = seqOt.fields[fi]
        if (f.name == "len"):
            lenOff = f.offset
        elif (f.name == "buffer"):
            bufOff = f.offset
    if lenOff < 0 || bufOff < 0:
        return Err[MirExpr]("mir_builder: seq layout mismatch")
    let lenAddr: MirExpr = (lenOff == 0) ? selPtr : mirBin(mbAdd, selPtr, mirConstI64(int64(lenOff)))
    let bufAddr: MirExpr = (bufOff == 0) ? selPtr : mirBin(mbAdd, selPtr, mirConstI64(int64(bufOff)))
    let lenVal: MirExpr = mirLoad(lenAddr, mirTypeI32())
    let bufVal: MirExpr = mirLoad(bufAddr, mirTypeI64())

    let count: int32 = kidCount(pat)
    var out: MirExpr = mirCmp(mcEq, lenVal, mirConstI64(int64(count)))
    if count == 0:
        return Ok[MirExpr](out)
    for i in 0..<count:
        var elemNode: Node = kid(pat, i)
        if elemNode != nil && elemNode.kind == nkCallArg && kidCount(elemNode) > 1:
            elemNode = kid(elemNode, 1)
        if casePatternIsWildcard(elemNode):
            continue
        let idx64: MirExpr = mirCast(mirTypeI64(), mirConstI64(int64(i)))
        let step: MirExpr = mirConstI64(int64(elemSize))
        let off: MirExpr = (elemSize == 1) ? idx64 : mirBin(mbMul, idx64, step)
        let addr: MirExpr = (elemSize == 0) ? bufVal : mirBin(mbAdd, bufVal, off)
        let loaded: MirExpr = mirLoad(addr, elemTy)
        let loaded64: MirExpr = mirCast(mirTypeI64(), loaded)
        let litRes: Result[MirExpr] = lowerExprValue(b, elemNode, mirTypeI64())
        if !IsOk[MirExpr](litRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](litRes))
        let eqExpr: MirExpr = mirCmp(mcEq, loaded64, Value[MirExpr](litRes))
        out = mirBin(mbAnd, out, eqExpr)
    return Ok[MirExpr](out)

fn caseMatchObjPattern(b: BlockBuilder, pat: Node, selPtr: MirExpr, selKey: str): Result[MirExpr] =
    if b == nil || b.module == nil:
        return Err[MirExpr]("mir_builder: case object match missing module")
    if pat == nil || pat.kind != nkCall || kidCount(pat) == 0:
        return Err[MirExpr]("mir_builder: case object match expects call pattern")
    let callee: Node = kid(pat, 0)
    var patPlain: str = ""
    var patKey: str = ""
    var objName: str = ""
    if callee != nil:
        patPlain = backendStripSpaces(plainName(callee))
        patKey = typeKey(callee)
        objName = patKey
        if len(objName) == 0:
            objName = patPlain
    if len(objName) == 0 || !mirHasObjType(b.module, objName):
        if selKey != nil && len(selKey) > 0 && mirHasObjType(b.module, selKey):
            objName = selKey
        else:
            let line: str = intToStr(pat.pos.line)
            let col: str = intToStr(pat.pos.col)
            return Err[MirExpr]("mir_builder: case object match unknown type (pat=" + patPlain +
                                " key=" + patKey + " @" + line + ":" + col + ")")
    let ot: MirObjType = mirGetObjType(b.module, objName)
    var out: MirExpr = mirConstI64(1)
    for ai in 1..<kidCount(pat):
        let arg: Node = kid(pat, ai)
        if arg == nil:
            continue
        if arg.kind == nkCallArg && kidCount(arg) > 1:
            let nameNode: Node = kid(arg, 0)
            let valNode: Node = kid(arg, 1)
            if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol):
                let fieldName: str = backendStripSpaces(plainName(nameNode))
                var found: bool = false
                for fi in 0..<ot.fields.len:
                    let f: MirObjField = ot.fields[fi]
                    if (f.name == fieldName):
                        found = true
                        var addr: MirExpr = selPtr
                        if f.offset != 0:
                            addr = mirBin(mbAdd, selPtr, mirConstI64(int64(f.offset)))
                        let loaded: MirExpr = mirLoad(addr, f.ty)
                        let loaded64: MirExpr = mirCast(mirTypeI64(), loaded)
                        if casePatternIsWildcard(valNode):
                            break
                        let valCore: Node = casePatternCore(valNode)
                        if valCore != nil && (valCore.kind == nkIdent || valCore.kind == nkSymbol):
                            if !(plainName(valCore) == "_"):
                                # Binding subpattern: always matches.
                                break
                        let litRes: Result[MirExpr] = lowerExprValue(b, valCore, mirTypeI64())
                        if !IsOk[MirExpr](litRes):
                            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](litRes))
                        let cond: MirExpr = mirCmp(mcEq, loaded64, Value[MirExpr](litRes))
                        out = mirBin(mbAnd, out, cond)
                        break
                if !found:
                    return Err[MirExpr]("mir_builder: case object match unknown field")
        else:
            let fieldIdx: int32 = ai - 1
            if fieldIdx >= 0 && fieldIdx < ot.fields.len:
                let f: MirObjField = ot.fields[fieldIdx]
                var addr2: MirExpr = selPtr
                if f.offset != 0:
                    addr2 = mirBin(mbAdd, selPtr, mirConstI64(int64(f.offset)))
                let loaded2: MirExpr = mirLoad(addr2, f.ty)
                let loaded64_2: MirExpr = mirCast(mirTypeI64(), loaded2)
                if casePatternIsWildcard(arg):
                    continue
                let core: Node = casePatternCore(arg)
                if core != nil && (core.kind == nkIdent || core.kind == nkSymbol):
                    if !(plainName(core) == "_"):
                        # Binding subpattern: always matches.
                        continue
                let litRes2: Result[MirExpr] = lowerExprValue(b, core, mirTypeI64())
                if !IsOk[MirExpr](litRes2):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](litRes2))
                let cond2: MirExpr = mirCmp(mcEq, loaded64_2, Value[MirExpr](litRes2))
                out = mirBin(mbAnd, out, cond2)
    return Ok[MirExpr](out)

fn caseMatchPattern(b: BlockBuilder, pat0: Node, selVal: MirExpr, selKey: str): Result[MirExpr] =
    if pat0 == nil:
        return Err[MirExpr]("mir_builder: nil case pattern")
    if casePatternIsWildcard(pat0):
        return Ok[MirExpr](mirConstI64(1))
    let core: Node = casePatternCore(pat0)
    if core == nil:
        return Err[MirExpr]("mir_builder: nil case pattern")

    let typeNode: Node = casePatternTypeNode(pat0)
    if typeNode != nil && typeNode.kind != nkEmpty:
        if core.kind == nkIdent || core.kind == nkSymbol:
            if !(plainName(core) == "_"):
                # Typed binding pattern: always matches.
                return Ok[MirExpr](mirConstI64(1))

    if core.kind == nkTupleLit:
        return caseMatchTuplePattern(b, core, selVal, selKey)
    if core.kind == nkSeqLit:
        return caseMatchSeqPattern(b, core, selVal, selKey)
    if core.kind == nkCurly:
        let bitsRes: Result[int64] = caseComputeSetBits(core)
        if !IsOk[int64](bitsRes):
            return ErrInfo[MirExpr](ErrorInfoOf[int64](bitsRes))
        let bits: MirExpr = mirConstI64(Value[int64](bitsRes))
        let idx64: MirExpr = mirCast(mirTypeI64(), selVal)
        let mask: MirExpr = mirBin(mbShl, mirConstI64(1), idx64)
        return Ok[MirExpr](mirCmp(mcNe, mirBin(mbAnd, bits, mask), mirConstI64(0)))
    if core.kind == nkCall:
        return caseMatchObjPattern(b, core, selVal, selKey)
    if core.kind == nkInfix && kidCount(core) >= 3:
        let opNode: Node = kid(core, 0)
        let op: str = backendOpName(opNode)
        if op == ".." || op == "..<":
            let aRes: Result[MirExpr] = lowerExprValue(b, kid(core, 1), mirTypeI64())
            if !IsOk[MirExpr](aRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](aRes))
            let bRes: Result[MirExpr] = lowerExprValue(b, kid(core, 2), mirTypeI64())
            if !IsOk[MirExpr](bRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](bRes))
            let sel64: MirExpr = mirCast(mirTypeI64(), selVal)
            let geExpr: MirExpr = mirCmp(mcGe, sel64, Value[MirExpr](aRes))
            var hiExpr: MirExpr
            if op == "..":
                hiExpr = mirCmp(mcLe, sel64, Value[MirExpr](bRes))
            else:
                hiExpr = mirCmp(mcLt, sel64, Value[MirExpr](bRes))
            return Ok[MirExpr](mirBin(mbAnd, geExpr, hiExpr))

    # Fallback: treat pattern as a value equality check.
    let patRes: Result[MirExpr] = lowerExprValue(b, core, mirTypeI64())
    if !IsOk[MirExpr](patRes):
        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](patRes))
    let sel64: MirExpr = mirCast(mirTypeI64(), selVal)
    return Ok[MirExpr](mirCmp(mcEq, sel64, Value[MirExpr](patRes)))

fn lowerCaseAssign(b: BlockBuilder, caseNode: Node, name: str, slot: int32): Result[bool] =
    if caseNode == nil || caseNode.kind != nkCase:
        return Err[bool]("mir_builder: invalid case assign")
    if kidCount(caseNode) < 1:
        return Err[bool]("mir_builder: case expects selector")
    let slotTy: MirType = localType(b.env, slot)
    # Default to 0 so a missing else doesn't leave it uninitialized.
    add(b.currentStmts, mirStmtAssign(name, slot, mirConstI64(0)))

    let selNode: Node = kid(caseNode, 0)
    let selTy: MirType = inferExprTypeWithGlobals(b.env, b.module, b.func, selNode, mirTypeI64())
    let selRes: Result[MirExpr] = lowerExprValue(b, selNode, selTy)
    if !IsOk[MirExpr](selRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](selRes))
    let selName: str = blockBuilderNextTemp(b, "__case_sel")
    let selSlot: int32 = localAdd(b.env, selName, selTy)
    mirSetLocalType(b.func, selSlot, selTy)
    add(b.currentStmts, mirStmtLet(selName, selSlot, Value[MirExpr](selRes)))
    let selVal: MirExpr = mirLocal(selSlot)
    let selKey: str = caseInferExprTypeKey(b, selNode)

    let endLabel: str = blockBuilderNextLabel(b, "case_end")
    let firstTest: str = blockBuilderNextLabel(b, "case_test")
    blockBuilderFinish(b, mirTermBr(firstTest))
    blockBuilderStart(b, firstTest)

    for i in 1..<kidCount(caseNode):
        let br: Node = kid(caseNode, i)
        if br == nil:
            continue
        if br.kind == nkOfBranch:
            if kidCount(br) == 0:
                return Err[bool]("mir_builder: empty of-branch")
            let bodyRaw: Node = kid(br, kidCount(br) - 1)
            var bodyNode: Node = bodyRaw
            if bodyNode != nil && bodyNode.kind != nkStmtList:
                var wrap: Node = newNode(nkStmtList, bodyNode.pos)
                addSon(wrap, bodyNode)
                bodyNode = wrap
            var guardExpr: Node = nil
            var patEnd: int32 = kidCount(br) - 1
            if kidCount(br) >= 2:
                let maybeGuard: Node = kid(br, kidCount(br) - 2)
                if maybeGuard != nil && maybeGuard.kind == nkGuard && kidCount(maybeGuard) > 0:
                    guardExpr = kid(maybeGuard, 0)
                    patEnd = kidCount(br) - 2
            if patEnd <= 0:
                return Err[bool]("mir_builder: of-branch missing patterns")

            var cond: MirExpr = nil
            for pi in 0..<patEnd:
                let pat: Node = kid(br, pi)
                let condRes: Result[MirExpr] = caseMatchPattern(b, pat, selVal, selKey)
                if !IsOk[MirExpr](condRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](condRes))
                if cond == nil:
                    cond = Value[MirExpr](condRes)
                else:
                    cond = mirBin(mbOr, cond, Value[MirExpr](condRes))
            if cond == nil:
                cond = mirConstI64(0)

            let matchLabel: str = blockBuilderNextLabel(b, "case_match")
            let nextLabel: str = blockBuilderNextLabel(b, "case_next")
            blockBuilderFinish(b, mirTermCbr(cond, matchLabel, nextLabel))

            blockBuilderStart(b, matchLabel)
            # Typed binding patterns: assign selector to the bound name before evaluating guard/body.
            for bi in 0..<patEnd:
                let pat2: Node = kid(br, bi)
                let core2: Node = casePatternCore(pat2)
                let tyNode2: Node = casePatternTypeNode(pat2)
                if core2 != nil && tyNode2 != nil && tyNode2.kind != nkEmpty &&
                   (core2.kind == nkIdent || core2.kind == nkSymbol) && !(plainName(core2) == "_"):
                    let bindName: str = plainName(core2)
                    let bindTy: MirType = mirTypeFromNodeWithModule(b.module, tyNode2)
                    let bindSlot: int32 = localAdd(b.env, bindName, bindTy)
                    mirSetLocalType(b.func, bindSlot, bindTy)
                    add(b.currentStmts, mirStmtAssign(bindName, bindSlot, mirCast(bindTy, selVal)))

            if guardExpr != nil && guardExpr.kind != nkEmpty:
                let execLabel: str = blockBuilderNextLabel(b, "case_exec")
                let guardRes: Result[bool] = lowerCondBranch(b, guardExpr, execLabel, nextLabel)
                if !IsOk[bool](guardRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](guardRes))
                blockBuilderStart(b, execLabel)

            # Assign value from the last expression in the branch body.
            if bodyNode == nil || bodyNode.kind != nkStmtList || kidCount(bodyNode) == 0:
                add(b.currentStmts, mirStmtAssign(name, slot, mirConstI64(0)))
                blockBuilderFinish(b, mirTermBr(endLabel))
                blockBuilderStart(b, nextLabel)
                continue
            for si in 0..<kidCount(bodyNode):
                if si + 1 >= kidCount(bodyNode):
                    break
                let stmt: Node = kid(bodyNode, si)
                let termRes: Result[bool] = lowerStmt(b, stmt)
                if !IsOk[bool](termRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](termRes))
                if Value[bool](termRes):
                    return Ok[bool](true)
            let last: Node = kid(bodyNode, kidCount(bodyNode) - 1)
            let valRes: Result[MirExpr] = lowerExprValue(b, last, slotTy)
            if !IsOk[MirExpr](valRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes))
            add(b.currentStmts, mirStmtAssign(name, slot, mirCast(slotTy, Value[MirExpr](valRes))))
            blockBuilderFinish(b, mirTermBr(endLabel))
            blockBuilderStart(b, nextLabel)
        elif br.kind == nkElse:
            if kidCount(br) == 0:
                return Err[bool]("mir_builder: else branch missing body")
            var bodyNode2: Node = kid(br, 0)
            if bodyNode2 != nil && bodyNode2.kind != nkStmtList:
                var wrap2: Node = newNode(nkStmtList, bodyNode2.pos)
                addSon(wrap2, bodyNode2)
                bodyNode2 = wrap2
            if bodyNode2 == nil || bodyNode2.kind != nkStmtList || kidCount(bodyNode2) == 0:
                add(b.currentStmts, mirStmtAssign(name, slot, mirConstI64(0)))
            else:
                for sj in 0..<kidCount(bodyNode2):
                    if sj + 1 >= kidCount(bodyNode2):
                        break
                    let stmt2: Node = kid(bodyNode2, sj)
                    let termRes2: Result[bool] = lowerStmt(b, stmt2)
                    if !IsOk[bool](termRes2):
                        return ErrInfo[bool](ErrorInfoOf[bool](termRes2))
                    if Value[bool](termRes2):
                        return Ok[bool](true)
                let last2: Node = kid(bodyNode2, kidCount(bodyNode2) - 1)
                let valRes2: Result[MirExpr] = lowerExprValue(b, last2, slotTy)
                if !IsOk[MirExpr](valRes2):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes2))
                add(b.currentStmts, mirStmtAssign(name, slot, mirCast(slotTy, Value[MirExpr](valRes2))))
            blockBuilderFinish(b, mirTermBr(endLabel))
            blockBuilderStart(b, endLabel)
            return Ok[bool](false)

    blockBuilderFinish(b, mirTermBr(endLabel))
    blockBuilderStart(b, endLabel)
    return Ok[bool](false)

fn lowerCaseStmt(b: BlockBuilder, caseNode: Node): Result[bool] =
    if caseNode == nil || caseNode.kind != nkCase:
        return Err[bool]("mir_builder: invalid case")
    if kidCount(caseNode) < 1:
        return Err[bool]("mir_builder: case expects selector")
    let selNode: Node = kid(caseNode, 0)
    let selTy: MirType = inferExprTypeWithGlobals(b.env, b.module, b.func, selNode, mirTypeI64())
    let selRes: Result[MirExpr] = lowerExprValue(b, selNode, selTy)
    if !IsOk[MirExpr](selRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](selRes))
    let selName: str = blockBuilderNextTemp(b, "__case_sel")
    let selSlot: int32 = localAdd(b.env, selName, selTy)
    mirSetLocalType(b.func, selSlot, selTy)
    add(b.currentStmts, mirStmtLet(selName, selSlot, Value[MirExpr](selRes)))
    let selVal: MirExpr = mirLocal(selSlot)
    let selKey: str = caseInferExprTypeKey(b, selNode)

    let endLabel: str = blockBuilderNextLabel(b, "case_end")
    var needsEnd: bool = false
    var allTerminated: bool = true
    let firstTest: str = blockBuilderNextLabel(b, "case_test")
    blockBuilderFinish(b, mirTermBr(firstTest))
    blockBuilderStart(b, firstTest)

    for i in 1..<kidCount(caseNode):
        let br: Node = kid(caseNode, i)
        if br == nil:
            continue
        if br.kind == nkOfBranch:
            if kidCount(br) == 0:
                return Err[bool]("mir_builder: empty of-branch")
            let bodyRaw: Node = kid(br, kidCount(br) - 1)
            var bodyNode: Node = bodyRaw
            if bodyNode != nil && bodyNode.kind != nkStmtList:
                var wrap: Node = newNode(nkStmtList, bodyNode.pos)
                addSon(wrap, bodyNode)
                bodyNode = wrap
            var guardExpr: Node = nil
            var patEnd: int32 = kidCount(br) - 1
            if kidCount(br) >= 2:
                let maybeGuard: Node = kid(br, kidCount(br) - 2)
                if maybeGuard != nil && maybeGuard.kind == nkGuard && kidCount(maybeGuard) > 0:
                    guardExpr = kid(maybeGuard, 0)
                    patEnd = kidCount(br) - 2
            if patEnd <= 0:
                return Err[bool]("mir_builder: of-branch missing patterns")

            var cond: MirExpr = nil
            for pi in 0..<patEnd:
                let pat: Node = kid(br, pi)
                let condRes: Result[MirExpr] = caseMatchPattern(b, pat, selVal, selKey)
                if !IsOk[MirExpr](condRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](condRes))
                if cond == nil:
                    cond = Value[MirExpr](condRes)
                else:
                    cond = mirBin(mbOr, cond, Value[MirExpr](condRes))
            if cond == nil:
                cond = mirConstI64(0)

            let matchLabel: str = blockBuilderNextLabel(b, "case_match")
            let nextLabel: str = blockBuilderNextLabel(b, "case_next")
            blockBuilderFinish(b, mirTermCbr(cond, matchLabel, nextLabel))

            blockBuilderStart(b, matchLabel)
            # Typed binding patterns: assign selector to the bound name before evaluating guard/body.
            for bi in 0..<patEnd:
                let pat2: Node = kid(br, bi)
                let core2: Node = casePatternCore(pat2)
                let tyNode2: Node = casePatternTypeNode(pat2)
                if core2 != nil && tyNode2 != nil && tyNode2.kind != nkEmpty &&
                   (core2.kind == nkIdent || core2.kind == nkSymbol) && !(plainName(core2) == "_"):
                    let bindName: str = plainName(core2)
                    let bindTy: MirType = mirTypeFromNodeWithModule(b.module, tyNode2)
                    let bindSlot: int32 = localAdd(b.env, bindName, bindTy)
                    mirSetLocalType(b.func, bindSlot, bindTy)
                    add(b.currentStmts, mirStmtAssign(bindName, bindSlot, mirCast(bindTy, selVal)))

            if guardExpr != nil && guardExpr.kind != nkEmpty:
                let execLabel: str = blockBuilderNextLabel(b, "case_exec")
                let guardRes: Result[bool] = lowerCondBranch(b, guardExpr, execLabel, nextLabel)
                if !IsOk[bool](guardRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](guardRes))
                blockBuilderStart(b, execLabel)

            let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
            if !IsOk[bool](bodyTermRes):
                return ErrInfo[bool](ErrorInfoOf[bool](bodyTermRes))
            let bodyTerminated: bool = Value[bool](bodyTermRes)
            if !bodyTerminated:
                needsEnd = true
                allTerminated = false
                blockBuilderFinish(b, mirTermBr(endLabel))
            blockBuilderStart(b, nextLabel)
        elif br.kind == nkElse:
            if kidCount(br) == 0:
                return Err[bool]("mir_builder: else branch missing body")
            var bodyNode2: Node = kid(br, 0)
            if bodyNode2 != nil && bodyNode2.kind != nkStmtList:
                var wrap2: Node = newNode(nkStmtList, bodyNode2.pos)
                addSon(wrap2, bodyNode2)
                bodyNode2 = wrap2
            let elseTermRes: Result[bool] = lowerStmtList(b, bodyNode2)
            if !IsOk[bool](elseTermRes):
                return ErrInfo[bool](ErrorInfoOf[bool](elseTermRes))
            let elseTerminated: bool = Value[bool](elseTermRes)
            if !elseTerminated:
                needsEnd = true
                allTerminated = false
                blockBuilderFinish(b, mirTermBr(endLabel))
            if needsEnd:
                blockBuilderStart(b, endLabel)
                return Ok[bool](false)
            if allTerminated:
                return Ok[bool](true)
            blockBuilderStart(b, endLabel)
            return Ok[bool](false)

    # No else: fallthrough.
    blockBuilderFinish(b, mirTermBr(endLabel))
    blockBuilderStart(b, endLabel)
    return Ok[bool](false)

fn lowerDestructureSeq(b: BlockBuilder, kind: NodeKind, pat: Node, init: Node): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: seq destructure missing module")
    if pat == nil || pat.kind != nkSeqLit:
        return Err[bool]("mir_builder: seq destructure expects seq pattern")
    if init == nil || init.kind == nkEmpty:
        return Err[bool]("mir_builder: seq destructure expects init")
    let seqKey: str = caseInferExprTypeKey(b, init)
    if !mirStrStartsWith(seqKey, "seq_"):
        return Err[bool]("mir_builder: seq destructure missing element type")
    let elemKey: str = str(ptr_add(void*(seqKey), 4))
    let elemTypeNode: Node = newIdent(elemKey, pat.pos)
    let elemTy: MirType = mirTypeFromNodeWithModule(b.module, elemTypeNode)
    let sizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemTypeNode)
    if !IsOk[int32](sizeRes):
        return ErrInfo[bool](ErrorInfoOf[int32](sizeRes))
    let elemSize: int32 = Value[int32](sizeRes)

    let initRes: Result[MirExpr] = lowerExprValue(b, init, mirTypeI64())
    if !IsOk[MirExpr](initRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](initRes))
    let seqName: str = blockBuilderNextTemp(b, "__pat_seq")
    let seqSlot: int32 = localAdd(b.env, seqName, mirTypeI64())
    mirSetLocalType(b.func, seqSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(seqName, seqSlot, Value[MirExpr](initRes)))
    let seqPtr: MirExpr = mirLocal(seqSlot)

    let seqOt: MirObjType = mirGetObjType(b.module, "seq")
    var lenOff: int32 = -1
    var bufOff: int32 = -1
    for fi in 0..<seqOt.fields.len:
        let f: MirObjField = seqOt.fields[fi]
        if (f.name == "len"):
            lenOff = f.offset
        elif (f.name == "buffer"):
            bufOff = f.offset
    if lenOff < 0 || bufOff < 0:
        return Err[bool]("mir_builder: seq layout mismatch")
    let bufAddr: MirExpr = (bufOff == 0) ? seqPtr : mirBin(mbAdd, seqPtr, mirConstI64(int64(bufOff)))
    let bufVal: MirExpr = mirLoad(bufAddr, mirTypeI64())

    for i in 0..<kidCount(pat):
        var elemPat: Node = kid(pat, i)
        if elemPat != nil && elemPat.kind == nkCallArg && kidCount(elemPat) > 1:
            elemPat = kid(elemPat, 1)
        if elemPat != nil && (elemPat.kind == nkIdent || elemPat.kind == nkSymbol) && !(plainName(elemPat) == "_"):
            let nm: str = plainName(elemPat)
            let slot: int32 = localAdd(b.env, nm, elemTy)
            mirSetLocalType(b.func, slot, elemTy)
            let idx64: MirExpr = mirCast(mirTypeI64(), mirConstI64(int64(i)))
            let step: MirExpr = mirConstI64(int64(elemSize))
            let off: MirExpr = (elemSize == 1) ? idx64 : mirBin(mbMul, idx64, step)
            let addr: MirExpr = (elemSize == 0) ? bufVal : mirBin(mbAdd, bufVal, off)
            let loaded: MirExpr = mirLoad(addr, elemTy)
            if kind == nkLet:
                add(b.currentStmts, mirStmtLet(nm, slot, loaded))
            else:
                add(b.currentStmts, mirStmtVar(nm, slot, loaded))
    return Ok[bool](false)

fn tupleTypeElemTypeNode(tupleType0: Node, idx: int32): Node =
    var tupleType: Node = tupleType0
    while tupleType != nil && tupleType.kind == nkPar && kidCount(tupleType) > 0:
        tupleType = kid(tupleType, 0)
    if tupleType != nil && tupleType.kind == nkVarTy && kidCount(tupleType) > 0:
        tupleType = kid(tupleType, 0)
    if tupleType == nil || tupleType.kind != nkTupleTy:
        return nil
    if idx < 0 || idx >= kidCount(tupleType):
        return nil
    let elem: Node = kid(tupleType, idx)
    if elem != nil && elem.kind == nkIdentDefs && kidCount(elem) > 1:
        return kid(elem, 1)
    return elem

fn tupleLitElemValueNode(tupleLit0: Node, idx: int32): Node =
    var tupleLit: Node = tupleLit0
    while tupleLit != nil && tupleLit.kind == nkPar && kidCount(tupleLit) > 0:
        tupleLit = kid(tupleLit, 0)
    if tupleLit == nil || tupleLit.kind != nkTupleLit:
        return nil
    if idx < 0 || idx >= kidCount(tupleLit):
        return nil
    var elem: Node = kid(tupleLit, idx)
    if elem != nil && elem.kind == nkCallArg && kidCount(elem) > 1:
        elem = kid(elem, 1)
    elif elem != nil && elem.kind == nkCallArg && kidCount(elem) > 0:
        elem = kid(elem, 0)
    return elem

fn inferTupleTypeNodeFromTupleLitBestEffort(lit0: Node): Node =
    var lit: Node = lit0
    while lit != nil && lit.kind == nkPar && kidCount(lit) > 0:
        lit = kid(lit, 0)
    if lit == nil || lit.kind != nkTupleLit:
        return nil
    if lit.typeCacheValid && lit.typeCache != nil:
        let tc: Node = lit.typeCache
        if tc != nil && tc.kind == nkTupleTy:
            return tc
    var tupleTy: Node = newNode(nkTupleTy, lit.pos)
    for i in 0..<kidCount(lit):
        var elem: Node = kid(lit, i)
        if elem != nil && elem.kind == nkCallArg && kidCount(elem) > 1:
            elem = kid(elem, 1)
        var elemTy: Node = nil
        if elem != nil && elem.typeCacheValid && elem.typeCache != nil:
            elemTy = elem.typeCache
        if elemTy == nil || elemTy.kind == nkEmpty:
            if elem != nil && elem.kind == nkTupleLit:
                elemTy = inferTupleTypeNodeFromTupleLitBestEffort(elem)
            elif elem != nil && elem.kind == nkStrLit:
                elemTy = newIdent("str", lit.pos)
            elif elem != nil && elem.kind == nkCharLit:
                elemTy = newIdent("char", lit.pos)
            elif elem != nil && elem.kind == nkBoolLit:
                elemTy = newIdent("bool", lit.pos)
            elif elem != nil && elem.kind == nkFloatLit:
                elemTy = newIdent("float64", lit.pos)
            else:
                elemTy = newIdent("int64", lit.pos)
        addSon(tupleTy, elemTy)
    return tupleTy

fn inferTupleTypeNodeFromTuplePatternBestEffort(pat0: Node): Node =
    var pat: Node = pat0
    while pat != nil && pat.kind == nkPar && kidCount(pat) > 0:
        pat = kid(pat, 0)
    if pat == nil || pat.kind != nkTupleLit:
        return nil
    var tupleTy: Node = newNode(nkTupleTy, pat.pos)
    for i in 0..<kidCount(pat):
        let elemPat: Node = kid(pat, i)
        var elemTy: Node = casePatternTypeNode(elemPat)
        if elemTy == nil || elemTy.kind == nkEmpty:
            elemTy = newIdent("int64", pat.pos)
        addSon(tupleTy, elemTy)
    return tupleTy

fn lowerDestructureTupleFromPtr(b: BlockBuilder, kind: NodeKind, pat: Node, typeNode: Node, init: Node, tupleObj: str, tupPtr: MirExpr): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: tuple destructure missing module")
    if pat == nil || pat.kind != nkTupleLit:
        return Err[bool]("mir_builder: tuple destructure expects tuple pattern")
    var tupleObj2: str = tupleObj

    var initCore0: Node = init
    while initCore0 != nil && initCore0.kind == nkPar && kidCount(initCore0) > 0:
        initCore0 = kid(initCore0, 0)

    if len(tupleObj2) == 0 || !mirHasObjType(b.module, tupleObj2):
        var tupleType: Node = typeNode
        if tupleType == nil || tupleType.kind == nkEmpty:
            if initCore0 != nil && initCore0.typeCacheValid && initCore0.typeCache != nil:
                let tc: Node = initCore0.typeCache
                if tc != nil && tc.kind == nkTupleTy:
                    tupleType = tc
            elif initCore0 != nil && initCore0.kind == nkTupleLit:
                tupleType = inferTupleTypeNodeFromTupleLitBestEffort(initCore0)
        if tupleType == nil || tupleType.kind == nkEmpty:
            tupleType = inferTupleTypeNodeFromTuplePatternBestEffort(pat)
        if tupleType != nil && tupleType.kind != nkEmpty:
            tupleObj2 = typeNodeObjTypeName(b.module, tupleType)

    if len(tupleObj2) == 0 || !mirHasObjType(b.module, tupleObj2):
        let posNode: Node = pat
        let line: str = intToStr(posNode.pos.line)
        let col: str = intToStr(posNode.pos.col)
        let key: str = caseInferExprTypeKey(b, init)
        return Err[bool]("mir_builder: tuple destructure unknown tuple type @" + line + ":" + col + " key=" + key)
    let ot: MirObjType = mirGetObjType(b.module, tupleObj2)

    let initCore: Node = initCore0

    for i in 0..<kidCount(pat):
        if ! (i < ot.fields.len):
            break
        var elemPat0: Node = kid(pat, i)
        if elemPat0 != nil && elemPat0.kind == nkCallArg && kidCount(elemPat0) > 1:
            elemPat0 = kid(elemPat0, 1)
        let core: Node = casePatternCore(elemPat0)

        var elemTypeNode: Node = tupleTypeElemTypeNode(typeNode, i)
        let patElemTy: Node = casePatternTypeNode(elemPat0)
        if patElemTy != nil && patElemTy.kind != nkEmpty:
            elemTypeNode = patElemTy
        if (elemTypeNode == nil || elemTypeNode.kind == nkEmpty) && initCore != nil &&
           initCore.typeCacheValid && initCore.typeCache != nil:
            elemTypeNode = tupleTypeElemTypeNode(initCore.typeCache, i)

        var elemInitNode: Node = nil
        if initCore != nil && initCore.kind == nkTupleLit:
            elemInitNode = tupleLitElemValueNode(initCore, i)

        if core != nil && (core.kind == nkIdent || core.kind == nkSymbol) && !(plainName(core) == "_"):
            let f: MirObjField = ot.fields[i]
            var addr: MirExpr = tupPtr
            if f.offset != 0:
                addr = mirBin(mbAdd, tupPtr, mirConstI64(int64(f.offset)))
            let loaded: MirExpr = mirLoad(addr, f.ty)
            let nm: str = plainName(core)
            let slot: int32 = localAdd(b.env, nm, f.ty)
            mirSetLocalType(b.func, slot, f.ty)
            if kind == nkLet:
                add(b.currentStmts, mirStmtLet(nm, slot, loaded))
            else:
                add(b.currentStmts, mirStmtVar(nm, slot, loaded))
            continue

        if core != nil && (core.kind == nkIntLit || core.kind == nkBoolLit || core.kind == nkCharLit || core.kind == nkNilLit):
            let fLit: MirObjField = ot.fields[i]
            var addrLit: MirExpr = tupPtr
            if fLit.offset != 0:
                addrLit = mirBin(mbAdd, tupPtr, mirConstI64(int64(fLit.offset)))
            let loadedLit: MirExpr = mirLoad(addrLit, fLit.ty)
            let loaded64: MirExpr = mirCast(mirTypeI64(), loadedLit)
            var wantLit: MirExpr = mirConstI64(0)
            if core.kind == nkIntLit:
                wantLit = mirConstI64(core.intVal)
            elif core.kind == nkCharLit:
                if core.strVal != nil && len(core.strVal) > 0:
                    wantLit = mirConstI64(int64(core.strVal[0]))
            elif core.kind == nkBoolLit:
                let nameLit: str = backendStripSpaces(core.ident)
                wantLit = mirConstI64((nameLit == "true") ? 1 : 0)
            # nkNilLit stays 0
            let condLit: MirExpr = mirCmp(mcEq, loaded64, wantLit)
            var argsLit: MirExpr[]
            add(argsLit, condLit)
            let msgLabel: str = mirAddCString(b.module, "literal tuple pattern mismatch")
            add(argsLit, mirGlobalAddr(msgLabel))
            add(b.currentStmts, mirStmtExpr(mirCall("assert", argsLit)))
            continue

        if core != nil && core.kind == nkTupleLit:
            let f2: MirObjField = ot.fields[i]
            var addr2: MirExpr = tupPtr
            if f2.offset != 0:
                addr2 = mirBin(mbAdd, tupPtr, mirConstI64(int64(f2.offset)))
            let loaded2: MirExpr = mirLoad(addr2, f2.ty)
            let loadedPtr: MirExpr = mirCast(mirTypeI64(), loaded2)

            var innerTypeNode: Node = elemTypeNode
            if innerTypeNode == nil || innerTypeNode.kind == nkEmpty:
                if elemInitNode != nil && elemInitNode.typeCacheValid && elemInitNode.typeCache != nil:
                    let tc2: Node = elemInitNode.typeCache
                    if tc2 != nil && tc2.kind == nkTupleTy:
                        innerTypeNode = tc2
                elif elemInitNode != nil && elemInitNode.kind == nkTupleLit:
                    innerTypeNode = inferTupleTypeNodeFromTupleLitBestEffort(elemInitNode)
            if innerTypeNode == nil || innerTypeNode.kind == nkEmpty:
                innerTypeNode = inferTupleTypeNodeFromTuplePatternBestEffort(core)

            var innerObj: str = ""
            if innerTypeNode != nil && innerTypeNode.kind != nkEmpty:
                innerObj = typeNodeObjTypeName(b.module, innerTypeNode)
            if len(innerObj) == 0 && elemInitNode != nil:
                let innerKey: str = caseInferExprTypeKey(b, elemInitNode)
                if len(innerKey) > 0 && mirHasObjType(b.module, innerKey):
                    innerObj = innerKey
            if len(innerObj) == 0 || !mirHasObjType(b.module, innerObj):
                return Err[bool]("mir_builder: tuple destructure unknown inner tuple type")

            let innerName: str = blockBuilderNextTemp(b, "__pat_tup")
            let innerSlot: int32 = localAdd(b.env, innerName, mirTypeI64())
            mirSetLocalType(b.func, innerSlot, mirTypeI64())
            add(b.currentStmts, mirStmtLet(innerName, innerSlot, loadedPtr))

            let innerRes: Result[bool] = lowerDestructureTupleFromPtr(b, kind, core, innerTypeNode, elemInitNode, innerObj, mirLocal(innerSlot))
            if !IsOk[bool](innerRes):
                return innerRes
    return Ok[bool](false)

fn lowerDestructureTuple(b: BlockBuilder, kind: NodeKind, pat: Node, typeNode: Node, init: Node): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: tuple destructure missing module")
    if pat == nil || pat.kind != nkTupleLit:
        return Err[bool]("mir_builder: tuple destructure expects tuple pattern")
    if init == nil || init.kind == nkEmpty:
        return Err[bool]("mir_builder: tuple destructure expects init")
    var initCore: Node = init
    while initCore != nil && initCore.kind == nkPar && kidCount(initCore) > 0:
        initCore = kid(initCore, 0)

    var tupleType: Node = typeNode
    if tupleType == nil || tupleType.kind == nkEmpty:
        if initCore != nil && initCore.typeCacheValid && initCore.typeCache != nil:
            let tc: Node = initCore.typeCache
            if tc != nil && tc.kind == nkTupleTy:
                tupleType = tc
        elif initCore != nil && initCore.kind == nkTupleLit:
            tupleType = inferTupleTypeNodeFromTupleLitBestEffort(initCore)
    if tupleType == nil || tupleType.kind == nkEmpty:
        tupleType = inferTupleTypeNodeFromTuplePatternBestEffort(pat)

    var tupleObj: str = ""
    if tupleType != nil && tupleType.kind != nkEmpty:
        tupleObj = typeNodeObjTypeName(b.module, tupleType)
    if len(tupleObj) == 0:
        let k: str = caseInferExprTypeKey(b, initCore)
        if len(k) > 0 && mirHasObjType(b.module, k):
            tupleObj = k
    if len(tupleObj) == 0 || !mirHasObjType(b.module, tupleObj):
        let posNode: Node = pat
        let line: str = intToStr(posNode.pos.line)
        let col: str = intToStr(posNode.pos.col)
        let key: str = caseInferExprTypeKey(b, initCore)
        return Err[bool]("mir_builder: tuple destructure unknown tuple type @" + line + ":" + col + " key=" + key)

    # Stage1 may clear typeCache for tuple literals. Ensure tuple literals used as destructure init
    # are lowered with the same tuple type/layout selected for this destructure.
    var restoreTupleLitTypeCache: bool = false
    var savedTupleLitTypeCacheValid: bool = false
    var savedTupleLitTypeCache: Node = nil
    if initCore != nil && initCore.kind == nkTupleLit &&
       (!initCore.typeCacheValid || initCore.typeCache == nil) &&
       tupleType != nil && tupleType.kind != nkEmpty:
        let wantObj: str = typeNodeObjTypeName(b.module, tupleType)
        if len(wantObj) > 0 && (wantObj == tupleObj):
            restoreTupleLitTypeCache = true
            savedTupleLitTypeCacheValid = initCore.typeCacheValid
            savedTupleLitTypeCache = initCore.typeCache
            initCore.typeCacheValid = true
            initCore.typeCache = tupleType

    let initRes: Result[MirExpr] = lowerExprValue(b, init, mirTypeI64())
    if restoreTupleLitTypeCache:
        initCore.typeCacheValid = savedTupleLitTypeCacheValid
        initCore.typeCache = savedTupleLitTypeCache
    if !IsOk[MirExpr](initRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](initRes))
    let tupName: str = blockBuilderNextTemp(b, "__pat_tup")
    let tupSlot: int32 = localAdd(b.env, tupName, mirTypeI64())
    mirSetLocalType(b.func, tupSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(tupName, tupSlot, Value[MirExpr](initRes)))
    let tupPtr: MirExpr = mirLocal(tupSlot)
    return lowerDestructureTupleFromPtr(b, kind, pat, typeNode, init, tupleObj, tupPtr)

fn lowerDestructureObject(b: BlockBuilder, kind: NodeKind, pat: Node, init: Node): Result[bool] =
    if b == nil || b.module == nil:
        return Err[bool]("mir_builder: object destructure missing module")
    if pat == nil || pat.kind != nkCall || kidCount(pat) == 0:
        return Err[bool]("mir_builder: object destructure expects call pattern")
    if init == nil || init.kind == nkEmpty:
        return Err[bool]("mir_builder: object destructure expects init")
    let callee: Node = kid(pat, 0)
    var patPlain: str = ""
    var patKey: str = ""
    var objName: str = ""
    var initKey: str = ""
    if callee != nil:
        patPlain = backendStripSpaces(plainName(callee))
        patKey = typeKey(callee)
        objName = patKey
        if len(objName) == 0:
            objName = patPlain
    if len(objName) == 0 || !mirHasObjType(b.module, objName):
        initKey = caseInferExprTypeKey(b, init)
        if len(initKey) > 0 && mirHasObjType(b.module, initKey):
            objName = initKey
    if len(objName) == 0 || !mirHasObjType(b.module, objName):
        let line: str = intToStr(pat.pos.line)
        let col: str = intToStr(pat.pos.col)
        return Err[bool]("mir_builder: object destructure unknown type (pat=" + patPlain +
                         " key=" + patKey + " initKey=" + initKey + " @" + line + ":" + col + ")")
    let ot: MirObjType = mirGetObjType(b.module, objName)
    let initRes: Result[MirExpr] = lowerExprValue(b, init, mirTypeI64())
    if !IsOk[MirExpr](initRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](initRes))
    let objTmp: str = blockBuilderNextTemp(b, "__pat_obj")
    let objSlot: int32 = localAdd(b.env, objTmp, mirTypeI64())
    mirSetLocalType(b.func, objSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(objTmp, objSlot, Value[MirExpr](initRes)))
    let objPtr: MirExpr = mirLocal(objSlot)

    let debug: bool = (getEnv "CHENG_BACKEND_DEBUG_DESTRUCTURE" == "1")
    if debug:
        let line: str = intToStr(pat.pos.line)
        let col: str = intToStr(pat.pos.col)
        var msg: str = "[backend] destructure obj @" + line + ":" + col + " objName=" + objName
        msg = msg + " patPlain=" + patPlain
        msg = msg + " patKey=" + patKey
        msg = msg + " initKey=" + initKey
        msg = msg + " fields=" + intToStr(ot.fields.len)
        msg = msg + " nkCallArg=" + intToStr(int32(nkCallArg))
        echo msg

    for ai in 1..<kidCount(pat):
        let arg: Node = kid(pat, ai)
        if debug:
            let ak: str = (arg != nil) ? intToStr(int32(arg.kind)) : "nil"
            let ac: str = (arg != nil) ? intToStr(kidCount(arg)) : "0"
            let an: str = (arg != nil) ? plainName(arg) : ""
            var msg3: str = "[backend] destructure arg#" + intToStr(ai)
            msg3 = msg3 + " kind=nk#" + ak + " kids=" + ac + " name=" + an
            echo msg3
        if arg != nil:
            let fieldIdx: int32 = ai - 1
            var corePos: Node = arg
            while corePos != nil && corePos.kind == nkPar && kidCount(corePos) > 0:
                corePos = kid(corePos, 0)
            if corePos != nil && corePos.kind == nkPattern && kidCount(corePos) > 0:
                corePos = kid(corePos, 0)
            if fieldIdx >= 0 && fieldIdx < ot.fields.len &&
               corePos != nil && (corePos.kind == nkIdent || corePos.kind == nkSymbol) &&
               !(plainName(corePos) == "_"):
                let nm: str = plainName(corePos)
                let f: MirObjField = ot.fields[fieldIdx]
                var addr: MirExpr = objPtr
                if f.offset != 0:
                    addr = mirBin(mbAdd, objPtr, mirConstI64(int64(f.offset)))
                let loaded: MirExpr = mirLoad(addr, f.ty)
                let slot: int32 = localAdd(b.env, nm, f.ty)
                mirSetLocalType(b.func, slot, f.ty)
                if debug:
                    var bindMsg: str = "[backend] destructure bind " + nm + " slot=" + intToStr(slot)
                    bindMsg = bindMsg + " field=" + f.name
                    echo bindMsg
                if kind == nkLet:
                    add(b.currentStmts, mirStmtLet(nm, slot, loaded))
                else:
                    add(b.currentStmts, mirStmtVar(nm, slot, loaded))
                continue
        if arg != nil && arg.kind == nkCallArg:
            var nameNode: Node = nil
            var valNode: Node = nil
            if kidCount(arg) > 1:
                nameNode = kid(arg, 0)
                valNode = kid(arg, 1)
            elif kidCount(arg) > 0:
                valNode = kid(arg, 0)
            var fieldName: str = ""
            if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol):
                fieldName = backendStripSpaces(plainName(nameNode))
            else:
                fieldName = backendStripSpaces(plainName(arg))
            var core: Node = valNode
            while core != nil && core.kind == nkPar && kidCount(core) > 0:
                core = kid(core, 0)
            if core != nil && core.kind == nkCallArg && kidCount(core) > 1:
                core = kid(core, 1)
            if core != nil && core.kind == nkPattern && kidCount(core) > 0:
                core = kid(core, 0)
            if debug:
                let nk: str = (nameNode != nil) ? intToStr(int32(nameNode.kind)) : "nil"
                let vk: str = (valNode != nil) ? intToStr(int32(valNode.kind)) : "nil"
                let ck: str = (core != nil) ? intToStr(int32(core.kind)) : "nil"
                let nn: str = (nameNode != nil) ? plainName(nameNode) : ""
                let vn: str = (valNode != nil) ? plainName(valNode) : ""
                let cn: str = (core != nil) ? plainName(core) : ""
                var msg2: str = "[backend] destructure field nk#" + nk + " name=" + nn
                msg2 = msg2 + " val nk#" + vk + " val=" + vn
                msg2 = msg2 + " core nk#" + ck + " core=" + cn
                msg2 = msg2 + " field=" + fieldName
                echo msg2
            if len(fieldName) > 0 &&
               core != nil && (core.kind == nkIdent || core.kind == nkSymbol) && !(plainName(core) == "_"):
                for fi in 0..<ot.fields.len:
                    let f: MirObjField = ot.fields[fi]
                    if (f.name == fieldName):
                        var addr: MirExpr = objPtr
                        if f.offset != 0:
                            addr = mirBin(mbAdd, objPtr, mirConstI64(int64(f.offset)))
                        let loaded: MirExpr = mirLoad(addr, f.ty)
                        let nm: str = plainName(core)
                        let slot: int32 = localAdd(b.env, nm, f.ty)
                        mirSetLocalType(b.func, slot, f.ty)
                        if kind == nkLet:
                            add(b.currentStmts, mirStmtLet(nm, slot, loaded))
                        else:
                            add(b.currentStmts, mirStmtVar(nm, slot, loaded))
                        break
    return Ok[bool](false)

fn lowerSeqCapAssignFallback(b: BlockBuilder, lhs: Node, rhs: Node): Result[bool] =
    if b == nil || b.module == nil || b.func == nil || lhs == nil || rhs == nil:
        return Ok[bool](false)
    if lhs.kind != nkDotExpr || kidCount(lhs) < 2:
        return Ok[bool](false)
    let base: Node = kid(lhs, 0)
    let member: Node = kid(lhs, 1)
    if base == nil || member == nil || (member.kind != nkIdent && member.kind != nkSymbol):
        return Ok[bool](false)
    let memberName: str = backendStripSpaces(plainName(member))
    if !(memberName == "cap"):
        return Ok[bool](false)
    let dbgSeqCap: bool = (getEnv "CHENG_BACKEND_DEBUG_SEQ_CAP_ASSIGN" == "1")

    # Keep low-level seq internals on raw header writes.
    let fcur: MirFunc = b.func
    let fp0: str = fcur.originFile
    let fp: str = (fp0 != nil) ? fp0 : ""
    if (len(fp) > 0 && strContains(fp, "src/std/seqs.cheng")) ||
       (len(fp) > 0 && strContains(fp, "src/stage1/seqs_mono_")):
        if dbgSeqCap:
            echo("[backend] seq.cap skip internal @" + fp + ":" + intToStr(lhs.pos.line) + ":" + intToStr(lhs.pos.col))
        return Ok[bool](false)

    var baseKey: str = caseInferExprTypeKey(b, base)
    if baseKey == nil || len(baseKey) == 0:
        baseKey = exprTypeKeyShallow(b, base)
    if (baseKey == nil || len(baseKey) == 0) && (base.kind == nkIdent || base.kind == nkSymbol):
        let nm0: str = plainName(base)
        let slot0: int32 = localIndex(b.env, nm0)
        if slot0 >= 0 && b.func != nil:
            let ol0: int32 = funcFindObjLocal(b.func, slot0)
            if ol0 >= 0:
                baseKey = funcObjTypeKey(b.func, slot0)
            else:
                baseKey = localTypeKey(b.env, slot0)
        if baseKey == nil || len(baseKey) == 0:
            let g0: str = mirGlobalObjTypeGet(nm0)
            if g0 != nil && len(g0) > 0:
                baseKey = g0
        if baseKey == nil || len(baseKey) == 0:
            let g1: str = mirGlobalTypeKeyGet(nm0)
            if g1 != nil && len(g1) > 0:
                baseKey = g1
    if baseKey == nil || len(baseKey) == 0:
        return Ok[bool](false)
    if mirStrStartsWith(baseKey, "ref_"):
        baseKey = str(ptr_add(void*(baseKey), 4))
    elif mirStrStartsWith(baseKey, "var_ref_"):
        baseKey = str(ptr_add(void*(baseKey), 8))
    elif mirStrStartsWith(baseKey, "var_"):
        baseKey = str(ptr_add(void*(baseKey), 4))
    if mirStrStartsWith(baseKey, "ptr_"):
        baseKey = str(ptr_add(void*(baseKey), 4))
    if baseKey != nil && len(baseKey) > 0:
        let canon: str = mirObjAliasCanon(baseKey)
        if canon != nil && len(canon) > 0:
            baseKey = canon
    if dbgSeqCap:
        var nmDbg: str = ""
        if base != nil && (base.kind == nkIdent || base.kind == nkSymbol):
            nmDbg = plainName(base)
        echo("[backend] seq.cap probe @" + fp + ":" + intToStr(lhs.pos.line) + ":" + intToStr(lhs.pos.col) +
             " base=" + nmDbg + " key=" + baseKey)
    if !mirStrStartsWith(baseKey, "seq_") && !mirStrStartsWith(baseKey, "seq_fixed_") && !(baseKey == "seq"):
        if dbgSeqCap:
            echo("[backend] seq.cap miss non-seq key")
        return Ok[bool](false)
    if !mirHasObjType(b.module, "seq"):
        return Ok[bool](false)

    var elemKey: str = ""
    if mirStrStartsWith(baseKey, "seq_"):
        elemKey = str(ptr_add(void*(baseKey), 4))
    elif mirStrStartsWith(baseKey, "seq_fixed_"):
        elemKey = str(ptr_add(void*(baseKey), 10))
    if (elemKey == nil || len(elemKey) == 0) && base != nil && base.typeCacheValid && base.typeCache != nil:
        var t0: Node = base.typeCache
        while t0 != nil && t0.kind == nkPar && kidCount(t0) > 0:
            t0 = kid(t0, 0)
        while t0 != nil && t0.kind == nkVarTy && kidCount(t0) > 0:
            t0 = kid(t0, 0)
            while t0 != nil && t0.kind == nkPar && kidCount(t0) > 0:
                t0 = kid(t0, 0)
        if t0 != nil && t0.kind == nkBracketExpr && kidCount(t0) > 1:
            let b0: str = backendStripSpaces(plainName(kid(t0, 0)))
            if (b0 == "seq") || (b0 == "seq_fixed"):
                elemKey = typeKey(kid(t0, 1))
    if elemKey == nil || len(elemKey) == 0:
        if dbgSeqCap:
            echo("[backend] seq.cap miss elem key")
        return Ok[bool](false)

    let elemNode: Node = newIdent(elemKey, lhs.pos)
    let elemSizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemNode)
    if !IsOk[int32](elemSizeRes):
        return ErrInfo[bool](ErrorInfoOf[int32](elemSizeRes))
    let elemSize: int32 = Value[int32](elemSizeRes)
    if elemSize <= 0:
        return Err[bool]("mir_builder: seq.cap assignment unknown element size")

    let baseRes: Result[MirExpr] = lowerExprValue(b, base, mirTypeI64())
    if !IsOk[MirExpr](baseRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](baseRes))
    let baseTmp: str = blockBuilderNextTemp(b, "__seq_cap_base")
    let baseSlot: int32 = localAdd(b.env, baseTmp, mirTypeI64())
    mirSetLocalType(b.func, baseSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(baseTmp, baseSlot, Value[MirExpr](baseRes)))
    let basePtr: MirExpr = mirLocal(baseSlot)

    let newCapRes: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI32())
    if !IsOk[MirExpr](newCapRes):
        return ErrInfo[bool](ErrorInfoOf[MirExpr](newCapRes))
    let newCapTmp: str = blockBuilderNextTemp(b, "__seq_cap_new")
    let newCapSlot: int32 = localAdd(b.env, newCapTmp, mirTypeI32())
    mirSetLocalType(b.func, newCapSlot, mirTypeI32())
    add(b.currentStmts, mirStmtLet(newCapTmp, newCapSlot, Value[MirExpr](newCapRes)))
    let newCapVal: MirExpr = mirLocal(newCapSlot)

    let seqOt: MirObjType = mirGetObjType(b.module, "seq")
    var capOff: int32 = -1
    var bufOff: int32 = -1
    for fi in 0..<seqOt.fields.len:
        let f: MirObjField = seqOt.fields[fi]
        if (f.name == "cap"):
            capOff = f.offset
        elif (f.name == "buffer"):
            bufOff = f.offset
    if capOff < 0 || bufOff < 0:
        return Err[bool]("mir_builder: seq layout mismatch")

    let capAddr: MirExpr = (capOff == 0) ? basePtr : mirBin(mbAdd, basePtr, mirConstI64(int64(capOff)))
    let bufAddr: MirExpr = (bufOff == 0) ? basePtr : mirBin(mbAdd, basePtr, mirConstI64(int64(bufOff)))

    let oldCapTmp: str = blockBuilderNextTemp(b, "__seq_cap_old")
    let oldCapSlot: int32 = localAdd(b.env, oldCapTmp, mirTypeI32())
    mirSetLocalType(b.func, oldCapSlot, mirTypeI32())
    add(b.currentStmts, mirStmtLet(oldCapTmp, oldCapSlot, mirLoad(capAddr, mirTypeI32())))
    let oldCapVal: MirExpr = mirLocal(oldCapSlot)

    let oldBufTmp: str = blockBuilderNextTemp(b, "__seq_buf_old")
    let oldBufSlot: int32 = localAdd(b.env, oldBufTmp, mirTypeI64())
    mirSetLocalType(b.func, oldBufSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(oldBufTmp, oldBufSlot, mirLoad(bufAddr, mirTypeI64())))
    let oldBufVal: MirExpr = mirLocal(oldBufSlot)

    let growLabel: str = blockBuilderNextLabel(b, "seq_cap_grow")
    let hasBufLabel: str = blockBuilderNextLabel(b, "seq_cap_has_buf")
    let hasOldCapLabel: str = blockBuilderNextLabel(b, "seq_cap_has_oldcap")
    let doZeroLabel: str = blockBuilderNextLabel(b, "seq_cap_zero")
    let joinLabel: str = blockBuilderNextLabel(b, "seq_cap_join")
    let growCond: MirExpr = mirCmp(mcGt, newCapVal, oldCapVal)
    blockBuilderFinish(b, mirTermCbr(growCond, growLabel, joinLabel))

    blockBuilderStart(b, growLabel)
    add(b.currentStmts, mirStmtStore(capAddr, newCapVal, mirTypeI32()))
    let bytesTmp: str = blockBuilderNextTemp(b, "__seq_cap_bytes")
    let bytesSlot: int32 = localAdd(b.env, bytesTmp, mirTypeI64())
    mirSetLocalType(b.func, bytesSlot, mirTypeI64())
    let newCap64: MirExpr = mirCast(mirTypeI64(), newCapVal)
    let newBytes: MirExpr = mirBin(mbMul, newCap64, mirConstI64(int64(elemSize)))
    add(b.currentStmts, mirStmtLet(bytesTmp, bytesSlot, newBytes))
    let bytesVal: MirExpr = mirLocal(bytesSlot)

    var reallocArgs: MirExpr[]
    add(reallocArgs, oldBufVal)
    add(reallocArgs, bytesVal)
    let newBufTmp: str = blockBuilderNextTemp(b, "__seq_buf_new")
    let newBufSlot: int32 = localAdd(b.env, newBufTmp, mirTypeI64())
    mirSetLocalType(b.func, newBufSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(newBufTmp, newBufSlot, mirCall("realloc", reallocArgs)))
    let newBufVal: MirExpr = mirLocal(newBufSlot)
    add(b.currentStmts, mirStmtStore(bufAddr, newBufVal, mirTypeI64()))

    let hasBufCond: MirExpr = mirCmp(mcNe, newBufVal, mirConstI64(0))
    blockBuilderFinish(b, mirTermCbr(hasBufCond, hasBufLabel, joinLabel))

    blockBuilderStart(b, hasBufLabel)
    let hasOldCapCond: MirExpr = mirCmp(mcGe, oldCapVal, mirConstI64(0))
    blockBuilderFinish(b, mirTermCbr(hasOldCapCond, hasOldCapLabel, joinLabel))

    blockBuilderStart(b, hasOldCapLabel)
    let oldCap64: MirExpr = mirCast(mirTypeI64(), oldCapVal)
    let oldBytes: MirExpr = mirBin(mbMul, oldCap64, mirConstI64(int64(elemSize)))
    let needZeroCond: MirExpr = mirCmp(mcGt, bytesVal, oldBytes)
    blockBuilderFinish(b, mirTermCbr(needZeroCond, doZeroLabel, joinLabel))

    blockBuilderStart(b, doZeroLabel)
    let zeroAddr: MirExpr = mirBin(mbAdd, newBufVal, oldBytes)
    let zeroBytes: MirExpr = mirBin(mbSub, bytesVal, oldBytes)
    var zeroArgs: MirExpr[]
    add(zeroArgs, zeroAddr)
    add(zeroArgs, zeroBytes)
    add(b.currentStmts, mirStmtExpr(mirCall("zeroMem", zeroArgs)))
    blockBuilderFinish(b, mirTermBr(joinLabel))

    blockBuilderStart(b, joinLabel)
    if dbgSeqCap:
        echo("[backend] seq.cap lowered ok @" + fp + ":" + intToStr(lhs.pos.line) + ":" + intToStr(lhs.pos.col))
    return Ok[bool](true)

fn lowerStmt(b: BlockBuilder, stmt: Node): Result[bool] =
    if stmt == nil:
        return Ok[bool](false)
    case stmt.kind
    of nkLet, nkVar:
        var pat: Node = nil
        if kidCount(stmt) > 0:
            pat = kid(stmt, 0)
        var init: Node = nil
        if kidCount(stmt) > 2:
            init = kid(stmt, 2)
        var nameNode: Node = pat
        var typeNode: Node = nil
        if kidCount(stmt) > 1:
            typeNode = kid(stmt, 1)
        if pat != nil && pat.kind == nkPattern && kidCount(pat) > 0:
            nameNode = kid(pat, 0)
            if kidCount(pat) > 1:
                typeNode = kid(pat, 1)
        var nameCore: Node = nameNode
        while nameCore != nil && nameCore.kind == nkPar && kidCount(nameCore) > 0:
            nameCore = kid(nameCore, 0)
        if nameCore != nil && nameCore.kind == nkSeqLit:
            return lowerDestructureSeq(b, stmt.kind, nameCore, init)
        if nameCore != nil && nameCore.kind == nkTupleLit:
            return lowerDestructureTuple(b, stmt.kind, nameCore, typeNode, init)
        if nameCore != nil && nameCore.kind == nkCall:
            return lowerDestructureObject(b, stmt.kind, nameCore, init)
        if nameCore != nil && (nameCore.kind == nkIntLit || nameCore.kind == nkBoolLit ||
                               nameCore.kind == nkCharLit || nameCore.kind == nkNilLit):
            if init == nil || init.kind == nkEmpty:
                return Err[bool]("mir_builder: literal pattern expects init")
            let tmpName: str = blockBuilderNextTemp(b, "__pat_lit")
            let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
            mirSetLocalType(b.func, tmpSlot, mirTypeI64())
            let initRes: Result[MirExpr] = lowerExprValue(b, init, mirTypeI64())
            if !IsOk[MirExpr](initRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](initRes))
            add(b.currentStmts, mirStmtLet(tmpName, tmpSlot, Value[MirExpr](initRes)))
            var want: MirExpr = mirConstI64(0)
            if nameCore.kind == nkIntLit:
                want = mirConstI64(nameCore.intVal)
            elif nameCore.kind == nkCharLit:
                if nameCore.strVal != nil && len(nameCore.strVal) > 0:
                    want = mirConstI64(int64(nameCore.strVal[0]))
            elif nameCore.kind == nkBoolLit:
                let nameLit: str = backendStripSpaces(nameCore.ident)
                want = mirConstI64((nameLit == "true") ? 1 : 0)
            # nkNilLit stays 0
            let cond: MirExpr = mirCmp(mcEq, mirLocal(tmpSlot), want)
            var args: MirExpr[]
            add(args, cond)
            let msgLabel: str = mirAddCString(b.module, "literal pattern mismatch")
            add(args, mirGlobalAddr(msgLabel))
            add(b.currentStmts, mirStmtExpr(mirCall("assert", args)))
            return Ok[bool](false)
        if nameCore == nil ||(nameCore.kind != nkIdent && nameCore.kind != nkSymbol):
            let line: str = (nameNode != nil) ? intToStr(nameNode.pos.line) : "0"
            let col: str = (nameNode != nil) ? intToStr(nameNode.pos.col) : "0"
            return Err[bool]("mir_builder: let/var expects identifier @" + line + ":" + col)
        nameNode = nameCore
        let name: str = plainName(nameNode)
        if (getEnv "CHENG_BACKEND_DEBUG_LET" == "1") &&
           ((backendStripSpaces(name) == "snapRes") || (backendStripSpaces(name) == "tlv")):
            var fnNm: str = ""
            var fp: str = ""
            if b != nil && b.func != nil:
                let fDbg: MirFunc = b.func
                fnNm = fDbg.name
                fp = fDbg.originFile
            let initKind: str = (init != nil) ? intToStr(int32(init.kind)) : "nil"
            let tKind: str = (typeNode != nil) ? intToStr(int32(typeNode.kind)) : "nil"
            echo("[backend] debugLet: fn=" + fnNm + " file=" + fp + " name='" + name + "'" +
                 " stmtKids=" + intToStr(kidCount(stmt)) + " typeKind=nk#" + tKind + " initKind=nk#" + initKind +
                 " @" + intToStr(stmt.pos.line) + ":" + intToStr(stmt.pos.col))
        var declType: MirType = mirTypeFromNodeWithModule(b.module, typeNode)
        if typeNode == nil || typeNode.kind == nkEmpty:
            declType = inferExprTypeWithGlobals(b.env, b.module, b.func, init, declType)
        elif isAddrCall(init) && declType.kind == mtI32:
            declType = mirTypeI64()
        var objTypeName: str = typeNodeObjTypeName(b.module, typeNode)
        var isObjValue: bool = typeNodeIsObjValue(b.module, typeNode)
        if len(objTypeName) == 0 && init != nil:
            var initCore0: Node = init
            while initCore0 != nil && initCore0.kind == nkPar && kidCount(initCore0) > 0:
                initCore0 = kid(initCore0, 0)
            if initCore0 != nil && initCore0.typeCacheValid && initCore0.typeCache != nil:
                objTypeName = typeNodeObjTypeName(b.module, initCore0.typeCache)
                isObjValue = typeNodeIsObjValue(b.module, initCore0.typeCache)
            if len(objTypeName) == 0 && initCore0 != nil:
                var initKey: str = caseInferExprTypeKey(b, initCore0)
                if initKey == nil || len(initKey) == 0:
                    initKey = mirInferNodeTypeKeyForOverload(b, initCore0)
                if (initKey == nil || len(initKey) == 0) && initCore0.kind == nkCall:
                    initKey = mirInferValueCallInnerKey(b, initCore0)
                if initKey != nil && len(initKey) > 0:
                    var key3: str = initKey
                    if mirStrStartsWith(key3, "ref_"):
                        key3 = str(ptr_add(void*(key3), 4))
                    elif mirStrStartsWith(key3, "var_ref_"):
                        key3 = str(ptr_add(void*(key3), 8))
                    elif mirStrStartsWith(key3, "var_"):
                        key3 = str(ptr_add(void*(key3), 4))
                    if mirStrStartsWith(key3, "ptr_"):
                        key3 = str(ptr_add(void*(key3), 4))
                    if key3 != nil && len(key3) > 0:
                        let canon3: str = mirObjAliasCanon(key3)
                        if canon3 != nil && len(canon3) > 0:
                            key3 = canon3
                        let objFromKey3: str = mirObjTypeFromTypeKey(b.module, key3)
                        if objFromKey3 != nil && len(objFromKey3) > 0:
                            objTypeName = objFromKey3
                            let aliasTy2: MirType = mirTryGetTypeAlias(b.module, key3)
                            isObjValue = aliasTy2.kind == mtVoid
                            if objTypeName == "seq" || objTypeName == "Table":
                                isObjValue = true
        if len(objTypeName) > 0:
            declType = mirTypeI64()
        let slot: int32 = localAdd(b.env, name, declType)
        mirSetLocalType(b.func, slot, declType)
        var declKey: str = ""
        if typeNode != nil && typeNode.kind != nkEmpty:
            declKey = mirTypeKeyFromNodeLoose(typeNode)
        elif init != nil:
            var initCoreKey: Node = init
            while initCoreKey != nil && initCoreKey.kind == nkPar && kidCount(initCoreKey) > 0:
                initCoreKey = kid(initCoreKey, 0)
            if initCoreKey != nil && initCoreKey.typeCacheValid && initCoreKey.typeCache != nil:
                declKey = mirTypeKeyFromNodeLoose(initCoreKey.typeCache)
            if declKey == nil || len(declKey) == 0:
                declKey = caseInferExprTypeKey(b, initCoreKey)
            if declKey == nil || len(declKey) == 0:
                declKey = mirInferNodeTypeKeyForOverload(b, initCoreKey)
            if (declKey == nil || len(declKey) == 0) && initCoreKey != nil && initCoreKey.kind == nkCall:
                declKey = mirInferValueCallInnerKey(b, initCoreKey)
            if declKey != nil && len(declKey) > 0:
                # Normalize away `var/ref` wrappers; keep `ptr_` when present.
                if mirStrStartsWith(declKey, "ref_"):
                    declKey = str(ptr_add(void*(declKey), 4))
                elif mirStrStartsWith(declKey, "var_ref_"):
                    declKey = str(ptr_add(void*(declKey), 8))
                elif mirStrStartsWith(declKey, "var_"):
                    declKey = str(ptr_add(void*(declKey), 4))
        if declKey != nil && len(declKey) > 0:
            localSetTypeKey(b.env, slot, declKey)
        if (getEnv "CHENG_BACKEND_DEBUG_LET" == "1") && (backendStripSpaces(name) == "tlv"):
            var fnNm2: str = ""
            if b != nil && b.func != nil:
                let fDbg2: MirFunc = b.func
                fnNm2 = fDbg2.name
            let caseKeyDbg: str = caseInferExprTypeKey(b, init)
            let inferKeyDbg: str = mirInferNodeTypeKeyForOverload(b, init)
            echo("[backend] debugLetInfer: fn=" + fnNm2 + " name='" + name +
                 "' declTy=nk#" + intToStr(int32(declType.kind)) +
                 " objTypeName='" + objTypeName + "' isObjValue=" + (isObjValue ? "1" : "0") +
                 " declKey='" + declKey + "' caseKey='" + caseKeyDbg + "' inferKey='" + inferKeyDbg + "'")
        if len(objTypeName) > 0:
            if isObjValue:
                let allocRes: Result[bool] = allocObjValueLocal(b, slot, objTypeName)
                if ! IsOk[bool](allocRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](allocRes))
            else:
                funcSetObjLocal(b.func, slot, objTypeName, -1)
            var kLocal: str = declKey
            if len(kLocal) == 0:
                kLocal = objTypeName
            if objTypeName != nil && !(objTypeName == "seq") && (len(kLocal) == 0 || !mirHasObjType(b.module, kLocal)):
                kLocal = objTypeName
            if len(kLocal) > 0:
                funcSetObjTypeKey(b.func, slot, kLocal)
        if init == nil || init.kind == nkEmpty:
            if isObjValue:
                let initRes2: Result[bool] = emitObjDefaultInit(b, slot, objTypeName)
                if ! IsOk[bool](initRes2):
                    return ErrInfo[bool](ErrorInfoOf[bool](initRes2))
                let sfi: SeqFixedInit = seqFixedInitInfo(typeNode)
                if sfi.elemType != nil && sfi.capExpr != nil:
                    let seqInitRes: Result[bool] = emitSeqFixedReserveInitToPtr(b, mirLocal(slot), sfi)
                    if !IsOk[bool](seqInitRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](seqInitRes))
                return Ok[bool](false)
            if declKey == "str" || declKey == "string" || declKey == "cstring":
                let label0: str = mirAddCString(b.module, "")
                if stmt.kind == nkLet:
                    add(b.currentStmts, mirStmtLet(name, slot, mirGlobalAddr(label0)))
                else:
                    add(b.currentStmts, mirStmtVar(name, slot, mirGlobalAddr(label0)))
                return Ok[bool](false)
            if stmt.kind == nkLet:
                add(b.currentStmts, mirStmtLet(name, slot, mirConstI64(0)))
            else:
                add(b.currentStmts, mirStmtVar(name, slot, mirConstI64(0)))
            return Ok[bool](false)
        if isControlExpr(init):
            if isObjValue:
                var initCore3: Node = init
                while initCore3 != nil && initCore3.kind == nkPar && kidCount(initCore3) > 0:
                    initCore3 = kid(initCore3, 0)
                if initCore3 != nil && initCore3.kind == nkIf:
                    let ifRes: Result[bool] = lowerIfAssignObjValue(b, initCore3, name, slot)
                    if !IsOk[bool](ifRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](ifRes))
                    return Ok[bool](false)
                var fnName: str = ""
                var fp: str = ""
                if b != nil && b.func != nil:
                    let f0: MirFunc = b.func
                    fnName = f0.name
                    fp = f0.originFile
                let line: str = intToStr(stmt.pos.line)
                let col: str = intToStr(stmt.pos.col)
                return Err[bool]("mir_builder: object init via control expr not supported: " + name +
                                 " (fn=" + fnName + " " + fp + ":" + line + ":" + col + ")")
            let assignRes: Result[bool] = lowerAssignValue(b, init, name, slot)
            if ! IsOk[bool](assignRes):
                return ErrInfo[bool](ErrorInfoOf[bool](assignRes))
            return Ok[bool](false)
        if isObjValue:
            let assignRes2: Result[bool] = lowerAssignValue(b, init, name, slot)
            if ! IsOk[bool](assignRes2):
                return ErrInfo[bool](ErrorInfoOf[bool](assignRes2))
            return Ok[bool](false)
        let initRes: Result[MirExpr] = lowerExprValue(b, init, declType)
        if ! IsOk[MirExpr](initRes):
            return ErrInfo[bool](ErrorInfoOf[MirExpr](initRes))
        var initCore2: Node = init
        while initCore2 != nil && initCore2.kind == nkPar && kidCount(initCore2) > 0:
            initCore2 = kid(initCore2, 0)
        if initCore2 != nil && (initCore2.kind == nkIdent || initCore2.kind == nkSymbol):
            let initName: str = plainName(initCore2)
            if moduleHasFuncByBase(b.module, initName):
                let f1: MirFunc = moduleFindFuncByBaseUnique(b.module, initName)
                if f1 != nil:
                    localSetCallTarget(b.env, slot, f1.name)
        if stmt.kind == nkLet:
            add(b.currentStmts, mirStmtLet(name, slot, Value[MirExpr](initRes)))
        else:
            add(b.currentStmts, mirStmtVar(name, slot, Value[MirExpr](initRes)))
        return Ok[bool](false)
    of nkAsgn:
        if kidCount(stmt) < 2:
            return Err[bool]("mir_builder: assignment expects lhs/rhs")
        let lhs: Node = kid(stmt, 0)
        let rhs: Node = kid(stmt, 1)
        let seqCapAssignRes: Result[bool] = lowerSeqCapAssignFallback(b, lhs, rhs)
        if !IsOk[bool](seqCapAssignRes):
            return ErrInfo[bool](ErrorInfoOf[bool](seqCapAssignRes))
        if Value[bool](seqCapAssignRes):
            return Ok[bool](false)
        if lhs != nil && lhs.kind == nkBracketExpr:
            if kidCount(lhs) == 1:
                let addrNode: Node = kid(lhs, 0)
                let ptrKey0: str = exprTypeKeyShallow(b, addrNode)
                var elemKey0: str = ""
                if lhs.typeCacheValid && lhs.typeCache != nil:
                    elemKey0 = backendStripSpaces(typeKey lhs.typeCache)
                    if mirStrStartsWith(elemKey0, "ptr_"):
                        elemKey0 = backendStripSpaces(str(ptr_add(void*(elemKey0), 4)))
                let addrRes: Result[MirExpr] = lowerExprPtrValue(b, addrNode)
                if ! IsOk[MirExpr](addrRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](addrRes))
                if (getEnv "CHENG_BACKEND_DEBUG_DEREF_STORE" == "1") && b != nil && b.func != nil:
                    let fDbg0: MirFunc = b.func
                    let fpDbg0: str = fDbg0.originFile
                    let fpDbg1: str = (fpDbg0 != nil) ? fpDbg0 : ""
                    echo("[backend] debugBracketStore: fn=" + fDbg0.name + " @" + fpDbg1 + ":" +
                         intToStr(lhs.pos.line) + ":" + intToStr(lhs.pos.col) + " lhsKind=nk#" +
                         intToStr(int32(lhs.kind)) + " ptrKey0='" + ptrKey0 + "' elemKey0='" + elemKey0 + "'")
                if isByteTypeKey(elemKey0) || isBytePtrTypeKey(ptrKey0):
                    let valRes0: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI32())
                    if ! IsOk[MirExpr](valRes0):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes0))
                    let storeTy: MirType = byteMirTypeFromElemOrPtrKey(elemKey0, ptrKey0)
                    lowerByteStoreNilChecked(b, Value[MirExpr](addrRes), Value[MirExpr](valRes0), mirTypeI32(), storeTy)
                else:
                    if mirStrStartsWith(ptrKey0, "ptr_"):
                        let baseKey0: str = str(ptr_add(void*(ptrKey0), 4))
                        let objTypeName0: str = mirPtrBaseObjTypeName(b.module, baseKey0)
                        if objTypeName0 != nil && len(objTypeName0) > 0:
                            let aliasTy0: MirType = mirTryGetTypeAlias(b.module, objTypeName0)
                            if aliasTy0.kind == mtVoid:
                                let dstPtr: MirExpr = Value[MirExpr](addrRes)
                                var rhs0: Node = rhs
                                while rhs0 != nil && rhs0.kind == nkPar && kidCount(rhs0) > 0:
                                    rhs0 = kid(rhs0, 0)
                                if rhs0 != nil && rhs0.kind == nkCall:
                                    let callRes: Result[MirExpr] = lowerCallWithLeadingArg(b, rhs0, dstPtr)
                                    if !IsOk[MirExpr](callRes):
                                        return ErrInfo[bool](ErrorInfoOf[MirExpr](callRes))
                                    return Ok[bool](false)
                                let srcRes: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI64())
                                if !IsOk[MirExpr](srcRes):
                                    return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
                                let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName0, Value[MirExpr](srcRes))
                                if !IsOk[bool](copyRes):
                                    return ErrInfo[bool](ErrorInfoOf[bool](copyRes))
                                return Ok[bool](false)
                    let storeType: MirType = inferExprTypeWithGlobals(b.env, b.module, b.func, rhs, mirTypeI32())
                    let valRes: Result[MirExpr] = lowerExprValue(b, rhs, storeType)
                    if ! IsOk[MirExpr](valRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes))
                    add(b.currentStmts,
                                    mirStmtStore(Value[MirExpr](addrRes),
                                                 Value[MirExpr](valRes),
                                                 storeType))
                return Ok[bool](false)
            if kidCount(lhs) == 2:
                let base0: Node = kid(lhs, 0)
                var idx0: Node = kid(lhs, 1)
                while idx0 != nil && idx0.kind == nkPar && kidCount(idx0) > 0:
                    idx0 = kid(idx0, 0)

                var baseObj: str = ""
                var baseKey2: str = ""
                if base0 != nil && base0.typeCacheValid && base0.typeCache != nil:
                    baseKey2 = typeKey base0.typeCache
                    baseObj = typeNodeObjTypeName(b.module, base0.typeCache)
                if base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol):
                    let nm: str = plainName(base0)
                    let slot0: int32 = localIndex(b.env, nm)
                    if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                        baseObj = funcObjTypeName(b.func, slot0)
                        baseKey2 = funcObjTypeKey(b.func, slot0)
                    elif slot0 >= 0 && len(baseKey2) == 0:
                        baseKey2 = localTypeKey(b.env, slot0)
                    if len(baseObj) == 0:
                        let gObj0: str = mirGlobalObjTypeGet(nm)
                        if gObj0 != nil && len(gObj0) > 0:
                            baseObj = gObj0
                    if len(baseKey2) == 0:
                        let gKey0: str = mirGlobalTypeKeyGet(nm)
                        if gKey0 != nil && len(gKey0) > 0:
                            baseKey2 = gKey0

                var basePtrOverride: MirExpr = mirConstI64(0)
                var haveBasePtrOverride: bool = false
                if base0 != nil && base0.kind == nkDotExpr:
                    let daRes: Result[DotAccess] = lowerDotAccess(b, base0)
                    if IsOk[DotAccess](daRes):
                        let da: DotAccess = Value[DotAccess](daRes)
                        if da.fieldTy.kind == mtVoid && da.objTypeName != nil && len(da.objTypeName) > 0:
                            haveBasePtrOverride = true
                            basePtrOverride = da.addr
                            if len(baseObj) == 0:
                                baseObj = da.objTypeName
                            if len(baseKey2) == 0:
                                baseKey2 = da.objTypeName
                    # Some stage1 pipelines omit typeCache on dot expressions. Recover a stable
                    # generic type key (e.g. `seq_T`) so indexed assignment can be lowered as a
                    # builtin seq store instead of falling back to `[]=` overload resolution.
                    let inferredKey2: str = caseInferExprTypeKey(b, base0)
                    if inferredKey2 != nil && len(inferredKey2) > 0:
                        if mirStrStartsWith(inferredKey2, "seq_") && !mirStrStartsWith(baseKey2, "seq_"):
                            baseKey2 = inferredKey2
                        elif mirStrStartsWith(inferredKey2, "seq_fixed_") && !mirStrStartsWith(baseKey2, "seq_fixed_"):
                            baseKey2 = inferredKey2
                        elif mirStrStartsWith(inferredKey2, "Table_") && !mirStrStartsWith(baseKey2, "Table_"):
                            baseKey2 = inferredKey2
                        elif len(baseKey2) == 0:
                            baseKey2 = inferredKey2

                var objName: str = baseObj
                if len(objName) == 0:
                    objName = baseKey2
                if mirStrStartsWith(objName, "var_ref_"):
                    objName = str(ptr_add(void*(objName), 8))
                elif mirStrStartsWith(objName, "var_") || mirStrStartsWith(objName, "ref_"):
                    objName = str(ptr_add(void*(objName), 4))

                if mirStrStartsWith(objName, "array_") && b.module != nil && mirHasObjType(b.module, objName):
                    var basePtrRes: Result[MirExpr]
                    if haveBasePtrOverride:
                        basePtrRes = Ok[MirExpr](basePtrOverride)
                    else:
                        basePtrRes = lowerExprValue(b, base0, mirTypeI64())
                    if !IsOk[MirExpr](basePtrRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](basePtrRes))
                    let idxRes32: Result[MirExpr] = lowerExprValue(b, idx0, mirTypeI32())
                    if !IsOk[MirExpr](idxRes32):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](idxRes32))
                    let basePtr: MirExpr = Value[MirExpr](basePtrRes)
                    let ot: MirObjType = mirGetObjType(b.module, objName)
                    if ot.fields.len == 0:
                        return Err[bool]("mir_builder: array type has no fields: " + objName)
                    let idx32: MirExpr = Value[MirExpr](idxRes32)
                    let arrLen32: MirExpr = mirCast(mirTypeI32(), mirConstI64(int64(ot.fields.len)))
                    var bcArgs: MirExpr[]
                    add(bcArgs, arrLen32)
                    add(bcArgs, idx32)
                    add(b.currentStmts, mirStmtExpr(mirCall("cheng_bounds_check", bcArgs)))
                    let idx64: MirExpr = mirCast(mirTypeI64(), idx32)
                    let f0: MirObjField = ot.fields[0]
                    let elemTy: MirType = f0.ty
                    let elemSize: int32 = mirTypeSize(elemTy)
                    if elemSize <= 0:
                        return Err[bool]("mir_builder: array element size unsupported: " + objName)
                    var stride: int64 = int64(alignUpPow2(elemSize, mirTypeAlignPow2(elemTy)))
                    if ot.fields.len > 1:
                        let f1: MirObjField = ot.fields[1]
                        let d: int32 = f1.offset - f0.offset
                        if d > 0:
                            stride = int64(d)
                    let off: MirExpr = (stride == 1) ? idx64 : mirBin(mbMul, idx64, mirConstI64(stride))
                    let addr: MirExpr = mirBin(mbAdd, basePtr, off)
                    # `array[T]` currently uses pointer slots when `T` is an object value.
                    # Store via owned backing memory to avoid dangling stack pointers from
                    # assignments like `arr[i] = localObj`.
                    var elemObjName: str = ""
                    if rhs != nil && (rhs.kind == nkIdent || rhs.kind == nkSymbol):
                        let srcNm0: str = plainName(rhs)
                        let srcSlot0: int32 = localIndex(b.env, srcNm0)
                        if srcSlot0 >= 0 && funcFindObjLocal(b.func, srcSlot0) >= 0:
                            elemObjName = funcObjTypeName(b.func, srcSlot0)
                    if (elemObjName == nil || len(elemObjName) == 0) &&
                       rhs != nil && rhs.typeCacheValid && rhs.typeCache != nil:
                        elemObjName = typeNodeObjTypeName(b.module, rhs.typeCache)
                    if elemObjName == nil || len(elemObjName) == 0:
                        var rhsKey0: str = caseInferExprTypeKey(b, rhs)
                        if rhsKey0 == nil || len(rhsKey0) == 0:
                            rhsKey0 = exprTypeKeyShallow(b, rhs)
                        if rhsKey0 != nil && len(rhsKey0) > 0:
                            if mirStrStartsWith(rhsKey0, "var_ref_"):
                                rhsKey0 = str(ptr_add(void*(rhsKey0), 8))
                            elif mirStrStartsWith(rhsKey0, "var_") || mirStrStartsWith(rhsKey0, "ref_"):
                                rhsKey0 = str(ptr_add(void*(rhsKey0), 4))
                            if mirStrStartsWith(rhsKey0, "ptr_"):
                                rhsKey0 = str(ptr_add(void*(rhsKey0), 4))
                            elemObjName = mirObjTypeFromTypeKey(b.module, rhsKey0)
                    if elemObjName != nil && len(elemObjName) > 0 && mirHasObjType(b.module, elemObjName):
                        let srcRes0: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI64())
                        if !IsOk[MirExpr](srcRes0):
                            return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes0))
                        let otElem: MirObjType = mirGetObjType(b.module, elemObjName)
                        if otElem.size <= 0:
                            return Err[bool]("mir_builder: array object element has invalid size: " + elemObjName)
                        let oldPtr: MirExpr = mirLoad(addr, mirTypeI64())
                        var allocArgs: MirExpr[]
                        add(allocArgs, oldPtr)
                        add(allocArgs, mirConstI64(int64(otElem.size)))
                        let newPtrName: str = blockBuilderNextTemp(b, "__arr_obj_ptr")
                        let newPtrSlot: int32 = localAdd(b.env, newPtrName, mirTypeI64())
                        mirSetLocalType(b.func, newPtrSlot, mirTypeI64())
                        add(b.currentStmts, mirStmtLet(newPtrName, newPtrSlot, mirCall("realloc", allocArgs)))
                        let newPtr: MirExpr = mirLocal(newPtrSlot)
                        add(b.currentStmts, mirStmtStore(addr, newPtr, mirTypeI64()))
                        let copyLabel: str = blockBuilderNextLabel(b, "arr_obj_copy")
                        let joinLabel: str = blockBuilderNextLabel(b, "arr_obj_join")
                        let hasPtr: MirExpr = mirCmp(mcNe, newPtr, mirConstI64(0))
                        blockBuilderFinish(b, mirTermCbr(hasPtr, copyLabel, joinLabel))
                        blockBuilderStart(b, copyLabel)
                        let copyResObj: Result[bool] = emitObjCopyPtrs(b, newPtr, elemObjName, Value[MirExpr](srcRes0))
                        if !IsOk[bool](copyResObj):
                            return ErrInfo[bool](ErrorInfoOf[bool](copyResObj))
                        blockBuilderFinish(b, mirTermBr(joinLabel))
                        blockBuilderStart(b, joinLabel)
                        return Ok[bool](false)
                    let valRes: Result[MirExpr] = lowerExprValue(b, rhs, elemTy)
                    if !IsOk[MirExpr](valRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes))
                    add(b.currentStmts, mirStmtStore(addr, Value[MirExpr](valRes), elemTy))
                    return Ok[bool](false)

                # Index assignment for dynamic `seq[T]`: lower to runtime `cheng_seq_set`.
                var seqKey: str = baseKey2
                if mirStrStartsWith(seqKey, "var_ref_"):
                    seqKey = str(ptr_add(void*(seqKey), 8))
                elif mirStrStartsWith(seqKey, "var_") || mirStrStartsWith(seqKey, "ref_"):
                    seqKey = str(ptr_add(void*(seqKey), 4))
                if mirStrStartsWith(seqKey, "ptr_"):
                    seqKey = str(ptr_add(void*(seqKey), 4))
                if mirStrStartsWith(seqKey, "seq_") && b.module != nil:
                    let elemKey: str = str(ptr_add(void*(seqKey), 4))
                    if elemKey == nil || len(elemKey) == 0:
                        return Err[bool]("mir_builder: seq index store missing element type")
                    let elemTypeNode: Node = newIdent(elemKey, lhs.pos)
                    let sizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemTypeNode)
                    if !IsOk[int32](sizeRes):
                        return ErrInfo[bool](ErrorInfoOf[int32](sizeRes))
                    let elemSize: int32 = Value[int32](sizeRes)
                    let elemTy: MirType = mirTypeFromNodeWithModule(b.module, elemTypeNode)

                    var baseRes3: Result[MirExpr]
                    if haveBasePtrOverride:
                        baseRes3 = Ok[MirExpr](basePtrOverride)
                    else:
                        baseRes3 = lowerExprValue(b, base0, mirTypeI64())
                    if !IsOk[MirExpr](baseRes3):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](baseRes3))
                    let seqName: str = blockBuilderNextTemp(b, "__seq_base")
                    let seqSlot: int32 = localAdd(b.env, seqName, mirTypeI64())
                    mirSetLocalType(b.func, seqSlot, mirTypeI64())
                    add(b.currentStmts, mirStmtLet(seqName, seqSlot, Value[MirExpr](baseRes3)))
                    let seqPtr: MirExpr = mirLocal(seqSlot)

                    let idxRes3: Result[MirExpr] = lowerExprValue(b, idx0, mirTypeI32())
                    if !IsOk[MirExpr](idxRes3):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](idxRes3))
                    let elemSize32: MirExpr = mirCast(mirTypeI32(), mirConstI64(int64(elemSize)))
                    var args3: MirExpr[]
                    add(args3, seqPtr)
                    add(args3, Value[MirExpr](idxRes3))
                    add(args3, elemSize32)
                    let ptrExpr: MirExpr = mirCall("cheng_seq_set_grow", args3)
                    if (elemKey == "bool"):
                        let valResB: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI32())
                        if !IsOk[MirExpr](valResB):
                            return ErrInfo[bool](ErrorInfoOf[MirExpr](valResB))
                        lowerByteStoreNilChecked(b, ptrExpr, Value[MirExpr](valResB), mirTypeI32(), mirTypeU8())
                        return Ok[bool](false)
                    let elemObjName: str = typeNodeObjTypeName(b.module, elemTypeNode)
                    if len(elemObjName) > 0 && typeNodeIsObjValue(b.module, elemTypeNode):
                        let srcRes0: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI64())
                        if !IsOk[MirExpr](srcRes0):
                            return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes0))
                        let copyRes0: Result[bool] = emitObjCopyPtrs(b, ptrExpr, elemObjName, Value[MirExpr](srcRes0))
                        if !IsOk[bool](copyRes0):
                            return ErrInfo[bool](ErrorInfoOf[bool](copyRes0))
                        return Ok[bool](false)
                    let valRes: Result[MirExpr] = lowerExprValue(b, rhs, elemTy)
                    if !IsOk[MirExpr](valRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes))
                    add(b.currentStmts, mirStmtStore(ptrExpr, Value[MirExpr](valRes), elemTy))
                    return Ok[bool](false)
            if kidCount(lhs) == 2:
                let base1: Node = kid(lhs, 0)
                let idx1: Node = kid(lhs, 1)
                let callNode: Node = newNode(nkCall, lhs.pos)
                callNode.typeCache = lhs.typeCache
                callNode.typeCacheValid = lhs.typeCacheValid
                addSon(callNode, newIdent("[]=", lhs.pos))
                addSon(callNode, base1)
                addSon(callNode, idx1)
                addSon(callNode, rhs)
                let callRes: Result[MirExpr] = lowerExprValue(b, callNode, mirTypeI64())
                if !IsOk[MirExpr](callRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](callRes))
                add(b.currentStmts, mirStmtExpr(Value[MirExpr](callRes)))
                return Ok[bool](false)
            var fnName2: str = ""
            var fp3: str = ""
            if b != nil && b.func != nil:
                let bf2: MirFunc = b.func
                fnName2 = bf2.name
                fp3 = bf2.originFile
            let line2: str = intToStr(lhs.pos.line)
            let col2: str = intToStr(lhs.pos.col)
            return Err[bool]("mir_builder: indexed assignment not supported (fn=" + fnName2 +
                             " " + fp3 + ":" + line2 + ":" + col2 + ")")
        if lhs != nil && (lhs.kind == nkHiddenDeref || lhs.kind == nkDerefExpr) && kidCount(lhs) > 0:
            let addrNode2: Node = kid(lhs, 0)
            # Prefer local type keys for deref stores; typeCache can be incomplete for ptr locals.
            var ptrKey1: str = ""
            if addrNode2 != nil && (addrNode2.kind == nkIdent || addrNode2.kind == nkSymbol):
                let slot0: int32 = localIndex(b.env, plainName(addrNode2))
                if slot0 >= 0:
                    ptrKey1 = localTypeKey(b.env, slot0)
            if ptrKey1 == nil || len(ptrKey1) == 0:
                ptrKey1 = exprTypeKeyShallow(b, addrNode2)
            var elemKey1: str = ""
            if lhs.typeCacheValid && lhs.typeCache != nil:
                elemKey1 = backendStripSpaces(typeKey lhs.typeCache)
                if mirStrStartsWith(elemKey1, "ptr_"):
                    elemKey1 = backendStripSpaces(str(ptr_add(void*(elemKey1), 4)))
            if (getEnv "CHENG_BACKEND_DEBUG_DEREF_STORE" == "1") && b != nil && b.func != nil:
                let fDbg: MirFunc = b.func
                let fpDbg: str = fDbg.originFile
                let fpDbg2: str = (fpDbg != nil) ? fpDbg : ""
                echo("[backend] debugDerefStore: fn=" + fDbg.name + " @" + fpDbg2 + ":" +
                     intToStr(lhs.pos.line) + ":" + intToStr(lhs.pos.col) + " lhsKind=nk#" +
                     intToStr(int32(lhs.kind)) + " ptrKey1='" + ptrKey1 + "' elemKey1='" + elemKey1 + "'")
            let addrRes2: Result[MirExpr] = lowerExprPtrValue(b, addrNode2)
            if ! IsOk[MirExpr](addrRes2):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](addrRes2))
            if isByteTypeKey(elemKey1) || isBytePtrTypeKey(ptrKey1):
                let valRes2a: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI32())
                if ! IsOk[MirExpr](valRes2a):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes2a))
                let storeTy2: MirType = byteMirTypeFromElemOrPtrKey(elemKey1, ptrKey1)
                lowerByteStoreNilChecked(b, Value[MirExpr](addrRes2), Value[MirExpr](valRes2a), mirTypeI32(), storeTy2)
            else:
                var storeType2: MirType = mirTypeVoid()
                # Some stage1 pipelines may keep a bare `ptr` key without an inner type.
                # Treat it as pointer-sized to avoid truncating pointer values.
                if (ptrKey1 == "ptr"):
                    storeType2 = mirTypeI64()
                if mirStrStartsWith(ptrKey1, "ptr_"):
                    let baseKey1: str = str(ptr_add(void*(ptrKey1), 4))
                    let objTypeName1: str = mirPtrBaseObjTypeName(b.module, baseKey1)
                    if objTypeName1 != nil && len(objTypeName1) > 0:
                        let aliasTy1: MirType = mirTryGetTypeAlias(b.module, objTypeName1)
                        if aliasTy1.kind == mtVoid:
                            let dstPtr: MirExpr = Value[MirExpr](addrRes2)
                            var rhs0: Node = rhs
                            while rhs0 != nil && rhs0.kind == nkPar && kidCount(rhs0) > 0:
                                rhs0 = kid(rhs0, 0)
                            if rhs0 != nil && rhs0.kind == nkCall:
                                let callRes: Result[MirExpr] = lowerCallWithLeadingArg(b, rhs0, dstPtr)
                                if !IsOk[MirExpr](callRes):
                                    return ErrInfo[bool](ErrorInfoOf[MirExpr](callRes))
                                return Ok[bool](false)
                            let srcRes: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI64())
                            if !IsOk[MirExpr](srcRes):
                                return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
                            let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName1, Value[MirExpr](srcRes))
                            if !IsOk[bool](copyRes):
                                return ErrInfo[bool](ErrorInfoOf[bool](copyRes))
                            return Ok[bool](false)
                    if baseKey1 != nil && len(baseKey1) > 0:
                        let baseKey1Trim: str = backendStripSpaces(baseKey1)
                        if mirStrStartsWith(baseKey1Trim, "ptr_") || mirStrStartsWith(baseKey1Trim, "ref_") ||
                           mirStrStartsWith(baseKey1Trim, "var_") || mirStrStartsWith(baseKey1Trim, "var_ref_") ||
                           (baseKey1Trim == "ptr") || (baseKey1Trim == "ref") || (baseKey1Trim == "var"):
                            storeType2 = mirTypeI64()
                        else:
                            let baseTypeNode: Node = newIdent(baseKey1Trim, lhs.pos)
                            storeType2 = mirTypeFromNodeWithModule(b.module, baseTypeNode)
                            if storeType2.kind == mtVoid:
                                storeType2 = mirTypeI64()
                    else:
                        storeType2 = mirTypeI64()
                if storeType2.kind == mtVoid:
                    storeType2 = inferExprTypeWithGlobals(b.env, b.module, b.func, rhs, mirTypeI32())
                let valRes2: Result[MirExpr] = lowerExprValue(b, rhs, storeType2)
                if ! IsOk[MirExpr](valRes2):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes2))
                add(b.currentStmts,
                                mirStmtStore(Value[MirExpr](addrRes2),
                                             Value[MirExpr](valRes2),
                                             storeType2))
            return Ok[bool](false)
        if lhs != nil && lhs.kind == nkDotExpr:
            let daRes: Result[DotAccess] = lowerDotAccess(b, lhs)
            if ! IsOk[DotAccess](daRes):
                return ErrInfo[bool](ErrorInfoOf[DotAccess](daRes))
            let da: DotAccess = Value[DotAccess](daRes)
            if da.fieldTy.kind == mtVoid:
                # Composite (inlined) object field assignment: copy from rhs pointer to dst field storage.
                var objNm: str = da.objTypeName
                if rhs != nil && (rhs.kind == nkIdent || rhs.kind == nkSymbol):
                    let srcSlot0: int32 = localIndex(b.env, plainName(rhs))
                    if srcSlot0 >= 0:
                        objNm = funcObjTypeName(b.func, srcSlot0)
                if len(objNm) == 0 && rhs != nil && rhs.typeCacheValid && rhs.typeCache != nil:
                    objNm = typeNodeObjTypeName(b.module, rhs.typeCache)
                if len(objNm) == 0:
                    return Err[bool]("mir_builder: object field assignment missing type")
                let srcRes: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI64())
                if !IsOk[MirExpr](srcRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
                let copyRes: Result[bool] = emitObjCopyPtrs(b, da.addr, objNm, Value[MirExpr](srcRes))
                if !IsOk[bool](copyRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](copyRes))
                return Ok[bool](false)
            if lhs.typeCacheValid && lhs.typeCache != nil:
                let objNm: str = typeNodeObjTypeName(b.module, lhs.typeCache)
                if len(objNm) > 0 && typeNodeIsObjValue(b.module, lhs.typeCache):
                    let srcRes: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI64())
                    if !IsOk[MirExpr](srcRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
                    let copyRes: Result[bool] = emitObjCopyPtrs(b, da.addr, objNm, Value[MirExpr](srcRes))
                    if !IsOk[bool](copyRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](copyRes))
                    return Ok[bool](false)
            let valRes: Result[MirExpr] = lowerExprValue(b, rhs, da.fieldTy)
            if ! IsOk[MirExpr](valRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes))
            add(b.currentStmts, mirStmtStore(da.addr, Value[MirExpr](valRes), da.fieldTy))
            return Ok[bool](false)
        if lhs == nil ||(lhs.kind != nkIdent && lhs.kind != nkSymbol):
            let k: str = (lhs != nil) ? intToStr(int32(lhs.kind)) : "0"
            let line: str = (lhs != nil) ? intToStr(lhs.pos.line) : "0"
            let col: str = (lhs != nil) ? intToStr(lhs.pos.col) : "0"
            return Err[bool]("mir_builder: assignment expects identifier (lhs nk#" + k + " @" + line + ":" + col + ")")
        let name2: str = backendStripSpaces(plainName(lhs))
        let slot2: int32 = localIndex(b.env, name2)
        if slot2 < 0:
            let mod: MirModule = b.module
            var gName: str = name2
            var gi: int32 = moduleGlobalIndex(mod, gName)
            if gi < 0 && b.func != nil && mirDupGlobalNamesHas(name2):
                let f2: MirFunc = b.func
                let g2: str = mirMaybeMangleDupGlobalName(name2, f2.originFile)
                if g2 != nil && len(g2) > 0:
                    gName = g2
                    gi = moduleGlobalIndex(mod, gName)
            if gi < 0 && mirDupGlobalNamesHas(name2):
                let gi2: int32 = moduleFindGlobalIndexByBaseUnique(mod, name2)
                if gi2 >= 0 && gi2 < mod.globals.len:
                    let g2: MirGlobal = mod.globals[gi2]
                    if g2.name != nil && len(g2.name) > 0:
                        gName = g2.name
                        gi = gi2
            if gi < 0 && mirStrStartsWith(name2, "__cheng_"):
                var declTy: MirType = inferExprTypeWithGlobals(b.env, mod, b.func, rhs, mirTypeI32())
                if declTy.kind == mtVoid:
                    declTy = mirTypeI32()
                var originFile2: str = ""
                if b.func != nil:
                    let f2: MirFunc = b.func
                    originFile2 = f2.originFile
                mirAddGlobal(mod, name2, declTy, 0, false, originFile2)
                gName = name2
                gi = moduleGlobalIndex(mod, gName)
            if gi < 0:
                let line: str = (lhs != nil) ? intToStr(lhs.pos.line) : "0"
                let col: str = (lhs != nil) ? intToStr(lhs.pos.col) : "0"
                return Err[bool]("mir_builder: assignment to unknown local/global: " + name2 + " @" + line + ":" + col)
            let g: MirGlobal = mod.globals[gi]
            let gObj: str = mirGlobalObjTypeGet(gName)
            if len(gObj) > 0:
                let dstPtr: MirExpr = mirLoad(mirGlobalAddr(gName), mirTypeI64())
                if isControlExpr(rhs):
                    let tmpName: str = blockBuilderNextTemp(b, "__global_obj_assign")
                    let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
                    mirSetLocalType(b.func, tmpSlot, mirTypeI64())
                    localSetTypeKey(b.env, tmpSlot, gObj)
                    let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, gObj)
                    if !IsOk[bool](allocRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](allocRes))
                    let tmpRes: Result[bool] = lowerAssignValue(b, rhs, tmpName, tmpSlot)
                    if !IsOk[bool](tmpRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](tmpRes))
                    let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, gObj, mirLocal(tmpSlot))
                    if !IsOk[bool](copyRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](copyRes))
                    return Ok[bool](false)
                var rhs0: Node = rhs
                while rhs0 != nil && rhs0.kind == nkPar && kidCount(rhs0) > 0:
                    rhs0 = kid(rhs0, 0)
                if rhs0 != nil && rhs0.kind == nkCall:
                    let callRes: Result[MirExpr] = lowerCallWithLeadingArg(b, rhs0, dstPtr)
                    if !IsOk[MirExpr](callRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](callRes))
                    return Ok[bool](false)
                let srcRes: Result[MirExpr] = lowerExprValue(b, rhs, mirTypeI64())
                if !IsOk[MirExpr](srcRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
                let copyRes2: Result[bool] = emitObjCopyPtrs(b, dstPtr, gObj, Value[MirExpr](srcRes))
                if !IsOk[bool](copyRes2):
                    return ErrInfo[bool](ErrorInfoOf[bool](copyRes2))
                return Ok[bool](false)
            if isControlExpr(rhs):
                let tmpName: str = blockBuilderNextTemp(b, "__global_assign")
                let tmpSlot: int32 = localAdd(b.env, tmpName, g.ty)
                mirSetLocalType(b.func, tmpSlot, g.ty)
                let tmpRes: Result[bool] = lowerAssignValue(b, rhs, tmpName, tmpSlot)
                if !IsOk[bool](tmpRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](tmpRes))
                add(b.currentStmts, mirStmtStore(mirGlobalAddr(gName), mirLocal(tmpSlot), g.ty))
                return Ok[bool](false)
            let valRes: Result[MirExpr] = lowerExprValue(b, rhs, g.ty)
            if ! IsOk[MirExpr](valRes):
                return ErrInfo[bool](ErrorInfoOf[MirExpr](valRes))
            add(b.currentStmts, mirStmtStore(mirGlobalAddr(gName), Value[MirExpr](valRes), g.ty))
            return Ok[bool](false)

        # For object-value locals, allow a user-defined `=` overload (compile-time resolved).
        let olIdxAssign: int32 = funcFindObjLocal(b.func, slot2)
        if olIdxAssign >= 0 && b.module != nil && b.func != nil:
            let frefAssign: MirFunc = b.func
            let dstOlAssign: MirObjLocal = frefAssign.objLocals[olIdxAssign]
            if dstOlAssign.frameOff >= 0:
                let aliasTyAssign: MirType = mirTryGetTypeAlias(b.module, dstOlAssign.objTypeName)
                if aliasTyAssign.kind == mtVoid:
                    var argNodesAssign: Node[2]
                    add(argNodesAssign, lhs)
                    add(argNodesAssign, rhs)
                    var candEq: MirFunc = mirResolveCalleeFuncBestEffort(b, "=", argNodesAssign, "")
                    if candEq != nil:
                        # Assignment overloads must not require an implicit `__ret` and must take `var` as the first arg.
                        if candEq.params.len > 0:
                            let pFirst: MirParam = candEq.params[0]
                            if (pFirst.name == "__ret"):
                                candEq = nil
                        if candEq != nil && candEq.params.len > 0:
                            let p0: MirParam = candEq.params[0]
                            if !mirStrStartsWith(p0.typeKey, "var_") && !(p0.typeKey == "var"):
                                candEq = nil
                        if candEq != nil && candEq.retType.kind == mtVoid:
                            var argsEq: MirExpr[]
                            for aiEq in 0..<argNodesAssign.len:
                                let argNode: Node = argNodesAssign[aiEq]
                                var wantVarAddr: bool = false
                                if candEq != nil && aiEq >= 0 && aiEq < candEq.params.len:
                                    let pEq: MirParam = candEq.params[aiEq]
                                    if mirStrStartsWith(pEq.typeKey, "var_"):
                                        let baseKey: str = str(ptr_add(void*(pEq.typeKey), 4))
                                        if baseKey == nil || len(baseKey) == 0:
                                            wantVarAddr = true
                                        elif mirHasObjType(b.module, baseKey):
                                            # Ref-like types have an object layout but are represented as pointer aliases.
                                            # `var RefType` expects a pointer-to-pointer (i.e. take the slot address).
                                            let aliasTy0: MirType = mirTryGetTypeAlias(b.module, baseKey)
                                            wantVarAddr = aliasTy0.kind != mtVoid
                                        elif mirStrStartsWith(baseKey, "seq_") && mirHasObjType(b.module, "seq"):
                                            wantVarAddr = false
                                        else:
                                            wantVarAddr = true
                                    elif (pEq.typeKey == "var"):
                                        wantVarAddr = true
                                if wantVarAddr:
                                    let addrRes: Result[MirExpr] = lowerVarArgAddr(b, argNode)
                                    if !IsOk[MirExpr](addrRes):
                                        return ErrInfo[bool](ErrorInfoOf[MirExpr](addrRes))
                                    add(argsEq, Value[MirExpr](addrRes))
                                else:
                                    # Call argument lowering should not depend on the call's return type.
                                    let argRes: Result[MirExpr] = lowerExprValue(b, argNode, mirTypeI64())
                                    if !IsOk[MirExpr](argRes):
                                        return ErrInfo[bool](ErrorInfoOf[MirExpr](argRes))
                                    add(argsEq, Value[MirExpr](argRes))
                            add(b.currentStmts, mirStmtExpr(mirCall(candEq.name, argsEq)))
                            return Ok[bool](false)
        let rhsAssignRes: Result[bool] = lowerAssignValue(b, rhs, name2, slot2)
        if ! IsOk[bool](rhsAssignRes):
            return ErrInfo[bool](ErrorInfoOf[bool](rhsAssignRes))
        return Ok[bool](false)
    of nkReturn:
        let fref2: MirFunc = b.func
        let retType2: MirType = fref2.retType
        var exprNode: Node = nil
        if kidCount(stmt) > 0:
            exprNode = kid(stmt, 0)
        if retType2.kind == mtVoid:
            if exprNode != nil && exprNode.kind != nkEmpty:
                return Err[bool]("mir_builder: void return cannot have a value")
            let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
            if ! IsOk[bool](deferRes):
                return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
            blockBuilderFinish(b, mirTermRet(nil))
            return Ok[bool](true)
        let retSlot3: int32 = localIndex(b.env, "__ret")
        if retSlot3 >= 0:
            let objRetName: str = funcObjTypeName(fref2, retSlot3)
            if len(objRetName) > 0:
                if exprNode == nil || exprNode.kind == nkEmpty:
                    return Err[bool]("mir_builder: return expects value")
                var expr0: Node = exprNode
                while expr0 != nil && expr0.kind == nkPar && kidCount(expr0) > 0:
                    expr0 = kid(expr0, 0)
                if expr0 != nil && expr0.kind == nkSeqLit && mirStrStartsWith(funcObjTypeKey(fref2, retSlot3), "seq_"):
                    let key: str = funcObjTypeKey(fref2, retSlot3)
                    let litRes: Result[bool] = emitSeqLitToPtr(b, mirLocal(retSlot3), key, expr0)
                    if ! IsOk[bool](litRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](litRes))
                    let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                    if ! IsOk[bool](deferRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
                    blockBuilderFinish(b, mirTermRet(mirLocal(retSlot3)))
                    return Ok[bool](true)
                if expr0 != nil && expr0.kind == nkComprehension && mirStrStartsWith(funcObjTypeKey(fref2, retSlot3), "seq_"):
                    let key2: str = funcObjTypeKey(fref2, retSlot3)
                    let compRes: Result[bool] = emitSeqComprehensionToPtr(b, "__ret", mirLocal(retSlot3), key2, expr0)
                    if !IsOk[bool](compRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](compRes))
                    let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                    if ! IsOk[bool](deferRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
                    blockBuilderFinish(b, mirTermRet(mirLocal(retSlot3)))
                    return Ok[bool](true)
                if expr0 != nil && expr0.kind == nkCall:
                    let callRes: Result[MirExpr] = lowerCallWithLeadingArg(b, expr0, mirLocal(retSlot3))
                    if ! IsOk[MirExpr](callRes):
                        return ErrInfo[bool](ErrorInfoOf[MirExpr](callRes))
                    let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                    if ! IsOk[bool](deferRes):
                        return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
                    blockBuilderFinish(b, mirTermRet(Value[MirExpr](callRes)))
                    return Ok[bool](true)
                if expr0 != nil && (expr0.kind == nkIdent || expr0.kind == nkSymbol):
                    let srcName: str = plainName(expr0)
                    let srcSlot: int32 = localIndex(b.env, srcName)
                    if srcSlot >= 0:
                        let copyRes: Result[bool] = emitObjCopy(b, retSlot3, objRetName, srcSlot)
                        if ! IsOk[bool](copyRes):
                            return ErrInfo[bool](ErrorInfoOf[bool](copyRes))
                        let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                        if ! IsOk[bool](deferRes):
                            return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
                        blockBuilderFinish(b, mirTermRet(mirLocal(retSlot3)))
                        return Ok[bool](true)
                let srcRes: Result[MirExpr] = lowerExprValue(b, expr0, mirTypeI64())
                if ! IsOk[MirExpr](srcRes):
                    return ErrInfo[bool](ErrorInfoOf[MirExpr](srcRes))
                let tmpName: str = blockBuilderNextTemp(b, "__ret_src")
                let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
                mirSetLocalType(fref2, tmpSlot, mirTypeI64())
                add(b.currentStmts, mirStmtLet(tmpName, tmpSlot, Value[MirExpr](srcRes)))
                let copyRes2: Result[bool] = emitObjCopy(b, retSlot3, objRetName, tmpSlot)
                if ! IsOk[bool](copyRes2):
                    return ErrInfo[bool](ErrorInfoOf[bool](copyRes2))
                let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                if ! IsOk[bool](deferRes):
                    return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
                blockBuilderFinish(b, mirTermRet(mirLocal(retSlot3)))
                return Ok[bool](true)
        if exprNode == nil || exprNode.kind == nkEmpty:
            return Err[bool]("mir_builder: return expects value")
        if isControlExpr(exprNode):
            let retName: str = blockBuilderNextTemp(b, "__ret")
            let slot: int32 = localAdd(b.env, retName, retType2)
            mirSetLocalType(fref2, slot, retType2)
            let assignRes: Result[bool] = lowerAssignValue(b, exprNode, retName, slot)
            if ! IsOk[bool](assignRes):
                return ErrInfo[bool](ErrorInfoOf[bool](assignRes))
            let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
            if ! IsOk[bool](deferRes):
                return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
            blockBuilderFinish(b, mirTermRet(mirLocal(slot)))
            return Ok[bool](true)
        let retRes: Result[MirExpr] = lowerExprValue(b, exprNode, retType2)
        if ! IsOk[MirExpr](retRes):
            return ErrInfo[bool](ErrorInfoOf[MirExpr](retRes))
        let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
        if ! IsOk[bool](deferRes):
            return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
        blockBuilderFinish(b, mirTermRet(Value[MirExpr](retRes)))
        return Ok[bool](true)
    of nkIf:
        let ifRes: Result[bool] = lowerIfStmt(b, stmt)
        if ! IsOk[bool](ifRes):
            return ErrInfo[bool](ErrorInfoOf[bool](ifRes))
        return ifRes
    of nkWhile:
        let whileRes: Result[bool] = lowerWhileStmt(b, stmt)
        if ! IsOk[bool](whileRes):
            return ErrInfo[bool](ErrorInfoOf[bool](whileRes))
        return whileRes
    of nkFor:
        let forRes: Result[bool] = lowerForStmt(b, stmt)
        if ! IsOk[bool](forRes):
            return ErrInfo[bool](ErrorInfoOf[bool](forRes))
        return forRes
    of nkCase:
        let caseRes: Result[bool] = lowerCaseStmt(b, stmt)
        if !IsOk[bool](caseRes):
            return ErrInfo[bool](ErrorInfoOf[bool](caseRes))
        return caseRes
    of nkBreak:
        let ctx: LoopContext = blockBuilderPeekLoop(b)
        if ctx == nil:
            return Err[bool]("mir_builder: break outside loop")
        let deferRes: Result[bool] = blockBuilderEmitDefers(b, ctx.deferDepth)
        if ! IsOk[bool](deferRes):
            return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
        blockBuilderFinish(b, mirTermBr(ctx.breakLabel))
        return Ok[bool](true)
    of nkContinue:
        let ctx2: LoopContext = blockBuilderPeekLoop(b)
        if ctx2 == nil:
            return Err[bool]("mir_builder: continue outside loop")
        let deferRes: Result[bool] = blockBuilderEmitDefers(b, ctx2.deferDepth)
        if ! IsOk[bool](deferRes):
            return ErrInfo[bool](ErrorInfoOf[bool](deferRes))
        blockBuilderFinish(b, mirTermBr(ctx2.continueLabel))
        return Ok[bool](true)
    of nkDefer:
        let frame: DeferFrame = blockBuilderPeekDefer(b)
        if frame == nil:
            return Err[bool]("mir_builder: defer outside stmt list")
        if kidCount(stmt) < 1:
            return Err[bool]("mir_builder: invalid defer")
        let body: Node = kid(stmt, 0)
        if body == nil || body.kind != nkStmtList:
            return Err[bool]("mir_builder: defer expects stmt list body")
        add(frame.bodies, body)
        return Ok[bool](false)
    of nkBlock:
        if kidCount(stmt) < 2:
            return Err[bool]("mir_builder: invalid block")
        let body: Node = kid(stmt, 1)
        let blockRes: Result[bool] = lowerStmtList(b, body)
        if ! IsOk[bool](blockRes):
            return ErrInfo[bool](ErrorInfoOf[bool](blockRes))
        return blockRes
    else:
        # Expression statements discard the value; lower as pointer-sized.
        let exprRes2: Result[MirExpr] = lowerExprValue(b, stmt, mirTypeI64())
        if ! IsOk[MirExpr](exprRes2):
            return ErrInfo[bool](ErrorInfoOf[MirExpr](exprRes2))
        add(b.currentStmts, mirStmtExpr(Value[MirExpr](exprRes2)))
        return Ok[bool](false)

fn lowerStmtList(b: BlockBuilder, listNode: Node): Result[bool] =
    if listNode == nil || listNode.kind != nkStmtList:
        return Err[bool]("mir_builder: expected stmt list")
    if b != nil && b.env != nil:
        localEnvPushScope(b.env)
    blockBuilderPushDefer(b)
    for i in 0..<kidCount(listNode):
        let stmt: Node = kid(listNode, i)
        let termRes: Result[bool] = lowerStmt(b, stmt)
        if ! IsOk[bool](termRes):
            blockBuilderPopDefer(b)
            if b != nil && b.env != nil:
                localEnvPopScope(b.env)
            return ErrInfo[bool](ErrorInfoOf[bool](termRes))
        let terminated: bool = Value[bool](termRes)
        if terminated:
            # It's legal (but unreachable) to have trailing statements after a terminator.
            # Stop lowering at the first terminator.
            blockBuilderPopDefer(b)
            if b != nil && b.env != nil:
                localEnvPopScope(b.env)
            return Ok[bool](true)
    let frame: DeferFrame = blockBuilderPopDefer(b)
    if frame != nil && frame.bodies.len > 0:
        var frames: DeferFrame[1]
        add(frames, frame)
        let emitRes: Result[bool] = emitDeferFrames(b, frames)
        if ! IsOk[bool](emitRes):
            if b != nil && b.env != nil:
                localEnvPopScope(b.env)
            return ErrInfo[bool](ErrorInfoOf[bool](emitRes))
    if b != nil && b.env != nil:
        localEnvPopScope(b.env)
    return Ok[bool](false)

fn mirParseImportcAnnotation(ann: Node, hasImportc: bool*, importcLinkName: str*): bool =
    if ann == nil || ann.kind != nkAnnotation || kidCount(ann) == 0:
        return false
    let annName: str = backendStripSpaces(plainName(kid(ann, 0)))
    if annName != "importc":
        return false
    if kidCount(ann) < 2:
        return false
    let arg0: Node = kid(ann, 1)
    if arg0 == nil || arg0.kind != nkStrLit:
        return false
    if hasImportc != nil:
        *hasImportc = true
    if importcLinkName != nil:
        *importcLinkName = arg0.strVal
    return true

fn mirParseImportcLinkName(funcNode: Node, hasImportc: bool*, importcLinkName: str*) =
    if hasImportc != nil:
        *hasImportc = false
    if importcLinkName != nil:
        *importcLinkName = ""
    if funcNode == nil:
        return
    for ki in 0..<kidCount(funcNode):
        let kidNode: Node = kid(funcNode, ki)
        if kidNode != nil:
            if kidNode.kind == nkAnnotation:
                if mirParseImportcAnnotation(kidNode, hasImportc, importcLinkName):
                    return
            elif kidNode.kind == nkPragma:
                for pi in 0..<kidCount(kidNode):
                    let ann2: Node = kid(kidNode, pi)
                    if mirParseImportcAnnotation(ann2, hasImportc, importcLinkName):
                        return

fn mirBuildFuncHeader(module: MirModule, funcNode: Node, originFile: str = "",
                      overloaded: hashsets.HashSetStr* = nil): Result[MirFunc] =
    if funcNode == nil || (funcNode.kind != nkFnDecl && funcNode.kind != nkIteratorDecl):
        return Err[MirFunc]("mir_builder: invalid func node")
    let nameNode: Node = kid(funcNode, 0)
    if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
        return Err[MirFunc]("mir_builder: function name expected")
    let funcName: str = backendStripSpaces(plainName(nameNode))
    var symName: str = funcName
    var baseSym: str = backendSanitizeLinkName(symName)
    let paramsNode: Node = kid(funcNode, 1)
    let retNode: Node = kid(funcNode, 2)
    var retType: MirType = mirTypeVoid()
    if retNode != nil && retNode.kind != nkEmpty:
        retType = mirTypeFromNodeWithModule(module, retNode)
    var retTypeKey: str = ""
    if retNode != nil && retNode.kind != nkEmpty:
        retTypeKey = mirTypeKeyFromNodeLoose(retNode)
    var objRetTypeName: str = ""
    if retNode != nil && retNode.kind != nkEmpty:
        let nm: str = typeNodeObjTypeName(module, retNode)
        if len(nm) > 0 && typeNodeIsObjValue(module, retNode):
            objRetTypeName = nm
            # Object returns use an implicit `__ret` pointer.
            retType = mirTypeI64()

    var body: Node = kid(funcNode, 3)
    if body != nil && body.kind == nkBlock && kidCount(body) > 1:
        let inner: Node = kid(body, 1)
        if inner != nil && inner.kind == nkStmtList:
            body = inner
    var hasImportc: bool = false
    var importcLinkName: str = ""
    mirParseImportcLinkName(funcNode, &hasImportc, &importcLinkName)

    if !hasImportc:
        symName = mirMaybeMangleDupFnBase(funcName, originFile)
        baseSym = backendSanitizeLinkName(symName)

    var isExtern: bool = false
    if body == nil || body.kind == nkEmpty:
        if (funcName == "main"):
            return Err[MirFunc]("mir_builder: main must have a body")
        if !hasImportc:
            # Forward decl (no body, no importc). Ignore; a later definition will provide the body.
            return Ok[MirFunc](nil)
        if len(objRetTypeName) > 0:
            return Err[MirFunc]("mir_builder: extern object return is not supported: " + funcName +
                                " -> " + objRetTypeName + " (file: " + originFile + ")")
        isExtern = true

    let f: MirFunc = mirNewFunc(symName, retType)
    f.retTypeKey = retTypeKey
    f.originFile = originFile
    f.isExtern = isExtern

    var sigParamKeys: str[]
    var paramBase: int32 = 0
    if len(objRetTypeName) > 0:
        let retSlot: int32 = 0
        funcSetObjLocal(f, retSlot, objRetTypeName, -1)
        if retNode != nil && retNode.kind != nkEmpty:
            let kret: str = typeKey(retNode)
            if len(kret) > 0:
                funcSetObjTypeKey(f, retSlot, kret)
        mirAddParam(f, "__ret", retSlot, mirTypeI64(), "")
        paramBase = 1

    if paramsNode != nil && paramsNode.kind == nkFormalParams:
        for pi in 0..<kidCount(paramsNode):
            let defs: Node = kid(paramsNode, pi)
            if defs == nil || defs.kind != nkIdentDefs || kidCount(defs) < 2:
                return Err[MirFunc]("mir_builder: invalid param")
            let pnameNode: Node = kid(defs, 0)
            if pnameNode == nil || (pnameNode.kind != nkIdent && pnameNode.kind != nkSymbol):
                return Err[MirFunc]("mir_builder: param expects identifier")
            let typeNode: Node = kid(defs, 1)
            let objTypeName: str = typeNodeObjTypeName(module, typeNode)
            var ptype: MirType = mirTypeFromNodeWithModule(module, typeNode)
            if len(objTypeName) > 0:
                # Represent object values as pointers to storage in MIR.
                ptype = mirTypeI64()
            let pname: str = plainName(pnameNode)
            let slot: int32 = paramBase + pi
            let pk2: str = typeKey(typeNode)
            add(sigParamKeys, pk2)
            if len(objTypeName) > 0:
                funcSetObjLocal(f, slot, objTypeName, -1)
                if len(pk2) > 0:
                    funcSetObjTypeKey(f, slot, pk2)
            # Default args are lowered by stage1 C-profile lowering (call-site expansion).
            mirAddParam(f, pname, slot, ptype, pk2)

    if funcName != nil && !(funcName == "main") && overloaded != nil && hashsets.hashSetStrHas(*overloaded, funcName):
        f.name = mirMangleOverloadName(baseSym, retTypeKey, sigParamKeys)
        if !hasImportc:
            f.linkName = f.name
    else:
        f.name = symName
        if hasImportc:
            f.linkName = importcLinkName
        else:
            f.linkName = baseSym
    if hasImportc:
        f.linkName = importcLinkName
    return Ok[MirFunc](f)

fn mirBuildFunc(module: MirModule, funcNode: Node, originFile: str = "",
                overloaded: hashsets.HashSetStr* = nil): Result[MirFunc] =
    if funcNode == nil || (funcNode.kind != nkFnDecl && funcNode.kind != nkIteratorDecl):
        return Err[MirFunc]("mir_builder: invalid func node")
    let nameNode: Node = kid(funcNode, 0)
    if nameNode == nil ||(nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
        return Err[MirFunc]("mir_builder: function name expected")
    let funcName: str = backendStripSpaces(plainName(nameNode))
    var symName: str = funcName
    var baseSym: str = backendSanitizeLinkName(symName)
    let paramsNode: Node = kid(funcNode, 1)
    let retNode: Node = kid(funcNode, 2)
    var retType: MirType = mirTypeVoid()
    if retNode != nil && retNode.kind != nkEmpty:
        retType = mirTypeFromNodeWithModule(module, retNode)
    var retTypeKey: str = ""
    if retNode != nil && retNode.kind != nkEmpty:
        retTypeKey = typeKey(retNode)
    var objRetTypeName: str = ""
    if retNode != nil && retNode.kind != nkEmpty:
        let nm: str = typeNodeObjTypeName(module, retNode)
        if len(nm) > 0 && len(retTypeKey) > 0:
            # Type keys may include module prefixes (e.g. `json_JsonNode`) that differ from the
            # canonical object type name (`JsonNode`). Preserve var/ref/ptr wrappers for overloads.
            var aliasKey: str = retTypeKey
            var step: int32 = 0
            while aliasKey != nil && len(aliasKey) > 0 && step < 4:
                if mirStrStartsWith(aliasKey, "var_ref_"):
                    aliasKey = str(ptr_add(void*(aliasKey), 8))
                elif mirStrStartsWith(aliasKey, "var_"):
                    aliasKey = str(ptr_add(void*(aliasKey), 4))
                elif mirStrStartsWith(aliasKey, "ref_"):
                    aliasKey = str(ptr_add(void*(aliasKey), 4))
                elif mirStrStartsWith(aliasKey, "ptr_"):
                    aliasKey = str(ptr_add(void*(aliasKey), 4))
                else:
                    break
                step = step + 1
            if aliasKey != nil && len(aliasKey) > 0 && !(aliasKey == nm):
                if !mirStrStartsWith(aliasKey, "seq_") && !mirStrStartsWith(aliasKey, "seq_fixed_") &&
                   !mirStrStartsWith(aliasKey, "Table_") && !mirStrStartsWith(aliasKey, "set_"):
                    mirObjAliasPut(aliasKey, nm)
        if len(nm) > 0 && typeNodeIsObjValue(module, retNode):
            objRetTypeName = nm
            # Object returns use an implicit `__ret` pointer.
            retType = mirTypeI64()
    var body: Node = kid(funcNode, 3)
    if body != nil && body.kind == nkBlock && kidCount(body) > 1:
        let inner: Node = kid(body, 1)
        if inner != nil && inner.kind == nkStmtList:
            body = inner
    var hasImportc: bool = false
    var importcLinkName: str = ""
    mirParseImportcLinkName(funcNode, &hasImportc, &importcLinkName)
    if !hasImportc:
        symName = mirMaybeMangleDupFnBase(funcName, originFile)
        baseSym = backendSanitizeLinkName(symName)
    if body == nil || body.kind == nkEmpty:
        if (funcName == "main"):
            return Err[MirFunc]("mir_builder: main must have a body")
        if !hasImportc:
            # Forward decl (no body, no importc). Ignore; a later definition will provide the body.
            return Ok[MirFunc](nil)
        if len(objRetTypeName) > 0:
            return Err[MirFunc]("mir_builder: extern object return is not supported: " + funcName +
                                " -> " + objRetTypeName + " (file: " + originFile + ")")
        let envExtern: LocalEnv = localEnvNew()
        let fExtern: MirFunc = mirNewFunc(symName, retType)
        fExtern.retTypeKey = retTypeKey
        fExtern.originFile = originFile
        fExtern.isExtern = true
        var sigParamKeys: str[]
        if paramsNode != nil && paramsNode.kind == nkFormalParams:
            for pi in 0..<kidCount(paramsNode):
                let defs: Node = kid(paramsNode, pi)
                if defs == nil || defs.kind != nkIdentDefs || kidCount(defs) < 2:
                    return Err[MirFunc]("mir_builder: invalid param")
                let pnameNode: Node = kid(defs, 0)
                if pnameNode == nil ||(pnameNode.kind != nkIdent && pnameNode.kind != nkSymbol):
                    return Err[MirFunc]("mir_builder: param expects identifier")
                let ptype: MirType = mirTypeFromNodeWithModule(module, kid(defs, 1))
                let pname: str = plainName(pnameNode)
                let slot: int32 = localAdd(envExtern, pname, ptype)
                let pk: str = mirTypeKeyFromNodeLoose(kid(defs, 1))
                add(sigParamKeys, pk)
                if len(pk) > 0:
                    localSetTypeKey(envExtern, slot, pk)
                # Default args are lowered by stage1 C-profile lowering (call-site expansion).
                mirAddParam(fExtern, pname, slot, ptype, pk)
        if funcName != nil && !(funcName == "main") && overloaded != nil && hashsets.hashSetStrHas(*overloaded, funcName):
            fExtern.name = mirMangleOverloadName(baseSym, retTypeKey, sigParamKeys)
            if !hasImportc:
                fExtern.linkName = fExtern.name
        else:
            fExtern.name = symName
            if hasImportc:
                fExtern.linkName = importcLinkName
            else:
                fExtern.linkName = baseSym
        if hasImportc:
            fExtern.linkName = importcLinkName
        return Ok[MirFunc](fExtern)
    if body != nil && body.kind != nkStmtList:
        let wrapped: Node = newNode(nkStmtList, body.pos)
        addSon(wrapped, body)
        body = wrapped
    let env: LocalEnv = localEnvNew()
    let f: MirFunc = mirNewFunc(symName, retType)
    f.retTypeKey = retTypeKey
    f.originFile = originFile
    let bb: BlockBuilder = blockBuilderNew(env, module, f)
    var sigParamKeys2: str[]
    var paramBase: int32 = 0
    if len(objRetTypeName) > 0:
        let retSlot: int32 = localAdd(env, "__ret", mirTypeI64())
        funcSetObjLocal(f, retSlot, objRetTypeName, -1)
        if retNode != nil && retNode.kind != nkEmpty:
            let kret: str = mirTypeKeyFromNodeLoose(retNode)
            if len(kret) > 0:
                funcSetObjTypeKey(f, retSlot, kret)
        mirAddParam(f, "__ret", retSlot, mirTypeI64(), "")
        add(bb.currentStmts, mirStmtParam("__ret", retSlot, 0))
        paramBase = 1
    if paramsNode != nil && paramsNode.kind == nkFormalParams:
        for pi in 0..<kidCount(paramsNode):
            let defs: Node = kid(paramsNode, pi)
            if defs == nil || defs.kind != nkIdentDefs || kidCount(defs) < 2:
                return Err[MirFunc]("mir_builder: invalid param")
            let pnameNode: Node = kid(defs, 0)
            if pnameNode == nil ||(pnameNode.kind != nkIdent && pnameNode.kind != nkSymbol):
                return Err[MirFunc]("mir_builder: param expects identifier")
            let typeNode: Node = kid(defs, 1)
            let objTypeName: str = typeNodeObjTypeName(module, typeNode)
            var ptype: MirType = mirTypeFromNodeWithModule(module, typeNode)
            if len(objTypeName) > 0:
                # Represent object values as pointers to storage in MIR.
                ptype = mirTypeI64()
            let pname: str = plainName(pnameNode)
            let slot: int32 = localAdd(env, pname, ptype)
            let pk2: str = mirTypeKeyFromNodeLoose(typeNode)
            add(sigParamKeys2, pk2)
            if len(pk2) > 0:
                localSetTypeKey(env, slot, pk2)
            if len(objTypeName) > 0:
                if len(pk2) > 0:
                    var aliasKey2: str = pk2
                    var step2: int32 = 0
                    while aliasKey2 != nil && len(aliasKey2) > 0 && step2 < 4:
                        if mirStrStartsWith(aliasKey2, "var_ref_"):
                            aliasKey2 = str(ptr_add(void*(aliasKey2), 8))
                        elif mirStrStartsWith(aliasKey2, "var_"):
                            aliasKey2 = str(ptr_add(void*(aliasKey2), 4))
                        elif mirStrStartsWith(aliasKey2, "ref_"):
                            aliasKey2 = str(ptr_add(void*(aliasKey2), 4))
                        elif mirStrStartsWith(aliasKey2, "ptr_"):
                            aliasKey2 = str(ptr_add(void*(aliasKey2), 4))
                        else:
                            break
                        step2 = step2 + 1
                    if aliasKey2 != nil && len(aliasKey2) > 0 && !(aliasKey2 == objTypeName):
                        if !mirStrStartsWith(aliasKey2, "seq_") && !mirStrStartsWith(aliasKey2, "seq_fixed_") &&
                           !mirStrStartsWith(aliasKey2, "Table_") && !mirStrStartsWith(aliasKey2, "set_"):
                            mirObjAliasPut(aliasKey2, objTypeName)
                funcSetObjLocal(f, slot, objTypeName, -1)
                if len(pk2) > 0:
                    funcSetObjTypeKey(f, slot, pk2)
            # Default args are lowered by stage1 C-profile lowering (call-site expansion).
            mirAddParam(f, pname, slot, ptype, pk2)
            add(bb.currentStmts, mirStmtParam(pname, slot, paramBase + pi))

    if funcName != nil && !(funcName == "main") && overloaded != nil && hashsets.hashSetStrHas(*overloaded, funcName):
        f.name = mirMangleOverloadName(baseSym, retTypeKey, sigParamKeys2)
        if !hasImportc:
            f.linkName = f.name
    else:
        f.name = symName
        if hasImportc:
            f.linkName = importcLinkName
        else:
            f.linkName = baseSym
    if hasImportc:
        f.linkName = importcLinkName

    # Multi-statement function body can implicitly return its last expression.
    if body != nil && body.kind == nkStmtList && kidCount(body) > 1 && retType.kind != mtVoid:
        let lastIdx: int32 = kidCount(body) - 1
        let lastStmt: Node = kid(body, lastIdx)
        if isImplicitReturnExpr(lastStmt):
            let body2: Node = newNode(nkStmtList, body.pos)
            for si in 0..<lastIdx:
                addSon(body2, kid(body, si))
            let retStmt2: Node = newNode(nkReturn, lastStmt.pos)
            addSon(retStmt2, lastStmt)
            addSon(body2, retStmt2)
            body = body2

    # Single-expression function body can implicitly return its value.
    if body != nil && body.kind == nkStmtList && kidCount(body) == 1 && retType.kind != mtVoid:
        let onlyStmt: Node = kid(body, 0)
        if isImplicitReturnExpr(onlyStmt):
            var retStmt: Node = newNode(nkReturn, onlyStmt.pos)
            addSon(retStmt, onlyStmt)
            let termRes: Result[bool] = lowerStmt(bb, retStmt)
            if ! IsOk[bool](termRes):
                return ErrInfo[MirFunc](ErrorInfoOf[bool](termRes))
            if ! Value[bool](termRes):
                return Err[MirFunc]("mir_builder: implicit return did not terminate")
            return Ok[MirFunc](f)

    if (getEnv "CHENG_BACKEND_DEBUG_SCOPE" == "1") && (funcName == "verifyLockAgainstRegistry"):
        let bp: SourcePos = body.pos
        echo("[backend] debugFuncBody: fn=" + funcName + " bodyKind=nk#" + intToStr(int32(body.kind)) +
             " kids=" + intToStr(kidCount(body)) + " @" + intToStr(bp.line) + ":" + intToStr(bp.col))
        for di2 in 0..<kidCount(body):
            let st2: Node = kid(body, di2)
            let k2: str = (st2 != nil) ? intToStr(int32(st2.kind)) : "nil"
            let l2: str = (st2 != nil) ? intToStr(st2.pos.line) : "0"
            let c2: str = (st2 != nil) ? intToStr(st2.pos.col) : "0"
            echo("[backend] debugFuncStmt: i=" + intToStr(di2) + " kind=nk#" + k2 + " @" + l2 + ":" + c2)

    let bodyRes: Result[bool] = lowerStmtList(bb, body)
    if ! IsOk[bool](bodyRes):
        return ErrInfo[MirFunc](ErrorInfoOf[bool](bodyRes))
    let terminated: bool = Value[bool](bodyRes)
    if ! terminated && retType.kind == mtVoid:
        blockBuilderFinish(bb, mirTermRet(nil))
        return Ok[MirFunc](f)
    if ! terminated:
        let line: str = intToStr(nameNode.pos.line)
        let col: str = intToStr(nameNode.pos.col)
        let loc: str = (originFile != nil && len(originFile) > 0) ? (" " + originFile + ":" + line + ":" + col) : ""
        return Err[MirFunc]("mir_builder: missing return: " + funcName + loc)
    return Ok[MirFunc](f)

fn mirFindMain(root: Node): Node =
    if root == nil:
        return nil
    for i in 0..<kidCount(root):
        let n: Node = kid(root, i)
        if n != nil && n.kind == nkFnDecl:
            let nameNode: Node = kid(n, 0)
            if plainName(nameNode) == "main":
                return n
    return nil

fn seqContainsStr(xs: str[], s: str): bool =
    if s == nil || xs.buffer == nil:
        return false
    for i in 0..<xs.len:
        if (xs[i] == s):
            return true
    return false

fn mir_buildFuncIndexCache(mod: MirModule) =
    if mod == nil:
        mir_funcIndex_cache_module = nil
        mir_funcIndex_cache_ready = false
        mir_funcIndex_cache_len = 0
        return
    mir_funcIndex_cache_module = mod
    mir_funcIndex_cache = hashmaps.hashMapStrIntInit(mod.funcs.len * 2 + 8)
    for i in 0..<mod.funcs.len:
        let f: MirFunc = mod.funcs[i]
        if f != nil && f.name != nil && len(f.name) > 0:
            hashmaps.hashMapStrIntPut(mir_funcIndex_cache, f.name, i)
    mir_funcIndex_cache_len = mod.funcs.len
    mir_funcIndex_cache_ready = true

fn mir_ensureFuncIndexCache(mod: MirModule) =
    if mod == nil:
        mir_funcIndex_cache_module = nil
        mir_funcIndex_cache_ready = false
        mir_funcIndex_cache_len = 0
        return
    if mod.funcs.len < 32:
        return
    if mir_funcIndex_cache_module != mod || !mir_funcIndex_cache_ready:
        mir_buildFuncIndexCache(mod)
        return
    if mir_funcIndex_cache_len > mod.funcs.len:
        mir_buildFuncIndexCache(mod)
        return
    if mir_funcIndex_cache_len < mod.funcs.len:
        for i in mir_funcIndex_cache_len..<mod.funcs.len:
            let f: MirFunc = mod.funcs[i]
            if f != nil && f.name != nil && len(f.name) > 0:
                hashmaps.hashMapStrIntPut(mir_funcIndex_cache, f.name, i)
        mir_funcIndex_cache_len = mod.funcs.len

fn moduleFuncIndex(mod: MirModule, name: str): int32 =
    if mod == nil || name == nil:
        return -1
    if mod.funcs.len >= 32:
        mir_ensureFuncIndexCache(mod)
        if mir_funcIndex_cache_ready && mir_funcIndex_cache_module == mod:
            var found: bool = false
            let idx: int32 = mirHashMapStrIntGetCompat(mir_funcIndex_cache, name, found)
            if !found:
                return -1
            if idx >= 0 && idx < mod.funcs.len:
                let f0: MirFunc = mod.funcs[idx]
                if f0 != nil && (f0.name == name):
                    return idx
            # Cache mismatch (unexpected): fall back to linear scan.
    for i in 0..<mod.funcs.len:
        let f: MirFunc = mod.funcs[i]
        if f != nil && (f.name == name):
            return i
    return -1

fn moduleHasFunc(mod: MirModule, name: str): bool =
    return moduleFuncIndex(mod, name) >= 0

fn moduleFindFunc(mod: MirModule, name: str): MirFunc =
    let idx: int32 = moduleFuncIndex(mod, name)
    if idx >= 0 && mod != nil && idx < mod.funcs.len:
        return mod.funcs[idx]
    return nil

fn mirTypeKeyIsVarargs(typeKey: str): bool =
    if typeKey == nil || len(typeKey) == 0:
        return false
    if (typeKey == "varargs"):
        return true
    return mirStrStartsWith(typeKey, "varargs_")

fn moduleHasFuncByBase(mod: MirModule, base0: str): bool =
    if mod == nil || base0 == nil || len(base0) == 0:
        return false
    if moduleHasFunc(mod, base0):
        return true
    let baseSym: str = backendSanitizeLinkName(base0)
    let prefix: str = baseSym + mirFuncSigMarker()
    let dupPrefix: str = baseSym + "__cheng_mod_"
    let instPrefix: str = baseSym + "_"
    for i in 0..<mod.funcs.len:
        let f: MirFunc = mod.funcs[i]
        if f != nil && ((f.name == base0) ||
                        mirStrStartsWith(f.name, prefix) ||
                        mirStrStartsWith(f.name, dupPrefix) ||
                        mirStrStartsWith(f.name, instPrefix)):
            return true
    return false

fn moduleFindGlobalIndexByBaseUnique(mod: MirModule, base0: str): int32 =
    if mod == nil || base0 == nil || len(base0) == 0:
        return -1
    let exactIdx: int32 = moduleGlobalIndex(mod, base0)
    if exactIdx >= 0 && exactIdx < mod.globals.len:
        return exactIdx
    let dupPrefix: str = base0 + "__cheng_mod_"
    var foundIdx: int32 = -1
    for i in 0..<mod.globals.len:
        let g: MirGlobal = mod.globals[i]
        if g.name == nil || len(g.name) == 0:
            continue
        if mirStrStartsWith(g.name, dupPrefix):
            if foundIdx >= 0:
                return -1
            foundIdx = i
    return foundIdx

fn mirGlobalTypeKeyByBaseUnique(mod: MirModule, base0: str): str =
    if base0 == nil || len(base0) == 0:
        return ""
    let idx: int32 = moduleFindGlobalIndexByBaseUnique(mod, base0)
    if idx >= 0 && idx < mod.globals.len:
        let g: MirGlobal = mod.globals[idx]
        if g.name != nil && len(g.name) > 0:
            let gk1: str = mirGlobalTypeKeyGet(g.name)
            if gk1 != nil && len(gk1) > 0:
                return gk1
    let gk0: str = mirGlobalTypeKeyGet(base0)
    if gk0 != nil && len(gk0) > 0:
        return gk0
    return ""

fn moduleFindFuncByBaseUnique(mod: MirModule, base0: str): MirFunc =
    if mod == nil || base0 == nil || len(base0) == 0:
        return nil
    let exact: MirFunc = moduleFindFunc(mod, base0)
    if exact != nil:
        return exact
    let baseSym: str = backendSanitizeLinkName(base0)
    let prefix: str = baseSym + mirFuncSigMarker()
    let dupPrefix: str = baseSym + "__cheng_mod_"
    let instPrefix: str = baseSym + "_"
    var found: MirFunc = nil
    for i in 0..<mod.funcs.len:
        let f: MirFunc = mod.funcs[i]
        if f != nil && ((f.name == base0) ||
                        mirStrStartsWith(f.name, prefix) ||
                        mirStrStartsWith(f.name, dupPrefix) ||
                        mirStrStartsWith(f.name, instPrefix)):
            if found != nil:
                return nil
            found = f
    return found

fn moduleFindFuncByBasePreferOrigin(mod: MirModule, base0: str, originFile0: str): MirFunc =
    if mod == nil || base0 == nil || len(base0) == 0:
        return nil
    let originFile: str = (originFile0 != nil) ? originFile0 : ""
    if originFile != nil && len(originFile) > 0:
        let direct: MirFunc = moduleFindFunc(mod, base0)
        if direct != nil && direct.originFile == originFile:
            return direct
        let baseSym: str = backendSanitizeLinkName(base0)
        let prefix: str = baseSym + mirFuncSigMarker()
        let dupPrefix: str = baseSym + "__cheng_mod_"
        let instPrefix: str = baseSym + "_"
        var found: MirFunc = nil
        for i in 0..<mod.funcs.len:
            let f: MirFunc = mod.funcs[i]
            if f == nil || f.originFile != originFile:
                continue
            if (f.name == base0) || mirStrStartsWith(f.name, prefix) ||
               mirStrStartsWith(f.name, dupPrefix) || mirStrStartsWith(f.name, instPrefix):
                if found != nil:
                    if found.name == f.name:
                        continue
                    return nil
                found = f
        if found != nil:
            return found
    return moduleFindFuncByBaseUnique(mod, base0)

fn mirInferNodeTypeKeyForOverload(b: BlockBuilder, n0: Node): str =
    if b == nil:
        return ""
    var n: Node = n0
    while n != nil && n.kind == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if n == nil:
        return ""
    if n.typeCacheValid && n.typeCache != nil:
        return typeKey n.typeCache
    if n.kind == nkStrLit:
        return "str"
    if n.kind == nkFloatLit:
        return "float64"
    if n.kind == nkBoolLit:
        return "bool"
    if n.kind == nkCharLit:
        return "char"
    if n.kind == nkIntLit:
        # Integer literals are treated as platform-sized `int` for overload resolution.
        # The scorer allows `NI` to match sized ints when needed.
        return "NI"
    if n.kind == nkIdent || n.kind == nkSymbol:
        let nm: str = plainName(n)
        let slot0: int32 = localIndex(b.env, nm)
        if slot0 >= 0:
            if b.func != nil && funcFindObjLocal(b.func, slot0) >= 0:
                let ok0: str = funcObjTypeKey(b.func, slot0)
                if ok0 != nil && len(ok0) > 0:
                    return ok0
            let lk0: str = localTypeKey(b.env, slot0)
            if lk0 != nil && len(lk0) > 0:
                return lk0
        if mirDupGlobalNamesHas(nm) && b.func != nil:
            let f0: MirFunc = b.func
            let sym0: str = mirMaybeMangleDupGlobalName(nm, f0.originFile)
            let gk1: str = mirGlobalTypeKeyGet(sym0)
            if gk1 != nil && len(gk1) > 0:
                return gk1
        let gk0: str = mirGlobalTypeKeyByBaseUnique(b.module, nm)
        if gk0 != nil && len(gk0) > 0:
            return gk0
    if n.kind == nkCall && kidCount(n) > 0:
        let calleeNode: Node = kid(n, 0)
        if calleeNode != nil && (calleeNode.kind == nkIdent || calleeNode.kind == nkSymbol):
            var tn: str = backendStripSpaces(plainName(calleeNode))
            if (tn == "string"):
                tn = "str"
            elif (tn == "int"):
                tn = "NI"
            elif (tn == "uint"):
                tn = "NU"
            elif (tn == "i64"):
                tn = "int64"
            elif (tn == "u64"):
                tn = "uint64"
            elif (tn == "i32"):
                tn = "int32"
            elif (tn == "u32"):
                tn = "uint32"
            elif (tn == "i16"):
                tn = "int16"
            elif (tn == "u16"):
                tn = "uint16"
            elif (tn == "i8"):
                tn = "int8"
            elif (tn == "u8"):
                tn = "uint8"
            if tn == "int64" || tn == "uint64" || tn == "NI" || tn == "NU" ||
               tn == "int32" || tn == "uint32" ||
               tn == "int16" || tn == "uint16" ||
               tn == "int8" || tn == "uint8" ||
               tn == "bool" || tn == "char" || tn == "str" || tn == "cstring":
                return tn
            if tn == "ptr" || tn == "void*":
                return "ptr"
    if n.kind == nkCall && b.module != nil && kidCount(n) > 0:
        let calleeNode: Node = kid(n, 0)
        var name: str = ""
        var typeArgs: Node[]
        if calleeNode != nil && calleeNode.kind == nkBracketExpr && kidCount(calleeNode) > 0:
            let base: Node = kid(calleeNode, 0)
            name = backendStripSpaces(plainName(base))
            for ti in 1..<kidCount(calleeNode):
                let t: Node = kid(calleeNode, ti)
                if t != nil && t.kind != nkEmpty:
                    add(typeArgs, t)
        else:
            name = backendStripSpaces(plainName(calleeNode))
        var callName: str = name
        if typeArgs.len > 0:
            callName = mangleInstance(name, typeArgs)
        var argNodes: Node[]
        for ai in 1..<kidCount(n):
            var argNode: Node = kid(n, ai)
            if argNode != nil && argNode.kind == nkCallArg && kidCount(argNode) > 1:
                argNode = kid(argNode, 1)
            add(argNodes, argNode)
        let callee0: MirFunc = mirResolveCalleeFuncBestEffort(b, callName, argNodes, "")
        if callee0 != nil:
            if callee0.params.len > 0:
                let p0: MirParam = callee0.params[0]
                if (p0.name == "__ret"):
                    return funcObjTypeKey(callee0, p0.slot)
            if callee0.retTypeKey != nil && len(callee0.retTypeKey) > 0:
                return callee0.retTypeKey
    if n.kind == nkInfix && kidCount(n) >= 3:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        let lhsNode: Node = kid(n, 1)
        let rhsNode: Node = kid(n, 2)
        let lk: str = mirInferNodeTypeKeyForOverload(b, lhsNode)
        let rk: str = mirInferNodeTypeKeyForOverload(b, rhsNode)
        if op == "+":
            if (lk == "str") || (rk == "str") || lhsNode.kind == nkStrLit || rhsNode.kind == nkStrLit:
                return "str"
        if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=":
            return "bool"
        if lk != nil && len(lk) > 0 && (rk == nil || len(rk) == 0):
            return lk
        if rk != nil && len(rk) > 0 && (lk == nil || len(lk) == 0):
            return rk
        if lk != nil && rk != nil && len(lk) > 0 && len(rk) > 0:
            if (lk == rk):
                return lk
            if ((lk == "int") || (lk == "NI")) &&
               ((rk == "int8") || (rk == "int16") || (rk == "int32") || (rk == "int64")):
                return rk
            if ((rk == "int") || (rk == "NI")) &&
               ((lk == "int8") || (lk == "int16") || (lk == "int32") || (lk == "int64")):
                return lk
            if ((lk == "uint") || (lk == "NU")) &&
               ((rk == "uint8") || (rk == "uint16") || (rk == "uint32") || (rk == "uint64")):
                return rk
            if ((rk == "uint") || (rk == "NU")) &&
               ((lk == "uint8") || (lk == "uint16") || (lk == "uint32") || (lk == "uint64")):
                return lk
    if n.kind == nkIdent || n.kind == nkSymbol:
        let nm: str = plainName(n)
        let slot0: int32 = localIndex(b.env, nm)
        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
            return funcObjTypeKey(b.func, slot0)
        if slot0 >= 0:
            return localTypeKey(b.env, slot0)
        let gObj: str = mirGlobalObjTypeGet(nm)
        if len(gObj) > 0:
            return gObj
    if n.kind == nkBracketExpr && kidCount(n) > 0:
        let base0: Node = kid(n, 0)
        if kidCount(n) > 1:
            var idx0: Node = kid(n, 1)
            while idx0 != nil && idx0.kind == nkPar && kidCount(idx0) > 0:
                idx0 = kid(idx0, 0)
            if idx0 != nil && idx0.kind == nkInfix && kidCount(idx0) >= 3:
                let opNode: Node = kid(idx0, 0)
                let op: str = backendOpName(opNode)
                if op == ".." || op == "..<":
                    return mirInferNodeTypeKeyForOverload(b, base0)
        let baseKey0: str = mirInferNodeTypeKeyForOverload(b, base0)
        if baseKey0 != nil && len(baseKey0) > 0:
            if mirStrStartsWith(baseKey0, "seq_"):
                return str(ptr_add(void*(baseKey0), 4))
            if mirStrStartsWith(baseKey0, "seq_fixed_"):
                return str(ptr_add(void*(baseKey0), 10))
            if mirStrStartsWith(baseKey0, "Table_"):
                return str(ptr_add(void*(baseKey0), 6))
            if mirStrStartsWith(baseKey0, "array_") && b.module != nil:
                for i0 in 6..<len(baseKey0):
                    if baseKey0[i0] == '_':
                        let suffix: str = str(ptr_add(void*(baseKey0), i0 + 1))
                        if suffix != nil && len(suffix) > 0:
                            if isBuiltinTypeName(suffix) || mirHasObjType(b.module, suffix) ||
                               mirStrStartsWith(suffix, "seq_") || mirStrStartsWith(suffix, "seq_fixed_") ||
                               mirStrStartsWith(suffix, "Table_"):
                                return suffix
    if n.kind == nkDotExpr && b.module != nil && b.func != nil:
        let dbgOverDot: bool = (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1")
        # Composite (inlined) object field access: `obj.field` may not exist as a single field in the
        # lowered layout (it becomes `field.subfield` entries). Try to recover the field object type
        # key for overload resolution (e.g. `bytesGet(frame.payload, i)` where `payload` is Bytes).
        if kidCount(n) == 2:
            let base0: Node = kid(n, 0)
            let field0: Node = kid(n, 1)
            if base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol) &&
               field0 != nil && (field0.kind == nkIdent || field0.kind == nkSymbol):
                let baseName0: str = plainName(base0)
                let slot1: int32 = localIndex(b.env, baseName0)
                if dbgOverDot:
                    let lk0: str = (slot1 >= 0) ? localTypeKey(b.env, slot1) : ""
                    let fok0: str = (slot1 >= 0) ? funcObjTypeKey(b.func, slot1) : ""
                    let fon0: str = (slot1 >= 0) ? funcObjTypeName(b.func, slot1) : ""
                    echo("[backend] debugOverloadDot: base='" + baseName0 + "' slot=" + intToStr(slot1) +
                         " localKey='" + lk0 + "' funcObjKey='" + fok0 + "' funcObjName='" + fon0 + "'")
                if slot1 >= 0:
                    let parentObj: str = funcObjTypeName(b.func, slot1)
                    if len(parentObj) > 0:
                        let ot0: MirObjType = mirGetObjType(b.module, parentObj)
                        let fieldName0: str = backendStripSpaces(plainName(field0))
                        let prefix: str = fieldName0 + "."
                        var baseOff: int32 = -1
                        for fi0 in 0..<ot0.fields.len:
                            let f0: MirObjField = ot0.fields[fi0]
                            if mirStrStartsWith(f0.name, prefix):
                                if baseOff < 0 || f0.offset < baseOff:
                                    baseOff = f0.offset
                        if baseOff >= 0:
                            let objKey0: str = inferInlineObjFieldTypeName(b.module, ot0, fieldName0, baseOff)
                            if objKey0 != nil && len(objKey0) > 0:
                                if dbgOverDot:
                                    echo("[backend] debugOverloadDot: direct parentObj='" + parentObj +
                                         "' field='" + fieldName0 + "' objKey='" + objKey0 + "'")
                                return objKey0
            if field0 != nil && (field0.kind == nkIdent || field0.kind == nkSymbol):
                let fieldName1: str = backendStripSpaces(plainName(field0))
                let baseKey1: str = mirInferNodeTypeKeyForOverload(b, base0)
                if baseKey1 != nil && len(baseKey1) > 0:
                    var key: str = baseKey1
                    if mirStrStartsWith(key, "ref_"):
                        key = str(ptr_add(void*(key), 4))
                    elif mirStrStartsWith(key, "var_ref_"):
                        key = str(ptr_add(void*(key), 8))
                    elif mirStrStartsWith(key, "var_"):
                        key = str(ptr_add(void*(key), 4))
                    if mirStrStartsWith(key, "ptr_"):
                        key = str(ptr_add(void*(key), 4))
                    let parentObj2: str = mirPtrBaseObjTypeName(b.module, key)
                    if dbgOverDot:
                        echo("[backend] debugOverloadDot: fallback field='" + fieldName1 + "' baseKey='" + baseKey1 +
                             "' stripped='" + key + "' parentObj2='" + parentObj2 + "'")
                    if parentObj2 != nil && len(parentObj2) > 0:
                        let ot1: MirObjType = mirGetObjType(b.module, parentObj2)
                        let prefix1: str = fieldName1 + "."
                        var baseOff1: int32 = -1
                        for fi1 in 0..<ot1.fields.len:
                            let f1: MirObjField = ot1.fields[fi1]
                            if mirStrStartsWith(f1.name, prefix1):
                                if baseOff1 < 0 || f1.offset < baseOff1:
                                    baseOff1 = f1.offset
                        if baseOff1 >= 0:
                            let objKey1: str = inferInlineObjFieldTypeName(b.module, ot1, fieldName1, baseOff1)
                            if objKey1 != nil && len(objKey1) > 0:
                                if dbgOverDot:
                                    echo("[backend] debugOverloadDot: fallback resolved objKey='" + objKey1 + "'")
                                return objKey1
        let dk: str = caseInferExprTypeKey(b, n)
        if dbgOverDot:
            echo("[backend] debugOverloadDot: caseInfer key='" + dk + "'")
        if dk != nil && len(dk) > 0:
            return dk
        let t: MirType = inferExprTypeWithGlobals(b.env, b.module, b.func, n, mirTypeI32())
        if t.kind == mtI64:
            return t.isUnsigned ? "uint64" : "int64"
        if t.kind == mtI32:
            return t.isUnsigned ? "uint32" : "int32"
        if t.kind == mtF64:
            return "float64"
        if t.kind == mtF32:
            return "float32"
    return ""

fn mirInferCallRetKeyHint(callNode: Node): str =
    if callNode != nil && callNode.typeCacheValid && callNode.typeCache != nil:
        return typeKey callNode.typeCache
    return ""

fn mirScoreCalleeForCall(callee: MirFunc, argKeys: str[], retKeyHint: str): int32 =
    if callee == nil:
        return -1
    var paramStart: int32 = 0
    if callee.params.len > 0:
        let p0: MirParam = callee.params[0]
        if (p0.name == "__ret"):
            paramStart = 1
    let argCount: int32 = argKeys.len
    var paramCount: int32 = callee.params.len - paramStart
    var hasVarargs: bool = false
    var fixedCount: int32 = paramCount
    if callee.isExtern && paramCount > 0:
        let lastP: MirParam = callee.params[callee.params.len - 1]
        if mirTypeKeyIsVarargs(lastP.typeKey):
            hasVarargs = true
            fixedCount = paramCount - 1
    if !hasVarargs && argCount != paramCount:
        return -1
    if hasVarargs && argCount < fixedCount:
        return -1
    var score: int32 = 0
    for i in 0..<fixedCount:
        let pk0: MirParam = callee.params[paramStart + i]
        let paramKey: str = (pk0.typeKey != nil) ? pk0.typeKey : ""
        let argKey0: str = argKeys[i]
        let argKey: str = (argKey0 != nil) ? argKey0 : ""
        if paramKey == nil || len(paramKey) == 0 || argKey == nil || len(argKey) == 0:
            continue
        let paramCanon: str = mirObjAliasCanon(paramKey)
        let argCanon: str = mirObjAliasCanon(argKey)
        if (paramKey == argKey) || (paramCanon == argCanon):
            score = score + 4
            continue
        # Allow platform-sized int/uint aliases to match sized integer args and vice versa.
        if ((paramKey == "int") || (paramKey == "NI")) &&
           ((argKey == "int32") || (argKey == "int64") || (argKey == "int") || (argKey == "NI")):
            score = score + 3
            continue
        if ((paramKey == "uint") || (paramKey == "NU")) &&
           ((argKey == "uint32") || (argKey == "uint64") || (argKey == "uint") || (argKey == "NU")):
            score = score + 3
            continue
        if ((argKey == "int") || (argKey == "NI")) &&
           ((paramKey == "int32") || (paramKey == "int64")):
            score = score + 3
            continue
        if ((argKey == "uint") || (argKey == "NU")) &&
           ((paramKey == "uint32") || (paramKey == "uint64")):
            score = score + 3
            continue
        if (paramKey == "var"):
            score = score + 1
            continue
        if mirStrStartsWith(paramKey, "var_"):
            let baseKey: str = str(ptr_add(void*(paramKey), 4))
            let baseCanon: str = mirObjAliasCanon(baseKey)
            if (baseKey == argKey) || (baseCanon == argCanon):
                score = score + 3
                continue
            if mirStrStartsWith(argKey, "ptr_"):
                let argPtrBase: str = str(ptr_add(void*(argKey), 4))
                let argPtrCanon: str = mirObjAliasCanon(argPtrBase)
                if (baseKey == argPtrBase) || (baseCanon == argPtrCanon):
                    score = score + 3
                    continue
        if mirStrStartsWith(argKey, "var_"):
            let baseKey2: str = str(ptr_add(void*(argKey), 4))
            let baseCanon2: str = mirObjAliasCanon(baseKey2)
            if ((baseKey2 == paramKey) || (baseCanon2 == paramCanon)) &&
               !mirStrStartsWith(paramKey, "ref_") &&
               !mirStrStartsWith(paramKey, "ptr_") &&
               !mirStrStartsWith(paramKey, "fn_"):
                score = score + 3
                continue
        if mirStrStartsWith(paramKey, "ptr_") && mirStrStartsWith(argKey, "var_"):
            let paramPtrBase: str = str(ptr_add(void*(paramKey), 4))
            let paramPtrCanon: str = mirObjAliasCanon(paramPtrBase)
            let argVarBase: str = str(ptr_add(void*(argKey), 4))
            let argVarCanon: str = mirObjAliasCanon(argVarBase)
            if (paramPtrBase == argVarBase) || (paramPtrCanon == argVarCanon):
                score = score + 3
                continue
        return -1
    if retKeyHint != nil && len(retKeyHint) > 0 && callee.retTypeKey != nil && len(callee.retTypeKey) > 0:
        if !(callee.retTypeKey == retKeyHint):
            return -1
        score = score + 2
    return score

fn mirCommonPrefixLen(a0: str, b0: str): int32 =
    if a0 == nil || b0 == nil:
        return 0
    let a: str = a0
    let b: str = b0
    var n: int32 = len(a)
    if len(b) < n:
        n = len(b)
    for i in 0..<n:
        if a[i] != b[i]:
            return i
    return n

fn mirResolveCalleeFuncBestEffort(b: BlockBuilder, baseName: str, argNodes: Node[], retKeyHint: str): MirFunc =
    if b == nil || b.module == nil || baseName == nil || len(baseName) == 0:
        return nil
    let mod: MirModule = b.module
    let candIdxs: int32[] = mirCalleeCandidatesGet(mod, baseName)
    for ciExact in 0..<candIdxs.len:
        let idx: int32 = candIdxs[ciExact]
        if idx >= 0 && idx < mod.funcs.len:
            let cand: MirFunc = mod.funcs[idx]
            if cand != nil && (cand.name == baseName):
                return cand
    var argKeys: str[argNodes.len]
    argKeys.len = 0
    for ai in 0..<argNodes.len:
        add(argKeys, mirInferNodeTypeKeyForOverload(b, argNodes[ai]))
    var debugResolve: bool = (getEnv "CHENG_BACKEND_DEBUG_RESOLVE" == "1")
    if debugResolve:
        let dbgName: str = getEnv "CHENG_BACKEND_DEBUG_RESOLVE_NAME"
        if dbgName != nil && len(dbgName) > 0:
            debugResolve = (baseName == dbgName)
        else:
            # Default to a small noisy builtin when no name filter is provided.
            debugResolve = (baseName == "Value")
    if debugResolve:
        var dbgFn: str = ""
        var dbgFile: str = ""
        if b != nil && b.func != nil:
            let dbgFunc0: MirFunc = b.func
            dbgFn = dbgFunc0.name
            dbgFile = dbgFunc0.originFile
        var dbgArgPos: str = ""
        if argNodes.len > 0 && argNodes[0] != nil:
            let an0: Node = argNodes[0]
            dbgArgPos = intToStr(an0.pos.line) + ":" + intToStr(an0.pos.col)
        echo("[backend] debugResolve: base='" + baseName + "' retHint='" + retKeyHint + "'")
        echo("[backend] debugResolve: fn='" + dbgFn + "' file='" + dbgFile + "' arg0Pos='" + dbgArgPos + "'")
        echo("[backend] debugResolve: argc=" + intToStr(argKeys.len))
        if argKeys.len > 0:
            echo("[backend] debugResolve: arg0Key='" + argKeys[0] + "'")
        if argNodes.len > 0 && argNodes[0] != nil:
            let an0: Node = argNodes[0]
            var anName: str = backendStripSpaces(plainName(an0))
            if anName == nil:
                anName = ""
            var anTypeKey: str = ""
            if an0.typeCacheValid && an0.typeCache != nil:
                anTypeKey = typeKey(an0.typeCache)
            echo("[backend] debugResolve: arg0 kind=nk#" + intToStr(int32(an0.kind)) +
                 " name='" + anName + "' typeKey='" + anTypeKey + "' kids=" + intToStr(kidCount(an0)))
            if an0.kind == nkCallArg && kidCount(an0) > 0:
                let anKid0: Node = kid(an0, 0)
                var anKid0Name: str = backendStripSpaces(plainName(anKid0))
                if anKid0Name == nil:
                    anKid0Name = ""
                var anKid0TypeKey: str = ""
                if anKid0 != nil && anKid0.typeCacheValid && anKid0.typeCache != nil:
                    anKid0TypeKey = typeKey(anKid0.typeCache)
                var anKid0Kind: int32 = -1
                if anKid0 != nil:
                    anKid0Kind = int32(anKid0.kind)
                echo("[backend] debugResolve: arg0.k0 kind=nk#" + intToStr(anKid0Kind) +
                     " name='" + anKid0Name + "' typeKey='" + anKid0TypeKey + "'")
        if argKeys.len > 1:
            echo("[backend] debugResolve: arg1Key='" + argKeys[1] + "'")
    var dbgCandCount: int32 = 0
    var dbgPrinted: int32 = 0
    let dbgMax: int32 = 30
    var best: MirFunc = nil
    var bestScore: int32 = -1
    var ambiguous: bool = false
    var ties: MirFunc[4]
    for ci in 0..<candIdxs.len:
        let idx: int32 = candIdxs[ci]
        if idx < 0 || idx >= mod.funcs.len:
            continue
        let cand: MirFunc = mod.funcs[idx]
        if cand == nil:
            continue
        let sc: int32 = mirScoreCalleeForCall(cand, argKeys, retKeyHint)
        if debugResolve:
            dbgCandCount = dbgCandCount + 1
            var pk0: str = ""
            var paramStart: int32 = 0
            if cand.params.len > 0:
                let p0: MirParam = cand.params[0]
                if (p0.name == "__ret"):
                    paramStart = 1
            if cand.params.len > paramStart:
                let p1: MirParam = cand.params[paramStart]
                pk0 = p1.typeKey
            if dbgPrinted < dbgMax:
                echo("[backend] debugResolve: cand='" + cand.name + "' pk0='" + pk0 +
                    "' file='" + cand.originFile + "' score=" + intToStr(sc))
                dbgPrinted = dbgPrinted + 1
        if sc < 0:
            continue
        if sc > bestScore:
            best = cand
            bestScore = sc
            ambiguous = false
            ties.len = 0
        elif sc == bestScore:
            if best != nil && best.name == cand.name && best.originFile == cand.originFile:
                continue
            if !ambiguous:
                ambiguous = true
                if best != nil:
                    add(ties, best)
            var seenTie: bool = false
            for ti0 in 0..<ties.len:
                let t0: MirFunc = ties[ti0]
                if t0 != nil && t0.name == cand.name && t0.originFile == cand.originFile:
                    seenTie = true
                    break
            if !seenTie:
                add(ties, cand)
    if ambiguous:
        var hasUnknownArg: bool = false
        for ai0 in 0..<argKeys.len:
            if argKeys[ai0] == nil || len(argKeys[ai0]) == 0:
                hasUnknownArg = true
                break
        if hasUnknownArg && ties.len > 0:
            return ties[0]
        if b.func != nil && mirDupFnBasesHas(baseName):
            let fTmp: MirFunc = b.func
            let prefer: str = mirMaybeMangleDupFnBase(baseName, fTmp.originFile)
            if prefer != nil && len(prefer) > 0:
                let prefFunc: MirFunc = moduleFindFunc(mod, prefer)
                if prefFunc != nil:
                    let sc2: int32 = mirScoreCalleeForCall(prefFunc, argKeys, retKeyHint)
                    if sc2 == bestScore:
                        return prefFunc
        if b.func != nil && ties.len > 0:
            var callerFile: str = ""
            let callerFunc: MirFunc = b.func
            if callerFunc != nil:
                callerFile = callerFunc.originFile
            if callerFile != nil && len(callerFile) > 0:
                var bestPref: MirFunc = nil
                var bestLen: int32 = -1
                var bestCount: int32 = 0
                for ti in 0..<ties.len:
                    let cand: MirFunc = ties[ti]
                    if cand != nil:
                        let candFile: str = cand.originFile
                        if candFile != nil && len(candFile) > 0:
                            let pl: int32 = mirCommonPrefixLen(callerFile, candFile)
                            if pl > bestLen:
                                bestPref = cand
                                bestLen = pl
                                bestCount = 1
                            elif pl == bestLen:
                                bestCount = bestCount + 1
                if bestPref != nil && bestCount == 1 && bestLen > 0:
                    return bestPref
        return nil
    if best == nil:
        if b.func != nil && mirDupFnBasesHas(baseName):
            let fTmp2: MirFunc = b.func
            let prefer2: str = mirMaybeMangleDupFnBase(baseName, fTmp2.originFile)
            if prefer2 != nil && len(prefer2) > 0:
                let prefFunc2: MirFunc = moduleFindFunc(mod, prefer2)
                if prefFunc2 != nil:
                    return prefFunc2
        let uniq: MirFunc = moduleFindFuncByBaseUnique(mod, baseName)
        if uniq != nil:
            return uniq
    if debugResolve:
        var bestNm: str = ""
        if best != nil:
            bestNm = best.name
        echo("[backend] debugResolve: done base='" + baseName + "' candCount=" + intToStr(dbgCandCount) +
             " best='" + bestNm + "' ambiguous=" + (ambiguous ? "1" : "0"))
    return best

fn mirResolveCalleeFunc(b: BlockBuilder, callNode: Node, baseName: str, argNodes: Node[]): Result[MirFunc] =
    let retKeyHint: str = mirInferCallRetKeyHint(callNode)
    let f: MirFunc = mirResolveCalleeFuncBestEffort(b, baseName, argNodes, retKeyHint)
    if f != nil:
        return Ok[MirFunc](f)
    var fnName: str = ""
    var fp: str = ""
    if b != nil && b.func != nil:
        let bf: MirFunc = b.func
        fnName = bf.name
        fp = bf.originFile
    let line: str = (callNode != nil) ? intToStr(callNode.pos.line) : "0"
    let col: str = (callNode != nil) ? intToStr(callNode.pos.col) : "0"
    return Err[MirFunc]("mir_builder: unresolved call target: " + baseName +
                        " (fn=" + fnName + " " + fp + ":" + line + ":" + col + ")")

fn moduleHasGlobal(mod: MirModule, name: str): bool =
    return moduleGlobalIndex(mod, name) >= 0

fn strHasSuffix(s: str, suffix: str): bool =
    if s == nil || suffix == nil:
        return false
    let n: int32 = len(s)
    let m: int32 = len(suffix)
    if m == 0:
        return true
    if n < m:
        return false
    for i in 0..<m:
        if s[n - m + i] != suffix[i]:
            return false
    return true

fn strHasPrefix(s: str, prefix: str): bool =
    if s == nil || prefix == nil:
        return false
    let n: int32 = len(s)
    let m: int32 = len(prefix)
    if m == 0:
        return true
    if n < m:
        return false
    for i in 0..<m:
        if s[i] != prefix[i]:
            return false
    return true

fn strStripPrefix(s: str, prefix: str): str =
    if s == nil || prefix == nil:
        return ""
    let n: int32 = len(s)
    let m: int32 = len(prefix)
    if m == 0:
        return s
    if n < m:
        return ""
    for i in 0..<m:
        if s[i] != prefix[i]:
            return ""
    return str(ptr_add(void*(s), m))

fn indexOfChar(s: str, ch: char): int32 =
    if s == nil || len(s) == 0:
        return -1
    for i in 0..<len(s):
        if s[i] == ch:
            return i
    return -1

fn parseQuotedValue(line: str): str =
    if line == nil || len(line) == 0:
        return ""
    let first: int32 = indexOfChar(line, '"')
    if first < 0:
        return ""
    let second: int32 = indexOfChar(str(ptr_add(void*(line), first + 1)), '"')
    if second <= 0:
        return ""
    return os.sliceStr(line, first + 1, first + second)

fn packageNameFromRest(rest: str): str =
    if rest == nil || len(rest) == 0:
        return ""
    let slash: int32 = indexOfChar(rest, '/')
    if slash <= 0:
        return ""
    return os.sliceStr(rest, 0, slash - 1)

fn packageIdFromRest(rest: str): str =
    let name: str = packageNameFromRest(rest)
    if name == nil || len(name) == 0:
        return ""
    if (name == "stdlib"):
        return ""
    return "pkg://cheng/" + name

fn packageIdFromManifest(manifestPath: str): str =
    if manifestPath == nil || len(manifestPath) == 0:
        return ""
    if ! frontend_lib.stage1_fileExists(manifestPath):
        return ""
    let content: str = frontend_lib.stage1_readFile(manifestPath)
    if content == nil || len(content) == 0:
        return ""
    let key: str = "package_id"
    var start: int32 = 0
    for i in 0..len(content):
        if i == len(content) || content[i] == '\n':
            if i > start:
                let line: str = os.sliceStr(content, start, i - 1)
                let trimmed: str = backendStripSpaces(line)
                if strHasPrefix(trimmed, key):
                    if len(trimmed) == len(key) || trimmed[len(key)] == '=' ||
                       trimmed[len(key)] == ':' || trimmed[len(key)] == ' ':
                        let value: str = parseQuotedValue(trimmed)
                        if value != nil && len(value) > 0:
                            return value
            start = i + 1
    return ""

fn packageIdMatches(manifestPath: str, expected: str): bool =
    if expected == nil || len(expected) == 0:
        return true
    let got: str = packageIdFromManifest manifestPath
    if got == nil || len(got) == 0:
        return false
    return (got == expected)

fn pkgRootsFromEnv(): str[] =
    var out: str[]
    let single: str = os.getEnvDefault("CHENG_PKG_ROOT", "")
    if single != nil && len(single) > 0:
        add(out, backendStripSpaces(single))
    let raw: str = os.getEnvDefault("CHENG_PKG_ROOTS", "")
    var hasCommaOrSemi: bool = false
    var k: int32 = 0
    while raw != nil && k < len(raw):
        let c0: char = raw[k]
        if c0 == ',' || c0 == ';':
            hasCommaOrSemi = true
            break
        k = k + 1
    let useColon: bool = !hasCommaOrSemi
    var start: int32 = 0
    var i: int32 = 0
    if raw != nil && len(raw) > 0:
        let __for_start_i_2 = i
        for __for_i_2 in __for_start_i_2..len(raw):
            i = __for_i_2
            let c: char = (i < len(raw)) ? raw[i] : char(int8(0))
            if i == len(raw) || c == ',' || c == ';' || (useColon && c == ':'):
                if i > start:
                    let part: str = os.sliceStr(raw, start, i - 1)
                    let trimmed: str = backendStripSpaces(part)
                    if trimmed != nil && len(trimmed) > 0:
                        add(out, trimmed)
                start = i + 1
            i = i + 1
    if out.len == 0:
        let home: str = os.getEnvDefault("HOME", "")
        if home != nil && len(home) > 0:
            add(out, os.joinPath(home, ".cheng-packages"))
    return out

fn resolvePkgCandidate(base: str): str =
    if base == nil || len(base) == 0:
        return ""
    var full: str = base
    if ! strHasSuffix(full, ".cheng"):
        full = full + ".cheng"
    if frontend_lib.stage1_fileExists(full):
        return full
    return ""

fn resolvePkgInRoot(pkgRoot: str, relInPkg: str, relForPkgRoot: str): str =
    if pkgRoot == nil || len(pkgRoot) == 0:
        return ""

    if relInPkg != nil && len(relInPkg) > 0:
        var candidate: str = resolvePkgCandidate(os.joinPath(os.joinPath(pkgRoot, "src"), relInPkg))
        if len(candidate) > 0:
            return candidate
        candidate = resolvePkgCandidate(os.joinPath(os.joinPath(pkgRoot, "cheng"), relInPkg))
        if len(candidate) > 0:
            return candidate
        candidate = resolvePkgCandidate(os.joinPath(pkgRoot, relInPkg))
        if len(candidate) > 0:
            return candidate

    if relForPkgRoot != nil && len(relForPkgRoot) > 0:
        var legacy: str = resolvePkgCandidate(os.joinPath(os.joinPath(pkgRoot, "src"), relForPkgRoot))
        if len(legacy) > 0:
            return legacy
        legacy = resolvePkgCandidate(os.joinPath(os.joinPath(pkgRoot, "cheng"), relForPkgRoot))
        if len(legacy) > 0:
            return legacy
        legacy = resolvePkgCandidate(os.joinPath(pkgRoot, relForPkgRoot))
        if len(legacy) > 0:
            return legacy
    return ""

fn resolvePkgImport(root: str, rest: str): str =
    if root == nil || len(root) == 0 || rest == nil || len(rest) == 0:
        return ""
    let slash: int32 = indexOfChar(rest, '/')
    if slash <= 0 || slash >= len(rest) - 1:
        return ""
    let pkg: str = os.sliceStr(rest, 0, slash - 1)
    if (pkg == "stdlib"):
        return ""
    let expectedPkgId: str = packageIdFromRest(rest)
    let relInPkg: str = os.sliceStr(rest, slash + 1, len(rest) - 1)
    let manifest: str = os.joinPath(root, "cheng-package.toml")
    if frontend_lib.stage1_fileExists(manifest):
        if ! packageIdMatches(manifest, expectedPkgId):
            return ""
        return resolvePkgInRoot(root, relInPkg, rest)

    # Container root: try cheng-<pkg> and <pkg> subdirectories.
    let prefixedRoot: str = os.joinPath(root, "cheng-" + pkg)
    let plainRoot: str = os.joinPath(root, pkg)
    let prefManifest: str = os.joinPath(prefixedRoot, "cheng-package.toml")
    if frontend_lib.stage1_fileExists(prefManifest):
        if packageIdMatches(prefManifest, expectedPkgId):
            let resolvedPref: str = resolvePkgInRoot(prefixedRoot, relInPkg, rest)
            if len(resolvedPref) > 0:
                return resolvedPref
    else:
        let resolvedPrefLegacy: str = resolvePkgInRoot(prefixedRoot, relInPkg, rest)
        if len(resolvedPrefLegacy) > 0:
            return resolvedPrefLegacy

    let plainManifest: str = os.joinPath(plainRoot, "cheng-package.toml")
    if frontend_lib.stage1_fileExists(plainManifest):
        if packageIdMatches(plainManifest, expectedPkgId):
            let resolvedPlain: str = resolvePkgInRoot(plainRoot, relInPkg, rest)
            if len(resolvedPlain) > 0:
                return resolvedPlain
    else:
        let resolvedPlainLegacy: str = resolvePkgInRoot(plainRoot, relInPkg, rest)
        if len(resolvedPlainLegacy) > 0:
            return resolvedPlainLegacy
    return ""

fn resolveImportToFilePath(importPath: str, fromFilePath: str): Result[str] =
    if importPath == nil || len(importPath) == 0:
        return Err[str]("mir_builder: empty import path")
    var path: str = importPath
    if os.isAbsolute(path):
        if ! strHasSuffix(path, ".cheng"):
            path = path + ".cheng"
        return Ok[str](path)

    var fromDir: str = ""
    if fromFilePath != nil && len(fromFilePath) > 0:
        let parts: SplitFileResult = os.splitFile(fromFilePath)
        fromDir = parts.dir

    if strHasPrefix(path, "./") || strHasPrefix(path, "../") || strHasPrefix(path, "."):
        if ! strHasSuffix(path, ".cheng"):
            path = path + ".cheng"
        if fromDir != nil && len(fromDir) > 0:
            return Ok[str](os.joinPath(fromDir, path))
        return Ok[str](path)

    if strHasPrefix(path, "std/"):
        let rest: str = strStripPrefix(path, "std/")
        var localStd: str = "src/std/" + rest
        if ! strHasSuffix(localStd, ".cheng"):
            localStd = localStd + ".cheng"
        if frontend_lib.stage1_fileExists(localStd):
            return Ok[str](localStd)
        return Ok[str](localStd)

    if strHasPrefix(path, "cheng/"):
        let rest: str = strStripPrefix(path, "cheng/")
        if rest == nil || len(rest) == 0:
            return Err[str]("mir_builder: invalid import path")
        var local: str = "src/" + rest
        if ! strHasSuffix(local, ".cheng"):
            local = local + ".cheng"
        if frontend_lib.stage1_fileExists(local):
            return Ok[str](local)
        let roots: str[] = pkgRootsFromEnv()
        for ri in 0..<roots.len:
            let resolved: str = resolvePkgImport(roots[ri], rest)
            if resolved != nil && len(resolved) > 0:
                return Ok[str](resolved)
        if ! strHasSuffix(path, ".cheng"):
            path = path + ".cheng"
        return Ok[str](path)

    if ! strHasSuffix(path, ".cheng"):
        path = path + ".cheng"
    if fromDir != nil && len(fromDir) > 0:
        let local2: str = os.joinPath(fromDir, path)
        if frontend_lib.stage1_fileExists(local2):
            return Ok[str](local2)
    return Ok[str](path)

fn collectImportPaths(root: Node): str[] =
    var out: str[]
    if root == nil:
        return out
    for i in 0..<kidCount(root):
        let n: Node = kid(root, i)
        if n == nil || n.kind != nkImportStmt || kidCount(n) == 0:
            continue
        let item: Node = kid(n, 0)
        if item == nil:
            continue
        if item.kind == nkStrLit:
            let v: str = item.strVal
            if v != nil && len(v) > 0:
                add(out, "" + v)
            continue
        if item.kind == nkImportAs && kidCount(item) > 0:
            let baseNode: Node = kid(item, 0)
            var base: str = plainName(baseNode)
            if baseNode != nil && baseNode.kind == nkStrLit:
                base = baseNode.strVal
            if len(base) > 0:
                add(out, "" + base)
            continue
        if item.kind == nkImportGroup && kidCount(item) > 0:
            let baseNode2: Node = kid(item, 0)
            var base: str = plainName(baseNode2)
            if baseNode2 != nil && baseNode2.kind == nkStrLit:
                base = baseNode2.strVal
            if len(base) > 0:
                for gi in 1..<kidCount(item):
                    let entryNode: Node = kid(item, gi)
                    var entry: str = plainName(entryNode)
                    if entryNode != nil && entryNode.kind == nkStrLit:
                        entry = entryNode.strVal
                    if len(entry) > 0:
                        add(out, base + "/" + entry)
            continue
        var base2: str = plainName(item)
        if item.kind == nkStrLit:
            base2 = item.strVal
        if len(base2) > 0:
            add(out, "" + base2)
    return out

fn isBuiltinTypeName(name: str): bool =
    if name == nil || len(name) == 0:
        return false
    if name == "void" || name == "bool" || name == "char":
        return true
    if name == "int8" || name == "uint8" || name == "i8" || name == "u8":
        return true
    if name == "int16" || name == "uint16" || name == "i16" || name == "u16":
        return true
    if name == "int32" || name == "uint32" || name == "i32" || name == "u32":
        return true
    if name == "int64" || name == "uint64" || name == "i64" || name == "u64":
        return true
    if name == "int" || name == "uint" || name == "NI" || name == "NU":
        return true
    if name == "float32" || name == "float64" || name == "float":
        return true
    if name == "str" || name == "string" || name == "cstring":
        return true
    if name == "ptr" || name == "void*":
        return true
    if name == "tuple" || mirStrStartsWith(name, "tuple_"):
        return true
    if name == "seq" || mirStrStartsWith(name, "seq_"):
        return true
    if name == "seq_fixed" || mirStrStartsWith(name, "seq_fixed_"):
        return true
    if name == "Table" || mirStrStartsWith(name, "Table_"):
        return true
    if mirStrStartsWith(name, "set_"):
        return true
    return false

fn mirConsumeTypeDecl(mod: MirModule, td: Node): Result[bool] =
    if td == nil || td.kind != nkTypeDecl || kidCount(td) < 2:
        return Err[bool]("mir_builder: invalid type decl")
    let nameNode: Node = kid(td, 0)
    let defNode: Node = kid(td, 1)
    var defCore: Node = defNode
    var isRefLike: bool = false
    if defCore != nil && (defCore.kind == nkRefTy || defCore.kind == nkPtrTy) && kidCount(defCore) > 0:
        isRefLike = true
        defCore = kid(defCore, 0)
    if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
        return Err[bool]("mir_builder: type name expects identifier")
    let name: str = backendStripSpaces(plainName(nameNode))
    let traceTypes: bool = (getEnv "CHENG_BACKEND_TRACE_TYPES" == "1")
    if traceTypes && (name == "__cheng_lambda_2_iter"):
        echo("[backend] trace: typeDecl " + name)
    if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1") && (name == "Node"):
        let dk0: str = (defNode != nil) ? intToStr(int32(defNode.kind)) : "nil"
        let dk1: str = (defCore != nil) ? intToStr(int32(defCore.kind)) : "nil"
        let rf: str = isRefLike ? "1" : "0"
        echo("[backend] debug: typeDecl Node defKind=nk#" + dk0 + " defCoreKind=nk#" + dk1 + " isRefLike=" + rf)
    if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1") && (name == "seq_string"):
        let k: int32 = int32(defNode.kind)
        var line: str = "[backend] debug: typeDecl seq_string defKind=" + intToStr(k)
        if defNode != nil && defNode.kind == nkBracketExpr:
            line = line + " kids=" + intToStr(kidCount(defNode))
            if kidCount(defNode) > 0:
                line = line + " base=" + backendStripSpaces(plainName(kid(defNode, 0)))
        line = line + " hasSeq=" + (mirHasObjType(mod, "seq") ? "1" : "0")
        echo line
    if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1") && (name == "Table_string"):
        let k2: int32 = int32(defNode.kind)
        var line2: str = "[backend] debug: typeDecl Table_string defKind=" + intToStr(k2)
        if defNode != nil && defNode.kind == nkBracketExpr:
            line2 = line2 + " kids=" + intToStr(kidCount(defNode))
            if kidCount(defNode) > 0:
                line2 = line2 + " base=" + backendStripSpaces(plainName(kid(defNode, 0)))
        line2 = line2 + " hasTable=" + (mirHasObjType(mod, "Table") ? "1" : "0")
        echo line2
    if moduleHasFunc(mod, name) || moduleHasGlobal(mod, name):
        return Err[bool]("mir_builder: type name conflicts with global")
    let existingObj: int32 = mirFindObjType(mod, name)
    if existingObj >= 0:
        # Stage1 lowering may emit an alias first and the concrete object later.
        # Prefer the concrete object layout when available.
        if defCore == nil || defCore.kind != nkObjectDecl:
            return Ok[bool](false)
    let existingAlias: int32 = mirFindTypeAlias(mod, name)
    if existingAlias >= 0:
        # Prefer object layouts over scalar aliases when a name collides.
        # This situation can happen when stage1 lowers an instantiation to an alias
        # and also keeps the concrete object definition.
        if defCore == nil || defCore.kind != nkObjectDecl:
            return Ok[bool](false)
    if kidCount(td) > 2:
        let generics: Node = kid(td, 2)
        if generics != nil && generics.kind != nkEmpty && kidCount(generics) > 0:
            # Generic types are expected to be eliminated (instantiated) by stage1 monomorphize.
            return Ok[bool](false)
    if isRefLike:
        # Ref/ptr types are represented as pointers; predeclare the scalar alias so
        # self-references and mutually-recursive ref types don't block layout construction.
        mirAddTypeAlias(mod, name, mirTypeI64())
    if defCore != nil && defCore.kind == nkObjectDecl:
        # `seq_fixed[T,N]` is used as an init-time reserve hint (cap hint) for `seq`.
        # Some stage1 pipelines may still surface partially-instantiated `seq_fixed_*_N` helper types.
        # Treat them as the builtin `seq` layout so these helpers don't block builds.
        if mirStrStartsWith(name, "seq_fixed_") && mirHasObjType(mod, "seq"):
            var rhs: MirObjType = mirGetObjType(mod, "seq")
            rhs.name = name
            mirAddObjType(mod, rhs)
            return Ok[bool](false)
    if defCore != nil && defCore.kind == nkObjectDecl:
        if kidCount(defCore) < 2:
            return Err[bool]("mir_builder: invalid object type")
        let recList: Node = kid(defCore, 1)
        if recList == nil || recList.kind != nkRecList:
            return Err[bool]("mir_builder: invalid record list")
        if traceTypes && (name == "__cheng_lambda_2_iter"):
            echo("[backend] trace: recList count=" + intToStr(kidCount(recList)))
        var fields: MirObjField[]
        var offset: int32 = 0
        var maxAlignPow2: int32 = 0
        for i in 0..<kidCount(recList):
            let item: Node = kid(recList, i)
            if item == nil:
                continue
            if item.kind == nkRecCase:
                return Err[bool]("mir_builder: record case not supported in backend")
            if item.kind != nkIdentDefs || kidCount(item) < 2:
                return Err[bool]("mir_builder: record field expects ident defs")
            let fieldNameNode: Node = kid(item, 0)
            let fieldTypeNode: Node = kid(item, 1)
            var fieldDefaultNode: Node = nil
            if kidCount(item) > 2:
                fieldDefaultNode = kid(item, 2)
            if fieldNameNode == nil || (fieldNameNode.kind != nkIdent && fieldNameNode.kind != nkSymbol):
                return Err[bool]("mir_builder: record field name expects identifier")
            if fieldTypeNode == nil || fieldTypeNode.kind == nkEmpty:
                return Err[bool]("mir_builder: record field requires type")
            if fieldDefaultNode != nil && fieldDefaultNode.kind != nkEmpty:
                return Err[bool]("mir_builder: record field default not supported in backend")
            let rawFieldName: str = plainName(fieldNameNode)
            let fieldName: str = backendStripSpaces(rawFieldName)
            if (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1") && name == "ProtoBuffer" && fieldName == "out":
                let fNodeName0: str = backendStripSpaces(plainName(fieldTypeNode))
                let fNodeKey0: str = typeKey(fieldTypeNode)
                echo("[backend] debugOverloadDot: consumeTypeDecl type='ProtoBuffer' field='out' nodeKind=nk#" +
                     intToStr(int32(fieldTypeNode.kind)) + " plain='" + fNodeName0 + "' typeKey='" + fNodeKey0 + "'")
            if traceTypes && (name == "__cheng_lambda_2_iter"):
                var firstCode: int32 = -1
                if rawFieldName != nil && len(rawFieldName) > 0:
                    firstCode = int32(rawFieldName[0])
                echo("[backend] trace: field '" + fieldName + "' rawLen=" + intToStr(len(rawFieldName)) +
                    " firstChar=" + intToStr(firstCode))
            var fieldTypeKey: str = ""
            if fieldTypeNode != nil && fieldTypeNode.kind == nkDotExpr && kidCount(fieldTypeNode) > 1:
                fieldTypeKey = typeKey(kid(fieldTypeNode, 1))
            else:
                fieldTypeKey = typeKey(fieldTypeNode)
            if len(fieldTypeKey) == 0:
                fieldTypeKey = backendStripSpaces(plainName(fieldTypeNode))
            let sfiField: SeqFixedInit = seqFixedInitInfo(fieldTypeNode)
            if sfiField.elemType != nil && sfiField.capExpr != nil:
                # Keep explicit `seq_fixed[T,N]` key for init-time reserve hints.
                let explicitKey: str = typeKey(fieldTypeNode)
                if explicitKey != nil && len(explicitKey) > 0:
                    fieldTypeKey = explicitKey
            if (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1") && name == "ProtoBuffer" && fieldName == "out":
                echo("[backend] debugOverloadDot: computed fieldTypeKey type='ProtoBuffer' field='out' key='" + fieldTypeKey +
                     "' len=" + intToStr(len(fieldTypeKey)))
            if len(fieldTypeKey) > 0:
                if (getEnv "CHENG_BACKEND_DEBUG_OVERLOAD_DOT" == "1") && name == "ProtoBuffer" && fieldName == "out":
                    echo("[backend] debugOverloadDot: put fieldTypeKey type='ProtoBuffer' field='out' key='" + fieldTypeKey + "'")
                mirObjFieldTypeKeyPut(name, fieldName, fieldTypeKey)
            let objFieldType: str = typeNodeObjTypeName(mod, fieldTypeNode)
            if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1") && (name == "EcKeyPair"):
                let isObjFieldValDbg: bool = typeNodeIsObjValue(mod, fieldTypeNode)
                echo("[backend] debugTypes: type=" + name + " field=" + fieldName +
                     " fieldTypeKey='" + fieldTypeKey + "' objFieldType='" + objFieldType +
                     "' isObjValue=" + (isObjFieldValDbg ? "1" : "0"))
            if len(objFieldType) > 0 && typeNodeIsObjValue(mod, fieldTypeNode) && mirHasObjType(mod, objFieldType):
                mirInlineObjFieldTypePut(name, fieldName, objFieldType)
                let inner: MirObjType = mirGetObjType(mod, objFieldType)
                if inner.size <= 0 || inner.fields.len == 0:
                    if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1"):
                        echo("[backend] debug: pending type " + name + " inline object unresolved: " + objFieldType)
                    return Ok[bool](true)
                let alignPow2: int32 = inner.alignPow2
                if alignPow2 > maxAlignPow2:
                    maxAlignPow2 = alignPow2
                offset = alignUpPow2(offset, alignPow2)
                for fi in 0..<inner.fields.len:
                    let innerF: MirObjField = inner.fields[fi]
                    var f: MirObjField
                    f.name = fieldName + "." + innerF.name
                    f.ty = innerF.ty
                    f.offset = offset + innerF.offset
                    add(fields, f)
                offset = offset + inner.size
                continue
            if fieldTypeNode != nil && (fieldTypeNode.kind == nkIdent || fieldTypeNode.kind == nkSymbol || fieldTypeNode.kind == nkBracketExpr ||
               fieldTypeNode.kind == nkDotExpr):
                # `typeKey(nkDotExpr)` is not stable (may fall back to "node"). Depend on the RHS name instead.
                var depKey: str = ""
                if fieldTypeNode.kind == nkDotExpr && kidCount(fieldTypeNode) > 1:
                    depKey = typeKey(kid(fieldTypeNode, 1))
                else:
                    depKey = typeKey(fieldTypeNode)
                let depName: str = (len(depKey) > 0) ? depKey : backendStripSpaces(plainName(fieldTypeNode))
                if len(depName) > 0 && !isBuiltinTypeName(depName):
                    let depAlias: MirType = mirTryGetTypeAlias(mod, depName)
                    if !mirHasObjType(mod, depName) && depAlias.kind == mtVoid:
                        if !(mirStrStartsWith(depName, "SeqUninit_") && ensureSeqUninitObjType(mod, depName)):
                            if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1"):
                                echo("[backend] debug: pending type " + name + " depends on " + depName)
                            return Ok[bool](true)
            let fieldTy: MirType = mirTypeFromNodeWithModule(mod, fieldTypeNode)
            let fieldSize: int32 = mirTypeSize(fieldTy)
            if fieldSize <= 0:
                return Err[bool]("mir_builder: unsupported record field type")
            let alignPow2: int32 = mirTypeAlignPow2(fieldTy)
            if alignPow2 > maxAlignPow2:
                maxAlignPow2 = alignPow2
            offset = alignUpPow2(offset, alignPow2)
            var f: MirObjField
            f.name = fieldName
            f.ty = fieldTy
            f.offset = offset
            add(fields, f)
            offset = offset + fieldSize
        var ot: MirObjType
        ot.name = name
        ot.alignPow2 = maxAlignPow2
        ot.size = alignUpPow2(offset, maxAlignPow2)
        ot.fields = fields
        if existingObj >= 0:
            mbWriteObjType(&mod.objTypes, existingObj, ot)
        else:
            mirAddObjType(mod, ot)
        if isRefLike:
            mirAddTypeAlias(mod, name, mirTypeI64())
        return Ok[bool](false)
    if defNode != nil && defNode.kind == nkEnumDecl:
        # Represent enums as int32 (matches stage1 C backend lowering).
        mirAddTypeAlias(mod, name, mirTypeI32())
        var nextVal: int64 = 0
        for fi in 0..<kidCount(defNode):
            let field: Node = kid(defNode, fi)
            if field == nil || field.kind == nkEmpty:
                continue
            if field.kind != nkEnumFieldDecl || kidCount(field) == 0:
                return Err[bool]("mir_builder: invalid enum field")
            let fieldNameNode: Node = kid(field, 0)
            if fieldNameNode == nil || (fieldNameNode.kind != nkIdent && fieldNameNode.kind != nkSymbol):
                return Err[bool]("mir_builder: enum field expects identifier")
            var valNode: Node = nil
            if kidCount(field) > 1:
                valNode = kid(field, 1)
            while valNode != nil && valNode.kind == nkPar && kidCount(valNode) > 0:
                valNode = kid(valNode, 0)
            var fieldVal: int64 = nextVal
            if valNode != nil && valNode.kind != nkEmpty:
                if valNode.kind == nkIntLit:
                    fieldVal = valNode.intVal
                elif valNode.kind == nkIdent || valNode.kind == nkSymbol:
                    let dep: str = plainName(valNode)
                    let gi: int32 = moduleGlobalIndex(mod, dep)
                    if gi >= 0:
                        let g: MirGlobal = mod.globals[gi]
                        if g.hasInit:
                            fieldVal = g.init
                        else:
                            return Ok[bool](true)
                    else:
                        return Ok[bool](true)
                else:
                    return Err[bool]("mir_builder: enum field value expects int literal")
            let fieldName: str = backendStripSpaces(plainName(fieldNameNode))
            if len(fieldName) == 0:
                return Err[bool]("mir_builder: enum field expects name")
            if moduleHasFunc(mod, fieldName) || moduleHasGlobal(mod, fieldName):
                return Err[bool]("mir_builder: enum field conflicts with existing name")
            mirAddGlobal(mod, fieldName, mirTypeI32(), fieldVal, true, "")
            nextVal = fieldVal + 1
        return Ok[bool](false)
    if defNode != nil && (defNode.kind == nkTupleTy || defNode.kind == nkBracketExpr):
        let rhsObjName: str = typeNodeObjTypeName(mod, defNode)
        if len(rhsObjName) > 0 && mirHasObjType(mod, rhsObjName):
            # Type aliases to object-like type expressions become a new name for the same layout.
            var rhs: MirObjType = mirGetObjType(mod, rhsObjName)
            rhs.name = name
            mirAddObjType(mod, rhs)
            mirObjAliasPut(name, rhsObjName)
            return Ok[bool](false)
        # Avoid producing scalar aliases to mtVoid for object-like type expressions.
        if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1"):
            echo("[backend] debug: pending alias " + name + " object-like rhs unresolved")
        return Ok[bool](true)
    if defNode == nil || defNode.kind == nkEmpty:
        return Err[bool]("mir_builder: type alias missing body")
    if defNode.kind == nkIdent || defNode.kind == nkSymbol:
        let rhsName: str = backendStripSpaces(plainName(defNode))
        let rhsObjName2: str = typeNodeObjTypeName(mod, defNode)
        if len(rhsObjName2) > 0 && mirHasObjType(mod, rhsObjName2):
            var rhs: MirObjType = mirGetObjType(mod, rhsObjName2)
            rhs.name = name
            mirAddObjType(mod, rhs)
            mirObjAliasPut(name, rhsObjName2)
            return Ok[bool](false)
        let rhsAlias: MirType = mirTryGetTypeAlias(mod, rhsName)
        if len(rhsName) > 0 && !isBuiltinTypeName(rhsName) && rhsAlias.kind == mtVoid:
            if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1"):
                echo("[backend] debug: pending alias " + name + " depends on alias " + rhsName)
            return Ok[bool](true)
    let aliasTy: MirType = mirTypeFromNodeWithModule(mod, defNode)
    mirAddTypeAlias(mod, name, aliasTy)
    return Ok[bool](false)

fn mirConsumeTypeDecls(mod: MirModule, root: Node): Result[bool] =
    if root == nil:
        return Ok[bool](false)
    var work: Node[]
    var queue: Node[]
    add(queue, root)
    while queue.len > 0:
        let n: Node = queue[queue.len - 1]
        queue.len = queue.len - 1
        if n == nil:
            continue
        if n.kind == nkTypeDecl:
            add(work, n)
            continue
        if n.kind == nkStmtList || n.kind == nkModule:
            for i in 0..<kidCount(n):
                add(queue, kid(n, i))
    if work.len == 0:
        return Ok[bool](false)
    var pending: Node[] = work
    var pass: int32 = 0
    while pending.len > 0:
        if pass > work.len + 8:
            return Err[bool]("mir_builder: type dependency resolution exceeded iteration limit")
        var next: Node[]
        var progressed: bool = false
        for i2 in 0..<pending.len:
            let td: Node = pending[i2]
            let res: Result[bool] = mirConsumeTypeDecl(mod, td)
            if !IsOk[bool](res):
                return ErrInfo[bool](ErrorInfoOf[bool](res))
            if Value[bool](res):
                add(next, td)
            else:
                progressed = true
        if !progressed:
            var msg: str = "mir_builder: unresolved type dependencies:"
            var shown: int32 = 0
            for i3 in 0..<pending.len:
                if !(shown < 32):
                    break
                let td2: Node = pending[i3]
                var nm2: str = ""
                if td2 != nil && kidCount(td2) > 0:
                    let nn: Node = kid(td2, 0)
                    if nn != nil && (nn.kind == nkIdent || nn.kind == nkSymbol):
                        nm2 = backendStripSpaces(plainName(nn))
                if nm2 != nil && len(nm2) > 0:
                    msg = msg + " " + nm2
                    shown = shown + 1
            return Err[bool](msg)
        pending = next
        pass = pass + 1
    return Ok[bool](false)

type
    MirBuildCtx = ref
        foundMain: bool
        traceEnabled: bool
        traceFnCount: int32
        traceGlobalCount: int32
        overloadedFnBases: hashsets.HashSetStr
        globalInits: MirGlobalInit[]

    MirGlobalInit = ref
        name: str
        ty: MirType
        objTypeName: str
        initNode: Node
        filePath: str
        seqFixedElemType: Node
        seqFixedCapExpr: Node

fn mirPredeclareGlobalsForTypes(mod: MirModule, root: Node) =
    # Array type expressions like `array[ConstLen, T]` require the length constant
    # to be available during type dependency resolution. Predeclare simple scalar
    # globals (int/bool/nil literals) so `tryResolveArrayCount` can resolve them.
    if mod == nil || root == nil:
        return
    let preFile: str = "<predeclared>"
    var queue: Node[]
    add(queue, root)
    while queue.len > 0:
        let n: Node = queue[queue.len - 1]
        queue.len = queue.len - 1
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkStmtList || n.kind == nkModule:
            for i in 0..<kidCount(n):
                add(queue, kid(n, i))
            continue
        if n.kind != nkConst && n.kind != nkLet && n.kind != nkVar:
            continue
        var pat: Node = nil
        if kidCount(n) > 0:
            pat = kid(n, 0)
        var init: Node = nil
        if kidCount(n) > 2:
            init = kid(n, 2)
        var nameNode: Node = pat
        var typeNode: Node = nil
        if kidCount(n) > 1:
            typeNode = kid(n, 1)
        if pat != nil && pat.kind == nkPattern && kidCount(pat) > 0:
            nameNode = kid(pat, 0)
            if kidCount(pat) > 1:
                typeNode = kid(pat, 1)
        if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
            continue
        let name: str = plainName(nameNode)
        if moduleHasFunc(mod, name) || moduleHasGlobal(mod, name) ||
           mirFindTypeAlias(mod, name) >= 0 || mirFindObjType(mod, name) >= 0:
            continue
        var initCore: Node = init
        while initCore != nil && initCore.kind == nkPar && kidCount(initCore) > 0:
            initCore = kid(initCore, 0)
        var hasInit: bool = false
        var initVal: int64 = 0
        if initCore != nil && initCore.kind != nkEmpty:
            if initCore.kind == nkIntLit:
                hasInit = true
                initVal = initCore.intVal
            elif initCore.kind == nkBoolLit:
                hasInit = true
                let v: str = backendStripSpaces(initCore.ident)
                initVal = (v == "true") ? 1 : 0
            elif initCore.kind == nkNilLit:
                hasInit = true
                initVal = 0
        var declTy: MirType = mirTypeFromNodeWithModule(mod, typeNode)
        if declTy.kind == mtVoid:
            if hasInit:
                if initCore != nil && initCore.kind == nkBoolLit:
                    declTy = mirTypeU8()
                elif initCore != nil && initCore.kind == nkNilLit:
                    declTy = mirTypeI64()
                else:
                    declTy = mirTypeI32()
            else:
                declTy = mirTypeI64()
        mirAddGlobal(mod, name, declTy, initVal, hasInit, preFile)
        if typeNode != nil && typeNode.kind != nkEmpty:
            mirGlobalTypeKeyPut(name, typeKey(typeNode))

fn mirPredeclareGlobalsForLowering(mod: MirModule, root: Node) =
    if mod == nil || root == nil:
        return
    let preFile: str = "<predeclared>"
    var queue: Node[]
    add(queue, root)
    while queue.len > 0:
        let n: Node = queue[queue.len - 1]
        queue.len = queue.len - 1
        if n == nil || n.kind == nkEmpty:
            continue
        if n.kind == nkStmtList || n.kind == nkModule:
            for i in 0..<kidCount(n):
                add(queue, kid(n, i))
            continue
        if n.kind != nkConst && n.kind != nkLet && n.kind != nkVar:
            continue
        var pat: Node = nil
        if kidCount(n) > 0:
            pat = kid(n, 0)
        var init: Node = nil
        if kidCount(n) > 2:
            init = kid(n, 2)
        var nameNode: Node = pat
        var typeNode: Node = nil
        if kidCount(n) > 1:
            typeNode = kid(n, 1)
        if pat != nil && pat.kind == nkPattern && kidCount(pat) > 0:
            nameNode = kid(pat, 0)
            if kidCount(pat) > 1:
                typeNode = kid(pat, 1)
        if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
            continue
        let rawName: str = backendStripSpaces(plainName(nameNode))
        if rawName == nil || len(rawName) == 0:
            continue
        let debugDot: bool = (getEnv "CHENG_BACKEND_DEBUG_DOT" == "1")
        let filePath: str = (n.strVal != nil && len(n.strVal) > 0) ? n.strVal : preFile
        if debugDot && rawName == "baseIdentity":
            var typeKindDbg: str = "nil"
            if typeNode != nil:
                typeKindDbg = intToStr(int32(typeNode.kind))
            echo("[backend] debugDot: predeclareLowering rawName='" + rawName +
                 "' file='" + filePath + "' typeKind=nk#" + typeKindDbg + "'")
        let name: str = mirMaybeMangleDupGlobalName(rawName, filePath)
        if moduleHasFunc(mod, name) || moduleHasGlobal(mod, name) ||
           mirFindTypeAlias(mod, name) >= 0 || mirFindObjType(mod, name) >= 0:
            continue

        var declType: MirType = mirTypeFromNodeWithModule(mod, typeNode)
        var objTypeName: str = ""
        var objTypeNode: Node = typeNode
        if (objTypeNode == nil || objTypeNode.kind == nkEmpty) && init != nil && init.kind != nkEmpty &&
           init.typeCacheValid && init.typeCache != nil:
            objTypeNode = init.typeCache
        if objTypeNode != nil && objTypeNode.kind != nkEmpty:
            objTypeName = typeNodeObjTypeName(mod, objTypeNode)
        let isObj: bool = len(objTypeName) > 0 && objTypeNode != nil && typeNodeIsObjValue(mod, objTypeNode)
        if debugDot && rawName == "baseIdentity":
            let objNodeKindDbg: str = (objTypeNode != nil) ? intToStr(int32(objTypeNode.kind)) : "nil"
            echo("[backend] debugDot: predeclareLowering name='" + name +
                 "' objTypeName='" + objTypeName + "' isObj=" + (isObj ? "1" : "0") +
                 " objNodeKind=nk#" + objNodeKindDbg + "'")
        if isObj:
            mirGlobalObjTypePut(name, objTypeName)
            declType = mirTypeI64()
        elif typeNode == nil || typeNode.kind == nkEmpty:
            declType = inferExprTypeWithGlobals(nil, mod, nil, init, declType)
        if declType.kind == mtVoid:
            declType = mirTypeI64()
        if !isObj && (declType.kind == mtI8 || declType.kind == mtI16):
            let wasUnsigned: bool = declType.isUnsigned
            declType = mirTypeI32()
            declType.isUnsigned = wasUnsigned

        var initCore: Node = init
        while initCore != nil && initCore.kind == nkPar && kidCount(initCore) > 0:
            initCore = kid(initCore, 0)
        var hasInit: bool = false
        var initVal: int64 = 0
        if !isObj && initCore != nil && initCore.kind != nkEmpty:
            if initCore.kind == nkIntLit:
                hasInit = true
                initVal = initCore.intVal
            elif initCore.kind == nkBoolLit:
                hasInit = true
                let v: str = backendStripSpaces(initCore.ident)
                initVal = (v == "true") ? 1 : 0
            elif initCore.kind == nkNilLit:
                hasInit = true
                initVal = 0
        mirAddGlobal(mod, name, declType, initVal, hasInit, preFile)

        var keyOut: str = ""
        if objTypeNode != nil && objTypeNode.kind != nkEmpty:
            keyOut = typeKey(objTypeNode)
            if keyOut == nil || len(keyOut) == 0:
                keyOut = mirTypeKeyFromNodeLoose(objTypeNode)
        elif typeNode != nil && typeNode.kind != nkEmpty:
            keyOut = typeKey(typeNode)
            if keyOut == nil || len(keyOut) == 0:
                keyOut = mirTypeKeyFromNodeLoose(typeNode)
        if keyOut != nil && len(keyOut) > 0:
            mirGlobalTypeKeyPut(name, keyOut)

fn ctxAddGlobalInit(ctx: MirBuildCtx, name: str, ty: MirType, objTypeName: str, initNode: Node, filePath: str,
                    seqFixedElemType: Node = nil, seqFixedCapExpr: Node = nil) =
    if ctx == nil || name == nil || len(name) == 0:
        return
    if ctx.globalInits.buffer == nil:
        ctx.globalInits = []
    var gi: MirGlobalInit
    new gi
    gi.name = name
    gi.ty = ty
    gi.objTypeName = objTypeName
    gi.initNode = initNode
    gi.filePath = filePath
    gi.seqFixedElemType = seqFixedElemType
    gi.seqFixedCapExpr = seqFixedCapExpr
    add(ctx.globalInits, gi)

fn mirParseModuleWithLoweredTypes(filePath: str, content: str, outRoot: Node*): bool =
    if outRoot == nil:
        return false
    let tokens: Token[] = lexTokens(content, filePath)
    let root: Node = parseModule(tokens, filePath)
    var diags: Diagnostic[]
    diags.buffer = nil
    diags.len = 0
    diags.cap = 16
    type_syntax_lowering.lowerTypeSyntax(root, &diags, filePath)
    if hasError diags:
        printDiagnostics diags
        return false
    *outRoot = root
    return true

fn mirConsumeFile(mod: MirModule, ctx: MirBuildCtx, filePath: str): Result[str[]] =
    if filePath == nil || len(filePath) == 0:
        return Err[str[]]("mir_builder: empty file path")
    if ! frontend_lib.stage1_fileExists(filePath):
        return Err[str[]]("mir_builder: import file not found")
    let content: str = frontend_lib.stage1_readFile(filePath)
    var root: Node = nil
    if !mirParseModuleWithLoweredTypes(filePath, content, &root):
        releaseNodeArena()
        return Err[str[]]("mir_builder: stage1 errors")
    let rawImports: str[] = collectImportPaths(root)
    var imports: str[]
    for ii in 0..<rawImports.len:
        let impPath: str = rawImports[ii]
        let resolvedRes: Result[str] = resolveImportToFilePath(impPath, filePath)
        if ! IsOk[str](resolvedRes):
            releaseNodeArena()
            return ErrInfo[str[]](ErrorInfoOf[str](resolvedRes))
        add(imports, Value[str](resolvedRes))
    let tdRes: Result[bool] = mirConsumeTypeDecls(mod, root)
    if ! IsOk[bool](tdRes):
        releaseNodeArena()
        return ErrInfo[str[]](ErrorInfoOf[bool](tdRes))
    for i in 0..<kidCount(root):
        let n: Node = kid(root, i)
        if n != nil && (n.kind == nkVar || n.kind == nkLet || n.kind == nkConst):
            var pat: Node = nil
            if kidCount(n) > 0:
                pat = kid(n, 0)
            var init: Node = nil
            if kidCount(n) > 2:
                init = kid(n, 2)
            var nameNode: Node = pat
            var typeNode: Node = nil
            if kidCount(n) > 1:
                typeNode = kid(n, 1)
            if pat != nil && pat.kind == nkPattern && kidCount(pat) > 0:
                nameNode = kid(pat, 0)
                if kidCount(pat) > 1:
                    typeNode = kid(pat, 1)
            if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
                releaseNodeArena()
                return Err[str[]]("mir_builder: global expects identifier")
            let name: str = plainName(nameNode)
            if moduleHasFunc(mod, name) || moduleHasGlobal(mod, name) ||
               mirFindTypeAlias(mod, name) >= 0 || mirFindObjType(mod, name) >= 0:
                releaseNodeArena()
                return Err[str[]]("mir_builder: duplicate global name")
            var declType: MirType = mirTypeFromNodeWithModule(mod, typeNode)
            if typeNode == nil || typeNode.kind == nkEmpty:
                declType = inferExprTypeWithGlobals(nil, mod, nil, init, declType)
            var hasInit: bool = false
            var initVal: int64 = 0
            if init != nil && init.kind != nkEmpty:
                hasInit = true
                if init.kind == nkIntLit:
                    initVal = init.intVal
                elif init.kind == nkBoolLit:
                    let v: str = backendStripSpaces(init.ident)
                    initVal = (v == "true") ? 1 : 0
                elif init.kind == nkNilLit:
                    initVal = 0
                else:
                    releaseNodeArena()
                    return Err[str[]]("mir_builder: unsupported global initializer")
            mirAddGlobal(mod, name, declType, initVal, hasInit, filePath)
            continue
        if n != nil && n.kind == nkFnDecl:
            let fRes: Result[MirFunc] = mirBuildFunc(mod, n, filePath)
            if ! IsOk[MirFunc](fRes):
                releaseNodeArena()
                return ErrInfo[str[]](ErrorInfoOf[MirFunc](fRes))
            let f: MirFunc = Value[MirFunc](fRes)
            if f == nil:
                continue
            if moduleHasFunc(mod, f.name) || moduleHasGlobal(mod, f.name) ||
               mirFindTypeAlias(mod, f.name) >= 0 || mirFindObjType(mod, f.name) >= 0:
                var sameFile: bool = false
                for di in 0..<mod.funcs.len:
                    let ex: MirFunc = mod.funcs[di]
                    if ex != nil && (ex.name == f.name) && (ex.originFile == f.originFile):
                        sameFile = true
                        break
                if sameFile:
                    continue
                releaseNodeArena()
                return Err[str[]]("mir_builder: duplicate function name: " + f.name)
            if (f.name == "main"):
                if ctx != nil && ctx.foundMain:
                    releaseNodeArena()
                    return Err[str[]]("mir_builder: multiple main functions")
                if ctx != nil:
                    ctx.foundMain = true
            mirAddFunc(mod, f)
    releaseNodeArena()
    return Ok[str[]](imports)

fn mirBuildModuleFromFile(path: str): Result[MirModule] =
    if len(path) == 0:
        return Err[MirModule]("mir_builder: empty path")
    mirGlobalObjTypesReset()
    mirGlobalTypeKeysReset()
    mirInlineObjFieldTypesReset()
    mirObjFieldTypeKeysReset()
    mirTupleFieldIndicesReset()
    mirObjAliasesReset()
    mirDupFnBasesReset()
    mirDupGlobalNamesReset()
    let mod: MirModule = mirNewModule("arm64-apple-darwin")
    ensureBuiltinObjTypes(mod)
    var ctx: MirBuildCtx
    new ctx
    ctx.foundMain = false
    ctx.traceEnabled = stage1TraceEnabled()
    ctx.traceFnCount = 0
    ctx.traceGlobalCount = 0
    ctx.globalInits = []

    # Pass 1: collect full import closure.
    var queue: str[]
    add(queue, path)
    var files: str[]
    var fileImportStart: int32[]
    var fileImportLen: int32[]
    var fileImportPool: str[]
    var fileIndex: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(128)
    var dupGlobalNameIndex: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(2048)
    var dupGlobalNames: str[]
    var dupGlobalCounts: int32[]
    for qi in 0..<queue.len:
        let filePath: str = queue[qi]
        if filePath == nil || len(filePath) == 0:
            return Err[MirModule]("mir_builder: empty file path")
        var seen: bool = false
        let seenIdx: int32 = mirHashMapStrIntGetCompat(fileIndex, filePath, seen)
        if seen && seenIdx >= 0:
            continue
        add(files, filePath)
        hashmaps.hashMapStrIntPut(fileIndex, filePath, files.len - 1)
        if ! frontend_lib.stage1_fileExists(filePath):
            return Err[MirModule]("mir_builder: import file not found")
        let content: str = frontend_lib.stage1_readFile(filePath)
        var root: Node = nil
        if !mirParseModuleWithLoweredTypes(filePath, content, &root):
            releaseNodeArena()
            return Err[MirModule]("mir_builder: stage1 errors")
        let rawImports: str[] = collectImportPaths(root)
        var declScanQueue: Node[]
        add(declScanQueue, root)
        while declScanQueue.len > 0:
            let n0: Node = declScanQueue[declScanQueue.len - 1]
            declScanQueue.len = declScanQueue.len - 1
            if n0 == nil || n0.kind == nkEmpty:
                continue
            if n0.kind == nkStmtList || n0.kind == nkModule:
                for ni in 0..<kidCount(n0):
                    add(declScanQueue, kid(n0, ni))
                continue
            if n0.kind != nkVar && n0.kind != nkLet && n0.kind != nkConst:
                continue
            var pat0: Node = nil
            if kidCount(n0) > 0:
                pat0 = kid(n0, 0)
            var nameNode0: Node = pat0
            if pat0 != nil && pat0.kind == nkPattern && kidCount(pat0) > 0:
                nameNode0 = kid(pat0, 0)
            if nameNode0 == nil || (nameNode0.kind != nkIdent && nameNode0.kind != nkSymbol):
                continue
            let globalName0: str = backendStripSpaces(plainName(nameNode0))
            if globalName0 == nil || len(globalName0) == 0:
                continue
            var foundDupG: bool = false
            let rawG: int32 = mirHashMapStrIntGetCompat(dupGlobalNameIndex, globalName0, foundDupG)
            let gIdx0: int32 = rawG - 1
            if foundDupG && rawG > 0 && gIdx0 >= 0 && gIdx0 < dupGlobalCounts.len:
                dupGlobalCounts[gIdx0] = dupGlobalCounts[gIdx0] + 1
            else:
                let newG: int32 = dupGlobalNames.len
                add(dupGlobalNames, globalName0)
                add(dupGlobalCounts, 1)
                hashmaps.hashMapStrIntPut(dupGlobalNameIndex, globalName0, newG + 1)
        var imports: str[]
        for ii0 in 0..<rawImports.len:
            let impPath: str = rawImports[ii0]
            let resolvedRes: Result[str] = resolveImportToFilePath(impPath, filePath)
            if ! IsOk[str](resolvedRes):
                releaseNodeArena()
                return ErrInfo[MirModule](ErrorInfoOf[str](resolvedRes))
            add(imports, Value[str](resolvedRes))
        let importStart: int32 = fileImportPool.len
        add(fileImportStart, importStart)
        add(fileImportLen, imports.len)
        for ii in 0..<imports.len:
            add(fileImportPool, imports[ii])
        releaseNodeArena()
        for ii in 0..<imports.len:
            add(queue, imports[ii])

    for gi in 0..<dupGlobalNames.len:
        if dupGlobalCounts[gi] > 1:
            hashsets.hashSetStrAdd(mirDupGlobalNames, dupGlobalNames[gi])

    # Pass 1b: consume type declarations in import order (imports before importers).
    # This avoids spurious "unresolved type dependencies" when a file's type decls
    # reference imported aliases/object types (e.g. HashMapStrInt, ByteReader, MirModule).
    var indeg: int32[]
    indeg.len = files.len
    var depHead: int32[]
    depHead.len = files.len
    for hi in 0..<depHead.len:
        depHead[hi] = -1
    var depTo: int32[]
    var depNext: int32[]
    for fi0 in 0..<files.len:
        let impStart: int32 = fileImportStart[fi0]
        let impLen: int32 = fileImportLen[fi0]
        for ji in 0..<impLen:
            let impPath: str = fileImportPool[impStart + ji]
            var found: bool = false
            let impIdx: int32 = mirHashMapStrIntGetCompat(fileIndex, impPath, found)
            if found && impIdx >= 0 && impIdx < files.len && impIdx != fi0:
                indeg[fi0] = indeg[fi0] + 1
                let edgeIdx: int32 = depTo.len
                add(depTo, fi0)
                add(depNext, depHead[impIdx])
                depHead[impIdx] = edgeIdx

    var ready: int32[]
    for i0 in 0..<files.len:
        if indeg[i0] == 0:
            add(ready, i0)

    var typeFiles: str[]
    while ready.len > 0:
        let idx0: int32 = ready[ready.len - 1]
        ready.len = ready.len - 1
        add(typeFiles, files[idx0])
        var edge: int32 = depHead[idx0]
        while edge >= 0:
            let depIdx: int32 = depTo[edge]
            let newDeg: int32 = indeg[depIdx] - 1
            indeg[depIdx] = newDeg
            if newDeg == 0:
                add(ready, depIdx)
            edge = depNext[edge]

    # Cycles should not exist in a well-formed program, but keep building a best-effort
    # order to avoid crashing; type resolution may still fail later with a real error.
    if typeFiles.len < files.len:
        for ci0 in 0..<files.len:
            let fp0: str = files[ci0]
            if !seqContainsStr(typeFiles, fp0):
                add(typeFiles, fp0)

    for tf0 in 0..<typeFiles.len:
        let filePath: str = typeFiles[tf0]
        if filePath == nil || len(filePath) == 0:
            return Err[MirModule]("mir_builder: empty file path")
        if ! frontend_lib.stage1_fileExists(filePath):
            return Err[MirModule]("mir_builder: import file not found")
        let content: str = frontend_lib.stage1_readFile(filePath)
        var root: Node = nil
        if !mirParseModuleWithLoweredTypes(filePath, content, &root):
            releaseNodeArena()
            return Err[MirModule]("mir_builder: stage1 errors")
        mirPredeclareGlobalsForTypes(mod, root)
        let tdRes: Result[bool] = mirConsumeTypeDecls(mod, root)
        if ! IsOk[bool](tdRes):
            releaseNodeArena()
            return ErrInfo[MirModule](ErrorInfoOf[bool](tdRes))
        releaseNodeArena()

    # Pass 2: predeclare function signatures across all files first.
    for fi in 0..<files.len:
        let filePath: str = files[fi]
        if filePath == nil || len(filePath) == 0:
            return Err[MirModule]("mir_builder: empty file path")
        if ! frontend_lib.stage1_fileExists(filePath):
            return Err[MirModule]("mir_builder: import file not found")
        let content: str = frontend_lib.stage1_readFile(filePath)
        var root: Node = nil
        if !mirParseModuleWithLoweredTypes(filePath, content, &root):
            releaseNodeArena()
            return Err[MirModule]("mir_builder: stage1 errors")
        for pi in 0..<kidCount(root):
            let n: Node = kid(root, pi)
            let stmtPath: str = (n != nil && n.strVal != nil && len(n.strVal) > 0) ? n.strVal : root.strVal
            let res: Result[bool] = mirPredeclareTopLevelFromRoot(mod, root, stmtPath, n, nil)
            if !IsOk[bool](res):
                releaseNodeArena()
                return ErrInfo[MirModule](ErrorInfoOf[bool](res))
        releaseNodeArena()

    # Pass 3: lower all top-level declarations now that types + signatures exist.
    for fi2 in 0..<files.len:
        let filePath: str = files[fi2]
        if filePath == nil || len(filePath) == 0:
            return Err[MirModule]("mir_builder: empty file path")
        if ! frontend_lib.stage1_fileExists(filePath):
            return Err[MirModule]("mir_builder: import file not found")
        let content: str = frontend_lib.stage1_readFile(filePath)
        var root: Node = nil
        if !mirParseModuleWithLoweredTypes(filePath, content, &root):
            releaseNodeArena()
            return Err[MirModule]("mir_builder: stage1 errors")
        for ti in 0..<kidCount(root):
            let n: Node = kid(root, ti)
            let stmtPath: str = (n != nil && n.strVal != nil && len(n.strVal) > 0) ? n.strVal : root.strVal
            let res: Result[bool] = mirConsumeTopLevelFromRoot(mod, ctx, root, stmtPath, n, nil)
            if ! IsOk[bool](res):
                releaseNodeArena()
                return ErrInfo[MirModule](ErrorInfoOf[bool](res))
        releaseNodeArena()
    let allowNoMain: bool = envIsTrue "CHENG_BACKEND_ALLOW_NO_MAIN" || backendAllowNoMainByEmit()
    if ! ctx.foundMain && !allowNoMain:
        return Err[MirModule]("mir_builder: main not found")

    if ctx.globalInits.len > 0 && !backendSkipGlobalInit():
        let initRes: Result[MirFunc] = mirBuildGlobalInitFunc(mod, ctx)
        if !IsOk[MirFunc](initRes):
            return ErrInfo[MirModule](ErrorInfoOf[MirFunc](initRes))
        mirAddFunc(mod, Value[MirFunc](initRes))
        if ctx.foundMain:
            mirInjectGlobalInitCall(mod, "__cheng_global_init")

    mirNormalizeModule(mod)
    return Ok[MirModule](mod)

fn mirConsumeTopLevelFromRoot(mod: MirModule, ctx: MirBuildCtx, root: Node, filePath: str, n: Node,
                              reachable: hashsets.HashSetStr* = nil,
                              overloaded: hashsets.HashSetStr* = nil): Result[bool] =
    if n == nil || n.kind == nkEmpty:
        return Ok[bool](false)
    if n.kind == nkStmtList || n.kind == nkModule:
        let fallback: str = (filePath != nil && len(filePath) > 0) ? filePath : (root != nil ? root.strVal : "")
        for j in 0..<kidCount(n):
            let nn: Node = kid(n, j)
            let stmtPath: str = (nn != nil && nn.strVal != nil && len(nn.strVal) > 0) ? nn.strVal : fallback
            let res: Result[bool] = mirConsumeTopLevelFromRoot(mod, ctx, root, stmtPath, nn, reachable, overloaded)
            if ! IsOk[bool](res):
                return res
        return Ok[bool](true)
    if n.kind == nkVar || n.kind == nkLet || n.kind == nkConst:
        var pat: Node = nil
        if kidCount(n) > 0:
            pat = kid(n, 0)
        var init: Node = nil
        if kidCount(n) > 2:
            init = kid(n, 2)
        var nameNode: Node = pat
        var typeNode: Node = nil
        if kidCount(n) > 1:
            typeNode = kid(n, 1)
        if pat != nil && pat.kind == nkPattern && kidCount(pat) > 0:
            nameNode = kid(pat, 0)
            if kidCount(pat) > 1:
                typeNode = kid(pat, 1)
        if nameNode == nil || (nameNode.kind != nkIdent && nameNode.kind != nkSymbol):
            return Err[bool]("mir_builder: global expects identifier")
        let rawName: str = backendStripSpaces(plainName(nameNode))
        let name: str = mirMaybeMangleDupGlobalName(rawName, filePath)
        let debugDot: bool = (getEnv "CHENG_BACKEND_DEBUG_DOT" == "1")
        if debugDot && rawName == "baseIdentity":
            var typeKindDbg: str = "nil"
            if typeNode != nil:
                typeKindDbg = intToStr(int32(typeNode.kind))
            echo("[backend] debugDot: consumeGlobal rawName='" + rawName +
                 "' file='" + filePath + "' typeKind=nk#" + typeKindDbg + "'")
        let existingGi: int32 = moduleGlobalIndex(mod, name)
        var allowDupGlobal: bool = false
        if existingGi >= 0:
            let g0: MirGlobal = mod.globals[existingGi]
            allowDupGlobal = (g0.originFile == "<predeclared>")
        var declType: MirType = mirTypeFromNodeWithModule(mod, typeNode)
        var objTypeName: str = ""
        var objTypeNode: Node = typeNode
        if (objTypeNode == nil || objTypeNode.kind == nkEmpty) && init != nil && init.kind != nkEmpty &&
           init.typeCacheValid && init.typeCache != nil:
            objTypeNode = init.typeCache
        if objTypeNode != nil && objTypeNode.kind != nkEmpty:
            objTypeName = typeNodeObjTypeName(mod, objTypeNode)
        let isObj: bool = len(objTypeName) > 0 && objTypeNode != nil && typeNodeIsObjValue(mod, objTypeNode)
        if debugDot && rawName == "baseIdentity":
            let objNodeKindDbg: str = (objTypeNode != nil) ? intToStr(int32(objTypeNode.kind)) : "nil"
            echo("[backend] debugDot: consumeGlobal name='" + name +
                 "' objTypeName='" + objTypeName + "' isObj=" + (isObj ? "1" : "0") +
                 " objNodeKind=nk#" + objNodeKindDbg + "'")
        if isObj:
            mirGlobalObjTypePut(name, objTypeName)
            if debugDot && rawName == "baseIdentity":
                let chkObj: str = mirGlobalObjTypeGet(name)
                echo("[backend] debugDot: consumeGlobal putObj name='" + name + "' objTypeName='" +
                     objTypeName + "' chkObj='" + chkObj + "'")
        if isObj:
            declType = mirTypeI64()
        elif typeNode == nil || typeNode.kind == nkEmpty:
            declType = inferExprTypeWithGlobals(nil, mod, nil, init, declType)
        # Match stage1 C backend's global layout: store sub-32-bit scalars as i32 slots.
        # This keeps the MVP backend's global pipeline simple and avoids i8/i16-only data sections.
        if !isObj && (declType.kind == mtI8 || declType.kind == mtI16):
            let wasUnsigned: bool = declType.isUnsigned
            declType = mirTypeI32()
            declType.isUnsigned = wasUnsigned

        if existingGi >= 0 && !allowDupGlobal && n.kind == nkConst && !isObj:
            var init0: Node = init
            while init0 != nil && init0.kind == nkPar && kidCount(init0) > 0:
                init0 = kid(init0, 0)
            let isLiteralInit: bool = init0 != nil &&
                (init0.kind == nkIntLit || init0.kind == nkBoolLit || init0.kind == nkNilLit)
            if isLiteralInit:
                let g0: MirGlobal = mod.globals[existingGi]
                let prevFile: str = g0.originFile
                let prevSyntheticOrStd: bool = (prevFile != nil && len(prevFile) > 0) &&
                    (prevFile[0] == '<' || __cheng_string_contains_str(prevFile, "/src/std/") ||
                     __cheng_string_contains_str(prevFile, "/src/core/") || __cheng_string_contains_str(prevFile, "/src/system/"))
                let curSyntheticOrStd: bool = (filePath != nil && len(filePath) > 0) &&
                    (filePath[0] == '<' || __cheng_string_contains_str(filePath, "/src/std/") ||
                     __cheng_string_contains_str(filePath, "/src/core/") || __cheng_string_contains_str(filePath, "/src/system/"))
                if (prevSyntheticOrStd || curSyntheticOrStd) &&
                   g0.ty.kind == declType.kind && g0.ty.isUnsigned == declType.isUnsigned:
                    allowDupGlobal = true

        if moduleHasFunc(mod, name) || (existingGi >= 0 && !allowDupGlobal) ||
           mirFindTypeAlias(mod, name) >= 0 || mirFindObjType(mod, name) >= 0:
            let line0: str = intToStr(nameNode.pos.line)
            let col0: str = intToStr(nameNode.pos.col)
            var prevFile: str = ""
            if existingGi >= 0:
                let gPrev: MirGlobal = mod.globals[existingGi]
                prevFile = gPrev.originFile
            return Err[bool]("mir_builder: duplicate global name: " + name +
                             " (prev=" + prevFile + " cur=" + filePath + ":" + line0 + ":" + col0 + ")")

        var hasInit: bool = false
        var initVal: int64 = 0

        if isObj:
            # Object globals are represented as pointers to heap storage; initialize at runtime.
            hasInit = false
            initVal = 0
            let sfi: SeqFixedInit = seqFixedInitInfo(typeNode)
            ctxAddGlobalInit(ctx, name, declType, objTypeName, init, filePath, sfi.elemType, sfi.capExpr)
        elif init != nil && init.kind != nkEmpty:
            # Scalar globals: allow static init for simple literals; otherwise defer to runtime init.
            if init.kind == nkIntLit:
                hasInit = true
                initVal = init.intVal
            elif init.kind == nkBoolLit:
                hasInit = true
                let v: str = backendStripSpaces(init.ident)
                initVal = (v == "true") ? 1 : 0
            elif init.kind == nkNilLit:
                hasInit = true
                initVal = 0
            else:
                hasInit = false
                initVal = 0
                ctxAddGlobalInit(ctx, name, declType, "", init, filePath)

        if existingGi >= 0 && allowDupGlobal:
            var gOut: MirGlobal
            gOut.name = name
            gOut.ty = declType
            gOut.init = initVal
            gOut.hasInit = hasInit
            gOut.originFile = filePath
            mbWriteGlobal(&mod.globals, existingGi, gOut)
        else:
            mirAddGlobal(mod, name, declType, initVal, hasInit, filePath)

        var keyOut: str = ""
        if objTypeNode != nil && objTypeNode.kind != nkEmpty:
            keyOut = typeKey(objTypeNode)
            if keyOut == nil || len(keyOut) == 0:
                keyOut = mirTypeKeyFromNodeLoose(objTypeNode)
        if len(keyOut) == 0 && typeNode != nil && typeNode.kind != nkEmpty:
            keyOut = typeKey(typeNode)
            if keyOut == nil || len(keyOut) == 0:
                keyOut = mirTypeKeyFromNodeLoose(typeNode)
        if len(keyOut) == 0 && init != nil && init.kind != nkEmpty:
            var initKeyNode: Node = init
            while initKeyNode != nil && initKeyNode.kind == nkPar && kidCount(initKeyNode) > 0:
                initKeyNode = kid(initKeyNode, 0)
            if initKeyNode != nil && initKeyNode.typeCacheValid && initKeyNode.typeCache != nil:
                keyOut = typeKey initKeyNode.typeCache
            elif initKeyNode != nil && initKeyNode.kind == nkStrLit:
                keyOut = "str"
            elif initKeyNode != nil && initKeyNode.kind == nkFloatLit:
                keyOut = "float64"
            elif initKeyNode != nil && initKeyNode.kind == nkBoolLit:
                keyOut = "bool"
            elif initKeyNode != nil && initKeyNode.kind == nkCharLit:
                keyOut = "char"
            elif initKeyNode != nil && initKeyNode.kind == nkIntLit:
                if declType.kind == mtI64:
                    keyOut = declType.isUnsigned ? "uint64" : "int64"
                elif declType.kind == mtI32:
                    keyOut = declType.isUnsigned ? "uint32" : "int32"
                elif declType.kind == mtF64:
                    keyOut = "float64"
                elif declType.kind == mtF32:
                    keyOut = "float32"
                elif declType.kind == mtI16:
                    keyOut = declType.isUnsigned ? "uint16" : "int16"
                elif declType.kind == mtI8:
                    keyOut = declType.isUnsigned ? "uint8" : "int8"
        if keyOut != nil && len(keyOut) > 0:
            mirGlobalTypeKeyPut(name, keyOut)
            if debugDot && rawName == "baseIdentity":
                let chkKey: str = mirGlobalTypeKeyGet(name)
                echo("[backend] debugDot: consumeGlobal putKey name='" + name +
                     "' keyOut='" + keyOut + "' chkKey='" + chkKey + "'")
        if ctx != nil && ctx.traceEnabled:
            ctx.traceGlobalCount = ctx.traceGlobalCount + 1
            if (ctx.traceGlobalCount % 200) == 0:
                stage1Trace("backend: mir globals=" + intToStr(ctx.traceGlobalCount) + " last=" + name)
        return Ok[bool](true)
    if n.kind == nkFnDecl || n.kind == nkIteratorDecl:
        if reachable != nil:
            let nameNode: Node = kid(n, 0)
            if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol):
                let nm: str = backendStripSpaces(plainName(nameNode))
                if !hashsets.hashSetStrHas(*reachable, nm):
                    return Ok[bool](false)
        if mirFuncSigHasUnresolvedGenerics(n):
            return Ok[bool](false)
        let fRes: Result[MirFunc] = mirBuildFunc(mod, n, filePath, overloaded)
        if ! IsOk[MirFunc](fRes):
            return ErrInfo[bool](ErrorInfoOf[MirFunc](fRes))
        let f: MirFunc = Value[MirFunc](fRes)
        if f == nil:
            return Ok[bool](false)
        # Predeclare pass inserts header-only entries first. Always try
        # same-file replacement before duplicate-name checks so stale caches
        # cannot leave body-less declarations in the final module.
        var sameFileIdx: int32 = -1
        for di in 0..<mod.funcs.len:
            let ex: MirFunc = mod.funcs[di]
            if ex != nil && (ex.name == f.name) && (ex.originFile == f.originFile):
                sameFileIdx = di
                break
        if sameFileIdx >= 0:
            let ex2: MirFunc = mod.funcs[sameFileIdx]
            if ex2 == nil || ex2.blocks.len == 0:
                mbWriteFunc(&mod.funcs, sameFileIdx, f)
                if (f.name == "main"):
                    if ctx != nil && ctx.foundMain:
                        return Err[bool]("mir_builder: multiple main functions")
                    if ctx != nil:
                        ctx.foundMain = true
                if ctx != nil && ctx.traceEnabled:
                    ctx.traceFnCount = ctx.traceFnCount + 1
                    if (ctx.traceFnCount % 50) == 0:
                        stage1Trace("backend: mir funcs=" + intToStr(ctx.traceFnCount) + " last=" + f.name)
                return Ok[bool](true)
            return Err[bool]("mir_builder: duplicate function name: " + f.name)
        if moduleHasFunc(mod, f.name) || moduleHasGlobal(mod, f.name) ||
           mirFindTypeAlias(mod, f.name) >= 0 || mirFindObjType(mod, f.name) >= 0:
            return Err[bool]("mir_builder: duplicate function name: " + f.name)
        if (f.name == "main"):
            if ctx != nil && ctx.foundMain:
                return Err[bool]("mir_builder: multiple main functions")
            if ctx != nil:
                ctx.foundMain = true
        mirAddFunc(mod, f)
        if ctx != nil && ctx.traceEnabled:
            ctx.traceFnCount = ctx.traceFnCount + 1
            if (ctx.traceFnCount % 50) == 0:
                stage1Trace("backend: mir funcs=" + intToStr(ctx.traceFnCount) + " last=" + f.name)
        return Ok[bool](true)
    return Ok[bool](false)

fn mirPredeclareTopLevelFromRoot(mod: MirModule, root: Node, filePath: str, n: Node,
                                 reachable: hashsets.HashSetStr* = nil,
                                 overloaded: hashsets.HashSetStr* = nil): Result[bool] =
    if mod == nil || n == nil || n.kind == nkEmpty:
        return Ok[bool](false)
    if n.kind == nkStmtList || n.kind == nkModule:
        let fallback: str = (filePath != nil && len(filePath) > 0) ? filePath : (root != nil ? root.strVal : "")
        for j in 0..<kidCount(n):
            let nn: Node = kid(n, j)
            let stmtPath: str = (nn != nil && nn.strVal != nil && len(nn.strVal) > 0) ? nn.strVal : fallback
            let res: Result[bool] = mirPredeclareTopLevelFromRoot(mod, root, stmtPath, nn, reachable, overloaded)
            if !IsOk[bool](res):
                return res
        return Ok[bool](true)
    if n.kind == nkFnDecl || n.kind == nkIteratorDecl:
        if reachable != nil:
            let nameNode: Node = kid(n, 0)
            if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol):
                let nm: str = backendStripSpaces(plainName(nameNode))
                if !hashsets.hashSetStrHas(*reachable, nm):
                    return Ok[bool](false)
        if mirFuncSigHasUnresolvedGenerics(n):
            return Ok[bool](false)
        let fRes: Result[MirFunc] = mirBuildFuncHeader(mod, n, filePath, overloaded)
        if !IsOk[MirFunc](fRes):
            return ErrInfo[bool](ErrorInfoOf[MirFunc](fRes))
        let f: MirFunc = Value[MirFunc](fRes)
        if f == nil:
            return Ok[bool](false)
        if moduleHasFunc(mod, f.name) || moduleHasGlobal(mod, f.name) ||
           mirFindTypeAlias(mod, f.name) >= 0 || mirFindObjType(mod, f.name) >= 0:
            var sameFile: bool = false
            var prevFile: str = ""
            for di in 0..<mod.funcs.len:
                let ex: MirFunc = mod.funcs[di]
                if ex != nil && (ex.name == f.name):
                    if (ex.originFile == f.originFile):
                        sameFile = true
                        break
                    let exFile: str = ex.originFile
                    if len prevFile == 0 && exFile != nil && len exFile > 0:
                        prevFile = exFile
            if sameFile:
                return Ok[bool](false)
            if len prevFile > 0:
                return Err[bool]("mir_builder: duplicate function name: " + f.name + " (files: " + prevFile + ", " + f.originFile + ")")
            return Err[bool]("mir_builder: duplicate function name: " + f.name + " (file: " + f.originFile + ")")
        mirAddFunc(mod, f)
        return Ok[bool](true)
    return Ok[bool](false)

fn mirBuildGlobalInitFunc(mod: MirModule, ctx: MirBuildCtx): Result[MirFunc] =
    if mod == nil || ctx == nil || ctx.globalInits.len == 0:
        return Err[MirFunc]("mir_builder: no global init work")
    let initName: str = "__cheng_global_init"
    if moduleHasFunc(mod, initName) || moduleHasGlobal(mod, initName) ||
       mirFindTypeAlias(mod, initName) >= 0 || mirFindObjType(mod, initName) >= 0:
        return Err[MirFunc]("mir_builder: global init name conflicts: " + initName)
    let f: MirFunc = mirNewFunc(initName, mirTypeVoid())
    f.originFile = "<global_init>"
    let env: LocalEnv = localEnvNew()
    let b: BlockBuilder = blockBuilderNew(env, mod, f)

    # 1) Scalar globals: store value to the global slot.
    for i in 0..<ctx.globalInits.len:
        let gi: MirGlobalInit = ctx.globalInits[i]
        if gi != nil && (gi.objTypeName == nil || len(gi.objTypeName) == 0):
            let init0: Node = gi.initNode
            if init0 != nil && init0.kind != nkEmpty:
                let valRes: Result[MirExpr] = lowerExprValue(b, init0, gi.ty)
                if !IsOk[MirExpr](valRes):
                    return ErrInfo[MirFunc](ErrorInfoOf[MirExpr](valRes))
                add(b.currentStmts, mirStmtStore(mirGlobalAddr(gi.name), Value[MirExpr](valRes), gi.ty))

    # 2) Object globals: allocate heap storage, zero it, and store the pointer.
    for i in 0..<ctx.globalInits.len:
        let gi2: MirGlobalInit = ctx.globalInits[i]
        if gi2 != nil && gi2.objTypeName != nil && len(gi2.objTypeName) > 0:
            let ot: MirObjType = mirGetObjType(mod, gi2.objTypeName)
            if ot.size <= 0:
                return Err[MirFunc]("mir_builder: global init missing object layout: " + gi2.objTypeName)
            let tmpName: str = blockBuilderNextTemp(b, "__gobj")
            let tmpSlot: int32 = localAdd(env, tmpName, mirTypeI64())
            mirSetLocalType(f, tmpSlot, mirTypeI64())
            var allocArgs: MirExpr[]
            add(allocArgs, mirConstI64(int64(ot.size)))
            add(b.currentStmts, mirStmtLet(tmpName, tmpSlot, mirCall("alloc", allocArgs)))
            var zeroArgs: MirExpr[]
            add(zeroArgs, mirLocal(tmpSlot))
            add(zeroArgs, mirConstI64(0))
            add(zeroArgs, mirConstI64(int64(ot.size)))
            add(b.currentStmts, mirStmtExpr(mirCall("setMem", zeroArgs)))
            if gi2.seqFixedElemType != nil && gi2.seqFixedCapExpr != nil:
                var sfi: SeqFixedInit
                sfi.elemType = gi2.seqFixedElemType
                sfi.capExpr = gi2.seqFixedCapExpr
                let seqInitRes: Result[bool] = emitSeqFixedReserveInitToPtr(b, mirLocal(tmpSlot), sfi)
                if !IsOk[bool](seqInitRes):
                    return ErrInfo[MirFunc](ErrorInfoOf[bool](seqInitRes))
            add(b.currentStmts, mirStmtStore(mirGlobalAddr(gi2.name), mirLocal(tmpSlot), mirTypeI64()))

    # 3) Object globals: run initializer calls (if any) into the allocated storage.
    for i in 0..<ctx.globalInits.len:
        let gi3: MirGlobalInit = ctx.globalInits[i]
        if gi3 != nil && gi3.objTypeName != nil && len(gi3.objTypeName) > 0:
            let init1: Node = gi3.initNode
            if init1 != nil && init1.kind != nkEmpty:
                var initCore: Node = init1
                while initCore != nil && initCore.kind == nkPar && kidCount(initCore) > 0:
                    initCore = kid(initCore, 0)
                if initCore == nil || initCore.kind != nkCall:
                    return Err[MirFunc]("mir_builder: global object init expects call: " + gi3.name)
                let lead: MirExpr = mirLoad(mirGlobalAddr(gi3.name), mirTypeI64())
                let callRes: Result[MirExpr] = lowerCallWithLeadingArg(b, initCore, lead)
                if !IsOk[MirExpr](callRes):
                    return ErrInfo[MirFunc](ErrorInfoOf[MirExpr](callRes))

    blockBuilderFinish(b, mirTermRet(nil))
    return Ok[MirFunc](f)

fn mirInjectGlobalInitCall(mod: MirModule, initName: str) =
    if mod == nil || initName == nil || len(initName) == 0:
        return
    let dbgGlobalInit: bool = (getEnv "CHENG_BACKEND_DEBUG_GLOBAL_INIT" == "1")
    for i in 0..<mod.funcs.len:
        let f: MirFunc = mod.funcs[i]
        let nameNorm: str = backendStripSpaces((f != nil) ? f.name : "")
        let linkNorm: str = backendStripSpaces((f != nil) ? f.linkName : "")
        let nameIsMain: bool = (nameNorm != nil && len(nameNorm) == 4 &&
                                nameNorm[0] == 'm' && nameNorm[1] == 'a' &&
                                nameNorm[2] == 'i' && nameNorm[3] == 'n')
        let linkIsMain: bool = (linkNorm != nil && len(linkNorm) == 4 &&
                                linkNorm[0] == 'm' && linkNorm[1] == 'a' &&
                                linkNorm[2] == 'i' && linkNorm[3] == 'n')
        if dbgGlobalInit && f != nil &&
           (mirStrIndexOf(f.name, "main") >= 0 ||
            (f.linkName != nil && mirStrIndexOf(f.linkName, "main") >= 0)):
            echo("[backend] debugGlobalInit: cand name='" + f.name +
                 "' link='" + f.linkName +
                 "' extern=" + (f.isExtern ? "1" : "0") +
                 " blocks=" + intToStr(f.blocks.len) +
                 " nameIsMain=" + (nameIsMain ? "1" : "0") +
                 " linkIsMain=" + (linkIsMain ? "1" : "0"))
        if f != nil && !f.isExtern &&
           (nameIsMain || linkIsMain) &&
           f.blocks.len > 0:
            let entry: MirBlock = f.blocks[0]
            if entry == nil:
                if dbgGlobalInit:
                    echo("[backend] debugGlobalInit: main entry nil")
                return

            # Insert after initial parameter loads so argc/argv survive the init call.
            for insertAt in 0..<entry.stmts.len:
                let st: MirStmt = entry.stmts[insertAt]
                if st.kind != msParam:
                    break

            if insertAt < entry.stmts.len:
                let s0: MirStmt = entry.stmts[insertAt]
                if s0.kind == msExpr:
                    let e0: MirExpr = s0.expr
                    if e0 != nil && e0.kind == meCall && (e0.callee == initName):
                        if dbgGlobalInit:
                            echo("[backend] debugGlobalInit: already inserted at=" + intToStr(insertAt))
                        return

            var args: MirExpr[]
            let call: MirExpr = mirCall(initName, args)
            let stmt: MirStmt = mirStmtExpr(call)
            var out: MirStmt[]
            for si in 0..<entry.stmts.len:
                if si == insertAt:
                    add(out, stmt)
                add(out, entry.stmts[si])
            if insertAt == entry.stmts.len:
                add(out, stmt)
            entry.stmts = out
            if dbgGlobalInit:
                echo("[backend] debugGlobalInit: inserted at=" + intToStr(insertAt) +
                     " total=" + intToStr(entry.stmts.len))
            return
    if dbgGlobalInit:
        echo("[backend] debugGlobalInit: main not found")

fn mirBuildModuleFromRoot(root: Node): Result[MirModule] =
    if root == nil:
        return Err[MirModule]("mir_builder: empty root")
    let prof: MirProfileState = mirProfileInit()
    let dbgLower: bool = (os.getEnvDefault("CHENG_BACKEND_DEBUG_MIR_LOWER", "") == "1")
    let dbgSummary: bool = (os.getEnvDefault("CHENG_BACKEND_DEBUG_MODULE_SUMMARY", "") == "1")
    mirGlobalObjTypesReset()
    mirGlobalTypeKeysReset()
    mirInlineObjFieldTypesReset()
    mirObjFieldTypeKeysReset()
    mirTupleFieldIndicesReset()
    mirObjAliasesReset()
    mirCalleeCandidatesReset()
    let mod: MirModule = mirNewModule("arm64-apple-darwin")
    mirProfileStep(prof, "reset")
    var ctx: MirBuildCtx
    new ctx
    ctx.foundMain = false
    ctx.traceEnabled = stage1TraceEnabled()
    ctx.traceFnCount = 0
    ctx.traceGlobalCount = 0
    if ctx.traceEnabled:
        stage1Trace("backend: mir build start files=" + intToStr(kidCount(root)))
    ctx.overloadedFnBases = mirComputeOverloadedFnBases(root)
    mirDupFnBases = mirComputeDuplicateFnBases(root, &ctx.overloadedFnBases)
    mirDupFnBasesReady = true
    mirDupGlobalNames = mirComputeDuplicateGlobalNames(root)
    mirDupGlobalNamesReady = true
    mirProfileStep(prof, "dups")
    ctx.globalInits = []
    ensureBuiltinObjTypes(mod)
    if (getEnv "CHENG_BACKEND_DEBUG_TYPES" == "1"):
        let hs: str = mirHasObjType(mod, "seq") ? "1" : "0"
        let ht: str = mirHasObjType(mod, "Table") ? "1" : "0"
        echo("[backend] debug: builtin_obj_after_ensure seq=" + hs + " table=" + ht)
    mirPredeclareGlobalsForTypes(mod, root)
    mirProfileStep(prof, "predeclare_globals_for_types")
    let tdRes: Result[bool] = mirConsumeTypeDecls(mod, root)
    if ! IsOk[bool](tdRes):
        return ErrInfo[MirModule](ErrorInfoOf[bool](tdRes))
    mirProfileStep(prof, "consume_type_decls")
    mirPredeclareGlobalsForLowering(mod, root)
    mirProfileStep(prof, "predeclare_globals_for_lowering")
    var reachable: hashsets.HashSetStr
    var reachablePtr: hashsets.HashSetStr* = nil
    let wholeProgramRaw: str = lowerAscii(backendStripSpaces(os.getEnvDefault("CHENG_BACKEND_WHOLE_PROGRAM", "1")))
    let wholeProgram: bool = !(wholeProgramRaw == "0" || wholeProgramRaw == "false" ||
                               wholeProgramRaw == "no" || wholeProgramRaw == "off")
    if !wholeProgram:
        reachable = mirComputeReachableFns(mod, root)
        reachablePtr = &reachable
    mirProfileStep(prof, "reachable")
    # Predeclare function signatures so lowering can infer object returns across order boundaries.
    var lastFilePath: str = root.strVal
    let rootKidCount: int32 = kidCount(root)
    for pi in 0..<kidCount(root):
        let n: Node = kid(root, pi)
        let ownPath: str = (n != nil && n.strVal != nil && len(n.strVal) > 0) ? n.strVal : ""
        if ownPath != nil && len(ownPath) > 0:
            lastFilePath = ownPath
        let filePath: str = (ownPath != nil && len(ownPath) > 0) ? ownPath : lastFilePath
        if ctx.traceEnabled:
            stage1Trace("backend: mir predeclare " + intToStr(pi + 1) + "/" + intToStr(rootKidCount) + " file=" + filePath)
        let res: Result[bool] = mirPredeclareTopLevelFromRoot(mod, root, filePath, n, reachablePtr, &ctx.overloadedFnBases)
        if !IsOk[bool](res):
            return ErrInfo[MirModule](ErrorInfoOf[bool](res))
    mirProfileStep(prof, "predeclare_top_level")
    if dbgSummary:
        echo("[mir] predeclare funcs=" + intToStr(mod.funcs.len) +
             " globals=" + intToStr(mod.globals.len) +
             " cstrs=" + intToStr(mod.cstrs.len))
    lastFilePath = root.strVal
    for i in 0..<kidCount(root):
        let n: Node = kid(root, i)
        let ownPath2: str = (n != nil && n.strVal != nil && len(n.strVal) > 0) ? n.strVal : ""
        if ownPath2 != nil && len(ownPath2) > 0:
            lastFilePath = ownPath2
        let filePath: str = (ownPath2 != nil && len(ownPath2) > 0) ? ownPath2 : lastFilePath
        if dbgLower:
            var nameDbg: str = ""
            var kindDbg: int32 = -1
            if n != nil:
                kindDbg = int32(n.kind)
                if (n.kind == nkFnDecl || n.kind == nkIteratorDecl || n.kind == nkTypeDecl ||
                    n.kind == nkConceptDecl || n.kind == nkTraitDecl) && kidCount(n) > 0:
                    let nameNode: Node = kid(n, 0)
                    if nameNode != nil && (nameNode.kind == nkIdent || nameNode.kind == nkSymbol):
                        nameDbg = backendStripSpaces(plainName(nameNode))
            let fDbg: os.File = os.get_stderr()
            os.write(fDbg, "mir_lower_dbg\t")
            os.write(fDbg, intToStr(i + 1))
            os.write(fDbg, "/")
            os.write(fDbg, intToStr(rootKidCount))
            os.write(fDbg, "\tfile=")
            os.write(fDbg, filePath)
            os.write(fDbg, "\tkind=nk#")
            os.write(fDbg, intToStr(kindDbg))
            if len(nameDbg) > 0:
                os.write(fDbg, "\tname=")
                os.write(fDbg, nameDbg)
            os.writeLine(fDbg, "")
            os.c_fflush fDbg
        if ctx.traceEnabled:
            stage1Trace("backend: mir lower " + intToStr(i + 1) + "/" + intToStr(rootKidCount) + " file=" + filePath)
        let res: Result[bool] = mirConsumeTopLevelFromRoot(mod, ctx, root, filePath, n, reachablePtr, &ctx.overloadedFnBases)
        if ! IsOk[bool](res):
            let info0: ErrorInfo = ErrorInfoOf[bool](res)
            let msg0: str = ErrorFormat(info0)
            if msg0 == nil || len(msg0) == 0 || msg0 == "error":
                var kindDbg: int32 = -1
                var nameDbg: str = ""
                var lineDbg: str = "0"
                var colDbg: str = "0"
                if n != nil:
                    kindDbg = int32(n.kind)
                    lineDbg = intToStr(n.pos.line)
                    colDbg = intToStr(n.pos.col)
                    if kidCount(n) > 0:
                        let nameNodeDbg: Node = kid(n, 0)
                        if nameNodeDbg != nil && (nameNodeDbg.kind == nkIdent || nameNodeDbg.kind == nkSymbol):
                            nameDbg = backendStripSpaces(plainName(nameNodeDbg))
                return Err[MirModule]("mir_builder: lower top-level failed file=" + filePath +
                    " idx=" + intToStr(i + 1) + "/" + intToStr(rootKidCount) +
                    " kind=nk#" + intToStr(kindDbg) +
                    " name=" + nameDbg +
                    " @" + lineDbg + ":" + colDbg)
            return ErrInfo[MirModule](info0)
    mirProfileStep(prof, "lower_top_level")
    if dbgSummary:
        echo("[mir] lower funcs=" + intToStr(mod.funcs.len) +
             " globals=" + intToStr(mod.globals.len) +
             " cstrs=" + intToStr(mod.cstrs.len))
    if ctx.traceEnabled:
        stage1Trace("backend: mir lower done funcs=" + intToStr(ctx.traceFnCount) +
            " globals=" + intToStr(ctx.traceGlobalCount) + " inits=" + intToStr(ctx.globalInits.len))
    let allowNoMain: bool = envIsTrue "CHENG_BACKEND_ALLOW_NO_MAIN" || backendAllowNoMainByEmit()
    if ! ctx.foundMain && !allowNoMain:
        return Err[MirModule]("mir_builder: main not found")

    if ctx.globalInits.len > 0 && !backendSkipGlobalInit():
        if ctx.traceEnabled:
            stage1Trace("backend: mir global_init build start")
        let initRes: Result[MirFunc] = mirBuildGlobalInitFunc(mod, ctx)
        if !IsOk[MirFunc](initRes):
            return ErrInfo[MirModule](ErrorInfoOf[MirFunc](initRes))
        mirAddFunc(mod, Value[MirFunc](initRes))
        if ctx.foundMain:
            mirInjectGlobalInitCall(mod, "__cheng_global_init")
        if ctx.traceEnabled:
            stage1Trace("backend: mir global_init build done")
    mirProfileStep(prof, "global_init")
    if dbgSummary:
        echo("[mir] global_init funcs=" + intToStr(mod.funcs.len) +
             " globals=" + intToStr(mod.globals.len) +
             " cstrs=" + intToStr(mod.cstrs.len))

    if ctx.traceEnabled:
        stage1Trace("backend: mir fixups start")
    let fixRes: Result[bool] = mirBuildMissingRoutinesFromMir(mod, root, &ctx.overloadedFnBases)
    if ! IsOk[bool](fixRes):
        return ErrInfo[MirModule](ErrorInfoOf[bool](fixRes))
    if ctx.traceEnabled:
        stage1Trace("backend: mir fixups done")
        stage1Trace("backend: mir normalize start")
    mirProfileStep(prof, "fixups")
    if dbgSummary:
        echo("[mir] fixups funcs=" + intToStr(mod.funcs.len) +
             " globals=" + intToStr(mod.globals.len) +
             " cstrs=" + intToStr(mod.cstrs.len))
    mirNormalizeModule(mod)
    if dbgSummary:
        echo("[mir] normalize funcs=" + intToStr(mod.funcs.len) +
             " globals=" + intToStr(mod.globals.len) +
             " cstrs=" + intToStr(mod.cstrs.len))
    if ctx.traceEnabled:
        stage1Trace("backend: mir normalize done")
    mirProfileStep(prof, "normalize")
    return Ok[MirModule](mod)

fn mirBuildModuleFromFileStage1(inPath: str): Result[MirModule] =
    if len(inPath) == 0:
        return Err[MirModule]("mir_builder: empty path")
    let dbgPipe: bool = (os.getEnvDefault("CHENG_BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    var dbgFile: os.File = nil
    if dbgPipe:
        dbgFile = os.get_stderr()
        os.writeLine(dbgFile, "[backend] stage1: enter")
        os.c_fflush dbgFile
    # Keep node/lex pools alive for MIR/codegen string ownership.
    releaseNodeArena()
    releaseLexStrings()
    initNodeArena()
    initLexStringPool()
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: pools_ready")
        os.c_fflush dbgFile

    if ! frontend_lib.stage1_fileExists(inPath):
        return Err[MirModule]("mir_builder: input file not found")
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: file_exists_ok")
        os.c_fflush dbgFile

    let profOn: bool = envIsTrue "CHENG_STAGE1_PROFILE"
    var profStart: int64 = 0
    if profOn:
        profStart = cheng_monotime_ns()
    var profMark: int64 = 0
    var profLex: int64 = 0
    var profLoad: int64 = 0
    var profSem: int64 = 0
    var profMono: int64 = 0
    var profOwn: int64 = 0

    if profOn:
        profMark = cheng_monotime_ns()
    # Avoid unconditional string concat during bootstrap (stage0-built stage1 can miscompile
    # large init-time concatenations and crash before any diagnostics).
    stage1Trace "internal: lex+parse"
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: lex_parse_start")
        os.c_fflush dbgFile
    let size: int64 = fileSize inPath
    let mtime: int64 = fileMtime inPath
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: file_meta_ok")
        os.c_fflush dbgFile
    var tokens: Token[]
    var lexDiags: Diagnostic[]
    lexDiags.buffer = nil
    lexDiags.len = 0
    lexDiags.cap = 0
    let cacheRes: TokenCacheResult = loadTokenCache(inPath, size, mtime)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: token_cache_checked")
        os.c_fflush dbgFile
    if cacheRes.hit:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: token_cache_hit")
            os.c_fflush dbgFile
        tokens = cacheRes.tokens
    else:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: token_cache_miss")
            os.c_fflush dbgFile
        let content: str = frontend_lib.stage1_readFile(inPath)
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: file_read_done")
            os.c_fflush dbgFile
        if (content == ""):
            return Err[MirModule]("mir_builder: unable to read input file")
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: lex_start")
            os.c_fflush dbgFile
        let lexRes: LexResult = lex(content, inPath)
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: lex_done")
            os.c_fflush dbgFile
        releaseString content
        tokens = lexRes.tokens
        lexDiags = lexRes.diagnostics
    var diags: Diagnostic[]
    diags.buffer = nil
    diags.len = 0
    diags.cap = 16
    if lexDiags.len > 0:
        appendDiagnostics(&diags, lexDiags)
    else:
        if ! cacheRes.hit:
            writeTokenCache(inPath, size, mtime, tokens)
    dumpTokens(inPath, tokens)
    let userRoot: Node = parseModuleWithDiagnostics(tokens, inPath, &diags)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: parsed_user_module")
        os.c_fflush dbgFile
    freeSeq(tokens)
    freeSeq(lexDiags)

    if userRoot != nil:
        let inPathTag: str = normalizeImportPath inPath
        if envIsTrue "CHENG_STAGE1_TRACE_IMPORTS":
            stage1Trace("import: inPathTag=" + inPathTag)
            stage1Trace("import: repoRoot=" + os.getCurrentDir())
        var tagPath: str = inPath
        if len inPathTag > 0:
            tagPath = inPathTag
        if len inPathTag > 0:
            nodeSetStrVal(userRoot, inPathTag)
        tagModuleChildren(userRoot, tagPath)

    if profOn:
        profLex = cheng_monotime_ns() - profMark
        profMark = cheng_monotime_ns()

    stage1Trace "internal: load system/imports"
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: imports_start")
        os.c_fflush dbgFile
    let repoRoot: str = os.getCurrentDir()
    var importVisited: StrSetList = strSetListInit(16)
    var importCache: NodeCache = nodeCacheInit(128)
    let sysRoot: Node = loadSystemModule(inPath, &diags)
    if sysRoot != nil:
        let sysResolved: str = resolveImportPath("system", "", repoRoot)
        if len sysResolved > 0:
            let sysCanon: str = canonicalizeResolvedPath(sysResolved, repoRoot)
            var sysTag: str = sysResolved
            if len sysCanon > 0:
                sysTag = sysCanon
            setAddStr(&importVisited, sysTag)
            tagModuleChildren(sysRoot, sysTag)
        else:
            tagModuleChildren(sysRoot, "src/std/system.cheng")
        var sysAliases: str[]
        sysAliases.buffer = nil
        sysAliases.len = 0
        sysAliases.cap = 8
        collectImportAliases(sysRoot, &sysAliases)
        if sysAliases.len > 0:
            lowerModuleQualifiers(sysRoot, sysAliases)
        let sysImported: Node[] = loadImports(sysRoot, "src/std", repoRoot, &diags, &importVisited,
            &importCache)
        for si in 0..<sysImported.len:
            addSon(sysRoot, sysImported[si])

    var root0: Node = nil
    if userRoot == nil:
        root0 = mergeModules(sysRoot, userRoot)
    else:
        let inParts: SplitFileResult = splitFile inPath
        let userDir: str = inParts.dir
        let imported: Node[] = loadImports(userRoot, userDir, repoRoot, &diags, &importVisited, &importCache)
        var aliases: str[]
        aliases.buffer = nil
        aliases.len = 0
        aliases.cap = 8
        collectImportAliases(userRoot, &aliases)
        if aliases.len > 0:
            lowerModuleQualifiers(userRoot, aliases)
        root0 = newNode(nkModule, userRoot.pos)
        nodeSetStrVal(root0, userRoot.strVal)
        nodeSetIdent(root0, userRoot.ident)
        if sysRoot != nil:
            for sj in 0..<kidCount sysRoot:
                addSon(root0, kid(sysRoot, sj))
        for ii in 0..<imported.len:
            addSon(root0, imported[ii])
        for ui in 0..<kidCount(userRoot):
            addSon(root0, kid(userRoot, ui))
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: imports_done")
        os.c_fflush dbgFile

    if profOn:
        profLoad = cheng_monotime_ns() - profMark
        profMark = cheng_monotime_ns()

    if mirStage1StdNoPointerPrecheck(root0, inPath, diags):
        if hasError diags:
            printDiagnostics diags
        else:
            echo "std policy: pointer types are forbidden in standard library"
        return Err[MirModule]("mir_builder: stage1 errors")
    if mirStage1NoPointerNonCAbiPrecheck(root0, inPath, diags):
        if hasError diags:
            printDiagnostics diags
        else:
            echo "no-pointer policy: pointer types are forbidden outside C ABI modules"
        return Err[MirModule]("mir_builder: stage1 errors")
    if mirFileLikelyUsesRawSpawn(inPath):
        echo "spawn raw function pointer is forbidden in default API; use std/async_rt_legacy.spawn"
        return Err[MirModule]("mir_builder: stage1 errors")
    type_syntax_lowering.lowerTypeSyntax(root0, &diags, inPath)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: type_syntax_done")
        os.c_fflush dbgFile

    let mm0: str = memMode()
    let strictOn0: bool = orcStrictEnabled()
    let ownDiags: bool = ownershipDiagnosticsEnabled()
    if envIsTrue "CHENG_STAGE1_TRACE_IMPORTS":
        stage1Trace("import: mm=" + mm0)
        stage1Trace("import: mm_strict=" + (strictOn0 ? "1" : "0"))
        stage1Trace("import: own_diags=" + (ownDiags ? "1" : "0"))
    let skipSem: bool = mirIsOne(getEnv "CHENG_STAGE1_SKIP_SEM")
    let skipMono: bool = mirShouldSkipMonoPass()
    let mmIsOrc: bool = mirIsOrcMode(mm0)
    if ! skipSem:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: semantics_start")
            os.c_fflush dbgFile
            os.writeLine(dbgFile, "[backend] stage1: semantics_pretrace")
            os.c_fflush dbgFile
        stage1Trace "internal: semantics"
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: semantics_precheck")
            os.c_fflush dbgFile
        checkSemantics(root0, diags, ownDiags, mmIsOrc && strictOn0)
        if profOn:
            profSem = cheng_monotime_ns() - profMark
            profMark = cheng_monotime_ns()
        if ownDiags && ownershipHintsEnabled() && mmIsOrc && strictOn0:
            if hasHint diags:
                printHints diags
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: semantics_done")
            os.c_fflush dbgFile
    else:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: semantics_skipped")
            os.c_fflush dbgFile

    stage1Trace "internal: monomorphize"
    var root: Node = root0
    if ! skipMono:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_start")
            os.c_fflush dbgFile
        root = monomorphize(root0, &diags)
        if profOn:
            profMono = cheng_monotime_ns() - profMark
            profMark = cheng_monotime_ns()
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_done")
            os.c_fflush dbgFile
    else:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_skipped")
            os.c_fflush dbgFile
    if dbgPipe:
        let errFlag: bool = hasError(diags)
        os.writeLine(dbgFile, "[backend] stage1: mono_diag_count=" + intToStr(diags.len) +
                     " has_error=" + (errFlag ? "1" : "0"))
        if diags.len > 0:
            let d0: Diagnostic = diags[0]
            os.writeLine(dbgFile, "[backend] stage1: mono_diag0 sev=" + intToStr(int32(d0.severity)) +
                         " file='" + d0.filename +
                         "' line=" + intToStr(d0.line) +
                         " col=" + intToStr(d0.col) +
                         " msg='" + d0.message + "'")
        if root != nil && ! errFlag:
            var seenMonoNames: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(512)
            var dupMonoNames: int32 = 0
            for di in 0..<kidCount(root):
                let dn: Node = kid(root, di)
                if dn == nil || (dn.kind != nkFnDecl && dn.kind != nkIteratorDecl):
                    continue
                if kidCount(dn) <= 0:
                    continue
                let dname: str = backendStripSpaces(plainName(kid(dn, 0)))
                if dname == nil || len(dname) == 0:
                    continue
                var foundCnt: bool = false
                let rawCnt: int32 = mirHashMapStrIntGetCompat(seenMonoNames, dname, foundCnt)
                let nextCnt: int32 = (foundCnt ? rawCnt : 0) + 1
                hashmaps.hashMapStrIntPut(seenMonoNames, dname, nextCnt)
                if foundCnt && rawCnt == 1 && dupMonoNames < 12:
                    os.writeLine(dbgFile, "[backend] stage1: mono_dup_fn '" + dname + "'")
                    dupMonoNames = dupMonoNames + 1
            os.writeLine(dbgFile, "[backend] stage1: mono_dup_fn_count=" + intToStr(dupMonoNames))
        os.c_fflush dbgFile
    if hasError diags:
        printDiagnostics diags
        return Err[MirModule]("mir_builder: stage1 errors")

    let skipCProfile: bool = envIsTrue "CHENG_STAGE1_SKIP_CPROFILE"
    if skipCProfile:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: c_profile_skipped")
            os.c_fflush dbgFile
    else:
        stage1Trace "internal: c-profile lowering"
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: c_profile_start")
            os.c_fflush dbgFile
        root = lowerCProfile(root, &diags)
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: c_profile_done")
            os.c_fflush dbgFile
        if hasError diags:
            printDiagnostics diags
            return Err[MirModule]("mir_builder: c-profile lowering failed")
    let monoAfterCProfile: bool = !envIsTrue "CHENG_STAGE1_SKIP_MONO_AFTER_CPROFILE"
    if !skipMono && !skipCProfile && monoAfterCProfile:
        # c_profile lowering can introduce new generic helper callsites
        # (e.g. Result/Option helpers). Run a second mono pass to ensure
        # all late-introduced generic calls are fully instantiated.
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_after_cprofile_start")
            os.c_fflush dbgFile
        root = monomorphize(root, &diags)
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_after_cprofile_done")
            os.c_fflush dbgFile
        if hasError diags:
            printDiagnostics diags
            return Err[MirModule]("mir_builder: stage1 errors")
    elif dbgPipe && !skipMono:
        os.writeLine(dbgFile, "[backend] stage1: mono_after_cprofile_skipped")
        os.c_fflush dbgFile

    let arcOn: bool = arcEnabled()
    let skipOwnership: bool = envIsTrue "CHENG_STAGE1_SKIP_OWNERSHIP"
    stage1Trace "internal: ownership"
    if skipOwnership:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: ownership_skipped")
            os.c_fflush dbgFile
        stage1Trace "internal: ownership skipped"
        setOwnershipEnabled false
    else:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: ownership_start")
            os.c_fflush dbgFile
        setOwnershipEnabled arcOn
        ownershipAnalyze root
        if profOn:
            profOwn = cheng_monotime_ns() - profMark
            profMark = cheng_monotime_ns()
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: ownership_done")
            os.c_fflush dbgFile

    if profOn:
        var msg: str = "profile: lex="
        msg = msg + int64ToStr(profLex / 1000000)
        msg = msg + "ms load="
        msg = msg + int64ToStr(profLoad / 1000000)
        msg = msg + "ms sem="
        msg = msg + int64ToStr(profSem / 1000000)
        msg = msg + "ms mono="
        msg = msg + int64ToStr(profMono / 1000000)
        msg = msg + "ms ownership="
        msg = msg + int64ToStr(profOwn / 1000000)
        msg = msg + "ms total="
        msg = msg + int64ToStr((cheng_monotime_ns() - profStart) / 1000000)
        msg = msg + "ms"
        let profLine: str = "[stage1] " + msg
        echo profLine

    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: mir_build_start")
        os.c_fflush dbgFile
    let mirRes: Result[MirModule] = mirBuildModuleFromRoot(root)
    if !IsOk[MirModule](mirRes):
        let info0: ErrorInfo = ErrorInfoOf[MirModule](mirRes)
        let msg0: str = ErrorFormat(info0)
        if msg0 == nil || len(msg0) == 0 || msg0 == "error":
            return Err[MirModule]("mir_builder: stage1 mir build failed (empty error) input=" + inPath)
    return mirRes
