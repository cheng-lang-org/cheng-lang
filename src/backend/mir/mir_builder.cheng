            var valueOff1: int32 = -1
            let srcObj1: str = mirObjTypeFromTypeKey(b.module, srcKey1)
            if srcObj1 != nil && len(srcObj1) > 0 && mirHasObjType(b.module, srcObj1):
                let srcOt1: MirObjType = mirGetObjType(b.module, srcObj1)
                for sfi1 in 0..<srcOt1.fields.len:
                    let sf1: MirObjField = srcOt1.fields[sfi1]
                    if (sf1.name == "value") || mirStrStartsWith(sf1.name, "value."):
                        if valueOff1 < 0 || sf1.offset < valueOff1:
                            valueOff1 = sf1.offset
            if valueOff1 < 0 && mirStrStartsWith(srcKey1, "Result_"):
                valueOff1 = 0
            if valueOff1 > 0:
                srcPtr1 = mirBin(mbAdd, srcPtr1, mirConstI64(int64(valueOff1)))
        var dstObj1: str = ""
        if callNode.typeCacheValid && callNode.typeCache != nil:
            dstObj1 = typeNodeObjTypeName(b.module, callNode.typeCache)
        if (dstObj1 == nil || len(dstObj1) == 0) && b != nil && b.func != nil &&
           lead != nil && lead.kind == meLocal:
            let leadSlot1: int32 = lead.localIndex
            if leadSlot1 >= 0 && funcFindObjLocal(b.func, leadSlot1) >= 0:
                dstObj1 = funcObjTypeName(b.func, leadSlot1)
        if dstObj1 != nil && len(dstObj1) > 0:
            let copyRes1: Result[bool] = emitObjCopyPtrs(b, lead, dstObj1, srcPtr1)
            if !IsOk[bool](copyRes1):
                return ErrInfo[MirExpr](ErrorInfoOf[bool](copyRes1))
            return Ok[MirExpr](lead)
        add(b.currentStmts, mirStmtStore(lead, mirLoad(srcPtr1, mirTypeI64()), mirTypeI64()))
        return Ok[MirExpr](lead)
    if callInternal == "Value" && getEnv "CHENG_BACKEND_DEBUG_VALUE_CALLSITE" == "1":
        var fnDbg2: str = ""
        if b != nil && b.func != nil:
            let fDbg2: MirFunc = b.func
            fnDbg2 = fDbg2.name
        echo("[backend] debugValueCallsite: fn=" + fnDbg2 +
             " name='" + name + "' callName='" + callName + "' argc=" + intToStr(argNodes.len))
    add(b.currentStmts, mirStmtExpr(mirCall(callInternal, args)))
    return Ok[MirExpr](lead)

fn lowerInExpr(b: BlockBuilder, lhsNode0: Node, rhsNode0: Node, negate: bool): Result[MirExpr] =
    if b == nil:
        return Err[MirExpr]("mir_builder: in missing builder")
    var lhsNode: Node = lhsNode0
    while lhsNode != nil && lhsNode.kind == nkPar && kidCount(lhsNode) > 0:
        lhsNode = kid(lhsNode, 0)
    var rhsNode: Node = rhsNode0
    while rhsNode != nil && rhsNode.kind == nkPar && kidCount(rhsNode) > 0:
        rhsNode = kid(rhsNode, 0)
    if lhsNode == nil || rhsNode == nil:
        return Err[MirExpr]("mir_builder: in expects lhs/rhs")

    # Evaluate LHS once (as i64) and reuse it in all branches.
    let lhsRes0: Result[MirExpr] = lowerExprValue(b, lhsNode, mirTypeI64())
    if ! IsOk[MirExpr](lhsRes0):
        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](lhsRes0))
    let lhsTmpName: str = blockBuilderNextTemp(b, "__in_lhs")
    let lhsTmpSlot: int32 = localAdd(b.env, lhsTmpName, mirTypeI64())
    mirSetLocalType(b.func, lhsTmpSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(lhsTmpName, lhsTmpSlot, Value[MirExpr](lhsRes0)))
    let lhsTmp: MirExpr = mirLocal(lhsTmpSlot)

    # Range membership: `x in a..b` / `a..<b`
    if rhsNode.kind == nkInfix && kidCount(rhsNode) >= 3:
        let opNode: Node = kid(rhsNode, 0)
        let op: str = backendOpName(opNode)
        if op == ".." || op == "..<":
            let startRes: Result[MirExpr] = lowerExprValue(b, kid(rhsNode, 1), mirTypeI64())
            if ! IsOk[MirExpr](startRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](startRes))
            let endRes: Result[MirExpr] = lowerExprValue(b, kid(rhsNode, 2), mirTypeI64())
            if ! IsOk[MirExpr](endRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](endRes))
            let geExpr: MirExpr = mirCmp(mcGe, lhsTmp, Value[MirExpr](startRes))
            var leExpr: MirExpr
            if op == "..":
                leExpr = mirCmp(mcLe, lhsTmp, Value[MirExpr](endRes))
            else:
                leExpr = mirCmp(mcLt, lhsTmp, Value[MirExpr](endRes))
            let inExpr: MirExpr = mirBin(mbAnd, geExpr, leExpr)
            if negate:
                return Ok[MirExpr](mirCmp(mcEq, inExpr, mirConstI64(0)))
            return Ok[MirExpr](inExpr)

    # Literal membership: tuple/bracket/seq literals lowered as a chain of `==` checks.
    if rhsNode.kind == nkTupleLit || rhsNode.kind == nkBracket || rhsNode.kind == nkSeqLit:
        if kidCount(rhsNode) == 0:
            if negate:
                return Ok[MirExpr](mirConstI64(1))
            return Ok[MirExpr](mirConstI64(0))
        var out: MirExpr = nil
        for i in 0..<kidCount(rhsNode):
            var elemNode: Node = kid(rhsNode, i)
            if elemNode != nil && elemNode.kind == nkCallArg && kidCount(elemNode) > 1:
                elemNode = kid(elemNode, 1)
            let elemRes: Result[MirExpr] = lowerExprValue(b, elemNode, mirTypeI64())
            if ! IsOk[MirExpr](elemRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](elemRes))
            let eqExpr: MirExpr = mirCmp(mcEq, lhsTmp, Value[MirExpr](elemRes))
            if out == nil:
                out = eqExpr
            else:
                out = mirBin(mbOr, out, eqExpr)
        if out == nil:
            out = mirConstI64(0)
        if negate:
            return Ok[MirExpr](mirCmp(mcEq, out, mirConstI64(0)))
        return Ok[MirExpr](out)

    var rhsKey: str = ""
    if rhsNode.typeCacheValid && rhsNode.typeCache != nil:
        rhsKey = typeKey rhsNode.typeCache
    if len(rhsKey) == 0 && (rhsNode.kind == nkIdent || rhsNode.kind == nkSymbol):
        let nm: str = plainName(rhsNode)
        let slot0: int32 = localIndex(b.env, nm)
        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
            rhsKey = funcObjTypeKey(b.func, slot0)
        elif slot0 >= 0:
            rhsKey = localTypeKey(b.env, slot0)
    if len(rhsKey) == 0 && rhsNode.kind == nkCall && b.module != nil && kidCount(rhsNode) > 0:
        # Fallback: infer object-return type key from the callee signature.
        let calleeNode: Node = kid(rhsNode, 0)
        var name: str = ""
        var typeArgs: Node[]
        if calleeNode != nil && calleeNode.kind == nkBracketExpr && kidCount(calleeNode) > 0:
            let base: Node = kid(calleeNode, 0)
            name = backendStripSpaces(plainName(base))
            for ti in 1..<kidCount(calleeNode):
                let t: Node = kid(calleeNode, ti)
                if t != nil && t.kind != nkEmpty:
                    add(typeArgs, t)
        else:
            name = backendStripSpaces(plainName(calleeNode))
        var callName: str = name
        if typeArgs.len > 0:
            callName = mangleInstance(name, typeArgs)
        var argNodes: Node[]
        for ai in 1..<kidCount(rhsNode):
            var argNode: Node = kid(rhsNode, ai)
            if argNode != nil && argNode.kind == nkCallArg && kidCount(argNode) > 1:
                argNode = kid(argNode, 1)
            add(argNodes, argNode)
        let callee0: MirFunc = mirResolveCalleeFuncBestEffort(b, callName, argNodes, "")
        if callee0 != nil:
            if callee0.params.len > 0:
                let p0: MirParam = callee0.params[0]
                if (p0.name == "__ret"):
                    rhsKey = funcObjTypeKey(callee0, p0.slot)
            if len(rhsKey) == 0 && callee0.retTypeKey != nil && len(callee0.retTypeKey) > 0:
                rhsKey = callee0.retTypeKey

    # set[T] is represented as a uint64 bitset.
    if rhsNode.kind == nkCurly || mirStrStartsWith(rhsKey, "set_"):
        let rhsRes: Result[MirExpr] = lowerExprValue(b, rhsNode, mirTypeI64())
        if ! IsOk[MirExpr](rhsRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsRes))
        let bits: MirExpr = mirCast(mirTypeI64(), Value[MirExpr](rhsRes))
        let idx64: MirExpr = mirCast(mirTypeI64(), lhsTmp)
        let mask: MirExpr = mirBin(mbShl, mirConstI64(1), idx64)
        let inExpr: MirExpr = mirCmp(mcNe, mirBin(mbAnd, bits, mask), mirConstI64(0))
        if negate:
            return Ok[MirExpr](mirCmp(mcEq, inExpr, mirConstI64(0)))
        return Ok[MirExpr](inExpr)

    # seq[T] membership: scan seq buffer.
    if mirStrStartsWith(rhsKey, "seq_"):
        let elemKey: str = str(ptr_add(void*(rhsKey), 4))
        if elemKey == nil || len(elemKey) == 0:
            return Err[MirExpr]("mir_builder: in seq missing element type")
        let elemTypeNode: Node = newIdent(elemKey, rhsNode.pos)
        let elemTy: MirType = mirTypeFromNodeWithModule(b.module, elemTypeNode)
        let sizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemTypeNode)
        if ! IsOk[int32](sizeRes):
            return ErrInfo[MirExpr](ErrorInfoOf[int32](sizeRes))
        let elemSize: int32 = Value[int32](sizeRes)

        let rhsRes: Result[MirExpr] = lowerExprValue(b, rhsNode, mirTypeI64())
        if ! IsOk[MirExpr](rhsRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsRes))
        let seqTmpName: str = blockBuilderNextTemp(b, "__in_seq")
        let seqTmpSlot: int32 = localAdd(b.env, seqTmpName, mirTypeI64())
        mirSetLocalType(b.func, seqTmpSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(seqTmpName, seqTmpSlot, Value[MirExpr](rhsRes)))
        let seqPtr: MirExpr = mirLocal(seqTmpSlot)

        let seqOt: MirObjType = mirGetObjType(b.module, "seq")
        var lenOff: int32 = -1
        var bufOff: int32 = -1
        for fi in 0..<seqOt.fields.len:
            let f: MirObjField = seqOt.fields[fi]
            if (f.name == "len"):
                lenOff = f.offset
            elif (f.name == "buffer"):
                bufOff = f.offset
        if lenOff < 0 || bufOff < 0:
            return Err[MirExpr]("mir_builder: seq layout mismatch")

        let lenAddr: MirExpr = (lenOff == 0) ? seqPtr : mirBin(mbAdd, seqPtr, mirConstI64(int64(lenOff)))
        let bufAddr: MirExpr = (bufOff == 0) ? seqPtr : mirBin(mbAdd, seqPtr, mirConstI64(int64(bufOff)))

        let lenName: str = blockBuilderNextTemp(b, "__in_len")
        let lenSlot: int32 = localAdd(b.env, lenName, mirTypeI32())
        mirSetLocalType(b.func, lenSlot, mirTypeI32())
        add(b.currentStmts, mirStmtLet(lenName, lenSlot, mirLoad(lenAddr, mirTypeI32())))

        let bufName: str = blockBuilderNextTemp(b, "__in_buf")
        let bufSlot: int32 = localAdd(b.env, bufName, mirTypeI64())
        mirSetLocalType(b.func, bufSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(bufName, bufSlot, mirLoad(bufAddr, mirTypeI64())))

        let idxName: str = blockBuilderNextTemp(b, "__in_i")
        let idxSlot: int32 = localAdd(b.env, idxName, mirTypeI32())
        mirSetLocalType(b.func, idxSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(idxName, idxSlot, mirConstI64(0)))

        let resName: str = blockBuilderNextTemp(b, "__in_res")
        let resSlot: int32 = localAdd(b.env, resName, mirTypeI32())
        mirSetLocalType(b.func, resSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(resName, resSlot, mirConstI64(0)))

        let condLabel: str = blockBuilderNextLabel(b, "in_cond")
        let bodyLabel: str = blockBuilderNextLabel(b, "in_body")
        let incLabel: str = blockBuilderNextLabel(b, "in_inc")
        let foundLabel: str = blockBuilderNextLabel(b, "in_found")
        let endLabel: str = blockBuilderNextLabel(b, "in_end")
        blockBuilderFinish(b, mirTermBr(condLabel))

        blockBuilderStart(b, condLabel)
        let condExpr: MirExpr = mirCmp(mcLt, mirLocal(idxSlot), mirLocal(lenSlot))
        blockBuilderFinish(b, mirTermCbr(condExpr, bodyLabel, endLabel))

        blockBuilderStart(b, bodyLabel)
        let idx64: MirExpr = mirCast(mirTypeI64(), mirLocal(idxSlot))
        let step: MirExpr = mirConstI64(int64(elemSize))
        let off: MirExpr = (elemSize == 1) ? idx64 : mirBin(mbMul, idx64, step)
        let addr: MirExpr = (elemSize == 0) ? mirLocal(bufSlot) : mirBin(mbAdd, mirLocal(bufSlot), off)
        let elemVal: MirExpr = mirLoad(addr, elemTy)
        let lhsCast: MirExpr = mirCast(elemTy, lhsTmp)
        let eqExpr: MirExpr = mirCmp(mcEq, elemVal, lhsCast)
        blockBuilderFinish(b, mirTermCbr(eqExpr, foundLabel, incLabel))

        blockBuilderStart(b, foundLabel)
        add(b.currentStmts, mirStmtAssign(resName, resSlot, mirConstI64(1)))
        blockBuilderFinish(b, mirTermBr(endLabel))

        blockBuilderStart(b, incLabel)
        let incExpr: MirExpr = mirBin(mbAdd, mirLocal(idxSlot), mirConstI64(1))
        add(b.currentStmts, mirStmtAssign(idxName, idxSlot, incExpr))
        blockBuilderFinish(b, mirTermBr(condLabel))

        blockBuilderStart(b, endLabel)
        if negate:
            return Ok[MirExpr](mirCmp(mcEq, mirLocal(resSlot), mirConstI64(0)))
        return Ok[MirExpr](mirLocal(resSlot))

    # str membership: char/substring search.
    if (rhsKey == "str") || (rhsKey == "string") || (rhsKey == "cstring") || rhsNode.kind == nkStrLit:
        let rhsRes: Result[MirExpr] = lowerExprValue(b, rhsNode, mirTypeI64())
        if ! IsOk[MirExpr](rhsRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsRes))
        let hayName: str = blockBuilderNextTemp(b, "__in_hay")
        let haySlot: int32 = localAdd(b.env, hayName, mirTypeI64())
        mirSetLocalType(b.func, haySlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(hayName, haySlot, Value[MirExpr](rhsRes)))
        let hayPtr: MirExpr = mirLocal(haySlot)

        var lhsIsStr: bool = false
        if lhsNode.kind == nkStrLit:
            lhsIsStr = true
        elif lhsNode.typeCacheValid && lhsNode.typeCache != nil:
            let lk: str = typeKey lhsNode.typeCache
            if (lk == "str") || (lk == "string") || (lk == "cstring"):
                lhsIsStr = true

        if ! lhsIsStr:
            # char in str
            let lenName: str = blockBuilderNextTemp(b, "__in_strlen")
            let lenSlot: int32 = localAdd(b.env, lenName, mirTypeI32())
            mirSetLocalType(b.func, lenSlot, mirTypeI32())
            var strlenArgs: MirExpr[]
            add(strlenArgs, hayPtr)
            add(b.currentStmts, mirStmtLet(lenName, lenSlot, mirCall("cheng_strlen", strlenArgs)))

            let idxName: str = blockBuilderNextTemp(b, "__in_i")
            let idxSlot: int32 = localAdd(b.env, idxName, mirTypeI32())
            mirSetLocalType(b.func, idxSlot, mirTypeI32())
            add(b.currentStmts, mirStmtVar(idxName, idxSlot, mirConstI64(0)))

            let resName: str = blockBuilderNextTemp(b, "__in_res")
            let resSlot: int32 = localAdd(b.env, resName, mirTypeI32())
            mirSetLocalType(b.func, resSlot, mirTypeI32())
            add(b.currentStmts, mirStmtVar(resName, resSlot, mirConstI64(0)))

            let condLabel: str = blockBuilderNextLabel(b, "in_cond")
            let bodyLabel: str = blockBuilderNextLabel(b, "in_body")
            let incLabel: str = blockBuilderNextLabel(b, "in_inc")
            let foundLabel: str = blockBuilderNextLabel(b, "in_found")
            let endLabel: str = blockBuilderNextLabel(b, "in_end")
            blockBuilderFinish(b, mirTermBr(condLabel))

            blockBuilderStart(b, condLabel)
            let condExpr: MirExpr = mirCmp(mcLt, mirLocal(idxSlot), mirLocal(lenSlot))
            blockBuilderFinish(b, mirTermCbr(condExpr, bodyLabel, endLabel))

            blockBuilderStart(b, bodyLabel)
            let idx64: MirExpr = mirCast(mirTypeI64(), mirLocal(idxSlot))
            let addr: MirExpr = mirBin(mbAdd, hayPtr, idx64)
            let raw: MirExpr = mirLoad(addr, mirTypeI32())
            let chVal: MirExpr = mirBin(mbAnd, raw, mirConstI64(255))
            let needle: MirExpr = mirCast(mirTypeI32(), lhsTmp)
            let eqExpr: MirExpr = mirCmp(mcEq, chVal, needle)
            blockBuilderFinish(b, mirTermCbr(eqExpr, foundLabel, incLabel))

            blockBuilderStart(b, foundLabel)
            add(b.currentStmts, mirStmtAssign(resName, resSlot, mirConstI64(1)))
            blockBuilderFinish(b, mirTermBr(endLabel))

            blockBuilderStart(b, incLabel)
            let incExpr: MirExpr = mirBin(mbAdd, mirLocal(idxSlot), mirConstI64(1))
            add(b.currentStmts, mirStmtAssign(idxName, idxSlot, incExpr))
            blockBuilderFinish(b, mirTermBr(condLabel))

            blockBuilderStart(b, endLabel)
            if negate:
                return Ok[MirExpr](mirCmp(mcEq, mirLocal(resSlot), mirConstI64(0)))
            return Ok[MirExpr](mirLocal(resSlot))

        # str in str
        let needleName: str = blockBuilderNextTemp(b, "__in_need")
        let needleSlot: int32 = localAdd(b.env, needleName, mirTypeI64())
        mirSetLocalType(b.func, needleSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(needleName, needleSlot, lhsTmp))
        let needlePtr: MirExpr = mirLocal(needleSlot)

        let nName: str = blockBuilderNextTemp(b, "__in_n")
        let nSlot: int32 = localAdd(b.env, nName, mirTypeI32())
        mirSetLocalType(b.func, nSlot, mirTypeI32())
        var nArgs: MirExpr[]
        add(nArgs, hayPtr)
        add(b.currentStmts, mirStmtLet(nName, nSlot, mirCall("cheng_strlen", nArgs)))

        let mName: str = blockBuilderNextTemp(b, "__in_m")
        let mSlot: int32 = localAdd(b.env, mName, mirTypeI32())
        mirSetLocalType(b.func, mSlot, mirTypeI32())
        var mArgs: MirExpr[]
        add(mArgs, needlePtr)
        add(b.currentStmts, mirStmtLet(mName, mSlot, mirCall("cheng_strlen", mArgs)))

        let resName2: str = blockBuilderNextTemp(b, "__in_res")
        let resSlot2: int32 = localAdd(b.env, resName2, mirTypeI32())
        mirSetLocalType(b.func, resSlot2, mirTypeI32())
        add(b.currentStmts, mirStmtVar(resName2, resSlot2, mirConstI64(0)))

        let checkEmpty: str = blockBuilderNextLabel(b, "in_check_empty")
        let checkLong: str = blockBuilderNextLabel(b, "in_check_long")
        let initLabel: str = blockBuilderNextLabel(b, "in_init")
        let outerCond: str = blockBuilderNextLabel(b, "in_outer_cond")
        let outerBody: str = blockBuilderNextLabel(b, "in_outer_body")
        let innerCond: str = blockBuilderNextLabel(b, "in_inner_cond")
        let innerBody: str = blockBuilderNextLabel(b, "in_inner_body")
        let matchLabel: str = blockBuilderNextLabel(b, "in_match")
        let endLabel2: str = blockBuilderNextLabel(b, "in_end")
        blockBuilderFinish(b, mirTermBr(checkEmpty))

        blockBuilderStart(b, checkEmpty)
        let emptyCond: MirExpr = mirCmp(mcEq, mirLocal(mSlot), mirConstI64(0))
        blockBuilderFinish(b, mirTermCbr(emptyCond, matchLabel, checkLong))

        blockBuilderStart(b, checkLong)
        let longCond: MirExpr = mirCmp(mcGt, mirLocal(mSlot), mirLocal(nSlot))
        blockBuilderFinish(b, mirTermCbr(longCond, endLabel2, initLabel))

        blockBuilderStart(b, initLabel)
        let iName: str = blockBuilderNextTemp(b, "__in_i")
        let iSlot: int32 = localAdd(b.env, iName, mirTypeI32())
        mirSetLocalType(b.func, iSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(iName, iSlot, mirConstI64(0)))

        let jName: str = blockBuilderNextTemp(b, "__in_j")
        let jSlot: int32 = localAdd(b.env, jName, mirTypeI32())
        mirSetLocalType(b.func, jSlot, mirTypeI32())
        add(b.currentStmts, mirStmtVar(jName, jSlot, mirConstI64(0)))

        let limName: str = blockBuilderNextTemp(b, "__in_lim")
        let limSlot: int32 = localAdd(b.env, limName, mirTypeI32())
        mirSetLocalType(b.func, limSlot, mirTypeI32())
        add(b.currentStmts, mirStmtLet(limName, limSlot, mirBin(mbSub, mirLocal(nSlot), mirLocal(mSlot))))

        blockBuilderFinish(b, mirTermBr(outerCond))

        blockBuilderStart(b, outerCond)
        let outerOk: MirExpr = mirCmp(mcLe, mirLocal(iSlot), mirLocal(limSlot))
        blockBuilderFinish(b, mirTermCbr(outerOk, outerBody, endLabel2))

        blockBuilderStart(b, outerBody)
        add(b.currentStmts, mirStmtAssign(jName, jSlot, mirConstI64(0)))
        blockBuilderFinish(b, mirTermBr(innerCond))

        blockBuilderStart(b, innerCond)
        let innerOk: MirExpr = mirCmp(mcLt, mirLocal(jSlot), mirLocal(mSlot))
        blockBuilderFinish(b, mirTermCbr(innerOk, innerBody, matchLabel))

        blockBuilderStart(b, innerBody)
        let ij: MirExpr = mirBin(mbAdd, mirLocal(iSlot), mirLocal(jSlot))
        let ij64: MirExpr = mirCast(mirTypeI64(), ij)
        let hAddr: MirExpr = mirBin(mbAdd, hayPtr, ij64)
        let hRaw: MirExpr = mirLoad(hAddr, mirTypeI32())
        let hCh: MirExpr = mirBin(mbAnd, hRaw, mirConstI64(255))
        let j64: MirExpr = mirCast(mirTypeI64(), mirLocal(jSlot))
        let nAddr: MirExpr = mirBin(mbAdd, needlePtr, j64)
        let nRaw: MirExpr = mirLoad(nAddr, mirTypeI32())
        let nCh: MirExpr = mirBin(mbAnd, nRaw, mirConstI64(255))
        let eqExpr2: MirExpr = mirCmp(mcEq, hCh, nCh)
        let stepJ: str = blockBuilderNextLabel(b, "in_step_j")
        let stepI: str = blockBuilderNextLabel(b, "in_step_i")
        blockBuilderFinish(b, mirTermCbr(eqExpr2, stepJ, stepI))

        blockBuilderStart(b, stepJ)
        add(b.currentStmts, mirStmtAssign(jName, jSlot, mirBin(mbAdd, mirLocal(jSlot), mirConstI64(1))))
        blockBuilderFinish(b, mirTermBr(innerCond))

        blockBuilderStart(b, stepI)
        add(b.currentStmts, mirStmtAssign(iName, iSlot, mirBin(mbAdd, mirLocal(iSlot), mirConstI64(1))))
        blockBuilderFinish(b, mirTermBr(outerCond))

        blockBuilderStart(b, matchLabel)
        add(b.currentStmts, mirStmtAssign(resName2, resSlot2, mirConstI64(1)))
        blockBuilderFinish(b, mirTermBr(endLabel2))

        blockBuilderStart(b, endLabel2)
        if negate:
            return Ok[MirExpr](mirCmp(mcEq, mirLocal(resSlot2), mirConstI64(0)))
        return Ok[MirExpr](mirLocal(resSlot2))

    # Table membership: `key in Table[V]` => `TableHas[V](t, key)`
    if mirStrStartsWith(rhsKey, "Table_"):
        let rhsRes: Result[MirExpr] = lowerExprValue(b, rhsNode, mirTypeI64())
        if ! IsOk[MirExpr](rhsRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](rhsRes))
        let tblName: str = blockBuilderNextTemp(b, "__in_tbl")
        let tblSlot: int32 = localAdd(b.env, tblName, mirTypeI64())
        mirSetLocalType(b.func, tblSlot, mirTypeI64())
        add(b.currentStmts, mirStmtLet(tblName, tblSlot, Value[MirExpr](rhsRes)))
        let valKey: str = str(ptr_add(void*(rhsKey), 6))
        let callName: str = "TableHas_" + valKey
        var args: MirExpr[]
        add(args, mirLocal(tblSlot))
        add(args, lhsTmp)
        let hasExpr: MirExpr = mirCall(callName, args)
        if negate:
            return Ok[MirExpr](mirCmp(mcEq, hasExpr, mirConstI64(0)))
        return Ok[MirExpr](hasExpr)

    let line: str = intToStr(rhsNode.pos.line)
    let col: str = intToStr(rhsNode.pos.col)
    return Err[MirExpr]("mir_builder: unsupported 'in' rhs (key=" + rhsKey + " @" + line + ":" + col + ")")

fn isFloat64Key(key0: str): bool =
    if key0 == nil:
        return false
    let key: str = backendStripSpaces(key0)
    return (key == "float64") || (key == "float")

fn isFloat32Key(key0: str): bool =
    if key0 == nil:
        return false
    let key: str = backendStripSpaces(key0)
    return key == "float32"

fn isIntegralMirType(ty: MirType): bool =
    return ty.kind == mtI8 || ty.kind == mtI16 || ty.kind == mtI32 || ty.kind == mtI64

fn isStringKey(key0: str): bool =
    if key0 == nil:
        return false
    let key: str = backendStripSpaces(key0)
    return (key == "str") || (key == "string") || (key == "cstring")

fn exprTypeKeyShallow(b: BlockBuilder, n0: Node): str =
    if b == nil:
        return ""
    var n: Node = n0
    while n != nil && n.kind == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if n == nil:
        return ""
    if n.kind != nkDotExpr && n.typeCacheValid && n.typeCache != nil:
        return typeKey n.typeCache
    if n.kind == nkDotExpr && kidCount(n) > 1:
        let base: Node = kid(n, 0)
        let field: Node = kid(n, 1)
        if base != nil && field != nil && (field.kind == nkIdent || field.kind == nkSymbol) && b.module != nil:
            var parentKey: str = backendStripSpaces(exprTypeKeyShallow(b, base))
            if mirStrStartsWith(parentKey, "ref_"):
                parentKey = str(ptr_add(void*(parentKey), 4))
            elif mirStrStartsWith(parentKey, "var_ref_"):
                parentKey = str(ptr_add(void*(parentKey), 8))
            elif mirStrStartsWith(parentKey, "var_"):
                parentKey = str(ptr_add(void*(parentKey), 4))
            if mirStrStartsWith(parentKey, "ptr_"):
                parentKey = str(ptr_add(void*(parentKey), 4))
            parentKey = mirObjAliasCanon(parentKey)
            let parentObj: str = mirPtrBaseObjTypeName(b.module, parentKey)
            if parentObj != nil && len(parentObj) > 0:
                let fieldName: str = backendStripSpaces(plainName(field))
                let fieldKey: str = backendStripSpaces(mirObjFieldTypeKeyGet(parentObj, fieldName))
                if fieldKey != nil && len(fieldKey) > 0:
                    return fieldKey
    if n.kind == nkFloatLit:
        return "float64"
    if n.kind == nkIdent || n.kind == nkSymbol:
        let nm: str = plainName(n)
        let slot0: int32 = localIndex(b.env, nm)
        if slot0 >= 0:
            return localTypeKey(b.env, slot0)
    if n.kind == nkCall && kidCount(n) > 0:
        let callee0: Node = kid(n, 0)
        # Type conversion call: `T*(x)` / `ref T(x)` / `var T(x)` can show up without a typeCache.
        if callee0 != nil && (callee0.kind == nkPtrTy || callee0.kind == nkRefTy || callee0.kind == nkVarTy):
            return typeKey callee0
    return ""

fn isByteTypeKey(key: str): bool =
    if key == nil || len(key) == 0:
        return false
    return (key == "bool") || (key == "char") ||
           (key == "int8") || (key == "uint8") ||
           (key == "i8") || (key == "u8")

fn isBytePtrTypeKey(key: str): bool =
    if key == nil || len(key) == 0:
        return false
    if ! mirStrStartsWith(key, "ptr_"):
        return false
    let elemKey: str = str(ptr_add(void*(key), 4))
    return isByteTypeKey(elemKey)

fn byteMirTypeFromKey(key0: str): MirType =
    if key0 == nil || len(key0) == 0:
        return mirTypeU8()
    let key: str = backendStripSpaces(key0)
    if (key == "int8") || (key == "i8"):
        return mirTypeI8()
    return mirTypeU8()

fn byteMirTypeFromPtrTypeKey(ptrKey0: str): MirType =
    if ptrKey0 == nil || len(ptrKey0) == 0:
        return mirTypeU8()
    let ptrKey: str = backendStripSpaces(ptrKey0)
    if !mirStrStartsWith(ptrKey, "ptr_"):
        return mirTypeU8()
    let elemKey: str = str(ptr_add(void*(ptrKey), 4))
    return byteMirTypeFromKey(elemKey)

fn byteMirTypeFromElemOrPtrKey(elemKey0: str, ptrKey0: str): MirType =
    if elemKey0 != nil && len(elemKey0) > 0:
        var elemKey: str = backendStripSpaces(elemKey0)
        if mirStrStartsWith(elemKey, "ptr_"):
            elemKey = backendStripSpaces(str(ptr_add(void*(elemKey), 4)))
        return byteMirTypeFromKey(elemKey)
    return byteMirTypeFromPtrTypeKey(ptrKey0)

fn lowerByteLoadNilChecked(b: BlockBuilder, addrExpr: MirExpr, byteTy: MirType, wantType: MirType): MirExpr =
    let addrName: str = blockBuilderNextTemp(b, "__byte_p")
    let addrSlot: int32 = localAdd(b.env, addrName, mirTypeI64())
    mirSetLocalType(b.func, addrSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(addrName, addrSlot, addrExpr))

    let resName: str = blockBuilderNextTemp(b, "__byte_res")
    let resSlot: int32 = localAdd(b.env, resName, wantType)
    mirSetLocalType(b.func, resSlot, wantType)

    let thenLabel: str = blockBuilderNextLabel(b, "byte_then")
    let elseLabel: str = blockBuilderNextLabel(b, "byte_else")
    let joinLabel: str = blockBuilderNextLabel(b, "byte_join")
    let okCond: MirExpr = mirCmp(mcNe, mirLocal(addrSlot), mirConstI64(0))
    blockBuilderFinish(b, mirTermCbr(okCond, thenLabel, elseLabel))

    blockBuilderStart(b, thenLabel)
    var loaded: MirExpr = mirLoad(mirLocal(addrSlot), byteTy)
    if wantType.kind != byteTy.kind || wantType.isUnsigned != byteTy.isUnsigned:
        loaded = mirCast(wantType, loaded)
    add(b.currentStmts, mirStmtAssign(resName, resSlot, loaded))
    blockBuilderFinish(b, mirTermBr(joinLabel))

    blockBuilderStart(b, elseLabel)
    add(b.currentStmts, mirStmtAssign(resName, resSlot, mirConstI64(0)))
    blockBuilderFinish(b, mirTermBr(joinLabel))

    blockBuilderStart(b, joinLabel)
    return mirLocal(resSlot)

fn lowerByteStoreNilChecked(b: BlockBuilder, addrExpr: MirExpr, valExpr: MirExpr, valType: MirType, storeTy: MirType) =
    let addrName: str = blockBuilderNextTemp(b, "__byte_p")
    let addrSlot: int32 = localAdd(b.env, addrName, mirTypeI64())
    mirSetLocalType(b.func, addrSlot, mirTypeI64())
    add(b.currentStmts, mirStmtLet(addrName, addrSlot, addrExpr))

    let valName: str = blockBuilderNextTemp(b, "__byte_v")
    let valSlot: int32 = localAdd(b.env, valName, valType)
    mirSetLocalType(b.func, valSlot, valType)
    add(b.currentStmts, mirStmtLet(valName, valSlot, valExpr))

    let thenLabel: str = blockBuilderNextLabel(b, "byte_then")
    let elseLabel: str = blockBuilderNextLabel(b, "byte_else")
    let joinLabel: str = blockBuilderNextLabel(b, "byte_join")
    let okCond: MirExpr = mirCmp(mcNe, mirLocal(addrSlot), mirConstI64(0))
    blockBuilderFinish(b, mirTermCbr(okCond, thenLabel, elseLabel))

    blockBuilderStart(b, thenLabel)
    add(b.currentStmts, mirStmtStore(mirLocal(addrSlot), mirLocal(valSlot), storeTy))
    blockBuilderFinish(b, mirTermBr(joinLabel))

    blockBuilderStart(b, elseLabel)
    blockBuilderFinish(b, mirTermBr(joinLabel))

    blockBuilderStart(b, joinLabel)

fn mirPtrBaseObjTypeName(mod: MirModule, baseKey0: str): str =
    if mod == nil || baseKey0 == nil || len(baseKey0) == 0:
        return ""
    if mirHasObjType(mod, baseKey0):
        return baseKey0
    if (mirStrStartsWith(baseKey0, "seq_") || mirStrStartsWith(baseKey0, "seq_fixed_")) && mirHasObjType(mod, "seq"):
        return "seq"
    if mirStrStartsWith(baseKey0, "Table_") && mirHasObjType(mod, "Table"):
        return "Table"
    let __for_start_i = len(baseKey0) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if baseKey0[i] == '.':
            let sub: str = str(ptr_add(void*(baseKey0), i + 1))
            if sub != nil && len(sub) > 0 && mirHasObjType(mod, sub):
                return sub
            break
    return ""

fn lowerToF64Bits(b: BlockBuilder, n0: Node): Result[MirExpr] =
    if b == nil:
        return Err[MirExpr]("mir_builder: float op missing builder")
    var n: Node = n0
    while n != nil && n.kind == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if n == nil:
        return Err[MirExpr]("mir_builder: float op expects operand")
    if n.kind == nkFloatLit:
        if n.strVal != nil && len(n.strVal) > 0:
            return Ok[MirExpr](mirConstI64(cheng_parse_f64_bits(n.strVal)))
        # Some stages may synthesize float literals without a raw string; default to 0.0 bits.
        return Ok[MirExpr](mirConstI64(0))
    var key: str = exprTypeKeyShallow(b, n)
    if len(key) == 0 && n.kind == nkInfix && kidCount(n) >= 3:
        key = exprTypeKeyShallow(b, kid(n, 1))
        if len(key) == 0:
            key = exprTypeKeyShallow(b, kid(n, 2))
    if isFloat64Key(key):
        let valRes2: Result[MirExpr] = lowerExprValue(b, n, mirTypeF64())
        if ! IsOk[MirExpr](valRes2):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes2))
        return Ok[MirExpr](mirCast(mirTypeI64(), Value[MirExpr](valRes2)))
    if n.kind == nkPrefix && kidCount(n) > 1:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        if op == "-" || op == "+":
            let rhs: Node = kid(n, 1)
            var rhsKey: str = exprTypeKeyShallow(b, rhs)
            if len(rhsKey) == 0 && rhs != nil && rhs.kind == nkInfix && kidCount(rhs) >= 3:
                rhsKey = exprTypeKeyShallow(b, kid(rhs, 1))
                if len(rhsKey) == 0:
                    rhsKey = exprTypeKeyShallow(b, kid(rhs, 2))
            if isFloat64Key(rhsKey):
                let valRes3: Result[MirExpr] = lowerExprValue(b, n, mirTypeF64())
                if ! IsOk[MirExpr](valRes3):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes3))
                return Ok[MirExpr](mirCast(mirTypeI64(), Value[MirExpr](valRes3)))
    if n.kind == nkIntLit:
        return Ok[MirExpr](mirConstI64(cheng_i64_to_f64_bits(n.intVal)))
    let valRes: Result[MirExpr] = lowerExprValue(b, n, mirTypeI64())
    if ! IsOk[MirExpr](valRes):
        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes))
    var val: MirExpr = Value[MirExpr](valRes)
    let vty: MirType = inferExprTypeWithGlobals(b.env, b.module, b.func, n, mirTypeI32())
    if vty.kind == mtI32 || vty.kind == mtF32:
        val = mirCast(mirTypeI64(), val)
    var args: MirExpr[]
    add(args, val)
    return Ok[MirExpr](mirCall("cheng_i64_to_f64_bits", args))

fn lowerToF32Bits(b: BlockBuilder, n0: Node): Result[MirExpr] =
    if b == nil:
        return Err[MirExpr]("mir_builder: float32 op missing builder")
    var n: Node = n0
    while n != nil && n.kind == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if n == nil:
        return Err[MirExpr]("mir_builder: float32 op expects operand")
    if n.kind == nkFloatLit:
        var bits64: int64 = 0
        if n.strVal != nil && len(n.strVal) > 0:
            bits64 = cheng_parse_f64_bits(n.strVal)
        var argsLit: MirExpr[]
        add(argsLit, mirConstI64(bits64))
        return Ok[MirExpr](mirCall("cheng_f64_bits_to_f32_bits", argsLit))
    if n.kind == nkCall && kidCount(n) > 0:
        let calleeNode: Node = kid(n, 0)
        let calleeName: str = backendStripSpaces(plainName(calleeNode))
        if calleeName == "float32":
            let vRes0: Result[MirExpr] = lowerExprValue(b, n, mirTypeF32())
            if !IsOk[MirExpr](vRes0):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](vRes0))
            return Ok[MirExpr](mirCast(mirTypeI32(), Value[MirExpr](vRes0)))
        if calleeName == "float64" || calleeName == "float":
            let bits64ResCall: Result[MirExpr] = lowerToF64Bits(b, n)
            if !IsOk[MirExpr](bits64ResCall):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](bits64ResCall))
            var argsCall: MirExpr[]
            add(argsCall, Value[MirExpr](bits64ResCall))
            return Ok[MirExpr](mirCall("cheng_f64_bits_to_f32_bits", argsCall))

    var key: str = exprTypeKeyShallow(b, n)
    if len(key) == 0 && n.kind == nkInfix && kidCount(n) >= 3:
        key = exprTypeKeyShallow(b, kid(n, 1))
        if len(key) == 0:
            key = exprTypeKeyShallow(b, kid(n, 2))
    if isFloat32Key(key):
        let vRes: Result[MirExpr] = lowerExprValue(b, n, mirTypeF32())
        if !IsOk[MirExpr](vRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](vRes))
        return Ok[MirExpr](mirCast(mirTypeI32(), Value[MirExpr](vRes)))
    if isFloat64Key(key):
        let bits64Res0: Result[MirExpr] = lowerToF64Bits(b, n)
        if !IsOk[MirExpr](bits64Res0):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](bits64Res0))
        var args64_0: MirExpr[]
        add(args64_0, Value[MirExpr](bits64Res0))
        return Ok[MirExpr](mirCall("cheng_f64_bits_to_f32_bits", args64_0))
    if n.kind == nkIntLit:
        var argsInt: MirExpr[]
        add(argsInt, mirConstI64(cheng_i64_to_f64_bits(n.intVal)))
        return Ok[MirExpr](mirCall("cheng_f64_bits_to_f32_bits", argsInt))

    let vty: MirType = inferExprTypeWithGlobals(b.env, b.module, b.func, n, mirTypeI32())
    if vty.kind == mtF32:
        let vRes2: Result[MirExpr] = lowerExprValue(b, n, mirTypeF32())
        if !IsOk[MirExpr](vRes2):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](vRes2))
        return Ok[MirExpr](mirCast(mirTypeI32(), Value[MirExpr](vRes2)))
    if vty.kind == mtF64:
        let bits64Res1: Result[MirExpr] = lowerToF64Bits(b, n)
        if !IsOk[MirExpr](bits64Res1):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](bits64Res1))
        var args64_1: MirExpr[]
        add(args64_1, Value[MirExpr](bits64Res1))
        return Ok[MirExpr](mirCall("cheng_f64_bits_to_f32_bits", args64_1))

    let valRes: Result[MirExpr] = lowerExprValue(b, n, mirTypeI64())
    if !IsOk[MirExpr](valRes):
        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes))
    var val: MirExpr = Value[MirExpr](valRes)
    if vty.kind == mtI32:
        val = mirCast(mirTypeI64(), val)
    let intToF64Helper: str = vty.isUnsigned ? "cheng_u64_to_f64_bits" : "cheng_i64_to_f64_bits"
    var upArgs: MirExpr[]
    add(upArgs, val)
    var downArgs: MirExpr[]
    add(downArgs, mirCall(intToF64Helper, upArgs))
    return Ok[MirExpr](mirCall("cheng_f64_bits_to_f32_bits", downArgs))

fn lowerObjConstructorCall(b: BlockBuilder, callNode: Node, objTypeName: str): Result[MirExpr] =
    if b == nil || b.module == nil || b.func == nil:
        return Err[MirExpr]("mir_builder: object constructor missing builder/module")
    if callNode == nil || callNode.kind != nkCall:
        return Err[MirExpr]("mir_builder: invalid object constructor call")
    if objTypeName == nil || len(objTypeName) == 0 || !mirHasObjType(b.module, objTypeName):
        return Err[MirExpr]("mir_builder: unknown object constructor type")
    let ot: MirObjType = mirGetObjType(b.module, objTypeName)

    let tmpName: str = blockBuilderNextTemp(b, "__obj")
    let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
    mirSetLocalType(b.func, tmpSlot, mirTypeI64())
    localSetTypeKey(b.env, tmpSlot, objTypeName)
    let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objTypeName)
    if ! IsOk[bool](allocRes):
        return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))
    let initRes: Result[bool] = emitObjDefaultInit(b, tmpSlot, objTypeName)
    if ! IsOk[bool](initRes):
        return ErrInfo[MirExpr](ErrorInfoOf[bool](initRes))

    let basePtr: MirExpr = mirLocal(tmpSlot)
    for ai in 1..<kidCount(callNode):
        let arg0: Node = kid(callNode, ai)
        if arg0 == nil || arg0.kind != nkCallArg || kidCount(arg0) < 2:
            return Err[MirExpr]("mir_builder: object constructor expects named args")
        let keyNode: Node = kid(arg0, 0)
        let valNode: Node = kid(arg0, 1)
        if keyNode == nil || (keyNode.kind != nkIdent && keyNode.kind != nkSymbol):
            return Err[MirExpr]("mir_builder: object constructor field expects identifier")
        let fieldName: str = backendStripSpaces(plainName(keyNode))

        var found: bool = false
        var field: MirObjField
        for fi in 0..<ot.fields.len:
            let f: MirObjField = ot.fields[fi]
            if (f.name == fieldName):
                field = f
                found = true
                break
        if found:
            var addr: MirExpr = basePtr
            if field.offset != 0:
                addr = mirBin(mbAdd, basePtr, mirConstI64(int64(field.offset)))
            let valRes: Result[MirExpr] = lowerExprValue(b, valNode, field.ty)
            if ! IsOk[MirExpr](valRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes))
            add(b.currentStmts, mirStmtStore(addr, Value[MirExpr](valRes), field.ty))
            continue

        let prefix: str = fieldName + "."
        var hasPrefix: bool = false
        var minOff: int32 = 2147483647
        for fi2 in 0..<ot.fields.len:
            let f2: MirObjField = ot.fields[fi2]
            if mirStrStartsWith(f2.name, prefix):
                hasPrefix = true
                if f2.offset < minOff:
                    minOff = f2.offset
        if !hasPrefix:
            let line: str = intToStr(keyNode.pos.line)
            let col: str = intToStr(keyNode.pos.col)
            if (getEnv "CHENG_BACKEND_DEBUG_OBJCTOR" == "1"):
                let calleeDbg: str = backendStripSpaces(plainName(kid(callNode, 0)))
                echo("[backend] debugObjCtorUnknown: objType='" + objTypeName + "' field='" + fieldName +
                     "' callee='" + calleeDbg + "' @" + line + ":" + col)
            return Err[MirExpr]("mir_builder: unknown object field '" + fieldName + "' @" + line + ":" + col)

        var dstObjName: str = mirInlineObjFieldTypeGet(objTypeName, fieldName)
        let fieldKey0: str = backendStripSpaces(mirObjFieldTypeKeyGet(objTypeName, fieldName))
        if fieldKey0 != nil && len(fieldKey0) > 0:
            dstObjName = mirObjTypeFromTypeKey(b.module, fieldKey0)
            if len(dstObjName) == 0 && mirHasObjType(b.module, fieldKey0):
                dstObjName = fieldKey0
            if len(dstObjName) == 0:
                let fieldCanon: str = mirObjAliasCanon(fieldKey0)
                if fieldCanon != nil && len(fieldCanon) > 0 && mirHasObjType(b.module, fieldCanon):
                    dstObjName = fieldCanon

        var srcObjName: str = ""
        if valNode != nil && valNode.typeCacheValid && valNode.typeCache != nil:
            srcObjName = typeNodeObjTypeName(b.module, valNode.typeCache)
        if len(srcObjName) == 0 && valNode != nil && (valNode.kind == nkIdent || valNode.kind == nkSymbol):
            let nm: str = plainName(valNode)
            let slot0: int32 = localIndex(b.env, nm)
            if slot0 >= 0:
                srcObjName = funcObjTypeName(b.func, slot0)
        if len(srcObjName) == 0 && valNode != nil && b != nil && b.module != nil:
            let key0: str = caseInferExprTypeKey(b, valNode)
            if key0 != nil && len(key0) > 0:
                srcObjName = mirObjTypeFromTypeKey(b.module, key0)
                if len(srcObjName) == 0:
                    let tn0: Node = newIdent(key0, valNode.pos)
                    srcObjName = typeNodeObjTypeName(b.module, tn0)
        if len(srcObjName) == 0 && valNode != nil && b != nil && b.module != nil:
            let key1: str = mirInferNodeTypeKeyForOverload(b, valNode)
            if key1 != nil && len(key1) > 0:
                srcObjName = mirObjTypeFromTypeKey(b.module, key1)
        if len(srcObjName) == 0 && valNode != nil && valNode.kind == nkCall && kidCount(valNode) > 1 && b != nil && b.module != nil:
            let valKey0: str = mirInferValueCallInnerKey(b, valNode)
            if valKey0 != nil && len(valKey0) > 0:
                srcObjName = mirObjTypeFromTypeKey(b.module, valKey0)
        if len(srcObjName) == 0 && len(dstObjName) > 0:
            srcObjName = dstObjName
        if (getEnv "CHENG_BACKEND_DEBUG_NESTED_CTOR" == "1") &&
           (((objTypeName == "GossipsubContext") && (fieldName == "params")) ||
            ((objTypeName == "Cid") && (fieldName == "codec"))):
            let kDbg: str = (valNode != nil) ? caseInferExprTypeKey(b, valNode) : ""
            let vkDbg: str = (valNode != nil) ? intToStr(int32(valNode.kind)) : "nil"
            let kDbg2: str = (valNode != nil) ? mirInferNodeTypeKeyForOverload(b, valNode) : ""
            let oDbg2: str = (kDbg2 != nil && len(kDbg2) > 0) ? mirObjTypeFromTypeKey(b.module, kDbg2) : ""
            echo("[backend] debugNestedCtor: ctor=" + objTypeName + " field=" + fieldName +
                 " valKind=nk#" + vkDbg + " key='" + kDbg + "' srcObjName='" + srcObjName + "'")
            echo("[backend] debugNestedCtor: ctor=" + objTypeName + " field=" + fieldName +
                 " inferKey='" + kDbg2 + "' inferObj='" + oDbg2 + "'")
        if len(srcObjName) == 0:
            let fkDbg: str = backendStripSpaces(mirObjFieldTypeKeyGet(objTypeName, fieldName))
            let vkDbg2: str = (valNode != nil) ? intToStr(int32(valNode.kind)) : "nil"
            return Err[MirExpr]("mir_builder: object constructor field '" + fieldName + "' expects object value" +
                                " (obj=" + objTypeName + " fieldKey=" + fkDbg +
                                " inlineObj=" + dstObjName + " valKind=nk#" + vkDbg2 + ")")
        let srcRes: Result[MirExpr] = lowerExprValue(b, valNode, mirTypeI64())
        if ! IsOk[MirExpr](srcRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](srcRes))
        var dstPtr: MirExpr = basePtr
        if minOff != 0 && minOff != 2147483647:
            dstPtr = mirBin(mbAdd, basePtr, mirConstI64(int64(minOff)))
        let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, srcObjName, Value[MirExpr](srcRes))
        if ! IsOk[bool](copyRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](copyRes))
    return Ok[MirExpr](mirLocal(tmpSlot))

fn lowerObjConstructorCallPositional(b: BlockBuilder, callNode: Node, objTypeName: str): Result[MirExpr] =
    if b == nil || b.module == nil || b.func == nil:
        return Err[MirExpr]("mir_builder: object constructor missing builder/module")
    if callNode == nil || callNode.kind != nkCall:
        return Err[MirExpr]("mir_builder: invalid object constructor call")
    if objTypeName == nil || len(objTypeName) == 0 || !mirHasObjType(b.module, objTypeName):
        return Err[MirExpr]("mir_builder: unknown object constructor type")
    let ot: MirObjType = mirGetObjType(b.module, objTypeName)
    let argCount: int32 = kidCount(callNode) - 1
    if (getEnv "CHENG_BACKEND_DEBUG_OBJCTOR" == "1") && (objTypeName == "Option_PublicKey"):
        var fnNameDbg: str = ""
        if b != nil && b.func != nil:
            let fDbg: MirFunc = b.func
            fnNameDbg = fDbg.name
        echo("[backend] debugObjCtor: obj=" + objTypeName +
             " argc=" + intToStr(argCount) + " fields=" + intToStr(ot.fields.len) +
             " fn=" + fnNameDbg)
    if argCount == 0:
        let tmpName: str = blockBuilderNextTemp(b, "__obj")
        let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
        mirSetLocalType(b.func, tmpSlot, mirTypeI64())
        localSetTypeKey(b.env, tmpSlot, objTypeName)
        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objTypeName)
        if !IsOk[bool](allocRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))
        let initRes: Result[bool] = emitObjDefaultInit(b, tmpSlot, objTypeName)
        if !IsOk[bool](initRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](initRes))
        return Ok[MirExpr](mirLocal(tmpSlot))
    if argCount > 0 && argCount <= ot.fields.len:
        let tmpName: str = blockBuilderNextTemp(b, "__obj")
        let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
        mirSetLocalType(b.func, tmpSlot, mirTypeI64())
        localSetTypeKey(b.env, tmpSlot, objTypeName)
        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objTypeName)
        if !IsOk[bool](allocRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))
        let initRes: Result[bool] = emitObjDefaultInit(b, tmpSlot, objTypeName)
        if !IsOk[bool](initRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](initRes))
        let dstPtr: MirExpr = mirLocal(tmpSlot)

        for fi0 in 0..<argCount:
            let f0: MirObjField = ot.fields[fi0]
            var valNode0: Node = kid(callNode, 1 + fi0)
            if valNode0 != nil && valNode0.kind == nkCallArg && kidCount(valNode0) > 1:
                valNode0 = kid(valNode0, 1)
            let valRes0: Result[MirExpr] = lowerExprValue(b, valNode0, f0.ty)
            if !IsOk[MirExpr](valRes0):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes0))
            var addr0: MirExpr = dstPtr
            if f0.offset != 0:
                addr0 = mirBin(mbAdd, dstPtr, mirConstI64(int64(f0.offset)))
            add(b.currentStmts, mirStmtStore(addr0, Value[MirExpr](valRes0), f0.ty))
        return Ok[MirExpr](mirLocal(tmpSlot))

    if argCount <= ot.fields.len + 1:
        var dstNode: Node = kid(callNode, 1)
        if dstNode != nil && dstNode.kind == nkCallArg && kidCount(dstNode) > 1:
            dstNode = kid(dstNode, 1)
        let dstRes: Result[MirExpr] = lowerExprValue(b, dstNode, mirTypeI64())
        if ! IsOk[MirExpr](dstRes):
            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](dstRes))
        let dstPtr: MirExpr = Value[MirExpr](dstRes)
        let initRes: Result[bool] = emitObjDefaultInitPtrs(b, dstPtr, objTypeName)
        if !IsOk[bool](initRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](initRes))

        let argFields: int32 = argCount - 1
        for fi in 0..<argFields:
            let f: MirObjField = ot.fields[fi]
            var valNode: Node = kid(callNode, 2 + fi)
            if valNode != nil && valNode.kind == nkCallArg && kidCount(valNode) > 1:
                valNode = kid(valNode, 1)
            let valRes: Result[MirExpr] = lowerExprValue(b, valNode, f.ty)
            if ! IsOk[MirExpr](valRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes))
            var addr: MirExpr = dstPtr
            if f.offset != 0:
                addr = mirBin(mbAdd, dstPtr, mirConstI64(int64(f.offset)))
            add(b.currentStmts, mirStmtStore(addr, Value[MirExpr](valRes), f.ty))
        return Ok[MirExpr](dstPtr)

    # Too many args for a positional object constructor.
    if argCount > ot.fields.len + 1:
        let line1: str = intToStr(callNode.pos.line)
        let col1: str = intToStr(callNode.pos.col)
        var fnName1: str = ""
        var fp1: str = ""
        if b != nil && b.func != nil:
            let bf1: MirFunc = b.func
            fnName1 = bf1.name
            fp1 = bf1.originFile
        return Err[MirExpr]("mir_builder: object constructor '" + objTypeName +
                            "' expects all fields (or dst + all fields)" +
                            " (argc=" + intToStr(argCount) + " fields=" + intToStr(ot.fields.len) +
                            " fn=" + fnName1 + " " + fp1 + ":" + line1 + ":" + col1 + ")")
    return Err[MirExpr]("mir_builder: object constructor internal error")

fn lowerVarArgAddr(b: BlockBuilder, argNode0: Node): Result[MirExpr] =
    if b == nil:
        return Err[MirExpr]("mir_builder: var arg missing builder")
    var argNode: Node = argNode0
    while argNode != nil && argNode.kind == nkPar && kidCount(argNode) > 0:
        argNode = kid(argNode, 0)
    if argNode != nil && argNode.kind == nkCall && kidCount(argNode) > 0:
        let calleeNode: Node = kid(argNode, 0)
        if calleeNode != nil && (calleeNode.kind == nkIdent || calleeNode.kind == nkSymbol):
            let name: str = backendStripSpaces(plainName(calleeNode))
            if name == "__addr":
                return lowerExprValue(b, argNode, mirTypeI64())
    if argNode != nil && argNode.kind == nkDotExpr:
        let daRes: Result[DotAccess] = lowerDotAccess(b, argNode)
        if !IsOk[DotAccess](daRes):
            return ErrInfo[MirExpr](ErrorInfoOf[DotAccess](daRes))
        let da: DotAccess = Value[DotAccess](daRes)
        return Ok[MirExpr](da.addr)
    if argNode != nil && argNode.kind == nkBracketExpr && kidCount(argNode) == 1:
        return lowerExprValue(b, kid(argNode, 0), mirTypeI64())
    if argNode != nil && (argNode.kind == nkHiddenDeref || argNode.kind == nkDerefExpr) && kidCount(argNode) > 0:
        return lowerExprValue(b, kid(argNode, 0), mirTypeI64())
    if argNode == nil || (argNode.kind != nkIdent && argNode.kind != nkSymbol):
        let k: str = (argNode != nil) ? intToStr(int32(argNode.kind)) : "0"
        let line: str = (argNode != nil) ? intToStr(argNode.pos.line) : "0"
        let col: str = (argNode != nil) ? intToStr(argNode.pos.col) : "0"
        return Err[MirExpr]("mir_builder: var arg expects lvalue (got nk#" + k + " @" + line + ":" + col + ")")
    let nm: str = plainName(argNode)
    let idx: int32 = localIndex(b.env, nm)
    if idx >= 0:
        # Object locals are represented as i64 pointer slots.
        # For object values that own stack storage (frameOff >= 0), the lvalue is the
        # pointed-to storage; passing `var Obj` should pass the pointer value (mirLocal),
        # not the address of the pointer slot (mirAddr).
        let olIdx: int32 = funcFindObjLocal(b.func, idx)
        if olIdx >= 0:
            let fref: MirFunc = b.func
            let ol: MirObjLocal = fref.objLocals[olIdx]
            if ol.frameOff >= 0:
                return Ok[MirExpr](mirLocal(idx))
        return Ok[MirExpr](mirAddr(idx))
    let gi: int32 = moduleGlobalIndex(b.module, nm)
    if gi >= 0:
        let gObj: str = mirGlobalObjTypeGet(nm)
        if len(gObj) > 0:
            return Ok[MirExpr](mirLoad(mirGlobalAddr(nm), mirTypeI64()))
        return Ok[MirExpr](mirGlobalAddr(nm))
    return Ok[MirExpr](mirGlobalAddr(nm))

fn lowerExprPtrValue(b: BlockBuilder, n: Node): Result[MirExpr] =
    # Pointer-context expression lowering (used by deref stores like `*p = v`).
    # `lowerExprValue` loads through `var_` slots to produce the underlying value.
    # For stores, we need the address:
    # - `var T` where T is a scalar: the slot already holds the target address; do not load.
    # - `var ptr_T`: the slot holds the address of a pointer value; load once to get ptr_T.
    if n == nil:
        return Err[MirExpr]("mir_builder: nil ptr expr")
    var node: Node = n
    while node != nil && node.kind == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if node == nil:
        return Err[MirExpr]("mir_builder: nil ptr expr")
    if node.kind == nkIdent || node.kind == nkSymbol:
        let nm: str = backendStripSpaces(plainName(node))
        let idx: int32 = localIndex(b.env, nm)
        if idx >= 0:
            let key0: str = localTypeKey(b.env, idx)
            if key0 != nil && len(key0) > 0:
                var baseKey: str = ""
                if mirStrStartsWith(key0, "var_ref_"):
                    baseKey = str(ptr_add(void*(key0), 8))
                elif mirStrStartsWith(key0, "var_"):
                    baseKey = str(ptr_add(void*(key0), 4))
                if baseKey != nil && len(baseKey) > 0:
                    if mirStrStartsWith(baseKey, "ptr_"):
                        return Ok[MirExpr](mirLoad(mirLocal(idx), mirTypeI64()))
                    return Ok[MirExpr](mirLocal(idx))
    return lowerExprValue(b, node, mirTypeI64())

fn lowerSpawnEntryArg(b: BlockBuilder, argNode0: Node): Result[MirExpr] =
    if b == nil:
        return Err[MirExpr]("mir_builder: spawn entry missing builder")
    var argNode: Node = argNode0
    while argNode != nil && argNode.kind == nkPar && kidCount(argNode) > 0:
        argNode = kid(argNode, 0)
    if argNode == nil || argNode.kind == nkNilLit:
        return Ok[MirExpr](mirConstI64(0))
    let baseRes: Result[MirExpr] = lowerExprValue(b, argNode, mirTypeI64())
    if IsOk[MirExpr](baseRes):
        return baseRes
    if argNode.kind == nkIdent || argNode.kind == nkSymbol:
        let msg: str = Error(baseRes)
        if msg != nil && mirStrStartsWith(msg, "mir_builder: unknown local/global: "):
            let nm: str = backendStripSpaces(plainName(argNode))
            if nm != nil && len(nm) > 0:
                var sym: str = nm
                if mirDupFnBasesHas(nm) && b.func != nil:
                    let f0: MirFunc = b.func
                    let m0: str = mirMaybeMangleDupFnBase(nm, f0.originFile)
                    if m0 != nil && len(m0) > 0:
                        sym = m0
                return Ok[MirExpr](mirGlobalAddr(sym))
    return baseRes

fn lowerExprValue(b: BlockBuilder, n: Node, wantType: MirType): Result[MirExpr] =
    if n == nil:
        return Err[MirExpr]("mir_builder: nil expr")
    var node: Node = n
    while node != nil && node.kind == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    while node != nil && node.kind == nkCallArg && kidCount(node) > 0:
        node = kid(node, kidCount(node) - 1)
    if node == nil:
        return Err[MirExpr]("mir_builder: nil expr")
    if node.kind == nkHiddenDeref || node.kind == nkDerefExpr:
        if kidCount(node) == 0:
            return Err[MirExpr]("mir_builder: deref expects operand")
        let addrNode: Node = kid(node, 0)
        var elemKey: str = ""
        if node.typeCacheValid && node.typeCache != nil:
            elemKey = backendStripSpaces(typeKey node.typeCache)
            if mirStrStartsWith(elemKey, "ptr_"):
                elemKey = backendStripSpaces(str(ptr_add(void*(elemKey), 4)))
        let ptrKey: str = exprTypeKeyShallow(b, addrNode)
        if isByteTypeKey(elemKey) || isBytePtrTypeKey(ptrKey):
            let addrRes: Result[MirExpr] = lowerExprValue(b, addrNode, mirTypeI64())
            if !IsOk[MirExpr](addrRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](addrRes))
            let byteTy: MirType = byteMirTypeFromElemOrPtrKey(elemKey, ptrKey)
            let loaded: MirExpr = lowerByteLoadNilChecked(b, Value[MirExpr](addrRes), byteTy, wantType)
            return Ok[MirExpr](loaded)
        if mirStrStartsWith(ptrKey, "ptr_"):
            # Pointer-to-object deref is a no-op in MIR because object values are represented as pointers.
            # Example: `seq[T]*` is lowered as an i64 pointer to the seq storage; `*p` yields the same pointer.
            let baseKey: str = str(ptr_add(void*(ptrKey), 4))
            if b != nil && b.module != nil && baseKey != nil && len(baseKey) > 0:
                let objTypeName: str = mirPtrBaseObjTypeName(b.module, baseKey)
                if objTypeName != nil && len(objTypeName) > 0:
                    let aliasTy: MirType = mirTryGetTypeAlias(b.module, objTypeName)
                    if aliasTy.kind == mtVoid:
                        return lowerExprValue(b, addrNode, mirTypeI64())
            let addrRes2: Result[MirExpr] = lowerExprValue(b, addrNode, mirTypeI64())
            if !IsOk[MirExpr](addrRes2):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](addrRes2))
            return Ok[MirExpr](mirLoad(Value[MirExpr](addrRes2), wantType))
        # Object values are represented as pointers in MIR; deref is a no-op.
        return lowerExprValue(b, addrNode, mirTypeI64())
    if node.kind == nkStrLit:
        var value: str = node.strVal
        if value == nil:
            value = ""
        let label: str = mirAddCString(b.module, value)
        return Ok[MirExpr](mirGlobalAddr(label))
    if node.kind == nkFloatLit:
        if node.strVal != nil && len(node.strVal) > 0:
            return Ok[MirExpr](mirCast(mirTypeF64(), mirConstI64(cheng_parse_f64_bits(node.strVal))))
        # Some stages may synthesize float literals without a raw string; default to 0.0 bits.
        return Ok[MirExpr](mirCast(mirTypeF64(), mirConstI64(0)))
    if node.kind == nkDotExpr:
        # Dot-call sugar (no-paren) for a zero-arg receiver method.
        # Example: `seq.reset` is lowered as `freeSeq[T](seq)` (where T is inferred from `seq[T]`).
        if kidCount(node) == 2:
            let base0: Node = kid(node, 0)
            let member0: Node = kid(node, 1)
            if base0 != nil && member0 != nil && (member0.kind == nkIdent || member0.kind == nkSymbol):
                let memberName0: str = backendStripSpaces(plainName(member0))
                if memberName0 == "reset":
                    let baseKey0: str = exprTypeKeyShallow(b, base0)
                    if mirStrStartsWith(baseKey0, "seq_"):
                        let elemKey0: str = str(ptr_add(void*(baseKey0), 4))
                        if elemKey0 == nil || len(elemKey0) == 0:
                            return Err[MirExpr]("mir_builder: seq.reset missing element type")
                        let baseRes0: Result[MirExpr] = lowerExprValue(b, base0, mirTypeI64())
                        if !IsOk[MirExpr](baseRes0):
                            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](baseRes0))
                        let typeArg0: Node = newIdent(elemKey0, node.pos)
                        var typeArgs0: Node[]
                        add(typeArgs0, typeArg0)
                        var callName0: str = mangleInstance("freeSeq", typeArgs0)
                        var callInternal0: str = callName0
                        if b.module != nil:
                            var argNodes0: Node[]
                            add(argNodes0, base0)
                            let cand0: MirFunc = mirResolveCalleeFuncBestEffort(b, callName0, argNodes0, "")
                            if cand0 != nil:
                                callInternal0 = cand0.name
                            else:
                                let cand1: MirFunc = mirResolveCalleeFuncBestEffort(b, "freeSeq", argNodes0, "")
                                if cand1 != nil:
                                    callInternal0 = cand1.name
                        var args0: MirExpr[]
                        add(args0, Value[MirExpr](baseRes0))
                        return Ok[MirExpr](mirCall(callInternal0, args0))
        let daRes: Result[DotAccess] = lowerDotAccess(b, node)
        if ! IsOk[DotAccess](daRes):
            return ErrInfo[MirExpr](ErrorInfoOf[DotAccess](daRes))
        let da: DotAccess = Value[DotAccess](daRes)
        if da.fieldTy.kind == mtVoid:
            return Ok[MirExpr](da.addr)
        if node.typeCacheValid && node.typeCache != nil:
            let objNm: str = typeNodeObjTypeName(b.module, node.typeCache)
            if len(objNm) > 0 && typeNodeIsObjValue(b.module, node.typeCache):
                # Object values in MIR are pointers to their storage; dot returns the field address.
                return Ok[MirExpr](da.addr)
        return Ok[MirExpr](mirLoad(da.addr, da.fieldTy))
    if node.kind == nkBracketExpr:
        # Generic bracket expressions used as values (e.g. `default[T]`).
        # Note: prefix-deref `*p` is also represented as `nkBracketExpr` with a single child.
        if kidCount(node) == 2:
            let base0: Node = kid(node, 0)
            if base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol):
                let baseName: str = backendStripSpaces(plainName(base0))
                if baseName == "default":
                    let typeArg0: Node = kid(node, 1)
                    if typeArg0 != nil && (typeArg0.kind == nkIdent || typeArg0.kind == nkSymbol):
                        let tn: str = backendStripSpaces(plainName(typeArg0))
                        if tn == "str" || tn == "string" || tn == "cstring":
                            let label0: str = mirAddCString(b.module, "")
                            return Ok[MirExpr](mirGlobalAddr(label0))
                    let mod0: MirModule = b.module
                    if mod0 != nil:
                        let objNm: str = typeNodeObjTypeName(mod0, typeArg0)
                        if len(objNm) > 0 && typeNodeIsObjValue(mod0, typeArg0):
                            let tmpName: str = blockBuilderNextTemp(b, "__default")
                            let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
                            mirSetLocalType(b.func, tmpSlot, mirTypeI64())
                            let tk0: str = typeKey(typeArg0)
                            if len(tk0) > 0:
                                localSetTypeKey(b.env, tmpSlot, tk0)
                                funcSetObjTypeKey(b.func, tmpSlot, tk0)
                            let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objNm)
                            if !IsOk[bool](allocRes):
                                return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))
                            let initRes: Result[bool] = emitObjDefaultInit(b, tmpSlot, objNm)
                            if !IsOk[bool](initRes):
                                return ErrInfo[MirExpr](ErrorInfoOf[bool](initRes))
                            return Ok[MirExpr](mirLocal(tmpSlot))
                    return Ok[MirExpr](mirConstI64(0))

            # Slice: `str/seq[T][a..b]` / `a..<b`
            var idx0: Node = kid(node, 1)
            while idx0 != nil && idx0.kind == nkPar && kidCount(idx0) > 0:
                idx0 = kid(idx0, 0)
            if idx0 != nil && idx0.kind == nkInfix && kidCount(idx0) >= 3:
                let opNode: Node = kid(idx0, 0)
                let op: str = backendOpName(opNode)
                if op == ".." || op == "..<":
                    var baseKey: str = ""
                    if base0 != nil && base0.typeCacheValid && base0.typeCache != nil:
                        baseKey = typeKey base0.typeCache
                    if len(baseKey) == 0 && base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol):
                        let nm: str = plainName(base0)
                        let slot0: int32 = localIndex(b.env, nm)
                        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                            baseKey = funcObjTypeKey(b.func, slot0)
                        elif slot0 >= 0:
                            baseKey = localTypeKey(b.env, slot0)
                    if len(baseKey) == 0 && base0 != nil && base0.kind == nkCall && b.module != nil && kidCount(base0) > 0:
                        let calleeNode: Node = kid(base0, 0)
                        var name: str = ""
                        var typeArgs: Node[]
                        if calleeNode != nil && calleeNode.kind == nkBracketExpr && kidCount(calleeNode) > 0:
                            let base: Node = kid(calleeNode, 0)
                            name = backendStripSpaces(plainName(base))
                            for ti in 1..<kidCount(calleeNode):
                                let t: Node = kid(calleeNode, ti)
                                if t != nil && t.kind != nkEmpty:
                                    add(typeArgs, t)
                        else:
                            name = backendStripSpaces(plainName(calleeNode))
                        var callName: str = name
                        if typeArgs.len > 0:
                            callName = mangleInstance(name, typeArgs)
                        var argNodes: Node[]
                        for ai in 1..<kidCount(base0):
                            var argNode: Node = kid(base0, ai)
                            if argNode != nil && argNode.kind == nkCallArg && kidCount(argNode) > 1:
                                argNode = kid(argNode, 1)
                            add(argNodes, argNode)
                        let callee0: MirFunc = mirResolveCalleeFuncBestEffort(b, callName, argNodes, "")
                        if callee0 != nil:
                            if callee0.params.len > 0:
                                let p0: MirParam = callee0.params[0]
                                if (p0.name == "__ret"):
                                    baseKey = funcObjTypeKey(callee0, p0.slot)
                            if len(baseKey) == 0 && callee0.retTypeKey != nil && len(callee0.retTypeKey) > 0:
                                baseKey = callee0.retTypeKey
                    if len(baseKey) == 0 && base0 != nil && base0.kind == nkStrLit:
                        baseKey = "str"

                    let startRes: Result[MirExpr] = lowerExprValue(b, kid(idx0, 1), mirTypeI64())
                    if !IsOk[MirExpr](startRes):
                        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](startRes))
                    let stopRes: Result[MirExpr] = lowerExprValue(b, kid(idx0, 2), mirTypeI64())
                    if !IsOk[MirExpr](stopRes):
                        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](stopRes))
                    let exclusive: MirExpr = (op == "..<") ? mirConstI64(1) : mirConstI64(0)
                    let start32: MirExpr = mirCast(mirTypeI32(), Value[MirExpr](startRes))
                    let stop32: MirExpr = mirCast(mirTypeI32(), Value[MirExpr](stopRes))

                    if (baseKey == "str") || (baseKey == "string") || (baseKey == "cstring") || (base0 != nil && base0.kind == nkStrLit):
                        let baseRes: Result[MirExpr] = lowerExprValue(b, base0, mirTypeI64())
                        if !IsOk[MirExpr](baseRes):
                            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](baseRes))
                        var args: MirExpr[]
                        add(args, Value[MirExpr](baseRes))
                        add(args, start32)
                        add(args, stop32)
                        add(args, exclusive)
                        return Ok[MirExpr](mirCall("__cheng_slice_string", args))

                    if mirStrStartsWith(baseKey, "seq_"):
                        let elemKey: str = str(ptr_add(void*(baseKey), 4))
                        if elemKey == nil || len(elemKey) == 0:
                            return Err[MirExpr]("mir_builder: seq slice missing element type")
                        let typeArg0: Node = newIdent(elemKey, node.pos)
                        var typeArgs2: Node[]
                        add(typeArgs2, typeArg0)
                        let callName2: str = mangleInstance("__cheng_slice_vec", typeArgs2)

                        let tmpName: str = blockBuilderNextTemp(b, "__slice_seq")
                        let tmpSlot: int32 = localAdd(b.env, tmpName, mirTypeI64())
                        mirSetLocalType(b.func, tmpSlot, mirTypeI64())
                        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, "seq")
                        if !IsOk[bool](allocRes):
                            return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))
                        funcSetObjTypeKey(b.func, tmpSlot, baseKey)

                        let baseRes2: Result[MirExpr] = lowerExprValue(b, base0, mirTypeI64())
                        if !IsOk[MirExpr](baseRes2):
                            return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](baseRes2))
                        var args2: MirExpr[]
                        add(args2, mirLocal(tmpSlot))
                        add(args2, Value[MirExpr](baseRes2))
                        add(args2, start32)
                        add(args2, stop32)
                        add(args2, exclusive)
                        return Ok[MirExpr](mirCall(callName2, args2))

            # Indexing: currently support fixed-size `array[N, T]` (object value).
            var baseObj: str = ""
            var baseKey2: str = ""
            if base0 != nil && base0.typeCacheValid && base0.typeCache != nil:
                baseKey2 = typeKey base0.typeCache
                baseObj = typeNodeObjTypeName(b.module, base0.typeCache)
            if base0 != nil && (base0.kind == nkIdent || base0.kind == nkSymbol):
                let nm: str = plainName(base0)
                let slot0: int32 = localIndex(b.env, nm)
                if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                    baseObj = funcObjTypeName(b.func, slot0)
                    baseKey2 = funcObjTypeKey(b.func, slot0)
                elif slot0 >= 0 && len(baseKey2) == 0:
                    baseKey2 = localTypeKey(b.env, slot0)
                elif slot0 < 0 && len(baseKey2) == 0:
                    let gk0: str = mirGlobalTypeKeyByBaseUnique(b.module, nm)
                    if gk0 != nil && len(gk0) > 0:
                        baseKey2 = gk0
                    let gObj0: str = mirGlobalObjTypeGet(nm)
                    if len(gObj0) > 0:
                        baseObj = gObj0
                        if len(baseKey2) == 0:
                            baseKey2 = gObj0

            var strKey0: str = baseKey2
            if mirStrStartsWith(strKey0, "var_ref_"):
                strKey0 = str(ptr_add(void*(strKey0), 8))
            elif mirStrStartsWith(strKey0, "var_") || mirStrStartsWith(strKey0, "ref_"):
                strKey0 = str(ptr_add(void*(strKey0), 4))
            if mirStrStartsWith(strKey0, "ptr_"):
                strKey0 = str(ptr_add(void*(strKey0), 4))
            if (strKey0 == "str") || (strKey0 == "string") || (strKey0 == "cstring") || (base0 != nil && base0.kind == nkStrLit):
                var idx1: Node = kid(node, 1)
                while idx1 != nil && idx1.kind == nkPar && kidCount(idx1) > 0:
                    idx1 = kid(idx1, 0)
                if idx1 == nil:
                    return Err[MirExpr]("mir_builder: string subscript expects index")
                let baseRes: Result[MirExpr] = lowerExprValue(b, base0, mirTypeI64())
                if !IsOk[MirExpr](baseRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](baseRes))
                let idxRes: Result[MirExpr] = lowerExprValue(b, idx1, mirTypeI64())
                if !IsOk[MirExpr](idxRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](idxRes))
                let addr: MirExpr = mirBin(mbAdd, Value[MirExpr](baseRes), Value[MirExpr](idxRes))
                return Ok[MirExpr](mirLoad(addr, mirTypeU8()))

            var basePtrOverride: MirExpr = mirConstI64(0)
            var haveBasePtrOverride: bool = false
            if base0 != nil && base0.kind == nkDotExpr:
                let daRes: Result[DotAccess] = lowerDotAccess(b, base0)
                if IsOk[DotAccess](daRes):
                    let da: DotAccess = Value[DotAccess](daRes)
                    if da.fieldTy.kind == mtVoid && da.objTypeName != nil && len(da.objTypeName) > 0:
                        haveBasePtrOverride = true
                        basePtrOverride = da.addr
                        if len(baseObj) == 0:
                            baseObj = da.objTypeName
                        if len(baseKey2) == 0:
                            baseKey2 = da.objTypeName
                # Some stage1 pipelines omit typeCache on dot expressions. Recover a stable generic
                # type key (e.g. `seq_T`) via the same field-type map used by `caseInferExprTypeKey`,
                # so indexing doesn't fall back to `[](base, idx)`.
                let inferredKey2: str = caseInferExprTypeKey(b, base0)
                if inferredKey2 != nil && len(inferredKey2) > 0:
                    if mirStrStartsWith(inferredKey2, "seq_") && !mirStrStartsWith(baseKey2, "seq_"):
                        baseKey2 = inferredKey2
                    elif mirStrStartsWith(inferredKey2, "seq_fixed_") && !mirStrStartsWith(baseKey2, "seq_fixed_"):
                        baseKey2 = inferredKey2
                    elif mirStrStartsWith(inferredKey2, "Table_") && !mirStrStartsWith(baseKey2, "Table_"):
                        baseKey2 = inferredKey2
                    elif len(baseKey2) == 0:
                        baseKey2 = inferredKey2

            var objName: str = baseObj
            if len(objName) == 0:
                objName = baseKey2
            if mirStrStartsWith(objName, "var_ref_"):
                objName = str(ptr_add(void*(objName), 8))
            elif mirStrStartsWith(objName, "var_") || mirStrStartsWith(objName, "ref_"):
                objName = str(ptr_add(void*(objName), 4))

            # Indexing for dynamic `seq[T]`: lower to runtime `cheng_seq_get`.
            var seqKey: str = baseKey2
            if mirStrStartsWith(seqKey, "var_ref_"):
                seqKey = str(ptr_add(void*(seqKey), 8))
            elif mirStrStartsWith(seqKey, "var_") || mirStrStartsWith(seqKey, "ref_"):
                seqKey = str(ptr_add(void*(seqKey), 4))
            if mirStrStartsWith(seqKey, "ptr_"):
                seqKey = str(ptr_add(void*(seqKey), 4))
            if mirStrStartsWith(seqKey, "seq_") && b.module != nil:
                let elemKey: str = str(ptr_add(void*(seqKey), 4))
                if elemKey == nil || len(elemKey) == 0:
                    return Err[MirExpr]("mir_builder: seq subscript missing element type")
                let elemTypeNode: Node = newIdent(elemKey, node.pos)
                let sizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemTypeNode)
                if !IsOk[int32](sizeRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[int32](sizeRes))
                let elemSize: int32 = Value[int32](sizeRes)
                let elemTy: MirType = mirTypeFromNodeWithModule(b.module, elemTypeNode)

                var baseRes3: Result[MirExpr]
                if haveBasePtrOverride:
                    baseRes3 = Ok[MirExpr](basePtrOverride)
                else:
                    baseRes3 = lowerExprValue(b, base0, mirTypeI64())
                if !IsOk[MirExpr](baseRes3):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](baseRes3))
                let seqName: str = blockBuilderNextTemp(b, "__seq_base")
                let seqSlot: int32 = localAdd(b.env, seqName, mirTypeI64())
                mirSetLocalType(b.func, seqSlot, mirTypeI64())
                add(b.currentStmts, mirStmtLet(seqName, seqSlot, Value[MirExpr](baseRes3)))
                let seqPtr: MirExpr = mirLocal(seqSlot)

                var lenOff: int32 = 0
                var bufOff: int32 = 8
                if mirHasObjType(b.module, "seq"):
                    let seqOt: MirObjType = mirGetObjType(b.module, "seq")
                    var lenFound: bool = false
                    var bufFound: bool = false
                    for fi in 0..<seqOt.fields.len:
                        let f: MirObjField = seqOt.fields[fi]
                        if (f.name == "len"):
                            lenOff = f.offset
                            lenFound = true
                        elif (f.name == "buffer"):
                            bufOff = f.offset
                            bufFound = true
                    if !lenFound || !bufFound:
                        return Err[MirExpr]("mir_builder: seq layout mismatch")

                let lenAddr: MirExpr = (lenOff == 0) ? seqPtr : mirBin(mbAdd, seqPtr, mirConstI64(int64(lenOff)))
                let bufAddr: MirExpr = (bufOff == 0) ? seqPtr : mirBin(mbAdd, seqPtr, mirConstI64(int64(bufOff)))
                let lenVal: MirExpr = mirLoad(lenAddr, mirTypeI32())
                let bufVal: MirExpr = mirLoad(bufAddr, mirTypeI64())
                let idxRes3: Result[MirExpr] = lowerExprValue(b, idx0, mirTypeI32())
                if !IsOk[MirExpr](idxRes3):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](idxRes3))
                let elemSize32: MirExpr = mirCast(mirTypeI32(), mirConstI64(int64(elemSize)))
                var args3: MirExpr[]
                add(args3, bufVal)
                add(args3, lenVal)
                add(args3, Value[MirExpr](idxRes3))
                add(args3, elemSize32)
                let ptrExpr: MirExpr = mirCall("cheng_seq_get", args3)
                if (elemKey == "bool"):
                    let loaded: MirExpr = lowerByteLoadNilChecked(b, ptrExpr, mirTypeU8(), wantType)
                    return Ok[MirExpr](loaded)
                if (elemKey == "char"):
                    let raw: MirExpr = mirLoad(ptrExpr, mirTypeI32())
                    let chVal: MirExpr = mirBin(mbAnd, raw, mirConstI64(255))
                    if wantType.kind == mtI32:
                        return Ok[MirExpr](chVal)
                    return Ok[MirExpr](mirCast(wantType, chVal))
                let elemObjName: str = typeNodeObjTypeName(b.module, elemTypeNode)
                if len(elemObjName) > 0 && typeNodeIsObjValue(b.module, elemTypeNode):
                    # Object values in MIR are pointers to storage. For `seq[T]` where `T` is an
                    # object value, `cheng_seq_get` already returns the element address.
                    return Ok[MirExpr](ptrExpr)
                let loaded: MirExpr = mirLoad(ptrExpr, elemTy)
                if wantType.kind != elemTy.kind || wantType.isUnsigned != elemTy.isUnsigned:
                    return Ok[MirExpr](mirCast(wantType, loaded))
                return Ok[MirExpr](loaded)

            if mirStrStartsWith(objName, "array_") && b.module != nil && mirHasObjType(b.module, objName):
                var basePtrRes: Result[MirExpr]
                if haveBasePtrOverride:
                    basePtrRes = Ok[MirExpr](basePtrOverride)
                else:
                    basePtrRes = lowerExprValue(b, base0, mirTypeI64())
                if !IsOk[MirExpr](basePtrRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](basePtrRes))
                let idxRes32: Result[MirExpr] = lowerExprValue(b, idx0, mirTypeI32())
                if !IsOk[MirExpr](idxRes32):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](idxRes32))
                let basePtr: MirExpr = Value[MirExpr](basePtrRes)
                let idx32: MirExpr = Value[MirExpr](idxRes32)

                let ot: MirObjType = mirGetObjType(b.module, objName)
                if ot.fields.len == 0:
                    return Err[MirExpr]("mir_builder: array type has no fields: " + objName)
                let arrLen32: MirExpr = mirCast(mirTypeI32(), mirConstI64(int64(ot.fields.len)))
                var bcArgs: MirExpr[]
                add(bcArgs, arrLen32)
                add(bcArgs, idx32)
                add(b.currentStmts, mirStmtExpr(mirCall("cheng_bounds_check", bcArgs)))
                let idx64: MirExpr = mirCast(mirTypeI64(), idx32)
                let f0: MirObjField = ot.fields[0]
                let elemTy: MirType = f0.ty
                let elemSize: int32 = mirTypeSize(elemTy)
                if elemSize <= 0:
                    return Err[MirExpr]("mir_builder: array element size unsupported: " + objName)
                var stride: int64 = int64(alignUpPow2(elemSize, mirTypeAlignPow2(elemTy)))
                if ot.fields.len > 1:
                    let f1: MirObjField = ot.fields[1]
                    let d: int32 = f1.offset - f0.offset
                    if d > 0:
                        stride = int64(d)
                let off: MirExpr = (stride == 1) ? idx64 : mirBin(mbMul, idx64, mirConstI64(stride))
                let addr: MirExpr = mirBin(mbAdd, basePtr, off)
                let loaded: MirExpr = mirLoad(addr, elemTy)
                if wantType.kind != elemTy.kind || wantType.isUnsigned != elemTy.isUnsigned:
                    return Ok[MirExpr](mirCast(wantType, loaded))
                return Ok[MirExpr](loaded)

            # Fallback: treat `base[idx]` as an operator call `[](base, idx)`.
            let callNode: Node = newNode(nkCall, node.pos)
            callNode.typeCache = node.typeCache
            callNode.typeCacheValid = node.typeCacheValid
            addSon(callNode, newIdent("[]", node.pos))
            addSon(callNode, base0)
            addSon(callNode, idx0)
            return lowerExprValue(b, callNode, wantType)
        if kidCount(node) == 1:
            let addrNode: Node = kid(node, 0)
            let ptrKey0: str = exprTypeKeyShallow(b, addrNode)
            let addrRes: Result[MirExpr] = lowerExprValue(b, addrNode, mirTypeI64())
            if ! IsOk[MirExpr](addrRes):
                return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](addrRes))
            if isBytePtrTypeKey(ptrKey0):
                let byteTy: MirType = byteMirTypeFromPtrTypeKey(ptrKey0)
                let loaded: MirExpr = lowerByteLoadNilChecked(b, Value[MirExpr](addrRes), byteTy, wantType)
                return Ok[MirExpr](loaded)
            if mirStrStartsWith(ptrKey0, "ptr_"):
                let baseKey0: str = str(ptr_add(void*(ptrKey0), 4))
                let objTypeName0: str = mirPtrBaseObjTypeName(b.module, baseKey0)
                if objTypeName0 != nil && len(objTypeName0) > 0:
                    let aliasTy0: MirType = mirTryGetTypeAlias(b.module, objTypeName0)
                    if aliasTy0.kind == mtVoid:
                        return Ok[MirExpr](Value[MirExpr](addrRes))
            return Ok[MirExpr](mirLoad(Value[MirExpr](addrRes), wantType))
        var fnName: str = ""
        var fp: str = ""
        if b != nil && b.func != nil:
            let f0: MirFunc = b.func
            fnName = f0.name
            fp = f0.originFile
        let line: str = intToStr(node.pos.line)
        let col: str = intToStr(node.pos.col)
        return Err[MirExpr]("mir_builder: subscript is not supported (fn=" + fnName + " " + fp +
                            ":" + line + ":" + col + ")")
    if node.kind == nkCurly:
        # Minimal set literal lowering: `set[int32]` as a uint64 bitset.
        # Current implementation supports only constant ordinal elements and constant ranges.
        let mod0: MirModule = b.module
        var bits: int64 = 0
        for i in 0..<kidCount(node):
            var item: Node = kid(node, i)
            while item != nil && item.kind == nkPar && kidCount(item) > 0:
                item = kid(item, 0)
            if item == nil:
                continue
            var fnName: str = ""
            var fp: str = ""
            if b != nil && b.func != nil:
                let f0: MirFunc = b.func
                fnName = f0.name
                fp = f0.originFile
            let line: str = intToStr(item.pos.line)
            let col: str = intToStr(item.pos.col)
            var startVal: int64 = 0
            var endVal: int64 = 0
            var hasRange: bool = false
            var exclusive: bool = false
            if item.kind == nkInfix && kidCount(item) >= 3:
                let opNode: Node = kid(item, 0)
                let op: str = backendOpName(opNode)
                if op == ".." || op == "..<":
                    hasRange = true
                    exclusive = op == "..<"
                    var lhs0: Node = kid(item, 1)
                    var rhs0: Node = kid(item, 2)
                    while lhs0 != nil && lhs0.kind == nkPar && kidCount(lhs0) > 0:
                        lhs0 = kid(lhs0, 0)
                    while rhs0 != nil && rhs0.kind == nkPar && kidCount(rhs0) > 0:
                        rhs0 = kid(rhs0, 0)
                    var okL: bool = false
                    var okR: bool = false
                    if lhs0 != nil && lhs0.kind == nkIntLit:
                        startVal = lhs0.intVal
                        okL = true
                    elif lhs0 != nil && lhs0.kind == nkCharLit:
                        if lhs0.strVal != nil && len(lhs0.strVal) > 0:
                            startVal = int64(lhs0.strVal[0])
                        okL = true
                    elif lhs0 != nil && (lhs0.kind == nkIdent || lhs0.kind == nkSymbol):
                        let nm: str = plainName(lhs0)
                        let gi: int32 = moduleGlobalIndex(mod0, nm)
                        if gi >= 0:
                            let g: MirGlobal = mod0.globals[gi]
                            if g.hasInit:
                                startVal = g.init
                                okL = true
                    if rhs0 != nil && rhs0.kind == nkIntLit:
                        endVal = rhs0.intVal
                        okR = true
                    elif rhs0 != nil && rhs0.kind == nkCharLit:
                        if rhs0.strVal != nil && len(rhs0.strVal) > 0:
                            endVal = int64(rhs0.strVal[0])
                        okR = true
                    elif rhs0 != nil && (rhs0.kind == nkIdent || rhs0.kind == nkSymbol):
                        let nm2: str = plainName(rhs0)
                        let gi2: int32 = moduleGlobalIndex(mod0, nm2)
                        if gi2 >= 0:
                            let g2: MirGlobal = mod0.globals[gi2]
                            if g2.hasInit:
                                endVal = g2.init
                                okR = true
                    if !okL || !okR:
                        return Err[MirExpr]("mir_builder: set range expects const ordinals (fn=" + fnName +
                                            " " + fp + ":" + line + ":" + col + ")")
            if hasRange:
                var v: int64 = startVal
                var stop: int64 = endVal
                if exclusive:
                    stop = stop - 1
                let __for_start_v_1 = v
                for __for_v_1 in __for_start_v_1..stop:
                    v = __for_v_1
                    if v >= 0 && v < 64:
                        bits = bits | (int64(1) << int32(v))
                    v = v + 1
                continue
            var v2: int64 = 0
            var okItem: bool = false
            if item.kind == nkIntLit:
                v2 = item.intVal
                okItem = true
            elif item.kind == nkCharLit:
                if item.strVal != nil && len(item.strVal) > 0:
                    v2 = int64(item.strVal[0])
                okItem = true
            elif item.kind == nkIdent || item.kind == nkSymbol:
                let nm3: str = plainName(item)
                let gi3: int32 = moduleGlobalIndex(mod0, nm3)
                if gi3 >= 0:
                    let g3: MirGlobal = mod0.globals[gi3]
                    if g3.hasInit:
                        v2 = g3.init
                        okItem = true
            if !okItem:
                let k: str = intToStr(int32(item.kind))
                return Err[MirExpr]("mir_builder: set literal expects const ordinals (nk#" + k +
                                    " fn=" + fnName + " " + fp + ":" + line + ":" + col + ")")
            if v2 >= 0 && v2 < 64:
                bits = bits | (int64(1) << int32(v2))
        return Ok[MirExpr](mirConstI64(bits))
    if node.kind == nkTupleLit:
        var tupleType: Node = nil
        if node.typeCacheValid && node.typeCache != nil:
            tupleType = node.typeCache
        else:
            # Stage1 may clear typeCache for tuple literals. Infer a best-effort element type list.
            var ty: Node = newNode(nkTupleTy, node.pos)
            for i0 in 0..<kidCount(node):
                var elemNode0: Node = kid(node, i0)
                if elemNode0 != nil && elemNode0.kind == nkCallArg && kidCount(elemNode0) > 1:
                    elemNode0 = kid(elemNode0, 1)
                var ek: str = ""
                if elemNode0 != nil && elemNode0.typeCacheValid && elemNode0.typeCache != nil:
                    ek = typeKey elemNode0.typeCache
                if len(ek) == 0:
                    if elemNode0 != nil && elemNode0.kind == nkStrLit:
                        ek = "str"
                    elif elemNode0 != nil && elemNode0.kind == nkCharLit:
                        ek = "char"
                    elif elemNode0 != nil && elemNode0.kind == nkBoolLit:
                        ek = "bool"
                    else:
                        ek = "int64"
                addSon(ty, newIdent(ek, node.pos))
            tupleType = ty
        let tupleObj: str = typeNodeObjTypeName(b.module, tupleType)
        if len(tupleObj) == 0 || ! typeNodeIsObjValue(b.module, tupleType):
            return Err[MirExpr]("mir_builder: tuple literal unsupported type")
        let tmpName: str = blockBuilderNextTemp(b, "__tuple")
        let slot: int32 = localAdd(b.env, tmpName, mirTypeI64())
        mirSetLocalType(b.func, slot, mirTypeI64())
        let allocRes: Result[bool] = allocObjValueLocal(b, slot, tupleObj)
        if ! IsOk[bool](allocRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))
        let ot: MirObjType = mirGetObjType(b.module, tupleObj)
        for i in 0..<kidCount(node):
            var elemNode: Node = kid(node, i)
            if elemNode != nil && elemNode.kind == nkCallArg && kidCount(elemNode) > 1:
                elemNode = kid(elemNode, 1)
            let fieldName: str = "f" + intToStr(i)
            for fi in 0..<ot.fields.len:
                let f: MirObjField = ot.fields[fi]
                if (f.name == fieldName):
                    let valRes: Result[MirExpr] = lowerExprValue(b, elemNode, f.ty)
                    if ! IsOk[MirExpr](valRes):
                        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes))
                    let basePtr: MirExpr = mirLocal(slot)
                    var addr: MirExpr = basePtr
                    if f.offset != 0:
                        addr = mirBin(mbAdd, basePtr, mirConstI64(int64(f.offset)))
                    add(b.currentStmts, mirStmtStore(addr, Value[MirExpr](valRes), f.ty))
                    break
        return Ok[MirExpr](mirLocal(slot))
    if node.kind == nkSeqLit:
        if b == nil || b.module == nil || b.func == nil:
            return Err[MirExpr]("mir_builder: seq literal missing builder/module")
        let count: int32 = kidCount(node)
        var elemSize: int32 = 0
        var elemMirTy: MirType = mirTypeI64()
        if count > 0:
            if ! node.typeCacheValid || node.typeCache == nil:
                var fnName: str = ""
                var fp: str = ""
                if b != nil && b.func != nil:
                    let f0: MirFunc = b.func
                    fnName = f0.name
                    fp = f0.originFile
                let line: str = intToStr(node.pos.line)
                let col: str = intToStr(node.pos.col)
                return Err[MirExpr]("mir_builder: seq literal requires type (fn=" + fnName + " " + fp +
                                    ":" + line + ":" + col + ")")
            var elemType: Node = nil
            let litType: Node = node.typeCache
            if litType != nil && litType.kind == nkBracketExpr && kidCount(litType) > 1:
                let base: Node = kid(litType, 0)
                if base != nil && (base.kind == nkIdent || base.kind == nkSymbol):
                    let nm: str = backendStripSpaces(plainName(base))
                    if nm == "seq":
                        elemType = kid(litType, 1)
            if elemType == nil:
                var fnName2: str = ""
                var fp2: str = ""
                if b != nil && b.func != nil:
                    let f2: MirFunc = b.func
                    fnName2 = f2.name
                    fp2 = f2.originFile
                let line2: str = intToStr(node.pos.line)
                let col2: str = intToStr(node.pos.col)
                return Err[MirExpr]("mir_builder: seq literal unsupported type (fn=" + fnName2 + " " + fp2 +
                                    ":" + line2 + ":" + col2 + ")")

            let sizeRes: Result[int32] = mirSizeOfTypeNode(b.module, elemType)
            if ! IsOk[int32](sizeRes):
                return ErrInfo[MirExpr](ErrorInfoOf[int32](sizeRes))
            elemSize = Value[int32](sizeRes)
            elemMirTy = mirTypeFromNodeWithModule(b.module, elemType)

        let seqObj: str = "seq"
        let tmpName: str = blockBuilderNextTemp(b, "__seq")
        let slot: int32 = localAdd(b.env, tmpName, mirTypeI64())
        mirSetLocalType(b.func, slot, mirTypeI64())
        let allocRes: Result[bool] = allocObjValueLocal(b, slot, seqObj)
        if ! IsOk[bool](allocRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](allocRes))

        let seqOt: MirObjType = mirGetObjType(b.module, seqObj)
        var lenOff: int32 = -1
        var capOff: int32 = -1
        var bufOff: int32 = -1
        for fi in 0..<seqOt.fields.len:
            let f: MirObjField = seqOt.fields[fi]
            if (f.name == "len"):
                lenOff = f.offset
            elif (f.name == "cap"):
                capOff = f.offset
            elif (f.name == "buffer"):
                bufOff = f.offset
        if lenOff < 0 || capOff < 0 || bufOff < 0:
            return Err[MirExpr]("mir_builder: seq layout mismatch")

        let basePtr: MirExpr = mirLocal(slot)
        let lenAddr: MirExpr = (lenOff == 0) ? basePtr : mirBin(mbAdd, basePtr, mirConstI64(int64(lenOff)))
        let capAddr: MirExpr = (capOff == 0) ? basePtr : mirBin(mbAdd, basePtr, mirConstI64(int64(capOff)))
        let bufAddr: MirExpr = (bufOff == 0) ? basePtr : mirBin(mbAdd, basePtr, mirConstI64(int64(bufOff)))
        add(b.currentStmts, mirStmtStore(lenAddr, mirConstI64(int64(count)), mirTypeI32()))
        add(b.currentStmts, mirStmtStore(capAddr, mirConstI64(int64(count)), mirTypeI32()))

        var bufPtr: MirExpr = mirConstI64(0)
        if count > 0 && elemSize > 0:
            let bytes: int64 = int64(count) * int64(elemSize)
            var allocArgs: MirExpr[]
            add(allocArgs, mirConstI64(bytes))
            let allocCall: MirExpr = mirCall("alloc", allocArgs)
            let bufName: str = blockBuilderNextTemp(b, "__seq_buf")
            let bufSlot: int32 = localAdd(b.env, bufName, mirTypeI64())
            mirSetLocalType(b.func, bufSlot, mirTypeI64())
            add(b.currentStmts, mirStmtLet(bufName, bufSlot, allocCall))
            bufPtr = mirLocal(bufSlot)
        add(b.currentStmts, mirStmtStore(bufAddr, bufPtr, mirTypeI64()))

        if count > 0 && elemSize > 0:
            for i in 0..<count:
                var elemNode: Node = kid(node, i)
                if elemNode != nil && elemNode.kind == nkCallArg && kidCount(elemNode) > 1:
                    elemNode = kid(elemNode, 1)
                let valRes: Result[MirExpr] = lowerExprValue(b, elemNode, elemMirTy)
                if ! IsOk[MirExpr](valRes):
                    return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](valRes))
                let off: int64 = int64(i) * int64(elemSize)
                let addr: MirExpr = (off == 0) ? bufPtr : mirBin(mbAdd, bufPtr, mirConstI64(off))
                add(b.currentStmts, mirStmtStore(addr, Value[MirExpr](valRes), elemMirTy))

        return Ok[MirExpr](mirLocal(slot))
    if isControlExpr(node):
        let tmpName: str = blockBuilderNextTemp(b, "__tmp")
        let tmpSlot: int32 = localAdd(b.env, tmpName, wantType)
        mirSetLocalType(b.func, tmpSlot, wantType)
        let assignRes: Result[bool] = lowerAssignValue(b, node, tmpName, tmpSlot)
        if ! IsOk[bool](assignRes):
            return ErrInfo[MirExpr](ErrorInfoOf[bool](assignRes))
        return Ok[MirExpr](mirLocal(tmpSlot))
    if node.kind == nkIntLit:
        return Ok[MirExpr](mirConstI64(node.intVal))
    if node.kind == nkBoolLit:
        let name: str = backendStripSpaces(node.ident)
        if name == "true":
            return Ok[MirExpr](mirConstI64(1))
        return Ok[MirExpr](mirConstI64(0))
    if node.kind == nkCharLit:
        if node.strVal != nil && len(node.strVal) > 0:
            let c: char = node.strVal[0]
            return Ok[MirExpr](mirConstI64(int64(c)))
        return Ok[MirExpr](mirConstI64(0))
    if node.kind == nkNilLit:
        return Ok[MirExpr](mirConstI64(0))
    if node.kind == nkIdent || node.kind == nkSymbol:
        let nm: str = plainName(node)
        let idx: int32 = localIndex(b.env, nm)
        if idx >= 0:
            let key0: str = localTypeKey(b.env, idx)
            if key0 != nil && len(key0) > 0 && b.module != nil:
                var key: str = key0
                var baseKey: str = ""
                if mirStrStartsWith(key, "var_ref_"):
                    baseKey = str(ptr_add(void*(key), 8))
                elif mirStrStartsWith(key, "var_"):
                    baseKey = str(ptr_add(void*(key), 4))
