type
    LocalEnv = ref
        names: str[]
        types: MirType[]
        typeKeys: str[]
        callTargets: str[]
        active: bool[]
        scopeMarks: int32[]
        nameIndex: hashmaps.HashMapStrInt
        prevSlots: int32[]
    DeferFrame = ref
        bodies: Node[]
    LoopContext = ref
        breakLabel: str
        continueLabel: str
        deferDepth: int32
    BlockBuilder = ref
        env: LocalEnv
        module: MirModule
        func: MirFunc
        currentLabel: str
        currentStmts: MirStmt[]
        labelCounter: int32
        objCursor: int32
        loopStack: LoopContext[]
        deferStack: DeferFrame[]

    DotAccess =
        addr: MirExpr
        fieldTy: MirType
        # Non-empty only when fieldTy == mtVoid (composite/inlined object field).
        objTypeName: str

