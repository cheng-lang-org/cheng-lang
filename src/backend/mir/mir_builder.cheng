            var optionCtorKind0: int32 = 0
            var optionSuffix0: str = ""
            if kidCount(node) == 2 && mirStrStartsWith(helperCallName0, "Some_"):
                optionCtorKind0 = 1
                optionSuffix0 = str(ptr_add(void*(helperCallName0), 5))
