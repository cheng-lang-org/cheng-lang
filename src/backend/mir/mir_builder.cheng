                        elif kidCount(countNode0) > 0:
                            countNode0 = kid(countNode0, 0)
                    let countRes0: Result[MirExpr] = lowerExprValue(b, countNode0, mirTypeI32())
                    if !IsOk[MirExpr](countRes0):
                        return ErrInfo[MirExpr](ErrorInfoOf[MirExpr](countRes0))
                    let bytes64_0: MirExpr = mirBin(mbMul,
                        mirCast(mirTypeI64(), Value[MirExpr](countRes0)),
                        mirConstI64(int64(elemSize0)))
                    let bytes32_0: MirExpr = mirCast(mirTypeI32(), bytes64_0)
                    if wantType.kind != mtI32:
                        return Ok[MirExpr](mirCast(wantType, bytes32_0))
