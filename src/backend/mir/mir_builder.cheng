                    let k0: str = (ch0 != nil) ? intToStr(int32(ch0.kind)) : "nil"
                    var extra0: str = ""
                    if ch0 != nil && (ch0.kind == nkIdent || ch0.kind == nkSymbol):
                        extra0 = " name=" + plainName(ch0)
                    if ch0 != nil && ch0.kind == nkCallArg:
