# Minimal HIR types for backend MVP.
import std/seqs

type
    HirTypeKind = enum
        htI32, htI64

    HirType = ref
        kind: HirTypeKind

    HirFunc = ref
        name: str
        retType: HirType

    HirModule = ref
        funcs: seq[HirFunc]

fn hirTypeI32(): HirType =
    var t: HirType
    new t
    t.kind = htI32
    return t

fn hirTypeI64(): HirType =
    var t: HirType
    new t
    t.kind = htI64
    return t

fn hirNewFunc(name: str, retType: HirType): HirFunc =
    var f: HirFunc
    new f
    f.name = name
    f.retType = retType
    return f

fn hirNewModule(): HirModule =
    var m: HirModule
    new m
    m.funcs = newSeq[HirFunc]()
    return m

fn hirAddFunc(module: HirModule, func: HirFunc) =
    addPtr[HirFunc](&module.funcs, func)
