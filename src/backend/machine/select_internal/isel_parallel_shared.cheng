import std/result
import std/strings
import std/strutils
import std/system
import std/hashmaps
import std/rawmem_support
import backend/uir/uir_types
import backend/machine/machine_types

type
    LabelState = ref
        nextId: int32
        prefix: str

    IselFuncIndexCacheState = object
        ready: bool
        module: UirModule
        len: int32
        map: hashmaps.HashMapStrInt

    IselFuncTask = ref
        funcIndex: int32
        costHint: int32
        func: UirFunc

    IselFuncTaskResult = ref
        funcIndex: int32
        loweredFunc: MachineFunc

    IselParallelTaskState = ref
        module: UirModule
        task: IselFuncTask
        result: IselFuncTaskResult
        err: ErrorInfo
        status: int32

fn add(dst: var IselFuncTask[], val: IselFuncTask) =
    let needLen: int32 = dst.len + 1
    if dst.cap < needLen:
        reserve(dst, needLen)
    setLen(dst, needLen)
    dst[needLen - 1] = val

fn add(dst: var IselFuncTaskResult[], val: IselFuncTaskResult) =
    let needLen: int32 = dst.len + 1
    if dst.cap < needLen:
        reserve(dst, needLen)
    setLen(dst, needLen)
    dst[needLen - 1] = val

fn add(dst: var IselParallelTaskState[], val: IselParallelTaskState) =
    let needLen: int32 = dst.len + 1
    if dst.cap < needLen:
        reserve(dst, needLen)
    setLen(dst, needLen)
    dst[needLen - 1] = val

fn add(dst: var int32[], val: int32) =
    let needLen: int32 = dst.len + 1
    if dst.cap < needLen:
        reserve(dst, needLen)
    setLen(dst, needLen)
    dst[needLen - 1] = val

fn add(dst: var str[], val: str) =
    let needLen: int32 = dst.len + 1
    if dst.cap < needLen:
        reserve(dst, needLen)
    setLen(dst, needLen)
    dst[needLen - 1] = val

fn iselNewLabelState(prefix: str): LabelState =
    var st: LabelState
    new st
    st.nextId = 0
    let ownedPrefix: str = strings.__cheng_str_clone(prefix)
    memRetain(ownedPrefix)
    st.prefix = ownedPrefix
    return st

fn iselTraceBlockNoop(_dbgEnabled: bool, _blockIndex: int32) =
    return

fn isel_strContains(hay: str, needle: str): bool =
    let n: int32 = len(hay)
    let m: int32 = len(needle)
    if m == 0:
        return true
    if n == 0:
        return false
    if n < m:
        return false
    for i in 0..n - m:
        for j in 0..<m:
            if !(hay[i + j] == needle[j]):
                break
        if j == m:
            return true
    return false

fn isel_strStartsWith(s: str, prefix: str): bool =
    let n: int32 = len(s)
    let m: int32 = len(prefix)
    if m == 0:
        return true
    if n == 0:
        return false
    if n < m:
        return false
    for i in 0..<m:
        if s[i] != prefix[i]:
            return false
    return true

fn iselTargetIsDarwin(target: str): bool =
    if len(target) == 0:
        return true
    return isel_strContains(target, "apple") || isel_strContains(target, "darwin") || isel_strContains(target, "ios")

fn iselTypeKeyIsVarargs(typeKey: str): bool =
    if len(typeKey) == 0:
        return false
    if strings.streq(typeKey, "varargs"):
        return true
    return isel_strStartsWith(typeKey, "varargs_")

fn iselVarargsElemTypeFromTypeKey(typeKey: str): Result[UirLowerType] =
    if len(typeKey) == 0 || strings.streq(typeKey, "varargs"):
        return Ok[UirLowerType](uirTypeI32())
    if strings.streq(typeKey, "varargs_int32") || strings.streq(typeKey, "varargs_i32"):
        return Ok[UirLowerType](uirTypeI32())
    if strings.streq(typeKey, "varargs_uint32") || strings.streq(typeKey, "varargs_u32"):
        return Ok[UirLowerType](uirTypeU32())
    if strings.streq(typeKey, "varargs_int") || strings.streq(typeKey, "varargs_NI"):
        return Ok[UirLowerType](uirTypeI32())
    if strings.streq(typeKey, "varargs_uint") || strings.streq(typeKey, "varargs_NU"):
        return Ok[UirLowerType](uirTypeU32())
    if strings.streq(typeKey, "varargs_int64") || strings.streq(typeKey, "varargs_i64"):
        return Ok[UirLowerType](uirTypeI64())
    if strings.streq(typeKey, "varargs_uint64") || strings.streq(typeKey, "varargs_u64"):
        return Ok[UirLowerType](uirTypeU64())
    if strings.streq(typeKey, "varargs_ptr") || strings.streq(typeKey, "varargs_void" + "*") ||
       strings.streq(typeKey, "varargs_cstring") || strings.streq(typeKey, "varargs_str"):
        return Ok[UirLowerType](uirTypeI64())
    if strings.streq(typeKey, "varargs_bool") || strings.streq(typeKey, "varargs_char") ||
       strings.streq(typeKey, "varargs_int8") || strings.streq(typeKey, "varargs_i8") ||
       strings.streq(typeKey, "varargs_uint8") || strings.streq(typeKey, "varargs_u8") ||
       strings.streq(typeKey, "varargs_int16") || strings.streq(typeKey, "varargs_i16") ||
       strings.streq(typeKey, "varargs_uint16") || strings.streq(typeKey, "varargs_u16"):
        return Ok[UirLowerType](uirTypeI32())
    return Err[UirLowerType]("isel: unsupported varargs element typeKey: " + typeKey)

fn iselSymPrefix(module: UirModule): str =
    if module != nil && iselTargetIsDarwin(uirModuleTargetOf(module)):
        return "_"
    return ""

fn iselIsInternalSym(name: str): bool =
    if len(name) == 0:
        return false
    # Backend-internal labels (e.g. cstring constants) are emitted without symPrefix.
    return isel_strStartsWith(name, "L_cheng_")

fn iselStripTargetSymPrefixOnce(target: str, name: str): str =
    if len(name) == 0:
        return ""
    if iselTargetIsDarwin(target) && len(name) > 0 && name[0] == '_' :
        # Only strip the Mach-O leading underscore once.
        # Do not strip if the symbol itself intentionally starts with "__" (e.g. __cheng_"*").
        if len(name) >= 2 && name[1] == '_' :
            return name
        return strings.sliceBytes(name, 1, len(name) - 1)
    return name

fn iselStableNameCopy(name: str): str =
    return name

fn iselPersistMachineName(target: str, name: str): str =
    let _target: str = target
    return name

fn iselJoinStable(a: str, b: str): str =
    if len(a) == 0:
        return b
    if len(b) == 0:
        return a
    return a + b

fn iselTypeIs64(ty: UirLowerType): bool =
    return iselTypeKind(ty) == mtI64 || iselTypeKind(ty) == mtF64

fn iselTypeIs32(ty: UirLowerType): bool =
    return iselTypeKind(ty) == mtI32 || iselTypeKind(ty) == mtF32

fn iselTypeKind(ty: UirLowerType): UirCoreTypeKind =
    return UirCoreTypeKind(uirCoreTypeKindRaw(ty))

fn iselTypeUnsigned(ty: UirLowerType): bool =
    return uirCoreTypeIsUnsigned(ty)

fn iselArgType(callee: UirFunc, index: int32, fallback: UirLowerType): UirLowerType =
    if callee != nil && index >= 0 && index < uirFuncParamsLen(callee):
        let p: UirParam = uirFuncParamAt(callee, index)
        return uirParamTypeOf(p)
    return fallback

fn iselLocalType(uirFunc: UirFunc, index: int32, fallback: UirLowerType): UirLowerType =
    if uirFunc != nil && index >= 0 && index < uirFuncLocalTypesLen(uirFunc):
        return uirFuncLocalTypeAt(uirFunc, index)
    return fallback

fn iselMaxType(a: UirLowerType, b: UirLowerType): UirLowerType =
    if iselTypeKind(a) == mtF64 || iselTypeKind(b) == mtF64:
        return uirTypeF64()
    if iselTypeKind(a) == mtF32 || iselTypeKind(b) == mtF32:
        return uirTypeF32()
    if iselTypeKind(a) == mtI64 || iselTypeKind(b) == mtI64:
        var out: UirLowerType = uirTypeI64()
        if iselTypeKind(a) == mtI64:
            out = uirCoreTypeWithUnsigned(out, iselTypeUnsigned(a))
        elif iselTypeKind(b) == mtI64:
            out = uirCoreTypeWithUnsigned(out, iselTypeUnsigned(b))
        return out
    var out2: UirLowerType = uirTypeI32()
    out2 = uirCoreTypeWithUnsigned(out2, iselTypeUnsigned(a) || iselTypeUnsigned(b))
    return out2

fn iselExprType(module: UirModule, uirFunc: UirFunc, expr: UirExpr,
                fallback: UirLowerType): UirLowerType =
    if iselExprInvalid(expr):
        return fallback
    if uirExprKindOf(expr) == meLocal:
        return iselLocalType(uirFunc, uirExprLocalIndexOf(expr), fallback)
    if uirExprKindOf(expr) == meCall:
        return fallback
    if uirExprKindOf(expr) == meBin:
        if uirExprBinOpOf(expr) == mbShl || uirExprBinOpOf(expr) == mbShr:
            return iselExprType(module, uirFunc, uirExprLhsOf(expr), fallback)
        let lt: UirLowerType = iselExprType(module, uirFunc, uirExprLhsOf(expr), fallback)
        let rt: UirLowerType = iselExprType(module, uirFunc, uirExprRhsOf(expr), fallback)
        return iselMaxType(lt, rt)
    if uirExprKindOf(expr) == meCmp:
        return uirTypeI32()
    if uirExprKindOf(expr) == meCast:
        return uirExprCastTypeOf(expr)
    if uirExprKindOf(expr) == meAddr:
        return uirTypeI64()
    if uirExprKindOf(expr) == meLoad:
        if iselTypeKind(uirExprLoadTypeOf(expr)) == mtVoid:
            return fallback
        return uirExprLoadTypeOf(expr)
    if uirExprKindOf(expr) == meGlobalAddr:
        return uirTypeI64()
    return fallback

fn iselTypeSize(ty: UirLowerType): int32 =
    if iselTypeKind(ty) == mtF64:
        return 8
    if iselTypeKind(ty) == mtI64:
        return 8
    if iselTypeKind(ty) == mtF32:
        return 4
    if iselTypeKind(ty) == mtI32:
        return 4
    if iselTypeKind(ty) == mtI16:
        return 2
    if iselTypeKind(ty) == mtI8:
        return 1
    return 0

fn iselTypeKindKnown(ty: UirLowerType): bool =
    let k: int32 = int32(iselTypeKind(ty))
    return k >= int32(mtVoid) && k <= int32(mtF64)

fn iselTypeAlignPow2(ty: UirLowerType): int32 =
    if iselTypeKind(ty) == mtF64:
        return 3
    if iselTypeKind(ty) == mtI64:
        return 3
    if iselTypeKind(ty) == mtF32:
        return 2
    if iselTypeKind(ty) == mtI32:
        return 2
    if iselTypeKind(ty) == mtI16:
        return 1
    if iselTypeKind(ty) == mtI8:
        return 0
    return 0

fn iselCondFromCmp(op: UirCmpOp, isUnsigned: bool): MachineCond =
    case op
    of mcEq: return MachineCond(0)
    of mcNe: return MachineCond(1)
    of mcLt: return isUnsigned ? MachineCond(7) : MachineCond(3)
    of mcLe: return isUnsigned ? MachineCond(8) : MachineCond(4)
    of mcGt: return isUnsigned ? MachineCond(9) : MachineCond(5)
    of mcGe: return isUnsigned ? MachineCond(10) : MachineCond(6)
    return MachineCond(0)

fn iselAddInst(func: MachineFunc, inst: MachineInst) =
    if iselFuncInvalid(func) || !machineInstValid(inst):
        return
    machineAddInst(func, inst)

fn iselAlignUp(v: int64, align: int64): int64 =
    if align <= 1:
        return v
    let m: int64 = v % align
    if m == 0:
        return v
    return v + (align - m)

fn iselIsCallIndirectBuiltin(name: str): bool =
    if len(name) == 0:
        return false
    return isel_strStartsWith(name, "__cheng_call_indirect_")

fn iselIsF64BitsIntrinsic(name: str): bool =
    if len(name) == 0:
        return false
    return strings.streq(name, "cheng_f64_add_bits") ||
           strings.streq(name, "cheng_f64_sub_bits") ||
           strings.streq(name, "cheng_f64_mul_bits") ||
           strings.streq(name, "cheng_f64_div_bits") ||
           strings.streq(name, "cheng_f64_neg_bits") ||
           strings.streq(name, "cheng_f64_lt_bits") ||
           strings.streq(name, "cheng_f64_le_bits") ||
           strings.streq(name, "cheng_f64_gt_bits") ||
           strings.streq(name, "cheng_f64_ge_bits") ||
           strings.streq(name, "cheng_i64_to_f64_bits")

fn iselFreshLabel(prefix: str, state: LabelState): str =
    let id: int32 = state.nextId
    state.nextId = state.nextId + 1
    let out: str = iselJoinStable(iselJoinStable(state.prefix, prefix), intToStr(id))
    memRetain(out)
    return out

fn iselStrPtrMaybeValid(s: str): bool =
    let ptrVal: int64 = int64(rawmem_support.rawmemAsVoid(s))
    if ptrVal == 0:
        return true
    if ptrVal <= 4096:
        return false
    if ptrVal >= int64(0x0001000000000000):
        return false
    let low32: int64 = ptrVal & int64(0xffffffff)
    let high32: int64 = (ptrVal >> 32) & int64(0xffffffff)
    if high32 == 0:
        return false
    if high32 > 1 && high32 < int64(0x1000):
        return false
    if low32 == 0 && high32 <= 1:
        return false
    if high32 == 0 && low32 < int64(1 << 20):
        return false
    if low32 > 0 && low32 < int64(1 << 20) && high32 > 0 && high32 < int64(1 << 20):
        return false
    return true

fn iselFuncLinkNameSafe(func: UirFunc): str =
    if func == nil:
        return ""
    let raw: str = uirFuncLinkNameObjFirst(func)
    return raw

fn iselFuncNameSafe(func: UirFunc): str =
    if func == nil:
        return ""
    let raw: str = uirFuncNameObjFirst(func)
    return raw

fn iselFuncBestName(func: UirFunc): str =
    let linkName: str = iselFuncLinkNameSafe(func)
    if len(linkName) > 0:
        return linkName
    let funcName: str = iselFuncNameSafe(func)
    if len(funcName) > 0:
        return funcName
    return ""

fn iselExprInvalid(expr: UirExpr): bool =
    return expr <= 0

fn iselBlockInvalid(block: UirLowerBlock): bool =
    return block <= 0

fn iselFuncInvalid(func: UirFunc): bool =
    return func == nil

fn iselModuleInvalid(module: UirModule): bool =
    return module == nil

fn iselOkMachineFunc(value: MachineFunc): Result[MachineFunc] =
    var out: Result[MachineFunc]
    out.ok = true
    out.value = value
    ErrorOkInto(out.err)
    return out

fn iselErrInfoMachineFunc(err: ErrorInfo): Result[MachineFunc] =
    var out: Result[MachineFunc]
    out.ok = false
    let msg: str = ErrorMessage(err)
    if len(msg) > 0:
        out.err = err
    else:
        ErrorNewInto(out.err, "isel: empty machine func error")
    return out

fn iselCollectFuncTasks(module: UirModule, maxFuncs: int32, dbgIsel: bool): IselFuncTask[] =
    var tasks: IselFuncTask[]
    reserve(tasks, uirModuleFuncsLen(module))
    for i in 0..<uirModuleFuncsLen(module):
        if maxFuncs > 0 && i >= maxFuncs:
            if dbgIsel:
                echo("[isel] stop at fn[" + intToStr(i) + "] due to BACKEND_DEBUG_ISEL_MAX_FUNCS")
            break
        let f: UirFunc = uirModuleFuncAt(module, i)
        if dbgIsel && f != nil:
            echo("[isel] fn[" + intToStr(i) + "] name=" + iselFuncBestName(f) +
                 " extern=" + (uirFuncIsExternObjFirst(f) ? "1" : "0"))
        if f == nil || uirFuncIsExternObjFirst(f):
            continue
        if uirFuncBlocksLenObjFirst(f) <= 0:
            if dbgIsel:
                echo("[isel] fn[" + intToStr(i) + "] skip zero-block nonextern")
            continue
        var task: IselFuncTask
        new task
        task.funcIndex = i
        task.costHint = iselFuncTaskCostHint(f)
        task.func = f
        add(tasks, task)
    return tasks

fn iselFuncLocalsSize(func: UirFunc): int64 =
    if iselFuncInvalid(func):
        return 0
    return int64(uirFuncLocalTypesLen(func)) * 8

fn iselFuncFrameSize(func: UirFunc, localsSize: int64): int64 =
    if iselFuncInvalid(func):
        return 0
    let objSize: int64 = int64(uirFuncObjFrameSizeOf(func))
    var frameSize: int64 = localsSize + objSize
    let rem: int64 = frameSize % 16
    if rem != 0:
        frameSize = frameSize + (16 - rem)
    return frameSize

fn iselLowerFuncBlocksCore(out: MachineFunc, module: UirModule, func: UirFunc,
                           labelState: LabelState, frameSize: int64, localsSize: int64,
                           retType: UirLowerType, retReg: MachineReg, tmpReg: MachineReg,
                           scratchReg: MachineReg, baseReg: MachineReg,
                           beforeBlock: fn (dbgEnabled: bool, blockIndex: int32),
                           afterBlock: fn (dbgEnabled: bool, blockIndex: int32),
                           dbgEnabled: bool,
                           lowerBlock: fn (func: MachineFunc, module: UirModule, block: UirLowerBlock,
                                           uirFunc: UirFunc, labelState: LabelState,
                                           frameSize: int64, localsSize: int64, isEntry: bool,
                                           retType: UirLowerType, retReg: MachineReg, tmpReg: MachineReg,
                                           scratchReg: MachineReg, baseReg: MachineReg): Result[int32]
                           ): Result[int32] =
    if iselFuncInvalid(func):
        return Err[int32]("isel: nil function")
    for i in 0..<uirFuncBlocksLenObjFirst(func):
        beforeBlock(dbgEnabled, i)
        let block: UirLowerBlock = uirFuncBlockAtObjFirst(func, i)
        let isEntry: bool = i == 0
        let bRes: Result[int32] = lowerBlock(out, module, block, func, labelState,
                                             frameSize, localsSize, isEntry, retType, retReg,
                                             tmpReg, scratchReg, baseReg)
        if !IsOk[int32](bRes):
            return ErrInfo[int32](ErrorInfoOf[int32](bRes))
        afterBlock(dbgEnabled, i)
    return Ok[int32](0)

fn iselExecuteLowerFuncTask(module: UirModule, task: IselFuncTask,
                            lowerFunc: fn (module: UirModule, func: UirFunc): Result[MachineFunc]
                            ): Result[IselFuncTaskResult] =
    if task == nil || task.func == nil:
        return iselOkFuncTaskResult(nil)
    let fRes: Result[MachineFunc] = lowerFunc(module, task.func)
    if !IsOk[MachineFunc](fRes):
        return iselErrInfoFuncTaskResult(ErrorInfoOf[MachineFunc](fRes))
    var out: IselFuncTaskResult
    new out
    out.funcIndex = task.funcIndex
    out.loweredFunc = fRes.value
    return iselOkFuncTaskResult(out)

fn iselRunParallelTaskWorkerBody(slots: var IselParallelTaskState[], slot: int32,
                                 executeTask: fn (module: UirModule, task: IselFuncTask): Result[IselFuncTaskResult]
                                 ) =
    if slot < 0 || slot >= slots.len:
        return
    let state: IselParallelTaskState = slots[slot]
    if state == nil:
        return
    let taskRes: Result[IselFuncTaskResult] = executeTask(state.module, state.task)
    if IsOk[IselFuncTaskResult](taskRes):
        state.result = taskRes.value
        atomicStoreI32(&state.status, 1)
        return
    state.err = ErrorInfoOf[IselFuncTaskResult](taskRes)
    atomicStoreI32(&state.status, 2)

fn iselGlobalNameAtSafe(module: UirModule, idx: int32): str =
    let raw: str = uirModuleGlobalNameAt(module, idx)
    return raw

fn iselModuleGlobalSym(module: UirModule, name: str,
                       isInternalSym: fn (name: str): bool,
                       stripTargetSymPrefixOnce: fn (target: str, name: str): str,
                       symPrefix: fn (module: UirModule): str): str =
    if len(name) == 0:
        return ""
    if isInternalSym(name):
        return name
    let base: str = stripTargetSymPrefixOnce(uirModuleTargetOf(module), name)
    var parts: str[]
    add(parts, symPrefix(module))
    add(parts, base)
    let out: str = strutils.join(parts, "")
    memRetain(out)
    return out

fn iselExprCalleeSafe(expr: UirExpr): str =
    if iselExprInvalid(expr):
        return ""
    return uirExprCalleeOf(expr)

fn iselExprSummary(expr: UirExpr): str =
    if iselExprInvalid(expr):
        return "nil"
    let kind: int32 = int32(uirExprKindOf(expr))
    var parts: str[]
    add(parts, "kind=")
    add(parts, intToStr(kind))
    if uirExprKindOf(expr) == meCall:
        add(parts, " callee=")
        add(parts, iselExprCalleeSafe(expr))
        add(parts, " argc=")
        add(parts, intToStr(uirExprArgsLen(expr)))
    elif uirExprKindOf(expr) == meGlobalAddr:
        add(parts, " global=")
        add(parts, uirExprGlobalNameOf(expr))
    return strutils.join(parts, "")

fn iselReportEmptySymbol(kind: str, uirFunc: UirFunc, expr: UirExpr, rawName: str) =
    echo("[isel.err.empty_symbol]")
    echo(kind)
    echo(iselFuncBestName(uirFunc))
    echo(rawName)
    if iselExprInvalid(expr):
        echo("nil")
        return
    echo(intToStr(int32(uirExprKindOf(expr))))
    if uirExprKindOf(expr) == meCall:
        echo(iselExprCalleeSafe(expr))
        echo(intToStr(uirExprArgsLen(expr)))
    elif uirExprKindOf(expr) == meGlobalAddr:
        echo(uirExprGlobalNameOf(expr))

fn iselRequireNamedSymbol(kind: str, uirFunc: UirFunc, expr: UirExpr,
                          rawName: str, symName: str): Result[str] =
    if len(symName) > 0:
        return Ok[str](symName)
    iselReportEmptySymbol(kind, uirFunc, expr, rawName)
    let fnName: str = iselFuncBestName(uirFunc)
    let exprInfo: str = iselExprSummary(expr)
    return Err[str]("isel: empty " + kind + " symbol fn=" + fnName +
                    " raw=" + rawName + " expr=" + exprInfo)

fn iselAppendKnownGlobals(out: MachineModule, module: UirModule, dbgStage: bool,
                          globalNameAtSafe: fn (module: UirModule, idx: int32): str,
                          typeKindKnown: fn (ty: UirLowerType): bool,
                          typeSize: fn (ty: UirLowerType): int32,
                          typeAlignPow2: fn (ty: UirLowerType): int32) =
    if dbgStage:
        echo("[isel.stage] globals.begin")
    for gi in 0..<uirModuleGlobalsLen(module):
        let gTy: UirLowerType = uirModuleGlobalTypeAt(module, gi)
        if !typeKindKnown(gTy):
            continue
        let gName: str = globalNameAtSafe(module, gi)
        let size: int32 = typeSize(gTy)
        if size <= 0:
            continue
        let alignPow2: int32 = typeAlignPow2(gTy)
        machineAddGlobal(out, gName, size, alignPow2,
                         uirModuleGlobalInitAt(module, gi),
                         uirModuleGlobalHasInitAt(module, gi))
    if dbgStage:
        echo("[isel.stage] globals.end")

# selector-owned cstring lowering materializes MachineCString payloads before object writers.
fn iselAppendModuleCStrings(out: MachineModule, module: UirModule, dbgStage: bool,
                            dbgCstrPrefix: str): Result[int32] =
    let _selectorCstringsEnabled: bool = machineSelectorCStringLoweringEnabled()
    let dbgCstr: bool = strings.streq(os.getEnvDefault("BACKEND_DEBUG_CSTRING_LOWERING", ""), "1")
    if dbgCstr:
        echo(dbgCstrPrefix + " module_cstrs=" + intToStr(uirModuleCStringsLen(module)) +
             " lower=1")
    if dbgStage:
        echo("[isel.stage] cstrings.begin")
    for ci in 0..<uirModuleCStringsLen(module):
        let cstr: UirCString = uirModuleCStringAt(module, ci)
        let cLabel: str = uirCStringLabelOf(cstr)
        let cValue: str = uirCStringValueOf(cstr)
        if dbgCstr && ci < 8:
            let cLen: int32 = len(cValue)
            let c0: int32 = (cLen > 0) ? int32(cValue[0]) : -1
            let c1: int32 = (cLen > 1) ? int32(cValue[1]) : -1
            echo(dbgCstrPrefix + " i=" + intToStr(ci) + " label=" + cLabel +
                 " len=" + intToStr(cLen) + " b0=" + intToStr(c0) + " b1=" + intToStr(c1))
        if len(cLabel) <= 0:
            return Err[int32]("isel: empty cstring label idx=" + intToStr(ci) +
                              " value_len=" + intToStr(len(cValue)))
        machineAddCString(out, cLabel, cValue)
    if dbgStage:
        echo("[isel.stage] cstrings.end")
    return Ok[int32](0)

fn iselPrepareFuncTasks(module: UirModule, maxFuncs: int32, dbgIsel: bool, dbgStage: bool,
                        sched: str): IselFuncTask[] =
    let funcTasks: IselFuncTask[] = iselCollectFuncTasks(module, maxFuncs, dbgIsel)
    if dbgStage:
        echo("[isel.stage] tasks.collected")
        echo(intToStr(funcTasks.len))
    if sched == "ws":
        iselSortFuncTasksForWs(funcTasks)
    if dbgIsel:
        echo("[isel] task_count=" + intToStr(funcTasks.len) + " sched=" + sched)
    return funcTasks

fn iselLowerFuncTasksSerialCore(module: UirModule, tasks: IselFuncTask[], dbgIsel: bool,
                                dbgStage: bool, emitLowerOk: bool,
                                executeTask: fn (module: UirModule, task: IselFuncTask): Result[IselFuncTaskResult]
                                ): Result[IselFuncTaskResult[]] =
    var loweredTasks: IselFuncTaskResult[]
    reserve(loweredTasks, tasks.len)
    for ti in 0..<tasks.len:
        let task: IselFuncTask = tasks[ti]
        if dbgStage:
            echo("[isel.stage] task.begin")
            echo(intToStr(ti))
            echo(task != nil ? intToStr(task.funcIndex) : "-1")
        if dbgIsel && task != nil:
            echo("[isel] task[" + intToStr(ti) + "] run fn[" + intToStr(task.funcIndex) +
                 "] cost=" + intToStr(task.costHint))
        let taskRes: Result[IselFuncTaskResult] = executeTask(module, task)
        if !IsOk[IselFuncTaskResult](taskRes):
            let err: ErrorInfo = ErrorInfoOf[IselFuncTaskResult](taskRes)
            let msg: str = ErrorMessage(err)
            if dbgStage:
                echo("[isel.stage] task.err")
                echo(intToStr(ti))
                echo(task != nil ? intToStr(task.funcIndex) : "-1")
                echo(intToStr(ErrorCodeOf(err)))
                echo(intToStr(len(msg)))
                if len(msg) > 0:
                    echo(msg)
            if len(msg) == 0:
                let tiMsg: str = intToStr(ti)
                if task != nil:
                    return Err[IselFuncTaskResult[]]("isel: func task failed index=" + intToStr(task.funcIndex))
                return Err[IselFuncTaskResult[]]("isel: func task failed index=" + tiMsg)
            return ErrInfo[IselFuncTaskResult[]](err)
        let loweredTask: IselFuncTaskResult = taskRes.value
        if loweredTask == nil || loweredTask.loweredFunc == nil:
            if dbgStage:
                echo("[isel.stage] task.skip")
                echo(intToStr(ti))
            continue
        if dbgIsel && emitLowerOk:
            echo("[isel] fn[" + intToStr(loweredTask.funcIndex) + "] lower.ok")
            echo("[isel] fn[" + intToStr(loweredTask.funcIndex) + "] lower.value.ok name=" +
                 machineFuncNameOf(loweredTask.loweredFunc) +
                 " insts=" + intToStr(machineFuncInstsLen(loweredTask.loweredFunc)))
        add(loweredTasks, loweredTask)
    var out: Result[IselFuncTaskResult[]]
    out.ok = true
    out.value = loweredTasks
    ErrorOkInto(out.err)
    return out

fn iselLowerFuncTasksParallelCore(slots: var IselParallelTaskState[], module: UirModule,
                                  tasks: IselFuncTask[], dbgIsel: bool, emitLowerOk: bool,
                                  executeTask: fn (module: UirModule, task: IselFuncTask): Result[IselFuncTaskResult],
                                  spawnWorker: fn (slot: int32): bool,
                                  lowerSerial: fn (module: UirModule, tasks: IselFuncTask[],
                                                   dbgIsel: bool, dbgStage: bool): Result[IselFuncTaskResult[]]
                                  ): Result[IselFuncTaskResult[]] =
    let workerLimit: int32 = machineThreadWorkerLimit(tasks.len)
    if workerLimit <= 1:
        return lowerSerial(module, tasks, dbgIsel, false)
    var loweredTasks: IselFuncTaskResult[]
    reserve(loweredTasks, tasks.len)
    setLen(slots, tasks.len)
    for i in 0..<tasks.len:
        slots[i] = nil
    var activeSlots: int32[]
    reserve(activeSlots, workerLimit)
    var nextTask: int32 = 0
    while nextTask < tasks.len || activeSlots.len > 0:
        while nextTask < tasks.len && activeSlots.len < workerLimit:
            let task: IselFuncTask = tasks[nextTask]
            let slotToSpawn: int32 = nextTask
            if dbgIsel && task != nil:
                echo("[isel] task[" + intToStr(slotToSpawn) + "] spawn fn[" + intToStr(task.funcIndex) +
                     "] cost=" + intToStr(task.costHint))
            var state: IselParallelTaskState
            new state
            state.module = module
            state.task = task
            state.status = 0
            slots[slotToSpawn] = state
            add(activeSlots, slotToSpawn)
            if !spawnWorker(slotToSpawn):
                iselRunParallelTaskWorkerBody(slots, slotToSpawn, executeTask)
            nextTask = slotToSpawn + 1
        var completedAt: int32 = -1
        for ai in 0..<activeSlots.len:
            let slot: int32 = activeSlots[ai]
            if iselParallelStateDone(slots[slot]):
                completedAt = ai
                break
        if completedAt < 0:
            if machineSchedRunOnce() == 0:
                machineThreadYield()
            continue
        let slot: int32 = activeSlots[completedAt]
        let state: IselParallelTaskState = slots[slot]
        iselRemoveParallelSlotAt(activeSlots, completedAt)
        let taskRes: Result[IselFuncTaskResult] = iselAwaitParallelTaskState(state)
        slots[slot] = nil
        if !IsOk[IselFuncTaskResult](taskRes):
            let err: ErrorInfo = ErrorInfoOf[IselFuncTaskResult](taskRes)
            let msg: str = ErrorMessage(err)
            let task: IselFuncTask = state != nil ? state.task : nil
            if len(msg) == 0:
                let tiMsg: str = intToStr(slot)
                if task != nil:
                    return Err[IselFuncTaskResult[]]("isel: func task failed index=" + intToStr(task.funcIndex))
                return Err[IselFuncTaskResult[]]("isel: func task failed index=" + tiMsg)
            return ErrInfo[IselFuncTaskResult[]](err)
        let loweredTask: IselFuncTaskResult = taskRes.value
        if loweredTask == nil || loweredTask.loweredFunc == nil:
            continue
        if dbgIsel && emitLowerOk:
            echo("[isel] fn[" + intToStr(loweredTask.funcIndex) + "] lower.ok")
            echo("[isel] fn[" + intToStr(loweredTask.funcIndex) + "] lower.value.ok name=" +
                 machineFuncNameOf(loweredTask.loweredFunc) +
                 " insts=" + intToStr(machineFuncInstsLen(loweredTask.loweredFunc)))
        add(loweredTasks, loweredTask)
    var out: Result[IselFuncTaskResult[]]
    out.ok = true
    out.value = loweredTasks
    ErrorOkInto(out.err)
    return out

fn iselLowerFuncTasksScheduled(module: UirModule, tasks: IselFuncTask[], sched: str,
                               dbgIsel: bool, dbgStage: bool,
                               lowerParallel: fn (module: UirModule, tasks: IselFuncTask[],
                                                  dbgIsel: bool): Result[IselFuncTaskResult[]],
                               lowerSerial: fn (module: UirModule, tasks: IselFuncTask[],
                                                dbgIsel: bool, dbgStage: bool): Result[IselFuncTaskResult[]]
                               ): Result[IselFuncTaskResult[]] =
    if dbgStage:
        echo("[isel.stage] tasks.lower.begin")
    var out: Result[IselFuncTaskResult[]]
    if sched == "ws":
        out = lowerParallel(module, tasks, dbgIsel)
    else:
        out = lowerSerial(module, tasks, dbgIsel, dbgStage)
    if dbgStage:
        echo("[isel.stage] tasks.lower.end")
    return out

fn iselAppendLoweredTaskResults(out: MachineModule, loweredTasksRes: Result[IselFuncTaskResult[]],
                                dbgIsel: bool, dbgStage: bool,
                                addFunc: fn (module: MachineModule, func: MachineFunc)
                                ): Result[int32] =
    if !IsOk[IselFuncTaskResult[]](loweredTasksRes):
        let err: ErrorInfo = ErrorInfoOf[IselFuncTaskResult[]](loweredTasksRes)
        let msg: str = ErrorMessage(err)
        if len(msg) == 0:
            return Err[int32]("isel: func task failed")
        return ErrInfo[int32](err)
    let loweredTasks: IselFuncTaskResult[] = loweredTasksRes.value
    iselSortTaskResultsByFuncIndex(loweredTasks)
    for ri in 0..<loweredTasks.len:
        let loweredTask: IselFuncTaskResult = loweredTasks[ri]
        if loweredTask == nil || loweredTask.loweredFunc == nil:
            continue
        addFunc(out, loweredTask.loweredFunc)
        if dbgStage:
            echo("[isel.stage] task.added")
            echo(intToStr(loweredTask.funcIndex))
        if dbgIsel:
            echo("[isel] fn[" + intToStr(loweredTask.funcIndex) + "] add.ok len=" +
                 intToStr(machineModuleFuncsLen(out)))
    if dbgIsel:
        echo("[isel] module.done funcs.len=" + intToStr(machineModuleFuncsLen(out)))
    return Ok[int32](0)

fn iselLowerModuleTaskPipeline(out: MachineModule, module: UirModule,
                               maxFuncs: int32, dbgIsel: bool, dbgStage: bool,
                               cstrLabel: str,
                               addFunc: fn (module: MachineModule, func: MachineFunc)
                               ): Result[MachineModule] =
    let sched: str = uirFnSchedNormalized()
    if dbgIsel:
        echo("[isel] target=" + uirModuleTargetOf(module) + " funcs=" + intToStr(uirModuleFuncsLen(module)))
    iselAppendKnownGlobals(out, module, dbgStage,
                           iselGlobalNameAtSafe, iselTypeKindKnown, iselTypeSize, iselTypeAlignPow2)
    let cstrRes: Result[int32] = iselAppendModuleCStrings(out, module, dbgStage, cstrLabel)
    if !IsOk[int32](cstrRes):
        return ErrInfo_MachineModule(ErrorInfoOf[int32](cstrRes))
    let funcTasks: IselFuncTask[] = iselPrepareFuncTasks(module, maxFuncs, dbgIsel, dbgStage, sched)
    let loweredTasksRes: Result[IselFuncTaskResult[]] =
        iselLowerFuncTasksScheduled(module, funcTasks, sched, dbgIsel, dbgStage,
                                    iselLowerFuncTasksParallel, iselLowerFuncTasksSerial)
    let addRes: Result[int32] = iselAppendLoweredTaskResults(out, loweredTasksRes, dbgIsel, dbgStage,
                                                             addFunc)
    if !IsOk[int32](addRes):
        return ErrInfo_MachineModule(ErrorInfoOf[int32](addRes))
    memRetain(out)
    return Ok_MachineModule(out)

fn iselOkFuncTaskResult(value: IselFuncTaskResult): Result[IselFuncTaskResult] =
    var out: Result[IselFuncTaskResult]
    out.ok = true
    out.value = value
    ErrorOkInto(out.err)
    return out

fn iselErrInfoFuncTaskResult(err: ErrorInfo): Result[IselFuncTaskResult] =
    var out: Result[IselFuncTaskResult]
    out.ok = false
    let msg: str = ErrorMessage(err)
    if len(msg) > 0:
        out.err = err
    else:
        ErrorNewInto(out.err, "isel: empty func task error")
    return out

fn iselFuncTaskCostHint(func: UirFunc): int32 =
    if func == nil:
        return 1
    let blockCost: int32 = uirFuncBlocksLenObjFirst(func) * 32
    let localCost: int32 = uirFuncLocalTypesLen(func) * 4
    let objCost: int32 = uirFuncObjFrameSizeOf(func)
    let total: int32 = blockCost + localCost + objCost
    return total > 0 ? total : 1

fn iselSortFuncTasksForWs(tasks: IselFuncTask[]) =
    if tasks.len <= 1:
        return
    for i in 1..<tasks.len:
        let key: IselFuncTask = tasks[i]
        var j: int32 = i - 1
        while j >= 0:
            let cur: IselFuncTask = tasks[j]
            if cur == nil:
                tasks[j + 1] = cur
                j = j - 1
                continue
            if key == nil:
                break
            if cur.costHint > key.costHint:
                break
            if cur.costHint == key.costHint && cur.funcIndex < key.funcIndex:
                break
            tasks[j + 1] = cur
            j = j - 1
        tasks[j + 1] = key

fn iselSortTaskResultsByFuncIndex(results: IselFuncTaskResult[]) =
    if results.len <= 1:
        return
    for i in 1..<results.len:
        let key: IselFuncTaskResult = results[i]
        var j: int32 = i - 1
        while j >= 0:
            let cur: IselFuncTaskResult = results[j]
            if cur == nil:
                results[j + 1] = cur
                j = j - 1
                continue
            if key == nil:
                break
            if cur.funcIndex <= key.funcIndex:
                break
            results[j + 1] = cur
            j = j - 1
        results[j + 1] = key

fn iselParallelStateDone(state: IselParallelTaskState): bool =
    if state == nil:
        return true
    return atomicLoadI32(&state.status) != 0

fn iselAwaitParallelTaskState(state: IselParallelTaskState): Result[IselFuncTaskResult] =
    if state == nil:
        return iselOkFuncTaskResult(nil)
    while atomicLoadI32(&state.status) == 0:
        if machineSchedRunOnce() == 0:
            machineThreadYield()
    if atomicLoadI32(&state.status) == 1:
        return iselOkFuncTaskResult(state.result)
    return iselErrInfoFuncTaskResult(state.err)

fn iselRemoveParallelSlotAt(slots: var int32[], at: int32) =
    if at < 0 || at >= slots.len:
        return
    var i: int32 = at
    while i + 1 < slots.len:
        slots[i] = slots[i + 1]
        i = i + 1
    setLen(slots, slots.len - 1)
