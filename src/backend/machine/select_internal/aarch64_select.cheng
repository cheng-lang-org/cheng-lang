fn uirModuleCountProofBackedFuncs(module: UirModule): int32 =
    if module == nil:
        return 0
    var out: int32 = 0
    for fi in 0..<uirModuleFuncsLen(module):
        let func: UirFunc = uirModuleFuncAt(module, fi)
        if (func != nil) && uirFuncProofBackedForOpt2(func):
            out = out + 1
    return out

