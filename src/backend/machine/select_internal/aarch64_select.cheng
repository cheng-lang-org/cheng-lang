fn uirModuleHealExternFlags(module: UirModule) =
    if module == nil:
        return
    for fi in 0..<uirModuleFuncsLen(module):
        let f: UirFunc = uirModuleFuncAt(module, fi)
        if f == nil:
            continue
        uirCoreFuncIsExtern(f)

