# UIR SLP vectorization: deterministic tree packing/canonicalization for
# straight-line arithmetic expressions.
import backend/uir/uir_types
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_vec_cost
import std/seqs
import std/strutils
import std/os

fn add(dst: var UirExpr[], val: UirExpr) =
    seqs.add(dst, val)

fn uirSlpWriteBlock(seqInst: UirBlockId[]*, idx: int32, val: UirBlockId) =
    if seqInst == nil || idx < 0 || idx >= seqInst->len:
        return
    uirCoreWriteBlock(seqInst, idx, val)

fn uirSlpPolicyNormalize(policy: str): str =
    let raw: str = strutils.toLowerAscii(strutils.strip(policy))
    if raw == "":
        return "autovec"
    return raw

fn uirSlpAssocBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirSlpCommutativeBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirSlpExprKeyInner(expr: UirExpr, depth: int32*): str =
    if expr <= 0:
        return "nil"
    if depth == nil:
        return "depth_nil"
    if *depth >= 128:
        return "depth_limit"
    *depth = *depth + 1
    let k: UirExprKind = uirExprKindOf(expr)
    var key: str = "k" + intToStr(int32(k))
    if k == meConstI64:
        key = key + ":v" + intToStr(int32(uirExprConstValueOf(expr) & 2147483647))
    elif k == meLocal || k == meAddr:
        key = key + ":l" + intToStr(uirExprLocalIndexOf(expr))
    elif k == meGlobalAddr:
        key = key + ":g" + uirExprGlobalNameOf(expr)
    elif k == meBin:
        key = key + ":b" + intToStr(int32(uirExprBinOpOf(expr))) + "(" +
              uirSlpExprKeyInner(uirExprLhsOf(expr), depth) + "," +
              uirSlpExprKeyInner(uirExprRhsOf(expr), depth) + ")"
    elif k == meCmp:
        key = key + ":c" + intToStr(int32(uirExprCmpOpOf(expr))) + "(" +
              uirSlpExprKeyInner(uirExprLhsOf(expr), depth) + "," +
              uirSlpExprKeyInner(uirExprRhsOf(expr), depth) + ")"
    elif k == meCast:
        key = key + ":cast(" + uirSlpExprKeyInner(uirExprCastExprOf(expr), depth) + ")"
    elif k == meLoad:
        key = key + ":load(" + uirSlpExprKeyInner(uirExprAddrExprOf(expr), depth) + ")"
    elif k == meCall:
        key = key + ":call(" + uirExprCalleeOf(expr) + ")"
    *depth = *depth - 1
    return key

fn uirSlpExprKey(expr: UirExpr): str =
    var depth: int32 = 0
    return uirSlpExprKeyInner(expr, &depth)

fn uirSlpExprPureLeaf(expr: UirExpr): bool =
    if expr <= 0:
        return false
    let kind: UirExprKind = uirExprKindOf(expr)
    if kind == meConstI64 || kind == meLocal || kind == meAddr || kind == meGlobalAddr:
        return true
    return false

fn uirSlpCollectAssoc(expr: UirExpr, op: UirBinOp, out: UirExpr[]): bool =
    if expr <= 0:
        return false
    if uirExprKindOf(expr) == meBin && uirExprBinOpOf(expr) == op:
        if !uirSlpCollectAssoc(uirExprLhsOf(expr), op, out):
            return false
        if !uirSlpCollectAssoc(uirExprRhsOf(expr), op, out):
            return false
        return true
    if !uirSlpExprPureLeaf(expr):
        return false
    add(out, expr)
    return true

fn uirSlpSortTermsByKey(terms: UirExpr[]) =
    if terms.len <= 1:
        return
    for i in 1..<terms.len:
        let v: UirExpr = terms[i]
        let vKey: str = uirSlpExprKey(v)
        var j: int32 = i - 1
        while j >= 0:
            let k: str = uirSlpExprKey(terms[j])
            if uirStrCmp(k, vKey) <= 0:
                break
            terms[j + 1] = terms[j]
            j = j - 1
        terms[j + 1] = v

fn uirSlpBuildBalanced(op: UirBinOp, terms: UirExpr[], lo: int32, hi: int32): UirExpr =
    if hi <= lo:
        return nil
    if hi - lo == 1:
        return terms[lo]
    let mid: int32 = lo + ((hi - lo) / 2)
    let lhs: UirExpr = uirSlpBuildBalanced(op, terms, lo, mid)
    let rhs: UirExpr = uirSlpBuildBalanced(op, terms, mid, hi)
    return uirCoreBin(op, lhs, rhs)

fn uirSlpRewriteExpr(expr: UirExpr,
                     width: int32,
                     packedExprs: int32*,
                     clusters: int32*): UirExpr =
    if expr <= 0:
        return nil
    let k: UirExprKind = uirExprKindOf(expr)
    var cur: UirExprId = expr
    if k == meBin || k == meCmp:
        uirCoreExprSetLhs(cur, uirSlpRewriteExpr(uirCoreExprLhsOf(cur), width, packedExprs, clusters))
        uirCoreExprSetRhs(cur, uirSlpRewriteExpr(uirCoreExprRhsOf(cur), width, packedExprs, clusters))
    elif k == meCall:
        for ai in 0..<uirCoreExprArgsLen(cur):
            uirCoreExprSetArgAt(cur, ai, uirSlpRewriteExpr(uirCoreExprArgAt(cur, ai), width, packedExprs, clusters))
    elif k == meCast:
        uirCoreExprSetCastExpr(cur, uirSlpRewriteExpr(uirCoreExprCastExprOf(cur), width, packedExprs, clusters))
    elif k == meLoad:
        uirCoreExprSetAddrExpr(cur, uirSlpRewriteExpr(uirCoreExprAddrExprOf(cur), width, packedExprs, clusters))

    if k == meCmp:
        let op: UirCmpOp = uirExprCmpOpOf(cur)
        if op == mcEq || op == mcNe:
            let lhsKey: str = uirSlpExprKey(uirCoreExprLhsOf(cur))
            let rhsKey: str = uirSlpExprKey(uirCoreExprRhsOf(cur))
            if uirStrCmp(rhsKey, lhsKey) < 0:
                let tmp: UirExpr = uirCoreExprLhsOf(cur)
                uirCoreExprSetLhs(cur, uirCoreExprRhsOf(cur))
                uirCoreExprSetRhs(cur, tmp)
                if packedExprs != nil:
                    *packedExprs = *packedExprs + 1
                if clusters != nil:
                    *clusters = *clusters + 1
        return cur

    if k != meBin:
        return cur
    let op: UirBinOp = uirExprBinOpOf(cur)
    if !uirSlpAssocBin(op):
        return cur
    var terms: UirExpr[]
    if !uirSlpCollectAssoc(cur, op, terms):
        if uirSlpCommutativeBin(op):
            let lhsKey: str = uirSlpExprKey(uirCoreExprLhsOf(cur))
            let rhsKey: str = uirSlpExprKey(uirCoreExprRhsOf(cur))
            if uirStrCmp(rhsKey, lhsKey) < 0:
                let tmp: UirExpr = uirCoreExprLhsOf(cur)
                uirCoreExprSetLhs(cur, uirCoreExprRhsOf(cur))
                uirCoreExprSetRhs(cur, tmp)
                if packedExprs != nil:
                    *packedExprs = *packedExprs + 1
            return cur
        return cur
    if terms.len < 2:
        return cur
    if uirSlpCommutativeBin(op):
        uirSlpSortTermsByKey(terms)
    let beforeKey: str = uirSlpExprKey(cur)
    let cand: UirExpr = uirSlpBuildBalanced(op, terms, 0, terms.len)
    let afterKey: str = uirSlpExprKey(cand)
    if uirStrCmp(beforeKey, afterKey) == 0:
        return cur
    if terms.len >= width && clusters != nil:
        *clusters = *clusters + 1
    if packedExprs != nil:
        *packedExprs = *packedExprs + 1
    return cand

fn uirSlpLooksPackable(expr: UirExpr): bool =
    if expr <= 0 || uirExprKindOf(expr) != meBin:
        return false
    let op: UirBinOp = uirExprBinOpOf(expr)
    if !uirSlpAssocBin(op):
        return false
    let lhs: UirExpr = uirExprLhsOf(expr)
    let rhs: UirExpr = uirExprRhsOf(expr)
    return uirSlpExprPureLeaf(lhs) && uirSlpExprPureLeaf(rhs)

fn uirVectorizeSlp(module: UirModule, maxWidth: int32, policy: str): bool =
    if module == nil:
        return false
    if maxWidth <= 0:
        return false
    let policyNorm: str = uirSlpPolicyNormalize(policy)
    if policyNorm == "none" || policyNorm == "loop":
        return false
    let d: UirVecCostDecision = uirDecideVecWidth(module, maxWidth)
    if !d.enable || d.width <= 1:
        return false

    var changed: bool = false
    var vectorizedBlocks: int32 = 0
    var packedExprs: int32 = 0
    var clusters: int32 = 0
    for fi in 0..<uirModuleFuncsLen(module):
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if funcView == nil || uirFuncIsExtern(funcView):
            continue
        let func: UirCoreFunc = funcView
        let blockCount: int32 = uirCoreFuncBlocksLen(func)
        for bi in 0..<blockCount:
            let blkView: UirLowerBlock = uirCoreFuncBlockAt(func, bi)
            if blkView <= 0:
                continue
            var blk: UirBlockId = blkView
            let beforePacked: int32 = packedExprs
            var prevPackable: bool = false
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            for si in 0..<stmtCount:
                var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                let thisPackable: bool = uirSlpLooksPackable(uirCoreStmtExprOf(st))
                st = uirCoreStmtWithExpr(st, uirSlpRewriteExpr(uirCoreStmtExprOf(st), d.width, &packedExprs, &clusters))
                if uirCoreStmtKindOf(st) == msStore:
                    st = uirCoreStmtWithAddrExpr(st, uirSlpRewriteExpr(uirCoreStmtAddrExprOf(st), d.width, &packedExprs, &clusters))
                uirCoreBlockSetStmtAt(blk, si, st)
                if thisPackable && prevPackable:
                    clusters = clusters + 1
                prevPackable = thisPackable
            let term: UirCoreTerm = uirCoreBlockTermOf(blk)
            if uirCoreTermKindOf(term) == mtRet:
                uirCoreBlockSetTerm(blk, uirCoreTermWithRetExpr(
                    term, uirSlpRewriteExpr(uirCoreTermRetExprOf(term), d.width, &packedExprs, &clusters)))
            elif uirCoreTermKindOf(term) == mtCbr:
                uirCoreBlockSetTerm(blk, uirCoreTermWithCondExpr(
                    term, uirSlpRewriteExpr(uirCoreTermCondExprOf(term), d.width, &packedExprs, &clusters)))
            if packedExprs > beforePacked:
                vectorizedBlocks = vectorizedBlocks + 1
                changed = true
            uirCoreFuncSetBlockAt(func, bi, blk)

    if os.getEnvDefault("UIR_SIMD_REPORT", "0") == "1":
        let f: os.File = os.get_stderr()
        os.write(f, "simd_slp_report\tpolicy=")
        os.write(f, policyNorm)
        os.write(f, "\twidth=")
        os.write(f, intToStr(d.width))
        os.write(f, "\tloops=")
        os.write(f, intToStr(d.loopCount))
        os.write(f, "\tarith=")
        os.write(f, intToStr(d.arithmeticExprCount))
        os.write(f, "\tvec_blocks=")
        os.write(f, intToStr(vectorizedBlocks))
        os.write(f, "\tpacked_exprs=")
        os.write(f, intToStr(packedExprs))
        os.write(f, "\tclusters=")
        os.write(f, intToStr(clusters))
        os.write(f, "\tscore=")
        os.writeLine(f, intToStr(d.score))
        os.c_fflush f
    return changed
