fn uirCoreFuncInitHeaderMeta(func: UirCoreFunc,
                             retTypeKey: str,
                             originFile: str,
                             declOrdinal: int32,
                             sourceAstIndex: int32,
                             isExtern: bool) =
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return
    var funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn == nil:
        return
    let dbgBoot: bool = uirOptEnvIsTrue("BACKEND_DEBUG_BOOT")
    let dbgNameObj0: str = funcVal.name
    let dbgNameDyn0: str = dyn.name
    let dbgName0: str = uirCoreChooseNonEmpty(dbgNameObj0, dbgNameDyn0)
    let dbgTrack: bool = dbgBoot &&
                         (dbgNameObj0 == "main" || dbgNameObj0 == "backendMain" ||
                          dbgNameDyn0 == "main" || dbgNameDyn0 == "backendMain" ||
                          strContains(originFile, "backend_driver.cheng") ||
                          strContains(funcVal.originFile, "backend_driver.cheng") ||
                          strContains(dyn.originFile, "backend_driver.cheng"))
    if dbgTrack:
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_init_header.before name=" +
                     dbgName0 +
                     " func_dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " obj_dyn_id=" + intToStr(funcVal.dynId) +
                     " obj_extern=" + (funcVal.isExtern ? "1" : "0") +
                     " dyn_extern=" + (dyn.isExtern ? "1" : "0") +
                     " set_extern=" + (isExtern ? "1" : "0") +
                     " obj_decl=" + intToStr(funcVal.declOrdinal) +
                     " obj_ast=" + intToStr(funcVal.sourceAstIndex))
        uirOptFFlush(uirOptGetStderr())
    let ownedRetTypeKey: str = uirCoreOwnStrSafe(retTypeKey)
    let ownedOriginFile: str = uirCoreOwnStrSafe(originFile)
    dyn.retTypeKey = ownedRetTypeKey
    dyn.originFile = ownedOriginFile
    dyn.declOrdinal = declOrdinal
    dyn.sourceAstIndex = sourceAstIndex
    dyn.isExtern = isExtern
    funcVal.originFile = ownedOriginFile
    funcVal.declOrdinal = declOrdinal
    funcVal.sourceAstIndex = sourceAstIndex
    funcVal.isExtern = isExtern
    uirCoreFuncObjStorePtr(funcObj, funcVal)
    uirCoreFuncSyncObjIdentityFromDyn(func)
    if dbgTrack:
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_init_header.after name=" +
                     uirCoreChooseNonEmpty(funcVal.name, dyn.name) +
                     " func_dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " obj_dyn_id=" + intToStr(funcVal.dynId) +
                     " obj_extern=" + (funcVal.isExtern ? "1" : "0") +
                     " dyn_extern=" + (dyn.isExtern ? "1" : "0") +
                     " obj_decl=" + intToStr(funcVal.declOrdinal) +
                     " dyn_decl=" + intToStr(dyn.declOrdinal) +
                     " obj_ast=" + intToStr(funcVal.sourceAstIndex) +
                     " dyn_ast=" + intToStr(dyn.sourceAstIndex))
        uirOptFFlush(uirOptGetStderr())

fn uirCoreFuncSetExtern(func: UirCoreFunc, isExtern: bool) =
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return
    let dbgBoot: bool = uirOptEnvIsTrue("BACKEND_DEBUG_BOOT")
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    var funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    let dbgName: str = funcVal.name
    var dbgNameDyn: str
    uirCoreSetEmpty(dbgNameDyn)
    if dyn != nil:
        uirCoreCopyStr(dbgNameDyn, dyn.name)
    let dbgDisplayName: str = uirCoreChooseNonEmpty(dbgName, dbgNameDyn)
    if dbgBoot && (dbgName == "main" || dbgName == "backendMain" ||
                   dbgNameDyn == "main" || dbgNameDyn == "backendMain"):
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_set_extern name=" +
                     dbgDisplayName +
                     " val=" + (isExtern ? "1" : "0") +
                     " dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " ptr=" + int64ToStr(uirCoreFuncPtrKey(func)))
        uirOptFFlush(uirOptGetStderr())
    if dyn != nil:
        dyn.isExtern = isExtern
    funcVal.isExtern = isExtern
    uirCoreFuncObjStorePtr(funcObj, funcVal)
    uirCoreFuncSyncObjIdentityFromDyn(func)

fn uirCoreFuncSetExported(func: UirCoreFunc, isExported: bool) =
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn != nil:
        dyn.isExported = isExported
    var funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    funcVal.isExported = isExported
    uirCoreFuncObjStorePtr(funcObj, funcVal)
    uirCoreFuncSyncObjIdentityFromDyn(func)

fn uirCoreFuncSetRetTypeKey(func: UirCoreFunc, retTypeKey: str) =
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return
    let ownedRetTypeKey: str = uirCoreOwnStrSafe(retTypeKey)
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn != nil:
        dyn.retTypeKey = ownedRetTypeKey
    # Keep retTypeKey live on dyn. Writing the object slot has repeatedly
    # poisoned adjacent metadata under old-stage0/fresh selfhost builds.
    uirCoreFuncSyncObjIdentityFromDyn(func)

fn uirCoreFuncSetPhaseContract(func: UirCoreFunc, phaseTag: int32,
                               highUirChecked: bool, lowUirLowered: bool,
                               fallbackReason: str) =
    if (!uirCoreFuncIdValid(func)):
        return
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    let dbgBoot: bool = uirOptEnvIsTrue("BACKEND_DEBUG_BOOT")
    var funcVal: UirCoreFuncObj
    if funcObj != nil:
        funcVal = uirCoreFuncObjLoadPtr(funcObj)
    var dbgNameObj0: str
    uirCoreSetEmpty(dbgNameObj0)
    if funcObj != nil:
        uirCoreCopyStr(dbgNameObj0, funcVal.name)
    var dbgNameDyn0: str
    uirCoreSetEmpty(dbgNameDyn0)
    if dyn != nil:
        uirCoreCopyStr(dbgNameDyn0, dyn.name)
    let dbgName0: str = uirCoreChooseNonEmpty(dbgNameObj0, dbgNameDyn0)
    let dbgTrack: bool = dbgBoot &&
                         (dbgNameObj0 == "main" || dbgNameObj0 == "backendMain" ||
                          dbgNameDyn0 == "main" || dbgNameDyn0 == "backendMain")
    if dbgTrack:
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_phase_contract.before name=" +
                     dbgName0 +
                     " obj_extern=" + ((funcObj != nil && funcVal.isExtern) ? "1" : "0") +
                     " dyn_extern=" + ((dyn != nil && dyn.isExtern) ? "1" : "0") +
                     " phase=" + intToStr(phaseTag) +
                     " high=" + (highUirChecked ? "1" : "0") +
                     " low=" + (lowUirLowered ? "1" : "0"))
        uirOptFFlush(uirOptGetStderr())
    if dyn == nil:
        return
    dyn.phaseTag = phaseTag
    dyn.highUirChecked = highUirChecked
    dyn.lowUirLowered = lowUirLowered
    dyn.phaseFallbackReason = uirCoreOwnStrSafe(fallbackReason)
    # Keep phase-contract metadata live on dyn only. Writing the object slots
    # here has been enough to poison adjacent metadata before returning from
    # UIR module build on old-stage0/selfhost paths.
    if dbgTrack:
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_phase_contract.after name=" +
                     dbgName0 +
                     " obj_extern=" + ((funcObj != nil && funcVal.isExtern) ? "1" : "0") +
                     " dyn_extern=" + (dyn.isExtern ? "1" : "0"))
        uirOptFFlush(uirOptGetStderr())

fn uirCoreFuncAddParam(func: UirCoreFunc, param: UirCoreParam) =
    var p: UirCoreParam = param
    p.name = uirCoreOwnStrSafe(p.name)
    p.typeKey = uirCoreOwnStrSafe(p.typeKey)
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn == nil:
        return
    var params0: UirCoreParam[] = dyn.params
    uirCoreAppendParam(params0, p)
    dyn.params = params0
    uirCoreFuncSyncObjPayloadFromDyn(func, dyn)

fn uirCoreModuleFuncsLen(module: UirCoreModule): int32 =
    if module == nil:
        return 0
    let funcs: UirCoreFunc[] = module.funcs
    if !uirCoreFuncRefSeqSane(funcs):
        return 0
    let out: int32 = funcs.len
    if out < 0:
        return 0
    return out

fn uirCoreModuleTargetOf(module: UirCoreModule): str =
    if module == nil:
        return ""
    return module.target

fn uirCoreModuleFuncAt(module: UirCoreModule, idx: int32): UirCoreFunc =
    if module == nil || idx < 0:
        return nil
    let funcs: UirCoreFunc[] = module.funcs
    if !uirCoreFuncRefSeqSane(funcs):
        return nil
    if idx >= funcs.len:
        return nil
    let out: UirCoreFunc = funcs[idx]
    if !uirCoreFuncIdValid(out):
        return nil
    return out

fn uirCoreParamTypeOf(param: UirCoreParam): UirCoreType =
    return param.ty

fn uirCoreParamSlotOf(param: UirCoreParam): int32 =
    return param.slot

fn uirCoreParamTypeKeyOf(param: UirCoreParam): str =
