    soa.exprB = exprB0
    soa.exprC = exprC0
    soa.exprImm = exprImm0
    soa.exprStrId = exprStrId0
    return soa.exprKind.len - 1

fn uirCoreSoaAppendStmt(soa: UirCoreSoa, kind: UirCoreStmtKind, dst: int32,
