    return term.kind

fn uirCoreTermRetExprOf(term: UirCoreTerm): UirExprId =
    return term.retExpr

fn uirCoreTermCondExprOf(term: UirCoreTerm): UirExprId =
    return term.condExpr

fn uirCoreTermTargetOf(term: UirCoreTerm): str =
    return term.target

fn uirCoreTermTargetTrueOf(term: UirCoreTerm): str =
    return term.targetTrue

fn uirCoreTermTargetFalseOf(term: UirCoreTerm): str =
    return term.targetFalse

fn uirCoreTermWithRetExpr(term: UirCoreTerm, retExpr: UirExprId): UirCoreTerm =
    var out: UirCoreTerm = term
    out.retExpr = retExpr
    return out

fn uirCoreTermWithCondExpr(term: UirCoreTerm, condExpr: UirExprId): UirCoreTerm =
    var out: UirCoreTerm = term
    out.condExpr = condExpr
    return out

fn uirCoreTermWithTarget(term: UirCoreTerm, target: str): UirCoreTerm =
    var out: UirCoreTerm = term
    out.target = target
    return out

fn uirCoreTermWithTargetTrue(term: UirCoreTerm, targetTrue: str): UirCoreTerm =
    var out: UirCoreTerm = term
    out.targetTrue = targetTrue
    return out

fn uirCoreTermWithTargetFalse(term: UirCoreTerm, targetFalse: str): UirCoreTerm =
    var out: UirCoreTerm = term
    out.targetFalse = targetFalse
    return out

fn uirCoreFuncBlocksLen(func: UirCoreFunc): int32 =
    if !uirCoreFuncIdValid(func):
        return 0
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    if dyn == nil:
        return 0
    let blocks: UirBlockId[] = dyn.blocks
    if uirCoreBlockSeqSane(blocks):
        return blocks.len
    return 0

fn uirCoreFuncBlocksLenObjFirst(func: UirCoreFunc): int32 =
    if !uirCoreFuncIdValid(func):
        return 0
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    var funcVal: UirCoreFuncObj
    if funcObj != nil:
        funcVal = uirCoreFuncObjLoadPtr(funcObj)
    var dynBlocks: UirBlockId[]
    if dyn != nil:
        dynBlocks = dyn.blocks
    else:
        dynBlocks = []
    var objBlocks: UirBlockId[]
    if funcObj != nil:
        objBlocks = funcVal.blocks
    else:
        objBlocks = []
    let dynSane: bool = uirCoreBlockSeqSane(dynBlocks)
    let objSane: bool = uirCoreBlockSeqSane(objBlocks)
    if dynSane && dynBlocks.len > 0:
        return dynBlocks.len
    if objSane && objBlocks.len > 0:
        if dyn != nil && (!dynSane || dynBlocks.len != objBlocks.len):
            dyn.blocks = uirCoreCloneBlockSeq(objBlocks)
        if dyn != nil && dyn.isExtern:
            dyn.isExtern = false
        if funcObj != nil && funcVal.isExtern:
            funcVal.isExtern = false
            uirCoreFuncObjStorePtr(funcObj, funcVal)
        return objBlocks.len
    if dynSane:
        return dynBlocks.len
    if objSane:
        return objBlocks.len
    if funcObj != nil && funcVal.blockBuffer != nil && funcVal.blockLen > 0:
        return funcVal.blockLen
    return 0

