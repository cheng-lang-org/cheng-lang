# Unified IR facade: carries native UIR entities while production lowering remains
# wired to UIR-internal implementation.

type
    UirGenericParam =
        name: str

type
    UirTraitConstraint =
        paramName: str
        traitName: str

type
    UirDictType = ref
        traitName: str
        methods: str[]

type
    UirInstanceKey =
        symbol: str
        typeArgs: str[]
        mode: str

type
    UirModule = UirCoreModule

type
    UirFunc = UirCoreFunc

type
    UirGlobal = UirCoreGlobal

type
    UirCString = UirCoreCString

type
    UirTypeAlias = UirCoreTypeAlias

type
    UirObjType = UirCoreObjType

type
    UirLowerType = UirCoreType

type
    UirLowerTypeKind = UirCoreTypeKind

type
    UirLowerBlock = UirBlockId

type
    UirExpr = UirExprId

type
    UirExprKind = UirCoreExprKind

type
    UirBinOp = UirCoreBinOp

type
    UirCmpOp = UirCoreCmpOp

type
    UirStmt = UirStmtId

type
    UirStmtKind = UirCoreStmtKind

type
    UirTerm = UirCoreTerm

type
    UirTermKind = UirCoreTermKind

type
    UirPhaseTag = int32

type
    UirParam = UirCoreParam

type
    UirObjLocal = UirCoreObjLocal

type
    UirObjField = UirCoreObjField

type
    UirSoaSurfaceStats =
        trackedFuncs: int32
        exprIds: int32
        stmtIds: int32
        blockIds: int32
        succEdges: int32
        predEdges: int32
        balanceOk: bool
        reason: str

fn uirTextLowerAscii(s: str): str =
    return strutils.toLowerAscii(s)

fn uirEnvParseBool(name: str, defaultValue: bool): bool =
    let raw: str = uirOptGetEnvDefault(name, "")
    if len(raw) == 0:
        return defaultValue
    let s: str = uirTextLowerAscii(strutils.strip(raw))
    if s == "1" || s == "true" || s == "yes" || s == "on":
        return true
    if s == "0" || s == "false" || s == "no" || s == "off":
        return false
    return defaultValue

fn uirEnvParseInt(name: str, defaultValue: int32, minValue: int32, maxValue: int32): int32 =
    let raw: str = strutils.strip(uirOptGetEnvDefault(name, ""))
    if len(raw) == 0:
        return defaultValue
    let n: int32 = len(raw)
    var neg: bool = false
    var i: int32 = 0
    if raw[0] == '-':
        neg = true
        i = 1
    if i >= n:
        return defaultValue
    var v: int64 = 0
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        let c: char = raw[i]
        if c < '0' || c > '9':
            return defaultValue
        v = v * 10 + int64(int32(c) - int32('0'))
        i = i + 1
    if neg:
        v = -v
    if v < int64(minValue):
        return minValue
    if v > int64(maxValue):
        return maxValue
    return int32(v)

fn uirEGraphGoalNormalize(goal: str): str =
    let target: str = uirTextLowerAscii(strutils.strip(goal))
    if target == "latency" || target == "size":
        return target
    return "balanced"

fn uirEGraphGoalParseEnv(name: str, defaultValue: str): str =
    let raw: str = uirOptGetEnvDefault(name, "")
    if len(raw) > 0:
        return uirEGraphGoalNormalize(raw)
    return uirEGraphGoalNormalize(defaultValue)

fn uirFnSchedNormalized(): str =
    var raw: str = strutils.strip(uirOptGetEnvDefault("BACKEND_FN_SCHED", ""))
    if len(raw) == 0:
        raw = strutils.strip(uirOptGetEnvDefault("STAGE1_FN_SCHED", ""))
    if uirTextLowerAscii(raw) == "ws":
        return "ws"
    return "serial"

fn uirExprRecursionLimit(): int32 =
    return 256

fn uirPhaseContractMarkerText(): str =
    return "single_ir_dual_phase " +
           "uir_phase_model=single_ir_dual_phase " +
           "p4_phase_v1 " +
           "phase_contract_version=p4_phase_v1 " +
           "ownership_func_v1 " +
           "generics_report " +
           "high_uir_checked_funcs= " +
           "low_uir_lowered_funcs= " +
           "high_uir_fallback_funcs= " +
           "uir_opt2.noalias " +
           "uir_opt2.egraph " +
           "uir_opt2.cost_model " +
           "uir_opt2.cost_model.weights"

fn uirSoaSurfaceStatsCollect(module: UirModule): UirSoaSurfaceStats =
    var out: UirSoaSurfaceStats
    out.balanceOk = true
    out.reason = "ok"
    if module == nil:
        out.balanceOk = false
        out.reason = "module=nil"
        return out
    let soaModule: UirCoreSoaModule = uirCoreSoaBuildFromModule(module)
    if soaModule == nil:
        out.balanceOk = false
        out.reason = "module=nil"
        return out
    out.trackedFuncs = uirCoreSoaModuleFuncCount(soaModule)
    out.exprIds = uirCoreSoaModuleExprCount(soaModule)
    out.stmtIds = uirCoreSoaModuleStmtCount(soaModule)
    out.blockIds = uirCoreSoaModuleBlockCount(soaModule)
    out.succEdges = uirCoreSoaModuleSuccEdgeCount(soaModule)
    out.predEdges = uirCoreSoaModulePredEdgeCount(soaModule)
    out.balanceOk = uirCoreSoaModuleEdgesBalanced(soaModule)
    out.reason = uirCoreSoaModuleEdgeBalanceReason(soaModule)
    return out

fn Ok_UirLowerType(value: UirLowerType): Result[UirLowerType] =
    var out: Result[UirLowerType]
    out.ok = true
    out.value = value
    ErrorOkInto(out.err)
    return out

fn Err_UirLowerType(err: str): Result[UirLowerType] =
    var out: Result[UirLowerType]
    out.ok = false
    ErrorNewInto(out.err, err)
    return out

