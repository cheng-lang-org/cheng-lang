    return changed

fn uirModInlinePass(module: UirModule, st: var UirProfileState, stage: str, inlineIters: int32): bool =
    if (module == nil):
        return false
    var maxIters: int32 = inlineIters
    if maxIters <= 0:
        maxIters = 1
    if maxIters > 16:
        maxIters = 16
    var changed: bool = false
    for i in 0..<maxIters:
        let changedI: bool = uirCoreInlineModuleOnce(module)
        uirProfilePass(st, stage + ".inline." + intToStr(i), changedI)
        if changedI:
            changed = true
        else:
            break
    return changed

fn uirModPruneFuncsPass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    let changed: bool = uirCorePruneUnreachableFuncs(module)
    uirProfilePass(st, stage + ".prune_unreachable_funcs", changed)
    return changed

fn uirFuncPruneBlocksPass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for i in 0..<uirModuleFuncsLen(module):
        let f: UirFunc = uirModuleFuncAt(module, i)
        if (f == nil) || uirFuncIsExtern(f):
            continue
        if uirCoreFuncPruneUnreachableBlocks(f):
            changed = true
    uirProfilePass(st, stage + ".prune_unreachable_blocks", changed)
    return changed

fn uirRunCoreModule2OncePass(module: UirModule, st: var UirProfileState, stage: str, inlineIters: int32): bool =
    if (module == nil):
        return false
    var changed: bool = false

    if uirModInlinePass(module, st, stage + ".inline", inlineIters):
        changed = true
    if uirModExprFoldPass(module, st, stage + ".opt"):
        changed = true
    if uirModConstPropPass(module, st, stage + ".opt"):
        changed = true
    if uirModForwardSubstPass(module, st, stage + ".opt"):
        changed = true
    if uirModNormExprPass(module, st, stage + ".opt"):
        changed = true
    if uirModConstPropPass(module, st, stage + ".opt"):
        changed = true
    if uirModCfgPass(module, st, stage + ".opt"):
        changed = true
    if uirModAlgebraicPass(module, st, stage + ".opt"):
        changed = true
    if uirModNoopPass(module, st, stage + ".opt"):
        changed = true
    if uirModNormExprPass(module, st, stage + ".opt"):
        changed = true
    if uirModDsePass(module, st, stage + ".opt"):
        changed = true
    if uirModFoldPurePass(module, st, stage + ".opt"):
        changed = true
    if uirModCopyPropPass(module, st, stage + ".opt"):
        changed = true
    if uirModConstPropPass(module, st, stage + ".opt"):
        changed = true
    if uirModCfgPass(module, st, stage + ".opt"):
        changed = true

    if uirFuncSroaPass(module, st, stage + ".func"):
        changed = true
    if uirModNormExprPass(module, st, stage + ".func"):
        changed = true
    if uirModAlgebraicPass(module, st, stage + ".func"):
        changed = true
    if uirModNormExprPass(module, st, stage + ".func"):
        changed = true
    if uirModNoopPass(module, st, stage + ".func"):
        changed = true
    if uirModDsePass(module, st, stage + ".func"):
        changed = true
    if uirRunCoreModuleFoldJumpToRetPass(module, st, stage + ".func"):
        changed = true
    if uirModFoldPurePass(module, st, stage + ".func"):
        changed = true
    if uirFuncCsePass(module, st, stage + ".func"):
        changed = true
    if uirModCopyPropPass(module, st, stage + ".func"):
        changed = true
    if uirFuncLicmPass(module, st, stage + ".func"):
        changed = true
    if uirModCfgPass(module, st, stage + ".func"):
        changed = true
    if uirModExprFoldPass(module, st, stage + ".func"):
        changed = true
    if uirModCfgPass(module, st, stage + ".func"):
        changed = true
    if uirModPruneFuncsPass(module, st, stage + ".func"):
        changed = true
    if uirFuncDcePass(module, st, stage + ".func"):
        changed = true
    if uirModCfgPass(module, st, stage + ".func"):
        changed = true

    return changed

fn uirFuncCsePass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for i in 0..<uirModuleFuncsLen(module):
        let f: UirFunc = uirModuleFuncAt(module, i)
        if (f == nil) || uirFuncIsExtern(f):
            continue
        if uirCoreFuncCse(f, module):
            changed = true
    uirProfilePass(st, stage + ".func_cse", changed)
    return changed

fn uirFuncSroaPass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    var changed: bool = false
