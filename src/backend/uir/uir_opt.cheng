fn uirCoreExprAllocFields(kind: UirCoreExprKind,
                          value: int64,
                          binOp: UirCoreBinOp,
                          cmpOp: UirCoreCmpOp,
                          lhs: UirExprId,
                          rhs: UirExprId,
                          localIndex: int32,
                          callee: str,
                          args: UirExprId[],
                          castType: UirCoreType,
                          castExpr: UirExprId,
                          addrExpr: UirExprId,
                          loadType: UirCoreType,
                          globalName: str): UirExprId =
    uirCore_exprPoolInit()
    let id: int32 = uirCore_exprPool_kind.len
    let argStart: int32 = uirCore_exprArgsFlat.len
    let argLenFlat: int32 = args.len
    if argLenFlat > 0:
        let flatNeedLen: int32 = argStart + argLenFlat
        if uirCore_exprArgsFlat.buffer == nil || uirCore_exprArgsFlat.cap < flatNeedLen:
            reserve(uirCore_exprArgsFlat, uirCoreReserveTargetCap(uirCore_exprArgsFlat.cap, flatNeedLen, 256))
        setLen(uirCore_exprArgsFlat, flatNeedLen)
        for ai in 0..<argLenFlat:
            uirCore_exprArgsFlat[argStart + ai] = args[ai]
    var argsOwned: UirExprId[]
    if argLenFlat > 0:
        reserve(argsOwned, argLenFlat)
        setLen(argsOwned, argLenFlat)
        for ai in 0..<argLenFlat:
            argsOwned[ai] = args[ai]
    uirCoreExprPoolReserve(id + 1)
    seqs.add(uirCore_exprPool_kind, uirCoreEncodeExprKind(kind))
    seqs.add(uirCore_exprPool_value, value)
    seqs.add(uirCore_exprPool_binOp, uirCoreEncodeBinOp(binOp))
    seqs.add(uirCore_exprPool_cmpOp, uirCoreEncodeCmpOp(cmpOp))
    add(uirCore_exprPool_lhs, lhs)
    add(uirCore_exprPool_rhs, rhs)
    seqs.add(uirCore_exprPool_localIndex, localIndex)
    seqs.add(uirCore_exprPool_callee, callee)
    let argsIdx: int32 = uirCore_exprPool_args.len
    let argsNeed: int32 = argsIdx + 1
    if uirCore_exprPool_args.buffer == nil || uirCore_exprPool_args.cap < argsNeed:
        reserve(uirCore_exprPool_args, uirCoreReserveTargetCap(uirCore_exprPool_args.cap, argsNeed, 64))
    setLen(uirCore_exprPool_args, argsNeed)
    uirCore_exprPool_args[argsIdx] = argsOwned
    seqs.add(uirCore_exprPool_argStart, argStart)
    seqs.add(uirCore_exprPool_argLenFlat, argLenFlat)
    seqs.add(uirCore_exprPool_castType, uirCoreEncodeType(castType))
    add(uirCore_exprPool_castExpr, castExpr)
    add(uirCore_exprPool_addrExpr, addrExpr)
    seqs.add(uirCore_exprPool_loadType, uirCoreEncodeType(loadType))
    seqs.add(uirCore_exprPool_globalName, globalName)
    return id

fn uirCoreExprAllocFieldsNoArgs(kind: UirCoreExprKind,
                                value: int64,
                                binOp: UirCoreBinOp,
                                cmpOp: UirCoreCmpOp,
                                lhs: UirExprId,
                                rhs: UirExprId,
                                localIndex: int32,
                                callee: str,
                                castType: UirCoreType,
                                castExpr: UirExprId,
                                addrExpr: UirExprId,
                                loadType: UirCoreType,
                                globalName: str): UirExprId =
    uirCore_exprPoolInit()
    let id: int32 = uirCore_exprPool_kind.len
    var noArgs: UirExprId[]
    uirCoreExprPoolReserve(id + 1)
    seqs.add(uirCore_exprPool_kind, uirCoreEncodeExprKind(kind))
    seqs.add(uirCore_exprPool_value, value)
    seqs.add(uirCore_exprPool_binOp, uirCoreEncodeBinOp(binOp))
    seqs.add(uirCore_exprPool_cmpOp, uirCoreEncodeCmpOp(cmpOp))
    add(uirCore_exprPool_lhs, lhs)
    add(uirCore_exprPool_rhs, rhs)
    seqs.add(uirCore_exprPool_localIndex, localIndex)
    seqs.add(uirCore_exprPool_callee, callee)
    let argsIdx1: int32 = uirCore_exprPool_args.len
    let argsNeed1: int32 = argsIdx1 + 1
    if uirCore_exprPool_args.buffer == nil || uirCore_exprPool_args.cap < argsNeed1:
        reserve(uirCore_exprPool_args, uirCoreReserveTargetCap(uirCore_exprPool_args.cap, argsNeed1, 64))
    setLen(uirCore_exprPool_args, argsNeed1)
    uirCore_exprPool_args[argsIdx1] = noArgs
    seqs.add(uirCore_exprPool_argStart, int32(0))
    seqs.add(uirCore_exprPool_argLenFlat, int32(0))
    seqs.add(uirCore_exprPool_castType, uirCoreEncodeType(castType))
    add(uirCore_exprPool_castExpr, castExpr)
    add(uirCore_exprPool_addrExpr, addrExpr)
    seqs.add(uirCore_exprPool_loadType, uirCoreEncodeType(loadType))
    seqs.add(uirCore_exprPool_globalName, globalName)
    return id

fn uirCoreStmtAllocFields(kind: UirCoreStmtKind,
                          name: str,
                          slot: int32,
                          expr: UirExprId,
                          paramIndex: int32,
                          addrExpr: UirExprId,
                          storeType: UirCoreType): UirStmtId =
    uirCore_stmtPoolInit()
    let id: int32 = uirCore_stmtPool_kind.len
    uirCoreStmtPoolReserve(id + 1)
    seqs.add(uirCore_stmtPool_kind, uirCoreEncodeStmtKind(kind))
    seqs.add(uirCore_stmtPool_name, name)
    seqs.add(uirCore_stmtPool_slot, slot)
    add(uirCore_stmtPool_expr, expr)
    seqs.add(uirCore_stmtPool_paramIndex, paramIndex)
    add(uirCore_stmtPool_addrExpr, addrExpr)
    seqs.add(uirCore_stmtPool_storeType, uirCoreEncodeType(storeType))
    return id

fn uirCoreBlockAllocFieldsFromStmtSeqRef(label: str, stmts: UirStmtId[]*, term: UirCoreTerm): UirBlockId =
    uirCore_blockPoolInit()
    let id: int32 = uirCore_blockPool_label.len
    uirCoreBlockPoolReserve(id + 1)
    seqs.add(uirCore_blockPool_label, label)
    uirCoreAppendBlockStmtSpanFromSeq(stmts)
    seqs.add(uirCore_blockPool_term, term)
    return id

fn uirCoreBlockAllocFieldsFromSpan(label: str, stmtStart: int32, stmtLen: int32, term: UirCoreTerm): UirBlockId =
    uirCore_blockPoolInit()
    let id: int32 = uirCore_blockPool_label.len
    uirCoreBlockPoolReserve(id + 1)
    seqs.add(uirCore_blockPool_label, label)
    seqs.add(uirCore_blockPool_stmtStart, stmtStart)
    seqs.add(uirCore_blockPool_stmtLenFlat, stmtLen)
    seqs.add(uirCore_blockPool_term, term)
    return id

fn uirCoreBlockAllocFields(label: str, stmts: UirStmtId[], term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFieldsFromStmtSeqRef(label, &stmts, term)

fn uirCoreConstI64(value: int64): UirExprId =
    return uirCoreExprAllocFieldsNoArgs(meConstI64, value, mbAdd, mcEq, 0, 0, -1,
                                        "", uirCoreTypeVoid(), 0, 0, uirCoreTypeVoid(), "")

fn uirCoreBin(op: UirCoreBinOp, lhs: UirExprId, rhs: UirExprId): UirExprId =
    return uirCoreExprAllocFieldsNoArgs(meBin, 0, op, mcEq, lhs, rhs, -1,
                                        "", uirCoreTypeVoid(), 0, 0, uirCoreTypeVoid(), "")

fn uirCoreLocal(index: int32): UirExprId =
    return uirCoreExprAllocFieldsNoArgs(meLocal, 0, mbAdd, mcEq, 0, 0, index,
                                        "", uirCoreTypeVoid(), 0, 0, uirCoreTypeVoid(), "")

fn uirCoreCall(name: str, args: UirExprId[]): UirExprId =
    var argsStable: UirExprId[] = args
    let argc: int32 = argsStable.len
    let lhs: UirExprId = (argc > 0) ? argsStable[0] : int32(0)
    let rhs: UirExprId = (argc > 1) ? argsStable[1] : int32(0)
    return uirCoreExprAllocFields(meCall, 0, mbAdd, mcEq, lhs, rhs, -1,
                                  uirCoreOwnStr(name), argsStable, uirCoreTypeVoid(), 0, 0, uirCoreTypeVoid(), "")

fn uirCoreCast(ty: UirCoreType, expr: UirExprId): UirExprId =
    return uirCoreExprAllocFieldsNoArgs(meCast, 0, mbAdd, mcEq, 0, 0, -1,
                                        "", ty, expr, 0, uirCoreTypeVoid(), "")

fn uirCoreAddr(slot: int32): UirExprId =
    return uirCoreExprAllocFieldsNoArgs(meAddr, 0, mbAdd, mcEq, 0, 0, slot,
                                        "", uirCoreTypeVoid(), 0, 0, uirCoreTypeVoid(), "")

fn uirCoreLoad(addr: UirExprId, ty: UirCoreType): UirExprId =
    return uirCoreExprAllocFieldsNoArgs(meLoad, 0, mbAdd, mcEq, 0, 0, -1,
                                        "", uirCoreTypeVoid(), 0, addr, ty, "")

fn uirCoreGlobalAddr(name: str): UirExprId =
    return uirCoreExprAllocFieldsNoArgs(meGlobalAddr, 0, mbAdd, mcEq, 0, 0, -1,
                                        "", uirCoreTypeVoid(), 0, 0, uirCoreTypeVoid(), uirCoreOwnStr(name))

fn uirCoreCmp(op: UirCoreCmpOp, lhs: UirExprId, rhs: UirExprId): UirExprId =
    return uirCoreExprAllocFieldsNoArgs(meCmp, 0, mbAdd, op, lhs, rhs, -1,
                                        "", uirCoreTypeVoid(), 0, 0, uirCoreTypeVoid(), "")

fn uirCoreTermRet(expr: UirExprId): UirCoreTerm =
    var t: UirCoreTerm
    t.kind = mtRet
    t.retExpr = expr
    return t

fn uirCoreTermBr(target: str): UirCoreTerm =
    var t: UirCoreTerm
    t.kind = mtBr
    t.target = uirCoreOwnStr(target)
    return t

fn uirCoreTermCbr(cond: UirExprId, tLabel: str, fLabel: str): UirCoreTerm =
    var t: UirCoreTerm
    t.kind = mtCbr
    t.condExpr = cond
    t.targetTrue = uirCoreOwnStr(tLabel)
    t.targetFalse = uirCoreOwnStr(fLabel)
    return t

fn uirCoreStmtLet(name: str, slot: int32, expr: UirExprId): UirStmtId =
    return uirCoreStmtAllocFields(msLet, uirCoreOwnStr(name), slot, expr, -1, 0, uirCoreTypeVoid())

fn uirCoreStmtVar(name: str, slot: int32, expr: UirExprId): UirStmtId =
    return uirCoreStmtAllocFields(msVar, uirCoreOwnStr(name), slot, expr, -1, 0, uirCoreTypeVoid())

fn uirCoreStmtAssign(name: str, slot: int32, expr: UirExprId): UirStmtId =
    return uirCoreStmtAllocFields(msAssign, uirCoreOwnStr(name), slot, expr, -1, 0, uirCoreTypeVoid())

fn uirCoreStmtExpr(expr: UirExprId): UirStmtId =
    return uirCoreStmtAllocFields(msExpr, "", -1, expr, -1, 0, uirCoreTypeVoid())

fn uirCoreStmtParam(name: str, slot: int32, paramIndex: int32): UirStmtId =
    return uirCoreStmtAllocFields(msParam, uirCoreOwnStr(name), slot, 0, paramIndex, 0, uirCoreTypeVoid())

fn uirCoreStmtStore(addr: UirExprId, value: UirExprId, ty: UirCoreType): UirStmtId =
    return uirCoreStmtAllocFields(msStore, "", -1, value, -1, addr, ty)

fn uirCoreBlock(label: str, term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFields(uirCoreOwnStr(label), [], term)

fn uirCoreBlockWithStmtSeqRef(label: str, stmts: UirStmtId[]*, term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFieldsFromStmtSeqRef(uirCoreOwnStr(label), stmts, term)

fn uirCoreBlockWithStmtSpan(label: str, stmtStart: int32, stmtLen: int32, term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFieldsFromSpan(uirCoreOwnStr(label), stmtStart, stmtLen, term)

fn uirCoreBlockWithStmts(label: str, stmts: UirStmtId[], term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFields(uirCoreOwnStr(label), stmts, term)

fn uirCoreNewFunc(name: str, retType: UirCoreType): UirCoreFunc =
    let raw: ptr = uirCoreHeapNew(int32(sizeof UirCoreFuncObj))
    if raw == nil:
        return nil
    uirCoreMemZero(raw, int32(sizeof UirCoreFuncObj))
    let f: UirCoreFunc = UirCoreFunc(raw)
    if f == nil:
        return f
    var fVal: UirCoreFuncObj = uirCoreFuncObjLoad(f)
    fVal.name = uirCoreOwnStr(name)
    fVal.linkName = uirCoreOwnStr(name)
    fVal.originFile = uirCoreOwnStr("")
    fVal.declOrdinal = -1
    fVal.dynId = uirCoreAllocFuncDynId()
    fVal.dynStatePtr = 0
    uirCoreRememberFuncDynAddr(f)
    fVal.sourceAstIndex = -1
    fVal.isExtern = false
    fVal.isExported = false
    fVal.retType = retType
    fVal.retTypeKey = uirCoreOwnStr("")
    fVal.params = []
    fVal.localTypes = []
    fVal.objLocals = []
    fVal.objFrameSize = 0
    fVal.blocks = []
    fVal.blockBuffer = nil
    fVal.blockLen = 0
    fVal.blockCap = 0
    fVal.phaseTag = uirCorePhaseHighTag()
    fVal.highUirChecked = false
    fVal.lowUirLowered = false
    fVal.phaseFallbackReason = uirCoreOwnStr("high_uir_unchecked")
    uirCoreFuncObjStore(f, fVal)
    let dyn0: UirCoreFuncDynState = uirCoreEnsureFuncDyn(f)
    if dyn0 == nil:
        return f
    dyn0.name = uirCoreOwnStr(name)
    dyn0.linkName = uirCoreOwnStr(name)
    dyn0.originFile = uirCoreOwnStr("")
    dyn0.declOrdinal = -1
    dyn0.sourceAstIndex = -1
    dyn0.isExtern = false
    dyn0.isExported = false
    dyn0.retType = retType
    dyn0.retTypeKey = uirCoreOwnStr("")
    dyn0.objFrameSize = 0
    dyn0.phaseTag = uirCorePhaseHighTag()
    dyn0.highUirChecked = false
    dyn0.lowUirLowered = false
    dyn0.phaseFallbackReason = uirCoreOwnStr("high_uir_unchecked")
    uirCoreCacheDynState(fVal.dynId, dyn0)
    if uirOptEnvIsTrue("BACKEND_DEBUG_STAGE1_PIPE") && name == "main":
        let ptrValDbg: int64 = uirCoreFuncPtrKey(f)
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_main_new_func name=" + name +
                     " ret_kind=" + intToStr(int32(retType.kind)) +
                     " dyn_id=" + intToStr(fVal.dynId) +
                     " ptr=" + int64ToStr(ptrValDbg))
        uirOptFFlush(uirOptGetStderr())
    uirCoreRecordFuncNames(f)
    return f

fn uirCoreBlockSeqAppend(seqInst: var UirBlockId[], block: UirBlockId) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = block

fn uirCoreBlockSeqSane(blocks: UirBlockId[]): bool =
    let blockCount: int32 = blocks.len
    if blockCount <= 0:
        return true
    if blockCount > (1 << 20):
        return false
    if blocks.cap < blockCount || blocks.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(blocks.buffer)
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreAppendBlockPtr(seqInst: UirBlockId[]*, block: UirBlockId) =
    if seqInst == nil:
        panic "uirCore_types: nil block seq pointer"
    if seqInst->len < 0 || seqInst->cap < 0:
        seqInst->buffer = nil
        seqInst->len = 0
        seqInst->cap = 0
    let idx: int32 = seqInst->len
    let needLen: int32 = idx + 1
    if seqInst->buffer == nil || seqInst->cap < needLen:
        cheng__seqGrowToRaw(&seqInst->buffer, &seqInst->cap, needLen, int32(sizeof UirBlockId))
