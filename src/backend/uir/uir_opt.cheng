fn uirCoreFuncIsExtern(func: UirCoreFunc): bool =
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    let dbgBoot: bool = uirOptEnvIsTrue("BACKEND_DEBUG_BOOT")
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    var funcVal: UirCoreFuncObj
    if funcObj != nil:
        funcVal = uirCoreFuncObjLoadPtr(funcObj)
    var dbgNameObj: str
    uirCoreSetEmpty(dbgNameObj)
    if funcObj != nil:
        uirCoreCopyStr(dbgNameObj, funcVal.name)
    var dbgNameDyn: str
    uirCoreSetEmpty(dbgNameDyn)
    if dyn != nil:
        uirCoreCopyStr(dbgNameDyn, dyn.name)
    let dbgName: str = uirCoreChooseNonEmpty(dbgNameObj, dbgNameDyn)
    let dbgTrack: bool = dbgBoot && (dbgName == "main" || dbgName == "backendMain")
    if dyn != nil:
        let blocks: UirBlockId[] = dyn.blocks
        if uirCoreBlockSeqSane(blocks) && blocks.len > 0:
            if dyn.isExtern:
                dyn.isExtern = false
            if funcObj != nil && funcVal.isExtern:
                funcVal.isExtern = false
                uirCoreFuncObjStorePtr(funcObj, funcVal)
            if dbgTrack:
                uirOptWriteLine(uirOptGetStderr(),
                             "[backend] dbg_is_extern.heal name=" + dbgName +
                             " blocks=" + intToStr(blocks.len) +
                             " dyn_id=" + intToStr(uirCoreFuncDynId(func)))
                uirOptFFlush(uirOptGetStderr())
            return false
    if dbgTrack:
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_is_extern name=" + dbgName +
                     " obj=" + ((funcObj != nil && funcVal.isExtern) ? "1" : "0") +
                     " dyn=" + ((dyn != nil && dyn.isExtern) ? "1" : "0") +
                     " blocks=" + intToStr(uirCoreFuncBlocksLen(func)) +
                     " dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " ptr=" + int64ToStr(uirCoreFuncPtrKey(func)))
        uirOptFFlush(uirOptGetStderr())
    if dyn == nil:
        if funcObj == nil:
            return false
        return funcVal.isExtern
    return dyn.isExtern

fn uirCoreFuncIsExternObjFirst(func: UirCoreFunc): bool =
    if !uirCoreFuncIdValid(func):
        return false
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    var funcVal: UirCoreFuncObj
    if funcObj != nil:
        funcVal = uirCoreFuncObjLoadPtr(funcObj)
    let blockCount: int32 = uirCoreFuncBlocksLenObjFirst(func)
    if blockCount > 0:
        if dyn != nil && dyn.isExtern:
            dyn.isExtern = false
        if funcObj != nil && funcVal.isExtern:
            funcVal.isExtern = false
            uirCoreFuncObjStorePtr(funcObj, funcVal)
        return false
    if funcObj != nil && !funcVal.isExtern:
        if dyn != nil && dyn.isExtern:
            dyn.isExtern = false
        return false
    if dyn != nil:
        return dyn.isExtern
    if funcObj != nil:
        return funcVal.isExtern
    return false

