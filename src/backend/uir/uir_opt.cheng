        if uirCoreStrPtrSane(norm.name):
            hashmaps.hashMapPtrIntPut(uirCore_objTypes_ptr_cache, int64(rawmemAsVoid(norm.name)), newIdx + 1)
        uirCore_objTypes_cache_len = module.objTypes.len

fn uirCoreAddFunc(module: UirCoreModule, func: UirCoreFunc) =
    let canAdd: bool = module != nil && uirCoreFuncIdValid(func)
    if canAdd:
        uirCoreCanonicalizeFunc(func)
        uirCoreFuncSyncBlocks(func)
        uirCoreAppendFuncPtr(&module.funcs, func)

fn uirCoreAddGlobal(module: UirCoreModule, name: str, ty: UirCoreType, init: int64, hasInit: bool, originFile: str) =
    if (module == nil):
        return
    var g: UirCoreGlobal
    g.name = uirCoreOwnStr(name)
    g.ty = ty
    g.init = init
    g.hasInit = hasInit
    g.originFile = uirCoreOwnStr(originFile)
    var globals0: UirCoreGlobal[] = module.globals
    var globalNames0: str[] = module.globalNames
    var globalTypesRaw0: int32[] = module.globalTypesRaw
    var globalInits0: int64[] = module.globalInits
    var globalHasInitBits0: int32[] = module.globalHasInitBits
    var globalOriginFiles0: str[] = module.globalOriginFiles
    seqs.add(globals0, g)
    seqs.add(globalNames0, g.name)
    seqs.add(globalTypesRaw0, uirCoreEncodeType(g.ty))
    seqs.add(globalInits0, g.init)
    seqs.add(globalHasInitBits0, hasInit ? 1 : 0)
    seqs.add(globalOriginFiles0, g.originFile)
    var mod0: UirCoreModule = module
    mod0.globals = globals0
    mod0.globalNames = globalNames0
    mod0.globalTypesRaw = globalTypesRaw0
    mod0.globalInits = globalInits0
    mod0.globalHasInitBits = globalHasInitBits0
    mod0.globalOriginFiles = globalOriginFiles0

fn uirCoreAppendObjFieldNamed(seqInst: var UirCoreObjField[], name: str, ty: UirCoreType, offset: int32) =
    var f: UirCoreObjField
    f.name = name
    f.ty = ty
    f.offset = offset
    seqs.add(seqInst, f)

fn uirCoreObjTypeRenamed(ty: UirCoreObjType, name: str): UirCoreObjType =
    var out: UirCoreObjType = ty
    out.name = name
    return out

fn uirCoreAddObjTypeParts(module: UirCoreModule, name: str, alignPow2: int32, size: int32, fields: UirCoreObjField[]) =
    if module == nil:
        return
    var ot: UirCoreObjType
    ot.name = name
    ot.alignPow2 = alignPow2
    ot.size = size
    ot.fields = fields
    uirCoreAddObjType(module, ot)

fn uirCoreReplaceObjTypeParts(module: UirCoreModule, idx: int32, name: str, alignPow2: int32, size: int32, fields: UirCoreObjField[]) =
    if (module == nil) || idx < 0 || idx >= module.objTypes.len:
        return
    var ot: UirCoreObjType
    ot.name = name
    ot.alignPow2 = alignPow2
    ot.size = size
    ot.fields = fields
    uirCoreWriteObjType(module.objTypes, idx, uirCoreCanonicalizeObjType(ot))

fn uirCoreReplaceGlobal(module: UirCoreModule, idx: int32, name: str, ty: UirCoreType, init: int64, hasInit: bool, originFile: str) =
    if (module == nil) || idx < 0 || idx >= module.globals.len:
        return
    var g: UirCoreGlobal
    g.name = uirCoreOwnStr(name)
    g.ty = ty
    g.init = init
    g.hasInit = hasInit
    g.originFile = uirCoreOwnStr(originFile)
    uirCoreWriteGlobal(module.globals, idx, g)
    if idx >= 0 && idx < module.globalNames.len:
        uirCoreSetStr(module.globalNames, idx, g.name)
    if idx >= 0 && idx < module.globalTypesRaw.len:
        uirCoreSetInt32(module.globalTypesRaw, idx, uirCoreEncodeType(g.ty))
    if idx >= 0 && idx < module.globalInits.len:
        uirCoreSetI64(module.globalInits, idx, g.init)
    if idx >= 0 && idx < module.globalHasInitBits.len:
        if hasInit:
            uirCoreSetInt32(module.globalHasInitBits, idx, 1)
        else:
            uirCoreSetInt32(module.globalHasInitBits, idx, 0)
    if idx >= 0 && idx < module.globalOriginFiles.len:
        uirCoreSetStr(module.globalOriginFiles, idx, g.originFile)

fn uirCoreCanonicalizeModule(module: UirCoreModule) =
    if module == nil:
        return
    let dbgCanon: bool = uirOptEnvIsTrue("BACKEND_DEBUG_CANON_MOD")
    let funcsSane: bool = uirCoreFuncRefSeqSane(module.funcs)
    if dbgCanon:
        echo("[backend] canon_mod: funcs=" + intToStr(module.funcs.len) +
             " funcs_sane=" + (funcsSane ? "1" : "0") +
             " globals=" + intToStr(module.globals.len) +
             " cstrs=" + intToStr(module.cstrs.len) +
             " aliases=" + intToStr(module.typeAliases.len) +
             " objs=" + intToStr(module.objTypes.len))
    if !funcsSane:
        var funcsKeep: UirCoreFunc[]
        for fi in 0..<module.funcs.len:
            let func: UirCoreFunc = module.funcs[fi]
            if dbgCanon:
                echo("[backend] canon_mod: func_scan fi=" + intToStr(fi) +
                     " ptr=" + int64ToStr(uirCoreFuncRawPtrVal(func)))
            if !uirCoreFuncIdValid(func):
                continue
            if uirCoreFindFuncNameCacheIndex(func) < 0:
                continue
            uirCoreAppendFuncRef(funcsKeep, func)
        if dbgCanon:
            echo("[backend] canon_mod: funcs_keep=" + intToStr(funcsKeep.len))
        uirCoreModuleSetFuncs(module, funcsKeep)
    for fi in 0..<module.funcs.len:
        let func: UirCoreFunc = module.funcs[fi]
        if dbgCanon:
            echo("[backend] canon_mod: func_canon fi=" + intToStr(fi) +
                 " ptr=" + int64ToStr(uirCoreFuncRawPtrVal(func)))
        uirCoreCanonicalizeFunc(func)
        if dbgCanon:
            echo("[backend] canon_mod: func_name fi=" + intToStr(fi) +
                 " name='" + uirCoreFuncNameOf(func) +
                 "' link='" + uirCoreFuncLinkNameOf(func) + "'")
    for gi in 0..<module.globals.len:
        if dbgCanon:
            echo("[backend] canon_mod: global_canon gi=" + intToStr(gi))
        var g: UirCoreGlobal = module.globals[gi]
        g.name = uirCoreCanonicalStr(g.name)
        g.originFile = uirCoreCanonicalStr(g.originFile)
        uirCoreWriteGlobal(module.globals, gi, g)
        if gi >= 0 && gi < module.globalNames.len:
            uirCoreSetStr(module.globalNames, gi, g.name)
        if gi >= 0 && gi < module.globalOriginFiles.len:
            uirCoreSetStr(module.globalOriginFiles, gi, g.originFile)
    for ci in 0..<module.cstrs.len:
        if dbgCanon:
            echo("[backend] canon_mod: cstr_canon ci=" + intToStr(ci))
        var c: UirCoreCString = module.cstrs[ci]
        c.value = uirCoreCanonicalStr(c.value)
        c.label = uirCoreCanonicalStr(uirCoreCStringLabelFromHash(uirCoreFnv1a64(c.value)))
        uirCoreWriteCString(&module.cstrs, ci, c)
        if ci >= 0 && ci < module.cstrLabels.len:
            uirCoreSetStr(module.cstrLabels, ci, c.label)
        if ci >= 0 && ci < module.cstrValues.len:
            uirCoreSetStr(module.cstrValues, ci, c.value)
    for ti in 0..<module.typeAliases.len:
        if dbgCanon:
            echo("[backend] canon_mod: alias_canon ti=" + intToStr(ti))
        let alias0: UirCoreTypeAlias = uirCoreCanonicalizeTypeAlias(module.typeAliases[ti])
        uirCoreWriteTypeAlias(module.typeAliases, ti, alias0)
    if !uirCoreObjTypeSeqSane(module.objTypes):
        var emptyObjTypes: UirCoreObjType[]
        var mod0: UirCoreModule = module
        mod0.objTypes = emptyObjTypes
        return
        return
    for oi in 0..<module.objTypes.len:
        if dbgCanon:
            echo("[backend] canon_mod: obj_canon oi=" + intToStr(oi))
        let obj0: UirCoreObjType = uirCoreCanonicalizeObjType(module.objTypes[oi])
        uirCoreWriteObjType(module.objTypes, oi, obj0)

fn uirCoreExprKindOf(expr: UirExprId): UirCoreExprKind =
    if (!uirCoreExprIdValid(expr)):
        return meConstI64
    return uirCoreDecodeExprKind(uirCore_exprPool_kind[expr])

fn uirCoreExprCalleeOf(expr: UirExprId): str =
    if (!uirCoreExprIdValid(expr)):
        return ""
    return uirCore_exprPool_callee[expr]

fn uirCoreExprLocalIndexOf(expr: UirExprId): int32 =
    if (!uirCoreExprIdValid(expr)):
        return -1
    return uirCore_exprPool_localIndex[expr]

fn uirCoreExprSetLocalIndex(expr: UirExprId, localIndex: int32) =
    if (!uirCoreExprIdValid(expr)):
        return
    uirCore_exprPool_localIndex[expr] = localIndex

fn uirCoreExprConstValueOf(expr: UirExprId): int64 =
    if (!uirCoreExprIdValid(expr)):
        return 0
    return uirCore_exprPool_value[expr]

fn uirCoreExprBinOpOf(expr: UirExprId): UirCoreBinOp =
    if (!uirCoreExprIdValid(expr)):
        return mbAdd
    return uirCoreDecodeBinOp(uirCore_exprPool_binOp[expr])

fn uirCoreExprCmpOpOf(expr: UirExprId): UirCoreCmpOp =
    if (!uirCoreExprIdValid(expr)):
        return mcEq
    return uirCoreDecodeCmpOp(uirCore_exprPool_cmpOp[expr])

fn uirCoreExprCastTypeOf(expr: UirExprId): UirCoreType =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreTypeVoid()
    return uirCoreDecodeType(uirCore_exprPool_castType[expr])

fn uirCoreExprLoadTypeOf(expr: UirExprId): UirCoreType =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreTypeVoid()
    return uirCoreDecodeType(uirCore_exprPool_loadType[expr])

fn uirCoreExprGlobalNameOf(expr: UirExprId): str =
    if (!uirCoreExprIdValid(expr)):
        return ""
    return uirCore_exprPool_globalName[expr]

fn uirCoreExprArgsSeqSane(args: UirExprId[]): bool =
    let argc: int32 = args.len
    if argc <= 0:
        return true
    if argc > (1 << 20):
        return false
    if args.cap < argc || args.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(args.buffer)
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreExprMirroredArgCount(expr: UirExprId): int32 =
    if !uirCoreExprIdValid(expr):
        return 0
    if uirCoreExprKindOf(expr) != meCall:
        return 0
    let lhs: UirExprId = uirCore_exprPool_lhs[expr]
    let rhs: UirExprId = uirCore_exprPool_rhs[expr]
    if uirCoreExprIdValid(lhs) && uirCoreExprIdValid(rhs):
        return 2
    if uirCoreExprIdValid(lhs):
        return 1
    return 0

fn uirCoreStmtSeqSane(stmts: UirStmtId[]): bool =
    let stmtCount: int32 = stmts.len
    if stmtCount <= 0:
        return true
    if stmtCount > (1 << 20):
        return false
    if stmts.cap < stmtCount || stmts.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(stmts.buffer)
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreExprArgsLen(expr: UirExprId): int32 =
    if (!uirCoreExprIdValid(expr)):
        return 0
    if expr < uirCore_exprPool_argLenFlat.len:
        let flatLen: int32 = uirCore_exprPool_argLenFlat[expr]
        if flatLen >= 0:
            return flatLen
    return uirCoreExprMirroredArgCount(expr)

fn uirCoreExprArgAt(expr: UirExprId, idx: int32): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    if idx < 0:
        return uirCoreInvalidId()
    if expr < uirCore_exprPool_argLenFlat.len:
        let flatLen: int32 = uirCore_exprPool_argLenFlat[expr]
        if idx < flatLen:
            let start: int32 = uirCore_exprPool_argStart[expr]
            let pos: int32 = start + idx
            if pos >= 0 && pos < uirCore_exprArgsFlat.len:
                return uirCore_exprArgsFlat[pos]
    if uirCoreExprKindOf(expr) == meCall:
        let lhs: UirExprId = uirCore_exprPool_lhs[expr]
        let rhs: UirExprId = uirCore_exprPool_rhs[expr]
        if idx == 0 && uirCoreExprIdValid(lhs):
            return lhs
        if idx == 1 && uirCoreExprIdValid(lhs) && uirCoreExprIdValid(rhs):
            return rhs
    return uirCoreInvalidId()

fn uirCoreExprSetArgAt(expr: UirExprId, idx: int32, val: UirExprId) =
    if (!uirCoreExprIdValid(expr)):
        return
    if expr >= uirCore_exprPool_args.len:
        panic "uirCore_types: expr args column out of sync"
    if idx < 0:
        panic "uirCore_types: expr arg index out of bounds"
    if expr < uirCore_exprPool_argLenFlat.len:
        let flatLen: int32 = uirCore_exprPool_argLenFlat[expr]
        if flatLen > 0:
            if idx >= flatLen:
                panic "uirCore_types: expr arg index out of bounds"
            let start: int32 = uirCore_exprPool_argStart[expr]
            let pos: int32 = start + idx
            if pos < 0 || pos >= uirCore_exprArgsFlat.len:
                panic "uirCore_types: expr arg flat column out of sync"
            uirCore_exprArgsFlat[pos] = val
    var args: UirExprId[] = uirCore_exprPool_args[expr]
    let materializedLen: int32 = uirCoreExprArgsLen(expr)
    if !uirCoreExprArgsSeqSane(args) || len(args) != materializedLen:
        # Recover call args from the mirrored lhs/rhs columns so late rewrite
        # passes can keep running even if the seq column was not materialized.
        var recovered: UirExprId[]
        if materializedLen > 0:
            reserve(recovered, materializedLen)
            setLen(recovered, materializedLen)
            for ai in 0..<materializedLen:
                recovered[ai] = uirCoreExprArgAt(expr, ai)
        args = recovered
    if idx < 0 || idx >= args.len:
        panic "uirCore_types: expr arg index out of bounds"
    args[idx] = val
    if uirCoreExprKindOf(expr) == meCall:
        if args.len > 0:
            uirCore_exprPool_lhs[expr] = args[0]
        if args.len > 1:
            uirCore_exprPool_rhs[expr] = args[1]
    uirCore_exprPool_args[expr] = args

fn uirCoreExprLhsOf(expr: UirExprId): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    return uirCore_exprPool_lhs[expr]

fn uirCoreExprSetLhs(expr: UirExprId, lhs: UirExprId) =
    if (!uirCoreExprIdValid(expr)):
        return
    uirCore_exprPool_lhs[expr] = lhs

fn uirCoreExprRhsOf(expr: UirExprId): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    return uirCore_exprPool_rhs[expr]

fn uirCoreExprSetRhs(expr: UirExprId, rhs: UirExprId) =
    if (!uirCoreExprIdValid(expr)):
        return
    uirCore_exprPool_rhs[expr] = rhs

fn uirCoreExprCastExprOf(expr: UirExprId): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    return uirCore_exprPool_castExpr[expr]

fn uirCoreExprSetCastExpr(expr: UirExprId, castExpr: UirExprId) =
    if (!uirCoreExprIdValid(expr)):
        return
    uirCore_exprPool_castExpr[expr] = castExpr

fn uirCoreExprAddrExprOf(expr: UirExprId): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    return uirCore_exprPool_addrExpr[expr]

fn uirCoreExprSetAddrExpr(expr: UirExprId, addrExpr: UirExprId) =
    if (!uirCoreExprIdValid(expr)):
        return
    uirCore_exprPool_addrExpr[expr] = addrExpr

fn uirCoreExprIsCall(expr: UirExprId): bool =
    return uirCoreExprIdValid(expr) && uirCoreExprKindOf(expr) == meCall

fn uirCoreExprIsGlobalAddr(expr: UirExprId): bool =
    return uirCoreExprIdValid(expr) && uirCoreExprKindOf(expr) == meGlobalAddr

fn uirCoreExprIsBinOrCmp(expr: UirExprId): bool =
    if (!uirCoreExprIdValid(expr)):
        return false
    let k: UirCoreExprKind = uirCoreExprKindOf(expr)
    return k == meBin || k == meCmp

fn uirCoreExprIsCast(expr: UirExprId): bool =
    return uirCoreExprIdValid(expr) && uirCoreExprKindOf(expr) == meCast

fn uirCoreExprIsAddrOrLoad(expr: UirExprId): bool =
    if (!uirCoreExprIdValid(expr)):
        return false
    let k: UirCoreExprKind = uirCoreExprKindOf(expr)
    return k == meAddr || k == meLoad

fn uirCoreStmtExprOf(stmt: UirStmtId): UirExprId =
    if (!uirCoreStmtIdValid(stmt)):
        return uirCoreInvalidId()
    return uirCore_stmtPool_expr[stmt]

fn uirCoreStmtKindOf(stmt: UirStmtId): UirCoreStmtKind =
    if (!uirCoreStmtIdValid(stmt)):
        return msExpr
    return uirCoreDecodeStmtKind(uirCore_stmtPool_kind[stmt])

fn uirCoreStmtNameOf(stmt: UirStmtId): str =
    if (!uirCoreStmtIdValid(stmt)):
        return ""
    return uirCore_stmtPool_name[stmt]

fn uirCoreStmtSlotOf(stmt: UirStmtId): int32 =
    if (!uirCoreStmtIdValid(stmt)):
