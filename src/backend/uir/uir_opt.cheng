type
    SsaPhiDef =
        varId: int32
        destSlot: int32

    SsaRowInt32 = ref
        values: int32[]
    SsaGridInt32 = SsaRowInt32[]

    SsaRowPhiDefs = ref
        values: SsaPhiDef[]
    SsaGridPhiDefs = SsaRowPhiDefs[]

    SsaMove =
        destSlot: int32
        srcSlot: int32

    SsaEdgeMoves = ref
        fromIdx: int32
        toIdx: int32
        fromLabel: str
        toLabel: str
        moves: SsaMove[]

    SsaRenameCtx = ref
        func: UirCoreFunc
        baseCount: int32
        blockCount: int32
        idom: int32[]
        domChildren: SsaGridInt32
        succs: SsaGridInt32
        phiDefsByBlock: SsaGridPhiDefs
        isCandidate: bool[]
        varTop: int32[]
        stackVal: int32[]
        stackPrev: int32[]
