fn uirCoreAppendStmtSeq(seqInst: var UirStmtId[][], val: UirStmtId[]) =
    seqs.add(seqInst, uirCoreCloneStmtSeq(val))

fn uirCoreCloneExprArgs(src: UirExprId[]): UirExprId[] =
    var out: UirExprId[]
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    setLen(out, n)
    for i in 0..<n:
        out[i] = src[i]
    return out

fn uirCoreCloneStmtSeq(src: UirStmtId[]): UirStmtId[] =
    var out: UirStmtId[]
    let n: int32 = len(src)
    if n <= 0:
        return out
    reserve(out, n)
    setLen(out, n)
    for i in 0..<n:
        out[i] = src[i]
    return out

fn uirCoreCloneParamSeq(src: UirCoreParam[]): UirCoreParam[] =
    var out: UirCoreParam[]
    if !uirCoreParamSeqSane(src):
        return out
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    for i in 0..<n:
        var p: UirCoreParam = src[i]
        p.name = uirCoreOwnStrBestEffortOrEmpty(p.name)
        p.typeKey = uirCoreOwnStrBestEffortOrEmpty(p.typeKey)
        uirCoreAppendParam(out, p)
    return out

fn uirCoreCloneTypeSeq(src: UirCoreType[]): UirCoreType[] =
    var out: UirCoreType[]
    if !uirCoreTypeSeqSane(src):
        return out
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    for i in 0..<n:
        uirCoreAppendType(out, src[i])
    return out

fn uirCoreCloneObjLocalSeq(src: UirCoreObjLocal[]): UirCoreObjLocal[] =
    var out: UirCoreObjLocal[]
    if !uirCoreObjLocalSeqSane(src):
        return out
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    for i in 0..<n:
        var ol: UirCoreObjLocal = src[i]
        ol.objTypeName = uirCoreOwnStrBestEffortOrEmpty(ol.objTypeName)
        ol.typeKey = uirCoreOwnStrBestEffortOrEmpty(ol.typeKey)
        uirCoreAppendObjLocal(out, ol)
    return out

fn uirCoreCloneBlockSeq(src: UirBlockId[]): UirBlockId[] =
    var out: UirBlockId[]
    if !uirCoreBlockSeqSane(src):
        return out
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    for i in 0..<n:
        uirCoreAppendBlockPtr(&out, src[i])
    return out

fn uirCoreStmtSeqLen(items: UirStmtId[]*): int32 =
    if items == nil:
        return 0
    return items->len

fn uirCoreStmtSeqDataPtr(items: UirStmtId[]*): ptr =
    if items == nil:
        return nil
    return items->buffer

fn uirCoreStmtSeqAppend(items: UirStmtId[]*, stmt: UirStmtId) =
    if items == nil:
        return
    seqs.add(items, stmt)

fn uirCoreStmtSeqAt(items: UirStmtId[]*, idx: int32): UirStmtId =
    if items == nil:
        return uirCoreInvalidId()
    return items[idx]

fn uirCoreStmtSeqSet(items: UirStmtId[]*, idx: int32, stmt: UirStmtId) =
    if items == nil:
        return
    items[idx] = stmt

fn uirCoreBlockStmtsFlatLen(): int32 =
    return uirCore_blockStmtsFlatCount

fn uirCoreResetStmtIdSeq(items: UirStmtId[]*) =
    if items == nil:
        return
    items->buffer = nil
    items->len = 0
    items->cap = 0

fn uirCoreSanitizeStmtIdSeq(items: UirStmtId[]*) =
    if items == nil:
        return
    var bad: bool = false
    if items->len < 0 || items->cap < 0:
        bad = true
    elif items->len > items->cap:
        bad = true
    elif items->len > 100000000 || items->cap > 100000000:
        bad = true
    if bad:
        uirCoreResetStmtIdSeq(items)

fn uirCoreBlockStmtsFlatAppend(stmt: UirStmtId) =
    uirCore_blockPoolInit()
    uirCoreSanitizeStmtIdSeq(&uirCore_blockStmtsFlat)
    let flatLenBefore: int32 = uirCoreStmtSeqLen(&uirCore_blockStmtsFlat)
    if crashTraceEnabled():
        crashTraceSetPhase(strToCStringTemp("uir.flat.append"))
        crashTraceMark(strToCStringTemp("uir.flat.append"), stmt, uirCore_blockStmtsFlatCount, flatLenBefore, 0)
    if uirCore_blockStmtsFlatCount < 0 || uirCore_blockStmtsFlatCount > flatLenBefore:
        uirCore_blockStmtsFlatCount = flatLenBefore
    uirCoreStmtSeqAppend(&uirCore_blockStmtsFlat, stmt)
    uirCore_blockStmtsFlatCount = uirCoreStmtSeqLen(&uirCore_blockStmtsFlat)

fn uirCoreBlockStmtsFlatAt(idx: int32): UirStmtId =
    if idx < 0 || idx >= uirCore_blockStmtsFlatCount:
        return uirCoreInvalidId()
    uirCoreSanitizeStmtIdSeq(&uirCore_blockStmtsFlat)
    let flatLen: int32 = uirCoreStmtSeqLen(&uirCore_blockStmtsFlat)
    if uirCore_blockStmtsFlatCount > flatLen:
        uirCore_blockStmtsFlatCount = flatLen
    if uirCoreStmtSeqDataPtr(&uirCore_blockStmtsFlat) == nil || idx >= flatLen:
        return uirCoreInvalidId()
    return uirCoreStmtSeqAt(&uirCore_blockStmtsFlat, idx)

fn uirCoreBlockStmtsFlatSet(idx: int32, stmt: UirStmtId) =
    if idx < 0 || idx >= uirCore_blockStmtsFlatCount:
        panic "uirCore_types: flat stmt index out of bounds"
    uirCoreSanitizeStmtIdSeq(&uirCore_blockStmtsFlat)
    let flatLen: int32 = uirCoreStmtSeqLen(&uirCore_blockStmtsFlat)
    if uirCore_blockStmtsFlatCount > flatLen:
        uirCore_blockStmtsFlatCount = flatLen
    if uirCoreStmtSeqDataPtr(&uirCore_blockStmtsFlat) == nil || idx >= flatLen:
        panic "uirCore_types: flat stmt backing out of sync"
    uirCoreStmtSeqSet(&uirCore_blockStmtsFlat, idx, stmt)

var
    uirCore_exprPool_ready: bool = false
    uirCore_exprPool_kind: int32[]
    uirCore_exprPool_value: int64[]
    uirCore_exprPool_binOp: int32[]
    uirCore_exprPool_cmpOp: int32[]
    uirCore_exprPool_lhs: UirExprId[]
    uirCore_exprPool_rhs: UirExprId[]
    uirCore_exprPool_localIndex: int32[]
    uirCore_exprPool_callee: str[]
    uirCore_exprPool_args: UirExprId[][]
    uirCore_exprPool_argStart: int32[]
    uirCore_exprPool_argLenFlat: int32[]
    uirCore_exprArgsFlat: UirExprId[]
    uirCore_exprPool_castType: int32[]
    uirCore_exprPool_castExpr: UirExprId[]
    uirCore_exprPool_addrExpr: UirExprId[]
    uirCore_exprPool_loadType: int32[]
    uirCore_exprPool_globalName: str[]
    uirCore_stmtPool_ready: bool = false
    uirCore_stmtPool_kind: int32[]
    uirCore_stmtPool_name: str[]
    uirCore_stmtPool_slot: int32[]
    uirCore_stmtPool_expr: UirExprId[]
    uirCore_stmtPool_paramIndex: int32[]
    uirCore_stmtPool_addrExpr: UirExprId[]
    uirCore_stmtPool_storeType: int32[]
    uirCore_blockPool_ready: bool = false
    uirCore_blockPool_label: str[]
    uirCore_blockPool_stmtStart: int32[]
    uirCore_blockPool_stmtLenFlat: int32[]
    uirCore_blockStmtsFlat: UirStmtId[]
    uirCore_blockStmtsFlatCount: int32 = 0
    uirCore_blockPool_term: UirCoreTerm[]

fn uirCoreAppendBlockStmtSpanFromSeq(stmts: UirStmtId[]*) =
    let start: int32 = uirCoreBlockStmtsFlatLen()
    let stmtLen: int32 = (stmts != nil) ? stmts->len : 0
    if stmts != nil && stmtLen > 0:
        for i in 0..<stmtLen:
            uirCoreBlockStmtsFlatAppend(stmts[i])
    seqs.add(uirCore_blockPool_stmtStart, start)
    seqs.add(uirCore_blockPool_stmtLenFlat, stmtLen)

fn uirCoreAppendBlockStmtSpan(val: UirStmtId[]) =
    uirCoreAppendBlockStmtSpanFromSeq(&val)

fn uirCore_exprPoolInit() =
    if uirCore_exprPool_ready:
        return
    uirCore_exprPool_kind = []
    uirCore_exprPool_value = []
    uirCore_exprPool_binOp = []
    uirCore_exprPool_cmpOp = []
    uirCore_exprPool_lhs = []
    uirCore_exprPool_rhs = []
    uirCore_exprPool_localIndex = []
    uirCore_exprPool_callee = []
    uirCore_exprPool_args = []
    uirCore_exprPool_argStart = []
    uirCore_exprPool_argLenFlat = []
    uirCore_exprArgsFlat = []
    uirCore_exprPool_castType = []
    uirCore_exprPool_castExpr = []
    uirCore_exprPool_addrExpr = []
    uirCore_exprPool_loadType = []
    uirCore_exprPool_globalName = []
    seqs.add(uirCore_exprPool_kind, uirCoreEncodeExprKind(meConstI64))
    seqs.add(uirCore_exprPool_value, int64(0))
    seqs.add(uirCore_exprPool_binOp, uirCoreEncodeBinOp(mbAdd))
    seqs.add(uirCore_exprPool_cmpOp, uirCoreEncodeCmpOp(mcEq))
    add(uirCore_exprPool_lhs, UirExprId(0))
