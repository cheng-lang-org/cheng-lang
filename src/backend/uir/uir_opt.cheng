# Unified IR optimizer facade (phase 1): reuse MIR optimization/validation.
import std/result
import cheng/backend/uir/uir_types
import cheng/backend/mir/mir_opt
import cheng/backend/mir/mir_types

fn uirOptimizeModule(module: UirModule) =
    mirOptimizeModule(module)

fn uirValidateModule(module: UirModule): Result[bool] =
    return mirValidateModule(module)
