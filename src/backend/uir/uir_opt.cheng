    seqs.add(predStart0, soa.predEdges.len)
    seqs.add(predLen0, int32(0))
    soa.blockFirstStmt = blockFirstStmt0
    soa.blockTermKind = blockTermKind0
    soa.blockTermA = blockTermA0
    soa.blockTermB = blockTermB0
    soa.succStart = succStart0
    soa.succLen = succLen0
