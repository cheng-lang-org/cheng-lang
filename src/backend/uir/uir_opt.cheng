fn uirCoreReservePoolsForOptimize(module: UirCoreModule, level: int32) =
    let _module: UirCoreModule = module
    let _level: int32 = level
    uirCore_exprPoolInit()
    uirCore_stmtPoolInit()
    uirCore_blockPoolInit()
    let exprLen: int32 = uirCore_exprPool_kind.len
    let stmtLen: int32 = uirCore_stmtPool_kind.len
    let blockLen: int32 = uirCore_blockPool_label.len
    var exprExtra: int32 = (exprLen / 2) + (stmtLen * 4) + 4096
    var stmtExtra: int32 = (stmtLen / 2) + (blockLen * 2) + 2048
    var blockExtra: int32 = (blockLen / 2) + 1024
    if _level >= 2:
        exprExtra = exprExtra + exprLen + (blockLen * 4) + 8192
        stmtExtra = stmtExtra + (stmtLen / 2) + 4096
        blockExtra = blockExtra + (blockLen / 2) + 2048
    if _level >= 3:
        exprExtra = exprExtra + (exprLen / 2) + (stmtLen * 2) + 8192
        stmtExtra = stmtExtra + (stmtLen / 2) + 2048
        blockExtra = blockExtra + (blockLen / 2) + 1024
    uirCoreExprPoolReserve(exprLen + exprExtra)
    uirCoreStmtPoolReserve(stmtLen + stmtExtra)
    uirCoreBlockPoolReserve(blockLen + blockExtra)

fn uirCoreReservePoolsForBuild(topLevelCount: int32) =
    uirCore_exprPoolInit()
    uirCore_stmtPoolInit()
    uirCore_blockPoolInit()
    var tlCount: int32 = topLevelCount
    if tlCount < 64:
        tlCount = 64
    var exprExtra: int32 = 8192 + (tlCount * 96)
    var stmtExtra: int32 = 4096 + (tlCount * 48)
    var blockExtra: int32 = 1024 + (tlCount * 12)
    if exprExtra > 262144:
        exprExtra = 262144
    if stmtExtra > 131072:
        stmtExtra = 131072
    if blockExtra > 32768:
        blockExtra = 32768
    uirCoreExprPoolReserve(uirCore_exprPool_kind.len + exprExtra)
    uirCoreStmtPoolReserve(uirCore_stmtPool_kind.len + stmtExtra)
    uirCoreBlockPoolReserve(uirCore_blockPool_label.len + blockExtra)

fn rawmemIsNil(expr: UirExprId): bool =
    return expr <= 0

fn rawmemIsNil(blk: UirBlockId): bool =
    return blk <= 0

fn rawmemIsNil(v: int32): bool =
    return v <= 0

fn rawmemIsNil(func: UirCoreFunc): bool =
    return !uirCoreFuncIdValid(func)

fn rawmemIsNil(module: UirCoreModule): bool =
    return module == nil

fn rawmemIsNil(soa: UirCoreSoa): bool =
    return soa == nil

fn rawmemIsNil(soaMod: UirCoreSoaModule): bool =
    return soaMod == nil

fn rawmemIsNil(p: ptr): bool =
    return p == nil

fn uirCoreExprIdValid(expr: UirExprId): bool =
    if expr <= 0:
        return false
    if !uirCore_exprPool_ready:
        return false
    if expr >= uirCore_exprPool_kind.len:
        return false
    # Stage0 crash hardening: keep SoA columns in lock-step before any lookup.
    if expr >= uirCore_exprPool_value.len:
        return false
    if expr >= uirCore_exprPool_binOp.len:
        return false
    if expr >= uirCore_exprPool_cmpOp.len:
        return false
    if expr >= uirCore_exprPool_lhs.len:
        return false
    if expr >= uirCore_exprPool_rhs.len:
        return false
    if expr >= uirCore_exprPool_localIndex.len:
        return false
    if expr >= uirCore_exprPool_callee.len:
        return false
    if expr >= uirCore_exprPool_args.len:
        return false
    if expr >= uirCore_exprPool_argStart.len:
        return false
    if expr >= uirCore_exprPool_argLenFlat.len:
        return false
    if expr >= uirCore_exprPool_castType.len:
        return false
    if expr >= uirCore_exprPool_castExpr.len:
        return false
    if expr >= uirCore_exprPool_addrExpr.len:
        return false
    if expr >= uirCore_exprPool_loadType.len:
        return false
    if expr >= uirCore_exprPool_globalName.len:
        return false
    return true

fn uirCoreBlockIdValid(blk: UirBlockId): bool =
    if blk <= 0:
        return false
    if !uirCore_blockPool_ready:
        return false
    if blk >= uirCore_blockPool_label.len:
        return false
    if blk >= uirCore_blockPool_stmtStart.len:
        return false
    if blk >= uirCore_blockPool_stmtLenFlat.len:
        return false
    if blk >= uirCore_blockPool_term.len:
        return false
    return true

fn uirCoreStmtIdValid(stmt: UirStmtId): bool =
    if stmt <= 0:
        return false
    if !uirCore_stmtPool_ready:
        return false
    if stmt >= uirCore_stmtPool_kind.len:
        return false
    if stmt >= uirCore_stmtPool_name.len:
        return false
    if stmt >= uirCore_stmtPool_slot.len:
        return false
    if stmt >= uirCore_stmtPool_expr.len:
        return false
    if stmt >= uirCore_stmtPool_paramIndex.len:
        return false
    if stmt >= uirCore_stmtPool_addrExpr.len:
        return false
    if stmt >= uirCore_stmtPool_storeType.len:
        return false
    return true

fn uirCoreInvalidId(): int32 =
    return int32(-1)

fn uirCoreFuncIdValid(id: UirFuncId): bool =
    return id >= 0

fn uirCoreFuncIdValid(func: UirCoreFunc): bool =
    if func == nil:
        return false
    let rawPtrVal: int64 = uirCoreFuncRawPtrVal(func)
    if uirCoreFuncPtrKnown(rawPtrVal):
        return true
    let ptrVal: int64 = uirCoreRecoverFuncPtr(rawPtrVal)
    return uirCoreFuncPtrKnown(ptrVal)

