        candidates: int32
        ruleHits: int32
        extracted: int32
        saturatedClasses: int32
        classBudgetHit: int32

    UirEGraphStatsPtr = ptr

# ---- begin backend/uir/uir_egraph_cost.cheng ----
# UIR e-graph cost model (phase-2): deterministic objective scoring with explicit goals.

type
    UirEGraphGoalWeights =
        nodeWeight: int32
        opWeight: int32
        iterWeight: int32

fn uirEGraphNormalizeGoal(goal: str): str =
    return uirEGraphGoalNormalize(goal)

fn uirEGraphGoalWeights(goal: str): UirEGraphGoalWeights =
    let target: str = uirEGraphNormalizeGoal(goal)
    var out: UirEGraphGoalWeights
    if target == "latency":
        out.nodeWeight = 3
        out.opWeight = 5
        out.iterWeight = 1
        return out
    if target == "size":
        out.nodeWeight = 8
        out.opWeight = 2
        out.iterWeight = 1
        return out
    out.nodeWeight = 4
    out.opWeight = 3
    out.iterWeight = 1
    return out

fn uirEGraphNodeWeight(goal: str): int32 =
    return uirEGraphGoalWeights(goal).nodeWeight

fn uirEGraphOpWeight(goal: str): int32 =
    return uirEGraphGoalWeights(goal).opWeight

fn uirEGraphIterWeight(goal: str): int32 =
    return uirEGraphGoalWeights(goal).iterWeight

fn uirEGraphGoalWeightSignature(goal: str): str =
    let target: str = uirEGraphNormalizeGoal(goal)
    let weights: UirEGraphGoalWeights = uirEGraphGoalWeights(target)
    return target + ".n" + intToStr(weights.nodeWeight) + "_o" + intToStr(weights.opWeight) + "_i" + intToStr(weights.iterWeight)

fn uirEGraphScore(goal: str, nodeCount: int32, opCost: int32, iterBudget: int32): int32 =
    let target: str = uirEGraphNormalizeGoal(goal)
    var n: int32 = nodeCount
    var o: int32 = opCost
    var b: int32 = iterBudget
    if n < 0:
        n = 0
    if o < 0:
        o = 0
    if b <= 0:
        b = 1
    let weights: UirEGraphGoalWeights = uirEGraphGoalWeights(target)
    # Goal-specific linear objective with explicit weights for audit/regression.
    return n * weights.nodeWeight + o * weights.opWeight + b * weights.iterWeight

fn uirEGraphCostAccept(goal: str, oldScore: int32, newScore: int32, oldNodes: int32, newNodes: int32): bool =
    if oldScore < 0 || newScore < 0:
        return false
    if newScore < oldScore:
        return true
    if newScore > oldScore:
        return false
    let target: str = uirEGraphNormalizeGoal(goal)
    if target == "size":
        return newNodes <= oldNodes
    return newNodes <= oldNodes
# ---- end backend/uir/uir_egraph_cost.cheng ----

# ---- begin backend/uir/uir_loop_analysis.cheng ----
# UIR loop analysis: deterministic back-edge based loop discovery.

type
    UirLoopSpan =
        funcIndex: int32
        headerBlock: int32
        latchBlock: int32

    UirLoopInfo =
        loopCount: int32
        reducibleCount: int32
        backEdgeCount: int32
        spans: UirLoopSpan[]

fn uirLoopSpanAppend(info: var UirLoopInfo, span: UirLoopSpan) =
    let idx: int32 = info.spans.len
    let needLen: int32 = idx + 1
    if info.spans.buffer == nil || info.spans.cap < needLen:
        cheng__seqGrowToRaw(&info.spans.buffer, &info.spans.cap, needLen, int32(sizeof UirLoopSpan))
    info.spans.len = needLen
    info.spans[idx] = span

fn uirLoopSpanExists(spans: UirLoopSpan[], funcIndex: int32, headerBlock: int32, latchBlock: int32): bool =
    for i in 0..<spans.len:
        let s: UirLoopSpan = spans[i]
        if s.funcIndex == funcIndex && s.headerBlock == headerBlock && s.latchBlock == latchBlock:
            return true
    return false

fn uirLoopFindBlockByLabel(func: UirCoreFunc, label: str): int32 =
    if (!uirCoreFuncIdValid(func)) || len(label) == 0:
        return int32(-1)
    let blockCount: int32 = uirCoreFuncBlocksLen(func)
    for bi in 0..<blockCount:
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        if uirStrCmp(uirCoreBlockLabelOf(blk), label) == 0:
            return bi
    return int32(-1)

fn uirLoopRecordBackEdge(info: var UirLoopInfo, funcIndex: int32, latchBlock: int32, headerBlock: int32) =
    if latchBlock < 0 || headerBlock < 0:
        return
    if headerBlock > latchBlock:
        return
    info.backEdgeCount = info.backEdgeCount + 1
    if uirLoopSpanExists(info.spans, funcIndex, headerBlock, latchBlock):
        return
    var span: UirLoopSpan
    span.funcIndex = funcIndex
    span.headerBlock = headerBlock
    span.latchBlock = latchBlock
    uirLoopSpanAppend(info, span)
    info.loopCount = info.loopCount + 1
    info.reducibleCount = info.reducibleCount + 1

fn uirLoopInfoHasLoopInFunc(info: UirLoopInfo, funcIndex: int32): bool =
    for i in 0..<info.spans.len:
        if info.spans[i].funcIndex == funcIndex:
            return true
    return false

fn uirLoopInfoBlockIsInLoopWindow(info: UirLoopInfo, funcIndex: int32, blockIndex: int32): bool =
    for i in 0..<info.spans.len:
        let s: UirLoopSpan = info.spans[i]
        if s.funcIndex != funcIndex:
            continue
        if blockIndex >= s.headerBlock && blockIndex <= s.latchBlock:
            return true
    return false

fn uirAnalyzeLoops(module: UirModule): UirLoopInfo =
    var info: UirLoopInfo
    info.loopCount = 0
    info.reducibleCount = 0
    info.backEdgeCount = 0
    info.spans = []
    if module == nil:
        return info
    for fi in 0..<uirModuleFuncsLen(module):
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if funcView == nil || uirFuncIsExtern(funcView):
            continue
        let func: UirCoreFunc = funcView
        let blockCount: int32 = uirCoreFuncBlocksLen(func)
        for bi in 0..<blockCount:
            let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
            if blk <= 0:
                continue
            let term: UirCoreTerm = uirCoreBlockTermOf(blk)
            if uirCoreTermKindOf(term) == mtBr:
                let dst: int32 = uirLoopFindBlockByLabel(func, uirCoreTermTargetOf(term))
                uirLoopRecordBackEdge(info, fi, bi, dst)
            elif uirCoreTermKindOf(term) == mtCbr:
                let dstTrue: int32 = uirLoopFindBlockByLabel(func, uirCoreTermTargetTrueOf(term))
                let dstFalse: int32 = uirLoopFindBlockByLabel(func, uirCoreTermTargetFalseOf(term))
                uirLoopRecordBackEdge(info, fi, bi, dstTrue)
                uirLoopRecordBackEdge(info, fi, bi, dstFalse)
    return info
# ---- end backend/uir/uir_loop_analysis.cheng ----

# ---- begin backend/uir/uir_vec_cost.cheng ----
# UIR vectorization cost model: loop/arith density based deterministic scoring.

type
    UirVecCostDecision =
        enable: bool
        width: int32
        loopCount: int32
        arithmeticExprCount: int32
        score: int32

fn uirVecCountExprArith(expr: UirExpr): int32 =
    if expr <= 0:
        return 0
    let kind: UirExprKind = uirExprKindOf(expr)
    var selfCost: int32 = 0
    if kind == meBin || kind == meCmp:
        selfCost = 1
    if kind == meBin || kind == meCmp:
        return selfCost + uirVecCountExprArith(uirExprLhsOf(expr)) + uirVecCountExprArith(uirExprRhsOf(expr))
    if kind == meCall:
        var sum: int32 = selfCost
        for ai in 0..<uirExprArgsLen(expr):
            sum = sum + uirVecCountExprArith(uirExprArgAt(expr, ai))
        return sum
    if kind == meCast:
        return selfCost + uirVecCountExprArith(uirExprCastExprOf(expr))
    if kind == meLoad:
        return selfCost + uirVecCountExprArith(uirExprAddrExprOf(expr))
    return selfCost

fn uirVecCountModuleArith(module: UirModule): int32 =
    if module == nil:
        return 0
    var total: int32 = 0
    for fi in 0..<uirModuleFuncsLen(module):
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if funcView == nil || uirFuncIsExtern(funcView):
            continue
        let func: UirCoreFunc = funcView
        let blockCount: int32 = uirCoreFuncBlocksLen(func)
        for bi in 0..<blockCount:
            let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
            if blk <= 0:
                continue
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            for si in 0..<stmtCount:
                let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                total = total + uirVecCountExprArith(uirCoreStmtExprOf(st))
                if uirCoreStmtKindOf(st) == msStore:
                    total = total + uirVecCountExprArith(uirCoreStmtAddrExprOf(st))
            let term: UirCoreTerm = uirCoreBlockTermOf(blk)
            if uirCoreTermKindOf(term) == mtRet:
                total = total + uirVecCountExprArith(uirCoreTermRetExprOf(term))
            elif uirCoreTermKindOf(term) == mtCbr:
                total = total + uirVecCountExprArith(uirCoreTermCondExprOf(term))
    return total

fn uirVecClampWidth(width: int32): int32 =
    if width <= 0:
        return 0
    if width >= 16:
        return 16
    if width >= 8:
        return 8
    if width >= 4:
        return 4
    if width >= 2:
        return 2
    return 1

fn uirDecideVecWidth(module: UirModule, maxWidth: int32): UirVecCostDecision =
    var d: UirVecCostDecision
    d.enable = false
    d.width = 0
    d.loopCount = 0
    d.arithmeticExprCount = 0
    d.score = 0
    if module == nil || maxWidth <= 0:
        return d
    let loopInfo: UirLoopInfo = uirAnalyzeLoops(module)
    let arithCount: int32 = uirVecCountModuleArith(module)
    d.loopCount = loopInfo.loopCount
    d.arithmeticExprCount = arithCount
    if arithCount <= 0:
        return d
    # Deterministic score: loop pressure dominates, arithmetic density refines.
    d.score = loopInfo.loopCount * 32 + arithCount
    var desired: int32 = 0
    if loopInfo.loopCount <= 0:
        # Fallback when loop windows are not recovered yet: keep conservative
        # width=2 so late vector passes can still canonicalize arithmetic trees.
        if arithCount >= 4:
            desired = 2
    else:
        desired = 2
        if d.score >= 128:
            desired = 8
        elif d.score >= 64:
            desired = 4
        elif d.score >= 24:
            desired = 2
    if desired > maxWidth:
        desired = maxWidth
    desired = uirVecClampWidth(desired)
    if desired <= 1:
        return d
    d.enable = true
    d.width = desired
    return d
# ---- end backend/uir/uir_vec_cost.cheng ----

# ---- begin backend/uir/uir_vectorize_loop.cheng ----
# UIR loop vectorization: deterministic reassociation pass for loop-carried arithmetic.

fn uirLoopVecReadI32(p: ptr): int32 =
    if p == nil:
        return 0
    var out: int32 = 0
    memCopyCompat(&out, p, int32(sizeof int32))
    return out

fn uirLoopVecWriteI32(p: ptr, value: int32) =
    if p == nil:
        return
    var tmp: int32 = value
    memCopyCompat(p, &tmp, int32(sizeof int32))

fn add(dst: var UirExpr[], val: UirExpr) =
    seqs.add(dst, val)

fn uirLoopVecWriteBlock(seqInst: UirBlockId[]*, idx: int32, val: UirBlockId) =
    if seqInst == nil || idx < 0 || idx >= seqInst->len:
        return
    uirCoreWriteBlock(seqInst, idx, val)

fn uirLoopVecPolicyNormalize(policy: str): str =
    let raw: str = strutils.toLowerAscii(strutils.strip(policy))
    if raw == "":
        return "autovec"
    return raw

fn uirLoopVecAssocBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirLoopVecExprKeyInner(expr: UirExpr, depth: ptr): str =
    if expr <= 0:
        return "nil"
    if depth == nil:
        return "depth_nil"
    if uirLoopVecReadI32(depth) >= 128:
        return "depth_limit"
    uirLoopVecWriteI32(depth, uirLoopVecReadI32(depth) + 1)
    let kind: UirExprKind = uirExprKindOf(expr)
    var parts: str[]
    seqs.add(parts, "k")
    seqs.add(parts, intToStr(int32(kind)))
    if kind == meConstI64:
        seqs.add(parts, ":v")
        seqs.add(parts, intToStr(int32(uirExprConstValueOf(expr) & 2147483647)))
    elif kind == meLocal || kind == meAddr:
        seqs.add(parts, ":l")
        seqs.add(parts, intToStr(uirExprLocalIndexOf(expr)))
    elif kind == meGlobalAddr:
        seqs.add(parts, ":g")
        seqs.add(parts, uirExprGlobalNameOf(expr))
    elif kind == meBin:
        seqs.add(parts, ":b")
        seqs.add(parts, intToStr(int32(uirExprBinOpOf(expr))))
        seqs.add(parts, "(")
        seqs.add(parts, uirLoopVecExprKeyInner(uirExprLhsOf(expr), depth))
        seqs.add(parts, ",")
        seqs.add(parts, uirLoopVecExprKeyInner(uirExprRhsOf(expr), depth))
        seqs.add(parts, ")")
    elif kind == meCmp:
        seqs.add(parts, ":c")
        seqs.add(parts, intToStr(int32(uirExprCmpOpOf(expr))))
        seqs.add(parts, "(")
        seqs.add(parts, uirLoopVecExprKeyInner(uirExprLhsOf(expr), depth))
        seqs.add(parts, ",")
        seqs.add(parts, uirLoopVecExprKeyInner(uirExprRhsOf(expr), depth))
        seqs.add(parts, ")")
    elif kind == meCast:
        seqs.add(parts, ":cast(")
        seqs.add(parts, uirLoopVecExprKeyInner(uirExprCastExprOf(expr), depth))
        seqs.add(parts, ")")
    elif kind == meLoad:
        seqs.add(parts, ":load(")
        seqs.add(parts, uirLoopVecExprKeyInner(uirExprAddrExprOf(expr), depth))
        seqs.add(parts, ")")
    elif kind == meCall:
        seqs.add(parts, ":call(")
        seqs.add(parts, uirExprCalleeOf(expr))
        seqs.add(parts, ")")
    uirLoopVecWriteI32(depth, uirLoopVecReadI32(depth) - 1)
    return strutils.join(parts, "")

fn uirLoopVecExprKey(expr: UirExpr): str =
    var depth: int32 = 0
    return uirLoopVecExprKeyInner(expr, &depth)

fn uirLoopVecExprPureLeaf(expr: UirExpr): bool =
    if expr <= 0:
        return false
    let kind: UirExprKind = uirExprKindOf(expr)
    if kind == meConstI64 || kind == meLocal || kind == meAddr || kind == meGlobalAddr:
        return true
    return false

fn uirLoopVecCollectAssoc(expr: UirExpr, op: UirBinOp, out: UirExpr[]): bool =
    if expr <= 0:
        return false
    if uirExprKindOf(expr) == meBin && uirExprBinOpOf(expr) == op:
        if !uirLoopVecCollectAssoc(uirExprLhsOf(expr), op, out):
            return false
        if !uirLoopVecCollectAssoc(uirExprRhsOf(expr), op, out):
            return false
        return true
    if !uirLoopVecExprPureLeaf(expr):
        return false
    add(out, expr)
    return true

fn uirLoopVecBuildBalanced(op: UirBinOp, terms: UirExpr[], lo: int32, hi: int32): UirExpr =
    if hi <= lo:
        return nil
    if hi - lo == 1:
        return terms[lo]
    let mid: int32 = lo + ((hi - lo) / 2)
    let lhs: UirExpr = uirLoopVecBuildBalanced(op, terms, lo, mid)
    let rhs: UirExpr = uirLoopVecBuildBalanced(op, terms, mid, hi)
    return uirCoreBin(op, lhs, rhs)

fn uirLoopVecRebalanceExpr(expr: UirExpr, width: int32, changedExprs: ptr): UirExpr =
    if expr <= 0:
        return nil
    let kind: UirExprKind = uirExprKindOf(expr)
    var cur: UirExprId = expr
    if kind == meBin || kind == meCmp:
        uirCoreExprSetLhs(cur, uirLoopVecRebalanceExpr(uirCoreExprLhsOf(cur), width, changedExprs))
        uirCoreExprSetRhs(cur, uirLoopVecRebalanceExpr(uirCoreExprRhsOf(cur), width, changedExprs))
    elif kind == meCall:
        for ai in 0..<uirCoreExprArgsLen(cur):
            uirCoreExprSetArgAt(cur, ai, uirLoopVecRebalanceExpr(uirCoreExprArgAt(cur, ai), width, changedExprs))
    elif kind == meCast:
        uirCoreExprSetCastExpr(cur, uirLoopVecRebalanceExpr(uirCoreExprCastExprOf(cur), width, changedExprs))
    elif kind == meLoad:
        uirCoreExprSetAddrExpr(cur, uirLoopVecRebalanceExpr(uirCoreExprAddrExprOf(cur), width, changedExprs))

    if kind != meBin:
        return cur
    let op: UirBinOp = uirExprBinOpOf(cur)
    if !uirLoopVecAssocBin(op):
        return cur
    var terms: UirExpr[]
    if !uirLoopVecCollectAssoc(cur, op, terms):
        return cur
    if terms.len < width:
        return cur
    let beforeKey: str = uirLoopVecExprKey(cur)
    let cand: UirExpr = uirLoopVecBuildBalanced(op, terms, 0, terms.len)
    let afterKey: str = uirLoopVecExprKey(cand)
    if uirStrCmp(beforeKey, afterKey) == 0:
        return cur
    if changedExprs != nil:
        *changedExprs = *changedExprs + 1
    return cand

fn uirVectorizeLoops(module: UirModule, maxWidth: int32, policy: str): bool =
    if module == nil:
        return false
    let policyNorm: str = uirLoopVecPolicyNormalize(policy)
    if policyNorm == "none" || policyNorm == "slp":
        return false
    let loops: UirLoopInfo = uirAnalyzeLoops(module)
    let restrictToLoopWindows: bool = loops.loopCount > 0
    let d: UirVecCostDecision = uirDecideVecWidth(module, maxWidth)
    if !d.enable || d.width <= 1:
        return false
    var changed: bool = false
    var vectorizedBlocks: int32 = 0
    var vectorizedExprs: int32 = 0
    for fi in 0..<uirModuleFuncsLen(module):
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if funcView == nil || uirFuncIsExtern(funcView):
            continue
        if restrictToLoopWindows && !uirLoopInfoHasLoopInFunc(loops, fi):
            continue
        let func: UirCoreFunc = funcView
        let blockCount: int32 = uirCoreFuncBlocksLen(func)
        for bi in 0..<blockCount:
            if restrictToLoopWindows && !uirLoopInfoBlockIsInLoopWindow(loops, fi, bi):
                continue
            let blkView: UirLowerBlock = uirCoreFuncBlockAt(func, bi)
            if blkView <= 0:
                continue
            var blk: UirBlockId = blkView
            let beforeExprs: int32 = vectorizedExprs
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            for si in 0..<stmtCount:
                var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                st = uirCoreStmtWithExpr(st, uirLoopVecRebalanceExpr(uirCoreStmtExprOf(st), d.width, &vectorizedExprs))
                if uirCoreStmtKindOf(st) == msStore:
                    st = uirCoreStmtWithAddrExpr(st, uirLoopVecRebalanceExpr(uirCoreStmtAddrExprOf(st), d.width, &vectorizedExprs))
                uirCoreBlockSetStmtAt(blk, si, st)
            let term: UirCoreTerm = uirCoreBlockTermOf(blk)
            if uirCoreTermKindOf(term) == mtRet:
                uirCoreBlockSetTerm(blk, uirCoreTermWithRetExpr(
                    term, uirLoopVecRebalanceExpr(uirCoreTermRetExprOf(term), d.width, &vectorizedExprs)))
            elif uirCoreTermKindOf(term) == mtCbr:
                uirCoreBlockSetTerm(blk, uirCoreTermWithCondExpr(
                    term, uirLoopVecRebalanceExpr(uirCoreTermCondExprOf(term), d.width, &vectorizedExprs)))
            if vectorizedExprs > beforeExprs:
                vectorizedBlocks = vectorizedBlocks + 1
                changed = true
            uirCoreFuncSetBlockAt(func, bi, blk)
    if uirOptEnvIsTrue("UIR_SIMD_REPORT"):
        let f: UirOptFile = uirOptGetStderr()
        uirOptWrite(f, "simd_loop_report\tpolicy=")
        uirOptWrite(f, policyNorm)
        uirOptWrite(f, "\twidth=")
        uirOptWrite(f, intToStr(d.width))
        uirOptWrite(f, "\tloops=")
        uirOptWrite(f, intToStr(loops.loopCount))
        uirOptWrite(f, "\tbackedges=")
        uirOptWrite(f, intToStr(loops.backEdgeCount))
        uirOptWrite(f, "\treducible=")
        uirOptWrite(f, intToStr(loops.reducibleCount))
        uirOptWrite(f, "\tvec_blocks=")
        uirOptWrite(f, intToStr(vectorizedBlocks))
        uirOptWrite(f, "\tvec_exprs=")
        uirOptWrite(f, intToStr(vectorizedExprs))
        uirOptWrite(f, "\tscore=")
        uirOptWriteLine(f, intToStr(d.score))
        uirOptFFlush(f)
    return changed
# ---- end backend/uir/uir_vectorize_loop.cheng ----

# ---- begin backend/uir/uir_vectorize_slp.cheng ----
# UIR SLP vectorization: deterministic tree packing/canonicalization for
# straight-line arithmetic expressions.

fn uirSlpReadI32(p: ptr): int32 =
    if p == nil:
        return 0
    var out: int32 = 0
    memCopyCompat(&out, p, int32(sizeof int32))
    return out

fn uirSlpWriteI32(p: ptr, value: int32) =
    if p == nil:
        return
    var tmp: int32 = value
    memCopyCompat(p, &tmp, int32(sizeof int32))

fn add(dst: var UirExpr[], val: UirExpr) =
    seqs.add(dst, val)

fn uirSlpWriteBlock(seqInst: UirBlockId[]*, idx: int32, val: UirBlockId) =
    if seqInst == nil || idx < 0 || idx >= seqInst->len:
        return
    uirCoreWriteBlock(seqInst, idx, val)

fn uirSlpPolicyNormalize(policy: str): str =
    let raw: str = strutils.toLowerAscii(strutils.strip(policy))
    if raw == "":
        return "autovec"
    return raw

fn uirSlpAssocBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirSlpCommutativeBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirSlpExprKeyInner(expr: UirExpr, depth: ptr): str =
    if expr <= 0:
        return "nil"
    if depth == nil:
        return "depth_nil"
    if uirSlpReadI32(depth) >= 128:
        return "depth_limit"
    uirSlpWriteI32(depth, uirSlpReadI32(depth) + 1)
    let k: UirExprKind = uirExprKindOf(expr)
    var parts: str[]
    seqs.add(parts, "k")
    seqs.add(parts, intToStr(int32(k)))
    if k == meConstI64:
        seqs.add(parts, ":v")
        seqs.add(parts, intToStr(int32(uirExprConstValueOf(expr) & 2147483647)))
    elif k == meLocal || k == meAddr:
        seqs.add(parts, ":l")
        seqs.add(parts, intToStr(uirExprLocalIndexOf(expr)))
    elif k == meGlobalAddr:
        seqs.add(parts, ":g")
        seqs.add(parts, uirExprGlobalNameOf(expr))
    elif k == meBin:
        seqs.add(parts, ":b")
        seqs.add(parts, intToStr(int32(uirExprBinOpOf(expr))))
        seqs.add(parts, "(")
        seqs.add(parts, uirSlpExprKeyInner(uirExprLhsOf(expr), depth))
        seqs.add(parts, ",")
        seqs.add(parts, uirSlpExprKeyInner(uirExprRhsOf(expr), depth))
        seqs.add(parts, ")")
    elif k == meCmp:
        seqs.add(parts, ":c")
        seqs.add(parts, intToStr(int32(uirExprCmpOpOf(expr))))
        seqs.add(parts, "(")
        seqs.add(parts, uirSlpExprKeyInner(uirExprLhsOf(expr), depth))
        seqs.add(parts, ",")
        seqs.add(parts, uirSlpExprKeyInner(uirExprRhsOf(expr), depth))
        seqs.add(parts, ")")
    elif k == meCast:
        seqs.add(parts, ":cast(")
        seqs.add(parts, uirSlpExprKeyInner(uirExprCastExprOf(expr), depth))
        seqs.add(parts, ")")
    elif k == meLoad:
        seqs.add(parts, ":load(")
        seqs.add(parts, uirSlpExprKeyInner(uirExprAddrExprOf(expr), depth))
        seqs.add(parts, ")")
    elif k == meCall:
        seqs.add(parts, ":call(")
        seqs.add(parts, uirExprCalleeOf(expr))
        seqs.add(parts, ")")
    uirSlpWriteI32(depth, uirSlpReadI32(depth) - 1)
    return strutils.join(parts, "")

fn uirSlpExprKey(expr: UirExpr): str =
    var depth: int32 = 0
    return uirSlpExprKeyInner(expr, &depth)

fn uirSlpExprPureLeaf(expr: UirExpr): bool =
    if expr <= 0:
        return false
    let kind: UirExprKind = uirExprKindOf(expr)
    if kind == meConstI64 || kind == meLocal || kind == meAddr || kind == meGlobalAddr:
        return true
    return false

fn uirSlpCollectAssoc(expr: UirExpr, op: UirBinOp, out: UirExpr[]): bool =
    if expr <= 0:
        return false
    if uirExprKindOf(expr) == meBin && uirExprBinOpOf(expr) == op:
        if !uirSlpCollectAssoc(uirExprLhsOf(expr), op, out):
            return false
        if !uirSlpCollectAssoc(uirExprRhsOf(expr), op, out):
            return false
        return true
    if !uirSlpExprPureLeaf(expr):
        return false
    add(out, expr)
    return true

fn uirSlpSortTermsByKey(terms: UirExpr[]) =
    if terms.len <= 1:
        return
    for i in 1..<terms.len:
        let v: UirExpr = terms[i]
        let vKey: str = uirSlpExprKey(v)
        var j: int32 = i - 1
        while j >= 0:
            let k: str = uirSlpExprKey(terms[j])
            if uirStrCmp(k, vKey) <= 0:
                break
            terms[j + 1] = terms[j]
            j = j - 1
        terms[j + 1] = v

fn uirSlpBuildBalanced(op: UirBinOp, terms: UirExpr[], lo: int32, hi: int32): UirExpr =
    if hi <= lo:
        return nil
    if hi - lo == 1:
        return terms[lo]
    let mid: int32 = lo + ((hi - lo) / 2)
    let lhs: UirExpr = uirSlpBuildBalanced(op, terms, lo, mid)
    let rhs: UirExpr = uirSlpBuildBalanced(op, terms, mid, hi)
    return uirCoreBin(op, lhs, rhs)

fn uirSlpRewriteExpr(expr: UirExpr,
                     width: int32,
                     packedExprs: ptr,
                     clusters: ptr): UirExpr =
    if expr <= 0:
        return nil
    let k: UirExprKind = uirExprKindOf(expr)
    var cur: UirExprId = expr
    if k == meBin || k == meCmp:
        uirCoreExprSetLhs(cur, uirSlpRewriteExpr(uirCoreExprLhsOf(cur), width, packedExprs, clusters))
        uirCoreExprSetRhs(cur, uirSlpRewriteExpr(uirCoreExprRhsOf(cur), width, packedExprs, clusters))
    elif k == meCall:
        for ai in 0..<uirCoreExprArgsLen(cur):
            uirCoreExprSetArgAt(cur, ai, uirSlpRewriteExpr(uirCoreExprArgAt(cur, ai), width, packedExprs, clusters))
    elif k == meCast:
        uirCoreExprSetCastExpr(cur, uirSlpRewriteExpr(uirCoreExprCastExprOf(cur), width, packedExprs, clusters))
    elif k == meLoad:
        uirCoreExprSetAddrExpr(cur, uirSlpRewriteExpr(uirCoreExprAddrExprOf(cur), width, packedExprs, clusters))

    if k == meCmp:
        let op: UirCmpOp = uirExprCmpOpOf(cur)
        if op == mcEq || op == mcNe:
            let lhsKey: str = uirSlpExprKey(uirCoreExprLhsOf(cur))
            let rhsKey: str = uirSlpExprKey(uirCoreExprRhsOf(cur))
            if uirStrCmp(rhsKey, lhsKey) < 0:
                let tmp: UirExpr = uirCoreExprLhsOf(cur)
                uirCoreExprSetLhs(cur, uirCoreExprRhsOf(cur))
                uirCoreExprSetRhs(cur, tmp)
                if packedExprs != nil:
                    *packedExprs = *packedExprs + 1
                if clusters != nil:
                    *clusters = *clusters + 1
        return cur

    if k != meBin:
        return cur
    let op: UirBinOp = uirExprBinOpOf(cur)
    if !uirSlpAssocBin(op):
        return cur
    var terms: UirExpr[]
    if !uirSlpCollectAssoc(cur, op, terms):
        if uirSlpCommutativeBin(op):
            let lhsKey: str = uirSlpExprKey(uirCoreExprLhsOf(cur))
            let rhsKey: str = uirSlpExprKey(uirCoreExprRhsOf(cur))
            if uirStrCmp(rhsKey, lhsKey) < 0:
                let tmp: UirExpr = uirCoreExprLhsOf(cur)
                uirCoreExprSetLhs(cur, uirCoreExprRhsOf(cur))
                uirCoreExprSetRhs(cur, tmp)
                if packedExprs != nil:
                    *packedExprs = *packedExprs + 1
            return cur
        return cur
    if terms.len < 2:
        return cur
    if uirSlpCommutativeBin(op):
        uirSlpSortTermsByKey(terms)
    let beforeKey: str = uirSlpExprKey(cur)
    let cand: UirExpr = uirSlpBuildBalanced(op, terms, 0, terms.len)
    let afterKey: str = uirSlpExprKey(cand)
    if uirStrCmp(beforeKey, afterKey) == 0:
        return cur
    if terms.len >= width && clusters != nil:
        *clusters = *clusters + 1
    if packedExprs != nil:
        *packedExprs = *packedExprs + 1
    return cand

fn uirSlpLooksPackable(expr: UirExpr): bool =
    if expr <= 0 || uirExprKindOf(expr) != meBin:
        return false
    let op: UirBinOp = uirExprBinOpOf(expr)
    if !uirSlpAssocBin(op):
        return false
    let lhs: UirExpr = uirExprLhsOf(expr)
    let rhs: UirExpr = uirExprRhsOf(expr)
    return uirSlpExprPureLeaf(lhs) && uirSlpExprPureLeaf(rhs)

fn uirVectorizeSlp(module: UirModule, maxWidth: int32, policy: str): bool =
    if module == nil:
        return false
    if maxWidth <= 0:
        return false
    let policyNorm: str = uirSlpPolicyNormalize(policy)
    if policyNorm == "none" || policyNorm == "loop":
        return false
    let d: UirVecCostDecision = uirDecideVecWidth(module, maxWidth)
    if !d.enable || d.width <= 1:
        return false

    var changed: bool = false
    var vectorizedBlocks: int32 = 0
    var packedExprs: int32 = 0
    var clusters: int32 = 0
    for fi in 0..<uirModuleFuncsLen(module):
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if funcView == nil || uirFuncIsExtern(funcView):
            continue
        let func: UirCoreFunc = funcView
        let blockCount: int32 = uirCoreFuncBlocksLen(func)
        for bi in 0..<blockCount:
            let blkView: UirLowerBlock = uirCoreFuncBlockAt(func, bi)
            if blkView <= 0:
                continue
            var blk: UirBlockId = blkView
            let beforePacked: int32 = packedExprs
            var prevPackable: bool = false
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            for si in 0..<stmtCount:
                var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                let thisPackable: bool = uirSlpLooksPackable(uirCoreStmtExprOf(st))
                st = uirCoreStmtWithExpr(st, uirSlpRewriteExpr(uirCoreStmtExprOf(st), d.width, &packedExprs, &clusters))
                if uirCoreStmtKindOf(st) == msStore:
                    st = uirCoreStmtWithAddrExpr(st, uirSlpRewriteExpr(uirCoreStmtAddrExprOf(st), d.width, &packedExprs, &clusters))
                uirCoreBlockSetStmtAt(blk, si, st)
                if thisPackable && prevPackable:
                    clusters = clusters + 1
                prevPackable = thisPackable
            let term: UirCoreTerm = uirCoreBlockTermOf(blk)
            if uirCoreTermKindOf(term) == mtRet:
                uirCoreBlockSetTerm(blk, uirCoreTermWithRetExpr(
                    term, uirSlpRewriteExpr(uirCoreTermRetExprOf(term), d.width, &packedExprs, &clusters)))
            elif uirCoreTermKindOf(term) == mtCbr:
                uirCoreBlockSetTerm(blk, uirCoreTermWithCondExpr(
                    term, uirSlpRewriteExpr(uirCoreTermCondExprOf(term), d.width, &packedExprs, &clusters)))
            if packedExprs > beforePacked:
                vectorizedBlocks = vectorizedBlocks + 1
                changed = true
            uirCoreFuncSetBlockAt(func, bi, blk)

    if uirOptEnvIsTrue("UIR_SIMD_REPORT"):
        let f: UirOptFile = uirOptGetStderr()
        uirOptWrite(f, "simd_slp_report\tpolicy=")
        uirOptWrite(f, policyNorm)
        uirOptWrite(f, "\twidth=")
        uirOptWrite(f, intToStr(d.width))
        uirOptWrite(f, "\tloops=")
        uirOptWrite(f, intToStr(d.loopCount))
        uirOptWrite(f, "\tarith=")
        uirOptWrite(f, intToStr(d.arithmeticExprCount))
        uirOptWrite(f, "\tvec_blocks=")
        uirOptWrite(f, intToStr(vectorizedBlocks))
        uirOptWrite(f, "\tpacked_exprs=")
        uirOptWrite(f, intToStr(packedExprs))
        uirOptWrite(f, "\tclusters=")
        uirOptWrite(f, intToStr(clusters))
        uirOptWrite(f, "\tscore=")
        uirOptWriteLine(f, intToStr(d.score))
        uirOptFFlush(f)
    return changed
# ---- end backend/uir/uir_vectorize_slp.cheng ----

# ---- begin backend/uir/uir_pass_manager.cheng ----
# UIR pass manager facade (phase-1): centralized optimization scheduling knobs.

fn uirRunLateVectorPasses(module: UirModule, optLevel: int32, simdEnabled: bool,
                          simdMaxWidth: int32, simdPolicy: str): bool =
    if module == nil:
        return false
    # Allow vectorization at opt2+ so loop fixtures can be covered even when
    # opt3-only SSA pipelines are unstable on specific hosts.
    if optLevel < 2:
        return false
    if !simdEnabled:
        return false
    var changed: bool = false
    if uirVectorizeLoops(module, simdMaxWidth, simdPolicy):
        changed = true
    if uirVectorizeSlp(module, simdMaxWidth, simdPolicy):
        changed = true
    return changed
# ---- end backend/uir/uir_pass_manager.cheng ----

# ---- begin backend/uir/uir_noalias_pass.cheng ----
# UIR no-alias preparation pass (phase-2):
# - conservative block-local load/store forwarding
# - conservative local mem2reg for resolved stack slots
# - NJVL-lite (unknown + kill-lite) optional mode

fn add(dst: var UirExpr[], val: UirExpr) =
    seqs.add(dst, val)

fn add(dst: var bool[], val: bool) =
    seqs.add(dst, val)

fn add(dst: var int32[], val: int32) =
    seqs.add(dst, val)

fn uirNoAliasInitExprSeq(n: int32): UirExpr[] =
    var out: UirExpr[]
    if n > 0:
        setLen(out, n)
    return out

fn uirNoAliasInitBoolSeq(n: int32, value: bool): bool[] =
    var out: bool[]
    if n <= 0:
        return out
    setLen(out, n)
    if value:
        for i in 0..<n:
            out[i] = true
    return out

fn uirNoAliasInitI32Seq(n: int32, value: int32): int32[] =
    var out: int32[]
    if n <= 0:
        return out
    setLen(out, n)
    if value != 0:
        for i in 0..<n:
            out[i] = value
    return out

fn uirNoAliasInvalidateKnown(knownValid: var bool[]) =
    for i in 0..<knownValid.len:
        knownValid[i] = false

fn uirNoAliasInvalidatePtrBase(ptrBase: var int32[]) =
    for i in 0..<ptrBase.len:
        ptrBase[i] = -1

fn uirNoAliasDisablePromotable(promotable: var bool[]) =
    for i in 0..<promotable.len:
        promotable[i] = false

fn uirNoAliasInvalidateAll(knownValid: var bool[], ptrBase: var int32[], promotable: var bool[]) =
    uirNoAliasInvalidateKnown(knownValid)
    uirNoAliasInvalidatePtrBase(ptrBase)
    uirNoAliasDisablePromotable(promotable)

fn uirNoAliasIsObjSlot(func: UirCoreFunc, slot: int32): bool =
    if (!uirCoreFuncIdValid(func)) || slot < 0:
        return false
    for i in 0..<uirCoreFuncObjLocalsLen(func):
        let ol: UirObjLocal = uirCoreFuncObjLocalAt(func, i)
        if ol.slot == slot:
            return true
    return false

fn uirNoAliasBuildObjSlotFlags(func: UirCoreFunc, localCount: int32): bool[] =
    var flags: bool[] = uirNoAliasInitBoolSeq(localCount, false)
    if (!uirCoreFuncIdValid(func)) || localCount <= 0:
        return flags
    for i in 0..<uirCoreFuncObjLocalsLen(func):
        let ol: UirObjLocal = uirCoreFuncObjLocalAt(func, i)
        if ol.slot >= 0 && ol.slot < localCount:
            flags[ol.slot] = true
    return flags

fn uirNoAliasEnsureName(name: str, slot: int32): str =
    if len(name) > 0:
        return name
    return "__na_l" + intToStr(slot)

fn uirNoAliasResolveAddrBaseSlotInner(addrExpr: UirExpr, ptrBase: int32[], depth: var int32): int32 =
    if (addrExpr <= 0):
        return -1
    if depth >= uirExprRecursionLimit():
        return -1
    depth = depth + 1
    var out: int32 = -1
    let k: UirExprKind = uirExprKindOf(addrExpr)
    if k == meAddr:
        out = uirExprLocalIndexOf(addrExpr)
    elif k == meLocal:
        let slot: int32 = uirExprLocalIndexOf(addrExpr)
        if slot >= 0 && slot < ptrBase.len:
            out = ptrBase[slot]
        else:
            out = -1
    elif k == meCast:
        out = uirNoAliasResolveAddrBaseSlotInner(uirExprCastExprOf(addrExpr), ptrBase, depth)
    else:
        out = -1
    depth = depth - 1
    return out

fn uirNoAliasResolveAddrBaseSlot(addrExpr: UirExpr, ptrBase: int32[]): int32 =
    var depth: int32 = 0
    return uirNoAliasResolveAddrBaseSlotInner(addrExpr, ptrBase, depth)

fn uirNoAliasExprStableInner(expr: UirExpr, depth: var int32): bool =
    if (expr <= 0):
        return false
    if depth >= uirExprRecursionLimit():
        return false
    depth = depth + 1
    var out: bool = false
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meConstI64 || k == meLocal || k == meAddr || k == meGlobalAddr:
        out = true
    elif k == meCall || k == meLoad:
        out = false
    elif k == meCast:
        out = uirNoAliasExprStableInner(uirExprCastExprOf(expr), depth)
    elif k == meBin || k == meCmp:
        out = uirNoAliasExprStableInner(uirExprLhsOf(expr), depth) &&
              uirNoAliasExprStableInner(uirExprRhsOf(expr), depth)
    else:
        out = false
    depth = depth - 1
    return out

fn uirNoAliasExprStable(expr: UirExpr): bool =
    var depth: int32 = 0
    return uirNoAliasExprStableInner(expr, depth)

fn uirNoAliasExprHasCallInner(expr: UirExpr, depth: var int32): bool =
    if (expr <= 0):
        return false
    if depth >= uirExprRecursionLimit():
        return true
    depth = depth + 1
    var out: bool = false
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meCall:
        out = true
    elif k == meCast:
        out = uirNoAliasExprHasCallInner(uirExprCastExprOf(expr), depth)
    elif k == meBin || k == meCmp:
        out = uirNoAliasExprHasCallInner(uirExprLhsOf(expr), depth) ||
              uirNoAliasExprHasCallInner(uirExprRhsOf(expr), depth)
    elif k == meLoad:
        out = uirNoAliasExprHasCallInner(uirExprAddrExprOf(expr), depth)
    elif k == meLocal || k == meAddr || k == meConstI64 || k == meGlobalAddr:
        out = false
    else:
        out = false
        for i in 0..<uirExprArgsLen(expr):
            if uirNoAliasExprHasCallInner(uirExprArgAt(expr, i), depth):
                out = true
                break
    depth = depth - 1
    return out

fn uirNoAliasExprHasCall(expr: UirExpr): bool =
    var depth: int32 = 0
    return uirNoAliasExprHasCallInner(expr, depth)

fn uirNoAliasExprMayClobber(expr: UirExpr): bool =
    return uirNoAliasExprHasCall(expr)

fn uirNoAliasExprHasLoadFromBaseInner(expr: UirExpr, baseSlot: int32, ptrBase: int32[], depth: var int32): bool =
    if (expr <= 0):
        return false
    if depth >= uirExprRecursionLimit():
        return true
    depth = depth + 1
    var out: bool = false
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meLoad:
        let loadBase: int32 = uirNoAliasResolveAddrBaseSlot(uirExprAddrExprOf(expr), ptrBase)
        if loadBase == baseSlot:
            out = true
        else:
            out = uirNoAliasExprHasLoadFromBaseInner(uirExprAddrExprOf(expr), baseSlot, ptrBase, depth)
    elif k == meCast:
        out = uirNoAliasExprHasLoadFromBaseInner(uirExprCastExprOf(expr), baseSlot, ptrBase, depth)
    elif k == meBin || k == meCmp:
        out = uirNoAliasExprHasLoadFromBaseInner(uirExprLhsOf(expr), baseSlot, ptrBase, depth) ||
              uirNoAliasExprHasLoadFromBaseInner(uirExprRhsOf(expr), baseSlot, ptrBase, depth)
    elif k == meCall:
        for i in 0..<uirExprArgsLen(expr):
            if uirNoAliasExprHasLoadFromBaseInner(uirExprArgAt(expr, i), baseSlot, ptrBase, depth):
                out = true
                break
    else:
        out = false
    depth = depth - 1
    return out

fn uirNoAliasExprHasLoadFromBase(expr: UirExpr, baseSlot: int32, ptrBase: int32[]): bool =
    var depth: int32 = 0
    return uirNoAliasExprHasLoadFromBaseInner(expr, baseSlot, ptrBase, depth)

fn uirNoAliasHasFutureLoad(blk: UirBlockId, startIdx: int32, baseSlot: int32, ptrBase: int32[]): bool =
    if (blk <= 0) || startIdx < 0:
        return false
    let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
    for si in startIdx..<stmtCount:
        let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
        if uirNoAliasExprHasLoadFromBase(uirCoreStmtExprOf(st), baseSlot, ptrBase):
            return true
        if uirCoreStmtKindOf(st) == msStore &&
           uirNoAliasExprHasLoadFromBase(uirCoreStmtAddrExprOf(st), baseSlot, ptrBase):
            return true
    let term: UirCoreTerm = uirCoreBlockTermOf(blk)
    if uirCoreTermKindOf(term) == mtRet:
        return uirNoAliasExprHasLoadFromBase(uirCoreTermRetExprOf(term), baseSlot, ptrBase)
    if uirCoreTermKindOf(term) == mtCbr:
        return uirNoAliasExprHasLoadFromBase(uirCoreTermCondExprOf(term), baseSlot, ptrBase)
    return false

fn uirNoAliasExprMarkUsesInner(expr: UirExpr, marks: var bool[], depth: var int32) =
    if (expr <= 0):
        return
    if depth >= uirExprRecursionLimit():
        for i in 0..<marks.len:
            marks[i] = true
        return
    depth = depth + 1
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meLocal:
        let slot: int32 = uirExprLocalIndexOf(expr)
        if slot >= 0 && slot < marks.len:
            marks[slot] = true
    elif k == meBin || k == meCmp:
        uirNoAliasExprMarkUsesInner(uirExprLhsOf(expr), marks, depth)
        uirNoAliasExprMarkUsesInner(uirExprRhsOf(expr), marks, depth)
    elif k == meCast:
        uirNoAliasExprMarkUsesInner(uirExprCastExprOf(expr), marks, depth)
    elif k == meLoad:
        uirNoAliasExprMarkUsesInner(uirExprAddrExprOf(expr), marks, depth)
    elif k == meCall:
        for i in 0..<uirExprArgsLen(expr):
            uirNoAliasExprMarkUsesInner(uirExprArgAt(expr, i), marks, depth)
    depth = depth - 1

fn uirNoAliasExprMarkUses(expr: UirExpr, marks: var bool[]) =
    var depth: int32 = 0
    uirNoAliasExprMarkUsesInner(expr, marks, depth)

fn uirNoAliasBuildLastUse(blk: UirBlockId, localCount: int32): int32[] =
    var lastUse: int32[] = uirNoAliasInitI32Seq(localCount, -1)
    if (blk <= 0) || localCount <= 0:
        return lastUse
    var marks: bool[] = uirNoAliasInitBoolSeq(localCount, false)
    let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
    for si in 0..<stmtCount:
        for i in 0..<localCount:
            marks[i] = false
        let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
        uirNoAliasExprMarkUses(uirCoreStmtExprOf(st), marks)
        uirNoAliasExprMarkUses(uirCoreStmtAddrExprOf(st), marks)
        for i in 0..<localCount:
            if marks[i]:
                lastUse[i] = si
    let termMark: int32 = stmtCount
    for i in 0..<localCount:
        marks[i] = false
    let term: UirCoreTerm = uirCoreBlockTermOf(blk)
    if uirCoreTermKindOf(term) == mtRet:
        uirNoAliasExprMarkUses(uirCoreTermRetExprOf(term), marks)
    elif uirCoreTermKindOf(term) == mtCbr:
        uirNoAliasExprMarkUses(uirCoreTermCondExprOf(term), marks)
    for i in 0..<localCount:
        if marks[i]:
            lastUse[i] = termMark
    return lastUse

fn uirNoAliasApplyKillLite(stepIdx: int32,
                           lastUse: int32[],
                           knownValid: var bool[],
                           ptrBase: var int32[],
                           killEvents: var int32) =
    for i in 0..<lastUse.len:
        if lastUse[i] != stepIdx:
            continue
        var touched: bool = false
        if i < knownValid.len && knownValid[i]:
            knownValid[i] = false
            touched = true
        if i < ptrBase.len && ptrBase[i] != -1:
            ptrBase[i] = -1
            touched = true
        if touched:
            killEvents = killEvents + 1

fn uirNoAliasExprCollectResolvedBasesInner(expr: UirExpr,
                                           ptrBase: int32[],
                                           resolved: var bool[],
                                           unknownCount: var int32,
                                           depth: var int32) =
    if (expr <= 0):
        return
    if depth >= uirExprRecursionLimit():
        unknownCount = unknownCount + 1
        return
    depth = depth + 1
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meAddr:
        let slot: int32 = uirExprLocalIndexOf(expr)
        if slot >= 0 && slot < resolved.len:
            resolved[slot] = true
        else:
            unknownCount = unknownCount + 1
    elif k == meLocal:
        let slot: int32 = uirExprLocalIndexOf(expr)
        if slot >= 0 && slot < ptrBase.len:
            let base: int32 = ptrBase[slot]
            if base >= 0 && base < resolved.len:
                resolved[base] = true
            else:
                unknownCount = unknownCount + 1
        else:
            unknownCount = unknownCount + 1
    elif k == meCast:
        uirNoAliasExprCollectResolvedBasesInner(uirExprCastExprOf(expr), ptrBase, resolved, unknownCount, depth)
    elif k == meLoad:
        uirNoAliasExprCollectResolvedBasesInner(uirExprAddrExprOf(expr), ptrBase, resolved, unknownCount, depth)
    elif k == meBin || k == meCmp:
        uirNoAliasExprCollectResolvedBasesInner(uirExprLhsOf(expr), ptrBase, resolved, unknownCount, depth)
        uirNoAliasExprCollectResolvedBasesInner(uirExprRhsOf(expr), ptrBase, resolved, unknownCount, depth)
    elif k == meCall:
        unknownCount = unknownCount + 1
        for i in 0..<uirExprArgsLen(expr):
            uirNoAliasExprCollectResolvedBasesInner(uirExprArgAt(expr, i), ptrBase, resolved, unknownCount, depth)
    depth = depth - 1

fn uirNoAliasExprCollectResolvedBasesInner(expr: UirExpr,
                                           ptrBase: var int32[],
                                           resolved: var bool[],
                                           unknownCount: var int32,
                                           depth: var int32) =
    if (expr <= 0):
        return
    if depth >= uirExprRecursionLimit():
        unknownCount = unknownCount + 1
        return
    depth = depth + 1
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meAddr:
        let slot: int32 = uirExprLocalIndexOf(expr)
        if slot >= 0 && slot < resolved.len:
            resolved[slot] = true
        else:
            unknownCount = unknownCount + 1
    elif k == meLocal:
        let slot: int32 = uirExprLocalIndexOf(expr)
        if slot >= 0 && slot < ptrBase.len:
            let base: int32 = ptrBase[slot]
            if base >= 0 && base < resolved.len:
                resolved[base] = true
            else:
                unknownCount = unknownCount + 1
        else:
            unknownCount = unknownCount + 1
    elif k == meCast:
        uirNoAliasExprCollectResolvedBasesInner(uirExprCastExprOf(expr), ptrBase, resolved, unknownCount, depth)
    elif k == meLoad:
        uirNoAliasExprCollectResolvedBasesInner(uirExprAddrExprOf(expr), ptrBase, resolved, unknownCount, depth)
    elif k == meBin || k == meCmp:
        uirNoAliasExprCollectResolvedBasesInner(uirExprLhsOf(expr), ptrBase, resolved, unknownCount, depth)
        uirNoAliasExprCollectResolvedBasesInner(uirExprRhsOf(expr), ptrBase, resolved, unknownCount, depth)
    elif k == meCall:
        unknownCount = unknownCount + 1
        for i in 0..<uirExprArgsLen(expr):
            uirNoAliasExprCollectResolvedBasesInner(uirExprArgAt(expr, i), ptrBase, resolved, unknownCount, depth)
    depth = depth - 1

fn uirNoAliasExprCollectResolvedBases(expr: UirExpr,
                                      ptrBase: int32[],
                                      resolved: var bool[],
                                      unknownCount: var int32) =
    var depth: int32 = 0
    uirNoAliasExprCollectResolvedBasesInner(expr, ptrBase, resolved, unknownCount, depth)

fn uirNoAliasExprCollectResolvedBases(expr: UirExpr,
                                      ptrBase: var int32[],
                                      resolved: var bool[],
                                      unknownCount: var int32) =
    var depth: int32 = 0
    uirNoAliasExprCollectResolvedBasesInner(expr, ptrBase, resolved, unknownCount, depth)


fn uirNoAliasApplyExprClobber(expr: UirExpr,
                              njvlLite: bool,
                              ptrBase: var int32[],
                              knownValid: var bool[],
                              promotable: var bool[],
                              unknownSlotClobbers: var int32,
                              unknownGlobalClobbers: var int32) =
    if !uirNoAliasExprMayClobber(expr):
        return
    if !njvlLite:
        uirNoAliasInvalidateAll(knownValid, ptrBase, promotable)
        return

    var resolved: bool[] = uirNoAliasInitBoolSeq(knownValid.len, false)
    var unknownCount: int32 = 0
    uirNoAliasExprCollectResolvedBases(expr, ptrBase, resolved, unknownCount)

    var resolvedCount: int32 = 0
    for i in 0..<resolved.len:
        if resolved[i]:
            resolvedCount = resolvedCount + 1
            knownValid[i] = false
            if i < ptrBase.len:
                ptrBase[i] = -1

    if unknownCount > 0:
        unknownSlotClobbers = unknownSlotClobbers + unknownCount

    if resolvedCount <= 0 || unknownCount > 0:
        unknownGlobalClobbers = unknownGlobalClobbers + 1
        uirNoAliasInvalidateAll(knownValid, ptrBase, promotable)

fn uirNoAliasRewriteExprInner(expr: UirExpr,
                              ptrBase: int32[],
                              knownVals: UirExpr[],
                              knownValid: bool[],
                              promotable: bool[],
                              changed: var bool,
                              forwardedLoads: var int32,
                              mem2regLoads: var int32,
                              proofBackedChanges: var int32,
                              proofBacked: bool,
                              depth: var int32): UirExpr =
    if (expr <= 0):
        return nil
    if depth >= uirExprRecursionLimit():
        return expr
    depth = depth + 1
    var cur: UirExprId = expr
    let k: UirExprKind = uirExprKindOf(cur)
    if k == meBin || k == meCmp:
        uirCoreExprSetLhs(cur, uirNoAliasRewriteExprInner(uirCoreExprLhsOf(cur), ptrBase, knownVals, knownValid, promotable,
                                                          changed, forwardedLoads, mem2regLoads,
                                                          proofBackedChanges, proofBacked, depth))
        uirCoreExprSetRhs(cur, uirNoAliasRewriteExprInner(uirCoreExprRhsOf(cur), ptrBase, knownVals, knownValid, promotable,
                                                          changed, forwardedLoads, mem2regLoads,
                                                          proofBackedChanges, proofBacked, depth))
        depth = depth - 1
        return cur
    if k == meCall:
        for i in 0..<uirCoreExprArgsLen(cur):
            uirCoreExprSetArgAt(cur, i, uirNoAliasRewriteExprInner(uirCoreExprArgAt(cur, i), ptrBase, knownVals, knownValid, promotable,
                                                                   changed, forwardedLoads, mem2regLoads,
                                                                   proofBackedChanges, proofBacked, depth))
        depth = depth - 1
        return cur
    if k == meCast:
        uirCoreExprSetCastExpr(cur, uirNoAliasRewriteExprInner(uirCoreExprCastExprOf(cur), ptrBase, knownVals, knownValid, promotable,
                                                               changed, forwardedLoads, mem2regLoads,
                                                               proofBackedChanges, proofBacked, depth))
        depth = depth - 1
        return cur
    if k == meLoad:
        uirCoreExprSetAddrExpr(cur, uirNoAliasRewriteExprInner(uirCoreExprAddrExprOf(cur), ptrBase, knownVals, knownValid, promotable,
                                                               changed, forwardedLoads, mem2regLoads,
                                                               proofBackedChanges, proofBacked, depth))
        let baseSlot: int32 = uirNoAliasResolveAddrBaseSlot(uirCoreExprAddrExprOf(cur), ptrBase)
        if baseSlot >= 0 && baseSlot < knownValid.len:
            if knownValid[baseSlot] && knownVals[baseSlot] > 0:
                changed = true
                forwardedLoads = forwardedLoads + 1
                if proofBacked:
                    proofBackedChanges = proofBackedChanges + 1
                depth = depth - 1
                return knownVals[baseSlot]
            if baseSlot < promotable.len && promotable[baseSlot]:
                changed = true
                mem2regLoads = mem2regLoads + 1
                if proofBacked:
                    proofBackedChanges = proofBackedChanges + 1
                depth = depth - 1
                return uirCoreLocal(baseSlot)
        depth = depth - 1
        return cur
    depth = depth - 1
    return cur

fn uirNoAliasRewriteExpr(expr: UirExpr,
                         ptrBase: int32[],
                         knownVals: UirExpr[],
                         knownValid: bool[],
                         promotable: bool[],
                         changed: var bool,
                         forwardedLoads: var int32,
                         mem2regLoads: var int32,
                         proofBackedChanges: var int32,
                         proofBacked: bool): UirExpr =
    var depth: int32 = 0
    return uirNoAliasRewriteExprInner(expr, ptrBase, knownVals, knownValid, promotable,
                                      changed, forwardedLoads, mem2regLoads,
                                      proofBackedChanges, proofBacked, depth)

fn uirNoAliasRunFunc(func: UirCoreFunc,
                     changedAny: var bool,
                     forwardedLoads: var int32,
                     mem2regLoads: var int32,
                     mem2regStores: var int32,
                     proofBackedChanges: var int32,
                     proofBacked: bool,
                     njvlLite: bool,
                     unknownSlotClobbers: var int32,
                     unknownGlobalClobbers: var int32,
                     killEvents: var int32): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    let localCount: int32 = uirCoreFuncLocalTypesLen(func)
    if localCount <= 0:
        return false

    var funcChanged: bool = false
    let objSlotFlags: bool[] = uirNoAliasBuildObjSlotFlags(func, localCount)
    let blockCount: int32 = uirCoreFuncBlocksLen(func)
    for bi in 0..<blockCount:
        let blkView: UirLowerBlock = uirCoreFuncBlockAt(func, bi)
        if (blkView <= 0):
            continue
        let blk: UirBlockId = blkView
        var ptrBase: int32[] = uirNoAliasInitI32Seq(localCount, -1)
        var knownVals: UirExpr[] = uirNoAliasInitExprSeq(localCount)
        var knownValid: bool[] = uirNoAliasInitBoolSeq(localCount, false)
        var promotable: bool[] = uirNoAliasInitBoolSeq(localCount, true)
        let lastUse: int32[] = uirNoAliasBuildLastUse(blk, localCount)
        for si0 in 0..<localCount:
            if si0 < objSlotFlags.len && objSlotFlags[si0]:
                promotable[si0] = false

        let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
        for si in 0..<stmtCount:
            var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
            let stmtKind: UirCoreStmtKind = uirCoreStmtKindOf(st)
            if stmtKind == msLet || stmtKind == msVar || stmtKind == msAssign:
                st = uirCoreStmtWithExpr(
                    st,
                    uirNoAliasRewriteExpr(uirCoreStmtExprOf(st), ptrBase, knownVals, knownValid, promotable,
                                          funcChanged, forwardedLoads, mem2regLoads,
                                          proofBackedChanges, proofBacked)
                )
                let slot: int32 = uirCoreStmtSlotOf(st)
                let expr: UirExpr = uirCoreStmtExprOf(st)
                if slot >= 0 && slot < localCount:
                    knownValid[slot] = false
                    if uirNoAliasExprStable(expr):
                        knownVals[slot] = expr
                        knownValid[slot] = true
                    let aliasBase: int32 = uirNoAliasResolveAddrBaseSlot(expr, ptrBase)
                    if aliasBase >= 0 && aliasBase < localCount:
                        ptrBase[slot] = aliasBase
                    else:
                        ptrBase[slot] = -1
                uirCoreBlockSetStmtAt(blk, si, st)
                uirNoAliasApplyExprClobber(expr, njvlLite, ptrBase, knownValid, promotable,
                                           unknownSlotClobbers, unknownGlobalClobbers)
            elif stmtKind == msParam:
                let slot: int32 = uirCoreStmtSlotOf(st)
                if slot >= 0 && slot < localCount:
                    knownValid[slot] = false
                    ptrBase[slot] = -1
            elif stmtKind == msStore:
                st = uirCoreStmtWithAddrExpr(
                    st,
                    uirNoAliasRewriteExpr(uirCoreStmtAddrExprOf(st), ptrBase, knownVals, knownValid, promotable,
                                          funcChanged, forwardedLoads, mem2regLoads,
                                          proofBackedChanges, proofBacked)
                )
                st = uirCoreStmtWithExpr(
                    st,
                    uirNoAliasRewriteExpr(uirCoreStmtExprOf(st), ptrBase, knownVals, knownValid, promotable,
                                          funcChanged, forwardedLoads, mem2regLoads,
                                          proofBackedChanges, proofBacked)
                )
                let addrExpr: UirExpr = uirCoreStmtAddrExprOf(st)
                let valueExpr: UirExpr = uirCoreStmtExprOf(st)
                let baseSlot: int32 = uirNoAliasResolveAddrBaseSlot(addrExpr, ptrBase)
                if baseSlot >= 0 && baseSlot < localCount && promotable[baseSlot]:
                    let futureLoad: bool = uirNoAliasHasFutureLoad(blk, si + 1, baseSlot, ptrBase)
                    if futureLoad:
                        st = uirCoreStmtWithKind(st, msAssign)
                        st = uirCoreStmtWithName(st, uirNoAliasEnsureName(uirCoreStmtNameOf(st), baseSlot))
                        st = uirCoreStmtWithSlot(st, baseSlot)
                        st = uirCoreStmtWithAddrExpr(st, nil)
                        let nextExpr: UirExpr = uirCoreStmtExprOf(st)
                        if uirNoAliasExprStable(nextExpr):
                            knownVals[baseSlot] = nextExpr
                            knownValid[baseSlot] = true
                        else:
                            knownValid[baseSlot] = false
                        mem2regStores = mem2regStores + 1
                        if proofBacked:
                            proofBackedChanges = proofBackedChanges + 1
                        funcChanged = true
                    elif uirNoAliasExprStable(valueExpr):
                        knownVals[baseSlot] = valueExpr
                        knownValid[baseSlot] = true
                    else:
                        knownValid[baseSlot] = false
                else:
                    if baseSlot >= 0 && baseSlot < localCount:
                        knownValid[baseSlot] = false
                    else:
                        unknownSlotClobbers = unknownSlotClobbers + 1
                        unknownGlobalClobbers = unknownGlobalClobbers + 1
                        uirNoAliasInvalidateAll(knownValid, ptrBase, promotable)
                uirCoreBlockSetStmtAt(blk, si, st)
                uirNoAliasApplyExprClobber(uirCoreStmtExprOf(st), njvlLite, ptrBase, knownValid, promotable,
                                           unknownSlotClobbers, unknownGlobalClobbers)
                uirNoAliasApplyExprClobber(uirCoreStmtAddrExprOf(st), njvlLite, ptrBase, knownValid, promotable,
                                           unknownSlotClobbers, unknownGlobalClobbers)
            else:
                st = uirCoreStmtWithExpr(
                    st,
                    uirNoAliasRewriteExpr(uirCoreStmtExprOf(st), ptrBase, knownVals, knownValid, promotable,
                                          funcChanged, forwardedLoads, mem2regLoads,
                                          proofBackedChanges, proofBacked)
                )
                uirCoreBlockSetStmtAt(blk, si, st)
                uirNoAliasApplyExprClobber(uirCoreStmtExprOf(st), njvlLite, ptrBase, knownValid, promotable,
                                           unknownSlotClobbers, unknownGlobalClobbers)

            if njvlLite:
                uirNoAliasApplyKillLite(si, lastUse, knownValid, ptrBase, killEvents)

        let term: UirCoreTerm = uirCoreBlockTermOf(blk)
        if uirCoreTermKindOf(term) == mtRet && !(uirCoreTermRetExprOf(term) <= 0):
            let retExpr: UirExpr = uirNoAliasRewriteExpr(uirCoreTermRetExprOf(term), ptrBase, knownVals, knownValid, promotable,
                                                         funcChanged, forwardedLoads, mem2regLoads,
                                                         proofBackedChanges, proofBacked)
            uirCoreBlockSetTerm(blk, uirCoreTermWithRetExpr(term, retExpr))
            uirNoAliasApplyExprClobber(retExpr, njvlLite, ptrBase, knownValid, promotable,
                                       unknownSlotClobbers, unknownGlobalClobbers)
        elif uirCoreTermKindOf(term) == mtCbr && !(uirCoreTermCondExprOf(term) <= 0):
            let condExpr: UirExpr = uirNoAliasRewriteExpr(uirCoreTermCondExprOf(term), ptrBase, knownVals, knownValid, promotable,
                                                          funcChanged, forwardedLoads, mem2regLoads,
                                                          proofBackedChanges, proofBacked)
            uirCoreBlockSetTerm(blk, uirCoreTermWithCondExpr(term, condExpr))
            uirNoAliasApplyExprClobber(condExpr, njvlLite, ptrBase, knownValid, promotable,
                                       unknownSlotClobbers, unknownGlobalClobbers)

        if njvlLite:
            uirNoAliasApplyKillLite(stmtCount, lastUse, knownValid, ptrBase, killEvents)

    if funcChanged:
        changedAny = true
    return funcChanged

fn uirNoAliasEmitReport(forwardedLoads: int32, mem2regLoads: int32, mem2regStores: int32,
                        changedFuncs: int32, proofBackedChanges: int32,
                        proofCheckedFuncs: int32, proofSkippedFuncs: int32,
                        proofRequired: bool,
                        njvlLite: bool,
                        unknownSlotClobbers: int32,
                        unknownGlobalClobbers: int32,
                        killEvents: int32) =
    let f: UirOptFile = uirOptGetStderr()
    uirOptWrite(f, "noalias_report\tforward_loads=")
    uirOptWrite(f, intToStr(forwardedLoads))
    uirOptWrite(f, "\tmem2reg_loads=")
    uirOptWrite(f, intToStr(mem2regLoads))
    uirOptWrite(f, "\tmem2reg_stores=")
    uirOptWrite(f, intToStr(mem2regStores))
    uirOptWrite(f, "\tchanged_funcs=")
    uirOptWrite(f, intToStr(changedFuncs))
    uirOptWrite(f, "\tproof_backed_changes=")
    uirOptWrite(f, intToStr(proofBackedChanges))
    uirOptWrite(f, "\tproof_checked_funcs=")
    uirOptWrite(f, intToStr(proofCheckedFuncs))
    uirOptWrite(f, "\tproof_skipped_funcs=")
    uirOptWrite(f, intToStr(proofSkippedFuncs))
    uirOptWrite(f, "\tproof_required=")
    uirOptWrite(f, intToStr(proofRequired ? 1 : 0))
    uirOptWrite(f, "\tnjvl_lite=")
    uirOptWrite(f, intToStr(njvlLite ? 1 : 0))
    uirOptWrite(f, "\tunknown_slot_clobbers=")
    uirOptWrite(f, intToStr(unknownSlotClobbers))
    uirOptWrite(f, "\tunknown_global_clobbers=")
    uirOptWrite(f, intToStr(unknownGlobalClobbers))
    uirOptWrite(f, "\tkill_events=")
    uirOptWrite(f, intToStr(killEvents))
    uirOptWriteLine(f, "")
    uirOptFFlush(f)

fn uirRunNoAliasPrep(module: UirModule, requireProof: bool): bool =
    if (module == nil):
        return false
    let njvlLite: bool = uirEnvParseBool("UIR_NOALIAS_NJVL_LITE", true)
    var changedAny: bool = false
    var forwardedLoads: int32 = 0
    var mem2regLoads: int32 = 0
    var mem2regStores: int32 = 0
    var changedFuncs: int32 = 0
    var proofBackedChanges: int32 = 0
    var proofCheckedFuncs: int32 = 0
    var proofSkippedFuncs: int32 = 0
    var unknownSlotClobbers: int32 = 0
    var unknownGlobalClobbers: int32 = 0
    var killEvents: int32 = 0
    for fi in 0..<uirModuleFuncsLen(module):
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if (funcView == nil) || uirFuncIsExtern(funcView):
            continue
        let func: UirCoreFunc = funcView
        let proofBacked: bool = uirFuncProofBackedForOpt2(func)
        if proofBacked:
            proofCheckedFuncs = proofCheckedFuncs + 1
        elif requireProof:
            proofSkippedFuncs = proofSkippedFuncs + 1
            continue
        if uirNoAliasRunFunc(func, changedAny, forwardedLoads, mem2regLoads, mem2regStores,
                             proofBackedChanges, proofBacked, njvlLite,
                             unknownSlotClobbers, unknownGlobalClobbers, killEvents):
            changedFuncs = changedFuncs + 1
    uirNoAliasEmitReport(forwardedLoads, mem2regLoads, mem2regStores, changedFuncs,
                         proofBackedChanges, proofCheckedFuncs, proofSkippedFuncs, requireProof,
                         njvlLite, unknownSlotClobbers, unknownGlobalClobbers, killEvents)
    return changedAny
# ---- end backend/uir/uir_noalias_pass.cheng ----

# ---- begin backend/uir/uir_internal/uir_core_ssu.cheng ----

fn uirCoreSsuReadI32(p: ptr): int32 =
    if p == nil:
        return 0
    var out: int32 = 0
    memCopyCompat(&out, p, int32(sizeof int32))
    return out

fn uirCoreSsuWriteI32(p: ptr, value: int32) =
    if p == nil:
        return
    var tmp: int32 = value
    memCopyCompat(p, &tmp, int32(sizeof int32))

fn add(dst: var int32[], val: int32) =
    seqs.add(dst, val)

fn uirCoreSsuRecursionLimit(): int32 =
    return 256

fn uirCoreSsuLowerAscii(s: str): str =
    return strutils.toLowerAscii(s)

fn uirCoreSsuParseBoolEnv(name: str, defaultValue: bool): bool =
    let raw: str = uirOptGetEnvDefault(name, "")
    if len(raw) == 0:
        return defaultValue
    let s: str = uirCoreSsuLowerAscii(raw)
    if s == "1" || s == "true" || s == "yes" || s == "on":
        return true
    if s == "0" || s == "false" || s == "no" || s == "off":
        return false
    return defaultValue

fn uirCoreSsuExprMarkUsesInner(expr: UirExprId, counts: int32[]*, depth: ptr) =
    if (!uirCoreExprIdValid(expr)) || (counts == nil) || (depth == nil):
        return
    if uirCoreSsuReadI32(depth) >= uirCoreSsuRecursionLimit():
        for i in 0..<counts->len:
            counts[i] = counts[i] + 1
        return
    uirCoreSsuWriteI32(depth, uirCoreSsuReadI32(depth) + 1)
    let k: UirCoreExprKind = uirCoreExprKindOf(expr)
    if k == meLocal:
        let slot: int32 = uirCoreExprLocalIndexOf(expr)
        if slot >= 0 && slot < counts->len:
            counts[slot] = counts[slot] + 1
    elif k == meBin || k == meCmp:
        uirCoreSsuExprMarkUsesInner(uirCoreExprLhsOf(expr), counts, depth)
        uirCoreSsuExprMarkUsesInner(uirCoreExprRhsOf(expr), counts, depth)
    elif k == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            uirCoreSsuExprMarkUsesInner(uirCoreExprArgAt(expr, i), counts, depth)
    elif k == meCast:
        uirCoreSsuExprMarkUsesInner(uirCoreExprCastExprOf(expr), counts, depth)
    elif k == meLoad:
        uirCoreSsuExprMarkUsesInner(uirCoreExprAddrExprOf(expr), counts, depth)
    uirCoreSsuWriteI32(depth, uirCoreSsuReadI32(depth) - 1)

fn uirCoreSsuExprMarkUses(expr: UirExprId, counts: int32[]*) =
    var depth: int32 = 0
    uirCoreSsuExprMarkUsesInner(expr, counts, &depth)

fn uirCoreSsuStmtMarkUses(stmt: UirStmtId, counts: int32[]*) =
    if (counts == nil):
        return
    uirCoreSsuExprMarkUses(uirCoreStmtExprOf(stmt), counts)
    uirCoreSsuExprMarkUses(uirCoreStmtAddrExprOf(stmt), counts)

fn uirCoreSsuTermMarkUses(term: UirCoreTerm, counts: int32[]*) =
    if (counts == nil):
        return
    if uirCoreTermKindOf(term) == mtRet:
        uirCoreSsuExprMarkUses(uirCoreTermRetExprOf(term), counts)
    elif uirCoreTermKindOf(term) == mtCbr:
        uirCoreSsuExprMarkUses(uirCoreTermCondExprOf(term), counts)

fn uirCoreSsuExprUsesSlotInner(expr: UirExprId, slot: int32, depth: ptr): bool =
    if (!uirCoreExprIdValid(expr)) || slot < 0 || (depth == nil):
        return false
    if uirCoreSsuReadI32(depth) >= uirCoreSsuRecursionLimit():
        return true
    uirCoreSsuWriteI32(depth, uirCoreSsuReadI32(depth) + 1)
    var out: bool = false
    let k: UirCoreExprKind = uirCoreExprKindOf(expr)
    if k == meLocal:
        out = uirCoreExprLocalIndexOf(expr) == slot
    elif k == meBin || k == meCmp:
        out = uirCoreSsuExprUsesSlotInner(uirCoreExprLhsOf(expr), slot, depth) ||
              uirCoreSsuExprUsesSlotInner(uirCoreExprRhsOf(expr), slot, depth)
    elif k == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            if uirCoreSsuExprUsesSlotInner(uirCoreExprArgAt(expr, i), slot, depth):
                out = true
                break
    elif k == meCast:
        out = uirCoreSsuExprUsesSlotInner(uirCoreExprCastExprOf(expr), slot, depth)
    elif k == meLoad:
        out = uirCoreSsuExprUsesSlotInner(uirCoreExprAddrExprOf(expr), slot, depth)
    else:
        out = false
    uirCoreSsuWriteI32(depth, uirCoreSsuReadI32(depth) - 1)
    return out

fn uirCoreSsuExprUsesSlot(expr: UirExprId, slot: int32): bool =
    var depth: int32 = 0
    return uirCoreSsuExprUsesSlotInner(expr, slot, &depth)

fn uirCoreSsuStmtUsesSlot(stmt: UirStmtId, slot: int32): bool =
    return uirCoreSsuExprUsesSlot(uirCoreStmtExprOf(stmt), slot) ||
           uirCoreSsuExprUsesSlot(uirCoreStmtAddrExprOf(stmt), slot)

fn uirCoreSsuTermUsesSlot(term: UirCoreTerm, slot: int32): bool =
    if uirCoreTermKindOf(term) == mtRet:
        return uirCoreSsuExprUsesSlot(uirCoreTermRetExprOf(term), slot)
    if uirCoreTermKindOf(term) == mtCbr:
        return uirCoreSsuExprUsesSlot(uirCoreTermCondExprOf(term), slot)
    return false

fn uirCoreSsuCopySrcSlot(stmt: UirStmtId, srcSlot: ptr): bool =
    if !(srcSlot == nil):
        uirCoreSsuWriteI32(srcSlot, -1)
    let kind: UirCoreStmtKind = uirCoreStmtKindOf(stmt)
    let dstSlot: int32 = uirCoreStmtSlotOf(stmt)
    if kind != msLet && kind != msVar && kind != msAssign:
        return false
    if dstSlot < 0:
        return false
    let e: UirExprId = uirCoreStmtExprOf(stmt)
    if (!uirCoreExprIdValid(e)) || uirCoreExprKindOf(e) != meLocal:
        return false
    let src: int32 = uirCoreExprLocalIndexOf(e)
    if src < 0 || src == dstSlot:
        return false
    if !(srcSlot == nil):
        uirCoreSsuWriteI32(srcSlot, src)
    return true

fn uirCoreSsuIsMoveCandidate(func: UirCoreFunc, blockIdx: int32, stmtIdx: int32): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func) || blockIdx < 0 || stmtIdx < 0 || blockIdx >= uirCoreFuncBlocksLen(func):
        return false
    let blk: UirBlockId = uirCoreFuncBlockAt(func, blockIdx)
    let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
    if (!uirCoreBlockIdValid(blk)) || stmtIdx >= stmtCount:
        return false
    var srcSlot: int32 = -1
    if !uirCoreSsuCopySrcSlot(uirCoreBlockStmtAt(blk, stmtIdx), &srcSlot):
        return false
    for si in stmtIdx + 1..<stmtCount:
        if uirCoreSsuStmtUsesSlot(uirCoreBlockStmtAt(blk, si), srcSlot):
            return false
    if uirCoreSsuTermUsesSlot(uirCoreBlockTermOf(blk), srcSlot):
        return false
    return true

fn uirCoreSsuCopyKind(func: UirCoreFunc, blockIdx: int32, stmtIdx: int32): int32 =
    if (!uirCoreFuncIdValid(func)) || blockIdx < 0 || stmtIdx < 0 || blockIdx >= uirCoreFuncBlocksLen(func):
        return 0
    let blk: UirBlockId = uirCoreFuncBlockAt(func, blockIdx)
    let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
    if (!uirCoreBlockIdValid(blk)) || stmtIdx >= stmtCount:
        return 0
    var srcSlot: int32 = -1
    if !uirCoreSsuCopySrcSlot(uirCoreBlockStmtAt(blk, stmtIdx), &srcSlot):
        return 0
    if uirCoreSsuIsMoveCandidate(func, blockIdx, stmtIdx):
        return 2
    return 1

fn uirCoreSsuEmitReport(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var enabled: bool = uirCoreSsuParseBoolEnv("UIR_SSU", true)
    var dupCandidates: int32 = 0
    var moveCandidates: int32 = 0
    var useVersionMax: int32 = 0
    var trackedFuncs: int32 = 0
    if enabled:
        let funcCount: int32 = uirCoreModuleFuncsLen(module)
        for fi in 0..<funcCount:
            let func: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
            if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
                continue
            trackedFuncs = trackedFuncs + 1
            let localCount: int32 = uirCoreFuncLocalTypesLen(func)
            var useCounts: int32[]
            for i0 in 0..<localCount:
                add(useCounts, 0)
            let blockCount: int32 = uirCoreFuncBlocksLen(func)
            for bi in 0..<blockCount:
                let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
                if (!uirCoreBlockIdValid(blk)):
                    continue
                let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
                for si in 0..<stmtCount:
                    uirCoreSsuStmtMarkUses(uirCoreBlockStmtAt(blk, si), &useCounts)
                    let ck: int32 = uirCoreSsuCopyKind(func, bi, si)
                    if ck == 2:
                        moveCandidates = moveCandidates + 1
                    elif ck == 1:
                        dupCandidates = dupCandidates + 1
                uirCoreSsuTermMarkUses(uirCoreBlockTermOf(blk), &useCounts)
            for i in 0..<useCounts.len:
                if useCounts[i] > useVersionMax:
                    useVersionMax = useCounts[i]

    let f: UirOptFile = uirOptGetStderr()
    uirOptWrite(f, "ssu_report\tenabled=")
    uirOptWrite(f, intToStr(enabled ? 1 : 0))
    uirOptWrite(f, "\ttracked_funcs=")
    uirOptWrite(f, intToStr(trackedFuncs))
    uirOptWrite(f, "\tdup_candidates=")
    uirOptWrite(f, intToStr(dupCandidates))
    uirOptWrite(f, "\tmove_candidates=")
    uirOptWrite(f, intToStr(moveCandidates))
    uirOptWrite(f, "\tuse_version_max=")
    uirOptWriteLine(f, intToStr(useVersionMax))
    uirOptFFlush(f)
    return enabled
# ---- end backend/uir/uir_internal/uir_core_ssu.cheng ----

# ---- begin backend/uir/uir_internal/uir_core_ssa.cheng ----
# MIR v1 SSA pass (minimal): builds SSA-like renaming + inserts edge moves (phi elimination).
# Notes:
# - Keeps object-local pointer slots (UirCoreObjLocal.slot) out of SSA, because isel initializes them by slot index.
# - Excludes addr-taken locals (meAddr) from SSA.

fn ssaLoadPtrValue(p: ptr): ptr =
    if p == nil:
        return nil
    return ptrLoadCompat(p)

fn ssaStorePtrValue(p: ptr, value: ptr) =
    if p == nil:
        return
    ptrStoreCompat(p, value)

fn add(seqInst: var SsaGridInt32, val: SsaRowInt32) =
    seqs.add(seqInst, val)

fn add(seqInst: var SsaGridPhiDefs, val: SsaRowPhiDefs) =
    seqs.add(seqInst, val)

fn add(seqInst: var int32[], val: int32) =
    seqs.add(seqInst, val)

fn add(seqInst: var bool[], val: bool) =
    seqs.add(seqInst, val)

fn add(seqInst: var SsaPhiDef[], val: SsaPhiDef) =
    seqs.add(seqInst, val)

fn add(seqInst: var SsaMove[], val: SsaMove) =
    seqs.add(seqInst, val)

fn add(seqInst: var UirStmtId[], val: UirStmtId) =
    seqs.add(seqInst, val)

fn ssaAppendCtxVarTop(ctx: SsaRenameCtx, value: int32) =
    if ctx == nil:
        return
    let idx: int32 = ctx.varTop.len
    let needLen: int32 = idx + 1
    if ctx.varTop.buffer == nil || ctx.varTop.cap < needLen:
        cheng__seqGrowToRaw(&ctx.varTop.buffer, &ctx.varTop.cap, needLen, int32(sizeof int32))
    ctx.varTop.len = needLen
    ctx.varTop[idx] = value

fn ssaAppendCtxEdgeMove(ctx: SsaRenameCtx, value: SsaEdgeMoves) =
    if ctx == nil:
        return
    let idx: int32 = ctx.edgeMoves.len
    let needLen: int32 = idx + 1
    if ctx.edgeMoves.buffer == nil || ctx.edgeMoves.cap < needLen:
        cheng__seqGrowToRaw(&ctx.edgeMoves.buffer, &ctx.edgeMoves.cap, needLen, int32(sizeof SsaEdgeMoves))
    ctx.edgeMoves.len = needLen
    ctx.edgeMoves[idx] = value

fn ssaExprRecursionLimit(): int32 =
    return 256

fn ssaNewSeq2DInt(n: int32): SsaGridInt32 =
    var out: SsaGridInt32
    out.buffer = nil
    out.len = 0
    out.cap = 0
    if n > 0:
        out.cap = n
        for i in 0..<n:
            var row: SsaRowInt32
            new row
            row.values = []
            add(out, row)
    return out

fn ssaNewSeq2DPhiDef(n: int32): SsaGridPhiDefs =
    var out: SsaGridPhiDefs
    out.buffer = nil
    out.len = 0
    out.cap = 0
    if n > 0:
        out.cap = n
        for i in 0..<n:
            var row: SsaRowPhiDefs
            new row
            row.values = []
            add(out, row)
    return out

fn ssaReadRowIntSlot(items: SsaGridInt32, idx: int32): SsaRowInt32 =
    if idx < 0 || idx >= items.len || (items.buffer == nil):
        return nil
    let off: int32 = idx * sizeof SsaRowInt32
    return SsaRowInt32(ssaLoadPtrValue(rawmemPtrAdd(items.buffer, off)))

fn ssaReadRowIntSlot(items: var SsaGridInt32, idx: int32): SsaRowInt32 =
    if idx < 0 || idx >= items.len || (items.buffer == nil):
        return nil
    let off: int32 = idx * sizeof SsaRowInt32
    return SsaRowInt32(ssaLoadPtrValue(rawmemPtrAdd(items.buffer, off)))


fn ssaWriteRowIntSlot(items: var SsaGridInt32, idx: int32, row: SsaRowInt32) =
    if idx < 0 || idx >= items.len || (items.buffer == nil):
        return
    let off: int32 = idx * sizeof SsaRowInt32
    ssaStorePtrValue(rawmemPtrAdd(items.buffer, off), ptr(row))

fn ssaReadRowPhiSlot(items: SsaGridPhiDefs, idx: int32): SsaRowPhiDefs =
    if idx < 0 || idx >= items.len || (items.buffer == nil):
        return nil
    let off: int32 = idx * sizeof SsaRowPhiDefs
    return SsaRowPhiDefs(ssaLoadPtrValue(rawmemPtrAdd(items.buffer, off)))

fn ssaReadRowPhiSlot(items: var SsaGridPhiDefs, idx: int32): SsaRowPhiDefs =
    if idx < 0 || idx >= items.len || (items.buffer == nil):
        return nil
    let off: int32 = idx * sizeof SsaRowPhiDefs
    return SsaRowPhiDefs(ssaLoadPtrValue(rawmemPtrAdd(items.buffer, off)))


fn ssaWriteRowPhiSlot(items: var SsaGridPhiDefs, idx: int32, row: SsaRowPhiDefs) =
    if idx < 0 || idx >= items.len || (items.buffer == nil):
        return
    let off: int32 = idx * sizeof SsaRowPhiDefs
    ssaStorePtrValue(rawmemPtrAdd(items.buffer, off), ptr(row))

fn ssaGridIntRow(items: SsaGridInt32, idx: int32): int32[] =
    var empty: int32[]
    if idx < 0 || idx >= items.len:
        return empty
    let row: SsaRowInt32 = ssaReadRowIntSlot(items, idx)
    if (row == nil):
        return empty
    return row.values

fn ssaGridIntRow(items: var SsaGridInt32, idx: int32): int32[] =
    var empty: int32[]
    if idx < 0 || idx >= items.len:
        return empty
    let row: SsaRowInt32 = ssaReadRowIntSlot(items, idx)
    if (row == nil):
        return empty
    return row.values


fn ssaGridIntSetRow(items: var SsaGridInt32, idx: int32, values: int32[]) =
    if idx < 0 || idx >= items.len:
        return
    var row: SsaRowInt32 = ssaReadRowIntSlot(items, idx)
    if (row == nil):
        var freshRow: SsaRowInt32
        new freshRow
        row = freshRow
        ssaWriteRowIntSlot(items, idx, row)
    row.values = values

fn ssaGridPhiRow(items: SsaGridPhiDefs, idx: int32): SsaPhiDef[] =
    var empty: SsaPhiDef[]
    if idx < 0 || idx >= items.len:
        return empty
    let row: SsaRowPhiDefs = ssaReadRowPhiSlot(items, idx)
    if (row == nil):
        return empty
    return row.values


fn ssaGridPhiSetRow(items: var SsaGridPhiDefs, idx: int32, values: SsaPhiDef[]) =
    if idx < 0 || idx >= items.len:
        return
    var row: SsaRowPhiDefs = ssaReadRowPhiSlot(items, idx)
    if (row == nil):
        var freshRow: SsaRowPhiDefs
        new freshRow
        row = freshRow
        ssaWriteRowPhiSlot(items, idx, row)
    row.values = values

fn ssaSeqContainsInt(items: int32[], v: int32): bool =
    for i in 0..<items.len:
        if items[i] == v:
            return true
    return false

fn ssaSeqContainsInt(items: var int32[], v: int32): bool =
    for i in 0..<items.len:
        if items[i] == v:
            return true
    return false


fn ssaSeqAddUniqueInt(items: var int32[], v: int32) =
    if ssaSeqContainsInt(items, v):
        return
    add(items, v)

fn ssa2dAddUniqueInt(items: var SsaGridInt32, idx: int32, v: int32) =
    if idx < 0 || idx >= items.len:
        return
    var inner: int32[] = ssaGridIntRow(items, idx)
    if ! ssaSeqContainsInt(inner, v):
        add(inner, v)
        ssaGridIntSetRow(items, idx, inner)

fn ssaSortIntsStable(items: var int32[]): bool =
    if items.len <= 1:
        return false
    var changed: bool = false
    for i in 1..<items.len:
        let key: int32 = items[i]
        var j: int32 = i - 1
        let __for_start_j = j
        for __for_rev_j in 0..(__for_start_j - (0)):
            j = __for_start_j - __for_rev_j
            if !(items[j] > key):
                break
            items[j + 1] = items[j]
            changed = true
        items[j + 1] = key
    return changed

fn ssaMarkAddrTakenInner(expr: UirExprId, addrTaken: var bool[], depth: var int32) =
    if !uirCoreExprIdValid(expr):
        return
    if depth >= ssaExprRecursionLimit():
        for i in 0..<addrTaken.len:
            addrTaken[i] = true
        return
    depth = depth + 1
    let kind: UirCoreExprKind = uirCoreExprKindOf(expr)
    if kind == meAddr:
        let slot: int32 = uirCoreExprLocalIndexOf(expr)
        if slot >= 0 && slot < addrTaken.len:
            addrTaken[slot] = true
    elif kind == meLoad:
        ssaMarkAddrTakenInner(uirCoreExprAddrExprOf(expr), addrTaken, depth)
    elif kind == meBin || kind == meCmp:
        ssaMarkAddrTakenInner(uirCoreExprLhsOf(expr), addrTaken, depth)
        ssaMarkAddrTakenInner(uirCoreExprRhsOf(expr), addrTaken, depth)
    elif kind == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            ssaMarkAddrTakenInner(uirCoreExprArgAt(expr, i), addrTaken, depth)
    elif kind == meCast:
        ssaMarkAddrTakenInner(uirCoreExprCastExprOf(expr), addrTaken, depth)
    depth = depth - 1

fn ssaMarkAddrTaken(expr: UirExprId, addrTaken: var bool[]) =
    var depth: int32 = 0
    ssaMarkAddrTakenInner(expr, addrTaken, depth)

fn ssaAllocSlot(func: UirCoreFunc, baseSlot: int32): int32 =
    if (!uirCoreFuncIdValid(func)):
        return -1
    let idx: int32 = uirCoreFuncLocalTypesLen(func)
    var ty: UirCoreType = uirCoreTypeI32()
    if baseSlot >= 0 && baseSlot < uirCoreFuncLocalTypesLen(func):
        ty = uirCoreFuncLocalTypeAt(func, baseSlot)
    uirCoreSetLocalType(func, idx, ty)
    return idx

fn ssaPush(varTop: var int32[], stackVal: var int32[], stackPrev: var int32[],
           varId: int32, value: int32) =
    if varId < 0 || varId >= varTop.len:
        return
    let rec: int32 = stackVal.len
    add(stackVal, value)
    add(stackPrev, varTop[varId])
    varTop[varId] = rec

fn ssaPop(varTop: var int32[], stackPrev: int32[], varId: int32) =
    if varId < 0 || varId >= varTop.len:
        return
    let rec: int32 = varTop[varId]
    if rec < 0 || rec >= stackPrev.len:
        return
    varTop[varId] = stackPrev[rec]

fn ssaCurrentSlot(varId: int32, varTop: int32[], stackVal: int32[]): int32 =
    if varId < 0 || varId >= varTop.len:
        return varId
    let rec: int32 = varTop[varId]
    if rec < 0 || rec >= stackVal.len:
        return varId
    return stackVal[rec]

fn ssaRewriteExprInner(expr: UirExprId,
                       baseCount: int32,
                       isCandidate: bool[],
                       varTop: int32[],
                       stackVal: int32[],
                       depth: var int32): Result[bool] =
    if !uirCoreExprIdValid(expr):
        return Ok[bool](true)
    if depth >= ssaExprRecursionLimit():
        return Ok[bool](true)
    depth = depth + 1
    let kind: UirCoreExprKind = uirCoreExprKindOf(expr)
    if kind == meLocal:
        let base: int32 = uirCoreExprLocalIndexOf(expr)
        if base >= 0 && base < baseCount && isCandidate[base]:
            uirCoreExprSetLocalIndex(expr, ssaCurrentSlot(base, varTop, stackVal))
        depth = depth - 1
        return Ok[bool](true)
    if kind == meAddr:
        depth = depth - 1
        return Ok[bool](true)
    if kind == meLoad:
        let r0: Result[bool] = ssaRewriteExprInner(uirCoreExprAddrExprOf(expr), baseCount, isCandidate, varTop, stackVal, depth)
        depth = depth - 1
        return r0
    if kind == meGlobalAddr:
        depth = depth - 1
        return Ok[bool](true)
    if kind == meBin || kind == meCmp:
        let l: Result[bool] = ssaRewriteExprInner(uirCoreExprLhsOf(expr), baseCount, isCandidate, varTop, stackVal, depth)
        if ! IsOk[bool](l):
            depth = depth - 1
            return l
        let r1: Result[bool] = ssaRewriteExprInner(uirCoreExprRhsOf(expr), baseCount, isCandidate, varTop, stackVal, depth)
        depth = depth - 1
        return r1
    if kind == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            let a: Result[bool] = ssaRewriteExprInner(uirCoreExprArgAt(expr, i), baseCount, isCandidate,
                                                      varTop, stackVal, depth)
            if ! IsOk[bool](a):
                depth = depth - 1
                return a
        depth = depth - 1
        return Ok[bool](true)
    if kind == meCast:
        let r2: Result[bool] = ssaRewriteExprInner(uirCoreExprCastExprOf(expr), baseCount, isCandidate, varTop, stackVal, depth)
        depth = depth - 1
        return r2
    depth = depth - 1
    return Ok[bool](true)

fn ssaRewriteExpr(expr: UirExprId, baseCount: int32, isCandidate: bool[],
                  varTop: int32[], stackVal: int32[]): Result[bool] =
    var depth: int32 = 0
    return ssaRewriteExprInner(expr, baseCount, isCandidate, varTop, stackVal, depth)

fn ssaIntersect(b1: int32, b2: int32, idom: int32[], rpoIndex: int32[]): int32 =
    var f1: int32 = b1
    var f2: int32 = b2
    while f1 != f2:
        while f1 >= 0 && f2 >= 0 && rpoIndex[f1] > rpoIndex[f2]:
            let n1: int32 = idom[f1]
            if n1 == f1:
                break
            f1 = n1
        while f2 >= 0 && f1 >= 0 && rpoIndex[f2] > rpoIndex[f1]:
            let n2: int32 = idom[f2]
            if n2 == f2:
                break
            f2 = n2
    return f1

fn ssaEdgeLess(a: SsaEdgeMoves, b: SsaEdgeMoves): bool =
    if (a == nil) || (!uirCoreBlockIdValid(b)):
        return false
    let c: int32 = uirCoreStrCmp(a.toLabel, b.toLabel)
    if c < 0:
        return true
    if c > 0:
        return false
    return uirCoreStrCmp(a.fromLabel, b.fromLabel) < 0

fn ssaSortEdgesStable(edges: SsaEdgeMoves[]*): bool =
    if (edges == nil) || edges->len <= 1:
        return false
    var changed: bool = false
    for i in 1..<edges->len:
        let key: SsaEdgeMoves = edges[i]
        var j: int32 = i - 1
        let __for_start_j = j
        for __for_rev_j in 0..(__for_start_j - (0)):
            j = __for_start_j - __for_rev_j
            if !(ssaEdgeLess(key, edges[j])):
                break
            edges[j + 1] = edges[j]
            changed = true
        edges[j + 1] = key
    return changed

fn ssaStrEq(a: str, b: str): bool =
    if a == b:
        return true
    if len(a) == 0 || len(b) == 0:
        return false
    let n: int32 = len(a)
    if len(b) != n:
        return false
    for i in 0..<n:
        if a[i] != b[i]:
            return false
    return true

fn ssaFindBlockIndexByLabel(func: UirCoreFunc, label: str): int32 =
    if (!uirCoreFuncIdValid(func)) || len(label) == 0:
        return -1
    for i in 0..<uirCoreFuncBlocksLen(func):
        let b: UirBlockId = uirCoreFuncBlockAt(func, i)
        if uirCoreBlockIdValid(b) && ssaStrEq(uirCoreBlockLabelOf(b), label):
            return i
    return -1

fn ssaRenameBlockInner(ctx: SsaRenameCtx, bi: int32, depth: var int32): Result[bool] =
    if (ctx == nil):
        return Err[bool]("uirCore_ssa: nil ctx")
    if depth >= ssaExprRecursionLimit():
        return Err[bool]("uirCore_ssa: rename recursion limit reached")
    depth = depth + 1
    let func: UirCoreFunc = ctx.func
    let n: int32 = ctx.blockCount
    if (!uirCoreFuncIdValid(func)) || n <= 0:
        depth = depth - 1
        return Ok[bool](true)
    if bi < 0 || bi >= n:
        depth = depth - 1
        return Ok[bool](true)
    if ctx.idom[bi] == -1:
        depth = depth - 1
        return Ok[bool](true)
    let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
    if (!uirCoreBlockIdValid(blk)):
        depth = depth - 1
        return Ok[bool](true)

    var pushed: int32[]

    let phis: SsaPhiDef[] = ssaGridPhiRow(ctx.phiDefsByBlock, bi)
    for pi in 0..<phis.len:
        let pd: SsaPhiDef = phis[pi]
        ssaPush(ctx.varTop, ctx.stackVal, ctx.stackPrev, pd.varId, pd.destSlot)
        add(pushed, pd.varId)

    for si in 0..<uirCoreBlockStmtsLen(blk):
        var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
        let stmtKind: UirCoreStmtKind = uirCoreStmtKindOf(st)
        if stmtKind == msLet || stmtKind == msVar || stmtKind == msAssign:
            let rr: Result[bool] = ssaRewriteExpr(uirCoreStmtExprOf(st), ctx.baseCount, ctx.isCandidate,
                                                  ctx.varTop, ctx.stackVal)
            if ! IsOk[bool](rr):
                depth = depth - 1
                return rr
            let base: int32 = uirCoreStmtSlotOf(st)
            if base >= 0 && base < ctx.baseCount && ctx.isCandidate[base]:
                let ns: int32 = ssaAllocSlot(func, base)
                st = uirCoreStmtWithSlot(st, ns)
                ssaPush(ctx.varTop, ctx.stackVal, ctx.stackPrev, base, ns)
                add(pushed, base)
            uirCoreBlockSetStmtAt(blk, si, st)
        elif stmtKind == msParam:
            let base2: int32 = uirCoreStmtSlotOf(st)
            if base2 >= 0 && base2 < ctx.baseCount && ctx.isCandidate[base2]:
                let ns2: int32 = ssaAllocSlot(func, base2)
                st = uirCoreStmtWithSlot(st, ns2)
                ssaPush(ctx.varTop, ctx.stackVal, ctx.stackPrev, base2, ns2)
                add(pushed, base2)
                uirCoreBlockSetStmtAt(blk, si, st)
        elif stmtKind == msStore:
            let rrA: Result[bool] = ssaRewriteExpr(uirCoreStmtAddrExprOf(st), ctx.baseCount, ctx.isCandidate,
                                                   ctx.varTop, ctx.stackVal)
            if ! IsOk[bool](rrA):
                depth = depth - 1
                return rrA
            let rrV: Result[bool] = ssaRewriteExpr(uirCoreStmtExprOf(st), ctx.baseCount, ctx.isCandidate,
                                                   ctx.varTop, ctx.stackVal)
            if ! IsOk[bool](rrV):
                depth = depth - 1
                return rrV
            uirCoreBlockSetStmtAt(blk, si, st)
        else:
            let rr2: Result[bool] = ssaRewriteExpr(uirCoreStmtExprOf(st), ctx.baseCount, ctx.isCandidate,
                                                   ctx.varTop, ctx.stackVal)
            if ! IsOk[bool](rr2):
                depth = depth - 1
                return rr2
            uirCoreBlockSetStmtAt(blk, si, st)

    let term: UirCoreTerm = uirCoreBlockTermOf(blk)
    if uirCoreTermKindOf(term) == mtRet && uirCoreExprIdValid(uirCoreTermRetExprOf(term)):
        let rr3: Result[bool] = ssaRewriteExpr(uirCoreTermRetExprOf(term), ctx.baseCount, ctx.isCandidate,
                                               ctx.varTop, ctx.stackVal)
        if ! IsOk[bool](rr3):
            depth = depth - 1
            return rr3
    elif uirCoreTermKindOf(term) == mtCbr && uirCoreExprIdValid(uirCoreTermCondExprOf(term)):
        let rr4: Result[bool] = ssaRewriteExpr(uirCoreTermCondExprOf(term), ctx.baseCount, ctx.isCandidate,
                                               ctx.varTop, ctx.stackVal)
        if ! IsOk[bool](rr4):
            depth = depth - 1
            return rr4

    let succList: int32[] = ssaGridIntRow(ctx.succs, bi)
    for sxi in 0..<succList.len:
        let toIdx: int32 = succList[sxi]
        if toIdx >= 0 && toIdx < n:
            let toPhis: SsaPhiDef[] = ssaGridPhiRow(ctx.phiDefsByBlock, toIdx)
            if toPhis.len > 0:
                var moves: SsaMove[]
                for mi in 0..<toPhis.len:
                    let pd2: SsaPhiDef = toPhis[mi]
                    var mv: SsaMove
                    mv.destSlot = pd2.destSlot
                    mv.srcSlot = ssaCurrentSlot(pd2.varId, ctx.varTop, ctx.stackVal)
                    add(moves, mv)
                if moves.len > 0:
                    var em: SsaEdgeMoves
                    new em
                    em.fromIdx = bi
                    em.toIdx = toIdx
                    em.fromLabel = uirCoreBlockLabelOf(blk)
                    let toBlk: UirBlockId = uirCoreFuncBlockAt(func, toIdx)
                    em.toLabel = uirCoreBlockLabelOf(toBlk)
                    em.moves = moves
                    ssaAppendCtxEdgeMove(ctx, em)

    let kids: int32[] = ssaGridIntRow(ctx.domChildren, bi)
    for ci in 0..<kids.len:
        let kres: Result[bool] = ssaRenameBlockInner(ctx, kids[ci], depth)
        if ! IsOk[bool](kres):
            depth = depth - 1
            return kres

    while pushed.len > 0:
        let vid: int32 = pushed[pushed.len - 1]
        pushed.len = pushed.len - 1
        ssaPop(ctx.varTop, ctx.stackPrev, vid)
    depth = depth - 1
    return Ok[bool](true)

fn ssaRenameBlock(ctx: SsaRenameCtx, bi: int32): Result[bool] =
    var depth: int32 = 0
    return ssaRenameBlockInner(ctx, bi, depth)

fn uirCoreSsaLowerFunc(module: UirCoreModule, func: UirCoreFunc): Result[bool] =
    if (!uirCoreFuncIdValid(func)):
        return Ok[bool](true)
    if uirCoreFuncIsExtern(func):
        return Ok[bool](true)
    let baseCount: int32 = uirCoreFuncLocalTypesLen(func)
    if baseCount <= 0:
        return Ok[bool](true)
    let n: int32 = uirCoreFuncBlocksLen(func)
    if n <= 0:
        return Ok[bool](true)

    for bi in 0..<n:
        let b: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(b)) || len(uirCoreBlockLabelOf(b)) == 0:
            return Err[bool]("uirCore_ssa: missing block label (" + uirCoreFuncNameOf(func) + ")")

    var preds: SsaGridInt32 = ssaNewSeq2DInt(n)
    var succs: SsaGridInt32 = ssaNewSeq2DInt(n)
    for bi in 0..<n:
        let b2: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(b2)):
            continue
        let term: UirCoreTerm = uirCoreBlockTermOf(b2)
        if uirCoreTermKindOf(term) == mtBr:
            let si: int32 = ssaFindBlockIndexByLabel(func, uirCoreTermTargetOf(term))
            if si < 0:
                return Err[bool]("uirCore_ssa: br target not found (" + uirCoreFuncNameOf(func) + ":" + uirCoreBlockLabelOf(b2) + ")")
            ssa2dAddUniqueInt(succs, bi, si)
            ssa2dAddUniqueInt(preds, si, bi)
        elif uirCoreTermKindOf(term) == mtCbr:
            let targetTrue: str = uirCoreTermTargetTrueOf(term)
            let targetFalse: str = uirCoreTermTargetFalseOf(term)
            let st: int32 = ssaFindBlockIndexByLabel(func, targetTrue)
            let sf: int32 = ssaFindBlockIndexByLabel(func, targetFalse)
            if st < 0 || sf < 0:
                var labelsDumpParts: str[]
                for li in 0..<n:
                    let lb: UirBlockId = uirCoreFuncBlockAt(func, li)
                    if (!uirCoreBlockIdValid(lb)):
                        continue
                    if labelsDumpParts.len > 0:
                        seqs.add(labelsDumpParts, ",")
                    let lbl: str = uirCoreBlockLabelOf(lb)
                    seqs.add(labelsDumpParts, lbl)
                    seqs.add(labelsDumpParts, "#")
                    seqs.add(labelsDumpParts, uirCoreU64ToHex(uirCoreFnv1a64(lbl)))
                let labelsDump: str = strutils.join(labelsDumpParts, "")
                return Err[bool]("uirCore_ssa: cbr target not found (" + uirCoreFuncNameOf(func) + ":" + uirCoreBlockLabelOf(b2) +
                                 ") true=" + targetTrue +
                                 " true_len=" + intToStr(len(targetTrue)) +
                                 " true_hash=" + uirCoreU64ToHex(uirCoreFnv1a64(targetTrue)) +
                                 " false=" + targetFalse +
                                 " false_len=" + intToStr(len(targetFalse)) +
                                 " false_hash=" + uirCoreU64ToHex(uirCoreFnv1a64(targetFalse)) +
                                 " labels=[" + labelsDump + "]")
            ssa2dAddUniqueInt(succs, bi, st)
            ssa2dAddUniqueInt(succs, bi, sf)
            ssa2dAddUniqueInt(preds, st, bi)
            ssa2dAddUniqueInt(preds, sf, bi)

    var entry: int32 = ssaFindBlockIndexByLabel(func, "entry")
    if entry < 0:
        entry = 0

    # Reverse postorder of reachable CFG.
    var visited: bool[]
    for i2 in 0..<n:
        add(visited, false)
    var stackNodes: int32[]
    var stackNext: int32[]
    var post: int32[]
    if entry >= 0 && entry < n:
        visited[entry] = true
        add(stackNodes, entry)
        add(stackNext, int32(0))
    while stackNodes.len > 0:
        let topIdx: int32 = stackNodes.len - 1
        let v: int32 = stackNodes[topIdx]
        let nextI: int32 = stackNext[topIdx]
        let vsucc: int32[] = ssaGridIntRow(succs, v)
        if nextI < vsucc.len:
            let s: int32 = vsucc[nextI]
            stackNext[topIdx] = nextI + 1
            if s >= 0 && s < n && ! visited[s]:
                visited[s] = true
                add(stackNodes, s)
                add(stackNext, int32(0))
        else:
            add(post, v)
            stackNodes.len = topIdx
            stackNext.len = topIdx

    var rpo: int32[]
    i2 = post.len - 1
    let __for_start_i2_1 = i2
    for __for_i2_1 in 0..(__for_start_i2_1 - (0)):
        i2 = __for_start_i2_1 - __for_i2_1
        add(rpo, post[i2])
        i2 = i2 - 1

    # rpoIndex for intersect; unreachable blocks get a large index.
    var rpoIndex: int32[]
    i2 = 0
    let __for_start_i2_2 = i2
    for __for_i2_2 in __for_start_i2_2..<n:
        i2 = __for_i2_2
        add(rpoIndex, 1000000000)
        i2 = i2 + 1
    i2 = 0
    let __for_start_i2_3 = i2
    for __for_i2_3 in __for_start_i2_3..<rpo.len:
        i2 = __for_i2_3
        rpoIndex[rpo[i2]] = i2
        i2 = i2 + 1

    # idom via Cooper-Harvey-Kennedy.
    var idom: int32[]
    i2 = 0
    let __for_start_i2_4 = i2
    for __for_i2_4 in __for_start_i2_4..<n:
        i2 = __for_i2_4
        add(idom, -1)
        i2 = i2 + 1
    if entry >= 0 && entry < n:
        idom[entry] = entry
    var changed: bool = true
    while changed:
        changed = false
        i2 = 0
        let __for_start_i2_5 = i2
        for __for_i2_5 in __for_start_i2_5..<rpo.len:
            i2 = __for_i2_5
            let b3: int32 = rpo[i2]
            if b3 == entry:
                i2 = i2 + 1
                continue
            let ps: int32[] = ssaGridIntRow(preds, b3)
            var newIdom: int32 = -1
            for pi in 0..<ps.len:
                let p: int32 = ps[pi]
                if p >= 0 && p < n && idom[p] != -1:
                    if newIdom == -1:
                        newIdom = p
                    else:
                        newIdom = ssaIntersect(p, newIdom, idom, rpoIndex)
            if newIdom != -1 && idom[b3] != newIdom:
                idom[b3] = newIdom
                changed = true
            i2 = i2 + 1

    var domChildren: SsaGridInt32 = ssaNewSeq2DInt(n)
    bi = 0
    let __for_start_bi_6 = bi
    for __for_bi_6 in __for_start_bi_6..<n:
        bi = __for_bi_6
        if bi != entry:
            let p2: int32 = idom[bi]
            if p2 >= 0 && p2 < n && p2 != bi:
                ssa2dAddUniqueInt(domChildren, p2, bi)
        bi = bi + 1

    # Dominance frontier.
    var df: SsaGridInt32 = ssaNewSeq2DInt(n)
    bi = 0
    let __for_start_bi_7 = bi
    for __for_bi_7 in __for_start_bi_7..<n:
        bi = __for_bi_7
        let ps2: int32[] = ssaGridIntRow(preds, bi)
        if ps2.len >= 2:
            for pi2 in 0..<ps2.len:
                var runner: int32 = ps2[pi2]
                while runner >= 0 && runner < n && runner != idom[bi]:
                    ssa2dAddUniqueInt(df, runner, bi)
                    let next2: int32 = idom[runner]
                    if next2 == runner:
                        break
                    runner = next2
        bi = bi + 1

    # Candidate locals: exclude addr-taken + object-local pointer slots.
    var addrTaken: bool[]
    i2 = 0
    let __for_start_i2_8 = i2
    for __for_i2_8 in __for_start_i2_8..<baseCount:
        i2 = __for_i2_8
        add(addrTaken, false)
        i2 = i2 + 1
    bi = 0
    let __for_start_bi_9 = bi
    for __for_bi_9 in __for_start_bi_9..<n:
        bi = __for_bi_9
        let bb: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if uirCoreBlockIdValid(bb):
            for si in 0..<uirCoreBlockStmtsLen(bb):
                let s2: UirStmtId = uirCoreBlockStmtAt(bb, si)
                let stmtKind: UirCoreStmtKind = uirCoreStmtKindOf(s2)
                if stmtKind == msLet || stmtKind == msVar || stmtKind == msAssign:
                    ssaMarkAddrTaken(uirCoreStmtExprOf(s2), addrTaken)
                elif stmtKind == msStore:
                    ssaMarkAddrTaken(uirCoreStmtAddrExprOf(s2), addrTaken)
                    ssaMarkAddrTaken(uirCoreStmtExprOf(s2), addrTaken)
                else:
                    ssaMarkAddrTaken(uirCoreStmtExprOf(s2), addrTaken)
            let termBb: UirCoreTerm = uirCoreBlockTermOf(bb)
            if uirCoreTermKindOf(termBb) == mtRet:
                ssaMarkAddrTaken(uirCoreTermRetExprOf(termBb), addrTaken)
            elif uirCoreTermKindOf(termBb) == mtCbr:
                ssaMarkAddrTaken(uirCoreTermCondExprOf(termBb), addrTaken)
        bi = bi + 1

    var isCandidate: bool[]
    i2 = 0
    let __for_start_i2_10 = i2
    for __for_i2_10 in __for_start_i2_10..<baseCount:
        i2 = __for_i2_10
        add(isCandidate, true)
        i2 = i2 + 1
    i2 = 0
    let __for_start_i2_11 = i2
    for __for_i2_11 in __for_start_i2_11..<baseCount:
        i2 = __for_i2_11
        if addrTaken[i2]:
            isCandidate[i2] = false
        i2 = i2 + 1
    for oi in 0..<uirCoreFuncObjLocalsLen(func):
        let ol: UirCoreObjLocal = uirCoreFuncObjLocalAt(func, oi)
        if ol.slot >= 0 && ol.slot < baseCount:
            isCandidate[ol.slot] = false

    # defBlocks[var] = blocks defining base slot.
    var defBlocks: SsaGridInt32 = ssaNewSeq2DInt(baseCount)
    bi = 0
    let __for_start_bi_12 = bi
    for __for_bi_12 in __for_start_bi_12..<n:
        bi = __for_bi_12
        let bb2: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if uirCoreBlockIdValid(bb2):
            for si2 in 0..<uirCoreBlockStmtsLen(bb2):
                let s3: UirStmtId = uirCoreBlockStmtAt(bb2, si2)
                let stmtKind3: UirCoreStmtKind = uirCoreStmtKindOf(s3)
                if stmtKind3 == msLet || stmtKind3 == msVar || stmtKind3 == msAssign || stmtKind3 == msParam:
                    let v: int32 = uirCoreStmtSlotOf(s3)
                    if v >= 0 && v < baseCount && isCandidate[v]:
                        ssa2dAddUniqueInt(defBlocks, v, bi)
        bi = bi + 1

    # Place phi vars by dominance frontier.
    var phiVarsByBlock: SsaGridInt32 = ssaNewSeq2DInt(n)
    for vId in 0..<baseCount:
        if ! isCandidate[vId]:
            continue
        let defs0: int32[] = ssaGridIntRow(defBlocks, vId)
        if defs0.len <= 1:
            continue
        var isDef: bool[]
        i2 = 0
        let __for_start_i2_13 = i2
        for __for_i2_13 in __for_start_i2_13..<n:
            i2 = __for_i2_13
            add(isDef, false)
            i2 = i2 + 1
        i2 = 0
        let __for_start_i2_14 = i2
        for __for_i2_14 in __for_start_i2_14..<defs0.len:
            i2 = __for_i2_14
            let d: int32 = defs0[i2]
            if d >= 0 && d < n:
                isDef[d] = true
            i2 = i2 + 1

        var hasPhi: bool[]
        i2 = 0
        let __for_start_i2_15 = i2
        for __for_i2_15 in __for_start_i2_15..<n:
            i2 = __for_i2_15
            add(hasPhi, false)
            i2 = i2 + 1

        var work: int32[] = defs0
        while work.len > 0:
            let b4: int32 = work[work.len - 1]
            work.len = work.len - 1
            let frontier: int32[] = ssaGridIntRow(df, b4)
            for fi in 0..<frontier.len:
                let y: int32 = frontier[fi]
                if y >= 0 && y < n && ! hasPhi[y]:
                    ssa2dAddUniqueInt(phiVarsByBlock, y, vId)
                    hasPhi[y] = true
                    if ! isDef[y]:
                        add(work, y)

    # Sort phi var lists deterministically and pre-allocate phi dest slots.
    var phiDefsByBlock: SsaGridPhiDefs = ssaNewSeq2DPhiDef(n)
    bi = 0
    let __for_start_bi_16 = bi
    for __for_bi_16 in __for_start_bi_16..<n:
        bi = __for_bi_16
        var vars: int32[] = ssaGridIntRow(phiVarsByBlock, bi)
        ssaSortIntsStable(vars)
        ssaGridIntSetRow(phiVarsByBlock, bi, vars)
        var defsOut: SsaPhiDef[] = ssaGridPhiRow(phiDefsByBlock, bi)
        for vi in 0..<vars.len:
            let varId2: int32 = vars[vi]
            let dest: int32 = ssaAllocSlot(func, varId2)
            var pd: SsaPhiDef
            pd.varId = varId2
            pd.destSlot = dest
            add(defsOut, pd)
        ssaGridPhiSetRow(phiDefsByBlock, bi, defsOut)
        bi = bi + 1

    # Renaming over dominator tree; record edge moves for phi elimination.
    var ctx: SsaRenameCtx
    new ctx
    ctx.func = func
    ctx.baseCount = baseCount
    ctx.blockCount = n
    ctx.idom = idom
    ctx.domChildren = domChildren
    ctx.succs = succs
    ctx.phiDefsByBlock = phiDefsByBlock
    ctx.isCandidate = isCandidate
    i2 = 0
    let __for_start_i2_17 = i2
    for __for_i2_17 in __for_start_i2_17..<baseCount:
        i2 = __for_i2_17
        ssaAppendCtxVarTop(ctx, -1)
        i2 = i2 + 1
    i2 = 0
    let __for_start_i2_18 = i2
    for __for_i2_18 in __for_start_i2_18..<baseCount:
        i2 = __for_i2_18
        if isCandidate[i2]:
            ssaPush(ctx.varTop, ctx.stackVal, ctx.stackPrev, i2, i2)
        i2 = i2 + 1

    let rrAll: Result[bool] = ssaRenameBlock(ctx, entry)
    if ! IsOk[bool](rrAll):
        return rrAll

    ssaSortEdgesStable(&ctx.edgeMoves)

    # Apply phi elimination moves with safe placement:
    # - from has single succ: append to from
    # - elif to has single pred: prepend to to
    # - else split edge and insert moves in new block
    var succCount: int32[]
    var predCount: int32[]
    bi = 0
    let __for_start_bi_19 = bi
    for __for_bi_19 in __for_start_bi_19..<n:
        bi = __for_bi_19
        let succList2: int32[] = ssaGridIntRow(succs, bi)
        let predList2: int32[] = ssaGridIntRow(preds, bi)
        add(succCount, succList2.len)
        add(predCount, predList2.len)
        bi = bi + 1

    for ei in 0..<ctx.edgeMoves.len:
        let em2: SsaEdgeMoves = ctx.edgeMoves[ei]
        if (em2 == nil) || em2.moves.len == 0:
            continue
        let fromBlk: UirBlockId = uirCoreFuncBlockAt(func, em2.fromIdx)
        if (!uirCoreBlockIdValid(fromBlk)):
            continue
        let fromSucc: int32 = succCount[em2.fromIdx]
        let toPred: int32 = predCount[em2.toIdx]
        if fromSucc == 1:
            for mi in 0..<em2.moves.len:
                let mv: SsaMove = em2.moves[mi]
                var appendStmts: UirStmtId[] = []
                for si in 0..<uirCoreBlockStmtsLen(fromBlk):
                    add(appendStmts, uirCoreBlockStmtAt(fromBlk, si))
                add(appendStmts, uirCoreStmtAssign("", mv.destSlot, uirCoreLocal(mv.srcSlot)))
                uirCoreBlockSetStmts(fromBlk, appendStmts)
            continue
        if toPred == 1:
            let toBlk: UirBlockId = uirCoreFuncBlockAt(func, em2.toIdx)
            if (!uirCoreBlockIdValid(toBlk)):
                return Err[bool]("uirCore_ssa: missing to block (" + uirCoreFuncNameOf(func) + ")")
            var newStmts: UirStmtId[]
            for mi2 in 0..<em2.moves.len:
                let mv2: SsaMove = em2.moves[mi2]
                add(newStmts, uirCoreStmtAssign("", mv2.destSlot, uirCoreLocal(mv2.srcSlot)))
            mi2 = 0
            let __for_start_mi2_20 = mi2
            for __for_mi2_20 in __for_start_mi2_20..<uirCoreBlockStmtsLen(toBlk):
                mi2 = __for_mi2_20
                add(newStmts, uirCoreBlockStmtAt(toBlk, mi2))
                mi2 = mi2 + 1
            uirCoreBlockSetStmts(toBlk, newStmts)
            continue

        # Split edge.
        let h: int64 = uirCoreFnv1a64(uirCoreFuncNameOf(func) + ":" + em2.fromLabel + "->" + em2.toLabel)
        var newLabelParts: str[]
        seqs.add(newLabelParts, "ssa_phi_edge_")
        seqs.add(newLabelParts, uirCoreU64ToHex(h))
        let newLabel: str = strutils.join(newLabelParts, "")
        var stmtsOut: UirStmtId[]
        for mi3 in 0..<em2.moves.len:
            let mv3: SsaMove = em2.moves[mi3]
            add(stmtsOut, uirCoreStmtAssign("", mv3.destSlot, uirCoreLocal(mv3.srcSlot)))
        let nb: UirBlockId = uirCoreBlockWithStmts(newLabel, stmtsOut, uirCoreTermBr(em2.toLabel))
        uirCoreAddBlock(func, nb)
        let fromTerm: UirCoreTerm = uirCoreBlockTermOf(fromBlk)
        if uirCoreTermKindOf(fromTerm) == mtBr:
            if (uirCoreTermTargetOf(fromTerm) == em2.toLabel):
                uirCoreBlockSetTerm(fromBlk, uirCoreTermWithTarget(fromTerm, uirCoreOwnStr(newLabel)))
        elif uirCoreTermKindOf(fromTerm) == mtCbr:
            var nextTerm: UirCoreTerm = fromTerm
            if (uirCoreTermTargetTrueOf(nextTerm) == em2.toLabel):
                nextTerm = uirCoreTermWithTargetTrue(nextTerm, uirCoreOwnStr(newLabel))
            if (uirCoreTermTargetFalseOf(nextTerm) == em2.toLabel):
                nextTerm = uirCoreTermWithTargetFalse(nextTerm, uirCoreOwnStr(newLabel))
            uirCoreBlockSetTerm(fromBlk, nextTerm)

    return Ok[bool](true)

fn uirCoreSsaLowerModule(module: UirCoreModule): Result[bool] =
    if (module == nil):
        return Ok[bool](true)
    for i in 0..<uirCoreModuleFuncsLen(module):
        let f: UirCoreFunc = uirCoreModuleFuncAt(module, i)
        let r: Result[bool] = uirCoreSsaLowerFunc(module, f)
        if ! IsOk[bool](r):
            return r
    return Ok[bool](true)
# ---- end backend/uir/uir_internal/uir_core_ssa.cheng ----

# ---- begin backend/uir/uir_internal/uir_core_opt.cheng ----
# MIR v1 optimizer (MVP): expression-level constant folding.

fn uirCoreOptReadI32(p: ptr): int32 =
    if p == nil:
        return 0
    var out: int32 = 0
    memCopyCompat(&out, p, int32(sizeof int32))
    return out

fn uirCoreOptWriteI32(p: ptr, value: int32) =
    if p == nil:
        return
    var tmp: int32 = value
    memCopyCompat(p, &tmp, int32(sizeof int32))

fn uirCoreOptWriteBool(p: ptr, value: bool) =
    if p == nil:
        return
    var tmp: bool = value
    memCopyCompat(p, &tmp, int32(sizeof bool))

fn uirCoreOptRecursionLimit(): int32 =
    return 256

fn uirCoreOptMaxType(a: UirCoreType, b: UirCoreType): UirCoreType =
    if a.kind == mtF64 || b.kind == mtF64:
        return uirCoreTypeF64()
    if a.kind == mtF32 || b.kind == mtF32:
        return uirCoreTypeF32()
    if a.kind == mtI64 || b.kind == mtI64:
        var out: UirCoreType = uirCoreTypeI64()
        if a.kind == mtI64:
            out.isUnsigned = a.isUnsigned
        elif b.kind == mtI64:
            out.isUnsigned = b.isUnsigned
        return out
    var out2: UirCoreType = uirCoreTypeI32()
    out2.isUnsigned = a.isUnsigned || b.isUnsigned
    return out2

fn uirCoreOptExprTypeInner(module: UirCoreModule,
                           func: UirCoreFunc,
                           expr: UirExprId,
                           fallback: UirCoreType,
                           depth: ptr): UirCoreType =
    if (!uirCoreExprIdValid(expr)) || (depth == nil):
        return fallback
    if uirCoreOptReadI32(depth) >= uirCoreOptRecursionLimit():
        return fallback
    uirCoreOptWriteI32(depth, uirCoreOptReadI32(depth) + 1)
    var out: UirCoreType = fallback
    let kind: UirCoreExprKind = uirCoreExprKindOf(expr)
    if kind == meLocal:
        let localIndex: int32 = uirCoreExprLocalIndexOf(expr)
        if uirCoreFuncIdValid(func) && localIndex >= 0 && localIndex < uirCoreFuncLocalTypesLen(func):
            out = uirCoreFuncLocalTypeAt(func, localIndex)
        else:
            out = fallback
    elif kind == meCall:
        let callee: str = uirCoreExprCalleeOf(expr)
        if !(module == nil) && len(callee) > 0:
            let funcCount: int32 = uirCoreModuleFuncsLen(module)
            for i in 0..<funcCount:
                let f: UirCoreFunc = uirCoreModuleFuncAt(module, i)
                if !(f == nil) && (uirCoreFuncNameOf(f) == callee):
                    out = uirCoreFuncRetTypeOf(f)
                    break
        else:
            out = fallback
    elif kind == meBin:
        let binOp: UirCoreBinOp = uirCoreExprBinOpOf(expr)
        if binOp == mbShl || binOp == mbShr:
            out = uirCoreOptExprTypeInner(module, func, uirCoreExprLhsOf(expr), fallback, depth)
        else:
            let lt: UirCoreType = uirCoreOptExprTypeInner(module, func, uirCoreExprLhsOf(expr), fallback, depth)
            let rt: UirCoreType = uirCoreOptExprTypeInner(module, func, uirCoreExprRhsOf(expr), fallback, depth)
            out = uirCoreOptMaxType(lt, rt)
    elif kind == meCmp:
        out = uirCoreTypeI32()
    elif kind == meCast:
        out = uirCoreExprCastTypeOf(expr)
    elif kind == meAddr:
        out = uirCoreTypeI64()
    elif kind == meLoad:
        let loadTy: UirCoreType = uirCoreExprLoadTypeOf(expr)
        if loadTy.kind == mtVoid:
            out = fallback
        else:
            out = loadTy
    elif kind == meGlobalAddr:
        out = uirCoreTypeI64()
    else:
        out = fallback
    uirCoreOptWriteI32(depth, uirCoreOptReadI32(depth) - 1)
    return out

fn uirCoreOptExprType(module: UirCoreModule, func: UirCoreFunc, expr: UirExprId, fallback: UirCoreType): UirCoreType =
    var depth: int32 = 0
    return uirCoreOptExprTypeInner(module, func, expr, fallback, &depth)

fn uirCoreOptWidth(ty: UirCoreType): int32 =
    if ty.kind == mtF32:
        return 32
    if ty.kind == mtF64:
        return 64
    if ty.kind == mtI8:
        return 8
    if ty.kind == mtI16:
        return 16
    if ty.kind == mtI32:
        return 32
    if ty.kind == mtI64:
        return 64
    return 64

fn uirCoreOptNorm(v: uint64, ty: UirCoreType): uint64 =
    let w: int32 = uirCoreOptWidth(ty)
    if w >= 64:
        return v
    let mask: uint64 = (uint64(1) << uint64(w)) - uint64(1)
    return v & mask

fn uirCoreOptSignedKey(v: uint64, ty: UirCoreType): uint64 =
    let w: int32 = uirCoreOptWidth(ty)
    let sign: uint64 = uint64(1) << (w - 1)
    return uirCoreOptNorm(v, ty) ^ sign

fn uirCoreOptArithShr(v: uint64, sh: int32, ty: UirCoreType): uint64 =
    let w: int32 = uirCoreOptWidth(ty)
    let vv: uint64 = uirCoreOptNorm(v, ty)
    if sh <= 0:
        return vv
    if sh >= w:
        # All bits become sign bit.
        let sign: uint64 = uint64(1) << (w - 1)
        return (vv & sign) != 0 ? uirCoreOptNorm(uint64(0) - uint64(1), ty) : uint64(0)
    let shifted: uint64 = vv >> sh
    let sign2: uint64 = uint64(1) << (w - 1)
    if (vv & sign2) == 0:
        return shifted
    let fill: uint64 = (uint64(0) - uint64(1)) << (w - sh)
    return uirCoreOptNorm(shifted | fill, ty)

fn uirCoreOptFoldBin(op: UirCoreBinOp, a0: int64, b0: int64, ty: UirCoreType, ok: ptr): int64 =
    if !(ok == nil):
        uirCoreOptWriteBool(ok, false)
    let a: uint64 = uirCoreOptNorm(uint64(a0), ty)
    let b: uint64 = uirCoreOptNorm(uint64(b0), ty)
    var out: uint64 = 0
    case op
    of mbAdd:
        out = a + b
    of mbSub:
        out = a - b
    of mbMul:
        out = a * b
    of mbAnd:
        out = a & b
    of mbOr:
        out = a | b
    of mbXor:
        out = a ^ b
    of mbShl:
        let w: int32 = uirCoreOptWidth(ty)
        let sh: int32 = int32(b % uint64(w))
        out = uirCoreOptNorm(a << sh, ty)
        if !(ok == nil):
            *ok = true
        return int64(out)
    of mbShr:
        let w2: int32 = uirCoreOptWidth(ty)
        let sh2: int32 = int32(b % uint64(w2))
        if ty.isUnsigned:
            out = uirCoreOptNorm(a >> sh2, ty)
        else:
            out = uirCoreOptArithShr(a, sh2, ty)
        if !(ok == nil):
            *ok = true
        return int64(out)
    else:
        return 0
    out = uirCoreOptNorm(out, ty)
    if !(ok == nil):
        uirCoreOptWriteBool(ok, true)
    return int64(out)

fn uirCoreOptFoldCmp(op: UirCoreCmpOp, a0: int64, b0: int64, ty: UirCoreType): int64 =
    let a: uint64 = uirCoreOptNorm(uint64(a0), ty)
    let b: uint64 = uirCoreOptNorm(uint64(b0), ty)
    var pass: bool = false
    if ty.isUnsigned:
        case op
        of mcEq: pass = (a == b)
        of mcNe: pass = (a != b)
        of mcLt: pass = (a < b)
        of mcLe: pass = (a <= b)
        of mcGt: pass = (a > b)
        of mcGe: pass = (a >= b)
        else:
            pass = false
    else:
        let ka: uint64 = uirCoreOptSignedKey(a, ty)
        let kb: uint64 = uirCoreOptSignedKey(b, ty)
        case op
        of mcEq: pass = (a == b)
        of mcNe: pass = (a != b)
        of mcLt: pass = (ka < kb)
        of mcLe: pass = (ka <= kb)
        of mcGt: pass = (ka > kb)
        of mcGe: pass = (ka >= kb)
        else:
            pass = false
    return pass ? 1 : 0

fn uirCoreOptFoldCast(srcType: UirCoreType, dstType: UirCoreType, v0: int64): int64 =
    let srcW: int32 = uirCoreOptWidth(srcType)
    let dstW: int32 = uirCoreOptWidth(dstType)
    let vv: uint64 = uirCoreOptNorm(uint64(v0), srcType)
    # Truncate or re-interpret same-width values.
    if dstW <= srcW:
        return int64(uirCoreOptNorm(vv, dstType))
    # Zero-extend.
    if dstType.isUnsigned:
        return int64(vv)
    # Sign-extend.
    if srcW >= 64:
        return int64(vv)
    let sign: uint64 = uint64(1) << uint64(srcW - 1)
    if (vv & sign) == 0:
        return int64(vv)
    let mask: uint64 = (uint64(1) << uint64(srcW)) - uint64(1)
    return int64(vv | (~mask))

fn uirCoreOptCastHasFloat(srcType: UirCoreType, dstType: UirCoreType): bool =
    if srcType.kind == mtF32 || srcType.kind == mtF64:
        return true
    if dstType.kind == mtF32 || dstType.kind == mtF64:
        return true
    return false

fn uirCoreOptTypeEq(a: UirCoreType, b: UirCoreType): bool =
    return a.kind == b.kind && a.isUnsigned == b.isUnsigned

fn uirCoreOptExprInner(module: UirCoreModule,
                       func: UirCoreFunc,
                       expr: UirExprId,
                       fallback: UirCoreType,
                       depth: ptr): UirExprId =
    if (!uirCoreExprIdValid(expr)) || (depth == nil):
        return uirCoreInvalidId()
    if *depth >= uirCoreOptRecursionLimit():
        return expr
    *depth = *depth + 1
    var out: UirExprId = expr
    let kind: UirCoreExprKind = uirCoreExprKindOf(expr)
    if kind == meConstI64 || kind == meLocal || kind == meAddr || kind == meGlobalAddr:
        out = expr
    elif kind == meLoad:
        let addrExpr: UirExprId = uirCoreExprAddrExprOf(expr)
        uirCoreExprSetAddrExpr(expr, uirCoreOptExprInner(module, func, addrExpr, uirCoreTypeI64(), depth))
        out = expr
    elif kind == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            let a: UirExprId = uirCoreExprArgAt(expr, i)
            let at: UirCoreType = uirCoreOptExprType(module, func, a, fallback)
            uirCoreExprSetArgAt(expr, i, uirCoreOptExprInner(module, func, a, at, depth))
        out = expr
    elif kind == meCast:
        let castExpr: UirExprId = uirCoreExprCastExprOf(expr)
        let castType: UirCoreType = uirCoreExprCastTypeOf(expr)
        let srcType: UirCoreType = uirCoreOptExprType(module, func, castExpr, fallback)
        uirCoreExprSetCastExpr(expr, uirCoreOptExprInner(module, func, castExpr, srcType, depth))
        let inner: UirExprId = uirCoreExprCastExprOf(expr)
        if uirCoreOptTypeEq(srcType, castType):
            out = inner
        elif uirCoreExprIdValid(inner) && uirCoreExprKindOf(inner) == meConstI64:
            # Numeric float casts in Cheng are lowered via runtime helpers in MIR builder.
            # Folding them as bit-width trunc/extend is semantically wrong, so keep the cast.
            if uirCoreOptCastHasFloat(srcType, castType):
                out = expr
            else:
                let v2: int64 = uirCoreOptFoldCast(srcType, castType, uirCoreExprConstValueOf(inner))
                out = uirCoreConstI64(v2)
        else:
            out = expr
    elif kind == meBin:
        let exprType: UirCoreType = uirCoreOptExprType(module, func, expr, fallback)
        uirCoreExprSetLhs(expr, uirCoreOptExprInner(module, func, uirCoreExprLhsOf(expr), exprType, depth))
        uirCoreExprSetRhs(expr, uirCoreOptExprInner(module, func, uirCoreExprRhsOf(expr), exprType, depth))
        let lhs0: UirExprId = uirCoreExprLhsOf(expr)
        let rhs0: UirExprId = uirCoreExprRhsOf(expr)
        if uirCoreExprIdValid(lhs0) && uirCoreExprIdValid(rhs0) &&
           uirCoreExprKindOf(lhs0) == meConstI64 && uirCoreExprKindOf(rhs0) == meConstI64:
            var ok: bool = false
            let v3: int64 = uirCoreOptFoldBin(uirCoreExprBinOpOf(expr), uirCoreExprConstValueOf(lhs0),
                                              uirCoreExprConstValueOf(rhs0), exprType, &ok)
            if ok:
                out = uirCoreConstI64(v3)
            else:
                out = expr
        else:
            out = expr
    elif kind == meCmp:
        let lhsExpr: UirExprId = uirCoreExprLhsOf(expr)
        let rhsExpr: UirExprId = uirCoreExprRhsOf(expr)
        let lt: UirCoreType = uirCoreOptExprType(module, func, lhsExpr, fallback)
        let rt: UirCoreType = uirCoreOptExprType(module, func, rhsExpr, fallback)
        let cmpTy: UirCoreType = uirCoreOptMaxType(lt, rt)
        uirCoreExprSetLhs(expr, uirCoreOptExprInner(module, func, lhsExpr, cmpTy, depth))
        uirCoreExprSetRhs(expr, uirCoreOptExprInner(module, func, rhsExpr, cmpTy, depth))
        let lhs1: UirExprId = uirCoreExprLhsOf(expr)
        let rhs1: UirExprId = uirCoreExprRhsOf(expr)
        if uirCoreExprIdValid(lhs1) && uirCoreExprIdValid(rhs1) &&
           uirCoreExprKindOf(lhs1) == meConstI64 && uirCoreExprKindOf(rhs1) == meConstI64:
            out = uirCoreConstI64(uirCoreOptFoldCmp(uirCoreExprCmpOpOf(expr), uirCoreExprConstValueOf(lhs1),
                                                    uirCoreExprConstValueOf(rhs1), cmpTy))
        else:
            out = expr
    else:
        out = expr
    *depth = *depth - 1
    return out

fn uirCoreOptExpr(module: UirCoreModule, func: UirCoreFunc, expr: UirExprId, fallback: UirCoreType): UirExprId =
    var depth: int32 = 0
    return uirCoreOptExprInner(module, func, expr, fallback, &depth)

fn uirCoreOptimizeFunc(module: UirCoreModule, func: UirCoreFunc): bool =
    if (module == nil) || (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    let fallback: UirCoreType = uirCoreFuncRetTypeOf(func)
    let blockCount: int32 = uirCoreFuncBlocksLen(func)
    for bi in 0..<blockCount:
        let b: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if uirCoreBlockIdValid(b):
            let stmtCount: int32 = uirCoreBlockStmtsLen(b)
            for si in 0..<stmtCount:
                var s: UirStmtId = uirCoreBlockStmtAt(b, si)
                let stmtKind: UirCoreStmtKind = uirCoreStmtKindOf(s)
                if stmtKind == msLet || stmtKind == msVar || stmtKind == msAssign:
                    var slotTy: UirCoreType = fallback
                    let slot: int32 = uirCoreStmtSlotOf(s)
                    if slot >= 0 && slot < uirCoreFuncLocalTypesLen(func):
                        slotTy = uirCoreFuncLocalTypeAt(func, slot)
                    s = uirCoreStmtWithExpr(s, uirCoreOptExpr(module, func, uirCoreStmtExprOf(s), slotTy))
                    uirCoreBlockSetStmtAt(b, si, s)
                elif stmtKind == msStore:
                    s = uirCoreStmtWithAddrExpr(s, uirCoreOptExpr(module, func, uirCoreStmtAddrExprOf(s), uirCoreTypeI64()))
                    s = uirCoreStmtWithExpr(s, uirCoreOptExpr(module, func, uirCoreStmtExprOf(s), uirCoreStmtStoreTypeOf(s)))
                    uirCoreBlockSetStmtAt(b, si, s)
                else:
                    s = uirCoreStmtWithExpr(s, uirCoreOptExpr(module, func, uirCoreStmtExprOf(s), fallback))
                    uirCoreBlockSetStmtAt(b, si, s)
            let term: UirCoreTerm = uirCoreBlockTermOf(b)
            if uirCoreTermKindOf(term) == mtRet && uirCoreExprIdValid(uirCoreTermRetExprOf(term)):
                let nextTerm: UirCoreTerm = uirCoreTermWithRetExpr(
                    term,
                    uirCoreOptExpr(module, func, uirCoreTermRetExprOf(term), uirCoreFuncRetTypeOf(func))
                )
                uirCoreBlockSetTerm(b, nextTerm)
                uirCoreFuncSetBlockAt(func, bi, b)
            elif uirCoreTermKindOf(term) == mtCbr && uirCoreExprIdValid(uirCoreTermCondExprOf(term)):
                let nextTerm2: UirCoreTerm = uirCoreTermWithCondExpr(
                    term,
                    uirCoreOptExpr(module, func, uirCoreTermCondExprOf(term), uirCoreTypeI32())
                )
                uirCoreBlockSetTerm(b, nextTerm2)
                uirCoreFuncSetBlockAt(func, bi, b)
    return true

fn uirCoreOptimizeModule(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var any: bool = false
    for i in 0..<uirCoreModuleFuncsLen(module):
        let f: UirCoreFunc = uirCoreModuleFuncAt(module, i)
        if uirCoreOptimizeFunc(module, f):
            any = true
    return any
# ---- end backend/uir/uir_internal/uir_core_opt.cheng ----

# ---- begin backend/uir/uir_internal/uir_core_opt2.cheng ----

fn add(seqInst: var bool[], val: bool) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var int32[], val: int32) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var UirExprId[], val: UirExprId) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var UirExpr[], val: UirExpr) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var UirBlockId[], val: UirBlockId) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var UirStmtId[], val: UirStmtId) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var str[], val: str) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var UirCoreFunc[], val: UirCoreFunc) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn uirCoreOpt2LowerAscii(s: str): str =
    return strutils.toLowerAscii(s)

fn uirCoreOpt2ParseBoolEnv(name: str, defaultValue: bool): bool =
    let raw: str = uirOptGetEnvDefault(name, "")
    if len(raw) == 0:
        return defaultValue
    let s: str = uirCoreOpt2LowerAscii(raw)
    if s == "1" || s == "true" || s == "yes" || s == "on":
        return true
    if s == "0" || s == "false" || s == "no" || s == "off":
        return false
    return defaultValue

fn uirCoreOpt2ParseIntEnv(name: str, defaultValue: int32, minValue: int32, maxValue: int32): int32 =
    let raw: str = uirOptGetEnvDefault(name, "")
    if len(raw) == 0:
        return defaultValue
    let n: int32 = len(raw)
    var i: int32 = 0
    var neg: bool = false
    if raw[0] == '-':
        neg = true
        i = 1
    if i >= n:
        return defaultValue
    var v: int64 = 0
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        let c: char = raw[i]
        if c < '0' || c > '9':
            return defaultValue
        v = v * 10 + int64(int32(c) - int32('0'))
        i = i + 1
    if neg:
        v = -v
    if v < int64(minValue):
        return minValue
    if v > int64(maxValue):
        return maxValue
    return int32(v)

fn uirCoreOpt2TypeKey(ty: UirCoreType): str =
    if ty.kind == mtVoid:
        return "v"
    if ty.kind == mtI8:
        return ty.isUnsigned ? "u8" : "i8"
    if ty.kind == mtI16:
        return ty.isUnsigned ? "u16" : "i16"
    if ty.kind == mtI32:
        return ty.isUnsigned ? "u32" : "i32"
    if ty.kind == mtI64:
        return ty.isUnsigned ? "u64" : "i64"
    if ty.kind == mtF32:
        return "f32"
    if ty.kind == mtF64:
        return "f64"
    return "ty"

fn uirCoreOpt2TypeEq(a: UirCoreType, b: UirCoreType): bool =
    return a.kind == b.kind && a.isUnsigned == b.isUnsigned

fn uirCoreOpt2ExprScanBudget(): int32 =
    # Keep opt2 resilient to pathological or cyclic expression graphs.
    return 2000000

fn uirCoreOpt2RecursionLimit(): int32 =
    # Guard recursive helper fallbacks from pathological expression graphs.
    return 256

fn uirCoreOpt2ExprSeenOrMark(seen: var bool[], expr: UirExprId): bool =
    if !uirCoreExprIdValid(expr):
        return false
    for __for_guard_seen_grow in seen.len..expr:
        add(seen, false)
    if seen[expr]:
        return true
    seen[expr] = true
    return false

fn uirCoreOpt2BlockSetTerm(blk: UirBlockId, term: UirCoreTerm) =
    if (!uirCoreBlockIdValid(blk)):
        return
    uirCoreBlockSetTerm(blk, term)

fn uirCoreOpt2BlockSetRetExpr(blk: UirBlockId, retExpr: UirExprId) =
    if (!uirCoreBlockIdValid(blk)):
        return
    var term: UirCoreTerm = uirCoreBlockTermOf(blk)
    term = uirCoreTermWithRetExpr(term, retExpr)
    uirCoreBlockSetTerm(blk, term)

fn uirCoreOpt2BlockSetCondExpr(blk: UirBlockId, condExpr: UirExprId) =
    if (!uirCoreBlockIdValid(blk)):
        return
    var term: UirCoreTerm = uirCoreBlockTermOf(blk)
    term = uirCoreTermWithCondExpr(term, condExpr)
    uirCoreBlockSetTerm(blk, term)

fn uirCoreOpt2BlockSetTarget(blk: UirBlockId, target: str) =
    if (!uirCoreBlockIdValid(blk)):
        return
    var term: UirCoreTerm = uirCoreBlockTermOf(blk)
    term = uirCoreTermWithTarget(term, target)
    uirCoreBlockSetTerm(blk, term)

fn uirCoreOpt2BlockSetTargetTrue(blk: UirBlockId, targetTrue: str) =
    if (!uirCoreBlockIdValid(blk)):
        return
    var term: UirCoreTerm = uirCoreBlockTermOf(blk)
    term = uirCoreTermWithTargetTrue(term, targetTrue)
    uirCoreBlockSetTerm(blk, term)

fn uirCoreOpt2BlockSetTargetFalse(blk: UirBlockId, targetFalse: str) =
    if (!uirCoreBlockIdValid(blk)):
        return
    var term: UirCoreTerm = uirCoreBlockTermOf(blk)
    term = uirCoreTermWithTargetFalse(term, targetFalse)
    uirCoreBlockSetTerm(blk, term)

fn uirCoreOpt2ExprHasCall(expr: UirExprId): bool =
    if (!uirCoreExprIdValid(expr)):
        return false
    var work: UirExprId[]
    var seen: bool[]
    work.cap = 16
    seen.cap = 16
    add(work, expr)
    var steps: int32 = 0
    let budget: int32 = uirCoreOpt2ExprScanBudget()
    while work.len > 0:
        let cur: UirExprId = work[work.len - 1]
        work.len = work.len - 1
        if (!uirCoreExprIdValid(cur)):
            continue
        if uirCoreOpt2ExprSeenOrMark(seen, cur):
            continue
        steps = steps + 1
        if steps > budget:
            return true
        let k: UirCoreExprKind = uirCoreExprKindOf(cur)
        if k == meCall:
            return true
        if k == meBin || k == meCmp:
            add(work, uirCoreExprRhsOf(cur))
            add(work, uirCoreExprLhsOf(cur))
            continue
        if k == meCast:
            add(work, uirCoreExprCastExprOf(cur))
            continue
        if k == meLoad:
            add(work, uirCoreExprAddrExprOf(cur))
            continue
    return false

fn uirCoreOpt2ExprHasAnyLoad(expr: UirExprId): bool =
    if (!uirCoreExprIdValid(expr)):
        return false
    var work: UirExprId[]
    var seen: bool[]
    work.cap = 16
    seen.cap = 16
    add(work, expr)
    var steps: int32 = 0
    let budget: int32 = uirCoreOpt2ExprScanBudget()
    while work.len > 0:
        let cur: UirExprId = work[work.len - 1]
        work.len = work.len - 1
        if (!uirCoreExprIdValid(cur)):
            continue
        if uirCoreOpt2ExprSeenOrMark(seen, cur):
            continue
        steps = steps + 1
        if steps > budget:
            return true
        let k: UirCoreExprKind = uirCoreExprKindOf(cur)
        if k == meLoad:
            return true
        if k == meBin || k == meCmp:
            add(work, uirCoreExprRhsOf(cur))
            add(work, uirCoreExprLhsOf(cur))
            continue
        if k == meCast:
            add(work, uirCoreExprCastExprOf(cur))
            continue
        if k == meCall:
            for i in 0..<uirCoreExprArgsLen(cur):
                add(work, uirCoreExprArgAt(cur, i))
            continue
    return false

fn uirCoreOpt2ExprIsPure(expr: UirExprId): bool =
    if (!uirCoreExprIdValid(expr)):
        return true
    # Iterative walk avoids stack overflow on cyclic/pathological expr graphs.
    var work: UirExprId[]
    var seen: bool[]
    work.cap = 16
    seen.cap = 16
    add(work, expr)
    var steps: int32 = 0
    let budget: int32 = uirCoreOpt2ExprScanBudget()
    while work.len > 0:
        let cur: UirExprId = work[work.len - 1]
        work.len = work.len - 1
        if (!uirCoreExprIdValid(cur)):
            continue
        if uirCoreOpt2ExprSeenOrMark(seen, cur):
            continue
        steps = steps + 1
        if steps > budget:
            # Conservative answer under pathological/cyclic graphs.
            return false
        let k: UirCoreExprKind = uirCoreExprKindOf(cur)
        if k == meConstI64 || k == meLocal || k == meAddr || k == meGlobalAddr:
            continue
        if k == meCall || k == meLoad:
            return false
        if k == meCast:
            add(work, uirCoreExprCastExprOf(cur))
            continue
        if k == meBin || k == meCmp:
            add(work, uirCoreExprRhsOf(cur))
            add(work, uirCoreExprLhsOf(cur))
            continue
        return false
    return true

fn uirCoreOpt2ExprUsesSlot(expr: UirExprId, slot: int32): bool =
    if (!uirCoreExprIdValid(expr)) || slot < 0:
        return false
    # Iterative walk avoids stack overflow on cyclic/pathological expr graphs.
    var work: UirExprId[]
    var seen: bool[]
    work.cap = 16
    seen.cap = 16
    add(work, expr)
    var steps: int32 = 0
    let budget: int32 = uirCoreOpt2ExprScanBudget()
    while work.len > 0:
        let cur: UirExprId = work[work.len - 1]
        work.len = work.len - 1
        if (!uirCoreExprIdValid(cur)):
            continue
        if uirCoreOpt2ExprSeenOrMark(seen, cur):
            continue
        steps = steps + 1
        if steps > budget:
            # Conservative answer under pathological/cyclic graphs.
            return true
        let k: UirCoreExprKind = uirCoreExprKindOf(cur)
        if k == meLocal || k == meAddr:
            if uirCoreExprLocalIndexOf(cur) == slot:
                return true
            continue
        if k == meBin || k == meCmp:
            add(work, uirCoreExprRhsOf(cur))
            add(work, uirCoreExprLhsOf(cur))
            continue
        if k == meCast:
            add(work, uirCoreExprCastExprOf(cur))
            continue
        if k == meLoad:
            add(work, uirCoreExprAddrExprOf(cur))
            continue
        if k == meCall:
            for i in 0..<uirCoreExprArgsLen(cur):
                add(work, uirCoreExprArgAt(cur, i))
    return false

fn uirCoreOpt2ExprMarkUses(expr: UirExprId, live: var bool[]) =
    if !uirCoreExprIdValid(expr):
        return
    # Iterative walk avoids stack overflow on cyclic/pathological expr graphs.
    var work: UirExprId[]
    var seen: bool[]
    work.cap = 16
    seen.cap = 16
    add(work, expr)
    var steps: int32 = 0
    let budget: int32 = uirCoreOpt2ExprScanBudget()
    while work.len > 0:
        let cur: UirExprId = work[work.len - 1]
        work.len = work.len - 1
        if (!uirCoreExprIdValid(cur)):
            continue
        if uirCoreOpt2ExprSeenOrMark(seen, cur):
            continue
        steps = steps + 1
        if steps > budget:
            # Conservative fallback: keep all locals live.
            for i in 0..<live.len:
                live[i] = true
            return
        let k: UirCoreExprKind = uirCoreExprKindOf(cur)
        if k == meLocal:
            let slot: int32 = uirCoreExprLocalIndexOf(cur)
            if slot >= 0 && slot < live.len:
                live[slot] = true
            continue
        if k == meBin || k == meCmp:
            add(work, uirCoreExprRhsOf(cur))
            add(work, uirCoreExprLhsOf(cur))
            continue
        if k == meCast:
            add(work, uirCoreExprCastExprOf(cur))
            continue
        if k == meLoad:
            add(work, uirCoreExprAddrExprOf(cur))
            continue
        if k == meCall:
            for i in 0..<uirCoreExprArgsLen(cur):
                add(work, uirCoreExprArgAt(cur, i))

fn uirCoreOpt2ResolveAddrBaseInner(expr: UirExprId, depth: var int32): int32 =
    if !uirCoreExprIdValid(expr):
        return -1
    if depth >= uirCoreOpt2RecursionLimit():
        return -1
    depth = depth + 1
    var out: int32 = -1
    if uirCoreExprKindOf(expr) == meAddr:
        out = uirCoreExprLocalIndexOf(expr)
    elif uirCoreExprKindOf(expr) == meCast:
        out = uirCoreOpt2ResolveAddrBaseInner(uirCoreExprCastExprOf(expr), depth)
    depth = depth - 1
    return out

fn uirCoreOpt2ResolveAddrBase(expr: UirExprId): int32 =
    var depth: int32 = 0
    return uirCoreOpt2ResolveAddrBaseInner(expr, depth)

fn uirCoreOpt2ExprHasLoadFromBaseInner(expr: UirExprId, baseSlot: int32, depth: var int32): bool =
    if (!uirCoreExprIdValid(expr)) || baseSlot < 0:
        return false
    if depth >= uirCoreOpt2RecursionLimit():
        return false
    depth = depth + 1
    var out: bool = false
    let k: UirCoreExprKind = uirCoreExprKindOf(expr)
    if k == meLoad:
        let b: int32 = uirCoreOpt2ResolveAddrBase(uirCoreExprAddrExprOf(expr))
        if b == baseSlot:
            out = true
        else:
            out = uirCoreOpt2ExprHasLoadFromBaseInner(uirCoreExprAddrExprOf(expr), baseSlot, depth)
    elif k == meBin || k == meCmp:
        out = uirCoreOpt2ExprHasLoadFromBaseInner(uirCoreExprLhsOf(expr), baseSlot, depth) ||
              uirCoreOpt2ExprHasLoadFromBaseInner(uirCoreExprRhsOf(expr), baseSlot, depth)
    elif k == meCast:
        out = uirCoreOpt2ExprHasLoadFromBaseInner(uirCoreExprCastExprOf(expr), baseSlot, depth)
    elif k == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            if uirCoreOpt2ExprHasLoadFromBaseInner(uirCoreExprArgAt(expr, i), baseSlot, depth):
                out = true
                break
    depth = depth - 1
    return out

fn uirCoreOpt2ExprHasLoadFromBase(expr: UirExprId, baseSlot: int32): bool =
    var depth: int32 = 0
    return uirCoreOpt2ExprHasLoadFromBaseInner(expr, baseSlot, depth)

fn uirCoreOpt2ExprRewriteWithMapInner(expr: UirExprId,
                                      mapValid: bool[],
                                      mapExpr: UirExprId[],
                                      changed: var bool,
                                      depth: var int32): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    if depth >= uirCoreOpt2RecursionLimit():
        return expr
    depth = depth + 1
    let k: UirCoreExprKind = uirCoreExprKindOf(expr)
    var out: UirExprId = expr
    if k == meLocal:
        let slot: int32 = uirCoreExprLocalIndexOf(expr)
        if slot >= 0 && slot < mapValid.len && mapValid[slot]:
            let repl: UirExprId = mapExpr[slot]
            if uirCoreExprIdValid(repl):
                if !(uirCoreExprKindOf(repl) == meLocal && uirCoreExprLocalIndexOf(repl) == slot):
                    changed = true
                    out = repl
    elif k == meBin || k == meCmp:
        uirCoreExprSetLhs(expr, uirCoreOpt2ExprRewriteWithMapInner(uirCoreExprLhsOf(expr), mapValid, mapExpr, changed, depth))
        uirCoreExprSetRhs(expr, uirCoreOpt2ExprRewriteWithMapInner(uirCoreExprRhsOf(expr), mapValid, mapExpr, changed, depth))
    elif k == meCast:
        uirCoreExprSetCastExpr(expr, uirCoreOpt2ExprRewriteWithMapInner(uirCoreExprCastExprOf(expr), mapValid, mapExpr, changed, depth))
    elif k == meLoad:
        uirCoreExprSetAddrExpr(expr, uirCoreOpt2ExprRewriteWithMapInner(uirCoreExprAddrExprOf(expr), mapValid, mapExpr, changed, depth))
    elif k == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            uirCoreExprSetArgAt(expr, i, uirCoreOpt2ExprRewriteWithMapInner(uirCoreExprArgAt(expr, i), mapValid, mapExpr, changed, depth))
    depth = depth - 1
    return out

fn uirCoreOpt2ExprRewriteWithMap(expr: UirExprId,
                                 mapValid: bool[],
                                 mapExpr: UirExprId[],
                                 changed: var bool): UirExprId =
    var depth: int32 = 0
    return uirCoreOpt2ExprRewriteWithMapInner(expr, mapValid, mapExpr, changed, depth)

fn uirCoreOpt2ResolveAlias(slot: int32, aliasValid: bool[], aliasSrc: int32[]): int32 =
    if slot < 0 || slot >= aliasValid.len || slot >= aliasSrc.len:
        return slot
    var cur: int32 = slot
    let guardBound: int32 = aliasValid.len + 2
    for _ in 0..<guardBound:
        if cur < 0 || cur >= aliasValid.len || cur >= aliasSrc.len:
            return cur
        if !aliasValid[cur]:
            return cur
        let next: int32 = aliasSrc[cur]
        if next < 0 || next == cur:
            return cur
        cur = next
    return cur

fn uirCoreOpt2ExprRewriteWithAliasInner(expr: UirExprId,
                                        aliasValid: bool[],
                                        aliasSrc: int32[],
                                        changed: var bool,
                                        depth: var int32): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    if depth >= uirCoreOpt2RecursionLimit():
        return expr
    depth = depth + 1
    let k: UirCoreExprKind = uirCoreExprKindOf(expr)
    var out: UirExprId = expr
    if k == meLocal:
        let slot: int32 = uirCoreExprLocalIndexOf(expr)
        if slot >= 0 && slot < aliasValid.len && slot < aliasSrc.len:
            let root: int32 = uirCoreOpt2ResolveAlias(slot, aliasValid, aliasSrc)
            if root != slot:
                changed = true
                out = uirCoreLocal(root)
    elif k == meBin || k == meCmp:
        uirCoreExprSetLhs(expr, uirCoreOpt2ExprRewriteWithAliasInner(uirCoreExprLhsOf(expr), aliasValid, aliasSrc, changed, depth))
        uirCoreExprSetRhs(expr, uirCoreOpt2ExprRewriteWithAliasInner(uirCoreExprRhsOf(expr), aliasValid, aliasSrc, changed, depth))
    elif k == meCast:
        uirCoreExprSetCastExpr(expr, uirCoreOpt2ExprRewriteWithAliasInner(uirCoreExprCastExprOf(expr), aliasValid, aliasSrc, changed, depth))
    elif k == meLoad:
        uirCoreExprSetAddrExpr(expr, uirCoreOpt2ExprRewriteWithAliasInner(uirCoreExprAddrExprOf(expr), aliasValid, aliasSrc, changed, depth))
    elif k == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            uirCoreExprSetArgAt(expr, i, uirCoreOpt2ExprRewriteWithAliasInner(uirCoreExprArgAt(expr, i), aliasValid, aliasSrc, changed, depth))
    depth = depth - 1
    return out

fn uirCoreOpt2ExprRewriteWithAlias(expr: UirExprId,
                                   aliasValid: bool[],
                                   aliasSrc: int32[],
                                   changed: var bool): UirExprId =
    var depth: int32 = 0
    return uirCoreOpt2ExprRewriteWithAliasInner(expr, aliasValid, aliasSrc, changed, depth)

fn uirCoreOpt2ExprIsConstI64(expr: UirExprId, value: int64): bool =
    if (!uirCoreExprIdValid(expr)):
        return false
    return uirCoreExprKindOf(expr) == meConstI64 && uirCoreExprConstValueOf(expr) == value

fn uirCoreOpt2ExprKeyInner(expr: UirExprId, depth: var int32): str =
    if (!uirCoreExprIdValid(expr)):
        return "nil"
    if depth >= uirCoreOpt2RecursionLimit():
        return "cycle"
    depth = depth + 1
    let k: UirCoreExprKind = uirCoreExprKindOf(expr)
    var parts: str[]
    if k == meConstI64:
        add(parts, "c:")
        add(parts, intToStr(int32(uirCoreExprConstValueOf(expr))))
    elif k == meLocal:
        add(parts, "l:")
        add(parts, intToStr(uirCoreExprLocalIndexOf(expr)))
    elif k == meAddr:
        add(parts, "a:")
        add(parts, intToStr(uirCoreExprLocalIndexOf(expr)))
    elif k == meGlobalAddr:
        add(parts, "g:")
        add(parts, uirCoreExprGlobalNameOf(expr))
    elif k == meCast:
        add(parts, "cast:")
        add(parts, uirCoreOpt2TypeKey(uirCoreExprCastTypeOf(expr)))
        add(parts, ":(")
        add(parts, uirCoreOpt2ExprKeyInner(uirCoreExprCastExprOf(expr), depth))
        add(parts, ")")
    elif k == meLoad:
        add(parts, "load:(")
        add(parts, uirCoreOpt2ExprKeyInner(uirCoreExprAddrExprOf(expr), depth))
        add(parts, ")")
    elif k == meBin:
        add(parts, "bin:")
        add(parts, intToStr(int32(uirCoreExprBinOpOf(expr))))
        add(parts, ":(")
        add(parts, uirCoreOpt2ExprKeyInner(uirCoreExprLhsOf(expr), depth))
        add(parts, "),(")
        add(parts, uirCoreOpt2ExprKeyInner(uirCoreExprRhsOf(expr), depth))
        add(parts, ")")
    elif k == meCmp:
        add(parts, "cmp:")
        add(parts, intToStr(int32(uirCoreExprCmpOpOf(expr))))
        add(parts, ":(")
        add(parts, uirCoreOpt2ExprKeyInner(uirCoreExprLhsOf(expr), depth))
        add(parts, "),(")
        add(parts, uirCoreOpt2ExprKeyInner(uirCoreExprRhsOf(expr), depth))
        add(parts, ")")
    elif k == meCall:
        add(parts, "call:")
        add(parts, uirCoreExprCalleeOf(expr))
        add(parts, "(")
        for i in 0..<uirCoreExprArgsLen(expr):
            if i > 0:
                add(parts, ",")
            add(parts, uirCoreOpt2ExprKeyInner(uirCoreExprArgAt(expr, i), depth))
        add(parts, ")")
    else:
        add(parts, "expr")
    depth = depth - 1
    return strutils.join(parts, "")

fn uirCoreOpt2ExprKey(expr: UirExprId): str =
    var depth: int32 = 0
    return uirCoreOpt2ExprKeyInner(expr, depth)

fn uirCoreOpt2ExprEq(a: UirExprId, b: UirExprId): bool =
    return uirCoreOpt2ExprKey(a) == uirCoreOpt2ExprKey(b)

fn uirCoreOpt2StmtKey(stmt: UirStmtId): str =
    var parts: str[]
    add(parts, "s:")
    add(parts, intToStr(int32(uirCoreStmtKindOf(stmt))))
    add(parts, ":slot=")
    add(parts, intToStr(uirCoreStmtSlotOf(stmt)))
    add(parts, ":e=(")
    add(parts, uirCoreOpt2ExprKey(uirCoreStmtExprOf(stmt)))
    add(parts, ")")
    add(parts, ":a=(")
    add(parts, uirCoreOpt2ExprKey(uirCoreStmtAddrExprOf(stmt)))
    add(parts, ")")
    add(parts, ":t=")
    add(parts, uirCoreOpt2TypeKey(uirCoreStmtStoreTypeOf(stmt)))
    return strutils.join(parts, "")

fn uirCoreOpt2TermKey(term: UirCoreTerm): str =
    if uirCoreTermKindOf(term) == mtRet:
        return "ret:(" + uirCoreOpt2ExprKey(uirCoreTermRetExprOf(term)) + ")"
    if uirCoreTermKindOf(term) == mtBr:
        return "br:" + uirCoreTermTargetOf(term)
    if uirCoreTermKindOf(term) == mtCbr:
        return "cbr:(" + uirCoreOpt2ExprKey(uirCoreTermCondExprOf(term)) + ")->" + uirCoreTermTargetTrueOf(term) + ":" + uirCoreTermTargetFalseOf(term)
    return "term"

fn uirCoreOpt2FindBlockIndex(func: UirCoreFunc, label: str): int32 =
    if (!uirCoreFuncIdValid(func)) || len(label) == 0:
        return -1
    for i in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, i)
        if uirCoreBlockIdValid(blk) && uirCoreBlockLabelOf(blk) == label:
            return i
    return -1

fn uirCoreOpt2RewriteTargets(func: UirCoreFunc, fromLabel: str, toLabel: str): bool =
    if (!uirCoreFuncIdValid(func)) || len(fromLabel) == 0 || len(toLabel) == 0 || fromLabel == toLabel:
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtBr:
            if uirCoreTermTargetOf(uirCoreBlockTermOf(blk)) == fromLabel:
                uirCoreOpt2BlockSetTarget(blk, uirCoreOwnStr(toLabel))
                changed = true
        elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
            if uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)) == fromLabel:
                uirCoreOpt2BlockSetTargetTrue(blk, uirCoreOwnStr(toLabel))
                changed = true
            if uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)) == fromLabel:
                uirCoreOpt2BlockSetTargetFalse(blk, uirCoreOwnStr(toLabel))
                changed = true
    return changed

fn uirCoreOpt2ReachableBlocks(func: UirCoreFunc): bool[] =
    var reachable: bool[]
    if (!uirCoreFuncIdValid(func)):
        return reachable
    for _ in 0..<uirCoreFuncBlocksLen(func):
        add(reachable, false)
    var queued: bool[]
    for _ in 0..<uirCoreFuncBlocksLen(func):
        add(queued, false)
    if uirCoreFuncBlocksLen(func) <= 0:
        return reachable
    var entry: int32 = uirCoreOpt2FindBlockIndex(func, "entry")
    if entry < 0:
        entry = 0
    var stack: int32[]
    add(stack, entry)
    queued[entry] = true
    for _ in 0..<uirCoreFuncBlocksLen(func) + 1:
        if stack.len <= 0:
            break
        let bi: int32 = stack[stack.len - 1]
        stack.len = stack.len - 1
        if bi < 0 || bi >= uirCoreFuncBlocksLen(func):
            continue
        queued[bi] = false
        if reachable[bi]:
            continue
        reachable[bi] = true
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtBr:
            let si: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetOf(uirCoreBlockTermOf(blk)))
            if si >= 0 && !reachable[si] && !queued[si]:
                queued[si] = true
                add(stack, si)
        elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
            let st: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)))
            let sf: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)))
            if st >= 0 && !reachable[st] && !queued[st]:
                queued[st] = true
                add(stack, st)
            if sf >= 0 && !reachable[sf] && !queued[sf]:
                queued[sf] = true
                add(stack, sf)
    return reachable

fn uirCoreOpt2InferExprTypeInner(func: UirCoreFunc, expr: UirExprId, depth: var int32): UirCoreType =
    if !uirCoreExprIdValid(expr):
        return uirCoreTypeI32()
    if depth >= uirCoreOpt2RecursionLimit():
        return uirCoreTypeI32()
    depth = depth + 1
    var out: UirCoreType = uirCoreTypeI32()
    if uirCoreExprKindOf(expr) == meConstI64:
        out = uirCoreTypeI64()
    elif uirCoreExprKindOf(expr) == meLocal:
        let slot: int32 = uirCoreExprLocalIndexOf(expr)
        if uirCoreFuncIdValid(func) && slot >= 0 && slot < uirCoreFuncLocalTypesLen(func):
            out = uirCoreFuncLocalTypeAt(func, slot)
        else:
            out = uirCoreTypeI32()
    elif uirCoreExprKindOf(expr) == meAddr || uirCoreExprKindOf(expr) == meGlobalAddr:
        out = uirCoreTypeI64()
    elif uirCoreExprKindOf(expr) == meCast:
        out = uirCoreExprCastTypeOf(expr)
    elif uirCoreExprKindOf(expr) == meLoad:
        out = uirCoreExprLoadTypeOf(expr)
    elif uirCoreExprKindOf(expr) == meCmp:
        out = uirCoreTypeI32()
    elif uirCoreExprKindOf(expr) == meBin:
        out = uirCoreOpt2InferExprTypeInner(func, uirCoreExprLhsOf(expr), depth)
    depth = depth - 1
    return out

fn uirCoreOpt2InferExprType(func: UirCoreFunc, expr: UirExprId): UirCoreType =
    var depth: int32 = 0
    return uirCoreOpt2InferExprTypeInner(func, expr, depth)

fn uirCoreOpt2ExprUsesAnyInSetInner(expr: UirExprId, flag: bool[], depth: var int32): bool =
    if !uirCoreExprIdValid(expr):
        return false
    if depth >= uirCoreOpt2RecursionLimit():
        return false
    depth = depth + 1
    var out: bool = false
    if uirCoreExprKindOf(expr) == meLocal || uirCoreExprKindOf(expr) == meAddr:
        let slot: int32 = uirCoreExprLocalIndexOf(expr)
        if slot >= 0 && slot < flag.len:
            out = flag[slot]
    elif uirCoreExprKindOf(expr) == meBin || uirCoreExprKindOf(expr) == meCmp:
        out = uirCoreOpt2ExprUsesAnyInSetInner(uirCoreExprLhsOf(expr), flag, depth) ||
              uirCoreOpt2ExprUsesAnyInSetInner(uirCoreExprRhsOf(expr), flag, depth)
    elif uirCoreExprKindOf(expr) == meCast:
        out = uirCoreOpt2ExprUsesAnyInSetInner(uirCoreExprCastExprOf(expr), flag, depth)
    elif uirCoreExprKindOf(expr) == meLoad:
        out = uirCoreOpt2ExprUsesAnyInSetInner(uirCoreExprAddrExprOf(expr), flag, depth)
    elif uirCoreExprKindOf(expr) == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            if uirCoreOpt2ExprUsesAnyInSetInner(uirCoreExprArgAt(expr, i), flag, depth):
                out = true
                break
    depth = depth - 1
    return out

fn uirCoreOpt2ExprUsesAnyInSet(expr: UirExprId, flag: bool[]): bool =
    var depth: int32 = 0
    return uirCoreOpt2ExprUsesAnyInSetInner(expr, flag, depth)

fn uirCoreOpt2ExprNormalizeInner(expr: UirExprId, changed: var bool, depth: var int32): UirExprId =
    if !uirCoreExprIdValid(expr):
        return uirCoreInvalidId()
    if depth >= uirCoreOpt2RecursionLimit():
        return expr
    depth = depth + 1
    if uirCoreExprKindOf(expr) == meBin || uirCoreExprKindOf(expr) == meCmp:
        uirCoreExprSetLhs(expr, uirCoreOpt2ExprNormalizeInner(uirCoreExprLhsOf(expr), changed, depth))
        uirCoreExprSetRhs(expr, uirCoreOpt2ExprNormalizeInner(uirCoreExprRhsOf(expr), changed, depth))
    elif uirCoreExprKindOf(expr) == meCast:
        uirCoreExprSetCastExpr(expr, uirCoreOpt2ExprNormalizeInner(uirCoreExprCastExprOf(expr), changed, depth))
    elif uirCoreExprKindOf(expr) == meLoad:
        uirCoreExprSetAddrExpr(expr, uirCoreOpt2ExprNormalizeInner(uirCoreExprAddrExprOf(expr), changed, depth))
    elif uirCoreExprKindOf(expr) == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            uirCoreExprSetArgAt(expr, i, uirCoreOpt2ExprNormalizeInner(uirCoreExprArgAt(expr, i), changed, depth))
    depth = depth - 1
    return expr

fn uirCoreOpt2ExprNormalize(expr: UirExprId, changed: var bool): UirExprId =
    var depth: int32 = 0
    return uirCoreOpt2ExprNormalizeInner(expr, changed, depth)

fn uirCoreOpt2ExprNormalizeNopProbe(expr: UirExprId): UirExprId =
    return expr

fn uirCoreOpt2ExprAlgebraicInner(expr: UirExprId, changed: var bool, depth: var int32): UirExprId =
    if !uirCoreExprIdValid(expr):
        return uirCoreInvalidId()
    if depth >= uirCoreOpt2RecursionLimit():
        return expr
    depth = depth + 1
    var out: UirExprId = expr
    if uirCoreExprKindOf(expr) == meCast:
        uirCoreExprSetCastExpr(expr, uirCoreOpt2ExprAlgebraicInner(uirCoreExprCastExprOf(expr), changed, depth))
        out = expr
    elif uirCoreExprKindOf(expr) == meLoad:
        uirCoreExprSetAddrExpr(expr, uirCoreOpt2ExprAlgebraicInner(uirCoreExprAddrExprOf(expr), changed, depth))
        out = expr
    elif uirCoreExprKindOf(expr) == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            uirCoreExprSetArgAt(expr, i, uirCoreOpt2ExprAlgebraicInner(uirCoreExprArgAt(expr, i), changed, depth))
        out = expr
    elif uirCoreExprKindOf(expr) == meCmp:
        uirCoreExprSetLhs(expr, uirCoreOpt2ExprAlgebraicInner(uirCoreExprLhsOf(expr), changed, depth))
        uirCoreExprSetRhs(expr, uirCoreOpt2ExprAlgebraicInner(uirCoreExprRhsOf(expr), changed, depth))
        out = expr
    elif uirCoreExprKindOf(expr) != meBin:
        out = expr
    else:
        uirCoreExprSetLhs(expr, uirCoreOpt2ExprAlgebraicInner(uirCoreExprLhsOf(expr), changed, depth))
        uirCoreExprSetRhs(expr, uirCoreOpt2ExprAlgebraicInner(uirCoreExprRhsOf(expr), changed, depth))

    if uirCoreExprKindOf(expr) != meBin:
        depth = depth - 1
        return out

    if uirCoreExprBinOpOf(expr) == mbAdd:
        if uirCoreOpt2ExprIsConstI64(uirCoreExprRhsOf(expr), 0):
            changed = true
            out = uirCoreExprLhsOf(expr)
            depth = depth - 1
            return out
        if uirCoreOpt2ExprIsConstI64(uirCoreExprLhsOf(expr), 0):
            changed = true
            out = uirCoreExprRhsOf(expr)
            depth = depth - 1
            return out
        out = expr
        depth = depth - 1
        return out
    if uirCoreExprBinOpOf(expr) == mbSub:
        if uirCoreOpt2ExprIsConstI64(uirCoreExprRhsOf(expr), 0):
            changed = true
            out = uirCoreExprLhsOf(expr)
            depth = depth - 1
            return out
        out = expr
        depth = depth - 1
        return out
    if uirCoreExprBinOpOf(expr) == mbMul:
        if uirCoreOpt2ExprIsConstI64(uirCoreExprRhsOf(expr), 1):
            changed = true
            out = uirCoreExprLhsOf(expr)
            depth = depth - 1
            return out
        if uirCoreOpt2ExprIsConstI64(uirCoreExprLhsOf(expr), 1):
            changed = true
            out = uirCoreExprRhsOf(expr)
            depth = depth - 1
            return out
        if uirCoreOpt2ExprIsConstI64(uirCoreExprRhsOf(expr), 0) || uirCoreOpt2ExprIsConstI64(uirCoreExprLhsOf(expr), 0):
            changed = true
            out = uirCoreConstI64(0)
            depth = depth - 1
            return out
        out = expr
        depth = depth - 1
        return out
    if uirCoreExprBinOpOf(expr) == mbOr || uirCoreExprBinOpOf(expr) == mbXor || uirCoreExprBinOpOf(expr) == mbShl || uirCoreExprBinOpOf(expr) == mbShr:
        if uirCoreOpt2ExprIsConstI64(uirCoreExprRhsOf(expr), 0):
            changed = true
            out = uirCoreExprLhsOf(expr)
            depth = depth - 1
            return out
    out = expr
    depth = depth - 1
    return out

fn uirCoreOpt2ExprAlgebraic(expr: UirExprId, changed: var bool): UirExprId =
    var depth: int32 = 0
    return uirCoreOpt2ExprAlgebraicInner(expr, changed, depth)

fn uirCoreOpt2ExprContainsCallOrLoad(expr: UirExprId): bool =
    return uirCoreOpt2ExprHasCall(expr) || uirCoreOpt2ExprHasAnyLoad(expr)

fn uirCoreOpt2StmtSideEffect(stmt: UirStmtId): bool =
    if uirCoreStmtKindOf(stmt) == msStore:
        return true
    if uirCoreStmtKindOf(stmt) == msLet || uirCoreStmtKindOf(stmt) == msVar || uirCoreStmtKindOf(stmt) == msAssign:
        return uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtExprOf(stmt)) ||
               uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtAddrExprOf(stmt))
    if uirCoreStmtKindOf(stmt) == msExpr:
        return uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtExprOf(stmt))
    return false

fn uirCoreOpt2BlockPreds(func: UirCoreFunc, targetIdx: int32): int32[] =
    var preds: int32[]
    if (!uirCoreFuncIdValid(func)) || targetIdx < 0 || targetIdx >= uirCoreFuncBlocksLen(func):
        return preds
    let targetLabel: str = uirCoreBlockLabelOf(uirCoreFuncBlockAt(func, targetIdx))
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtBr:
            if uirCoreTermTargetOf(uirCoreBlockTermOf(blk)) == targetLabel:
                add(preds, bi)
        elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
            if uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)) == targetLabel || uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)) == targetLabel:
                add(preds, bi)
    return preds

fn uirCoreOpt2RewriteLoadsFromSlotInner(expr: UirExprId,
                                        slot: int32,
                                        replacement: UirExprId,
                                        changed: var bool,
                                        depth: var int32): UirExprId =
    if !uirCoreExprIdValid(expr):
        return uirCoreInvalidId()
    if depth >= uirCoreOpt2RecursionLimit():
        return expr
    depth = depth + 1
    var out: UirExprId = expr
    if uirCoreExprKindOf(expr) == meLoad:
        let base: int32 = uirCoreOpt2ResolveAddrBase(uirCoreExprAddrExprOf(expr))
        if base == slot && uirCoreExprIdValid(replacement):
            changed = true
            out = replacement
        else:
            uirCoreExprSetAddrExpr(expr, uirCoreOpt2RewriteLoadsFromSlotInner(uirCoreExprAddrExprOf(expr), slot, replacement, changed, depth))
            out = expr
    elif uirCoreExprKindOf(expr) == meBin || uirCoreExprKindOf(expr) == meCmp:
        uirCoreExprSetLhs(expr, uirCoreOpt2RewriteLoadsFromSlotInner(uirCoreExprLhsOf(expr), slot, replacement, changed, depth))
        uirCoreExprSetRhs(expr, uirCoreOpt2RewriteLoadsFromSlotInner(uirCoreExprRhsOf(expr), slot, replacement, changed, depth))
        out = expr
    elif uirCoreExprKindOf(expr) == meCast:
        uirCoreExprSetCastExpr(expr, uirCoreOpt2RewriteLoadsFromSlotInner(uirCoreExprCastExprOf(expr), slot, replacement, changed, depth))
        out = expr
    elif uirCoreExprKindOf(expr) == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            uirCoreExprSetArgAt(expr, i, uirCoreOpt2RewriteLoadsFromSlotInner(uirCoreExprArgAt(expr, i), slot, replacement, changed, depth))
        out = expr
    depth = depth - 1
    return out

fn uirCoreOpt2RewriteLoadsFromSlot(expr: UirExprId,
                                   slot: int32,
                                   replacement: UirExprId,
                                   changed: var bool): UirExprId =
    var depth: int32 = 0
    return uirCoreOpt2RewriteLoadsFromSlotInner(expr, slot, replacement, changed, depth)

fn uirCoreOpt2ExprFindKey(keys: str[], key: str): int32 =
    for i in 0..<keys.len:
        if keys[i] == key:
            return i
    return -1

fn uirCoreOpt2ExprHasUnknownMemAccessInner(expr: UirExprId, depth: var int32): bool =
    if !uirCoreExprIdValid(expr):
        return false
    if depth >= uirCoreOpt2RecursionLimit():
        return true
    depth = depth + 1
    var out: bool = false
    if uirCoreExprKindOf(expr) == meLoad:
        out = uirCoreOpt2ResolveAddrBase(uirCoreExprAddrExprOf(expr)) < 0
    elif uirCoreExprKindOf(expr) == meBin || uirCoreExprKindOf(expr) == meCmp:
        out = uirCoreOpt2ExprHasUnknownMemAccessInner(uirCoreExprLhsOf(expr), depth) ||
              uirCoreOpt2ExprHasUnknownMemAccessInner(uirCoreExprRhsOf(expr), depth)
    elif uirCoreExprKindOf(expr) == meCast:
        out = uirCoreOpt2ExprHasUnknownMemAccessInner(uirCoreExprCastExprOf(expr), depth)
    elif uirCoreExprKindOf(expr) == meCall:
        out = true
    else:
        out = false
    depth = depth - 1
    return out

fn uirCoreOpt2ExprHasUnknownMemAccess(expr: UirExprId): bool =
    var depth: int32 = 0
    return uirCoreOpt2ExprHasUnknownMemAccessInner(expr, depth)

fn uirCoreFuncCse(func: UirCoreFunc, module: UirCoreModule): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    let _unused_module: UirCoreModule = module
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        var keys: str[]
        var slots: int32[]
        for si in 0..<uirCoreBlockStmtsLen(blk):
            var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
            if uirCoreStmtKindOf(st) == msLet || uirCoreStmtKindOf(st) == msVar || uirCoreStmtKindOf(st) == msAssign:
                if uirCoreOpt2ExprIsPure(uirCoreStmtExprOf(st)):
                    let key: str = uirCoreOpt2ExprKey(uirCoreStmtExprOf(st))
                    let idx: int32 = uirCoreOpt2ExprFindKey(keys, key)
                    if idx >= 0 && idx < slots.len:
                        let prevSlot: int32 = slots[idx]
                        if prevSlot >= 0 && prevSlot != uirCoreStmtSlotOf(st):
                            st = uirCoreStmtWithExpr(st, uirCoreLocal(prevSlot))
                            changed = true
                    else:
                        add(keys, key)
                        add(slots, uirCoreStmtSlotOf(st))
                if uirCoreStmtSlotOf(st) >= 0:
                    for ki in 0..<slots.len:
                        if slots[ki] == uirCoreStmtSlotOf(st):
                            slots[ki] = -1
                uirCoreBlockSetStmtAt(blk, si, st)
                if uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtExprOf(st)):
                    keys.len = 0
                    slots.len = 0
            elif uirCoreStmtKindOf(st) == msStore:
                st = uirCoreStmtWithAddrExpr(st, uirCoreStmtAddrExprOf(st))
                uirCoreBlockSetStmtAt(blk, si, st)
                keys.len = 0
                slots.len = 0
            elif uirCoreStmtKindOf(st) == msExpr:
                uirCoreBlockSetStmtAt(blk, si, st)
                if uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtExprOf(st)):
                    keys.len = 0
                    slots.len = 0
            else:
                uirCoreBlockSetStmtAt(blk, si, st)
    return changed

fn uirCoreFuncSroa(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    let localCount: int32 = uirCoreFuncLocalTypesLen(func)
    if localCount <= 0:
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        var knownVals: UirExprId[]
        var knownValid: bool[]
        for _ in 0..<localCount:
            add(knownVals, nil)
            add(knownValid, false)
        for si in 0..<uirCoreBlockStmtsLen(blk):
            var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
            for slot in 0..<localCount:
                if knownValid[slot] && uirCoreExprIdValid(knownVals[slot]):
                    st = uirCoreStmtWithExpr(st, uirCoreOpt2RewriteLoadsFromSlot(uirCoreStmtExprOf(st), slot, knownVals[slot], changed))
                    st = uirCoreStmtWithAddrExpr(st, uirCoreOpt2RewriteLoadsFromSlot(uirCoreStmtAddrExprOf(st), slot, knownVals[slot], changed))
            if uirCoreStmtKindOf(st) == msStore:
                let base: int32 = uirCoreOpt2ResolveAddrBase(uirCoreStmtAddrExprOf(st))
                if base >= 0 && base < localCount && !uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtExprOf(st)):
                    knownVals[base] = uirCoreStmtExprOf(st)
                    knownValid[base] = true
                else:
                    if base >= 0 && base < localCount:
                        knownValid[base] = false
                    else:
                        for i in 0..<localCount:
                            knownValid[i] = false
            elif uirCoreStmtKindOf(st) == msLet || uirCoreStmtKindOf(st) == msVar || uirCoreStmtKindOf(st) == msAssign:
                if uirCoreStmtSlotOf(st) >= 0 && uirCoreStmtSlotOf(st) < localCount:
                    knownVals[uirCoreStmtSlotOf(st)] = uirCoreStmtExprOf(st)
                    knownValid[uirCoreStmtSlotOf(st)] = true
                if uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtExprOf(st)):
                    for i in 0..<localCount:
                        knownValid[i] = false
            elif uirCoreStmtKindOf(st) == msExpr:
                if uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtExprOf(st)):
                    for i in 0..<localCount:
                        knownValid[i] = false
            uirCoreBlockSetStmtAt(blk, si, st)

        if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtRet:
            for slot in 0..<localCount:
                if knownValid[slot] && uirCoreExprIdValid(knownVals[slot]):
                    uirCoreOpt2BlockSetRetExpr(blk, uirCoreOpt2RewriteLoadsFromSlot(uirCoreTermRetExprOf(uirCoreBlockTermOf(blk)), slot, knownVals[slot], changed))
        elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
            for slot in 0..<localCount:
                if knownValid[slot] && uirCoreExprIdValid(knownVals[slot]):
                    uirCoreOpt2BlockSetCondExpr(blk, uirCoreOpt2RewriteLoadsFromSlot(uirCoreTermCondExprOf(uirCoreBlockTermOf(blk)), slot, knownVals[slot], changed))
    return changed

fn uirCoreOpt2HoistExprToPreheaderInner(expr: UirExprId,
                                        func: UirCoreFunc,
                                        preheader: UirBlockId,
                                        defsInLoop: bool[],
                                        changed: var bool,
                                        depth: var int32): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    if depth >= uirCoreOpt2RecursionLimit():
        return expr
    depth = depth + 1
    if uirCoreExprKindOf(expr) == meBin || uirCoreExprKindOf(expr) == meCmp:
        uirCoreExprSetLhs(expr, uirCoreOpt2HoistExprToPreheaderInner(uirCoreExprLhsOf(expr), func, preheader, defsInLoop, changed, depth))
        uirCoreExprSetRhs(expr, uirCoreOpt2HoistExprToPreheaderInner(uirCoreExprRhsOf(expr), func, preheader, defsInLoop, changed, depth))
    elif uirCoreExprKindOf(expr) == meCast:
        uirCoreExprSetCastExpr(expr, uirCoreOpt2HoistExprToPreheaderInner(uirCoreExprCastExprOf(expr), func, preheader, defsInLoop, changed, depth))
    elif uirCoreExprKindOf(expr) == meLoad:
        uirCoreExprSetAddrExpr(expr, uirCoreOpt2HoistExprToPreheaderInner(uirCoreExprAddrExprOf(expr), func, preheader, defsInLoop, changed, depth))
    elif uirCoreExprKindOf(expr) == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            uirCoreExprSetArgAt(expr, i, uirCoreOpt2HoistExprToPreheaderInner(uirCoreExprArgAt(expr, i), func, preheader, defsInLoop, changed, depth))

    if (!uirCoreBlockIdValid(preheader)) || (!uirCoreFuncIdValid(func)):
        depth = depth - 1
        return expr
    if !uirCoreOpt2ExprIsPure(expr):
        depth = depth - 1
        return expr
    if uirCoreExprKindOf(expr) == meConstI64 || uirCoreExprKindOf(expr) == meLocal || uirCoreExprKindOf(expr) == meAddr || uirCoreExprKindOf(expr) == meGlobalAddr:
        depth = depth - 1
        return expr
    if uirCoreOpt2ExprUsesAnyInSet(expr, defsInLoop):
        depth = depth - 1
        return expr

    let slot: int32 = uirCoreFuncLocalTypesLen(func)
    uirCoreFuncAddLocalType(func, uirCoreOpt2InferExprType(func, expr))
    let hoisted: UirStmtId = uirCoreStmtAssign("", slot, expr)
    var preheaderStmts: UirStmtId[]
    for si in 0..<uirCoreBlockStmtsLen(preheader):
        add(preheaderStmts, uirCoreBlockStmtAt(preheader, si))
    add(preheaderStmts, hoisted)
    uirCoreBlockSetStmts(preheader, preheaderStmts)
    changed = true
    let out: UirExprId = uirCoreLocal(slot)
    depth = depth - 1
    return out

fn uirCoreOpt2HoistExprToPreheader(expr: UirExprId,
                                   func: UirCoreFunc,
                                   preheader: UirBlockId,
                                   defsInLoop: bool[],
                                   changed: var bool): UirExprId =
    var depth: int32 = 0
    return uirCoreOpt2HoistExprToPreheaderInner(expr, func, preheader, defsInLoop, changed, depth)

fn uirCoreFuncLicm(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    if uirCoreFuncBlocksLen(func) <= 1:
        return false
    var changed: bool = false

    for hi in 0..<uirCoreFuncBlocksLen(func):
        let header: UirBlockId = uirCoreFuncBlockAt(func, hi)
        if (!uirCoreBlockIdValid(header)):
            continue
        let preds: int32[] = uirCoreOpt2BlockPreds(func, hi)
        if preds.len <= 1:
            continue

        var backPreds: int32[]
        var preheaderIdx: int32 = -1
        for pi in 0..<preds.len:
            let predIdx: int32 = preds[pi]
            if predIdx > hi:
                add(backPreds, predIdx)
            else:
                preheaderIdx = predIdx
        if backPreds.len <= 0 || preheaderIdx < 0 || preheaderIdx >= uirCoreFuncBlocksLen(func):
            continue
        let preheader: UirBlockId = uirCoreFuncBlockAt(func, preheaderIdx)
        if (!uirCoreBlockIdValid(preheader)):
            continue
        if uirCoreTermKindOf(uirCoreBlockTermOf(preheader)) != mtBr || uirCoreTermTargetOf(uirCoreBlockTermOf(preheader)) != uirCoreBlockLabelOf(header):
            continue

        var defsInLoop: bool[]
        for _ in 0..<uirCoreFuncLocalTypesLen(func):
            add(defsInLoop, false)
        for bpi in 0..<backPreds.len:
            let lb: UirBlockId = uirCoreFuncBlockAt(func, backPreds[bpi])
            if (!uirCoreBlockIdValid(lb)):
                continue
            for si in 0..<uirCoreBlockStmtsLen(lb):
                let st: UirStmtId = uirCoreBlockStmtAt(lb, si)
                if (uirCoreStmtKindOf(st) == msLet || uirCoreStmtKindOf(st) == msVar || uirCoreStmtKindOf(st) == msAssign) && uirCoreStmtSlotOf(st) >= 0 && uirCoreStmtSlotOf(st) < defsInLoop.len:
                    defsInLoop[uirCoreStmtSlotOf(st)] = true
        for si in 0..<uirCoreBlockStmtsLen(header):
            let st: UirStmtId = uirCoreBlockStmtAt(header, si)
            if (uirCoreStmtKindOf(st) == msLet || uirCoreStmtKindOf(st) == msVar || uirCoreStmtKindOf(st) == msAssign) && uirCoreStmtSlotOf(st) >= 0 && uirCoreStmtSlotOf(st) < defsInLoop.len:
                defsInLoop[uirCoreStmtSlotOf(st)] = true

        if uirCoreTermKindOf(uirCoreBlockTermOf(header)) == mtCbr:
            uirCoreOpt2BlockSetCondExpr(header, uirCoreOpt2HoistExprToPreheader(uirCoreTermCondExprOf(uirCoreBlockTermOf(header)), func, preheader, defsInLoop, changed))

    return changed

fn uirCoreFuncDceStmts(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    let localCount: int32 = uirCoreFuncLocalTypesLen(func)
    var changed: bool = false

    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        var live: bool[]
        for _ in 0..<localCount:
            add(live, false)
        if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtRet:
            uirCoreOpt2ExprMarkUses(uirCoreTermRetExprOf(uirCoreBlockTermOf(blk)), live)
        elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
            uirCoreOpt2ExprMarkUses(uirCoreTermCondExprOf(uirCoreBlockTermOf(blk)), live)

        var keep: bool[]
        for _ in 0..<uirCoreBlockStmtsLen(blk):
            add(keep, true)

        var si: int32 = uirCoreBlockStmtsLen(blk) - 1
        let __for_start_si = si
        for __for_rev_si in 0..(__for_start_si - (0)):
            si = __for_start_si - __for_rev_si
            let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
            var defSlot: int32 = -1
            if uirCoreStmtKindOf(st) == msLet || uirCoreStmtKindOf(st) == msVar || uirCoreStmtKindOf(st) == msAssign || uirCoreStmtKindOf(st) == msParam:
                defSlot = uirCoreStmtSlotOf(st)

            var hasSideEffect: bool = uirCoreOpt2StmtSideEffect(st)
            if uirCoreStmtKindOf(st) == msParam:
                hasSideEffect = true

            var used: bool = hasSideEffect
            if defSlot >= 0 && defSlot < live.len && live[defSlot]:
                used = true

            if !used:
                keep[si] = false
                changed = true
                continue

            if defSlot >= 0 && defSlot < live.len:
                live[defSlot] = false
            uirCoreOpt2ExprMarkUses(uirCoreStmtExprOf(st), live)
            uirCoreOpt2ExprMarkUses(uirCoreStmtAddrExprOf(st), live)

        var newStmts: UirStmtId[]
        for i in 0..<uirCoreBlockStmtsLen(blk):
            if keep[i]:
                add(newStmts, uirCoreBlockStmtAt(blk, i))
        uirCoreBlockSetStmts(blk, newStmts)

    return changed

fn uirCoreInlineCallExprInner(expr: UirExprId,
                              module: UirCoreModule,
                              changed: var bool,
                              depth: var int32): UirExprId =
    if (!uirCoreExprIdValid(expr)) || (module == nil):
        return expr
    if depth >= uirCoreOpt2RecursionLimit():
        return expr
    depth = depth + 1
    var out: UirExprId = expr
    if uirCoreExprKindOf(expr) == meBin || uirCoreExprKindOf(expr) == meCmp:
        uirCoreExprSetLhs(expr, uirCoreInlineCallExprInner(uirCoreExprLhsOf(expr), module, changed, depth))
        uirCoreExprSetRhs(expr, uirCoreInlineCallExprInner(uirCoreExprRhsOf(expr), module, changed, depth))
    elif uirCoreExprKindOf(expr) == meCast:
        uirCoreExprSetCastExpr(expr, uirCoreInlineCallExprInner(uirCoreExprCastExprOf(expr), module, changed, depth))
    elif uirCoreExprKindOf(expr) == meLoad:
        uirCoreExprSetAddrExpr(expr, uirCoreInlineCallExprInner(uirCoreExprAddrExprOf(expr), module, changed, depth))
    elif uirCoreExprKindOf(expr) == meCall:
        for i in 0..<uirCoreExprArgsLen(expr):
            uirCoreExprSetArgAt(expr, i, uirCoreInlineCallExprInner(uirCoreExprArgAt(expr, i), module, changed, depth))
        if uirCoreExprArgsLen(expr) == 0:
            let callee: str = uirCoreExprCalleeOf(expr)
            if len(callee) > 0:
                for fi in 0..<uirCoreModuleFuncsLen(module):
                    let f: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
                    if (f == nil) || uirCoreFuncIsExtern(f) || uirCoreFuncNameOf(f) != callee:
                        continue
                    if uirCoreFuncBlocksLen(f) != 1 || uirCoreFuncParamsLen(f) != 0:
                        continue
                    let b: UirBlockId = uirCoreFuncBlockAt(f, 0)
                    if (!uirCoreBlockIdValid(b)) || uirCoreTermKindOf(uirCoreBlockTermOf(b)) != mtRet:
                        continue
                    if uirCoreBlockStmtsLen(b) > 0:
                        var inlineSafe: bool = true
                        for si in 0..<uirCoreBlockStmtsLen(b):
                            if uirCoreOpt2StmtSideEffect(uirCoreBlockStmtAt(b, si)):
                                inlineSafe = false
                                break
                        if !inlineSafe:
                            continue
                    let repl: UirExprId = uirCoreTermRetExprOf(uirCoreBlockTermOf(b))
                    if (!uirCoreExprIdValid(repl)):
                        continue
                    changed = true
                    out = repl
                    break
    depth = depth - 1
    return out

fn uirCoreInlineCallExpr(expr: UirExprId, module: UirCoreModule, changed: var bool): UirExprId =
    var depth: int32 = 0
    return uirCoreInlineCallExprInner(expr, module, changed, depth)

fn uirCoreInlineModuleOnce(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for fi in 0..<uirCoreModuleFuncsLen(module):
        let f: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (f == nil) || uirCoreFuncIsExtern(f):
            continue
        for bi in 0..<uirCoreFuncBlocksLen(f):
            let blk: UirBlockId = uirCoreFuncBlockAt(f, bi)
            if (!uirCoreBlockIdValid(blk)):
                continue
            for si in 0..<uirCoreBlockStmtsLen(blk):
                var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                st = uirCoreStmtWithExpr(st, uirCoreInlineCallExpr(uirCoreStmtExprOf(st), module, changed))
                st = uirCoreStmtWithAddrExpr(st, uirCoreInlineCallExpr(uirCoreStmtAddrExprOf(st), module, changed))
                uirCoreBlockSetStmtAt(blk, si, st)
            if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtRet:
                uirCoreOpt2BlockSetRetExpr(blk, uirCoreInlineCallExpr(uirCoreTermRetExprOf(uirCoreBlockTermOf(blk)), module, changed))
            elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
                uirCoreOpt2BlockSetCondExpr(blk, uirCoreInlineCallExpr(uirCoreTermCondExprOf(uirCoreBlockTermOf(blk)), module, changed))
    return changed

fn uirCoreOpt2CalleeBudgetSentinel(): str =
    return "__uir_core_opt2_budget_exceeded__"

fn uirCoreOpt2ExprCollectCallees(expr: UirExprId, names: var str[]) =
    if !uirCoreExprIdValid(expr):
        return
    # Iterative walk avoids stack overflow on cyclic/pathological expr graphs.
    let sentinel: str = uirCoreOpt2CalleeBudgetSentinel()
    var work: UirExprId[]
    var seen: bool[]
    work.cap = 16
    seen.cap = 16
    add(work, expr)
    var steps: int32 = 0
    let budget: int32 = uirCoreOpt2ExprScanBudget()
    while work.len > 0:
        let cur: UirExprId = work[work.len - 1]
        work.len = work.len - 1
        if (!uirCoreExprIdValid(cur)):
            continue
        if uirCoreOpt2ExprSeenOrMark(seen, cur):
            continue
        steps = steps + 1
        if steps > budget:
            var hasSentinel: bool = false
            for i in 0..<names.len:
                if names[i] == sentinel:
                    hasSentinel = true
                    break
            if !hasSentinel:
                add(names, sentinel)
            return
        let k: UirCoreExprKind = uirCoreExprKindOf(cur)
        if k == meCall:
            if len(uirCoreExprCalleeOf(cur)) > 0:
                var exists: bool = false
                for i in 0..<names.len:
                    if names[i] == uirCoreExprCalleeOf(cur):
                        exists = true
                        break
                if !exists:
                    add(names, uirCoreExprCalleeOf(cur))
            for i in 0..<uirCoreExprArgsLen(cur):
                add(work, uirCoreExprArgAt(cur, i))
            continue
        if k == meBin || k == meCmp:
            add(work, uirCoreExprRhsOf(cur))
            add(work, uirCoreExprLhsOf(cur))
            continue
        if k == meCast:
            add(work, uirCoreExprCastExprOf(cur))
            continue
        if k == meLoad:
            add(work, uirCoreExprAddrExprOf(cur))
            continue

fn uirCoreOpt2ReplaceModuleFuncs(mod: UirCoreModule, funcs: UirCoreFunc[]) =
    if (mod == nil):
        return
    uirCoreModuleSetFuncs(mod, funcs)

fn uirCorePruneUnreachableFuncs(module: UirCoreModule): bool =
    if (module == nil):
        return false
    if uirCoreModuleFuncsLen(module) <= 0:
        return false

    var reachable: bool[]
    for _ in 0..<uirCoreModuleFuncsLen(module):
        add(reachable, false)
    var queued: bool[]
    for _ in 0..<uirCoreModuleFuncsLen(module):
        add(queued, false)

    var entryIdx: int32 = -1
    var mainIdx: int32 = -1
    var backendMainIdx: int32 = -1
    var firstIdx: int32 = -1
    for i in 0..<uirCoreModuleFuncsLen(module):
        let f: UirCoreFunc = uirCoreModuleFuncAt(module, i)
        if (f == nil) || uirCoreFuncIsExtern(f):
            continue
        if firstIdx < 0:
            firstIdx = i
        let fnName: str = uirCoreFuncNameOf(f)
        if fnName == "main":
            mainIdx = i
            break
        if backendMainIdx < 0 && fnName == "backendMain":
            backendMainIdx = i
    if mainIdx >= 0:
        entryIdx = mainIdx
    elif backendMainIdx >= 0:
        entryIdx = backendMainIdx
    else:
        entryIdx = firstIdx
    if entryIdx < 0:
        return false

    var work: int32[]
    add(work, entryIdx)
    queued[entryIdx] = true
    for fi in 0..<uirCoreModuleFuncsLen(module):
        let fKeep: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if fKeep == nil || uirCoreFuncIsExtern(fKeep):
            continue
        if !uirCoreFuncIsExported(fKeep):
            continue
        if !queued[fi]:
            queued[fi] = true
            add(work, fi)
    for _ in 0..<uirCoreModuleFuncsLen(module) + 1:
        if work.len <= 0:
            break
        let fi: int32 = work[work.len - 1]
        work.len = work.len - 1
        if fi < 0 || fi >= uirCoreModuleFuncsLen(module):
            continue
        queued[fi] = false
        if reachable[fi]:
            continue
        reachable[fi] = true
        let f: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (f == nil):
            continue
        var callees: str[]
        for bi in 0..<uirCoreFuncBlocksLen(f):
            let blk: UirBlockId = uirCoreFuncBlockAt(f, bi)
            if (!uirCoreBlockIdValid(blk)):
                continue
            for si in 0..<uirCoreBlockStmtsLen(blk):
                let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                uirCoreOpt2ExprCollectCallees(uirCoreStmtExprOf(st), callees)
                uirCoreOpt2ExprCollectCallees(uirCoreStmtAddrExprOf(st), callees)
            if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtRet:
                uirCoreOpt2ExprCollectCallees(uirCoreTermRetExprOf(uirCoreBlockTermOf(blk)), callees)
            elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
                uirCoreOpt2ExprCollectCallees(uirCoreTermCondExprOf(uirCoreBlockTermOf(blk)), callees)
        var budgetExceeded: bool = false
        let sentinel: str = uirCoreOpt2CalleeBudgetSentinel()
        for ci in 0..<callees.len:
            if callees[ci] == sentinel:
                budgetExceeded = true
                break
        if budgetExceeded:
            # Conservative fallback: skip pruning when callee graph is pathological.
            return false
        for ci in 0..<callees.len:
            let name: str = callees[ci]
            for ti in 0..<uirCoreModuleFuncsLen(module):
                let tf: UirCoreFunc = uirCoreModuleFuncAt(module, ti)
                if (tf == nil):
                    continue
                if uirCoreFuncNameOf(tf) == name && !reachable[ti] && !queued[ti]:
                    queued[ti] = true
                    add(work, ti)
        
    var changed: bool = false
    var kept: UirCoreFunc[]
    for i in 0..<uirCoreModuleFuncsLen(module):
        let f: UirCoreFunc = uirCoreModuleFuncAt(module, i)
        if (f == nil):
            continue
        if uirCoreFuncIsExtern(f) || reachable[i]:
            add(kept, f)
        else:
            changed = true
    if changed:
        uirCoreOpt2ReplaceModuleFuncs(module, kept)
    return changed

fn uirCoreOptimizeModuleNoopAssign(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for fi in 0..<uirCoreModuleFuncsLen(module):
        let func: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        for bi in 0..<uirCoreFuncBlocksLen(func):
            let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
            if (!uirCoreBlockIdValid(blk)):
                continue
            var out: UirStmtId[]
            for si in 0..<uirCoreBlockStmtsLen(blk):
                let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                var dropStmt: bool = false
                if uirCoreStmtKindOf(st) == msAssign && uirCoreStmtSlotOf(st) >= 0:
                    let expr: UirExprId = uirCoreStmtExprOf(st)
                    if uirCoreExprIdValid(expr):
                        if uirCoreExprKindOf(expr) == meLocal && uirCoreExprLocalIndexOf(expr) == uirCoreStmtSlotOf(st):
                            dropStmt = true
                        elif uirCoreExprKindOf(expr) == meCast:
                            let castExpr: UirExprId = uirCoreExprCastExprOf(expr)
                            if uirCoreExprIdValid(castExpr) && uirCoreExprKindOf(castExpr) == meLocal &&
                               uirCoreExprLocalIndexOf(castExpr) == uirCoreStmtSlotOf(st):
                                let srcTy: UirCoreType = uirCoreOpt2InferExprType(func, castExpr)
                                if uirCoreOpt2TypeEq(srcTy, uirCoreExprCastTypeOf(expr)):
                                    dropStmt = true
                if dropStmt:
                    changed = true
                    continue
                add(out, st)
            if out.len != uirCoreBlockStmtsLen(blk):
                uirCoreBlockSetStmts(blk, out)
    return changed

fn uirCoreOptimizeModuleDseStores(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for fi in 0..<uirCoreModuleFuncsLen(module):
        let func: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        for bi in 0..<uirCoreFuncBlocksLen(func):
            let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
            if (!uirCoreBlockIdValid(blk)):
                continue
            var out: UirStmtId[]
            var openStoreBase: int32 = -1
            var openStorePos: int32 = -1
            for si in 0..<uirCoreBlockStmtsLen(blk):
                let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                if uirCoreStmtKindOf(st) == msStore:
                    let base: int32 = uirCoreOpt2ResolveAddrBase(uirCoreStmtAddrExprOf(st))
                    if base >= 0 && openStorePos >= 0 && openStoreBase == base && openStorePos < out.len:
                        out[openStorePos] = st
                        changed = true
                        continue
                    add(out, st)
                    if base >= 0:
                        openStoreBase = base
                        openStorePos = out.len - 1
                    else:
                        openStoreBase = -1
                        openStorePos = -1
                    continue
                if uirCoreOpt2ExprHasCall(uirCoreStmtExprOf(st)) || uirCoreOpt2ExprHasCall(uirCoreStmtAddrExprOf(st)):
                    openStoreBase = -1
                    openStorePos = -1
                elif openStoreBase >= 0 &&
                     (uirCoreOpt2ExprHasLoadFromBase(uirCoreStmtExprOf(st), openStoreBase) ||
                      uirCoreOpt2ExprHasLoadFromBase(uirCoreStmtAddrExprOf(st), openStoreBase)):
                    openStoreBase = -1
                    openStorePos = -1
                add(out, st)
            uirCoreBlockSetStmts(blk, out)
    return changed

fn uirCoreOptimizeModuleForwardSubstitute(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var changedAny: bool = false
    for fi in 0..<uirCoreModuleFuncsLen(module):
        let func: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        let n: int32 = uirCoreFuncLocalTypesLen(func)
        for bi in 0..<uirCoreFuncBlocksLen(func):
            let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
            if (!uirCoreBlockIdValid(blk)):
                continue
            var availVals: UirExprId[]
            var availValid: bool[]
            for _ in 0..<n:
                add(availVals, nil)
                add(availValid, false)

            for si in 0..<uirCoreBlockStmtsLen(blk):
                var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                st = uirCoreStmtWithExpr(st, uirCoreOpt2ExprRewriteWithMap(uirCoreStmtExprOf(st), availValid, availVals, changedAny))
                st = uirCoreStmtWithAddrExpr(st, uirCoreOpt2ExprRewriteWithMap(uirCoreStmtAddrExprOf(st), availValid, availVals, changedAny))

                var defSlot: int32 = -1
                if uirCoreStmtKindOf(st) == msLet || uirCoreStmtKindOf(st) == msVar || uirCoreStmtKindOf(st) == msAssign || uirCoreStmtKindOf(st) == msParam:
                    defSlot = uirCoreStmtSlotOf(st)

                if defSlot >= 0 && defSlot < n:
                    for k in 0..<n:
                        if availValid[k] && uirCoreOpt2ExprUsesSlot(availVals[k], defSlot):
                            availValid[k] = false
                    availValid[defSlot] = false
                    if (uirCoreStmtKindOf(st) == msLet || uirCoreStmtKindOf(st) == msVar || uirCoreStmtKindOf(st) == msAssign) && uirCoreOpt2ExprIsPure(uirCoreStmtExprOf(st)):
                        availVals[defSlot] = uirCoreStmtExprOf(st)
                        availValid[defSlot] = true

                if uirCoreStmtKindOf(st) == msStore || uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtExprOf(st)) || uirCoreOpt2ExprContainsCallOrLoad(uirCoreStmtAddrExprOf(st)):
                    for i in 0..<n:
                        availValid[i] = false

                uirCoreBlockSetStmtAt(blk, si, st)

            if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtRet:
                uirCoreOpt2BlockSetRetExpr(blk, uirCoreOpt2ExprRewriteWithMap(uirCoreTermRetExprOf(uirCoreBlockTermOf(blk)), availValid, availVals, changedAny))
            elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
                uirCoreOpt2BlockSetCondExpr(blk, uirCoreOpt2ExprRewriteWithMap(uirCoreTermCondExprOf(uirCoreBlockTermOf(blk)), availValid, availVals, changedAny))
    return changedAny

fn uirCoreOptimizeModuleFoldPureExprs(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for fi in 0..<uirCoreModuleFuncsLen(module):
        let func: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        for bi in 0..<uirCoreFuncBlocksLen(func):
            let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
            if (!uirCoreBlockIdValid(blk)):
                continue
            var out: UirStmtId[]
            for si in 0..<uirCoreBlockStmtsLen(blk):
                let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                if uirCoreStmtKindOf(st) == msExpr && uirCoreOpt2ExprIsPure(uirCoreStmtExprOf(st)):
                    changed = true
                    continue
                add(out, st)
            uirCoreBlockSetStmts(blk, out)
    return changed

fn uirCoreOptimizeModuleConstProp(module: UirCoreModule): bool =
    var changedAny: bool = false
    if (module == nil):
        return changedAny
    return changedAny

fn uirCoreOptimizeModuleNormalizeExpr(module: UirCoreModule): bool =
    var changed: bool = false
    if (module == nil):
        return changed
    return changed

fn uirCoreOptimizeModuleAlgebraic(module: UirCoreModule): bool =
    var changed: bool = false
    if (module == nil):
        return changed
    return changed

fn uirCoreOptimizeModuleCopyProp(module: UirCoreModule): bool =
    var changedAny: bool = false
    if (module == nil):
        return changedAny
    return changedAny

fn uirCoreFuncMergeIdenticalRetBlocks(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    var keys: str[]
    var labels: str[]
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtRet || uirCoreBlockStmtsLen(blk) != 0:
            continue
        let key: str = uirCoreOpt2ExprKey(uirCoreTermRetExprOf(uirCoreBlockTermOf(blk)))
        let idx: int32 = uirCoreOpt2ExprFindKey(keys, key)
        if idx >= 0 && idx < labels.len:
            let canonical: str = labels[idx]
            if uirCoreBlockLabelOf(blk) != canonical:
                if uirCoreOpt2RewriteTargets(func, uirCoreBlockLabelOf(blk), canonical):
                    changed = true
        else:
            add(keys, key)
            add(labels, uirCoreBlockLabelOf(blk))
    return changed

fn uirCoreFuncMergeEquivalentBlocks(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    var keys: str[]
    var labels: str[]
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        var keyParts: str[]
        for si in 0..<uirCoreBlockStmtsLen(blk):
            add(keyParts, uirCoreOpt2StmtKey(uirCoreBlockStmtAt(blk, si)))
            add(keyParts, ";")
        add(keyParts, "|")
        add(keyParts, uirCoreOpt2TermKey(uirCoreBlockTermOf(blk)))
        let key: str = strutils.join(keyParts, "")
        let idx: int32 = uirCoreOpt2ExprFindKey(keys, key)
        if idx >= 0 && idx < labels.len:
            let canonical: str = labels[idx]
            if uirCoreBlockLabelOf(blk) != canonical && bi != 0:
                if uirCoreOpt2RewriteTargets(func, uirCoreBlockLabelOf(blk), canonical):
                    changed = true
        else:
            add(keys, key)
            add(labels, uirCoreBlockLabelOf(blk))
    return changed

fn uirCoreFuncFoldCbrToRetExpr(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtCbr:
            continue
        let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)))
        let fi: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)))
        if ti < 0 || fi < 0:
            continue
        let tb: UirBlockId = uirCoreFuncBlockAt(func, ti)
        let fb: UirBlockId = uirCoreFuncBlockAt(func, fi)
        if (!uirCoreBlockIdValid(tb)) || (!uirCoreBlockIdValid(fb)):
            continue
        if uirCoreBlockStmtsLen(tb) != 0 || uirCoreBlockStmtsLen(fb) != 0:
            continue
        if uirCoreTermKindOf(uirCoreBlockTermOf(tb)) != mtRet || uirCoreTermKindOf(uirCoreBlockTermOf(fb)) != mtRet:
            continue
        if uirCoreOpt2ExprEq(uirCoreTermRetExprOf(uirCoreBlockTermOf(tb)), uirCoreTermRetExprOf(uirCoreBlockTermOf(fb))):
            uirCoreOpt2BlockSetTerm(blk, uirCoreTermRet(uirCoreTermRetExprOf(uirCoreBlockTermOf(tb))))
            changed = true
    return changed

fn uirCoreFuncFoldCbrToRetBool(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtCbr:
            continue
        let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)))
        let fi: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)))
        if ti < 0 || fi < 0:
            continue
        let tb: UirBlockId = uirCoreFuncBlockAt(func, ti)
        let fb: UirBlockId = uirCoreFuncBlockAt(func, fi)
        if (!uirCoreBlockIdValid(tb)) || (!uirCoreBlockIdValid(fb)) || uirCoreBlockStmtsLen(tb) != 0 || uirCoreBlockStmtsLen(fb) != 0:
            continue
        if uirCoreTermKindOf(uirCoreBlockTermOf(tb)) != mtRet || uirCoreTermKindOf(uirCoreBlockTermOf(fb)) != mtRet:
            continue
        if uirCoreOpt2ExprIsConstI64(uirCoreTermRetExprOf(uirCoreBlockTermOf(tb)), 1) && uirCoreOpt2ExprIsConstI64(uirCoreTermRetExprOf(uirCoreBlockTermOf(fb)), 0):
            uirCoreOpt2BlockSetTerm(blk, uirCoreTermRet(uirCoreTermCondExprOf(uirCoreBlockTermOf(blk))))
            changed = true
        elif uirCoreOpt2ExprIsConstI64(uirCoreTermRetExprOf(uirCoreBlockTermOf(tb)), 0) && uirCoreOpt2ExprIsConstI64(uirCoreTermRetExprOf(uirCoreBlockTermOf(fb)), 1):
            uirCoreOpt2BlockSetTerm(blk, uirCoreTermRet(uirCoreCmp(mcEq, uirCoreTermCondExprOf(uirCoreBlockTermOf(blk)), uirCoreConstI64(0))))
            changed = true
    return changed

fn uirCoreFuncFoldCbrConstantTarget(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtCbr:
            continue
        let cond: UirExprId = uirCoreTermCondExprOf(uirCoreBlockTermOf(blk))
        if uirCoreExprIdValid(cond) && uirCoreExprKindOf(cond) == meConstI64:
            if uirCoreExprConstValueOf(cond) != 0:
                uirCoreOpt2BlockSetTerm(blk, uirCoreTermBr(uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk))))
            else:
                uirCoreOpt2BlockSetTerm(blk, uirCoreTermBr(uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk))))
            changed = true
    return changed

fn uirCoreOptimizeModuleFoldJumpToRet(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for fi in 0..<uirCoreModuleFuncsLen(module):
        let func: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        for bi in 0..<uirCoreFuncBlocksLen(func):
            let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
            if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtBr:
                continue
            let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetOf(uirCoreBlockTermOf(blk)))
            if ti < 0:
                continue
            let tb: UirBlockId = uirCoreFuncBlockAt(func, ti)
            if (!uirCoreBlockIdValid(tb)) || uirCoreBlockStmtsLen(tb) != 0 || uirCoreTermKindOf(uirCoreBlockTermOf(tb)) != mtRet:
                continue
            uirCoreOpt2BlockSetTerm(blk, uirCoreTermRet(uirCoreTermRetExprOf(uirCoreBlockTermOf(tb))))
            changed = true
    return changed

fn uirCoreFuncSimplifyBranches(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr && uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)) == uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)):
            uirCoreOpt2BlockSetTerm(blk, uirCoreTermBr(uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk))))
            changed = true
    return changed

fn uirCoreFuncSimplifyCbrZeroCmp(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtCbr:
            continue
        let cond: UirExprId = uirCoreTermCondExprOf(uirCoreBlockTermOf(blk))
        if (!uirCoreExprIdValid(cond)) || uirCoreExprKindOf(cond) != meCmp:
            continue
        if uirCoreExprCmpOpOf(cond) == mcNe:
            if uirCoreOpt2ExprIsConstI64(uirCoreExprRhsOf(cond), 0):
                uirCoreOpt2BlockSetCondExpr(blk, uirCoreExprLhsOf(cond))
                changed = true
            elif uirCoreOpt2ExprIsConstI64(uirCoreExprLhsOf(cond), 0):
                uirCoreOpt2BlockSetCondExpr(blk, uirCoreExprRhsOf(cond))
                changed = true
    return changed

fn uirCoreFuncThreadCbrToBr(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtCbr:
            continue
        let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)))
        let fi: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)))
        if ti >= 0:
            let tb: UirBlockId = uirCoreFuncBlockAt(func, ti)
            if uirCoreBlockIdValid(tb) && uirCoreBlockStmtsLen(tb) == 0 && uirCoreTermKindOf(uirCoreBlockTermOf(tb)) == mtBr:
                uirCoreOpt2BlockSetTargetTrue(blk, uirCoreOwnStr(uirCoreTermTargetOf(uirCoreBlockTermOf(tb))))
                changed = true
        if fi >= 0:
            let fb: UirBlockId = uirCoreFuncBlockAt(func, fi)
            if uirCoreBlockIdValid(fb) && uirCoreBlockStmtsLen(fb) == 0 && uirCoreTermKindOf(uirCoreBlockTermOf(fb)) == mtBr:
                uirCoreOpt2BlockSetTargetFalse(blk, uirCoreOwnStr(uirCoreTermTargetOf(uirCoreBlockTermOf(fb))))
                changed = true
    return changed

fn uirCoreFuncFoldCbrSameTarget(func: UirCoreFunc): bool =
    return uirCoreFuncSimplifyBranches(func)

fn uirCoreFuncNormalizeCbrTruthiness(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    if uirCoreFuncSimplifyCbrZeroCmp(func):
        changed = true
    if uirCoreFuncFoldCbrConstantTarget(func):
        changed = true
    return changed

fn uirCoreFuncFoldRetAlias(func: UirCoreFunc): bool =
    var changed: bool = false
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return changed
    return changed

fn uirCoreFuncThreadBrToCbr(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtBr:
            continue
        let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetOf(uirCoreBlockTermOf(blk)))
        if ti < 0:
            continue
        let tb: UirBlockId = uirCoreFuncBlockAt(func, ti)
        if (!uirCoreBlockIdValid(tb)) || uirCoreBlockStmtsLen(tb) != 0 || uirCoreTermKindOf(uirCoreBlockTermOf(tb)) != mtCbr:
            continue
        uirCoreOpt2BlockSetTerm(blk, uirCoreTermCbr(uirCoreTermCondExprOf(uirCoreBlockTermOf(tb)), uirCoreTermTargetTrueOf(uirCoreBlockTermOf(tb)), uirCoreTermTargetFalseOf(uirCoreBlockTermOf(tb))))
        changed = true
    return changed

fn uirCoreFuncFoldEmptyJumpBlocks(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)):
            continue
        if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtBr:
            let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetOf(uirCoreBlockTermOf(blk)))
            if ti >= 0:
                let tb: UirBlockId = uirCoreFuncBlockAt(func, ti)
                if uirCoreBlockIdValid(tb) && uirCoreBlockStmtsLen(tb) == 0 && uirCoreTermKindOf(uirCoreBlockTermOf(tb)) == mtBr && uirCoreBlockLabelOf(tb) != uirCoreBlockLabelOf(blk):
                    uirCoreOpt2BlockSetTarget(blk, uirCoreOwnStr(uirCoreTermTargetOf(uirCoreBlockTermOf(tb))))
                    changed = true
        elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
            let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)))
            if ti >= 0:
                let tb: UirBlockId = uirCoreFuncBlockAt(func, ti)
                if uirCoreBlockIdValid(tb) && uirCoreBlockStmtsLen(tb) == 0 && uirCoreTermKindOf(uirCoreBlockTermOf(tb)) == mtBr:
                    uirCoreOpt2BlockSetTargetTrue(blk, uirCoreOwnStr(uirCoreTermTargetOf(uirCoreBlockTermOf(tb))))
                    changed = true
            let fi: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)))
            if fi >= 0:
                let fb: UirBlockId = uirCoreFuncBlockAt(func, fi)
                if uirCoreBlockIdValid(fb) && uirCoreBlockStmtsLen(fb) == 0 && uirCoreTermKindOf(uirCoreBlockTermOf(fb)) == mtBr:
                    uirCoreOpt2BlockSetTargetFalse(blk, uirCoreOwnStr(uirCoreTermTargetOf(uirCoreBlockTermOf(fb))))
                    changed = true
    return changed

fn uirCoreFuncMergeUncondJumpChain(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if (!uirCoreBlockIdValid(blk)) || uirCoreTermKindOf(uirCoreBlockTermOf(blk)) != mtBr:
            continue
        var target: str
        uirCoreSetEmpty(target)
        uirCoreCopyStr(target, uirCoreTermTargetOf(uirCoreBlockTermOf(blk)))
        let guardBound: int32 = uirCoreFuncBlocksLen(func) + 2
        for _ in 0..<guardBound:
            let ti: int32 = uirCoreOpt2FindBlockIndex(func, target)
            if ti < 0:
                break
            let tb: UirBlockId = uirCoreFuncBlockAt(func, ti)
            if (!uirCoreBlockIdValid(tb)) || uirCoreBlockStmtsLen(tb) != 0 || uirCoreTermKindOf(uirCoreBlockTermOf(tb)) != mtBr:
                break
            if uirCoreTermTargetOf(uirCoreBlockTermOf(tb)) == target || uirCoreTermTargetOf(uirCoreBlockTermOf(tb)) == uirCoreBlockLabelOf(blk):
                break
            uirCoreCopyStr(target, uirCoreTermTargetOf(uirCoreBlockTermOf(tb)))
        if target != uirCoreTermTargetOf(uirCoreBlockTermOf(blk)):
            uirCoreOpt2BlockSetTarget(blk, uirCoreOwnStr(target))
            changed = true
    return changed

fn uirCoreFuncPruneUnreachableBlocks(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
        return false
    let reachable: bool[] = uirCoreOpt2ReachableBlocks(func)
    if reachable.len != uirCoreFuncBlocksLen(func):
        return false
    var out: UirBlockId[]
    var changed: bool = false
    for bi in 0..<uirCoreFuncBlocksLen(func):
        if reachable[bi]:
            add(out, uirCoreFuncBlockAt(func, bi))
        else:
            changed = true
    if changed:
        uirCoreFuncSetBlocks(func, out)
    return changed

fn uirCoreOpt2HasCycleVisit(func: UirCoreFunc, idx: int32, marks: int32[], depth: int32): bool =
    if (!uirCoreFuncIdValid(func)) || idx < 0 || idx >= marks.len:
        return false
    if depth > uirCoreFuncBlocksLen(func) + 2:
        return true
    let mark: int32 = marks[idx]
    if mark == 1:
        return true
    if mark == 2:
        return false
    marks[idx] = 1
    let blk: UirBlockId = uirCoreFuncBlockAt(func, idx)
    if uirCoreBlockIdValid(blk):
        if uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtBr:
            let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetOf(uirCoreBlockTermOf(blk)))
            if ti >= 0 && uirCoreOpt2HasCycleVisit(func, ti, marks, depth + 1):
                return true
        elif uirCoreTermKindOf(uirCoreBlockTermOf(blk)) == mtCbr:
            let ti: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetTrueOf(uirCoreBlockTermOf(blk)))
            if ti >= 0 && uirCoreOpt2HasCycleVisit(func, ti, marks, depth + 1):
                return true
            let fi: int32 = uirCoreOpt2FindBlockIndex(func, uirCoreTermTargetFalseOf(uirCoreBlockTermOf(blk)))
            if fi >= 0 && uirCoreOpt2HasCycleVisit(func, fi, marks, depth + 1):
                return true
    marks[idx] = 2
    return false

fn uirCoreFuncHasBackEdge(func: UirCoreFunc): bool =
    if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func) || uirCoreFuncBlocksLen(func) <= 1:
        return false
    var marks: int32[]
    for _ in 0..<uirCoreFuncBlocksLen(func):
        add(marks, 0)
    for bi in 0..<uirCoreFuncBlocksLen(func):
        if marks[bi] != 0:
            continue
        if uirCoreOpt2HasCycleVisit(func, bi, marks, 0):
            return true
    return false

fn uirCoreModuleHasBackEdge(module: UirCoreModule): bool =
    if (module == nil):
        return false
    for fi in 0..<uirCoreModuleFuncsLen(module):
        if uirCoreFuncHasBackEdge(uirCoreModuleFuncAt(module, fi)):
            return true
    return false

fn uirCoreOptimizeModuleCfg(module: UirCoreModule): bool =
    if (module == nil):
        return false
    var changedAny: bool = false
    for fi in 0..<uirCoreModuleFuncsLen(module):
        let func: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        # Temporary safety fence:
        # loop CFG canonicalization is currently unstable on stage0 and can
        # produce invalid branch forms at runtime (for/while regressions).
        if uirCoreFuncHasBackEdge(func):
            continue
        var changed: bool = false
        for _ in 0..<6:
            var passChanged: bool = false
            if uirCoreFuncFoldCbrConstantTarget(func):
                passChanged = true
            if uirCoreFuncFoldCbrSameTarget(func):
                passChanged = true
            if uirCoreFuncThreadCbrToBr(func):
                passChanged = true
            if uirCoreFuncFoldEmptyJumpBlocks(func):
                passChanged = true
            if uirCoreFuncMergeUncondJumpChain(func):
                passChanged = true
            if uirCoreFuncPruneUnreachableBlocks(func):
                passChanged = true
            if !passChanged:
                break
            changed = true
        if changed:
            changedAny = true
    return changedAny

fn uirCoreOptimizeModule2Once(module: UirCoreModule): bool =
    if (module == nil):
        return false
    let moduleHasLoop: bool = uirCoreModuleHasBackEdge(module)
    var changed: bool = false

    if !moduleHasLoop:
        if uirCoreInlineModuleOnce(module):
            changed = true
        if uirCoreOptimizeModuleConstProp(module):
            changed = true
        if uirCoreOptimizeModuleForwardSubstitute(module):
            changed = true
        if uirCoreOptimizeModuleNormalizeExpr(module):
            changed = true
        if uirCoreOptimizeModuleAlgebraic(module):
            changed = true
        if uirCoreOptimizeModuleNoopAssign(module):
            changed = true
        if uirCoreOptimizeModuleDseStores(module):
            changed = true
        if uirCoreOptimizeModuleFoldPureExprs(module):
            changed = true
        if uirCoreOptimizeModuleCopyProp(module):
            changed = true

    for fi in 0..<uirCoreModuleFuncsLen(module):
        let func: UirCoreFunc = uirCoreModuleFuncAt(module, fi)
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        # Temporary safety fence:
        # skip aggressive function-level opt2 transforms for loop functions
        # until loop CFG transforms are fully stabilized.
        if uirCoreFuncHasBackEdge(func):
            continue
        if uirCoreFuncSroa(func):
            changed = true
        if uirCoreFuncCse(func, module):
            changed = true
        if uirCoreFuncLicm(func):
            changed = true
        if uirCoreFuncMergeIdenticalRetBlocks(func):
            changed = true
        if uirCoreFuncMergeEquivalentBlocks(func):
            changed = true
        if uirCoreFuncFoldCbrToRetExpr(func):
            changed = true
        if uirCoreFuncFoldCbrToRetBool(func):
            changed = true
        if uirCoreFuncFoldCbrConstantTarget(func):
            changed = true
        if uirCoreFuncSimplifyBranches(func):
            changed = true
        if uirCoreFuncSimplifyCbrZeroCmp(func):
            changed = true
        if uirCoreFuncThreadCbrToBr(func):
            changed = true
        if uirCoreFuncFoldCbrSameTarget(func):
            changed = true
        if uirCoreFuncNormalizeCbrTruthiness(func):
            changed = true
        if uirCoreFuncFoldRetAlias(func):
            changed = true
        if uirCoreFuncThreadBrToCbr(func):
            changed = true
        if uirCoreFuncFoldEmptyJumpBlocks(func):
            changed = true
        if uirCoreFuncMergeUncondJumpChain(func):
            changed = true
        if uirCoreFuncPruneUnreachableBlocks(func):
            changed = true
        if uirCoreFuncDceStmts(func):
            changed = true

    if !moduleHasLoop:
        if uirCoreOptimizeModuleFoldJumpToRet(module):
            changed = true
        if uirCoreOptimizeModuleCfg(module):
            changed = true
    if uirCorePruneUnreachableFuncs(module):
        changed = true

    return changed

fn uirCoreOptimizeModule2(module: UirCoreModule): bool =
    if (module == nil):
        return false
    let maxIters: int32 = uirCoreOpt2ParseIntEnv("UIR_OPT2_ITERS", 5, 1, 32)
    var changedAny: bool = false
    for _ in 0..<maxIters:
        let changed: bool = uirCoreOptimizeModule2Once(module)
        if changed:
            changedAny = true
        else:
            break
    return changedAny
# ---- end backend/uir/uir_internal/uir_core_opt2.cheng ----

# ---- begin backend/uir/uir_egraph_rewrite.cheng ----
# UIR e-graph rewrite engine (phase-3):
# - per-expression equivalence saturation with bounded candidate sets
# - deterministic extraction via explicit cost model

fn uirEGraphReadI32(p: ptr): int32 =
    if p == nil:
        return 0
    var out: int32 = 0
    memCopyCompat(&out, p, int32(sizeof int32))
    return out

fn uirEGraphWriteI32(p: ptr, value: int32) =
    if p == nil:
        return
    var tmp: int32 = value
    memCopyCompat(p, &tmp, int32(sizeof int32))

fn uirEGraphWriteI64(p: ptr, value: int64) =
    if p == nil:
        return
    var tmp: int64 = value
    memCopyCompat(p, &tmp, int32(sizeof int64))

fn uirEGraphLoadStats(p: ptr): UirEGraphStats =
    var out: UirEGraphStats
    if p == nil:
        return out
    memCopyCompat(&out, p, int32(sizeof UirEGraphStats))
    return out

fn uirEGraphStoreStats(p: ptr, value: UirEGraphStats) =
    if p == nil:
        return
    var tmp: UirEGraphStats = value
    memCopyCompat(p, &tmp, int32(sizeof UirEGraphStats))

fn uirEGraphWriteBlock(seqInst: UirBlockId[]*, idx: int32, val: UirBlockId) =
    if (seqInst == nil):
        return
    if idx < 0 || idx >= seqInst->len:
        return
    seqInst[idx] = val

fn add(dst: var UirEGraphCandidate[], val: UirEGraphCandidate) =
    seqs.add(dst, val)

fn uirExprIsConst(expr: UirExpr, value: int64): bool =
    if (expr <= 0) || uirExprKindOf(expr) != meConstI64:
        return false
    return uirExprConstValueOf(expr) == value

fn uirExprTryConstI64(expr: UirExpr, out: ptr): bool =
    if (expr <= 0) || (out == nil):
        return false
    if uirExprKindOf(expr) != meConstI64:
        return false
    uirEGraphWriteI64(out, uirExprConstValueOf(expr))
    return true

fn uirEGraphExprKeyInner(expr: UirExpr, depth: ptr): str =
    if (expr <= 0):
        return "nil"
    if (depth == nil):
        return "depth_nil"
    if uirEGraphReadI32(depth) >= uirExprRecursionLimit():
        return "depth_limit"
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) + 1)
    let k: UirExprKind = uirExprKindOf(expr)
    var parts: str[]
    seqs.add(parts, "k")
    seqs.add(parts, intToStr(int32(k)))
    if k == meConstI64:
        seqs.add(parts, ":v")
        seqs.add(parts, intToStr(int32(uirExprConstValueOf(expr) & 2147483647)))
    elif k == meLocal || k == meAddr:
        seqs.add(parts, ":l")
        seqs.add(parts, intToStr(uirExprLocalIndexOf(expr)))
    elif k == meGlobalAddr:
        seqs.add(parts, ":g")
        seqs.add(parts, uirExprGlobalNameOf(expr))
    elif k == meBin:
        seqs.add(parts, ":b")
        seqs.add(parts, intToStr(int32(uirExprBinOpOf(expr))))
        seqs.add(parts, "(")
        seqs.add(parts, uirEGraphExprKeyInner(uirExprLhsOf(expr), depth))
        seqs.add(parts, ",")
        seqs.add(parts, uirEGraphExprKeyInner(uirExprRhsOf(expr), depth))
        seqs.add(parts, ")")
    elif k == meCmp:
        seqs.add(parts, ":c")
        seqs.add(parts, intToStr(int32(uirExprCmpOpOf(expr))))
        seqs.add(parts, "(")
        seqs.add(parts, uirEGraphExprKeyInner(uirExprLhsOf(expr), depth))
        seqs.add(parts, ",")
        seqs.add(parts, uirEGraphExprKeyInner(uirExprRhsOf(expr), depth))
        seqs.add(parts, ")")
    elif k == meCast:
        seqs.add(parts, ":cast(")
        seqs.add(parts, uirEGraphExprKeyInner(uirExprCastExprOf(expr), depth))
        seqs.add(parts, ")")
    elif k == meLoad:
        seqs.add(parts, ":load(")
        seqs.add(parts, uirEGraphExprKeyInner(uirExprAddrExprOf(expr), depth))
        seqs.add(parts, ")")
    elif k == meCall:
        seqs.add(parts, ":call(")
        seqs.add(parts, uirExprCalleeOf(expr))
        for i in 0..<uirExprArgsLen(expr):
            seqs.add(parts, ",")
            seqs.add(parts, uirEGraphExprKeyInner(uirExprArgAt(expr, i), depth))
        seqs.add(parts, ")")
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) - 1)
    return strutils.join(parts, "")

fn uirEGraphExprKey(expr: UirExpr): str =
    var depth: int32 = 0
    return uirEGraphExprKeyInner(expr, &depth)

fn uirExprEqualInner(a: UirExpr, b: UirExpr, depth: ptr): bool =
    if a == b:
        return true
    if (a <= 0) || (b <= 0) || (depth == nil):
        return false
    if uirEGraphReadI32(depth) >= uirExprRecursionLimit():
        return false
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) + 1)
    var out: bool = false
    let ka: UirExprKind = uirExprKindOf(a)
    let kb: UirExprKind = uirExprKindOf(b)
    if ka != kb:
        out = false
    elif ka == meConstI64:
        out = uirExprConstValueOf(a) == uirExprConstValueOf(b)
    elif ka == meLocal || ka == meAddr:
        out = uirExprLocalIndexOf(a) == uirExprLocalIndexOf(b)
    elif ka == meGlobalAddr:
        out = uirStrCmp(uirExprGlobalNameOf(a), uirExprGlobalNameOf(b)) == 0
    elif ka == meCall:
        if uirStrCmp(uirExprCalleeOf(a), uirExprCalleeOf(b)) != 0:
            out = false
        else:
            let n: int32 = uirExprArgsLen(a)
            if n != uirExprArgsLen(b):
                out = false
            else:
                out = true
                for i in 0..<n:
                    if !uirExprEqualInner(uirExprArgAt(a, i), uirExprArgAt(b, i), depth):
                        out = false
                        break
    elif ka == meBin:
        if uirExprBinOpOf(a) != uirExprBinOpOf(b):
            out = false
        else:
            out = uirExprEqualInner(uirExprLhsOf(a), uirExprLhsOf(b), depth) &&
                  uirExprEqualInner(uirExprRhsOf(a), uirExprRhsOf(b), depth)
    elif ka == meCmp:
        if uirExprCmpOpOf(a) != uirExprCmpOpOf(b):
            out = false
        else:
            out = uirExprEqualInner(uirExprLhsOf(a), uirExprLhsOf(b), depth) &&
                  uirExprEqualInner(uirExprRhsOf(a), uirExprRhsOf(b), depth)
    elif ka == meCast:
        out = uirExprEqualInner(uirExprCastExprOf(a), uirExprCastExprOf(b), depth)
    elif ka == meLoad:
        out = uirExprEqualInner(uirExprAddrExprOf(a), uirExprAddrExprOf(b), depth)
    else:
        out = false
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) - 1)
    return out

fn uirExprEqual(a: UirExpr, b: UirExpr): bool =
    var depth: int32 = 0
    return uirExprEqualInner(a, b, &depth)

fn uirExprNodeCountInner(expr: UirExpr, depth: ptr): int32 =
    if (expr <= 0):
        return 0
    if (depth == nil):
        return 1
    if uirEGraphReadI32(depth) >= uirExprRecursionLimit():
        return 1
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) + 1)
    var out: int32 = 1
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meBin || k == meCmp:
        out = 1 + uirExprNodeCountInner(uirExprLhsOf(expr), depth) + uirExprNodeCountInner(uirExprRhsOf(expr), depth)
    elif k == meCall:
        var n: int32 = 1
        for i in 0..<uirExprArgsLen(expr):
            n = n + uirExprNodeCountInner(uirExprArgAt(expr, i), depth)
        out = n
    elif k == meCast:
        out = 1 + uirExprNodeCountInner(uirExprCastExprOf(expr), depth)
    elif k == meLoad:
        out = 1 + uirExprNodeCountInner(uirExprAddrExprOf(expr), depth)
    else:
        out = 1
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) - 1)
    return out

fn uirExprNodeCount(expr: UirExpr): int32 =
    var depth: int32 = 0
    return uirExprNodeCountInner(expr, &depth)

fn uirExprLatencyCostInner(expr: UirExpr, depth: ptr): int32 =
    if (expr <= 0):
        return 0
    if (depth == nil):
        return 0
    if uirEGraphReadI32(depth) >= uirExprRecursionLimit():
        return 0
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) + 1)
    var out: int32 = 0
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meBin:
        let op: UirBinOp = uirExprBinOpOf(expr)
        var selfCost: int32 = 1
        if op == mbMul:
            selfCost = 4
        elif op == mbSdiv || op == mbSmod:
            selfCost = 7
        elif op == mbShl || op == mbShr:
            selfCost = 2
        out = selfCost + uirExprLatencyCostInner(uirExprLhsOf(expr), depth) + uirExprLatencyCostInner(uirExprRhsOf(expr), depth)
    elif k == meCmp:
        out = 1 + uirExprLatencyCostInner(uirExprLhsOf(expr), depth) + uirExprLatencyCostInner(uirExprRhsOf(expr), depth)
    elif k == meCall:
        var n: int32 = 8
        for i in 0..<uirExprArgsLen(expr):
            n = n + uirExprLatencyCostInner(uirExprArgAt(expr, i), depth)
        out = n
    elif k == meCast:
        out = 1 + uirExprLatencyCostInner(uirExprCastExprOf(expr), depth)
    elif k == meLoad:
        out = 3 + uirExprLatencyCostInner(uirExprAddrExprOf(expr), depth)
    else:
        out = 0
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) - 1)
    return out

fn uirExprLatencyCost(expr: UirExpr): int32 =
    var depth: int32 = 0
    return uirExprLatencyCostInner(expr, &depth)

fn uirEGraphAssocBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirEGraphCommutativeBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirTryFoldConstBin(op: UirBinOp, lhs: int64, rhs: int64, folded: ptr): bool =
    if (folded == nil):
        return false
    if op == mbAdd:
        uirEGraphWriteI64(folded, lhs + rhs)
        return true
    if op == mbSub:
        uirEGraphWriteI64(folded, lhs - rhs)
        return true
    if op == mbMul:
        uirEGraphWriteI64(folded, lhs * rhs)
        return true
    if op == mbSdiv:
        if rhs == 0:
            return false
        uirEGraphWriteI64(folded, lhs / rhs)
        return true
    if op == mbSmod:
        if rhs == 0:
            return false
        uirEGraphWriteI64(folded, lhs % rhs)
        return true
    if op == mbAnd:
        uirEGraphWriteI64(folded, lhs & rhs)
        return true
    if op == mbOr:
        uirEGraphWriteI64(folded, lhs | rhs)
        return true
    if op == mbXor:
        uirEGraphWriteI64(folded, lhs ^ rhs)
        return true
    if op == mbShl || op == mbShr:
        if rhs < 0 || rhs >= 63:
            return false
        let sh: int32 = int32(rhs)
        if op == mbShl:
            uirEGraphWriteI64(folded, lhs << sh)
        else:
            uirEGraphWriteI64(folded, lhs >> sh)
        return true
    return false

fn uirEGraphRuleCount(): int32 =
    return 26

fn uirEGraphApplyRule(expr: UirExpr, ruleId: int32): UirExpr =
    if (expr <= 0):
        return nil
    let k: UirExprKind = uirExprKindOf(expr)

    if ruleId == 24 && k == meCast:
        let inner: UirExpr = uirExprCastExprOf(expr)
        if !(inner <= 0) && uirExprKindOf(inner) == meCast:
            return uirExprCastExprOf(inner)
        return nil

    if ruleId == 25 && k == meCmp:
        let lhsCmp: UirExpr = uirExprLhsOf(expr)
        let rhsCmp: UirExpr = uirExprRhsOf(expr)
        if uirExprEqual(lhsCmp, rhsCmp):
            let cmpOp: UirCmpOp = uirExprCmpOpOf(expr)
            var fold: int64 = 0
            if cmpOp == mcEq || cmpOp == mcLe || cmpOp == mcGe:
                fold = 1
            return uirCoreConstI64(fold)
        return nil

    if k != meBin:
        return nil
    let op: UirBinOp = uirExprBinOpOf(expr)
    let lhs: UirExpr = uirExprLhsOf(expr)
    let rhs: UirExpr = uirExprRhsOf(expr)

    if ruleId == 0 && op == mbAdd && uirExprIsConst(rhs, 0):
        return lhs
    if ruleId == 1 && op == mbAdd && uirExprIsConst(lhs, 0):
        return rhs
    if ruleId == 2 && op == mbSub && uirExprIsConst(rhs, 0):
        return lhs
    if ruleId == 3 && op == mbSub && uirExprEqual(lhs, rhs):
        return uirCoreConstI64(0)
    if ruleId == 4 && op == mbMul && uirExprIsConst(rhs, 1):
        return lhs
    if ruleId == 5 && op == mbMul && uirExprIsConst(lhs, 1):
        return rhs
    if ruleId == 6 && op == mbMul && (uirExprIsConst(lhs, 0) || uirExprIsConst(rhs, 0)):
        return uirCoreConstI64(0)
    if ruleId == 7 && op == mbSdiv && uirExprIsConst(rhs, 1):
        return lhs
    if ruleId == 8 && op == mbSmod && uirExprIsConst(rhs, 1):
        return uirCoreConstI64(0)
    if ruleId == 9 && op == mbOr && (uirExprIsConst(rhs, 0) || uirExprIsConst(lhs, 0)):
        if uirExprIsConst(rhs, 0):
            return lhs
        return rhs
    if ruleId == 10 && op == mbOr && uirExprEqual(lhs, rhs):
        return lhs
    if ruleId == 11 && op == mbXor && (uirExprIsConst(rhs, 0) || uirExprIsConst(lhs, 0)):
        if uirExprIsConst(rhs, 0):
            return lhs
        return rhs
    if ruleId == 12 && op == mbXor && uirExprEqual(lhs, rhs):
        return uirCoreConstI64(0)
    if ruleId == 13 && op == mbAnd && (uirExprIsConst(rhs, -1) || uirExprIsConst(lhs, -1)):
        if uirExprIsConst(rhs, -1):
            return lhs
        return rhs
    if ruleId == 14 && op == mbAnd && (uirExprIsConst(rhs, 0) || uirExprIsConst(lhs, 0)):
        return uirCoreConstI64(0)
    if ruleId == 15 && op == mbAnd && uirExprEqual(lhs, rhs):
        return lhs
    if ruleId == 16 && (op == mbShl || op == mbShr) && uirExprIsConst(rhs, 0):
        return lhs
    if ruleId == 17 && op == mbAdd && uirExprEqual(lhs, rhs):
        return uirCoreBin(mbShl, lhs, uirCoreConstI64(1))
    if ruleId == 18 && op == mbMul && (uirExprIsConst(lhs, 2) || uirExprIsConst(rhs, 2)):
        if uirExprIsConst(lhs, 2):
            return uirCoreBin(mbShl, rhs, uirCoreConstI64(1))
        return uirCoreBin(mbShl, lhs, uirCoreConstI64(1))

    if ruleId == 19 && uirEGraphCommutativeBin(op):
        let lhsKey: str = uirEGraphExprKey(lhs)
        let rhsKey: str = uirEGraphExprKey(rhs)
        if uirStrCmp(rhsKey, lhsKey) < 0:
            return uirCoreBin(op, rhs, lhs)
        return nil

    if ruleId == 20 && uirEGraphAssocBin(op):
        if !(lhs <= 0) && uirExprKindOf(lhs) == meBin && uirExprBinOpOf(lhs) == op:
            return uirCoreBin(op, uirExprLhsOf(lhs), uirCoreBin(op, uirExprRhsOf(lhs), rhs))
        return nil

    if ruleId == 21 && uirEGraphAssocBin(op):
        if !(rhs <= 0) && uirExprKindOf(rhs) == meBin && uirExprBinOpOf(rhs) == op:
            return uirCoreBin(op, uirCoreBin(op, lhs, uirExprLhsOf(rhs)), uirExprRhsOf(rhs))
        return nil

    if ruleId == 22:
        var lhsConst: int64 = 0
        var rhsConst: int64 = 0
        if uirExprTryConstI64(lhs, &lhsConst) && uirExprTryConstI64(rhs, &rhsConst):
            var folded: int64 = 0
            if uirTryFoldConstBin(op, lhsConst, rhsConst, &folded):
                return uirCoreConstI64(folded)
        return nil

    if ruleId == 23:
        if op == mbAnd:
            if !(rhs <= 0) && uirExprKindOf(rhs) == meBin && uirExprBinOpOf(rhs) == mbOr:
                if uirExprEqual(lhs, uirExprLhsOf(rhs)) || uirExprEqual(lhs, uirExprRhsOf(rhs)):
                    return lhs
            if !(lhs <= 0) && uirExprKindOf(lhs) == meBin && uirExprBinOpOf(lhs) == mbOr:
                if uirExprEqual(rhs, uirExprLhsOf(lhs)) || uirExprEqual(rhs, uirExprRhsOf(lhs)):
                    return rhs
        if op == mbOr:
            if !(rhs <= 0) && uirExprKindOf(rhs) == meBin && uirExprBinOpOf(rhs) == mbAnd:
                if uirExprEqual(lhs, uirExprLhsOf(rhs)) || uirExprEqual(lhs, uirExprRhsOf(rhs)):
                    return lhs
            if !(lhs <= 0) && uirExprKindOf(lhs) == meBin && uirExprBinOpOf(lhs) == mbAnd:
                if uirExprEqual(rhs, uirExprLhsOf(lhs)) || uirExprEqual(rhs, uirExprRhsOf(lhs)):
                    return rhs
        return nil

    return nil

fn uirEGraphFindCandidate(cands: UirEGraphCandidate[], key: str): int32 =
    for i in 0..<cands.len:
        if uirStrCmp(cands[i].key, key) == 0:
            return i
    return -1

fn uirEGraphCandidateInsert(cands: UirEGraphCandidate[],
                            expr: UirExpr,
                            goal: str,
                            iterBudget: int32): bool =
    if (expr <= 0):
        return false
    let key: str = uirEGraphExprKey(expr)
    if uirEGraphFindCandidate(cands, key) >= 0:
        return false
    var cand: UirEGraphCandidate
    cand.key = key
    cand.expr = expr
    cand.nodeCount = uirExprNodeCount(expr)
    cand.opCost = uirExprLatencyCost(expr)
    cand.score = uirEGraphScore(goal, cand.nodeCount, cand.opCost, iterBudget)
    add(cands, cand)
    return true

fn uirEGraphCandidateBetter(a: UirEGraphCandidate, b: UirEGraphCandidate): bool =
    if a.score != b.score:
        return a.score < b.score
    if a.nodeCount != b.nodeCount:
        return a.nodeCount < b.nodeCount
    if a.opCost != b.opCost:
        return a.opCost < b.opCost
    return uirStrCmp(a.key, b.key) < 0

fn uirEGraphSaturateExpr(expr: UirExpr,
                         goal: str,
                         iterBudget: int32,
                         roundBudget: int32,
                         classNodeBudget: int32,
                         stats: ptr,
                         depth: ptr): UirExpr =
    if (expr <= 0):
        return nil
    if (depth == nil):
        return expr
    if uirEGraphReadI32(depth) >= uirExprRecursionLimit():
        return expr
    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) + 1)
    var cur: UirExprId = expr
    let k: UirExprKind = uirExprKindOf(cur)
    if k == meBin || k == meCmp:
        let lhs2: UirExprId = uirEGraphSaturateExpr(uirCoreExprLhsOf(cur), goal, iterBudget, roundBudget, classNodeBudget, stats, depth)
        let rhs2: UirExprId = uirEGraphSaturateExpr(uirCoreExprRhsOf(cur), goal, iterBudget, roundBudget, classNodeBudget, stats, depth)
        uirCoreExprSetLhs(cur, lhs2)
        uirCoreExprSetRhs(cur, rhs2)
    elif k == meCall:
        for i in 0..<uirCoreExprArgsLen(cur):
            let arg2: UirExprId = uirEGraphSaturateExpr(uirCoreExprArgAt(cur, i), goal, iterBudget, roundBudget, classNodeBudget, stats, depth)
            uirCoreExprSetArgAt(cur, i, arg2)
    elif k == meCast:
        let castExpr2: UirExprId = uirEGraphSaturateExpr(uirCoreExprCastExprOf(cur), goal, iterBudget, roundBudget, classNodeBudget, stats, depth)
        uirCoreExprSetCastExpr(cur, castExpr2)
    elif k == meLoad:
        let addrExpr2: UirExprId = uirEGraphSaturateExpr(uirCoreExprAddrExprOf(cur), goal, iterBudget, roundBudget, classNodeBudget, stats, depth)
        uirCoreExprSetAddrExpr(cur, addrExpr2)

    var cands: UirEGraphCandidate[]
    uirEGraphCandidateInsert(cands, cur, goal, iterBudget)
    var usedRounds: int32 = 0
    var saturated: bool = true
    var localRuleHits: int32 = 0
    for round in 0..<roundBudget:
        usedRounds = usedRounds + 1
        let processLen: int32 = cands.len
        var addedThisRound: int32 = 0
        for ci in 0..<processLen:
            let baseExpr: UirExpr = cands[ci].expr
            for ruleId in 0..<uirEGraphRuleCount():
                let rewritten: UirExpr = uirEGraphApplyRule(baseExpr, ruleId)
                if (rewritten <= 0):
                    continue
                if uirEGraphCandidateInsert(cands, rewritten, goal, iterBudget):
                    localRuleHits = localRuleHits + 1
                    addedThisRound = addedThisRound + 1
                    if cands.len >= classNodeBudget:
                        saturated = false
                        break
            if cands.len >= classNodeBudget:
                break
        if cands.len >= classNodeBudget:
            break
        if addedThisRound == 0:
            break
        if round == roundBudget - 1:
            saturated = false

    var bestIdx: int32 = 0
    for i in 1..<cands.len:
        if uirEGraphCandidateBetter(cands[i], cands[bestIdx]):
            bestIdx = i
    let bestExpr: UirExpr = cands[bestIdx].expr

    if !(stats == nil):
        let statsPtr: UirEGraphStatsPtr = UirEGraphStatsPtr(stats)
        var statsVal: UirEGraphStats = uirEGraphLoadStats(statsPtr)
        statsVal.classes = statsVal.classes + 1
        statsVal.rounds = statsVal.rounds + usedRounds
        statsVal.candidates = statsVal.candidates + cands.len
        statsVal.ruleHits = statsVal.ruleHits + localRuleHits
        if saturated:
            statsVal.saturatedClasses = statsVal.saturatedClasses + 1
        if cands.len >= classNodeBudget:
            statsVal.classBudgetHit = statsVal.classBudgetHit + 1
        if !uirExprEqual(bestExpr, cur):
            statsVal.extracted = statsVal.extracted + 1
        uirEGraphStoreStats(statsPtr, statsVal)

    uirEGraphWriteI32(depth, uirEGraphReadI32(depth) - 1)
    return bestExpr

fn uirEGraphEmitReport(goal: str,
                       iterBudget: int32,
                       roundBudget: int32,
                       classNodeBudget: int32,
                       requireProof: bool,
                       proofCheckedFuncs: int32,
                       proofSkippedFuncs: int32,
                       st: UirEGraphStats) =
    let f: UirOptFile = uirOptGetStderr()
    uirOptWrite(f, "egraph_report\tgoal=")
    uirOptWrite(f, goal)
    uirOptWrite(f, "\titer_budget=")
    uirOptWrite(f, intToStr(iterBudget))
    uirOptWrite(f, "\tround_budget=")
    uirOptWrite(f, intToStr(roundBudget))
    uirOptWrite(f, "\tclass_node_budget=")
    uirOptWrite(f, intToStr(classNodeBudget))
    uirOptWrite(f, "\trequire_proof=")
    uirOptWrite(f, intToStr(requireProof ? 1 : 0))
    uirOptWrite(f, "\tproof_checked_funcs=")
    uirOptWrite(f, intToStr(proofCheckedFuncs))
    uirOptWrite(f, "\tproof_skipped_funcs=")
    uirOptWrite(f, intToStr(proofSkippedFuncs))
    uirOptWrite(f, "\tclasses=")
    uirOptWrite(f, intToStr(st.classes))
    uirOptWrite(f, "\trounds=")
    uirOptWrite(f, intToStr(st.rounds))
    uirOptWrite(f, "\tcandidates=")
    uirOptWrite(f, intToStr(st.candidates))
    uirOptWrite(f, "\trule_hits=")
    uirOptWrite(f, intToStr(st.ruleHits))
    uirOptWrite(f, "\textracted=")
    uirOptWrite(f, intToStr(st.extracted))
    uirOptWrite(f, "\tsaturated_classes=")
    uirOptWrite(f, intToStr(st.saturatedClasses))
    uirOptWrite(f, "\tclass_budget_hit=")
    uirOptWriteLine(f, intToStr(st.classBudgetHit))
    uirOptFFlush(f)

fn uirRunEGraphRewrite(module: UirModule, iterBudget: int32, goal: str, requireProof: bool): bool =
    if (module == nil):
        return false
    let normalizedGoal: str = uirEGraphNormalizeGoal(goal)
    var rounds: int32 = iterBudget
    if rounds <= 0:
        rounds = 1
    if rounds > 32:
        rounds = 32
    let roundBudget: int32 = uirEnvParseInt("UIR_EGRAPH_ROUND_BUDGET", rounds, 1, 64)
    let classNodeBudget: int32 = uirEnvParseInt("UIR_EGRAPH_CLASS_NODE_BUDGET", 128, 16, 4096)
    let classBudget: int32 = uirEnvParseInt("UIR_EGRAPH_CLASS_BUDGET", 1000000, 64, 10000000)
    var changedAny: bool = false
    var stats: UirEGraphStats
    stats.classes = 0
    stats.rounds = 0
    stats.candidates = 0
    stats.ruleHits = 0
    stats.extracted = 0
    stats.saturatedClasses = 0
    stats.classBudgetHit = 0
    var stopBudget: bool = false
    var proofCheckedFuncs: int32 = 0
    var proofSkippedFuncs: int32 = 0

    for fi in 0..<uirModuleFuncsLen(module):
        if stopBudget:
            break
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if (funcView == nil) || uirFuncIsExtern(funcView):
            continue
        let func: UirCoreFunc = funcView
        let proofBacked: bool = uirFuncProofBackedForOpt2(func)
        if proofBacked:
            proofCheckedFuncs = proofCheckedFuncs + 1
        elif requireProof:
            proofSkippedFuncs = proofSkippedFuncs + 1
            continue
        let blockCount: int32 = uirCoreFuncBlocksLen(func)
        for bi in 0..<blockCount:
            if stopBudget:
                break
            let blkView: UirLowerBlock = uirCoreFuncBlockAt(func, bi)
            if (blkView <= 0):
                continue
            let blk: UirBlockId = blkView
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            for si in 0..<stmtCount:
                if stopBudget:
                    break
                var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                let stmtExpr: UirExpr = uirCoreStmtExprOf(st)
                if !(stmtExpr <= 0):
                    let beforeExpr: UirExpr = stmtExpr
                    var depthExpr: int32 = 0
                    st = uirCoreStmtWithExpr(st, uirEGraphSaturateExpr(stmtExpr, normalizedGoal, rounds, roundBudget,
                                                                        classNodeBudget, &stats, &depthExpr))
                    if !uirExprEqual(beforeExpr, uirCoreStmtExprOf(st)):
                        changedAny = true
                if uirCoreStmtKindOf(st) == msStore && !(uirCoreStmtAddrExprOf(st) <= 0):
                    let beforeAddr: UirExpr = uirCoreStmtAddrExprOf(st)
                    var depthAddr: int32 = 0
                    st = uirCoreStmtWithAddrExpr(st, uirEGraphSaturateExpr(uirCoreStmtAddrExprOf(st), normalizedGoal, rounds, roundBudget,
                                                                            classNodeBudget, &stats, &depthAddr))
                    if !uirExprEqual(beforeAddr, uirCoreStmtAddrExprOf(st)):
                        changedAny = true
                uirCoreBlockSetStmtAt(blk, si, st)
                if stats.classes >= classBudget:
                    stopBudget = true
            if !stopBudget:
                let term: UirCoreTerm = uirCoreBlockTermOf(blk)
                if uirCoreTermKindOf(term) == mtRet && !(uirCoreTermRetExprOf(term) <= 0):
                    let beforeRet: UirExpr = uirCoreTermRetExprOf(term)
                    var depthRet: int32 = 0
                    let nextRet: UirExpr = uirEGraphSaturateExpr(uirCoreTermRetExprOf(term), normalizedGoal, rounds, roundBudget,
                                                                 classNodeBudget, &stats, &depthRet)
                    uirCoreBlockSetTerm(blk, uirCoreTermWithRetExpr(term, nextRet))
                    if !uirExprEqual(beforeRet, nextRet):
                        changedAny = true
                elif uirCoreTermKindOf(term) == mtCbr && !(uirCoreTermCondExprOf(term) <= 0):
                    let beforeCond: UirExpr = uirCoreTermCondExprOf(term)
                    var depthCond: int32 = 0
                    let nextCond: UirExpr = uirEGraphSaturateExpr(uirCoreTermCondExprOf(term), normalizedGoal, rounds, roundBudget,
                                                                  classNodeBudget, &stats, &depthCond)
                    uirCoreBlockSetTerm(blk, uirCoreTermWithCondExpr(term, nextCond))
                    if !uirExprEqual(beforeCond, nextCond):
                        changedAny = true
            uirCoreFuncSetBlockAt(func, bi, blk)
            if stats.classes >= classBudget:
                stopBudget = true
    if uirOptEnvIsTrue("UIR_EGRAPH_REPORT"):
        uirEGraphEmitReport(normalizedGoal, rounds, roundBudget, classNodeBudget,
                            requireProof, proofCheckedFuncs, proofSkippedFuncs, stats)
    return changedAny
# ---- end backend/uir/uir_egraph_rewrite.cheng ----

# ---- begin backend/uir/uir_opt.cheng ----
# Unified IR optimizer facade.

type
    UirProfileState =
        startNs: int64
        lastNs: int64
        enabled: bool

fn uirOptNowNs(): int64 =
    return uirOptCMonotimeNs()

fn uirProfileInit(enabled: bool): UirProfileState =
    var st: UirProfileState
    st.enabled = enabled
    let nowNs: int64 = uirOptNowNs()
    st.startNs = nowNs
    st.lastNs = nowNs
    return st

fn uirProfileStep(st: var UirProfileState, label: str) =
    if ! st.enabled:
        return
    let nowNs: int64 = uirOptNowNs()
    let stepMs: int64 = (nowNs - st.lastNs) / 1000000
    let totalMs: int64 = (nowNs - st.startNs) / 1000000
    st.lastNs = nowNs
    let f: UirOptFile = uirOptGetStderr()
    uirOptWrite(f, "uir_profile")
    uirOptWrite(f, "\t")
    uirOptWrite(f, label)
    uirOptWrite(f, "\tstep_ms=")
    uirOptWrite(f, intToStr(stepMs))
    uirOptWrite(f, "\ttotal_ms=")
    uirOptWriteLine(f, intToStr(totalMs))
    uirOptFFlush(f)

fn uirProfilePass(st: var UirProfileState, label: str, changed: bool) =
    uirProfileStep(st, label)
    if changed:
        uirProfileStep(st, label + ".changed")

fn uirProfileOpt2ProofRequirement(st: var UirProfileState, label: str, module: UirModule) =
    uirProfileStep(st, label + ".proof_required")
    uirProfileStep(st, label + ".proof_backed_funcs=" +
                       intToStr(uirModuleCountProofBackedFuncs(module)))

fn uirNormalizeOptLevel(level: int32): int32 =
    var out: int32 = level
    if out < 0:
        out = 0
    if out > 3:
        out = 3
    return out

fn uirRunCoreOptimize2(module: UirModule): bool =
    if (module == nil):
        return false
    return uirCoreOptimizeModule2(module)

fn uirRunCoreOptimizeConverge(module: UirModule, stage: str, maxIters: int32, st: var UirProfileState): bool =
    var rounds: int32 = maxIters
    if rounds <= 0:
        rounds = 1
    var any: bool = false
    for i in 0..<rounds:
        let changed: bool = uirRunCoreOptimize2(module)
        uirProfilePass(st, stage + "." + intToStr(i), changed)
        if changed:
            any = true
        else:
            break
    return any

fn uirModExprFoldPass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    let changed: bool = uirCoreOptimizeModule(module)
    uirProfilePass(st, stage + ".expr_fold", changed)
    return changed

fn uirModNormExprPass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    let changed: bool = uirCoreOptimizeModuleNormalizeExpr(module)
    uirProfilePass(st, stage + ".normalize_expr", changed)
    return changed

fn uirModConstPropPass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    let changed: bool = uirCoreOptimizeModuleConstProp(module)
    uirProfilePass(st, stage + ".const_prop", changed)
    return changed

fn uirModForwardSubstPass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    let changed: bool = uirCoreOptimizeModuleForwardSubstitute(module)
    uirProfilePass(st, stage + ".forward_subst", changed)
    return changed

