fn uirCoreOwnObjLocal(olIn: UirCoreObjLocal): UirCoreObjLocal =
    var out: UirCoreObjLocal = olIn
    out.objTypeName = uirCoreOwnStrSafe(out.objTypeName)
    out.typeKey = uirCoreOwnStrSafe(out.typeKey)
    return out

