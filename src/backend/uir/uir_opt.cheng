fn uirCoreFuncObjFrameSizeOf(func: UirCoreFunc): int32 =
    let saneMax: int32 = 16 * 1024 * 1024
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    var funcVal: UirCoreFuncObj
    if funcObj != nil:
        funcVal = uirCoreFuncObjLoadPtr(funcObj)
    let funcSize: int32 = (funcObj != nil) ? funcVal.objFrameSize : 0
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    if dyn != nil:
        let dynSize: int32 = dyn.objFrameSize
        let dynSane: bool = dynSize >= 0 && dynSize <= saneMax
        let funcSane: bool = funcSize >= 0 && funcSize <= saneMax
        if funcSane:
            if !dynSane || dynSize != funcSize:
                dyn.objFrameSize = funcSize
            return funcSize
        if dynSane:
            if funcObj != nil:
                funcVal.objFrameSize = dynSize
                uirCoreFuncObjStorePtr(funcObj, funcVal)
            return dynSize
        if funcObj != nil:
            funcVal.objFrameSize = 0
            uirCoreFuncObjStorePtr(funcObj, funcVal)
        dyn.objFrameSize = 0
        return 0
    if funcObj == nil:
        return 0
    if funcSize < 0 || funcSize > saneMax:
        funcVal.objFrameSize = 0
        uirCoreFuncObjStorePtr(funcObj, funcVal)
        return 0
    return funcSize

