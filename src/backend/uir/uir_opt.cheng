fn uirFuncLicmPass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for i in 0..<uirModuleFuncsLen(module):
        let f: UirFunc = uirModuleFuncAt(module, i)
        if (f == nil) || uirFuncIsExtern(f):
