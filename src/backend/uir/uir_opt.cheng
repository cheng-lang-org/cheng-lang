fn uirCoreFuncSyncObjIdentityFromDyn(func: UirCoreFunc, syncRetTypeKey: bool = false) =
    if !uirCoreFuncIdValid(func):
        return
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    if dyn == nil:
        return
    var funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    let dbgBoot: bool = uirOptEnvIsTrue("BACKEND_DEBUG_BOOT")
    let dbgNameObj0: str = funcVal.name
    let dbgNameDyn0: str = dyn.name
    let dbgName0: str = uirCoreChooseNonEmpty(dbgNameObj0, dbgNameDyn0)
    let dbgTrack: bool = dbgBoot &&
                         (dbgNameObj0 == "main" || dbgNameObj0 == "backendMain" ||
                          dbgNameDyn0 == "main" || dbgNameDyn0 == "backendMain" ||
                          strContains(funcVal.originFile, "backend_driver.cheng") ||
                          strContains(dyn.originFile, "backend_driver.cheng"))
    if dbgTrack:
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_sync_obj_id.before name=" +
                     dbgName0 +
                     " func_dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " obj_dyn_id=" + intToStr(funcVal.dynId) +
                     " obj_extern=" + (funcVal.isExtern ? "1" : "0") +
                     " dyn_extern=" + (dyn.isExtern ? "1" : "0") +
                     " obj_origin=" + funcVal.originFile +
                     " dyn_origin=" + dyn.originFile +
                     " obj_decl=" + intToStr(funcVal.declOrdinal) +
                     " dyn_decl=" + intToStr(dyn.declOrdinal) +
                     " obj_ast=" + intToStr(funcVal.sourceAstIndex) +
                     " dyn_ast=" + intToStr(dyn.sourceAstIndex))
        uirOptFFlush(uirOptGetStderr())
    if uirCoreStrPtrSane(dyn.name):
        funcVal.name = dyn.name
    if uirCoreStrPtrSane(dyn.linkName) && len(dyn.linkName) > 0:
        funcVal.linkName = dyn.linkName
    elif uirCoreStrPtrSane(dyn.name):
        funcVal.linkName = dyn.name
    if uirCoreStrPtrSane(dyn.originFile):
        funcVal.originFile = dyn.originFile
    funcVal.declOrdinal = dyn.declOrdinal
    funcVal.sourceAstIndex = dyn.sourceAstIndex
    let dynId: int32 = uirCoreFuncDynId(func)
    if uirCoreFuncDynIdSane(dynId):
        funcVal.dynId = dynId
    funcVal.isExtern = dyn.isExtern
    funcVal.isExported = dyn.isExported
    funcVal.retType = dyn.retType
    if syncRetTypeKey && uirCoreStrPtrSane(dyn.retTypeKey):
        funcVal.retTypeKey = dyn.retTypeKey
    funcVal.objFrameSize = dyn.objFrameSize
    uirCoreFuncObjStorePtr(funcObj, funcVal)
    # Keep phase-contract metadata authoritative on dyn. Rewriting these object
    # slots has correlated with tail corruption on old-stage0/fresh selfhost
    # builds, similar to the retTypeKey instability above.
    if dbgTrack:
        uirOptWriteLine(uirOptGetStderr(),
                     "[backend] dbg_sync_obj_id.after name=" +
                     uirCoreChooseNonEmpty(funcVal.name, dyn.name) +
                     " func_dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " obj_dyn_id=" + intToStr(funcVal.dynId) +
                     " obj_extern=" + (funcVal.isExtern ? "1" : "0") +
                     " dyn_extern=" + (dyn.isExtern ? "1" : "0") +
                     " obj_origin=" + funcVal.originFile +
                     " dyn_origin=" + dyn.originFile +
                     " obj_decl=" + intToStr(funcVal.declOrdinal) +
                     " dyn_decl=" + intToStr(dyn.declOrdinal) +
                     " obj_ast=" + intToStr(funcVal.sourceAstIndex) +
                     " dyn_ast=" + intToStr(dyn.sourceAstIndex))
        uirOptFFlush(uirOptGetStderr())

