# Concrete Result specializations needed by stage1/self-link bootstrap.
fn Ok_UirCoreExpr(value: UirExprId): Result[UirExprId] =
    return Ok[UirExprId](value)

fn Err_UirCoreExpr(err: str): Result[UirExprId] =
    return Err[UirExprId](err)

fn ErrInfo_UirCoreExpr(err: ErrorInfo): Result[UirExprId] =
    return ErrInfo[UirExprId](err)

fn Ok_UirCoreFunc(value: UirCoreFunc): Result[UirCoreFunc] =
    return Ok[UirCoreFunc](value)

fn Err_UirCoreFunc(err: str): Result[UirCoreFunc] =
    return Err[UirCoreFunc](err)

fn ErrInfo_UirCoreFunc(err: ErrorInfo): Result[UirCoreFunc] =
    return ErrInfo[UirCoreFunc](err)

fn Ok_UirCoreModule(value: UirCoreModule): Result[UirCoreModule] =
    if (value == nil):
        return Err[UirCoreModule]("uir core module ok(nil) is forbidden")
    return Ok[UirCoreModule](value)

fn Err_UirCoreModule(err: str): Result[UirCoreModule] =
    return Err[UirCoreModule](err)

fn ErrInfo_UirCoreModule(err: ErrorInfo): Result[UirCoreModule] =
