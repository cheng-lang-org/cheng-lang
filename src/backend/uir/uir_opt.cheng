    return changed

fn uirFuncDcePass(module: UirModule, st: var UirProfileState, stage: str): bool =
    if (module == nil):
        return false
    var changed: bool = false
    for i in 0..<uirModuleFuncsLen(module):
        let f: UirFunc = uirModuleFuncAt(module, i)
        if (f == nil) || uirFuncIsExtern(f):
            continue
        # Current DCE liveness is not backedge-aware enough; keep loop funcs
        # conservative to avoid dropping live initializers.
        if uirCoreFuncHasBackEdge(f):
            continue
        if uirCoreFuncDceStmts(f):
            changed = true
    uirProfilePass(st, stage + ".func_dce", changed)
    return changed

