fn uirCoreModuleSetFuncAt(module: UirCoreModule, idx: int32, func: UirCoreFunc) =
    if (module == nil):
        return
    if uirCoreFuncIdValid(func):
        uirCoreCanonicalizeFunc(func)
        uirCoreFuncSyncBlocks(func)
    var funcsLocal: UirCoreFunc[] = module.funcs
    uirCoreWriteFunc(&funcsLocal, idx, func)
    var mod0: UirCoreModule = module
    mod0.funcs = funcsLocal

fn uirCoreModuleSetFuncs(module: UirCoreModule, funcs: UirCoreFunc[]) =
    if (module == nil):
        return
    var funcsLocal: UirCoreFunc[] = []
    for i in 0..<funcs.len:
        add(funcsLocal, funcs[i])
    var mod0: UirCoreModule = module
    mod0.funcs = funcsLocal

fn uirCoreModuleCountHighUirCheckedFuncs(module: UirCoreModule): int32 =
    if (module == nil):
        return 0
    var total: int32 = 0
    for i in 0..<module.funcs.len:
        let f = module.funcs[i]
        if (f == nil) || uirCoreFuncIsExtern(f):
            continue
        if uirCoreFuncHighUirCheckedOf(f):
            total = total + 1
    return total

fn uirCoreModuleCountLowUirLoweredFuncs(module: UirCoreModule): int32 =
    if (module == nil):
        return 0
    var total: int32 = 0
    for i in 0..<module.funcs.len:
        let f = module.funcs[i]
        if (f == nil) || uirCoreFuncIsExtern(f):
            continue
        if uirCoreFuncLowUirLoweredOf(f):
            total = total + 1
    return total

fn uirCoreModuleCountHighUirFallbackFuncs(module: UirCoreModule): int32 =
    if (module == nil):
        return 0
    var total: int32 = 0
    for i in 0..<module.funcs.len:
        let f = module.funcs[i]
        if (f == nil) || uirCoreFuncIsExtern(f):
            continue
        if !uirCoreFuncHighUirCheckedOf(f) && len(uirCoreFuncPhaseFallbackReasonOf(f)) > 0:
            total = total + 1
    return total

fn uirCoreModuleApplyPhaseContract(module: UirCoreModule, highUirChecked: bool, fallbackReason: str) =
    if (module == nil):
        return
    for i in 0..<module.funcs.len:
        let f = module.funcs[i]
        if (f == nil) || uirCoreFuncIsExtern(f):
            continue
        if highUirChecked:
            uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), highUirChecked, true, "")
        else:
            uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), highUirChecked, true, fallbackReason)

