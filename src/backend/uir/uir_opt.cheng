fn uirCoreSoaArenaZero(): UirCoreSoaArena =
    var arena: UirCoreSoaArena
    arena.exprCap = 0
    arena.stmtCap = 0
    arena.blockCap = 0
    arena.edgeCap = 0
    return arena

fn uirCoreSoaArenaAccumulate(arena: var UirCoreSoaArena, exprCap: int32, stmtCap: int32,
                             blockCap: int32, edgeCap: int32) =
    if exprCap > 0:
        arena.exprCap = arena.exprCap + exprCap
    if stmtCap > 0:
        arena.stmtCap = arena.stmtCap + stmtCap
    if blockCap > 0:
        arena.blockCap = arena.blockCap + blockCap
    if edgeCap > 0:
        arena.edgeCap = arena.edgeCap + edgeCap

fn uirCoreSoaEstimateFuncArena(func: UirCoreFunc): UirCoreSoaArena =
    var arena: UirCoreSoaArena = uirCoreSoaArenaZero()
    if (!uirCoreFuncIdValid(func)):
        return arena
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
        # Heuristic: expressions are at least one per stmt, and binary/call trees
        # typically contribute an additional node. Keep this linear and cache-friendly.
        let exprCap: int32 = stmtCount * 2 + 4
        let edgeCap: int32 = 2
        uirCoreSoaArenaAccumulate(arena, exprCap, stmtCount, 1, edgeCap)
    return arena

fn uirCoreSoaReserveModuleColumns(soa: UirCoreSoaModule, arena: UirCoreSoaArena) =
    if (soa == nil):
        return
    if arena.exprCap > 0:
        reserve(soa.exprKind, arena.exprCap)
        reserve(soa.exprType, arena.exprCap)
        reserve(soa.exprA, arena.exprCap)
        reserve(soa.exprB, arena.exprCap)
        reserve(soa.exprC, arena.exprCap)
        reserve(soa.exprImm, arena.exprCap)
        reserve(soa.exprStrId, arena.exprCap)
    if arena.stmtCap > 0:
        reserve(soa.stmtKind, arena.stmtCap)
        reserve(soa.stmtDst, arena.stmtCap)
        reserve(soa.stmtExpr, arena.stmtCap)
        reserve(soa.stmtNext, arena.stmtCap)
    if arena.blockCap > 0:
        reserve(soa.blockFirstStmt, arena.blockCap)
        reserve(soa.blockTermKind, arena.blockCap)
        reserve(soa.blockTermA, arena.blockCap)
        reserve(soa.blockTermB, arena.blockCap)
        reserve(soa.succStart, arena.blockCap)
        reserve(soa.succLen, arena.blockCap)
        reserve(soa.predStart, arena.blockCap)
        reserve(soa.predLen, arena.blockCap)
        reserve(soa.funcSpans, arena.blockCap)
    if arena.edgeCap > 0:
        reserve(soa.succEdges, arena.edgeCap)
        reserve(soa.predEdges, arena.edgeCap)

