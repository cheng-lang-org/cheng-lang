    return uirCoreTypeKindRaw(ty) == int32(mtF32)

fn uirCoreTypeIsI16(ty: UirCoreType): bool =
    return uirCoreTypeKindRaw(ty) == int32(mtI16)

fn uirCoreTypeIsI8(ty: UirCoreType): bool =
    return uirCoreTypeKindRaw(ty) == int32(mtI8)

fn uirCoreTermKindRet(): UirCoreTermKind =
    return mtRet

fn uirCoreTermKindBr(): UirCoreTermKind =
    return mtBr

fn uirCoreTermKindCbr(): UirCoreTermKind =
    return mtCbr

fn uirCoreTermKindIsRet(kind: UirCoreTermKind): bool =
    return kind == mtRet

fn uirCoreTermKindIsBr(kind: UirCoreTermKind): bool =
    return kind == mtBr

fn uirCoreTermKindIsCbr(kind: UirCoreTermKind): bool =
    return kind == mtCbr

fn uirCoreEncodeBinOp(op: UirCoreBinOp): int32 =
    return int32(op)

fn uirCoreBinOpAdd(): UirCoreBinOp =
    return mbAdd

fn uirCoreBinOpSub(): UirCoreBinOp =
    return mbSub

fn uirCoreBinOpMul(): UirCoreBinOp =
