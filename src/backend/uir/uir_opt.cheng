    uirCore_funcDynKeys: int64[]

var
    uirCore_funcDynVals: UirCoreFuncDynState[]
    uirCore_funcDynAddrs: int64[]
    uirCore_nextFuncDynId: int32

const uirCoreFuncDynIdMax: int32 = 1 << 20

fn uirCoreFuncDynIdSane(dynId: int32): bool =
    return dynId > 0 && dynId <= uirCoreFuncDynIdMax

fn uirCoreFuncPtrRememberable(ptrVal: int64): bool =
    if ptrVal == 0:
        return false
    if ptrVal <= 4096:
        return false
    if ptrVal >= int64(0x0001000000000000):
        return false
    let high32: int64 = (ptrVal >> 32) & int64(0xffffffff)
    let low32: int64 = ptrVal & int64(0xffffffff)
    if high32 == 1 && low32 > 0 && low32 <= int64(uirCoreFuncDynIdMax):
        return false
    return true

fn uirCoreHostVoidPtr(ptrVal: int64): ptr =
    return ptr(uint64(ptrVal))

fn uirCoreFuncRawPtrVal(func: UirCoreFunc): int64 =
    if func == nil:
        return 0
    return int64(UirCoreFuncObjPtr(func))

fn uirCoreFuncRetainPtr(func: UirCoreFunc): ptr =
    if func == nil:
        return nil
    return ptr(UirCoreFuncObjPtr(func))

fn uirCoreDynStatePtrVal(dyn: UirCoreFuncDynState): int64 =
    if dyn == nil:
        return 0
    return int64(uint64(dyn))

fn uirCoreDynStateRetainPtr(dyn: UirCoreFuncDynState): ptr =
    if dyn == nil:
        return nil
    return ptr(dyn)

fn uirCoreFuncFromPtrVal(ptrVal: int64): UirCoreFunc =
    return UirCoreFunc(uirCoreHostVoidPtr(ptrVal))

fn uirCoreFuncObjPtrFromPtrVal(ptrVal: int64): UirCoreFuncObjPtr =
    return UirCoreFuncObjPtr(uirCoreHostVoidPtr(ptrVal))

fn uirCoreReadBlockIdPtr(p: ptr): UirBlockId =
    if p == nil:
        return 0
    var out: UirBlockId = 0
    memCopyCompat(&out, p, int32(sizeof UirBlockId))
    return out

fn uirCoreLoadFuncObjValue(funcObj: UirCoreFuncObjPtr): UirCoreFuncObj =
    var out: UirCoreFuncObj
    if funcObj == nil:
        return out
    memCopyCompat(&out, ptr(funcObj), int32(sizeof UirCoreFuncObj))
    return out

fn uirCoreStoreFuncObjValue(funcObj: UirCoreFuncObjPtr, value: UirCoreFuncObj) =
    if funcObj == nil:
        return
    var tmp: UirCoreFuncObj = value
    memCopyCompat(ptr(funcObj), &tmp, int32(sizeof UirCoreFuncObj))

fn uirCoreFuncPtrKnown(ptrVal: int64): bool =
    if uirCoreHostPtrSane(ptrVal):
        return true
    if ptrVal <= 4096:
        return false
    let high32: int64 = (ptrVal >> 32) & int64(0xffffffff)
    if high32 != 0:
        return false
    let recovered: ptr = cheng_func_ptr_shadow_recover(uint64(ptrVal))
    if recovered == nil:
        return false
    return int64(recovered) == ptrVal

fn uirCoreRememberFuncDynAddr(func: UirCoreFunc) =
    if func == nil:
        return
    let dynId: int32 = uirCoreFuncDynId(func)
    if !uirCoreFuncDynIdSane(dynId):
        return
    let ptrVal: int64 = uirCoreRecoverFuncPtr(uirCoreFuncRawPtrVal(func))
    if !uirCoreFuncPtrRememberable(ptrVal):
        return
    cheng_func_ptr_shadow_remember(uirCoreHostVoidPtr(ptrVal))
    uirCoreEnsureFuncDynCache()
    let needLen: int32 = dynId
    var dynAddrs0: int64[] = uirCore_funcDynAddrs
    if dynAddrs0.buffer == nil || dynAddrs0.cap < needLen:
        cheng__seqGrowToRaw(&dynAddrs0.buffer, &dynAddrs0.cap, needLen, int32(sizeof int64))
    let oldLen: int32 = dynAddrs0.len
    if oldLen < needLen:
        dynAddrs0.len = needLen
        for i in oldLen..<needLen:
            dynAddrs0[i] = 0
    for i in 0..<dynAddrs0.len:
        if i == dynId - 1:
            continue
        if dynAddrs0[i] == ptrVal:
            dynAddrs0[i] = 0
    dynAddrs0[dynId - 1] = ptrVal
    uirCore_funcDynAddrs = dynAddrs0

fn uirCoreFuncFromDynKey(dynKey: int64): UirCoreFunc =
    if dynKey <= 0:
        return nil
    let high32: int64 = (dynKey >> 32) & int64(0xffffffff)
    let low32: int64 = dynKey & int64(0xffffffff)
    if high32 != 1 || low32 <= 0:
        return nil
    let dynId: int32 = int32(low32)
    if !uirCoreFuncDynIdSane(dynId):
        return nil
    uirCoreEnsureFuncDynCache()
    let idx: int32 = dynId - 1
    if idx < 0 || idx >= uirCore_funcDynAddrs.len:
        return nil
    let ptrVal: int64 = uirCore_funcDynAddrs[idx]
    if !uirCoreFuncPtrKnown(ptrVal):
        return nil
    return uirCoreFuncFromPtrVal(ptrVal)

fn uirCoreRecoverFuncPtr(ptrVal: int64): int64 =
    if uirCoreHostPtrSane(ptrVal):
        return ptrVal
    let recovered: ptr = cheng_func_ptr_shadow_recover(uint64(ptrVal))
    if recovered == nil:
        return 0
    return int64(recovered)

fn uirCoreEnsureFuncDynCache() =
    if !uirCoreFuncDynSeqSane(uirCore_funcDynVals):
        uirCore_funcDynVals = []
    if !uirCoreInt64SeqSane(uirCore_funcDynAddrs):
        uirCore_funcDynAddrs = []

fn uirCoreCacheDynState(dynId: int32, dyn: UirCoreFuncDynState) =
    if !uirCoreFuncDynIdSane(dynId) || dyn == nil:
        return
    uirCoreEnsureFuncDynCache()
    let needLen: int32 = dynId
    var dynVals0: UirCoreFuncDynState[] = uirCore_funcDynVals
    if dynVals0.buffer == nil || dynVals0.cap < needLen:
        cheng__seqGrowToRaw(&dynVals0.buffer, &dynVals0.cap, needLen, int32(sizeof ptr))
    let oldLen: int32 = dynVals0.len
    if oldLen < needLen:
        dynVals0.len = needLen
        for i in oldLen..<needLen:
            dynVals0[i] = nil
    memRetain(uirCoreDynStateRetainPtr(dyn))
    dynVals0[dynId - 1] = dyn
    uirCore_funcDynVals = dynVals0

fn uirCoreCachedDynStateById(dynId: int32): UirCoreFuncDynState =
    if !uirCoreFuncDynIdSane(dynId):
        return nil
    uirCoreEnsureFuncDynCache()
    let idx: int32 = dynId - 1
    if idx < 0 || idx >= uirCore_funcDynVals.len:
        return nil
    let dyn: UirCoreFuncDynState = uirCore_funcDynVals[idx]
    if dyn == nil:
        return nil
    let dynPtr: int64 = uirCoreDynStatePtrVal(dyn)
    if !uirCoreHostPtrSane(dynPtr):
        var dynVals0: UirCoreFuncDynState[] = uirCore_funcDynVals
        dynVals0[idx] = nil
        uirCore_funcDynVals = dynVals0
        return nil
    uirCoreSanitizeFuncDynPayload(dyn)
    return dyn

fn uirCoreFindDynIdByPtrKey(ptrKey: int64): int32 =
    let recoveredKey: int64 = uirCoreRecoverFuncPtr(ptrKey)
    if !uirCoreHostPtrSane(recoveredKey):
        return 0
    uirCoreEnsureFuncDynCache()
    let dynAddrCount: int32 = uirCore_funcDynAddrs.len
    if dynAddrCount <= 0:
        return 0
    for rev in 0..<dynAddrCount:
        let i: int32 = dynAddrCount - 1 - rev
        if uirCore_funcDynAddrs[i] != recoveredKey:
            continue
        let dynId: int32 = i + 1
        if !uirCoreFuncDynIdSane(dynId):
            continue
        return dynId
    return 0

fn uirCoreFuncNameCacheKey(func: UirCoreFunc): int64 =
    if func == nil:
        return 0
    let f0: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if f0 == nil:
        return 0
    let dynId: int32 = uirCoreFuncDynId(func)
    if !uirCoreFuncDynIdSane(dynId):
        return 0
    return int64(0x100000000) + int64(dynId)

fn uirCoreFuncPtrKey(func: UirCoreFunc): int64 =
    if func == nil:
        return 0
    return uirCoreRecoverFuncPtr(uirCoreFuncRawPtrVal(func))

