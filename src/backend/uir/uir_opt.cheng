                hashmaps.hashMapStrIntPut(uirCore_typeAliases_cache, a.name, i + 1)
                hashmaps.hashMapPtrIntPut(uirCore_typeAliases_ptr_cache, int64(rawmemAsVoid(name)), i + 1)
            return i
    return -1

