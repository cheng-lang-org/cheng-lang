fn uirCoreAppendExprArgs(seqInst: var UirExprId[][], val: UirExprId[]) =
    seqs.add(seqInst, uirCoreCloneExprArgs(val))

fn uirCoreAppendExprArgsFlat(val: UirExprId[]): int32 =
    let flatSeq: UirExprId[]* = &uirCore_exprArgsFlat
    let start: int32 = flatSeq->len
    let n: int32 = val.len
    if n <= 0:
        return start
    let needLen: int32 = start + n
    if flatSeq->buffer == nil || flatSeq->cap < needLen:
        cheng__seqGrowToRaw(&flatSeq->buffer, &flatSeq->cap, needLen, int32(sizeof int32))
    flatSeq->len = needLen
    for i in 0..<n:
        flatSeq[start + i] = val[i]
    return start

fn uirCoreAppendType(seqInst: var UirCoreType[], val: UirCoreType) =
    if seqInst.len < 0 || seqInst.cap < 0:
        seqInst.buffer = nil
        seqInst.len = 0
        seqInst.cap = 0
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        cheng__seqGrowToRaw(&seqInst.buffer, &seqInst.cap, needLen, int32(sizeof UirCoreType))
    seqInst.len = needLen
    seqInst[idx] = val

