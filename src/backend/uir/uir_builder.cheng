# Unified IR builder facade: stage1 frontend entry routed through UIR frontend.
import std/result
import std/os
import backend/uir/uir_types
import backend/uir/uir_internal/uir_core_builder
import backend/uir/uir_internal/uir_core_types

fn uirBuilderCoreModuleResultOrPanic(res: Result[UirCoreModule], path: str, emptyPrefix: str): UirModule =
    if !res.ok:
        let msg: str = ErrorFormat(res.err)
        if len(msg) == 0 || msg == "error":
            os.writeLine(os.get_stderr(), emptyPrefix + path)
            os.c_fflush os.get_stderr()
            panic "uirCore_builder: build failed (empty error) input=" + path
        panic msg
    if res.value == nil:
        panic "uirCore_builder: build ok(nil) input=" + path
    return res.value

fn uirBuildModuleFromFileOrPanic(path: str): UirModule =
    let res: Result[UirCoreModule] = uirCoreBuildModuleFromFile(path)
    return uirBuilderCoreModuleResultOrPanic(res,
                                             path,
                                             "[backend] stage1_orpanic: empty_error uirCoreBuildModuleFromFile input=")

fn uirBuildModuleFromFileStage1TargetOrPanic(path: str, target: str): UirModule =
    let res: Result[UirCoreModule] = uirCoreBuildModuleFromFileStage1(path, target)
    return uirBuilderCoreModuleResultOrPanic(res,
                                             path,
                                             "[backend] stage1_orpanic: empty_error uirCoreBuildModuleFromFileStage1 input=")

fn uirBuildModuleFromFileStage1OrPanic(path: str): UirModule =
    return uirBuildModuleFromFileStage1TargetOrPanic(path, "")
