# Unified IR facade: carries native UIR entities while production lowering remains
# wired to UIR-internal implementation.
import backend/uir/uir_internal/uir_core_types
import std/result
import std/strutils

@importc("getenv")
fn uirTypesGetEnvRaw(name: cstring): cstring

fn uirTypesGetEnvDefault(key: str, defaultValue: str): str =
    let value: cstring = uirTypesGetEnvRaw(strToCStringTemp(key))
    if value == nil || c_strlen(value) == 0:
        return defaultValue
    return strFromCStringBorrow(value)

