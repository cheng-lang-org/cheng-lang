# Thin facade for current-source root implementation entrypoints.
import std/result
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_root_engine

fn uirCoreRootImplBuildModuleFromRootId(rootInputId: AstNodeId): Result[UirCoreModule] =
    return uirCoreRootEngineBuildModuleFromRootId(rootInputId)

fn uirCoreRootImplBuildModuleFromRoot(rootInput: Node): Result[UirCoreModule] =
    return uirCoreRootEngineBuildModuleFromRoot(rootInput)
