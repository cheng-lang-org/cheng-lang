import std/result
import std/system
import stage1/frontend_lib
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_file_compile_impl

fn uirCoreFileCompileVariantsCStringOrEmpty(raw: cstring): str =
    if raw != nil:
        return str(raw)
    return ""

fn uirCoreFileCompileVariantsBuildModuleFromFileStage1Default(inPath: str): Result[UirCoreModule] =
    return uirCoreFileCompileImplBuildModuleFromFileStage1(inPath, "")

fn uirCoreFileCompileVariantsBuildModuleFromFileStage1OrPanicDefault(inPath: str): UirCoreModule =
    return uirCoreFileCompileImplBuildModuleFromFileStage1OrPanic(inPath, "")

fn uirCoreFileCompileVariantsBuildModuleFromFileStage1RawOrPanic(inRaw: cstring, targetRaw: cstring): UirCoreModule =
    frontend_lib.Stage1_setMainInputRaw(inRaw)
    let inPath: str = uirCoreFileCompileVariantsCStringOrEmpty(inRaw)
    let target: str = uirCoreFileCompileVariantsCStringOrEmpty(targetRaw)
    let mod: UirCoreModule = uirCoreFileCompileImplBuildModuleFromFileStage1OrPanic(inPath, target)
    frontend_lib.Stage1_clearMainInputRaw()
    return mod

fn uirCoreFileCompileVariantsBuildModuleFromFileStage1TargetFirst(target: str, inPath: str): Result[UirCoreModule] =
    return uirCoreFileCompileImplBuildModuleFromFileStage1(inPath, target)

fn uirCoreFileCompileVariantsBuildModuleFromFileStage1TargetFirstOrPanic(target: str, inPath: str): UirCoreModule =
    return uirCoreFileCompileImplBuildModuleFromFileStage1OrPanic(inPath, target)

fn uirCoreFileCompileVariantsBuildModuleFromFileStage1HostOnlyOrPanic(inPath: str): UirCoreModule =
    return uirCoreFileCompileImplBuildModuleFromFileStage1OrPanic(inPath, "arm64-apple-darwin")
