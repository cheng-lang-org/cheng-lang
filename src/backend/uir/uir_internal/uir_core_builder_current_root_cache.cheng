# Shared builder-local current-root/type-decl/type-node caches split from uir_core_builder.
import std/hashmaps
import std/seqs
import std/os
import std/system
import stage1/ast
import stage1/frontend_lib
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_base_helpers
import backend/uir/uir_internal/uir_core_builder_symbol_state
import backend/uir/uir_internal/uir_core_builder_type_name_cache

fn uir_core_builder_current_root_cache_add(dst: var Node[], val: Node) =
    seqs.Add(dst, val)

fn uir_core_builder_current_root_cache_add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn uirCoreCurrentRootCacheStableText(s: str): str =
    let owned: str = uirCoreOwnStrSafe(s)
    if len(owned) > 0:
        return owned
    return s

var uirCore_currentParsedRoot: Node
var uirCore_typeDeclByName_cache_root: Node
var uirCore_typeDeclByName_cache_index: hashmaps.HashMapStrInt
var uirCore_typeDeclByName_cache_index_ready: bool
var uirCore_typeDeclByName_cache_values: Node[]
var uirCore_typeDeclByName_cache_ready: bool
var uirCore_typeDeclByName_indexVisited: hashmaps.HashMapPtrInt
var uirCore_typeDeclByName_indexVisited_ready: bool
var uirCore_typeDeclByName_indexBuildInProgress: bool
var uirCore_typeDeclByName_indexBuildCount: int32
var uirCore_fieldTypeKeyFromCurrentRoot_cache_module: UirCoreModule
var uirCore_fieldTypeKeyFromCurrentRoot_cache_root: Node
var uirCore_fieldTypeKeyFromCurrentRoot_cache_index: hashmaps.HashMapStrInt
var uirCore_fieldTypeKeyFromCurrentRoot_cache_index_ready: bool
var uirCore_fieldTypeKeyFromCurrentRoot_cache_values: str[]
var uirCore_typeNodeObjName_cache_module: UirCoreModule
var uirCore_typeNodeObjName_cache_obj_types_len: int32
var uirCore_typeNodeObjName_cache_alias_len: int32
var uirCore_typeNodeObjName_ready: int8[]
var uirCore_typeNodeObjName_values: str[]

fn uirCoreCurrentParsedRootGet(): Node =
    return uirCore_currentParsedRoot

fn uirCoreCurrentParsedRootSet(root: Node) =
    uirCore_currentParsedRoot = root

fn uirCoreFieldTypeKeyFromCurrentRootCacheMatches(mod: UirCoreModule, root: Node): bool =
    return uirCore_fieldTypeKeyFromCurrentRoot_cache_module == mod &&
           uirCore_fieldTypeKeyFromCurrentRoot_cache_root == root

fn uirCoreTypeNodeObjNameCacheReset(mod: UirCoreModule = nil) =
    uirCore_typeNodeObjName_cache_module = mod
    uirCore_typeNodeObjName_cache_obj_types_len = (mod != nil) ? uirCoreModuleObjTypesLen(mod) : 0
    uirCore_typeNodeObjName_cache_alias_len = uirCoreObjAliasCount()
    uirCore_typeNodeObjName_values = []
    uirCore_typeNodeObjName_ready = []
    reserve(uirCore_typeNodeObjName_values, 256)
    reserve(uirCore_typeNodeObjName_ready, 256)

fn uirCoreTypeNodeObjNameCacheNeedsReset(mod: UirCoreModule): bool =
    if mod == nil:
        return uirCore_typeNodeObjName_cache_module != nil
    if uirCore_typeNodeObjName_cache_module != mod:
        return true
    if uirCore_typeNodeObjName_cache_obj_types_len != uirCoreModuleObjTypesLen(mod):
        return true
    if uirCore_typeNodeObjName_cache_alias_len != uirCoreObjAliasCount():
        return true
    return false

fn uirCoreFindTypeDeclByNameCacheReset(root: Node) =
    uirCore_typeDeclByName_cache_root = root
    uirCore_typeDeclByName_cache_ready = false
    if !uirCore_typeDeclByName_indexBuildInProgress:
        uirCore_typeDeclByName_indexBuildCount = 0
    if !uirCore_typeDeclByName_cache_index_ready:
        uirCore_typeDeclByName_cache_index = hashmaps.HashMapStrIntInit(256)
        uirCore_typeDeclByName_cache_index_ready = true
    else:
        hashmaps.HashMapStrIntClear(uirCore_typeDeclByName_cache_index)
    uirCore_typeDeclByName_cache_values = []
    reserve(uirCore_typeDeclByName_cache_values, 256)

fn uirCoreFindTypeDeclByNameCacheGet(root: Node, targetName0: str, found: var bool): Node =
    found = false
    if !astNodeIdValid(root) || uirCore_typeDeclByName_cache_root != root || len(targetName0) == 0:
        return astInvalidNodeId()
    var foundRaw: bool
    let raw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_typeDeclByName_cache_index, targetName0, foundRaw)
    if !foundRaw:
        return astInvalidNodeId()
    let idx: int32 = raw - 1
    if idx < 0 || idx >= uirCore_typeDeclByName_cache_values.len:
        return astInvalidNodeId()
    found = true
    return uirCore_typeDeclByName_cache_values[idx]

fn uirCoreFindTypeDeclByNameCachePut(root: Node, targetName0: str, td: Node) =
    if !astNodeIdValid(root) || uirCore_typeDeclByName_cache_root != root || len(targetName0) == 0:
        return
    if !uirCore_typeDeclByName_cache_index_ready:
        uirCoreFindTypeDeclByNameCacheReset(root)
    var foundRaw: bool
    let targetName: str = uirCoreCurrentRootCacheStableText(targetName0)
    let raw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_typeDeclByName_cache_index, targetName, foundRaw)
    if foundRaw && raw > 0 && raw <= uirCore_typeDeclByName_cache_values.len:
        let cachedIdx: int32 = raw - 1
        if cachedIdx >= 0 && cachedIdx < uirCore_typeDeclByName_cache_values.len:
            if !astNodeIdValid(uirCore_typeDeclByName_cache_values[cachedIdx]) && astNodeIdValid(td):
                uirCore_typeDeclByName_cache_values[cachedIdx] = td
            return
    let newIdx: int32 = uirCore_typeDeclByName_cache_values.len
    uir_core_builder_current_root_cache_add(uirCore_typeDeclByName_cache_values, td)
    hashmaps.HashMapStrIntPut(uirCore_typeDeclByName_cache_index, targetName, newIdx + 1)

fn uirCoreFindTypeDeclByNameIndexVisit(root: Node, n: Node, visitedCount: var int32, foundDeclCount: var int32) =
    visitedCount = visitedCount + 1
    if !astNodeIdValid(n):
        return
    let nodeKey: int64 = int64(n)
    var seen: bool
    hashmaps.HashMapPtrIntGetEx(uirCore_typeDeclByName_indexVisited, nodeKey, seen)
    if seen:
        return
    hashmaps.HashMapPtrIntPut(uirCore_typeDeclByName_indexVisited, nodeKey, 1)
    if astNodeIsTypeDecl(n) && kidCount(n) > 0:
        let nameNode: Node = kid(n, 0)
        if astNodeIdValid(nameNode) && astNodeIsIdentOrSymbol(nameNode):
            let candName: str = backendStripSpaces(plainName(nameNode))
            if len(candName) > 0:
                foundDeclCount = foundDeclCount + 1
                uirCoreFindTypeDeclByNameCachePut(root, candName, n)
    for i in 0..<kidCount(n):
        uirCoreFindTypeDeclByNameIndexVisit(root, kid(n, i), visitedCount, foundDeclCount)

fn uirCoreFindTypeDeclByNameIndexBuild(root: Node) =
    let debugTypeDeclProfile: bool = envIsTrue("BACKEND_DEBUG_TYPEDECL_PROFILE")
    if uirCore_typeDeclByName_indexBuildInProgress:
        if debugTypeDeclProfile:
            let f: os.File = os.Get_stderr()
            os.WriteLine(f, "[backend] typeDeclIndexBuild: skip re-entrant build")
            os.C_fflush(f)
        return
    if !astNodeIdValid(root):
        return
    let buildStartNs: int64 = cheng_monotime_ns()
    var visitedCount: int32
    var foundDeclCount: int32
    uirCore_typeDeclByName_indexBuildInProgress = true
    defer:
        uirCore_typeDeclByName_indexBuildInProgress = false
    if !astNodeIdValid(root):
        return
    if !uirCore_typeDeclByName_indexVisited_ready:
        uirCore_typeDeclByName_indexVisited = hashmaps.HashMapPtrIntInit(1024)
        uirCore_typeDeclByName_indexVisited_ready = true
    else:
        hashmaps.HashMapPtrIntClear(uirCore_typeDeclByName_indexVisited)
    uirCoreFindTypeDeclByNameIndexVisit(root, root, visitedCount, foundDeclCount)
    uirCore_typeDeclByName_cache_ready = true
    if debugTypeDeclProfile:
        let f: os.File = os.Get_stderr()
        let elapsedMs: int64 = (cheng_monotime_ns() - buildStartNs) / 1000000
        os.Write(f, "[backend] typeDeclIndexBuild ")
        os.Write(f, "visited=")
        os.Write(f, intToStr(visitedCount))
        os.Write(f, " decls=")
        os.Write(f, intToStr(foundDeclCount))
        os.Write(f, " cache_size=")
        os.Write(f, intToStr(uirCore_typeDeclByName_cache_values.len))
        os.Write(f, " elapsed_ms=")
        os.WriteLine(f, intToStr(elapsedMs))
        os.C_fflush(f)

fn uirCoreFieldTypeKeyFromCurrentRootCacheReset(mod: UirCoreModule, root: Node) =
    uirCore_fieldTypeKeyFromCurrentRoot_cache_module = mod
    uirCore_fieldTypeKeyFromCurrentRoot_cache_root = root
    if !uirCore_fieldTypeKeyFromCurrentRoot_cache_index_ready:
        uirCore_fieldTypeKeyFromCurrentRoot_cache_index = hashmaps.HashMapStrIntInit(512)
        uirCore_fieldTypeKeyFromCurrentRoot_cache_index_ready = true
    else:
        hashmaps.HashMapStrIntClear(uirCore_fieldTypeKeyFromCurrentRoot_cache_index)
    uirCore_fieldTypeKeyFromCurrentRoot_cache_values = []
    reserve(uirCore_fieldTypeKeyFromCurrentRoot_cache_values, 256)

fn uirCoreFieldTypeKeyFromCurrentRootCacheGet(mod: UirCoreModule, root: Node, parentType: str, fieldName: str, found: var bool): str =
    found = false
    if mod == nil || !astNodeIdValid(root) ||
       uirCore_fieldTypeKeyFromCurrentRoot_cache_module != mod ||
       uirCore_fieldTypeKeyFromCurrentRoot_cache_root != root:
        return ""
    let key: str = symbolJoinFieldKey(parentType, fieldName)
    if len(key) == 0:
        return ""
    var foundRaw: bool
    let raw: int32 = uirCoreHashMapStrIntGetCompatLocal(
        uirCore_fieldTypeKeyFromCurrentRoot_cache_index, key, foundRaw)
    if !foundRaw || raw <= 0:
        return ""
    let idx: int32 = raw - 1
    if idx < 0 || idx >= uirCore_fieldTypeKeyFromCurrentRoot_cache_values.len:
        return ""
    found = true
    return uirCore_fieldTypeKeyFromCurrentRoot_cache_values[idx]

fn uirCoreFieldTypeKeyFromCurrentRootCachePut(mod: UirCoreModule, root: Node,
                                             parentType: str, fieldName: str, fieldTypeKey: str) =
    if mod == nil || !astNodeIdValid(root) ||
       uirCore_fieldTypeKeyFromCurrentRoot_cache_module != mod ||
       uirCore_fieldTypeKeyFromCurrentRoot_cache_root != root:
        return
    let key: str = symbolJoinFieldKey(parentType, fieldName)
    if len(key) == 0:
        return
    let stableKey: str = uirCoreCurrentRootCacheStableText(key)
    let stableFieldTypeKey: str = uirCoreCurrentRootCacheStableText(fieldTypeKey)
    var foundRaw: bool
    let raw: int32 = uirCoreHashMapStrIntGetCompatLocal(
        uirCore_fieldTypeKeyFromCurrentRoot_cache_index, stableKey, foundRaw)
    if foundRaw && raw > 0:
        let idx: int32 = raw - 1
        if idx >= 0 && idx < uirCore_fieldTypeKeyFromCurrentRoot_cache_values.len:
            uirCore_fieldTypeKeyFromCurrentRoot_cache_values[idx] = stableFieldTypeKey
            return
    let newIdx: int32 = uirCore_fieldTypeKeyFromCurrentRoot_cache_values.len
    uir_core_builder_current_root_cache_add(uirCore_fieldTypeKeyFromCurrentRoot_cache_values, stableFieldTypeKey)
    hashmaps.HashMapStrIntPut(uirCore_fieldTypeKeyFromCurrentRoot_cache_index, stableKey, newIdx + 1)

fn uirCoreTypeObjResolveCachesReset(mod: UirCoreModule = nil) =
    uirCoreTypeNodeObjNameCacheReset(mod)
    uirCoreTypeKeyObjNameCacheReset(mod)
    uirCoreFieldTypeKeyFromCurrentRootCacheReset(mod, astInvalidNodeId())

fn uirCoreTypeNodeCacheFallback(typeNode: Node): Node =
    if astNodeIdValid(typeNode) && nodeTypeCacheValid(typeNode) && astRefNonNil(nodeTypeCache(typeNode)):
        let cached: Node = nodeTypeCache(typeNode)
        if astNodeIdValid(cached) && !astNodeIsEmpty(cached) && cached != typeNode:
            return cached
    return astInvalidNodeId()

fn uirCoreTypeNodeObjNameCacheEnsure(nodeId: Node) =
    if !astNodeIdValid(nodeId):
        return
    let needLen: int32 = int32(nodeId) + 1
    if needLen <= 0:
        return
    reserve(uirCore_typeNodeObjName_values, needLen)
    reserve(uirCore_typeNodeObjName_ready, needLen)
    if uirCore_typeNodeObjName_values.len < needLen:
        setLen(uirCore_typeNodeObjName_values, needLen)
    if uirCore_typeNodeObjName_ready.len < needLen:
        setLen(uirCore_typeNodeObjName_ready, needLen)

fn uirCoreTypeNodeObjNameCacheValuesLen(): int32 =
    return uirCore_typeNodeObjName_values.len

fn uirCoreTypeNodeObjNameCacheReadyLen(): int32 =
    return uirCore_typeNodeObjName_ready.len

fn uirCoreTypeNodeObjNameCacheValueAt(idx: int32): str =
    if idx < 0 || idx >= uirCore_typeNodeObjName_values.len:
        return ""
    return uirCore_typeNodeObjName_values[idx]

fn uirCoreTypeNodeObjNameCacheReadyAt(idx: int32): int8 =
    if idx < 0 || idx >= uirCore_typeNodeObjName_ready.len:
        return int8(0)
    return uirCore_typeNodeObjName_ready[idx]

fn uirCoreTypeNodeObjNameCacheSetValueAt(idx: int32, value: str) =
    if idx < 0 || idx >= uirCore_typeNodeObjName_values.len:
        return
    uirCore_typeNodeObjName_values[idx] = value

fn uirCoreTypeNodeObjNameCacheSetReadyAt(idx: int32, ready: int8) =
    if idx < 0 || idx >= uirCore_typeNodeObjName_ready.len:
        return
    uirCore_typeNodeObjName_ready[idx] = ready

fn uirCoreCurrentParsedRootValid(): bool =
    return astNodeIdValid(uirCore_currentParsedRoot) &&
           astNodeIsModuleOrStmtList(uirCore_currentParsedRoot)

fn uirCoreFindTypeDeclByName(root: Node, targetName0: str): Node =
    let targetName: str = backendStripSpaces(targetName0)
    if !astNodeIdValid(root) || len(targetName) == 0 || len(targetName) > 256:
        return astInvalidNodeId()
    if uirCore_typeDeclByName_cache_root != root:
        uirCoreFindTypeDeclByNameCacheReset(root)
    if !uirCore_typeDeclByName_cache_ready:
        uirCoreFindTypeDeclByNameIndexBuild(root)
    if !uirCore_typeDeclByName_cache_ready:
        return astInvalidNodeId()
    var cachedFound: bool
    let cached: Node = uirCoreFindTypeDeclByNameCacheGet(root, targetName, cachedFound)
    if cachedFound:
        return cached
    uirCoreFindTypeDeclByNameCachePut(root, targetName, astInvalidNodeId())
    return astInvalidNodeId()
