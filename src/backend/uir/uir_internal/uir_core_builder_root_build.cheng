# Thin facade for current-source root-build entrypoints.
import std/result
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_root_pipeline

fn uirCoreRootBuildModuleFromRootId(rootInputId: AstNodeId): Result[UirCoreModule] =
    return uirCoreRootPipelineBuildModuleFromRootId(rootInputId)

fn uirCoreRootBuildModuleFromRoot(rootInput: Node): Result[UirCoreModule] =
    return uirCoreRootPipelineBuildModuleFromRoot(rootInput)
