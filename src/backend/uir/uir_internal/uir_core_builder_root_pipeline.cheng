# Thin facade for current-source root pipeline entrypoints.
import std/result
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_root_impl

fn uirCoreRootPipelineBuildModuleFromRootId(rootInputId: AstNodeId): Result[UirCoreModule] =
    return uirCoreRootImplBuildModuleFromRootId(rootInputId)

fn uirCoreRootPipelineBuildModuleFromRoot(rootInput: Node): Result[UirCoreModule] =
    return uirCoreRootImplBuildModuleFromRoot(rootInput)
