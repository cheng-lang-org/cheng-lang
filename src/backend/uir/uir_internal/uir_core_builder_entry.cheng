# Thin current-source facade for executable seeds.
#
# Keep the public build surface stable while moving the heavy implementation
# body into a separate imported module so stage0 does not need to parse and
# semantically lower the full builder monolith at the active root.
import std/result
import std/system
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_runtime

fn uirCoreBuildModuleFromFile(path: str): Result[UirCoreModule] =
    return uirCoreRuntimeBuildModuleFromFileStage1(path, "")

fn uirCoreBuildModuleFromRootId(rootInputId: AstNodeId): Result[UirCoreModule] =
    return uirCoreRuntimeBuildModuleFromRootId(rootInputId)

fn uirCoreBuildModuleFromRoot(rootInput: Node): Result[UirCoreModule] =
    return uirCoreRuntimeBuildModuleFromRoot(rootInput)

fn uirCoreBuildModuleFromFileStage1(inPath: str, target: str): Result[UirCoreModule] =
    return uirCoreRuntimeBuildModuleFromFileStage1(inPath, target)

fn uirCoreBuildModuleFromFileStage1Default(inPath: str): Result[UirCoreModule] =
    return uirCoreRuntimeBuildModuleFromFileStage1Default(inPath)

fn uirCoreBuildModuleFromFileStage1OrPanic(inPath: str, target: str): UirCoreModule =
    return uirCoreRuntimeBuildModuleFromFileStage1OrPanic(inPath, target)

fn uirCoreBuildModuleFromFileStage1OrPanicDefault(inPath: str): UirCoreModule =
    return uirCoreRuntimeBuildModuleFromFileStage1OrPanicDefault(inPath)

fn uirCoreBuildModuleFromFileStage1RawOrPanic(inRaw: cstring, targetRaw: cstring): UirCoreModule =
    return uirCoreRuntimeBuildModuleFromFileStage1RawOrPanic(inRaw, targetRaw)

fn uirCoreBuildModuleFromFileStage1TargetFirst(target: str, inPath: str): Result[UirCoreModule] =
    return uirCoreRuntimeBuildModuleFromFileStage1TargetFirst(target, inPath)

fn uirCoreBuildModuleFromFileStage1TargetFirstOrPanic(target: str, inPath: str): UirCoreModule =
    return uirCoreRuntimeBuildModuleFromFileStage1TargetFirstOrPanic(target, inPath)

fn uirCoreBuildModuleFromFileStage1HostOnlyOrPanic(inPath: str): UirCoreModule =
    return uirCoreRuntimeBuildModuleFromFileStage1HostOnlyOrPanic(inPath)
