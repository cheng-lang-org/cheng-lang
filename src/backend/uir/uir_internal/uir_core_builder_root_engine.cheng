# Thin facade for current-source root engine entrypoints.
#
# Keep builder-bearing roots off the active import surface by routing the
# heavy root-build implementation through root_exec_impl.
import std/result
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_root_exec_impl

fn uirCoreRootEngineBuildModuleFromRootId(rootInputId: AstNodeId): Result[UirCoreModule] =
    return uirCoreRootExecImplBuildModuleFromRootId(rootInputId)

fn uirCoreRootEngineBuildModuleFromRoot(rootInput: Node): Result[UirCoreModule] =
    return uirCoreRootExecImplBuildModuleFromRoot(rootInput)
