fn uirCoreForceMangleDupFnBase(baseName0: str, originFile0: str): str =
    let baseName: str = (len(baseName0) > 0) ? baseName0 : ""
    if len(baseName) == 0:
        return ""
    if (baseName == "main"):
        return baseName
    let originFile: str = (len(originFile0) > 0) ? originFile0 : ""
    return symbolJoin3(baseName, "__cheng_mod_", uirCoreModuleIdForFile(originFile))

fn uirCoreMaybeMangleDupFnBase(baseName0: str, originFile0: str): str =
    let baseName: str = (len(baseName0) > 0) ? baseName0 : ""
