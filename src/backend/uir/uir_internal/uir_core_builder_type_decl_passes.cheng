# Shared builder-local type-decl consumption and global predeclare passes split from uir_core_builder.
import std/os
import std/result
import std/seqs
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_base_helpers
import backend/uir/uir_internal/uir_core_builder_type_surface_helpers
import backend/uir/uir_internal/uir_core_builder_type_query_helpers
import backend/uir/uir_internal/uir_core_builder_current_root_cache
import backend/uir/uir_internal/uir_core_builder_current_root_type_decl_helpers
import backend/uir/uir_internal/uir_core_builder_module_lookup_cache
import backend/uir/uir_internal/uir_core_builder_symbol_state
import backend/uir/uir_internal/uir_core_builder_object_synthesis

fn uir_core_builder_type_decl_passes_add(dst: var Node[], val: Node) =
    seqs.Add(dst, val)

fn isBuiltinTypeName(name: str): bool =
    if len(name) == 0:
        return false
    if name == "void" || name == "bool" || name == "char":
        return true
    if name == "int8" || name == "uint8" || name == "i8" || name == "u8":
        return true
    if name == "int16" || name == "uint16" || name == "i16" || name == "u16":
        return true
    if name == "int32" || name == "uint32" || name == "i32" || name == "u32":
        return true
    if name == "int64" || name == "uint64" || name == "i64" || name == "u64":
        return true
    if name == "int" || name == "uint" || name == "NI" || name == "NU":
        return true
    if name == "float32" || name == "float64" || name == "float":
        return true
    if isStringOrPtrKey(name):
        return true
    if name == "tuple" || uirCoreStrStartsWith(name, "tuple_"):
        return true
    if name == "seq" || uirCoreStrStartsWith(name, "seq_"):
        return true
    if name == "seq_fixed" || uirCoreStrStartsWith(name, "seq_fixed_"):
        return true
    if name == "Table" || uirCoreStrStartsWith(name, "Table_"):
        return true
    if uirCoreStrStartsWith(name, "set_"):
        return true
    return false

fn uirCoreDebugFacadeTypeName(name: str): bool =
    if len(name) == 0:
        return false
    return name == "UirGlobal" || name == "UirCString" || name == "UirTypeAlias" ||
           name == "UirObjType" || name == "UirLowerType" || name == "UirTerm" ||
           name == "UirParam" || name == "UirObjLocal" || name == "UirObjField" ||
           name == "UirTermKind" || name == "UirStmtKind" || name == "UirExprKind" ||
           name == "UirCmpOp" || name == "UirBinOp" || name == "UirLowerTypeKind" ||
           name == "UirCoreGlobal" || name == "UirCoreCString" || name == "UirCoreTypeAlias" ||
           name == "UirCoreObjType" || name == "UirCoreType" || name == "UirCoreTerm" ||
           name == "UirCoreParam" || name == "UirCoreObjLocal" || name == "UirCoreObjField" ||
           name == "UirCoreTypeKind" || name == "UirCoreTermKind" ||
           name == "UirCoreStmtKind" || name == "UirCoreExprKind" ||
           name == "UirCoreCmpOp" || name == "UirCoreBinOp"

fn uirCoreDebugNodeKindText(n: Node): str =
    if n == nil:
        return "nil"
    return intToStr(int32(nodeKind(n)))

fn uirCoreTypeDeclBool01(v: bool): str =
    return v ? "1" : "0"

fn uirCoreTypeDeclBracketDebugSuffix(defNode: Node): str =
    if !astNodeIdValid(defNode) || !astNodeIsBracketExpr(defNode):
        return ""
    if kidCount(defNode) <= 0:
        return " kids=" + intToStr(kidCount(defNode))
    return " kids=" + intToStr(kidCount(defNode)) +
           " base=" + backendStripSpaces(plainName(kid(defNode, 0)))

fn uirCoreTypeDeclSeqStringDebugLine(mod: UirCoreModule, defNode: Node): str =
    return "[backend] debug: typeDecl seq_string defKind=" + intToStr(int32(nodeKind(defNode))) +
           uirCoreTypeDeclBracketDebugSuffix(defNode) +
           " hasSeq=" + uirCoreTypeDeclBool01(uirCoreHasObjType(mod, "seq"))

fn uirCoreTypeDeclTableStringDebugLine(mod: UirCoreModule, defNode: Node): str =
    return "[backend] debug: typeDecl Table_string defKind=" + intToStr(int32(nodeKind(defNode))) +
           uirCoreTypeDeclBracketDebugSuffix(defNode) +
           " hasTable=" + uirCoreTypeDeclBool01(uirCoreHasObjType(mod, "Table"))

fn uirCoreFieldTypeExplicitSeqFixedKey(fieldTypeNode: Node): str =
    let sfiField: SeqFixedInit = seqFixedInitInfo(fieldTypeNode)
    if seqFixedInitElemType(sfiField) == nil || seqFixedInitCapExpr(sfiField) == nil:
        return ""
    return backendStripSpaces(typeKey(fieldTypeNode))

fn uirCoreFieldTypeKeyForConsumeTypeDecl(mod: UirCoreModule, fieldTypeNode: Node,
                                         looseFieldTypeKey: str, objFieldType: str): str =
    let explicitKey: str = uirCoreFieldTypeExplicitSeqFixedKey(fieldTypeNode)
    if len(explicitKey) > 0:
        return explicitKey
    let resolvedKey: str = backendStripSpaces(
        uirCoreFieldTypeNodeResolvedKey(mod, fieldTypeNode, looseFieldTypeKey, objFieldType))
    if len(resolvedKey) > 0:
        return resolvedKey
    return backendStripSpaces(plainName(fieldTypeNode))

fn uirCoreFieldObjTypeFromFieldKey(mod: UirCoreModule, fieldTypeKey: str, isObjFieldValue: bool): str =
    if !isObjFieldValue || len(fieldTypeKey) == 0:
        return ""
    if uirCoreHasObjType(mod, fieldTypeKey):
        return fieldTypeKey
    let uniqObjFromFieldKey: str = uirCoreFindObjTypeByBaseUnique(mod, fieldTypeKey)
    if len(uniqObjFromFieldKey) > 0:
        return uniqObjFromFieldKey
    return uirCoreObjTypeFromTypeKey(mod, fieldTypeKey)

fn uirCoreFieldObjTypeFromCachedNode(mod: UirCoreModule, fieldTypeNode: Node): str =
    if !astNodeIdValid(fieldTypeNode) || !nodeTypeCacheValid(fieldTypeNode) || !astRefNonNil(nodeTypeCache(fieldTypeNode)):
        return ""
    return typeNodeObjTypeNameCore(mod, nodeTypeCache(fieldTypeNode))

fn uirCoreFieldCachedKey(fieldTypeNode: Node): str =
    if !astNodeIdValid(fieldTypeNode) || !nodeTypeCacheValid(fieldTypeNode) || !astRefNonNil(nodeTypeCache(fieldTypeNode)):
        return ""
    let cachedFieldTypeNode: Node = nodeTypeCache(fieldTypeNode)
    let directKey: str = backendStripSpaces(typeKey(cachedFieldTypeNode))
    if len(directKey) > 0:
        return directKey
    return backendStripSpaces(uirCoreTypeKeyFromNodeLoose(cachedFieldTypeNode))

fn uirCoreFieldObjTypeFromCachedKey(mod: UirCoreModule, fieldTypeNode: Node): str =
    let cachedFieldKey: str = uirCoreFieldCachedKey(fieldTypeNode)
    if len(cachedFieldKey) == 0:
        return ""
    return uirCoreObjTypeFromTypeKey(mod, cachedFieldKey)

fn uirCoreFieldObjTypeFromCurrentDecl(mod: UirCoreModule, fieldTypeNode: Node,
                                      fieldTypeKey: str, isObjFieldValue: bool): str =
    if typeNodeIsObjValue(mod, fieldTypeNode):
        return ""
    if len(uirCoreFieldObjTypeFromFieldKey(mod, fieldTypeKey, isObjFieldValue)) > 0:
        return ""
    if len(uirCoreFieldObjTypeFromCachedNode(mod, fieldTypeNode)) > 0:
        return ""
    if len(uirCoreFieldObjTypeFromCachedKey(mod, fieldTypeNode)) > 0:
        return ""
    return uirCoreObjTypeFromCurrentRootDecl(mod, fieldTypeKey)

fn uirCoreFieldObjTypeForConsumeTypeDecl(mod: UirCoreModule, fieldTypeNode: Node,
                                         fieldTypeKey: str, isObjFieldValue: bool): str =
    let directObjFieldType: str = typeNodeObjTypeName(mod, fieldTypeNode)
    if len(directObjFieldType) > 0:
        return directObjFieldType
    let objFromFieldKey: str = uirCoreFieldObjTypeFromFieldKey(mod, fieldTypeKey, isObjFieldValue)
    if len(objFromFieldKey) > 0:
        return objFromFieldKey
    let objFromCachedNode: str = uirCoreFieldObjTypeFromCachedNode(mod, fieldTypeNode)
    if len(objFromCachedNode) > 0:
        return objFromCachedNode
    let objFromCachedKey: str = uirCoreFieldObjTypeFromCachedKey(mod, fieldTypeNode)
    if len(objFromCachedKey) > 0:
        return objFromCachedKey
    return uirCoreFieldObjTypeFromCurrentDecl(mod, fieldTypeNode, fieldTypeKey, isObjFieldValue)

fn uirCoreFieldUsesCurrentDeclObjValue(mod: UirCoreModule, fieldTypeNode: Node,
                                       fieldTypeKey: str, isObjFieldValue: bool): bool =
    if isObjFieldValue:
        return true
    return len(uirCoreFieldObjTypeFromCurrentDecl(mod, fieldTypeNode, fieldTypeKey, isObjFieldValue)) > 0

fn uirCoreTypeFieldDebugHasObj(mod: UirCoreModule, fieldTypeKey: str): bool =
    if len(fieldTypeKey) == 0:
        return false
    return uirCoreHasObjType(mod, fieldTypeKey)

fn uirCoreTypeFieldDebugObjFromKey(mod: UirCoreModule, fieldTypeKey: str): str =
    if len(fieldTypeKey) == 0:
        return ""
    return uirCoreObjTypeFromTypeKey(mod, fieldTypeKey)

fn uirCoreTypeFieldDebugDeclObjLike(fieldTypeKey: str): bool =
    if len(fieldTypeKey) == 0 || !uirCoreCurrentParsedRootValid():
        return false
    let tdDbg0: Node = uirCoreFindTypeDeclByName(uirCoreCurrentParsedRootGet(), fieldTypeKey)
    if !astNodeIdValid(tdDbg0):
        return false
    return uirCoreTypeDeclIsObjectLike(tdDbg0)

fn uirCoreTypeFieldDebugMatchCount(mod: UirCoreModule, fieldTypeKey: str): int32 =
    if len(fieldTypeKey) == 0:
        return 0
    var out: int32
    for oiDbg0 in 0..<uirCoreModuleObjTypesLen(mod):
        let otDbg0: UirCoreObjType = uirCoreModuleObjTypeAt(mod, oiDbg0)
        let otName0: str = uirCoreNameOf(otDbg0)
        if len(otName0) == 0 || !uirCoreObjTypeNameMatchesBaseAny(otName0, fieldTypeKey):
            continue
        out = out + 1
    return out

fn uirCoreTypeFieldDebugFirstMatchName(mod: UirCoreModule, fieldTypeKey: str): str =
    if len(fieldTypeKey) == 0:
        return ""
    for oiDbg0 in 0..<uirCoreModuleObjTypesLen(mod):
        let otDbg0: UirCoreObjType = uirCoreModuleObjTypeAt(mod, oiDbg0)
        let otName0: str = uirCoreNameOf(otDbg0)
        if len(otName0) == 0 || !uirCoreObjTypeNameMatchesBaseAny(otName0, fieldTypeKey):
            continue
        return otName0
    return ""

fn uirCoreTypeFieldDebugCachedType(fieldTypeNode: Node): str =
    if !astNodeIdValid(fieldTypeNode) || !nodeTypeCacheValid(fieldTypeNode) || !astRefNonNil(nodeTypeCache(fieldTypeNode)):
        return ""
    return backendStripSpaces(plainName(nodeTypeCache(fieldTypeNode)))

fn uirCoreTypeDeclDepKey(fieldTypeNode: Node): str =
    if astNodeIsDotExpr(fieldTypeNode) && kidCount(fieldTypeNode) > 1:
        return backendStripSpaces(typeKey(kid(fieldTypeNode, 1)))
    return backendStripSpaces(typeKey(fieldTypeNode))

fn uirCoreTypeDeclDepName(fieldTypeNode: Node): str =
    let depKey: str = uirCoreTypeDeclDepKey(fieldTypeNode)
    if len(depKey) > 0:
        return depKey
    return backendStripSpaces(plainName(fieldTypeNode))

fn uirCoreTypeDeclPendingName(td: Node): str =
    if !astNodeIdValid(td) || kidCount(td) <= 0:
        return ""
    let nn: Node = kid(td, 0)
    if (nn == nil) || !astNodeIsIdentOrSymbol(nn):
        return ""
    return backendStripSpaces(plainName(nn))

fn uirCoreTypeDeclPendingNamesMsg(pendingNames: str[]): str =
    var out: str = "uirCore_builder: unresolved type dependencies:"
    for i in 0..<pendingNames.len:
        let nm: str = pendingNames[i]
        if len(nm) > 0:
            out = out + " " + nm
    return out

fn uirCorePredeclaredFilePath(): str =
    return "<predeclared>"

fn uirCoreNodeFilePathOrPredeclared(n: Node): str =
    let filePath: str = nodeStrVal(n)
    if len(filePath) > 0:
        return filePath
    return uirCorePredeclaredFilePath()

fn uirCorePredeclareLoweringObjTypeNode(typeNode: Node, init: Node): Node =
    if astNodeIdValid(typeNode) && !astNodeIsEmpty(typeNode):
        return typeNode
    if astNodeIdValid(init) && !astNodeIsEmpty(init) &&
       nodeTypeCacheValid(init) && astRefNonNil(nodeTypeCache(init)):
        return nodeTypeCache(init)
    return typeNode

fn uirCorePredeclareLoweringObjTypeName(mod: UirCoreModule, typeNode: Node, init: Node): str =
    let objTypeNode: Node = uirCorePredeclareLoweringObjTypeNode(typeNode, init)
    if !astNodeIdValid(objTypeNode) || astNodeIsEmpty(objTypeNode):
        return ""
    return typeNodeObjTypeName(mod, objTypeNode)

fn uirCorePredeclareLoweringTypeKey(typeNode: Node, init: Node): str =
    let objTypeNode: Node = uirCorePredeclareLoweringObjTypeNode(typeNode, init)
    if astNodeIdValid(objTypeNode) && !astNodeIsEmpty(objTypeNode):
        let objKey: str = backendStripSpaces(typeKey(objTypeNode))
        if len(objKey) > 0:
            return objKey
        let looseObjKey: str = backendStripSpaces(uirCoreTypeKeyFromNodeLoose(objTypeNode))
        if len(looseObjKey) > 0:
            return looseObjKey
    if astNodeIdValid(typeNode) && !astNodeIsEmpty(typeNode):
        let typeKey0: str = backendStripSpaces(typeKey(typeNode))
        if len(typeKey0) > 0:
            return typeKey0
        return backendStripSpaces(uirCoreTypeKeyFromNodeLoose(typeNode))
    return ""

fn uirCoreConsumeTypeDecl(mod: UirCoreModule, td: Node): Result[bool] =
    if !astNodeIdValid(td) || !astNodeIsTypeDecl(td) || kidCount(td) < 2:
        return Err[bool]("uirCore_builder: invalid type decl")
    let nameNode: Node = kid(td, 0)
    let defNode: Node = kid(td, 1)
    var defCore: Node = defNode
    var isRefLike: bool
    if (defCore != nil) && (astNodeIsRefTy(defCore) || astNodeIsPtrTy(defCore)) && kidCount(defCore) > 0:
        isRefLike = true
        defCore = kid(defCore, 0)
    if (nameNode == nil) || !astNodeIsIdentOrSymbol(nameNode):
        return Err[bool]("uirCore_builder: type name expects identifier")
    let name: str = backendStripSpaces(plainName(nameNode))
    var isObjectLikeDef: bool
    if astNodeIdValid(defCore):
        let defKind: NodeKind = nodeKind(defCore)
        if defKind == astNodeKindObjectDecl() || defKind == astNodeKindRecList():
            isObjectLikeDef = true
    let dbgTypeNameFilter: str = os.GetEnvDefault("BACKEND_DEBUG_TYPE_NAME", "")
    let dbgTypeNameHit: bool = len(dbgTypeNameFilter) > 0 && name == dbgTypeNameFilter
    if dbgTypeNameHit:
        os.WriteLine(os.Get_stderr(),
                     "[backend] debugTypeDecl: name=" + name +
                     " defKind=nk#" + uirCoreDebugNodeKindText(defNode) +
                     " defCoreKind=nk#" + uirCoreDebugNodeKindText(defCore) +
                     " isRefLike=" + uirCoreTypeDeclBool01(isRefLike) +
                     " isObjectLikeDef=" + uirCoreTypeDeclBool01(isObjectLikeDef))
        os.C_fflush(os.Get_stderr())
    let debugFacadeTypes: bool = (getEnv "BACKEND_DEBUG_UIR_FACADE" == "1") && uirCoreDebugFacadeTypeName(name)
    if debugFacadeTypes:
        echo("[backend] debugFacade: typeDecl name=" + name +
             " defKind=nk#" + uirCoreDebugNodeKindText(defNode) +
             " defCoreKind=nk#" + uirCoreDebugNodeKindText(defCore) +
             " isRefLike=" + uirCoreTypeDeclBool01(isRefLike) +
             " isObjectLikeDef=" + uirCoreTypeDeclBool01(isObjectLikeDef))
    let traceTypes: bool = (getEnv "BACKEND_TRACE_TYPES" == "1")
    if traceTypes && (name == "__cheng_lambda_2_iter"):
        echo("[backend] trace: typeDecl " + name)
    if (getEnv "BACKEND_DEBUG_TYPES" == "1") && (name == "Node"):
        echo("[backend] debug: typeDecl Node defKind=nk#" + uirCoreDebugNodeKindText(defNode) +
             " defCoreKind=nk#" + uirCoreDebugNodeKindText(defCore) +
             " isRefLike=" + uirCoreTypeDeclBool01(isRefLike))
    if (getEnv "BACKEND_DEBUG_TYPES" == "1") && (name == "seq_string"):
        echo(uirCoreTypeDeclSeqStringDebugLine(mod, defNode))
    if (getEnv "BACKEND_DEBUG_TYPES" == "1") && (name == "Table_string"):
        echo(uirCoreTypeDeclTableStringDebugLine(mod, defNode))
    if moduleHasFunc(mod, name) || moduleHasGlobal(mod, name):
        return Err[bool]("uirCore_builder: type name conflicts with global")
    let existingObj: int32 = uirCoreFindObjType(mod, name)
    if existingObj >= 0:
        if !isObjectLikeDef:
            return Ok[bool](false)
    let existingAlias: int32 = uirCoreFindTypeAlias(mod, name)
    if existingAlias >= 0:
        if !isObjectLikeDef:
            return Ok[bool](false)
    if kidCount(td) > 2:
        let generics: Node = kid(td, 2)
        if astNodeIdValid(generics) && !astNodeIsEmpty(generics) && kidCount(generics) > 0:
            if dbgTypeNameHit:
                os.WriteLine(os.Get_stderr(),
                             "[backend] debugTypeDecl: skip generic source decl")
                os.C_fflush(os.Get_stderr())
            return Ok[bool](false)
    if isRefLike:
        uirCoreAddTypeAlias(mod, name, uirCoreTypeI64())
        uirCoreTypeObjResolveCachesReset(mod)
    if isObjectLikeDef:
        if uirCoreStrStartsWith(name, "seq_fixed_") && uirCoreHasObjType(mod, "seq"):
            let rhs: UirCoreObjType = uirCoreObjTypeRenamed(uirCoreGetObjType(mod, "seq"), name)
            uirCoreAddObjType(mod, rhs)
            return Ok[bool](false)
    if isObjectLikeDef:
        var recList: Node = astInvalidNodeId()
        if astNodeIsObjectDecl(defCore):
            if kidCount(defCore) < 2:
                return Err[bool]("uirCore_builder: invalid object type")
            recList = kid(defCore, 1)
        else:
            recList = defCore
        if !astNodeIdValid(recList) || !astNodeIsRecList(recList):
            return Err[bool]("uirCore_builder: invalid record list")
        if traceTypes && (name == "__cheng_lambda_2_iter"):
            echo("[backend] trace: recList count=" + intToStr(kidCount(recList)))
        var fields: UirCoreObjField[]
        var offset: int32
        var maxAlignPow2: int32
        for i in 0..<kidCount(recList):
            let item: Node = kid(recList, i)
            if (item == nil):
                continue
            if astNodeIsRecCase(item):
                return Err[bool]("uirCore_builder: record case not supported in backend")
            if !astNodeIsIdentDefs(item) || kidCount(item) < 2:
                return Err[bool]("uirCore_builder: record field expects ident defs")
            let fieldNameNode: Node = kid(item, 0)
            let fieldTypeNode: Node = kid(item, 1)
            var fieldDefaultNode: Node = astInvalidNodeId()
            if kidCount(item) > 2:
                fieldDefaultNode = kid(item, 2)
            if (fieldNameNode == nil) || !astNodeIsIdentOrSymbol(fieldNameNode):
                return Err[bool]("uirCore_builder: record field name expects identifier")
            if !astNodeIdValid(fieldTypeNode) || astNodeIsEmpty(fieldTypeNode):
                return Err[bool]("uirCore_builder: record field requires type")
            if astNodeIdValid(fieldDefaultNode) && !astNodeIsEmpty(fieldDefaultNode):
                return Err[bool]("uirCore_builder: record field default not supported in backend")
            let rawFieldName: str = plainName(fieldNameNode)
            let fieldName: str = backendStripSpaces(rawFieldName)
            if (getEnv "BACKEND_DEBUG_OVERLOAD_DOT" == "1") && name == "ProtoBuffer" && fieldName == "out":
                let fNodeName0: str = backendStripSpaces(plainName(fieldTypeNode))
                let fNodeKey0: str = typeKey(fieldTypeNode)
                echo("[backend] debugOverloadDot: consumeTypeDecl type='ProtoBuffer' field='out' nodeKind=nk#" +
                     intToStr(int32(nodeKind(fieldTypeNode))) + " plain='" + fNodeName0 + "' typeKey='" + fNodeKey0 + "'")
            if traceTypes && (name == "__cheng_lambda_2_iter"):
                var firstCode: int32 = -1
                if len(rawFieldName) > 0:
                    firstCode = int32(rawFieldName[0])
                echo("[backend] trace: field '" + fieldName + "' rawLen=" + intToStr(len(rawFieldName)) +
                    " firstChar=" + intToStr(firstCode))
            let looseFieldTypeKey: str = uirCoreTypeKeyFromNodeLoose(fieldTypeNode)
            let baseIsObjFieldValue: bool = typeNodeIsObjValue(mod, fieldTypeNode)
            let directObjFieldType: str = typeNodeObjTypeName(mod, fieldTypeNode)
            let fieldTypeKey: str = uirCoreFieldTypeKeyForConsumeTypeDecl(mod, fieldTypeNode, looseFieldTypeKey, directObjFieldType)
            let objFieldType: str = uirCoreFieldObjTypeForConsumeTypeDecl(mod, fieldTypeNode, fieldTypeKey, baseIsObjFieldValue)
            let isObjFieldValue: bool = uirCoreFieldUsesCurrentDeclObjValue(mod, fieldTypeNode, fieldTypeKey, baseIsObjFieldValue)
            if (getEnv "BACKEND_DEBUG_OVERLOAD_DOT" == "1") && name == "ProtoBuffer" && fieldName == "out":
                echo("[backend] debugOverloadDot: computed fieldTypeKey type='ProtoBuffer' field='out' key='" + fieldTypeKey +
                     "' len=" + intToStr(len(fieldTypeKey)))
            if len(fieldTypeKey) > 0:
                if (getEnv "BACKEND_DEBUG_OVERLOAD_DOT" == "1") && name == "ProtoBuffer" && fieldName == "out":
                    echo("[backend] debugOverloadDot: put fieldTypeKey type='ProtoBuffer' field='out' key='" + fieldTypeKey + "'")
                uirCoreObjFieldTypeKeyPut(name, fieldName, fieldTypeKey)
            let dbgTypeFieldFilter: str = getEnv "BACKEND_DEBUG_TYPE_FIELD"
            if len(dbgTypeFieldFilter) > 0 && dbgTypeFieldFilter == (name + "::" + fieldName):
                let entryDbg0: str = uirCoreObjFieldTypeKeyDebugEntry(name, fieldName)
                echo("[backend] debugTypeField: key='" + dbgTypeFieldFilter +
                     "' nodeKind=nk#" + intToStr(int32(nodeKind(fieldTypeNode))) +
                     "' rawTypeKey='" + backendStripSpaces(typeKey(fieldTypeNode)) +
                     "' looseKey='" + looseFieldTypeKey +
                     "' fallbackKey='" + uirCoreTypeKeyFallbackText(fieldTypeNode) +
                     "' plain='" + backendStripSpaces(plainName(fieldTypeNode)) +
                     "' fieldTypeKey='" + fieldTypeKey +
                     "' objFieldType='" + objFieldType +
                     "' hasObjTypeKey=" + uirCoreTypeDeclBool01(uirCoreTypeFieldDebugHasObj(mod, fieldTypeKey)) +
                     "' objFromFieldKey='" + uirCoreTypeFieldDebugObjFromKey(mod, fieldTypeKey) +
                     "' typeDeclObjLike=" + uirCoreTypeDeclBool01(uirCoreTypeFieldDebugDeclObjLike(fieldTypeKey)) +
                     "' matchCount=" + intToStr(uirCoreTypeFieldDebugMatchCount(mod, fieldTypeKey)) +
                     "' matchName='" + uirCoreTypeFieldDebugFirstMatchName(mod, fieldTypeKey) +
                     "' cachedType='" + uirCoreTypeFieldDebugCachedType(fieldTypeNode) +
                      "' entry='" + entryDbg0 +
                     "' isObjValue=" + uirCoreTypeDeclBool01(isObjFieldValue) + "'")
            if (getEnv "BACKEND_DEBUG_TYPES" == "1") && (name == "EcKeyPair"):
                echo("[backend] debugTypes: type=" + name + " field=" + fieldName +
                     " fieldTypeKey='" + fieldTypeKey + "' objFieldType='" + objFieldType +
                     "' isObjValue=" + uirCoreTypeDeclBool01(isObjFieldValue))
            if len(objFieldType) > 0 && isObjFieldValue && uirCoreHasObjType(mod, objFieldType):
                uirCoreInlineObjFieldTypePut(name, fieldName, objFieldType)
                let inner: UirCoreObjType = uirCoreGetObjType(mod, objFieldType)
                if uirCoreSizeOf(inner) <= 0 || uirCoreFieldsLen(inner) == 0:
                    if (getEnv "BACKEND_DEBUG_TYPES" == "1"):
                        echo("[backend] debug: pending type " + name + " inline object unresolved: " + objFieldType)
                    return Ok[bool](true)
                let alignPow2: int32 = uirCoreAlignPow2Of(inner)
                if alignPow2 > maxAlignPow2:
                    maxAlignPow2 = alignPow2
                offset = alignUpPow2(offset, alignPow2)
                for fi in 0..<uirCoreFieldsLen(inner):
                    let innerF: UirCoreObjField = uirCoreFieldAt(inner, fi)
                    uirCoreAppendObjFieldNamed(fields, fieldName + "." + uirCoreNameOf(innerF), uirCoreTypeOf(innerF), offset + uirCoreOffsetOf(innerF))
                offset = offset + uirCoreSizeOf(inner)
                continue
            if (fieldTypeNode != nil) && (astNodeIsIdentOrSymbol(fieldTypeNode) || astNodeIsBracketExpr(fieldTypeNode) ||
               astNodeIsDotExpr(fieldTypeNode)):
                let depName: str = uirCoreTypeDeclDepName(fieldTypeNode)
                if len(depName) > 0 && !isBuiltinTypeName(depName):
                    let depAlias: UirCoreType = uirCoreTryGetTypeAlias(mod, depName)
                    if !uirCoreHasObjType(mod, depName) && uirCoreTypeKindOf(depAlias) == uirCoreTypeKindVoid():
                        if !(uirCoreStrStartsWith(depName, "SeqUninit_") && ensureSeqUninitObjType(mod, depName)):
                            if (getEnv "BACKEND_DEBUG_TYPES" == "1"):
                                echo("[backend] debug: pending type " + name + " depends on " + depName)
                            return Ok[bool](true)
            let fieldTy: UirCoreType = uirCoreTypeFromNodeWithModule(mod, fieldTypeNode)
            let fieldSize: int32 = uirCoreTypeSize(fieldTy)
            if fieldSize <= 0:
                return Err[bool]("uirCore_builder: unsupported record field type")
            let alignPow2: int32 = uirCoreTypeAlignPow2(fieldTy)
            if alignPow2 > maxAlignPow2:
                maxAlignPow2 = alignPow2
            offset = alignUpPow2(offset, alignPow2)
            uirCoreAppendObjFieldNamed(fields, fieldName, fieldTy, offset)
            offset = offset + fieldSize
        let objSize: int32 = alignUpPow2(offset, maxAlignPow2)
        if debugFacadeTypes:
            echo("[backend] debugFacade: addObjType name=" + name +
                 " size=" + intToStr(objSize) +
                 " fields=" + intToStr(fields.len))
        if existingObj >= 0:
            uirCoreReplaceObjTypeParts(mod, existingObj, name, maxAlignPow2, objSize, fields)
        else:
            uirCoreAddObjTypeParts(mod, name, maxAlignPow2, objSize, fields)
        if isRefLike:
            uirCoreAddTypeAlias(mod, name, uirCoreTypeI64())
        uirCoreTypeObjResolveCachesReset(mod)
        if dbgTypeNameHit:
            os.WriteLine(os.Get_stderr(),
                         "[backend] debugTypeDecl: added object layout size=" + intToStr(objSize) +
                         " fields=" + intToStr(fields.len) +
                         " aliasKind=" + intToStr(int32(uirCoreTypeKindOf(uirCoreTryGetTypeAlias(mod, name)))))
            os.C_fflush(os.Get_stderr())
        return Ok[bool](false)
    if astNodeIdValid(defNode) && astNodeIsEnumDecl(defNode):
        if debugFacadeTypes:
            echo("[backend] debugFacade: addEnumAlias name=" + name)
        uirCoreAddTypeAlias(mod, name, uirCoreTypeI32())
        uirCoreTypeObjResolveCachesReset(mod)
        var nextVal: int64
        for fi in 0..<kidCount(defNode):
            let field: Node = kid(defNode, fi)
            if !astNodeIdValid(field) || astNodeIsEmpty(field):
                continue
            if !astNodeIsEnumFieldDecl(field) || kidCount(field) == 0:
                return Err[bool]("uirCore_builder: invalid enum field")
            let fieldNameNode: Node = kid(field, 0)
            if (fieldNameNode == nil) || !astNodeIsIdentOrSymbol(fieldNameNode):
                return Err[bool]("uirCore_builder: enum field expects identifier")
            var valNode: Node = astInvalidNodeId()
            if kidCount(field) > 1:
                valNode = kid(field, 1)
            while astNodeIdValid(valNode) && astNodeIsPar(valNode) && kidCount(valNode) > 0:
                valNode = kid(valNode, 0)
            var fieldVal: int64 = nextVal
            if astNodeIdValid(valNode) && !astNodeIsEmpty(valNode):
                if astNodeIsIntLit(valNode):
                    fieldVal = nodeIntVal(valNode)
                elif astNodeIsIdentOrSymbol(valNode):
                    let dep: str = plainName(valNode)
                    let gi: int32 = moduleGlobalIndex(mod, dep)
                    if gi >= 0:
                        let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod, gi)
                        if uirCoreGlobalHasInit(g):
                            fieldVal = uirCoreGlobalInitOf(g)
                        else:
                            return Ok[bool](true)
                    else:
                        return Ok[bool](true)
                else:
                    return Err[bool]("uirCore_builder: enum field value expects int literal")
            let fieldName: str = backendStripSpaces(plainName(fieldNameNode))
            if len(fieldName) == 0:
                return Err[bool]("uirCore_builder: enum field expects name")
            if moduleHasFunc(mod, fieldName) || moduleHasGlobal(mod, fieldName):
                return Err[bool]("uirCore_builder: enum field conflicts with existing name")
            uirCoreAddGlobal(mod, fieldName, uirCoreTypeI32(), fieldVal, true, "")
            nextVal = fieldVal + 1
        return Ok[bool](false)
    if (defNode != nil) && (astNodeIsTupleTy(defNode) || astNodeIsBracketExpr(defNode)):
        let rhsObjName: str = typeNodeObjTypeName(mod, defNode)
        if len(rhsObjName) > 0 && uirCoreHasObjType(mod, rhsObjName):
            let rhs: UirCoreObjType = uirCoreObjTypeRenamed(uirCoreGetObjType(mod, rhsObjName), name)
            uirCoreAddObjType(mod, rhs)
            uirCoreObjAliasPut(name, rhsObjName)
            uirCoreTypeObjResolveCachesReset(mod)
            return Ok[bool](false)
        if (getEnv "BACKEND_DEBUG_TYPES" == "1"):
            echo("[backend] debug: pending alias " + name + " object-like rhs unresolved")
        return Ok[bool](true)
    if !astNodeIdValid(defNode) || astNodeIsEmpty(defNode):
        return Err[bool]("uirCore_builder: type alias missing body")
    if astNodeIsIdentOrSymbol(defNode):
        let rhsName: str = backendStripSpaces(plainName(defNode))
        let rhsObjName2: str = typeNodeObjTypeName(mod, defNode)
        if debugFacadeTypes:
            let rhsAliasDbg: UirCoreType = uirCoreTryGetTypeAlias(mod, rhsName)
            echo("[backend] debugFacade: alias name=" + name +
                 " rhs=" + rhsName +
                 " rhsObj=" + rhsObjName2 +
                 " hasObj=" + (uirCoreHasObjType(mod, rhsObjName2) ? "1" : "0") +
                 " rhsAliasKind=" + intToStr(int32(uirCoreTypeKindOf(rhsAliasDbg))))
        if len(rhsObjName2) > 0 && uirCoreHasObjType(mod, rhsObjName2):
            let rhs: UirCoreObjType = uirCoreObjTypeRenamed(uirCoreGetObjType(mod, rhsObjName2), name)
            uirCoreAddObjType(mod, rhs)
            uirCoreObjAliasPut(name, rhsObjName2)
            uirCoreTypeObjResolveCachesReset(mod)
            if dbgTypeNameHit:
                os.WriteLine(os.Get_stderr(),
                             "[backend] debugTypeDecl: alias to obj " + rhsObjName2)
                os.C_fflush(os.Get_stderr())
            return Ok[bool](false)
        let rhsAlias: UirCoreType = uirCoreTryGetTypeAlias(mod, rhsName)
        if len(rhsName) > 0 && !isBuiltinTypeName(rhsName) && uirCoreTypeKindOf(rhsAlias) == uirCoreTypeKindVoid():
            if (getEnv "BACKEND_DEBUG_TYPES" == "1"):
                echo("[backend] debug: pending alias " + name + " depends on alias " + rhsName)
            return Ok[bool](true)
    let aliasTy: UirCoreType = uirCoreTypeFromNodeWithModule(mod, defNode)
    uirCoreAddTypeAlias(mod, name, aliasTy)
    uirCoreTypeObjResolveCachesReset(mod)
    if dbgTypeNameHit:
        os.WriteLine(os.Get_stderr(),
                     "[backend] debugTypeDecl: added scalar alias kind=" + intToStr(int32(uirCoreTypeKindOf(aliasTy))))
        os.C_fflush(os.Get_stderr())
    return Ok[bool](false)

fn uirCoreCountTypeDecls(root: Node): int32 =
    if !astNodeIdValid(root):
        return 0
    var out: int32 = astNodeIsTypeDecl(root) ? 1 : 0
    if astNodeIsModuleOrStmtList(root):
        for i in 0..<kidCount(root):
            out = out + uirCoreCountTypeDecls(kid(root, i))
    return out

fn uirCoreConsumeTypeDeclsPass(mod: UirCoreModule, n: Node,
                               progressed: var bool, pendingCount: var int32,
                               pendingNames: var str[], errorOk: var bool,
                               errorInfo: var ErrorInfo) =
    if errorOk || !astNodeIdValid(n):
        return
    if astNodeIsTypeDecl(n):
        let res: Result[bool] = uirCoreConsumeTypeDecl(mod, n)
        if !uirCoreResultBoolIsOk(res):
            errorOk = true
            errorInfo = uirCoreResultBoolErrorInfo(res)
            return
        if uirCoreResultBoolValue(res):
            pendingCount = pendingCount + 1
            if pendingNames.len < 32:
                let nm: str = uirCoreTypeDeclPendingName(n)
                if len(nm) > 0:
                    add(pendingNames, nm)
        else:
            progressed = true
        return
    if astNodeIsModuleOrStmtList(n):
        for i in 0..<kidCount(n):
            uirCoreConsumeTypeDeclsPass(mod, kid(n, i), progressed, pendingCount, pendingNames, errorOk, errorInfo)
            if errorOk:
                return

fn uirCoreConsumeTypeDecls(mod: UirCoreModule, root: Node, allowPendingUnresolved: bool = false): Result[bool] =
    if (root == nil):
        return Ok[bool](false)
    let workCount: int32 = uirCoreCountTypeDecls(root)
    if workCount == 0:
        return Ok[bool](false)
    var pass: int32
    while true:
        if pass > workCount + 8:
            return Err[bool]("uirCore_builder: type dependency resolution exceeded iteration limit")
        var progressed: bool
        var pendingCount: int32
        var pendingNames: str[]
        var errorOk: bool
        var errorInfo: ErrorInfo
        uirCoreConsumeTypeDeclsPass(mod, root, progressed, pendingCount, pendingNames, errorOk, errorInfo)
        if errorOk:
            return ErrInfo[bool](errorInfo)
        if pendingCount == 0:
            return Ok[bool](false)
        if !progressed:
            if allowPendingUnresolved:
                return Ok[bool](true)
            return Err[bool](uirCoreTypeDeclPendingNamesMsg(pendingNames))
        pass = pass + 1

fn uirCorePredeclareGlobalsForTypesVisit(mod: UirCoreModule, n: Node) =
    if !astNodeIdValid(n) || astNodeIsEmpty(n):
        return
    if astNodeIsModuleOrStmtList(n):
        for i in 0..<kidCount(n):
            uirCorePredeclareGlobalsForTypesVisit(mod, kid(n, i))
        return
    if !astNodeIsConst(n) && !astNodeIsLet(n) && !astNodeIsVar(n):
        return
    var pat: Node = astInvalidNodeId()
    if kidCount(n) > 0:
        pat = kid(n, 0)
    var init: Node = astInvalidNodeId()
    if kidCount(n) > 2:
        init = kid(n, 2)
    var nameNode: Node = pat
    var typeNode: Node = astInvalidNodeId()
    if kidCount(n) > 1:
        typeNode = kid(n, 1)
    if astNodeIdValid(pat) && astNodeIsPattern(pat) && kidCount(pat) > 0:
        nameNode = kid(pat, 0)
        if kidCount(pat) > 1:
            typeNode = kid(pat, 1)
    if (nameNode == nil) || !astNodeIsIdentOrSymbol(nameNode):
        return
    let name: str = plainName(nameNode)
    if moduleHasFunc(mod, name) || moduleHasGlobal(mod, name) ||
       uirCoreFindTypeAlias(mod, name) >= 0 || uirCoreFindObjType(mod, name) >= 0:
        return
    var initCore: Node = init
    while astNodeIdValid(initCore) && astNodeIsPar(initCore) && kidCount(initCore) > 0:
        initCore = kid(initCore, 0)
    var hasInit: bool
    var initVal: int64
    if astNodeIdValid(initCore) && !astNodeIsEmpty(initCore):
        if astNodeIsIntLit(initCore):
            hasInit = true
            initVal = nodeIntVal(initCore)
        elif astNodeIsBoolLit(initCore):
            hasInit = true
            let v: str = backendStripSpaces(nodeIdent(initCore))
            initVal = (v == "true") ? 1 : 0
        elif astNodeIsNilLit(initCore):
            hasInit = true
            initVal = 0
    var declTy: UirCoreType = uirCoreTypeFromNodeWithModule(mod, typeNode)
    if uirCoreTypeKindOf(declTy) == uirCoreTypeKindVoid():
        if hasInit:
            if astNodeIdValid(initCore) && astNodeIsBoolLit(initCore):
                declTy = uirCoreTypeU8()
            elif astNodeIdValid(initCore) && astNodeIsNilLit(initCore):
                declTy = uirCoreTypeI64()
            else:
                declTy = uirCoreTypeI32()
        else:
            declTy = uirCoreTypeI64()
    uirCoreAddGlobal(mod, name, declTy, initVal, hasInit, uirCorePredeclaredFilePath())
    if astNodeIdValid(typeNode) && !astNodeIsEmpty(typeNode):
        uirCoreGlobalTypeKeyPut(name, typeKey(typeNode))

fn uirCorePredeclareGlobalsForTypes(mod: UirCoreModule, root: Node) =
    if (mod == nil) || (root == nil):
        return
    uirCorePredeclareGlobalsForTypesVisit(mod, root)

fn uirCorePredeclareGlobalsForLoweringVisit(mod: UirCoreModule, n: Node) =
    if !astNodeIdValid(n) || astNodeIsEmpty(n):
        return
    if astNodeIsModuleOrStmtList(n):
        for i in 0..<kidCount(n):
            uirCorePredeclareGlobalsForLoweringVisit(mod, kid(n, i))
        return
    if !astNodeIsConst(n) && !astNodeIsLet(n) && !astNodeIsVar(n):
        return
    var pat: Node = astInvalidNodeId()
    if kidCount(n) > 0:
        pat = kid(n, 0)
    var init: Node = astInvalidNodeId()
    if kidCount(n) > 2:
        init = kid(n, 2)
    var nameNode: Node = pat
    var typeNode: Node = astInvalidNodeId()
    if kidCount(n) > 1:
        typeNode = kid(n, 1)
    if astNodeIdValid(pat) && astNodeIsPattern(pat) && kidCount(pat) > 0:
        nameNode = kid(pat, 0)
        if kidCount(pat) > 1:
            typeNode = kid(pat, 1)
    if (nameNode == nil) || !astNodeIsIdentOrSymbol(nameNode):
        return
    let rawName: str = backendStripSpaces(plainName(nameNode))
    if len(rawName) == 0:
        return
    let debugDot: bool = (getEnv "BACKEND_DEBUG_DOT" == "1")
    let filePath: str = uirCoreNodeFilePathOrPredeclared(n)
    if debugDot && rawName == "baseIdentity":
        echo("[backend] debugDot: predeclareLowering rawName='" + rawName +
             "' file='" + filePath + "' typeKind=nk#" + uirCoreDebugNodeKindText(typeNode) + "'")
    let name: str = uirCoreMaybeMangleDupGlobalName(rawName, filePath)
    if moduleHasFunc(mod, name) || moduleHasGlobal(mod, name) ||
       uirCoreFindTypeAlias(mod, name) >= 0 || uirCoreFindObjType(mod, name) >= 0:
        return
    var declType: UirCoreType = uirCoreTypeFromNodeWithModule(mod, typeNode)
    let objTypeNode: Node = uirCorePredeclareLoweringObjTypeNode(typeNode, init)
    let objTypeName: str = uirCorePredeclareLoweringObjTypeName(mod, typeNode, init)
    let isObj: bool = len(objTypeName) > 0 && (objTypeNode != nil) && typeNodeIsObjValue(mod, objTypeNode)
    if debugDot && rawName == "baseIdentity":
        echo("[backend] debugDot: predeclareLowering name='" + name +
             "' objTypeName='" + objTypeName + "' isObj=" + uirCoreTypeDeclBool01(isObj) +
             " objNodeKind=nk#" + uirCoreDebugNodeKindText(objTypeNode) + "'")
    if isObj:
        uirCoreGlobalObjTypePut(name, objTypeName)
        declType = uirCoreTypeI64()
    elif !astNodeIdValid(typeNode) || astNodeIsEmpty(typeNode):
        declType = inferExprTypeWithGlobals(nil, mod, nil, init, declType)
    if uirCoreTypeKindOf(declType) == uirCoreTypeKindVoid():
        declType = uirCoreTypeI64()
    if !isObj && (uirCoreTypeKindOf(declType) == uirCoreTypeKindI8() || uirCoreTypeKindOf(declType) == uirCoreTypeKindI16()):
        let wasUnsigned: bool = uirCoreTypeIsUnsigned(declType)
        declType = uirCoreTypeWithUnsigned(uirCoreTypeI32(), wasUnsigned)
    var initCore: Node = init
    while astNodeIdValid(initCore) && astNodeIsPar(initCore) && kidCount(initCore) > 0:
        initCore = kid(initCore, 0)
    var hasInit: bool
    var initVal: int64
    if !isObj && astNodeIdValid(initCore) && !astNodeIsEmpty(initCore):
        if astNodeIsIntLit(initCore):
            hasInit = true
            initVal = nodeIntVal(initCore)
        elif astNodeIsBoolLit(initCore):
            hasInit = true
            let v: str = backendStripSpaces(nodeIdent(initCore))
            initVal = (v == "true") ? 1 : 0
        elif astNodeIsNilLit(initCore):
            hasInit = true
            initVal = 0
    uirCoreAddGlobal(mod, name, declType, initVal, hasInit, uirCorePredeclaredFilePath())
    let keyOut: str = uirCorePredeclareLoweringTypeKey(typeNode, init)
    if len(keyOut) > 0:
        uirCoreGlobalTypeKeyPut(name, keyOut)

fn uirCorePredeclareGlobalsForLowering(mod: UirCoreModule, root: Node) =
    if (mod == nil) || (root == nil):
        return
    uirCorePredeclareGlobalsForLoweringVisit(mod, root)
