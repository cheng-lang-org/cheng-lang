# Shared builder-local types split from uir_core_builder.
import std/result
import std/hashmaps
import std/hashsets
import stage1/ast
import backend/uir/uir_internal/uir_core_types

type
    LocalEnv = ref
        names: str[]
        types: UirCoreType[]
        typeKeys: str[]
        callTargets: str[]
        active: int32[]
        scopeMarks: int32[]
        nameIndex: hashmaps.HashMapStrInt
        prevSlots: int32[]
    DeferFrame = ref
        bodies: Node[]
    LoopContext = ref
        breakLabel: str
        continueLabel: str
        deferDepth: int32
    BlockBuilder = ref
        env: LocalEnv
        module: UirCoreModule
        func: UirCoreFunc
        funcShadowPtr: int64
        funcShadowDynKey: int64
        currentLabel: str
        currentStmtStart: int32
        currentStmtLen: int32
        labelCounter: int32
        objCursor: int32
        loopStack: LoopContext[]
        deferStack: DeferFrame[]
        exprLowerDepth: int32
        exprLowerStack: Node[]
        implicitResultUsed: bool

    DotAccess =
        addr: UirExprId
        fieldTy: UirCoreType
        # Non-empty only when fieldTy == mtVoid (composite/inlined object field).
        objTypeName: str

    UirCorePhaseContractStats =
        highCheckedFuncs: int32
        highFallbackFuncs: int32
        highUnmappedFuncs: int32
        highNoProofFuncs: int32

    UirCoreGlobalInit = ref
        name: str
        ty: UirCoreType
        objTypeName: str
        initNode: Node
        filePath: str
        seqFixedElemType: Node
        seqFixedCapExpr: Node

    UirFnTask = ref
        funcIndex: int32
        nameTextId: int32
        declOrdinal: int32
        sourceAstIndex: int32
        taskOrdinal: int32
        originFile: str
        bodyTokStart: int32
        bodyTokEnd: int32
        costHint: int32
        genericEpoch: int32
        funcNode: AstNodeId
        routineName: str

    UirFnTaskResult = ref
        funcIndex: int32
        nameTextId: int32
        declOrdinal: int32
        taskOrdinal: int32
        loweredFunc: UirCoreFunc
        cstrings: str[]
        objAliasUpdates: str[]
        genericRequests: str[]
        diagBundle: str[]
        profileCounters: int32[]

    UirCoreSharedSnapshot = ref
        funcCount: int32
        globalCount: int32
        cstringCount: int32

    UirCoreBuildCtx = ref
        foundMain: bool
        traceEnabled: bool
        traceFnCount: int32
        traceGlobalCount: int32
        overloadedFnBases: hashsets.HashSetStr
        globalInitNames: str[]
        globalInitTypes: UirCoreType[]
        globalInitObjTypeNames: str[]
        globalInitNodes: Node[]
        globalInitFilePaths: str[]
        globalInitSeqFixedElemTypes: Node[]
        globalInitSeqFixedCapExprs: Node[]

fn Ok_DotAccess(value: DotAccess): Result[DotAccess] =
    var out: Result[DotAccess]
    out.ok = true
    out.value = value
    ErrorOkInto(out.err)
    return out

fn Err_DotAccess(err: str): Result[DotAccess] =
    var out: Result[DotAccess]
    out.ok = false
    ErrorNewInto(out.err, err)
    return out

fn Ok_UirFnTask(value: UirFnTask): Result[UirFnTask] =
    var out: Result[UirFnTask]
    out.ok = true
    out.value = value
    ErrorOkInto(out.err)
    return out

fn Err_UirFnTask(err: str): Result[UirFnTask] =
    var out: Result[UirFnTask]
    out.ok = false
    ErrorNewInto(out.err, err)
    return out

fn ErrInfo_UirFnTask(err: ErrorInfo): Result[UirFnTask] =
    var out: Result[UirFnTask]
    out.ok = false
    out.err = err
    return out

fn Ok_UirFnTaskResult(value: UirFnTaskResult): Result[UirFnTaskResult] =
    var out: Result[UirFnTaskResult]
    out.ok = true
    out.value = value
    ErrorOkInto(out.err)
    return out

fn Err_UirFnTaskResult(err: str): Result[UirFnTaskResult] =
    var out: Result[UirFnTaskResult]
    out.ok = false
    ErrorNewInto(out.err, err)
    return out

fn ErrInfo_UirFnTaskResult(err: ErrorInfo): Result[UirFnTaskResult] =
    var out: Result[UirFnTaskResult]
    out.ok = false
    out.err = err
    return out
