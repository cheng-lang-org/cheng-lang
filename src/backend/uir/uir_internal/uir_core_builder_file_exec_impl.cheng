# Thin facade for current-source file exec entrypoints.
#
# Keep builder-bearing roots off the active import surface by routing the
# heavy file-build implementation through file_exec_pipeline.
import std/result
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_file_exec_pipeline

fn uirCoreFileExecImplBuildModuleFromFileStage1(inPath: str, target: str): Result[UirCoreModule] =
    return uirCoreFileExecPipelineBuildModuleFromFileStage1(inPath, target)

fn uirCoreFileExecImplBuildModuleFromFileStage1OrPanic(inPath: str, target: str): UirCoreModule =
    return uirCoreFileExecPipelineBuildModuleFromFileStage1OrPanic(inPath, target)
