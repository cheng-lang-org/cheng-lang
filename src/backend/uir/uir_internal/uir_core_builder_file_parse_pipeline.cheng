# Thin facade for current-source file parse pipeline entrypoints.
import std/result
import std/system
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_file_compile_impl
import backend/uir/uir_internal/uir_core_builder_file_compile_variants

fn uirCoreFileParsePipelineBuildModuleFromFileStage1(inPath: str, target: str): Result[UirCoreModule] =
    return uirCoreFileCompileImplBuildModuleFromFileStage1(inPath, target)

fn uirCoreFileParsePipelineBuildModuleFromFileStage1Default(inPath: str): Result[UirCoreModule] =
    return uirCoreFileCompileVariantsBuildModuleFromFileStage1Default(inPath)

fn uirCoreFileParsePipelineBuildModuleFromFileStage1OrPanic(inPath: str, target: str): UirCoreModule =
    return uirCoreFileCompileImplBuildModuleFromFileStage1OrPanic(inPath, target)

fn uirCoreFileParsePipelineBuildModuleFromFileStage1OrPanicDefault(inPath: str): UirCoreModule =
    return uirCoreFileCompileVariantsBuildModuleFromFileStage1OrPanicDefault(inPath)

fn uirCoreFileParsePipelineBuildModuleFromFileStage1RawOrPanic(inRaw: cstring, targetRaw: cstring): UirCoreModule =
    return uirCoreFileCompileVariantsBuildModuleFromFileStage1RawOrPanic(inRaw, targetRaw)

fn uirCoreFileParsePipelineBuildModuleFromFileStage1TargetFirst(target: str, inPath: str): Result[UirCoreModule] =
    return uirCoreFileCompileVariantsBuildModuleFromFileStage1TargetFirst(target, inPath)

fn uirCoreFileParsePipelineBuildModuleFromFileStage1TargetFirstOrPanic(target: str, inPath: str): UirCoreModule =
    return uirCoreFileCompileVariantsBuildModuleFromFileStage1TargetFirstOrPanic(target, inPath)

fn uirCoreFileParsePipelineBuildModuleFromFileStage1HostOnlyOrPanic(inPath: str): UirCoreModule =
    return uirCoreFileCompileVariantsBuildModuleFromFileStage1HostOnlyOrPanic(inPath)
