var uirCore_predeclareMeta_len: int32
var uirCore_predeclareMeta_ready: bool[]
var uirCore_predeclareMeta_funcPtrs: int64[]
var uirCore_predeclareMeta_names: str[]
var uirCore_predeclareMeta_nameReady: int8[]
var uirCore_predeclareMeta_nameTextIds: int32[]
var uirCore_predeclareMeta_nameIndexed: int8[]
var uirCore_predeclareMeta_nameIndexedPtrKeys: int64[]
var uirCore_predeclareMeta_nameIndexedNames: str[]
var uirCore_predeclareMeta_originRaws: str[]
var uirCore_predeclareMeta_originNorms: str[]
var uirCore_predeclareMeta_originReady: int8[]
var uirCore_predeclareMeta_declOrdinals: int32[]
var uirCore_predeclareMeta_sourceAstIndices: int32[]
var uirCore_predeclareMeta_nameScanLen: int32
var uirCore_predeclareMeta_nameIndex: hashmaps.HashMapStrInt
var uirCore_predeclareMeta_nameChainHead: hashmaps.HashMapStrInt
var uirCore_predeclareMeta_nameChainEntryIdx: int32[]
var uirCore_predeclareMeta_nameChainEntryNext: int32[]
var uirCore_predeclareMeta_namePtrIndex: hashmaps.HashMapPtrInt
var uirCore_predeclareMeta_nameTextIndex: hashmaps.HashMapPtrInt
var uirCore_predeclareMeta_nameDupSet: hashsets.HashSetStr
var uirCore_predeclareMeta_sourceIndex: hashmaps.HashMapPtrInt
var uirCore_predeclareMeta_declIndex: hashmaps.HashMapPtrInt
var uirCore_predeclareMeta_sourceOriginIndex: hashmaps.HashMapStrInt
var uirCore_predeclareMeta_declOriginIndex: hashmaps.HashMapStrInt
var uirCore_predeclareMeta_recent_module: UirCoreModule
var uirCore_predeclareMeta_recent_idx: int32
var uirCore_predeclareMeta_recent_funcPtr: int64
var uirCore_predeclareMeta_recent_name: str
var uirCore_predeclareMeta_recent_originNorm: str
var uirCore_predeclareMeta_recent_declOrdinal: int32
var uirCore_predeclareMeta_recent_sourceAstIndex: int32
var uirCore_predeclareMeta_recent_nameReady: bool
var uirCore_predeclareMeta_recent_originReady: bool
var uirCore_predeclareMeta_recent_valid: bool
var uirCore_topLevelPathNorm_ptr_index: hashmaps.HashMapPtrInt
var uirCore_topLevelPathNorm_text_index: hashmaps.HashMapStrInt
var uirCore_topLevelPathNorm_ptr_values: str[]
var uirCore_topLevelPathNorm_last_ptr: int64
var uirCore_topLevelPathNorm_last_in: str
var uirCore_topLevelPathNorm_last_out: str
var uirCore_topLevelPathNorm_last_sourceAstIndex: int32
var uirCore_topLevelPathNorm_last_sourceOrigin: str
var uirCore_topLevelRoutineName_ready: int8[]
var uirCore_topLevelRoutineName_values: str[]
var uirCore_topLevelRoutineName_textIds: int32[]
var uirCore_moduleHasName_cache_module: UirCoreModule
var uirCore_moduleHasName_index: hashmaps.HashMapStrInt
var uirCore_moduleHasName_ptr_index: hashmaps.HashMapPtrInt
var uirCore_moduleHasName_ready: int8[]
var uirCore_moduleHasName_values: int8[]
var uirCore_moduleHasName_globalsLens: int32[]
var uirCore_moduleHasName_typeAliasLens: int32[]
var uirCore_moduleHasName_objTypeLens: int32[]
var uirCore_sameOrigin_recent_module: UirCoreModule
var uirCore_sameOrigin_recent_fnName: str
var uirCore_sameOrigin_recent_originNorm: str
var uirCore_sameOrigin_recent_declOrdinal: int32
var uirCore_sameOrigin_recent_sourceAstIndex: int32
var uirCore_sameOrigin_recent_nameTextId: int32
var uirCore_sameOrigin_recent_funcsLen: int32
var uirCore_sameOrigin_recent_result: int32
var uirCore_sameOrigin_recent_funcPtr: int64
var uirCore_sameOrigin_recent_valid: bool

fn uir_core_builder_top_level_passes_add(dst: var int32[], val: int32) =
    seqs.add(dst, val)

fn uir_core_builder_top_level_passes_add(dst: var str[], val: str) =
    seqs.add(dst, val)

fn uirCoreTopLevelStableText(s: str): str =
    if len(s) == 0:
        return ""
    return uirCoreOwnStrSafe(s)

fn uirCoreTopLevelSeqFixedNodeNormalized(typeNode0: Node): Node =
    var t: Node = typeNode0
    while astNodeIdValid(t) && nodeKind(t) == nkPar && kidCount(t) > 0:
        t = kid(t, 0)
    while astNodeIdValid(t) && nodeKind(t) == nkVarTy && kidCount(t) > 0:
        t = kid(t, 0)
        while astNodeIdValid(t) && nodeKind(t) == nkPar && kidCount(t) > 0:
            t = kid(t, 0)
    if astNodeIdValid(t) && nodeKind(t) == nkDotExpr && kidCount(t) > 1:
        t = kid(t, 1)
    return t

fn uirCoreTopLevelSeqFixedElemType(typeNode0: Node): Node =
    let t: Node = uirCoreTopLevelSeqFixedNodeNormalized(typeNode0)
    if !astNodeIdValid(t) || nodeKind(t) != nkBracketExpr || kidCount(t) < 3:
        return nil
    return kid(t, 1)

fn uirCoreTopLevelSeqFixedCapExpr(typeNode0: Node): Node =
    let t: Node = uirCoreTopLevelSeqFixedNodeNormalized(typeNode0)
    if !astNodeIdValid(t) || nodeKind(t) != nkBracketExpr || kidCount(t) < 3:
        return nil
    return kid(t, 2)

fn uirCorePredeclareMetaReserve(needLen: int32) =
    var target: int32 = uirCore_predeclareMeta_ready.cap
    if target < 256:
        target = 256
    while target < needLen:
        target = target * 2
    if uirCore_predeclareMeta_ready.cap < target:
        reserve(uirCore_predeclareMeta_ready, target)
    if uirCore_predeclareMeta_funcPtrs.cap < target:
        reserve(uirCore_predeclareMeta_funcPtrs, target)
    if uirCore_predeclareMeta_names.cap < target:
        reserve(uirCore_predeclareMeta_names, target)
    if uirCore_predeclareMeta_nameReady.cap < target:
        reserve(uirCore_predeclareMeta_nameReady, target)
    if uirCore_predeclareMeta_nameTextIds.cap < target:
        reserve(uirCore_predeclareMeta_nameTextIds, target)
    if uirCore_predeclareMeta_nameIndexed.cap < target:
        reserve(uirCore_predeclareMeta_nameIndexed, target)
    if uirCore_predeclareMeta_nameIndexedPtrKeys.cap < target:
        reserve(uirCore_predeclareMeta_nameIndexedPtrKeys, target)
    if uirCore_predeclareMeta_nameIndexedNames.cap < target:
        reserve(uirCore_predeclareMeta_nameIndexedNames, target)
    if uirCore_predeclareMeta_originRaws.cap < target:
        reserve(uirCore_predeclareMeta_originRaws, target)
    if uirCore_predeclareMeta_originNorms.cap < target:
        reserve(uirCore_predeclareMeta_originNorms, target)
    if uirCore_predeclareMeta_originReady.cap < target:
        reserve(uirCore_predeclareMeta_originReady, target)
    if uirCore_predeclareMeta_declOrdinals.cap < target:
        reserve(uirCore_predeclareMeta_declOrdinals, target)
    if uirCore_predeclareMeta_sourceAstIndices.cap < target:
        reserve(uirCore_predeclareMeta_sourceAstIndices, target)

fn uirCorePredeclareMetaRecentReset() =
    uirCore_predeclareMeta_recent_module = nil
    uirCore_predeclareMeta_recent_idx = -1
    uirCore_predeclareMeta_recent_funcPtr = 0
    uirCore_predeclareMeta_recent_name = ""
    uirCore_predeclareMeta_recent_originNorm = ""
    uirCore_predeclareMeta_recent_declOrdinal = -1
    uirCore_predeclareMeta_recent_sourceAstIndex = -1
    uirCore_predeclareMeta_recent_nameReady = false
    uirCore_predeclareMeta_recent_originReady = false
    uirCore_predeclareMeta_recent_valid = false

fn uirCorePredeclareMetaRecentMatches(mod: UirCoreModule, idx: int32, funcPtr: int64): bool =
    if !uirCore_predeclareMeta_recent_valid:
        return false
    if mod != uirCore_predeclareMeta_recent_module:
        return false
    if idx != uirCore_predeclareMeta_recent_idx:
        return false
    return funcPtr == uirCore_predeclareMeta_recent_funcPtr

fn uirCorePredeclareMetaRecentStore(mod: UirCoreModule, idx: int32, funcPtr: int64) =
    if mod == nil || idx < 0 || idx >= uirCore_predeclareMeta_len:
        uirCorePredeclareMetaRecentReset()
        return
    uirCore_predeclareMeta_recent_module = mod
    uirCore_predeclareMeta_recent_idx = idx
    uirCore_predeclareMeta_recent_funcPtr = funcPtr
    uirCore_predeclareMeta_recent_name = uirCore_predeclareMeta_names[idx]
    uirCore_predeclareMeta_recent_originNorm = uirCore_predeclareMeta_originNorms[idx]
    uirCore_predeclareMeta_recent_declOrdinal = uirCore_predeclareMeta_declOrdinals[idx]
    uirCore_predeclareMeta_recent_sourceAstIndex = uirCore_predeclareMeta_sourceAstIndices[idx]
    uirCore_predeclareMeta_recent_nameReady =
        uirCore_predeclareMeta_nameReady[idx] == int8(1)
    uirCore_predeclareMeta_recent_originReady =
        uirCore_predeclareMeta_originReady[idx] == int8(1)
    uirCore_predeclareMeta_recent_valid = true

fn uirCoreSameOriginRecentReset() =
    uirCore_sameOrigin_recent_module = nil
    uirCore_sameOrigin_recent_fnName = ""
    uirCore_sameOrigin_recent_originNorm = ""
    uirCore_sameOrigin_recent_declOrdinal = -1
    uirCore_sameOrigin_recent_sourceAstIndex = -1
    uirCore_sameOrigin_recent_nameTextId = 0
    uirCore_sameOrigin_recent_funcsLen = -1
    uirCore_sameOrigin_recent_result = -1
    uirCore_sameOrigin_recent_funcPtr = 0
    uirCore_sameOrigin_recent_valid = false

fn uirCoreSameOriginRecentLookup(mod: UirCoreModule, fnName: str,
                                 fnOriginNorm: str,
                                 declOrdinal: int32,
                                 sourceAstIndex: int32,
                                 nameTextId: int32): int32 =
    if !uirCore_sameOrigin_recent_valid || mod == nil:
        return -1
    if mod != uirCore_sameOrigin_recent_module ||
       fnName != uirCore_sameOrigin_recent_fnName ||
       fnOriginNorm != uirCore_sameOrigin_recent_originNorm ||
       declOrdinal != uirCore_sameOrigin_recent_declOrdinal ||
       sourceAstIndex != uirCore_sameOrigin_recent_sourceAstIndex ||
       nameTextId != uirCore_sameOrigin_recent_nameTextId:
        return -1
    let funcsLen: int32 = uirCoreModuleFuncsLen(mod)
    if funcsLen != uirCore_sameOrigin_recent_funcsLen:
        return -1
    let idx: int32 = uirCore_sameOrigin_recent_result
    if idx < 0 || idx >= funcsLen:
        return -1
    let f: UirCoreFunc = uirCoreModuleFuncAt(mod, idx)
    if f == nil:
        return -1
    let funcPtr: int64 = uirCorePredeclareMetaFuncKey(f)
    if funcPtr != uirCore_sameOrigin_recent_funcPtr:
        return -1
    return idx

fn uirCoreSameOriginRecentStore(mod: UirCoreModule, fnName: str,
                                fnOriginNorm: str,
                                declOrdinal: int32,
                                sourceAstIndex: int32,
                                nameTextId: int32,
                                resultIdx: int32) =
    if mod == nil || resultIdx < 0:
        return
    let funcsLen: int32 = uirCoreModuleFuncsLen(mod)
    if resultIdx >= funcsLen:
        return
    let f: UirCoreFunc = uirCoreModuleFuncAt(mod, resultIdx)
    if f == nil:
        return
    uirCore_sameOrigin_recent_module = mod
    uirCore_sameOrigin_recent_fnName = uirCoreTopLevelStableText(fnName)
    uirCore_sameOrigin_recent_originNorm = uirCoreTopLevelStableText(fnOriginNorm)
    uirCore_sameOrigin_recent_declOrdinal = declOrdinal
    uirCore_sameOrigin_recent_sourceAstIndex = sourceAstIndex
    uirCore_sameOrigin_recent_nameTextId = nameTextId
    uirCore_sameOrigin_recent_funcsLen = funcsLen
    uirCore_sameOrigin_recent_result = resultIdx
    uirCore_sameOrigin_recent_funcPtr = uirCorePredeclareMetaFuncKey(f)
    uirCore_sameOrigin_recent_valid = true

fn uirCorePredeclareMetaReset(mod: UirCoreModule = nil) =
    let funcsLen: int32 = (mod != nil) ? uirCoreModuleFuncsLen(mod) : 0
    uirCore_predeclareMeta_module = mod
    uirCore_predeclareMeta_len = funcsLen
    uirCorePredeclareMetaRecentReset()
    uirCoreSameOriginRecentReset()
    if uirCore_predeclareMeta_nameIndex.mask == 0:
        uirCore_predeclareMeta_nameIndex = hashmaps.hashMapStrIntInit(1024)
    else:
        hashmaps.hashMapStrIntClear(uirCore_predeclareMeta_nameIndex)
    if uirCore_predeclareMeta_nameChainHead.mask == 0:
        uirCore_predeclareMeta_nameChainHead = hashmaps.hashMapStrIntInit(1024)
    else:
        hashmaps.hashMapStrIntClear(uirCore_predeclareMeta_nameChainHead)
    if uirCore_predeclareMeta_namePtrIndex.mask == 0:
        uirCore_predeclareMeta_namePtrIndex = hashmaps.hashMapPtrIntInit(1024)
    else:
        hashmaps.hashMapPtrIntClear(uirCore_predeclareMeta_namePtrIndex)
    if uirCore_predeclareMeta_nameTextIndex.mask == 0:
        uirCore_predeclareMeta_nameTextIndex = hashmaps.hashMapPtrIntInit(1024)
    else:
        hashmaps.hashMapPtrIntClear(uirCore_predeclareMeta_nameTextIndex)
    if uirCore_predeclareMeta_nameDupSet.map.mask == 0:
        uirCore_predeclareMeta_nameDupSet = hashsets.hashSetStrInit(1024)
    else:
        hashsets.hashSetStrClear(uirCore_predeclareMeta_nameDupSet)
    if uirCore_predeclareMeta_sourceIndex.mask == 0:
        uirCore_predeclareMeta_sourceIndex = hashmaps.hashMapPtrIntInit(1024)
    else:
        hashmaps.hashMapPtrIntClear(uirCore_predeclareMeta_sourceIndex)
    if uirCore_predeclareMeta_declIndex.mask == 0:
        uirCore_predeclareMeta_declIndex = hashmaps.hashMapPtrIntInit(1024)
    else:
        hashmaps.hashMapPtrIntClear(uirCore_predeclareMeta_declIndex)
    if uirCore_predeclareMeta_sourceOriginIndex.mask == 0:
        uirCore_predeclareMeta_sourceOriginIndex = hashmaps.hashMapStrIntInit(1024)
    else:
        hashmaps.hashMapStrIntClear(uirCore_predeclareMeta_sourceOriginIndex)
    if uirCore_predeclareMeta_declOriginIndex.mask == 0:
        uirCore_predeclareMeta_declOriginIndex = hashmaps.hashMapStrIntInit(1024)
    else:
        hashmaps.hashMapStrIntClear(uirCore_predeclareMeta_declOriginIndex)
    uirCorePredeclareMetaReserve(funcsLen)
    setLen(uirCore_predeclareMeta_ready, funcsLen)
    setLen(uirCore_predeclareMeta_funcPtrs, funcsLen)
    setLen(uirCore_predeclareMeta_names, funcsLen)
    setLen(uirCore_predeclareMeta_nameReady, funcsLen)
    setLen(uirCore_predeclareMeta_nameTextIds, funcsLen)
    setLen(uirCore_predeclareMeta_nameIndexed, funcsLen)
    setLen(uirCore_predeclareMeta_nameIndexedPtrKeys, funcsLen)
    setLen(uirCore_predeclareMeta_nameIndexedNames, funcsLen)
    setLen(uirCore_predeclareMeta_originRaws, funcsLen)
    setLen(uirCore_predeclareMeta_originNorms, funcsLen)
    setLen(uirCore_predeclareMeta_originReady, funcsLen)
    setLen(uirCore_predeclareMeta_declOrdinals, funcsLen)
    setLen(uirCore_predeclareMeta_sourceAstIndices, funcsLen)
    setLen(uirCore_predeclareMeta_nameChainEntryIdx, 0)
    setLen(uirCore_predeclareMeta_nameChainEntryNext, 0)
    uirCore_predeclareMeta_nameScanLen = 0
    for i in 0..<funcsLen:
        uirCore_predeclareMeta_ready[i] = false
        uirCore_predeclareMeta_funcPtrs[i] = 0
        uirCore_predeclareMeta_names[i] = nil
        uirCore_predeclareMeta_nameReady[i] = int8(0)
        uirCore_predeclareMeta_nameTextIds[i] = 0
        uirCore_predeclareMeta_nameIndexed[i] = int8(0)
        uirCore_predeclareMeta_nameIndexedPtrKeys[i] = int64(0)
        uirCore_predeclareMeta_nameIndexedNames[i] = nil
        uirCore_predeclareMeta_originRaws[i] = nil
        uirCore_predeclareMeta_originNorms[i] = nil
        uirCore_predeclareMeta_originReady[i] = int8(0)
        uirCore_predeclareMeta_declOrdinals[i] = -1
        uirCore_predeclareMeta_sourceAstIndices[i] = -1

fn uirCorePredeclareMetaAppendLast(mod: UirCoreModule) =
    if mod == nil:
        uirCore_predeclareMeta_len = 0
        uirCorePredeclareMetaRecentReset()
        uirCoreSameOriginRecentReset()
        return
    let funcsLen: int32 = uirCoreModuleFuncsLen(mod)
    if funcsLen <= 0:
        uirCore_predeclareMeta_len = funcsLen
        uirCorePredeclareMetaRecentReset()
        uirCoreSameOriginRecentReset()
        return
    uirCorePredeclareMetaReserve(funcsLen)
    setLen(uirCore_predeclareMeta_ready, funcsLen)
    setLen(uirCore_predeclareMeta_funcPtrs, funcsLen)
    setLen(uirCore_predeclareMeta_names, funcsLen)
    setLen(uirCore_predeclareMeta_nameReady, funcsLen)
    setLen(uirCore_predeclareMeta_nameTextIds, funcsLen)
    setLen(uirCore_predeclareMeta_nameIndexed, funcsLen)
    setLen(uirCore_predeclareMeta_nameIndexedPtrKeys, funcsLen)
    setLen(uirCore_predeclareMeta_nameIndexedNames, funcsLen)
    setLen(uirCore_predeclareMeta_originRaws, funcsLen)
    setLen(uirCore_predeclareMeta_originNorms, funcsLen)
    setLen(uirCore_predeclareMeta_originReady, funcsLen)
    setLen(uirCore_predeclareMeta_declOrdinals, funcsLen)
    setLen(uirCore_predeclareMeta_sourceAstIndices, funcsLen)
    let idx: int32 = funcsLen - 1
    uirCore_predeclareMeta_ready[idx] = false
    uirCore_predeclareMeta_funcPtrs[idx] = 0
    uirCore_predeclareMeta_names[idx] = nil
    uirCore_predeclareMeta_nameReady[idx] = int8(0)
    uirCore_predeclareMeta_nameTextIds[idx] = 0
    uirCore_predeclareMeta_nameIndexed[idx] = int8(0)
    uirCore_predeclareMeta_nameIndexedPtrKeys[idx] = int64(0)
    uirCore_predeclareMeta_nameIndexedNames[idx] = nil
    uirCore_predeclareMeta_originRaws[idx] = nil
    uirCore_predeclareMeta_originNorms[idx] = nil
    uirCore_predeclareMeta_originReady[idx] = int8(0)
    uirCore_predeclareMeta_declOrdinals[idx] = -1
    uirCore_predeclareMeta_sourceAstIndices[idx] = -1
    uirCore_predeclareMeta_len = funcsLen
    uirCorePredeclareMetaRecentReset()
    uirCoreSameOriginRecentReset()

fn uirCorePredeclareMetaFuncKey(f: UirCoreFunc): int64 =
    if f == nil:
        return 0
    let funcObj: UirCoreFuncObjPtrLocal = uirCoreFuncObjPtr(f)
    let dynId: int32 = uirCoreTopLevelFuncObjDynId(funcObj)
    if uirCoreFuncDynIdSane(dynId):
        return int64(0x100000000) + int64(dynId)
    let ptrKey: int64 = uirCoreFuncPtrKey(f)
    if ptrKey != 0:
        return ptrKey
    return uirCoreFuncRawPtrVal(f)

fn uirCoreModuleFuncAtKnownLen(module: UirCoreModule, funcsLen: int32,
                               idx: int32): UirCoreFunc =
    if module == nil || idx < 0 || idx >= funcsLen:
        return nil
    let out: UirCoreFunc = module.funcs[idx]
    if !uirCoreFuncIdValid(out):
        return nil
    return out

fn uirCorePredeclareMetaNamePtrKey(name: str): int64 =
    if len(name) == 0 || !uirCoreStrPtrSane(name):
        return 0
    return int64(strDataPtr(name))

fn uirCorePredeclareMetaNameTextKey(nameTextId: int32): int64 =
    if nameTextId <= 0:
        return 0
    return int64(nameTextId) + int64(1)

fn uirCorePredeclareMetaSourceKey(sourceAstIndex: int32): int64 =
    if sourceAstIndex < 0:
        return 0
    return int64(sourceAstIndex) + int64(1)

fn uirCorePredeclareMetaDeclKey(declOrdinal: int32): int64 =
    if declOrdinal < 0:
        return 0
    return int64(declOrdinal) + int64(1)

fn uirCorePredeclareMetaSourceOriginKey(originNorm: str, sourceAstIndex: int32): str =
    if len(originNorm) == 0 || sourceAstIndex < 0:
        return ""
    let modId: str = uirCoreModuleIdForFile(originNorm)
    if len(modId) == 0:
        return ""
    return uirCoreTopLevelStableText(modId + "#s#" + intToStr(sourceAstIndex))

fn uirCorePredeclareMetaDeclOriginKey(originNorm: str, declOrdinal: int32): str =
    if len(originNorm) == 0 || declOrdinal < 0:
        return ""
    let modId: str = uirCoreModuleIdForFile(originNorm)
    if len(modId) == 0:
        return ""
    return uirCoreTopLevelStableText(modId + "#d#" + intToStr(declOrdinal))

fn uirCorePredeclareMetaRecordKeys(idx: int32, name: str,
                                   declOrdinal: int32,
                                   sourceAstIndex: int32) =
    uirCorePredeclareMetaRecordNameKeys(idx, name)
    uirCorePredeclareMetaRecordHintKeys(idx, declOrdinal, sourceAstIndex)

fn uirCorePredeclareMetaRecordNameKeys(idx: int32, name: str) =
    if idx < 0:
        return
    if idx >= uirCore_predeclareMeta_len:
        return
    let stableName: str = uirCoreTopLevelStableText(name)
    let namePtrKey: int64 = uirCorePredeclareMetaNamePtrKey(name)
    if len(stableName) == 0 || !uirCoreStrPtrSane(stableName):
        uirCore_predeclareMeta_nameIndexed[idx] = int8(0)
        uirCore_predeclareMeta_nameIndexedPtrKeys[idx] = int64(0)
        uirCore_predeclareMeta_nameIndexedNames[idx] = nil
        return
    let indexedName: str = uirCore_predeclareMeta_nameIndexedNames[idx]
    if uirCore_predeclareMeta_nameIndexed[idx] == int8(1) &&
       (uirCore_predeclareMeta_nameIndexedPtrKeys[idx] == namePtrKey ||
        (len(indexedName) > 0 && uirCorePredeclareNameMatches(indexedName, stableName))):
        return
    var foundExisting: bool = false
    let rawExisting: int32 = hashmaps.hashMapStrIntGetEx(uirCore_predeclareMeta_nameIndex, stableName, foundExisting)
    let existingIdx: int32 = rawExisting - 1
    if foundExisting && rawExisting > 0 && existingIdx >= 0 && existingIdx != idx:
        hashsets.hashSetStrAdd(uirCore_predeclareMeta_nameDupSet, stableName)
    var foundHead: bool = false
    let rawHead: int32 = hashmaps.hashMapStrIntGetEx(uirCore_predeclareMeta_nameChainHead, stableName, foundHead)
    let entryIdx: int32 = uirCore_predeclareMeta_nameChainEntryIdx.len
    uir_core_builder_top_level_passes_add(uirCore_predeclareMeta_nameChainEntryIdx, idx)
    uir_core_builder_top_level_passes_add(uirCore_predeclareMeta_nameChainEntryNext,
        (foundHead && rawHead > 0) ? (rawHead - 1) : -1)
    hashmaps.hashMapStrIntPut(uirCore_predeclareMeta_nameChainHead, stableName, entryIdx + 1)
    hashmaps.hashMapStrIntPut(uirCore_predeclareMeta_nameIndex, stableName, idx + 1)
    if namePtrKey != 0:
        hashmaps.hashMapPtrIntPut(uirCore_predeclareMeta_namePtrIndex, namePtrKey, idx + 1)
    uirCore_predeclareMeta_nameIndexed[idx] = int8(1)
    uirCore_predeclareMeta_nameIndexedPtrKeys[idx] = namePtrKey
    uirCore_predeclareMeta_nameIndexedNames[idx] = stableName

fn uirCorePredeclareMetaNameMayHaveDup(mod: UirCoreModule, name: str): bool =
    if mod == nil || len(name) == 0:
        return false
    uirCorePredeclareMetaEnsure(mod)
    return hashsets.hashSetStrHas(uirCore_predeclareMeta_nameDupSet, name)

fn uirCorePredeclareMetaFindSameNameRoutineChainMatch(mod: UirCoreModule,
                                                      fnName: str,
                                                      fnOriginNorm: str,
                                                      declOrdinal: int32,
                                                      sourceAstIndex: int32,
                                                      nameTextId: int32 = 0,
                                                      skipIdx: int32 = -1): int32 =
    if mod == nil || len(fnName) == 0:
        return -1
    uirCorePredeclareMetaEnsure(mod)
    var foundHead: bool = false
    let rawHead: int32 = hashmaps.hashMapStrIntGetEx(uirCore_predeclareMeta_nameChainHead,
                                                     fnName, foundHead)
    if !foundHead || rawHead <= 0:
        return -1
    let funcsLen: int32 = uirCoreModuleFuncsLen(mod)
    let entryLen: int32 = uirCore_predeclareMeta_nameChainEntryIdx.len
    var entryIdx: int32 = rawHead - 1
    var steps: int32 = 0
    while entryIdx >= 0 && entryIdx < entryLen && steps < entryLen:
        let nextEntryIdx: int32 = uirCore_predeclareMeta_nameChainEntryNext[entryIdx]
        let idx: int32 = uirCore_predeclareMeta_nameChainEntryIdx[entryIdx]
        steps = steps + 1
        if idx >= 0 && idx < funcsLen && idx != skipIdx:
            let exScan: UirCoreFunc = uirCoreModuleFuncAtKnownLen(mod, funcsLen, idx)
            if exScan != nil:
                var nameMatchedByCache: bool = false
                if mod == uirCore_predeclareMeta_module &&
                   idx < uirCore_predeclareMeta_len &&
                   uirCore_predeclareMeta_ready[idx]:
                    if nameTextId > 0:
                        let cachedTextId: int32 = uirCore_predeclareMeta_nameTextIds[idx]
                        if cachedTextId > 0:
                            if cachedTextId != nameTextId:
                                entryIdx = nextEntryIdx
                                continue
                            nameMatchedByCache = true
                    if !nameMatchedByCache && uirCore_predeclareMeta_nameReady[idx] == int8(1):
                        if !uirCorePredeclareNameMatches(uirCore_predeclareMeta_names[idx], fnName):
                            entryIdx = nextEntryIdx
                            continue
                        nameMatchedByCache = true
                if !nameMatchedByCache:
                    let exScanNameFast: str = uirCoreFuncNameFastForPredeclareLookup(mod, idx, exScan)
                    if len(exScanNameFast) > 0 && exScanNameFast != fnName:
                        entryIdx = nextEntryIdx
                        continue
                    var exScanName: str = exScanNameFast
                    if len(exScanName) == 0 && uirCorePredeclareMetaEnsureNameAt(mod, idx, exScan):
                        exScanName = uirCore_predeclareMeta_names[idx]
                    if len(exScanName) == 0 || exScanName != fnName:
                        entryIdx = nextEntryIdx
                        continue
                if uirCoreFuncMatchesRoutineKeyCachedOrNormalized(mod, idx, exScan, fnName,
                                                                  fnOriginNorm, declOrdinal,
                                                                  sourceAstIndex, nameTextId):
                    return idx
        if nextEntryIdx == entryIdx:
            break
        entryIdx = nextEntryIdx
    return -1

fn uirCorePredeclareMetaRecordNameTextKey(idx: int32, nameTextId: int32) =
    if idx < 0 || idx >= uirCore_predeclareMeta_len || nameTextId <= 0:
        return
    let key: int64 = uirCorePredeclareMetaNameTextKey(nameTextId)
    if key == 0:
        return
    hashmaps.hashMapPtrIntPut(uirCore_predeclareMeta_nameTextIndex, key, idx + 1)
    uirCore_predeclareMeta_nameTextIds[idx] = nameTextId

fn uirCorePredeclareMetaRecordHintKeys(idx: int32,
                                       declOrdinal: int32,
                                       sourceAstIndex: int32) =
    if idx < 0:
        return
    let sourceKey: int64 = uirCorePredeclareMetaSourceKey(sourceAstIndex)
    if sourceKey != 0:
        hashmaps.hashMapPtrIntPut(uirCore_predeclareMeta_sourceIndex, sourceKey, idx + 1)
    let declKey: int64 = uirCorePredeclareMetaDeclKey(declOrdinal)
    if declKey != 0:
        hashmaps.hashMapPtrIntPut(uirCore_predeclareMeta_declIndex, declKey, idx + 1)

fn uirCorePredeclareMetaRecordOriginHintKeys(idx: int32, originNorm: str,
                                             declOrdinal: int32,
                                             sourceAstIndex: int32) =
    if idx < 0 || len(originNorm) == 0:
        return
    let sourceOriginKey: str = uirCorePredeclareMetaSourceOriginKey(originNorm, sourceAstIndex)
    if len(sourceOriginKey) > 0:
        hashmaps.hashMapStrIntPut(uirCore_predeclareMeta_sourceOriginIndex, sourceOriginKey, idx + 1)
    let declOriginKey: str = uirCorePredeclareMetaDeclOriginKey(originNorm, declOrdinal)
    if len(declOriginKey) > 0:
        hashmaps.hashMapStrIntPut(uirCore_predeclareMeta_declOriginIndex, declOriginKey, idx + 1)

fn uirCorePredeclareMetaEnsure(mod: UirCoreModule) =
    if mod == nil:
        if uirCore_predeclareMeta_module != nil || uirCore_predeclareMeta_len != 0:
            uirCorePredeclareMetaReset()
        return
    let funcsLen: int32 = uirCoreModuleFuncsLen(mod)
    if uirCore_predeclareMeta_module != mod:
        uirCorePredeclareMetaReset(mod)
        return
    if funcsLen == uirCore_predeclareMeta_len:
        return
    if funcsLen == uirCore_predeclareMeta_len + 1:
        uirCorePredeclareMetaAppendLast(mod)
        return
    uirCorePredeclareMetaReset(mod)

fn uirCorePredeclareMetaCachedName(idx: int32): str =
    if idx < 0 || idx >= uirCore_predeclareMeta_len || !uirCore_predeclareMeta_ready[idx]:
