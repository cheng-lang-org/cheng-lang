import backend/uir/uir_internal/uir_core_builder_entry_path_cache

type
    HashSetStrPtr = hashsets.HashSetStr *
    UirCoreFuncObjPtrLocal = UirCoreFuncObj *

fn uirCoreTopLevelFuncObjDynId(funcObj: UirCoreFuncObjPtrLocal): int32 =
    let funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    return funcVal.dynId

fn uirCoreTopLevelFuncObjName(funcObj: UirCoreFuncObjPtrLocal): str =
    let funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    return (uirCoreStrPtrSane(funcVal.name) && len(funcVal.name) > 0) ? funcVal.name : ""

fn uirCoreTopLevelFuncObjOriginFile(funcObj: UirCoreFuncObjPtrLocal): str =
    let funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    return (uirCoreStrPtrSane(funcVal.originFile) && len(funcVal.originFile) > 0) ? funcVal.originFile : ""

fn uirCoreTopLevelFuncObjDeclOrdinal(funcObj: UirCoreFuncObjPtrLocal): int32 =
    let funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    return funcVal.declOrdinal

fn uirCoreTopLevelFuncObjSourceAstIndex(funcObj: UirCoreFuncObjPtrLocal): int32 =
    let funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    return funcVal.sourceAstIndex

