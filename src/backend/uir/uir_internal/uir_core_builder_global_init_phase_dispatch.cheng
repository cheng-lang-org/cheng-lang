# Global-init phase dispatch stays thin and delegates each chunk body to its
# own file so the entry builder does not materialize lowering-heavy chunks.
import std/os
import std/result
import std/seqs
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_types
import backend/uir/uir_internal/uir_core_builder_global_init_common
import backend/uir/uir_internal/uir_core_builder_global_init_const_phase
import backend/uir/uir_internal/uir_core_builder_global_init_heap_phase
import backend/uir/uir_internal/uir_core_builder_global_init_ctor_phase

fn uirCoreBuildGlobalInitConstPhase(mod: UirCoreModule, ctx: UirCoreBuildCtx,
                                    chunkSize: int32,
                                    dbgGlobalInitIndex: bool, fDbgGlobalInitIndex: os.File,
                                    helperNames: var str[]): Result[bool] =
    var startIndex: int32 = 0
    var chunkOrdinal: int32 = 0
    while startIndex < uirCoreBuildCtxGlobalInitLen(ctx):
        var nextIndex: int32 = startIndex
        var phaseFunc: UirCoreFunc = nil
        let phaseRes: Result[bool] = uirCoreBuildGlobalInitConstChunk(
            mod, ctx, startIndex, chunkSize, chunkOrdinal,
            dbgGlobalInitIndex, fDbgGlobalInitIndex, nextIndex, phaseFunc)
        if !IsOk[bool](phaseRes):
            return ErrInfo[bool](ErrorInfoOf[bool](phaseRes))
        if phaseFunc == nil:
            break
        uirCoreAddFunc(mod, phaseFunc)
        seqs.Add(helperNames, uirCoreOwnStr(uirCoreGlobalInitChunkHelperName("__cheng_global_init_const", chunkOrdinal)))
        startIndex = nextIndex
        chunkOrdinal = chunkOrdinal + 1
    return Ok[bool](true)

