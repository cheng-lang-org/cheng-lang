# Shared builder-local helper aggregation.
# Keep these low-level routines in one module so stage0 does not need to
# materialize a broad helper import fanout before lowering UIR builder code.
import std/os
import std/seqs
import std/strutils
import std/hashmaps
import std/hashsets
import std/strings
import std/system
import std/rawmem_support
import stage1/lexer
import stage1/ast
import stage1/token
import stage1/frontend_lib
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_types
import backend/uir/uir_internal/uir_core_builder_symbol_state
import backend/uir/uir_internal/uir_core_builder_type_name_cache

fn scopeStripSpaces(s: str): str =
    if len(s) == 0:
        return ""
    return strutils.Strip(s)

fn scopeStripSpacesMaybe(s: str): str =
    if len(s) == 0:
        return ""
    if len(strutils.Strip(s)) == 0:
        return ""
    return strutils.Strip(s)

fn scopeOpNameId(id: AstNodeId): str =
    if !astNodeIdValid(id):
        return ""
    return scopeStripSpaces(astPlainName(id))

fn scopeOpName(n: Node): str =
    return scopeOpNameId(n)

fn scopeConcat2(left0: str, right0: str): str =
    if len(left0) <= 0:
        return right0
    if len(right0) <= 0:
        return left0
    return left0 + right0

fn resolverAppendStr(seqInst: var str[], val: str) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn resolverStripSpaces(s: str): str =
    if len(s) == 0:
        return ""
    return strutils.Strip(s)

fn strHasSuffix(s: str, suffix: str): bool =
    let n: int32 = len(s)
    let m: int32 = len(suffix)
    if m == 0:
        return true
    if n == 0:
        return false
    if n < m:
        return false
    for i in 0..<m:
        if s[n - m + i] != suffix[i]:
            return false
    return true

fn strHasPrefix(s: str, prefix: str): bool =
    let n: int32 = len(s)
    let m: int32 = len(prefix)
    if m == 0:
        return true
    if n == 0:
        return false
    if n < m:
        return false
    for i in 0..<m:
        if s[i] != prefix[i]:
            return false
    return true

fn strStripPrefix(s: str, prefix: str): str =
    let n: int32 = len(s)
    let m: int32 = len(prefix)
    if m == 0:
        return s
    if n == 0:
        return ""
    if n < m:
        return ""
    for i in 0..<m:
        if s[i] != prefix[i]:
            return ""
    return rawmemStrFromOffset(s, m)

fn indexOfChar(s: str, ch: char): int32 =
    if len(s) == 0:
        return -1
    for i in 0..<len(s):
        if s[i] == ch:
            return i
    return -1

fn indexOfCharFrom(s: str, ch: char, start0: int32): int32 =
    if len(s) == 0:
        return -1
    var start: int32 = start0
    if start < 0:
        start = 0
    let n: int32 = len(s)
    if start >= n:
        return -1
    for i in start..<n:
        if s[i] == ch:
            return i
    return -1

fn resolverSliceRange(s: str, start0: int32, end0: int32): str =
    if len(s) == 0:
        return ""
    let n: int32 = len(s)
    if n <= 0:
        return ""
    var start: int32 = start0
    var endIdx: int32 = end0
    if start < 0:
        start = 0
    if endIdx >= n:
        endIdx = n - 1
    if start > endIdx:
        return ""
    return strutils.SliceStr(s, start, endIdx)

fn resolverParseQuotedValue(line: str): str =
    if len(line) <= 0:
        return ""
    let first: int32 = indexOfCharFrom(line, '"', 0)
    if first >= 0:
        let second: int32 = indexOfCharFrom(line, '"', first + 1)
        if second > first:
            return resolverSliceRange(line, first + 1, second - 1)
    return ""

fn resolverImportPathDropChengPrefix(path: str): str =
    if len(path) == 0:
        return ""
    if strHasPrefix(path, "cheng/"):
        if len(path) <= 6:
            return ""
        return strStripPrefix(path, "cheng/")
    return path

fn packageNameFromRest(rest: str): str =
    if len(resolverImportPathDropChengPrefix(rest)) == 0:
        return ""
    let slash: int32 = indexOfChar(resolverImportPathDropChengPrefix(rest), '/')
    if slash <= 0:
        return ""
    if strutils.SliceStr(resolverImportPathDropChengPrefix(rest), 0, slash - 1) == "std":
        return ""
    if strutils.SliceStr(resolverImportPathDropChengPrefix(rest), 0, slash - 1) == "core":
        return ""
    if strutils.SliceStr(resolverImportPathDropChengPrefix(rest), 0, slash - 1) == "system":
        return ""
    if strutils.SliceStr(resolverImportPathDropChengPrefix(rest), 0, slash - 1) == "ide":
        return ""
    if strutils.SliceStr(resolverImportPathDropChengPrefix(rest), 0, slash - 1) == "gui":
        return ""
    return strutils.SliceStr(resolverImportPathDropChengPrefix(rest), 0, slash - 1)

fn packageIdFromRest(rest: str): str =
    if len(packageNameFromRest(rest)) == 0:
        return ""
    if packageNameFromRest(rest) == "stdlib":
        return ""
    return "pkg://cheng/" + packageNameFromRest(rest)

fn resolverTrimPkgImportPrefix(rel: str, pkgName: str): str =
    if len(pkgName) == 0:
        return rel
    if len(rel) > len(pkgName) + 1 && strHasPrefix(rel, pkgName + "/"):
        return resolverSliceRange(rel, len(pkgName) + 1, len(rel) - 1)
    return rel

fn resolverPackageIdFromManifest(manifestPath: str): str =
    if len(manifestPath) == 0:
        return ""
    if !frontend_lib.Stage1_fileExists(manifestPath):
        return ""
    var content: str
    let _readOk: bool = frontend_lib.Stage1_readFileInto(manifestPath, content)
    if len(content) == 0:
        return ""
    let contentLen: int32 = len(content)
    var start: int32
    for i in 0..contentLen:
        if i == contentLen || content[i] == '\n':
            if i > start:
                if strHasPrefix(resolverStripSpaces(resolverSliceRange(content, start, i - 1)), "package_id"):
                    if len(resolverStripSpaces(resolverSliceRange(content, start, i - 1))) == 10 ||
                       resolverStripSpaces(resolverSliceRange(content, start, i - 1))[10] == '=' ||
                       resolverStripSpaces(resolverSliceRange(content, start, i - 1))[10] == ':' ||
                       resolverStripSpaces(resolverSliceRange(content, start, i - 1))[10] == ' ':
                        if len(resolverParseQuotedValue(resolverStripSpaces(resolverSliceRange(content, start, i - 1)))) > 0:
                            return resolverParseQuotedValue(resolverStripSpaces(resolverSliceRange(content, start, i - 1)))
            start = i + 1
    return ""

fn resolverPackageIdMatches(manifestPath: str, expected: str): bool =
    if len(expected) == 0:
        return true
    return resolverPackageIdFromManifest(manifestPath) == expected

fn pkgRootsFromEnv(): str[] =
    var out: str[]
    let single: str = os.GetEnvDefault("PKG_ROOT", "")
    if len(single) > 0:
        let trimmedSingle: str = resolverStripSpaces(single)
        if len(trimmedSingle) > 0:
            resolverAppendStr(out, trimmedSingle)
    let raw: str = os.GetEnvDefault("PKG_ROOTS", "")
    if len(raw) > 0:
        let rawLen: int32 = len(raw)
        var hasCommaOrSemi: bool
        for k in 0..<rawLen:
            let c0: char = raw[k]
            if c0 == ',' || c0 == ';':
                hasCommaOrSemi = true
                break
        let useColon: bool = !hasCommaOrSemi
        var start: int32
        for i in 0..rawLen:
            if i == rawLen || raw[i] == ',' || raw[i] == ';' || (useColon && raw[i] == ':'):
                if i > start:
                    let part: str = resolverSliceRange(raw, start, i - 1)
                    let trimmed: str = resolverStripSpaces(part)
                    if len(trimmed) > 0:
                        resolverAppendStr(out, trimmed)
                start = i + 1
    if out.len == 0:
        let home: str = os.GetEnvDefault("HOME", "")
        if len(home) > 0:
            resolverAppendStr(out, os.JoinPath(home, ".cheng-packages"))
    return out

fn resolverResolvePkgCandidate(base: str): str =
    if len(base) == 0:
        return ""
    if strHasSuffix(base, ".cheng"):
        if frontend_lib.Stage1_fileExists(base):
            return base
        return ""
    if frontend_lib.Stage1_fileExists(base + ".cheng"):
        return base + ".cheng"
    return ""

fn resolvePkgInRoot(pkgRoot: str, relInPkg: str, relForPkgRoot: str): str =
    if len(pkgRoot) == 0:
        return ""

    if len(relInPkg) > 0:
        if len(resolverResolvePkgCandidate(os.JoinPath(os.JoinPath(pkgRoot, "src"), relInPkg))) > 0:
            return resolverResolvePkgCandidate(os.JoinPath(os.JoinPath(pkgRoot, "src"), relInPkg))
        if len(resolverResolvePkgCandidate(os.JoinPath(os.JoinPath(pkgRoot, "cheng"), relInPkg))) > 0:
            return resolverResolvePkgCandidate(os.JoinPath(os.JoinPath(pkgRoot, "cheng"), relInPkg))
        if len(resolverResolvePkgCandidate(os.JoinPath(pkgRoot, relInPkg))) > 0:
            return resolverResolvePkgCandidate(os.JoinPath(pkgRoot, relInPkg))

    if len(relForPkgRoot) > 0:
        if len(resolverResolvePkgCandidate(os.JoinPath(os.JoinPath(pkgRoot, "src"), relForPkgRoot))) > 0:
            return resolverResolvePkgCandidate(os.JoinPath(os.JoinPath(pkgRoot, "src"), relForPkgRoot))
        if len(resolverResolvePkgCandidate(os.JoinPath(os.JoinPath(pkgRoot, "cheng"), relForPkgRoot))) > 0:
            return resolverResolvePkgCandidate(os.JoinPath(os.JoinPath(pkgRoot, "cheng"), relForPkgRoot))
        if len(resolverResolvePkgCandidate(os.JoinPath(pkgRoot, relForPkgRoot))) > 0:
            return resolverResolvePkgCandidate(os.JoinPath(pkgRoot, relForPkgRoot))
    return ""

fn resolvePkgImport(root: str, rest: str): str =
    if len(root) == 0 || len(rest) == 0:
        return ""
    if frontend_lib.Stage1_fileExists(os.JoinPath(root, "cheng-package.toml")):
        if !resolverPackageIdMatches(os.JoinPath(root, "cheng-package.toml"), packageIdFromRest(rest)):
            return ""
        return resolvePkgInRoot(
            root,
            resolverTrimPkgImportPrefix(
                resolverStripSpaces((len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest),
                packageNameFromRest(rest)
            ),
            (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest
        )

    if len(packageIdFromRest(rest)) > 0:
        if len(packageNameFromRest(rest)) == 0:
            return ""
        if frontend_lib.Stage1_fileExists(os.JoinPath(os.JoinPath(root, "cheng-" + packageNameFromRest(rest)), "cheng-package.toml")) &&
           resolverPackageIdMatches(os.JoinPath(os.JoinPath(root, "cheng-" + packageNameFromRest(rest)), "cheng-package.toml"), packageIdFromRest(rest)):
            if len(resolvePkgInRoot(
                os.JoinPath(root, "cheng-" + packageNameFromRest(rest)),
                resolverTrimPkgImportPrefix(
                    (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest,
                    packageNameFromRest(rest)
                ),
                (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest
            )) > 0:
                return resolvePkgInRoot(
                    os.JoinPath(root, "cheng-" + packageNameFromRest(rest)),
                    resolverTrimPkgImportPrefix(
                        (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest,
                        packageNameFromRest(rest)
                    ),
                    (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest
                )
        if frontend_lib.Stage1_fileExists(os.JoinPath(os.JoinPath(root, packageNameFromRest(rest)), "cheng-package.toml")) &&
           resolverPackageIdMatches(os.JoinPath(os.JoinPath(root, packageNameFromRest(rest)), "cheng-package.toml"), packageIdFromRest(rest)):
            if len(resolvePkgInRoot(
                os.JoinPath(root, packageNameFromRest(rest)),
                resolverTrimPkgImportPrefix(
                    (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest,
                    packageNameFromRest(rest)
                ),
                (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest
            )) > 0:
                return resolvePkgInRoot(
                    os.JoinPath(root, packageNameFromRest(rest)),
                    resolverTrimPkgImportPrefix(
                        (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest,
                        packageNameFromRest(rest)
                    ),
                    (len(resolverImportPathDropChengPrefix(rest)) > 0) ? resolverImportPathDropChengPrefix(rest) : rest
                )
        return ""

    let slash: int32 = indexOfChar(rest, '/')
    if slash > 0 && slash < len(rest) - 1:
        return resolvePkgInRoot(
            os.JoinPath(root, resolverSliceRange(rest, 0, slash - 1)),
            resolverSliceRange(rest, slash + 1, len(rest) - 1),
            rest
        )
    return ""

fn astNodeSeqAppend(seqInst: var Node[], node: Node) =
    seqs.Add(seqInst, node)

fn builderStrSeqAppend(seqInst: var str[], value: str) =
    seqs.Add(seqInst, value)

fn builderExprSeqAppend(seqInst: var UirExprId[], expr: UirExprId) =
    seqs.Add(seqInst, expr)

fn isControlExprId(id: AstNodeId): bool =
    var node: AstNodeId = id
    while astNodeIsPar(node) && kidCount(node) > 0:
        node = kidAt(node, 0)
    if !astNodeIdValid(node):
        return false
    if astNodeIsIf(node):
        return true
    if astNodeIsCase(node):
        return true
    if astNodeIsInfix(node) && kidCount(node) >= 3:
        if scopeOpNameId(kidAt(node, 0)) == "&&" || scopeOpNameId(kidAt(node, 0)) == "||":
            return true
    return false

fn isControlExpr(n: Node): bool =
    return isControlExprId(n)

fn isImplicitReturnExprId(id: AstNodeId): bool =
    if !astNodeIdValid(id):
        return false
    var node: AstNodeId = id
    while astNodeIsPar(node) && kidCount(node) > 0:
        node = kidAt(node, 0)
    if !astNodeIdValid(node):
        return false
    return astNodeIsCall(node) || astNodeIsInfix(node) || astNodeIsPrefix(node) ||
           astNodeIsPostfix(node) || astNodeIsDotExpr(node) || astNodeIsBracketExpr(node) ||
           astNodeIsCurlyExpr(node) || astNodeIsTupleLit(node) || astNodeIsSeqLit(node) ||
           astNodeIsTableLit(node) || astNodeIsIdent(node) || astNodeIsSymbol(node) ||
           astNodeIsIntLit(node) || astNodeIsFloatLit(node) || astNodeIsStringLiteral(node) ||
           astNodeIsCharLit(node) || astNodeIsBoolLit(node) || astNodeIsNilLit(node)

fn isImplicitReturnExpr(n: Node): bool =
    return isImplicitReturnExprId(n)

fn uirCoreAddStrPtr(items: str[]*, value: str) =
    if items == nil:
        return
    seqs.Add(items, value)

fn mbWrite[T](seqInst: var T[], idx: int32, val: T) =
    if idx < 0 || idx >= seqInst.len:
        panic "uirCore_builder: seq index out of bounds"
    seqInst[idx] = val

fn mbWriteBool(seqInst: var int32[], idx: int32, val: bool) =
    if idx < 0 || idx >= seqInst.len:
        panic "uirCore_builder: seq index out of bounds"
    seqInst[idx] = val ? 1 : 0

fn mbWriteStr(seqInst: var str[], idx: int32, val: str) =
    if idx < 0 || idx >= seqInst.len:
        panic "uirCore_builder: seq index out of bounds"
    seqInst[idx] = val

fn mbWriteObjLocal(seqInst: var UirCoreObjLocal[], idx: int32, val: UirCoreObjLocal) =
    if idx < 0 || idx >= seqInst.len:
        panic "uirCore_builder: seq index out of bounds"
    seqInst[idx] = val

fn mbWriteObjType(seqInst: var UirCoreObjType[], idx: int32, val: UirCoreObjType) =
    if idx < 0 || idx >= seqInst.len:
        panic "uirCore_builder: seq index out of bounds"
    seqInst[idx] = val

fn mbWriteGlobal(seqInst: var UirCoreGlobal[], idx: int32, val: UirCoreGlobal) =
    if idx < 0 || idx >= seqInst.len:
        panic "uirCore_builder: seq index out of bounds"
    seqInst[idx] = val

fn mbWriteFunc(seqInst: var UirCoreFunc[], idx: int32, val: UirCoreFunc) =
    if idx < 0 || idx >= seqInst.len:
        panic "uirCore_builder: seq index out of bounds"
    seqInst[idx] = val

@importc("driver_c_str_contains_char")
fn builder_text_c_str_contains_char(s: str, value: int32): int32

fn uir_core_builder_text_helpers_add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn backendStripStableText(s: str): str =
    let owned: str = uirCoreOwnStrSafe(s)
    if len(owned) > 0:
        return owned
    return s

var backendStripPtrIndex: hashmaps.HashMapPtrInt
var backendStripTextIndex: hashmaps.HashMapStrInt
var backendStripValues: str[]
var backendStripRecentPtr: int64
var backendStripRecentRaw: str
var backendStripRecentNorm: str
var backendStripRecentValid: bool
var uirCore_importcSourceCache_file: str
var uirCore_importcSourceCache_content: str

fn backendStripPtrKey(s: str): int64 =
    if !uirCoreStrPtrSane(s):
        return 0
    return int64(strDataPtr(s))

fn backendStripRemember(raw: str, norm: str, ptrKey: int64) =
    backendStripRecentPtr = ptrKey
    backendStripRecentRaw = backendStripStableText(raw)
    backendStripRecentNorm = backendStripStableText(norm)
    backendStripRecentValid = true

fn backendStripCacheReset() =
    backendStripPtrIndex = hashmaps.HashMapPtrIntInit(4096)
    backendStripTextIndex = hashmaps.HashMapStrIntInit(4096)
    setLen(backendStripValues, 0)
    reserve(backendStripValues, 1024)
    backendStripRecentPtr = 0
    backendStripRecentRaw = ""
    backendStripRecentNorm = ""
    backendStripRecentValid = false

fn backendStripSpaces(s: str): str =
    if len(s) == 0:
        return ""
    let ptrKey: int64 = backendStripPtrKey(s)
    if backendStripRecentValid:
        if ptrKey != 0 && ptrKey == backendStripRecentPtr:
            return backendStripRecentNorm
        if len(backendStripRecentRaw) > 0 && backendStripRecentRaw == s:
            return backendStripRecentNorm
    if ptrKey != 0:
        var foundPtr: bool
        let cachedIdx: int32 = hashmaps.HashMapPtrIntGet(backendStripPtrIndex, ptrKey, foundPtr)
        if foundPtr && cachedIdx > 0 && cachedIdx <= backendStripValues.len:
            let cachedPtr: str = get(backendStripValues, cachedIdx - 1)
            backendStripRemember(s, cachedPtr, ptrKey)
            return cachedPtr
    var foundText: bool
    let cachedTextIdx: int32 = uirCoreHashMapStrIntGetCompatLocal(backendStripTextIndex, s, foundText)
    if foundText && cachedTextIdx > 0 && cachedTextIdx <= backendStripValues.len:
        let cached: str = get(backendStripValues, cachedTextIdx - 1)
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(backendStripPtrIndex, ptrKey, cachedTextIdx)
        backendStripRemember(s, cached, ptrKey)
        return cached
    let hasWs: bool = builder_text_c_str_contains_char(s, int32(' ')) != 0 ||
                      builder_text_c_str_contains_char(s, int32('\t')) != 0 ||
                      builder_text_c_str_contains_char(s, int32('\n')) != 0 ||
                      builder_text_c_str_contains_char(s, int32('\r')) != 0
    if !hasWs:
        let stable: str = backendStripStableText(s)
        let cached: str = len(stable) > 0 ? stable : s
        let nextIdx: int32 = backendStripValues.len + 1
        uir_core_builder_text_helpers_add(backendStripValues, cached)
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(backendStripPtrIndex, ptrKey, nextIdx)
        hashmaps.HashMapStrIntPut(backendStripTextIndex, cached, nextIdx)
        backendStripRemember(cached, cached, ptrKey)
        return cached
    let n: int32 = len(s)
    if n == 0:
        return ""
    var kept: int32
    for i in 0..<n:
        let c: char = s[i]
        if c != ' ' && c != '\t' && c != '\n' && c != '\r':
            kept = kept + 1
    if kept <= 0:
        let nextIdx: int32 = backendStripValues.len + 1
        uir_core_builder_text_helpers_add(backendStripValues, "")
        if ptrKey != 0:
            hashmaps.HashMapPtrIntPut(backendStripPtrIndex, ptrKey, nextIdx)
        let stableRaw: str = backendStripStableText(s)
        hashmaps.HashMapStrIntPut(backendStripTextIndex, stableRaw, nextIdx)
        backendStripRemember(stableRaw, "", ptrKey)
        return ""
    let out: str = newStringOfCap(kept)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var outIdx: int32
    for i in 0..<n:
        let c: char = s[i]
        if c != ' ' && c != '\t' && c != '\n' && c != '\r':
            rawmemWriteChar(outPtr, outIdx, c)
            outIdx = outIdx + 1
    let stableOut: str = backendStripStableText(out)
    let cachedOut: str = len(stableOut) > 0 ? stableOut : out
    let stableRaw: str = backendStripStableText(s)
    let cachedRaw: str = len(stableRaw) > 0 ? stableRaw : s
    let nextIdx: int32 = backendStripValues.len + 1
    uir_core_builder_text_helpers_add(backendStripValues, cachedOut)
    if ptrKey != 0:
        hashmaps.HashMapPtrIntPut(backendStripPtrIndex, ptrKey, nextIdx)
    hashmaps.HashMapStrIntPut(backendStripTextIndex, cachedRaw, nextIdx)
    backendStripRemember(cachedRaw, cachedOut, ptrKey)
    return cachedOut

fn backendStripSpacesMaybe(s: str): str =
    return backendStripSpaces(s)

fn uirCoreImportcSourceContent(filePath0: str): str =
    if len(backendStripSpaces(filePath0)) == 0 || !frontend_lib.Stage1_fileExists(backendStripSpaces(filePath0)):
        return ""
    if uirCore_importcSourceCache_file == backendStripSpaces(filePath0) &&
       len(uirCore_importcSourceCache_content) > 0:
        return uirCore_importcSourceCache_content
    var content: str
    if !frontend_lib.Stage1_readFileInto(backendStripSpaces(filePath0), &content):
        return ""
    uirCore_importcSourceCache_file = backendStripStableText(backendStripSpaces(filePath0))
    uirCore_importcSourceCache_content = content
    return content

fn backendIsSafeLinkName(name: str): bool =
    if len(name) == 0:
        return false
    let n: int32 = len(name)
    if n == 0:
        return false
    let c0: char = name[0]
    let v0: int32 = int32(int64(c0) & 0xFF)
    if ! ((v0 >= 65 && v0 <= 90) || (v0 >= 97 && v0 <= 122) || v0 == 95):
        return false
    for i in 0..<n:
        let c: char = name[i]
        let v: int32 = int32(int64(c) & 0xFF)
        if (v >= 65 && v <= 90) || (v >= 97 && v <= 122) ||
           (v >= 48 && v <= 57) || v == 95:
            continue
        return false
    return true

fn backendHexDigitLower(v: int32): char =
    if v < 10:
        return char(int8(48 + v))
    return char(int8(97 + (v - 10)))

fn backendHexByteLower(v: int32): str =
    let hi: int32 = (v / 16) & 15
    let lo: int32 = v & 15
    return charToStr(backendHexDigitLower(hi)) + charToStr(backendHexDigitLower(lo))

fn backendSanitizeLinkNameFill(out: str, name: str, nameLen: int32): str =
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return "__cheng_anon"
    rawmem_support.RawmemCopy(outPtr, rawmemAsVoid("__cheng_sym"), 11)
    var writePos: int32 = 11
    for i in 0..<nameLen:
        let c: char = name[i]
        let v: int32 = int32(int64(c) & 0xFF)
        rawmemWriteChar(outPtr, writePos, '_')
        rawmemWriteChar(outPtr, writePos + 1, backendHexDigitLower((v / 16) & 15))
        rawmemWriteChar(outPtr, writePos + 2, backendHexDigitLower(v & 15))
        writePos = writePos + 3
    return out

fn backendSanitizeLinkName(raw: str): str =
    if len(raw) == 0:
        return ""
    let stripped: str = backendStripSpaces(raw)
    if backendIsSafeLinkName(stripped):
        return stripped
    if len(stripped) == 0:
        return "__cheng_anon"
    let nameLen: int32 = len(stripped)
    if nameLen == 0:
        return "__cheng_anon"
    return backendSanitizeLinkNameFill(newStringAlloc(11 + (nameLen * 3)), stripped, nameLen)

fn uirCoreStrStartsWith(s: str, prefix: str): bool =
    let sLen: int32 = strLenFast(s)
    let prefixLen: int32 = strLenFast(prefix)
    return uirCoreStrStartsWithWithLen(s, sLen, prefix, prefixLen)

fn uirCoreStrEqWithLen(a: str, aLen: int32, b: str, bLen: int32): bool =
    if aLen != bLen:
        return false
    if aLen <= 0:
        return true
    let aPtr: ptr = strDataPtr(a)
    let bPtr: ptr = strDataPtr(b)
    if aPtr == bPtr:
        return true
    if aPtr == nil || bPtr == nil:
        return false
    return cmpMem(aPtr, bPtr, int64(aLen)) == 0

fn uirCoreStrEqFast(a: str, b: str): bool =
    return uirCoreStrEqWithLen(a, strLenFast(a), b, strLenFast(b))

fn uirCoreStrStartsWithWithLen(s: str, sLen: int32, prefix: str, prefixLen: int32): bool =
    if prefixLen <= 0:
        return true
    if sLen < prefixLen:
        return false
    let sPtr: ptr = strDataPtr(s)
    let prefixPtr: ptr = strDataPtr(prefix)
    if sPtr == nil || prefixPtr == nil:
        return false
    return cmpMem(sPtr, prefixPtr, int64(prefixLen)) == 0

fn uirCoreStripLeadingUnderscores(raw: str): str =
    if len(raw) == 0:
        return ""
    let n: int32 = len(raw)
    if n <= 0:
        return ""
    var i: int32
    while i < n && raw[i] == '_':
        i = i + 1
    if i <= 0:
        return raw
    if i >= n:
        return ""
    return rawmemStrFromOffset(raw, i)

fn uirCoreStrFindFrom(text: str, pat: str, start: int32 = 0): int32 =
    let n: int32 = strLenFast(text)
    let m: int32 = strLenFast(pat)
    if m <= 0:
        return start <= n ? start : -1
    if n <= 0 || start < 0 || start >= n || m > n:
        return -1
    let textPtr: ptr = strDataPtr(text)
    let patPtr: ptr = strDataPtr(pat)
    if textPtr == nil || patPtr == nil:
        return -1
    let first: uint8 = load(patPtr)
    let last: int32 = n - m
    var i: int32 = start
    while i <= last:
        if load(system_ptr_add(textPtr, i)) == first &&
           cmpMem(system_ptr_add(textPtr, i), patPtr, int64(m)) == 0:
            return i
        i = i + 1
    return -1

fn uirCoreStrIndexOfWithLen(s: str, sLen: int32, sub: str, subLen: int32): int32 =
    let n: int32 = sLen
    let m: int32 = subLen
    if m == 0:
        return 0
    if n == 0:
        return -1
    if m > n:
        return -1
    let sPtr: ptr = strDataPtr(s)
    let subPtr: ptr = strDataPtr(sub)
    if sPtr == nil || subPtr == nil:
        return -1
    let first: uint8 = load(subPtr)
    let last: int32 = n - m
    var i: int32
    while i <= last:
        if load(system_ptr_add(sPtr, i)) == first &&
           cmpMem(system_ptr_add(sPtr, i), subPtr, int64(m)) == 0:
            return i
        i = i + 1
    return -1

fn uirCoreStrIndexOf(s: str, sub: str): int32 =
    return uirCoreStrIndexOfWithLen(s, strLenFast(s), sub, strLenFast(sub))

fn uirCoreStrEqAt(s: str, off: int32, pat: str): bool =
    let n: int32 = strLenFast(s)
    let m: int32 = strLenFast(pat)
    return uirCoreStrEqAtWithLen(s, n, off, pat, m)

fn uirCoreStrEqAtWithLen(s: str, sLen: int32, off: int32, pat: str, patLen: int32): bool =
    let n: int32 = sLen
    let m: int32 = patLen
    if off < 0 || m <= 0 || off + m > n:
        return false
    let sPtr: ptr = strDataPtr(s)
    let patPtr: ptr = strDataPtr(pat)
    if sPtr == nil || patPtr == nil:
        return false
    return cmpMem(system_ptr_add(sPtr, off), patPtr, int64(m)) == 0

fn uirCoreStrTake(s: str, count: int32): str =
    if len(s) == 0 || count <= 0:
        return ""
    let n: int32 = len(s)
    var k: int32 = count
    if k > n:
        k = n
    let out: str = newStringOfCap(k)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    if k > 0:
        rawmemCopy(outPtr, s, k)
    rawmemSet(rawmemPtrAdd(outPtr, k), 0, 1)
    return out

fn uirCoreStrSliceRange(s: str, start0: int32, end0: int32): str =
    if len(s) == 0:
        return ""
    let n: int32 = len(s)
    var start: int32 = start0
    var endIdx: int32 = end0
    if start < 0:
        start = 0
    if endIdx >= n:
        endIdx = n - 1
    if start > endIdx:
        return ""
    let outLen: int32 = endIdx - start + 1
    let out: str = newStringOfCap(outLen)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    rawmemCopy(outPtr, rawmemPtrAdd(rawmemAsVoid(s), start), outLen)
    rawmemSet(rawmemPtrAdd(outPtr, outLen), 0, 1)
    return out

@importc("driver_c_new_string_copy_n")
fn builder_importc_c_new_string_copy_n_raw(raw: ptr, n: int32): cstring

fn builder_importc_c_new_string_copy_n(raw: ptr, n: int32): str =
    if raw == nil || n <= 0:
        return ""
    let outRaw: cstring = builder_importc_c_new_string_copy_n_raw(raw, n)
    return strViewUnsafe(outRaw, n)

fn uirCoreImportcLinkNameCharOk(ch: char): bool =
    if ch >= 'a' && ch <= 'z':
        return true
    if ch >= 'A' && ch <= 'Z':
        return true
    if ch >= '0' && ch <= '9':
        return true
    return ch == '_' || ch == '$' || ch == '.'

fn uirCoreImportcLinkNameValid(name0: str): bool =
    let name: str = backendStripSpaces(name0)
    if len(name) == 0:
        return false
    for i in 0..<len(name):
        if !uirCoreImportcLinkNameCharOk(name[i]):
            return false
    return true

fn uirCoreNormalizeImportcLinkName(funcName0: str, linkName0: str): str =
    let funcName: str = backendStripSpaces(funcName0)
    let linkName: str = backendStripSpaces(linkName0)
    if uirCoreImportcLinkNameValid(linkName):
        if uirCoreStrStartsWith(funcName, "driver_c_") && linkName != funcName:
            return funcName
        return linkName
    let fallback0: str = backendSanitizeLinkName(funcName)
    if uirCoreImportcLinkNameValid(fallback0):
        return fallback0
    return funcName

fn uirCoreImportcAnnNeedle(): str =
    return "@importc(\""

fn uirCoreImportcLinkNameFromSource(filePath: str, funcName0: str): str =
    let funcName: str = backendStripSpaces(funcName0)
    if len(funcName) == 0:
        return ""
    let content: str = uirCoreImportcSourceContent(filePath)
    if len(content) == 0:
        return ""
    let fnNeedle: str = scopeConcat2("fn ", funcName)
    if len(fnNeedle) == 0:
        return ""
    var searchFrom: int32
    while searchFrom >= 0:
        let fnPos: int32 = uirCoreStrFindFrom(content, fnNeedle, searchFrom)
        if fnPos < 0:
            return ""
        var nameEnd: int32 = fnPos + len(fnNeedle)
        while nameEnd < len(content) && (content[nameEnd] == ' ' || content[nameEnd] == '\t'):
            nameEnd = nameEnd + 1
        if nameEnd >= len(content) || content[nameEnd] != '(':
            searchFrom = fnPos + 1
            continue
        var annPos: int32 = -1
        var annSearch: int32
        while annSearch >= 0:
            let nextAnn: int32 = uirCoreStrFindFrom(content, uirCoreImportcAnnNeedle(), annSearch)
            if nextAnn < 0 || nextAnn >= fnPos:
                break
            annPos = nextAnn
            annSearch = nextAnn + 1
        if annPos < 0:
            return ""
        let interveningFn: int32 = uirCoreStrFindFrom(content, "fn ", annPos + 1)
        if interveningFn >= 0 && interveningFn < fnPos:
            searchFrom = fnPos + 1
            continue
        let valueStart: int32 = annPos + len(uirCoreImportcAnnNeedle())
        var valueEnd: int32 = valueStart
        while valueEnd < len(content) && content[valueEnd] != '"':
            valueEnd = valueEnd + 1
        if valueEnd <= valueStart || valueEnd > fnPos:
            searchFrom = fnPos + 1
            continue
        return builder_importc_c_new_string_copy_n(rawmem_support.RawmemPtrAdd(rawmemAsVoid(content), valueStart), valueEnd - valueStart)
    return ""

fn uirCorePathBaseName(path: str): str =
    if len(path) == 0:
        return ""
    let name0: str = backendStripSpaces(frontend_lib.Stage1SplitName(path))
    if len(name0) > 0:
        return name0
    return backendStripSpaces(path)

fn uirCorePathDirName(path: str): str =
    if len(path) == 0:
        return ""
    return backendStripSpaces(frontend_lib.Stage1SplitDir(path))

var uirCoreEntryPathCachedRaw: str
var uirCoreEntryPathCachedNorm: str
var uirCoreEntryPathCachedDir: str
var uirCoreEntryPathCachedBase: str
var uirCoreEntryPathCachedKeepDir: bool = true
var uirCoreEntryPathCacheReady: bool

fn uirCoreRefreshEntryPathCache() =
    let raw: str = backendStripSpaces(os.GetEnvDefault("BACKEND_INPUT", ""))
    let keepDir: bool = os.GetEnvDefault("BACKEND_REACHABLE_KEEP_ENTRY_DIR", "1") != "0"
    if uirCoreEntryPathCacheReady &&
       raw == uirCoreEntryPathCachedRaw &&
       keepDir == uirCoreEntryPathCachedKeepDir:
        return
    uirCoreEntryPathCachedRaw = raw
    uirCoreEntryPathCachedNorm = raw
    uirCoreEntryPathCachedDir = uirCorePathDirName(raw)
    uirCoreEntryPathCachedBase = uirCorePathBaseName(raw)
    uirCoreEntryPathCachedKeepDir = keepDir
    uirCoreEntryPathCacheReady = true

fn uirCoreIsEntryFilePath(filePath: str): bool =
    if len(filePath) == 0:
        return false
    uirCoreRefreshEntryPathCache()
    let entryPath: str = uirCoreEntryPathCachedNorm
    if len(entryPath) == 0:
        return false
    if filePath == entryPath:
        return true
    let keepEntryDir: bool = uirCoreEntryPathCachedKeepDir
    if keepEntryDir:
        let fileDir: str = uirCorePathDirName(filePath)
        let entryDir: str = uirCoreEntryPathCachedDir
        if len(fileDir) > 0 && len(entryDir) > 0 && fileDir == entryDir:
            return true
    let fileBase: str = uirCorePathBaseName(filePath)
    let entryBase: str = uirCoreEntryPathCachedBase
    if len(fileBase) == 0 || len(entryBase) == 0:
        return false
    return fileBase == entryBase

fn uir_core_builder_obj_local_state_add(dst: var UirCoreObjLocal[], val: UirCoreObjLocal) =
    seqs.Add(dst, val)

fn funcFindObjLocal(func: UirCoreFunc, slot: int32): int32 =
    if (!uirCoreFuncIdValid(func)):
        return -1
    for i in 0..<uirCoreFuncObjLocalsLen(func):
        let ol: UirCoreObjLocal = uirCoreFuncObjLocalAt(func, i)
        if ol.slot == slot:
            return i
    return -1

fn funcFindObjLocalByPtrKey(ptrKey: int64, slot: int32): int32 =
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDynByPtrKey(ptrKey)
    if dyn == nil:
        return -1
    for i in 0..<dyn.objLocals.len:
        let ol: UirCoreObjLocal = dyn.objLocals[i]
        if ol.slot == slot:
            return i
    return -1

fn funcObjTypeName(func: UirCoreFunc, slot: int32): str =
    let idx: int32 = funcFindObjLocal(func, slot)
    if idx < 0:
        return ""
    let ol: UirCoreObjLocal = uirCoreFuncObjLocalAt(func, idx)
    return ol.objTypeName

fn funcObjTypeKey(func: UirCoreFunc, slot: int32): str =
    let idx: int32 = funcFindObjLocal(func, slot)
    if idx < 0:
        return ""
    let ol: UirCoreObjLocal = uirCoreFuncObjLocalAt(func, idx)
    if len(ol.typeKey) > 0:
        return ol.typeKey
    return ol.objTypeName

fn uirCoreDebugBuildMainState(tag: str, f: UirCoreFunc): void =
    let externDbg: bool = uirCoreFuncIsExtern(f)
    let nameDbg: str = uirCoreFuncNameOf(f)
    echo("[backend] dbg_build_main." + tag +
         " dyn_id=" + intToStr(uirCoreFuncDynId(f)) +
         " obj_extern=" + (externDbg ? "1" : "0") +
         " dyn_extern=" + (externDbg ? "1" : "0") +
         " obj_name=" + nameDbg +
         " dyn_name=" + nameDbg +
         " blocks=" + intToStr(uirCoreFuncBlocksLen(f)) +
         " ptr=" + int64ToStr(uirCoreFuncPtrKey(f)))

fn uirCoreHiddenResultSlot(env: LocalEnv, func: UirCoreFunc): int32 =
    if env == nil:
        return -1
    let resultSlot: int32 = localIndex(env, "__result")
    if !uirCoreFuncIdValid(func):
        return resultSlot
    let retSlot: int32 = localIndex(env, "__ret")
    if retSlot >= 0 && len(funcObjTypeName(func, retSlot)) > 0:
        return retSlot
    return resultSlot

fn uirCoreResolveLocalSlotOrImplicitResult(env: LocalEnv, func: UirCoreFunc, name0: str): int32 =
    if env == nil:
        return -1
    let name: str = backendStripSpaces(name0)
    if len(name) == 0:
        return -1
    let slot: int32 = localIndex(env, name)
    if slot >= 0:
        return slot
    if name == "result":
        return uirCoreHiddenResultSlot(env, func)
    return -1

fn uirCoreMarkImplicitResultUse(b: BlockBuilder, name0: str, slot: int32) =
    if (b == nil) || slot < 0:
        return
    let name: str = backendStripSpaces(name0)
    if name != "result":
        return
    if localIndex(blockBuilderEnv(b), name) >= 0:
        return
    if slot == uirCoreHiddenResultSlot(blockBuilderEnv(b), blockBuilderFuncRef(b)):
        blockBuilderSetImplicitResultUsed(b, true)

fn funcSetObjTypeKey(func: UirCoreFunc, slot: int32, typeKey: str) =
    if (!uirCoreFuncIdValid(func)) || len(typeKey) == 0:
        return
    let idx: int32 = funcFindObjLocal(func, slot)
    if idx < 0:
        return
    var ol: UirCoreObjLocal = uirCoreFuncObjLocalAt(func, idx)
    ol.typeKey = typeKey
    uirCoreFuncSetObjLocalAt(func, idx, ol)

fn funcAddObjLocalKnownNew(func: UirCoreFunc, slot: int32, objTypeName: str,
                           frameOff: int32, typeKey: str = "") =
    if (!uirCoreFuncIdValid(func)) || len(objTypeName) == 0:
        return
    let objTypeOwned: str = uirCoreOwnStrSafe(objTypeName)
    let typeKeyOwned: str = len(typeKey) > 0 ? uirCoreOwnStrSafe(typeKey) : objTypeOwned
    var ol: UirCoreObjLocal
    ol.slot = slot
    ol.objTypeName = objTypeOwned
    ol.typeKey = typeKeyOwned
    ol.frameOff = frameOff
    uirCoreFuncAddObjLocal(func, ol)

fn funcSetObjTypeKeyByPtrKey(ptrKey: int64, slot: int32, typeKey: str) =
    if len(typeKey) == 0:
        return
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDynByPtrKey(ptrKey)
    if dyn == nil:
        return
    let idx: int32 = funcFindObjLocalByPtrKey(ptrKey, slot)
    if idx < 0:
        return
    var objLocals0: UirCoreObjLocal[] = dyn.objLocals
    var ol: UirCoreObjLocal = objLocals0[idx]
    ol.typeKey = typeKey
    objLocals0[idx] = ol
    dyn.objLocals = objLocals0
    uirCoreFuncSyncObjPayloadByPtrKey(ptrKey, dyn)

fn funcSetObjLocal(func: UirCoreFunc, slot: int32, objTypeName: str, frameOff: int32) =
    if (!uirCoreFuncIdValid(func)) || len(objTypeName) == 0:
        return
    let idx: int32 = funcFindObjLocal(func, slot)
    let objTypeOwned: str = uirCoreOwnStrSafe(objTypeName)
    var ol: UirCoreObjLocal
    ol.slot = slot
    ol.objTypeName = objTypeOwned
    ol.typeKey = objTypeOwned
    ol.frameOff = frameOff
    if idx >= 0:
        uirCoreFuncSetObjLocalAt(func, idx, ol)
        return
    uirCoreFuncAddObjLocal(func, ol)

fn funcSetObjLocalByPtrKey(ptrKey: int64, slot: int32, objTypeName: str, frameOff: int32) =
    if len(objTypeName) == 0:
        return
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDynByPtrKey(ptrKey)
    if dyn == nil:
        return
    let idx: int32 = funcFindObjLocalByPtrKey(ptrKey, slot)
    let objTypeOwned: str = uirCoreOwnStrSafe(objTypeName)
    var ol: UirCoreObjLocal
    ol.slot = slot
    ol.objTypeName = objTypeOwned
    ol.typeKey = objTypeOwned
    ol.frameOff = frameOff
    var objLocals0: UirCoreObjLocal[] = dyn.objLocals
    if idx >= 0:
        objLocals0[idx] = ol
    else:
        uir_core_builder_obj_local_state_add(objLocals0, ol)
    dyn.objLocals = objLocals0
    uirCoreFuncSyncObjPayloadByPtrKey(ptrKey, dyn)

fn funcObjFrameSizeOfPtrKey(ptrKey: int64): int32 =
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDynByPtrKey(ptrKey)
    if dyn == nil:
        return 0
    return dyn.objFrameSize

fn funcSetObjFrameSizeByPtrKey(ptrKey: int64, objFrameSize: int32) =
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDynByPtrKey(ptrKey)
    if dyn == nil:
        return
    dyn.objFrameSize = objFrameSize

fn uir_core_builder_overload_scan_add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn uir_core_builder_overload_scan_add(dst: var int32[], val: int32) =
    seqs.Add(dst, val)

fn uirCoreFuncSigMarker(): str =
    return "__cheng_sig_"

fn uirCoreFnv1a64Update(h0: uint64, s0: str): uint64 =
    var h: uint64 = h0
    for i in 0..<len(s0):
        let c: char = s0[i]
        h = h ^ uint64(int64(c) & int64(0xFF))
        h = h * uint64(1099511628211)
    return h

fn uirCoreFnv1a64UpdateChar(h0: uint64, ch: char): uint64 =
    var h: uint64 = h0
    h = h ^ uint64(int64(ch) & int64(0xFF))
    h = h * uint64(1099511628211)
    return h

fn uirCoreFuncSigInputTail(paramKeys: str[], idx: int32, out0: str): str =
    if idx >= paramKeys.len:
        return out0
    let pk0: str = paramKeys[idx]
    if len(pk0) > 0:
        return uirCoreFuncSigInputTail(paramKeys, idx + 1, out0 + pk0 + ";")
    return uirCoreFuncSigInputTail(paramKeys, idx + 1, out0 + ";")

fn uirCoreFuncSigInput(retKey0: str, paramKeys: str[]): str =
    if len(retKey0) > 0:
        return uirCoreFuncSigInputTail(paramKeys, 0, retKey0 + "|")
    return uirCoreFuncSigInputTail(paramKeys, 0, "|")

fn uirCoreSigSanitizeChar(ch: char): char =
    let ok: bool =
        (ch >= 'a' && ch <= 'z') ||
        (ch >= 'A' && ch <= 'Z') ||
        (ch >= '0' && ch <= '9') ||
        ch == '_'
    if ok:
        return ch
    return '_'

fn uirCoreSigSanitizeAtomFill(out: str, atom: str, atomLen: int32): str =
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    for i in 0..<atomLen:
        rawmemWriteChar(outPtr, i, uirCoreSigSanitizeChar(atom[i]))
    return out

fn uirCoreSigSanitizeAtom(atom0: str): str =
    let atomLen: int32 = len(atom0)
    if atomLen <= 0:
        return "empty"
    let out: str = uirCoreSigSanitizeAtomFill(newStringAlloc(atomLen), atom0, atomLen)
    if len(out) > 0:
        return out
    return "empty"

fn uirCoreFuncSigIdTail(paramKeys: str[], idx: int32, out0: str): str =
    if idx >= paramKeys.len:
        return out0
    return uirCoreFuncSigIdTail(paramKeys, idx + 1, out0 + "__p_" + uirCoreSigSanitizeAtom(paramKeys[idx]))

fn uirCoreFuncSigId(retKey: str, paramKeys: str[]): str =
    let retSan: str = uirCoreSigSanitizeAtom(retKey)
    if paramKeys.len == 0:
        return "ret_" + retSan + "__p_void"
    return uirCoreFuncSigIdTail(paramKeys, 0, "ret_" + retSan)

fn uirCoreMangleOverloadName(baseSym: str, retKey: str, paramKeys: str[]): str =
    let marker: str = uirCoreFuncSigMarker()
    let sigId: str = uirCoreFuncSigId(retKey, paramKeys)
    return baseSym + marker + sigId

fn uirCoreOverloadBaseId(nameNode: AstNodeId, textId: int32): str =
    let plain: str = backendStripSpaces(astPlainName(nameNode))
    if len(plain) > 0:
        return plain
    if textId > 0:
        return backendStripSpaces(tokenTextById(textId))
    return ""

fn uirCoreComputeOverloadedFnBasesId(rootId: AstNodeId): hashsets.HashSetStr =
    var overloaded: hashsets.HashSetStr = hashsets.HashSetStrInit(256)
    if !astNodeIdValid(rootId):
        return overloaded
    let rootKids: int32 = astKidCount(rootId)
    let mapCap: int32 = (rootKids > 128) ? (rootKids * 2) : 256
    var nameIndex: hashmaps.HashMapStrInt = hashmaps.HashMapStrIntInit(mapCap)
    var stack: int32[]
    stack.cap = (rootKids > 0) ? rootKids : 8
    uir_core_builder_overload_scan_add(stack, rootId)
    while stack.len > 0:
        let top: AstNodeId = stack[stack.len - 1]
        stack.len = stack.len - 1
        if !astNodeIdValid(top) || isEmpty(top):
            continue
        if !astNodeIsRoutineDecl(top):
            for ki in 0..<astKidCount(top):
                uir_core_builder_overload_scan_add(stack, astKidAt(top, ki))
            continue
        let n: AstNodeId = top
        if astKidCount(n) == 0:
            continue
        if uirCoreFuncSigHasUnresolvedGenericsId(n):
            continue
        let nameNode: AstNodeId = astKidAt(n, 0)
        if !astNodeIdValid(nameNode) || !astNodeIsIdentOrSymbol(nameNode):
            continue
        let textId: int32 = astNodeIdentId(nameNode)
        let baseId: str = uirCoreOverloadBaseId(nameNode, textId)
        if len(baseId) == 0:
            continue
        var prevFound: bool
        let prevIdxPlus1: int32 = hashmaps.HashMapStrIntGetEx(nameIndex, baseId, prevFound)
        let prevIdx: int32 = (prevIdxPlus1 > 0) ? (prevIdxPlus1 - 1) : -1
        if prevIdx < 0:
            hashmaps.HashMapStrIntPut(nameIndex, baseId, 1)
            continue
        hashsets.HashSetStrAdd(overloaded, baseId)
    return overloaded

fn uirCoreComputeOverloadedFnBases(root: Node): hashsets.HashSetStr =
    return uirCoreComputeOverloadedFnBasesId(root)
