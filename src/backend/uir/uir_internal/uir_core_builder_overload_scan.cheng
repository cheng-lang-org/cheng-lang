# UIR core builder overload/mangle helpers (split from uir_core_builder).
import std/hashsets
import std/hashmaps
import stage1/ast

fn uirCoreFuncSigMarker(): str =
    return "__cheng_sig_"

fn uirCoreFuncSigInput(retKey0: str, paramKeys: str[]): str =
    var retKey: str = retKey0
    if len(retKey) == 0:
        retKey = ""
    var out: str = retKey + "|"
    for i in 0..<paramKeys.len:
        let pk0: str = paramKeys[i]
        let pk: str = (len(pk0) > 0) ? pk0 : ""
        out = out + pk + ";"
    return out

fn uirCoreFuncSigId(retKey: str, paramKeys: str[]): str =
    return uirCoreU64ToHex(uirCoreFnv1a64(uirCoreFuncSigInput(retKey, paramKeys)))

fn uirCoreMangleOverloadName(baseSym: str, retKey: str, paramKeys: str[]): str =
    return baseSym + uirCoreFuncSigMarker() + uirCoreFuncSigId(retKey, paramKeys)

fn uirCoreComputeOverloadedFnBasesId(rootId: AstNodeId): hashsets.HashSetStr =
    # Stage1 monomorphize may emit multiple functions with the same base name (e.g. `len`)
    # but different signatures. The MIR module requires globally-unique function symbols,
    # so we precompute which base names are overloaded.
    var overloaded: hashsets.HashSetStr = hashsets.hashSetStrInit(256)
    if !astNodeIdValid(rootId):
        return overloaded
    let rootKids: int32 = astKidCount(rootId)
    let mapCap: int32 = (rootKids > 128) ? (rootKids * 2) : 256
    var nameIndex: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(mapCap)
    var firstSigs: str[]
    for i in 0..<rootKids:
        let top: AstNodeId = astKidAt(rootId, i)
        if !astNodeIdValid(top) || astNodeKind(top) == nkEmpty:
            continue
        var n: AstNodeId = top
        if (astNodeKind(n) != nkFnDecl && astNodeKind(n) != nkIteratorDecl) || astKidCount(n) == 0:
            # Keep a shallow fallback for wrapper nodes; do not walk function bodies.
            if astKidCount(top) <= 0:
                continue
            n = astKidAt(top, 0)
            if !astNodeIdValid(n) || astNodeKind(n) == nkEmpty:
                continue
            if (astNodeKind(n) != nkFnDecl && astNodeKind(n) != nkIteratorDecl) || astKidCount(n) == 0:
                continue
        if uirCoreFuncSigHasUnresolvedGenericsId(n):
            continue
        let nameNode: AstNodeId = astKidAt(n, 0)
        if !astNodeIdValid(nameNode) || (astNodeKind(nameNode) != nkIdent && astNodeKind(nameNode) != nkSymbol):
            continue
        let rawName: str = backendStripSpaces(astPlainName(nameNode))
        let baseId: str = rawName
        if len(baseId) == 0:
            continue

        let paramsNode: AstNodeId = astKidAt(n, 1)
        var paramKeys: str[]
        if astNodeIdValid(paramsNode) && astNodeKind(paramsNode) == nkFormalParams:
            for pi in 0..<astKidCount(paramsNode):
                let defs: AstNodeId = astKidAt(paramsNode, pi)
                if astNodeIdValid(defs) && astNodeKind(defs) == nkIdentDefs && astKidCount(defs) > 1:
                    let tn: AstNodeId = astKidAt(defs, 1)
                    let pk: str = astNodeIdValid(tn) ? typeKey(tn) : ""
                    add(paramKeys, pk)

        let retNode: AstNodeId = astKidAt(n, 2)
        var retKey: str = ""
        if astNodeIdValid(retNode) && astNodeKind(retNode) != nkEmpty:
            retKey = typeKey(retNode)
        let sigId: str = uirCoreFuncSigId(retKey, paramKeys)

        let prevIdxPlus1: int32 = hashmaps.hashMapStrIntGet(nameIndex, baseId)
        let prevIdx: int32 = (prevIdxPlus1 > 0) ? (prevIdxPlus1 - 1) : -1
        if prevIdx < 0:
            let newIdx: int32 = firstSigs.len
            add(firstSigs, sigId)
            hashmaps.hashMapStrIntPut(nameIndex, baseId, newIdx + 1)
            continue
        if prevIdx >= 0 && prevIdx < firstSigs.len:
            let prevSig: str = firstSigs[prevIdx]
            if !(prevSig == sigId):
                hashsets.hashSetStrAdd(overloaded, baseId)
    return overloaded

fn uirCoreComputeOverloadedFnBases(root: Node): hashsets.HashSetStr =
    return uirCoreComputeOverloadedFnBasesId(root)
