# Thin facade for current-source file-build entrypoints.
import std/result
import std/system
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_file_pipeline

fn uirCoreFileBuildModuleFromFileStage1(inPath: str, target: str): Result[UirCoreModule] =
    return uirCoreFilePipelineBuildModuleFromFileStage1(inPath, target)

fn uirCoreFileBuildModuleFromFileStage1Default(inPath: str): Result[UirCoreModule] =
    return uirCoreFilePipelineBuildModuleFromFileStage1Default(inPath)

fn uirCoreFileBuildModuleFromFileStage1OrPanic(inPath: str, target: str): UirCoreModule =
    return uirCoreFilePipelineBuildModuleFromFileStage1OrPanic(inPath, target)

fn uirCoreFileBuildModuleFromFileStage1OrPanicDefault(inPath: str): UirCoreModule =
    return uirCoreFilePipelineBuildModuleFromFileStage1OrPanicDefault(inPath)

fn uirCoreFileBuildModuleFromFileStage1RawOrPanic(inRaw: cstring, targetRaw: cstring): UirCoreModule =
    return uirCoreFilePipelineBuildModuleFromFileStage1RawOrPanic(inRaw, targetRaw)

fn uirCoreFileBuildModuleFromFileStage1TargetFirst(target: str, inPath: str): Result[UirCoreModule] =
    return uirCoreFilePipelineBuildModuleFromFileStage1TargetFirst(target, inPath)

fn uirCoreFileBuildModuleFromFileStage1TargetFirstOrPanic(target: str, inPath: str): UirCoreModule =
    return uirCoreFilePipelineBuildModuleFromFileStage1TargetFirstOrPanic(target, inPath)

fn uirCoreFileBuildModuleFromFileStage1HostOnlyOrPanic(inPath: str): UirCoreModule =
    return uirCoreFilePipelineBuildModuleFromFileStage1HostOnlyOrPanic(inPath)
