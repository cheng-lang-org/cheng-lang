# Current-source runtime facade for the extracted builder entry.
#
# Keep the public runtime symbols stable while routing heavy root/file build
# implementations through smaller imported modules. This preserves the same
# algorithmic path but removes the monolithic runtime body from active roots.
import std/result
import std/system
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_root_build
import backend/uir/uir_internal/uir_core_builder_file_build

fn uirCoreRuntimeBuildModuleFromRootId(rootInputId: AstNodeId): Result[UirCoreModule] =
    return uirCoreRootBuildModuleFromRootId(rootInputId)

fn uirCoreRuntimeBuildModuleFromRoot(rootInput: Node): Result[UirCoreModule] =
    return uirCoreRootBuildModuleFromRoot(rootInput)

fn uirCoreRuntimeBuildModuleFromFileStage1(inPath: str, target: str): Result[UirCoreModule] =
    return uirCoreFileBuildModuleFromFileStage1(inPath, target)

fn uirCoreRuntimeBuildModuleFromFileStage1Default(inPath: str): Result[UirCoreModule] =
    return uirCoreFileBuildModuleFromFileStage1Default(inPath)

fn uirCoreRuntimeBuildModuleFromFileStage1OrPanic(inPath: str, target: str): UirCoreModule =
    return uirCoreFileBuildModuleFromFileStage1OrPanic(inPath, target)

fn uirCoreRuntimeBuildModuleFromFileStage1OrPanicDefault(inPath: str): UirCoreModule =
    return uirCoreFileBuildModuleFromFileStage1OrPanicDefault(inPath)

fn uirCoreRuntimeBuildModuleFromFileStage1RawOrPanic(inRaw: cstring, targetRaw: cstring): UirCoreModule =
    return uirCoreFileBuildModuleFromFileStage1RawOrPanic(inRaw, targetRaw)

fn uirCoreRuntimeBuildModuleFromFileStage1TargetFirst(target: str, inPath: str): Result[UirCoreModule] =
    return uirCoreFileBuildModuleFromFileStage1TargetFirst(target, inPath)

fn uirCoreRuntimeBuildModuleFromFileStage1TargetFirstOrPanic(target: str, inPath: str): UirCoreModule =
    return uirCoreFileBuildModuleFromFileStage1TargetFirstOrPanic(target, inPath)

fn uirCoreRuntimeBuildModuleFromFileStage1HostOnlyOrPanic(inPath: str): UirCoreModule =
    return uirCoreFileBuildModuleFromFileStage1HostOnlyOrPanic(inPath)
