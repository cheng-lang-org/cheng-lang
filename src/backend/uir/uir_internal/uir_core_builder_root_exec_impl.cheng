# Thin facade for current-source root exec entrypoints.
#
# Keep builder-bearing roots off the active import surface by routing the
# heavy root-build implementation through root_exec_pipeline.
import std/result
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_root_exec_pipeline

fn uirCoreRootExecImplBuildModuleFromRootId(rootInputId: AstNodeId): Result[UirCoreModule] =
    return uirCoreRootExecPipelineBuildModuleFromRootId(rootInputId)

fn uirCoreRootExecImplBuildModuleFromRoot(rootInput: Node): Result[UirCoreModule] =
    return uirCoreRootExecPipelineBuildModuleFromRoot(rootInput)
