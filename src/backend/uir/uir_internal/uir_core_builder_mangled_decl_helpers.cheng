# Shared builder-local overload/mangled-decl helpers split from uir_core_builder.
import std/os
import std/system
import std/strings
import stage1/ast
import backend/uir/uir_internal/uir_core_builder_base_helpers
import backend/uir/uir_internal/uir_core_builder_type_surface_helpers
import backend/uir/uir_internal/uir_core_builder_symbol_state
import backend/uir/uir_internal/uir_core_builder_dup_scan
import backend/uir/uir_internal/uir_core_builder_top_level_passes

fn uirCoreTypeKeyForOverloadOrEmpty(tnId: AstNodeId): str =
    if astNodeIdValid(tnId):
        return uirCoreTypeKeyForOverload(tnId)
    return ""

fn uirCoreFnDeclOverloadRetKey(nId: AstNodeId): str =
    let retNodeId: AstNodeId = astKidAt(nId, 2)
    if astNodeIdValid(retNodeId) && !isEmpty(retNodeId):
        return uirCoreTypeKeyForOverload(retNodeId)
    return ""

fn uirCoreIndexedFnDeclName(nId: AstNodeId, rawName: str, overloaded: ptr,
                            baseSym: str, symName: str, fp: str,
                            dbgDollarOverload: bool): str =
    if !uirCoreShouldMangleOverloadFn(rawName, overloaded):
        return symName
    let paramsNodeId: AstNodeId = astKidAt(nId, 1)
    var paramKeys: str[]
    if astNodeIdValid(paramsNodeId) && astNodeIsFormalParams(paramsNodeId):
        let paramCap: int32 = astKidCount(paramsNodeId)
        if paramCap > 0:
            setLen(paramKeys, paramCap)
        var paramCount: int32 = 0
        for pi in 0..<astKidCount(paramsNodeId):
            let defsId: AstNodeId = astKidAt(paramsNodeId, pi)
            if !astNodeIdValid(defsId):
                continue
            if astNodeIsIdentDefs(defsId) && astKidCount(defsId) > 1:
                let tnId: AstNodeId = astKidAt(defsId, 1)
                if paramCount < paramKeys.len:
                    paramKeys[paramCount] = uirCoreTypeKeyForOverloadOrEmpty(tnId)
                    paramCount = paramCount + 1
        if paramCount < paramKeys.len:
            setLen(paramKeys, paramCount)
    let retKey: str = uirCoreFnDeclOverloadRetKey(nId)
    if dbgDollarOverload && rawName == "$" && strContains(fp, "src/std/strings.cheng"):
        os.writeLine(os.get_stderr(),
            "[backend] dollar_index origin=" + fp +
            " ret='" + retKey +
            "' params='" + $paramKeys + "'")
        os.c_fflush(os.get_stderr())
    return uirCoreMangleOverloadName(baseSym, retKey, paramKeys)

fn uirCoreCountFnDeclsMangledId(rootId: AstNodeId): int32 =
    if !astNodeIdValid(rootId):
        return 0
    var total: int32 = 0
    for i in 0..<astKidCount(rootId):
        let nId: AstNodeId = astKidAt(rootId, i)
        if !astNodeIdValid(nId):
            continue
        if astNodeIsModuleOrStmtList(nId):
            total = total + uirCoreCountFnDeclsMangledId(nId)
        elif astNodeIsRoutineDecl(nId) && !uirCoreFuncSigHasUnresolvedGenericsId(nId):
            total = total + 1
    return total

fn uirCoreIndexFnDeclsMangledId(rootId: AstNodeId, overloaded: ptr,
                                outNames: var str[], outNodes: var int32[],
                                outFiles: var str[], nextIdx: var int32,
                                filePath: str) =
    let dbgDollarOverload: bool = envIsTrue "BACKEND_DEBUG_DOLLAR_OVERLOAD"
    if !astNodeIdValid(rootId):
        return
    for i in 0..<astKidCount(rootId):
        let nId: AstNodeId = astKidAt(rootId, i)
        if !astNodeIdValid(nId):
            continue
        if isEmpty(nId):
            continue
        let ownPath0: str = astNodeStrVal(nId)
        let nextFilePath: str = uirCoreNormalizeTopLevelPath(ownPath0, filePath)
        if astNodeIsModuleOrStmtList(nId):
            uirCoreIndexFnDeclsMangledId(nId, overloaded, outNames, outNodes, outFiles, nextIdx, nextFilePath)
            continue
        if !astNodeIsRoutineDecl(nId):
            continue
        if uirCoreFuncSigHasUnresolvedGenericsId(nId):
            continue
        let nameNodeId: AstNodeId = astKidAt(nId, 0)
        if !astNodeIdValid(nameNodeId):
            continue
        if !astNodeIsIdentOrSymbol(nameNodeId):
            continue
        let rawName: str = backendStripSpaces(astPlainName(nameNodeId))
        let fp: str = nextFilePath
        let symName: str = uirCoreMaybeMangleDupFnBase(rawName, fp)
        let baseSym: str = backendSanitizeLinkName(symName)
        let name: str = uirCoreIndexedFnDeclName(nId, rawName, overloaded, baseSym, symName, fp, dbgDollarOverload)

        if nextIdx >= outNames.len || nextIdx >= outNodes.len || nextIdx >= outFiles.len:
            panic "uirCore_builder: decl index overflow"
        outNames[nextIdx] = name
        outNodes[nextIdx] = int32(nId)
        outFiles[nextIdx] = fp
        nextIdx = nextIdx + 1

fn uirCoreShouldMangleOverloadFn(baseName0: str, overloaded: ptr): bool =
    let baseName: str = baseName0
    let _overloaded: ptr = overloaded
    if len(baseName) == 0 || baseName == "main":
        return false
    return uirCoreDupFnBasesHas(baseName)
