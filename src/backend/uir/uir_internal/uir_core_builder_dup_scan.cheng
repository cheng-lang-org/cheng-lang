# UIR core builder duplicate-name scan helpers (split from uir_core_builder).
import std/hashsets
import std/hashmaps
import std/seqs
import std/strutils
import stage1/ast
import stage1/token
import backend/uir/uir_internal/uir_core_types

fn uir_core_builder_dup_scan_add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn uir_core_builder_dup_scan_add(dst: var int32[], val: int32) =
    seqs.Add(dst, val)

fn dupScanStableText(s: str): str =
    let owned: str = uirCoreOwnStrSafe(s)
    if len(owned) > 0:
        return owned
    return s

fn dupScanStripSpaces(s: str): str =
    if len(s) == 0:
        return ""
    let n: int32 = len s
    if n > 0 && s[0] != ' ' && s[n - 1] != ' ':
        return s
    return strutils.Strip(s)

fn dupScanSeenIndex(nameIndex: hashmaps.HashMapStrInt, name: str): int32 =
    let idxPlus1: int32 = hashmaps.HashMapStrIntGet(nameIndex, name)
    if idxPlus1 <= 0:
        return -1
    return idxPlus1 - 1

fn dupScanNameTextId(nameNode: AstNodeId): int32 =
    if !astNodeIdValid(nameNode):
        return 0
    if !astNodeIsIdentOrSymbol(nameNode):
        return 0
    return astNodeIdentId(nameNode)

fn dupScanTextIdInList(values: int32[], textId: int32): bool =
    if textId <= 0 || values.len == 0:
        return false
    for i in 0..<values.len:
        if values[i] == textId:
            return true
    return false

fn uirCoreCollectGenericParamTextIdsId(genericsId: AstNodeId): int32[] =
    var out: int32[]
    out.cap = 4
    if !astNodeIdValid(genericsId) || isEmpty(genericsId):
        return out
    for i in 0..<astKidCount(genericsId):
        let n0: AstNodeId = astKidAt(genericsId, i)
        if !astNodeIdValid(n0) || isEmpty(n0):
            continue
        var nameNode: AstNodeId = astInvalidNodeId()
        if astNodeIsIdentDefs(n0) && astKidCount(n0) > 0:
            nameNode = astKidAt(n0, 0)
        elif astNodeIsIdentOrSymbol(n0):
            nameNode = n0
        elif astKidCount(n0) > 0:
            nameNode = astKidAt(n0, 0)
        let textId: int32 = dupScanNameTextId(nameNode)
        if textId > 0:
            uir_core_builder_dup_scan_add(out, textId)
    return out

fn uirCoreCollectGenericParamNamesId(genericsId: AstNodeId): str[] =
    let textIds: int32[] = uirCoreCollectGenericParamTextIdsId(genericsId)
    var out: str[]
    out.cap = textIds.len
    for i in 0..<textIds.len:
        let textId: int32 = textIds[i]
        if textId > 0:
            let nm: str = tokenTextById(textId)
            if len(nm) > 0:
                uir_core_builder_dup_scan_add(out, dupScanStableText(nm))
    return out

fn uirCoreCollectGenericParamNames(generics: Node): str[] =
    return uirCoreCollectGenericParamNamesId(generics)

fn uirCoreTypeNodeHasGenericParamTextIdsId(typeNode0Id: AstNodeId, genericTextIds: int32[]): bool =
    if !astNodeIdValid(typeNode0Id) || genericTextIds.len == 0:
        return false
    var stack: int32[]
    stack.cap = 16
    uir_core_builder_dup_scan_add(stack, typeNode0Id)
    while stack.len > 0:
        let n: AstNodeId = stack[stack.len - 1]
        stack.len = stack.len - 1
        if !astNodeIdValid(n) || isEmpty(n):
            continue
        if astNodeIsIdentOrSymbol(n):
            let textId: int32 = astNodeIdentId(n)
            if dupScanTextIdInList(genericTextIds, textId):
                return true
        for ki in 0..<astKidCount(n):
            uir_core_builder_dup_scan_add(stack, astKidAt(n, ki))
    return false

fn uirCoreImplicitGenericTextId(id: int32): bool =
    if id <= 0:
        return false
    if tokenTextLen(id) != 1:
        return false
    let c: char = tokenTextByteAtId(id, 0)
    return c >= 'A' && c <= 'Z'

fn uirCoreTypeNodeHasImplicitGenericParamId(typeNode0Id: AstNodeId): bool =
    if !astNodeIdValid(typeNode0Id):
        return false
    var stack: int32[]
    stack.cap = 16
    uir_core_builder_dup_scan_add(stack, typeNode0Id)
    while stack.len > 0:
        let n: AstNodeId = stack[stack.len - 1]
        stack.len = stack.len - 1
        if !astNodeIdValid(n) || isEmpty(n):
            continue
        if astNodeIsIdentOrSymbol(n):
            if uirCoreImplicitGenericTextId(astNodeIdentId(n)):
                return true
        for ki in 0..<astKidCount(n):
            uir_core_builder_dup_scan_add(stack, astKidAt(n, ki))
    return false

fn uirCoreTypeNodeHasGenericParamId(typeNode0Id: AstNodeId, genericNames: str[]): bool =
    if !astNodeIdValid(typeNode0Id) || genericNames.len == 0:
        return false
    var stack: int32[]
    stack.cap = 16
    uir_core_builder_dup_scan_add(stack, typeNode0Id)
    while stack.len > 0:
        let n: AstNodeId = stack[stack.len - 1]
        stack.len = stack.len - 1
        if !astNodeIdValid(n) || isEmpty(n):
            continue
        if astNodeIsIdentOrSymbol(n):
            let nm: str = dupScanStripSpaces(astPlainName(n))
            if len(nm) > 0:
                for gi in 0..<genericNames.len:
                    if nm == genericNames[gi]:
                        return true
        for ki in 0..<astKidCount(n):
            uir_core_builder_dup_scan_add(stack, astKidAt(n, ki))
    return false

fn uirCoreTypeNodeHasGenericParam(typeNode0: Node, genericNames: str[]): bool =
    return uirCoreTypeNodeHasGenericParamId(typeNode0, genericNames)

fn uirCoreFuncSigHasUnresolvedGenericsId(fnNodeId: AstNodeId): bool =
    if !astNodeIdValid(fnNodeId) || astKidCount(fnNodeId) <= 2:
        return false
    let retNode: AstNodeId = (astKidCount(fnNodeId) > 2) ? astKidAt(fnNodeId, 2) : astInvalidNodeId()
    let paramsNode: AstNodeId = (astKidCount(fnNodeId) > 1) ? astKidAt(fnNodeId, 1) : astInvalidNodeId()
    let genNode: AstNodeId = (astKidCount(fnNodeId) > 4) ? astKidAt(fnNodeId, 4) : astInvalidNodeId()

    if astNodeIdValid(genNode) && !isEmpty(genNode) && astKidCount(genNode) > 0:
        # Generic bodies must be monomorphized before lowering, even when the
        # type params are not spelled back into the normalized signature.
        return true
        let genTextIds: int32[] = uirCoreCollectGenericParamTextIdsId(genNode)
        if genTextIds.len == 0:
            return false
        if astNodeIdValid(retNode) && !isEmpty(retNode):
            if uirCoreTypeNodeHasGenericParamTextIdsId(retNode, genTextIds):
                return true
        if astNodeIdValid(paramsNode) && astNodeIsFormalParams(paramsNode):
            for pi in 0..<astKidCount(paramsNode):
                let defs: AstNodeId = astKidAt(paramsNode, pi)
                if astNodeIdValid(defs) && astNodeIsIdentDefs(defs) && astKidCount(defs) > 1:
                    let tn: AstNodeId = astKidAt(defs, 1)
                    if astNodeIdValid(tn) && !isEmpty(tn):
                        if uirCoreTypeNodeHasGenericParamTextIdsId(tn, genTextIds):
                            return true
        return false

    # Implicit generic sugar omits the explicit generic parameter list, so
    # treat bare single-letter uppercase type identifiers in the signature as
    # unresolved generic params as well.
    if astNodeIdValid(retNode) && !isEmpty(retNode):
        if uirCoreTypeNodeHasImplicitGenericParamId(retNode):
            return true
    if astNodeIdValid(paramsNode) && astNodeIsFormalParams(paramsNode):
        for pi in 0..<astKidCount(paramsNode):
            let defs: AstNodeId = astKidAt(paramsNode, pi)
            if astNodeIdValid(defs) && astNodeIsIdentDefs(defs) && astKidCount(defs) > 1:
                let tn: AstNodeId = astKidAt(defs, 1)
                if astNodeIdValid(tn) && !isEmpty(tn):
                    if uirCoreTypeNodeHasImplicitGenericParamId(tn):
                        return true
    return false

fn uirCoreFuncSigHasUnresolvedGenerics(fnNode: Node): bool =
    return uirCoreFuncSigHasUnresolvedGenericsId(fnNode)

fn uirCoreComputeDuplicateFnBasesId(rootId: AstNodeId, overloaded: ptr = nil): hashsets.HashSetStr =
    let _overloaded: ptr = overloaded
    var dup: hashsets.HashSetStr = hashsets.HashSetStrInit(256)
    if !astNodeIdValid(rootId):
        return dup
    let rootKids: int32 = astKidCount(rootId)
    let mapCap: int32 = (rootKids > 128) ? (rootKids * 2) : 256
    var nameIndex: hashmaps.HashMapStrInt = hashmaps.HashMapStrIntInit(mapCap)
    var seenCounts: int32[]
    var stack: int32[]
    stack.cap = (rootKids > 0) ? rootKids : 8
    uir_core_builder_dup_scan_add(stack, rootId)
    while stack.len > 0:
        let top: AstNodeId = stack[stack.len - 1]
        stack.len = stack.len - 1
        if !astNodeIdValid(top) || isEmpty(top):
            continue
        if !astNodeIsRoutineDecl(top):
            # Walk wrapper/container nodes recursively but never descend into
            # function bodies.
            for j in 0..<astKidCount(top):
                uir_core_builder_dup_scan_add(stack, astKidAt(top, j))
            continue
        let n: AstNodeId = top
        let nameNode: AstNodeId = astKidAt(n, 0)
        if !astNodeIdValid(nameNode) || !astNodeIsIdentOrSymbol(nameNode):
            continue
        let textId: int32 = dupScanNameTextId(nameNode)
        var rawName: str = dupScanStripSpaces(astPlainName(nameNode))
        if len(rawName) == 0 && textId > 0:
            rawName = dupScanStripSpaces(tokenTextById(textId))
        if rawName == "main":
            continue
        if uirCoreFuncSigHasUnresolvedGenericsId(n):
            continue
        if len(rawName) == 0:
            continue
        let stableRawName: str = dupScanStableText(rawName)
        let idx: int32 = dupScanSeenIndex(nameIndex, rawName)
        if idx < 0:
            let newIdx: int32 = seenCounts.len
            uir_core_builder_dup_scan_add(seenCounts, 1)
            hashmaps.HashMapStrIntPut(nameIndex, stableRawName, newIdx + 1)
            continue
        if idx >= 0 && idx < seenCounts.len:
            let next: int32 = seenCounts[idx] + 1
            seenCounts[idx] = next
            if next > 1:
                hashsets.HashSetStrAdd(dup, stableRawName)
            continue
    return dup

fn uirCoreComputeDuplicateFnBases(root: Node, overloaded: ptr = nil): hashsets.HashSetStr =
    return uirCoreComputeDuplicateFnBasesId(root, overloaded)

fn uirCoreComputeDuplicateGlobalNamesId(rootId: AstNodeId): hashsets.HashSetStr =
    var dup: hashsets.HashSetStr = hashsets.HashSetStrInit(256)
    if !astNodeIdValid(rootId):
        return dup
    let rootKids: int32 = astKidCount(rootId)
    let mapCap: int32 = (rootKids > 128) ? (rootKids * 2) : 256
    var nameIndex: hashmaps.HashMapStrInt = hashmaps.HashMapStrIntInit(mapCap)
    var seenCounts: int32[]
    for i in 0..<rootKids:
        let top: AstNodeId = astKidAt(rootId, i)
        if !astNodeIdValid(top) || isEmpty(top):
            continue
        var n: AstNodeId = top
        if !astNodeIsVar(n) && !astNodeIsLet(n) && !astNodeIsConst(n):
            # Keep a shallow fallback for wrapper nodes.
            if astKidCount(top) <= 0:
                continue
            n = astKidAt(top, 0)
            if !astNodeIdValid(n) || isEmpty(n):
                continue
            if !astNodeIsVar(n) && !astNodeIsLet(n) && !astNodeIsConst(n):
                continue
        var pat: AstNodeId = astInvalidNodeId()
        if astKidCount(n) > 0:
            pat = astKidAt(n, 0)
        var nameNode: AstNodeId = pat
        if astNodeIdValid(pat) && astNodeIsPattern(pat) && astKidCount(pat) > 0:
            nameNode = astKidAt(pat, 0)
        if !astNodeIdValid(nameNode) || !astNodeIsIdentOrSymbol(nameNode):
            continue
        let textId: int32 = dupScanNameTextId(nameNode)
        var rawName: str = dupScanStripSpaces(astPlainName(nameNode))
        if len(rawName) == 0 && textId > 0:
            rawName = dupScanStripSpaces(tokenTextById(textId))
        if len(rawName) == 0:
            continue
        let stableRawName: str = dupScanStableText(rawName)
        let idx: int32 = dupScanSeenIndex(nameIndex, rawName)
        if idx < 0:
            let newIdx: int32 = seenCounts.len
            uir_core_builder_dup_scan_add(seenCounts, 1)
            hashmaps.HashMapStrIntPut(nameIndex, stableRawName, newIdx + 1)
            continue
        if idx >= 0 && idx < seenCounts.len:
            let next: int32 = seenCounts[idx] + 1
            seenCounts[idx] = next
            if next > 1:
                hashsets.HashSetStrAdd(dup, stableRawName)
    return dup

fn uirCoreComputeDuplicateGlobalNames(root: Node): hashsets.HashSetStr =
    return uirCoreComputeDuplicateGlobalNamesId(root)
