# Thin facade for current-source file pipeline entrypoints.
import std/result
import std/system
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_file_parse_pipeline

fn uirCoreFilePipelineBuildModuleFromFileStage1(inPath: str, target: str): Result[UirCoreModule] =
    return uirCoreFileParsePipelineBuildModuleFromFileStage1(inPath, target)

fn uirCoreFilePipelineBuildModuleFromFileStage1Default(inPath: str): Result[UirCoreModule] =
    return uirCoreFileParsePipelineBuildModuleFromFileStage1Default(inPath)

fn uirCoreFilePipelineBuildModuleFromFileStage1OrPanic(inPath: str, target: str): UirCoreModule =
    return uirCoreFileParsePipelineBuildModuleFromFileStage1OrPanic(inPath, target)

fn uirCoreFilePipelineBuildModuleFromFileStage1OrPanicDefault(inPath: str): UirCoreModule =
    return uirCoreFileParsePipelineBuildModuleFromFileStage1OrPanicDefault(inPath)

fn uirCoreFilePipelineBuildModuleFromFileStage1RawOrPanic(inRaw: cstring, targetRaw: cstring): UirCoreModule =
    return uirCoreFileParsePipelineBuildModuleFromFileStage1RawOrPanic(inRaw, targetRaw)

fn uirCoreFilePipelineBuildModuleFromFileStage1TargetFirst(target: str, inPath: str): Result[UirCoreModule] =
    return uirCoreFileParsePipelineBuildModuleFromFileStage1TargetFirst(target, inPath)

fn uirCoreFilePipelineBuildModuleFromFileStage1TargetFirstOrPanic(target: str, inPath: str): UirCoreModule =
    return uirCoreFileParsePipelineBuildModuleFromFileStage1TargetFirstOrPanic(target, inPath)

fn uirCoreFilePipelineBuildModuleFromFileStage1HostOnlyOrPanic(inPath: str): UirCoreModule =
    return uirCoreFileParsePipelineBuildModuleFromFileStage1HostOnlyOrPanic(inPath)
