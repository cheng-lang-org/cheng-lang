# Shared builder-local current-root/type-decl/generic-inst helpers split from uir_core_builder.
import std/os
import std/result
import std/strutils
import std/seqs
import std/hashmaps
import std/rawmem_support
import stage1/ast
import stage1/monomorphize
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_symbol_state
import backend/uir/uir_internal/uir_core_builder_current_root_cache
import backend/uir/uir_internal/uir_core_builder_text_helpers
import backend/uir/uir_internal/uir_core_builder_string_utils
import backend/uir/uir_internal/uir_core_builder_type_key_helpers
import backend/uir/uir_internal/uir_core_builder_loose_type_key_helpers
import backend/uir/uir_internal/uir_core_builder_object_synthesis

fn uir_core_builder_current_root_type_decl_helpers_add(dst: var Node[], val: Node) =
    seqs.add(dst, val)

fn uir_core_builder_current_root_type_decl_helpers_add(dst: var str[], val: str) =
    seqs.add(dst, val)

fn uirCoreTypeKeyStripIterWrappers(typeKey0: str): str =
    var key: str = backendStripSpaces(typeKey0)
    if len(key) == 0:
        return ""
    while true:
        if uirCoreStrStartsWith(key, "ref_"):
            key = str(rawmemPtrAdd(rawmemAsVoid(key), 4))
            continue
        if uirCoreStrStartsWith(key, "var_ref_"):
            key = str(rawmemPtrAdd(rawmemAsVoid(key), 8))
            continue
        if uirCoreStrStartsWith(key, "var_"):
            key = str(rawmemPtrAdd(rawmemAsVoid(key), 4))
            continue
        if uirCoreStrStartsWith(key, "ptr_"):
            key = str(rawmemPtrAdd(rawmemAsVoid(key), 4))
            continue
        break
    return key

fn uirCoreTypeKeyBaseName(typeKey0: str): str =
    let key: str = backendStripSpaces(typeKey0)
    if len(key) == 0:
        return ""
    let __for_start_i = len(key) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if key[i] == '.':
            return str(rawmemPtrAdd(rawmemAsVoid(key), i + 1))
    return key

fn uirCoreTypeDeclCoreNode(td: Node): Node =
    if !astNodeIdValid(td) || nodeKind(td) != nkTypeDecl || kidCount(td) < 2:
        return astInvalidNodeId()
    var defCore: Node = kid(td, 1)
    while astNodeIdValid(defCore) &&
          (nodeKind(defCore) == nkRefTy || nodeKind(defCore) == nkPtrTy || nodeKind(defCore) == nkVarTy) &&
          kidCount(defCore) > 0:
        defCore = kid(defCore, 0)
    return defCore

fn uirCoreTypeDeclIsObjectLike(td: Node): bool =
    let defCore: Node = uirCoreTypeDeclCoreNode(td)
    if !astNodeIdValid(defCore):
        return false
    let kind: NodeKind = nodeKind(defCore)
    return kind == nkObjectDecl || kind == nkRecList

fn uirCoreObjTypeFromCurrentRootDecl(module: UirCoreModule, typeKey0: str): str =
    if (module == nil) || !uirCoreCurrentParsedRootValid():
        return ""
    var key: str = uirCoreTypeKeyStripIterWrappers(backendStripSpaces(typeKey0))
    if len(key) == 0:
        return ""
    let canon: str = uirCoreObjAliasCanon(key)
    if len(canon) > 0:
        key = canon
    let existingObj: str = uirCoreObjTypeFromTypeKey(module, key)
    if len(existingObj) > 0:
        return existingObj
    var td: Node = uirCoreFindTypeDeclByName(uirCore_currentParsedRoot, key)
    if !astNodeIdValid(td):
        let baseKey: str = uirCoreTypeKeyBaseName(key)
        if len(baseKey) > 0 && !(baseKey == key):
            td = uirCoreFindTypeDeclByName(uirCore_currentParsedRoot, baseKey)
            if astNodeIdValid(td):
                key = baseKey
    if !astNodeIdValid(td):
        return ""
    if uirCoreTypeDeclIsObjectLike(td):
        return key
    let defCore: Node = uirCoreTypeDeclCoreNode(td)
    if !astNodeIdValid(defCore):
        return ""
    let rhsObj: str = typeNodeObjTypeName(module, defCore)
    if len(rhsObj) > 0:
        return rhsObj
    var rhsKey: str = ""
    if nodeKind(defCore) == nkDotExpr && kidCount(defCore) > 1:
        rhsKey = backendStripSpaces(typeKey(kid(defCore, 1)))
        if len(rhsKey) == 0:
            rhsKey = backendStripSpaces(plainName(kid(defCore, 1)))
    else:
        rhsKey = backendStripSpaces(typeKey(defCore))
        if len(rhsKey) == 0:
            rhsKey = uirCoreTypeKeyFromNodeLoose(defCore)
        if len(rhsKey) == 0:
            rhsKey = backendStripSpaces(plainName(defCore))
    if len(rhsKey) == 0 || rhsKey == key:
        return ""
    return uirCoreObjTypeFromTypeKey(module, rhsKey)

fn uirCoreFieldTypeKeyFromTypeDecl(module: UirCoreModule, td: Node, fieldName0: str): str =
    if (module == nil) || !astNodeIdValid(td) || nodeKind(td) != nkTypeDecl || kidCount(td) < 2:
        return ""
    let fieldName: str = backendStripSpaces(fieldName0)
    if len(fieldName) == 0:
        return ""
    var defCore: Node = kid(td, 1)
    while astNodeIdValid(defCore) &&
          (nodeKind(defCore) == nkRefTy || nodeKind(defCore) == nkPtrTy || nodeKind(defCore) == nkVarTy) &&
          kidCount(defCore) > 0:
        defCore = kid(defCore, 0)
    var recList: Node = astInvalidNodeId()
    if astNodeIdValid(defCore) && nodeKind(defCore) == nkObjectDecl:
        if kidCount(defCore) > 1:
            recList = kid(defCore, 1)
    elif astNodeIdValid(defCore) && nodeKind(defCore) == nkRecList:
        recList = defCore
    if !astNodeIdValid(recList) || nodeKind(recList) != nkRecList:
        return ""
    for i in 0..<kidCount(recList):
        let item: Node = kid(recList, i)
        if !astNodeIdValid(item) || nodeKind(item) != nkIdentDefs || kidCount(item) < 2:
            continue
        let fieldNameNode: Node = kid(item, 0)
        if !astNodeIdValid(fieldNameNode) || (nodeKind(fieldNameNode) != nkIdent && nodeKind(fieldNameNode) != nkSymbol):
            continue
        if backendStripSpaces(plainName(fieldNameNode)) != fieldName:
            continue
        let fieldTypeNode: Node = kid(item, 1)
        if !astNodeIdValid(fieldTypeNode) || nodeKind(fieldTypeNode) == nkEmpty:
            return ""
        let looseFieldTypeKey: str = uirCoreTypeKeyFromNodeLoose(fieldTypeNode)
        var fieldTypeKey: str = ""
        if nodeKind(fieldTypeNode) == nkDotExpr && kidCount(fieldTypeNode) > 1:
            fieldTypeKey = backendStripSpaces(typeKey(kid(fieldTypeNode, 1)))
        else:
            fieldTypeKey = backendStripSpaces(typeKey(fieldTypeNode))
        if len(fieldTypeKey) == 0:
            fieldTypeKey = looseFieldTypeKey
        if len(fieldTypeKey) == 0:
            fieldTypeKey = uirCoreTypeKeyFallbackText(fieldTypeNode)
        if len(fieldTypeKey) == 0:
            fieldTypeKey = backendStripSpaces(plainName(fieldTypeNode))
        let objFieldType: str = typeNodeObjTypeName(module, fieldTypeNode)
        if len(fieldTypeKey) == 0 && nodeKind(fieldTypeNode) == nkBracketExpr:
            let synthFieldKey: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(module, fieldTypeNode)
            if len(synthFieldKey) > 0:
                fieldTypeKey = synthFieldKey
        if objFieldType == "seq" && uirCoreStrStartsWith(looseFieldTypeKey, "seq_"):
            fieldTypeKey = looseFieldTypeKey
        elif objFieldType == "Table" && uirCoreStrStartsWith(looseFieldTypeKey, "Table_"):
            fieldTypeKey = looseFieldTypeKey
        return backendStripSpaces(fieldTypeKey)
    return ""

fn uirCoreFieldTypeKeyFromCurrentRoot(module: UirCoreModule, parentType0: str, fieldName0: str): str =
    if (module == nil) || !uirCoreCurrentParsedRootValid():
        return ""
    let fieldName: str = backendStripSpaces(fieldName0)
    if len(fieldName) == 0:
        return ""
    var parentType: str = backendStripSpaces(parentType0)
    if len(parentType) == 0:
        return ""
    parentType = uirCoreStripRefVarKeyOnce(parentType)
    parentType = uirCoreStripPtrKeyOnce(parentType)
    let parentObj: str = uirCoreObjTypeFromTypeKey(module, parentType)
    if len(parentObj) > 0:
        parentType = parentObj
    let parentCanon: str = uirCoreObjAliasCanon(parentType)
    if len(parentCanon) > 0:
        parentType = parentCanon
    if uirCore_fieldTypeKeyFromCurrentRoot_cache_module != module ||
       uirCore_fieldTypeKeyFromCurrentRoot_cache_root != uirCore_currentParsedRoot:
        uirCoreFieldTypeKeyFromCurrentRootCacheReset(module, uirCore_currentParsedRoot)
    var cachedFound: bool = false
    let cached: str = uirCoreFieldTypeKeyFromCurrentRootCacheGet(module, uirCore_currentParsedRoot, parentType, fieldName, cachedFound)
    if cachedFound:
        return cached
    let td: Node = uirCoreFindTypeDeclByName(uirCore_currentParsedRoot, parentType)
    if !astNodeIdValid(td):
        uirCoreFieldTypeKeyFromCurrentRootCachePut(module, uirCore_currentParsedRoot, parentType, fieldName, "")
        return ""
    let out: str = uirCoreFieldTypeKeyFromTypeDecl(module, td, fieldName)
    uirCoreFieldTypeKeyFromCurrentRootCachePut(module, uirCore_currentParsedRoot, parentType, fieldName, out)
    return out

fn uirCoreFindGenericTypeDeclForInstName(root: Node, targetInstName: str, rawArgs: Node[]): Node =
    if !astNodeIdValid(root) || len(targetInstName) == 0:
        return astInvalidNodeId()
    if nodeKind(root) == nkTypeDecl && kidCount(root) > 2:
        let generics: Node = kid(root, 2)
        if astNodeIdValid(generics) && nodeKind(generics) == nkGenericParams && kidCount(generics) > 0 && kidCount(root) > 0:
            let nameNode: Node = kid(root, 0)
            if astNodeIdValid(nameNode) && (nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol):
                let candName: str = backendStripSpaces(plainName(nameNode))
                if len(candName) > 0:
                    let candInstName: str = mangleInstance(candName, rawArgs)
                    if candInstName == targetInstName:
                        return root
    for i in 0..<kidCount(root):
        let found: Node = uirCoreFindGenericTypeDeclForInstName(kid(root, i), targetInstName, rawArgs)
        if astNodeIdValid(found):
            return found
    return astInvalidNodeId()

fn uirCoreDebugRootGenericTypeSummary(root: Node, limit: int32 = 8): str =
    if !astNodeIdValid(root) || limit <= 0:
        return ""
    var queue: Node[]
    uir_core_builder_current_root_type_decl_helpers_add(queue, root)
    var parts: str[] = []
    while queue.len > 0:
        let nId: Node = queue[queue.len - 1]
        queue.len = queue.len - 1
        if !astNodeIdValid(nId):
            continue
        if nodeKind(nId) == nkTypeDecl && kidCount(nId) > 2:
            let gpId: Node = kid(nId, 2)
            if astNodeIdValid(gpId) && nodeKind(gpId) == nkGenericParams && kidCount(gpId) > 0:
                var nm: str = ""
                if kidCount(nId) > 0:
                    let nameId: Node = kid(nId, 0)
                    if astNodeIdValid(nameId) && (nodeKind(nameId) == nkIdent || nodeKind(nameId) == nkSymbol):
                        nm = backendStripSpaces(plainName(nameId))
                if len(nm) == 0:
                    nm = "<anon>"
                uir_core_builder_current_root_type_decl_helpers_add(parts, nm + "#" + intToStr(kidCount(gpId)))
                if parts.len >= limit:
                    break
        for i in 0..<kidCount(nId):
            uir_core_builder_current_root_type_decl_helpers_add(queue, kid(nId, i))
    return strutil.join(parts, ",")

fn uirCoreEnsureGenericTypeInstFromCurrentRoot(module: UirCoreModule, typeNode: Node): str =
    if (module == nil) || !uirCoreCurrentParsedRootValid() || !astNodeIdValid(typeNode):
        return ""
    if nodeKind(typeNode) != nkBracketExpr || kidCount(typeNode) <= 0:
        return ""
    let dbgGenericSynth: bool = envIsTrue "BACKEND_DEBUG_GENERIC_TYPE_SYNTH"
    let base: Node = kid(typeNode, 0)
    let baseName: str = typeNodeCanonicalName(base)
    if baseName == "seq" || baseName == "seq_fixed" || baseName == "Table" ||
       baseName == "Option" || baseName == "Result" || baseName == "SeqUninit" ||
       baseName == "__cheng_tables_Entry" || baseName == "array":
        return ""
    let genNode: Node = (len(baseName) > 0) ? findGenericTypeDecl(uirCore_currentParsedRoot, baseName) : astInvalidNodeId()
    var rawArgs: Node[]
    for ai in 1..<kidCount(typeNode):
        let arg: Node = kid(typeNode, ai)
        if astNodeIdValid(arg) && nodeKind(arg) != nkEmpty:
            uir_core_builder_current_root_type_decl_helpers_add(rawArgs, arg)
    if rawArgs.len == 0:
        return ""
    let targetInstName0: str = uirCoreTypeKeyFromNodeLoose(typeNode)
    let targetInstName: str = len(targetInstName0) > 0 ? targetInstName0 : uirCoreLegacyGenericBracketInstName(typeNode)
    var actualGenNode: Node = genNode
    if stage1AstRefNonNil(actualGenNode) && len(targetInstName) > 0:
        let probeName: str = mangleInstance(baseName, rawArgs)
        if probeName != targetInstName:
            actualGenNode = astInvalidNodeId()
    if !stage1AstRefNonNil(actualGenNode) && len(targetInstName) > 0:
        actualGenNode = uirCoreFindGenericTypeDeclForInstName(uirCore_currentParsedRoot, targetInstName, rawArgs)
    if dbgGenericSynth:
        let genFound: str = stage1AstRefNonNil(genNode) ? "1" : "0"
        let actualFound: str = stage1AstRefNonNil(actualGenNode) ? "1" : "0"
        let rootSummary: str = !stage1AstRefNonNil(actualGenNode) ? uirCoreDebugRootGenericTypeSummary(uirCore_currentParsedRoot) : ""
        os.writeLine(os.get_stderr(),
                     "[backend] debugGenericSynth: base=" + baseName +
                     " target=" + targetInstName +
                     " genFound=" + genFound +
                     " actualFound=" + actualFound +
                     (len(rootSummary) > 0 ? " root_generics=" + rootSummary : ""))
        os.c_fflush(os.get_stderr())
    if !stage1AstRefNonNil(actualGenNode):
        return ""
    var generics: Node = astInvalidNodeId()
    if kidCount(actualGenNode) > 2:
        generics = kid(actualGenNode, 2)
    var mapNames: str[4]
    var mapTypes: Node[4]
    collectTypeArgMap(generics, rawArgs, &mapNames, &mapTypes)
    var instArgs: Node[4]
    buildFullTypeArgs(generics, mapNames, mapTypes, rawArgs, instArgs)
    var instName: str = len(targetInstName) > 0 ? targetInstName : mangleInstance(baseName, instArgs)
    if len(instName) == 0:
        return ""
    if uirCoreHasObjType(module, instName):
        return instName
    let instCanon0: str = uirCoreObjAliasCanon(instName)
    if len(instCanon0) > 0 && uirCoreHasObjType(module, instCanon0):
        return instCanon0
    var defNode: Node = astInvalidNodeId()
    if kidCount(actualGenNode) > 1:
        defNode = kid(actualGenNode, 1)
    if !astNodeIdValid(defNode) || nodeKind(defNode) == nkEmpty:
        return ""
    let replacedDef: Node = replaceTypeVars(defNode, mapNames, mapTypes)
    if !astNodeIdValid(replacedDef) || nodeKind(replacedDef) == nkEmpty:
        return ""
    var decl: Node = newNode(nkTypeDecl, nodePos(actualGenNode))
    nodeSetStrVal(decl, nodeStrVal(actualGenNode))
    addSon(decl, newIdent(instName, nodePos(typeNode)))
    addSon(decl, replacedDef)
    addSon(decl, newNode(nkEmpty, nodePos(actualGenNode)))
    addSon(decl, newNode(nkEmpty, nodePos(actualGenNode)))
    var pragmaNode: Node = astInvalidNodeId()
    if kidCount(actualGenNode) > 4:
        pragmaNode = kid(actualGenNode, 4)
    if astNodeIdValid(pragmaNode) && nodeKind(pragmaNode) != nkEmpty:
        addSon(decl, cloneTree(pragmaNode))
    else:
        addSon(decl, newNode(nkEmpty, nodePos(actualGenNode)))
    let consumeRes: Result[bool] = uirCoreConsumeTypeDecl(module, decl)
    if dbgGenericSynth:
        os.writeLine(os.get_stderr(),
                     "[backend] debugGenericSynth: consume_ok=" + (uirCoreResultBoolIsOk(consumeRes) ? "1" : "0") +
                     " pending=" + ((uirCoreResultBoolIsOk(consumeRes) && uirCoreResultBoolValue(consumeRes)) ? "1" : "0"))
        os.c_fflush(os.get_stderr())
    if !uirCoreResultBoolIsOk(consumeRes):
        return ""
    if uirCoreResultBoolValue(consumeRes):
        return ""
    if uirCoreHasObjType(module, instName):
        if dbgGenericSynth:
            os.writeLine(os.get_stderr(),
                         "[backend] debugGenericSynth: obj_ready=1 name=" + instName)
            os.c_fflush(os.get_stderr())
        return instName
    let instCanon: str = uirCoreObjAliasCanon(instName)
    if len(instCanon) > 0 && uirCoreHasObjType(module, instCanon):
        if dbgGenericSynth:
            os.writeLine(os.get_stderr(),
                         "[backend] debugGenericSynth: obj_ready=1 canon=" + instCanon)
            os.c_fflush(os.get_stderr())
        return instCanon
    if dbgGenericSynth:
        os.writeLine(os.get_stderr(),
                     "[backend] debugGenericSynth: obj_ready=0 name=" + instName)
        os.c_fflush(os.get_stderr())
    return ""

fn uirCoreRecoverLegacyGenericObjKey(module: UirCoreModule, key0: str): str =
    if (module == nil):
        return ""
    var key: str = backendStripSpaces(key0)
    if len(key) == 0:
        return ""
    if uirCoreStrStartsWith(key, "var_ref_"):
        key = str(rawmemPtrAdd(rawmemAsVoid(key), 8))
    elif uirCoreStrStartsWith(key, "var_"):
        key = str(rawmemPtrAdd(rawmemAsVoid(key), 4))
    elif uirCoreStrStartsWith(key, "ref_"):
        key = str(rawmemPtrAdd(rawmemAsVoid(key), 4))
    elif uirCoreStrStartsWith(key, "ptr_"):
        key = str(rawmemPtrAdd(rawmemAsVoid(key), 4))
    var innerKey: str = ""
    if uirCoreStrStartsWith(key, "seq_fixed_"):
        innerKey = str(rawmemPtrAdd(rawmemAsVoid(key), 10))
    elif uirCoreStrStartsWith(key, "seq_"):
        innerKey = str(rawmemPtrAdd(rawmemAsVoid(key), 4))
    if len(innerKey) == 0:
        return ""
    if uirCoreStrStartsWith(innerKey, "Result_") && ensureResultObjType(module, innerKey):
        return innerKey
    if uirCoreStrStartsWith(innerKey, "Option_") && ensureOptionObjType(module, innerKey):
        return innerKey
    if uirCoreStrStartsWith(innerKey, "SeqUninit_") && ensureSeqUninitObjType(module, innerKey):
        return innerKey
    if uirCoreStrStartsWith(innerKey, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, innerKey):
        return innerKey
    return ""

fn uirCoreTypeKeyIsTableIter(typeKey0: str): bool =
    let key: str = uirCoreTypeKeyBaseName(uirCoreTypeKeyStripIterWrappers(typeKey0))
    return (key == "Table") || uirCoreStrStartsWith(key, "Table_")

fn uirCoreTypeKeyTableValKey(typeKey0: str): str =
    let key: str = uirCoreTypeKeyBaseName(uirCoreTypeKeyStripIterWrappers(typeKey0))
    if uirCoreStrStartsWith(key, "Table_"):
        return str(rawmemPtrAdd(rawmemAsVoid(key), 6))
    return ""

fn uirCoreHashMapIterFlavorFromTypeKey(typeKey0: str): int32 =
    let key: str = uirCoreTypeKeyBaseName(uirCoreTypeKeyStripIterWrappers(typeKey0))
    if (key == "HashMapStrInt"):
        return 1
    if (key == "HashMapStrSeqInt"):
        return 2
    if (key == "HashMapPtrInt"):
        return 3
    let __for_start_i = len(key) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if key[i] == '_':
            let suffix: str = str(rawmemPtrAdd(rawmemAsVoid(key), i + 1))
            if (suffix == "HashMapStrInt"):
                return 1
            if (suffix == "HashMapStrSeqInt"):
                return 2
            if (suffix == "HashMapPtrInt"):
                return 3
    return 0
