# Shared builder-local current-root/type-decl/generic-inst helpers split from uir_core_builder.
import std/os
import std/result
import std/strutils
import std/seqs
import std/hashmaps
import std/rawmem_support
import stage1/ast
import stage1/monomorphize
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_base_helpers
import backend/uir/uir_internal/uir_core_builder_symbol_state
import backend/uir/uir_internal/uir_core_builder_current_root_cache
import backend/uir/uir_internal/uir_core_builder_type_surface_helpers
import backend/uir/uir_internal/uir_core_builder_object_synthesis

fn uir_core_builder_current_root_type_decl_helpers_add(dst: var Node[], val: Node) =
    seqs.Add(dst, val)

fn uir_core_builder_current_root_type_decl_helpers_add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn uirCoreTypeKeyStripIterWrappers(typeKey0: str): str =
    var key: str = uirCoreParamKeyCanon(typeKey0)
    if len(key) == 0:
        return ""
    while true:
        if uirCoreKeyHasRefPrefix(key):
            key = rawmemStrFromOffset(key, 4)
            continue
        if uirCoreKeyHasVarRefPrefix(key):
            key = rawmemStrFromOffset(key, 8)
            continue
        if uirCoreKeyHasVarPrefix(key):
            key = rawmemStrFromOffset(key, 4)
            continue
        if uirCoreKeyHasPtrPrefix(key):
            key = rawmemStrFromOffset(key, 4)
            continue
        break
    return key

fn uirCoreTypeKeyBaseName(typeKey0: str): str =
    let key: str = backendStripSpaces(typeKey0)
    if len(key) == 0:
        return ""
    let __for_start_i = len(key) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if key[i] == '.':
            return rawmemStrFromOffset(key, i + 1)
    return key

fn uirCoreTypeDeclCoreNode(td: Node): Node =
    if !astNodeIdValid(td) || !astNodeIsTypeDecl(td) || kidCount(td) < 2:
        return astInvalidNodeId()
    var defCore: Node = kid(td, 1)
    while astNodeIdValid(defCore) &&
          (astNodeIsRefTy(defCore) || astNodeIsPtrTy(defCore) || astNodeIsVarTy(defCore)) &&
          kidCount(defCore) > 0:
        defCore = kid(defCore, 0)
    return defCore

fn uirCoreTypeDeclIsObjectLike(td: Node): bool =
    let defCore: Node = uirCoreTypeDeclCoreNode(td)
    if !astNodeIdValid(defCore):
        return false
    return astNodeIsObjectDecl(defCore) || astNodeIsRecList(defCore)

fn uirCoreTypeDeclRhsKey(defCore: Node): str =
    if !astNodeIdValid(defCore):
        return ""
    if astNodeIsDotExpr(defCore) && kidCount(defCore) > 1:
        let rhsTypeKey: str = backendStripSpaces(typeKey(kid(defCore, 1)))
        if len(rhsTypeKey) > 0:
            return rhsTypeKey
        return backendStripSpaces(plainName(kid(defCore, 1)))
    let directKey: str = backendStripSpaces(typeKey(defCore))
    if len(directKey) > 0:
        return directKey
    let looseKey: str = uirCoreTypeKeyFromNodeLoose(defCore)
    if len(looseKey) > 0:
        return looseKey
    return backendStripSpaces(plainName(defCore))

fn uirCoreFieldTypeNodeDirectKey(fieldTypeNode: Node): str =
    if astNodeIsDotExpr(fieldTypeNode) && kidCount(fieldTypeNode) > 1:
        return backendStripSpaces(typeKey(kid(fieldTypeNode, 1)))
    let directKey: str = backendStripSpaces(typeKey(fieldTypeNode))
    if len(directKey) > 0:
        return directKey
    let looseKey: str = uirCoreTypeKeyFromNodeLoose(fieldTypeNode)
    if len(looseKey) > 0:
        return looseKey
    let fallbackKey: str = uirCoreTypeKeyFallbackText(fieldTypeNode)
    if len(fallbackKey) > 0:
        return fallbackKey
    return backendStripSpaces(plainName(fieldTypeNode))

fn uirCoreFieldTypeNodeResolvedKey(module: UirCoreModule, fieldTypeNode: Node,
                                   looseFieldTypeKey: str, objFieldType: str): str =
    if objFieldType == "seq" && uirCoreStrStartsWith(looseFieldTypeKey, "seq_"):
        return looseFieldTypeKey
    if objFieldType == "Table" && uirCoreStrStartsWith(looseFieldTypeKey, "Table_"):
        return looseFieldTypeKey
    let directFieldTypeKey: str = uirCoreFieldTypeNodeDirectKey(fieldTypeNode)
    if len(directFieldTypeKey) > 0:
        return backendStripSpaces(directFieldTypeKey)
    if astNodeIsBracketExpr(fieldTypeNode):
        return uirCoreEnsureGenericTypeInstFromCurrentRoot(module, fieldTypeNode)
    return ""

fn uirCoreTypeDeclNameOrAnon(nId: Node): str =
    if kidCount(nId) > 0:
        let nameId: Node = kid(nId, 0)
        if astNodeIdValid(nameId) && astNodeIsIdentOrSymbol(nameId):
            let nm: str = backendStripSpaces(plainName(nameId))
            if len(nm) > 0:
                return nm
    return "<anon>"

fn uirCoreTargetInstName(typeNode: Node, targetInstName0: str): str =
    if len(targetInstName0) > 0:
        return targetInstName0
    return uirCoreLegacyGenericBracketInstName(typeNode)

fn uirCoreDebugBool01(v: bool): str =
    return v ? "1" : "0"

fn uirCoreDebugRootSummaryIfMissing(actualGenNode: Node): str =
    if stage1AstRefNonNil(actualGenNode):
        return ""
    return uirCoreDebugRootGenericTypeSummary(uirCoreCurrentParsedRootGet())

fn uirCoreResolvedInstName(targetInstName: str, baseName: str, instArgs: Node[]): str =
    if len(targetInstName) > 0:
        return targetInstName
    return mangleInstance(baseName, instArgs)

fn uirCoreRecoverLegacyInnerKey(key: str): str =
    if uirCoreStrStartsWith(key, "seq_fixed_"):
        return rawmemStrFromOffset(key, 10)
    if uirCoreStrStartsWith(key, "seq_"):
        return rawmemStrFromOffset(key, 4)
    return ""

fn uirCoreObjTypeFromCurrentRootDecl(module: UirCoreModule, typeKey0: str): str =
    if (module == nil) || !uirCoreCurrentParsedRootValid():
        return ""
    let currentRoot: Node = uirCoreCurrentParsedRootGet()
    var key: str = uirCoreTypeKeyStripIterWrappers(backendStripSpaces(typeKey0))
    if len(key) == 0:
        return ""
    let canon: str = uirCoreObjAliasCanon(key)
    if len(canon) > 0:
        key = canon
    let existingObj: str = uirCoreObjTypeFromTypeKey(module, key)
    if len(existingObj) > 0:
        return existingObj
    var td: Node = uirCoreFindTypeDeclByName(currentRoot, key)
    if !astNodeIdValid(td):
        let baseKey: str = uirCoreTypeKeyBaseName(key)
        if len(baseKey) > 0 && !(baseKey == key):
            td = uirCoreFindTypeDeclByName(currentRoot, baseKey)
            if astNodeIdValid(td):
                key = baseKey
    if !astNodeIdValid(td):
        return ""
    if uirCoreTypeDeclIsObjectLike(td):
        return key
    let defCore: Node = uirCoreTypeDeclCoreNode(td)
    if !astNodeIdValid(defCore):
        return ""
    let rhsObj: str = typeNodeObjTypeName(module, defCore)
    if len(rhsObj) > 0:
        return rhsObj
    let rhsKey: str = uirCoreTypeDeclRhsKey(defCore)
    if len(rhsKey) == 0 || rhsKey == key:
        return ""
    return uirCoreObjTypeFromTypeKey(module, rhsKey)

fn uirCoreFieldTypeKeyFromTypeDecl(module: UirCoreModule, td: Node, fieldName0: str): str =
    if (module == nil) || !astNodeIdValid(td) || !astNodeIsTypeDecl(td) || kidCount(td) < 2:
        return ""
    let fieldName: str = backendStripSpaces(fieldName0)
    if len(fieldName) == 0:
        return ""
    var defCore: Node = kid(td, 1)
    while astNodeIdValid(defCore) &&
          (astNodeIsRefTy(defCore) || astNodeIsPtrTy(defCore) || astNodeIsVarTy(defCore)) &&
          kidCount(defCore) > 0:
        defCore = kid(defCore, 0)
    var recList: Node = astInvalidNodeId()
    if astNodeIdValid(defCore) && astNodeIsObjectDecl(defCore):
        if kidCount(defCore) > 1:
            recList = kid(defCore, 1)
    elif astNodeIdValid(defCore) && astNodeIsRecList(defCore):
        recList = defCore
    if !astNodeIdValid(recList) || !astNodeIsRecList(recList):
        return ""
    for i in 0..<kidCount(recList):
        let item: Node = kid(recList, i)
        if !astNodeIdValid(item) || !astNodeIsIdentDefs(item) || kidCount(item) < 2:
            continue
        let fieldNameNode: Node = kid(item, 0)
        if !astNodeIdValid(fieldNameNode) || !astNodeIsIdentOrSymbol(fieldNameNode):
            continue
        if backendStripSpaces(plainName(fieldNameNode)) != fieldName:
            continue
        let fieldTypeNode: Node = kid(item, 1)
        if !astNodeIdValid(fieldTypeNode) || astNodeIsEmpty(fieldTypeNode):
            return ""
        let looseFieldTypeKey: str = uirCoreTypeKeyFromNodeLoose(fieldTypeNode)
        let objFieldType: str = typeNodeObjTypeName(module, fieldTypeNode)
        return backendStripSpaces(uirCoreFieldTypeNodeResolvedKey(module, fieldTypeNode, looseFieldTypeKey, objFieldType))
    return ""

fn uirCoreFieldTypeKeyFromCurrentRoot(module: UirCoreModule, parentType0: str, fieldName0: str): str =
    if (module == nil) || !uirCoreCurrentParsedRootValid():
        return ""
    let currentRoot: Node = uirCoreCurrentParsedRootGet()
    let fieldName: str = backendStripSpaces(fieldName0)
    if len(fieldName) == 0:
        return ""
    var parentType: str = backendStripSpaces(parentType0)
    if len(parentType) == 0:
        return ""
    parentType = uirCoreStripRefVarKeyOnce(parentType)
    parentType = uirCoreStripPtrKeyOnce(parentType)
    let parentObj: str = uirCoreObjTypeFromTypeKey(module, parentType)
    if len(parentObj) > 0:
        parentType = parentObj
    let parentCanon: str = uirCoreObjAliasCanon(parentType)
    if len(parentCanon) > 0:
        parentType = parentCanon
    if !uirCoreFieldTypeKeyFromCurrentRootCacheMatches(module, currentRoot):
        uirCoreFieldTypeKeyFromCurrentRootCacheReset(module, currentRoot)
    var cachedFound: bool
    let cached: str = uirCoreFieldTypeKeyFromCurrentRootCacheGet(module, currentRoot, parentType, fieldName, cachedFound)
    if cachedFound:
        return cached
    let td: Node = uirCoreFindTypeDeclByName(currentRoot, parentType)
    if !astNodeIdValid(td):
        uirCoreFieldTypeKeyFromCurrentRootCachePut(module, currentRoot, parentType, fieldName, "")
        return ""
    let out: str = uirCoreFieldTypeKeyFromTypeDecl(module, td, fieldName)
    uirCoreFieldTypeKeyFromCurrentRootCachePut(module, currentRoot, parentType, fieldName, out)
    return out

fn uirCoreFindGenericTypeDeclForInstName(root: Node, targetInstName: str, rawArgs: Node[]): Node =
    if !astNodeIdValid(root) || len(targetInstName) == 0:
        return astInvalidNodeId()
    if astNodeIsTypeDecl(root) && kidCount(root) > 2:
        let generics: Node = kid(root, 2)
        if astNodeIdValid(generics) && astNodeIsGenericParams(generics) && kidCount(generics) > 0 && kidCount(root) > 0:
            let nameNode: Node = kid(root, 0)
            if astNodeIdValid(nameNode) && astNodeIsIdentOrSymbol(nameNode):
                let candName: str = backendStripSpaces(plainName(nameNode))
                if len(candName) > 0:
                    let candInstName: str = mangleInstance(candName, rawArgs)
                    if candInstName == targetInstName:
                        return root
    for i in 0..<kidCount(root):
        let found: Node = uirCoreFindGenericTypeDeclForInstName(kid(root, i), targetInstName, rawArgs)
        if astNodeIdValid(found):
            return found
    return astInvalidNodeId()

fn uirCoreDebugRootGenericTypeSummaryCollect(root: Node, limit: int32, parts: var str[]) =
    if !astNodeIdValid(root) || parts.len >= limit:
        return
    if astNodeIsTypeDecl(root) && kidCount(root) > 2:
        let gpId: Node = kid(root, 2)
        if astNodeIdValid(gpId) && astNodeIsGenericParams(gpId) && kidCount(gpId) > 0:
            uir_core_builder_current_root_type_decl_helpers_add(parts, uirCoreTypeDeclNameOrAnon(root) + "#" + intToStr(kidCount(gpId)))
            if parts.len >= limit:
                return
    for i in 0..<kidCount(root):
        uirCoreDebugRootGenericTypeSummaryCollect(kid(root, i), limit, parts)
        if parts.len >= limit:
            return

fn uirCoreDebugRootGenericTypeSummary(root: Node, limit: int32 = 8): str =
    if !astNodeIdValid(root) || limit <= 0:
        return ""
    var parts: str[]
    uirCoreDebugRootGenericTypeSummaryCollect(root, limit, parts)
    return strutil.Join(parts, ",")

fn uirCoreEnsureGenericTypeInstFromCurrentRoot(module: UirCoreModule, typeNode: Node): str =
    if (module == nil) || !uirCoreCurrentParsedRootValid() || !astNodeIdValid(typeNode):
        return ""
    if !astNodeIsBracketExpr(typeNode) || kidCount(typeNode) <= 0:
        return ""
    let dbgGenericSynth: bool = envIsTrue "BACKEND_DEBUG_GENERIC_TYPE_SYNTH"
    let base: Node = kid(typeNode, 0)
    let baseName: str = typeNodeCanonicalName(base)
    if baseName == "seq" || baseName == "seq_fixed" || baseName == "Table" ||
       baseName == "Option" || baseName == "Result" || baseName == "SeqUninit" ||
       baseName == "__cheng_tables_Entry" || baseName == "array":
        return ""
    let currentRoot: Node = uirCoreCurrentParsedRootGet()
    let genNode: Node = (len(baseName) > 0) ? findGenericTypeDecl(currentRoot, baseName) : astInvalidNodeId()
    var rawArgs: Node[]
    for ai in 1..<kidCount(typeNode):
        let arg: Node = kid(typeNode, ai)
        if astNodeIdValid(arg) && !astNodeIsEmpty(arg):
            uir_core_builder_current_root_type_decl_helpers_add(rawArgs, arg)
    if rawArgs.len == 0:
        return ""
    let targetInstName0: str = uirCoreTypeKeyFromNodeLoose(typeNode)
    let targetInstName: str = uirCoreTargetInstName(typeNode, targetInstName0)
    var actualGenNode: Node = genNode
    if stage1AstRefNonNil(actualGenNode) && len(targetInstName) > 0:
        let probeName: str = mangleInstance(baseName, rawArgs)
        if probeName != targetInstName:
            actualGenNode = astInvalidNodeId()
    if !stage1AstRefNonNil(actualGenNode) && len(targetInstName) > 0:
        actualGenNode = uirCoreFindGenericTypeDeclForInstName(currentRoot, targetInstName, rawArgs)
    if dbgGenericSynth:
        let genFound: str = uirCoreDebugBool01(stage1AstRefNonNil(genNode))
        let actualFound: str = uirCoreDebugBool01(stage1AstRefNonNil(actualGenNode))
        let rootSummary: str = uirCoreDebugRootSummaryIfMissing(actualGenNode)
        os.WriteLine(os.Get_stderr(),
                     "[backend] debugGenericSynth: base=" + baseName +
                     " target=" + targetInstName +
                     " genFound=" + genFound +
                     " actualFound=" + actualFound +
                     (len(rootSummary) > 0 ? " root_generics=" + rootSummary : ""))
        os.C_fflush(os.Get_stderr())
    if !stage1AstRefNonNil(actualGenNode):
        return ""
    var generics: Node = astInvalidNodeId()
    if kidCount(actualGenNode) > 2:
        generics = kid(actualGenNode, 2)
    var mapNames: str[]
    var mapTypes: Node[]
    collectTypeArgMap(generics, rawArgs, mapNames, mapTypes)
    var instArgs: Node[]
    buildFullTypeArgs(generics, mapNames, mapTypes, rawArgs, instArgs)
    let instName: str = uirCoreResolvedInstName(targetInstName, baseName, instArgs)
    if len(instName) == 0:
        return ""
    if uirCoreHasObjType(module, instName):
        return instName
    let instCanon0: str = uirCoreObjAliasCanon(instName)
    if len(instCanon0) > 0 && uirCoreHasObjType(module, instCanon0):
        return instCanon0
    var defNode: Node = astInvalidNodeId()
    if kidCount(actualGenNode) > 1:
        defNode = kid(actualGenNode, 1)
    if !astNodeIdValid(defNode) || astNodeIsEmpty(defNode):
        return ""
    let replacedDef: Node = replaceTypeVars(defNode, mapNames, mapTypes)
    if !astNodeIdValid(replacedDef) || astNodeIsEmpty(replacedDef):
        return ""
    var decl: Node = newNode(astNodeKindTypeDecl(), nodePos(actualGenNode))
    nodeSetStrVal(decl, nodeStrVal(actualGenNode))
    addSon(decl, newIdent(instName, nodePos(typeNode)))
    addSon(decl, replacedDef)
    addSon(decl, newNode(astNodeKindEmpty(), nodePos(actualGenNode)))
    addSon(decl, newNode(astNodeKindEmpty(), nodePos(actualGenNode)))
    var pragmaNode: Node = astInvalidNodeId()
    if kidCount(actualGenNode) > 4:
        pragmaNode = kid(actualGenNode, 4)
    if astNodeIdValid(pragmaNode) && !astNodeIsEmpty(pragmaNode):
        addSon(decl, cloneTree(pragmaNode))
    else:
        addSon(decl, newNode(astNodeKindEmpty(), nodePos(actualGenNode)))
    let consumeRes: Result[bool] = uirCoreConsumeTypeDecl(module, decl)
    if dbgGenericSynth:
        os.WriteLine(os.Get_stderr(),
                     "[backend] debugGenericSynth: consume_ok=" + (uirCoreResultBoolIsOk(consumeRes) ? "1" : "0") +
                     " pending=" + ((uirCoreResultBoolIsOk(consumeRes) && uirCoreResultBoolValue(consumeRes)) ? "1" : "0"))
        os.C_fflush(os.Get_stderr())
    if !uirCoreResultBoolIsOk(consumeRes):
        return ""
    if uirCoreResultBoolValue(consumeRes):
        return ""
    if uirCoreHasObjType(module, instName):
        if dbgGenericSynth:
            os.WriteLine(os.Get_stderr(),
                         "[backend] debugGenericSynth: obj_ready=1 name=" + instName)
            os.C_fflush(os.Get_stderr())
        return instName
    let instCanon: str = uirCoreObjAliasCanon(instName)
    if len(instCanon) > 0 && uirCoreHasObjType(module, instCanon):
        if dbgGenericSynth:
            os.WriteLine(os.Get_stderr(),
                         "[backend] debugGenericSynth: obj_ready=1 canon=" + instCanon)
            os.C_fflush(os.Get_stderr())
        return instCanon
    if dbgGenericSynth:
        os.WriteLine(os.Get_stderr(),
                     "[backend] debugGenericSynth: obj_ready=0 name=" + instName)
        os.C_fflush(os.Get_stderr())
    return ""

fn uirCoreRecoverLegacyGenericObjKey(module: UirCoreModule, key0: str): str =
    if (module == nil):
        return ""
    var key: str = backendStripSpaces(key0)
    if len(key) == 0:
        return ""
    if uirCoreStrStartsWith(key, "var_ref_"):
        key = rawmemStrFromOffset(key, 8)
    elif uirCoreStrStartsWith(key, "var_"):
        key = rawmemStrFromOffset(key, 4)
    elif uirCoreStrStartsWith(key, "ref_"):
        key = rawmemStrFromOffset(key, 4)
    elif uirCoreStrStartsWith(key, "ptr_"):
        key = rawmemStrFromOffset(key, 4)
    let innerKey: str = uirCoreRecoverLegacyInnerKey(key)
    if len(innerKey) == 0:
        return ""
    if uirCoreStrStartsWith(innerKey, "Result_") && ensureResultObjType(module, innerKey):
        return innerKey
    if uirCoreStrStartsWith(innerKey, "Option_") && ensureOptionObjType(module, innerKey):
        return innerKey
    if uirCoreStrStartsWith(innerKey, "SeqUninit_") && ensureSeqUninitObjType(module, innerKey):
        return innerKey
    if uirCoreStrStartsWith(innerKey, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, innerKey):
        return innerKey
    return ""

fn uirCoreTypeKeyIsTableIter(typeKey0: str): bool =
    let key: str = uirCoreTypeKeyBaseName(uirCoreTypeKeyStripIterWrappers(typeKey0))
    return (key == "Table") || uirCoreStrStartsWith(key, "Table_")

fn uirCoreTypeKeyTableValKey(typeKey0: str): str =
    let key: str = uirCoreTypeKeyBaseName(uirCoreTypeKeyStripIterWrappers(typeKey0))
    if uirCoreStrStartsWith(key, "Table_"):
        return rawmemStrFromOffset(key, 6)
    return ""

fn uirCoreHashMapIterFlavorFromTypeKey(typeKey0: str): int32 =
    let key: str = uirCoreTypeKeyBaseName(uirCoreTypeKeyStripIterWrappers(typeKey0))
    if (key == "HashMapStrInt"):
        return 1
    if (key == "HashMapStrSeqInt"):
        return 2
    if (key == "HashMapPtrInt"):
        return 3
    let __for_start_i = len(key) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if key[i] == '_':
            let suffix: str = rawmemStrFromOffset(key, i + 1)
            if (suffix == "HashMapStrInt"):
                return 1
            if (suffix == "HashMapStrSeqInt"):
                return 2
            if (suffix == "HashMapPtrInt"):
                return 3
    return 0
