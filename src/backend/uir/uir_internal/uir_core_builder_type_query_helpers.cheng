# Shared builder-local type query and shallow inference helpers split from uir_core_builder.
import std/os
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_types
import backend/uir/uir_internal/uir_core_builder_base_helpers
import backend/uir/uir_internal/uir_core_builder_type_surface_helpers
import backend/uir/uir_internal/uir_core_builder_module_lookup_cache
import backend/uir/uir_internal/uir_core_builder_reachability_scan

fn uirCoreTypeKindNameLocal(t: UirCoreType): str =
    if t.kind == mtVoid:
        return "void"
    if t.kind == mtF64:
        return "f64"
    if t.kind == mtF32:
        return "f32"
    if t.kind == mtI64:
        return t.isUnsigned ? "u64" : "i64"
    if t.kind == mtI32:
        return t.isUnsigned ? "u32" : "i32"
    if t.kind == mtI16:
        return t.isUnsigned ? "u16" : "i16"
    if t.kind == mtI8:
        return t.isUnsigned ? "u8" : "i8"
    return "i32"

fn backendOpName(n: Node): str =
    if (n == nil):
        return ""
    return backendStripSpaces(nodeIdent(n))

fn uirCoreIntBitsDefault32(): int32 =
    let raw: str = backendStripSpaces(os.GetEnv("INTBITS"))
    if (raw == "64"):
        return 64
    return 32

fn uirCoreTypeFromCanonicalNameOrDefault(name: str, defaultTy: UirCoreType): UirCoreType =
    if len(name) == 0:
        return defaultTy
    if name == "void":
        return uirCoreTypeVoid()
    if name == "tuple" || uirCoreStrStartsWith(name, "tuple_"):
        return uirCoreTypeI64()
    if name == "float64" || name == "float":
        return uirCoreTypeF64()
    if name == "float32":
        return uirCoreTypeF32()
    if name == "bool":
        return uirCoreTypeU8()
    if name == "char":
        return uirCoreTypeU8()
    if name == "int8" || name == "i8":
        return uirCoreTypeI8()
    if name == "uint8" || name == "u8":
        return uirCoreTypeU8()
    if name == "int16" || name == "i16":
        return uirCoreTypeI16()
    if name == "uint16" || name == "u16":
        return uirCoreTypeU16()
    if name == "int" || name == "NI":
        let bits: int32 = uirCoreIntBitsDefault32()
        if bits == 64:
            return uirCoreTypeI64()
        return uirCoreTypeI32()
    if name == "uint" || name == "NU":
        let bits2: int32 = uirCoreIntBitsDefault32()
        if bits2 == 64:
            return uirCoreTypeU64()
        return uirCoreTypeU32()
    if name == "int64" || name == "i64":
        return uirCoreTypeI64()
    if name == "uint64" || name == "u64":
        return uirCoreTypeU64()
    if name == "int32" || name == "i32":
        return uirCoreTypeI32()
    if name == "uint32" || name == "u32":
        return uirCoreTypeU32()
    if uirCoreStrStartsWith(name, "set_"):
        return uirCoreTypeU64()
    if uirCoreKeyHasSeqPrefix(name) || uirCoreKeyHasSeqFixedPrefix(name) || uirCoreKeyHasTablePrefix(name):
        return uirCoreTypeI64()
    if isStringOrPtrKeyCanon(name):
        return uirCoreTypeI64()
    if uirCoreKeyHasPtrPrefix(name) || uirCoreKeyHasRefPrefix(name) || uirCoreKeyHasFnPrefix(name):
        return uirCoreTypeI64()
    return defaultTy

fn uirCoreTypeFromNode(n: Node): UirCoreType =
    if !astNodeIdValid(n) || nodeKind(n) == nkEmpty:
        return uirCoreTypeI32()
    let k: NodeKind = nodeKind(n)
    if k == nkPtrTy || k == nkRefTy || k == nkFnTy || k == nkSetTy || k == nkVarTy || k == nkTupleTy:
        return uirCoreTypeI64()
    let name: str =
        (k == nkIdent || k == nkSymbol) ? typeNodeCanonicalName(n) : backendStripSpaces(plainName(n))
    return uirCoreTypeFromCanonicalNameOrDefault(name, uirCoreTypeI32())

fn uirCoreTypeFromTypeKeyName(key0: str): UirCoreType =
    if len(key0) == 0:
        return uirCoreTypeI64()
    let key: str = backendStripSpaces(key0)
    return uirCoreTypeFromCanonicalNameOrDefault(key, uirCoreTypeI64())

fn uirCoreLooksLikeTypeParamName(name0: str): bool =
    let name: str = backendStripSpaces(name0)
    if len(name) != 1:
        return false
    let c: char = name[0]
    return c >= 'A' && c <= 'Z'

fn uirCoreBuiltinTypeNameSize(name0: str): int32 =
    let nm: str = backendStripSpaces(name0)
    if nm == "bool" || nm == "char" || nm == "int8" || nm == "uint8" || nm == "i8" || nm == "u8":
        return 1
    if nm == "int16" || nm == "uint16" || nm == "i16" || nm == "u16":
        return 2
    if nm == "int32" || nm == "uint32" || nm == "i32" || nm == "u32" || nm == "float32":
        return 4
    if nm == "int" || nm == "uint" || nm == "NI" || nm == "NU":
        let bits: int32 = uirCoreIntBitsDefault32()
        return (bits == 64) ? 8 : 4
    if nm == "int64" || nm == "uint64" || nm == "i64" || nm == "u64" || nm == "float64":
        return 8
    if isStringOrPtrKey(nm):
        return 8
    if uirCoreStrStartsWith(nm, "ptr_") || uirCoreStrStartsWith(nm, "ref_") || uirCoreStrStartsWith(nm, "fn_"):
        return 8
    if uirCoreStrStartsWith(nm, "seq_") || uirCoreStrStartsWith(nm, "seq_fixed_") || uirCoreStrStartsWith(nm, "Table_"):
        return 8
    if uirCoreStrStartsWith(nm, "set_"):
        return 8
    if nm == "void":
        return 0
    if uirCoreLooksLikeTypeParamName(nm):
        return 8
    return -1

fn uirCoreTypeFromNodeWithModule(module: UirCoreModule, n: Node): UirCoreType =
    if !astNodeIdValid(n) || n == nil:
        return uirCoreTypeI32()
    let k: NodeKind = nodeKind(n)
    if (module == nil) || (k != nkIdent && k != nkSymbol):
        return uirCoreTypeFromNode(n)
    let name: str = typeNodeCanonicalName(n)
    let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, name)
    if aliasTy.kind != mtVoid:
        return aliasTy
    if k == nkIdent || k == nkSymbol:
        return uirCoreTypeFromCanonicalNameOrDefault(name, uirCoreTypeI32())
    let ty: UirCoreType = uirCoreTypeFromNode(n)
    if module == nil:
        return ty
    return ty

fn inferExprType(env: LocalEnv, n: Node, fallback: UirCoreType): UirCoreType =
    if (n == nil):
        return fallback
    var node: Node = n
    while astNodeIdValid(node) && nodeKind(node) == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if (node == nil):
        return fallback
    if uirCoreNodeIsStringLiteral(node):
        return uirCoreTypeI64()
    if nodeKind(node) == nkFloatLit:
        return uirCoreTypeF64()
    if nodeKind(node) == nkCharLit:
        return uirCoreTypeU8()
    if nodeKind(node) == nkBoolLit:
        return uirCoreTypeU8()
    if nodeKind(node) == nkIdent || nodeKind(node) == nkSymbol:
        let idx: int32 = localIndex(env, plainName(node))
        if idx >= 0:
            return localType(env, idx)
        return fallback
    if nodeKind(node) == nkCall && kidCount(node) > 0:
        let calleeNode: Node = kid(node, 0)
        let name: str = backendStripSpaces(plainName(calleeNode))
        if name == "__addr":
            return uirCoreTypeI64()
        if name == "uint64" || name == "u64":
            return uirCoreTypeU64()
        if name == "int64" || name == "i64":
            return uirCoreTypeI64()
        if name == "uint32" || name == "u32":
            return uirCoreTypeU32()
        if name == "int32" || name == "i32":
            return uirCoreTypeI32()
        return fallback
    if nodeKind(node) == nkPrefix && kidCount(node) > 1:
        return inferExprType(env, kid(node, 1), fallback)
    if nodeKind(node) == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        let lt: UirCoreType = inferExprType(env, kid(node, 1), fallback)
        let rt: UirCoreType = inferExprType(env, kid(node, 2), fallback)
        if op == "<<" || op == ">>":
            return lt
        if lt.kind == mtF64 || rt.kind == mtF64:
            return uirCoreTypeF64()
        if lt.kind == mtF32 || rt.kind == mtF32:
            return uirCoreTypeF32()
        if lt.kind == mtI64 || rt.kind == mtI64:
            var out: UirCoreType = uirCoreTypeI64()
            out.isUnsigned = (lt.kind == mtI64 && lt.isUnsigned) || (rt.kind == mtI64 && rt.isUnsigned)
            return out
        var out2: UirCoreType = uirCoreTypeI32()
        out2.isUnsigned = lt.isUnsigned || rt.isUnsigned
        return out2
    return fallback

fn inferExprTypeWithGlobals(env: LocalEnv, module: UirCoreModule, func: UirCoreFunc, n: Node, fallback: UirCoreType): UirCoreType =
    if (n == nil):
        return fallback
    var node: Node = n
    while astNodeIdValid(node) && nodeKind(node) == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if (node == nil):
        return fallback
    if uirCoreNodeIsStringLiteral(node):
        return uirCoreTypeI64()
    if nodeKind(node) == nkFloatLit:
        return uirCoreTypeF64()
    if nodeKind(node) == nkCall:
        let name: str = uirCoreCallNameForReachability(module, node)
        if name == "new":
            return uirCoreTypeI64()
        if len(name) > 0 && (module != nil):
            let exact: UirCoreFunc = moduleFindFunc(module, name)
            if (exact != nil):
                return uirCoreFuncRetTypeOf(exact)
            let unique: UirCoreFunc = moduleFindFuncByBaseUnique(module, name)
            if (unique != nil):
                return uirCoreFuncRetTypeOf(unique)
    if nodeKind(node) == nkDotExpr && kidCount(node) > 1:
        let base: Node = kid(node, 0)
        let field: Node = kid(node, 1)
        if (base != nil) && (nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol) &&
           (field != nil) && (nodeKind(field) == nkIdent || nodeKind(field) == nkSymbol):
            let baseName: str = plainName(base)
            let slot: int32 = uirCoreResolveLocalSlotOrImplicitResult(env, func, baseName)
            if slot >= 0:
                let objTypeName: str = funcObjTypeName(func, slot)
                if len(objTypeName) > 0:
                    let ot: UirCoreObjType = uirCoreGetObjType(module, objTypeName)
                    let fieldName: str = backendStripSpaces(plainName(field))
                    for fi in 0..<ot.fields.len:
                        let f: UirCoreObjField = ot.fields[fi]
                        if (f.name == fieldName):
                            return f.ty
        return fallback
    if nodeKind(node) == nkIdent || nodeKind(node) == nkSymbol:
        let name: str = plainName(node)
        let idx: int32 = uirCoreResolveLocalSlotOrImplicitResult(env, func, name)
        if idx >= 0:
            return localType(env, idx)
        let gidx: int32 = moduleGlobalIndex(module, name)
        if gidx >= 0:
            let g2: UirCoreGlobal = uirCoreModuleGlobalAt(module, gidx)
            return g2.ty
        if moduleHasFuncByBase(module, name):
            return uirCoreTypeI64()
        return fallback
    return inferExprType(env, node, fallback)

fn isAddrCall(n: Node): bool =
    if !astNodeIdValid(n) || nodeKind(n) != nkCall || kidCount(n) == 0:
        return false
    let calleeNode: Node = kid(n, 0)
    let name: str = backendStripSpaces(plainName(calleeNode))
    return name == "__addr"
