    seqs.add(seqInst, val)

fn uirCoreAppendObjLocal(seqInst: var UirCoreObjLocal[], val: UirCoreObjLocal) =
    seqs.add(seqInst, val)

fn uirCoreOwnObjLocal(olIn: UirCoreObjLocal): UirCoreObjLocal =
    var out: UirCoreObjLocal = olIn
    out.objTypeName = uirCoreOwnStrSafe(out.objTypeName)
    out.typeKey = uirCoreOwnStrSafe(out.typeKey)
    return out

fn uirCoreAppendFuncRef(seqInst: var UirCoreFunc[], val: UirCoreFunc) =
    add(seqInst, val)

fn uirCoreAppendGlobal(seqInst: var UirCoreGlobal[], val: UirCoreGlobal) =
    seqs.add(seqInst, val)

fn uirCoreAppendCString(seqInst: var UirCoreCString[], val: UirCoreCString) =
    seqs.add(seqInst, val)

fn uirCoreAppendTerm(seqInst: var UirCoreTerm[], val: UirCoreTerm) =
    seqs.add(seqInst, val)

fn uirCoreAppendStmtSeq(seqInst: var UirStmtId[][], val: UirStmtId[]) =
    seqs.add(seqInst, uirCoreCloneStmtSeq(val))

fn uirCoreCloneExprArgs(src: UirExprId[]): UirExprId[] =
    var out: UirExprId[]
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    setLen(out, n)
    for i in 0..<n:
        out[i] = src[i]
    return out

fn uirCoreCloneStmtSeq(src: UirStmtId[]): UirStmtId[] =
    var out: UirStmtId[]
    let n: int32 = len(src)
    if n <= 0:
        return out
    reserve(out, n)
    setLen(out, n)
    for i in 0..<n:
        out[i] = src[i]
    return out

fn uirCoreCloneParamSeq(src: UirCoreParam[]): UirCoreParam[] =
    var out: UirCoreParam[]
    if !uirCoreParamSeqSane(src):
        return out
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    for i in 0..<n:
        var p: UirCoreParam = src[i]
        p.name = uirCoreOwnStrBestEffort(p.name)
        p.typeKey = uirCoreOwnStrBestEffort(p.typeKey)
        uirCoreAppendParam(out, p)
    return out

fn uirCoreCloneTypeSeq(src: UirCoreType[]): UirCoreType[] =
    var out: UirCoreType[]
    if !uirCoreTypeSeqSane(src):
        return out
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    for i in 0..<n:
        uirCoreAppendType(out, src[i])
    return out

fn uirCoreCloneObjLocalSeq(src: UirCoreObjLocal[]): UirCoreObjLocal[] =
    var out: UirCoreObjLocal[]
    if !uirCoreObjLocalSeqSane(src):
        return out
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    for i in 0..<n:
        var ol: UirCoreObjLocal = src[i]
        ol.objTypeName = uirCoreOwnStrBestEffort(ol.objTypeName)
        ol.typeKey = uirCoreOwnStrBestEffort(ol.typeKey)
        uirCoreAppendObjLocal(out, ol)
    return out

fn uirCoreCloneBlockSeq(src: UirBlockId[]): UirBlockId[] =
    var out: UirBlockId[]
    if !uirCoreBlockSeqSane(src):
        return out
    let n: int32 = src.len
    if n <= 0:
        return out
    reserve(out, n)
    for i in 0..<n:
        uirCoreAppendBlockPtr(&out, src[i])
    return out

fn uirCoreStmtSeqLen(items: UirStmtId[]*): int32 =
    if items == nil:
        return 0
    return items->len

fn uirCoreStmtSeqDataPtr(items: UirStmtId[]*): ptr =
    if items == nil:
        return nil
    return items->buffer

fn uirCoreStmtSeqAppend(items: UirStmtId[]*, stmt: UirStmtId) =
    if items == nil:
        return
    seqs.add(items, stmt)

fn uirCoreStmtSeqAt(items: UirStmtId[]*, idx: int32): UirStmtId =
    if items == nil:
        return uirCoreInvalidId()
    return items[idx]

fn uirCoreStmtSeqSet(items: UirStmtId[]*, idx: int32, stmt: UirStmtId) =
    if items == nil:
        return
    items[idx] = stmt

fn uirCoreBlockStmtsFlatLen(): int32 =
    return uirCore_blockStmtsFlatCount

fn uirCoreResetStmtIdSeq(items: UirStmtId[]*) =
    if items == nil:
        return
    items->buffer = nil
    items->len = 0
    items->cap = 0

fn uirCoreSanitizeStmtIdSeq(items: UirStmtId[]*) =
    if items == nil:
        return
    var bad: bool = false
    if items->len < 0 || items->cap < 0:
        bad = true
    elif items->len > items->cap:
        bad = true
    elif items->len > 100000000 || items->cap > 100000000:
        bad = true
    if bad:
        uirCoreResetStmtIdSeq(items)

fn uirCoreBlockStmtsFlatAppend(stmt: UirStmtId) =
    uirCore_blockPoolInit()
    uirCoreSanitizeStmtIdSeq(&uirCore_blockStmtsFlat)
    let flatLenBefore: int32 = uirCoreStmtSeqLen(&uirCore_blockStmtsFlat)
    if crashTraceEnabled():
        crashTraceSetPhase(cstring("uir.flat.append"))
        crashTraceMark(cstring("uir.flat.append"), stmt, uirCore_blockStmtsFlatCount, flatLenBefore, 0)
    if uirCore_blockStmtsFlatCount < 0 || uirCore_blockStmtsFlatCount > flatLenBefore:
        uirCore_blockStmtsFlatCount = flatLenBefore
    uirCoreStmtSeqAppend(&uirCore_blockStmtsFlat, stmt)
    uirCore_blockStmtsFlatCount = uirCoreStmtSeqLen(&uirCore_blockStmtsFlat)

fn uirCoreBlockStmtsFlatAt(idx: int32): UirStmtId =
    if idx < 0 || idx >= uirCore_blockStmtsFlatCount:
        return uirCoreInvalidId()
    uirCoreSanitizeStmtIdSeq(&uirCore_blockStmtsFlat)
    let flatLen: int32 = uirCoreStmtSeqLen(&uirCore_blockStmtsFlat)
    if uirCore_blockStmtsFlatCount > flatLen:
        uirCore_blockStmtsFlatCount = flatLen
    if uirCoreStmtSeqDataPtr(&uirCore_blockStmtsFlat) == nil || idx >= flatLen:
        return uirCoreInvalidId()
    return uirCoreStmtSeqAt(&uirCore_blockStmtsFlat, idx)

fn uirCoreBlockStmtsFlatSet(idx: int32, stmt: UirStmtId) =
    if idx < 0 || idx >= uirCore_blockStmtsFlatCount:
        panic "uirCore_types: flat stmt index out of bounds"
    uirCoreSanitizeStmtIdSeq(&uirCore_blockStmtsFlat)
    let flatLen: int32 = uirCoreStmtSeqLen(&uirCore_blockStmtsFlat)
    if uirCore_blockStmtsFlatCount > flatLen:
        uirCore_blockStmtsFlatCount = flatLen
    if uirCoreStmtSeqDataPtr(&uirCore_blockStmtsFlat) == nil || idx >= flatLen:
        panic "uirCore_types: flat stmt backing out of sync"
    uirCoreStmtSeqSet(&uirCore_blockStmtsFlat, idx, stmt)

fn uirCoreAppendBlockStmtSpanFromSeq(stmts: UirStmtId[]*) =
    let start: int32 = uirCoreBlockStmtsFlatLen()
    let stmtLen: int32 = (stmts != nil) ? stmts->len : 0
    if stmts != nil && stmtLen > 0:
        for i in 0..<stmtLen:
            uirCoreBlockStmtsFlatAppend(stmts[i])
    seqs.add(uirCore_blockPool_stmtStart, start)
    seqs.add(uirCore_blockPool_stmtLenFlat, stmtLen)

fn uirCoreAppendBlockStmtSpan(val: UirStmtId[]) =
    uirCoreAppendBlockStmtSpanFromSeq(&val)

var
    uirCore_exprPool_ready: bool = false
    uirCore_exprPool_kind: int32[]
    uirCore_exprPool_value: int64[]
    uirCore_exprPool_binOp: int32[]
    uirCore_exprPool_cmpOp: int32[]
    uirCore_exprPool_lhs: UirExprId[]
    uirCore_exprPool_rhs: UirExprId[]
    uirCore_exprPool_localIndex: int32[]
    uirCore_exprPool_callee: str[]
    uirCore_exprPool_args: UirExprId[][]
    uirCore_exprPool_argStart: int32[]
    uirCore_exprPool_argLenFlat: int32[]
    uirCore_exprArgsFlat: UirExprId[]
    uirCore_exprPool_castType: int32[]
    uirCore_exprPool_castExpr: UirExprId[]
    uirCore_exprPool_addrExpr: UirExprId[]
    uirCore_exprPool_loadType: int32[]
    uirCore_exprPool_globalName: str[]
    uirCore_stmtPool_ready: bool = false
    uirCore_stmtPool_kind: int32[]
    uirCore_stmtPool_name: str[]
    uirCore_stmtPool_slot: int32[]
    uirCore_stmtPool_expr: UirExprId[]
    uirCore_stmtPool_paramIndex: int32[]
    uirCore_stmtPool_addrExpr: UirExprId[]
    uirCore_stmtPool_storeType: int32[]
    uirCore_blockPool_ready: bool = false
    uirCore_blockPool_label: str[]
    uirCore_blockPool_stmtsSeq: UirStmtId[][]
    uirCore_blockPool_stmtStart: int32[]
    uirCore_blockPool_stmtLenFlat: int32[]
    uirCore_blockStmtsFlat: UirStmtId[]
    uirCore_blockStmtsFlatCount: int32 = 0
    uirCore_blockPool_term: UirCoreTerm[]

fn uirCore_exprPoolInit() =
    if uirCore_exprPool_ready:
        return
    uirCore_exprPool_kind = []
    uirCore_exprPool_value = []
    uirCore_exprPool_binOp = []
    uirCore_exprPool_cmpOp = []
    uirCore_exprPool_lhs = []
    uirCore_exprPool_rhs = []
    uirCore_exprPool_localIndex = []
    uirCore_exprPool_callee = []
    uirCore_exprPool_args = []
    uirCore_exprPool_argStart = []
    uirCore_exprPool_argLenFlat = []
    uirCore_exprArgsFlat = []
    uirCore_exprPool_castType = []
    uirCore_exprPool_castExpr = []
    uirCore_exprPool_addrExpr = []
    uirCore_exprPool_loadType = []
    uirCore_exprPool_globalName = []
    seqs.add(uirCore_exprPool_kind, uirCoreEncodeExprKind(meConstI64))
    seqs.add(uirCore_exprPool_value, int64(0))
    seqs.add(uirCore_exprPool_binOp, uirCoreEncodeBinOp(mbAdd))
    seqs.add(uirCore_exprPool_cmpOp, uirCoreEncodeCmpOp(mcEq))
    add(uirCore_exprPool_lhs, UirExprId(0))
    add(uirCore_exprPool_rhs, UirExprId(0))
    seqs.add(uirCore_exprPool_localIndex, int32(-1))
    seqs.add(uirCore_exprPool_callee, "")
    var noArgs: UirExprId[]
    let argsIdx0: int32 = uirCore_exprPool_args.len
    let argsNeed0: int32 = argsIdx0 + 1
    if uirCore_exprPool_args.buffer == nil || uirCore_exprPool_args.cap < argsNeed0:
        reserve(uirCore_exprPool_args, uirCoreReserveTargetCap(uirCore_exprPool_args.cap, argsNeed0, 64))
    setLen(uirCore_exprPool_args, argsNeed0)
    uirCore_exprPool_args[argsIdx0] = noArgs
    seqs.add(uirCore_exprPool_argStart, int32(0))
    seqs.add(uirCore_exprPool_argLenFlat, int32(0))
    seqs.add(uirCore_exprPool_castType, uirCoreEncodeType(uirCoreTypeVoid()))
    add(uirCore_exprPool_castExpr, UirExprId(0))
    add(uirCore_exprPool_addrExpr, UirExprId(0))
    seqs.add(uirCore_exprPool_loadType, uirCoreEncodeType(uirCoreTypeVoid()))
    seqs.add(uirCore_exprPool_globalName, "")
    uirCore_exprPool_ready = true

fn uirCore_stmtPoolInit() =
    if uirCore_stmtPool_ready:
        return
    uirCore_stmtPool_kind = []
    uirCore_stmtPool_name = []
    uirCore_stmtPool_slot = []
    uirCore_stmtPool_expr = []
    uirCore_stmtPool_paramIndex = []
    uirCore_stmtPool_addrExpr = []
    uirCore_stmtPool_storeType = []
    seqs.add(uirCore_stmtPool_kind, uirCoreEncodeStmtKind(msExpr))
    seqs.add(uirCore_stmtPool_name, "")
    seqs.add(uirCore_stmtPool_slot, int32(-1))
    add(uirCore_stmtPool_expr, UirExprId(0))
    seqs.add(uirCore_stmtPool_paramIndex, int32(-1))
    add(uirCore_stmtPool_addrExpr, UirExprId(0))
    seqs.add(uirCore_stmtPool_storeType, uirCoreEncodeType(uirCoreTypeVoid()))
    uirCore_stmtPool_ready = true

fn uirCore_blockPoolInit() =
    if uirCore_blockPool_ready:
        return
    uirCore_blockPool_label = []
    uirCore_blockPool_stmtsSeq = []
    uirCore_blockPool_stmtStart = []
    uirCore_blockPool_stmtLenFlat = []
    uirCoreResetStmtIdSeq(&uirCore_blockStmtsFlat)
    uirCore_blockStmtsFlatCount = 0
    uirCore_blockPool_term = []
    var nilTerm: UirCoreTerm
    nilTerm.kind = mtBr
    nilTerm.retExpr = 0
    nilTerm.condExpr = 0
    nilTerm.target = ""
    nilTerm.targetTrue = ""
    nilTerm.targetFalse = ""
    seqs.add(uirCore_blockPool_label, "")
    var noStmts: UirStmtId[]
    uirCoreAppendStmtSeq(uirCore_blockPool_stmtsSeq, noStmts)
    seqs.add(uirCore_blockPool_stmtStart, int32(0))
    seqs.add(uirCore_blockPool_stmtLenFlat, int32(0))
    seqs.add(uirCore_blockPool_term, nilTerm)
    uirCore_blockPool_ready = true

fn uirCoreExprPoolReserve(needLen: int32) =
    uirCore_exprPoolInit()
    let target: int32 = uirCoreReserveTargetCap(uirCore_exprPool_kind.cap, needLen, 256)
    if uirCore_exprPool_kind.cap < target:
        reserve(uirCore_exprPool_kind, target)
    if uirCore_exprPool_value.cap < target:
        reserve(uirCore_exprPool_value, target)
    if uirCore_exprPool_binOp.cap < target:
        reserve(uirCore_exprPool_binOp, target)
    if uirCore_exprPool_cmpOp.cap < target:
        reserve(uirCore_exprPool_cmpOp, target)
    if uirCore_exprPool_lhs.cap < target:
        reserve(uirCore_exprPool_lhs, target)
    if uirCore_exprPool_rhs.cap < target:
        reserve(uirCore_exprPool_rhs, target)
    if uirCore_exprPool_localIndex.cap < target:
        reserve(uirCore_exprPool_localIndex, target)
    if uirCore_exprPool_callee.cap < target:
        reserve(uirCore_exprPool_callee, target)
    if uirCore_exprPool_args.cap < target:
        reserve(uirCore_exprPool_args, target)
    if uirCore_exprPool_argStart.cap < target:
        reserve(uirCore_exprPool_argStart, target)
    if uirCore_exprPool_argLenFlat.cap < target:
        reserve(uirCore_exprPool_argLenFlat, target)
    if uirCore_exprPool_castType.cap < target:
        reserve(uirCore_exprPool_castType, target)
    if uirCore_exprPool_castExpr.cap < target:
        reserve(uirCore_exprPool_castExpr, target)
    if uirCore_exprPool_addrExpr.cap < target:
        reserve(uirCore_exprPool_addrExpr, target)
    if uirCore_exprPool_loadType.cap < target:
        reserve(uirCore_exprPool_loadType, target)
    if uirCore_exprPool_globalName.cap < target:
        reserve(uirCore_exprPool_globalName, target)

fn uirCoreStmtPoolReserve(needLen: int32) =
    uirCore_stmtPoolInit()
    let target: int32 = uirCoreReserveTargetCap(uirCore_stmtPool_kind.cap, needLen, 256)
    if uirCore_stmtPool_kind.cap < target:
        reserve(uirCore_stmtPool_kind, target)
    if uirCore_stmtPool_name.cap < target:
        reserve(uirCore_stmtPool_name, target)
    if uirCore_stmtPool_slot.cap < target:
        reserve(uirCore_stmtPool_slot, target)
    if uirCore_stmtPool_expr.cap < target:
        reserve(uirCore_stmtPool_expr, target)
    if uirCore_stmtPool_paramIndex.cap < target:
        reserve(uirCore_stmtPool_paramIndex, target)
    if uirCore_stmtPool_addrExpr.cap < target:
        reserve(uirCore_stmtPool_addrExpr, target)
    if uirCore_stmtPool_storeType.cap < target:
        reserve(uirCore_stmtPool_storeType, target)

fn uirCoreBlockPoolReserve(needLen: int32) =
    uirCore_blockPoolInit()
    let target: int32 = uirCoreReserveTargetCap(uirCore_blockPool_label.cap, needLen, 128)
    if uirCore_blockPool_label.cap < target:
        reserve(uirCore_blockPool_label, target)
    if uirCore_blockPool_stmtsSeq.cap < target:
        reserve(uirCore_blockPool_stmtsSeq, target)
    if uirCore_blockPool_stmtStart.cap < target:
        reserve(uirCore_blockPool_stmtStart, target)
    if uirCore_blockPool_stmtLenFlat.cap < target:
        reserve(uirCore_blockPool_stmtLenFlat, target)
    if uirCore_blockPool_term.cap < target:
        reserve(uirCore_blockPool_term, target)

fn uirCoreReservePoolsForOptimize(module: UirCoreModule, level: int32) =
    let _module: UirCoreModule = module
    let _level: int32 = level
    uirCore_exprPoolInit()
    uirCore_stmtPoolInit()
    uirCore_blockPoolInit()
    let exprLen: int32 = uirCore_exprPool_kind.len
    let stmtLen: int32 = uirCore_stmtPool_kind.len
    let blockLen: int32 = uirCore_blockPool_label.len
    var exprExtra: int32 = (exprLen / 2) + (stmtLen * 4) + 4096
    var stmtExtra: int32 = (stmtLen / 2) + (blockLen * 2) + 2048
    var blockExtra: int32 = (blockLen / 2) + 1024
    if _level >= 2:
        exprExtra = exprExtra + exprLen + (blockLen * 4) + 8192
        stmtExtra = stmtExtra + (stmtLen / 2) + 4096
        blockExtra = blockExtra + (blockLen / 2) + 2048
    if _level >= 3:
        exprExtra = exprExtra + (exprLen / 2) + (stmtLen * 2) + 8192
        stmtExtra = stmtExtra + (stmtLen / 2) + 2048
        blockExtra = blockExtra + (blockLen / 2) + 1024
    uirCoreExprPoolReserve(exprLen + exprExtra)
    uirCoreStmtPoolReserve(stmtLen + stmtExtra)
    uirCoreBlockPoolReserve(blockLen + blockExtra)

fn uirCoreReservePoolsForBuild(topLevelCount: int32) =
    uirCore_exprPoolInit()
    uirCore_stmtPoolInit()
    uirCore_blockPoolInit()
    var tlCount: int32 = topLevelCount
    if tlCount < 64:
        tlCount = 64
    var exprExtra: int32 = 8192 + (tlCount * 96)
    var stmtExtra: int32 = 4096 + (tlCount * 48)
    var blockExtra: int32 = 1024 + (tlCount * 12)
    if exprExtra > 262144:
        exprExtra = 262144
    if stmtExtra > 131072:
        stmtExtra = 131072
    if blockExtra > 32768:
        blockExtra = 32768
    uirCoreExprPoolReserve(uirCore_exprPool_kind.len + exprExtra)
    uirCoreStmtPoolReserve(uirCore_stmtPool_kind.len + stmtExtra)
    uirCoreBlockPoolReserve(uirCore_blockPool_label.len + blockExtra)

fn rawmemIsNil(expr: UirExprId): bool =
    return expr <= 0

fn rawmemIsNil(blk: UirBlockId): bool =
    return blk <= 0

fn rawmemIsNil(v: int32): bool =
    return v <= 0

fn rawmemIsNil(func: UirCoreFunc): bool =
    return !uirCoreFuncIdValid(func)

fn rawmemIsNil(module: UirCoreModule): bool =
    return module == nil

fn rawmemIsNil(soa: UirCoreSoa): bool =
    return soa == nil

fn rawmemIsNil(soaMod: UirCoreSoaModule): bool =
    return soaMod == nil

fn rawmemIsNil(p: ptr): bool =
    return p == nil

fn uirCoreExprIdValid(expr: UirExprId): bool =
    if expr <= 0:
        return false
    if !uirCore_exprPool_ready:
        return false
    if expr >= uirCore_exprPool_kind.len:
        return false
    # Stage0 crash hardening: keep SoA columns in lock-step before any lookup.
    if expr >= uirCore_exprPool_value.len:
        return false
    if expr >= uirCore_exprPool_binOp.len:
        return false
    if expr >= uirCore_exprPool_cmpOp.len:
        return false
    if expr >= uirCore_exprPool_lhs.len:
        return false
    if expr >= uirCore_exprPool_rhs.len:
        return false
    if expr >= uirCore_exprPool_localIndex.len:
        return false
    if expr >= uirCore_exprPool_callee.len:
        return false
    if expr >= uirCore_exprPool_args.len:
        return false
    if expr >= uirCore_exprPool_argStart.len:
        return false
    if expr >= uirCore_exprPool_argLenFlat.len:
        return false
    if expr >= uirCore_exprPool_castType.len:
        return false
    if expr >= uirCore_exprPool_castExpr.len:
        return false
    if expr >= uirCore_exprPool_addrExpr.len:
        return false
    if expr >= uirCore_exprPool_loadType.len:
        return false
    if expr >= uirCore_exprPool_globalName.len:
        return false
    return true

fn uirCoreBlockIdValid(blk: UirBlockId): bool =
    if blk <= 0:
        return false
    if !uirCore_blockPool_ready:
        return false
    if blk >= uirCore_blockPool_label.len:
        return false
    if blk >= uirCore_blockPool_stmtStart.len:
        return false
    if blk >= uirCore_blockPool_stmtLenFlat.len:
        return false
    if blk >= uirCore_blockPool_term.len:
        return false
    return true

fn uirCoreStmtIdValid(stmt: UirStmtId): bool =
    if stmt <= 0:
        return false
    if !uirCore_stmtPool_ready:
        return false
    if stmt >= uirCore_stmtPool_kind.len:
        return false
    if stmt >= uirCore_stmtPool_name.len:
        return false
    if stmt >= uirCore_stmtPool_slot.len:
        return false
    if stmt >= uirCore_stmtPool_expr.len:
        return false
    if stmt >= uirCore_stmtPool_paramIndex.len:
        return false
    if stmt >= uirCore_stmtPool_addrExpr.len:
        return false
    if stmt >= uirCore_stmtPool_storeType.len:
        return false
    return true

fn uirCoreInvalidId(): int32 =
    return int32(-1)

fn uirCoreFuncIdValid(id: UirFuncId): bool =
    return id >= 0

fn uirCoreFuncIdValid(func: UirCoreFunc): bool =
    if func == nil:
        return false
    let rawPtrVal: int64 = int64(rawmemAsVoid(func))
    if uirCoreFuncPtrKnown(rawPtrVal):
        return true
    let ptrVal: int64 = uirCoreRecoverFuncPtr(rawPtrVal)
    return uirCoreFuncPtrKnown(ptrVal)

fn uirCoreSoaNew(): UirCoreSoa =
    var soa: UirCoreSoa = new(UirCoreSoa)
    soa.exprKind = []
    soa.exprType = []
    soa.exprA = []
    soa.exprB = []
    soa.exprC = []
    soa.exprImm = []
    soa.exprStrId = []
    soa.stmtKind = []
    soa.stmtDst = []
    soa.stmtExpr = []
    soa.stmtNext = []
    soa.blockFirstStmt = []
    soa.blockTermKind = []
    soa.blockTermA = []
    soa.blockTermB = []
    soa.succStart = []
    soa.succLen = []
    soa.succEdges = []
    soa.predStart = []
    soa.predLen = []
    soa.predEdges = []
    return soa

fn uirCoreSoaExprCount(soa: UirCoreSoa): int32 =
    if (soa == nil):
        return 0
    return soa.exprKind.len

fn uirCoreSoaStmtCount(soa: UirCoreSoa): int32 =
    if (soa == nil):
        return 0
    return soa.stmtKind.len

fn uirCoreSoaBlockCount(soa: UirCoreSoa): int32 =
    if (soa == nil):
        return 0
    return soa.blockFirstStmt.len

fn uirCoreSoaAppendExpr(soa: UirCoreSoa, kind: UirCoreExprKind, ty: UirCoreType,
                        a: int32, b: int32, c: int32, imm: int64, strId: int32): UirExprId =
    if (soa == nil):
        return uirCoreInvalidId()
    var exprKind0: UirCoreExprKind[] = soa.exprKind
    var exprType0: UirCoreType[] = soa.exprType
    var exprA0: int32[] = soa.exprA
    var exprB0: int32[] = soa.exprB
    var exprC0: int32[] = soa.exprC
    var exprImm0: int64[] = soa.exprImm
    var exprStrId0: int32[] = soa.exprStrId
    seqs.add(exprKind0, kind)
    seqs.add(exprType0, ty)
    seqs.add(exprA0, a)
    seqs.add(exprB0, b)
    seqs.add(exprC0, c)
    seqs.add(exprImm0, imm)
    seqs.add(exprStrId0, strId)
    soa.exprKind = exprKind0
    soa.exprType = exprType0
    soa.exprA = exprA0
    soa.exprB = exprB0
    soa.exprC = exprC0
    soa.exprImm = exprImm0
    soa.exprStrId = exprStrId0
    return soa.exprKind.len - 1

fn uirCoreSoaAppendStmt(soa: UirCoreSoa, kind: UirCoreStmtKind, dst: int32,
                        expr: int32, next: int32): UirStmtId =
    if (soa == nil):
        return uirCoreInvalidId()
    var stmtKind0: UirCoreStmtKind[] = soa.stmtKind
    var stmtDst0: int32[] = soa.stmtDst
    var stmtExpr0: int32[] = soa.stmtExpr
    var stmtNext0: int32[] = soa.stmtNext
    seqs.add(stmtKind0, kind)
    seqs.add(stmtDst0, dst)
    seqs.add(stmtExpr0, expr)
    seqs.add(stmtNext0, next)
    soa.stmtKind = stmtKind0
    soa.stmtDst = stmtDst0
    soa.stmtExpr = stmtExpr0
    soa.stmtNext = stmtNext0
    return soa.stmtKind.len - 1

fn uirCoreSoaAppendBlock(soa: UirCoreSoa, firstStmt: int32, termKind: UirCoreTermKind,
                         termA: int32, termB: int32): UirBlockId =
    if (soa == nil):
        return uirCoreInvalidId()
    var blockFirstStmt0: int32[] = soa.blockFirstStmt
    var blockTermKind0: UirCoreTermKind[] = soa.blockTermKind
    var blockTermA0: int32[] = soa.blockTermA
    var blockTermB0: int32[] = soa.blockTermB
    var succStart0: int32[] = soa.succStart
    var succLen0: int32[] = soa.succLen
    var predStart0: int32[] = soa.predStart
    var predLen0: int32[] = soa.predLen
    seqs.add(blockFirstStmt0, firstStmt)
    seqs.add(blockTermKind0, termKind)
    seqs.add(blockTermA0, termA)
    seqs.add(blockTermB0, termB)
    seqs.add(succStart0, soa.succEdges.len)
    seqs.add(succLen0, int32(0))
    seqs.add(predStart0, soa.predEdges.len)
    seqs.add(predLen0, int32(0))
    soa.blockFirstStmt = blockFirstStmt0
    soa.blockTermKind = blockTermKind0
    soa.blockTermA = blockTermA0
    soa.blockTermB = blockTermB0
    soa.succStart = succStart0
    soa.succLen = succLen0
    soa.predStart = predStart0
    soa.predLen = predLen0
    return soa.blockFirstStmt.len - 1

fn uirCoreSoaArenaZero(): UirCoreSoaArena =
    var arena: UirCoreSoaArena
    arena.exprCap = 0
    arena.stmtCap = 0
    arena.blockCap = 0
    arena.edgeCap = 0
    return arena

fn uirCoreSoaArenaAccumulate(arena: var UirCoreSoaArena, exprCap: int32, stmtCap: int32,
                             blockCap: int32, edgeCap: int32) =
    if exprCap > 0:
        arena.exprCap = arena.exprCap + exprCap
    if stmtCap > 0:
        arena.stmtCap = arena.stmtCap + stmtCap
    if blockCap > 0:
        arena.blockCap = arena.blockCap + blockCap
    if edgeCap > 0:
        arena.edgeCap = arena.edgeCap + edgeCap

fn uirCoreSoaEstimateFuncArena(func: UirCoreFunc): UirCoreSoaArena =
    var arena: UirCoreSoaArena = uirCoreSoaArenaZero()
    if (!uirCoreFuncIdValid(func)):
        return arena
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
        # Heuristic: expressions are at least one per stmt, and binary/call trees
        # typically contribute an additional node. Keep this linear and cache-friendly.
        let exprCap: int32 = stmtCount * 2 + 4
        let edgeCap: int32 = 2
        uirCoreSoaArenaAccumulate(arena, exprCap, stmtCount, 1, edgeCap)
    return arena

fn uirCoreSoaReserveModuleColumns(soa: UirCoreSoaModule, arena: UirCoreSoaArena) =
    if (soa == nil):
        return
    if arena.exprCap > 0:
        reserve(soa.exprKind, arena.exprCap)
        reserve(soa.exprType, arena.exprCap)
        reserve(soa.exprA, arena.exprCap)
        reserve(soa.exprB, arena.exprCap)
        reserve(soa.exprC, arena.exprCap)
        reserve(soa.exprImm, arena.exprCap)
        reserve(soa.exprStrId, arena.exprCap)
    if arena.stmtCap > 0:
        reserve(soa.stmtKind, arena.stmtCap)
        reserve(soa.stmtDst, arena.stmtCap)
        reserve(soa.stmtExpr, arena.stmtCap)
        reserve(soa.stmtNext, arena.stmtCap)
    if arena.blockCap > 0:
        reserve(soa.blockFirstStmt, arena.blockCap)
        reserve(soa.blockTermKind, arena.blockCap)
        reserve(soa.blockTermA, arena.blockCap)
        reserve(soa.blockTermB, arena.blockCap)
        reserve(soa.succStart, arena.blockCap)
        reserve(soa.succLen, arena.blockCap)
        reserve(soa.predStart, arena.blockCap)
        reserve(soa.predLen, arena.blockCap)
        reserve(soa.funcSpans, arena.blockCap)
    if arena.edgeCap > 0:
        reserve(soa.succEdges, arena.edgeCap)
        reserve(soa.predEdges, arena.edgeCap)

fn uirCoreSoaModuleNew(arena: UirCoreSoaArena): UirCoreSoaModule =
    var soa: UirCoreSoaModule = new(UirCoreSoaModule)
    soa.arena = arena
    soa.exprKind = []
    soa.exprType = []
    soa.exprA = []
    soa.exprB = []
    soa.exprC = []
    soa.exprImm = []
    soa.exprStrId = []
    soa.stmtKind = []
    soa.stmtDst = []
    soa.stmtExpr = []
    soa.stmtNext = []
    soa.blockFirstStmt = []
    soa.blockTermKind = []
    soa.blockTermA = []
    soa.blockTermB = []
    soa.succStart = []
    soa.succLen = []
    soa.succEdges = []
    soa.predStart = []
    soa.predLen = []
    soa.predEdges = []
    soa.funcSpans = []
    uirCoreSoaReserveModuleColumns(soa, arena)
    return soa

fn uirCoreSoaExprFieldNeedsExprRebase(kind: UirCoreExprKind, fieldIndex: int32): bool =
    if fieldIndex <= 0:
        return kind == meBin || kind == meCmp || kind == meCall || kind == meCast || kind == meLoad
    if fieldIndex == 1:
        return kind == meBin || kind == meCmp || kind == meCall
    if fieldIndex == 2:
        return kind == meCall
    return false

fn uirCoreSoaTermExprRebaseNeeded(kind: UirCoreTermKind, fieldIndex: int32): bool =
    if kind == mtRet && fieldIndex == 0:
        return true
    if kind == mtCbr && fieldIndex == 0:
        return true
    return false

fn uirCoreSoaTermBlockRebaseNeeded(kind: UirCoreTermKind, fieldIndex: int32): bool =
    if kind == mtBr && fieldIndex == 0:
        return true
    if kind == mtCbr && fieldIndex == 1:
        return true
    return false

fn uirCoreSoaRebaseExprId(raw: int32, base: int32): int32 =
    if ! uirCoreExprIdValid(raw):
        return raw
    return raw + base

fn uirCoreSoaRebaseStmtId(raw: int32, base: int32): int32 =
    if ! uirCoreStmtIdValid(raw):
        return raw
    return raw + base

fn uirCoreSoaRebaseBlockId(raw: int32, base: int32): int32 =
    if ! uirCoreBlockIdValid(raw):
        return raw
    return raw + base

fn uirCoreSoaModuleRollbackAppend(soaMod: UirCoreSoaModule,
                                  exprLen: int32,
                                  stmtLen: int32,
                                  blockLen: int32,
                                  succLen: int32,
                                  predLen: int32,
                                  spanLen: int32) =
    if (soaMod == nil):
        return
    if exprLen >= 0 && exprLen <= soaMod.exprKind.len:
        soaMod.exprKind.len = exprLen
        if exprLen <= soaMod.exprType.len:
            soaMod.exprType.len = exprLen
        if exprLen <= soaMod.exprA.len:
            soaMod.exprA.len = exprLen
        if exprLen <= soaMod.exprB.len:
            soaMod.exprB.len = exprLen
        if exprLen <= soaMod.exprC.len:
            soaMod.exprC.len = exprLen
        if exprLen <= soaMod.exprImm.len:
            soaMod.exprImm.len = exprLen
        if exprLen <= soaMod.exprStrId.len:
            soaMod.exprStrId.len = exprLen
    if stmtLen >= 0 && stmtLen <= soaMod.stmtKind.len:
        soaMod.stmtKind.len = stmtLen
        if stmtLen <= soaMod.stmtDst.len:
            soaMod.stmtDst.len = stmtLen
        if stmtLen <= soaMod.stmtExpr.len:
            soaMod.stmtExpr.len = stmtLen
        if stmtLen <= soaMod.stmtNext.len:
            soaMod.stmtNext.len = stmtLen
    if blockLen >= 0 && blockLen <= soaMod.blockFirstStmt.len:
        soaMod.blockFirstStmt.len = blockLen
        if blockLen <= soaMod.blockTermKind.len:
            soaMod.blockTermKind.len = blockLen
        if blockLen <= soaMod.blockTermA.len:
            soaMod.blockTermA.len = blockLen
        if blockLen <= soaMod.blockTermB.len:
            soaMod.blockTermB.len = blockLen
        if blockLen <= soaMod.succStart.len:
            soaMod.succStart.len = blockLen
        if blockLen <= soaMod.succLen.len:
            soaMod.succLen.len = blockLen
        if blockLen <= soaMod.predStart.len:
            soaMod.predStart.len = blockLen
        if blockLen <= soaMod.predLen.len:
            soaMod.predLen.len = blockLen
    if succLen >= 0 && succLen <= soaMod.succEdges.len:
        soaMod.succEdges.len = succLen
    if predLen >= 0 && predLen <= soaMod.predEdges.len:
        soaMod.predEdges.len = predLen
    if spanLen >= 0 && spanLen <= soaMod.funcSpans.len:
        soaMod.funcSpans.len = spanLen

fn uirCoreSoaAppendFuncIntoModule(soaMod: UirCoreSoaModule, funcIndex: int32, funcSoa: UirCoreSoa): bool =
    if (soaMod == nil) || (funcSoa == nil):
        return false

    let exprBase: int32 = soaMod.exprKind.len
    let stmtBase: int32 = soaMod.stmtKind.len
    let blockBase: int32 = soaMod.blockFirstStmt.len
    let succEdgeBase: int32 = soaMod.succEdges.len
    let predEdgeBase: int32 = soaMod.predEdges.len
    let funcSpanBase: int32 = soaMod.funcSpans.len
    let exprCount: int32 = funcSoa.exprKind.len
    let stmtCount: int32 = funcSoa.stmtKind.len
    let blockCount: int32 = funcSoa.blockFirstStmt.len
    let succCount: int32 = funcSoa.succEdges.len
    let predCount: int32 = funcSoa.predEdges.len

    if funcSoa.exprType.len != exprCount || funcSoa.exprA.len != exprCount || funcSoa.exprB.len != exprCount ||
       funcSoa.exprC.len != exprCount || funcSoa.exprImm.len != exprCount || funcSoa.exprStrId.len != exprCount:
        return false
    if funcSoa.stmtDst.len != stmtCount || funcSoa.stmtExpr.len != stmtCount || funcSoa.stmtNext.len != stmtCount:
        return false
    if funcSoa.blockTermKind.len != blockCount || funcSoa.blockTermA.len != blockCount || funcSoa.blockTermB.len != blockCount ||
       funcSoa.succStart.len != blockCount || funcSoa.succLen.len != blockCount || funcSoa.predStart.len != blockCount ||
       funcSoa.predLen.len != blockCount:
        return false

    var localBi: int32 = 0
    while localBi < blockCount:
        let sStart: int32 = funcSoa.succStart[localBi]
        let sLen: int32 = funcSoa.succLen[localBi]
        let pStart: int32 = funcSoa.predStart[localBi]
        let pLen: int32 = funcSoa.predLen[localBi]
        if sStart < 0 || sLen < 0 || pStart < 0 || pLen < 0:
            return false
        if sStart + sLen > succCount:
            return false
        if pStart + pLen > predCount:
            return false
        localBi = localBi + 1

    var exprI: int32 = 0
    var exprKindOut: UirCoreExprKind[] = soaMod.exprKind
    var exprTypeOut: UirCoreType[] = soaMod.exprType
    var exprAOut: int32[] = soaMod.exprA
    var exprBOut: int32[] = soaMod.exprB
    var exprCOut: int32[] = soaMod.exprC
    var exprImmOut: int64[] = soaMod.exprImm
    var exprStrIdOut: int32[] = soaMod.exprStrId
    while exprI < exprCount:
        let kind: UirCoreExprKind = funcSoa.exprKind[exprI]
        let rawA: int32 = funcSoa.exprA[exprI]
        let rawB: int32 = funcSoa.exprB[exprI]
        let rawC: int32 = funcSoa.exprC[exprI]
        let a: int32 = if uirCoreSoaExprFieldNeedsExprRebase(kind, 0): uirCoreSoaRebaseExprId(rawA, exprBase) else: rawA
        let b: int32 = if uirCoreSoaExprFieldNeedsExprRebase(kind, 1): uirCoreSoaRebaseExprId(rawB, exprBase) else: rawB
        let c: int32 = if uirCoreSoaExprFieldNeedsExprRebase(kind, 2): uirCoreSoaRebaseExprId(rawC, exprBase) else: rawC
        seqs.add(exprKindOut, kind)
        seqs.add(exprTypeOut, funcSoa.exprType[exprI])
        seqs.add(exprAOut, a)
        seqs.add(exprBOut, b)
        seqs.add(exprCOut, c)
        seqs.add(exprImmOut, funcSoa.exprImm[exprI])
        seqs.add(exprStrIdOut, funcSoa.exprStrId[exprI])
        exprI = exprI + 1
    soaMod.exprKind = exprKindOut
    soaMod.exprType = exprTypeOut
    soaMod.exprA = exprAOut
    soaMod.exprB = exprBOut
    soaMod.exprC = exprCOut
    soaMod.exprImm = exprImmOut
    soaMod.exprStrId = exprStrIdOut

    var stmtI: int32 = 0
    var stmtKindOut: UirCoreStmtKind[] = soaMod.stmtKind
    var stmtDstOut: int32[] = soaMod.stmtDst
    var stmtExprOut: int32[] = soaMod.stmtExpr
    var stmtNextOut: int32[] = soaMod.stmtNext
    while stmtI < stmtCount:
        let kind: UirCoreStmtKind = funcSoa.stmtKind[stmtI]
        let rawDst: int32 = funcSoa.stmtDst[stmtI]
        let rawExpr: int32 = funcSoa.stmtExpr[stmtI]
        let rawNext: int32 = funcSoa.stmtNext[stmtI]
        let dst: int32 = if kind == msStore: uirCoreSoaRebaseExprId(rawDst, exprBase) else: rawDst
        let expr: int32 = uirCoreSoaRebaseExprId(rawExpr, exprBase)
        let next: int32 = uirCoreSoaRebaseStmtId(rawNext, stmtBase)
        seqs.add(stmtKindOut, kind)
        seqs.add(stmtDstOut, dst)
        seqs.add(stmtExprOut, expr)
        seqs.add(stmtNextOut, next)
        stmtI = stmtI + 1
    soaMod.stmtKind = stmtKindOut
    soaMod.stmtDst = stmtDstOut
    soaMod.stmtExpr = stmtExprOut
    soaMod.stmtNext = stmtNextOut

    var blockI: int32 = 0
    var blockFirstStmtOut: int32[] = soaMod.blockFirstStmt
    var blockTermKindOut: UirCoreTermKind[] = soaMod.blockTermKind
    var blockTermAOut: int32[] = soaMod.blockTermA
    var blockTermBOut: int32[] = soaMod.blockTermB
    var succStartOut: int32[] = soaMod.succStart
    var succLenOut: int32[] = soaMod.succLen
    var predStartOut: int32[] = soaMod.predStart
    var predLenOut: int32[] = soaMod.predLen
    while blockI < blockCount:
        let termKind: UirCoreTermKind = funcSoa.blockTermKind[blockI]
        let rawFirstStmt: int32 = funcSoa.blockFirstStmt[blockI]
        let rawTermA: int32 = funcSoa.blockTermA[blockI]
        let rawTermB: int32 = funcSoa.blockTermB[blockI]
        let firstStmt: int32 = uirCoreSoaRebaseStmtId(rawFirstStmt, stmtBase)
        let termAExpr: int32 = uirCoreSoaRebaseExprId(rawTermA, exprBase)
        let termBExpr: int32 = uirCoreSoaRebaseExprId(rawTermB, exprBase)
        let termABlk: int32 = uirCoreSoaRebaseBlockId(rawTermA, blockBase)
        let termBBlk: int32 = uirCoreSoaRebaseBlockId(rawTermB, blockBase)
        var termA: int32 = rawTermA
        if uirCoreSoaTermExprRebaseNeeded(termKind, 0):
            termA = termAExpr
        elif uirCoreSoaTermBlockRebaseNeeded(termKind, 0):
            termA = termABlk
        var termB: int32 = rawTermB
        if uirCoreSoaTermExprRebaseNeeded(termKind, 1):
            termB = termBExpr
        elif uirCoreSoaTermBlockRebaseNeeded(termKind, 1):
            termB = termBBlk
        seqs.add(blockFirstStmtOut, firstStmt)
        seqs.add(blockTermKindOut, termKind)
        seqs.add(blockTermAOut, termA)
        seqs.add(blockTermBOut, termB)
        seqs.add(succStartOut, funcSoa.succStart[blockI] + succEdgeBase)
        seqs.add(succLenOut, funcSoa.succLen[blockI])
        seqs.add(predStartOut, funcSoa.predStart[blockI] + predEdgeBase)
        seqs.add(predLenOut, funcSoa.predLen[blockI])
        blockI = blockI + 1
    soaMod.blockFirstStmt = blockFirstStmtOut
    soaMod.blockTermKind = blockTermKindOut
    soaMod.blockTermA = blockTermAOut
    soaMod.blockTermB = blockTermBOut
    soaMod.succStart = succStartOut
    soaMod.succLen = succLenOut
    soaMod.predStart = predStartOut
    soaMod.predLen = predLenOut

    var succI: int32 = 0
    var succEdgesOut: int32[] = soaMod.succEdges
    while succI < succCount:
        let rawDst: int32 = funcSoa.succEdges[succI]
        seqs.add(succEdgesOut, uirCoreSoaRebaseBlockId(rawDst, blockBase))
        succI = succI + 1
    soaMod.succEdges = succEdgesOut

    var predI: int32 = 0
    var predEdgesOut: int32[] = soaMod.predEdges
    while predI < predCount:
        let rawSrc: int32 = funcSoa.predEdges[predI]
        seqs.add(predEdgesOut, uirCoreSoaRebaseBlockId(rawSrc, blockBase))
        predI = predI + 1
    soaMod.predEdges = predEdgesOut

    let blockEnd: int32 = blockBase + blockCount
    var checkBi: int32 = blockBase
    while checkBi < blockEnd:
        let sStart: int32 = soaMod.succStart[checkBi]
        let sLen: int32 = soaMod.succLen[checkBi]
        let pStart: int32 = soaMod.predStart[checkBi]
        let pLen: int32 = soaMod.predLen[checkBi]
        if sStart < 0 || sLen < 0 || pStart < 0 || pLen < 0:
            uirCoreSoaModuleRollbackAppend(soaMod, exprBase, stmtBase, blockBase, succEdgeBase, predEdgeBase, funcSpanBase)
            return false
        if sStart + sLen > soaMod.succEdges.len:
            uirCoreSoaModuleRollbackAppend(soaMod, exprBase, stmtBase, blockBase, succEdgeBase, predEdgeBase, funcSpanBase)
            return false
        if pStart + pLen > soaMod.predEdges.len:
            uirCoreSoaModuleRollbackAppend(soaMod, exprBase, stmtBase, blockBase, succEdgeBase, predEdgeBase, funcSpanBase)
            return false
        checkBi = checkBi + 1

    var span: UirCoreSoaFuncSpan
    span.funcIndex = funcIndex
    span.exprStart = exprBase
    span.exprLen = funcSoa.exprKind.len
    span.stmtStart = stmtBase
    span.stmtLen = funcSoa.stmtKind.len
    span.blockStart = blockBase
    span.blockLen = funcSoa.blockFirstStmt.len
    span.succStart = succEdgeBase
    span.succLen = funcSoa.succEdges.len
    span.predStart = predEdgeBase
    span.predLen = funcSoa.predEdges.len
    var funcSpansOut: UirCoreSoaFuncSpan[] = soaMod.funcSpans
    seqs.add(funcSpansOut, span)
    soaMod.funcSpans = funcSpansOut
    return true

fn uirCoreSoaBuildFromModule(module: UirCoreModule): UirCoreSoaModule =
    if (module == nil):
        return nil
    var arena: UirCoreSoaArena = uirCoreSoaArenaZero()
    for fi in 0..<module.funcs.len:
        let func = module.funcs[fi]
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        let est: UirCoreSoaArena = uirCoreSoaEstimateFuncArena(func)
        uirCoreSoaArenaAccumulate(arena, est.exprCap, est.stmtCap, est.blockCap, est.edgeCap)
    let soaMod = uirCoreSoaModuleNew(arena)
    if (soaMod == nil):
        return nil
    for fi in 0..<module.funcs.len:
        let func = module.funcs[fi]
        if (!uirCoreFuncIdValid(func)) || uirCoreFuncIsExtern(func):
            continue
        let funcSoa = uirCoreSoaBuildFromFunc(func)
        # Keep module-level SoA projection resilient: skip malformed function
        # fragments instead of failing the whole module projection.
        if (funcSoa == nil):
            continue
        if ! uirCoreSoaAppendFuncIntoModule(soaMod, fi, funcSoa):
            continue
    return soaMod

fn uirCoreSoaModuleFuncCount(soaMod: UirCoreSoaModule): int32 =
    if (soaMod == nil):
        return 0
    return soaMod.funcSpans.len

fn uirCoreSoaModuleExprCount(soaMod: UirCoreSoaModule): int32 =
    if (soaMod == nil):
        return 0
    return soaMod.exprKind.len

fn uirCoreSoaModuleStmtCount(soaMod: UirCoreSoaModule): int32 =
    if (soaMod == nil):
        return 0
    return soaMod.stmtKind.len

fn uirCoreSoaModuleBlockCount(soaMod: UirCoreSoaModule): int32 =
    if (soaMod == nil):
        return 0
    return soaMod.blockFirstStmt.len

fn uirCoreSoaModuleSuccEdgeCount(soaMod: UirCoreSoaModule): int32 =
    if (soaMod == nil):
        return 0
    return soaMod.succEdges.len

fn uirCoreSoaModulePredEdgeCount(soaMod: UirCoreSoaModule): int32 =
    if (soaMod == nil):
        return 0
    return soaMod.predEdges.len

fn uirCoreSoaModuleEdgesBalanced(soaMod: UirCoreSoaModule): bool =
    if (soaMod == nil):
        return false
    if soaMod.succEdges.len != soaMod.predEdges.len:
        return false
    for bi in 0..<soaMod.blockFirstStmt.len:
        let sStart: int32 = soaMod.succStart[bi]
        let sLen: int32 = soaMod.succLen[bi]
        let pStart: int32 = soaMod.predStart[bi]
        let pLen: int32 = soaMod.predLen[bi]
        if sStart < 0 || sLen < 0 || pStart < 0 || pLen < 0:
            return false
        if sStart + sLen > soaMod.succEdges.len:
            return false
        if pStart + pLen > soaMod.predEdges.len:
            return false
    for i in 0..<soaMod.succEdges.len:
        let dst: int32 = soaMod.succEdges[i]
        if dst < 0 || dst >= soaMod.blockFirstStmt.len:
            return false
    for i in 0..<soaMod.predEdges.len:
        let src: int32 = soaMod.predEdges[i]
        if src < 0 || src >= soaMod.blockFirstStmt.len:
            return false
    return true

fn uirCoreSoaModuleEdgeBalanceReason(soaMod: UirCoreSoaModule): str =
    if (soaMod == nil):
        return "module=nil"
    if soaMod.succEdges.len != soaMod.predEdges.len:
        return "edge_count_mismatch succ=" + intToStr(soaMod.succEdges.len) +
               " pred=" + intToStr(soaMod.predEdges.len)
    for bi in 0..<soaMod.blockFirstStmt.len:
        let sStart: int32 = soaMod.succStart[bi]
        let sLen: int32 = soaMod.succLen[bi]
        let pStart: int32 = soaMod.predStart[bi]
        let pLen: int32 = soaMod.predLen[bi]
        if sStart < 0 || sLen < 0 || pStart < 0 || pLen < 0:
            return "negative_range block=" + intToStr(bi) +
                   " succ=(" + intToStr(sStart) + "," + intToStr(sLen) + ")" +
                   " pred=(" + intToStr(pStart) + "," + intToStr(pLen) + ")"
        if sStart + sLen > soaMod.succEdges.len:
            return "succ_range_oob block=" + intToStr(bi) +
                   " start=" + intToStr(sStart) +
                   " len=" + intToStr(sLen) +
                   " total=" + intToStr(soaMod.succEdges.len)
        if pStart + pLen > soaMod.predEdges.len:
            return "pred_range_oob block=" + intToStr(bi) +
                   " start=" + intToStr(pStart) +
                   " len=" + intToStr(pLen) +
                   " total=" + intToStr(soaMod.predEdges.len)
    for i in 0..<soaMod.succEdges.len:
        let dst: int32 = soaMod.succEdges[i]
        if dst < 0 || dst >= soaMod.blockFirstStmt.len:
            return "succ_edge_invalid idx=" + intToStr(i) +
                   " dst=" + intToStr(dst) +
                   " blocks=" + intToStr(soaMod.blockFirstStmt.len)
    for i in 0..<soaMod.predEdges.len:
        let src: int32 = soaMod.predEdges[i]
        if src < 0 || src >= soaMod.blockFirstStmt.len:
            return "pred_edge_invalid idx=" + intToStr(i) +
                   " src=" + intToStr(src) +
                   " blocks=" + intToStr(soaMod.blockFirstStmt.len)
    return "ok"

fn uirCoreSoaInferExprType(func: UirCoreFunc, e: UirExprId): UirCoreType =
    if (!uirCoreExprIdValid(e)):
        return uirCoreTypeVoid()
    let ek: UirCoreExprKind = uirCoreExprKindOf(e)
    if ek == meConstI64:
        return uirCoreTypeI64()
    if ek == meCmp:
        return uirCoreTypeI32()
    if ek == meCast:
        return uirCoreExprCastTypeOf(e)
    if ek == meLoad:
        return uirCoreExprLoadTypeOf(e)
    if ek == meAddr || ek == meGlobalAddr:
        return uirCoreTypeI64()
    if ek == meLocal:
        let slot: int32 = uirCoreExprLocalIndexOf(e)
        if uirCoreFuncIdValid(func) && slot >= 0 && slot < uirCoreFuncLocalTypesLen(func):
            return uirCoreFuncLocalTypeAt(func, slot)
        return uirCoreTypeI64()
    if ek == meBin:
        let lhsTy: UirCoreType = uirCoreSoaInferExprType(func, uirCoreExprLhsOf(e))
        if lhsTy.kind != mtVoid:
            return lhsTy
        let rhsTy: UirCoreType = uirCoreSoaInferExprType(func, uirCoreExprRhsOf(e))
        if rhsTy.kind != mtVoid:
            return rhsTy
        return uirCoreTypeI64()
    return uirCoreTypeI64()

fn uirCoreSoaInternStr(indexMap: var hashmaps.HashMapStrInt, strPool: var str[], s: str): int32 =
    if len(s) == 0:
        return uirCoreInvalidId()
    var found: bool = false
    let raw: int32 = uirCoreHashMapStrIntGetCompat(indexMap, s, found)
    if found && raw > 0:
        return raw - 1
    let id: int32 = strPool.len
    seqs.add(strPool, uirCoreOwnStr(s))
    hashmaps.hashMapStrIntPut(indexMap, s, id + 1)
    return id

fn uirCoreSoaResolveLabel(labelMap: var hashmaps.HashMapStrInt, label: str): int32 =
    if len(label) == 0:
        return uirCoreInvalidId()
    var found: bool = false
    let raw: int32 = uirCoreHashMapStrIntGetCompat(labelMap, label, found)
    if !found || raw <= 0:
        return uirCoreInvalidId()
    return raw - 1

fn uirCoreSoaAppendExprTree(soa: UirCoreSoa, func: UirCoreFunc, expr: UirExprId,
                            strIndex: var hashmaps.HashMapStrInt, strPool: var str[]): UirExprId =
    if (soa == nil) || (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    var a: int32 = uirCoreInvalidId()
    var b: int32 = uirCoreInvalidId()
    var c: int32 = uirCoreInvalidId()
    var imm: int64 = 0
    var strId: int32 = uirCoreInvalidId()
    let ty: UirCoreType = uirCoreSoaInferExprType(func, expr)
    let ek: UirCoreExprKind = uirCoreExprKindOf(expr)
    if ek == meConstI64:
        imm = uirCoreExprConstValueOf(expr)
    elif ek == meLocal || ek == meAddr:
        a = uirCoreExprLocalIndexOf(expr)
    elif ek == meBin || ek == meCmp:
        a = uirCoreSoaAppendExprTree(soa, func, uirCoreExprLhsOf(expr), strIndex, strPool)
        b = uirCoreSoaAppendExprTree(soa, func, uirCoreExprRhsOf(expr), strIndex, strPool)
    elif ek == meCall:
        strId = uirCoreSoaInternStr(strIndex, strPool, uirCoreExprCalleeOf(expr))
        imm = uirCoreExprArgsLen(expr)
        for ai in 0..<uirCoreExprArgsLen(expr):
            let argId: int32 = uirCoreSoaAppendExprTree(soa, func, uirCoreExprArgAt(expr, ai), strIndex, strPool)
            if ai == 0:
                a = argId
            elif ai == 1:
                b = argId
            elif ai == 2:
                c = argId
    elif ek == meCast:
        a = uirCoreSoaAppendExprTree(soa, func, uirCoreExprCastExprOf(expr), strIndex, strPool)
    elif ek == meLoad:
        a = uirCoreSoaAppendExprTree(soa, func, uirCoreExprAddrExprOf(expr), strIndex, strPool)
    elif ek == meGlobalAddr:
        strId = uirCoreSoaInternStr(strIndex, strPool, uirCoreExprGlobalNameOf(expr))
    return uirCoreSoaAppendExpr(soa, ek, ty, a, b, c, imm, strId)

fn uirCoreSoaBuildFromFunc(func: UirCoreFunc): UirCoreSoa =
    let soa = uirCoreSoaNew()
    if (soa == nil) || (!uirCoreFuncIdValid(func)):
        return soa

    var strIndex: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(uirCoreFuncBlocksLen(func) * 4 + 32)
    var strPool: str[]
    var labelMap: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(uirCoreFuncBlocksLen(func) * 2 + 8)

    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk = uirCoreFuncBlockAt(func, bi)
        let label: str = uirCoreBlockLabelOf(blk)
        if len(label) == 0:
            continue
        hashmaps.hashMapStrIntPut(labelMap, label, bi + 1)

    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk = uirCoreFuncBlockAt(func, bi)
        var firstStmt: int32 = uirCoreInvalidId()
        var prevStmt: int32 = uirCoreInvalidId()
        var termKind: UirCoreTermKind = mtRet
        var termA: int32 = uirCoreInvalidId()
        var termB: int32 = uirCoreInvalidId()
        for si in 0..<uirCoreBlockStmtsLen(blk):
            let st: UirStmtId = uirCoreBlockStmtAt(blk, si)
            var dst: int32 = uirCoreStmtSlotOf(st)
            let exprId: int32 = uirCoreSoaAppendExprTree(soa, func, uirCoreStmtExprOf(st), strIndex, strPool)
            if uirCoreStmtKindOf(st) == msStore:
                dst = uirCoreSoaAppendExprTree(soa, func, uirCoreStmtAddrExprOf(st), strIndex, strPool)
            let stmtId: int32 = uirCoreSoaAppendStmt(soa, uirCoreStmtKindOf(st), dst, exprId, uirCoreInvalidId())
            if firstStmt < 0:
                firstStmt = stmtId
            if prevStmt >= 0:
                soa.stmtNext[prevStmt] = stmtId
            prevStmt = stmtId
        let term: UirCoreTerm = uirCoreBlockTermOf(blk)
        termKind = term.kind
        if termKind == mtRet:
            termA = uirCoreSoaAppendExprTree(soa, func, term.retExpr, &strIndex, &strPool)
        elif termKind == mtBr:
            termA = uirCoreSoaResolveLabel(labelMap, term.target)
        elif termKind == mtCbr:
            termA = uirCoreSoaAppendExprTree(soa, func, term.condExpr, &strIndex, &strPool)
            termB = uirCoreSoaResolveLabel(labelMap, term.targetTrue)
        let _ = uirCoreSoaAppendBlock(soa, firstStmt, termKind, termA, termB)

    var succEdges0: int32[] = soa.succEdges
    for bi in 0..<soa.blockTermKind.len:
        let startEdge: int32 = succEdges0.len
        var edgeCount: int32 = 0
        let k: UirCoreTermKind = soa.blockTermKind[bi]
        if k == mtBr:
            let dst: int32 = soa.blockTermA[bi]
            if dst >= 0 && dst < soa.blockFirstStmt.len:
                seqs.add(succEdges0, dst)
                edgeCount = edgeCount + 1
        elif k == mtCbr:
            let trueDst: int32 = soa.blockTermB[bi]
            if trueDst >= 0 && trueDst < soa.blockFirstStmt.len:
                seqs.add(succEdges0, trueDst)
                edgeCount = edgeCount + 1
            let blk = uirCoreFuncBlockAt(func, bi)
            let term: UirCoreTerm = uirCoreBlockTermOf(blk)
            let falseDst: int32 = uirCoreSoaResolveLabel(labelMap, term.targetFalse)
            if falseDst >= 0 && falseDst < soa.blockFirstStmt.len:
                seqs.add(succEdges0, falseDst)
                edgeCount = edgeCount + 1
        soa.succStart[bi] = startEdge
        soa.succLen[bi] = edgeCount
    soa.succEdges = succEdges0

    var predCounts: int32[]
    for bi in 0..<soa.blockFirstStmt.len:
        add(predCounts, 0)
    for bi in 0..<soa.blockFirstStmt.len:
        let succStartI: int32 = soa.succStart[bi]
        let succLenI: int32 = soa.succLen[bi]
        for ei in succStartI..<succStartI + succLenI:
            if ei < 0 || ei >= soa.succEdges.len:
                continue
            let dst: int32 = soa.succEdges[ei]
            if dst >= 0 && dst < predCounts.len:
                predCounts[dst] = predCounts[dst] + 1

    soa.predEdges = []
    var predTotal: int32 = 0
    for bi in 0..<soa.blockFirstStmt.len:
        soa.predStart[bi] = predTotal
        soa.predLen[bi] = predCounts[bi]
        predTotal = predTotal + predCounts[bi]
    for _i in 0..<predTotal:
        var predEdges0: int32[] = soa.predEdges
        seqs.add(predEdges0, uirCoreInvalidId())
        soa.predEdges = predEdges0
    var writePos: int32[]
    for bi in 0..<soa.blockFirstStmt.len:
        add(writePos, soa.predStart[bi])
    for bi in 0..<soa.blockFirstStmt.len:
        let succStartI: int32 = soa.succStart[bi]
        let succLenI: int32 = soa.succLen[bi]
        for ei in succStartI..<succStartI + succLenI:
            if ei < 0 || ei >= soa.succEdges.len:
                continue
            let dst: int32 = soa.succEdges[ei]
            if dst < 0 || dst >= writePos.len:
                continue
            let pos: int32 = writePos[dst]
            if pos >= 0 && pos < soa.predEdges.len:
                soa.predEdges[pos] = bi
                writePos[dst] = pos + 1
    return soa

fn uirCoreStmtKindName(k: UirCoreStmtKind): str =
    case k
    of msLet:
        return "let"
    of msVar:
        return "var"
    of msAssign:
        return "asgn"
    of msExpr:
        return "expr"
    of msParam:
        return "param"
    of msStore:
        return "store"
    return "stmt"

fn uirCoreTypeKindName(t: UirCoreType): str =
    if t.kind == mtVoid:
        return "void"
    if t.kind == mtI8:
        return t.isUnsigned ? "u8" : "i8"
    if t.kind == mtI16:
        return t.isUnsigned ? "u16" : "i16"
    if t.kind == mtI32:
        return t.isUnsigned ? "u32" : "i32"
    if t.kind == mtI64:
        return t.isUnsigned ? "u64" : "i64"
    if t.kind == mtF32:
        return "f32"
    if t.kind == mtF64:
        return "f64"
    return "type"

fn uirCorePhaseHighTag(): int32 =
    return int32(0)

fn uirCorePhaseLowTag(): int32 =
    return int32(1)

fn uirCorePhaseTagName(tag: int32): str =
    if tag == uirCorePhaseLowTag():
        return "low"
    return "high"

var
    uirCore_typeAliases_cache_module: UirCoreModule
    uirCore_typeAliases_cache: hashmaps.HashMapStrInt
    uirCore_typeAliases_ptr_cache: hashmaps.HashMapPtrInt
    uirCore_typeAliases_cache_len: int32
    uirCore_typeAliases_cache_ready: bool

    uirCore_objTypes_cache_module: UirCoreModule
    uirCore_objTypes_cache: hashmaps.HashMapStrInt
    uirCore_objTypes_ptr_cache: hashmaps.HashMapPtrInt
    uirCore_objTypes_cache_len: int32
    uirCore_objTypes_cache_ready: bool

    uirCore_cstrs_cache_module: UirCoreModule
    uirCore_cstrs_cache: hashmaps.HashMapStrInt
    uirCore_cstrs_cache_len: int32
    uirCore_cstrs_cache_ready: bool

fn uirCoreHashMapStrIntGetCompat(m: hashmaps.HashMapStrInt, key: str, found: var bool): int32 =
    if len(key) == 0 || m.mask == 0:
        found = false
        return -1
    if m.states.len <= 0 || m.keys.len <= 0 || m.vals.len <= 0:
        found = false
        return -1
    var mask: int32 = int32(m.mask)
    if mask < 0:
        found = false
        return -1
    if mask >= m.states.len || mask >= m.keys.len || mask >= m.vals.len:
        let cap0: int32 = m.states.len
        if m.keys.len < cap0 || m.vals.len < cap0:
            found = false
            return -1
        mask = cap0 - 1
    if mask < 0:
        found = false
        return -1
    var probe: int32 = int32(hashmaps.hashMapHash64StrMeta(key) & uint64(mask))
    var scanned: int32 = 0
    let __for_start_scanned_compat = scanned
    for __for_scanned_compat in __for_start_scanned_compat..mask:
        scanned = __for_scanned_compat
        let st: uint8 = m.states[probe]
        if st == uint8(0):
            found = false
            return -1
        if hashmaps.hashMapStrEq(m.keys[probe], key):
            found = true
            return m.vals[probe]
        probe = (probe + 1) & mask
        scanned = scanned + 1
    found = false
    return -1

fn uirCore_buildTypeAliasIndexCache(module: UirCoreModule) =
    if (module == nil):
        uirCore_typeAliases_cache_module = nil
        uirCore_typeAliases_cache_ready = false
        uirCore_typeAliases_cache_len = 0
        return
    let cacheCap: int32 = module.typeAliases.len * 8 + 64
    uirCore_typeAliases_cache_module = module
    uirCore_typeAliases_cache = hashmaps.hashMapStrIntInit(cacheCap)
    uirCore_typeAliases_ptr_cache = hashmaps.hashMapPtrIntInit(cacheCap)
    for i in 0..<module.typeAliases.len:
        let a: UirCoreTypeAlias = module.typeAliases[i]
        if uirCoreStrPtrSane(a.name) && len(a.name) > 0:
            hashmaps.hashMapStrIntPut(uirCore_typeAliases_cache, a.name, i + 1)
            hashmaps.hashMapPtrIntPut(uirCore_typeAliases_ptr_cache, int64(rawmemAsVoid(a.name)), i + 1)
    uirCore_typeAliases_cache_len = module.typeAliases.len
    uirCore_typeAliases_cache_ready = true

fn uirCore_buildObjTypeIndexCache(module: UirCoreModule) =
    if (module == nil):
        uirCore_objTypes_cache_module = nil
        uirCore_objTypes_cache_ready = false
        uirCore_objTypes_cache_len = 0
        return
    let cacheCap: int32 = module.objTypes.len * 8 + 64
    uirCore_objTypes_cache_module = module
    uirCore_objTypes_cache = hashmaps.hashMapStrIntInit(cacheCap)
    uirCore_objTypes_ptr_cache = hashmaps.hashMapPtrIntInit(cacheCap)
    for i in 0..<module.objTypes.len:
        let t: UirCoreObjType = module.objTypes[i]
        if len(t.name) > 0:
            hashmaps.hashMapStrIntPut(uirCore_objTypes_cache, t.name, i + 1)
            if uirCoreStrPtrSane(t.name):
                hashmaps.hashMapPtrIntPut(uirCore_objTypes_ptr_cache, int64(rawmemAsVoid(t.name)), i + 1)
    uirCore_objTypes_cache_len = module.objTypes.len
    uirCore_objTypes_cache_ready = true

fn uirCore_buildCStringIndexCache(module: UirCoreModule) =
    if (module == nil):
        uirCore_cstrs_cache_module = nil
        uirCore_cstrs_cache_ready = false
        uirCore_cstrs_cache_len = 0
        return
    let total: int32 = uirCoreModuleCStringsLen(module)
    uirCore_cstrs_cache_module = module
    uirCore_cstrs_cache = hashmaps.hashMapStrIntInit(total * 2 + 8)
    for i in 0..<total:
        let value: str = uirCoreModuleCStringValueAt(module, i)
        if len(value) > 0:
            hashmaps.hashMapStrIntPut(uirCore_cstrs_cache, value, i + 1)
    uirCore_cstrs_cache_len = total
    uirCore_cstrs_cache_ready = true

fn uirCoreTypeI32(): UirCoreType =
    var t: UirCoreType
    t.kind = mtI32
    t.isUnsigned = false
    return t

fn uirCoreTypeI8(): UirCoreType =
    var t: UirCoreType
    t.kind = mtI8
    t.isUnsigned = false
    return t

