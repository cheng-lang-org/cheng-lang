# MIR/UIR core types.
# Runtime path is ID/SoA based (`UirExprId/UirStmtId/UirBlockId/UirFuncId`).
import std/seqs as seqs
import std/os
import std/strings
import std/result
import std/hashmaps
import std/rawmem_support
import std/crash_trace_internal

@importc("cheng_func_ptr_shadow_remember")
fn cheng_func_ptr_shadow_remember(p: ptr)
@importc("cheng_func_ptr_shadow_recover")
fn cheng_func_ptr_shadow_recover(p: uint64): ptr
@importc("cheng_malloc")
fn uirCoreHeapNew(size: int32): ptr
@importc("cheng_zero_mem_compat")
fn uirCoreMemZero(dest: ptr, size: int32)

fn uirCoreReserveTargetCap(currentCap: int32, needLen: int32, minCap: int32): int32 =
    var target: int32 = currentCap
    if target < minCap:
        target = minCap
    if target < 8:
        target = 8
    while target < needLen:
        if target < 1024:
            target = target * 2
        else:
            target = target + (target / 2)
    return target

fn add(seqInst: var int32[], val: int32) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var int64[], val: int64) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn add(seqInst: var str[], val: str) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

var
    uirCore_ownedStr_ptr_index: hashmaps.HashMapPtrInt
    uirCore_ownedStr_owned_ptr_index: hashmaps.HashMapPtrInt
    uirCore_ownedStr_text_index: hashmaps.HashMapStrInt
    uirCore_ownedStr_ptr_values: str[]

fn uirCoreOwnStrCacheReset() =
    uirCore_ownedStr_ptr_index = hashmaps.hashMapPtrIntInit(1024)
    uirCore_ownedStr_owned_ptr_index = hashmaps.hashMapPtrIntInit(1024)
    uirCore_ownedStr_text_index = hashmaps.hashMapStrIntInit(1024)
    setLen(uirCore_ownedStr_ptr_values, 0)

fn uirCoreOwnStr(s: str): str =
    if !uirCoreStrPtrSane(s):
        return ""
    let ptrKey: int64 = int64(rawmemAsVoid(s))
    if ptrKey != 0:
        var foundOwnedPtr: bool = false
        let rawOwnedPtr: int32 = hashmaps.hashMapPtrIntGet(uirCore_ownedStr_owned_ptr_index, ptrKey, foundOwnedPtr)
        let idxOwnedPtr: int32 = rawOwnedPtr - 1
        if foundOwnedPtr && idxOwnedPtr >= 0 && idxOwnedPtr < uirCore_ownedStr_ptr_values.len:
            return uirCore_ownedStr_ptr_values[idxOwnedPtr]
        var foundOwned: bool = false
        let raw: int32 = hashmaps.hashMapPtrIntGet(uirCore_ownedStr_ptr_index, ptrKey, foundOwned)
        let idx: int32 = raw - 1
        if foundOwned && idx >= 0 && idx < uirCore_ownedStr_ptr_values.len:
            return uirCore_ownedStr_ptr_values[idx]
    if len(s) <= 0:
        return ""
    var foundText: bool = false
    let rawText: int32 = uirCoreHashMapStrIntGetCompat(uirCore_ownedStr_text_index, s, foundText)
    let idxText: int32 = rawText - 1
    if foundText && idxText >= 0 && idxText < uirCore_ownedStr_ptr_values.len:
        let ownedText: str = uirCore_ownedStr_ptr_values[idxText]
        if ptrKey != 0:
            hashmaps.hashMapPtrIntPut(uirCore_ownedStr_ptr_index, ptrKey, idxText + 1)
        return ownedText
    let cloned: str = strings.__cheng_str_clone(s)
    if ptrKey != 0 && uirCoreStrPtrSane(cloned) && len(cloned) > 0:
        let nextIdx: int32 = uirCore_ownedStr_ptr_values.len
        seqs.add(uirCore_ownedStr_ptr_values, cloned)
        hashmaps.hashMapStrIntPut(uirCore_ownedStr_text_index, cloned, nextIdx + 1)
        hashmaps.hashMapPtrIntPut(uirCore_ownedStr_ptr_index, ptrKey, nextIdx + 1)
        let clonedPtr: int64 = int64(rawmemAsVoid(cloned))
        if clonedPtr != 0:
            hashmaps.hashMapPtrIntPut(uirCore_ownedStr_owned_ptr_index, clonedPtr, nextIdx + 1)
    return cloned

fn uirCoreLookupOwnedStr(s: str): str =
    if !uirCoreStrPtrSane(s):
        return ""
    let ptrKey: int64 = int64(rawmemAsVoid(s))
    if ptrKey == 0:
        return ""
    var foundOwnedPtr: bool = false
    let rawOwnedPtr: int32 = hashmaps.hashMapPtrIntGet(uirCore_ownedStr_owned_ptr_index, ptrKey, foundOwnedPtr)
    let idxOwnedPtr: int32 = rawOwnedPtr - 1
    if foundOwnedPtr && idxOwnedPtr >= 0 && idxOwnedPtr < uirCore_ownedStr_ptr_values.len:
        return uirCore_ownedStr_ptr_values[idxOwnedPtr]
    var foundOwned: bool = false
    let raw: int32 = hashmaps.hashMapPtrIntGet(uirCore_ownedStr_ptr_index, ptrKey, foundOwned)
    let idx: int32 = raw - 1
    if foundOwned && idx >= 0 && idx < uirCore_ownedStr_ptr_values.len:
        return uirCore_ownedStr_ptr_values[idx]
    return ""

fn uirCoreHostPtrSane(ptrVal: int64): bool =
    if ptrVal == 0:
        return true
    if ptrVal <= 4096:
        return false
    if ptrVal >= int64(0x0001000000000000):
        return false
    let low32: int64 = ptrVal & int64(0xffffffff)
    let high32: int64 = (ptrVal >> 32) & int64(0xffffffff)
    if high32 == 0:
        return false
    # Host/runtime object pointers on Darwin arm64 stay in a much lower range than
    # dyn-key/shadow-style pseudo-pointers. Values like 0x2d1c00000056 are not
    # plausible heap/code addresses and should not be treated as recoverable refs.
    if high32 >= int64(0x1000):
        return false
    # macOS arm64 user pointers commonly live in the low single-digit high32
    # range (for example 0x00000007_xxxxxxxx). Keep high32==1 reserved for
    # shadow/dyn keys, and reject tiny low32 offsets that are typical of
    # truncated/corrupted pseudo-pointers rather than heap objects.
    if high32 == 1 && low32 < int64(1 << 24):
        return false
    if high32 > 1 && high32 < int64(0x1000) && low32 < int64(1 << 20):
        return false
    if low32 == 0 && high32 <= 1:
        return false
    if high32 == low32 && low32 > 0 && low32 < int64(1 << 20):
        return false
    return true

fn uirCoreOwnStrSafe(s: str): str =
    if !uirCoreStrPtrSane(s):
        return ""
    return uirCoreOwnStr(s)

fn uirCoreOwnStrBestEffort(primary: str, fallback: str = ""): str =
    if uirCoreStrPtrSane(primary):
        return uirCoreOwnStr(primary)
    if uirCoreStrPtrSane(fallback):
        return uirCoreOwnStr(fallback)
    return ""

fn uirCoreCanonicalStr(s: str): str =
    if !uirCoreStrPtrSane(s):
        return ""
    if len(s) <= 0:
        return ""
    let cached: str = uirCoreLookupOwnedStr(s)
    if len(cached) > 0:
        return cached
    return s

fn uirCoreStrPtrSane(s: str): bool =
    let objPtr: int64 = int64(rawmemAsVoid(s))
    if uirCoreHostPtrSane(objPtr):
        return true
    if objPtr <= 4096:
        return false
    let low32: int64 = objPtr & int64(0xffffffff)
    let high32: int64 = (objPtr >> 32) & int64(0xffffffff)
    # Fresh Cheng sidecar/selfhost heaps can materialize owned strings in the
    # low 32-bit address space. Accept those here so function/global/type names
    # survive arena release, but keep the stricter host-ptr check for function
    # refs and other shadowable pointers.
    if high32 == 0 && low32 >= int64(1 << 24):
        return true
    return false

fn uirCoreSeqPtrSane(ptrVal: int64): bool =
    if !uirCoreHostPtrSane(ptrVal):
        return false
    if (ptrVal & int64(3)) != 0:
        return false
    return true

type
    UirCoreTypeKind = enum
        mtVoid, mtI8, mtI16, mtI32, mtI64, mtF32, mtF64

type
    UirCoreType =
        kind: UirCoreTypeKind
        isUnsigned: bool

type
    UirCoreBinOp = enum
        mbAdd, mbSub, mbMul, mbSdiv, mbSmod,
        mbAnd, mbOr, mbXor, mbShl, mbShr

type
    UirCoreCmpOp = enum
        mcEq, mcNe, mcLt, mcLe, mcGt, mcGe

type
    UirCoreExprKind = enum
        meConstI64, meBin, meCmp, meLocal, meCall, meCast,
        meAddr, meLoad, meGlobalAddr

type
    UirExprId = int32

type
    UirStmtId = int32

type
    UirBlockId = int32

type
    UirFuncId = int32

type
    # SoA hard-cut runtime alias contract: statement handle is ID-only.
    UirCoreStmt = UirStmtId

type
    UirCoreStmtKind = enum
        msLet, msVar, msAssign, msExpr, msParam, msStore

type
    UirCoreParam =
        name: str
        slot: int32
        ty: UirCoreType
        typeKey: str

type
    UirCoreTermKind = enum
        mtRet, mtBr, mtCbr

type
    UirCoreTerm =
        kind: UirCoreTermKind
        retExpr: UirExprId
        condExpr: UirExprId
        target: str
        targetTrue: str
        targetFalse: str

type
    # Object locals are represented as an i64 pointer slot.
    # - frameOff >= 0: compiler-allocated stack storage (base = localsArea + frameOff)
    # - frameOff < 0: external pointer (e.g. ref param/local)
    UirCoreObjLocal =
        slot: int32
        objTypeName: str
        # Fully-resolved type key (e.g. `seq_int32`), used by backend-only lowering.
        typeKey: str
        frameOff: int32

type
    UirCoreFuncDynState = ref
        name: str
        linkName: str
        originFile: str
        declOrdinal: int32
        sourceAstIndex: int32
        isExtern: bool
        retType: UirCoreType
        retTypeKey: str
        objFrameSize: int32
        phaseTag: int32
        highUirChecked: bool
        lowUirLowered: bool
        phaseFallbackReason: str
        params: UirCoreParam[]
        localTypes: UirCoreType[]
        objLocals: UirCoreObjLocal[]
        blocks: UirBlockId[]

type
    UirCoreFuncObj =
        name: str
        linkName: str
        originFile: str
        declOrdinal: int32
        sourceAstIndex: int32
        dynId: int32
        dynStatePtr: int64
        isExtern: bool
        retType: UirCoreType
        retTypeKey: str
        params: UirCoreParam[]
        localTypes: UirCoreType[]
        objLocals: UirCoreObjLocal[]
        objFrameSize: int32
        blocks: UirBlockId[]
        blockBuffer: ptr
        blockLen: int32
        blockCap: int32
        # P4 phase contract: single-IR dual-phase bookkeeping.
        phaseTag: int32
        highUirChecked: bool
        lowUirLowered: bool
        phaseFallbackReason: str

type
    UirCoreFuncObjPtr = UirCoreFuncObjPtr

type
    UirCoreFunc = ref UirCoreFuncObj

type
    UirCoreCString =
        label: str
        value: str

type
    UirCoreTypeAlias =
        name: str
        ty: UirCoreType

type
    UirCoreObjField =
        name: str
        ty: UirCoreType
        offset: int32

type
    UirCoreObjType =
        name: str
        size: int32
        alignPow2: int32
        fields: UirCoreObjField[]

type
    UirCoreGlobal =
        name: str
        ty: UirCoreType
        init: int64
        hasInit: bool
        originFile: str

type
    UirCoreModule = ref
        target: str
        funcs: UirCoreFunc[]
        cstrs: UirCoreCString[]
        cstrLabels: str[]
        cstrValues: str[]
        globals: UirCoreGlobal[]
        globalNames: str[]
        globalTypesRaw: int32[]
        globalInits: int64[]
        globalHasInitBits: int32[]
        globalOriginFiles: str[]
        typeAliases: UirCoreTypeAlias[]
        objTypes: UirCoreObjType[]

type
    UirCoreSoa = ref
        exprKind: UirCoreExprKind[]
        exprType: UirCoreType[]
        exprA: int32[]
        exprB: int32[]
        exprC: int32[]
        exprImm: int64[]
        exprStrId: int32[]
        stmtKind: UirCoreStmtKind[]
        stmtDst: int32[]
        stmtExpr: int32[]
        stmtNext: int32[]
        blockFirstStmt: int32[]
        blockTermKind: UirCoreTermKind[]
        blockTermA: int32[]
        blockTermB: int32[]
        succStart: int32[]
        succLen: int32[]
        succEdges: int32[]
        predStart: int32[]
        predLen: int32[]
        predEdges: int32[]

    UirCoreSoaArena =
        exprCap: int32
        stmtCap: int32
        blockCap: int32
        edgeCap: int32

    UirCoreSoaFuncSpan =
        funcIndex: int32
        exprStart: int32
        exprLen: int32
        stmtStart: int32
        stmtLen: int32
        blockStart: int32
        blockLen: int32
        succStart: int32
        succLen: int32
        predStart: int32
        predLen: int32

    UirCoreSoaModule = ref
        arena: UirCoreSoaArena
        exprKind: UirCoreExprKind[]
        exprType: UirCoreType[]
        exprA: int32[]
        exprB: int32[]
        exprC: int32[]
        exprImm: int64[]
        exprStrId: int32[]
        stmtKind: UirCoreStmtKind[]
        stmtDst: int32[]
        stmtExpr: int32[]
        stmtNext: int32[]
        blockFirstStmt: int32[]
        blockTermKind: UirCoreTermKind[]
        blockTermA: int32[]
        blockTermB: int32[]
        succStart: int32[]
        succLen: int32[]
        succEdges: int32[]
        predStart: int32[]
        predLen: int32[]
        predEdges: int32[]
        funcSpans: UirCoreSoaFuncSpan[]

var
    uirCore_funcNameIndex: hashmaps.HashMapPtrInt
    uirCore_funcNameKeys: int64[]
    uirCore_funcDynIndex: hashmaps.HashMapPtrInt
    uirCore_funcDynKeys: int64[]

type
    UirCoreFuncDynCache = ref
        nameVals: str[]
        linkVals: str[]
        dynVals: UirCoreFuncDynState[]
        dynAddrs: int64[]
        nextDynId: int32

var
    uirCore_funcDynCache: UirCoreFuncDynCache
    uirCore_nextFuncDynId: int32

const uirCoreFuncDynIdMax: int32 = 1 << 20

fn uirCoreFuncDynIdSane(dynId: int32): bool =
    return dynId > 0 && dynId <= uirCoreFuncDynIdMax

fn uirCoreFuncPtrRememberable(ptrVal: int64): bool =
    if ptrVal == 0:
        return false
    if ptrVal <= 4096:
        return false
    if ptrVal >= int64(0x0001000000000000):
        return false
    let high32: int64 = (ptrVal >> 32) & int64(0xffffffff)
    let low32: int64 = ptrVal & int64(0xffffffff)
    if high32 == 1 && low32 > 0 && low32 <= int64(uirCoreFuncDynIdMax):
        return false
    return true

fn uirCoreHostVoidPtr(ptrVal: int64): ptr =
    return ptr(uint64(ptrVal))

fn uirCoreFuncFromPtrVal(ptrVal: int64): UirCoreFunc =
    return UirCoreFunc(uirCoreHostVoidPtr(ptrVal))

fn uirCoreFuncObjPtrFromPtrVal(ptrVal: int64): UirCoreFuncObjPtr =
    return UirCoreFuncObjPtr(uirCoreHostVoidPtr(ptrVal))

fn uirCoreFuncPtrKnown(ptrVal: int64): bool =
    if uirCoreHostPtrSane(ptrVal):
        return true
    if ptrVal <= 4096:
        return false
    let high32: int64 = (ptrVal >> 32) & int64(0xffffffff)
    if high32 != 0:
        return false
    let recovered: ptr = cheng_func_ptr_shadow_recover(uint64(ptrVal))
    if recovered == nil:
        return false
    return int64(recovered) == ptrVal

fn uirCoreRememberFuncPtr(func: UirCoreFunc) =
    if func == nil:
        return
    let ptrVal: int64 = int64(rawmemAsVoid(func))
    if !uirCoreFuncPtrRememberable(ptrVal):
        return
    cheng_func_ptr_shadow_remember(uirCoreHostVoidPtr(ptrVal))

fn uirCoreRememberFuncDynAddr(func: UirCoreFunc) =
    if func == nil:
        return
    let dynId: int32 = uirCoreFuncDynId(func)
    if !uirCoreFuncDynIdSane(dynId):
        return
    let ptrVal: int64 = uirCoreRecoverFuncPtr(int64(rawmemAsVoid(func)))
    if !uirCoreFuncPtrRememberable(ptrVal):
        return
    cheng_func_ptr_shadow_remember(uirCoreHostVoidPtr(ptrVal))
    let cache: UirCoreFuncDynCache = uirCoreEnsureFuncDynCache()
    if cache == nil:
        return
    let needLen: int32 = dynId
    var dynAddrs0: int64[] = cache.dynAddrs
    if dynAddrs0.buffer == nil || dynAddrs0.cap < needLen:
        cheng__seqGrowToRaw(&dynAddrs0.buffer, &dynAddrs0.cap, needLen, int32(sizeof int64))
    let oldLen: int32 = dynAddrs0.len
    if oldLen < needLen:
        dynAddrs0.len = needLen
        for i in oldLen..<needLen:
            dynAddrs0[i] = 0
    for i in 0..<dynAddrs0.len:
        if i == dynId - 1:
            continue
        if dynAddrs0[i] == ptrVal:
            dynAddrs0[i] = 0
    dynAddrs0[dynId - 1] = ptrVal
    cache.dynAddrs = dynAddrs0

fn uirCoreFuncFromDynKey(dynKey: int64): UirCoreFunc =
    if dynKey <= 0:
        return nil
    let high32: int64 = (dynKey >> 32) & int64(0xffffffff)
    let low32: int64 = dynKey & int64(0xffffffff)
    if high32 != 1 || low32 <= 0:
        return nil
    let dynId: int32 = int32(low32)
    if !uirCoreFuncDynIdSane(dynId):
        return nil
    let cache: UirCoreFuncDynCache = uirCoreEnsureFuncDynCache()
    if cache == nil:
        return nil
    let idx: int32 = dynId - 1
    if idx < 0 || idx >= cache.dynAddrs.len:
        return nil
    let ptrVal: int64 = cache.dynAddrs[idx]
    if !uirCoreFuncPtrKnown(ptrVal):
        return nil
    return uirCoreFuncFromPtrVal(ptrVal)

fn uirCoreRecoverFuncPtr(ptrVal: int64): int64 =
    if uirCoreHostPtrSane(ptrVal):
        return ptrVal
    let recovered: ptr = cheng_func_ptr_shadow_recover(uint64(ptrVal))
    if recovered == nil:
        return 0
    return int64(recovered)

fn uirCoreEnsureFuncDynCache(): UirCoreFuncDynCache =
    var cache: UirCoreFuncDynCache = uirCore_funcDynCache
    if cache == nil:
        cache = new(UirCoreFuncDynCache)
        if cache == nil:
            return nil
        cache.nameVals = []
        cache.linkVals = []
        cache.dynVals = []
        cache.dynAddrs = []
        cache.nextDynId = 1
        uirCore_funcDynCache = cache
    if !uirCoreFuncDynSeqSane(cache.dynVals):
        cache.dynVals = []
    if !uirCoreInt64SeqSane(cache.dynAddrs):
        cache.dynAddrs = []
    if !uirCoreStrSeqSane(cache.nameVals):
        cache.nameVals = []
    if !uirCoreStrSeqSane(cache.linkVals):
        cache.linkVals = []
    if !uirCoreFuncDynIdSane(cache.nextDynId):
        cache.nextDynId = 1
    return cache

fn uirCoreCacheDynState(dynId: int32, dyn: UirCoreFuncDynState) =
    if !uirCoreFuncDynIdSane(dynId) || dyn == nil:
        return
    let cache: UirCoreFuncDynCache = uirCoreEnsureFuncDynCache()
    if cache == nil:
        return
    let needLen: int32 = dynId
    var dynVals0: UirCoreFuncDynState[] = cache.dynVals
    if dynVals0.buffer == nil || dynVals0.cap < needLen:
        cheng__seqGrowToRaw(&dynVals0.buffer, &dynVals0.cap, needLen, int32(sizeof ptr))
    let oldLen: int32 = dynVals0.len
    if oldLen < needLen:
        dynVals0.len = needLen
        for i in oldLen..<needLen:
            dynVals0[i] = nil
    memRetain(rawmemAsVoid(dyn))
    dynVals0[dynId - 1] = dyn
    cache.dynVals = dynVals0

fn uirCoreCachedDynStateById(dynId: int32): UirCoreFuncDynState =
    if !uirCoreFuncDynIdSane(dynId):
        return nil
    let cache: UirCoreFuncDynCache = uirCoreEnsureFuncDynCache()
    if cache == nil:
        return nil
    let idx: int32 = dynId - 1
    if idx < 0 || idx >= cache.dynVals.len:
        return nil
    let dyn: UirCoreFuncDynState = cache.dynVals[idx]
    if dyn == nil:
        return nil
    let dynPtr: int64 = int64(rawmemAsVoid(dyn))
    if !uirCoreHostPtrSane(dynPtr):
        var dynVals0: UirCoreFuncDynState[] = cache.dynVals
        dynVals0[idx] = nil
        cache.dynVals = dynVals0
        return nil
    uirCoreSanitizeFuncDynPayload(dyn)
    return dyn

fn uirCoreFindDynIdByPtrKey(ptrKey: int64): int32 =
    let recoveredKey: int64 = uirCoreRecoverFuncPtr(ptrKey)
    if !uirCoreHostPtrSane(recoveredKey):
        return 0
    let cache: UirCoreFuncDynCache = uirCoreEnsureFuncDynCache()
    if cache == nil:
        return 0
    let dynAddrCount: int32 = cache.dynAddrs.len
    if dynAddrCount <= 0:
        return 0
    for rev in 0..<dynAddrCount:
        let i: int32 = dynAddrCount - 1 - rev
        if cache.dynAddrs[i] != recoveredKey:
            continue
        let dynId: int32 = i + 1
        if !uirCoreFuncDynIdSane(dynId):
            continue
        return dynId
    return 0

fn uirCoreFuncNameCacheKey(func: UirCoreFunc): int64 =
    if func == nil:
        return 0
    let f0: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if f0 == nil:
        return 0
    let dynId: int32 = uirCoreFuncDynId(func)
    if !uirCoreFuncDynIdSane(dynId):
        return 0
    return int64(0x100000000) + int64(dynId)

fn uirCoreFuncPtrKey(func: UirCoreFunc): int64 =
    if func == nil:
        return 0
    return uirCoreRecoverFuncPtr(int64(rawmemAsVoid(func)))

fn uirCoreFuncDynId(func: UirCoreFunc): int32 =
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return 0
    if uirCoreFuncDynIdSane(funcObj->dynId):
        return funcObj->dynId
    let recoveredDynId: int32 = uirCoreFindDynIdByPtrKey(int64(rawmemAsVoid(func)))
    if !uirCoreFuncDynIdSane(recoveredDynId):
        return 0
    funcObj->dynId = recoveredDynId
    return recoveredDynId

fn uirCoreAllocFuncDynId(): int32 =
    if !uirCoreFuncDynIdSane(uirCore_nextFuncDynId):
        uirCore_nextFuncDynId = 1
    let out: int32 = uirCore_nextFuncDynId
    uirCore_nextFuncDynId = uirCore_nextFuncDynId + 1
    if !uirCoreFuncDynIdSane(uirCore_nextFuncDynId):
        uirCore_nextFuncDynId = 1
    return out

fn uirCoreFuncObjPtr(func: UirCoreFunc): UirCoreFuncObjPtr =
    if func == nil:
        return nil
    let rawPtrVal: int64 = int64(rawmemAsVoid(func))
    if uirCoreFuncPtrKnown(rawPtrVal):
        return uirCoreFuncObjPtrFromPtrVal(rawPtrVal)
    let ptrVal: int64 = uirCoreRecoverFuncPtr(rawPtrVal)
    if !uirCoreFuncPtrKnown(ptrVal):
        return nil
    return uirCoreFuncObjPtrFromPtrVal(ptrVal)

fn uirCoreFuncDynStatePtr(func: UirCoreFunc): UirCoreFuncDynState =
    if !uirCoreFuncIdValid(func):
        return nil
    let dynId: int32 = uirCoreFuncDynId(func)
    if uirCoreFuncDynIdSane(dynId):
        let cached: UirCoreFuncDynState = uirCoreCachedDynStateForFunc(func, dynId)
        if cached != nil:
            return cached
        return nil
    return nil

fn uirCoreFuncObjPtrFromKey(ptrKey: int64): UirCoreFuncObjPtr =
    let recoveredKey: int64 = uirCoreRecoverFuncPtr(ptrKey)
    if !uirCoreFuncPtrKnown(recoveredKey):
        return nil
    return uirCoreFuncObjPtrFromPtrVal(recoveredKey)

fn uirCoreFuncDynStatePtrFromKey(ptrKey: int64): UirCoreFuncDynState =
    let f0: UirCoreFuncObjPtr = uirCoreFuncObjPtrFromKey(ptrKey)
    if f0 == nil:
        return nil
    let recoveredKey: int64 = uirCoreRecoverFuncPtr(ptrKey)
    let func0: UirCoreFunc = uirCoreHostPtrSane(recoveredKey) ? uirCoreFuncFromPtrVal(recoveredKey) : nil
    var dynId: int32 = f0->dynId
    if !uirCoreFuncDynIdSane(dynId):
        dynId = uirCoreFindDynIdByPtrKey(ptrKey)
        if uirCoreFuncDynIdSane(dynId):
            f0->dynId = dynId
    if uirCoreFuncDynIdSane(dynId):
        let cached: UirCoreFuncDynState =
            (func0 != nil) ? uirCoreCachedDynStateForFunc(func0, dynId) : uirCoreCachedDynStateById(dynId)
        if cached != nil:
            return cached
        return nil
    return nil

fn uirCoreEnsureFuncDynByPtrKey(ptrKey: int64): UirCoreFuncDynState =
    let direct: UirCoreFuncDynState = uirCoreFuncDynStatePtrFromKey(ptrKey)
    if direct != nil:
        return direct
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtrFromKey(ptrKey)
    if funcObj == nil || !uirCoreFuncDynIdSane(funcObj->dynId):
        return nil
    let cached0: UirCoreFuncDynState = uirCoreCachedDynStateById(funcObj->dynId)
    if cached0 != nil:
        return cached0
    let created: UirCoreFuncDynState = uirCoreFuncDynStateNew()
    if created == nil:
        return nil
    memRetain(rawmemAsVoid(created))
    created.name = uirCoreOwnStrBestEffort(funcObj->name)
    created.linkName = uirCoreOwnStrBestEffort(funcObj->linkName)
    created.originFile = uirCoreOwnStrBestEffort(funcObj->originFile)
    created.declOrdinal = funcObj->declOrdinal
    created.sourceAstIndex = funcObj->sourceAstIndex
    created.isExtern = funcObj->isExtern
    created.retType = funcObj->retType
    created.retTypeKey = uirCoreOwnStrBestEffort(funcObj->retTypeKey)
    created.objFrameSize = funcObj->objFrameSize
    created.phaseTag = funcObj->phaseTag
    created.highUirChecked = funcObj->highUirChecked
    created.lowUirLowered = funcObj->lowUirLowered
    created.phaseFallbackReason = uirCoreOwnStrBestEffort(funcObj->phaseFallbackReason, "high_uir_unchecked")
    created.params = uirCoreCloneParamSeq(funcObj->params)
    created.localTypes = uirCoreCloneTypeSeq(funcObj->localTypes)
    created.objLocals = uirCoreCloneObjLocalSeq(funcObj->objLocals)
    created.blocks = uirCoreCloneBlockSeq(funcObj->blocks)
    uirCoreCacheDynState(funcObj->dynId, created)
    return created

fn uirCoreFuncNameOfPtrKey(ptrKey: int64): str =
    let dyn: UirCoreFuncDynState = uirCoreFuncDynStatePtrFromKey(ptrKey)
    if dyn != nil:
        return dyn.name
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtrFromKey(ptrKey)
    if funcObj == nil:
        return ""
    return funcObj->name

fn uirCoreFuncOriginFileOfPtrKey(ptrKey: int64): str =
    let dyn: UirCoreFuncDynState = uirCoreFuncDynStatePtrFromKey(ptrKey)
    if dyn != nil:
        return dyn.originFile
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtrFromKey(ptrKey)
    if funcObj == nil:
        return ""
    return funcObj->originFile

fn uirCoreFuncRetTypeOfPtrKey(ptrKey: int64): UirCoreType =
    let dyn: UirCoreFuncDynState = uirCoreFuncDynStatePtrFromKey(ptrKey)
    if dyn != nil:
        return dyn.retType
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtrFromKey(ptrKey)
    if funcObj == nil:
        return uirCoreTypeVoid()
    return funcObj->retType

fn uirCoreFindFuncDynIndexByPtrKey(ptrKey: int64): int32 =
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtrFromKey(ptrKey)
    if funcObj == nil:
        return -1
    if uirCoreFuncDynIdSane(funcObj->dynId):
        return funcObj->dynId - 1
    if uirCoreFuncDynStatePtrFromKey(ptrKey) != nil:
        return 0
    return -1

fn uirCoreFuncObjMatchesDynState(func: UirCoreFunc, dyn: UirCoreFuncDynState): bool =
    let f0: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if f0 == nil || dyn == nil:
        return false
    if len(f0->name) > 0 && len(dyn.name) > 0 && f0->name != dyn.name:
        return false
    if len(f0->originFile) > 0 && len(dyn.originFile) > 0 && f0->originFile != dyn.originFile:
        return false
    if f0->declOrdinal >= 0 && dyn.declOrdinal >= 0 && f0->declOrdinal != dyn.declOrdinal:
        return false
    if f0->sourceAstIndex >= 0 && dyn.sourceAstIndex >= 0 && f0->sourceAstIndex != dyn.sourceAstIndex:
        return false
    if f0->retType.kind != dyn.retType.kind:
        return false
    if f0->retType.isUnsigned != dyn.retType.isUnsigned:
        return false
    return true

fn uirCoreFuncObjMatchesDynIdentity(func: UirCoreFunc, dyn: UirCoreFuncDynState): bool =
    let f0: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if f0 == nil || dyn == nil:
        return false
    if f0->declOrdinal >= 0 && dyn.declOrdinal >= 0 &&
       f0->sourceAstIndex >= 0 && dyn.sourceAstIndex >= 0 &&
       f0->declOrdinal == dyn.declOrdinal &&
       f0->sourceAstIndex == dyn.sourceAstIndex:
        return true
    let sameNamePtr: bool = uirCoreStrPtrSane(f0->name) && uirCoreStrPtrSane(dyn.name) &&
                            rawmemAsVoid(f0->name) == rawmemAsVoid(dyn.name)
    if sameNamePtr:
        if f0->declOrdinal >= 0 && dyn.declOrdinal >= 0 && f0->declOrdinal != dyn.declOrdinal:
            return false
        if f0->sourceAstIndex >= 0 && dyn.sourceAstIndex >= 0 && f0->sourceAstIndex != dyn.sourceAstIndex:
            return false
        return true
    if len(f0->name) > 0 && len(dyn.name) > 0 && f0->name == dyn.name:
        if f0->declOrdinal >= 0 && dyn.declOrdinal >= 0 && f0->declOrdinal != dyn.declOrdinal:
            return false
        if f0->sourceAstIndex >= 0 && dyn.sourceAstIndex >= 0 && f0->sourceAstIndex != dyn.sourceAstIndex:
            return false
        return true
    let sameOriginPtr: bool = uirCoreStrPtrSane(f0->originFile) && uirCoreStrPtrSane(dyn.originFile) &&
                              rawmemAsVoid(f0->originFile) == rawmemAsVoid(dyn.originFile)
    if sameOriginPtr:
        if f0->sourceAstIndex >= 0 && dyn.sourceAstIndex >= 0 && f0->sourceAstIndex != dyn.sourceAstIndex:
            return false
        return true
    if len(f0->originFile) > 0 && len(dyn.originFile) > 0 &&
       f0->originFile == dyn.originFile:
        if f0->sourceAstIndex >= 0 && dyn.sourceAstIndex >= 0 && f0->sourceAstIndex != dyn.sourceAstIndex:
            return false
        return true
    return false

fn uirCoreFuncDynSeqSane(vals: UirCoreFuncDynState[]): bool =
    let count: int32 = vals.len
    if count < 0 || count > (1 << 20):
        return false
    if vals.cap < count || vals.cap > (1 << 20):
        return false
    if count <= 0:
        return vals.buffer == nil || vals.cap == 0
    return uirCoreSeqPtrSane(int64(rawmemAsVoid(vals.buffer)))

fn uirCoreInt64SeqSane(vals: int64[]): bool =
    let count: int32 = vals.len
    if count < 0 || count > (1 << 20):
        return false
    if vals.cap < count || vals.cap > (1 << 20):
        return false
    if count <= 0:
        return vals.buffer == nil || vals.cap == 0
    return uirCoreSeqPtrSane(int64(rawmemAsVoid(vals.buffer)))

fn uirCoreStrSeqSane(vals: str[]): bool =
    let count: int32 = vals.len
    if count < 0 || count > (1 << 20):
        return false
    if vals.cap < count || vals.cap > (1 << 20):
        return false
    if count <= 0:
        return vals.buffer == nil || vals.cap == 0
    return uirCoreSeqPtrSane(int64(rawmemAsVoid(vals.buffer)))

fn uirCoreTypeSeqSane(vals: UirCoreType[]): bool =
    let count: int32 = vals.len
    if count < 0 || count > (1 << 20):
        return false
    if vals.cap < count || vals.cap > (1 << 20):
        return false
    if count <= 0:
        return vals.buffer == nil || vals.cap == 0
    return uirCoreSeqPtrSane(int64(rawmemAsVoid(vals.buffer)))

fn uirCoreParamSeqSane(vals: UirCoreParam[]): bool =
    let count: int32 = vals.len
    if count < 0 || count > (1 << 20):
        return false
    if vals.cap < count || vals.cap > (1 << 20):
        return false
    if count <= 0:
        return vals.buffer == nil || vals.cap == 0
    return uirCoreSeqPtrSane(int64(rawmemAsVoid(vals.buffer)))

fn uirCoreObjLocalSeqSane(vals: UirCoreObjLocal[]): bool =
    let count: int32 = vals.len
    if count < 0 || count > (1 << 20):
        return false
    if vals.cap < count || vals.cap > (1 << 20):
        return false
    if count <= 0:
        return vals.buffer == nil || vals.cap == 0
    return uirCoreSeqPtrSane(int64(rawmemAsVoid(vals.buffer)))

fn uirCoreSanitizeFuncDynPayload(dyn: UirCoreFuncDynState) =
    if dyn == nil:
        return
    if !uirCoreParamSeqSane(dyn.params):
        dyn.params = []
    if !uirCoreTypeSeqSane(dyn.localTypes):
        dyn.localTypes = []
    if !uirCoreObjLocalSeqSane(dyn.objLocals):
        dyn.objLocals = []
    if !uirCoreBlockSeqSane(dyn.blocks):
        dyn.blocks = []

fn uirCoreEnsureFuncDynTables() =
    if uirCore_nextFuncDynId <= 0:
        uirCore_nextFuncDynId = 1

fn uirCoreInitFuncDynState(out: UirCoreFuncDynState) =
    if out == nil:
        return
    out.name = ""
    out.linkName = ""
    out.originFile = ""
    out.declOrdinal = -1
    out.sourceAstIndex = -1
    out.isExtern = false
    out.retType = uirCoreTypeVoid()
    out.retTypeKey = ""
    out.objFrameSize = 0
    out.phaseTag = uirCorePhaseHighTag()
    out.highUirChecked = false
    out.lowUirLowered = false
    out.phaseFallbackReason = "high_uir_unchecked"
    out.params = []
    out.localTypes = []
    out.objLocals = []
    out.blocks = []
    uirCoreSanitizeFuncDynPayload(out)

fn uirCoreFuncDynStateNew(): UirCoreFuncDynState =
    var out: UirCoreFuncDynState = new(UirCoreFuncDynState)
    uirCoreInitFuncDynState(out)
    return out

fn uirCoreFuncDynCanPreservePayload(funcObj: UirCoreFuncObjPtr,
                                    payloadSrc: UirCoreFuncDynState): bool =
    if funcObj == nil || payloadSrc == nil:
        return false
    if len(funcObj->name) > 0 && len(payloadSrc.name) > 0 && funcObj->name == payloadSrc.name:
        return true
    if funcObj->declOrdinal >= 0 && payloadSrc.declOrdinal >= 0 &&
       funcObj->declOrdinal == payloadSrc.declOrdinal:
        return true
    if funcObj->sourceAstIndex >= 0 && payloadSrc.sourceAstIndex >= 0 &&
       funcObj->sourceAstIndex == payloadSrc.sourceAstIndex:
        return true
    if len(funcObj->originFile) > 0 && len(payloadSrc.originFile) > 0 &&
       funcObj->originFile == payloadSrc.originFile:
        return true
    return false

fn uirCoreCloneFuncDynFromObj(funcObj: UirCoreFuncObjPtr,
                              payloadSrc: UirCoreFuncDynState = nil): UirCoreFuncDynState =
    if funcObj == nil:
        return nil
    let created: UirCoreFuncDynState = uirCoreFuncDynStateNew()
    if created == nil:
        return nil
    memRetain(rawmemAsVoid(created))
    created.name = uirCoreOwnStrBestEffort(funcObj->name)
    created.linkName = uirCoreOwnStrBestEffort(funcObj->linkName)
    if (payloadSrc != nil) && uirCoreStrPtrSane(payloadSrc.originFile) && len(payloadSrc.originFile) > 0:
        created.originFile = uirCoreOwnStrBestEffort(payloadSrc.originFile)
    else:
        created.originFile = uirCoreOwnStrBestEffort(funcObj->originFile)
    created.declOrdinal = ((payloadSrc != nil) && payloadSrc.declOrdinal >= 0) ? payloadSrc.declOrdinal : funcObj->declOrdinal
    created.sourceAstIndex = ((payloadSrc != nil) && payloadSrc.sourceAstIndex >= 0) ? payloadSrc.sourceAstIndex : funcObj->sourceAstIndex
    created.isExtern = ((payloadSrc != nil) ? payloadSrc.isExtern : funcObj->isExtern)
    created.retType = funcObj->retType
    if (payloadSrc != nil) && uirCoreStrPtrSane(payloadSrc.retTypeKey) && len(payloadSrc.retTypeKey) > 0:
        created.retTypeKey = uirCoreOwnStrBestEffort(payloadSrc.retTypeKey)
    else:
        created.retTypeKey = uirCoreOwnStrBestEffort(funcObj->retTypeKey)
    created.objFrameSize = funcObj->objFrameSize
    created.phaseTag = funcObj->phaseTag
    created.highUirChecked = funcObj->highUirChecked
    created.lowUirLowered = funcObj->lowUirLowered
    created.phaseFallbackReason = uirCoreOwnStrBestEffort(funcObj->phaseFallbackReason, "high_uir_unchecked")
    let preservePayload: bool = uirCoreFuncDynCanPreservePayload(funcObj, payloadSrc)
    if preservePayload:
        created.params = uirCoreCloneParamSeq(payloadSrc.params)
        created.localTypes = uirCoreCloneTypeSeq(payloadSrc.localTypes)
        created.objLocals = uirCoreCloneObjLocalSeq(payloadSrc.objLocals)
        created.blocks = uirCoreCloneBlockSeq(payloadSrc.blocks)
    else:
        created.params = uirCoreCloneParamSeq(funcObj->params)
        created.localTypes = uirCoreCloneTypeSeq(funcObj->localTypes)
        created.objLocals = uirCoreCloneObjLocalSeq(funcObj->objLocals)
        created.blocks = uirCoreCloneBlockSeq(funcObj->blocks)
    uirCoreSanitizeFuncDynPayload(created)
    return created

fn uirCoreRefreshFuncDynFromObj(func: UirCoreFunc, dynId: int32): UirCoreFuncDynState =
    if !uirCoreFuncDynIdSane(dynId):
        return nil
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return nil
    let cached0: UirCoreFuncDynState = uirCoreCachedDynStateById(dynId)
    let created: UirCoreFuncDynState = uirCoreCloneFuncDynFromObj(funcObj, cached0)
    if created == nil:
        return nil
    uirCoreCacheDynState(dynId, created)
    return created

fn uirCoreCloneFuncDynFromFunc(func: UirCoreFunc): UirCoreFuncDynState =
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return nil
    let created: UirCoreFuncDynState = uirCoreFuncDynStateNew()
    if created == nil:
        return nil
    memRetain(rawmemAsVoid(created))
    created.name = uirCoreOwnStrBestEffort(funcObj->name)
    created.linkName = uirCoreOwnStrBestEffort(funcObj->linkName)
    created.originFile = uirCoreOwnStrBestEffort(funcObj->originFile)
    created.declOrdinal = funcObj->declOrdinal
    created.sourceAstIndex = funcObj->sourceAstIndex
    created.isExtern = funcObj->isExtern
    created.retType = funcObj->retType
    created.retTypeKey = uirCoreOwnStrBestEffort(funcObj->retTypeKey)
    created.objFrameSize = funcObj->objFrameSize
    created.phaseTag = funcObj->phaseTag
    created.highUirChecked = funcObj->highUirChecked
    created.lowUirLowered = funcObj->lowUirLowered
    created.phaseFallbackReason = uirCoreOwnStrBestEffort(funcObj->phaseFallbackReason, "high_uir_unchecked")
    created.params = uirCoreCloneParamSeq(funcObj->params)
    created.localTypes = uirCoreCloneTypeSeq(funcObj->localTypes)
    created.objLocals = uirCoreCloneObjLocalSeq(funcObj->objLocals)
    created.blocks = uirCoreCloneBlockSeq(funcObj->blocks)
    uirCoreSanitizeFuncDynPayload(created)
    return created

fn uirCoreCachedDynStateForFunc(func: UirCoreFunc, dynId: int32): UirCoreFuncDynState =
    if !uirCoreFuncDynIdSane(dynId):
        return nil
    return uirCoreCachedDynStateById(dynId)

fn uirCoreFindFuncNameCacheIndex(func: UirCoreFunc): int32 =
    if func == nil:
        return -1
    let dyn: UirCoreFuncDynState = uirCoreFuncDynStatePtr(func)
    if dyn != nil:
        if len(dyn.name) > 0 || len(dyn.linkName) > 0:
            let dynId: int32 = uirCoreFuncDynId(func)
            return uirCoreFuncDynIdSane(dynId) ? (dynId - 1) : 0
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return -1
    if len(funcObj->name) <= 0 && len(funcObj->linkName) <= 0:
        return -1
    return uirCoreFuncDynIdSane(funcObj->dynId) ? (funcObj->dynId - 1) : 0

fn uirCoreRecordFuncNames(func: UirCoreFunc) =
    return

fn uirCoreFindFuncDynIndex(func: UirCoreFunc): int32 =
    let direct: UirCoreFuncDynState = uirCoreFuncDynStatePtr(func)
    let dynId: int32 = uirCoreFuncDynId(func)
    if uirCoreFuncDynIdSane(dynId):
        return dynId - 1
    if direct != nil:
        return 0
    return -1

fn uirCoreFuncDyn(func: UirCoreFunc): UirCoreFuncDynState =
    let direct: UirCoreFuncDynState = uirCoreFuncDynStatePtr(func)
    if direct != nil:
        uirCoreSanitizeFuncDynPayload(direct)
        return direct
    let dynId: int32 = uirCoreFuncDynId(func)
    if !uirCoreFuncDynIdSane(dynId):
        return nil
    let cached: UirCoreFuncDynState = uirCoreCachedDynStateForFunc(func, dynId)
    if cached == nil:
        return nil
    return cached

fn uirCoreEnsureFuncDyn(func: UirCoreFunc): UirCoreFuncDynState =
    let direct: UirCoreFuncDynState = uirCoreFuncDynStatePtr(func)
    if direct != nil:
        uirCoreSanitizeFuncDynPayload(direct)
        return direct
    let dynId: int32 = uirCoreFuncDynId(func)
    if !uirCoreFuncDynIdSane(dynId):
        return nil
    let cached: UirCoreFuncDynState = uirCoreCachedDynStateForFunc(func, dynId)
    if cached != nil:
        return cached
    let created: UirCoreFuncDynState = uirCoreCloneFuncDynFromFunc(func)
    if created == nil:
        return nil
    uirCoreCacheDynState(dynId, created)
    return created

fn uirCoreEncodeType(ty: UirCoreType): int32 =
    let kindBits: int32 = int32(ty.kind) & 255
    let unsignedBits: int32 = ty.isUnsigned ? 256 : 0
    return kindBits | unsignedBits

fn uirCoreTypeKindRaw(ty: UirCoreType): int32 =
    return uirCoreEncodeType(ty) & 255

fn uirCoreTypeIsUnsigned(ty: UirCoreType): bool =
    return (uirCoreEncodeType(ty) & 256) != 0

fn uirCoreTypeWithUnsigned(ty: UirCoreType, isUnsigned: bool): UirCoreType =
    var out: UirCoreType = ty
    out.isUnsigned = isUnsigned
    return out

fn uirCoreEncodeBinOp(op: UirCoreBinOp): int32 =
    return int32(op)

fn uirCoreDecodeBinOp(raw: int32): UirCoreBinOp =
    if raw < int32(mbAdd) || raw > int32(mbShr):
        return mbAdd
    return UirCoreBinOp(raw)

fn uirCoreEncodeCmpOp(op: UirCoreCmpOp): int32 =
    return int32(op)

fn uirCoreDecodeCmpOp(raw: int32): UirCoreCmpOp =
    if raw < int32(mcEq) || raw > int32(mcGe):
        return mcEq
    return UirCoreCmpOp(raw)

fn uirCoreEncodeExprKind(kind: UirCoreExprKind): int32 =
    return int32(kind)

fn uirCoreDecodeExprKind(raw: int32): UirCoreExprKind =
    if raw < int32(meConstI64) || raw > int32(meGlobalAddr):
        return meConstI64
    return UirCoreExprKind(raw)

fn uirCoreEncodeStmtKind(kind: UirCoreStmtKind): int32 =
    return int32(kind)

fn uirCoreDecodeStmtKind(raw: int32): UirCoreStmtKind =
    if raw < int32(msLet) || raw > int32(msStore):
        return msExpr
    return UirCoreStmtKind(raw)

fn uirCoreDecodeType(raw: int32): UirCoreType =
    var out: UirCoreType
    let kindBits: int32 = raw & 255
    if kindBits < int32(mtVoid) || kindBits > int32(mtF64):
        out.kind = mtVoid
        out.isUnsigned = false
        return out
    out.kind = UirCoreTypeKind(kindBits)
    out.isUnsigned = (raw & 256) != 0
    return out

fn add(seqInst: var UirExprId[][], val: UirExprId[]) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

