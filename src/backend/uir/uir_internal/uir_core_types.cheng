        return ""
    return uirCore_exprPool_globalName[expr]

fn uirCoreExprArgsSeqSane(args: UirExprId[]): bool =
    let argc: int32 = args.len
    if argc <= 0:
        return true
    if argc > (1 << 20):
        return false
    if args.cap < argc || args.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(rawmemAsVoid(args.buffer))
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreExprMirroredArgCount(expr: UirExprId): int32 =
    if !uirCoreExprIdValid(expr):
        return 0
    if uirCoreExprKindOf(expr) != meCall:
        return 0
    let lhs: UirExprId = uirCore_exprPool_lhs[expr]
    let rhs: UirExprId = uirCore_exprPool_rhs[expr]
    if uirCoreExprIdValid(lhs) && uirCoreExprIdValid(rhs):
        return 2
    if uirCoreExprIdValid(lhs):
        return 1
    return 0

fn uirCoreStmtSeqSane(stmts: UirStmtId[]): bool =
    let stmtCount: int32 = stmts.len
    if stmtCount <= 0:
        return true
    if stmtCount > (1 << 20):
        return false
    if stmts.cap < stmtCount || stmts.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(rawmemAsVoid(stmts.buffer))
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreExprArgsLen(expr: UirExprId): int32 =
    if (!uirCoreExprIdValid(expr)):
        return 0
    if expr < uirCore_exprPool_argLenFlat.len:
        let flatLen: int32 = uirCore_exprPool_argLenFlat[expr]
        if flatLen > 0:
            return flatLen
    if expr < uirCore_exprPool_args.len:
        let args: UirExprId[] = uirCore_exprPool_args[expr]
        if uirCoreExprArgsSeqSane(args):
            let argc: int32 = len(args)
            if argc > 0:
                return argc
        elif uirCoreExprKindOf(expr) != meCall:
            return 0
    return uirCoreExprMirroredArgCount(expr)

fn uirCoreExprArgAt(expr: UirExprId, idx: int32): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    if idx < 0:
        return uirCoreInvalidId()
    if expr < uirCore_exprPool_argLenFlat.len:
        let flatLen: int32 = uirCore_exprPool_argLenFlat[expr]
        if idx < flatLen:
            let start: int32 = uirCore_exprPool_argStart[expr]
            let pos: int32 = start + idx
            if pos >= 0 && pos < uirCore_exprArgsFlat.len:
                return uirCore_exprArgsFlat[pos]
    if expr < uirCore_exprPool_args.len:
        let args: UirExprId[] = uirCore_exprPool_args[expr]
        if uirCoreExprArgsSeqSane(args):
            let argc: int32 = len(args)
            if idx < argc:
                return args[idx]
        elif uirCoreExprKindOf(expr) != meCall:
            return uirCoreInvalidId()
    if uirCoreExprKindOf(expr) == meCall:
        let lhs: UirExprId = uirCore_exprPool_lhs[expr]
        let rhs: UirExprId = uirCore_exprPool_rhs[expr]
        if idx == 0 && uirCoreExprIdValid(lhs):
            return lhs
        if idx == 1 && uirCoreExprIdValid(lhs) && uirCoreExprIdValid(rhs):
            return rhs
    return uirCoreInvalidId()

fn uirCoreExprSetArgAt(expr: UirExprId, idx: int32, val: UirExprId) =
    if (!uirCoreExprIdValid(expr)):
        return
    if expr >= uirCore_exprPool_args.len:
        panic "uirCore_types: expr args column out of sync"
    if idx < 0:
        panic "uirCore_types: expr arg index out of bounds"
    if expr < uirCore_exprPool_argLenFlat.len:
        let flatLen: int32 = uirCore_exprPool_argLenFlat[expr]
        if flatLen > 0:
            if idx >= flatLen:
                panic "uirCore_types: expr arg index out of bounds"
            let start: int32 = uirCore_exprPool_argStart[expr]
            let pos: int32 = start + idx
            if pos < 0 || pos >= uirCore_exprArgsFlat.len:
                panic "uirCore_types: expr arg flat column out of sync"
            uirCore_exprArgsFlat[pos] = val
    var args: UirExprId[] = uirCore_exprPool_args[expr]
    let materializedLen: int32 = uirCoreExprArgsLen(expr)
    if !uirCoreExprArgsSeqSane(args) || len(args) != materializedLen:
        # Recover call args from the mirrored lhs/rhs columns so late rewrite
        # passes can keep running even if the seq column was not materialized.
        var recovered: UirExprId[]
        if materializedLen > 0:
            reserve(recovered, materializedLen)
            setLen(recovered, materializedLen)
            for ai in 0..<materializedLen:
                recovered[ai] = uirCoreExprArgAt(expr, ai)
        args = recovered
    if idx < 0 || idx >= args.len:
        panic "uirCore_types: expr arg index out of bounds"
    args[idx] = val
    if uirCoreExprKindOf(expr) == meCall:
        if args.len > 0:
            uirCore_exprPool_lhs[expr] = args[0]
        if args.len > 1:
            uirCore_exprPool_rhs[expr] = args[1]
    uirCore_exprPool_args[expr] = args

fn uirCoreExprLhsOf(expr: UirExprId): UirExprId =
    if (!uirCoreExprIdValid(expr)):
        return uirCoreInvalidId()
    return uirCore_exprPool_lhs[expr]

fn uirCoreExprSetLhs(expr: UirExprId, lhs: UirExprId) =
