fn add(seqInst: var UirCoreParam[], val: UirCoreParam) =
    seqs.add(seqInst, val)

fn add(seqInst: var UirCoreCString[], val: UirCoreCString) =
    seqs.add(seqInst, val)

fn add(seqInst: var UirCoreTypeAlias[], val: UirCoreTypeAlias) =
