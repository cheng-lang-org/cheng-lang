fn uirCoreBlockStmtsLen(blk: UirBlockId): int32 =
    if (!uirCoreBlockIdValid(blk)):
        return 0
    if blk < uirCore_blockPool_stmtLenFlat.len:
        let stmtLen: int32 = uirCore_blockPool_stmtLenFlat[blk]
        if stmtLen < 0:
            return 0
        if stmtLen == 0:
            return 0
        if blk < uirCore_blockPool_stmtStart.len:
            let stmtStart: int32 = uirCore_blockPool_stmtStart[blk]
            if stmtStart >= 0 && stmtStart + stmtLen <= uirCoreBlockStmtsFlatLen():
                return stmtLen
    if blk < uirCore_blockPool_stmtsSeq.len:
        let stmtsSeq: UirStmtId[] = uirCore_blockPool_stmtsSeq[blk]
        if uirCoreStmtSeqSane(stmtsSeq):
            return stmtsSeq.len
    return 0

fn uirCoreBlockStmtAt(blk: UirBlockId, idx: int32): UirStmtId =
    if (!uirCoreBlockIdValid(blk)):
        return uirCoreInvalidId()
    if blk < uirCore_blockPool_stmtLenFlat.len && blk < uirCore_blockPool_stmtStart.len:
        let stmtLen: int32 = uirCore_blockPool_stmtLenFlat[blk]
        if idx >= 0 && idx < stmtLen:
            let stmtStart: int32 = uirCore_blockPool_stmtStart[blk]
            let pos: int32 = stmtStart + idx
            if stmtStart >= 0 && pos >= 0 && pos < uirCoreBlockStmtsFlatLen():
                return uirCoreBlockStmtsFlatAt(pos)
    if blk < uirCore_blockPool_stmtsSeq.len:
        let stmtsSeq: UirStmtId[] = uirCore_blockPool_stmtsSeq[blk]
        if uirCoreStmtSeqSane(stmtsSeq):
            if idx < 0 || idx >= stmtsSeq.len:
                return uirCoreInvalidId()
            return stmtsSeq[idx]
    return uirCoreInvalidId()

fn uirCoreBlockSetStmtAt(blk: UirBlockId, idx: int32, stmt: UirStmtId) =
    if (!uirCoreBlockIdValid(blk)):
        return
    let stmtLen: int32 = uirCoreBlockStmtsLen(blk)
    if idx < 0 || idx >= stmtLen:
        panic "uirCore_types: block stmt index out of bounds"
    if blk < uirCore_blockPool_stmtStart.len:
        let stmtStart: int32 = uirCore_blockPool_stmtStart[blk]
        let pos: int32 = stmtStart + idx
        if stmtStart < 0 || pos < 0 || pos >= uirCoreBlockStmtsFlatLen():
            panic "uirCore_types: block stmt flat column out of sync"
        uirCoreBlockStmtsFlatSet(pos, stmt)
    if blk < uirCore_blockPool_stmtsSeq.len:
        var stmtsSeq: UirStmtId[] = uirCore_blockPool_stmtsSeq[blk]
        if uirCoreStmtSeqSane(stmtsSeq) && idx < stmtsSeq.len:
            stmtsSeq[idx] = stmt
            uirCoreWriteStmtSeq2D(&uirCore_blockPool_stmtsSeq, blk, stmtsSeq)

fn uirCoreBlockSetStmts(blk: UirBlockId, stmts: UirStmtId[]) =
    if (!uirCoreBlockIdValid(blk)):
        return
    if blk < uirCore_blockPool_stmtsSeq.len:
        uirCoreWriteStmtSeq2D(&uirCore_blockPool_stmtsSeq, blk, stmts)
    let start: int32 = uirCoreBlockStmtsFlatLen()
    let stmtLen: int32 = stmts.len
    if stmtLen > 0:
        for i in 0..<stmtLen:
            uirCoreBlockStmtsFlatAppend(stmts[i])
    uirCore_blockPool_stmtStart[blk] = start
    uirCore_blockPool_stmtLenFlat[blk] = stmtLen

