fn uirCoreFuncBlocksLen(func: UirCoreFunc): int32 =
    if !uirCoreFuncIdValid(func):
        return 0
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    if dyn == nil:
        return 0
    let blocks: UirBlockId[] = dyn.blocks
    if uirCoreBlockSeqSane(blocks):
        return blocks.len
    return 0

fn uirCoreFuncBlocksLenObjFirst(func: UirCoreFunc): int32 =
    if !uirCoreFuncIdValid(func):
        return 0
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    var dynBlocks: UirBlockId[]
    if dyn != nil:
        dynBlocks = dyn.blocks
    else:
        dynBlocks = []
    var objBlocks: UirBlockId[]
    if funcObj != nil:
        objBlocks = funcObj->blocks
    else:
        objBlocks = []
    let dynSane: bool = uirCoreBlockSeqSane(dynBlocks)
    let objSane: bool = uirCoreBlockSeqSane(objBlocks)
    if dynSane && dynBlocks.len > 0:
        return dynBlocks.len
    if objSane && objBlocks.len > 0:
        if dyn != nil && (!dynSane || dynBlocks.len != objBlocks.len):
            dyn.blocks = uirCoreCloneBlockSeq(objBlocks)
        if dyn != nil && dyn.isExtern:
            dyn.isExtern = false
        if funcObj != nil && funcObj->isExtern:
            funcObj->isExtern = false
        return objBlocks.len
    if dynSane:
        return dynBlocks.len
    if objSane:
        return objBlocks.len
    if funcObj != nil && funcObj->blockBuffer != nil && funcObj->blockLen > 0:
        return funcObj->blockLen
    return 0

fn uirCoreFuncBlockAt(func: UirCoreFunc, idx: int32): UirBlockId =
    if !uirCoreFuncIdValid(func):
        return 0
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    if dyn == nil:
        return 0
    let blocks: UirBlockId[] = dyn.blocks
    if !uirCoreBlockSeqSane(blocks):
        return 0
    if idx < 0 || idx >= blocks.len:
        return 0
    return blocks[idx]

fn uirCoreFuncBlockAtObjFirst(func: UirCoreFunc, idx: int32): UirBlockId =
    if !uirCoreFuncIdValid(func):
        return 0
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    var dynBlocks: UirBlockId[]
    if dyn != nil:
        dynBlocks = dyn.blocks
    else:
        dynBlocks = []
    var objBlocks: UirBlockId[]
    if funcObj != nil:
        objBlocks = funcObj->blocks
    else:
        objBlocks = []
    let dynSane: bool = uirCoreBlockSeqSane(dynBlocks)
    let objSane: bool = uirCoreBlockSeqSane(objBlocks)
    if dynSane && idx >= 0 && idx < dynBlocks.len:
        return dynBlocks[idx]
    if objSane && idx >= 0 && idx < objBlocks.len:
        if dyn != nil && (!dynSane || dynBlocks.len != objBlocks.len):
            dyn.blocks = uirCoreCloneBlockSeq(objBlocks)
        if dyn != nil && dyn.isExtern:
            dyn.isExtern = false
        if funcObj != nil && funcObj->isExtern:
            funcObj->isExtern = false
        return objBlocks[idx]
    if funcObj != nil && funcObj->blockBuffer != nil && idx >= 0 && idx < funcObj->blockLen:
        let elemBytes: int32 = idx * int32(sizeof UirBlockId)
        return load(rawmem_support.rawmemPtrAdd(funcObj->blockBuffer, elemBytes))
    return 0

fn uirCoreFuncSetBlockAt(func: UirCoreFunc, idx: int32, blk: UirBlockId) =
    if (!uirCoreFuncIdValid(func)):
        return
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn == nil:
        return
    var blocks0: UirBlockId[] = dyn.blocks
    if uirCoreBlockSeqSane(blocks0) && idx >= 0 && idx < blocks0.len:
        uirCoreWriteBlock(&blocks0, idx, blk)
        dyn.blocks = blocks0
        uirCoreFuncSyncBlocks(func)

fn uirCoreFuncSetBlocks(func: UirCoreFunc, blocks: UirBlockId[]) =
    if (!uirCoreFuncIdValid(func)):
        return
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn == nil:
        return
    dyn.blocks = blocks
    uirCoreFuncSyncBlocks(func)

fn uirCoreFuncIsExtern(func: UirCoreFunc): bool =
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    let dbgBoot: bool = os.getEnvDefault("BACKEND_DEBUG_BOOT", "") == "1"
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    let dbgNameObj: str = (funcObj != nil) ? funcObj->name : ""
    let dbgNameDyn: str = (dyn != nil) ? dyn.name : ""
    let dbgName: str = len(dbgNameObj) > 0 ? dbgNameObj : dbgNameDyn
    let dbgTrack: bool = dbgBoot && (dbgName == "main" || dbgName == "backendMain")
    if dyn != nil:
        let blocks: UirBlockId[] = dyn.blocks
        if uirCoreBlockSeqSane(blocks) && blocks.len > 0:
            if dyn.isExtern:
                dyn.isExtern = false
            if funcObj != nil && funcObj->isExtern:
                funcObj->isExtern = false
            if dbgTrack:
                os.writeLine(os.get_stderr(),
                             "[backend] dbg_is_extern.heal name=" + dbgName +
                             " blocks=" + intToStr(blocks.len) +
                             " dyn_id=" + intToStr(uirCoreFuncDynId(func)))
                os.c_fflush(os.get_stderr())
            return false
    if dbgTrack:
        os.writeLine(os.get_stderr(),
                     "[backend] dbg_is_extern name=" + dbgName +
                     " obj=" + ((funcObj != nil && funcObj->isExtern) ? "1" : "0") +
                     " dyn=" + ((dyn != nil && dyn.isExtern) ? "1" : "0") +
                     " blocks=" + intToStr(uirCoreFuncBlocksLen(func)) +
                     " dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " ptr=" + int64ToStr(uirCoreFuncPtrKey(func)))
        os.c_fflush(os.get_stderr())
    if dyn == nil:
        if funcObj == nil:
            return false
        return funcObj->isExtern
    return dyn.isExtern

