fn Ok_UirCoreModule(value: UirCoreModule): Result[UirCoreModule] =
    var out: Result[UirCoreModule]
    if (value == nil):
        out.ok = false
        ErrorNewInto(out.err, "uir core module ok(nil) is forbidden")
        return out
    out.ok = true
    out.value = value
    ErrorOkInto(out.err)
    return out

