fn uirCoreWriteObjLocal(seqInst: UirCoreObjLocal[]*, idx: int32, val: UirCoreObjLocal) =
    if (seqInst == nil):
        panic "uirCore_types: nil seq pointer"
    if idx < 0 || idx >= seqInst->len:
        panic "uirCore_types: seq index out of bounds"
    seqInst[idx] = val

fn uirCoreWriteObjField(seqInst: UirCoreObjField[]*, idx: int32, val: UirCoreObjField) =
    if (seqInst == nil):
        panic "uirCore_types: nil seq pointer"
    if idx < 0 || idx >= seqInst->len:
        panic "uirCore_types: seq index out of bounds"
    seqInst[idx] = val

fn uirCoreOwnExprStrings(expr: UirExprId) =
    if (!uirCoreExprIdValid(expr)):
        return
    let kind: UirCoreExprKind = uirCoreExprKindOf(expr)
    if kind == meCall:
        uirCore_exprPool_callee[expr] = uirCoreCanonicalStr(uirCoreExprCalleeOf(expr))
        let argc: int32 = uirCoreExprArgsLen(expr)
        for i in 0..<argc:
            let argExpr: UirExprId = uirCoreExprArgAt(expr, i)
            if uirCoreExprIdValid(argExpr):
                uirCoreOwnExprStrings(argExpr)
        return
    if kind == meGlobalAddr:
        uirCore_exprPool_globalName[expr] = uirCoreCanonicalStr(uirCoreExprGlobalNameOf(expr))
        return
    if kind == meBin || kind == meCmp:
        uirCoreOwnExprStrings(uirCoreExprLhsOf(expr))
        uirCoreOwnExprStrings(uirCoreExprRhsOf(expr))
        return
    if kind == meCast:
        uirCoreOwnExprStrings(uirCoreExprCastExprOf(expr))
        return
    if kind == meLoad:
        uirCoreOwnExprStrings(uirCoreExprAddrExprOf(expr))
        return

fn uirCoreOwnTermStrings(term: UirCoreTerm): UirCoreTerm =
    var out: UirCoreTerm = term
    if out.kind == mtRet:
        uirCoreOwnExprStrings(out.retExpr)
        return out
    if out.kind == mtBr:
        out.target = uirCoreCanonicalStr(out.target)
        return out
    if out.kind == mtCbr:
        out.targetTrue = uirCoreCanonicalStr(out.targetTrue)
        out.targetFalse = uirCoreCanonicalStr(out.targetFalse)
        uirCoreOwnExprStrings(out.condExpr)
        return out
    return out

fn uirCoreOwnStmtStrings(stmt: UirStmtId): UirStmtId =
    if (!uirCoreStmtIdValid(stmt)):
        return stmt
    uirCore_stmtPool_name[stmt] = uirCoreCanonicalStr(uirCoreStmtNameOf(stmt))
    uirCoreOwnExprStrings(uirCoreStmtExprOf(stmt))
    uirCoreOwnExprStrings(uirCoreStmtAddrExprOf(stmt))
    return stmt

fn uirCoreCanonicalizeBlock(blk: UirBlockId) =
    if (!uirCoreBlockIdValid(blk)):
        return
    uirCore_blockPool_label[blk] = uirCoreCanonicalStr(uirCore_blockPool_label[blk])
    let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
    for si in 0..<stmtCount:
        let stmt: UirStmtId = uirCoreBlockStmtAt(blk, si)
        if uirCoreStmtIdValid(stmt):
            uirCoreOwnStmtStrings(stmt)
    uirCore_blockPool_term[blk] = uirCoreOwnTermStrings(uirCore_blockPool_term[blk])

fn uirCoreCanonicalizeFunc(func: UirCoreFunc) =
    if (!uirCoreFuncIdValid(func)):
        return
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn == nil:
        return
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    let objName0: str = (funcObj != nil) ? funcObj->name : ""
    let objLink0: str = (funcObj != nil) ? funcObj->linkName : ""
    let objOrigin0: str = (funcObj != nil) ? funcObj->originFile : ""
    let objFallback0: str = (funcObj != nil) ? funcObj->phaseFallbackReason : ""
    if len(dyn.name) == 0 && len(objName0) > 0:
        dyn.name = objName0
    dyn.linkName = dyn.linkName
    if len(dyn.linkName) == 0 && len(objLink0) > 0:
        dyn.linkName = objLink0
    if len(dyn.linkName) == 0 && len(dyn.name) > 0:
        dyn.linkName = dyn.name
    if len(dyn.originFile) == 0 && len(objOrigin0) > 0:
        dyn.originFile = objOrigin0
    if len(dyn.phaseFallbackReason) == 0 && len(objFallback0) > 0:
        dyn.phaseFallbackReason = objFallback0
    var params0: UirCoreParam[] = dyn.params
    for i in 0..<params0.len:
        var p: UirCoreParam = params0[i]
        p.name = uirCoreCanonicalStr(p.name)
        p.typeKey = uirCoreCanonicalStr(p.typeKey)
        uirCoreWriteParam(&params0, i, p)
    dyn.params = params0
    var objLocals0: UirCoreObjLocal[] = dyn.objLocals
    for oi in 0..<objLocals0.len:
        var ol: UirCoreObjLocal = objLocals0[oi]
        ol.objTypeName = uirCoreCanonicalStr(ol.objTypeName)
        ol.typeKey = uirCoreCanonicalStr(ol.typeKey)
        uirCoreWriteObjLocal(&objLocals0, oi, ol)
    dyn.objLocals = objLocals0
    let blocks0: UirBlockId[] = dyn.blocks
    for bi in 0..<blocks0.len:
        uirCoreCanonicalizeBlock(blocks0[bi])
    if funcObj != nil:
        funcObj->name = dyn.name
        funcObj->linkName = dyn.linkName
        funcObj->originFile = dyn.originFile
        funcObj->phaseFallbackReason = dyn.phaseFallbackReason
        uirCoreFuncSyncObjPayloadRaw(funcObj, dyn)
    uirCoreFuncSyncBlocks(func)
    uirCoreRecordFuncNames(func)

fn uirCoreCanonicalizeTypeAlias(aIn: UirCoreTypeAlias): UirCoreTypeAlias =
    var out: UirCoreTypeAlias = aIn
    out.name = uirCoreCanonicalStr(out.name)
    return out

fn uirCoreObjFieldSeqSane(fields: UirCoreObjField[]): bool =
    let fieldCount: int32 = fields.len
    if fieldCount <= 0:
        return true
    if fieldCount > (1 << 20):
        return false
    if fields.cap < fieldCount || fields.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(rawmemAsVoid(fields.buffer))
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreObjTypeSeqSane(items: UirCoreObjType[]): bool =
    let itemCount: int32 = items.len
    if itemCount <= 0:
        return true
    if itemCount > (1 << 20):
        return false
    if items.cap < itemCount || items.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(rawmemAsVoid(items.buffer))
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreCanonicalizeObjType(ty: UirCoreObjType): UirCoreObjType =
    var out: UirCoreObjType = ty
    out.name = uirCoreCanonicalStr(out.name)
    if !uirCoreObjFieldSeqSane(out.fields):
        var emptyFields: UirCoreObjField[]
        out.fields = emptyFields
        return out
    for i in 0..<out.fields.len:
        var f: UirCoreObjField = out.fields[i]
        f.name = uirCoreCanonicalStr(f.name)
        uirCoreWriteObjField(&out.fields, i, f)
    return out

fn uirCoreSetLocalType(func: UirCoreFunc, slot: int32, ty: UirCoreType) =
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn == nil:
        return
    if slot < 0:
        return
    uirCoreSanitizeFuncDynPayload(dyn)
    var localTypes0: UirCoreType[] = dyn.localTypes
    for i in localTypes0.len..slot:
        uirCoreAppendType(localTypes0, uirCoreTypeI32())
    uirCoreWriteType(&localTypes0, slot, ty)
    dyn.localTypes = localTypes0
    uirCoreFuncSyncObjPayloadFromDyn(func, dyn)

fn uirCoreAddParam(func: UirCoreFunc, name: str, slot: int32, ty: UirCoreType, typeKey: str = "") =
    var p: UirCoreParam
    p.name = uirCoreOwnStrSafe(name)
    p.slot = slot
    p.ty = ty
    p.typeKey = uirCoreOwnStrSafe(typeKey)
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
    if dyn == nil:
        return
    if slot < 0:
        return
    uirCoreSanitizeFuncDynPayload(dyn)
    var params0: UirCoreParam[] = dyn.params
    uirCoreAppendParam(params0, p)
    dyn.params = params0
    uirCoreFuncSyncObjPayloadFromDyn(func, dyn)
    uirCoreSetLocalType(func, slot, ty)

fn uirCoreNewModule(target: str): UirCoreModule =
    var m: UirCoreModule = new(UirCoreModule)
    m.target = uirCoreOwnStr(target)
    m.funcs = []
    m.cstrs = []
    m.cstrLabels = []
    m.cstrValues = []
    m.globals = []
    m.globalNames = []
    m.globalTypesRaw = []
    m.globalInits = []
    m.globalHasInitBits = []
    m.globalOriginFiles = []
    m.typeAliases = []
    m.objTypes = []
    return m

fn uirCoreTypeSize(ty: UirCoreType): int32 =
    if ty.kind == mtF64:
        return 8
    if ty.kind == mtI64:
        return 8
    if ty.kind == mtF32:
        return 4
    if ty.kind == mtI32:
        return 4
    if ty.kind == mtI16:
        return 2
    if ty.kind == mtI8:
        return 1
    return 0

fn uirCoreTypeAlignPow2(ty: UirCoreType): int32 =
    if ty.kind == mtF64:
        return 3
    if ty.kind == mtI64:
        return 3
    if ty.kind == mtF32:
        return 2
    if ty.kind == mtI32:
        return 2
    if ty.kind == mtI16:
        return 1
    if ty.kind == mtI8:
        return 0
    return 0

fn uirCoreFindTypeAlias(module: UirCoreModule, name: str): int32 =
    if (module == nil):
        return -1
    if !uirCoreStrPtrSane(name):
        return -1
    if len(name) == 0:
        return -1
    if module.typeAliases.len > 0:
        if uirCore_typeAliases_cache_module != module || !uirCore_typeAliases_cache_ready ||
           uirCore_typeAliases_cache_len != module.typeAliases.len:
            uirCore_buildTypeAliasIndexCache(module)
        if uirCore_typeAliases_cache_ready && uirCore_typeAliases_cache_module == module:
            let ptrKey: int64 = int64(rawmemAsVoid(name))
            if ptrKey != 0:
                var foundAliasPtr: bool = false
                let rawPtr: int32 = hashmaps.hashMapPtrIntGet(uirCore_typeAliases_ptr_cache, ptrKey, foundAliasPtr)
                let idxPtr: int32 = rawPtr - 1
                if foundAliasPtr:
                    return rawPtr > 0 ? idxPtr : -1
            var foundAlias: bool = false
            let raw: int32 = uirCoreHashMapStrIntGetCompat(uirCore_typeAliases_cache, name, foundAlias)
            let idx: int32 = raw - 1
            if foundAlias && raw > 0:
                hashmaps.hashMapPtrIntPut(uirCore_typeAliases_ptr_cache, ptrKey, raw)
                return idx
            if ptrKey != 0:
                hashmaps.hashMapPtrIntPut(uirCore_typeAliases_ptr_cache, ptrKey, 0)
            return -1
    for i in 0..<module.typeAliases.len:
        let a: UirCoreTypeAlias = module.typeAliases[i]
        if !uirCoreStrPtrSane(a.name):
            continue
        if (a.name == name):
            if uirCore_typeAliases_cache_ready && uirCore_typeAliases_cache_module == module:
                hashmaps.hashMapStrIntPut(uirCore_typeAliases_cache, a.name, i + 1)
                hashmaps.hashMapPtrIntPut(uirCore_typeAliases_ptr_cache, int64(rawmemAsVoid(name)), i + 1)
            return i
    return -1

fn uirCoreTryGetTypeAlias(module: UirCoreModule, name: str): UirCoreType =
    let idx: int32 = uirCoreFindTypeAlias(module, name)
    if idx < 0:
        return uirCoreTypeVoid()
    let a: UirCoreTypeAlias = module.typeAliases[idx]
    return a.ty

fn uirCoreAddTypeAlias(module: UirCoreModule, name: str, ty: UirCoreType) =
    if (module == nil):
        return
    if !uirCoreStrPtrSane(name):
        return
    if len(name) == 0:
        return
    let key: str = uirCoreOwnStr(name)
    if !uirCoreStrPtrSane(key):
        return
    let idx: int32 = uirCoreFindTypeAlias(module, key)
    if idx >= 0:
        var a2: UirCoreTypeAlias
        a2.name = key
        a2.ty = ty
        a2 = uirCoreCanonicalizeTypeAlias(a2)
        uirCoreWriteTypeAlias(&module.typeAliases, idx, a2)
        if uirCore_typeAliases_cache_ready && uirCore_typeAliases_cache_module == module:
            hashmaps.hashMapStrIntPut(uirCore_typeAliases_cache, a2.name, idx + 1)
            hashmaps.hashMapPtrIntPut(uirCore_typeAliases_ptr_cache, int64(rawmemAsVoid(a2.name)), idx + 1)
            uirCore_typeAliases_cache_len = module.typeAliases.len
        return
    let newIdx: int32 = module.typeAliases.len
    var a: UirCoreTypeAlias
    a.name = key
    a.ty = ty
    a = uirCoreCanonicalizeTypeAlias(a)
    var typeAliases0: UirCoreTypeAlias[] = module.typeAliases
    seqs.add(typeAliases0, a)
    var mod0: UirCoreModule = module
    mod0.typeAliases = typeAliases0
    if uirCore_typeAliases_cache_ready && uirCore_typeAliases_cache_module == module:
        hashmaps.hashMapStrIntPut(uirCore_typeAliases_cache, a.name, newIdx + 1)
        hashmaps.hashMapPtrIntPut(uirCore_typeAliases_ptr_cache, int64(rawmemAsVoid(a.name)), newIdx + 1)
        uirCore_typeAliases_cache_len = module.typeAliases.len

fn uirCoreFindObjType(module: UirCoreModule, name: str): int32 =
    if (module == nil) || len(name) == 0:
        return -1
    if module.objTypes.len > 0:
        if uirCore_objTypes_cache_module != module || !uirCore_objTypes_cache_ready ||
           uirCore_objTypes_cache_len != module.objTypes.len:
            uirCore_buildObjTypeIndexCache(module)
        if uirCore_objTypes_cache_ready && uirCore_objTypes_cache_module == module:
            if uirCoreStrPtrSane(name):
                let ptrKey: int64 = int64(rawmemAsVoid(name))
                if ptrKey != 0:
                    var foundObjPtr: bool = false
                    let rawPtr: int32 = hashmaps.hashMapPtrIntGet(uirCore_objTypes_ptr_cache, ptrKey, foundObjPtr)
                    let idxPtr: int32 = rawPtr - 1
                    if foundObjPtr:
                        return rawPtr > 0 ? idxPtr : -1
            var foundObj: bool = false
            let raw: int32 = uirCoreHashMapStrIntGetCompat(uirCore_objTypes_cache, name, foundObj)
            let idx: int32 = raw - 1
            if foundObj && raw > 0:
                if uirCoreStrPtrSane(name):
                    hashmaps.hashMapPtrIntPut(uirCore_objTypes_ptr_cache, int64(rawmemAsVoid(name)), raw)
                return idx
            if uirCoreStrPtrSane(name):
                let ptrKeyMiss: int64 = int64(rawmemAsVoid(name))
                if ptrKeyMiss != 0:
                    hashmaps.hashMapPtrIntPut(uirCore_objTypes_ptr_cache, ptrKeyMiss, 0)
            return -1
    for i in 0..<module.objTypes.len:
        let t: UirCoreObjType = module.objTypes[i]
        if (t.name == name):
            if uirCore_objTypes_cache_ready && uirCore_objTypes_cache_module == module:
                hashmaps.hashMapStrIntPut(uirCore_objTypes_cache, t.name, i + 1)
                if uirCoreStrPtrSane(name):
                    hashmaps.hashMapPtrIntPut(uirCore_objTypes_ptr_cache, int64(rawmemAsVoid(name)), i + 1)
            return i
    return -1

fn uirCoreHasObjType(module: UirCoreModule, name: str): bool =
    return uirCoreFindObjType(module, name) >= 0

fn uirCoreGetObjType(module: UirCoreModule, name: str): UirCoreObjType =
    let idx: int32 = uirCoreFindObjType(module, name)
    if idx < 0:
        var t: UirCoreObjType
        t.name = ""
        t.size = 0
        t.alignPow2 = 0
        return t
    return module.objTypes[idx]

fn uirCoreAddObjType(module: UirCoreModule, ty: UirCoreObjType) =
    let norm: UirCoreObjType = uirCoreCanonicalizeObjType(ty)
    if (module == nil) || len(norm.name) == 0:
        return
    let idx: int32 = uirCoreFindObjType(module, norm.name)
    if idx >= 0:
        uirCoreWriteObjType(&module.objTypes, idx, norm)
        if uirCore_objTypes_cache_ready && uirCore_objTypes_cache_module == module:
            hashmaps.hashMapStrIntPut(uirCore_objTypes_cache, norm.name, idx + 1)
            if uirCoreStrPtrSane(norm.name):
                hashmaps.hashMapPtrIntPut(uirCore_objTypes_ptr_cache, int64(rawmemAsVoid(norm.name)), idx + 1)
            uirCore_objTypes_cache_len = module.objTypes.len
        return
    let newIdx: int32 = module.objTypes.len
    var objTypes0: UirCoreObjType[] = module.objTypes
    seqs.add(objTypes0, norm)
    var mod0: UirCoreModule = module
    mod0.objTypes = objTypes0
    if uirCore_objTypes_cache_ready && uirCore_objTypes_cache_module == module:
        hashmaps.hashMapStrIntPut(uirCore_objTypes_cache, norm.name, newIdx + 1)
        if uirCoreStrPtrSane(norm.name):
            hashmaps.hashMapPtrIntPut(uirCore_objTypes_ptr_cache, int64(rawmemAsVoid(norm.name)), newIdx + 1)
        uirCore_objTypes_cache_len = module.objTypes.len

fn uirCoreAddFunc(module: UirCoreModule, func: UirCoreFunc) =
    let canAdd: bool = module != nil && uirCoreFuncIdValid(func)
    if canAdd:
        uirCoreCanonicalizeFunc(func)
        uirCoreFuncSyncBlocks(func)
        uirCoreAppendFuncPtr(&module.funcs, func)

fn uirCoreAddGlobal(module: UirCoreModule, name: str, ty: UirCoreType, init: int64, hasInit: bool, originFile: str) =
    if (module == nil):
        return
    var g: UirCoreGlobal
    g.name = uirCoreOwnStr(name)
    g.ty = ty
    g.init = init
    g.hasInit = hasInit
    g.originFile = uirCoreOwnStr(originFile)
    var globals0: UirCoreGlobal[] = module.globals
    var globalNames0: str[] = module.globalNames
    var globalTypesRaw0: int32[] = module.globalTypesRaw
    var globalInits0: int64[] = module.globalInits
    var globalHasInitBits0: int32[] = module.globalHasInitBits
    var globalOriginFiles0: str[] = module.globalOriginFiles
    seqs.add(globals0, g)
    seqs.add(globalNames0, g.name)
    seqs.add(globalTypesRaw0, uirCoreEncodeType(g.ty))
    seqs.add(globalInits0, g.init)
    seqs.add(globalHasInitBits0, hasInit ? 1 : 0)
    seqs.add(globalOriginFiles0, g.originFile)
    var mod0: UirCoreModule = module
    mod0.globals = globals0
    mod0.globalNames = globalNames0
    mod0.globalTypesRaw = globalTypesRaw0
    mod0.globalInits = globalInits0
    mod0.globalHasInitBits = globalHasInitBits0
    mod0.globalOriginFiles = globalOriginFiles0

fn uirCoreAppendObjFieldNamed(seqInst: var UirCoreObjField[], name: str, ty: UirCoreType, offset: int32) =
    var f: UirCoreObjField
    f.name = name
    f.ty = ty
    f.offset = offset
    seqs.add(seqInst, f)

fn uirCoreObjTypeRenamed(ty: UirCoreObjType, name: str): UirCoreObjType =
    var out: UirCoreObjType = ty
    out.name = name
    return out

fn uirCoreAddObjTypeParts(module: UirCoreModule, name: str, alignPow2: int32, size: int32, fields: UirCoreObjField[]) =
    if module == nil:
        return
    var ot: UirCoreObjType
    ot.name = name
    ot.alignPow2 = alignPow2
    ot.size = size
    ot.fields = fields
    uirCoreAddObjType(module, ot)

fn uirCoreReplaceObjTypeParts(module: UirCoreModule, idx: int32, name: str, alignPow2: int32, size: int32, fields: UirCoreObjField[]) =
    if (module == nil) || idx < 0 || idx >= module.objTypes.len:
        return
    var ot: UirCoreObjType
    ot.name = name
    ot.alignPow2 = alignPow2
    ot.size = size
    ot.fields = fields
    uirCoreWriteObjType(module.objTypes, idx, uirCoreCanonicalizeObjType(ot))

fn uirCoreReplaceGlobal(module: UirCoreModule, idx: int32, name: str, ty: UirCoreType, init: int64, hasInit: bool, originFile: str) =
    if (module == nil) || idx < 0 || idx >= module.globals.len:
        return
    var g: UirCoreGlobal
    g.name = uirCoreOwnStr(name)
    g.ty = ty
    g.init = init
    g.hasInit = hasInit
    g.originFile = uirCoreOwnStr(originFile)
    uirCoreWriteGlobal(module.globals, idx, g)
    if idx >= 0 && idx < module.globalNames.len:
        uirCoreSetStr(module.globalNames, idx, g.name)
    if idx >= 0 && idx < module.globalTypesRaw.len:
        uirCoreSetInt32(module.globalTypesRaw, idx, uirCoreEncodeType(g.ty))
    if idx >= 0 && idx < module.globalInits.len:
        uirCoreSetI64(module.globalInits, idx, g.init)
    if idx >= 0 && idx < module.globalHasInitBits.len:
        if hasInit:
            uirCoreSetInt32(module.globalHasInitBits, idx, 1)
        else:
            uirCoreSetInt32(module.globalHasInitBits, idx, 0)
    if idx >= 0 && idx < module.globalOriginFiles.len:
        uirCoreSetStr(module.globalOriginFiles, idx, g.originFile)

fn uirCoreCanonicalizeModule(module: UirCoreModule) =
    if module == nil:
        return
    let dbgCanon: bool = os.getEnvDefault("BACKEND_DEBUG_CANON_MOD", "") == "1"
    let funcsSane: bool = uirCoreFuncRefSeqSane(module.funcs)
    if dbgCanon:
        echo("[backend] canon_mod: funcs=" + intToStr(module.funcs.len) +
             " funcs_sane=" + (funcsSane ? "1" : "0") +
             " globals=" + intToStr(module.globals.len) +
             " cstrs=" + intToStr(module.cstrs.len) +
             " aliases=" + intToStr(module.typeAliases.len) +
             " objs=" + intToStr(module.objTypes.len))
    if !funcsSane:
        var funcsKeep: UirCoreFunc[]
        for fi in 0..<module.funcs.len:
            let func: UirCoreFunc = module.funcs[fi]
            if dbgCanon:
                echo("[backend] canon_mod: func_scan fi=" + intToStr(fi) +
                     " ptr=" + int64ToStr(int64(rawmemAsVoid(func))))
            if !uirCoreFuncIdValid(func):
                continue
            if uirCoreFindFuncNameCacheIndex(func) < 0:
                continue
            uirCoreAppendFuncRef(funcsKeep, func)
        if dbgCanon:
            echo("[backend] canon_mod: funcs_keep=" + intToStr(funcsKeep.len))
        uirCoreModuleSetFuncs(module, funcsKeep)
    for fi in 0..<module.funcs.len:
        let func: UirCoreFunc = module.funcs[fi]
        if dbgCanon:
            echo("[backend] canon_mod: func_canon fi=" + intToStr(fi) +
                 " ptr=" + int64ToStr(int64(rawmemAsVoid(func))))
        uirCoreCanonicalizeFunc(func)
        if dbgCanon:
            echo("[backend] canon_mod: func_name fi=" + intToStr(fi) +
                 " name='" + uirCoreFuncNameOf(func) +
                 "' link='" + uirCoreFuncLinkNameOf(func) + "'")
    for gi in 0..<module.globals.len:
        if dbgCanon:
            echo("[backend] canon_mod: global_canon gi=" + intToStr(gi))
        var g: UirCoreGlobal = module.globals[gi]
        g.name = uirCoreCanonicalStr(g.name)
        g.originFile = uirCoreCanonicalStr(g.originFile)
        uirCoreWriteGlobal(module.globals, gi, g)
        if gi >= 0 && gi < module.globalNames.len:
            uirCoreSetStr(module.globalNames, gi, g.name)
        if gi >= 0 && gi < module.globalOriginFiles.len:
            uirCoreSetStr(module.globalOriginFiles, gi, g.originFile)
    for ci in 0..<module.cstrs.len:
        if dbgCanon:
            echo("[backend] canon_mod: cstr_canon ci=" + intToStr(ci))
        var c: UirCoreCString = module.cstrs[ci]
        c.value = uirCoreCanonicalStr(c.value)
        c.label = uirCoreCanonicalStr(uirCoreCStringLabelFromHash(uirCoreFnv1a64(c.value)))
        uirCoreWriteCString(&module.cstrs, ci, c)
        if ci >= 0 && ci < module.cstrLabels.len:
            uirCoreSetStr(module.cstrLabels, ci, c.label)
        if ci >= 0 && ci < module.cstrValues.len:
            uirCoreSetStr(module.cstrValues, ci, c.value)
    for ti in 0..<module.typeAliases.len:
        if dbgCanon:
            echo("[backend] canon_mod: alias_canon ti=" + intToStr(ti))
        let alias0: UirCoreTypeAlias = uirCoreCanonicalizeTypeAlias(module.typeAliases[ti])
        uirCoreWriteTypeAlias(module.typeAliases, ti, alias0)
    if !uirCoreObjTypeSeqSane(module.objTypes):
        var emptyObjTypes: UirCoreObjType[]
        var mod0: UirCoreModule = module
        mod0.objTypes = emptyObjTypes
        return
        return
    for oi in 0..<module.objTypes.len:
        if dbgCanon:
            echo("[backend] canon_mod: obj_canon oi=" + intToStr(oi))
        let obj0: UirCoreObjType = uirCoreCanonicalizeObjType(module.objTypes[oi])
        uirCoreWriteObjType(module.objTypes, oi, obj0)

fn uirCoreExprKindOf(expr: UirExprId): UirCoreExprKind =
    if (!uirCoreExprIdValid(expr)):
        return meConstI64
    return uirCoreDecodeExprKind(uirCore_exprPool_kind[expr])

fn uirCoreExprCalleeOf(expr: UirExprId): str =
