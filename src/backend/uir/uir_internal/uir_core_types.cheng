fn add(seqInst: var UirCoreCmpOp[], val: UirCoreCmpOp) =
    seqs.add(seqInst, val)

fn add(seqInst: var UirCoreExprKind[], val: UirCoreExprKind) =
    seqs.add(seqInst, val)

fn add(seqInst: var UirCoreStmtKind[], val: UirCoreStmtKind) =
    seqs.add(seqInst, val)

fn add(seqInst: var UirCoreTermKind[], val: UirCoreTermKind) =
    seqs.add(seqInst, val)

fn add(seqInst: var UirCoreTerm[], val: UirCoreTerm) =
