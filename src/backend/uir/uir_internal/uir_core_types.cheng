                                        "", uirCoreTypeVoid(), 0, 0, uirCoreTypeVoid(), "")

fn uirCoreTermRet(expr: UirExprId): UirCoreTerm =
    var t: UirCoreTerm
    t.kind = mtRet
    t.retExpr = expr
    return t

fn uirCoreTermBr(target: str): UirCoreTerm =
    var t: UirCoreTerm
    t.kind = mtBr
    t.target = uirCoreOwnStr(target)
    return t

fn uirCoreTermCbr(cond: UirExprId, tLabel: str, fLabel: str): UirCoreTerm =
    var t: UirCoreTerm
    t.kind = mtCbr
    t.condExpr = cond
    t.targetTrue = uirCoreOwnStr(tLabel)
    t.targetFalse = uirCoreOwnStr(fLabel)
    return t

fn uirCoreStmtLet(name: str, slot: int32, expr: UirExprId): UirStmtId =
    return uirCoreStmtAllocFields(msLet, uirCoreOwnStr(name), slot, expr, -1, 0, uirCoreTypeVoid())

fn uirCoreStmtVar(name: str, slot: int32, expr: UirExprId): UirStmtId =
    return uirCoreStmtAllocFields(msVar, uirCoreOwnStr(name), slot, expr, -1, 0, uirCoreTypeVoid())

fn uirCoreStmtAssign(name: str, slot: int32, expr: UirExprId): UirStmtId =
    return uirCoreStmtAllocFields(msAssign, uirCoreOwnStr(name), slot, expr, -1, 0, uirCoreTypeVoid())

fn uirCoreStmtExpr(expr: UirExprId): UirStmtId =
    return uirCoreStmtAllocFields(msExpr, "", -1, expr, -1, 0, uirCoreTypeVoid())

fn uirCoreStmtParam(name: str, slot: int32, paramIndex: int32): UirStmtId =
    return uirCoreStmtAllocFields(msParam, uirCoreOwnStr(name), slot, 0, paramIndex, 0, uirCoreTypeVoid())

fn uirCoreStmtStore(addr: UirExprId, value: UirExprId, ty: UirCoreType): UirStmtId =
    return uirCoreStmtAllocFields(msStore, "", -1, value, -1, addr, ty)

fn uirCoreBlock(label: str, term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFields(uirCoreOwnStr(label), [], term)

fn uirCoreBlockWithStmtSeqRef(label: str, stmts: UirStmtId[]*, term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFieldsFromStmtSeqRef(uirCoreOwnStr(label), stmts, term)

fn uirCoreBlockWithStmtSpan(label: str, stmtStart: int32, stmtLen: int32, term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFieldsFromSpan(uirCoreOwnStr(label), stmtStart, stmtLen, term)

fn uirCoreBlockWithStmts(label: str, stmts: UirStmtId[], term: UirCoreTerm): UirBlockId =
    return uirCoreBlockAllocFields(uirCoreOwnStr(label), stmts, term)

fn uirCoreNewFunc(name: str, retType: UirCoreType): UirCoreFunc =
    let raw: ptr = uirCoreHeapNew(int32(sizeof UirCoreFuncObj))
    if raw == nil:
        return nil
    uirCoreMemZero(raw, int32(sizeof UirCoreFuncObj))
    let f: UirCoreFunc = UirCoreFunc(raw)
    if f == nil:
        return f
    let fObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(f)
    if fObj == nil:
        return f
    fObj->name = uirCoreOwnStr(name)
    fObj->linkName = uirCoreOwnStr(name)
    fObj->originFile = uirCoreOwnStr("")
    fObj->declOrdinal = -1
    fObj->dynId = uirCoreAllocFuncDynId()
    fObj->dynStatePtr = 0
    uirCoreRememberFuncDynAddr(f)
    fObj->sourceAstIndex = -1
    fObj->isExtern = false
    fObj->retType = retType
    fObj->retTypeKey = uirCoreOwnStr("")
    fObj->params = []
    fObj->localTypes = []
    fObj->objLocals = []
    fObj->objFrameSize = 0
    fObj->blocks = []
    fObj->blockBuffer = nil
    fObj->blockLen = 0
    fObj->blockCap = 0
    fObj->phaseTag = uirCorePhaseHighTag()
    fObj->highUirChecked = false
    fObj->lowUirLowered = false
    fObj->phaseFallbackReason = uirCoreOwnStr("high_uir_unchecked")
    let dyn0: UirCoreFuncDynState = uirCoreEnsureFuncDyn(f)
    if dyn0 == nil:
        return f
    dyn0.name = uirCoreOwnStr(name)
    dyn0.linkName = uirCoreOwnStr(name)
    dyn0.originFile = uirCoreOwnStr("")
    dyn0.declOrdinal = -1
    dyn0.sourceAstIndex = -1
    dyn0.isExtern = false
    dyn0.retType = retType
    dyn0.retTypeKey = uirCoreOwnStr("")
    dyn0.objFrameSize = 0
    dyn0.phaseTag = uirCorePhaseHighTag()
    dyn0.highUirChecked = false
    dyn0.lowUirLowered = false
    dyn0.phaseFallbackReason = uirCoreOwnStr("high_uir_unchecked")
    uirCoreCacheDynState(fObj->dynId, dyn0)
    if (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1") && name == "main":
        let ptrValDbg: int64 = uirCoreFuncPtrKey(f)
        os.writeLine(os.get_stderr(),
                     "[backend] dbg_main_new_func name=" + name +
                     " ret_kind=" + intToStr(int32(retType.kind)) +
                     " dyn_id=" + intToStr(fObj->dynId) +
                     " ptr=" + int64ToStr(ptrValDbg))
        os.c_fflush(os.get_stderr())
    uirCoreRecordFuncNames(f)
    return f

fn uirCoreBlockSeqAppend(seqInst: var UirBlockId[], block: UirBlockId) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = block

fn uirCoreBlockSeqSane(blocks: UirBlockId[]): bool =
    let blockCount: int32 = blocks.len
    if blockCount <= 0:
        return true
    if blockCount > (1 << 20):
        return false
    if blocks.cap < blockCount || blocks.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(rawmemAsVoid(blocks.buffer))
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreAppendBlockPtr(seqInst: UirBlockId[]*, block: UirBlockId) =
    if seqInst == nil:
        panic "uirCore_types: nil block seq pointer"
    if seqInst->len < 0 || seqInst->cap < 0:
        seqInst->buffer = nil
        seqInst->len = 0
        seqInst->cap = 0
    let idx: int32 = seqInst->len
    let needLen: int32 = idx + 1
    if seqInst->buffer == nil || seqInst->cap < needLen:
        cheng__seqGrowToRaw(&seqInst->buffer, &seqInst->cap, needLen, int32(sizeof UirBlockId))
    seqInst->len = needLen
    seqInst[idx] = block

fn uirCoreFuncRefSeqSane(funcs: UirCoreFunc[]): bool =
    let funcCount: int32 = funcs.len
    if funcCount <= 0:
        return true
    if funcCount > (1 << 20):
        return false
    if funcs.cap < funcCount || funcs.cap > (1 << 20):
        return false
    let ptrVal: int64 = int64(rawmemAsVoid(funcs.buffer))
    if !uirCoreSeqPtrSane(ptrVal):
        return false
    return true

fn uirCoreAppendFuncPtr(seqInst: UirCoreFunc[]*, val: UirCoreFunc) =
    if seqInst == nil:
        panic "uirCore_types: nil func seq pointer"
    if seqInst->len < 0 || seqInst->cap < 0:
        seqInst->buffer = nil
        seqInst->len = 0
        seqInst->cap = 0
    let idx: int32 = seqInst->len
    let needLen: int32 = idx + 1
    if seqInst->buffer == nil || seqInst->cap < needLen:
        cheng__seqGrowToRaw(&seqInst->buffer, &seqInst->cap, needLen, int32(sizeof ptr))
    seqInst->len = needLen
    if val != nil:
        memRetain(rawmemAsVoid(val))
    seqInst[idx] = val

fn uirCoreFuncSyncBlocks(func: UirCoreFunc) =
    if !uirCoreFuncIdValid(func):
        return
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    if dyn == nil:
        funcObj->blocks = []
        funcObj->blockBuffer = nil
        funcObj->blockLen = 0
        funcObj->blockCap = 0
        return
    # `func.blocks` is the single source of truth. Raw mirrors were prone to
    # going stale after later block rewrites, which made selector/codegen see
    # empty or old blocks even though builder finish had valid stmt spans.
    let blocks: UirBlockId[] = dyn.blocks
    if !uirCoreBlockSeqSane(blocks):
        funcObj->blocks = []
        funcObj->blockBuffer = nil
        funcObj->blockLen = 0
        funcObj->blockCap = 0
        return
    funcObj->blocks = uirCoreCloneBlockSeq(blocks)
    funcObj->blockBuffer = nil
    funcObj->blockLen = 0
    funcObj->blockCap = 0

fn uirCoreAddBlock(func: UirCoreFunc, block: UirBlockId) =
    let canAdd: bool = uirCoreFuncIdValid(func) && block != nil
    if canAdd:
        let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDyn(func)
        if dyn == nil:
            return
        uirCoreCanonicalizeBlock(block)
        var blocks0: UirBlockId[] = dyn.blocks
        uirCoreAppendBlockPtr(&blocks0, block)
        dyn.blocks = blocks0
        uirCoreFuncSyncBlocks(func)

fn uirCoreAddBlockByPtrKey(ptrKey: int64, block: UirBlockId) =
    if !uirCoreHostPtrSane(ptrKey) || block == nil:
        return
    let dyn: UirCoreFuncDynState = uirCoreEnsureFuncDynByPtrKey(ptrKey)
    if dyn == nil:
        return
    uirCoreCanonicalizeBlock(block)
    var blocks0: UirBlockId[] = dyn.blocks
    uirCoreAppendBlockPtr(&blocks0, block)
    dyn.blocks = blocks0
    let func0: UirCoreFunc = uirCoreFuncFromDynKey(int64(0x100000000) + int64(uirCoreFindDynIdByPtrKey(ptrKey)))
    if func0 != nil:
        let funcObj0: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func0)
        if funcObj0 != nil:
            funcObj0->blocks = uirCoreCloneBlockSeq(blocks0)
            funcObj0->blockBuffer = nil
            funcObj0->blockLen = 0
            funcObj0->blockCap = 0

fn uirCoreWriteType(seqInst: UirCoreType[]*, idx: int32, val: UirCoreType) =
    if (seqInst == nil):
        panic "uirCore_types: nil seq pointer"
    if idx < 0 || idx >= seqInst->len:
        panic "uirCore_types: seq index out of bounds"
    seqInst[idx] = val

