fn uirCoreFuncSyncObjIdentityFromDyn(func: UirCoreFunc, syncRetTypeKey: bool = false) =
    if !uirCoreFuncIdValid(func):
        return
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(func)
    if funcObj == nil:
        return
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    if dyn == nil:
        return
    let dbgBoot: bool = os.getEnvDefault("BACKEND_DEBUG_BOOT", "") == "1"
    let dbgNameObj0: str = (funcObj != nil) ? funcObj->name : ""
    let dbgNameDyn0: str = (dyn != nil) ? dyn.name : ""
    let dbgTrack: bool = dbgBoot &&
                         (dbgNameObj0 == "main" || dbgNameObj0 == "backendMain" ||
                          dbgNameDyn0 == "main" || dbgNameDyn0 == "backendMain" ||
                          strContains(funcObj->originFile, "backend_driver.cheng") ||
                          strContains(dyn.originFile, "backend_driver.cheng"))
    if dbgTrack:
        os.writeLine(os.get_stderr(),
                     "[backend] dbg_sync_obj_id.before name=" +
                     (len(dbgNameObj0) > 0 ? dbgNameObj0 : dbgNameDyn0) +
                     " func_dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " obj_dyn_id=" + intToStr(funcObj->dynId) +
                     " obj_extern=" + (funcObj->isExtern ? "1" : "0") +
                     " dyn_extern=" + (dyn.isExtern ? "1" : "0") +
                     " obj_origin=" + funcObj->originFile +
                     " dyn_origin=" + dyn.originFile +
                     " obj_decl=" + intToStr(funcObj->declOrdinal) +
                     " dyn_decl=" + intToStr(dyn.declOrdinal) +
                     " obj_ast=" + intToStr(funcObj->sourceAstIndex) +
                     " dyn_ast=" + intToStr(dyn.sourceAstIndex))
        os.c_fflush(os.get_stderr())
    if uirCoreStrPtrSane(dyn.name):
        funcObj->name = dyn.name
    if uirCoreStrPtrSane(dyn.linkName) && len(dyn.linkName) > 0:
        funcObj->linkName = dyn.linkName
    elif uirCoreStrPtrSane(dyn.name):
        funcObj->linkName = dyn.name
    if uirCoreStrPtrSane(dyn.originFile):
        funcObj->originFile = dyn.originFile
    funcObj->declOrdinal = dyn.declOrdinal
    funcObj->sourceAstIndex = dyn.sourceAstIndex
    let dynId: int32 = uirCoreFuncDynId(func)
    if uirCoreFuncDynIdSane(dynId):
        funcObj->dynId = dynId
    funcObj->isExtern = dyn.isExtern
    funcObj->retType = dyn.retType
    if syncRetTypeKey && uirCoreStrPtrSane(dyn.retTypeKey):
        funcObj->retTypeKey = dyn.retTypeKey
    funcObj->objFrameSize = dyn.objFrameSize
    funcObj->phaseTag = dyn.phaseTag
    funcObj->highUirChecked = dyn.highUirChecked
    funcObj->lowUirLowered = dyn.lowUirLowered
    if uirCoreStrPtrSane(dyn.phaseFallbackReason):
        funcObj->phaseFallbackReason = dyn.phaseFallbackReason
    if dbgTrack:
        os.writeLine(os.get_stderr(),
                     "[backend] dbg_sync_obj_id.after name=" +
                     (len(funcObj->name) > 0 ? funcObj->name : dyn.name) +
                     " func_dyn_id=" + intToStr(uirCoreFuncDynId(func)) +
                     " obj_dyn_id=" + intToStr(funcObj->dynId) +
                     " obj_extern=" + (funcObj->isExtern ? "1" : "0") +
                     " dyn_extern=" + (dyn.isExtern ? "1" : "0") +
                     " obj_origin=" + funcObj->originFile +
                     " dyn_origin=" + dyn.originFile +
                     " obj_decl=" + intToStr(funcObj->declOrdinal) +
                     " dyn_decl=" + intToStr(dyn.declOrdinal) +
                     " obj_ast=" + intToStr(funcObj->sourceAstIndex) +
                     " dyn_ast=" + intToStr(dyn.sourceAstIndex))
        os.c_fflush(os.get_stderr())

