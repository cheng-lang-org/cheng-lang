    var out: UirCoreTerm = term
    out.retExpr = retExpr
    return out

fn uirCoreTermWithCondExpr(term: UirCoreTerm, condExpr: UirExprId): UirCoreTerm =
    var out: UirCoreTerm = term
    out.condExpr = condExpr
    return out

fn uirCoreTermWithTarget(term: UirCoreTerm, target: str): UirCoreTerm =
