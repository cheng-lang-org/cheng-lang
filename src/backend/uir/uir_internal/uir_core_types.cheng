fn uirCoreAppendExprId(seqInst: var UirExprId[], val: UirExprId) =
    seqs.add(seqInst, val)

fn uirCoreAppendInt32(seqInst: var int32[], val: int32) =
    seqs.add(seqInst, val)

fn uirCoreAppendStr(seqInst: var str[], val: str) =
    seqs.add(seqInst, val)

fn uirCoreAppendExprArgs(seqInst: var UirExprId[][], val: UirExprId[]) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, uirCoreReserveTargetCap(seqInst.cap, needLen, 64))
    setLen(seqInst, needLen)
    seqInst[idx] = uirCoreCloneExprArgs(val)

fn uirCoreAppendExprArgsFlat(val: UirExprId[]): int32 =
    let start: int32 = uirCore_exprArgsFlat.len
    let n: int32 = val.len
    if n <= 0:
        return start
    let needLen: int32 = start + n
    if uirCore_exprArgsFlat.buffer == nil || uirCore_exprArgsFlat.cap < needLen:
        reserve(uirCore_exprArgsFlat, uirCoreReserveTargetCap(uirCore_exprArgsFlat.cap, needLen, 256))
    setLen(uirCore_exprArgsFlat, needLen)
    for i in 0..<n:
        uirCore_exprArgsFlat[start + i] = val[i]
    return start

fn uirCoreAppendType(seqInst: var UirCoreType[], val: UirCoreType) =
    if seqInst.len < 0 || seqInst.cap < 0:
        seqInst.buffer = nil
        seqInst.len = 0
        seqInst.cap = 0
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        cheng__seqGrowToRaw(&seqInst.buffer, &seqInst.cap, needLen, int32(sizeof UirCoreType))
    seqInst.len = needLen
    seqInst[idx] = val

fn uirCoreAppendStmtKind(seqInst: var UirCoreStmtKind[], val: UirCoreStmtKind) =
    seqs.add(seqInst, val)

fn uirCoreAppendTermKind(seqInst: var UirCoreTermKind[], val: UirCoreTermKind) =
    seqs.add(seqInst, val)

fn uirCoreAppendSoaFuncSpan(seqInst: var UirCoreSoaFuncSpan[], val: UirCoreSoaFuncSpan) =
    seqs.add(seqInst, val)

fn uirCoreAppendParam(seqInst: var UirCoreParam[], val: UirCoreParam) =
    if seqInst.len < 0 || seqInst.cap < 0:
        seqInst.buffer = nil
        seqInst.len = 0
        seqInst.cap = 0
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        cheng__seqGrowToRaw(&seqInst.buffer, &seqInst.cap, needLen, int32(sizeof UirCoreParam))
    seqInst.len = needLen
    seqInst[idx] = val

fn uirCoreAppendTypeAlias(seqInst: var UirCoreTypeAlias[], val: UirCoreTypeAlias) =
