    let fallback: str = highUirChecked ? "" : fallbackReason
    for i in 0..<module.funcs.len:
        let f = module.funcs[i]
        if (f == nil) || f.isExtern:
            continue
        uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), highUirChecked, true, fallback)

