fn uirCoreFnv1a64(s: str): int64 =
    var h: uint64 = uint64(1469598103934665603)
    for i in 0..<len(s):
        let c: char = s[i]
        h = h ^ uint64(int64(c) & int64(0xFF))
        h = h * uint64(1099511628211)
    return int64(h)

fn uirCoreHexDigit(v: int32): char =
    if v < 10:
        return char(int8(48 + v))
    return char(int8(97 + (v - 10)))

fn uirCoreU64ToHex(v: int64): str =
    let n: int32 = 16
    let out: str = newStringOfCap(n)
    let outPtr: ptr = ptr(out)
    if outPtr == nil:
        return ""
    for i in 0..<n:
        let shift: int32 = (n - 1 - i) * 4
        let nib: int32 = int32((v >> shift) & int64(0xF))
        rawmemWriteChar(outPtr, i, uirCoreHexDigit(nib))
    return out

fn uirCoreCStringLabelFromHash(h: int64): str =
    let prefixLen: int32 = 12
    let hexLen: int32 = 16
    let out: str = newStringAlloc(prefixLen + hexLen)
    if out == nil:
        return ""
    let outPtr: ptr = ptr(out)
    rawmemWriteChar(outPtr, 0, 'L')
    rawmemWriteChar(outPtr, 1, '_')
    rawmemWriteChar(outPtr, 2, 'c')
    rawmemWriteChar(outPtr, 3, 'h')
    rawmemWriteChar(outPtr, 4, 'e')
    rawmemWriteChar(outPtr, 5, 'n')
    rawmemWriteChar(outPtr, 6, 'g')
    rawmemWriteChar(outPtr, 7, '_')
    rawmemWriteChar(outPtr, 8, 's')
    rawmemWriteChar(outPtr, 9, 't')
    rawmemWriteChar(outPtr, 10, 'r')
    rawmemWriteChar(outPtr, 11, '_')
    for i in 0..<hexLen:
        let shift: int32 = (hexLen - 1 - i) * 4
        let nib: int32 = int32((h >> shift) & int64(0xF))
        rawmemWriteChar(outPtr, prefixLen + i, uirCoreHexDigit(nib))
    return out

fn uirCoreFindCStringLabel(module: UirCoreModule, value: str): str =
    if (module == nil):
        return ""
    let v: str = len(value) == 0 ? "" : value
    let total: int32 = uirCoreModuleCStringsLen(module)
    if total >= 32:
        if uirCore_cstrs_cache_module != module || !uirCore_cstrs_cache_ready ||
           uirCore_cstrs_cache_len != total:
            uirCore_buildCStringIndexCache(module)
        if uirCore_cstrs_cache_ready && uirCore_cstrs_cache_module == module:
            var foundCstr: bool = false
            let raw: int32 = uirCoreHashMapStrIntGetCompat(uirCore_cstrs_cache, v, foundCstr)
            let idx: int32 = raw - 1
            if foundCstr && raw > 0 && idx >= 0 && idx < total:
                return uirCoreModuleCStringLabelAt(module, idx)
    for i in 0..<total:
        let curValue: str = uirCoreModuleCStringValueAt(module, i)
        if curValue == v:
            return uirCoreModuleCStringLabelAt(module, i)
    return ""

fn uirCoreAddCString(module: UirCoreModule, value: str): str =
    if (module == nil):
        return ""
    var v: str = value
    if len(v) == 0:
        v = ""
    if os.getEnvDefault("BACKEND_DEBUG_CSTRING_LOWERING", "") == "1":
        echo("[uir.cstr.add] value_len=" + intToStr(len(v)))
        if len(v) > 0:
            echo(v)
    let existing: str = uirCoreFindCStringLabel(module, v)
    if len(existing) > 0:
        return existing
    let h: int64 = uirCoreFnv1a64(v)
    let label: str = uirCoreCStringLabelFromHash(h)
    let newIdx: int32 = uirCoreModuleCStringsLen(module)
    var c: UirCoreCString
    c.label = uirCoreOwnStr(label)
    c.value = uirCoreOwnStr(v)
    var cstrs0: UirCoreCString[] = module.cstrs
    var cstrLabels0: str[] = module.cstrLabels
    var cstrValues0: str[] = module.cstrValues
    seqs.add(cstrs0, c)
    seqs.add(cstrLabels0, c.label)
    seqs.add(cstrValues0, c.value)
    var mod0: UirCoreModule = module
    mod0.cstrs = cstrs0
    mod0.cstrLabels = cstrLabels0
    mod0.cstrValues = cstrValues0
    if uirCore_cstrs_cache_ready && uirCore_cstrs_cache_module == module:
        hashmaps.hashMapStrIntPut(uirCore_cstrs_cache, c.value, newIdx + 1)
        uirCore_cstrs_cache_len = uirCoreModuleCStringsLen(module)
    return label

fn uirCoreStrCmp(a: str, b: str): int32 =
    if len(a) == 0 && len(b) == 0:
        return 0
    if len(a) == 0:
        return -1
    if len(b) == 0:
        return 1
    let na: int32 = len(a)
    let nb: int32 = len(b)
    let n: int32 = na < nb ? na : nb
    for i in 0..<n:
        let ca: int32 = int32(int64(a[i]) & int64(0xFF))
        let cb: int32 = int32(int64(b[i]) & int64(0xFF))
        if ca < cb:
            return -1
        if ca > cb:
            return 1
    if na < nb:
        return -1
    if na > nb:
        return 1
    return 0

fn uirCoreNormalizeModule(module: UirCoreModule) =
    if (module == nil):
        return
    # Deterministic ordering: stable insertion-sort by name/label.
    for i in 1..<module.globals.len:
        let key: UirCoreGlobal = module.globals[i]
        var keyTypeRaw: int32 = uirCoreEncodeType(key.ty)
        if i >= 0 && i < module.globalTypesRaw.len:
            keyTypeRaw = uirCoreModuleGlobalTypeRawFastAt(module, i)
        var keyInit: int64 = key.init
        if i >= 0 && i < module.globalInits.len:
            keyInit = uirCoreModuleGlobalInitFastAt(module, i)
        var keyHasInit: int32 = 0
        if key.hasInit:
            keyHasInit = 1
        if i >= 0 && i < module.globalHasInitBits.len:
            keyHasInit = uirCoreModuleGlobalHasInitFastAt(module, i)
        var keyOrigin: str = ""
        if i >= 0 && i < module.globalOriginFiles.len:
            keyOrigin = uirCoreModuleGlobalOriginFastAt(module, i)
        var j: int32 = i - 1
        var keyName: str = ""
        if i >= 0 && i < module.globalNames.len:
            keyName = uirCoreModuleGlobalNameFastAt(module, i)
        for __for_guard_j in 0..i:
            if !(j >= 0):
                break
            let cur: UirCoreGlobal = module.globals[j]
            var curName: str = ""
            if j >= 0 && j < module.globalNames.len:
                curName = uirCoreModuleGlobalNameFastAt(module, j)
            if uirCoreStrCmp(curName, keyName) <= 0:
                break
            uirCoreWriteGlobal(&module.globals, j + 1, cur)
            if j >= 0 && j < module.globalNames.len && j + 1 < module.globalNames.len:
                uirCoreSetStr(module.globalNames, j + 1, uirCoreModuleGlobalNameFastAt(module, j))
            if j >= 0 && j < module.globalTypesRaw.len && j + 1 < module.globalTypesRaw.len:
                uirCoreSetInt32(module.globalTypesRaw, j + 1, uirCoreModuleGlobalTypeRawFastAt(module, j))
            if j >= 0 && j < module.globalInits.len && j + 1 < module.globalInits.len:
                uirCoreSetI64(module.globalInits, j + 1, uirCoreModuleGlobalInitFastAt(module, j))
            if j >= 0 && j < module.globalHasInitBits.len && j + 1 < module.globalHasInitBits.len:
                uirCoreSetInt32(module.globalHasInitBits, j + 1, uirCoreModuleGlobalHasInitFastAt(module, j))
            if j >= 0 && j < module.globalOriginFiles.len && j + 1 < module.globalOriginFiles.len:
                uirCoreSetStr(module.globalOriginFiles, j + 1, uirCoreModuleGlobalOriginFastAt(module, j))
            j = j - 1
        uirCoreWriteGlobal(&module.globals, j + 1, key)
        if j + 1 >= 0 && j + 1 < module.globalNames.len:
            uirCoreSetStr(module.globalNames, j + 1, keyName)
        if j + 1 >= 0 && j + 1 < module.globalTypesRaw.len:
            uirCoreSetInt32(module.globalTypesRaw, j + 1, keyTypeRaw)
        if j + 1 >= 0 && j + 1 < module.globalInits.len:
            uirCoreSetI64(module.globalInits, j + 1, keyInit)
        if j + 1 >= 0 && j + 1 < module.globalHasInitBits.len:
            uirCoreSetInt32(module.globalHasInitBits, j + 1, keyHasInit)
        if j + 1 >= 0 && j + 1 < module.globalOriginFiles.len:
            uirCoreSetStr(module.globalOriginFiles, j + 1, keyOrigin)

    for i in 1..<module.cstrs.len:
        let key2: UirCoreCString = module.cstrs[i]
        var j2: int32 = i - 1
        var keyLabel: str = key2.label
        if i >= 0 && i < module.cstrLabels.len:
            keyLabel = uirCoreModuleCStringLabelFastAt(module, i)
        var keyValue: str = key2.value
        if i >= 0 && i < module.cstrValues.len:
            keyValue = uirCoreModuleCStringValueFastAt(module, i)
        for __for_guard_j2 in 0..i:
            if !(j2 >= 0):
                break
            let cur2: UirCoreCString = module.cstrs[j2]
            var curLabel: str = cur2.label
            if j2 >= 0 && j2 < module.cstrLabels.len:
                curLabel = uirCoreModuleCStringLabelFastAt(module, j2)
            if uirCoreStrCmp(curLabel, keyLabel) <= 0:
                break
            uirCoreWriteCString(&module.cstrs, j2 + 1, cur2)
            if j2 >= 0 && j2 < module.cstrLabels.len && j2 + 1 < module.cstrLabels.len:
                uirCoreSetStr(module.cstrLabels, j2 + 1, uirCoreModuleCStringLabelFastAt(module, j2))
            if j2 >= 0 && j2 < module.cstrValues.len && j2 + 1 < module.cstrValues.len:
                uirCoreSetStr(module.cstrValues, j2 + 1, uirCoreModuleCStringValueFastAt(module, j2))
            j2 = j2 - 1
        uirCoreWriteCString(&module.cstrs, j2 + 1, key2)
        if j2 + 1 >= 0 && j2 + 1 < module.cstrLabels.len:
            uirCoreSetStr(module.cstrLabels, j2 + 1, keyLabel)
        if j2 + 1 >= 0 && j2 + 1 < module.cstrValues.len:
            uirCoreSetStr(module.cstrValues, j2 + 1, keyValue)

    for i in 1..<module.funcs.len:
        let key3 = module.funcs[i]
        let keyName: str = (key3 == nil) ? "" : uirCoreFuncNameOf(key3)
        var j3: int32 = i - 1
        let __for_start_j3 = j3
        for __for_rev_j3 in 0..(__for_start_j3 - (0)):
            j3 = __for_start_j3 - __for_rev_j3
            let cur = module.funcs[j3]
            let curName: str = (cur == nil) ? "" : uirCoreFuncNameOf(cur)
            if uirCoreStrCmp(curName, keyName) <= 0:
                break
            uirCoreWriteFunc(&module.funcs, j3 + 1, cur)
        uirCoreWriteFunc(&module.funcs, j3 + 1, key3)

fn uirCoreDemoModule(): UirCoreModule =
    let mod = uirCoreNewModule("arm64-apple-darwin")
    let retType: UirCoreType = uirCoreTypeI32()
    let f = uirCoreNewFunc("main", retType)
    let v: UirExprId = uirCoreConstI64(0)
    uirCoreAddBlock(f, uirCoreBlock("entry", uirCoreTermRet(v)))
    uirCoreAddFunc(mod, f)
    return mod

fn uirCoreFormatExpr(expr: UirExprId): str =
    if (!uirCoreExprIdValid(expr)):
        return "nil"
    let ek: UirCoreExprKind = uirCoreExprKindOf(expr)
    if ek == meConstI64:
        return intToStr(int32(uirCoreExprConstValueOf(expr)))
    if ek == meBin:
        var op: str = "?"
        case uirCoreExprBinOpOf(expr)
        of mbAdd: op = "+"
        of mbSub: op = "-"
        of mbMul: op = "*"
        of mbSdiv: op = "/"
        of mbSmod: op = "%"
        of mbAnd: op = "&"
        of mbOr: op = "|"
        of mbXor: op = "^"
        of mbShl: op = "<<"
        of mbShr: op = ">>"
        return "(" + uirCoreFormatExpr(uirCoreExprLhsOf(expr)) + " " + op + " " + uirCoreFormatExpr(uirCoreExprRhsOf(expr)) + ")"
    if ek == meCmp:
        var op2: str = "=="
        case uirCoreExprCmpOpOf(expr)
        of mcEq: op2 = "=="
        of mcNe: op2 = "!="
        of mcLt: op2 = "<"
        of mcLe: op2 = "<="
        of mcGt: op2 = ">"
        of mcGe: op2 = ">="
        return "(" + uirCoreFormatExpr(uirCoreExprLhsOf(expr)) + " " + op2 + " " + uirCoreFormatExpr(uirCoreExprRhsOf(expr)) + ")"
    if ek == meLocal:
        return "$l" + intToStr(uirCoreExprLocalIndexOf(expr))
    if ek == meAddr:
        return "&$l" + intToStr(uirCoreExprLocalIndexOf(expr))
    if ek == meLoad:
        return "*" + uirCoreFormatExpr(uirCoreExprAddrExprOf(expr))
    if ek == meGlobalAddr:
        return "&" + uirCoreExprGlobalNameOf(expr)
    if ek == meCall:
        var out: str = uirCoreExprCalleeOf(expr) + "("
        for i in 0..<uirCoreExprArgsLen(expr):
            if i > 0:
                out = out + ", "
            out = out + uirCoreFormatExpr(uirCoreExprArgAt(expr, i))
        return out + ")"
    if ek == meCast:
        let cty: UirCoreType = uirCoreExprCastTypeOf(expr)
        let cexpr: UirExprId = uirCoreExprCastExprOf(expr)
        if cty.kind == mtVoid:
            return "void(" + uirCoreFormatExpr(cexpr) + ")"
        if cty.kind == mtF64:
            return "f64(" + uirCoreFormatExpr(cexpr) + ")"
        if cty.kind == mtF32:
            return "f32(" + uirCoreFormatExpr(cexpr) + ")"
        if cty.kind == mtI64:
            return (cty.isUnsigned ? "u64(" : "i64(") + uirCoreFormatExpr(cexpr) + ")"
        if cty.kind == mtI32:
            return (cty.isUnsigned ? "u32(" : "i32(") + uirCoreFormatExpr(cexpr) + ")"
        if cty.kind == mtI16:
            return (cty.isUnsigned ? "u16(" : "i16(") + uirCoreFormatExpr(cexpr) + ")"
        if cty.kind == mtI8:
            return (cty.isUnsigned ? "u8(" : "i8(") + uirCoreFormatExpr(cexpr) + ")"
        return "i32(" + uirCoreFormatExpr(cexpr) + ")"
    return "?"

fn uirCoreFormat(module: UirCoreModule): str =
    var out: str = ""
    out = out + "module " + module.target + "\n"
    for gi in 0..<module.globals.len:
        let g: UirCoreGlobal = module.globals[gi]
        out = out + "global " + g.name + ": "
        if g.ty.kind == mtVoid:
            out = out + "void"
        elif g.ty.kind == mtF64:
            out = out + "f64"
        elif g.ty.kind == mtF32:
            out = out + "f32"
        elif g.ty.kind == mtI64:
            out = out + (g.ty.isUnsigned ? "u64" : "i64")
        elif g.ty.kind == mtI32:
            out = out + (g.ty.isUnsigned ? "u32" : "i32")
        elif g.ty.kind == mtI16:
            out = out + (g.ty.isUnsigned ? "u16" : "i16")
        elif g.ty.kind == mtI8:
            out = out + (g.ty.isUnsigned ? "u8" : "i8")
        else:
            out = out + "i32"
        if g.hasInit:
            out = out + " = " + intToStr(int32(g.init))
        out = out + "\n"
    for i in 0..<module.funcs.len:
        let f = module.funcs[i]
        out = out + "fn " + uirCoreFuncNameOf(f) + "("
        for pi in 0..<uirCoreFuncParamsLen(f):
            let p: UirCoreParam = uirCoreFuncParamAt(f, pi)
            if pi > 0:
                out = out + ", "
            out = out + p.name
        out = out + "): "
        let retTy: UirCoreType = uirCoreFuncRetTypeOf(f)
        if retTy.kind == mtVoid:
            out = out + "void\n"
        elif retTy.kind == mtF64:
            out = out + "f64\n"
        elif retTy.kind == mtF32:
            out = out + "f32\n"
        elif retTy.kind == mtI64:
            out = out + (retTy.isUnsigned ? "u64\n" : "i64\n")
        elif retTy.kind == mtI32:
            out = out + (retTy.isUnsigned ? "u32\n" : "i32\n")
        elif retTy.kind == mtI16:
            out = out + (retTy.isUnsigned ? "u16\n" : "i16\n")
        elif retTy.kind == mtI8:
            out = out + (retTy.isUnsigned ? "u8\n" : "i8\n")
        else:
            out = out + "i32\n"
        for bi in 0..<uirCoreFuncBlocksLen(f):
            let b = uirCoreFuncBlockAt(f, bi)
            let bLabel: str = uirCoreBlockLabelOf(b)
            out = out + bLabel + ":\n"
            for si in 0..<uirCoreBlockStmtsLen(b):
                let s: UirStmtId = uirCoreBlockStmtAt(b, si)
                let sk: UirCoreStmtKind = uirCoreStmtKindOf(s)
                let sname: str = uirCoreStmtNameOf(s)
                let sexpr: UirExprId = uirCoreStmtExprOf(s)
                if sk == msLet:
                    out = out + "  let " + sname + " = " + uirCoreFormatExpr(sexpr) + "\n"
                elif sk == msVar:
                    out = out + "  var " + sname + " = " + uirCoreFormatExpr(sexpr) + "\n"
                elif sk == msAssign:
                    out = out + "  " + sname + " = " + uirCoreFormatExpr(sexpr) + "\n"
                elif sk == msParam:
                    out = out + "  param " + sname + "\n"
                elif sk == msStore:
                    out = out + "  *" + uirCoreFormatExpr(uirCoreStmtAddrExprOf(s)) + " = " + uirCoreFormatExpr(sexpr) + "\n"
                else:
                    out = out + "  expr " + uirCoreFormatExpr(sexpr) + "\n"
            let term: UirCoreTerm = uirCoreBlockTermOf(b)
            if term.kind == mtRet:
                let retExpr: UirExprId = term.retExpr
                if (!uirCoreExprIdValid(retExpr)):
                    out = out + "  ret\n"
                else:
                    out = out + "  ret " + uirCoreFormatExpr(retExpr) + "\n"
            elif term.kind == mtBr:
                out = out + "  br " + term.target + "\n"
            else:
                let condExpr: UirExprId = term.condExpr
                out = out + "  cbr " + uirCoreFormatExpr(condExpr) + " ? " +
                      term.targetTrue + " : " + term.targetFalse + "\n"
    return out

fn uirCoreValidateExpr(func: UirCoreFunc, expr: UirExprId, ctx: str): Result[bool] =
    if (!uirCoreExprIdValid(expr)):
        return Err[bool]("uirCore_validate: nil expr (" + ctx + ")")
    let ek: UirCoreExprKind = uirCoreExprKindOf(expr)
    if ek == meConstI64:
        return Ok[bool](true)
    if ek == meLocal:
        let localIndex: int32 = uirCoreExprLocalIndexOf(expr)
        if localIndex < 0:
            return Err[bool]("uirCore_validate: negative local index (" + ctx + ")")
        if uirCoreFuncIdValid(func) && localIndex >= uirCoreFuncLocalTypesLen(func):
            return Err[bool]("uirCore_validate: local index out of range (" + ctx + ")")
        return Ok[bool](true)
    if ek == meAddr:
        let addrSlot: int32 = uirCoreExprLocalIndexOf(expr)
        if addrSlot < 0:
            return Err[bool]("uirCore_validate: negative addr slot (" + ctx + ")")
        if uirCoreFuncIdValid(func):
            if addrSlot >= uirCoreFuncLocalTypesLen(func):
                return Err[bool]("uirCore_validate: addr slot out of range (" + ctx + ")")
            for oi in 0..<uirCoreFuncObjLocalsLen(func):
                let ol: UirCoreObjLocal = uirCoreFuncObjLocalAt(func, oi)
                if ol.slot == addrSlot && ol.frameOff >= 0:
                    return Err[bool]("uirCore_validate: meAddr on object-local slot (pointer-to-pointer) (" + ctx + ")")
        return Ok[bool](true)
    if ek == meLoad:
        let loadType: UirCoreType = uirCoreExprLoadTypeOf(expr)
        let addrExpr: UirExprId = uirCoreExprAddrExprOf(expr)
        if loadType.kind == mtVoid:
            return Err[bool]("uirCore_validate: load void type (" + ctx + ")")
        if (!uirCoreExprIdValid(addrExpr)):
            return Err[bool]("uirCore_validate: load missing addr (" + ctx + ")")
        return uirCoreValidateExpr(func, addrExpr, ctx + "/load.addr")
    if ek == meGlobalAddr:
        if len(uirCoreExprGlobalNameOf(expr)) == 0:
            return Err[bool]("uirCore_validate: global addr missing name (" + ctx + ")")
        return Ok[bool](true)
    if ek == meBin || ek == meCmp:
        let lhs: UirExprId = uirCoreExprLhsOf(expr)
        let rhs: UirExprId = uirCoreExprRhsOf(expr)
        if (!uirCoreExprIdValid(lhs)) || (!uirCoreExprIdValid(rhs)):
            return Err[bool]("uirCore_validate: binary expr missing operand (" + ctx + ")")
        let lres: Result[bool] = uirCoreValidateExpr(func, lhs, ctx + "/lhs")
        if ! IsOk[bool](lres):
            return lres
        return uirCoreValidateExpr(func, rhs, ctx + "/rhs")
    if ek == meCall:
        if len(uirCoreExprCalleeOf(expr)) == 0:
            return Err[bool]("uirCore_validate: call missing callee (" + ctx + ")")
        for ai in 0..<uirCoreExprArgsLen(expr):
            let ares: Result[bool] = uirCoreValidateExpr(func, uirCoreExprArgAt(expr, ai), ctx + "/arg")
            if ! IsOk[bool](ares):
                return ares
        return Ok[bool](true)
    if ek == meCast:
        let castExpr: UirExprId = uirCoreExprCastExprOf(expr)
        if (!uirCoreExprIdValid(castExpr)):
            return Err[bool]("uirCore_validate: cast missing expr (" + ctx + ")")
        return uirCoreValidateExpr(func, castExpr, ctx + "/cast")
    return Err[bool]("uirCore_validate: unknown expr kind (" + ctx + ")")

fn uirCoreValidateObjType(ty: UirCoreObjType): Result[bool] =
    if len(ty.name) == 0:
        return Err[bool]("uirCore_validate: obj type missing name")
    if ty.size < 0:
        return Err[bool]("uirCore_validate: obj type size < 0 (" + ty.name + ")")
    if ty.size == 0 && ty.fields.len != 0:
        return Err[bool]("uirCore_validate: obj type size == 0 but has fields (" + ty.name + ")")
    if ty.alignPow2 < 0:
        return Err[bool]("uirCore_validate: obj type alignPow2 < 0 (" + ty.name + ")")
    let align: int32 = 1 << ty.alignPow2
    if align <= 0:
        return Err[bool]("uirCore_validate: obj type invalid alignPow2 (" + ty.name + ")")
    if (ty.size % align) != 0:
        return Err[bool]("uirCore_validate: obj type size not aligned (" + ty.name + ")")
    var maxAlign: int32 = 0
    var lastEnd: int32 = 0
    for i in 0..<ty.fields.len:
        let f: UirCoreObjField = ty.fields[i]
        if len(f.name) == 0:
            return Err[bool]("uirCore_validate: obj field missing name (" + ty.name + ")")
        if f.ty.kind == mtVoid:
            return Err[bool]("uirCore_validate: obj field has void type (" + ty.name + "." + f.name + ")")
        let sz: int32 = uirCoreTypeSize(f.ty)
        if sz <= 0:
            return Err[bool]("uirCore_validate: obj field has unsupported type (" + ty.name + "." + f.name + ")")
        let ap2: int32 = uirCoreTypeAlignPow2(f.ty)
        if ap2 > maxAlign:
            maxAlign = ap2
        let falign: int32 = 1 << ap2
        if falign > 0 && (f.offset % falign) != 0:
            return Err[bool]("uirCore_validate: obj field misaligned (" + ty.name + "." + f.name + ")")
        if f.offset < lastEnd:
            return Err[bool]("uirCore_validate: obj field overlaps (" + ty.name + "." + f.name + ")")
        let end: int32 = f.offset + sz
        if end > ty.size:
            return Err[bool]("uirCore_validate: obj field out of bounds (" + ty.name + "." + f.name + ")")
        lastEnd = end
    if ty.alignPow2 < maxAlign:
        return Err[bool]("uirCore_validate: obj type alignPow2 too small (" + ty.name + ")")
    return Ok[bool](true)

fn uirCoreValidateFunc(module: UirCoreModule, func: UirCoreFunc): Result[bool] =
    if (!uirCoreFuncIdValid(func)):
        return Err[bool]("uirCore_validate: nil func")
    let funcName: str = uirCoreFuncNameOf(func)
    let funcRetType: UirCoreType = uirCoreFuncRetTypeOf(func)
    let funcIsExtern: bool = uirCoreFuncIsExtern(func)
    let funcPhaseTag: int32 = uirCoreFuncPhaseTagOf(func)
    let funcLowUirLowered: bool = uirCoreFuncLowUirLoweredOf(func)
    let funcHighUirChecked: bool = uirCoreFuncHighUirCheckedOf(func)
    let funcFallbackReason: str = uirCoreFuncPhaseFallbackReasonOf(func)
    if len(funcName) == 0:
        return Err[bool]("uirCore_validate: func missing name")
    if funcIsExtern:
        return Ok[bool](true)
    if funcPhaseTag != uirCorePhaseLowTag() && funcPhaseTag != uirCorePhaseHighTag():
        return Err[bool]("uirCore_validate: invalid phase tag (" + funcName + ")")
    if funcLowUirLowered && funcPhaseTag != uirCorePhaseLowTag():
        return Err[bool]("uirCore_validate: low lowered func not in low phase (" + funcName + ")")
    if funcPhaseTag == uirCorePhaseLowTag() && !funcLowUirLowered:
        return Err[bool]("uirCore_validate: low phase func missing lowered flag (" + funcName + ")")
    let hasFallbackReason: bool = len(funcFallbackReason) > 0
    if funcHighUirChecked && hasFallbackReason:
        return Err[bool]("uirCore_validate: checked high phase cannot carry fallback reason (" + funcName + ")")
    if !funcHighUirChecked && !hasFallbackReason:
        return Err[bool]("uirCore_validate: unchecked high phase requires fallback reason (" + funcName + ")")
    if uirCoreFuncBlocksLen(func) == 0:
        return Err[bool]("uirCore_validate: func has no blocks (" + funcName + ")")
    # Labels: unique + reachable branch targets.
    for i in 0..<uirCoreFuncBlocksLen(func):
        let b = uirCoreFuncBlockAt(func, i)
        if (!uirCoreBlockIdValid(b)):
            return Err[bool]("uirCore_validate: nil block (" + funcName + ")")
        let label: str = uirCoreBlockLabelOf(b)
        if len(label) == 0:
            return Err[bool]("uirCore_validate: block missing label (" + funcName + ")")
        for j in 0..<i:
            let prev = uirCoreFuncBlockAt(func, j)
            if uirCoreBlockIdValid(prev) && (uirCoreBlockLabelOf(prev) == label):
                return Err[bool]("uirCore_validate: duplicate block label (" + funcName + ":" + label + ")")

    for bi in 0..<uirCoreFuncBlocksLen(func):
        let b2 = uirCoreFuncBlockAt(func, bi)
        let b2Label: str = uirCoreBlockLabelOf(b2)
        let term2: UirCoreTerm = uirCoreBlockTermOf(b2)
        let retExpr2: UirExprId = term2.retExpr
        let condExpr2: UirExprId = term2.condExpr
        if term2.kind == mtRet:
            if funcRetType.kind != mtVoid && (!uirCoreExprIdValid(retExpr2)):
                return Err[bool]("uirCore_validate: missing ret expr (" + funcName + ":" + b2Label + ")")
            if funcRetType.kind == mtVoid && uirCoreExprIdValid(retExpr2):
                return Err[bool]("uirCore_validate: void ret with expr (" + funcName + ":" + b2Label + ")")
        elif term2.kind == mtBr:
            if len(term2.target) == 0:
                return Err[bool]("uirCore_validate: br missing target (" + funcName + ":" + b2Label + ")")
            var found: bool = false
            for li in 0..<uirCoreFuncBlocksLen(func):
                let bb = uirCoreFuncBlockAt(func, li)
                if uirCoreBlockIdValid(bb) && (uirCoreBlockLabelOf(bb) == term2.target):
                    found = true
                    break
            if ! found:
                return Err[bool]("uirCore_validate: br target not found (" + funcName + ":" + b2Label + ")")
        else:
            if (!uirCoreExprIdValid(condExpr2)):
                return Err[bool]("uirCore_validate: cbr missing cond (" + funcName + ":" + b2Label + ")")
            if len(term2.targetTrue) == 0:
                return Err[bool]("uirCore_validate: cbr missing true target (" + funcName + ":" + b2Label + ")")
            if len(term2.targetFalse) == 0:
                return Err[bool]("uirCore_validate: cbr missing false target (" + funcName + ":" + b2Label + ")")
            var foundT: bool = false
            var foundF: bool = false
            for li2 in 0..<uirCoreFuncBlocksLen(func):
                let bb2 = uirCoreFuncBlockAt(func, li2)
                if uirCoreBlockIdValid(bb2) && (uirCoreBlockLabelOf(bb2) == term2.targetTrue):
                    foundT = true
                if uirCoreBlockIdValid(bb2) && (uirCoreBlockLabelOf(bb2) == term2.targetFalse):
                    foundF = true
            if ! foundT || ! foundF:
                return Err[bool]("uirCore_validate: cbr target not found (" + funcName + ":" + b2Label + ")")
        for si in 0..<uirCoreBlockStmtsLen(b2):
            let s: UirStmtId = uirCoreBlockStmtAt(b2, si)
            let sk: UirCoreStmtKind = uirCoreStmtKindOf(s)
            let sslot: int32 = uirCoreStmtSlotOf(s)
            let sexpr: UirExprId = uirCoreStmtExprOf(s)
            let sname: str = uirCoreStmtNameOf(s)
            let sparamIndex: int32 = uirCoreStmtParamIndexOf(s)
            let saddr: UirExprId = uirCoreStmtAddrExprOf(s)
            let sstoreTy: UirCoreType = uirCoreStmtStoreTypeOf(s)
            if sk != msLet && sk != msVar && sk != msAssign &&
               sk != msExpr && sk != msParam && sk != msStore:
                return Err[bool]("uirCore_validate: invalid stmt kind (" + funcName + ":" + b2Label +
                                 " si=" + intToStr(si) +
                                 " kind=" + intToStr(int32(sk)) +
                                 " slot=" + intToStr(sslot) +
                                 " stmts.len=" + intToStr(uirCoreBlockStmtsLen(b2)) +
                                 ")")
            if sk == msLet || sk == msVar || sk == msAssign:
                if sslot < 0:
                    return Err[bool]("uirCore_validate: stmt slot < 0 (" + funcName + ":" + b2Label + ")")
                if (!uirCoreExprIdValid(sexpr)):
                    return Err[bool]("uirCore_validate: stmt missing expr (" + funcName + ":" + b2Label +
                                     " si=" + intToStr(si) +
                                     " kind=" + uirCoreStmtKindName(sk) +
                                     " name=" + (len(sname) == 0 ? "" : sname) +
                                     " slot=" + intToStr(sslot) + ")")
                let eres: Result[bool] = uirCoreValidateExpr(func, sexpr, funcName + ":" + b2Label + "/stmt")
                if ! IsOk[bool](eres):
                    return eres
            elif sk == msParam:
                if sslot < 0 || sparamIndex < 0:
                    return Err[bool]("uirCore_validate: param stmt invalid (" + funcName + ":" + b2Label + ")")
            elif sk == msStore:
                if (!uirCoreExprIdValid(saddr)) || (!uirCoreExprIdValid(sexpr)):
                    return Err[bool]("uirCore_validate: store missing expr/addr (" + funcName + ":" + b2Label + ")")
                if sstoreTy.kind == mtVoid:
                    return Err[bool]("uirCore_validate: store void type (" + funcName + ":" + b2Label + ")")
                let ares: Result[bool] = uirCoreValidateExpr(func, saddr, funcName + ":" + b2Label + "/store.addr")
                if ! IsOk[bool](ares):
                    return ares
                let vres: Result[bool] = uirCoreValidateExpr(func, sexpr, funcName + ":" + b2Label + "/store.value")
                if ! IsOk[bool](vres):
                    return vres
            else:
                if (!uirCoreExprIdValid(sexpr)):
                    return Err[bool]("uirCore_validate: expr stmt missing expr (" + funcName + ":" + b2Label +
                                     " si=" + intToStr(si) +
                                     " kind=" + uirCoreStmtKindName(sk) + ")")
                let eres2: Result[bool] = uirCoreValidateExpr(func, sexpr, funcName + ":" + b2Label + "/expr")
                if ! IsOk[bool](eres2):
                    return eres2

        if term2.kind == mtRet && uirCoreExprIdValid(retExpr2):
            let rres: Result[bool] = uirCoreValidateExpr(func, retExpr2, funcName + ":" + b2Label + "/ret")
            if ! IsOk[bool](rres):
                return rres
        if term2.kind == mtCbr && uirCoreExprIdValid(condExpr2):
            let cres: Result[bool] = uirCoreValidateExpr(func, condExpr2, funcName + ":" + b2Label + "/cbr.cond")
            if ! IsOk[bool](cres):
                return cres

    # Object locals should be backed by i64 pointer slots.
    for oi in 0..<uirCoreFuncObjLocalsLen(func):
        let ol2: UirCoreObjLocal = uirCoreFuncObjLocalAt(func, oi)
        if ol2.slot < 0 || ol2.slot >= uirCoreFuncLocalTypesLen(func):
            return Err[bool]("uirCore_validate: obj local slot out of range (" + funcName + ")")
        if uirCoreFuncLocalTypesLen(func) > 0:
            let slotTy: UirCoreType = uirCoreFuncLocalTypeAt(func, ol2.slot)
            if slotTy.kind != mtI64:
                let tk: str = len(ol2.typeKey) > 0 ? ol2.typeKey : ""
                return Err[bool]("uirCore_validate: obj local slot not i64 (" + funcName +
                                 " slot=" + intToStr(ol2.slot) +
                                 " ty=" + uirCoreTypeKindName(slotTy) +
                                 " obj=" + ol2.objTypeName +
                                 " typeKey=" + tk +
                                 " frameOff=" + intToStr(ol2.frameOff) + ")")
        if len(ol2.objTypeName) == 0:
            return Err[bool]("uirCore_validate: obj local missing objTypeName (" + funcName + ")")
        if !(module == nil) && ! uirCoreHasObjType(module, ol2.objTypeName):
            return Err[bool]("uirCore_validate: obj local objType not found (" + funcName + ":" + ol2.objTypeName + ")")

    return Ok[bool](true)

fn uirCoreValidateModule(module: UirCoreModule): Result[bool] =
    if (module == nil):
        return Err[bool]("uirCore_validate: nil module")
    for oi in 0..<module.objTypes.len:
        let ot: UirCoreObjType = module.objTypes[oi]
        let ores: Result[bool] = uirCoreValidateObjType(ot)
        if ! IsOk[bool](ores):
            return ores
    for fi in 0..<module.funcs.len:
        let f = module.funcs[fi]
        let fres: Result[bool] = uirCoreValidateFunc(module, f)
        if ! IsOk[bool](fres):
            return fres
    return Ok[bool](true)
