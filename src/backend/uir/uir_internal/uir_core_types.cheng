    let dbgNameObj0: str = (funcObj != nil) ? funcObj->name : ""
    let dbgNameDyn0: str = (uirCoreFuncDyn(func) != nil) ? uirCoreFuncDyn(func).name : ""
    let dbgTrack: bool = dbgBoot &&
                         (dbgNameObj0 == "main" || dbgNameObj0 == "backendMain" ||
                          dbgNameDyn0 == "main" || dbgNameDyn0 == "backendMain")
    if dbgTrack:
        os.writeLine(os.get_stderr(),
                     "[backend] dbg_phase_contract.before name=" +
                     (len(dbgNameObj0) > 0 ? dbgNameObj0 : dbgNameDyn0) +
                     " obj_extern=" + ((funcObj != nil && funcObj->isExtern) ? "1" : "0") +
                     " dyn_extern=" + ((uirCoreFuncDyn(func) != nil && uirCoreFuncDyn(func).isExtern) ? "1" : "0") +
                     " phase=" + intToStr(phaseTag) +
                     " high=" + (highUirChecked ? "1" : "0") +
                     " low=" + (lowUirLowered ? "1" : "0"))
        os.c_fflush(os.get_stderr())
    if funcObj != nil:
        funcObj->phaseTag = phaseTag
        funcObj->highUirChecked = highUirChecked
        funcObj->lowUirLowered = lowUirLowered
        funcObj->phaseFallbackReason = uirCoreOwnStrSafe(fallbackReason)
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(func)
    if dyn == nil:
        return
    dyn.phaseTag = phaseTag
    dyn.highUirChecked = highUirChecked
    dyn.lowUirLowered = lowUirLowered
    dyn.phaseFallbackReason = uirCoreOwnStrSafe(fallbackReason)
    if dbgTrack:
        os.writeLine(os.get_stderr(),
                     "[backend] dbg_phase_contract.after name=" +
                     (len(dbgNameObj0) > 0 ? dbgNameObj0 : dbgNameDyn0) +
                     " obj_extern=" + ((funcObj != nil && funcObj->isExtern) ? "1" : "0") +
                     " dyn_extern=" + (dyn.isExtern ? "1" : "0"))
        os.c_fflush(os.get_stderr())

fn uirCoreFuncAddParam(func: UirCoreFunc, param: UirCoreParam) =
