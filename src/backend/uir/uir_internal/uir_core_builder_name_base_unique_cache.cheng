# Shared builder-local name/base-unique cache helpers split from uir_core_builder.
import std/system
import std/hashmaps
import std/seqs
import std/rawmem_support
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_base_helpers
import backend/uir/uir_internal/uir_core_builder_type_name_cache

@importc("driver_c_new_string_copy_n")
fn builder_name_cache_c_new_string_copy_n_raw(raw: ptr, n: int32): cstring

fn builder_name_cache_c_new_string_copy_n(raw: ptr, n: int32): str =
    if raw == nil || n <= 0:
        return ""
    let outRaw: cstring = builder_name_cache_c_new_string_copy_n_raw(raw, n)
    return strViewUnsafe(outRaw, n)

fn uirCoreModMarker(): str =
    return "__cheng_mod_"

fn uirCoreBaseUniqueStableText(s: str): str =
    if len(s) == 0:
        return ""
    return uirCoreOwnStr(s)

fn uirCoreBaseUniqueTextCacheFind(keys: str[], key0: str): int32 =
    if len(key0) == 0 || keys.len <= 0:
        return -1
    var i: int32 = keys.len - 1
    while i >= 0:
        if keys[i] == key0:
            return i
        i = i - 1
    return -1

fn uirCoreBaseUniqueTextCacheGet(keys: str[], vals: int32[], key0: str, found: var bool): int32 =
    found = false
    if len(key0) == 0:
        return 0
    let idx: int32 = uirCoreBaseUniqueTextCacheFind(keys, key0)
    if idx < 0 || idx >= vals.len:
        return 0
    found = true
    return vals[idx]

fn uirCoreBaseUniqueTextCachePut(keys: var str[], vals: var int32[], key0: str, rawVal: int32) =
    if len(key0) == 0:
        return
    let idx: int32 = uirCoreBaseUniqueTextCacheFind(keys, key0)
    if idx >= 0 && idx < vals.len:
        keys[idx] = key0
        vals[idx] = rawVal
        return
    seqs.add(keys, key0)
    seqs.add(vals, rawVal)

fn uirCoreBaseUniquePtrCacheFind(keys: int64[], key0: int64): int32 =
    if key0 == 0 || keys.len <= 0:
        return -1
    var i: int32 = keys.len - 1
    while i >= 0:
        if keys[i] == key0:
            return i
        i = i - 1
    return -1

fn uirCoreBaseUniquePtrCacheGet(keys: int64[], vals: int32[], key0: int64, found: var bool): int32 =
    found = false
    if key0 == 0:
        return 0
    let idx: int32 = uirCoreBaseUniquePtrCacheFind(keys, key0)
    if idx < 0 || idx >= vals.len:
        return 0
    found = true
    return vals[idx]

fn uirCoreBaseUniquePtrCachePut(keys: var int64[], vals: var int32[], key0: int64, rawVal: int32) =
    if key0 == 0:
        return
    let idx: int32 = uirCoreBaseUniquePtrCacheFind(keys, key0)
    if idx >= 0 && idx < vals.len:
        keys[idx] = key0
        vals[idx] = rawVal
        return
    seqs.add(keys, key0)
    seqs.add(vals, rawVal)

var
    uirCore_globalBaseUnique_cache_module: UirCoreModule
    uirCore_globalBaseUnique_cache_keys: str[]
    uirCore_globalBaseUnique_cache_vals: int32[]
    uirCore_globalBaseUnique_ptr_cache_keys: int64[]
    uirCore_globalBaseUnique_ptr_cache_vals: int32[]
    uirCore_globalBaseUnique_cache_len: int32
    uirCore_globalBaseUnique_cache_ready: bool
    uirCore_globalBaseUnique_recent_module: UirCoreModule
    uirCore_globalBaseUnique_recent_base: str
    uirCore_globalBaseUnique_recent_len: int32
    uirCore_globalBaseUnique_recent_ptr: int64
    uirCore_globalBaseUnique_recent_raw: int32
    uirCore_globalBaseUnique_recent_valid: bool

    uirCore_funcBaseUnique_cache_module: UirCoreModule
    uirCore_funcBaseUnique_cache_keys: str[]
    uirCore_funcBaseUnique_cache_vals: int32[]
    uirCore_funcBaseUnique_ptr_cache_keys: int64[]
    uirCore_funcBaseUnique_ptr_cache_vals: int32[]
    uirCore_funcBaseUnique_exact_keys: str[]
    uirCore_funcBaseUnique_exact_vals: int32[]
    uirCore_funcBaseUnique_cache_len: int32
    uirCore_funcBaseUnique_cache_ready: bool
    uirCore_funcBaseUnique_recent_module: UirCoreModule
    uirCore_funcBaseUnique_recent_base: str
    uirCore_funcBaseUnique_recent_len: int32
    uirCore_funcBaseUnique_recent_ptr: int64
