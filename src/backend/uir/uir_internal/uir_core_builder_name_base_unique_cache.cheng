# Shared builder-local name/base-unique cache helpers split from uir_core_builder.
import std/system
import std/hashmaps
import std/seqs
import std/rawmem_support
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_type_name_cache
import backend/uir/uir_internal/uir_core_builder_string_utils
import backend/uir/uir_internal/uir_core_builder_overload_scan

@importc("driver_c_new_string_copy_n")
fn builder_name_cache_c_new_string_copy_n_raw(raw: ptr, n: int32): cstring

fn builder_name_cache_c_new_string_copy_n(raw: ptr, n: int32): str =
    if raw == nil || n <= 0:
        return ""
    let outRaw: cstring = builder_name_cache_c_new_string_copy_n_raw(raw, n)
    return strViewUnsafe(outRaw, n)

fn uirCoreModMarker(): str =
    return "__cheng_mod_"

fn uirCoreBaseUniqueStableText(s: str): str =
    if len(s) == 0:
        return ""
    return uirCoreOwnStr(s)

var
    uirCore_globalBaseUnique_cache_module: UirCoreModule
    uirCore_globalBaseUnique_cache: hashmaps.HashMapStrInt
    uirCore_globalBaseUnique_ptr_cache: hashmaps.HashMapPtrInt
    uirCore_globalBaseUnique_exact_cache: hashmaps.HashMapStrInt
    uirCore_globalBaseUnique_cache_len: int32
    uirCore_globalBaseUnique_cache_ready: bool
    uirCore_globalBaseUnique_recent_module: UirCoreModule
    uirCore_globalBaseUnique_recent_base: str
    uirCore_globalBaseUnique_recent_len: int32
    uirCore_globalBaseUnique_recent_ptr: int64
    uirCore_globalBaseUnique_recent_raw: int32
    uirCore_globalBaseUnique_recent_valid: bool

    uirCore_funcBaseUnique_cache_module: UirCoreModule
    uirCore_funcBaseUnique_cache: hashmaps.HashMapStrInt
    uirCore_funcBaseUnique_ptr_cache: hashmaps.HashMapPtrInt
    uirCore_funcBaseUnique_exact_cache: hashmaps.HashMapStrInt
    uirCore_funcBaseUnique_cache_len: int32
    uirCore_funcBaseUnique_cache_ready: bool
    uirCore_funcBaseUnique_recent_module: UirCoreModule
    uirCore_funcBaseUnique_recent_base: str
    uirCore_funcBaseUnique_recent_len: int32
    uirCore_funcBaseUnique_recent_ptr: int64
    uirCore_funcBaseUnique_recent_raw: int32
    uirCore_funcBaseUnique_recent_valid: bool

    uirCore_objTypeBaseUnique_cache_module: UirCoreModule
    uirCore_objTypeBaseUnique_cache: hashmaps.HashMapStrInt
    uirCore_objTypeBaseUnique_exact_cache: hashmaps.HashMapStrInt
    uirCore_objTypeBaseUnique_cache_len: int32
    uirCore_objTypeBaseUnique_cache_ready: bool

    uirCore_sanitizedLinkPrefix_ptr_index: hashmaps.HashMapPtrInt
    uirCore_sanitizedLinkPrefix_text_index: hashmaps.HashMapStrInt
    uirCore_sanitizedLinkPrefix_values: str[]
    uirCore_sanitizedLinkPrefix_recent_ptr: int64
    uirCore_sanitizedLinkPrefix_recent_raw: str
    uirCore_sanitizedLinkPrefix_recent_val: str
    uirCore_sanitizedLinkPrefix_recent_valid: bool

fn uirCoreHexNibble(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn uirCoreRecoverSanitizedLinkInput(name0: str, name0Len: int32): str =
    if name0[0] != ' ' && name0[name0Len - 1] != ' ':
        return name0
    return backendStripSpaces(name0)

fn uirCoreSanitizedLinkPrefixCacheEnsure() =
    if uirCore_sanitizedLinkPrefix_ptr_index.mask == 0:
        uirCore_sanitizedLinkPrefix_ptr_index = hashmaps.hashMapPtrIntInit(4096)
    if uirCore_sanitizedLinkPrefix_text_index.mask == 0:
        uirCore_sanitizedLinkPrefix_text_index = hashmaps.hashMapStrIntInit(4096)

fn uirCoreSanitizedLinkPrefixRemember(raw: str, value: str, ptrKey: int64) =
    uirCore_sanitizedLinkPrefix_recent_ptr = ptrKey
    uirCore_sanitizedLinkPrefix_recent_raw = uirCoreBaseUniqueStableText(raw)
    uirCore_sanitizedLinkPrefix_recent_val = uirCoreBaseUniqueStableText(value)
    uirCore_sanitizedLinkPrefix_recent_valid = true

fn uirCoreTakeBeforeModMarker(name0: str): str =
    let modMarker: str = uirCoreModMarker()
    let modOff: int32 = uirCoreStrIndexOfWithLen(name0, strLenFast(name0), modMarker, strLenFast(modMarker))
    if modOff > 0:
        return uirCoreStrTake(name0, modOff)
    return name0

fn uirCoreRecoverSanitizedLinkPrefixImpl(name0: str, name0Len: int32): str =
    let prefixLen: int32 = 11
    if name0Len <= prefixLen + 1 || name0[0] != '_' || name0[1] != '_':
        return ""
    let name: str = uirCoreRecoverSanitizedLinkInput(name0, name0Len)
    let nameLen: int32 = strLenFast(name)
    if nameLen <= prefixLen + 1:
        return ""
    if name[0] != '_' || name[1] != '_' || name[2] != 'c' || name[3] != 'h' ||
       name[4] != 'e' || name[5] != 'n' || name[6] != 'g' || name[7] != '_' ||
       name[8] != 's' || name[9] != 'y' || name[10] != 'm' || name[11] != '_':
        return ""
    let maxBytes: int32 = (nameLen - prefixLen) / 3
    if maxBytes <= 0:
        return ""
    let out: str = newStringOfCap(maxBytes)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var outIdx: int32 = 0
    var i: int32 = prefixLen
    while i + 2 < nameLen && name[i] == '_':
        let hi: int32 = uirCoreHexNibble(name[i + 1])
        let lo: int32 = uirCoreHexNibble(name[i + 2])
        if hi < 0 || lo < 0:
            break
        rawmem_support.rawmemSet(rawmem_support.rawmemPtrAdd(outPtr, outIdx), hi * 16 + lo, 1)
        outIdx = outIdx + 1
        i = i + 3
    if outIdx <= 0:
        return ""
    if outIdx != maxBytes:
        return uirCoreTakeBeforeModMarker(builder_name_cache_c_new_string_copy_n(outPtr, outIdx))
    return uirCoreTakeBeforeModMarker(out)

fn uirCoreRecoverSanitizedLinkPrefix(name0: str): str =
    let name0Len: int32 = strLenFast(name0)
    if name0Len <= 0:
        return ""
    uirCoreSanitizedLinkPrefixCacheEnsure()
    let ptrKey: int64 = uirCoreTypeKeyObjNamePtrKey(name0)
    if uirCore_sanitizedLinkPrefix_recent_valid:
        if ptrKey != 0 && ptrKey == uirCore_sanitizedLinkPrefix_recent_ptr:
            return uirCore_sanitizedLinkPrefix_recent_val
        if len(uirCore_sanitizedLinkPrefix_recent_raw) > 0 && uirCore_sanitizedLinkPrefix_recent_raw == name0:
            return uirCore_sanitizedLinkPrefix_recent_val
    if ptrKey != 0:
        var foundPtr: bool = false
        let rawPtr: int32 = hashmaps.hashMapPtrIntGet(uirCore_sanitizedLinkPrefix_ptr_index, ptrKey, foundPtr)
        let idxPtr: int32 = rawPtr - 1
        if foundPtr && idxPtr >= 0 && idxPtr < uirCore_sanitizedLinkPrefix_values.len:
            let cachedPtr: str = uirCore_sanitizedLinkPrefix_values[idxPtr]
            uirCoreSanitizedLinkPrefixRemember(name0, cachedPtr, ptrKey)
            return cachedPtr
    var foundText: bool = false
    let rawText: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_sanitizedLinkPrefix_text_index, name0, foundText)
    let idxText: int32 = rawText - 1
    if foundText && idxText >= 0 && idxText < uirCore_sanitizedLinkPrefix_values.len:
        let cachedText: str = uirCore_sanitizedLinkPrefix_values[idxText]
        if ptrKey != 0:
            hashmaps.hashMapPtrIntPut(uirCore_sanitizedLinkPrefix_ptr_index, ptrKey, idxText + 1)
        uirCoreSanitizedLinkPrefixRemember(name0, cachedText, ptrKey)
        return cachedText
    let decoded0: str = uirCoreRecoverSanitizedLinkPrefixImpl(name0, name0Len)
    let cachedValue: str = uirCoreBaseUniqueStableText(decoded0)
    let cachedRaw0: str = uirCoreBaseUniqueStableText(name0)
    let cachedRaw: str = len(cachedRaw0) > 0 ? cachedRaw0 : name0
    let nextIdx: int32 = uirCore_sanitizedLinkPrefix_values.len + 1
    seqs.add(uirCore_sanitizedLinkPrefix_values, cachedValue)
    hashmaps.hashMapStrIntPut(uirCore_sanitizedLinkPrefix_text_index, cachedRaw, nextIdx)
    if ptrKey != 0:
        hashmaps.hashMapPtrIntPut(uirCore_sanitizedLinkPrefix_ptr_index, ptrKey, nextIdx)
    uirCoreSanitizedLinkPrefixRemember(cachedRaw, cachedValue, ptrKey)
    return cachedValue

fn uirCoreFuncNameForCacheLocal(f: UirCoreFunc): str =
    if f == nil:
        return ""
    let objName: str = uirCoreFuncNameObjFirst(f)
    if uirCoreStrPtrSane(objName):
        return objName
    let dyn: UirCoreFuncDynState = uirCoreFuncDynStatePtr(f)
    if dyn != nil && uirCoreStrPtrSane(dyn.name):
        return dyn.name
    return uirCoreFuncNameOf(f)

fn uirCoreFuncNameMatchesBaseAnyWithLen(fnName0: str, fnNameLen: int32,
                                        base0: str, baseLen: int32): bool =
    if fnNameLen <= 0 || baseLen <= 0:
        return false
    if uirCoreStrEqWithLen(fnName0, fnNameLen, base0, baseLen):
        return true
    let modMarker: str = uirCoreModMarker()
    let modMarkerLen: int32 = strLenFast(modMarker)
    let sigMarker: str = uirCoreFuncSigMarker()
    let sigMarkerLen: int32 = strLenFast(sigMarker)
    if fnNameLen > 11 &&
       fnName0[0] == '_' && fnName0[1] == '_' &&
       fnName0[2] == 'c' && fnName0[3] == 'h' &&
       fnName0[4] == 'e' && fnName0[5] == 'n' &&
       fnName0[6] == 'g' && fnName0[7] == '_' &&
       fnName0[8] == 's' && fnName0[9] == 'y' &&
       fnName0[10] == 'm' && fnName0[11] == '_':
        let rawAlias0: str = uirCoreRecoverSanitizedLinkPrefix(fnName0)
        let rawAliasLen: int32 = strLenFast(rawAlias0)
        if rawAliasLen == baseLen && uirCoreStrEqWithLen(rawAlias0, rawAliasLen, base0, baseLen):
            return true
    let hasBasePrefix: bool = fnNameLen >= baseLen &&
                              uirCoreStrEqAtWithLen(fnName0, fnNameLen, 0, base0, baseLen)
    if hasBasePrefix && uirCoreStrEqAtWithLen(fnName0, fnNameLen, baseLen, sigMarker, sigMarkerLen):
        return true
    if hasBasePrefix && uirCoreStrEqAtWithLen(fnName0, fnNameLen, baseLen, modMarker, modMarkerLen):
        return true
    return false

fn uirCoreFuncNameMatchesBaseAny(fnName0: str, base0: str): bool =
    return uirCoreFuncNameMatchesBaseAnyWithLen(fnName0, strLenFast(fnName0), base0, strLenFast(base0))

fn uirCoreObjTypeBaseUniqueCacheConsider(
    exactObjNames: hashmaps.HashMapStrInt,
    baseName: str,
    idx: int32,
    objName: str
) =
    if len(baseName) == 0 || idx < 0:
        return
    let stableBaseName: str = uirCoreBaseUniqueStableText(baseName)
    var foundExactName: bool = false
    let exactRaw: int32 = uirCoreHashMapStrIntGetCompatLocal(exactObjNames, stableBaseName, foundExactName)
    if foundExactName && exactRaw > 0:
        return
    var foundCur: bool = false
    let curRaw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_objTypeBaseUnique_cache, stableBaseName, foundCur)
    if !foundCur:
        hashmaps.hashMapStrIntPut(uirCore_objTypeBaseUnique_cache, stableBaseName, uirCoreBaseUniqueEncode(idx))
        return
    if curRaw <= 1:
        return
    let curIdx: int32 = curRaw - 2
    if curIdx == idx:
        return
    if curIdx >= 0 && uirCore_objTypeBaseUnique_cache_module != nil &&
       curIdx < uirCoreModuleObjTypesLen(uirCore_objTypeBaseUnique_cache_module):
        let curOt: UirCoreObjType = uirCoreModuleObjTypeAt(uirCore_objTypeBaseUnique_cache_module, curIdx)
        if curOt.name == objName:
            return
    hashmaps.hashMapStrIntPut(uirCore_objTypeBaseUnique_cache, stableBaseName, 1)

fn uirCoreBaseUniqueEncode(idx: int32): int32 =
    if idx >= 0:
        return idx + 2
    return 1

fn uirCoreFuncBaseUniqueCacheConsider(
    exactFuncNames: hashmaps.HashMapStrInt,
    baseName: str,
    idx: int32,
    fnName: str
) =
    if len(baseName) == 0 || idx < 0:
        return
    let stableBaseName: str = uirCoreBaseUniqueStableText(baseName)
    var foundExactName: bool = false
    let exactRaw: int32 = uirCoreHashMapStrIntGetCompatLocal(exactFuncNames, stableBaseName, foundExactName)
    if foundExactName && exactRaw > 0:
        return
    var foundCur: bool = false
    let curRaw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_funcBaseUnique_cache, stableBaseName, foundCur)
    if !foundCur:
        hashmaps.hashMapStrIntPut(uirCore_funcBaseUnique_cache, stableBaseName, uirCoreBaseUniqueEncode(idx))
        return
    if curRaw <= 1:
        return
    let curIdx: int32 = curRaw - 2
    if curIdx == idx:
        return
    if curIdx >= 0 && uirCore_funcBaseUnique_cache_module != nil &&
       curIdx < uirCoreModuleFuncsLen(uirCore_funcBaseUnique_cache_module):
        let curF: UirCoreFunc = uirCoreModuleFuncAt(uirCore_funcBaseUnique_cache_module, curIdx)
        if curF != nil && uirCoreFuncNameForCacheLocal(curF) == fnName:
            return
    hashmaps.hashMapStrIntPut(uirCore_funcBaseUnique_cache, stableBaseName, 1)

fn uirCoreGlobalBaseUniqueCacheReset(mod: UirCoreModule = nil) =
    uirCore_globalBaseUnique_cache_module = mod
    uirCore_globalBaseUnique_cache_len = (mod != nil) ? uirCoreModuleGlobalsLen(mod) : 0
    uirCore_globalBaseUnique_cache = hashmaps.hashMapStrIntInit(uirCore_globalBaseUnique_cache_len * 2 + 8)
    uirCore_globalBaseUnique_ptr_cache = hashmaps.hashMapPtrIntInit(uirCore_globalBaseUnique_cache_len * 2 + 8)
    uirCore_globalBaseUnique_exact_cache = hashmaps.hashMapStrIntInit(uirCore_globalBaseUnique_cache_len * 2 + 8)
    uirCore_globalBaseUnique_cache_ready = (mod != nil)
    uirCore_globalBaseUnique_recent_module = nil
    uirCore_globalBaseUnique_recent_base = ""
    uirCore_globalBaseUnique_recent_len = -1
    uirCore_globalBaseUnique_recent_ptr = 0
    uirCore_globalBaseUnique_recent_raw = 0
    uirCore_globalBaseUnique_recent_valid = false

fn uirCoreGlobalBaseUniqueCacheBuild(mod: UirCoreModule) =
    uirCoreGlobalBaseUniqueCacheReset(mod)
    if mod == nil:
        return
    let globalsLen: int32 = uirCoreModuleGlobalsLen(mod)
    let modMarker: str = uirCoreModMarker()
    let modMarkerLen: int32 = strLenFast(modMarker)
    for i in 0..<globalsLen:
        let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod, i)
        if len(g.name) == 0:
            continue
        hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_exact_cache, g.name, i + 1)
        hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_cache, g.name, uirCoreBaseUniqueEncode(i))
        let namePtr: int64 = uirCoreTypeKeyObjNamePtrKey(g.name)
        if namePtr != 0:
            hashmaps.hashMapPtrIntPut(uirCore_globalBaseUnique_ptr_cache, namePtr, uirCoreBaseUniqueEncode(i))
    for i in 0..<globalsLen:
        let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod, i)
        if len(g.name) == 0:
            continue
        let modOff: int32 = uirCoreStrIndexOfWithLen(g.name, strLenFast(g.name), modMarker, modMarkerLen)
        if modOff <= 0:
            continue
        let base: str = uirCoreStrTake(g.name, modOff)
        if len(base) == 0 || (base == g.name):
            continue
        var hasExact: bool = false
        let exactRaw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_globalBaseUnique_exact_cache, base, hasExact)
        if hasExact && exactRaw > 0:
            continue
        var foundCur: bool = false
        let curRaw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_globalBaseUnique_cache, base, foundCur)
        if !foundCur:
            hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_cache, base, uirCoreBaseUniqueEncode(i))
            continue
        if curRaw <= 1:
            continue
        let curIdx: int32 = curRaw - 2
        if curIdx != i:
            hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_cache, base, 1)

fn uirCoreGlobalBaseUniqueCacheAppendLast(mod: UirCoreModule) =
    if mod == nil || !uirCore_globalBaseUnique_cache_ready || uirCore_globalBaseUnique_cache_module != mod:
        return
    let globalsLen: int32 = uirCoreModuleGlobalsLen(mod)
    if globalsLen <= 0:
        uirCore_globalBaseUnique_cache_len = globalsLen
        return
    let i: int32 = globalsLen - 1
    let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod, i)
    uirCore_globalBaseUnique_cache_len = globalsLen
    if len(g.name) == 0:
        return
    hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_exact_cache, g.name, i + 1)
    hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_cache, g.name, uirCoreBaseUniqueEncode(i))
    let namePtr: int64 = uirCoreTypeKeyObjNamePtrKey(g.name)
    if namePtr != 0:
        hashmaps.hashMapPtrIntPut(uirCore_globalBaseUnique_ptr_cache, namePtr, uirCoreBaseUniqueEncode(i))
    let modMarker: str = uirCoreModMarker()
    let modOff: int32 = uirCoreStrIndexOfWithLen(g.name, strLenFast(g.name), modMarker, strLenFast(modMarker))
    if modOff <= 0:
        return
    let base: str = uirCoreStrTake(g.name, modOff)
    if len(base) == 0 || (base == g.name):
        return
    var hasExact: bool = false
    let exactRaw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_globalBaseUnique_exact_cache, base, hasExact)
    if hasExact && exactRaw > 0:
        return
    var foundCur: bool = false
    let curRaw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_globalBaseUnique_cache, base, foundCur)
    if !foundCur:
        hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_cache, base, uirCoreBaseUniqueEncode(i))
        return
    if curRaw <= 1:
        return
    let curIdx: int32 = curRaw - 2
    if curIdx != i:
        hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_cache, base, 1)

fn uirCoreGlobalBaseUniqueCacheEnsure(mod: UirCoreModule) =
    if mod == nil:
        if uirCore_globalBaseUnique_cache_ready:
            uirCoreGlobalBaseUniqueCacheReset()
        return
    let globalsLen: int32 = uirCoreModuleGlobalsLen(mod)
    if !uirCore_globalBaseUnique_cache_ready || uirCore_globalBaseUnique_cache_module != mod:
        uirCoreGlobalBaseUniqueCacheBuild(mod)
        return
    if uirCore_globalBaseUnique_cache_len == globalsLen:
        return
    if globalsLen == uirCore_globalBaseUnique_cache_len + 1:
        uirCoreGlobalBaseUniqueCacheAppendLast(mod)
        return
    if uirCore_globalBaseUnique_cache_len != globalsLen:
        uirCoreGlobalBaseUniqueCacheBuild(mod)

fn uirCoreGlobalBaseUniqueCacheTryGet(mod: UirCoreModule, base0: str, found: var bool): int32 =
    found = false
    if mod == nil || len(base0) == 0:
        return -1
    uirCoreGlobalBaseUniqueCacheEnsure(mod)
    if !uirCore_globalBaseUnique_cache_ready || uirCore_globalBaseUnique_cache_module != mod:
        return -1
    let globalsLen: int32 = uirCoreModuleGlobalsLen(mod)
    let ptrKey: int64 = uirCoreTypeKeyObjNamePtrKey(base0)
    if uirCore_globalBaseUnique_recent_valid &&
       uirCore_globalBaseUnique_recent_module == mod &&
       uirCore_globalBaseUnique_recent_len == globalsLen &&
       ((ptrKey != 0 && uirCore_globalBaseUnique_recent_ptr == ptrKey) ||
        uirCore_globalBaseUnique_recent_base == base0):
        let recentRaw: int32 = uirCore_globalBaseUnique_recent_raw
        found = recentRaw > 0
        if !found:
            return -1
        return recentRaw - 2
    if ptrKey != 0:
        var foundPtr: bool = false
        let rawPtr: int32 = hashmaps.hashMapPtrIntGet(uirCore_globalBaseUnique_ptr_cache, ptrKey, foundPtr)
        if foundPtr:
            uirCore_globalBaseUnique_recent_module = mod
            uirCore_globalBaseUnique_recent_base = base0
            uirCore_globalBaseUnique_recent_len = globalsLen
            uirCore_globalBaseUnique_recent_ptr = ptrKey
            uirCore_globalBaseUnique_recent_raw = rawPtr
            uirCore_globalBaseUnique_recent_valid = true
            found = rawPtr > 0
            if !found:
                return -1
            return rawPtr - 2
    let raw: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_globalBaseUnique_cache, base0, found)
    if ptrKey != 0:
        hashmaps.hashMapPtrIntPut(uirCore_globalBaseUnique_ptr_cache, ptrKey, found ? raw : 0)
    uirCore_globalBaseUnique_recent_module = mod
    uirCore_globalBaseUnique_recent_base = uirCoreBaseUniqueStableText(base0)
    uirCore_globalBaseUnique_recent_len = globalsLen
    uirCore_globalBaseUnique_recent_ptr = ptrKey
    uirCore_globalBaseUnique_recent_raw = found ? raw : 0
    uirCore_globalBaseUnique_recent_valid = true
    if !found || raw <= 0:
        return -1
    return raw - 2

fn uirCoreGlobalBaseUniqueCachePut(mod: UirCoreModule, base0: str, idx: int32) =
    if mod == nil || len(base0) == 0:
        return
    uirCoreGlobalBaseUniqueCacheEnsure(mod)
    if !uirCore_globalBaseUnique_cache_ready || uirCore_globalBaseUnique_cache_module != mod:
        return
    let stableBase0: str = uirCoreBaseUniqueStableText(base0)
    let raw: int32 = uirCoreBaseUniqueEncode(idx)
    hashmaps.hashMapStrIntPut(uirCore_globalBaseUnique_cache, stableBase0, raw)
    let ptrKey: int64 = uirCoreTypeKeyObjNamePtrKey(base0)
    if ptrKey != 0:
        hashmaps.hashMapPtrIntPut(uirCore_globalBaseUnique_ptr_cache, ptrKey, raw)
        uirCore_globalBaseUnique_recent_module = mod
        uirCore_globalBaseUnique_recent_base = stableBase0
        uirCore_globalBaseUnique_recent_len = uirCoreModuleGlobalsLen(mod)
        uirCore_globalBaseUnique_recent_ptr = ptrKey
        uirCore_globalBaseUnique_recent_raw = raw
        uirCore_globalBaseUnique_recent_valid = true

fn uirCoreObjTypeBaseUniqueCacheReset(mod: UirCoreModule = nil) =
    uirCore_objTypeBaseUnique_cache_module = mod
    uirCore_objTypeBaseUnique_cache_len = (mod != nil) ? uirCoreModuleObjTypesLen(mod) : 0
    uirCore_objTypeBaseUnique_cache = hashmaps.hashMapStrIntInit(uirCore_objTypeBaseUnique_cache_len * 2 + 8)
    uirCore_objTypeBaseUnique_exact_cache = hashmaps.hashMapStrIntInit(uirCore_objTypeBaseUnique_cache_len * 2 + 8)
    uirCore_objTypeBaseUnique_cache_ready = (mod != nil)

fn uirCoreObjTypeBaseUniqueCacheBuild(mod: UirCoreModule) =
    uirCoreObjTypeBaseUniqueCacheReset(mod)
    if mod == nil:
        return
    let objTypesLen: int32 = uirCoreModuleObjTypesLen(mod)
    let modMarker: str = uirCoreModMarker()
    let modMarkerLen: int32 = strLenFast(modMarker)
    for i in 0..<objTypesLen:
        let ot: UirCoreObjType = uirCoreModuleObjTypeAt(mod, i)
        if len(ot.name) == 0:
            continue
        hashmaps.hashMapStrIntPut(uirCore_objTypeBaseUnique_exact_cache, ot.name, i + 1)
        hashmaps.hashMapStrIntPut(uirCore_objTypeBaseUnique_cache, ot.name, uirCoreBaseUniqueEncode(i))
    for i in 0..<objTypesLen:
        let ot: UirCoreObjType = uirCoreModuleObjTypeAt(mod, i)
        if len(ot.name) == 0:
            continue
        let rawAlias0: str = uirCoreRecoverSanitizedLinkPrefix(ot.name)
        if len(rawAlias0) > 0 && !(rawAlias0 == ot.name):
            uirCoreObjTypeBaseUniqueCacheConsider(uirCore_objTypeBaseUnique_exact_cache, rawAlias0, i, ot.name)
        let modOff: int32 = uirCoreStrIndexOfWithLen(ot.name, strLenFast(ot.name), modMarker, modMarkerLen)
        if modOff > 0:
            let baseObj: str = uirCoreStrTake(ot.name, modOff)
            if len(baseObj) > 0 && !(baseObj == ot.name):
                uirCoreObjTypeBaseUniqueCacheConsider(uirCore_objTypeBaseUnique_exact_cache, baseObj, i, ot.name)

fn uirCoreObjTypeBaseUniqueCacheAppendLast(mod: UirCoreModule) =
