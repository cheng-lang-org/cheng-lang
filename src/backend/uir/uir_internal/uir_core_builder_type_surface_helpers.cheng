# Shared builder-local call/type-key/scalar helper aggregation split from uir_core_builder.
import std/system
import std/os
import std/rawmem_support
import std/seqs
import stage1/ast
import stage1/token
import stage1/lexer
import stage1/monomorphize
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_base_helpers
