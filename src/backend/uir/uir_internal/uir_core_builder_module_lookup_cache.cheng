# Shared builder-local module/global/object lookup cache helpers split from uir_core_builder.
import std/seqs
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_base_helpers
import backend/uir/uir_internal/uir_core_builder_type_name_cache
import backend/uir/uir_internal/uir_core_builder_name_base_unique_cache
import backend/uir/uir_internal/uir_core_builder_callee_candidate_cache

var
    uirCore_funcIndex_cache_module: UirCoreModule
    uirCore_funcIndex_cache_keys: str[]
    uirCore_funcIndex_cache_vals: int32[]
    uirCore_funcIndex_cache_len: int32
    uirCore_funcIndex_cache_ready: bool

    uirCore_funcBaseHas_cache_module: UirCoreModule
    uirCore_funcBaseHas_cache_keys: str[]
    uirCore_funcBaseHas_cache_vals: int32[]
    uirCore_funcBaseHas_checked_len_keys: str[]
    uirCore_funcBaseHas_checked_len_vals: int32[]
    uirCore_funcBaseHas_cache_len: int32
    uirCore_funcBaseHas_cache_ready: bool

    uirCore_globalIndex_cache_module: UirCoreModule
    uirCore_globalIndex_cache_keys: str[]
    uirCore_globalIndex_cache_vals: int32[]
    uirCore_globalIndex_cache_len: int32
    uirCore_globalIndex_cache_ready: bool

fn uir_core_builder_module_lookup_cache_add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn uir_core_builder_module_lookup_cache_add(dst: var int32[], val: int32) =
    seqs.Add(dst, val)

fn uirCoreModuleLookupCacheStableText(s: str): str =
    if len(s) == 0:
        return ""
    return uirCoreOwnStr(s)

fn uirCoreModuleLookupCacheFind(keys: str[], key0: str): int32 =
    if len(key0) == 0 || keys.len <= 0:
        return -1
    var i: int32 = keys.len - 1
    while i >= 0:
        if keys[i] == key0:
            return i
        i = i - 1
    return -1

fn uirCoreModuleLookupCacheSet(keys: var str[], vals: var int32[], key0: str, rawVal: int32) =
    if len(key0) == 0:
        return
    let stableKey0: str = uirCoreModuleLookupCacheStableText(key0)
    let keyText: str = len(stableKey0) > 0 ? stableKey0 : key0
    let idx: int32 = uirCoreModuleLookupCacheFind(keys, keyText)
    if idx >= 0 && idx < vals.len:
        keys[idx] = keyText
        vals[idx] = rawVal
        return
    uir_core_builder_module_lookup_cache_add(keys, keyText)
    uir_core_builder_module_lookup_cache_add(vals, rawVal)

fn uirCoreFuncBaseHasCacheReset(mod: UirCoreModule = nil) =
    uirCore_funcBaseHas_cache_module = mod
    uirCore_funcBaseHas_cache_len = (mod != nil) ? uirCoreModuleFuncsLen(mod) : 0
    let cacheCapRaw: int32 = uirCore_funcBaseHas_cache_len * 2 + 64
    var cacheCap: int32 = cacheCapRaw
    if cacheCap < 256:
        cacheCap = 256
    if cacheCap > 8192:
        cacheCap = 8192
    setLen(uirCore_funcBaseHas_cache_keys, 0)
    setLen(uirCore_funcBaseHas_cache_vals, 0)
    setLen(uirCore_funcBaseHas_checked_len_keys, 0)
    setLen(uirCore_funcBaseHas_checked_len_vals, 0)
    reserve(uirCore_funcBaseHas_cache_keys, cacheCap)
    reserve(uirCore_funcBaseHas_cache_vals, cacheCap)
    reserve(uirCore_funcBaseHas_checked_len_keys, cacheCap)
    reserve(uirCore_funcBaseHas_checked_len_vals, cacheCap)
    uirCore_funcBaseHas_cache_ready = (mod != nil)

fn uirCoreEnsureFuncBaseHasCache(mod: UirCoreModule) =
    if mod == nil:
        if uirCore_funcBaseHas_cache_module != nil || uirCore_funcBaseHas_cache_ready:
            uirCoreFuncBaseHasCacheReset(nil)
        return
    let funcsLen: int32 = uirCoreModuleFuncsLen(mod)
    if !uirCore_funcBaseHas_cache_ready ||
       uirCore_funcBaseHas_cache_module != mod ||
       funcsLen < uirCore_funcBaseHas_cache_len:
        uirCoreFuncBaseHasCacheReset(mod)
        return
    if funcsLen > uirCore_funcBaseHas_cache_len:
        uirCore_funcBaseHas_cache_len = funcsLen

fn uirCoreFuncBaseHasCacheMarkCheckedLen(base0: str, funcsLen: int32) =
    if len(base0) == 0 || funcsLen < 0:
        return
    let encodedLen: int32 = funcsLen + 1
    uirCoreModuleLookupCacheSet(uirCore_funcBaseHas_checked_len_keys,
                                uirCore_funcBaseHas_checked_len_vals,
                                base0, encodedLen)

fn uirCoreFuncBaseHasCacheCheckedAtLen(base0: str, funcsLen: int32): bool =
    if len(base0) == 0 || funcsLen < 0:
        return false
    let encodedLen: int32 = funcsLen + 1
    let idx: int32 = uirCoreModuleLookupCacheFind(uirCore_funcBaseHas_checked_len_keys, base0)
    if idx < 0 || idx >= uirCore_funcBaseHas_checked_len_vals.len:
        return false
    return uirCore_funcBaseHas_checked_len_vals[idx] == encodedLen

fn uirCoreFuncBaseHasCacheTryGet(mod: UirCoreModule, base0: str, found: var bool): bool =
    found = false
    if mod == nil || len(base0) == 0:
        return false
    uirCoreEnsureFuncBaseHasCache(mod)
    if !uirCore_funcBaseHas_cache_ready || uirCore_funcBaseHas_cache_module != mod:
        return false
    let funcsLen: int32 = uirCoreModuleFuncsLen(mod)
    let idx: int32 = uirCoreModuleLookupCacheFind(uirCore_funcBaseHas_cache_keys, base0)
    if idx < 0 || idx >= uirCore_funcBaseHas_cache_vals.len:
        return false
    let raw: int32 = uirCore_funcBaseHas_cache_vals[idx]
    found = true
    if raw > 1:
        return true
    if uirCoreFuncBaseHasCacheCheckedAtLen(base0, funcsLen):
        return false
    if !uirCoreCalleeCandidateAppendedFuncsAffectBase(mod, base0):
        uirCoreFuncBaseHasCacheMarkCheckedLen(base0, funcsLen)
        return false
    found = false
    return false

fn uirCoreFuncBaseHasCachePut(mod: UirCoreModule, base0: str, hasBase: bool) =
    if mod == nil || len(base0) == 0:
        return
    uirCoreEnsureFuncBaseHasCache(mod)
    if !uirCore_funcBaseHas_cache_ready || uirCore_funcBaseHas_cache_module != mod:
        return
    let encoded: int32 = hasBase ? 2 : 1
    uirCoreModuleLookupCacheSet(uirCore_funcBaseHas_cache_keys, uirCore_funcBaseHas_cache_vals,
                                base0, encoded)
    if !hasBase:
        uirCoreFuncBaseHasCacheMarkCheckedLen(base0, uirCoreModuleFuncsLen(mod))

fn uirCoreCalleeCandidateExactFuncIndexFresh(mod: UirCoreModule, name: str,
                                             foundExact: var bool): int32 =
    return uirCoreCalleeCandidateExactIndexFresh(mod, name, foundExact)

fn uirCoreGlobalIndexCacheReset(module: UirCoreModule = nil) =
    uirCore_globalIndex_cache_module = module
    setLen(uirCore_globalIndex_cache_keys, 0)
    setLen(uirCore_globalIndex_cache_vals, 0)
    reserve(uirCore_globalIndex_cache_keys, 8)
    reserve(uirCore_globalIndex_cache_vals, 8)
    uirCore_globalIndex_cache_ready = (module != nil)
    uirCore_globalIndex_cache_len = (module != nil) ? uirCoreModuleGlobalsLen(module) : 0

fn uirCoreEnsureGlobalIndexCache(module: UirCoreModule) =
    if module == nil:
        if uirCore_globalIndex_cache_module != nil || uirCore_globalIndex_cache_ready:
            uirCoreGlobalIndexCacheReset(nil)
        return
    let globalsLen: int32 = uirCoreModuleGlobalsLen(module)
    if !uirCore_globalIndex_cache_ready || uirCore_globalIndex_cache_module != module:
        uirCoreGlobalIndexCacheReset(module)
        reserve(uirCore_globalIndex_cache_keys, globalsLen * 2 + 8)
        reserve(uirCore_globalIndex_cache_vals, globalsLen * 2 + 8)
        uirCore_globalIndex_cache_ready = true
        uirCore_globalIndex_cache_len = globalsLen
        return
    if uirCore_globalIndex_cache_len != globalsLen:
        uirCoreGlobalIndexCacheReset(module)
        reserve(uirCore_globalIndex_cache_keys, globalsLen * 2 + 8)
        reserve(uirCore_globalIndex_cache_vals, globalsLen * 2 + 8)
        uirCore_globalIndex_cache_ready = true
        uirCore_globalIndex_cache_len = globalsLen

fn moduleGlobalIndex(module: UirCoreModule, name: str): int32 =
    if (module == nil) || len(name) == 0:
        return -1
    if uirCoreModuleGlobalsLen(module) > 0:
        uirCoreEnsureGlobalIndexCache(module)
        if uirCore_globalIndex_cache_ready && uirCore_globalIndex_cache_module == module:
            let cacheIdx: int32 = uirCoreModuleLookupCacheFind(uirCore_globalIndex_cache_keys, name)
            if cacheIdx >= 0 && cacheIdx < uirCore_globalIndex_cache_vals.len:
                let idx: int32 = uirCore_globalIndex_cache_vals[cacheIdx]
                if idx < 0:
                    return -1
                if idx >= 0 && idx < uirCoreModuleGlobalsLen(module):
                    let g0: UirCoreGlobal = uirCoreModuleGlobalAt(module, idx)
                    if uirCoreGlobalNameOf(g0) == name:
                        return idx
                return -1
    for i in 0..<uirCoreModuleGlobalsLen(module):
        let g: UirCoreGlobal = uirCoreModuleGlobalAt(module, i)
        let gName: str = uirCoreGlobalNameOf(g)
        if gName == name:
            if uirCore_globalIndex_cache_ready && uirCore_globalIndex_cache_module == module:
                uirCoreModuleLookupCacheSet(uirCore_globalIndex_cache_keys,
                                            uirCore_globalIndex_cache_vals,
                                            gName, i)
            return i
    if uirCore_globalIndex_cache_ready && uirCore_globalIndex_cache_module == module:
        uirCoreModuleLookupCacheSet(uirCore_globalIndex_cache_keys,
                                    uirCore_globalIndex_cache_vals,
                                    name, -1)
    return -1

fn moduleHasGlobal(mod: UirCoreModule, name: str): bool =
    return moduleGlobalIndex(mod, name) >= 0

fn moduleGlobalType(module: UirCoreModule, name: str, fallback: UirCoreType): UirCoreType =
    let idx: int32 = moduleGlobalIndex(module, name)
    if idx < 0:
        return fallback
    let g: UirCoreGlobal = uirCoreModuleGlobalAt(module, idx)
    return uirCoreGlobalTypeOf(g)

fn uirCoreFuncIndexCacheReset(mod: UirCoreModule = nil) =
    uirCore_funcIndex_cache_module = mod
    setLen(uirCore_funcIndex_cache_keys, 0)
    setLen(uirCore_funcIndex_cache_vals, 0)
    reserve(uirCore_funcIndex_cache_keys, 8)
    reserve(uirCore_funcIndex_cache_vals, 8)
    uirCore_funcIndex_cache_ready = (mod != nil)
    uirCore_funcIndex_cache_len = (mod != nil) ? uirCoreModuleFuncsLen(mod) : 0

fn uirCoreEnsureFuncIndexCache(mod: UirCoreModule) =
    if mod == nil:
        if uirCore_funcIndex_cache_module != nil || uirCore_funcIndex_cache_ready:
            uirCoreFuncIndexCacheReset(nil)
        return
    let funcsLen: int32 = uirCoreModuleFuncsLen(mod)
    if !uirCore_funcIndex_cache_ready || uirCore_funcIndex_cache_module != mod:
        uirCoreFuncIndexCacheReset(mod)
        reserve(uirCore_funcIndex_cache_keys, funcsLen * 2 + 8)
        reserve(uirCore_funcIndex_cache_vals, funcsLen * 2 + 8)
        uirCore_funcIndex_cache_ready = true
        uirCore_funcIndex_cache_len = funcsLen
        return
    if uirCore_funcIndex_cache_len != funcsLen:
        uirCoreFuncIndexCacheReset(mod)
        reserve(uirCore_funcIndex_cache_keys, funcsLen * 2 + 8)
        reserve(uirCore_funcIndex_cache_vals, funcsLen * 2 + 8)
        uirCore_funcIndex_cache_ready = true
        uirCore_funcIndex_cache_len = funcsLen

fn moduleFuncIndex(mod: UirCoreModule, name: str): int32 =
    let nameLen: int32 = strLenFast(name)
    if (mod == nil) || nameLen == 0:
        return -1
    var foundExactCache: bool
    let exactIdx: int32 = uirCoreFuncExactCacheTryGet(mod, name, foundExactCache)
    if foundExactCache:
        if exactIdx >= 0 && exactIdx < uirCoreModuleFuncsLen(mod):
            let exactF: UirCoreFunc = uirCoreModuleFuncAt(mod, exactIdx)
            if (exactF != nil) && uirCoreStrEqWithLen(uirCoreFuncNameForCacheLocal(exactF),
                                                      strLenFast(uirCoreFuncNameForCacheLocal(exactF)),
                                                      name, nameLen):
                return exactIdx
        return -1
    if uirCoreModuleFuncsLen(mod) > 0:
        uirCoreEnsureFuncIndexCache(mod)
        if uirCore_funcIndex_cache_ready && uirCore_funcIndex_cache_module == mod:
            let cacheIdx: int32 = uirCoreModuleLookupCacheFind(uirCore_funcIndex_cache_keys, name)
            if cacheIdx >= 0 && cacheIdx < uirCore_funcIndex_cache_vals.len:
                let idx: int32 = uirCore_funcIndex_cache_vals[cacheIdx]
                if idx < 0:
                    return -1
                if idx >= 0 && idx < uirCoreModuleFuncsLen(mod):
                    let f0: UirCoreFunc = uirCoreModuleFuncAt(mod, idx)
                    if (f0 != nil) && uirCoreStrEqWithLen(uirCoreFuncNameForCacheLocal(f0),
                                                          strLenFast(uirCoreFuncNameForCacheLocal(f0)),
                                                          name, nameLen):
                        return idx
                return -1
    for i in 0..<uirCoreModuleFuncsLen(mod):
        let f: UirCoreFunc = uirCoreModuleFuncAt(mod, i)
        if (f != nil) && uirCoreStrEqWithLen(uirCoreFuncNameForCacheLocal(f),
                                             strLenFast(uirCoreFuncNameForCacheLocal(f)),
                                             name, nameLen):
            if uirCore_funcIndex_cache_ready && uirCore_funcIndex_cache_module == mod:
                let cachedName: str = uirCoreFuncNameForCacheLocal(f)
                uirCoreModuleLookupCacheSet(uirCore_funcIndex_cache_keys, uirCore_funcIndex_cache_vals,
                                            cachedName, i)
            return i
    if uirCore_funcIndex_cache_ready && uirCore_funcIndex_cache_module == mod:
        uirCoreModuleLookupCacheSet(uirCore_funcIndex_cache_keys, uirCore_funcIndex_cache_vals,
                                    name, -1)
    return -1

fn moduleHasFunc(mod: UirCoreModule, name: str): bool =
    return moduleFuncIndex(mod, name) >= 0

fn moduleFindFunc(mod: UirCoreModule, name: str): UirCoreFunc =
    var foundExact: bool
    let exactIdx: int32 = uirCoreCalleeCandidateExactFuncIndexFresh(mod, name, foundExact)
    if exactIdx >= 0 && exactIdx < uirCoreModuleFuncsLen(mod):
        return uirCoreModuleFuncAt(mod, exactIdx)
    if foundExact:
        return nil
    let idx: int32 = moduleFuncIndex(mod, name)
    if idx >= 0 && (mod != nil) && idx < uirCoreModuleFuncsLen(mod):
        return uirCoreModuleFuncAt(mod, idx)
    return nil

fn uirCoreObjTypeNameMatchesBaseAny(typeName0: str, base0: str): bool =
    if len(typeName0) == 0 || len(base0) == 0:
        return false
    if typeName0 == base0:
        return true
    let baseLen: int32 = len(base0)
    let rawAlias0: str = uirCoreRecoverSanitizedLinkPrefix(typeName0)
    if len(rawAlias0) == baseLen && rawAlias0 == base0:
        return true
    if baseLen > 0 && uirCoreStrStartsWith(typeName0, base0) &&
       uirCoreStrEqAt(typeName0, baseLen, uirCoreModMarker()):
        return true
    return false

fn uirCoreFindObjTypeByBaseUnique(module: UirCoreModule, base0: str): str =
    if (module == nil) || len(base0) == 0:
        return ""
    var foundCached: bool
    let cachedIdx: int32 = uirCoreObjTypeBaseUniqueCacheTryGet(module, base0, foundCached)
    if foundCached:
        if cachedIdx >= 0 && cachedIdx < uirCoreModuleObjTypesLen(module):
            let ot0: UirCoreObjType = uirCoreModuleObjTypeAt(module, cachedIdx)
            return uirCoreObjTypeNameOf(ot0)
        return ""
    return ""

fn moduleHasFuncByBase(mod: UirCoreModule, base0: str): bool =
    let baseLen: int32 = strLenFast(base0)
    if (mod == nil) || baseLen == 0:
        return false
    var foundHasCached: bool
    let hasCached: bool = uirCoreFuncBaseHasCacheTryGet(mod, base0, foundHasCached)
    if foundHasCached:
        return hasCached
    var foundCached: bool
    let cachedIdx: int32 = uirCoreFuncBaseUniqueCacheTryGet(mod, base0, foundCached)
    if foundCached:
        if cachedIdx < 0:
            uirCoreFuncBaseHasCachePut(mod, base0, true)
            return true
        if cachedIdx < uirCoreModuleFuncsLen(mod):
            let out0: bool = uirCoreModuleFuncAt(mod, cachedIdx) != nil
            uirCoreFuncBaseHasCachePut(mod, base0, out0)
            return out0
    if uirCoreFuncBaseUniqueCacheFresh(mod):
        uirCoreFuncBaseHasCachePut(mod, base0, false)
        return false
    var candStart: int32 = -1
    var candLen: int32
    if uirCoreCalleeCandidateSpanFresh(mod, base0, candStart, candLen):
        uirCoreFuncBaseHasCachePut(mod, base0, true)
        return true
    if uirCoreCalleeCandidateCacheFresh(mod):
        uirCoreFuncBaseHasCachePut(mod, base0, false)
        return false
    if moduleHasFunc(mod, base0):
        uirCoreFuncBaseHasCachePut(mod, base0, true)
        return true
    for i in 0..<uirCoreModuleFuncsLen(mod):
        let f: UirCoreFunc = uirCoreModuleFuncAt(mod, i)
        if f == nil:
            continue
        let fnName0: str = uirCoreFuncNameForCacheLocal(f)
        if uirCoreFuncNameMatchesBaseAnyWithLen(fnName0, strLenFast(fnName0), base0, baseLen):
            uirCoreFuncBaseHasCachePut(mod, base0, true)
            return true
    uirCoreFuncBaseHasCachePut(mod, base0, false)
    return false

fn moduleFindGlobalIndexByBaseUnique(mod: UirCoreModule, base0: str): int32 =
    if (mod == nil) || len(base0) == 0:
        return -1
    var foundCached: bool
    let cachedIdx: int32 = uirCoreGlobalBaseUniqueCacheTryGet(mod, base0, foundCached)
    if foundCached:
        return cachedIdx
    return -1

fn uirCoreGlobalTypeKeyByBaseUnique(mod: UirCoreModule, base0: str): str =
    if len(base0) == 0:
        return ""
    let idx: int32 = moduleFindGlobalIndexByBaseUnique(mod, base0)
    if idx >= 0 && idx < uirCoreModuleGlobalsLen(mod):
        let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod, idx)
        let gName: str = uirCoreGlobalNameOf(g)
        if len(gName) > 0:
            let gk1: str = uirCoreGlobalTypeKeyGet(gName)
            if len(gk1) > 0:
                return gk1
    let gk0: str = uirCoreGlobalTypeKeyGet(base0)
    if len(gk0) > 0:
        return gk0
    return ""

fn moduleFindFuncByBaseUnique(mod: UirCoreModule, base0: str): UirCoreFunc =
    if (mod == nil) || len(base0) == 0:
        return nil
    var foundCached: bool
    let cachedIdx: int32 = uirCoreFuncBaseUniqueCacheTryGet(mod, base0, foundCached)
    if foundCached:
        if cachedIdx >= 0 && cachedIdx < uirCoreModuleFuncsLen(mod):
            return uirCoreModuleFuncAt(mod, cachedIdx)
        return nil
    return nil

fn moduleFindFuncByBasePreferOrigin(mod: UirCoreModule, base0: str, originFile0: str): UirCoreFunc =
    if (mod == nil) || len(base0) == 0:
        return nil
    var foundUnique: bool
    let uniqueIdx: int32 = uirCoreFuncBaseUniqueCacheTryGet(mod, base0, foundUnique)
    let uniqueFresh: bool = uirCoreFuncBaseUniqueCacheFresh(mod)
    if len(originFile0) > 0:
        let direct: UirCoreFunc = moduleFindFunc(mod, base0)
        if (direct != nil) && uirCoreFuncOriginFileOf(direct) == originFile0:
            return direct
        if foundUnique && uniqueIdx >= 0 && uniqueIdx < uirCoreModuleFuncsLen(mod):
            return uirCoreModuleFuncAt(mod, uniqueIdx)
        if !foundUnique && uniqueFresh:
            return nil
        var candStart: int32 = -1
        var candLen: int32
        if !uirCoreCalleeCandidateSpanFresh(mod, base0, candStart, candLen):
            return moduleFindFuncByBaseUnique(mod, base0)
        var found: UirCoreFunc = nil
        for ci in 0..<candLen:
            let idx: int32 = uirCoreCalleeCandidatePoolAt(candStart + ci)
            if idx < 0 || idx >= uirCoreModuleFuncsLen(mod):
                continue
            let f: UirCoreFunc = uirCoreModuleFuncAt(mod, idx)
            if (f == nil) || uirCoreFuncOriginFileOf(f) != originFile0:
                continue
            let fnName: str = uirCoreFuncNameOf(f)
            if (found != nil):
                if uirCoreFuncNameOf(found) == fnName:
                    continue
                return nil
            found = f
        if (found != nil):
            return found
    if foundUnique && uniqueIdx >= 0 && uniqueIdx < uirCoreModuleFuncsLen(mod):
        return uirCoreModuleFuncAt(mod, uniqueIdx)
    if !foundUnique && uniqueFresh:
        return nil
    return moduleFindFuncByBaseUnique(mod, base0)
