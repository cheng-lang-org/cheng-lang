# UIR core builder policy/plugin/native-contract helpers (split from uir_core_builder).
import std/os
import std/seqs
import std/strings
import std/strutils
import stage1/ast
import stage1/frontend_lib
import stage1/semantics
import stage1/diagnostics
import backend/uir/uir_types
import backend/uir/uir_internal/uir_core_types

fn uir_core_builder_policy_contract_add(dst: var str[], val: str) =
    seqs.Add(dst, val)

fn uir_core_builder_policy_contract_add(dst: var int32[], val: int32) =
    seqs.Add(dst, val)

fn uir_core_builder_policy_contract_add(dst: var UirStmtId[], val: UirStmtId) =
    seqs.Add(dst, val)

fn uir_core_builder_policy_contract_add(dst: var UirExprId[], val: UirExprId) =
    seqs.Add(dst, val)

fn uir_core_builder_policy_contract_add(dst: var Diagnostic[], val: Diagnostic) =
    seqs.Add(dst, val)

var
    uirCorePluginEnableCached: int32 = -1
    uirCorePluginPathsCached: str[]
    uirCorePluginPathsCachedReady: bool = false
    uirCorePluginMeteringCached: str = nil

fn policyStripSpaces(s: str): str =
    if len(s) == 0:
        return ""
    return strutils.Strip(s)

fn policyLowerAscii(s: str): str =
    return strutils.ToLowerAscii(s)

fn policyEqAsciiLowerKeyword(raw: str, lowerKeyword: str): bool =
    if len(raw) != len(lowerKeyword):
        return false
    for i in 0..<len(lowerKeyword):
        var ch: char = raw[i]
        if ch >= 'A' && ch <= 'Z':
            ch = chr(int32(ch) + 32)
        if ch != lowerKeyword[i]:
            return false
    return true

fn policyHasSuffix(s: str, suffix: str): bool =
    let n: int32 = len(s)
    let m: int32 = len(suffix)
    if m == 0:
        return true
    if n == 0:
        return false
    if n < m:
        return false
    for i in 0..<m:
        if s[n - m + i] != suffix[i]:
            return false
    return true

fn policyModuleHasGlobal(mod: UirCoreModule, name: str): bool =
    if mod == nil || len(name) == 0:
        return false
    let n: int32 = uirCoreModuleGlobalsLen(mod)
    for i in 0..<n:
        let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod, i)
        if uirCoreGlobalNameOf(g) == name:
            return true
    return false

fn policyModuleHasFunc(mod: UirCoreModule, name: str): bool =
    if mod == nil || len(name) == 0:
        return false
    let n: int32 = uirCoreModuleFuncsLen(mod)
    for i in 0..<n:
        let f: UirCoreFunc = uirCoreModuleFuncAt(mod, i)
        if f == nil:
            continue
        if uirCoreFuncNameOf(f) == name || uirCoreFuncLinkNameOf(f) == name:
            return true
    return false

fn backendSkipGlobalInit(): bool =
    return envIsTrue "BACKEND_SKIP_GLOBAL_INIT"

fn backendAllowNoMainByEmit(): bool =
    let emitModeRaw: str = policyStripSpaces(os.GetEnvDefault("BACKEND_EMIT", ""))
    let emitMode: str = policyLowerAscii(emitModeRaw)
    if emitMode == "obj" || emitMode == "object" || emitMode == "o":
        return true
    let outPathRaw: str = policyStripSpaces(os.GetEnvDefault("BACKEND_OUTPUT", ""))
    if len(outPathRaw) <= 0:
        return false
    let outPath: str = policyLowerAscii(outPathRaw)
    if policyHasSuffix(outPath, ".o") || policyHasSuffix(outPath, ".obj"):
        return true
    return false

fn uirCorePluginEnabled(): bool =
    if uirCorePluginEnableCached >= 0:
        return uirCorePluginEnableCached == 1
    let raw: str = policyLowerAscii(policyStripSpaces(getEnv "PLUGIN_ENABLE"))
    let enabled: bool = (raw == "1" || raw == "true" || raw == "yes" || raw == "on")
    uirCorePluginEnableCached = enabled ? 1 : 0
    return enabled

fn uirCorePluginPathsFromEnv(): str[] =
    if uirCorePluginPathsCachedReady:
        return uirCorePluginPathsCached
    var out: str[]
    let raw: str = policyStripSpaces(getEnv "PLUGIN_PATH")
    if len(raw) > 0:
        uir_core_builder_policy_contract_add(out, raw)
    let raw2: str = policyStripSpaces(getEnv "PLUGIN_PATHS")
    if len(raw2) > 0:
        if out.len == 0 || out[0] != raw2:
            uir_core_builder_policy_contract_add(out, raw2)
    uirCorePluginPathsCached = out
    uirCorePluginPathsCachedReady = true
    return out

fn uirCorePluginMeteringId(): str =
    let cached: str = uirCorePluginMeteringCached
    if len(cached) > 0:
        return cached
    let raw: str = getEnv "METERING_PLUGIN"
    if len(raw) == 0:
        return ""
    let trimmed: str = policyStripSpaces(raw)
    uirCorePluginMeteringCached = trimmed
    return trimmed

fn uirCoreResolvePluginImportCandidate(candidate: str): str =
    let _: str = candidate
    return ""

fn uirCoreResolvePluginImportPath(path: str): str =
    let _: str = path
    if !uirCorePluginEnabled():
        return ""
    let roots: str[] = uirCorePluginPathsFromEnv()
    if roots.len > 0:
        let _: str = roots[0]
    return ""

fn uirCoreApplyAstPluginHooks(filePath: str, root: Node): Node =
    let _: str = filePath
    if astRefIsNil(root):
        return root
    if !uirCorePluginEnabled():
        return root
    return root

fn uirCoreApplyAstPluginHooksId(filePath: str, rootId: AstNodeId): AstNodeId =
    return uirCoreApplyAstPluginHooks(filePath, rootId)

fn uirCoreApplyMirPluginHooks(filePath: str, root: Node): Node =
    let _: str = filePath
    if astRefIsNil(root):
        return root
    if !uirCorePluginEnabled():
        return root
    return root

fn uirCoreApplyMirPluginHooksId(filePath: str, rootId: AstNodeId): AstNodeId =
    return uirCoreApplyMirPluginHooks(filePath, rootId)
fn uirCoreNativeContractEnabled(): bool =
    let raw: str = policyLowerAscii(policyStripSpaces(getEnv "BACKEND_NATIVE_CONTRACT"))
    return raw == "1" || raw == "true" || raw == "yes" || raw == "on"

fn uirCoreNativeContractChargeSymbol(): str =
    let raw: str = policyStripSpaces(getEnv "BACKEND_NATIVE_CONTRACT_CHARGE_SYMBOL")
    if len(raw) > 0:
        return raw
    return "__cheng_contract_charge_block"

fn uirCoreNativeContractGasCounterSymbol(): str =
    let raw: str = policyStripSpaces(getEnv "BACKEND_NATIVE_CONTRACT_GAS_COUNTER")
    if len(raw) > 0:
        return raw
    return "__cheng_contract_gas_used"

fn uirCoreNativeContractStartsWith(text: str, prefix: str): bool =
    let n: int32 = len(text)
    let m: int32 = len(prefix)
    if m <= 0:
        return true
    if n <= 0:
        return false
    if m > n:
        return false
    for i in 0..<m:
        if text[i] != prefix[i]:
            return false
    return true

fn uirCoreNativeContractStripLeadingUnderscores(raw: str): str =
    if len(raw) == 0:
        return ""
    let n: int32 = len(raw)
    var i: int32 = 0
    for __for_guard_i in 0..<n:
        if !(i < n && raw[i] == '_'):
            break
        i = i + 1
    if i <= 0:
        return raw
    if i >= n:
        return ""
    return strings.SliceBytes(raw, i, n - i)

fn uirCoreNativeContractNormalizeSymbol(raw: str): str =
    let s0: str = policyLowerAscii(policyStripSpaces(raw))
    if len(s0) == 0:
        return ""
    return uirCoreNativeContractStripLeadingUnderscores(s0)

fn uirCoreNativeContractTypeIsFloat(ty: UirCoreType): bool =
    return ty.kind == mtF32 || ty.kind == mtF64

fn uirCoreNativeContractIsSyscallSymbol(raw: str): bool =
    let sym: str = uirCoreNativeContractNormalizeSymbol(raw)
    if len(sym) == 0:
        return false
    return uirCoreNativeContractStartsWith(sym, "cheng_linux_syscall")

fn uirCoreNativeContractIsFloatIntrinsicSymbol(raw: str): bool =
    let sym: str = uirCoreNativeContractNormalizeSymbol(raw)
    if len(sym) == 0:
        return false
    if uirCoreNativeContractStartsWith(sym, "cheng_f64_"):
        return true
    if uirCoreNativeContractStartsWith(sym, "cheng_f32_"):
        return true
    if sym == "cheng_parse_f64_bits" ||
       sym == "cheng_i64_to_f64_bits" ||
       sym == "cheng_u64_to_f64_bits" ||
       sym == "cheng_f64_bits_to_i64" ||
       sym == "cheng_f64_bits_to_u64":
        return true
    return false

fn uirCoreNativeContractExprViolation(expr: UirExprId, where: str): str =
    if !uirCoreExprIdValid(expr):
        return ""
    let exprKind: UirCoreExprKind = uirCoreExprKindOf(expr)
    if exprKind == meCall:
        let callee: str = uirCoreExprCalleeOf(expr)
        if uirCoreNativeContractIsSyscallSymbol(callee):
            return "forbid syscall symbol=" + callee + " @" + where
        if uirCoreNativeContractIsFloatIntrinsicSymbol(callee):
            return "forbid float intrinsic symbol=" + callee + " @" + where
        for ai in 0..<uirCoreExprArgsLen(expr):
            let v: str = uirCoreNativeContractExprViolation(uirCoreExprArgAt(expr, ai), where + "/arg" + intToStr(ai))
            if len(v) > 0:
                return v
        return ""
    if exprKind == meBin || exprKind == meCmp:
        let lhsV: str = uirCoreNativeContractExprViolation(uirCoreExprLhsOf(expr), where + "/lhs")
        if len(lhsV) > 0:
            return lhsV
        let rhsV: str = uirCoreNativeContractExprViolation(uirCoreExprRhsOf(expr), where + "/rhs")
        if len(rhsV) > 0:
            return rhsV
        return ""
    if exprKind == meCast:
        if uirCoreNativeContractTypeIsFloat(uirCoreExprCastTypeOf(expr)):
            return "forbid float cast @" + where
        return uirCoreNativeContractExprViolation(uirCoreExprCastExprOf(expr), where + "/cast")
    if exprKind == meLoad:
        if uirCoreNativeContractTypeIsFloat(uirCoreExprLoadTypeOf(expr)):
            return "forbid float load @" + where
        return uirCoreNativeContractExprViolation(uirCoreExprAddrExprOf(expr), where + "/addr")
    return ""

fn uirCoreNativeContractStmtViolation(stmt: UirStmtId, where: str): str =
    if uirCoreStmtKindOf(stmt) == msStore && uirCoreNativeContractTypeIsFloat(uirCoreStmtStoreTypeOf(stmt)):
        return "forbid float store @" + where
    let exprV: str = uirCoreNativeContractExprViolation(uirCoreStmtExprOf(stmt), where + "/expr")
    if len(exprV) > 0:
        return exprV
    let addrV: str = uirCoreNativeContractExprViolation(uirCoreStmtAddrExprOf(stmt), where + "/addr")
    if len(addrV) > 0:
        return addrV
    return ""

fn uirCoreNativeContractTermViolation(term: UirCoreTerm, where: str): str =
    if uirCoreTermKindOf(term) == mtRet:
        return uirCoreNativeContractExprViolation(uirCoreTermRetExprOf(term), where + "/ret")
    if uirCoreTermKindOf(term) == mtCbr:
        return uirCoreNativeContractExprViolation(uirCoreTermCondExprOf(term), where + "/cond")
    return ""

fn uirCoreNativeContractFuncViolation(f: UirCoreFunc): str =
    if f == nil:
        return ""
    let fnName: str = uirCoreFuncNameOf(f)
    if uirCoreNativeContractTypeIsFloat(uirCoreFuncRetTypeOf(f)):
        return "forbid float return type fn=" + fnName
    for pi in 0..<uirCoreFuncParamsLen(f):
        let p: UirCoreParam = uirCoreFuncParamAt(f, pi)
        if uirCoreNativeContractTypeIsFloat(p.ty):
            return "forbid float param fn=" + fnName + " param=" + p.name
    for li in 0..<uirCoreFuncLocalTypesLen(f):
        if uirCoreNativeContractTypeIsFloat(uirCoreFuncLocalTypeAt(f, li)):
            return "forbid float local fn=" + fnName + " slot=" + intToStr(li)
    for bi in 0..<uirCoreFuncBlocksLen(f):
        let blk: UirBlockId = uirCoreFuncBlockAt(f, bi)
        if !uirCoreBlockIdValid(blk):
            continue
        let blkLabel: str = uirCoreBlockLabelOf(blk)
        let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
        for si in 0..<stmtCount:
            let stmt0: UirStmtId = uirCoreBlockStmtAt(blk, si)
            let sv: str = uirCoreNativeContractStmtViolation(stmt0,
                                                             "fn=" + fnName + " block=" + blkLabel + " stmt=" + intToStr(si))
            if len(sv) > 0:
                return sv
        let tv: str = uirCoreNativeContractTermViolation(uirCoreBlockTermOf(blk),
                                                         "fn=" + fnName + " block=" + blkLabel + " term")
        if len(tv) > 0:
            return tv
    return ""

fn uirCoreNativeContractFindFuncIndex(mod: UirCoreModule, rawName: str): int32 =
    if mod == nil:
        return -1
    let name: str = policyStripSpaces(rawName)
    if len(name) == 0:
        return -1
    for i in 0..<uirCoreModuleFuncsLen(mod):
        let f: UirCoreFunc = uirCoreModuleFuncAt(mod, i)
        if f == nil:
            continue
        if uirCoreFuncNameOf(f) == name || uirCoreFuncLinkNameOf(f) == name:
            return i
    let nameNorm: str = uirCoreNativeContractNormalizeSymbol(name)
    if len(nameNorm) == 0:
        return -1
    for i2 in 0..<uirCoreModuleFuncsLen(mod):
        let f2: UirCoreFunc = uirCoreModuleFuncAt(mod, i2)
        if f2 == nil:
            continue
        let fnNorm: str = uirCoreNativeContractNormalizeSymbol(uirCoreFuncNameOf(f2))
        if fnNorm == nameNorm:
            return i2
        let lnNorm: str = uirCoreNativeContractNormalizeSymbol(uirCoreFuncLinkNameOf(f2))
        if lnNorm == nameNorm:
            return i2
    return -1

fn uirCoreNativeContractEnqueueByName(mod: UirCoreModule, queue: var int32[], reachable: var bool[], rawName: str) =
    if mod == nil:
        return
    let idx: int32 = uirCoreNativeContractFindFuncIndex(mod, rawName)
    if idx < 0 || idx >= reachable.len:
        return
    if reachable[idx]:
        return
    reachable[idx] = true
    uir_core_builder_policy_contract_add(queue, idx)

fn uirCoreNativeContractCollectCallsFromExpr(mod: UirCoreModule, expr: UirExprId,
                                             queue: var int32[], reachable: var bool[]) =
    if !uirCoreExprIdValid(expr):
        return
    let exprKind: UirCoreExprKind = uirCoreExprKindOf(expr)
    if exprKind == meCall:
        uirCoreNativeContractEnqueueByName(mod, queue, reachable, uirCoreExprCalleeOf(expr))
        for ai in 0..<uirCoreExprArgsLen(expr):
            uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreExprArgAt(expr, ai), queue, reachable)
        return
    if exprKind == meBin || exprKind == meCmp:
        uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreExprLhsOf(expr), queue, reachable)
        uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreExprRhsOf(expr), queue, reachable)
        return
    if exprKind == meCast:
        uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreExprCastExprOf(expr), queue, reachable)
        return
    if exprKind == meLoad:
        uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreExprAddrExprOf(expr), queue, reachable)
        return

fn uirCoreNativeContractCollectCallsFromStmt(mod: UirCoreModule, stmt: UirStmtId,
                                             queue: var int32[], reachable: var bool[]) =
    uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreStmtExprOf(stmt), queue, reachable)
    uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreStmtAddrExprOf(stmt), queue, reachable)

fn uirCoreNativeContractCollectCallsFromTerm(mod: UirCoreModule, term: UirCoreTerm,
                                             queue: var int32[], reachable: var bool[]) =
    if uirCoreTermKindOf(term) == mtRet:
        uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreTermRetExprOf(term), queue, reachable)
    elif uirCoreTermKindOf(term) == mtCbr:
        uirCoreNativeContractCollectCallsFromExpr(mod, uirCoreTermCondExprOf(term), queue, reachable)

fn uirCoreNativeContractReachableMask(mod: UirCoreModule): bool[] =
    var reachable: bool[]
    if mod == nil:
        return reachable
    reachable.len = uirCoreModuleFuncsLen(mod)
    var queue: int32[]
    var entryIdx: int32 = uirCoreNativeContractFindFuncIndex(mod, "main")
    if entryIdx < 0:
        entryIdx = uirCoreNativeContractFindFuncIndex(mod, "_main")
    if entryIdx < 0:
        for i in 0..<reachable.len:
            reachable[i] = true
        return reachable
    if entryIdx >= 0 && entryIdx < reachable.len:
        reachable[entryIdx] = true
        uir_core_builder_policy_contract_add(queue, entryIdx)
    for qi in 0..<queue.len:
        let idx: int32 = queue[qi]
        if idx < 0 || idx >= uirCoreModuleFuncsLen(mod):
            continue
        let f: UirCoreFunc = uirCoreModuleFuncAt(mod, idx)
        if f == nil || uirCoreFuncIsExtern(f):
            continue
        for bi in 0..<uirCoreFuncBlocksLen(f):
            let blk: UirBlockId = uirCoreFuncBlockAt(f, bi)
            if !uirCoreBlockIdValid(blk):
                continue
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            for si in 0..<stmtCount:
                uirCoreNativeContractCollectCallsFromStmt(mod, uirCoreBlockStmtAt(blk, si), queue, reachable)
            uirCoreNativeContractCollectCallsFromTerm(mod, uirCoreBlockTermOf(blk), queue, reachable)
    return reachable

fn uirCoreNativeContractEnsureGasHelper(mod: UirCoreModule, chargeName: str, counterName: str) =
    if mod == nil:
        return
    if !policyModuleHasGlobal(mod, counterName):
        uirCoreAddGlobal(mod, counterName, uirCoreTypeI64(), 0, true, "<native_contract>")
    if policyModuleHasFunc(mod, chargeName):
        return
    let helper: UirCoreFunc = uirCoreNewFunc(chargeName, uirCoreTypeI64())
    uirCoreFuncSetOriginFile(helper, "<native_contract>")
    uirCoreAddParamNoTypeKey(helper, "cost", 0, uirCoreTypeI64())
    uirCoreSetLocalType(helper, 1, uirCoreTypeI64())
    uirCoreSetLocalType(helper, 2, uirCoreTypeI64())
    var stmts: UirStmtId[]
    uir_core_builder_policy_contract_add(stmts, uirCoreStmtParam("cost", 0, 0))
    let oldExpr: UirExprId = uirCoreLoad(uirCoreGlobalAddr(counterName), uirCoreTypeI64())
    uir_core_builder_policy_contract_add(stmts, uirCoreStmtLet("gas_old", 1, oldExpr))
    let nextExpr: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(1), uirCoreLocal(0))
    uir_core_builder_policy_contract_add(stmts, uirCoreStmtLet("gas_new", 2, nextExpr))
    uir_core_builder_policy_contract_add(stmts, uirCoreStmtStore(uirCoreGlobalAddr(counterName), uirCoreLocal(2), uirCoreTypeI64()))
    let term: UirCoreTerm = uirCoreTermRet(uirCoreLocal(2))
    let entry: UirBlockId = uirCoreBlockWithStmts("entry", stmts, term)
    uirCoreAddBlock(helper, entry)
    uirCoreAddFunc(mod, helper)

fn uirCoreNativeContractFirstNonParamStmt(blk: UirBlockId): int32 =
    if !uirCoreBlockIdValid(blk):
        return -1
    # Use for-range form; avoid fragile while+local-alias lowering.
    let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
    for idx in 0..<stmtCount:
        let stmt0: UirStmtId = uirCoreBlockStmtAt(blk, idx)
        if uirCoreStmtKindOf(stmt0) != msParam:
            return idx
    return stmtCount

fn uirCoreNativeContractStmtCallsCharge(stmt: UirStmtId, chargeNorm: str): bool =
    if uirCoreStmtKindOf(stmt) != msExpr:
        return false
    let expr0: UirExprId = uirCoreStmtExprOf(stmt)
    if !uirCoreExprIdValid(expr0):
        return false
    if uirCoreExprKindOf(expr0) != meCall:
        return false
    let calleeNorm: str = uirCoreNativeContractNormalizeSymbol(uirCoreExprCalleeOf(expr0))
    return calleeNorm == chargeNorm

fn uirCoreNativeContractInjectGas(mod: UirCoreModule) =
    if mod == nil:
        return
    let chargeName: str = uirCoreNativeContractChargeSymbol()
    let counterName: str = uirCoreNativeContractGasCounterSymbol()
    uirCoreNativeContractEnsureGasHelper(mod, chargeName, counterName)
    let chargeNorm: str = uirCoreNativeContractNormalizeSymbol(chargeName)
    var fi: int32 = 0
    while fi < uirCoreModuleFuncsLen(mod):
        let f: UirCoreFunc = uirCoreModuleFuncAt(mod, fi)
        fi = fi + 1
        if f == nil || uirCoreFuncIsExtern(f):
            continue
        let fnNorm: str = uirCoreNativeContractNormalizeSymbol(uirCoreFuncNameOf(f))
        if fnNorm == chargeNorm:
            continue
        var bi: int32 = 0
        while bi < uirCoreFuncBlocksLen(f):
            let blk: UirBlockId = uirCoreFuncBlockAt(f, bi)
            bi = bi + 1
            if !uirCoreBlockIdValid(blk):
                continue
            let insertAt: int32 = uirCoreNativeContractFirstNonParamStmt(blk)
            if insertAt < 0:
                continue
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            if insertAt < stmtCount:
                let firstStmt: UirStmtId = uirCoreBlockStmtAt(blk, insertAt)
                if uirCoreNativeContractStmtCallsCharge(firstStmt, chargeNorm):
                    continue
            var args: UirExprId[]
            let blockCost: int64 = int64(1 + stmtCount)
            uir_core_builder_policy_contract_add(args, uirCoreConstI64(blockCost))
            let chargeExpr: UirExprId = uirCoreCall(chargeName, args)
            let chargeStmt: UirStmtId = uirCoreStmtExpr(chargeExpr)
            var out: UirStmtId[]
            var si: int32 = 0
            while si < stmtCount:
                if si == insertAt:
                    uir_core_builder_policy_contract_add(out, chargeStmt)
                uir_core_builder_policy_contract_add(out, uirCoreBlockStmtAt(blk, si))
                si = si + 1
            if insertAt >= stmtCount:
                uir_core_builder_policy_contract_add(out, chargeStmt)
            uirCoreBlockSetStmts(blk, out)

fn uirCoreNativeContractEnforce(filePath: str, mod: UirCoreModule) =
    if mod == nil:
        return
    let reachable: bool[] = uirCoreNativeContractReachableMask(mod)
    for fi in 0..<uirCoreModuleFuncsLen(mod):
        if fi < reachable.len && !reachable[fi]:
            continue
        let f: UirCoreFunc = uirCoreModuleFuncAt(mod, fi)
        let v: str = uirCoreNativeContractFuncViolation(f)
        if len(v) > 0:
            panic("uirCore_builder: native_contract hard-fail @" + filePath + ": " + v)
    uirCoreNativeContractInjectGas(mod)

fn uirCoreApplyUirPluginHooks(filePath: str, mod: UirCoreModule) =
    let pluginEnabled: bool = uirCorePluginEnabled()
    let nativeContractEnabled: bool = uirCoreNativeContractEnabled()
    if !pluginEnabled && !nativeContractEnabled:
        return
    if mod == nil:
        return
    if nativeContractEnabled:
        uirCoreNativeContractEnforce(filePath, mod)
    return

fn uirCoreIsOne(raw: str): bool =
    return len(raw) == 1 && raw[0] == char('1')

fn uirCoreParseInt32(raw: str, defaultValue: int32): int32 =
    if len(raw) == 0:
        return defaultValue
    let n: int32 = len(raw)
    var i: int32 = 0
    var neg: bool = false
    if raw[0] == '-':
        neg = true
        i = 1
    if i >= n:
        return defaultValue
    var v: int64 = 0
    for __for_guard_i in 0..<n:
        if !(i < n):
            break
        let c: char = raw[i]
        if c < '0' || c > '9':
            return defaultValue
        v = v * 10 + int64(int32(c) - int32('0'))
        i = i + 1
    if neg:
        v = -v
    return int32(v)

fn uirCoreGenericSpecBudget(): int32 =
    return 0

fn uirCoreGenericModeNormalized(): str =
    let raw0: str = policyLowerAscii(policyStripSpaces(getEnv "GENERIC_MODE"))
    if len(raw0) == 0:
        return "dict"
    if raw0 == "dict" || raw0 == "dictionary":
        return raw0
    return "dict"

fn uirCoreBorrowIrNormalized(): str =
    let raw0: str = policyLowerAscii(policyStripSpaces(getEnv "BORROW_IR"))
    if len(raw0) == 0:
        return "mir"
    return raw0

fn uirCoreGenericLoweringNormalized(): str =
    let raw0: str = policyLowerAscii(policyStripSpaces(getEnv "GENERIC_LOWERING"))
    if len(raw0) == 0:
        return "mir_dict"
    return raw0

fn uirCoreBorrowIrSupported(mode: str): bool =
    return mode == "mir" || mode == "stage1"

fn uirCoreGenericLoweringSupported(mode: str): bool =
    return mode == "mir_dict"

fn uirCoreDictHelperClosureEnabled(): bool =
    let mode: str = uirCoreGenericModeNormalized()
    return mode == "dict" || mode == "dictionary"

fn uirCoreShouldSkipMonoPass(): bool =
    let mode: str = uirCoreGenericModeNormalized()
    if mode == "dict" || mode == "dictionary":
        # Dict mode keeps mono off by default for compile-time stability.
        # Local env can opt back into mono for debug/bring-up.
        let forceMonoDict: bool = envIsTrue "STAGE1_FORCE_MONO_DICT"
        var skipDict: bool = true
        if forceMonoDict:
            skipDict = false
        if os.GetEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1":
            let f: os.File = os.Get_stderr()
            os.Write(f, "[backend] stage1: skip_mono mode=")
            os.Write(f, mode)
            os.Write(f, " skip_dict=")
            os.Write(f, skipDict ? "1" : "0")
            os.Write(f, "\n")
            os.C_fflush f
        return skipDict
    return true

fn uirCoreIsOrcMode(mm: str): bool =
    return len(mm) == 3 &&
           mm[0] == char('o') && mm[1] == char('r') && mm[2] == char('c')

fn uirCoreEnsurePolicyDiag(diags: var Diagnostic[], filePath: str, msg: str) =
    if hasError(diags):
        return
    let needsRawPtrHint: bool = strContains(msg, "no-pointer policy:") || strContains(msg, "std policy:")
    let finalMsg: str = needsRawPtrHint ? rawPointerForbidMessage(msg) : msg
    let d: Diagnostic = diagMake(svError, filePath, 1, 1, finalMsg)
    uir_core_builder_policy_contract_add(diags, d)

fn uirCoreFileLikelyHasPointerSyntax(path: str): bool =
    if len(path) == 0:
        return false
    let content: str = frontend_lib.Stage1_readFile(path)
    if len(content) == 0:
        return false
    if strContains(content, "rawmemPtrAdd(") || strContains(content, "load_" + "ptr(") || strContains(content, "store_" + "ptr("):
        return true
    if strContains(content, "all" + "oc(") || strContains(content, "deall" + "oc("):
        return true
    if strContains(content, "ptr[") || strContains(content, "ref["):
        return true
    var colonSeen: bool = false
    var sawAssign: bool = false
    for i in 0..<len(content):
        let ch: char = content[i]
        if ch == '\n' || ch == '\r':
            colonSeen = false
            sawAssign = false
            continue
        if ch == ':':
            colonSeen = true
            sawAssign = false
            continue
        if ch == '=':
            sawAssign = true
            continue
        if ch == '*' && colonSeen && !sawAssign:
            return true
    return false

fn uirCoreRawSpawnScopePush(scopeStarts: var int32[], bindNames: var str[], bindRaws: var bool[]) =
    seqs.Add(scopeStarts, len(bindNames))

fn uirCoreRawSpawnScopePop(scopeStarts: var int32[], bindNames: var str[], bindRaws: var bool[]) =
    if scopeStarts.len <= 0:
        return
    let mark: int32 = scopeStarts[scopeStarts.len - 1]
    scopeStarts.len = scopeStarts.len - 1
    bindNames.len = mark
    bindRaws.len = mark

fn uirCoreRawSpawnScopeNode(kind: NodeKind): bool =
    return kind == nkModule || kind == nkStmtList ||
           kind == nkFnDecl || kind == nkIteratorDecl ||
           kind == nkLambda || kind == nkDo

fn uirCoreBindRawSpawnName(nameNode: Node, rawLike: bool, bindNames: var str[], bindRaws: var bool[]) =
    if stage1AstRefIsNil(nameNode):
        return
    if nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol:
        seqs.Add(bindNames, semNodeNameNormalized(nameNode))
        seqs.Add(bindRaws, rawLike)
        return
    if nodeKind(nameNode) == nkPattern && kidCount(nameNode) > 0:
        uirCoreBindRawSpawnName(kid(nameNode, 0), rawLike, bindNames, bindRaws)

fn uirCoreBindRawSpawnNameId(nameId: AstNodeId, rawLike: bool, bindNames: var str[], bindRaws: var bool[]) =
    uirCoreBindRawSpawnName(nameId, rawLike, bindNames, bindRaws)

fn uirCoreLookupRawSpawnName(name: str, bindNames: var str[], bindRaws: var bool[]): bool =
    if len(name) == 0 || bindNames.len != bindRaws.len:
        return false
    var i: int32 = bindNames.len - 1
    while i >= 0:
        if bindNames[i] == name:
            return bindRaws[i]
        i = i - 1
    return false

fn uirCoreCallArgValueId(argId0: AstNodeId): AstNodeId =
    var argId: AstNodeId = argId0
    if astNodeIdValid(argId) && astNodeKind(argId) == nkCallArg:
        if astKidCount(argId) > 1:
            argId = astKidAt(argId, 1)
        elif astKidCount(argId) > 0:
            argId = astKidAt(argId, 0)
    while astNodeIdValid(argId) && astNodeKind(argId) == nkPar && astKidCount(argId) == 1:
        argId = astKidAt(argId, 0)
    return argId

fn uirCoreIsDefaultSpawnCallId(callId: AstNodeId): bool =
    if !astNodeIdValid(callId) || astNodeKind(callId) != nkCall || astKidCount(callId) == 0:
        return false
    var headId: AstNodeId = astKidAt(callId, 0)
    if !astNodeIdValid(headId):
        return false
    if astNodeKind(headId) == nkDotExpr:
        return false
    if astNodeKind(headId) == nkBracketExpr && astKidCount(headId) > 0:
        let baseId: AstNodeId = astKidAt(headId, 0)
        if !astNodeIdValid(baseId):
            return false
        if astNodeKind(baseId) == nkDotExpr:
            return false
        headId = baseId
    if astNodeKind(headId) != nkIdent && astNodeKind(headId) != nkSymbol:
        return false
    return semNodeNameNormalizedId(headId) == "spawn"

fn uirCoreExprLooksRawSpawnFnPtrId(exprId0: AstNodeId, bindNames: var str[], bindRaws: var bool[]): bool =
    var exprId: AstNodeId = uirCoreCallArgValueId(exprId0)
    if !astNodeIdValid(exprId):
        return false
    let kind: NodeKind = astNodeKind(exprId)
    if kind == nkIdent || kind == nkSymbol:
        return uirCoreLookupRawSpawnName(semNodeNameNormalizedId(exprId), bindNames, bindRaws)
    if kind == nkCall && astKidCount(exprId) > 0:
        let headId: AstNodeId = astKidAt(exprId, 0)
        if semIsPtrLikeTypeNodeId(headId) || semIsVoidPtrTypeNodeId(headId):
            return true
    return false

fn uirCoreBindRawSpawnFormalParamsId(paramsId: AstNodeId, bindNames: var str[], bindRaws: var bool[]) =
    if !astNodeIdValid(paramsId) || astNodeKind(paramsId) != nkFormalParams:
        return
    for i in 0..<astKidCount(paramsId):
        let defsId: AstNodeId = astKidAt(paramsId, i)
        if !astNodeIdValid(defsId) || astNodeKind(defsId) != nkIdentDefs || astKidCount(defsId) < 2:
            continue
        let typeId: AstNodeId = identDefsTypeId(defsId)
        let rawLike: bool = semIsPtrLikeTypeNodeId(typeId) || semIsVoidPtrTypeNodeId(typeId)
        for j in 0..<identDefsNameCountId(defsId):
            uirCoreBindRawSpawnNameId(astKidAt(defsId, j), rawLike, bindNames, bindRaws)

fn uirCoreAstUsesRawSpawnId(nId: AstNodeId, bindNames: var str[], bindRaws: var bool[], scopeStarts: var int32[]): bool =
    if !astNodeIdValid(nId):
        return false
    let kind: NodeKind = astNodeKind(nId)
    let ownsScope: bool = uirCoreRawSpawnScopeNode(kind)
    if ownsScope:
        uirCoreRawSpawnScopePush(scopeStarts, bindNames, bindRaws)
    defer:
        if ownsScope:
            uirCoreRawSpawnScopePop(scopeStarts, bindNames, bindRaws)
    if kind == nkFnDecl || kind == nkIteratorDecl || kind == nkLambda:
        if astKidCount(nId) > 1:
            uirCoreBindRawSpawnFormalParamsId(astKidAt(nId, 1), bindNames, bindRaws)
    if kind == nkCall && uirCoreIsDefaultSpawnCallId(nId):
        if astKidCount(nId) > 1 && uirCoreExprLooksRawSpawnFnPtrId(astKidAt(nId, 1), bindNames, bindRaws):
            return true
    for i in 0..<astKidCount(nId):
        if uirCoreAstUsesRawSpawnId(astKidAt(nId, i), bindNames, bindRaws, scopeStarts):
            return true
    if kind == nkLet || kind == nkVar || kind == nkConst:
        var nameId: AstNodeId = astInvalidNodeId()
        var typeId: AstNodeId = astInvalidNodeId()
        var valueId: AstNodeId = astInvalidNodeId()
        if astKidCount(nId) > 0:
            nameId = astKidAt(nId, 0)
        if astKidCount(nId) > 1:
            typeId = astKidAt(nId, 1)
        if astKidCount(nId) > 2:
            valueId = astKidAt(nId, 2)
        var rawLike: bool = false
        if astNodeIdValid(typeId) && astNodeKind(typeId) != nkEmpty:
            rawLike = semIsPtrLikeTypeNodeId(typeId) || semIsVoidPtrTypeNodeId(typeId)
        elif astNodeIdValid(valueId):
            rawLike = uirCoreExprLooksRawSpawnFnPtrId(valueId, bindNames, bindRaws)
        uirCoreBindRawSpawnNameId(nameId, rawLike, bindNames, bindRaws)
    return false

fn uirCoreFileLikelyUsesRawSpawn(rootId: AstNodeId): bool =
    if !astNodeIdValid(rootId):
        return false
    let rootKind: NodeKind = astNodeKind(rootId)
    var bindNames: str[]
    var bindRaws: bool[]
    var scopeStarts: int32[]
    if rootKind == nkModule || rootKind == nkStmtList:
        for i in 0..<astKidCount(rootId):
            let kidId: AstNodeId = astKidAt(rootId, i)
            if astNodeIdValid(kidId) && astNodeKind(kidId) == nkModule:
                continue
            if uirCoreAstUsesRawSpawnId(kidId, bindNames, bindRaws, scopeStarts):
                return true
        return false
    return uirCoreAstUsesRawSpawnId(rootId, bindNames, bindRaws, scopeStarts)

fn uirCorePathLooksStdModule(path: str): bool =
    if len(path) == 0:
        return false
    if strContains(path, "src/std/") || strContains(path, "src\\std\\"):
        return true
    return false

fn uirCorePathSyntheticOrStd(path: str): bool =
    if len(path) == 0:
        return false
    if path[0] == '<':
        return true
    if strContains(path, "/src/std/") || strContains(path, "\\src\\std\\"):
        return true
    if strContains(path, "/src/core/") || strContains(path, "\\src\\core\\"):
        return true
    if strContains(path, "/src/system/") || strContains(path, "\\src\\system\\"):
        return true
    # bootstrap-relaxed duplicate scope:
    # compiler-internal helper modules can carry same local helper names.
    if strContains(path, "src/stage1/") || strContains(path, "src\\stage1\\"):
        return true
    if strContains(path, "src/backend/") || strContains(path, "src\\backend\\"):
        return true
    if strContains(path, "src/tooling/") || strContains(path, "src\\tooling\\"):
        return true
    return false

fn uirCoreSkipSemStdDuplicateRelaxEnabled(): bool =
    if uirCoreIsOne(os.GetEnvDefault("BACKEND_STAGE1_DISABLE_DUP_SCAN", "0")):
        return true
    return false

fn uirCoreStage1ParseModeNormalized(): str =
    if !policyEqAsciiLowerKeyword(policyStripSpaces(os.GetEnvDefault("BACKEND_BUILD_TRACK", "dev")), "release"):
        return "outline"
    if len(policyStripSpaces(os.GetEnvDefault("BACKEND_STAGE1_PARSE_MODE", ""))) > 0:
        if policyEqAsciiLowerKeyword(policyStripSpaces(os.GetEnvDefault("BACKEND_STAGE1_PARSE_MODE", "")), "outline"):
            return "outline"
        return "full"
    if len(policyStripSpaces(os.GetEnvDefault("STAGE1_PARSE_MODE", ""))) > 0:
        if policyEqAsciiLowerKeyword(policyStripSpaces(os.GetEnvDefault("STAGE1_PARSE_MODE", "")), "outline"):
            return "outline"
        return "full"
    return "full"

fn uirCoreFnSchedNormalized(): str =
    return uirFnSchedNormalized()

fn uirCoreStdNoPointerEnabled(): bool =
    let stdNoPtrEnv: str = getEnv "STAGE1_STD_NO_POINTERS"
    if uirCoreIsOne(stdNoPtrEnv):
        return true
    if stdNoPtrEnv == "0":
        return false
    let abiEnv: str = getEnv "ABI"
    return abiEnv == "v2_noptr"

fn uirCoreStage1StdNoPointerPrecheck(root: Node, inPath: str, diags: var Diagnostic[]): bool =
    if !uirCoreStdNoPointerEnabled():
        return false
    var ctx: SemCtx
    initSemCtxInPlace(ctx)
    ctx.diags = diags
    ctx.filename = inPath
    var hits: int32 = semCheckStdNoPointerPolicy(ctx, root)
    # Heuristic fallback must honor std policy exemptions; otherwise internal
    # bridge modules (explicitly exempt) are rejected in strict bootstrap.
    if hits <= 0 &&
       uirCorePathLooksStdModule(inPath) &&
       !semIsStdPointerPolicyExempt(inPath) &&
       uirCoreFileLikelyHasPointerSyntax(inPath):
        hits = 1
    diags = ctx.diags
    if hits > 0:
        uirCoreEnsurePolicyDiag(diags, inPath, "std policy: pointer types are forbidden in standard library")
    return hits > 0

fn uirCoreStage1StdNoPointerPrecheckId(rootId: AstNodeId, inPath: str, diags: var Diagnostic[]): bool =
    return uirCoreStage1StdNoPointerPrecheck(rootId, inPath, diags)

fn uirCoreStage1NoPointerNonCAbiPrecheck(root: Node, inPath: str, diags: var Diagnostic[]): bool =
    # User-surface no-pointer policy is always on here; compiler-internal
    # modules are exempted by path instead of public env toggles.
    if !semShouldEnforceNonCAbiNoPointer():
        return false
    var ctx: SemCtx
    initSemCtxInPlace(ctx)
    ctx.diags = diags
    ctx.filename = inPath
    var hits: int32 = semCheckNoPointerNonCAbiPolicy(ctx, root)
    # Heuristic fallback must use the same scope gate as semantic checks.
    # Otherwise compiler-internal modules would be flagged even though the
    # policy is now path-scoped instead of env-scoped.
    if hits <= 0 &&
       semPointerPolicyShouldCheckNonCAbi(inPath) &&
       uirCoreFileLikelyHasPointerSyntax(inPath):
        hits = 1
    diags = ctx.diags
    if hits > 0:
        uirCoreEnsurePolicyDiag(diags, inPath, "no-pointer policy: pointer types are forbidden in user modules")
    return hits > 0

fn uirCoreStage1NoPointerNonCAbiPrecheckId(rootId: AstNodeId, inPath: str, diags: var Diagnostic[]): bool =
    return uirCoreStage1NoPointerNonCAbiPrecheck(rootId, inPath, diags)
