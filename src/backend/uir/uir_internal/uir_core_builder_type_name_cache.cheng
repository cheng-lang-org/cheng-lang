# Shared builder-local type-name cache helpers split from uir_core_builder.
import std/hashmaps
import std/seqs
import std/system
import std/rawmem_support
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_symbol_state

fn uir_core_builder_type_name_cache_add(dst: var str[], val: str) =
    seqs.add(dst, val)

var uirCore_typeKeyObjName_cache_module: UirCoreModule
var uirCore_typeKeyObjName_cache_obj_types_len: int32
var uirCore_typeKeyObjName_cache_alias_len: int32
var uirCore_typeKeyObjName_index: hashmaps.HashMapStrInt
var uirCore_typeKeyObjName_ptr_index: hashmaps.HashMapPtrInt
var uirCore_typeKeyObjName_values: str[]
var uirCore_typeTextObjName_text_index: hashmaps.HashMapPtrInt
var uirCore_typeTextObjName_values: str[]
var uirCore_typeKeyObjName_recent_module: UirCoreModule
var uirCore_typeKeyObjName_recent_obj_types_len: int32
var uirCore_typeKeyObjName_recent_alias_len: int32
var uirCore_typeKeyObjName_recent_ptr: int64
var uirCore_typeKeyObjName_recent_val: str
var uirCore_typeKeyObjName_recent_valid: bool

fn uirCoreTypeKeyObjNamePtrKey(s: str): int64 =
    if !uirCoreStrPtrSane(s):
        return 0
    return int64(strDataPtr(s))

fn uirCoreTypeKeyObjNameCacheReset(mod: UirCoreModule = nil) =
    uirCore_typeKeyObjName_cache_module = mod
    let objTypeLen: int32 = (mod != nil) ? uirCoreModuleObjTypesLen(mod) : 0
    let aliasLen: int32 = uirCoreObjAliasCount()
    let cacheCap: int32 = (objTypeLen > 0) ? (objTypeLen * 8 + 64) : 2048
    if uirCore_typeKeyObjName_index.mask == 0:
        uirCore_typeKeyObjName_index = hashmaps.hashMapStrIntInit(cacheCap)
    else:
        hashmaps.hashMapStrIntClear(uirCore_typeKeyObjName_index)
    if uirCore_typeKeyObjName_ptr_index.mask == 0:
        uirCore_typeKeyObjName_ptr_index = hashmaps.hashMapPtrIntInit(cacheCap)
    else:
        hashmaps.hashMapPtrIntClear(uirCore_typeKeyObjName_ptr_index)
    uirCore_typeKeyObjName_cache_obj_types_len = objTypeLen
    uirCore_typeKeyObjName_cache_alias_len = aliasLen
    uirCore_typeKeyObjName_values.len = 0
    if uirCore_typeKeyObjName_values.cap < cacheCap:
        uirCore_typeKeyObjName_values.cap = cacheCap
    if uirCore_typeTextObjName_text_index.mask == 0:
        uirCore_typeTextObjName_text_index = hashmaps.hashMapPtrIntInit(cacheCap)
    else:
        hashmaps.hashMapPtrIntClear(uirCore_typeTextObjName_text_index)
    uirCore_typeTextObjName_values.len = 0
    if uirCore_typeTextObjName_values.cap < cacheCap:
        uirCore_typeTextObjName_values.cap = cacheCap
    uirCore_typeKeyObjName_recent_module = nil
    uirCore_typeKeyObjName_recent_obj_types_len = -1
    uirCore_typeKeyObjName_recent_alias_len = -1
    uirCore_typeKeyObjName_recent_ptr = 0
    uirCore_typeKeyObjName_recent_val = ""
    uirCore_typeKeyObjName_recent_valid = false

fn uirCoreTypeKeyObjNameCacheNeedsReset(mod: UirCoreModule): bool =
    if mod == nil:
        return uirCore_typeKeyObjName_cache_module != nil
    if uirCore_typeKeyObjName_cache_module != mod:
        return true
    if uirCore_typeKeyObjName_cache_obj_types_len != uirCoreModuleObjTypesLen(mod):
        return true
    if uirCore_typeKeyObjName_cache_alias_len != uirCoreObjAliasCount():
        return true
    return false

fn uirCoreTypeTextObjNameCacheGet(mod: UirCoreModule, textId: int32, found: var bool): str =
    found = false
    if mod == nil || textId <= 0:
        return ""
    if uirCoreTypeKeyObjNameCacheNeedsReset(mod):
        uirCoreTypeKeyObjNameCacheReset(mod)
    var foundText: bool = false
    let raw: int32 = hashmaps.hashMapPtrIntGet(uirCore_typeTextObjName_text_index, int64(textId), foundText)
    if !foundText:
        return ""
    found = true
    if raw > 0:
        let idx: int32 = raw - 1
        if idx >= 0 && idx < uirCore_typeTextObjName_values.len:
            return get_string(uirCore_typeTextObjName_values, idx)
    return ""

fn uirCoreTypeTextObjNameCachePut(mod: UirCoreModule, textId: int32, objName: str) =
    if mod == nil || textId <= 0:
        return
    if uirCoreTypeKeyObjNameCacheNeedsReset(mod):
        uirCoreTypeKeyObjNameCacheReset(mod)
    var foundText: bool = false
    let raw: int32 = hashmaps.hashMapPtrIntGet(uirCore_typeTextObjName_text_index, int64(textId), foundText)
    if foundText:
        if raw > 0:
            let idx: int32 = raw - 1
            if idx >= 0 && idx < uirCore_typeTextObjName_values.len:
                uirCore_typeTextObjName_values[idx] = objName
                hashmaps.hashMapPtrIntPut(uirCore_typeTextObjName_text_index, int64(textId), len(objName) > 0 ? (idx + 1) : 0)
                return
        elif len(objName) == 0:
            return
    let newIdx: int32 = uirCore_typeTextObjName_values.len
    uir_core_builder_type_name_cache_add(uirCore_typeTextObjName_values, objName)
    hashmaps.hashMapPtrIntPut(uirCore_typeTextObjName_text_index, int64(textId), len(objName) > 0 ? (newIdx + 1) : 0)

fn uirCoreTypeKeyObjNameCacheGet(mod: UirCoreModule, key: str, found: var bool): str =
    found = false
    if mod == nil || len(key) == 0:
        return ""
    if uirCoreTypeKeyObjNameCacheNeedsReset(mod):
        uirCoreTypeKeyObjNameCacheReset(mod)
    let ptrKey: int64 = uirCoreTypeKeyObjNamePtrKey(key)
    if ptrKey != 0 &&
       uirCore_typeKeyObjName_recent_valid &&
       uirCore_typeKeyObjName_recent_module == mod &&
       uirCore_typeKeyObjName_recent_obj_types_len == uirCoreModuleObjTypesLen(mod) &&
       uirCore_typeKeyObjName_recent_alias_len == uirCoreObjAliasCount() &&
       uirCore_typeKeyObjName_recent_ptr == ptrKey:
        found = true
        return uirCore_typeKeyObjName_recent_val
    if ptrKey != 0:
        var foundPtr: bool = false
        let rawPtr: int32 = hashmaps.hashMapPtrIntGet(uirCore_typeKeyObjName_ptr_index, ptrKey, foundPtr)
        if foundPtr:
            found = true
            if rawPtr > 0:
                let ptrIdx: int32 = rawPtr - 1
                if ptrIdx >= 0 && ptrIdx < uirCore_typeKeyObjName_values.len:
                    let outPtr: str = get_string(uirCore_typeKeyObjName_values, ptrIdx)
                    uirCore_typeKeyObjName_recent_module = mod
                    uirCore_typeKeyObjName_recent_obj_types_len = uirCoreModuleObjTypesLen(mod)
                    uirCore_typeKeyObjName_recent_alias_len = uirCoreObjAliasCount()
                    uirCore_typeKeyObjName_recent_ptr = ptrKey
                    uirCore_typeKeyObjName_recent_val = outPtr
                    uirCore_typeKeyObjName_recent_valid = true
                    return outPtr
            uirCore_typeKeyObjName_recent_module = mod
            uirCore_typeKeyObjName_recent_obj_types_len = uirCoreModuleObjTypesLen(mod)
            uirCore_typeKeyObjName_recent_alias_len = uirCoreObjAliasCount()
            uirCore_typeKeyObjName_recent_ptr = ptrKey
            uirCore_typeKeyObjName_recent_val = ""
            uirCore_typeKeyObjName_recent_valid = true
            return ""
    let idx: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_typeKeyObjName_index, key, found)
    if !found || idx < 0 || idx >= uirCore_typeKeyObjName_values.len:
        return ""
    if ptrKey != 0:
        hashmaps.hashMapPtrIntPut(uirCore_typeKeyObjName_ptr_index, ptrKey, idx + 1)
    let out: str = get_string(uirCore_typeKeyObjName_values, idx)
    if ptrKey != 0:
        uirCore_typeKeyObjName_recent_module = mod
        uirCore_typeKeyObjName_recent_obj_types_len = uirCoreModuleObjTypesLen(mod)
        uirCore_typeKeyObjName_recent_alias_len = uirCoreObjAliasCount()
        uirCore_typeKeyObjName_recent_ptr = ptrKey
        uirCore_typeKeyObjName_recent_val = out
        uirCore_typeKeyObjName_recent_valid = true
    return out

fn uirCoreTypeKeyObjNameCachePut(mod: UirCoreModule, key: str, objName: str) =
    if mod == nil || len(key) == 0:
        return
    if uirCoreTypeKeyObjNameCacheNeedsReset(mod):
        uirCoreTypeKeyObjNameCacheReset(mod)
    let ptrKey: int64 = uirCoreTypeKeyObjNamePtrKey(key)
    if ptrKey != 0:
        var foundPtr: bool = false
        let rawPtr: int32 = hashmaps.hashMapPtrIntGet(uirCore_typeKeyObjName_ptr_index, ptrKey, foundPtr)
        if foundPtr:
            if rawPtr > 0:
                let ptrIdx: int32 = rawPtr - 1
                if ptrIdx >= 0 && ptrIdx < uirCore_typeKeyObjName_values.len:
                    uirCore_typeKeyObjName_values[ptrIdx] = objName
                    hashmaps.hashMapPtrIntPut(uirCore_typeKeyObjName_ptr_index, ptrKey, len(objName) > 0 ? (ptrIdx + 1) : 0)
                    uirCore_typeKeyObjName_recent_module = mod
                    uirCore_typeKeyObjName_recent_obj_types_len = uirCoreModuleObjTypesLen(mod)
                    uirCore_typeKeyObjName_recent_alias_len = uirCoreObjAliasCount()
                    uirCore_typeKeyObjName_recent_ptr = ptrKey
                    uirCore_typeKeyObjName_recent_val = objName
                    uirCore_typeKeyObjName_recent_valid = true
                    return
            elif len(objName) == 0:
                uirCore_typeKeyObjName_recent_module = mod
                uirCore_typeKeyObjName_recent_obj_types_len = uirCoreModuleObjTypesLen(mod)
                uirCore_typeKeyObjName_recent_alias_len = uirCoreObjAliasCount()
                uirCore_typeKeyObjName_recent_ptr = ptrKey
                uirCore_typeKeyObjName_recent_val = ""
                uirCore_typeKeyObjName_recent_valid = true
                return
    var found: bool = false
    let idx: int32 = uirCoreHashMapStrIntGetCompatLocal(uirCore_typeKeyObjName_index, key, found)
    if found && idx >= 0 && idx < uirCore_typeKeyObjName_values.len:
        uirCore_typeKeyObjName_values[idx] = objName
        if ptrKey != 0:
            hashmaps.hashMapPtrIntPut(uirCore_typeKeyObjName_ptr_index, ptrKey, len(objName) > 0 ? (idx + 1) : 0)
            uirCore_typeKeyObjName_recent_module = mod
            uirCore_typeKeyObjName_recent_obj_types_len = uirCoreModuleObjTypesLen(mod)
            uirCore_typeKeyObjName_recent_alias_len = uirCoreObjAliasCount()
            uirCore_typeKeyObjName_recent_ptr = ptrKey
            uirCore_typeKeyObjName_recent_val = objName
            uirCore_typeKeyObjName_recent_valid = true
        return
    let newIdx: int32 = uirCore_typeKeyObjName_values.len
    uir_core_builder_type_name_cache_add(uirCore_typeKeyObjName_values, objName)
    hashmaps.hashMapStrIntPut(uirCore_typeKeyObjName_index, key, newIdx)
    if ptrKey != 0:
        hashmaps.hashMapPtrIntPut(uirCore_typeKeyObjName_ptr_index, ptrKey, len(objName) > 0 ? (newIdx + 1) : 0)
        uirCore_typeKeyObjName_recent_module = mod
        uirCore_typeKeyObjName_recent_obj_types_len = uirCoreModuleObjTypesLen(mod)
        uirCore_typeKeyObjName_recent_alias_len = uirCoreObjAliasCount()
        uirCore_typeKeyObjName_recent_ptr = ptrKey
        uirCore_typeKeyObjName_recent_val = objName
        uirCore_typeKeyObjName_recent_valid = true

fn uirCoreHashMapStrIntGetCompatLocal(m: hashmaps.HashMapStrInt, key: str, found: var bool): int32 =
    if len(key) == 0 || m.mask == 0:
        found = false
        return -1
    if m.states.len <= 0 || m.keys.len <= 0 || m.vals.len <= 0:
        found = false
        return -1
    var mask: int32 = int32(m.mask)
    if mask < 0:
        found = false
        return -1
    if mask >= m.states.len || mask >= m.keys.len || mask >= m.vals.len:
        let cap0: int32 = m.states.len
        if m.keys.len < cap0 || m.vals.len < cap0:
            found = false
            return -1
        mask = cap0 - 1
    if mask < 0:
        found = false
        return -1
    var probe: int32 = int32(hashmaps.hashMapHash64StrMeta(key) & uint64(mask))
    var scanned: int32 = 0
    let __for_start_scanned_compat = scanned
    for __for_scanned_compat in __for_start_scanned_compat..mask:
        scanned = __for_scanned_compat
        let st: uint8 = m.states[probe]
        if st == uint8(0):
            found = false
            return -1
        if hashmaps.hashMapStrEq(m.keys[probe], key):
            found = true
            return m.vals[probe]
        probe = (probe + 1) & mask
        scanned = scanned + 1
    found = false
    return -1
