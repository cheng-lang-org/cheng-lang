# Shared builder-local indirect-call and type-arg helpers split from uir_core_builder.
import std/result
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_scope_helpers
import backend/uir/uir_internal/uir_core_builder_text_helpers
import backend/uir/uir_internal/uir_core_builder_string_utils
import backend/uir/uir_internal/uir_core_builder_scalar_key_helpers
import backend/uir/uir_internal/uir_core_builder_obj_local_state
import backend/uir/uir_internal/uir_core_builder_module_lookup_cache
import backend/uir/uir_internal/uir_core_builder_call_source_helpers

fn uirCoreMethodBaseObjTypeName(b: BlockBuilder, dotBase0: Node): str =
    if (b == nil) || b.module == nil || !astNodeIdValid(dotBase0):
        return ""
    var dotBase: Node = dotBase0
    while astNodeIdValid(dotBase) && nodeKind(dotBase) == nkPar && kidCount(dotBase) > 0:
        dotBase = kid(dotBase, 0)
    let baseKey0: str = uirCoreNormalizeObjLookupKey(b.module, caseInferExprTypeKey(b, dotBase))
    if len(baseKey0) > 0:
        if uirCoreHasObjType(b.module, baseKey0):
            return baseKey0
        if (uirCoreStrStartsWith(baseKey0, "seq_") || uirCoreStrStartsWith(baseKey0, "seq_fixed_")) &&
           uirCoreHasObjType(b.module, "seq"):
            return "seq"
        if uirCoreStrStartsWith(baseKey0, "Table_") && uirCoreHasObjType(b.module, "Table"):
            return "Table"
    return ""

fn uirCoreObjTypeHasNamedField(module: UirCoreModule, objTypeName: str, fieldName: str): bool =
    if (module == nil) || len(objTypeName) == 0 || len(fieldName) == 0 || !uirCoreHasObjType(module, objTypeName):
        return false
    let ot0: UirCoreObjType = uirCoreGetObjType(module, objTypeName)
    let prefix0: str = uirCoreAppendChar(fieldName, '.')
    for fi0 in 0..<ot0.fields.len:
        let f0: UirCoreObjField = ot0.fields[fi0]
        if (f0.name == fieldName) || uirCoreStrStartsWith(f0.name, prefix0):
            return true
    return false

fn uirCoreIndirectCalleeDebugName(calleeNode0: Node): str =
    var calleeNode: Node = calleeNode0
    while astNodeIdValid(calleeNode) && nodeKind(calleeNode) == nkPar && kidCount(calleeNode) > 0:
        calleeNode = kid(calleeNode, 0)
    if (calleeNode != nil) && (nodeKind(calleeNode) == nkIdent || nodeKind(calleeNode) == nkSymbol):
        return backendStripSpaces(plainName(calleeNode))
    if uirCoreNodeIsFieldDot(calleeNode):
        let mem0: Node = uirCoreDotFieldNode(calleeNode)
        if (mem0 != nil) && (nodeKind(mem0) == nkIdent || nodeKind(mem0) == nkSymbol):
            return backendStripSpaces(plainName(mem0))
    return ""

fn uirCoreCallCalleeLooksIndirect(b: BlockBuilder, calleeNode0: Node): bool =
    if b == nil:
        return false
    var calleeNode: Node = calleeNode0
    while astNodeIdValid(calleeNode) && nodeKind(calleeNode) == nkPar && kidCount(calleeNode) > 0:
        calleeNode = kid(calleeNode, 0)
    if (calleeNode != nil) && (nodeKind(calleeNode) == nkIdent || nodeKind(calleeNode) == nkSymbol):
        let nm0: str = plainName(calleeNode)
        let localIdx0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm0)
        if localIdx0 >= 0:
            let target0: str = localCallTarget(b.env, localIdx0)
            if len(target0) > 0:
                return false
            let localTy0: UirCoreType = localType(b.env, localIdx0)
            if localTy0.kind == mtI64:
                return true
    elif uirCoreNodeIsFieldDot(calleeNode) && b.module != nil:
        let base0: Node = uirCoreDotBaseNode(calleeNode)
        let baseKey0: str = uirCoreMethodBaseObjTypeName(b, base0)
        let fieldName0: str = uirCoreMemberName(uirCoreDotFieldNode(calleeNode))
        if len(baseKey0) > 0 && uirCoreObjTypeHasNamedField(b.module, baseKey0, fieldName0):
            return true
    var calleeKey0: str = uirCoreStripRefVarKeyOnce(caseInferExprTypeKey(b, calleeNode))
    calleeKey0 = uirCoreStripPtrKeyOnce(calleeKey0)
    return uirCoreStrStartsWith(calleeKey0, "fn") || uirCoreStrStartsWith(calleeKey0, "fn_")

fn uirCoreDebugIndirectCall(b: BlockBuilder, node: Node, calleeNode: Node, tag: str) =
    if getEnv "BACKEND_DEBUG_INDIRECT" != "1":
        return
    let dbgName: str = getEnv "BACKEND_DEBUG_INDIRECT_NAME"
    let calleeNm: str = uirCoreIndirectCalleeDebugName(calleeNode)
    if len(dbgName) > 0 && calleeNm != dbgName:
        return
    var fn0: str = ""
    var fp0: str = ""
    if (b != nil) && uirCoreFuncIdValid(b.func):
        let f0: UirCoreFunc = b.func
        fn0 = uirCoreFuncNameOf(f0)
        fp0 = uirCoreFuncOriginFileOf(f0)
    let line0: str = intToStr(nodePosLine(node))
    let col0: str = intToStr(nodePosCol(node))
    echo("[backend] " + tag + ": callee='" + calleeNm + "' isIndirect=1 fn=" + fn0 +
         " " + fp0 + ":" + line0 + ":" + col0)

fn uirCoreLowerIndirectCall(b: BlockBuilder, node: Node, calleeNode: Node, argNodes: Node[],
                            hasLeadArg: bool, leadArg: UirExprId, debugTag: str): Result[UirExprId] =
    uirCoreDebugIndirectCall(b, node, calleeNode, debugTag)
    let fnPtrRes: Result[UirExprId] = lowerExprValue(b, calleeNode, uirCoreTypeI64())
    if !IsOk[UirExprId](fnPtrRes):
        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](fnPtrRes))
    var indArgs: UirExprId[]
    builderExprSeqAppend(indArgs, Value[UirExprId](fnPtrRes))
    if hasLeadArg:
        builderExprSeqAppend(indArgs, leadArg)
    for xi in 0..<argNodes.len:
        let argNode0: Node = argNodes[xi]
        let argRes0: Result[UirExprId] = lowerExprValue(b, argNode0, uirCoreTypeI64())
        if !IsOk[UirExprId](argRes0):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](argRes0))
        builderExprSeqAppend(indArgs, Value[UirExprId](argRes0))
    let indName: str = "__cheng_call_indirect_" + intToStr(indArgs.len - 1)
    return Ok[UirExprId](uirCoreCall(indName, indArgs))

fn uirCoreTryLowerMethodSugarCall(b: BlockBuilder, node: Node, calleeNode: Node,
                                  wantType: UirCoreType, outExpr: var UirExprId): Result[bool] =
    if (b == nil) || b.module == nil || !uirCoreNodeIsFieldDot(calleeNode):
        return Ok[bool](false)
    let dotBase0: Node = uirCoreDotBaseNode(calleeNode)
    let dotMember0: Node = uirCoreDotFieldNode(calleeNode)
    if (dotBase0 == nil) || (dotMember0 == nil) || (nodeKind(dotMember0) != nkIdent && nodeKind(dotMember0) != nkSymbol):
        return Ok[bool](false)
    let objTypeName0: str = uirCoreMethodBaseObjTypeName(b, dotBase0)
    if len(objTypeName0) == 0:
        return Ok[bool](false)
    let fieldName0: str = uirCoreMemberName(dotMember0)
    if len(fieldName0) == 0:
        return Ok[bool](false)
    if uirCoreObjTypeHasNamedField(b.module, objTypeName0, fieldName0):
        return Ok[bool](false)
    if !moduleHasFuncByBase(b.module, fieldName0):
        return Err[bool]("uirCore_builder: unknown member call")
    let call2: Node = newNode(nkCall, nodePos(node))
    addSon(call2, newIdent(fieldName0, nodePos(node)))
    let baseArg0: Node = newNode(nkCallArg, nodePos(node))
    addSon(baseArg0, dotBase0)
    addSon(call2, baseArg0)
    for ai0 in 1..<kidCount(node):
        addSon(call2, kid(node, ai0))
    nodeSetTypeCacheValid(call2, nodeTypeCacheValid(node))
    nodeSetTypeCache(call2, nodeTypeCache(node))
    let callRes: Result[UirExprId] = lowerExprValue(b, call2, wantType)
    if !IsOk[UirExprId](callRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](callRes))
    outExpr = Value[UirExprId](callRes)
    return Ok[bool](true)

fn uirCoreNodeIsTypeArgInCallNoEnv(module: UirCoreModule, n: Node): bool =
    if (module == nil) || (n == nil):
        return false
    case nodeKind(n)
    of nkPtrTy, nkRefTy, nkVarTy, nkFnTy, nkTupleTy, nkSetTy, nkBracketExpr:
        return true
    of nkIdent, nkSymbol:
        let nm: str = backendStripSpaces(plainName(n))
        if len(nm) == 0:
            return false
        if isBuiltinTypeName(nm):
            return true
        return uirCoreFindTypeAlias(module, nm) >= 0 || uirCoreFindObjType(module, nm) >= 0
    return false

fn nodeIsTypeArgInCall(b: BlockBuilder, n: Node): bool =
    if (b == nil) || (n == nil):
        return false
    case nodeKind(n)
    of nkPtrTy, nkRefTy, nkVarTy, nkFnTy, nkTupleTy, nkSetTy, nkBracketExpr:
        return true
    of nkIdent, nkSymbol:
        let nm: str = backendStripSpaces(plainName(n))
        if uirCoreResolveLocalSlotOrImplicitResult(b.env, blockBuilderFuncRef(b), nm) >= 0:
            return false
        if moduleGlobalIndex(b.module, nm) >= 0:
            return false
        if nm == "int8" || nm == "uint8" || nm == "i8" || nm == "u8" ||
           nm == "int16" || nm == "uint16" || nm == "i16" || nm == "u16" ||
           nm == "int32" || nm == "uint32" || nm == "i32" || nm == "u32" ||
           nm == "int64" || nm == "uint64" || nm == "i64" || nm == "u64" ||
           nm == "int" || nm == "uint" ||
           nm == "float32" || nm == "float64" || nm == "float" ||
           nm == "bool" || nm == "char" || nm == "void" || isStringKey(nm):
            return true
        return uirCoreFindTypeAlias(b.module, nm) >= 0 || uirCoreFindObjType(b.module, nm) >= 0
    return false
