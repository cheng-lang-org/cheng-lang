                    for fi1 in 0..<uirCoreFieldsLen(ot1):
                        let f1: UirCoreObjField = uirCoreFieldAt(ot1, fi1)
                        if (uirCoreNameOf(f1) == "ok"):
                            hasOk1 = true
                        elif (uirCoreNameOf(f1) == "err") || uirCoreStrStartsWith(uirCoreNameOf(f1), "err."):
                            hasErr1 = true
                        elif ((uirCoreNameOf(f1) == "value") || uirCoreStrStartsWith(uirCoreNameOf(f1), "value.")) && valueOff1 < 0:
