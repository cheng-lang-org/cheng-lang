fn uirCoreDebugRootHasTypeDecl(root: Node, typeName: str): bool =
    if !astNodeIdValid(root) || len(typeName) == 0:
        return false
    for i in 0..<astKidCount(root):
        let nId: AstNodeId = astKidAt(root, i)
        if !astNodeIdValid(nId) || astNodeKind(nId) != nkTypeDecl || astKidCount(nId) <= 0:
            continue
        let nameId: AstNodeId = astKidAt(nId, 0)
        if astNodeIdValid(nameId) &&
           (astNodeKind(nameId) == nkIdent || astNodeKind(nameId) == nkSymbol) &&
           backendStripSpaces(astPlainName(nameId)) == typeName:
            return true
    return false

type
    UirCoreProfileState = ref
        enabled: bool
        startNs: int64
        lastNs: int64

fn uirCoreProfileInit(): UirCoreProfileState =
    let enabled: bool = envIsTrue "UIR_PROFILE"
    if !enabled:
        return nil
    var p: UirCoreProfileState
    new p
    p.enabled = true
    p.startNs = cheng_monotime_ns()
    p.lastNs = p.startNs
    return p

fn uirCoreProfileStep(p: UirCoreProfileState, name: str) =
    if p == nil || !p.enabled:
        return
    let now: int64 = cheng_monotime_ns()
    let stepMs: int64 = (now - p.lastNs) / 1000000
    let totalMs: int64 = (now - p.startNs) / 1000000
    p.lastNs = now
    # Write directly to stderr to avoid fork-buffer duplication.
    let f: os.File = os.get_stderr()
    os.write(f, "uir_profile\t")
    os.write(f, name)
    os.write(f, "\tstep_ms=")
    os.write(f, int64ToStr(stepMs))
    os.write(f, "\ttotal_ms=")
    os.writeLine(f, int64ToStr(totalMs))
    os.c_fflush f

fn uirCoreFuncNameStableLocal(f: UirCoreFunc): str =
    let funcObj: UirCoreFuncObjPtr = uirCoreFuncObjPtr(f)
    let funcVal: UirCoreFuncObj = uirCoreFuncObjLoadPtr(funcObj)
    if len(funcVal.name) > 0:
        return funcVal.name
    let dyn: UirCoreFuncDynState = uirCoreFuncDyn(f)
    if dyn != nil && len(dyn.name) > 0:
        return dyn.name
    return uirCoreFuncNameOf(f)

fn uirCoreOwnershipEngineNormalized(): str =
    let raw: str = backendLowerAscii(backendStripSpaces(getEnv "STAGE1_OWNERSHIP_ENGINE"))
    if len(raw) == 0:
        return "scan"
    if raw == "legacy":
        return "legacy"
    if raw == "scan":
        return "scan"
    return "scan"

fn uirCoreOwnershipProofNodeWeight(kind: NodeKind): int32 =
    if kind == nkAsgn || kind == nkFastAsgn || kind == nkCall ||
       kind == nkReturn || kind == nkYield ||
       kind == nkDerefExpr || kind == nkHiddenDeref || kind == nkDotExpr || kind == nkBracketExpr:
        return 2
    if kind == nkVar || kind == nkLet || kind == nkFor || kind == nkWhile ||
       kind == nkIf || kind == nkWhen || kind == nkCase || kind == nkStmtList || kind == nkBlock:
        return 1
    return 0

fn uirCoreOwnershipProofCount(n: Node): int32 =
    if (n == nil):
        return 0
    var total: int32 = uirCoreOwnershipProofNodeWeight(nodeKind(n))
    for i in 0..<kidCount(n):
        total = total + uirCoreOwnershipProofCount(kid(n, i))
    return total

fn uirCoreFuncSyntheticByName(funcName: str): bool =
    if len(funcName) == 0:
        return true
    if uirCoreStrStartsWith(funcName, "__cheng_"):
        return true
    if uirCoreStrIndexOf(funcName, "__cheng_mod_") >= 0:
        return true
    if uirCoreStrIndexOf(funcName, uirCoreFuncSigMarker()) >= 0:
        return true
    return false

fn uirCoreFuncOwnershipProofScore(func: UirCoreFunc): int32 =
    if !uirCoreFuncIdValid(func) || uirCoreFuncIsExtern(func):
        return 0
    if uirCoreFuncBlocksLen(func) <= 0:
        return 0
    var score: int32 = 0
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if !uirCoreBlockIdValid(blk):
            continue
        score = score + uirCoreBlockStmtsLen(blk)
        let term0: UirCoreTerm = uirCoreBlockTermOf(blk)
        if uirCoreTermKindOf(term0) == mtRet && uirCoreExprIdValid(uirCoreTermRetExprOf(term0)):
            score = score + 1
        elif uirCoreTermKindOf(term0) == mtCbr && uirCoreExprIdValid(uirCoreTermCondExprOf(term0)):
            score = score + 1
    return score

fn uirCoreApplyOwnershipPhaseContract(module: UirCoreModule, skipOwnership: bool, borrowIrMode: str): UirCorePhaseContractStats =
    var st: UirCorePhaseContractStats
    if module == nil:
        return st
    let skipReason: str = skipOwnership ? (borrowIrMode == "mir" ? "mir_borrow_skipped" : "ownership_skipped") : ""
    for i in 0..<uirCoreModuleFuncsLen(module):
        let f: UirCoreFunc = uirCoreModuleFuncAt(module, i)
        if f == nil || uirCoreFuncIsExtern(f):
            continue
        var highChecked: bool = false
        var fallbackReason: str = ""
        if skipOwnership:
            fallbackReason = skipReason
        else:
            let proofCount: int32 = uirCoreFuncOwnershipProofScore(f)
            if proofCount > 0 && !uirCoreFuncSyntheticByName(uirCoreFuncNameOf(f)):
                highChecked = true
            elif proofCount == 0:
                fallbackReason = "high_uir_ownership_no_proof"
                st.highNoProofFuncs = st.highNoProofFuncs + 1
            else:
                fallbackReason = "high_uir_ownership_synthetic"
                st.highUnmappedFuncs = st.highUnmappedFuncs + 1
        if highChecked:
            st.highCheckedFuncs = st.highCheckedFuncs + 1
        else:
            st.highFallbackFuncs = st.highFallbackFuncs + 1
        uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), highChecked, true, fallbackReason)
    return st

fn emitDeferFrames(b: BlockBuilder, frames: DeferFrame[]): Result[bool] =
    if frames.buffer == nil || frames.len == 0:
        return Ok[bool](false)
    for fi in 0..<frames.len:
        let frame: DeferFrame = frames[fi]
        if frame != nil && frame.bodies.buffer != nil:
            let __for_start_bi = frame.bodies.len - 1
            for __for_rev_bi in 0..(__for_start_bi - (0)):
                let bi = __for_start_bi - __for_rev_bi
                let body: Node = frame.bodies[bi]
                if !astNodeIdValid(body) || nodeKind(body) != nkStmtList:
                    return Err[bool]("uirCore_builder: invalid defer body")
                let bodyRes: Result[bool] = lowerStmtList(b, body)
                if !uirCoreResultBoolIsOk(bodyRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyRes))
                if uirCoreResultBoolValue(bodyRes):
                    return Err[bool]("uirCore_builder: defer body terminated")
    return Ok[bool](false)

fn blockBuilderEmitDefers(b: BlockBuilder, minDepth: int32): Result[bool] =
    if b == nil:
        return Ok[bool](false)
    var md: int32 = minDepth
    if md < 0:
        md = 0
    if md >= b.deferStack.len:
        return Ok[bool](false)
    var frames: DeferFrame[]
    let __for_start_i = b.deferStack.len - 1
    for __for_rev_i in 0..(__for_start_i - (md)):
        let i = __for_start_i - __for_rev_i
        deferFrameSeqAppend(frames, b.deferStack[i])
    return emitDeferFrames(b, frames)

fn alignUpPow2(value: int32, alignPow2: int32): int32 =
    if alignPow2 <= 0:
        return value
    let align: int32 = 1 << alignPow2
    let rem: int32 = value % align
    if rem == 0:
        return value
    return value + (align - rem)

fn uirCoreConcat2(left0: str, right0: str): str =
    let left: str = rawmemAsVoid(left0) == nil ? "" : left0
    let right: str = rawmemAsVoid(right0) == nil ? "" : right0
    let nLeft: int32 = len(left)
    let nRight: int32 = len(right)
    if nLeft <= 0:
        return right
    if nRight <= 0:
        return left
    let out: str = newStringAlloc(nLeft + nRight)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    rawmem_support.rawmemCopy(outPtr, rawmemAsVoid(left), nLeft)
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(outPtr, nLeft), rawmemAsVoid(right), nRight)
    return out

fn uirCoreAppendChar(left0: str, ch: char): str =
    let left: str = rawmemAsVoid(left0) == nil ? "" : left0
    let nLeft: int32 = len(left)
    let out: str = newStringAlloc(nLeft + 1)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    if nLeft > 0:
        rawmem_support.rawmemCopy(outPtr, rawmemAsVoid(left), nLeft)
    rawmemWriteChar(outPtr, nLeft, ch)
    return out

fn uirCoreIndexedName(prefix0: str, idx: int32): str =
    return uirCoreConcat2(prefix0, intToStr(idx))

fn uirCoreArrayObjName(capacity: int32, elemKey0: str): str =
    return uirCoreJoinWithChar(uirCoreIndexedName("array_", capacity), '_', elemKey0)

fn typeNodeObjTypeNameCore(module: UirCoreModule, typeNode: Node): str =
    if (module == nil) || (typeNode == nil):
        return ""
    if nodeKind(typeNode) == nkVarTy && kidCount(typeNode) > 0:
        return typeNodeObjTypeName(module, kid(typeNode, 0))
    if (nodeKind(typeNode) == nkRefTy || nodeKind(typeNode) == nkPtrTy) && kidCount(typeNode) > 0:
        return typeNodeObjTypeName(module, kid(typeNode, 0))
    if nodeKind(typeNode) == nkDotExpr && kidCount(typeNode) > 1:
        return typeNodeObjTypeName(module, kid(typeNode, 1))
    let kind: NodeKind = nodeKind(typeNode)
    if kind == nkIdent || kind == nkSymbol:
        let cachedTypeNode: Node = uirCoreTypeNodeCacheFallback(typeNode)
        let textId: int32 = typeNodeCanonicalIdentId(typeNode)
        if textId > 0:
            var textCached: bool = false
            let textCachedVal: str = uirCoreTypeTextObjNameCacheGet(module, textId, textCached)
            if textCached:
                if len(textCachedVal) > 0:
                    return textCachedVal
                if astNodeIdValid(cachedTypeNode):
                    let fallbackObj0: str = typeNodeObjTypeName(module, cachedTypeNode)
                    if len(fallbackObj0) > 0:
                        uirCoreTypeTextObjNameCachePut(module, textId, fallbackObj0)
                        return fallbackObj0
        let nm: str = typeNodeCanonicalName(typeNode)
        var nmCached: bool = false
        let nmCachedVal: str = uirCoreTypeKeyObjNameCacheGet(module, nm, nmCached)
        if nmCached:
            if len(nmCachedVal) > 0:
                if textId > 0:
                    uirCoreTypeTextObjNameCachePut(module, textId, nmCachedVal)
                return nmCachedVal
            if astNodeIdValid(cachedTypeNode):
                let fallbackObj1: str = typeNodeObjTypeName(module, cachedTypeNode)
                if len(fallbackObj1) > 0:
                    uirCoreTypeKeyObjNameCachePut(module, nm, fallbackObj1)
                    if textId > 0:
                        uirCoreTypeTextObjNameCachePut(module, textId, fallbackObj1)
                    return fallbackObj1
        if uirCoreStrStartsWith(nm, "seq_") && uirCoreHasObjType(module, "seq"):
            uirCoreTypeKeyObjNameCachePut(module, nm, "seq")
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, "seq")
            return "seq"
        if uirCoreStrStartsWith(nm, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
            uirCoreTypeKeyObjNameCachePut(module, nm, "seq")
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, "seq")
            return "seq"
        if uirCoreStrStartsWith(nm, "Table_") && uirCoreHasObjType(module, "Table"):
            uirCoreTypeKeyObjNameCachePut(module, nm, "Table")
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, "Table")
            return "Table"
        if uirCoreStrStartsWith(nm, "SeqUninit_") && ensureSeqUninitObjType(module, nm):
            uirCoreTypeKeyObjNameCachePut(module, nm, nm)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, nm)
            return nm
        if uirCoreStrStartsWith(nm, "Option_") && ensureOptionObjType(module, nm):
            uirCoreTypeKeyObjNameCachePut(module, nm, nm)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, nm)
            return nm
        if uirCoreStrStartsWith(nm, "Result_") && ensureResultObjType(module, nm):
            uirCoreTypeKeyObjNameCachePut(module, nm, nm)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, nm)
            return nm
        if uirCoreStrStartsWith(nm, "__cheng_tables_Entry_"):
            if ensureTablesEntryObjType(module, nm):
                uirCoreTypeKeyObjNameCachePut(module, nm, nm)
                if textId > 0:
                    uirCoreTypeTextObjNameCachePut(module, textId, nm)
                return nm
        if uirCoreHasObjType(module, nm):
            uirCoreTypeKeyObjNameCachePut(module, nm, nm)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, nm)
            return nm
        let canon: str = uirCoreObjAliasCanon(nm)
        if len(canon) > 0 && !(canon == nm) && uirCoreHasObjType(module, canon):
            uirCoreTypeKeyObjNameCachePut(module, nm, canon)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, canon)
            return canon
        let resolvedObj0: str = uirCoreObjTypeFromTypeKey(module, nm)
        if len(resolvedObj0) > 0:
            uirCoreTypeKeyObjNameCachePut(module, nm, resolvedObj0)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, resolvedObj0)
            return resolvedObj0
        if astNodeIdValid(cachedTypeNode):
            let fallbackObj2: str = typeNodeObjTypeName(module, cachedTypeNode)
            if len(fallbackObj2) > 0:
                uirCoreTypeKeyObjNameCachePut(module, nm, fallbackObj2)
                if textId > 0:
                    uirCoreTypeTextObjNameCachePut(module, textId, fallbackObj2)
                return fallbackObj2
        uirCoreTypeKeyObjNameCachePut(module, nm, "")
        if textId > 0:
            uirCoreTypeTextObjNameCachePut(module, textId, "")
        return ""
    if kind == nkBracketExpr && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if base != nil:
            let nm3: str = typeNodeCanonicalName(base)
            if (nm3 == "seq") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if (nm3 == "seq_fixed") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if (nm3 == "Table") && uirCoreHasObjType(module, "Table"):
                return "Table"
            let legacyInstName: str = uirCoreLegacyGenericBracketInstName(typeNode)
            if len(legacyInstName) > 0:
                var legacyCached: bool = false
                let legacyCachedVal: str = uirCoreTypeKeyObjNameCacheGet(module, legacyInstName, legacyCached)
                if legacyCached:
                    if len(legacyCachedVal) == 0:
                        let synthLegacy: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(module, typeNode)
                        if len(synthLegacy) > 0:
                            uirCoreTypeKeyObjNameCachePut(module, legacyInstName, synthLegacy)
                            return synthLegacy
                    return legacyCachedVal
                if uirCoreStrStartsWith(legacyInstName, "Result_") && ensureResultObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                if uirCoreStrStartsWith(legacyInstName, "Option_") && ensureOptionObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                if uirCoreStrStartsWith(legacyInstName, "SeqUninit_") && ensureSeqUninitObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                if uirCoreStrStartsWith(legacyInstName, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                if uirCoreHasObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                uirCoreTypeKeyObjNameCachePut(module, legacyInstName, "")
            var instArgs: Node[]
            instArgs.cap = 4
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if astNodeIdValid(a) && nodeKind(a) != nkEmpty:
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm3, instArgs)
                var instCached: bool = false
                let instCachedVal: str = uirCoreTypeKeyObjNameCacheGet(module, instName, instCached)
                if instCached:
                    if len(instCachedVal) == 0:
                        let synthInstCached: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(module, typeNode)
                        if len(synthInstCached) > 0:
                            uirCoreTypeKeyObjNameCachePut(module, instName, synthInstCached)
                            return synthInstCached
                    return instCachedVal
                if (nm3 == "array"):
                    if ensureArrayObjTypeFromTypeExpr(module, typeNode, instName):
                        uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                        return instName
                if (nm3 == "SeqUninit") && ensureSeqUninitObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                if (nm3 == "Option") && ensureOptionObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                if (nm3 == "Result") && ensureResultObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                if (nm3 == "seq") && uirCoreHasObjType(module, "seq"):
                    uirCoreTypeKeyObjNameCachePut(module, instName, "seq")
                    return "seq"
                if (nm3 == "seq_fixed") && uirCoreHasObjType(module, "seq"):
                    uirCoreTypeKeyObjNameCachePut(module, instName, "seq")
                    return "seq"
                if (nm3 == "Table") && uirCoreHasObjType(module, "Table"):
                    uirCoreTypeKeyObjNameCachePut(module, instName, "Table")
                    return "Table"
                if uirCoreHasObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                let synthInstName: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(module, typeNode)
                if len(synthInstName) > 0:
                    uirCoreTypeKeyObjNameCachePut(module, instName, synthInstName)
                    return synthInstName
                if (nm3 == "__cheng_tables_Entry") && ensureTablesEntryObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                let prefix: str = uirCoreAppendChar(instName, '_')
                var foundName: str = ""
                var foundCount: int32 = 0
                for oi in 0..<uirCoreModuleObjTypesLen(module):
                    let ot: UirCoreObjType = uirCoreModuleObjTypeAt(module, oi)
                    if len(ot.name) > 0 && uirCoreStrStartsWith(ot.name, prefix):
                        foundName = ot.name
                        foundCount = foundCount + 1
                        if foundCount > 1:
                            break
                if foundCount == 1 && len(foundName) > 0 && uirCoreHasObjType(module, foundName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, foundName)
                    return foundName
                uirCoreTypeKeyObjNameCachePut(module, instName, "")
        let looseKey0: str = uirCoreTypeKeyFromNodeLoose(typeNode)
        if len(looseKey0) > 0:
            if uirCoreHasObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
            let canonLoose0: str = uirCoreObjAliasCanon(looseKey0)
            if len(canonLoose0) > 0 && !(canonLoose0 == looseKey0) && uirCoreHasObjType(module, canonLoose0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, canonLoose0)
                return canonLoose0
            if uirCoreStrStartsWith(looseKey0, "seq_") && uirCoreHasObjType(module, "seq"):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, "seq")
                return "seq"
            if uirCoreStrStartsWith(looseKey0, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, "seq")
                return "seq"
            if uirCoreStrStartsWith(looseKey0, "Table_") && uirCoreHasObjType(module, "Table"):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, "Table")
                return "Table"
            if uirCoreStrStartsWith(looseKey0, "SeqUninit_") && ensureSeqUninitObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
            if uirCoreStrStartsWith(looseKey0, "Option_") && ensureOptionObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
            if uirCoreStrStartsWith(looseKey0, "Result_") && ensureResultObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
            if uirCoreStrStartsWith(looseKey0, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
        return ""
    if kind == nkTupleTy:
        let key: str = typeKey(typeNode)
        # Record tuple field labels (if any) so `t.foo` can resolve to `fN` fields.
        if len(key) > 0:
            for ti in 0..<kidCount(typeNode):
                let elemNode0: Node = kid(typeNode, ti)
                var elemTypeNode0: Node = elemNode0
                var fieldLabel0: str = ""
                if astNodeIdValid(elemNode0) && nodeKind(elemNode0) == nkIdentDefs:
                    if kidCount(elemNode0) > 0:
                        let nameNode0: Node = kid(elemNode0, 0)
                        if (nameNode0 != nil) && (nodeKind(nameNode0) == nkIdent || nodeKind(nameNode0) == nkSymbol):
                            fieldLabel0 = backendStripSpaces(plainName(nameNode0))
                    if kidCount(elemNode0) > 1:
                        elemTypeNode0 = kid(elemNode0, 1)
                var elemTypeKey0: str = ""
                if astNodeIdValid(elemTypeNode0) && nodeKind(elemTypeNode0) == nkDotExpr && kidCount(elemTypeNode0) > 1:
                    elemTypeKey0 = typeKey(kid(elemTypeNode0, 1))
                else:
                    elemTypeKey0 = typeKey(elemTypeNode0)
                if len(elemTypeKey0) == 0 && (elemTypeNode0 != nil):
                    elemTypeKey0 = backendStripSpaces(plainName(elemTypeNode0))
                let fName0: str = uirCoreConcat2("f", intToStr(ti))
                if len(elemTypeKey0) > 0:
                    uirCoreObjFieldTypeKeyPut(key, fName0, elemTypeKey0)
                    if len(fieldLabel0) > 0:
                        uirCoreObjFieldTypeKeyPut(key, fieldLabel0, elemTypeKey0)
                if len(fieldLabel0) > 0:
                    uirCoreTupleFieldIndexPut(key, fieldLabel0, ti)
        if len(key) > 0 && ! uirCoreHasObjType(module, key):
            var fields: UirCoreObjField[]
            var offset: int32 = 0
            var maxAlignPow2: int32 = 0
            for i in 0..<kidCount(typeNode):
                let elemNode: Node = kid(typeNode, i)
                var elemTypeNode: Node = elemNode
                if astNodeIdValid(elemNode) && nodeKind(elemNode) == nkIdentDefs && kidCount(elemNode) > 1:
                    elemTypeNode = kid(elemNode, 1)
                if !astNodeIdValid(elemTypeNode) || nodeKind(elemTypeNode) == nkEmpty:
                    return ""
                let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(module, elemTypeNode)
                let fieldSize: int32 = uirCoreTypeSize(elemTy)
                if fieldSize <= 0:
                    return ""
                let alignPow2: int32 = uirCoreTypeAlignPow2(elemTy)
                if alignPow2 > maxAlignPow2:
                    maxAlignPow2 = alignPow2
                offset = alignUpPow2(offset, alignPow2)
                uirCoreAppendObjFieldNamed(fields, uirCoreConcat2("f", intToStr(i)), elemTy, offset)
                offset = offset + fieldSize
            uirCoreAddObjTypeParts(module, key, maxAlignPow2, alignUpPow2(offset, maxAlignPow2), fields)
        if len(key) > 0 && uirCoreHasObjType(module, key):
            uirCoreTypeKeyObjNameCachePut(module, key, key)
            return key
        return ""
    let nodeKey0: str = typeKey(typeNode)
    if len(nodeKey0) > 0:
        var keyCached: bool = false
        let keyCachedVal: str = uirCoreTypeKeyObjNameCacheGet(module, nodeKey0, keyCached)
        if keyCached:
            return keyCachedVal
        if uirCoreHasObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        let canon0: str = uirCoreObjAliasCanon(nodeKey0)
        if len(canon0) > 0 && !(canon0 == nodeKey0) && uirCoreHasObjType(module, canon0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, canon0)
            return canon0
        if uirCoreStrStartsWith(nodeKey0, "seq_") && uirCoreHasObjType(module, "seq"):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, "seq")
            return "seq"
        if uirCoreStrStartsWith(nodeKey0, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, "seq")
            return "seq"
        if uirCoreStrStartsWith(nodeKey0, "Table_") && uirCoreHasObjType(module, "Table"):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, "Table")
            return "Table"
        if uirCoreStrStartsWith(nodeKey0, "SeqUninit_") && ensureSeqUninitObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        if uirCoreStrStartsWith(nodeKey0, "Option_") && ensureOptionObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        if uirCoreStrStartsWith(nodeKey0, "Result_") && ensureResultObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        if uirCoreStrStartsWith(nodeKey0, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        uirCoreTypeKeyObjNameCachePut(module, nodeKey0, "")
    return ""

fn typeNodeObjTypeName(module: UirCoreModule, typeNode: Node): str =
    if (module == nil) || (typeNode == nil):
        return ""
    if uirCoreTypeNodeObjNameCacheNeedsReset(module):
        uirCoreTypeNodeObjNameCacheReset(module)
    if astNodeIdValid(typeNode):
        uirCoreTypeNodeObjNameCacheEnsure(typeNode)
        let idx0: int32 = int32(typeNode)
        if idx0 >= 0 && idx0 < uirCore_typeNodeObjName_ready.len && uirCore_typeNodeObjName_ready[idx0] != int8(0):
            let cachedRes0: str = uirCore_typeNodeObjName_values[idx0]
            if len(cachedRes0) > 0:
                return cachedRes0
            if nodeKind(typeNode) == nkBracketExpr && uirCoreCurrentParsedRootValid():
                let retryRes0: str = typeNodeObjTypeNameCore(module, typeNode)
                if len(retryRes0) > 0:
                    uirCore_typeNodeObjName_values[idx0] = retryRes0
                    return retryRes0
            let cachedTypeNode0: Node = uirCoreTypeNodeCacheFallback(typeNode)
            if astNodeIdValid(cachedTypeNode0):
                let fallbackRes0: str = typeNodeObjTypeNameCore(module, cachedTypeNode0)
                if len(fallbackRes0) > 0:
                    uirCore_typeNodeObjName_values[idx0] = fallbackRes0
                    return fallbackRes0
            return cachedRes0
    let res: str = typeNodeObjTypeNameCore(module, typeNode)
    if astNodeIdValid(typeNode):
        uirCoreTypeNodeObjNameCacheEnsure(typeNode)
        let idx1: int32 = int32(typeNode)
        if idx1 >= 0 && idx1 < uirCore_typeNodeObjName_values.len && idx1 < uirCore_typeNodeObjName_ready.len:
            uirCore_typeNodeObjName_values[idx1] = res
            uirCore_typeNodeObjName_ready[idx1] = int8(1)
    return res

fn uirCoreNewAllocExprForTypeNode(b: BlockBuilder, allocTypeNode0: Node): Result[UirExprId] =
    var allocTypeNode: Node = allocTypeNode0
    while astNodeIdValid(allocTypeNode) && nodeKind(allocTypeNode) == nkVarTy && kidCount(allocTypeNode) > 0:
        allocTypeNode = kid(allocTypeNode, 0)
    if astNodeIdValid(allocTypeNode) && nodeKind(allocTypeNode) == nkRefTy && kidCount(allocTypeNode) > 0:
        allocTypeNode = kid(allocTypeNode, 0)
    if !astNodeIdValid(allocTypeNode) || nodeKind(allocTypeNode) == nkEmpty:
        return Err[UirExprId]("uirCore_builder: new missing type info")
    var size: int64 = 0
    let dbgNew: bool = (getEnv "BACKEND_DEBUG_NEW" == "1")
    var innerObjName: str = typeNodeObjTypeName(b.module, allocTypeNode)
    let allocKeyLoose: str = uirCoreTypeKeyFromNodeLoose(allocTypeNode)
    let allocKeyRaw: str = backendStripSpaces(typeKey(allocTypeNode))
    if len(innerObjName) == 0 && astNodeIdValid(allocTypeNode) && nodeKind(allocTypeNode) == nkBracketExpr:
        let synthAllocKey: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(b.module, allocTypeNode)
        if len(synthAllocKey) > 0:
            innerObjName = uirCoreObjTypeFromTypeKey(b.module, synthAllocKey)
    if dbgNew:
        os.writeLine(os.get_stderr(),
                     "[backend] debugNewAlloc: keyLoose=" + allocKeyLoose +
                     " keyRaw=" + allocKeyRaw +
                     " objName=" + innerObjName +
                     " kind=nk#" + intToStr(int32(nodeKind(allocTypeNode))) +
                     " @" + intToStr(nodePosLine(allocTypeNode)) + ":" + intToStr(nodePosCol(allocTypeNode)))
        os.c_fflush(os.get_stderr())
    if len(innerObjName) > 0 && b.module != nil && uirCoreHasObjType(b.module, innerObjName):
        let otNew: UirCoreObjType = uirCoreGetObjType(b.module, innerObjName)
        size = int64(otNew.size)
        if dbgNew:
            os.writeLine(os.get_stderr(),
                         "[backend] debugNewAlloc: size_from_obj=" + intToStr(otNew.size))
            os.c_fflush(os.get_stderr())
    else:
        let szRes: Result[int32] = uirCoreSizeOfTypeNode(b.module, allocTypeNode)
        if !IsOk[int32](szRes):
            return ErrInfo[UirExprId](ErrorInfoOf[int32](szRes))
        size = int64(Value[int32](szRes))
        if dbgNew:
            os.writeLine(os.get_stderr(),
                         "[backend] debugNewAlloc: size_from_type=" + intToStr(Value[int32](szRes)))
            os.c_fflush(os.get_stderr())
    let tmpName: str = blockBuilderNextTemp(b, "__new_p")
    let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
    uirCoreSetLocalType(b.func, tmpSlot, uirCoreTypeI64())
    var allocArgs: UirExprId[]
    builderExprSeqAppend(allocArgs, uirCoreConstI64(size))
    blockBuilderAddStmt(b, uirCoreStmtLet(tmpName, tmpSlot, uirCoreCall("alloc", allocArgs)))
    var zeroArgs: UirExprId[]
    builderExprSeqAppend(zeroArgs, uirCoreLocal(tmpSlot))
    builderExprSeqAppend(zeroArgs, uirCoreConstI64(size))
    blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall("zeroMem", zeroArgs)))
    return Ok[UirExprId](uirCoreLocal(tmpSlot))

fn typeNodeIsObjValue(module: UirCoreModule, typeNode: Node): bool =
    if (module == nil) || (typeNode == nil):
        return false
    if nodeKind(typeNode) == nkVarTy && kidCount(typeNode) > 0:
        return typeNodeIsObjValue(module, kid(typeNode, 0))
    if nodeKind(typeNode) == nkDotExpr && kidCount(typeNode) > 1:
        return typeNodeIsObjValue(module, kid(typeNode, 1))
    if nodeKind(typeNode) == nkTupleTy:
        let nm: str = typeNodeObjTypeName(module, typeNode)
        return len(nm) > 0
    let kind: NodeKind = nodeKind(typeNode)
    if kind == nkIdent || kind == nkSymbol:
        let cachedTypeNode: Node = uirCoreTypeNodeCacheFallback(typeNode)
        let nm: str = typeNodeCanonicalName(typeNode)
        if uirCoreHasObjType(module, nm):
            # Ref-like types are represented as pointer aliases + object layout.
            let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, nm)
            if aliasTy.kind != mtVoid:
                return false
            if astNodeIdValid(typeNode) && nodeTypeCacheValid(typeNode) && astRefNonNil(nodeTypeCache(typeNode)):
                let tc: Node = nodeTypeCache(typeNode)
                if nodeKind(tc) == nkRefTy || nodeKind(tc) == nkPtrTy:
                    return false
            return true
        if uirCoreStrStartsWith(nm, "seq_") && uirCoreHasObjType(module, "seq"):
            return true
        if uirCoreStrStartsWith(nm, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
            return true
        if uirCoreStrStartsWith(nm, "Table_") && uirCoreHasObjType(module, "Table"):
            return true
        if uirCoreStrStartsWith(nm, "SeqUninit_") && ensureSeqUninitObjType(module, nm):
            return true
        if uirCoreStrStartsWith(nm, "Option_") && ensureOptionObjType(module, nm):
            return true
        if uirCoreStrStartsWith(nm, "Result_") && ensureResultObjType(module, nm):
            return true
        if uirCoreStrStartsWith(nm, "__cheng_tables_Entry_"):
            return ensureTablesEntryObjType(module, nm)
        if astNodeIdValid(cachedTypeNode):
            return typeNodeIsObjValue(module, cachedTypeNode)
        return false
    if kind == nkBracketExpr && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if base != nil:
            let nm2: str = typeNodeCanonicalName(base)
            if (nm2 == "seq") && uirCoreHasObjType(module, "seq"):
                return true
            if (nm2 == "seq_fixed") && uirCoreHasObjType(module, "seq"):
                return true
            if (nm2 == "Table") && uirCoreHasObjType(module, "Table"):
                return true
            let legacyInstName: str = uirCoreLegacyGenericBracketInstName(typeNode)
            if len(legacyInstName) > 0:
                if uirCoreStrStartsWith(legacyInstName, "Result_") && ensureResultObjType(module, legacyInstName):
                    return true
                if uirCoreStrStartsWith(legacyInstName, "Option_") && ensureOptionObjType(module, legacyInstName):
                    return true
                if uirCoreStrStartsWith(legacyInstName, "SeqUninit_") && ensureSeqUninitObjType(module, legacyInstName):
                    return true
                if uirCoreStrStartsWith(legacyInstName, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, legacyInstName):
                    return true
                if uirCoreHasObjType(module, legacyInstName):
                    return true
            var instArgs: Node[]
            instArgs.cap = 4
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if astNodeIdValid(a) && nodeKind(a) != nkEmpty:
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm2, instArgs)
                if (nm2 == "array") && ensureArrayObjTypeFromTypeExpr(module, typeNode, instName):
                    return true
                if (nm2 == "SeqUninit") && ensureSeqUninitObjType(module, instName):
                    return true
                if (nm2 == "Option") && ensureOptionObjType(module, instName):
                    return true
                if (nm2 == "Result") && ensureResultObjType(module, instName):
                    return true
                if uirCoreHasObjType(module, instName):
                    return true
                if len(uirCoreEnsureGenericTypeInstFromCurrentRoot(module, typeNode)) > 0:
                    return true
                if (nm2 == "__cheng_tables_Entry") && ensureTablesEntryObjType(module, instName):
                    return true
                let looseKey0: str = uirCoreTypeKeyFromNodeLoose(typeNode)
                if len(looseKey0) > 0:
                    if uirCoreHasObjType(module, looseKey0):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "seq_") && uirCoreHasObjType(module, "seq"):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "Table_") && uirCoreHasObjType(module, "Table"):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "SeqUninit_") && ensureSeqUninitObjType(module, looseKey0):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "Option_") && ensureOptionObjType(module, looseKey0):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "Result_") && ensureResultObjType(module, looseKey0):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "__cheng_tables_Entry_"):
                        return ensureTablesEntryObjType(module, looseKey0)
                return false
        return false
    let nodeKey0: str = typeKey(typeNode)
    if len(nodeKey0) > 0:
        if uirCoreHasObjType(module, nodeKey0):
            let aliasTy0: UirCoreType = uirCoreTryGetTypeAlias(module, nodeKey0)
            if aliasTy0.kind == mtVoid:
                return true
        if uirCoreStrStartsWith(nodeKey0, "seq_") && uirCoreHasObjType(module, "seq"):
            return true
        if uirCoreStrStartsWith(nodeKey0, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
            return true
        if uirCoreStrStartsWith(nodeKey0, "Table_") && uirCoreHasObjType(module, "Table"):
            return true
        if uirCoreStrStartsWith(nodeKey0, "SeqUninit_") && ensureSeqUninitObjType(module, nodeKey0):
            return true
        if uirCoreStrStartsWith(nodeKey0, "Option_") && ensureOptionObjType(module, nodeKey0):
            return true
        if uirCoreStrStartsWith(nodeKey0, "Result_") && ensureResultObjType(module, nodeKey0):
            return true
        if uirCoreStrStartsWith(nodeKey0, "__cheng_tables_Entry_"):
            return ensureTablesEntryObjType(module, nodeKey0)
    let cachedTypeNode0: Node = uirCoreTypeNodeCacheFallback(typeNode)
    if astNodeIdValid(cachedTypeNode0):
        return typeNodeIsObjValue(module, cachedTypeNode0)
    return false

fn ensureBuiltinObjTypes(module: UirCoreModule) =
    if (module == nil):
        return
    if ! uirCoreHasObjType(module, "seq"):
        var fields: UirCoreObjField[]
        uirCoreAppendObjFieldNamed(fields, "len", uirCoreTypeI32(), 0)
        uirCoreAppendObjFieldNamed(fields, "cap", uirCoreTypeI32(), 4)
        uirCoreAppendObjFieldNamed(fields, "buffer", uirCoreTypeI64(), 8)
        uirCoreAddObjTypeParts(module, "seq", 3, 16, fields)
    if ! uirCoreHasObjType(module, "Table"):
        # stdlib `tables.Table[V]` (generic) has a stable layout independent of V:
        #   keys: seq[str]      (inlined as keys.len/cap/buffer)
        #   vals: seq[V]        (inlined as vals.len/cap/buffer)
        #   states: seq[uint8]  (inlined as states.len/cap/buffer)
        #   len: int32
        var fields2: UirCoreObjField[]
        uirCoreAppendObjFieldNamed(fields2, "keys.len", uirCoreTypeI32(), 0)
        uirCoreAppendObjFieldNamed(fields2, "keys.cap", uirCoreTypeI32(), 4)
        uirCoreAppendObjFieldNamed(fields2, "keys.buffer", uirCoreTypeI64(), 8)
        uirCoreAppendObjFieldNamed(fields2, "vals.len", uirCoreTypeI32(), 16)
        uirCoreAppendObjFieldNamed(fields2, "vals.cap", uirCoreTypeI32(), 20)
        uirCoreAppendObjFieldNamed(fields2, "vals.buffer", uirCoreTypeI64(), 24)
        uirCoreAppendObjFieldNamed(fields2, "states.len", uirCoreTypeI32(), 32)
        uirCoreAppendObjFieldNamed(fields2, "states.cap", uirCoreTypeI32(), 36)
        uirCoreAppendObjFieldNamed(fields2, "states.buffer", uirCoreTypeI64(), 40)
        uirCoreAppendObjFieldNamed(fields2, "len", uirCoreTypeI32(), 48)
        uirCoreAddObjTypeParts(module, "Table", 3, 56, fields2)

fn ensureArrayObjTypeFromTypeExpr(module: UirCoreModule, arrType: Node, arrName: str): bool =
    if (module == nil) || (arrType == nil) || len(arrName) == 0:
        return false
    if uirCoreHasObjType(module, arrName):
        return true
    if nodeKind(arrType) != nkBracketExpr || kidCount(arrType) < 3:
        return false
    let base: Node = kid(arrType, 0)
    if (base == nil) || (nodeKind(base) != nkIdent && nodeKind(base) != nkSymbol):
        return false
    let baseName: str = backendStripSpaces(plainName(base))
    if !(baseName == "array"):
        return false
    let arg1: Node = kid(arrType, 1)
    let arg2: Node = kid(arrType, 2)
    if !astNodeIdValid(arg1) || !astNodeIdValid(arg2) || nodeKind(arg1) == nkEmpty || nodeKind(arg2) == nkEmpty:
        return false

    let c1: int32 = tryResolveArrayCount(module, arg1)
    let c2: int32 = tryResolveArrayCount(module, arg2)
    var count: int32 = -1
    var elemTypeNode: Node = astInvalidNodeId()
    if c1 > 0 && c2 <= 0:
        count = c1
        elemTypeNode = arg2
    elif c2 > 0 && c1 <= 0:
        count = c2
        elemTypeNode = arg1
    elif c1 > 0 && c2 > 0:
        # Ambiguous; prefer `array[Count, ElemType]`.
        count = c1
        elemTypeNode = arg2
    if count <= 0 || !astNodeIdValid(elemTypeNode) || nodeKind(elemTypeNode) == nkEmpty:
        return false

    # If element type isn't resolved yet, defer array layout creation so we don't
    # lock in an incorrect element representation (e.g. unknown object types default to i32).
    if nodeKind(elemTypeNode) == nkIdent || nodeKind(elemTypeNode) == nkSymbol:
        let elemName: str = backendStripSpaces(plainName(elemTypeNode))
        if len(elemName) > 0 && !isBuiltinTypeName(elemName):
            if !uirCoreHasObjType(module, elemName):
                let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, elemName)
                if aliasTy.kind == mtVoid:
                    return false

    var elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(module, elemTypeNode)
    let elemObjName: str = typeNodeObjTypeName(module, elemTypeNode)
    if len(elemObjName) > 0 && typeNodeIsObjValue(module, elemTypeNode):
        elemTy = uirCoreTypeI64()
    let elemSize: int32 = uirCoreTypeSize(elemTy)
    if elemSize <= 0:
        return false
    let elemAlignPow2: int32 = uirCoreTypeAlignPow2(elemTy)
    let stride: int32 = alignUpPow2(elemSize, elemAlignPow2)
    if stride <= 0:
        return false
    var fields: UirCoreObjField[]
    var off: int32 = 0
    for i in 0..<count:
        uirCoreAppendObjFieldNamed(fields, uirCoreIndexedName("e", i), elemTy, off)
        off = off + stride
    uirCoreAddObjTypeParts(module, arrName, elemAlignPow2, alignUpPow2(off, elemAlignPow2), fields)
    return true

fn uirCoreBuildMissingRoutinesFromUirId(mod: UirCoreModule, rootId: AstNodeId, overloaded: ptr = nil, errOut: ptr = nil): bool =
    if mod == nil || !astNodeIdValid(rootId):
        return true
    stage1Trace("backend: uir fixups.id enter")
    let traceOn: bool = stage1TraceEnabled()
    let dbgPipe: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    let dbgConstFix: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_CONST", "") == "1")
    var dbgFile: os.File = nil
    if dbgPipe:
        dbgFile = os.get_stderr()
        os.writeLine(dbgFile, "[backend] stage1: fixups_enter")
        os.c_fflush dbgFile
    let declCap: int32 = uirCoreCountFnDeclsMangledId(rootId)
    var declNames: str[]
    var declNodes: AstNodeId[]
    var declFiles: str[]
    if declCap > 0:
        setLen(declNames, declCap)
        setLen(declNodes, declCap)
        setLen(declFiles, declCap)
    var declCount: int32 = 0
    let rootFilePath: str = uirCoreNormalizeTopLevelPath(astNodeStrVal(rootId), "")
    uirCoreIndexFnDeclsMangledId(rootId, overloaded, declNames, declNodes, declFiles, declCount, rootFilePath)
    if declCount >= 0 && declCount < declNames.len:
        setLen(declNames, declCount)
    if declCount >= 0 && declCount < declNodes.len:
        setLen(declNodes, declCount)
    if declCount >= 0 && declCount < declFiles.len:
        setLen(declFiles, declCount)
    if dbgConstFix:
        os.writeLine(os.get_stderr(), "[backend] const: fixups_after_index")
        os.c_fflush os.get_stderr()
    if traceOn:
        stage1Trace("backend: uir fixups.id indexed decl_nodes=" + intToStr(declNodes.len))
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: fixups_indexed decl_nodes=" + intToStr(declNodes.len))
        os.c_fflush dbgFile

    var existingFuncs: str[]
    let existingCap: int32 = uirCoreModuleFuncsLen(mod) + declNames.len + 8
    if existingCap > 0:
        setLen(existingFuncs, existingCap)
    var existingFuncCount: int32 = 0
    for fi0 in 0..<uirCoreModuleFuncsLen(mod):
        let f0: UirCoreFunc = uirCoreModuleFuncAt(mod, fi0)
        if uirCoreFuncIdValid(f0) && len(uirCoreFuncNameOf(f0)) > 0:
            if !uirCoreStrListHas(existingFuncs, existingFuncCount, uirCoreFuncNameOf(f0)):
                uirCoreFixedStrAppend(existingFuncs, &existingFuncCount, uirCoreFuncNameOf(f0))
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: fixups_existing_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
        os.c_fflush dbgFile
    if dbgConstFix:
        os.writeLine(os.get_stderr(), "[backend] const: fixups_after_existing")
        os.c_fflush os.get_stderr()
    if traceOn:
        stage1Trace("backend: uir fixups.id existing_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))

    var seen: str[]
    if declNames.len > 0:
        setLen(seen, declNames.len)
    var seenCount: int32 = 0
    var queue: str[]
    if declNames.len > 0:
        setLen(queue, declNames.len)
    var queueCount: int32 = 0
    for fi in 0..<uirCoreModuleFuncsLen(mod):
        let f0: UirCoreFunc = uirCoreModuleFuncAt(mod, fi)
        uirCoreMaybeEnqueueFromFunc(mod, declNames, seen, seenCount, queue, queueCount, f0)
    if traceOn:
        stage1Trace("backend: uir fixups.id queue_seeded=" + intToStr(queueCount))
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: fixups_queue_seeded=" + intToStr(queueCount))
        os.c_fflush dbgFile
    if dbgConstFix:
        os.writeLine(os.get_stderr(), "[backend] const: fixups_after_queue_seeded")
        os.c_fflush os.get_stderr()

    var builtAny: bool = false
    var qi: int32 = 0
    if dbgConstFix:
        os.writeLine(os.get_stderr(), "[backend] const: fixups_before_loop")
        os.c_fflush os.get_stderr()
    while qi < queueCount:
        if dbgConstFix:
            if qi == 0:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter0_enter")
                os.c_fflush os.get_stderr()
            elif qi == 1:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter1_enter")
                os.c_fflush os.get_stderr()
            elif qi == 2:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter2_enter")
                os.c_fflush os.get_stderr()
        let shouldLogIter: bool = qi < 4 || ((qi % 32) == 0)
        if dbgPipe && shouldLogIter:
            os.writeLine(dbgFile, "[backend] stage1: fixups_iter qi=" + intToStr(qi) + " queue=" + intToStr(queueCount))
            os.c_fflush dbgFile
        let nm: str = queue[qi]
        qi = qi + 1
        if len(nm) == 0:
            continue
        if uirCoreStrListHas(existingFuncs, existingFuncCount, nm):
            continue
        let idx: int32 = uirCoreDeclIndexFind(declNames, nm)
        if idx < 0 || idx >= declNodes.len:
            continue
        let nId: AstNodeId = declNodes[idx]
        if !astNodeIdValid(nId):
            continue
        if uirCoreFuncSigHasUnresolvedGenericsId(nId):
            continue
        let fp: str = (idx >= 0 && idx < declFiles.len) ? declFiles[idx] : ""
        if dbgConstFix:
            if qi == 1:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter0_before_build_func")
                os.c_fflush os.get_stderr()
            elif qi == 2:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter1_before_build_func")
                os.c_fflush os.get_stderr()
            elif qi == 3:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter2_before_build_func")
                os.c_fflush os.get_stderr()
        let fRes: Result[UirCoreFunc] = uirCoreBuildFuncId(mod, nId, fp, overloaded)
        if ! IsOk[UirCoreFunc](fRes):
            let infoBuild: ErrorInfo = ErrorInfoOf[UirCoreFunc](fRes)
            let msgBuild: str = "uirCore_builder: fixups build func failed name=" + nm +
                                " code=" + intToStr(ErrorCodeOf(infoBuild))
            if dbgPipe:
                os.writeLine(dbgFile, "[backend] stage1: fixups_build_func_err " + msgBuild)
                os.c_fflush dbgFile
            if errOut != nil:
                store(errOut, msgBuild)
            return false
        if dbgConstFix:
            if qi == 1:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter0_after_build_func")
                os.c_fflush os.get_stderr()
            elif qi == 2:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter1_after_build_func")
                os.c_fflush os.get_stderr()
            elif qi == 3:
                os.writeLine(os.get_stderr(), "[backend] const: fixups_iter2_after_build_func")
                os.c_fflush os.get_stderr()
        let f: UirCoreFunc = Value[UirCoreFunc](fRes)
        if !uirCoreFuncIdValid(f):
            continue
        let stableName: str = (len(nm) > 0) ? nm : uirCoreTopLevelRoutineNameId(nId)
        let stableOriginFile: str = fp
        let stableDeclOrdinal: int32 = astNodeDeclOrdinal(nId)
        let stableSourceAstIndex: int32 = astNodeIndex(nId)
        uirCoreFuncInitHeaderMeta(f, uirCoreFuncRetTypeKeyOf(f), stableOriginFile,
                                  stableDeclOrdinal, stableSourceAstIndex,
                                  uirCoreFuncIsExtern(f))
        let sameRoutineIdx: int32 = uirCoreModuleFuncSameOriginIndex(
            mod, stableName, stableOriginFile,
            stableDeclOrdinal, stableSourceAstIndex)
        if sameRoutineIdx >= 0:
            let exSame: UirCoreFunc = uirCoreModuleFuncAt(mod, sameRoutineIdx)
            if !uirCoreFuncIdValid(exSame) || uirCoreFuncBlocksLen(exSame) == 0:
                uirCoreModuleSetFuncAt(mod, sameRoutineIdx, f)
                if !uirCoreStrListHas(existingFuncs, existingFuncCount, stableName):
                    uirCoreFixedStrAppend(existingFuncs, &existingFuncCount, stableName)
                builtAny = true
                uirCoreMaybeEnqueueFromFunc(mod, declNames, seen, seenCount, queue, queueCount, f)
            continue
        if moduleHasFunc(mod, stableName) || moduleHasGlobal(mod, stableName) ||
           uirCoreFindTypeAlias(mod, stableName) >= 0 || uirCoreFindObjType(mod, stableName) >= 0:
            if dbgPipe:
                os.writeLine(dbgFile, "[backend] stage1: fixups_duplicate_err name=" + stableName)
                os.c_fflush dbgFile
            if errOut != nil:
                store(errOut, "uirCore_builder: duplicate function name: " + stableName)
            return false
        uirCoreAddFunc(mod, f)
        if !uirCoreStrListHas(existingFuncs, existingFuncCount, stableName):
            uirCoreFixedStrAppend(existingFuncs, &existingFuncCount, stableName)
        builtAny = true
        uirCoreMaybeEnqueueFromFunc(mod, declNames, seen, seenCount, queue, queueCount, f)
    if traceOn:
        stage1Trace("backend: uir fixups.id done built_any=" + (builtAny ? "1" : "0") + " queue=" + intToStr(queueCount))
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: fixups_done built_any=" + (builtAny ? "1" : "0") + " queue=" + intToStr(queueCount))
        os.c_fflush dbgFile
    return true

fn uirCoreInferCtorSuffixFromTypeCache(b: BlockBuilder, callNode: Node, objPrefix: str): str =
    if (b == nil) || b.module == nil || (callNode == nil) || len(objPrefix) == 0:
        return ""
    if nodeTypeCacheValid(callNode) && astRefNonNil(nodeTypeCache(callNode)):
        let tc: Node = nodeTypeCache(callNode)
        let objName0: str = typeNodeObjTypeName(b.module, tc)
        if len(objName0) > 0 && uirCoreStrStartsWith(objName0, objPrefix):
            let suffix0: str = str(rawmemPtrAdd(rawmemAsVoid(objName0), len(objPrefix)))
            if len(suffix0) > 0:
                return suffix0
        let key0: str = typeKey(tc)
        if len(key0) > 0 && uirCoreStrStartsWith(key0, objPrefix):
            let suffix1: str = str(rawmemPtrAdd(rawmemAsVoid(key0), len(objPrefix)))
            if len(suffix1) > 0:
                return suffix1
    return ""

fn uirCoreSizeOfTypeNode(module: UirCoreModule, typeNode: Node): Result[int32] =
    if !astNodeIdValid(typeNode) || nodeKind(typeNode) == nkEmpty:
        return Err[int32]("uirCore_builder: sizeof expects a type/expression")
    if nodeKind(typeNode) == nkPtrTy || nodeKind(typeNode) == nkRefTy || nodeKind(typeNode) == nkFnTy || nodeKind(typeNode) == nkVarTy:
        return Ok[int32](8)
    if nodeKind(typeNode) == nkTupleTy:
        let nm: str = typeNodeObjTypeName(module, typeNode)
        if len(nm) > 0 && (module != nil) && uirCoreHasObjType(module, nm):
            let ot: UirCoreObjType = uirCoreGetObjType(module, nm)
            return Ok[int32](ot.size)
        return Err[int32]("uirCore_builder: sizeof unknown tuple type")
    if nodeKind(typeNode) == nkIdent || nodeKind(typeNode) == nkSymbol:
        let nm: str = backendStripSpaces(plainName(typeNode))
        if nm == "bool" || nm == "char" || nm == "int8" || nm == "uint8" || nm == "i8" || nm == "u8":
            return Ok[int32](1)
        if nm == "int16" || nm == "uint16" || nm == "i16" || nm == "u16":
            return Ok[int32](2)
        if nm == "int32" || nm == "uint32" || nm == "i32" || nm == "u32" || nm == "float32":
            return Ok[int32](4)
        if nm == "int" || nm == "uint" || nm == "NI" || nm == "NU":
            let bits: int32 = uirCoreIntBitsDefault32()
            if bits == 64:
                return Ok[int32](8)
            return Ok[int32](4)
        if nm == "int64" || nm == "uint64" || nm == "i64" || nm == "u64" || nm == "float64":
            return Ok[int32](8)
        if isStringOrPtrKey(nm):
            return Ok[int32](8)
        if uirCoreStrStartsWith(nm, "ptr_") || uirCoreStrStartsWith(nm, "ref_") || uirCoreStrStartsWith(nm, "fn_"):
            return Ok[int32](8)
        if uirCoreStrStartsWith(nm, "seq_") || uirCoreStrStartsWith(nm, "seq_fixed_") || uirCoreStrStartsWith(nm, "Table_"):
            return Ok[int32](8)
        if uirCoreStrStartsWith(nm, "set_"):
            return Ok[int32](8)
        if nm == "void":
            return Ok[int32](0)
        if (module != nil):
            let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, nm)
            if aliasTy.kind == mtF64:
                return Ok[int32](8)
            if aliasTy.kind == mtF32:
                return Ok[int32](4)
            if aliasTy.kind == mtI64:
                return Ok[int32](8)
            if aliasTy.kind == mtI32:
                return Ok[int32](4)
            if aliasTy.kind == mtI16:
                return Ok[int32](2)
            if aliasTy.kind == mtI8:
                return Ok[int32](1)
            let objAliasName: str = typeNodeObjTypeName(module, typeNode)
            if len(objAliasName) > 0 && uirCoreHasObjType(module, objAliasName):
                let otAlias: UirCoreObjType = uirCoreGetObjType(module, objAliasName)
                return Ok[int32](otAlias.size)
            let resolvedTy: UirCoreType = uirCoreTypeFromNodeWithModule(module, typeNode)
            let resolvedSize: int32 = uirCoreTypeSize(resolvedTy)
            if resolvedTy.kind != mtVoid && resolvedSize >= 0:
                return Ok[int32](resolvedSize)
        if (module != nil) && uirCoreHasObjType(module, nm):
            let ot2: UirCoreObjType = uirCoreGetObjType(module, nm)
            return Ok[int32](ot2.size)
        # Bare generic params (`T`/`V`/`K`) lower as pointer-sized runtime values.
        # This must work outside skip-mono too because std generic helpers such as
        # `seqs.setLen[T]` still evaluate `sizeof T` during ordinary lowering.
        if uirCoreLooksLikeTypeParamName(nm):
            return Ok[int32](8)
        if getEnv("BACKEND_SIZEOF_UNKNOWN_FALLBACK") == "1":
            return Ok[int32](8)
        let line2: str = intToStr(nodePosLine(typeNode))
        let col2: str = intToStr(nodePosCol(typeNode))
        return Err[int32]("uirCore_builder: sizeof unknown type '" + nm + "' @" + line2 + ":" + col2)
    if nodeKind(typeNode) == nkBracketExpr && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if (base != nil) && (nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol):
            let nm2: str = backendStripSpaces(plainName(base))
            if nm2 == "seq" && (module != nil) && uirCoreHasObjType(module, "seq"):
                let ot3: UirCoreObjType = uirCoreGetObjType(module, "seq")
                return Ok[int32](ot3.size)
            if (module != nil) && uirCoreHasObjType(module, nm2):
                let ot4: UirCoreObjType = uirCoreGetObjType(module, nm2)
                return Ok[int32](ot4.size)
            var instArgs: Node[]
            instArgs.cap = 4
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if astNodeIdValid(a) && nodeKind(a) != nkEmpty:
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm2, instArgs)
                if (module != nil) && uirCoreHasObjType(module, instName):
                    let ot5: UirCoreObjType = uirCoreGetObjType(module, instName)
                    return Ok[int32](ot5.size)
    let k: str = intToStr(int32(nodeKind(typeNode)))
    let line: str = intToStr(nodePosLine(typeNode))
    let col: str = intToStr(nodePosCol(typeNode))
    return Err[int32]("uirCore_builder: sizeof unsupported type (nk#" + k + " @" + line + ":" + col + ")")

fn uirCoreSizeOfExprOrTypeNode(b: BlockBuilder, argNode0: Node): Result[int32] =
    if b == nil:
        return uirCoreSizeOfTypeNode(nil, argNode0)
    var szRes: Result[int32] = uirCoreSizeOfTypeNode(b.module, argNode0)
    # `sizeof` is frequently used on fields/locals where typeCache may be missing
    # or cleared by earlier lowering. Recover the byte size from resolved object/local
    # metadata before falling back to a hard error.
    if !IsOk[int32](szRes) && astNodeIdValid(argNode0):
        var da0: DotAccess
        let dotRes0: Result[bool] = uirCoreTryLowerDotAccess(b, argNode0, &da0)
        if IsOk[bool](dotRes0) && Value[bool](dotRes0):
            if da0.fieldTy.kind == mtI32:
                szRes = Ok[int32](4)
            elif da0.fieldTy.kind == mtI64:
                szRes = Ok[int32](8)
            elif da0.fieldTy.kind == mtVoid && len(da0.objTypeName) > 0 &&
                 b.module != nil && uirCoreHasObjType(b.module, da0.objTypeName):
                let ot0: UirCoreObjType = uirCoreGetObjType(b.module, da0.objTypeName)
                szRes = Ok[int32](ot0.size)
        elif nodeKind(argNode0) == nkIdent || nodeKind(argNode0) == nkSymbol:
            let nm: str = plainName(argNode0)
            let slot: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm)
            if slot >= 0:
                let olIdx: int32 = funcFindObjLocal(b.func, slot)
                if olIdx >= 0:
                    let objNm: str = funcObjTypeName(b.func, slot)
                    if len(objNm) > 0 && b.module != nil && uirCoreHasObjType(b.module, objNm):
                        let ot1: UirCoreObjType = uirCoreGetObjType(b.module, objNm)
                        szRes = Ok[int32](ot1.size)
                else:
                    let ty0: UirCoreType = localType(b.env, slot)
                    if ty0.kind == mtI64:
                        szRes = Ok[int32](8)
                    elif ty0.kind == mtI32:
                        szRes = Ok[int32](4)
                    elif ty0.kind == mtVoid:
                        szRes = Ok[int32](0)
            else:
                let gi0: int32 = moduleGlobalIndex(b.module, nm)
                if gi0 >= 0:
                    let mod0: UirCoreModule = b.module
                    let g0: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, gi0)
                    if g0.ty.kind == mtI64:
                        szRes = Ok[int32](8)
                    elif g0.ty.kind == mtI32:
                        szRes = Ok[int32](4)
                    elif g0.ty.kind == mtVoid:
                        szRes = Ok[int32](0)
    if !IsOk[int32](szRes) && astNodeIdValid(argNode0) && nodeTypeCacheValid(argNode0) && astRefNonNil(nodeTypeCache(argNode0)):
        szRes = uirCoreSizeOfTypeNode(b.module, nodeTypeCache(argNode0))
    return szRes

fn inferInlineObjFieldTypeName(module: UirCoreModule, parent: UirCoreObjType, fieldName: str, baseOff: int32): str =
    # Match a nested/inlined field by layout against known object types.
    # Example: `Table.keys.*`/`Table.vals.*`/`Table.states.*` matches
    # builtin `seq` (len/cap/buffer) at baseOff.
    if (module == nil) || len(fieldName) == 0 || baseOff < 0:
        return ""
    let mapped: str = uirCoreInlineObjFieldTypeGet(parent.name, fieldName)
    if len(mapped) > 0:
        if (getEnv "BACKEND_DEBUG_OVERLOAD_DOT" == "1") && parent.name == "ProtoBuffer" && fieldName == "out":
            echo("[backend] debugOverloadDot: inferInline mapped parent='ProtoBuffer' field='out' mapped='" + mapped + "'")
        return mapped
    # Prefer declared field type keys over structural matching to avoid
    # aliasing to an unrelated object type with the same flattened layout.
    let declaredKey: str = uirCoreObjFieldTypeKeyGet(parent.name, fieldName)
    var rootDeclaredKey: str = declaredKey
    if len(rootDeclaredKey) == 0:
        rootDeclaredKey = uirCoreFieldTypeKeyFromCurrentRoot(module, parent.name, fieldName)
    if (getEnv "BACKEND_DEBUG_OVERLOAD_DOT" == "1") && parent.name == "ProtoBuffer" && fieldName == "out":
        let lookupKeyDbg: str = parent.name + "::" + fieldName
        let scanEntry: str = uirCoreObjFieldTypeKeyDebugEntry(parent.name, fieldName)
        if len(scanEntry) > 0:
            echo("[backend] debugOverloadDot: scan fieldKeyMap key='" + lookupKeyDbg + "' " + scanEntry)
        else:
            echo("[backend] debugOverloadDot: scan fieldKeyMap key='" + lookupKeyDbg + "' missing")
        echo("[backend] debugOverloadDot: lookupKey len=" + intToStr(len(lookupKeyDbg)) +
             " parentLen=" + intToStr(len(parent.name)) + " fieldLen=" + intToStr(len(fieldName)))
        echo("[backend] debugOverloadDot: inferInline declaredKey parent='ProtoBuffer' field='out' key='" + declaredKey + "'")
    if len(declaredKey) > 0:
        let declaredObj: str = uirCoreObjTypeFromTypeKey(module, declaredKey)
        if (getEnv "BACKEND_DEBUG_OVERLOAD_DOT" == "1") && parent.name == "ProtoBuffer" && fieldName == "out":
        echo("[backend] debugOverloadDot: inferInline declaredObj parent='ProtoBuffer' field='out' obj='" + declaredObj + "'")
        if len(declaredObj) > 0:
            uirCoreInlineObjFieldTypePut(parent.name, fieldName, declaredObj)
            return declaredObj
    if len(rootDeclaredKey) > 0 && !(rootDeclaredKey == declaredKey):
        let rootDeclaredObj: str = uirCoreObjTypeFromTypeKey(module, rootDeclaredKey)
        if len(rootDeclaredObj) > 0:
            uirCoreInlineObjFieldTypePut(parent.name, fieldName, rootDeclaredObj)
            return rootDeclaredObj
    let prefix: str = uirCoreAppendChar(fieldName, '.')
    for ti in 0..<uirCoreModuleObjTypesLen(module):
        let cand: UirCoreObjType = uirCoreModuleObjTypeAt(module, ti)
        if len(cand.name) == 0 || cand.fields.len == 0:
            continue
        var ok: bool = true
        for ci in 0..<cand.fields.len:
            let cf: UirCoreObjField = cand.fields[ci]
            let wantName: str = uirCoreConcat2(prefix, cf.name)
            let wantOff: int32 = baseOff + cf.offset
            var found: bool = false
            for pi in 0..<parent.fields.len:
                let pf: UirCoreObjField = parent.fields[pi]
                if (pf.name == wantName) && pf.offset == wantOff && pf.ty.kind == cf.ty.kind:
                    found = true
                    break
            if !found:
                ok = false
                break
        if ok:
            return cand.name
    return ""

fn uirCoreObjTypeFromTypeKey(module: UirCoreModule, typeKey0: str): str =
    if (module == nil) || len(typeKey0) == 0:
        return ""
    var key: str = uirCoreTypeKeyStripIterWrappers(typeKey0)
    if len(key) == 0:
        return ""
    let canon: str = uirCoreObjAliasCanon(key)
    if len(canon) > 0:
        key = canon
    if uirCoreHasObjType(module, key):
        return key
    let uniq0: str = uirCoreFindObjTypeByBaseUnique(module, key)
    if len(uniq0) > 0:
        return uniq0
    if uirCoreStrStartsWith(key, "seq_") && uirCoreHasObjType(module, "seq"):
        return "seq"
    if uirCoreStrStartsWith(key, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
        return "seq"
    if uirCoreStrStartsWith(key, "Table_") && uirCoreHasObjType(module, "Table"):
        return "Table"
    if uirCoreStrStartsWith(key, "Option_") && ensureOptionObjType(module, key):
        return key
    if uirCoreStrStartsWith(key, "Result_") && ensureResultObjType(module, key):
        return key
    if uirCoreStrStartsWith(key, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, key):
        return key
    let layout0: str = uirCorePtrBaseObjTypeName(module, key)
    if len(layout0) > 0:
        return layout0
    let base: str = uirCoreTypeKeyBaseName(key)
    if len(base) > 0 && !(base == key):
        var baseName: str = base
        let baseCanon: str = uirCoreObjAliasCanon(baseName)
        if len(baseCanon) > 0:
            baseName = baseCanon
        if uirCoreHasObjType(module, baseName):
            return baseName
        let uniq1: str = uirCoreFindObjTypeByBaseUnique(module, baseName)
        if len(uniq1) > 0:
            return uniq1
        if uirCoreStrStartsWith(baseName, "Option_") && ensureOptionObjType(module, baseName):
            return baseName
        if uirCoreStrStartsWith(baseName, "Result_") && ensureResultObjType(module, baseName):
            return baseName
        if uirCoreStrStartsWith(baseName, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, baseName):
            return baseName
        let layout1: str = uirCorePtrBaseObjTypeName(module, baseName)
        if len(layout1) > 0:
            return layout1
        let rootObj1: str = uirCoreObjTypeFromCurrentRootDecl(module, baseName)
        if len(rootObj1) > 0:
            return rootObj1
    return ""

fn uirCoreDirectObjValueTypeNameFromKey(module: UirCoreModule, typeKey0: str): str =
    if (module == nil) || len(typeKey0) == 0:
        return ""
    var key: str = uirCoreTypeKeyStripIterWrappers(uirCoreStripRefVarKeyOnce(typeKey0))
    if len(key) == 0:
        return ""
    if uirCoreStrStartsWith(key, "ptr_") || uirCoreStrStartsWith(key, "ref_"):
        return ""
    return uirCoreObjTypeFromTypeKey(module, key)

fn uirCoreDotObjTypeNameFromKey(module: UirCoreModule, key0: str): str =
    if (module == nil):
        return ""
    let key: str = uirCoreTypeKeyStripIterWrappers(uirCoreStripRefVarKeyOnce(key0))
    if len(key) == 0:
        return ""
    let recoveredObjKey0: str = uirCoreRecoverLegacyGenericObjKey(module, key)
    if len(recoveredObjKey0) > 0:
        return recoveredObjKey0
    let obj0: str = uirCoreObjTypeFromTypeKey(module, key)
    if len(obj0) > 0:
        return obj0
    let rootObj0: str = uirCoreObjTypeFromCurrentRootDecl(module, key)
    if len(rootObj0) > 0:
        return rootObj0
    if uirCoreStrStartsWith(key, "array_"):
        for i0 in 6..<len(key):
            if key[i0] == '_':
                let suffix: str = str(rawmemPtrAdd(rawmemAsVoid(key), i0 + 1))
                let suffixObj: str = uirCoreDotObjTypeNameFromKey(module, suffix)
                if len(suffixObj) > 0:
                    return suffixObj
    return ""

fn uirCoreIndexedElemObjTypeNameFromKey(module: UirCoreModule, key0: str): str =
    if (module == nil):
        return ""
    let key: str = uirCoreTypeKeyStripIterWrappers(key0)
    if len(key) == 0:
        return ""
    if uirCoreStrStartsWith(key, "seq_"):
        let elemKey: str = uirCoreTypeKeyStripIterWrappers(str(rawmemPtrAdd(rawmemAsVoid(key), 4)))
        if len(elemKey) > 0:
            let elemObj: str = uirCoreDotObjTypeNameFromKey(module, elemKey)
            if len(elemObj) > 0:
                return elemObj
            if uirCoreStrStartsWith(elemKey, "seq_") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if uirCoreStrStartsWith(elemKey, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if uirCoreStrStartsWith(elemKey, "Table_") && uirCoreHasObjType(module, "Table"):
                return "Table"
    elif uirCoreStrStartsWith(key, "seq_fixed_"):
        let elemKey2: str = uirCoreTypeKeyStripIterWrappers(str(rawmemPtrAdd(rawmemAsVoid(key), 10)))
        if len(elemKey2) > 0:
            let elemObj2: str = uirCoreDotObjTypeNameFromKey(module, elemKey2)
            if len(elemObj2) > 0:
                return elemObj2
            if uirCoreStrStartsWith(elemKey2, "seq_") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if uirCoreStrStartsWith(elemKey2, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if uirCoreStrStartsWith(elemKey2, "Table_") && uirCoreHasObjType(module, "Table"):
                return "Table"
    return uirCoreDotObjTypeNameFromKey(module, key)

fn uirCoreGlobalObjTypeNameFromSymbol(module: UirCoreModule, symName: str): str =
    if (module == nil) || len(symName) == 0:
        return ""
    let obj0: str = uirCoreGlobalObjTypeGet(symName)
    if len(obj0) > 0:
        return obj0
    return uirCoreDotObjTypeNameFromKey(module, uirCoreGlobalTypeKeyGet(symName))

fn uirCoreInferValueCallInnerKey(b: BlockBuilder, callNode: Node): str =
    if (b == nil) || !astNodeIdValid(callNode) || nodeKind(callNode) != nkCall || kidCount(callNode) <= 1:
        return ""
    let dbgValueInner: bool = (getEnv "BACKEND_DEBUG_VALUE_CALLSITE" == "1")
    let calleeName0: str = uirCoreCallCalleeName(callNode)
    let valueLikeCall0: bool = (calleeName0 == "Value") ||
        uirCoreStrStartsWith(calleeName0, "Value_") ||
        uirCoreStrStartsWith(calleeName0, "Value__")
    if dbgValueInner:
        let line0: str = intToStr(nodePosLine(callNode))
        let col0: str = intToStr(nodePosCol(callNode))
        echo("[backend] debugValueInner: callee='" + calleeName0 + "' valueLike=" +
             (valueLikeCall0 ? "1" : "0") + " @" + line0 + ":" + col0)
    # Relaxed fallback: some stage1 paths keep callee names qualified/mangled.
    # For unary calls whose first arg is a Result helper wrapper, still recover the inner value key.
    if !valueLikeCall0 && kidCount(callNode) != 2:
        return ""
    var arg0: Node = kid(callNode, 1)
    if astNodeIdValid(arg0) && nodeKind(arg0) == nkCallArg && kidCount(arg0) > 1:
        arg0 = kid(arg0, 1)
    var argKey0: str = caseInferExprTypeKey(b, arg0)
    if len(argKey0) == 0:
        argKey0 = uirCoreInferNodeTypeKeyForOverload(b, arg0)
    if (len(argKey0) == 0) && astNodeIdValid(arg0) && nodeTypeCacheValid(arg0) && astRefNonNil(nodeTypeCache(arg0)):
        argKey0 = typeKey(nodeTypeCache(arg0))
        if len(argKey0) == 0:
            argKey0 = uirCoreTypeKeyFromNodeLoose(nodeTypeCache(arg0))
    if (len(argKey0) == 0) && (arg0 != nil) && (nodeKind(arg0) == nkIdent || nodeKind(arg0) == nkSymbol):
        let nm0: str = backendStripSpaces(plainName(arg0))
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm0)
        if slot0 >= 0:
            argKey0 = localTypeKey(b.env, slot0)
        if (len(argKey0) == 0) && b.module != nil:
            argKey0 = uirCoreGlobalTypeKeyByBaseUnique(b.module, nm0)
    if len(argKey0) > 0:
        argKey0 = uirCoreTypeKeyStripIterWrappers(argKey0)
    if len(argKey0) > 0 && uirCoreStrStartsWith(argKey0, "Result_"):
        let valKey0: str = str(rawmemPtrAdd(rawmemAsVoid(argKey0), 7))
        if dbgValueInner:
            echo("[backend] debugValueInner: argKey='" + argKey0 + "' valKey='" + valKey0 + "'")
        if len(valKey0) > 0:
            return valKey0
    if b.module != nil && len(argKey0) > 0:
        let objName0: str = uirCoreDotObjTypeNameFromKey(b.module, argKey0)
        if len(objName0) > 0:
            let valueKey0: str = uirCoreObjFieldTypeKeyGet(objName0, "value")
            if len(valueKey0) > 0:
                return valueKey0
    return ""

fn uirCoreResolveGlobalObjTypeName(b: BlockBuilder, baseName0: str): str =
    if (b == nil) || b.module == nil || len(baseName0) == 0:
        return ""
    let mod0: UirCoreModule = b.module
    let debugDot: bool = (getEnv "BACKEND_DEBUG_DOT" == "1")
    let baseName: str = backendStripSpaces(baseName0)
    if len(baseName) == 0:
        return ""
    let obj0: str = uirCoreGlobalObjTypeGet(baseName)
    if len(obj0) > 0:
        return obj0
    let key0: str = uirCoreGlobalTypeKeyGet(baseName)
    let obj1: str = uirCoreDotObjTypeNameFromKey(mod0, key0)
    if len(obj1) > 0:
        return obj1
    let gi0: int32 = moduleGlobalIndex(mod0, baseName)
    if debugDot:
        echo("[backend] debugDot: globalObjProbe base='" + baseName + "' obj0='" + obj0 +
             "' key0='" + key0 + "' obj1='" + obj1 + "' gi0=" + intToStr(gi0))
    let globals0: UirCoreGlobal[] = mod0.globals
    if gi0 >= 0 && gi0 < globals0.len:
        let g0: UirCoreGlobal = globals0[gi0]
        let gObj0: str = uirCoreGlobalObjTypeNameFromSymbol(mod0, g0.name)
        if len(gObj0) > 0:
            return gObj0
        let gKey0: str = uirCoreGlobalTypeKeyGet(g0.name)
        let gObj1: str = uirCoreDotObjTypeNameFromKey(mod0, gKey0)
        if debugDot:
            echo("[backend] debugDot: globalObjProbe exact g.name='" + g0.name +
                 "' gObj0='" + gObj0 + "' gKey0='" + gKey0 + "' gObj1='" + gObj1 +
                 "' g.origin='" + g0.originFile + "' g.ty=nk#" + intToStr(int32(g0.ty.kind)) + "'")
        if len(gObj1) > 0:
            return gObj1
    if uirCoreFuncIdValid(b.func) && uirCoreDupGlobalNamesHas(baseName):
        let f0: UirCoreFunc = b.func
        let sym0: str = uirCoreMaybeMangleDupGlobalName(baseName, uirCoreFuncOriginFileOf(f0))
        if debugDot:
            echo("[backend] debugDot: globalObjProbe dup base='" + baseName + "' sym0='" + sym0 + "'")
        if len(sym0) > 0 && !(sym0 == baseName):
            let mObj0: str = uirCoreGlobalObjTypeNameFromSymbol(mod0, sym0)
            if len(mObj0) > 0:
                return mObj0
            let mKey0: str = uirCoreGlobalTypeKeyGet(sym0)
            let mObj1: str = uirCoreDotObjTypeNameFromKey(mod0, mKey0)
            if debugDot:
                echo("[backend] debugDot: globalObjProbe dup sym0='" + sym0 +
                     "' mObj0='" + mObj0 + "' mKey0='" + mKey0 + "' mObj1='" + mObj1 + "'")
            if len(mObj1) > 0:
                return mObj1
            let mGi0: int32 = moduleGlobalIndex(mod0, sym0)
            if mGi0 >= 0 && mGi0 < globals0.len:
                let mg0: UirCoreGlobal = globals0[mGi0]
                let mgObj0: str = uirCoreGlobalObjTypeNameFromSymbol(mod0, mg0.name)
                if len(mgObj0) > 0:
                    return mgObj0
                let mgKey0: str = uirCoreGlobalTypeKeyGet(mg0.name)
                let mgObj1: str = uirCoreDotObjTypeNameFromKey(mod0, mgKey0)
                if debugDot:
                    echo("[backend] debugDot: globalObjProbe dup-index mg.name='" + mg0.name +
                         "' mgObj0='" + mgObj0 + "' mgKey0='" + mgKey0 + "' mgObj1='" + mgObj1 + "'")
                if len(mgObj1) > 0:
                    return mgObj1
    let uniqGi: int32 = moduleFindGlobalIndexByBaseUnique(mod0, baseName)
    if uniqGi >= 0 && uniqGi < globals0.len:
        let ug: UirCoreGlobal = globals0[uniqGi]
        let uObj0: str = uirCoreGlobalObjTypeNameFromSymbol(mod0, ug.name)
        if len(uObj0) > 0:
            return uObj0
        let uKey0: str = uirCoreGlobalTypeKeyGet(ug.name)
        let uObj1: str = uirCoreDotObjTypeNameFromKey(mod0, uKey0)
        if len(uObj1) > 0:
            return uObj1
    let uniqKey: str = uirCoreGlobalTypeKeyByBaseUnique(mod0, baseName)
    let uniqObj: str = uirCoreDotObjTypeNameFromKey(mod0, uniqKey)
    if debugDot:
        echo("[backend] debugDot: globalObjProbe uniq base='" + baseName +
             "' uniqGi=" + intToStr(uniqGi) + " uniqKey='" + uniqKey + "' uniqObj='" + uniqObj + "'")
    if len(uniqObj) > 0:
        return uniqObj
    return ""

fn uirCoreDotResolveBracketBaseObjTypeName(b: BlockBuilder, base: Node, dotNode: Node,
                                           debugDot: bool): str =
    if (b == nil) || !astNodeIdValid(base) || nodeKind(base) != nkBracketExpr || kidCount(base) != 2:
        return ""
    let base0: Node = kid(base, 0)
    if astNodeIdValid(base0) && nodeTypeCacheValid(base0) && astRefNonNil(nodeTypeCache(base0)):
        var t0: Node = nodeTypeCache(base0)
        while astNodeIdValid(t0) && nodeKind(t0) == nkPar && kidCount(t0) > 0:
            t0 = kid(t0, 0)
        if astNodeIdValid(t0) && nodeKind(t0) == nkVarTy && kidCount(t0) > 0:
            t0 = kid(t0, 0)
        if (t0 != nil) && (nodeKind(t0) == nkRefTy || nodeKind(t0) == nkPtrTy) && kidCount(t0) > 0:
            t0 = kid(t0, 0)
        if astNodeIdValid(t0) && nodeKind(t0) == nkBracketExpr && kidCount(t0) > 0:
            let tyBase: Node = kid(t0, 0)
            if (tyBase != nil) && (nodeKind(tyBase) == nkIdent || nodeKind(tyBase) == nkSymbol):
                let tyName: str = backendStripSpaces(plainName(tyBase))
                if (tyName == "array") && kidCount(t0) >= 3:
                    let arg1: Node = kid(t0, 1)
                    let arg2: Node = kid(t0, 2)
                    let c1: int32 = tryResolveArrayCount(b.module, arg1)
                    let c2: int32 = tryResolveArrayCount(b.module, arg2)
                    var elemTypeNode: Node = astInvalidNodeId()
                    if c1 > 0 && c2 <= 0:
                        elemTypeNode = arg2
                    elif c2 > 0 && c1 <= 0:
                        elemTypeNode = arg1
                    elif c1 > 0 && c2 > 0:
                        elemTypeNode = arg2
                    if astNodeIdValid(elemTypeNode) && nodeKind(elemTypeNode) != nkEmpty:
                        let objTypeName0: str = typeNodeObjTypeName(b.module, elemTypeNode)
                        if len(objTypeName0) > 0:
                            return objTypeName0
                elif (tyName == "seq") && kidCount(t0) >= 2:
                    let elemTypeNode2: Node = kid(t0, 1)
                    if astNodeIdValid(elemTypeNode2) && nodeKind(elemTypeNode2) != nkEmpty:
                        let objTypeName1: str = typeNodeObjTypeName(b.module, elemTypeNode2)
                        if len(objTypeName1) > 0:
                            return objTypeName1
                elif (tyName == "seq_fixed") && kidCount(t0) >= 2:
                    let elemTypeNode3: Node = kid(t0, 1)
                    if astNodeIdValid(elemTypeNode3) && nodeKind(elemTypeNode3) != nkEmpty:
                        let objTypeName2: str = typeNodeObjTypeName(b.module, elemTypeNode3)
                        if len(objTypeName2) > 0:
                            return objTypeName2
    var key0: str = ""
    if (base0 != nil) && (nodeKind(base0) == nkIdent || nodeKind(base0) == nkSymbol):
        let slot0Name: str = backendStripSpaces(plainName(base0))
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, slot0Name)
        if slot0 >= 0:
            key0 = localTypeKey(b.env, slot0)
    if len(key0) == 0:
        key0 = exprTypeKeyShallow(b, base0)
    if len(key0) == 0:
        var da0: DotAccess
        let dotKeyRes0: Result[bool] = uirCoreTryLowerDotAccess(b, base0, &da0)
        if !IsOk[bool](dotKeyRes0):
            return ""
        if Value[bool](dotKeyRes0) && da0.fieldTy.kind == mtVoid && len(da0.objTypeName) > 0:
            key0 = da0.objTypeName
    if (len(key0) == 0) && (base0 != nil) && (nodeKind(base0) == nkIdent || nodeKind(base0) == nkSymbol):
        let base0Name: str = backendStripSpaces(plainName(base0))
        let gObj0: str = uirCoreResolveGlobalObjTypeName(b, base0Name)
        if len(gObj0) > 0:
            key0 = gObj0
    if (base0 != nil) && len(key0) > 0 && (key0 == "seq" || key0 == "Table"):
        let refinedKey: str = caseInferExprTypeKey(b, base0)
        if len(refinedKey) > 0 && !(refinedKey == key0):
            key0 = refinedKey
    if astNodeIdValid(base0) && nodeKind(base0) == nkDotExpr && kidCount(base0) > 1 &&
       len(key0) > 0 && (key0 == "seq" || key0 == "Table"):
        let parentNode0: Node = kid(base0, 0)
        let memberNode0: Node = kid(base0, 1)
        let memberName0: str = backendStripSpaces(plainName(memberNode0))
        var parentKey0: str = caseInferExprTypeKey(b, parentNode0)
        var parentObj0: str = uirCoreDotObjTypeNameFromKey(b.module, parentKey0)
        if len(parentObj0) == 0 && (parentNode0 != nil) && (nodeKind(parentNode0) == nkIdent || nodeKind(parentNode0) == nkSymbol):
            let parentName0: str = backendStripSpaces(plainName(parentNode0))
            parentObj0 = uirCoreResolveGlobalObjTypeName(b, parentName0)
        if len(parentObj0) > 0 && len(memberName0) > 0:
            let fieldKey1: str = backendStripSpaces(uirCoreObjFieldTypeKeyGet(parentObj0, memberName0))
            if len(fieldKey1) > 0:
                key0 = fieldKey1
    let objTypeName: str = len(key0) > 0 ? uirCoreIndexedElemObjTypeNameFromKey(b.module, key0) : ""
    if debugDot && len(objTypeName) == 0:
        var bKind: int32 = -1
        if (base0 != nil):
            bKind = int32(nodeKind(base0))
        let lineD: str = intToStr(nodePosLine(dotNode))
        let colD: str = intToStr(nodePosCol(dotNode))
        echo("[backend] debugDot: bracket-dot missing objTypeName key0='" + key0 +
            "' base0Kind=nk#" + intToStr(bKind) + " @" + lineD + ":" + colD)
    return objTypeName

fn uirCoreDotResolveCallBaseObjTypeName(b: BlockBuilder, base: Node, debugDot: bool): str =
    if (b == nil) || !astNodeIdValid(base) || nodeKind(base) != nkCall || b.module == nil:
        return ""
    let callName: str = uirCoreCallNameForReachability(b.module, base)
    if debugDot:
        echo("[backend] debugDot: call-dot callName='" + callName + "'")
    if len(callName) > 0:
        var callee0: UirCoreFunc = moduleFindFunc(b.module, callName)
        if (callee0 == nil):
            callee0 = moduleFindFuncByBaseUnique(b.module, callName)
        if (callee0 != nil) && len(uirCoreFuncRetTypeKeyOf(callee0)) > 0:
            let key: str = uirCoreFuncRetTypeKeyOf(callee0)
            let objTypeName0: str = uirCoreDotObjTypeNameFromKey(b.module, key)
            if debugDot:
                echo("[backend] debugDot: call-dot callee retTypeKey='" + uirCoreFuncRetTypeKeyOf(callee0) +
                     "' objTypeFromRet='" + objTypeName0 + "'")
            if len(objTypeName0) > 0:
                return objTypeName0
    if kidCount(base) > 1:
        let valKey0: str = uirCoreInferValueCallInnerKey(b, base)
        if debugDot:
            echo("[backend] debugDot: call-dot valKey='" + valKey0 + "'")
        if len(valKey0) > 0:
            let objTypeName1: str = uirCoreDotObjTypeNameFromKey(b.module, valKey0)
            if debugDot:
                echo("[backend] debugDot: call-dot objTypeFromVal='" + objTypeName1 + "'")
            if len(objTypeName1) > 0:
                return objTypeName1
    let callKey2: str = caseInferExprTypeKey(b, base)
    if debugDot:
        echo("[backend] debugDot: call-dot callExprKey='" + callKey2 + "'")
    if len(callKey2) > 0:
        let objTypeName2: str = uirCoreDotObjTypeNameFromKey(b.module, callKey2)
        if debugDot:
            echo("[backend] debugDot: call-dot objTypeFromExprKey='" + objTypeName2 + "'")
        return objTypeName2
    return ""

fn uirCoreDotResolveHiddenDerefBaseObjTypeName(b: BlockBuilder, base: Node): str =
    if (b == nil) || !astNodeIdValid(base) ||
       !((nodeKind(base) == nkHiddenDeref || nodeKind(base) == nkDerefExpr) && kidCount(base) > 0):
        return ""
    let inner: Node = kid(base, 0)
    if astNodeIdValid(inner) && nodeTypeCacheValid(inner) && astRefNonNil(nodeTypeCache(inner)):
        return typeNodeObjTypeName(b.module, nodeTypeCache(inner))
    if (inner != nil) && (nodeKind(inner) == nkIdent || nodeKind(inner) == nkSymbol):
        let slot2: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, plainName(inner))
        if slot2 >= 0:
            let objTypeName0: str = funcObjTypeName(b.func, slot2)
            if len(objTypeName0) > 0:
                return objTypeName0
            let key2: str = localTypeKey(b.env, slot2)
            let objTypeName1: str = uirCoreDotObjTypeNameFromKey(b.module, key2)
            if len(objTypeName1) > 0:
                return objTypeName1
    if (inner != nil) && b.module != nil:
        let key3: str = exprTypeKeyShallow(b, inner)
        return uirCoreDotObjTypeNameFromKey(b.module, key3)
    return ""

fn uirCoreNormalizeDotFieldName(b: BlockBuilder, dotNode: Node, base: Node, baseName: str,
                                objTypeName: str, ot: UirCoreObjType, field: Node): str =
    var fieldName: str = uirCoreMemberName(field)
    if len(fieldName) == 0:
        fieldName = uirCoreGuessIdentNameFromSource(b.func, field)
    if len(fieldName) == 0:
        fieldName = uirCoreGuessDotFieldNameFromSource(b.func, dotNode)
    let seqLikeObj: bool = (ot.name == "seq") || (objTypeName == "seq") ||
        uirCoreStrStartsWith(objTypeName, "seq_") || uirCoreStrStartsWith(objTypeName, "seq_fixed_")
    var seqGuessBaseName: str = baseName
    if len(seqGuessBaseName) == 0 && astNodeIdValid(base) &&
       (nodeKind(base) == nkHiddenDeref || nodeKind(base) == nkDerefExpr) && kidCount(base) > 0:
        seqGuessBaseName = backendStripSpaces(plainName(kid(base, 0)))
    if len(fieldName) == 0 && seqLikeObj:
        fieldName = uirCoreGuessSeqBuiltinFieldFromSource(b.func, dotNode, seqGuessBaseName)
    let seqFieldName: str = uirCoreSeqBuiltinFieldName(fieldName)
    if seqLikeObj && (seqFieldName == "len" || seqFieldName == "cap" || seqFieldName == "buffer"):
        return seqFieldName
    if fieldName == "data" && ot.name == "seq":
        return "buffer"
    return fieldName

fn uirCoreMakeDotAccessRaw(basePtr: UirExprId, fieldTy: UirCoreType,
                           objTypeName: str, offset: int32): DotAccess =
    var addr: UirExprId = basePtr
    if offset != 0:
        addr = uirCoreBin(mbAdd, basePtr, uirCoreConstI64(int64(offset)))
    var da: DotAccess
    da.addr = addr
    da.fieldTy = fieldTy
    da.objTypeName = objTypeName
    return da

fn uirCoreMakeDotAccessForField(module: UirCoreModule, ot: UirCoreObjType, basePtr: UirExprId,
                                fieldTy: UirCoreType, fieldName: str, offset: int32): DotAccess =
    return uirCoreMakeDotAccessRaw(basePtr, fieldTy,
                                   inferInlineObjFieldTypeName(module, ot, fieldName, offset),
                                   offset)

fn uirCoreObjFieldIndexByName(ot: UirCoreObjType, fieldName: str): int32 =
    for fi in 0..<ot.fields.len:
        let f: UirCoreObjField = ot.fields[fi]
        if f.name == fieldName:
            return fi
    return -1

fn uirCoreTupleAliasFieldIndex(base: Node, objTypeName: str, fieldName: str): int32 =
    var ti: int32 = uirCoreTupleFieldIndexGet(objTypeName, fieldName)
    if ti >= 0 || ti == -2:
        return ti
    if astNodeIdValid(base) && nodeTypeCacheValid(base) && astRefNonNil(nodeTypeCache(base)):
        var tc: Node = nodeTypeCache(base)
        while astNodeIdValid(tc) && nodeKind(tc) == nkPar && kidCount(tc) > 0:
            tc = kid(tc, 0)
        if astNodeIdValid(tc) && nodeKind(tc) == nkVarTy && kidCount(tc) > 0:
            tc = kid(tc, 0)
        if (tc != nil) && (nodeKind(tc) == nkRefTy || nodeKind(tc) == nkPtrTy) && kidCount(tc) > 0:
            tc = kid(tc, 0)
        if astNodeIdValid(tc) && nodeKind(tc) == nkTupleTy:
            for tj in 0..<kidCount(tc):
                let elem: Node = kid(tc, tj)
                if astNodeIdValid(elem) && nodeKind(elem) == nkIdentDefs && kidCount(elem) > 0:
                    let nameNode: Node = kid(elem, 0)
                    if (nameNode != nil) && (nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol):
                        let lbl: str = backendStripSpaces(plainName(nameNode))
                        if len(lbl) > 0 && (lbl == fieldName):
                            uirCoreTupleFieldIndexPut(objTypeName, fieldName, tj)
                            return tj
    return ti

fn uirCoreObjInlineFieldBaseOffset(ot: UirCoreObjType, fieldName: str): int32 =
    let fieldLenPrefix: int32 = len(fieldName)
    var prefix: str = ""
    if fieldLenPrefix > 0:
        let prefixAlloc: str = newStringAlloc(fieldLenPrefix + 1)
        let prefixPtr: ptr = rawmemAsVoid(prefixAlloc)
        if prefixPtr != nil:
            rawmem_support.rawmemCopy(prefixPtr, rawmemAsVoid(fieldName), fieldLenPrefix)
            rawmemWriteChar(rawmem_support.rawmemPtrAdd(prefixPtr, fieldLenPrefix), '.')
            prefix = prefixAlloc
    var baseOff: int32 = -1
    for fj in 0..<ot.fields.len:
        let f2: UirCoreObjField = ot.fields[fj]
        if uirCoreStrStartsWith(f2.name, prefix):
            if baseOff < 0 || f2.offset < baseOff:
                baseOff = f2.offset
    return baseOff

fn uirCoreDebugDotFail(b: BlockBuilder, base: Node, baseName: str, objTypeName: str,
                       basePtrRes: Result[UirExprId]) =
    var bKind2: int32 = -1
    if (base != nil):
        bKind2 = int32(nodeKind(base))
    let okPtr: bool = IsOk[UirExprId](basePtrRes)
    let okPtrStr: str = okPtr ? "1" : "0"
    let modNil: str = ((b == nil) || b.module == nil) ? "1" : "0"
    echo("[backend] debugDot: dotFail objTypeName='" + objTypeName + "' baseKind=nk#" +
        intToStr(bKind2) + " basePtrOk=" + okPtrStr + " moduleNil=" + modNil)
    if len(baseName) > 0 && (b != nil) && b.env != nil:
        let dbgSlot: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, baseName)
        var dbgMsgParts: str[]
        add(dbgMsgParts, "[backend] debugDot: baseName='")
        add(dbgMsgParts, baseName)
        add(dbgMsgParts, "' slot=")
        add(dbgMsgParts, intToStr(dbgSlot))
        if dbgSlot >= 0 && uirCoreFuncIdValid(b.func):
            let fObj: str = funcObjTypeName(b.func, dbgSlot)
            let fKey: str = funcObjTypeKey(b.func, dbgSlot)
            let lKey: str = localTypeKey(b.env, dbgSlot)
            let lKey0: str = uirCoreStripRefVarKeyOnce(lKey)
            add(dbgMsgParts, " funcObjTypeName='")
            add(dbgMsgParts, fObj)
            add(dbgMsgParts, "' funcObjTypeKey='")
            add(dbgMsgParts, fKey)
            add(dbgMsgParts, "' localTypeKey='")
            add(dbgMsgParts, lKey)
            add(dbgMsgParts, "' localTypeKeyStrip='")
            add(dbgMsgParts, lKey0)
            add(dbgMsgParts, "'")
            let hasObj: bool = len(lKey0) > 0 && uirCoreHasObjType(b.module, lKey0)
            add(dbgMsgParts, " hasObj=")
            add(dbgMsgParts, hasObj ? "1" : "0")
            if !hasObj && b.module != nil && len(lKey0) > 0:
                let modDbg: UirCoreModule = b.module
                let objsDbg: UirCoreObjType[] = modDbg.objTypes
                let pref0: str = lKey0 + "_"
                var shown0: int32 = 0
                for oi0 in 0..<objsDbg.len:
                    let ot0: UirCoreObjType = objsDbg[oi0]
                    if len(ot0.name) == 0:
                        continue
                    if ot0.name == lKey0 || uirCoreStrStartsWith(ot0.name, pref0):
                        echo("[backend] debugDot: localKeyCandidate key='" + lKey0 +
                             "' cand='" + ot0.name + "'")
                        shown0 = shown0 + 1
                        if shown0 >= 6:
                            break
        echo fmt(dbgMsgParts)
        let altName: str = baseName + "Res"
        let altSlot: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, altName)
        if altSlot >= 0:
            let altKey: str = localTypeKey(b.env, altSlot)
            echo("[backend] debugDot: altName='" + altName + "' slot=" + intToStr(altSlot) +
                 " localTypeKey='" + altKey + "'")
    if astNodeIdValid(base) && nodeTypeCacheValid(base) && astRefNonNil(nodeTypeCache(base)):
        let tc: Node = nodeTypeCache(base)
        let tcKind2: str = intToStr(int32(nodeKind(tc)))
        let tcName: str = backendStripSpaces(plainName(tc))
        let tcKey: str = typeKey(tc)
        let tcObj: str = typeNodeObjTypeName(b.module, tc)
        echo("[backend] debugDot: nodeTypeCache(base) kind=nk#" + tcKind2 + " name='" + tcName +
            "' key='" + tcKey + "' objTypeName='" + tcObj + "'")
    if !okPtr:
        echo("[backend] debugDot: dotFail basePtrErr=" + Error(basePtrRes))

fn uirCoreTryResolveDotBaseFromLocal(b: BlockBuilder, base: Node, baseName: var str,
                                     objTypeName: var str, basePtrRes: var Result[UirExprId]) =
    if (base == nil) || !((nodeKind(base) == nkIdent) || (nodeKind(base) == nkSymbol)):
        return
    baseName = backendStripSpaces(plainName(base))
    let slot: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, baseName)
    uirCoreMarkImplicitResultUse(b, baseName, slot)
    if slot < 0:
        return
    objTypeName = funcObjTypeName(b.func, slot)
    if len(objTypeName) > 0:
        basePtrRes = Ok[UirExprId](uirCoreLocal(slot))
        return
    let key: str = localTypeKey(b.env, slot)
    let objFromKey0: str = uirCoreDotObjTypeNameFromKey(b.module, key)
    if len(objFromKey0) > 0:
        objTypeName = objFromKey0
        basePtrRes = Ok[UirExprId](uirCoreLocal(slot))

fn uirCoreResolveDotBaseFallback(b: BlockBuilder, base: Node, dotNode: Node, baseName: str,
                                 debugDot: bool, objTypeName: var str, basePtrRes: var Result[UirExprId]) =
    if astNodeIdValid(base) && nodeKind(base) == nkBracketExpr && kidCount(base) == 2:
        let bracketObjTypeName: str = uirCoreDotResolveBracketBaseObjTypeName(b, base, dotNode, debugDot)
        if len(bracketObjTypeName) > 0:
            objTypeName = bracketObjTypeName
    if len(objTypeName) == 0 && len(baseName) > 0:
        let gObj: str = uirCoreResolveGlobalObjTypeName(b, baseName)
        if len(gObj) > 0:
            objTypeName = gObj
    var da0: DotAccess
    let dotBaseRes: Result[bool] = uirCoreTryLowerDotAccess(b, base, &da0)
    if IsOk[bool](dotBaseRes) && Value[bool](dotBaseRes):
        if len(da0.objTypeName) > 0:
            objTypeName = da0.objTypeName
            basePtrRes = Ok[UirExprId](da0.addr)
        elif da0.fieldTy.kind == mtVoid:
            basePtrRes = Ok[UirExprId](da0.addr)
    if astNodeIdValid(base) && nodeTypeCacheValid(base) && astRefNonNil(nodeTypeCache(base)):
        let cachedObjTypeName: str = typeNodeObjTypeName(b.module, nodeTypeCache(base))
        if len(cachedObjTypeName) > 0:
            objTypeName = cachedObjTypeName
    if len(objTypeName) == 0 && astNodeIdValid(base) && nodeKind(base) == nkCall && b.module != nil:
        objTypeName = uirCoreDotResolveCallBaseObjTypeName(b, base, debugDot)
    if len(objTypeName) == 0 && (base != nil) &&
       (nodeKind(base) == nkHiddenDeref || nodeKind(base) == nkDerefExpr) && kidCount(base) > 0:
        objTypeName = uirCoreDotResolveHiddenDerefBaseObjTypeName(b, base)
    if !IsOk[UirExprId](basePtrRes):
        basePtrRes = lowerExprValue(b, base, uirCoreTypeI64())

fn uirCoreDotResolveSeqBaseObjTypeName(module: UirCoreModule, baseKey0: str): str =
    if module == nil:
        return ""
    let seqKey0: str = backendStripSpaces(baseKey0)
    if (uirCoreStrStartsWith(seqKey0, "seq_") || uirCoreStrStartsWith(seqKey0, "seq_fixed_")) &&
       uirCoreHasObjType(module, "seq"):
        return "seq"
    return ""

fn uirCoreResolveDotFieldAccess(module: UirCoreModule, base: Node, objTypeName: str,
                                ot: UirCoreObjType, basePtr: UirExprId,
                                fieldName: str): Result[DotAccess] =
    let fieldIdx: int32 = uirCoreObjFieldIndexByName(ot, fieldName)
    if fieldIdx >= 0:
        let f: UirCoreObjField = ot.fields[fieldIdx]
        return Ok[DotAccess](uirCoreMakeDotAccessForField(module, ot, basePtr, f.ty, fieldName, f.offset))
    if ((objTypeName == "tuple") || uirCoreStrStartsWith(objTypeName, "tuple_")):
        let ti: int32 = uirCoreTupleAliasFieldIndex(base, objTypeName, fieldName)
        if ti == -2:
            return Err[DotAccess]("uirCore_builder: ambiguous tuple field")
        if ti >= 0:
            let altFieldName: str = uirCoreIndexedName("f", ti)
            let altIdx: int32 = uirCoreObjFieldIndexByName(ot, altFieldName)
            if altIdx >= 0:
                let f2: UirCoreObjField = ot.fields[altIdx]
                return Ok[DotAccess](uirCoreMakeDotAccessRaw(basePtr, f2.ty, "", f2.offset))
    let baseOff: int32 = uirCoreObjInlineFieldBaseOffset(ot, fieldName)
    if baseOff >= 0:
        return Ok[DotAccess](uirCoreMakeDotAccessRaw(basePtr, uirCoreTypeVoid(),
                                                     inferInlineObjFieldTypeName(module, ot, fieldName, baseOff),
                                                     baseOff))
    return Err[DotAccess]("uirCore_builder: unknown object field")

fn uirCoreTryLowerDotAccess(b: BlockBuilder, node0: Node, out: ptr): Result[bool] =
    if out == nil:
        return Ok[bool](false)
    var node: Node = node0
    while astNodeIdValid(node) && nodeKind(node) == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if !astNodeIdValid(node) || nodeKind(node) != nkDotExpr:
        return Ok[bool](false)
    let daRes: Result[DotAccess] = lowerDotAccess(b, node)
    if !IsOk[DotAccess](daRes):
        return ErrInfo[bool](ErrorInfoOf[DotAccess](daRes))
    store(out, Value[DotAccess](daRes))
    return Ok[bool](true)

fn lowerDotAccess(b: BlockBuilder, dotNode: Node): Result[DotAccess] =
    if (b == nil) || !astNodeIdValid(dotNode) || nodeKind(dotNode) != nkDotExpr || kidCount(dotNode) < 2:
        return Err[DotAccess]("uirCore_builder: invalid dot expr")
    let debugDot: bool = (getEnv "BACKEND_DEBUG_DOT" == "1")
    var base: Node = kid(dotNode, 0)
    let field: Node = kid(dotNode, 1)
    while astNodeIdValid(base) && nodeKind(base) == nkPar && kidCount(base) > 0:
        base = kid(base, 0)
    if (field == nil) || (nodeKind(field) != nkIdent && nodeKind(field) != nkSymbol):
        return Err[DotAccess]("uirCore_builder: dot field expects identifier")
    var basePtrRes: Result[UirExprId]
    var baseName: str = ""
    var objTypeName: str = ""
    uirCoreTryResolveDotBaseFromLocal(b, base, baseName, objTypeName, basePtrRes)
    if len(objTypeName) == 0:
        uirCoreResolveDotBaseFallback(b, base, dotNode, baseName, debugDot, objTypeName, basePtrRes)
    if len(objTypeName) == 0 && b.module != nil:
        objTypeName = uirCoreDotResolveSeqBaseObjTypeName(b.module, exprTypeKeyShallow(b, base))
    if len(objTypeName) == 0 || ! IsOk[UirExprId](basePtrRes):
        if debugDot:
            uirCoreDebugDotFail(b, base, baseName, objTypeName, basePtrRes)
        return Err[DotAccess]("uirCore_builder: dot base is not an object/ref")
    let basePtr: UirExprId = Value[UirExprId](basePtrRes)
    let ot: UirCoreObjType = uirCoreGetObjType(b.module, objTypeName)
    if len(ot.name) == 0:
        return Err[DotAccess]("uirCore_builder: unknown object type")
    let fieldName: str = uirCoreNormalizeDotFieldName(b, dotNode, base, baseName, objTypeName, ot, field)
    let daRes0: Result[DotAccess] = uirCoreResolveDotFieldAccess(b.module, base, objTypeName, ot, basePtr, fieldName)
    if !IsOk[DotAccess](daRes0):
        return ErrInfo[DotAccess](ErrorInfoOf[DotAccess](daRes0))
    var da0: DotAccess = Value[DotAccess](daRes0)
    if da0.fieldTy.kind == mtVoid && len(da0.objTypeName) == 0:
        if nodeTypeCacheValid(dotNode) && astRefNonNil(nodeTypeCache(dotNode)):
            let dotObj0: str = typeNodeObjTypeName(b.module, nodeTypeCache(dotNode))
            if len(dotObj0) > 0:
                da0.objTypeName = dotObj0
        if len(da0.objTypeName) == 0:
            var dotKey0: str = caseInferExprTypeKey(b, dotNode)
            if len(dotKey0) == 0:
                dotKey0 = exprTypeKeyShallow(b, dotNode)
            if len(dotKey0) > 0:
                let dotObj1: str = uirCoreObjTypeFromTypeKey(b.module, dotKey0)
                if len(dotObj1) > 0:
                    da0.objTypeName = dotObj1
    return Ok[DotAccess](da0)

fn uirCoreCallEffectiveArgCount(argNodes: Node[]): int32 =
    var n: int32 = 0
    for i in 0..<argNodes.len:
        let arg: Node = argNodes[i]
        if astNodeIdValid(arg) && nodeKind(arg) != nkEmpty:
            n = n + 1
    return n

fn uirCoreCallNodeEffectiveArgCount(callNode: Node): int32 =
    if !astNodeIdValid(callNode) || nodeKind(callNode) != nkCall:
        return 0
    var n: int32 = 0
    for i in 1..<kidCount(callNode):
        var arg: Node = kid(callNode, i)
        if astNodeIdValid(arg) && nodeKind(arg) == nkCallArg:
            if kidCount(arg) > 1:
                arg = kid(arg, 1)
            elif kidCount(arg) > 0:
                arg = kid(arg, 0)
        if astNodeIdValid(arg) && nodeKind(arg) != nkEmpty:
            n = n + 1
    return n

fn lowerCallWithLeadingArg(b: BlockBuilder, callNode: Node, lead: UirExprId): Result[UirExprId] =
    if (b == nil) || !astNodeIdValid(callNode) || nodeKind(callNode) != nkCall || kidCount(callNode) == 0:
        return Err[UirExprId]("uirCore_builder: expected call")
    let calleeNode: Node = kid(callNode, 0)
    if (calleeNode == nil):
        return Err[UirExprId]("uirCore_builder: call expects callee")
    var typeArgs: Node[]
    var name: str = uirCoreResolveCalleeNameAndTypeArgs(calleeNode, &typeArgs)
    if len(name) == 0:
        if nodeKind(calleeNode) != nkIdent && nodeKind(calleeNode) != nkSymbol:
            var fnName: str = ""
            var fp: str = ""
            if uirCoreFuncIdValid(b.func):
                let f0: UirCoreFunc = b.func
                fnName = uirCoreFuncNameOf(f0)
                fp = uirCoreFuncOriginFileOf(f0)
            let line: str = intToStr(nodePosLine(callNode))
            let col: str = intToStr(nodePosCol(callNode))
            let k: str = intToStr(int32(nodeKind(calleeNode)))
            return Err[UirExprId]("uirCore_builder: call expects identifier callee (kind=nk#" + k +
                                 " fn=" + fnName + " " + fp + ":" + line + ":" + col + ")")
        name = backendStripSpaces(plainName(calleeNode))
    let localCalleeIdx: int32 = localIndex(b.env, name)
    if localCalleeIdx >= 0:
        let target: str = localCallTarget(b.env, localCalleeIdx)
        if len(target) > 0:
            name = target

    var valueNodes: Node[]
    for ai in 1..<kidCount(callNode):
        let raw: Node = kid(callNode, ai)
        astNodeSeqAppend(valueNodes, raw)

    if name == "Value" && valueNodes.len == 1 && b.module != nil:
        var srcNode0: Node = valueNodes[0]
        if astNodeIdValid(srcNode0) && nodeKind(srcNode0) == nkCallArg:
            if kidCount(srcNode0) > 1:
                srcNode0 = kid(srcNode0, 1)
            elif kidCount(srcNode0) > 0:
                srcNode0 = kid(srcNode0, 0)
        if (srcNode0 != nil):
            let srcRes0: Result[UirExprId] = lowerExprValue(b, srcNode0, uirCoreTypeI64())
            if IsOk[UirExprId](srcRes0):
                var srcPtr0: UirExprId = Value[UirExprId](srcRes0)
                var srcKey0: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, srcNode0))
                if uirCoreStrStartsWith(srcKey0, "ptr_"):
                    srcKey0 = str(rawmemPtrAdd(rawmemAsVoid(srcKey0), 4))
                var valueOff0: int32 = -1
                let srcObj0: str = uirCoreObjTypeFromTypeKey(b.module, srcKey0)
                if len(srcObj0) > 0 && uirCoreHasObjType(b.module, srcObj0):
                    let srcOt0: UirCoreObjType = uirCoreGetObjType(b.module, srcObj0)
                    for sfi in 0..<srcOt0.fields.len:
                        let sf0: UirCoreObjField = srcOt0.fields[sfi]
                        if (sf0.name == "value") || uirCoreStrStartsWith(sf0.name, "value."):
                            if valueOff0 < 0 || sf0.offset < valueOff0:
                                valueOff0 = sf0.offset
                if valueOff0 < 0 && uirCoreStrStartsWith(srcKey0, "Result_"):
                    valueOff0 = 0
                if valueOff0 > 0:
                    srcPtr0 = uirCoreBin(mbAdd, srcPtr0, uirCoreConstI64(int64(valueOff0)))
                var dstObj0: str = ""
                if nodeTypeCacheValid(callNode) && astRefNonNil(nodeTypeCache(callNode)):
                    dstObj0 = typeNodeObjTypeName(b.module, nodeTypeCache(callNode))
                if (len(dstObj0) == 0) && (b != nil) && uirCoreFuncIdValid(b.func) &&
                   (lead != nil) && uirCoreExprKindOf(lead) == meLocal:
                    let leadSlot0: int32 = uirCoreExprLocalIndexOf(lead)
                    if leadSlot0 >= 0 && funcFindObjLocal(b.func, leadSlot0) >= 0:
                        dstObj0 = funcObjTypeName(b.func, leadSlot0)
                if len(dstObj0) > 0:
                    let copyRes0: Result[bool] = emitObjCopyPtrs(b, lead, dstObj0, srcPtr0)
                    if !uirCoreResultBoolIsOk(copyRes0):
                        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes0))
                    if getEnv "BACKEND_DEBUG_VALUE_LOWER" == "1":
                        var fnDbg1: str = ""
                        if (b != nil) && uirCoreFuncIdValid(b.func):
                            let fDbg1: UirCoreFunc = b.func
                            fnDbg1 = uirCoreFuncNameOf(fDbg1)
                        echo("[backend] debugValueLower: fn=" + fnDbg1 + " dstObj=" + dstObj0)
                    return Ok[UirExprId](lead)

    if name == "ErrorInfoOf" && valueNodes.len == 1 && b.module != nil:
        var srcNode1: Node = valueNodes[0]
        if astNodeIdValid(srcNode1) && nodeKind(srcNode1) == nkCallArg:
            if kidCount(srcNode1) > 1:
                srcNode1 = kid(srcNode1, 1)
            elif kidCount(srcNode1) > 0:
                srcNode1 = kid(srcNode1, 0)
        if (srcNode1 != nil):
            let srcRes1: Result[UirExprId] = lowerExprValue(b, srcNode1, uirCoreTypeI64())
            if IsOk[UirExprId](srcRes1):
                var srcPtr1: UirExprId = Value[UirExprId](srcRes1)
                var srcKey1: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, srcNode1))
                if uirCoreStrStartsWith(srcKey1, "ptr_"):
                    srcKey1 = str(rawmemPtrAdd(rawmemAsVoid(srcKey1), 4))
                var errOff1: int32 = -1
                let srcObj1: str = uirCoreObjTypeFromTypeKey(b.module, srcKey1)
                if len(srcObj1) > 0 && uirCoreHasObjType(b.module, srcObj1):
                    let srcOt1: UirCoreObjType = uirCoreGetObjType(b.module, srcObj1)
                    for sfi1 in 0..<srcOt1.fields.len:
                        let sf1: UirCoreObjField = srcOt1.fields[sfi1]
                        if (sf1.name == "err") || uirCoreStrStartsWith(sf1.name, "err."):
                            if errOff1 < 0 || sf1.offset < errOff1:
                                errOff1 = sf1.offset
                if errOff1 > 0:
                    srcPtr1 = uirCoreBin(mbAdd, srcPtr1, uirCoreConstI64(int64(errOff1)))
                var dstObj1: str = ""
                if nodeTypeCacheValid(callNode) && astRefNonNil(nodeTypeCache(callNode)):
                    dstObj1 = typeNodeObjTypeName(b.module, nodeTypeCache(callNode))
                if (len(dstObj1) == 0) && (b != nil) && uirCoreFuncIdValid(b.func) &&
                   (lead != nil) && uirCoreExprKindOf(lead) == meLocal:
                    let leadSlot1: int32 = uirCoreExprLocalIndexOf(lead)
                    if leadSlot1 >= 0 && funcFindObjLocal(b.func, leadSlot1) >= 0:
                        dstObj1 = funcObjTypeName(b.func, leadSlot1)
                if (len(dstObj1) == 0) && uirCoreHasObjType(b.module, "ErrorInfo"):
                    dstObj1 = "ErrorInfo"
                if len(dstObj1) > 0:
                    let copyRes1: Result[bool] = emitObjCopyPtrs(b, lead, dstObj1, srcPtr1)
                    if !uirCoreResultBoolIsOk(copyRes1):
                        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes1))
                    return Ok[UirExprId](lead)

    var callName: str = name
    if typeArgs.len > 0:
        callName = mangleInstance(name, typeArgs)
    let helperCallNameL: str = uirCoreStripLeadingUnderscores(callName)

    if uirCoreDictHelperClosureEnabled() && b.module != nil:
        if kidCount(callNode) == 2:
            var ctorKindL: int32 = 0
            var resultSuffixL: str = ""
            if uirCoreStrStartsWith(helperCallNameL, "Ok_"):
                ctorKindL = 1
                resultSuffixL = str(rawmemPtrAdd(rawmemAsVoid(helperCallNameL), 3))
            elif uirCoreStrStartsWith(helperCallNameL, "Err_"):
                ctorKindL = 2
                resultSuffixL = str(rawmemPtrAdd(rawmemAsVoid(helperCallNameL), 4))
            elif uirCoreStrStartsWith(helperCallNameL, "ErrInfo_"):
                ctorKindL = 3
                resultSuffixL = str(rawmemPtrAdd(rawmemAsVoid(helperCallNameL), 8))
            if ctorKindL <= 0:
                if helperCallNameL == "Ok":
                    ctorKindL = 1
                elif helperCallNameL == "Err":
                    ctorKindL = 2
                elif helperCallNameL == "ErrInfo":
                    ctorKindL = 3
                if ctorKindL > 0:
                    resultSuffixL = uirCoreInferCtorSuffixFromTypeCache(b, callNode, "Result_")
            if ctorKindL > 0 && len(resultSuffixL) > 0:
                let resultObjNameL: str = "Result_" + resultSuffixL
                if !uirCoreHasObjType(b.module, resultObjNameL):
                    let _ensResultL: bool = ensureResultObjType(b.module, resultObjNameL)
                if uirCoreHasObjType(b.module, resultObjNameL):
                    var payloadNodeL: Node = kid(callNode, 1)
                    if astNodeIdValid(payloadNodeL) && nodeKind(payloadNodeL) == nkCallArg:
                        if kidCount(payloadNodeL) > 1:
                            payloadNodeL = kid(payloadNodeL, 1)
                        elif kidCount(payloadNodeL) > 0:
                            payloadNodeL = kid(payloadNodeL, 0)
                    var payloadExprL: Node = payloadNodeL
                    if ctorKindL == 2:
                        var errCtorL: Node = newNode(nkCall, nodePos(callNode))
                        addSon(errCtorL, newIdent("ErrorInfo", nodePos(callNode)))
                        var errCodeArgL: Node = newNode(nkCallArg, nodePos(callNode))
                        addSon(errCodeArgL, newIdent("code", nodePos(callNode)))
                        addSon(errCodeArgL, newIntLit(0, nodePos(callNode)))
                        addSon(errCtorL, errCodeArgL)
                        var errMsgArgL: Node = newNode(nkCallArg, nodePos(callNode))
                        addSon(errMsgArgL, newIdent("msg", nodePos(callNode)))
                        addSon(errMsgArgL, payloadNodeL)
                        addSon(errCtorL, errMsgArgL)
                        payloadExprL = errCtorL

                    var ctorCallL: Node = newNode(nkCall, nodePos(callNode))
                    addSon(ctorCallL, newIdent(resultObjNameL, nodePos(callNode)))
                    var okArgL: Node = newNode(nkCallArg, nodePos(callNode))
                    addSon(okArgL, newIdent("ok", nodePos(callNode)))
                    if ctorKindL == 1:
                        addSon(okArgL, newBoolLit(true, nodePos(callNode)))
                    else:
                        addSon(okArgL, newBoolLit(false, nodePos(callNode)))
                    addSon(ctorCallL, okArgL)
                    var payloadArgL: Node = newNode(nkCallArg, nodePos(callNode))
                    if ctorKindL == 1:
                        addSon(payloadArgL, newIdent("value", nodePos(callNode)))
                    else:
                        addSon(payloadArgL, newIdent("err", nodePos(callNode)))
                    addSon(payloadArgL, payloadExprL)
                    addSon(ctorCallL, payloadArgL)
                    let ctorResL: Result[UirExprId] = lowerObjConstructorCall(b, ctorCallL, resultObjNameL)
                    if !IsOk[UirExprId](ctorResL):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](ctorResL))
                    let copyResL: Result[bool] = emitObjCopyPtrs(b, lead, resultObjNameL, Value[UirExprId](ctorResL))
                    if !uirCoreResultBoolIsOk(copyResL):
                        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyResL))
                    return Ok[UirExprId](lead)

        var optionCtorKindL: int32 = 0
        var optionSuffixL: str = ""
        if kidCount(callNode) == 2 && uirCoreStrStartsWith(helperCallNameL, "Some_"):
            optionCtorKindL = 1
            optionSuffixL = str(rawmemPtrAdd(rawmemAsVoid(helperCallNameL), 5))
        elif kidCount(callNode) == 1 && uirCoreStrStartsWith(helperCallNameL, "None_"):
            optionCtorKindL = 2
            optionSuffixL = str(rawmemPtrAdd(rawmemAsVoid(helperCallNameL), 5))
        if optionCtorKindL <= 0:
            if kidCount(callNode) == 2 && helperCallNameL == "Some":
                optionCtorKindL = 1
                optionSuffixL = uirCoreInferCtorSuffixFromTypeCache(b, callNode, "Option_")
            elif kidCount(callNode) == 1 && helperCallNameL == "None":
                optionCtorKindL = 2
                optionSuffixL = uirCoreInferCtorSuffixFromTypeCache(b, callNode, "Option_")
        if optionCtorKindL > 0 && len(optionSuffixL) > 0:
            let optionObjNameL: str = "Option_" + optionSuffixL
            if !uirCoreHasObjType(b.module, optionObjNameL):
                let _ensOptionL: bool = ensureOptionObjType(b.module, optionObjNameL)
            if uirCoreHasObjType(b.module, optionObjNameL):
                var ctorCallOptL: Node = newNode(nkCall, nodePos(callNode))
                addSon(ctorCallOptL, newIdent(optionObjNameL, nodePos(callNode)))
                var hasArgOptL: Node = newNode(nkCallArg, nodePos(callNode))
                addSon(hasArgOptL, newIdent("has", nodePos(callNode)))
                addSon(hasArgOptL, newBoolLit(optionCtorKindL == 1, nodePos(callNode)))
                addSon(ctorCallOptL, hasArgOptL)
                if optionCtorKindL == 1:
                    var payloadNodeOptL: Node = kid(callNode, 1)
                    if astNodeIdValid(payloadNodeOptL) && nodeKind(payloadNodeOptL) == nkCallArg:
                        if kidCount(payloadNodeOptL) > 1:
                            payloadNodeOptL = kid(payloadNodeOptL, 1)
                        elif kidCount(payloadNodeOptL) > 0:
                            payloadNodeOptL = kid(payloadNodeOptL, 0)
                    var payloadArgOptL: Node = newNode(nkCallArg, nodePos(callNode))
                    addSon(payloadArgOptL, newIdent("value", nodePos(callNode)))
                    addSon(payloadArgOptL, payloadNodeOptL)
                    addSon(ctorCallOptL, payloadArgOptL)
                let ctorResOptL: Result[UirExprId] = lowerObjConstructorCall(b, ctorCallOptL, optionObjNameL)
                if !IsOk[UirExprId](ctorResOptL):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](ctorResOptL))
                let copyResOptL: Result[bool] = emitObjCopyPtrs(b, lead, optionObjNameL, Value[UirExprId](ctorResOptL))
                if !uirCoreResultBoolIsOk(copyResOptL):
                    return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyResOptL))
                return Ok[UirExprId](lead)

    if b.module != nil && uirCoreHasObjType(b.module, callName):
        var hasNamedArgs: bool = false
        for ni in 0..<valueNodes.len:
            let an: Node = valueNodes[ni]
            if astNodeIdValid(an) && nodeKind(an) == nkCallArg:
                hasNamedArgs = true
                break

        if hasNamedArgs:
            let initRes: Result[bool] = emitObjDefaultInitPtrs(b, lead, callName)
            if !uirCoreResultBoolIsOk(initRes):
                return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes))
            let ot: UirCoreObjType = uirCoreGetObjType(b.module, callName)
            for vi in 0..<valueNodes.len:
                let arg0: Node = valueNodes[vi]
                if !astNodeIdValid(arg0) || nodeKind(arg0) != nkCallArg || kidCount(arg0) < 2:
                    return Err[UirExprId]("uirCore_builder: object constructor expects named args")
                let keyNode: Node = kid(arg0, 0)
                let valNode: Node = kid(arg0, 1)
                if (keyNode == nil) || (nodeKind(keyNode) != nkIdent && nodeKind(keyNode) != nkSymbol):
                    return Err[UirExprId]("uirCore_builder: object constructor field expects identifier")
                let fieldName: str = backendStripSpaces(plainName(keyNode))

                var found: bool = false
                var field: UirCoreObjField
                for fi in 0..<ot.fields.len:
                    let f: UirCoreObjField = ot.fields[fi]
                    if (f.name == fieldName):
                        field = f
                        found = true
                        break
                if found:
                    var addr: UirExprId = lead
                    if field.offset != 0:
                        addr = uirCoreBin(mbAdd, lead, uirCoreConstI64(int64(field.offset)))
                    let valRes: Result[UirExprId] = lowerExprValue(b, valNode, field.ty)
                    if !IsOk[UirExprId](valRes):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes))
                    blockBuilderAddStmt(b, uirCoreStmtStore(addr, Value[UirExprId](valRes), field.ty))
                    continue

                let prefix: str = uirCoreAppendChar(fieldName, '.')
                var hasPrefix: bool = false
                var minOff: int32 = 2147483647
                for fi2 in 0..<ot.fields.len:
                    let f2: UirCoreObjField = ot.fields[fi2]
                    if uirCoreStrStartsWith(f2.name, prefix):
                        hasPrefix = true
                        if f2.offset < minOff:
                            minOff = f2.offset
                if !hasPrefix:
                    let line: str = intToStr(nodePosLine(keyNode))
                    let col: str = intToStr(nodePosCol(keyNode))
                    return Err[UirExprId]("uirCore_builder: unknown object constructor field: " + fieldName +
                                        " (" + callName + " @" + line + ":" + col + ")")

                var dstAddr: UirExprId = lead
                if minOff != 0:
                    dstAddr = uirCoreBin(mbAdd, lead, uirCoreConstI64(int64(minOff)))

                var objNm: str = inferInlineObjFieldTypeName(b.module, ot, fieldName, minOff)
                if len(objNm) == 0 && astNodeIdValid(valNode) && nodeTypeCacheValid(valNode) && astRefNonNil(nodeTypeCache(valNode)):
                    objNm = typeNodeObjTypeName(b.module, nodeTypeCache(valNode))
                if len(objNm) == 0 && (valNode != nil) && (nodeKind(valNode) == nkIdent || nodeKind(valNode) == nkSymbol):
                    let srcSlot: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, plainName(valNode))
                    if srcSlot >= 0:
                        objNm = funcObjTypeName(b.func, srcSlot)
                if len(objNm) == 0 && (valNode != nil) && (b != nil) && b.module != nil:
                    let key3: str = caseInferExprTypeKey(b, valNode)
                    if len(key3) > 0:
                        let tn3: Node = newIdent(key3, nodePos(valNode))
                        objNm = typeNodeObjTypeName(b.module, tn3)
                    if (getEnv "BACKEND_DEBUG_NESTED_CTOR" == "1") && (callName == "GossipsubContext") && (fieldName == "params"):
                        let canon3: str = uirCoreObjAliasCanon(key3)
                        let canonOk: str = (len(canon3) > 0) ? canon3 : ""
                        echo("[backend] debugNestedCtorLead: ctor=" + callName + " field=" + fieldName +
                             " key3='" + key3 + "' canon='" + canonOk + "' objNm='" + objNm + "'" +
                             " aliasReady=" + (uirCoreObjAliasReadyFlag() ? "1" : "0"))
                if len(objNm) == 0:
                    let line3: str = ((valNode != nil)) ? intToStr(nodePosLine(valNode)) : "0"
                    let col3: str = ((valNode != nil)) ? intToStr(nodePosCol(valNode)) : "0"
                    let k3: str = ((valNode != nil)) ? intToStr(int32(nodeKind(valNode))) : "0"
                    var fnName3: str = ""
                    var fp3: str = ""
                    if (b != nil) && uirCoreFuncIdValid(b.func):
                        let f3: UirCoreFunc = b.func
                        fnName3 = uirCoreFuncNameOf(f3)
                        fp3 = uirCoreFuncOriginFileOf(f3)
                    return Err[UirExprId]("uirCore_builder: object constructor nested field expects object value" +
                                        " (ctor=" + callName + " field=" + fieldName + " valKind=nk#" + k3 +
                                        " fn=" + fnName3 + " " + fp3 + ":" + line3 + ":" + col3 + ")")

                let srcRes: Result[UirExprId] = lowerExprValue(b, valNode, uirCoreTypeI64())
                if !IsOk[UirExprId](srcRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](srcRes))
                let copyRes: Result[bool] = emitObjCopyPtrs(b, dstAddr, objNm, Value[UirExprId](srcRes))
                if !uirCoreResultBoolIsOk(copyRes):
                    return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes))
            return Ok[UirExprId](lead)

        let ot2: UirCoreObjType = uirCoreGetObjType(b.module, callName)
        let argCount: int32 = valueNodes.len
        if argCount == 0:
            let initRes2: Result[bool] = emitObjDefaultInitPtrs(b, lead, callName)
            if !uirCoreResultBoolIsOk(initRes2):
                return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes2))
            return Ok[UirExprId](lead)
        if argCount == ot2.fields.len + 1:
            return lowerObjConstructorCallPositional(b, callNode, callName)
        if argCount > ot2.fields.len:
            let line0: str = intToStr(nodePosLine(callNode))
            let col0: str = intToStr(nodePosCol(callNode))
            var fnName0: str = ""
            var fp0: str = ""
            if (b != nil) && uirCoreFuncIdValid(b.func):
                let bf0: UirCoreFunc = b.func
                fnName0 = uirCoreFuncNameOf(bf0)
                fp0 = uirCoreFuncOriginFileOf(bf0)
            return Err[UirExprId]("uirCore_builder: object constructor '" + callName + "' expects all fields" +
                                " (argc=" + intToStr(argCount) + " fields=" + intToStr(ot2.fields.len) +
