                    if astNodeIdValid(elem) && nodeKind(elem) == nkIdentDefs && kidCount(elem) > 0:
                        let nameNode: Node = kid(elem, 0)
                        if (nameNode != nil) && (nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol):
                            let lbl: str = backendStripSpaces(plainName(nameNode))
                            if len(lbl) > 0 && (lbl == fieldName):
