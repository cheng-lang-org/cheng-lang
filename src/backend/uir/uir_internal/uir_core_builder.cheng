                        if name == "ErrorInfoOf" && hasErr:
                            let dotNode1: Node = newNode(astNodeKindDotExpr(), nodePos(node))
                            addSon(dotNode1, arg0)
                            addSon(dotNode1, newIdent("err", nodePos(node)))
                            return lowerExprValue(b, dotNode1, wantType)
                        if name == "IsOk" && hasOk:
                            let dotNode2: Node = newNode(astNodeKindDotExpr(), nodePos(node))
                            addSon(dotNode2, arg0)
                            addSon(dotNode2, newIdent("ok", nodePos(node)))
                            return lowerExprValue(b, dotNode2, wantType)
                        if name == "IsErr" && hasOk:
                            let dotNode3: Node = newNode(astNodeKindDotExpr(), nodePos(node))
                            addSon(dotNode3, arg0)
                            addSon(dotNode3, newIdent("ok", nodePos(node)))
                            let notNode: Node = newNode(astNodeKindPrefix(), nodePos(node))
                            addSon(notNode, newIdent("!", nodePos(node)))
                            addSon(notNode, dotNode3)
                            return lowerExprValue(b, notNode, wantType)
                        if name == "Error" && hasErr:
                            let dotNode4: Node = newNode(astNodeKindDotExpr(), nodePos(node))
                            addSon(dotNode4, arg0)
                            addSon(dotNode4, newIdent("err", nodePos(node)))
                            if moduleHasFuncByBase(blockBuilderModule(b), "ErrorMessage"):
                                let errCall0: Node = newNode(astNodeKindCall(), nodePos(node))
                                addSon(errCall0, newIdent("ErrorMessage", nodePos(node)))
                                addSon(errCall0, dotNode4)
                                return lowerExprValue(b, errCall0, wantType)
