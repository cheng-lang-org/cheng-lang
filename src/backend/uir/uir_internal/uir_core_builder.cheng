                    let retObjName: str = funcObjTypeName(calleeSig, pFirstSig.slot)
                    if len(retObjName) > 0:
                        let tmpName: str = blockBuilderNextTemp(b, "__callret")
                        let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
                        uirCoreSetLocalType(b.func, tmpSlot, uirCoreTypeI64())
                        let retKeySig: str = funcObjTypeKey(calleeSig, pFirstSig.slot)
                        if len(retKeySig) > 0:
                            localSetTypeKey(b.env, tmpSlot, retKeySig)
                            funcSetObjTypeKey(b.func, tmpSlot, retKeySig)
                        else:
                            localSetTypeKey(b.env, tmpSlot, retObjName)
                            funcSetObjTypeKey(b.func, tmpSlot, retObjName)
                        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, retObjName)
                        if ! uirCoreResultBoolIsOk(allocRes):
                            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
                        return lowerCallWithLeadingArg(b, node, uirCoreLocal(tmpSlot))

        # builtin: string operator-call sugar. Some stage1/mono paths rewrite `"a" + "b"`
        # to `+(a, b)` before backend lowering; handle it here so we never leak a raw
        # operator symbol callsite into MIR/codegen.
        if name == "+" && typeArgs.len == 0 && argNodes.len == 2:
            let lhsNode0: Node = argNodes[0]
            let rhsNode0: Node = argNodes[1]
            let lhsKey0: str = caseInferExprTypeKey(b, lhsNode0)
            let rhsKey0: str = caseInferExprTypeKey(b, rhsNode0)
            if uirCoreNodeHasStringCtx(lhsKey0, lhsNode0) || uirCoreNodeHasStringCtx(rhsKey0, rhsNode0):
                let lhsRes0: Result[UirExprId] = lowerExprValue(b, lhsNode0, uirCoreTypeI64())
                if !IsOk[UirExprId](lhsRes0):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](lhsRes0))
                let rhsRes0: Result[UirExprId] = lowerExprValue(b, rhsNode0, uirCoreTypeI64())
                if !IsOk[UirExprId](rhsRes0):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsRes0))
                var concatArgs0: UirExprId[]
                builderExprSeqAppend(concatArgs0, Value[UirExprId](lhsRes0))
                builderExprSeqAppend(concatArgs0, Value[UirExprId](rhsRes0))
                return Ok[UirExprId](uirCoreCall(uirCoreResolveStrConcatCallSymbol(b.module), concatArgs0))

        # builtin: len(x) for str/seq/Table (cannot rely on overload resolution because `len`
        # can also be user-defined for custom types).
        if name == "elemSize" && typeArgs.len == 1 && uirCoreCallEffectiveArgCount(argNodes) == 0:
            let szRes0: Result[int32] = uirCoreSizeOfTypeNode(b.module, typeArgs[0])
            if !IsOk[int32](szRes0):
                return ErrInfo[UirExprId](ErrorInfoOf[int32](szRes0))
            let sizeExpr0: UirExprId = uirCoreConstI64(int64(Value[int32](szRes0)))
            if wantType.kind != mtI64:
                return Ok[UirExprId](uirCoreCast(wantType, sizeExpr0))
            return Ok[UirExprId](sizeExpr0)

        if name == "len" && typeArgs.len == 0 && argNodes.len == 1:
            let arg0: Node = argNodes[0]
            var k0: str = caseInferExprTypeKey(b, arg0)
            if len(k0) == 0 && (arg0 != nil) && (nodeKind(arg0) == nkIdent || nodeKind(arg0) == nkSymbol):
                let nm0: str = plainName(arg0)
                let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm0)
                if slot0 >= 0 && uirCoreFuncIdValid(b.func):
                    let olIdx0: int32 = funcFindObjLocal(b.func, slot0)
                    if olIdx0 >= 0:
                        k0 = funcObjTypeName(b.func, slot0)
                    else:
                        let ty0: UirCoreType = localType(b.env, slot0)
                        if ty0.kind == mtI64:
                            k0 = "str"

            # str/cstring
            if uirCoreNodeHasStringCtx(k0, arg0):
                let valRes0: Result[UirExprId] = lowerExprValue(b, arg0, uirCoreTypeI64())
                if !IsOk[UirExprId](valRes0):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes0))
                let lenName0: str = blockBuilderNextTemp(b, "__len_str")
                let lenSlot0: int32 = localAdd(b.env, lenName0, uirCoreTypeI32())
                uirCoreSetLocalType(b.func, lenSlot0, uirCoreTypeI32())
                var args0: UirExprId[]
                builderExprSeqAppend(args0, Value[UirExprId](valRes0))
                blockBuilderAddStmt(b, uirCoreStmtLet(lenName0, lenSlot0, uirCoreCall("cheng_strlen", args0)))
                return Ok[UirExprId](uirCoreLocal(lenSlot0))

            # seq[T]
            if b.module != nil && uirCoreHasObjType(b.module, "seq") &&
               ((k0 == "seq") || uirCoreStrStartsWith(k0, "seq_") || uirCoreStrStartsWith(k0, "seq_fixed_")):
                let seqRes0: Result[UirExprId] = lowerExprValue(b, arg0, uirCoreTypeI64())
                if !IsOk[UirExprId](seqRes0):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](seqRes0))
                let seqName0: str = blockBuilderNextTemp(b, "__len_seq")
                let seqSlot0: int32 = localAdd(b.env, seqName0, uirCoreTypeI64())
                uirCoreSetLocalType(b.func, seqSlot0, uirCoreTypeI64())
                blockBuilderAddStmt(b, uirCoreStmtLet(seqName0, seqSlot0, Value[UirExprId](seqRes0)))
                let seqPtr0: UirExprId = uirCoreLocal(seqSlot0)

                let seqOt0: UirCoreObjType = uirCoreGetObjType(b.module, "seq")
                var lenOff0: int32 = -1
                for fi0 in 0..<seqOt0.fields.len:
                    let f0: UirCoreObjField = seqOt0.fields[fi0]
                    if (f0.name == "len"):
                        lenOff0 = f0.offset
                        break
                if lenOff0 < 0:
                    return Err[UirExprId]("uirCore_builder: seq layout mismatch")

                let lenAddr0: UirExprId = (lenOff0 == 0) ? seqPtr0 : uirCoreBin(mbAdd, seqPtr0, uirCoreConstI64(int64(lenOff0)))
                let lenName1: str = blockBuilderNextTemp(b, "__len")
                let lenSlot1: int32 = localAdd(b.env, lenName1, uirCoreTypeI32())
                uirCoreSetLocalType(b.func, lenSlot1, uirCoreTypeI32())
                blockBuilderAddStmt(b, uirCoreStmtLet(lenName1, lenSlot1, uirCoreLoad(lenAddr0, uirCoreTypeI32())))
                return Ok[UirExprId](uirCoreLocal(lenSlot1))

            # tables.Table[V]
            if b.module != nil && uirCoreHasObjType(b.module, "Table") &&
               ((k0 == "Table") || uirCoreStrStartsWith(k0, "Table_")):
                let tabRes0: Result[UirExprId] = lowerExprValue(b, arg0, uirCoreTypeI64())
                if !IsOk[UirExprId](tabRes0):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](tabRes0))
                let tabName0: str = blockBuilderNextTemp(b, "__len_table")
                let tabSlot0: int32 = localAdd(b.env, tabName0, uirCoreTypeI64())
                uirCoreSetLocalType(b.func, tabSlot0, uirCoreTypeI64())
                blockBuilderAddStmt(b, uirCoreStmtLet(tabName0, tabSlot0, Value[UirExprId](tabRes0)))
                let tabPtr0: UirExprId = uirCoreLocal(tabSlot0)

                let tabOt0: UirCoreObjType = uirCoreGetObjType(b.module, "Table")
                var lenOff1: int32 = -1
                for fj0 in 0..<tabOt0.fields.len:
                    let f1: UirCoreObjField = tabOt0.fields[fj0]
                    if (f1.name == "len"):
                        lenOff1 = f1.offset
                        break
                if lenOff1 < 0:
                    return Err[UirExprId]("uirCore_builder: Table layout mismatch")

                let lenAddr1: UirExprId = (lenOff1 == 0) ? tabPtr0 : uirCoreBin(mbAdd, tabPtr0, uirCoreConstI64(int64(lenOff1)))
                let lenName2: str = blockBuilderNextTemp(b, "__len")
                let lenSlot2: int32 = localAdd(b.env, lenName2, uirCoreTypeI32())
                uirCoreSetLocalType(b.func, lenSlot2, uirCoreTypeI32())
                blockBuilderAddStmt(b, uirCoreStmtLet(lenName2, lenSlot2, uirCoreLoad(lenAddr1, uirCoreTypeI32())))
                return Ok[UirExprId](uirCoreLocal(lenSlot2))

        # Fallback: infer object-return calls from the callee signature when typeCache is missing
        # or doesn't indicate an object value.
        if b.module != nil &&
           (!nodeTypeCacheValid(node) || astRefIsNil(nodeTypeCache(node)) || !typeNodeIsObjValue(b.module, nodeTypeCache(node))):
            var callName2: str = name
            if typeArgs.len > 0:
                callName2 = mangleInstance(name, typeArgs)
            let callee0: UirCoreFunc = uirCoreResolveCalleeFuncBestEffort(b, callName2, argNodes, "")
            if (callee0 != nil) && uirCoreFuncParamsLen(callee0) > 0:
                let p0: UirCoreParam = uirCoreFuncParamAt(callee0, 0)
                if (p0.name == "__ret"):
                    let objNm: str = funcObjTypeName(callee0, p0.slot)
                    if len(objNm) > 0:
                        let tmpName: str = blockBuilderNextTemp(b, "__callret")
                        let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
                        uirCoreSetLocalType(b.func, tmpSlot, uirCoreTypeI64())
                        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objNm)
                        if ! uirCoreResultBoolIsOk(allocRes):
                            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
                        let kret: str = funcObjTypeKey(callee0, p0.slot)
                        if len(kret) > 0:
                            localSetTypeKey(b.env, tmpSlot, kret)
                            funcSetObjTypeKey(b.func, tmpSlot, kret)
                        else:
                            localSetTypeKey(b.env, tmpSlot, objNm)
                            funcSetObjTypeKey(b.func, tmpSlot, objNm)
                        return lowerCallWithLeadingArg(b, node, uirCoreLocal(tmpSlot))

        if name == "elemSize" && typeArgs.len == 1 && uirCoreCallEffectiveArgCount(argNodes) == 0:
            return "int32"
        var callName: str = name
        if typeArgs.len > 0:
            callName = mangleInstance(name, typeArgs)
        var calleeFunc: UirCoreFunc = nil
        var callInternal: str = callName
        let mod2: UirCoreModule = b.module
        if (mod2 != nil):
            let hint: str = uirCoreInferCallRetKeyHint(node)
            let cand: UirCoreFunc = uirCoreResolveCalleeFuncBestEffort(b, callName, argNodes, hint)
            if (cand != nil):
                calleeFunc = cand
                callInternal = uirCoreCallSymbolForFunc(cand)
            elif moduleHasFuncByBase(mod2, callName):
                let calleeRes: Result[UirCoreFunc] = uirCoreResolveCalleeFunc(b, node, callName, argNodes)
                if !IsOk[UirCoreFunc](calleeRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirCoreFunc](calleeRes))
                calleeFunc = Value[UirCoreFunc](calleeRes)
                callInternal = uirCoreCallSymbolForFunc(calleeFunc)
        if len(callInternal) == 0 && len(callName) > 0:
            callInternal = callName
        if name == "Value" && argNodes.len == 1:
            let valueArg0: Node = argNodes[0]
            if (valueArg0 != nil):
                let valueBaseRes: Result[UirExprId] = lowerExprValue(b, valueArg0, uirCoreTypeI64())
                if IsOk[UirExprId](valueBaseRes):
                    var valueAddr0: UirExprId = Value[UirExprId](valueBaseRes)
                    if (mod2 != nil):
                        var valueArgKey0: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, valueArg0))
                        valueArgKey0 = uirCoreStripPtrKeyOnce(valueArgKey0)
                        let valueObj0: str = uirCoreObjTypeFromTypeKey(mod2, valueArgKey0)
                        if len(valueObj0) > 0 && uirCoreHasObjType(mod2, valueObj0):
                            let valueOt0: UirCoreObjType = uirCoreGetObjType(mod2, valueObj0)
                            var valueOff0: int32 = -1
                            for vfi in 0..<valueOt0.fields.len:
                                let vf0: UirCoreObjField = valueOt0.fields[vfi]
                                if (vf0.name == "value") || uirCoreStrStartsWith(vf0.name, "value."):
                                    valueOff0 = vf0.offset
                                    break
                            if valueOff0 > 0:
                                valueAddr0 = uirCoreBin(mbAdd, valueAddr0, uirCoreConstI64(int64(valueOff0)))
                    var valueOutTy0: UirCoreType = wantType
                    if valueOutTy0.kind == mtVoid && (mod2 != nil):
                        let valueInnerKey0: str = uirCoreInferValueCallInnerKey(b, node)
                        if len(valueInnerKey0) > 0:
                            valueOutTy0 = uirCoreTypeFromNodeWithModule(mod2, newIdent(valueInnerKey0, nodePos(node)))
                    if valueOutTy0.kind == mtVoid:
                        valueOutTy0 = uirCoreTypeI64()
                    if getEnv "BACKEND_DEBUG_VALUE_LOWER" == "1":
                        var fnDbg0: str = ""
                        if (b != nil) && uirCoreFuncIdValid(b.func):
                            let fDbg0: UirCoreFunc = b.func
                            fnDbg0 = uirCoreFuncNameOf(fDbg0)
                        echo("[backend] debugValueLower: fn=" + fnDbg0 + " valueOutTy=" + uirCoreTypeKindNameLocal(valueOutTy0))
                    return Ok[UirExprId](uirCoreLoad(valueAddr0, valueOutTy0))

        var args: UirExprId[]
        let dbgVarCallRaw: str = getEnv "BACKEND_DEBUG_VARCALL"
        var dbgVarCall: bool = (dbgVarCallRaw == "1")
        let dbgVarCallName: str = getEnv "BACKEND_DEBUG_VARCALL_NAME"
        if dbgVarCall && len(dbgVarCallName) > 0:
            dbgVarCall = (callName == dbgVarCallName)
        let dbgStrCalls: bool = (getEnv "BACKEND_DEBUG_STR_CALLS" == "1")
        let dbgTrackCall: bool = dbgStrCalls &&
            (callName == "echo" || callName == "hasPrefix" || callName == "dropPrefix" || callName == "stage1Trace")
        for ai2 in 0..<argNodes.len:
            let argNode: Node = argNodes[ai2]
            if dbgTrackCall:
                var dbgKind: str = "nil"
                var dbgName: str = ""
                var dbgStrVal: str = ""
                if astNodeIdValid(argNode):
                    dbgKind = intToStr(int32(nodeKind(argNode)))
                    dbgName = plainName(argNode)
                    dbgStrVal = nodeStrVal(argNode)
                echo("[backend] debugStrCall: call=" + callName +
                     " arg#" + intToStr(ai2) +
                     " kind=nk#" + dbgKind +
                     " name='" + dbgName + "'" +
                     " str='" + dbgStrVal + "'")
            let dbgSpawn: bool = (getEnv "BACKEND_DEBUG_SPAWN" == "1")
            if dbgSpawn && name == "spawn":
                var kindStr: str = "nil"
                if (argNode != nil):
                    kindStr = intToStr(int32(nodeKind(argNode)))
                echo("[backend] debugSpawn: arg#" + intToStr(ai2 + 1) + " kind=nk#" + kindStr)
            var wantVarAddr: bool = false
            var pi2: int32 = ai2
            var dbgParamKey: str = ""
            if (calleeFunc != nil) && uirCoreFuncParamsLen(calleeFunc) > 0:
                let pFirst: UirCoreParam = uirCoreFuncParamAt(calleeFunc, 0)
                if (pFirst.name == "__ret"):
                    pi2 = ai2 + 1
            if (calleeFunc != nil) && pi2 >= 0 && pi2 < uirCoreFuncParamsLen(calleeFunc):
                let p0: UirCoreParam = uirCoreFuncParamAt(calleeFunc, pi2)
                dbgParamKey = p0.typeKey
                wantVarAddr = uirCoreParamWantsVarAddr(mod2, p0.typeKey)
            if dbgVarCall:
                var calleeDbg: str = ""
                if (calleeFunc != nil):
                    calleeDbg = uirCoreFuncNameOf(calleeFunc)
                echo("[backend] debugVarCall: call=" + callName +
                     " callee=" + calleeDbg +
                     " argIdx=" + intToStr(ai2) +
                     " paramKey=" + dbgParamKey +
                     " wantVarAddr=" + (wantVarAddr ? "1" : "0"))
            if wantVarAddr:
                let addrRes: Result[UirExprId] = lowerVarArgAddr(b, argNode)
                if !IsOk[UirExprId](addrRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](addrRes))
                builderExprSeqAppend(args, Value[UirExprId](addrRes))
            elif (ai2 == 0) && (name == "spawn"):
                let fnRes: Result[UirExprId] = lowerSpawnEntryArg(b, argNode)
                if !IsOk[UirExprId](fnRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](fnRes))
                builderExprSeqAppend(args, Value[UirExprId](fnRes))
            else:
                # Call argument lowering should not depend on the call's return type.
                let argRes: Result[UirExprId] = lowerExprValue(b, argNode, uirCoreTypeI64())
                if !IsOk[UirExprId](argRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](argRes))
                builderExprSeqAppend(args, Value[UirExprId](argRes))
        let valueLikeCall1: bool = (callInternal == "Value") || (callName == "Value") ||
            ((calleeFunc != nil) && len(uirCoreFuncLinkNameOf(calleeFunc)) > 0 && (uirCoreFuncLinkNameOf(calleeFunc) == "Value"))
        if valueLikeCall1 && args.len >= 1:
            var valueAddr1: UirExprId = args[0]
            if (mod2 != nil) && argNodes.len > 0 && astRefNonNil(argNodes[0]):
                var valueArgKey1: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, argNodes[0]))
                valueArgKey1 = uirCoreStripPtrKeyOnce(valueArgKey1)
                var valueOff1: int32 = -1
                let valueObj1: str = uirCoreObjTypeFromTypeKey(mod2, valueArgKey1)
                if len(valueObj1) > 0 && uirCoreHasObjType(mod2, valueObj1):
                    let valueOt1: UirCoreObjType = uirCoreGetObjType(mod2, valueObj1)
                    for vfi1 in 0..<valueOt1.fields.len:
                        let vf1: UirCoreObjField = valueOt1.fields[vfi1]
                        if (vf1.name == "value") || uirCoreStrStartsWith(vf1.name, "value."):
                            if valueOff1 < 0 || vf1.offset < valueOff1:
                                valueOff1 = vf1.offset
                if valueOff1 < 0 && uirCoreStrStartsWith(valueArgKey1, "Result_"):
                    valueOff1 = 0
                if valueOff1 > 0:
                    valueAddr1 = uirCoreBin(mbAdd, valueAddr1, uirCoreConstI64(int64(valueOff1)))
            var outTy1: UirCoreType = wantType
            if outTy1.kind == mtVoid && (mod2 != nil):
                let innerKey2: str = uirCoreInferValueCallInnerKey(b, node)
                if len(innerKey2) > 0:
                    outTy1 = uirCoreTypeFromNodeWithModule(mod2, newIdent(innerKey2, nodePos(node)))
            if outTy1.kind == mtVoid:
                outTy1 = uirCoreTypeI64()
            return Ok[UirExprId](uirCoreLoad(valueAddr1, outTy1))
        if len(callInternal) == 0:
            var fnDbg4: str = ""
            if (b != nil) && uirCoreFuncIdValid(b.func):
                let fDbg4: UirCoreFunc = b.func
                fnDbg4 = uirCoreFuncNameOf(fDbg4)
            return Err[UirExprId]("uirCore_builder: empty call symbol fn=" + fnDbg4 +
                                  " name='" + name + "' callName='" + callName + "'")
        return Ok[UirExprId](uirCoreCall(callInternal, args))
    if nodeKind(node) == nkPrefix && kidCount(node) > 1:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        let rhs: Node = kid(node, 1)
        if op == "$":
            var argNodes0: Node[1]
            astNodeSeqAppend(argNodes0, rhs)
            var callInternal0: str = "$"
            let mod2: UirCoreModule = b.module
            if (mod2 != nil):
                let cand: UirCoreFunc = uirCoreResolveCalleeFuncBestEffort(b, "$", argNodes0, "str")
                if (cand != nil):
                    callInternal0 = uirCoreCallSymbolForFunc(cand)
                elif moduleHasFuncByBase(mod2, "$"):
                    let calleeRes: Result[UirCoreFunc] = uirCoreResolveCalleeFunc(b, node, "$", argNodes0)
                    if !IsOk[UirCoreFunc](calleeRes):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirCoreFunc](calleeRes))
                    let callee: UirCoreFunc = Value[UirCoreFunc](calleeRes)
                    callInternal0 = uirCoreCallSymbolForFunc(callee)
            if len(callInternal0) == 0:
                callInternal0 = "$"
            let rhsRes0: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI64())
            if !IsOk[UirExprId](rhsRes0):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsRes0))
            var args0: UirExprId[]
            builderExprSeqAppend(args0, Value[UirExprId](rhsRes0))
            return Ok[UirExprId](uirCoreCall(callInternal0, args0))
        if op == "-":
            var k: str = exprTypeKeyShallow(b, node)
            if len(k) == 0:
                k = exprTypeKeyShallow(b, rhs)
            if isFloat64Key(k):
                let rhsBitsRes: Result[UirExprId] = lowerToF64Bits(b, rhs)
                if ! IsOk[UirExprId](rhsBitsRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsBitsRes))
                var args: UirExprId[]
                builderExprSeqAppend(args, Value[UirExprId](rhsBitsRes))
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF64(), uirCoreCall("cheng_f64_neg_bits", args)))
            let rhsRes: Result[UirExprId] = lowerExprValue(b, rhs, wantType)
            if ! IsOk[UirExprId](rhsRes):
                return rhsRes
            let zero: UirExprId = uirCoreConstI64(0)
            return Ok[UirExprId](uirCoreBin(mbSub, zero, Value[UirExprId](rhsRes)))
        if op == "+":
            return lowerExprValue(b, rhs, wantType)
        if op == "~":
            let rhsRes2: Result[UirExprId] = lowerExprValue(b, rhs, wantType)
            if ! IsOk[UirExprId](rhsRes2):
                return rhsRes2
            let allBits: UirExprId = uirCoreConstI64(-1)
            return Ok[UirExprId](uirCoreBin(mbXor, Value[UirExprId](rhsRes2), allBits))
        if op == "!":
            let rhsRes3: Result[UirExprId] = lowerExprValue(b, rhs, wantType)
            if ! IsOk[UirExprId](rhsRes3):
                return rhsRes3
            let zero2: UirExprId = uirCoreConstI64(0)
            return Ok[UirExprId](uirCoreCmp(mcEq, Value[UirExprId](rhsRes3), zero2))
    if nodeKind(node) == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        let lhsNode: Node = kid(node, 1)
        let rhsNode: Node = kid(node, 2)
        if op == "in" || op == "notin":
            return lowerInExpr(b, lhsNode, rhsNode, op == "notin")
        if op == "+" || op == "==" || op == "!=":
            let lk: str = caseInferExprTypeKey(b, lhsNode)
            let rk: str = caseInferExprTypeKey(b, rhsNode)
            let selfK: str = exprTypeKeyShallow(b, node)
            if isStringKey(selfK) || uirCoreNodeHasStringCtx(lk, lhsNode) || uirCoreNodeHasStringCtx(rk, rhsNode):
                if (getEnv "BACKEND_DEBUG_STR_CALLS" == "1"):
                    echo("[backend] debugStrInfix: op=" + op +
                         " lhs_kind=nk#" + intToStr(int32(nodeKind(lhsNode))) +
                         " rhs_kind=nk#" + intToStr(int32(nodeKind(rhsNode))) +
                         " lhs_name='" + plainName(lhsNode) + "'" +
                         " rhs_name='" + plainName(rhsNode) + "'" +
                         " lhs_str='" + nodeStrVal(lhsNode) + "'" +
                         " rhs_str='" + nodeStrVal(rhsNode) + "'" +
                         " lhs_key='" + lk + "'" +
                         " rhs_key='" + rk + "'" +
                         " self_key='" + selfK + "'")
                let lhsIsNil: bool = uirCoreIsNilExpr(lhsNode)
                let rhsIsNil: bool = uirCoreIsNilExpr(rhsNode)
                if op != "+" && (lhsIsNil || rhsIsNil):
                    let hasSemanticStrCtx: bool = isSemanticStrKey(selfK) ||
                                                  uirCoreNodeHasSemanticStrCtx(lk, lhsNode) ||
                                                  uirCoreNodeHasSemanticStrCtx(rk, rhsNode)
                    if hasSemanticStrCtx:
                        if !uirCoreSkipSemStdDuplicateRelaxEnabled():
                            return Err[UirExprId]("uirCore_builder: semantic str cannot be compared with nil")
                    if lhsIsNil && rhsIsNil:
                        if op == "==":
                            return Ok[UirExprId](uirCoreConstI64(1))
                        return Ok[UirExprId](uirCoreConstI64(0))
                    let valNode: Node = lhsIsNil ? rhsNode : lhsNode
                    let valResNilCmp: Result[UirExprId] = lowerExprValue(b, valNode, uirCoreTypeI64())
                    if !IsOk[UirExprId](valResNilCmp):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valResNilCmp))
                    if op == "==":
                        return Ok[UirExprId](uirCoreCmp(mcEq, Value[UirExprId](valResNilCmp), uirCoreConstI64(0)))
                    return Ok[UirExprId](uirCoreCmp(mcNe, Value[UirExprId](valResNilCmp), uirCoreConstI64(0)))
                let lhsResS: Result[UirExprId] = lowerExprValue(b, lhsNode, uirCoreTypeI64())
                if ! IsOk[UirExprId](lhsResS):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](lhsResS))
                let rhsResS: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI64())
                if ! IsOk[UirExprId](rhsResS):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsResS))
                let lhsS: UirExprId = Value[UirExprId](lhsResS)
                let rhsS: UirExprId = Value[UirExprId](rhsResS)
                var argsS: UirExprId[]
                builderExprSeqAppend(argsS, lhsS)
                builderExprSeqAppend(argsS, rhsS)
                if op == "+":
                    return Ok[UirExprId](uirCoreCall(uirCoreResolveStrConcatCallSymbol(b.module), argsS))
                let eqCall: UirExprId = uirCoreCall("__cheng_str_eq", argsS)
                if op == "==":
                    return Ok[UirExprId](eqCall)
                return Ok[UirExprId](uirCoreCmp(mcEq, eqCall, uirCoreConstI64(0)))
            if (op == "==" || op == "!=") && (uirCoreObjAliasCanon(lk) == "Bytes") && (uirCoreObjAliasCanon(rk) == "Bytes"):
                let lhsResB: Result[UirExprId] = lowerExprValue(b, lhsNode, uirCoreTypeI64())
                if ! IsOk[UirExprId](lhsResB):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](lhsResB))
                let rhsResB: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI64())
                if ! IsOk[UirExprId](rhsResB):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsResB))
                let lhsB: UirExprId = Value[UirExprId](lhsResB)
                let rhsB: UirExprId = Value[UirExprId](rhsResB)
                var argsB: UirExprId[]
                builderExprSeqAppend(argsB, lhsB)
                builderExprSeqAppend(argsB, rhsB)
                let eqCall: UirExprId = uirCoreCall("bytesEqual", argsB)
                if op == "==":
                    return Ok[UirExprId](eqCall)
                return Ok[UirExprId](uirCoreCmp(mcEq, eqCall, uirCoreConstI64(0)))
        var kInfix: str = exprTypeKeyShallow(b, node)
        if len(kInfix) == 0:
            kInfix = exprTypeKeyShallow(b, lhsNode)
        if len(kInfix) == 0:
            kInfix = exprTypeKeyShallow(b, rhsNode)
        let lhsInferTy: UirCoreType = inferExprTypeWithGlobals(b.env, b.module, b.func, lhsNode, uirCoreTypeI32())
        let rhsInferTy: UirCoreType = inferExprTypeWithGlobals(b.env, b.module, b.func, rhsNode, uirCoreTypeI32())
        let inferF64: bool = lhsInferTy.kind == mtF64 || rhsInferTy.kind == mtF64
        let inferF32: bool = lhsInferTy.kind == mtF32 || rhsInferTy.kind == mtF32
        if (isFloat32Key(kInfix) || (inferF32 && !inferF64)):
            let lhsBits32Res: Result[UirExprId] = lowerToF32Bits(b, lhsNode)
            if !IsOk[UirExprId](lhsBits32Res):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](lhsBits32Res))
            let rhsBits32Res: Result[UirExprId] = lowerToF32Bits(b, rhsNode)
            if !IsOk[UirExprId](rhsBits32Res):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsBits32Res))
            let lhsBits32: UirExprId = Value[UirExprId](lhsBits32Res)
            let rhsBits32: UirExprId = Value[UirExprId](rhsBits32Res)
            if op == "==":
                return Ok[UirExprId](uirCoreCmp(mcEq, lhsBits32, rhsBits32))
            if op == "!=":
                return Ok[UirExprId](uirCoreCmp(mcNe, lhsBits32, rhsBits32))

            var lhsUpArgs: UirExprId[]
            builderExprSeqAppend(lhsUpArgs, lhsBits32)
            let lhsBits64: UirExprId = uirCoreCall("cheng_f32_bits_to_f64_bits", lhsUpArgs)
            var rhsUpArgs: UirExprId[]
            builderExprSeqAppend(rhsUpArgs, rhsBits32)
            let rhsBits64: UirExprId = uirCoreCall("cheng_f32_bits_to_f64_bits", rhsUpArgs)
            var args32: UirExprId[]
            builderExprSeqAppend(args32, lhsBits64)
            builderExprSeqAppend(args32, rhsBits64)
            if args32.len != 2:
                return Err[UirExprId]("uirCore_builder: float32 compare arg list corrupt")
            if op == "+":
                var downArgs0: UirExprId[]
                builderExprSeqAppend(downArgs0, uirCoreCall("cheng_f64_add_bits", args32))
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF32(), uirCoreCall("cheng_f64_bits_to_f32_bits", downArgs0)))
            if op == "-":
                var downArgs1: UirExprId[]
                builderExprSeqAppend(downArgs1, uirCoreCall("cheng_f64_sub_bits", args32))
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF32(), uirCoreCall("cheng_f64_bits_to_f32_bits", downArgs1)))
            if op == "*":
                var downArgs2: UirExprId[]
                builderExprSeqAppend(downArgs2, uirCoreCall("cheng_f64_mul_bits", args32))
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF32(), uirCoreCall("cheng_f64_bits_to_f32_bits", downArgs2)))
            if op == "/":
                var downArgs3: UirExprId[]
                builderExprSeqAppend(downArgs3, uirCoreCall("cheng_f64_div_bits", args32))
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF32(), uirCoreCall("cheng_f64_bits_to_f32_bits", downArgs3)))
            if op == "<":
                return Ok[UirExprId](uirCoreCall("cheng_f64_lt_bits", args32))
            if op == "<=":
                return Ok[UirExprId](uirCoreCall("cheng_f64_le_bits", args32))
            if op == ">":
                return Ok[UirExprId](uirCoreCall("cheng_f64_gt_bits", args32))
            if op == ">=":
                return Ok[UirExprId](uirCoreCall("cheng_f64_ge_bits", args32))
            return Err[UirExprId]("uirCore_builder: unsupported float32 infix op")
        if isFloat64Key(kInfix) || inferF64:
            let lhsBitsRes: Result[UirExprId] = lowerToF64Bits(b, lhsNode)
            if ! IsOk[UirExprId](lhsBitsRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](lhsBitsRes))
            let rhsBitsRes: Result[UirExprId] = lowerToF64Bits(b, rhsNode)
            if ! IsOk[UirExprId](rhsBitsRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsBitsRes))
            let lhsBits: UirExprId = Value[UirExprId](lhsBitsRes)
            let rhsBits: UirExprId = Value[UirExprId](rhsBitsRes)
            if op == "==":
                return Ok[UirExprId](uirCoreCmp(mcEq, lhsBits, rhsBits))
            if op == "!=":
                return Ok[UirExprId](uirCoreCmp(mcNe, lhsBits, rhsBits))
            var args2: UirExprId[]
            builderExprSeqAppend(args2, lhsBits)
            builderExprSeqAppend(args2, rhsBits)
            if args2.len != 2:
                return Err[UirExprId]("uirCore_builder: float compare arg list corrupt")
            if op == "+":
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF64(), uirCoreCall("cheng_f64_add_bits", args2)))
            if op == "-":
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF64(), uirCoreCall("cheng_f64_sub_bits", args2)))
            if op == "*":
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF64(), uirCoreCall("cheng_f64_mul_bits", args2)))
            if op == "/":
                return Ok[UirExprId](uirCoreCast(uirCoreTypeF64(), uirCoreCall("cheng_f64_div_bits", args2)))
            if op == "<":
                return Ok[UirExprId](uirCoreCall("cheng_f64_lt_bits", args2))
            if op == "<=":
                return Ok[UirExprId](uirCoreCall("cheng_f64_le_bits", args2))
            if op == ">":
                return Ok[UirExprId](uirCoreCall("cheng_f64_gt_bits", args2))
            if op == ">=":
                return Ok[UirExprId](uirCoreCall("cheng_f64_ge_bits", args2))
            return Err[UirExprId]("uirCore_builder: unsupported float infix op")
        let lhsRes: Result[UirExprId] = lowerExprValue(b, lhsNode, wantType)
        if ! IsOk[UirExprId](lhsRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](lhsRes))
        let rhsRes: Result[UirExprId] = lowerExprValue(b, rhsNode, wantType)
        if ! IsOk[UirExprId](rhsRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsRes))
        let lhs: UirExprId = Value[UirExprId](lhsRes)
        let rhs: UirExprId = Value[UirExprId](rhsRes)
        if op == "+":
            return Ok[UirExprId](uirCoreBin(mbAdd, lhs, rhs))
        if op == "-":
            return Ok[UirExprId](uirCoreBin(mbSub, lhs, rhs))
        if op == "*":
            return Ok[UirExprId](uirCoreBin(mbMul, lhs, rhs))
        if op == "/":
            return Ok[UirExprId](uirCoreBin(mbSdiv, lhs, rhs))
        if op == "%":
            return Ok[UirExprId](uirCoreBin(mbSmod, lhs, rhs))
        if op == "&":
            return Ok[UirExprId](uirCoreBin(mbAnd, lhs, rhs))
        if op == "|":
            return Ok[UirExprId](uirCoreBin(mbOr, lhs, rhs))
        if op == "^":
            return Ok[UirExprId](uirCoreBin(mbXor, lhs, rhs))
        if op == "<<":
            return Ok[UirExprId](uirCoreBin(mbShl, lhs, rhs))
        if op == ">>":
            return Ok[UirExprId](uirCoreBin(mbShr, lhs, rhs))
        if op == "==":
            return Ok[UirExprId](uirCoreCmp(mcEq, lhs, rhs))
        if op == "!=":
            return Ok[UirExprId](uirCoreCmp(mcNe, lhs, rhs))
        if op == "<":
            return Ok[UirExprId](uirCoreCmp(mcLt, lhs, rhs))
        if op == "<=":
            return Ok[UirExprId](uirCoreCmp(mcLe, lhs, rhs))
        if op == ">":
            return Ok[UirExprId](uirCoreCmp(mcGt, lhs, rhs))
        if op == ">=":
            return Ok[UirExprId](uirCoreCmp(mcGe, lhs, rhs))
        return Err[UirExprId]("uirCore_builder: unsupported infix op")
    return Err[UirExprId]("uirCore_builder: unsupported expr kind")

fn uirCoreBuildExpr(env: LocalEnv, n: Node): Result[UirExprId] =
    if (n == nil):
        return Err[UirExprId]("uirCore_builder: nil expr")
    if nodeKind(n) == nkCallArg:
        if kidCount(n) > 0:
            return uirCoreBuildExpr(env, kid(n, kidCount(n) - 1))
        return Err[UirExprId]("uirCore_builder: invalid call arg expr")
    if nodeKind(n) == nkIntLit:
        return Ok[UirExprId](uirCoreConstI64(nodeIntVal(n)))
    if nodeKind(n) == nkFloatLit:
        if len(nodeStrVal(n)) > 0:
            return Ok[UirExprId](uirCoreConstI64(cheng_parse_f64_bits(nodeStrVal(n))))
        return Ok[UirExprId](uirCoreConstI64(0))
    if nodeKind(n) == nkBoolLit:
        let name: str = backendStripSpaces(nodeIdent(n))
        if name == "true":
            return Ok[UirExprId](uirCoreConstI64(1))
        return Ok[UirExprId](uirCoreConstI64(0))
    if nodeKind(n) == nkCharLit:
        if len(nodeStrVal(n)) > 0:
            let c: char = nodeStrVal(n)[0]
            return Ok[UirExprId](uirCoreConstI64(int64(c)))
        return Ok[UirExprId](uirCoreConstI64(0))
    if nodeKind(n) == nkNilLit:
        return Ok[UirExprId](uirCoreConstI64(0))
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        let nm: str = plainName(n)
        let idx: int32 = localIndex(env, nm)
        if idx < 0:
            return Err[UirExprId]("uirCore_builder: unknown local")
        return Ok[UirExprId](uirCoreLocal(idx))
    if nodeKind(n) == nkPar && kidCount(n) > 0:
        return uirCoreBuildExpr(env, kid(n, 0))
    if nodeKind(n) == nkCall && kidCount(n) > 0:
        let calleeNode: Node = kid(n, 0)
        if (calleeNode == nil) ||(nodeKind(calleeNode) != nkIdent && nodeKind(calleeNode) != nkSymbol):
            return Err[UirExprId]("uirCore_builder: call expects identifier callee")
        let name: str = backendStripSpaces(plainName(calleeNode))
        if kidCount(n) == 2 &&
           (name == "int64" || name == "i64" || name == "uint64" || name == "u64" ||
            name == "int32" || name == "i32" || name == "uint32" || name == "u32" ||
            name == "int" || name == "uint" || name == "NI" || name == "NU"):
            let argNode0: Node = kid(n, 1)
            var castArg: Node = argNode0
            if astNodeIdValid(argNode0) && nodeKind(argNode0) == nkCallArg && kidCount(argNode0) > 1:
                castArg = kid(argNode0, 1)
            let castRes: Result[UirExprId] = uirCoreBuildExpr(env, castArg)
            if ! IsOk[UirExprId](castRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](castRes))
            let castType: UirCoreType = uirCoreTypeFromNodeWithModule(nil, calleeNode)
            return Ok[UirExprId](uirCoreCast(castType, Value[UirExprId](castRes)))
        var args: UirExprId[]
        for ai in 1..<kidCount(n):
            var argNode: Node = kid(n, ai)
            if astNodeIdValid(argNode) && nodeKind(argNode) == nkCallArg && kidCount(argNode) > 1:
                argNode = kid(argNode, 1)
            let argRes: Result[UirExprId] = uirCoreBuildExpr(env, argNode)
            if ! IsOk[UirExprId](argRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](argRes))
            builderExprSeqAppend(args, Value[UirExprId](argRes))
        return Ok[UirExprId](uirCoreCall(name, args))
    if nodeKind(n) == nkPrefix && kidCount(n) > 1:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        let rhs: Node = kid(n, 1)
        if op == "-":
            let rhsRes: Result[UirExprId] = uirCoreBuildExpr(env, rhs)
            if ! IsOk[UirExprId](rhsRes):
                return rhsRes
            let zero: UirExprId = uirCoreConstI64(0)
            return Ok[UirExprId](uirCoreBin(mbSub, zero, Value[UirExprId](rhsRes)))
        if op == "+":
            return uirCoreBuildExpr(env, rhs)
        if op == "~":
            let rhsRes2: Result[UirExprId] = uirCoreBuildExpr(env, rhs)
            if ! IsOk[UirExprId](rhsRes2):
                return rhsRes2
            let allBits: UirExprId = uirCoreConstI64(-1)
            return Ok[UirExprId](uirCoreBin(mbXor, Value[UirExprId](rhsRes2), allBits))
        if op == "!":
            let rhsRes3: Result[UirExprId] = uirCoreBuildExpr(env, rhs)
            if ! IsOk[UirExprId](rhsRes3):
                return rhsRes3
            let zero2: UirExprId = uirCoreConstI64(0)
            return Ok[UirExprId](uirCoreCmp(mcEq, Value[UirExprId](rhsRes3), zero2))
    if nodeKind(n) == nkInfix && kidCount(n) >= 3:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        let lhsNode: Node = kid(n, 1)
        let rhsNode: Node = kid(n, 2)
        var selfKey: str = ""
        var lhsKey: str = ""
        var rhsKey: str = ""
        if nodeTypeCacheValid(n) && astRefNonNil(nodeTypeCache(n)):
            selfKey = typeKey(nodeTypeCache(n))
        if nodeTypeCacheValid(lhsNode) && astRefNonNil(nodeTypeCache(lhsNode)):
            lhsKey = typeKey(nodeTypeCache(lhsNode))
        if nodeTypeCacheValid(rhsNode) && astRefNonNil(nodeTypeCache(rhsNode)):
            rhsKey = typeKey(nodeTypeCache(rhsNode))
        let lhsRes: Result[UirExprId] = uirCoreBuildExpr(env, lhsNode)
        if ! IsOk[UirExprId](lhsRes):
            return lhsRes
        let rhsRes: Result[UirExprId] = uirCoreBuildExpr(env, rhsNode)
        if ! IsOk[UirExprId](rhsRes):
            return rhsRes
        let lhs: UirExprId = Value[UirExprId](lhsRes)
        let rhs: UirExprId = Value[UirExprId](rhsRes)
        if op == "+":
            if isStringKey(selfKey) || uirCoreNodeHasStringCtx(lhsKey, lhsNode) || uirCoreNodeHasStringCtx(rhsKey, rhsNode):
                var argsS: UirExprId[]
                builderExprSeqAppend(argsS, lhs)
                builderExprSeqAppend(argsS, rhs)
                return Ok[UirExprId](uirCoreCall("__cheng_concat_str", argsS))
            return Ok[UirExprId](uirCoreBin(mbAdd, lhs, rhs))
        if op == "-":
            return Ok[UirExprId](uirCoreBin(mbSub, lhs, rhs))
        if op == "*":
            return Ok[UirExprId](uirCoreBin(mbMul, lhs, rhs))
        if op == "/":
            return Ok[UirExprId](uirCoreBin(mbSdiv, lhs, rhs))
        if op == "%":
            return Ok[UirExprId](uirCoreBin(mbSmod, lhs, rhs))
        if op == "&":
            return Ok[UirExprId](uirCoreBin(mbAnd, lhs, rhs))
        if op == "|":
            return Ok[UirExprId](uirCoreBin(mbOr, lhs, rhs))
        if op == "^":
            return Ok[UirExprId](uirCoreBin(mbXor, lhs, rhs))
        if op == "<<":
            return Ok[UirExprId](uirCoreBin(mbShl, lhs, rhs))
        if op == ">>":
            return Ok[UirExprId](uirCoreBin(mbShr, lhs, rhs))
        if op == "&&":
            let lhsNz: UirExprId = uirCoreCmp(mcNe, lhs, uirCoreConstI64(0))
            let rhsNz: UirExprId = uirCoreCmp(mcNe, rhs, uirCoreConstI64(0))
            return Ok[UirExprId](uirCoreBin(mbAnd, lhsNz, rhsNz))
        if op == "||":
            let lhsNz2: UirExprId = uirCoreCmp(mcNe, lhs, uirCoreConstI64(0))
            let rhsNz2: UirExprId = uirCoreCmp(mcNe, rhs, uirCoreConstI64(0))
            return Ok[UirExprId](uirCoreBin(mbOr, lhsNz2, rhsNz2))
        if op == "==":
            return Ok[UirExprId](uirCoreCmp(mcEq, lhs, rhs))
        if op == "!=":
            return Ok[UirExprId](uirCoreCmp(mcNe, lhs, rhs))
        if op == "<":
            return Ok[UirExprId](uirCoreCmp(mcLt, lhs, rhs))
        if op == "<=":
            return Ok[UirExprId](uirCoreCmp(mcLe, lhs, rhs))
        if op == ">":
            return Ok[UirExprId](uirCoreCmp(mcGt, lhs, rhs))
        if op == ">=":
            return Ok[UirExprId](uirCoreCmp(mcGe, lhs, rhs))
        let line4: str = intToStr(nodePosLine(n))
        let col4: str = intToStr(nodePosCol(n))
        return Err[UirExprId]("uirCore_builder: unsupported infix op '" + op + "' @" + line4 + ":" + col4)
    let k3: str = intToStr(int32(nodeKind(n)))
    let line3: str = intToStr(nodePosLine(n))
    let col3: str = intToStr(nodePosCol(n))
    return Err[UirExprId]("uirCore_builder: unsupported expr kind (nk#" + k3 + " @" + line3 + ":" + col3 + ")")

fn uirCoreExprFromIfBranch(b: BlockBuilder, n: Node, wantType: UirCoreType): Result[UirExprId] =
    if (n == nil):
        return Err[UirExprId]("uirCore_builder: nil if branch")
    if nodeKind(n) == nkStmtList:
        if kidCount(n) != 1:
            return Err[UirExprId]("uirCore_builder: if expr branch expects single expr")
        return lowerExprValue(b, kid(n, 0), wantType)
    return lowerExprValue(b, n, wantType)

fn lowerIfAssign(b: BlockBuilder, ifNode: Node, name: str, slot: int32): Result[bool] =
    if !astNodeIdValid(ifNode) || nodeKind(ifNode) != nkIf:
        return Err[bool]("uirCore_builder: invalid if expr")
    let total: int32 = kidCount(ifNode)
    if total < 3:
        return Err[bool]("uirCore_builder: if expr expects condition and else")
    let hasElse: bool = (total % 2) == 1
    if ! hasElse:
        return Err[bool]("uirCore_builder: if expr requires else")
    let slotType: UirCoreType = localType(b.env, slot)
    let condCount: int32 = (total - 1) / 2
    let joinLabel: str = blockBuilderNextLabel(b, "if_join")
    var elseLabel: str = ""
    for ci in 0..<condCount:
        let condNode: Node = kid(ifNode, ci * 2)
        let thenNode: Node = kid(ifNode, ci * 2 + 1)
        let thenLabel: str = blockBuilderNextLabel(b, "if_then")
        let isLast: bool = ci == condCount - 1
        var falseLabel: str = ""
        var nextCondLabel: str = ""
        if isLast:
            elseLabel = blockBuilderNextLabel(b, "if_else")
            falseLabel = elseLabel
        else:
            nextCondLabel = blockBuilderNextLabel(b, "if_cond")
            falseLabel = nextCondLabel
        let condRes: Result[bool] = lowerCondBranch(b, condNode, thenLabel, falseLabel)
        if ! uirCoreResultBoolIsOk(condRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(condRes))
        blockBuilderStart(b, thenLabel)
        let thenRes: Result[UirExprId] = uirCoreExprFromIfBranch(b, thenNode, slotType)
        if ! IsOk[UirExprId](thenRes):
            return ErrInfo[bool](ErrorInfoOf[UirExprId](thenRes))
        blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, Value[UirExprId](thenRes)))
        blockBuilderFinish(b, uirCoreTermBr(joinLabel))
        if ! isLast:
            blockBuilderStart(b, nextCondLabel)
    let elseNode: Node = kid(ifNode, total - 1)
    blockBuilderStart(b, elseLabel)
    let elseRes: Result[UirExprId] = uirCoreExprFromIfBranch(b, elseNode, slotType)
    if ! IsOk[UirExprId](elseRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](elseRes))
    blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, Value[UirExprId](elseRes)))
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))
    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn lowerIfAssignObjValue(b: BlockBuilder, ifNode: Node, name: str, slot: int32): Result[bool] =
    if !astNodeIdValid(ifNode) || nodeKind(ifNode) != nkIf:
        return Err[bool]("uirCore_builder: invalid if expr")
    let total: int32 = kidCount(ifNode)
    if total < 3:
        return Err[bool]("uirCore_builder: if expr expects condition and else")
    let hasElse: bool = (total % 2) == 1
    if ! hasElse:
        return Err[bool]("uirCore_builder: if expr requires else")
    let condCount: int32 = (total - 1) / 2
    let joinLabel: str = blockBuilderNextLabel(b, "if_join")
    var elseLabel: str = ""
    for ci in 0..<condCount:
        let condNode: Node = kid(ifNode, ci * 2)
        var thenExpr: Node = kid(ifNode, ci * 2 + 1)
        if astNodeIdValid(thenExpr) && nodeKind(thenExpr) == nkStmtList:
            if kidCount(thenExpr) != 1:
                return Err[bool]("uirCore_builder: if expr branch expects single expr")
            thenExpr = kid(thenExpr, 0)
        let thenLabel: str = blockBuilderNextLabel(b, "if_then")
        let isLast: bool = ci == condCount - 1
        var falseLabel: str = ""
        var nextCondLabel: str = ""
        if isLast:
            elseLabel = blockBuilderNextLabel(b, "if_else")
            falseLabel = elseLabel
        else:
            nextCondLabel = blockBuilderNextLabel(b, "if_cond")
            falseLabel = nextCondLabel
        let condRes: Result[bool] = lowerCondBranch(b, condNode, thenLabel, falseLabel)
        if ! uirCoreResultBoolIsOk(condRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(condRes))
        blockBuilderStart(b, thenLabel)
        let thenAssignRes: Result[bool] = lowerAssignValue(b, thenExpr, name, slot)
        if !uirCoreResultBoolIsOk(thenAssignRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(thenAssignRes))
        blockBuilderFinish(b, uirCoreTermBr(joinLabel))
        if ! isLast:
            blockBuilderStart(b, nextCondLabel)
    var elseExpr: Node = kid(ifNode, total - 1)
    if astNodeIdValid(elseExpr) && nodeKind(elseExpr) == nkStmtList:
        if kidCount(elseExpr) != 1:
            return Err[bool]("uirCore_builder: if expr branch expects single expr")
        elseExpr = kid(elseExpr, 0)
    blockBuilderStart(b, elseLabel)
    let elseAssignRes: Result[bool] = lowerAssignValue(b, elseExpr, name, slot)
    if !uirCoreResultBoolIsOk(elseAssignRes):
        return ErrInfo[bool](uirCoreResultBoolErrorInfo(elseAssignRes))
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))
    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn lowerIfStmt(b: BlockBuilder, ifNode: Node): Result[bool] =
    if !astNodeIdValid(ifNode) || nodeKind(ifNode) != nkIf:
        return Err[bool]("uirCore_builder: invalid if stmt")
    let total: int32 = kidCount(ifNode)
    if total < 2:
        return Err[bool]("uirCore_builder: if expects branches")
    let hasElse: bool = (total % 2) == 1
    let condCount: int32 = total / 2
    let joinLabel: str = blockBuilderNextLabel(b, "if_join")
    var needsJoin: bool = false
    var allTerminated: bool = true
    var elseLabel: str = ""
    for ci in 0..<condCount:
        let condNode: Node = kid(ifNode, ci * 2)
        var thenNode: Node = kid(ifNode, ci * 2 + 1)
        if astNodeIdValid(thenNode) && nodeKind(thenNode) != nkStmtList:
            var wrap: Node = newNode(nkStmtList, nodePos(thenNode))
            addSon(wrap, thenNode)
            thenNode = wrap
        if !astNodeIdValid(thenNode) || nodeKind(thenNode) != nkStmtList:
            return Err[bool]("uirCore_builder: if stmt expects stmt list")
        let thenLabel: str = blockBuilderNextLabel(b, "if_then")
        let isLast: bool = ci == condCount - 1
        var falseLabel: str = ""
        var nextCondLabel: str = ""
        if isLast:
            if hasElse:
                elseLabel = blockBuilderNextLabel(b, "if_else")
                falseLabel = elseLabel
            else:
                falseLabel = joinLabel
                needsJoin = true
                allTerminated = false
        else:
            nextCondLabel = blockBuilderNextLabel(b, "if_cond")
            falseLabel = nextCondLabel
        let condRes: Result[bool] = lowerCondBranch(b, condNode, thenLabel, falseLabel)
        if ! uirCoreResultBoolIsOk(condRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(condRes))
        blockBuilderStart(b, thenLabel)
        let thenTermRes: Result[bool] = lowerStmtList(b, thenNode)
        if ! uirCoreResultBoolIsOk(thenTermRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(thenTermRes))
        let thenTerminated: bool = uirCoreResultBoolValue(thenTermRes)
        if ! thenTerminated:
            allTerminated = false
            needsJoin = true
            blockBuilderFinish(b, uirCoreTermBr(joinLabel))
        if ! isLast:
            blockBuilderStart(b, nextCondLabel)
    if hasElse:
        var elseNode: Node = kid(ifNode, total - 1)
        if astNodeIdValid(elseNode) && nodeKind(elseNode) != nkStmtList:
            var wrap2: Node = newNode(nkStmtList, nodePos(elseNode))
            addSon(wrap2, elseNode)
            elseNode = wrap2
        if !astNodeIdValid(elseNode) || nodeKind(elseNode) != nkStmtList:
            return Err[bool]("uirCore_builder: if else expects stmt list")
        blockBuilderStart(b, elseLabel)
        let elseTermRes: Result[bool] = lowerStmtList(b, elseNode)
        if ! uirCoreResultBoolIsOk(elseTermRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(elseTermRes))
        let elseTerminated: bool = uirCoreResultBoolValue(elseTermRes)
        if ! elseTerminated:
            allTerminated = false
            needsJoin = true
            blockBuilderFinish(b, uirCoreTermBr(joinLabel))
    if needsJoin:
        blockBuilderStart(b, joinLabel)
        return Ok[bool](false)
    if allTerminated:
        return Ok[bool](true)
    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn nodeIsTrueLiteral(n0: Node): bool =
    if (n0 == nil):
        return false
    var n: Node = n0
    while astNodeIdValid(n) && nodeKind(n) == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if (n == nil):
        return false
    if nodeKind(n) == nkBoolLit:
        let v: str = backendStripSpaces(nodeIdent(n))
        return (v == "true")
    return false

fn nodeHasBreakAtLoopDepth(n: Node, loopDepth: int32): bool =
    if (n == nil):
        return false
    if nodeKind(n) == nkBreak:
        return loopDepth == 0
    var childDepth: int32 = loopDepth
    if nodeKind(n) == nkWhile || nodeKind(n) == nkFor:
        childDepth = loopDepth + 1
    for i in 0..<kidCount(n):
        if nodeHasBreakAtLoopDepth(kid(n, i), childDepth):
            return true
    return false

fn lowerWhileStmt(b: BlockBuilder, whileNode: Node): Result[bool] =
    if !astNodeIdValid(whileNode) || nodeKind(whileNode) != nkWhile:
        return Err[bool]("uirCore_builder: invalid while")
    if kidCount(whileNode) < 2:
        return Err[bool]("uirCore_builder: while expects cond/body")
    let isInfinite: bool = nodeIsTrueLiteral(kid(whileNode, 0)) &&
                           ! nodeHasBreakAtLoopDepth(kid(whileNode, 1), 0)
    let condLabel: str = blockBuilderNextLabel(b, "while_cond")
    let bodyLabel: str = blockBuilderNextLabel(b, "while_body")
    let endLabel: str = blockBuilderNextLabel(b, "while_end")
    blockBuilderFinish(b, uirCoreTermBr(condLabel))
    blockBuilderStart(b, condLabel)
    let condRes: Result[bool] = lowerCondBranch(b, kid(whileNode, 0), bodyLabel, endLabel)
    if ! uirCoreResultBoolIsOk(condRes):
        return ErrInfo[bool](uirCoreResultBoolErrorInfo(condRes))
    blockBuilderStart(b, bodyLabel)
    blockBuilderPushLoop(b, endLabel, condLabel)
    let bodyNode: Node = kid(whileNode, 1)
    if !astNodeIdValid(bodyNode) || nodeKind(bodyNode) != nkStmtList:
        return Err[bool]("uirCore_builder: while expects stmt list body")
    if (getEnv "BACKEND_DEBUG_SCOPE" == "1") && (b != nil) && uirCoreFuncIdValid(b.func):
        let fDbg: UirCoreFunc = b.func
        if (uirCoreFuncNameOf(fDbg) == "verifyLockAgainstRegistry"):
            echo("[backend] debugWhileBody: fn=" + uirCoreFuncNameOf(fDbg) + " kids=" + intToStr(kidCount(bodyNode)) +
                 " @" + intToStr(nodePosLine(bodyNode)) + ":" + intToStr(nodePosCol(bodyNode)))
            for di in 0..<kidCount(bodyNode):
                let st: Node = kid(bodyNode, di)
                let sk: str = ((st != nil)) ? intToStr(int32(nodeKind(st))) : "nil"
                let sl: str = ((st != nil)) ? intToStr(nodePosLine(st)) : "0"
                let sc: str = ((st != nil)) ? intToStr(nodePosCol(st)) : "0"
                var sn: str = ""
                if (st != nil) && (nodeKind(st) == nkLet || nodeKind(st) == nkVar) && kidCount(st) > 0:
                    sn = plainName(kid(st, 0))
                echo("[backend] debugWhileStmt: i=" + intToStr(di) + " kind=nk#" + sk + " @" + sl + ":" + sc + " name=" + sn)
    let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
    blockBuilderPopLoop(b)
    if ! uirCoreResultBoolIsOk(bodyTermRes):
        return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyTermRes))
    let bodyTerminated: bool = uirCoreResultBoolValue(bodyTermRes)
    if ! bodyTerminated:
        blockBuilderFinish(b, uirCoreTermBr(condLabel))
    if isInfinite:
        # Ensure the unused false-branch label exists for CFG integrity.
        blockBuilderStart(b, endLabel)
        blockBuilderFinish(b, uirCoreTermBr(endLabel))
        return Ok[bool](true)
    blockBuilderStart(b, endLabel)
    return Ok[bool](false)

fn lowerCondBranch(b: BlockBuilder, condNode: Node, tLabel: str, fLabel: str): Result[bool] =
    if (condNode == nil):
        return Err[bool]("uirCore_builder: nil cond")
    var node: Node = condNode
    while astNodeIdValid(node) && nodeKind(node) == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    if astNodeIdValid(node) && nodeKind(node) == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        if op == "&&" || op == "||":
            let lhsNode: Node = kid(node, 1)
            let rhsNode: Node = kid(node, 2)
            let lhsRes: Result[UirExprId] = lowerExprValue(b, lhsNode, uirCoreTypeI32())
            if ! IsOk[UirExprId](lhsRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](lhsRes))
            if op == "&&":
                let rhsLabel: str = blockBuilderNextLabel(b, "and_rhs")
                blockBuilderFinish(b, uirCoreTermCbr(Value[UirExprId](lhsRes), rhsLabel, fLabel))
                blockBuilderStart(b, rhsLabel)
                let rhsRes: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI32())
                if ! IsOk[UirExprId](rhsRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](rhsRes))
                blockBuilderFinish(b, uirCoreTermCbr(Value[UirExprId](rhsRes), tLabel, fLabel))
                return Ok[bool](true)
            else:
                let rhsLabel2: str = blockBuilderNextLabel(b, "or_rhs")
                blockBuilderFinish(b, uirCoreTermCbr(Value[UirExprId](lhsRes), tLabel, rhsLabel2))
                blockBuilderStart(b, rhsLabel2)
                let rhsRes2: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI32())
                if ! IsOk[UirExprId](rhsRes2):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](rhsRes2))
                blockBuilderFinish(b, uirCoreTermCbr(Value[UirExprId](rhsRes2), tLabel, fLabel))
                return Ok[bool](true)
    let condRes: Result[UirExprId] = lowerExprValue(b, node, uirCoreTypeI32())
    if ! IsOk[UirExprId](condRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](condRes))
    blockBuilderFinish(b, uirCoreTermCbr(Value[UirExprId](condRes), tLabel, fLabel))
    return Ok[bool](true)

fn lowerBoolAssign(b: BlockBuilder, exprNode: Node, name: str, slot: int32): Result[bool] =
    let trueLabel: str = blockBuilderNextLabel(b, "bool_true")
    let falseLabel: str = blockBuilderNextLabel(b, "bool_false")
    let joinLabel: str = blockBuilderNextLabel(b, "bool_join")
    let condRes: Result[bool] = lowerCondBranch(b, exprNode, trueLabel, falseLabel)
    if ! uirCoreResultBoolIsOk(condRes):
        return ErrInfo[bool](uirCoreResultBoolErrorInfo(condRes))
    blockBuilderStart(b, trueLabel)
    blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreConstI64(1)))
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))
    blockBuilderStart(b, falseLabel)
    blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreConstI64(0)))
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))
    blockBuilderStart(b, joinLabel)
    return Ok[bool](false)

fn lowerAssignValue(b: BlockBuilder, exprNode: Node, name: str, slot: int32): Result[bool] =
    let objLocalIdx: int32 = funcFindObjLocal(b.func, slot)
    if objLocalIdx >= 0:
        let fref: UirCoreFunc = b.func
        let dstOl: UirCoreObjLocal = uirCoreFuncObjLocalAt(fref, objLocalIdx)
        let objTypeName: str = dstOl.objTypeName
        let dstPtr: UirExprId = uirCoreLocal(slot)
        let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(b.module, objTypeName)
        let hiddenResultSlot0: int32 = uirCoreHiddenResultSlot(b.env, fref)
        let isImplicitObjResultDst: bool = (slot == hiddenResultSlot0) && len(objTypeName) > 0
        if (getEnv "BACKEND_DEBUG_ALIAS" == "1") && (objTypeName == "Node"):
            let mTmp: UirCoreModule = b.module
            echo("[backend] debug: alias Node kind=" + intToStr(int32(aliasTy.kind)) +
                 " aliases=" + intToStr(uirCoreModuleTypeAliasesLen(mTmp)) +
                 " objs=" + intToStr(uirCoreModuleObjTypesLen(mTmp)))
        if aliasTy.kind != mtVoid:
            if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
                blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreConstI64(0)))
                return Ok[bool](false)
            let rhsRes: Result[UirExprId] = lowerExprValue(b, exprNode, aliasTy)
            if ! IsOk[UirExprId](rhsRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](rhsRes))
            blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, Value[UirExprId](rhsRes)))
            return Ok[bool](false)
        if dstOl.frameOff < 0 && !isImplicitObjResultDst:
            # Pointer-like locals (for example ref-like values) are tracked as objLocals for layout info,
            # but they do not own object storage. Assign them like scalar pointer slots.
            let slotKeyPtr: str = localTypeKey(b.env, slot)
            if len(slotKeyPtr) > 0 && uirCoreStrStartsWith(slotKeyPtr, "var_") &&
               !uirCoreStrStartsWith(slotKeyPtr, "var_ref_"):
                let dstPtrVar: UirExprId = uirCoreLocal(slot)
                if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
                    let initVarRes: Result[bool] = emitObjDefaultInitPtrs(b, dstPtrVar, objTypeName)
                    if !uirCoreResultBoolIsOk(initVarRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(initVarRes))
                    return Ok[bool](false)
                var nodeVarPtr: Node = exprNode
                while astNodeIdValid(nodeVarPtr) && nodeKind(nodeVarPtr) == nkPar && kidCount(nodeVarPtr) > 0:
                    nodeVarPtr = kid(nodeVarPtr, 0)
                if astNodeIdValid(nodeVarPtr) && nodeKind(nodeVarPtr) == nkCall:
                    let callVarRes: Result[UirExprId] = lowerCallWithLeadingArg(b, nodeVarPtr, dstPtrVar)
                    if !IsOk[UirExprId](callVarRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](callVarRes))
                    return Ok[bool](false)
                let srcVarPtrRes: Result[UirExprId] = lowerExprValue(b, exprNode, uirCoreTypeI64())
                if !IsOk[UirExprId](srcVarPtrRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](srcVarPtrRes))
                let copyVarPtrRes: Result[bool] = emitObjCopyPtrs(b, dstPtrVar, objTypeName, Value[UirExprId](srcVarPtrRes))
                if !uirCoreResultBoolIsOk(copyVarPtrRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyVarPtrRes))
                return Ok[bool](false)
            if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
                blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreConstI64(0)))
                return Ok[bool](false)
            var node2: Node = exprNode
            while astNodeIdValid(node2) && nodeKind(node2) == nkPar && kidCount(node2) > 0:
                node2 = kid(node2, 0)
            if astNodeIdValid(node2) && nodeKind(node2) == nkCase:
                let caseRes: Result[bool] = lowerCaseAssign(b, node2, name, slot)
                if !uirCoreResultBoolIsOk(caseRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(caseRes))
                return caseRes
            if astNodeIdValid(node2) && nodeKind(node2) == nkIf:
                let ifRes: Result[bool] = lowerIfAssign(b, node2, name, slot)
                if ! uirCoreResultBoolIsOk(ifRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(ifRes))
                return Ok[bool](false)
            if astNodeIdValid(node2) && nodeKind(node2) == nkInfix && kidCount(node2) >= 3:
                let opNode: Node = kid(node2, 0)
                let op: str = backendOpName(opNode)
                if op == "&&" || op == "||":
                    let boolRes: Result[bool] = lowerBoolAssign(b, node2, name, slot)
                    if ! uirCoreResultBoolIsOk(boolRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(boolRes))
                    return Ok[bool](false)
            let slotType0: UirCoreType = localType(b.env, slot)
            let rhsRes0: Result[UirExprId] = lowerExprValue(b, exprNode, slotType0)
            if ! IsOk[UirExprId](rhsRes0):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](rhsRes0))
            blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, Value[UirExprId](rhsRes0)))
            return Ok[bool](false)
        if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
            let initRes: Result[bool] = emitObjDefaultInitPtrs(b, dstPtr, objTypeName)
            if ! uirCoreResultBoolIsOk(initRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(initRes))
            return Ok[bool](false)
        var node: Node = exprNode
        while astNodeIdValid(node) && nodeKind(node) == nkPar && kidCount(node) > 0:
            node = kid(node, 0)
        if (node != nil) && (nodeKind(node) == nkIdent || nodeKind(node) == nkSymbol):
            let srcName: str = plainName(node)
            let srcSlot: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, srcName)
            if srcSlot >= 0:
                let srcObjLocalIdx: int32 = funcFindObjLocal(b.func, srcSlot)
                if srcObjLocalIdx >= 0:
                    let srcOl: UirCoreObjLocal = uirCoreFuncObjLocalAt(fref, srcObjLocalIdx)
                    let dstLayout: str = uirCoreObjLayoutName(b.module, objTypeName)
                    let srcLayout: str = uirCoreObjLayoutName(b.module, srcOl.objTypeName)
                    if ! (srcLayout == dstLayout):
                        let line: str = intToStr(nodePosLine(node))
                        let col: str = intToStr(nodePosCol(node))
                        return Err[bool]("uirCore_builder: object copy type mismatch dst=" + objTypeName +
                                         " src=" + srcOl.objTypeName +
                                         " (dstName=" + name + " srcName=" + srcName +
                                         " fn=" + uirCoreFuncNameOf(fref) + " " + uirCoreFuncOriginFileOf(fref) + ":" + line + ":" + col + ")")
                    let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, uirCoreLocal(srcSlot))
                    if ! uirCoreResultBoolIsOk(copyRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes))
                    return Ok[bool](false)
            if srcSlot < 0:
                var gSym: str = srcName
                let mod0: UirCoreModule = b.module
                var gi: int32 = moduleGlobalIndex(mod0, gSym)
                if gi < 0 && uirCoreFuncIdValid(b.func) && uirCoreDupGlobalNamesHas(srcName):
                    let f2: UirCoreFunc = b.func
                    let g2: str = uirCoreMaybeMangleDupGlobalName(srcName, uirCoreFuncOriginFileOf(f2))
                    if len(g2) > 0:
                        gSym = g2
                        gi = moduleGlobalIndex(mod0, gSym)
                if gi < 0 && uirCoreDupGlobalNamesHas(srcName):
                    let gi2: int32 = moduleFindGlobalIndexByBaseUnique(mod0, srcName)
                    if (mod0 != nil) && gi2 >= 0 && gi2 < uirCoreModuleGlobalsLen(mod0):
                        let g2: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, gi2)
                        if len(g2.name) > 0:
                            gSym = g2.name
                            gi = gi2
                if gi >= 0:
                    let gObj: str = uirCoreGlobalObjTypeGet(gSym)
                    if len(gObj) > 0:
                        if ! (gObj == objTypeName):
                            return Err[bool]("uirCore_builder: object copy global type mismatch")
                        let srcPtr: UirExprId = uirCoreLoad(uirCoreGlobalAddr(gSym), uirCoreTypeI64())
                        let copyRes2: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, srcPtr)
                        if ! uirCoreResultBoolIsOk(copyRes2):
                            return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes2))
                        return Ok[bool](false)
        if astNodeIdValid(node) && nodeKind(node) == nkCall:
            if uirCoreCallIsNamed(node, "new"):
                if os.getEnvDefault("BACKEND_DEBUG_NEW", "") == "1":
                    os.writeLine(os.get_stderr(),
                                 "[backend] debugNewAssign: dst=" + name +
                                 " obj=" + objTypeName +
                                 " slot=" + intToStr(slot))
                    os.c_fflush(os.get_stderr())
                let newRes: Result[UirExprId] = lowerExprValue(b, node, uirCoreTypeI64())
                if !IsOk[UirExprId](newRes):
                    return Err[bool]("uirCore_builder: new init assign failed dst=" + name +
                                     " obj=" + objTypeName + " err=" + Error(newRes))
                blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, Value[UirExprId](newRes)))
                return Ok[bool](false)
            if nodeTypeCacheValid(node) && astRefNonNil(nodeTypeCache(node)):
                let callObj: str = typeNodeObjTypeName(b.module, nodeTypeCache(node))
                if len(callObj) > 0 && ! (callObj == objTypeName):
                    return Err[bool]("uirCore_builder: object call return type mismatch")
            let callRes: Result[UirExprId] = lowerCallWithLeadingArg(b, node, dstPtr)
            if ! IsOk[UirExprId](callRes):
                let fallbackMsgObjCall: str = "uirCore_builder: object call assign failed dst=" + name +
                    " obj=" + objTypeName + " fn=" + uirCoreFuncNameOf(fref) +
                    " " + uirCoreFuncOriginFileOf(fref) +
                    " @" + intToStr(nodePosLine(node)) + ":" + intToStr(nodePosCol(node)) +
                    " err=" + Error(callRes)
                os.writeLine(os.get_stderr(), fallbackMsgObjCall)
                os.c_fflush os.get_stderr()
                return Err[bool](fallbackMsgObjCall)
            return Ok[bool](false)
        if astNodeIdValid(node) && nodeKind(node) == nkDotExpr:
            let srcRes: Result[UirExprId] = lowerExprValue(b, node, uirCoreTypeI64())
            if !IsOk[UirExprId](srcRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes))
            let tmpName: str = "__obj_src"
            let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
            uirCoreSetLocalType(b.func, tmpSlot, uirCoreTypeI64())
            blockBuilderAddStmt(b, uirCoreStmtLet(tmpName, tmpSlot, Value[UirExprId](srcRes)))
            let copyRes3: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, uirCoreLocal(tmpSlot))
            if !uirCoreResultBoolIsOk(copyRes3):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes3))
            return Ok[bool](false)
        if astNodeIdValid(node) && nodeKind(node) == nkTupleLit:
            let litRes: Result[bool] = emitTupleLitToPtr(b, dstPtr, objTypeName, node)
            if ! uirCoreResultBoolIsOk(litRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(litRes))
            return Ok[bool](false)
        if astNodeIdValid(node) && nodeKind(node) == nkSeqLit && uirCoreStrStartsWith(dstOl.typeKey, "seq_"):
            let key: str = dstOl.typeKey
            let litRes2: Result[bool] = emitSeqLitToPtr(b, dstPtr, key, node)
            if ! uirCoreResultBoolIsOk(litRes2):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(litRes2))
            return Ok[bool](false)
        if astNodeIdValid(node) && nodeKind(node) == nkComprehension && uirCoreStrStartsWith(dstOl.typeKey, "seq_"):
            let key2: str = dstOl.typeKey
            let compRes: Result[bool] = emitSeqComprehensionToPtr(b, name, dstPtr, key2, node)
            if !uirCoreResultBoolIsOk(compRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(compRes))
            return compRes
        if astNodeIdValid(node) && nodeKind(node) == nkBracketExpr && kidCount(node) == 2 && uirCoreStrStartsWith(dstOl.typeKey, "seq_"):
            var idx0: Node = kid(node, 1)
            while astNodeIdValid(idx0) && nodeKind(idx0) == nkPar && kidCount(idx0) > 0:
                idx0 = kid(idx0, 0)
            if astNodeIdValid(idx0) && nodeKind(idx0) == nkInfix && kidCount(idx0) >= 3:
                let opNode: Node = kid(idx0, 0)
                let op: str = backendOpName(opNode)
                if op == ".." || op == "..<":
                    let base0: Node = kid(node, 0)
                    var baseKey: str = ""
                    if astNodeIdValid(base0) && nodeTypeCacheValid(base0) && astRefNonNil(nodeTypeCache(base0)):
                        baseKey = typeKey nodeTypeCache(base0)
                    if len(baseKey) == 0 && (base0 != nil) && (nodeKind(base0) == nkIdent || nodeKind(base0) == nkSymbol):
                        let nm: str = plainName(base0)
                        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm)
                        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                            baseKey = funcObjTypeKey(b.func, slot0)
                    if len(baseKey) > 0 && uirCoreStrStartsWith(baseKey, "seq_") && !(baseKey == dstOl.typeKey):
                        return Err[bool]("uirCore_builder: seq slice type mismatch")

                    let baseRes: Result[UirExprId] = lowerExprValue(b, base0, uirCoreTypeI64())
                    if !IsOk[UirExprId](baseRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](baseRes))
                    let startRes: Result[UirExprId] = lowerExprValue(b, kid(idx0, 1), uirCoreTypeI64())
                    if !IsOk[UirExprId](startRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](startRes))
                    let stopRes: Result[UirExprId] = lowerExprValue(b, kid(idx0, 2), uirCoreTypeI64())
                    if !IsOk[UirExprId](stopRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](stopRes))
                    let exclusive: UirExprId = (op == "..<") ? uirCoreConstI64(1) : uirCoreConstI64(0)
                    let start32: UirExprId = uirCoreCast(uirCoreTypeI32(), Value[UirExprId](startRes))
                    let stop32: UirExprId = uirCoreCast(uirCoreTypeI32(), Value[UirExprId](stopRes))

                    let elemKey: str = str(rawmemPtrAdd(rawmemAsVoid(dstOl.typeKey), 4))
                    let typeArg0: Node = newIdent(elemKey, nodePos(node))
                    var typeArgs2: Node[]
                    astNodeSeqAppend(typeArgs2, typeArg0)
                    let callName2: str = mangleInstance("__cheng_slice_vec", typeArgs2)
                    var args2: UirExprId[]
                    builderExprSeqAppend(args2, dstPtr)
                    builderExprSeqAppend(args2, Value[UirExprId](baseRes))
                    builderExprSeqAppend(args2, start32)
                    builderExprSeqAppend(args2, stop32)
                    builderExprSeqAppend(args2, exclusive)
                    blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall(callName2, args2)))
                    return Ok[bool](false)
        if astNodeIdValid(node) && nodeTypeCacheValid(node) && astRefNonNil(nodeTypeCache(node)):
            let rhsObj: str = typeNodeObjTypeName(b.module, nodeTypeCache(node))
            if len(rhsObj) > 0 && typeNodeIsObjValue(b.module, nodeTypeCache(node)):
                if !(rhsObj == objTypeName):
                    return Err[bool]("uirCore_builder: object value assignment type mismatch")
                let srcRes: Result[UirExprId] = lowerExprValue(b, node, uirCoreTypeI64())
                if !IsOk[UirExprId](srcRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes))
                let tmpName: str = "__obj_src"
                let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
                uirCoreSetLocalType(b.func, tmpSlot, uirCoreTypeI64())
                blockBuilderAddStmt(b, uirCoreStmtLet(tmpName, tmpSlot, Value[UirExprId](srcRes)))
                let copyRes3: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, uirCoreLocal(tmpSlot))
                if !uirCoreResultBoolIsOk(copyRes3):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes3))
                return Ok[bool](false)
        if astNodeIdValid(node) && nodeKind(node) == nkBracketExpr && kidCount(node) == 2:
            let srcRes: Result[UirExprId] = lowerExprValue(b, node, uirCoreTypeI64())
            if !IsOk[UirExprId](srcRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes))
            let tmpName: str = "__obj_src"
            let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
            uirCoreSetLocalType(b.func, tmpSlot, uirCoreTypeI64())
            blockBuilderAddStmt(b, uirCoreStmtLet(tmpName, tmpSlot, Value[UirExprId](srcRes)))
            let copyRes3: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, uirCoreLocal(tmpSlot))
            if !uirCoreResultBoolIsOk(copyRes3):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes3))
            return Ok[bool](false)
        if (node != nil) && (nodeKind(node) == nkInfix || nodeKind(node) == nkPrefix || nodeKind(node) == nkPostfix):
            let srcRes4: Result[UirExprId] = lowerExprValue(b, node, uirCoreTypeI64())
            if !IsOk[UirExprId](srcRes4):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes4))
            let tmpName4: str = "__obj_src"
            let tmpSlot4: int32 = localAdd(b.env, tmpName4, uirCoreTypeI64())
            uirCoreSetLocalType(b.func, tmpSlot4, uirCoreTypeI64())
            blockBuilderAddStmt(b, uirCoreStmtLet(tmpName4, tmpSlot4, Value[UirExprId](srcRes4)))
            let srcObjLocalIdx4: int32 = funcFindObjLocal(b.func, tmpSlot4)
            if srcObjLocalIdx4 >= 0:
                let srcOl4: UirCoreObjLocal = uirCoreFuncObjLocalAt(fref, srcObjLocalIdx4)
                let dstLayout4: str = uirCoreObjLayoutName(b.module, objTypeName)
                let srcLayout4: str = uirCoreObjLayoutName(b.module, srcOl4.objTypeName)
                if ! (srcLayout4 == dstLayout4):
                    return Err[bool]("uirCore_builder: object value assignment type mismatch")
                let copyRes4: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName, uirCoreLocal(tmpSlot4))
                if !uirCoreResultBoolIsOk(copyRes4):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes4))
                return Ok[bool](false)
        var fnName: str = ""
        var fp: str = ""
        if (b != nil) && uirCoreFuncIdValid(b.func):
            let f0: UirCoreFunc = b.func
            fnName = uirCoreFuncNameOf(f0)
            fp = uirCoreFuncOriginFileOf(f0)
        let line: str = ((exprNode != nil)) ? intToStr(nodePosLine(exprNode)) : "0"
        let col: str = ((exprNode != nil)) ? intToStr(nodePosCol(exprNode)) : "0"
        let k: str = ((node != nil)) ? intToStr(int32(nodeKind(node))) : "0"
        var tcObj: str = ""
        var tcKind: str = "0"
        if astNodeIdValid(node) && nodeTypeCacheValid(node) && astRefNonNil(nodeTypeCache(node)):
            let tc0: Node = nodeTypeCache(node)
            tcObj = typeNodeObjTypeName(b.module, tc0)
            tcKind = intToStr(int32(nodeKind(tc0)))
        return Err[bool]("uirCore_builder: object value assignment not supported: " + name +
                         " (obj=" + objTypeName + " rhsKind=nk#" + k +
                         " tcObj=" + tcObj + " tcKind=nk#" + tcKind +
                         " fn=" + fnName + " " + fp + ":" + line + ":" + col + ")")
    let slotKey0: str = localTypeKey(b.env, slot)
    if uirCoreParamIsVarKey(slotKey0):
        let baseKey0: str = uirCoreParamVarBaseKey(slotKey0)
        let storeThroughAddr: bool = uirCoreParamWantsVarAddr(b.module, slotKey0)
        if storeThroughAddr:
            var storeTy0: UirCoreType = uirCoreTypeI64()
            if len(baseKey0) > 0:
                if isPtrRefVarLikeKey(baseKey0):
                    storeTy0 = uirCoreTypeI64()
                else:
                    storeTy0 = uirCoreTypeFromTypeKeyName(baseKey0)
                    if storeTy0.kind == mtVoid:
                        storeTy0 = uirCoreTypeI64()
            var nodeVarStore: Node = exprNode
            while astNodeIdValid(nodeVarStore) && nodeKind(nodeVarStore) == nkPar && kidCount(nodeVarStore) > 0:
                nodeVarStore = kid(nodeVarStore, 0)
            if astNodeIdValid(nodeVarStore) && nodeKind(nodeVarStore) == nkNilLit && isSemanticStrKey(baseKey0):
                let lineStore: str = intToStr(nodePosLine(nodeVarStore))
                let colStore: str = intToStr(nodePosCol(nodeVarStore))
                if !uirCoreSkipSemStdDuplicateRelaxEnabled():
                    return Err[bool]("uirCore_builder: semantic str cannot be assigned nil; use \"\" @" +
                                     lineStore + ":" + colStore)
            if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
                blockBuilderAddStmt(b, uirCoreStmtStore(uirCoreLocal(slot), uirCoreConstI64(0), storeTy0))
                return Ok[bool](false)
            let rhsVarRes: Result[UirExprId] = lowerExprValue(b, exprNode, storeTy0)
            if !IsOk[UirExprId](rhsVarRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](rhsVarRes))
            blockBuilderAddStmt(b, uirCoreStmtStore(uirCoreLocal(slot), Value[UirExprId](rhsVarRes), storeTy0))
            return Ok[bool](false)
        # Object-value `var` assignment must write through the pointed storage.
        # Rebinding the local pointer slot drops the caller-visible update.
        var dstObjType: str = ""
        if len(baseKey0) > 0 && b.module != nil:
            dstObjType = uirCoreObjTypeFromTypeKey(b.module, baseKey0)
            if (len(dstObjType) == 0) &&
               (baseKey0 == "seq" || uirCoreStrStartsWith(baseKey0, "seq_") || uirCoreStrStartsWith(baseKey0, "seq_fixed_")) &&
               uirCoreHasObjType(b.module, "seq"):
                dstObjType = "seq"
            if (len(dstObjType) == 0) &&
               (baseKey0 == "Table" || uirCoreStrStartsWith(baseKey0, "Table_")) &&
               uirCoreHasObjType(b.module, "Table"):
                dstObjType = "Table"
        if len(dstObjType) > 0:
            let dstPtr0: UirExprId = uirCoreLocal(slot)
            if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
                let initRes0: Result[bool] = emitObjDefaultInitPtrs(b, dstPtr0, dstObjType)
                if !uirCoreResultBoolIsOk(initRes0):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(initRes0))
                return Ok[bool](false)
            var nodeVar0: Node = exprNode
            while astNodeIdValid(nodeVar0) && nodeKind(nodeVar0) == nkPar && kidCount(nodeVar0) > 0:
                nodeVar0 = kid(nodeVar0, 0)
            if astNodeIdValid(nodeVar0) && nodeKind(nodeVar0) == nkCall:
                let callRes0: Result[UirExprId] = lowerCallWithLeadingArg(b, nodeVar0, dstPtr0)
                if !IsOk[UirExprId](callRes0):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](callRes0))
                return Ok[bool](false)
            let srcVarRes: Result[UirExprId] = lowerExprValue(b, exprNode, uirCoreTypeI64())
            if !IsOk[UirExprId](srcVarRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](srcVarRes))
            let copyVarRes: Result[bool] = emitObjCopyPtrs(b, dstPtr0, dstObjType, Value[UirExprId](srcVarRes))
            if !uirCoreResultBoolIsOk(copyVarRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyVarRes))
            return Ok[bool](false)
    if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
        if isStringKey(localTypeKey(b.env, slot)):
            let labelEmpty: str = uirCoreAddCString(b.module, "")
            blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreGlobalAddr(labelEmpty)))
            return Ok[bool](false)
        blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreConstI64(0)))
        return Ok[bool](false)
    var node: Node = exprNode
    while astNodeIdValid(node) && nodeKind(node) == nkPar && kidCount(node) > 0:
        node = kid(node, 0)
    let slotKey1: str = localTypeKey(b.env, slot)
    if astNodeIdValid(node) && nodeKind(node) == nkNilLit && isSemanticStrKey(slotKey1):
        let lineAssign: str = intToStr(nodePosLine(node))
        let colAssign: str = intToStr(nodePosCol(node))
        if !uirCoreSkipSemStdDuplicateRelaxEnabled():
            return Err[bool]("uirCore_builder: semantic str cannot be assigned nil; use \"\" @" +
                             lineAssign + ":" + colAssign)
    if astNodeIdValid(node) && nodeKind(node) == nkCase:
        let caseRes: Result[bool] = lowerCaseAssign(b, node, name, slot)
        if !uirCoreResultBoolIsOk(caseRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(caseRes))
        return caseRes
    if astNodeIdValid(node) && nodeKind(node) == nkIf:
        let ifRes: Result[bool] = lowerIfAssign(b, node, name, slot)
        if ! uirCoreResultBoolIsOk(ifRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(ifRes))
        return Ok[bool](false)
    if astNodeIdValid(node) && nodeKind(node) == nkInfix && kidCount(node) >= 3:
        let opNode: Node = kid(node, 0)
        let op: str = backendOpName(opNode)
        if op == "&&" || op == "||":
            let boolRes: Result[bool] = lowerBoolAssign(b, node, name, slot)
            if ! uirCoreResultBoolIsOk(boolRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(boolRes))
            return Ok[bool](false)
    let slotType: UirCoreType = localType(b.env, slot)
    let rhsRes: Result[UirExprId] = lowerExprValue(b, exprNode, slotType)
    if ! IsOk[UirExprId](rhsRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](rhsRes))
    blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, Value[UirExprId](rhsRes)))
    return Ok[bool](false)

fn lowerForStmt(b: BlockBuilder, forNode: Node): Result[bool] =
    if !astNodeIdValid(forNode) || nodeKind(forNode) != nkFor:
        return Err[bool]("uirCore_builder: invalid for")
    if kidCount(forNode) < 3:
        return Err[bool]("uirCore_builder: for expects pattern/iter/body")
    let iterExpr: Node = kid(forNode, 1)
    let bodyRaw: Node = kid(forNode, 2)

    # Parse patterns:
    # - Single: `for v in xs:`
    # - Tuple: `for i, v in xs:` (parser represents it as nkTupleLit of patterns)
    var patNames: str[]
    var patTypes: Node[]
    let patNode: Node = kid(forNode, 0)
    if astNodeIdValid(patNode) && nodeKind(patNode) == nkTupleLit:
        for pi in 0..<kidCount(patNode):
            let p: Node = kid(patNode, pi)
            var nameNode: Node = p
            var typeNode: Node = astInvalidNodeId()
            if astNodeIdValid(p) && nodeKind(p) == nkPattern && kidCount(p) > 0:
                nameNode = kid(p, 0)
                if kidCount(p) > 1:
                    typeNode = kid(p, 1)
            if (nameNode == nil) || (nodeKind(nameNode) != nkIdent && nodeKind(nameNode) != nkSymbol):
                return Err[bool]("uirCore_builder: for expects identifier patterns")
            builderStrSeqAppend(patNames, plainName(nameNode))
            astNodeSeqAppend(patTypes, typeNode)
    else:
        var nameNode: Node = patNode
        var typeNode: Node = astInvalidNodeId()
        if astNodeIdValid(patNode) && nodeKind(patNode) == nkPattern && kidCount(patNode) > 0:
            nameNode = kid(patNode, 0)
            if kidCount(patNode) > 1:
                typeNode = kid(patNode, 1)
        if (nameNode == nil) || (nodeKind(nameNode) != nkIdent && nodeKind(nameNode) != nkSymbol):
            return Err[bool]("uirCore_builder: for expects identifier pattern")
        builderStrSeqAppend(patNames, plainName(nameNode))
        astNodeSeqAppend(patTypes, typeNode)
    if patNames.len <= 0:
        return Err[bool]("uirCore_builder: for expects pattern")
    if patNames.len > 2:
        return Err[bool]("uirCore_builder: for supports up to 2 patterns")

    var bodyNode: Node = bodyRaw
    if astNodeIdValid(bodyNode) && nodeKind(bodyNode) != nkStmtList:
        var wrapBody: Node = newNode(nkStmtList, nodePos(bodyNode))
        addSon(wrapBody, bodyNode)
        bodyNode = wrapBody
    if !astNodeIdValid(bodyNode) || nodeKind(bodyNode) != nkStmtList:
        return Err[bool]("uirCore_builder: for expects stmt list body")

    # 1) Range loops: `for i in a..b` / `a..<b`
    if astNodeIdValid(iterExpr) && nodeKind(iterExpr) == nkInfix && kidCount(iterExpr) >= 3:
        let opNode: Node = kid(iterExpr, 0)
        let op: str = backendOpName(opNode)
        if op == ".." || op == "..<":
            if patNames.len != 1:
                return Err[bool]("uirCore_builder: range for expects single pattern")
            let varName: str = patNames[0]
            let varTypeNode: Node = patTypes[0]
            let varType: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, varTypeNode)
            let slot: int32 = localAdd(b.env, varName, varType)
            uirCoreSetLocalType(b.func, slot, varType)

            let startNode: Node = kid(iterExpr, 1)
            let endNode: Node = kid(iterExpr, 2)
            let startRes: Result[UirExprId] = lowerExprValue(b, startNode, varType)
            if ! IsOk[UirExprId](startRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](startRes))
            blockBuilderAddStmt(b, uirCoreStmtVar(varName, slot, Value[UirExprId](startRes)))

            let endName: str = blockBuilderNextTemp(b, "__for_end")
            let endSlot: int32 = localAdd(b.env, endName, varType)
            uirCoreSetLocalType(b.func, endSlot, varType)
            let endRes: Result[UirExprId] = lowerExprValue(b, endNode, varType)
            if ! IsOk[UirExprId](endRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](endRes))
            blockBuilderAddStmt(b, uirCoreStmtVar(endName, endSlot, Value[UirExprId](endRes)))

            let condLabel: str = blockBuilderNextLabel(b, "for_cond")
            let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
            let incLabel: str = blockBuilderNextLabel(b, "for_inc")
            let endLabel: str = blockBuilderNextLabel(b, "for_end")
            blockBuilderFinish(b, uirCoreTermBr(condLabel))

            blockBuilderStart(b, condLabel)
            var condExpr: UirExprId
            if op == "..":
                condExpr = uirCoreCmp(mcLe, uirCoreLocal(slot), uirCoreLocal(endSlot))
            else:
                condExpr = uirCoreCmp(mcLt, uirCoreLocal(slot), uirCoreLocal(endSlot))
            blockBuilderFinish(b, uirCoreTermCbr(condExpr, bodyLabel, endLabel))

            blockBuilderStart(b, bodyLabel)
            blockBuilderPushLoop(b, endLabel, incLabel)
            let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
            blockBuilderPopLoop(b)
            if ! uirCoreResultBoolIsOk(bodyTermRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyTermRes))
            let bodyTerminated: bool = uirCoreResultBoolValue(bodyTermRes)
            if ! bodyTerminated:
                blockBuilderFinish(b, uirCoreTermBr(incLabel))

            blockBuilderStart(b, incLabel)
            let incExpr: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(slot), uirCoreConstI64(1))
            blockBuilderAddStmt(b, uirCoreStmtAssign(varName, slot, incExpr))
            blockBuilderFinish(b, uirCoreTermBr(condLabel))

            blockBuilderStart(b, endLabel)
            return Ok[bool](false)

    # 2) Iterable loops: `for v in seq/str/Table/HashMap`
    var iterKey: str = ""
    if astNodeIdValid(iterExpr) && nodeTypeCacheValid(iterExpr) && astRefNonNil(nodeTypeCache(iterExpr)):
        iterKey = typeKey nodeTypeCache(iterExpr)
    if (len(iterKey) == 0 || (iterKey == "node")) && (iterExpr != nil) && (nodeKind(iterExpr) == nkIdent || nodeKind(iterExpr) == nkSymbol):
        let nm: str = plainName(iterExpr)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm)
        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
            iterKey = funcObjTypeKey(b.func, slot0)
        elif slot0 >= 0:
            iterKey = localTypeKey(b.env, slot0)
    if (len(iterKey) == 0 || (iterKey == "node")) && astNodeIdValid(iterExpr) && nodeKind(iterExpr) == nkSeqLit:
        # For seq literals, stage1 sometimes clears typeCache. Infer a best-effort element type.
        if kidCount(iterExpr) > 0:
            var elemKey: str = "int32"
            for ii in 0..<kidCount(iterExpr):
                var e: Node = kid(iterExpr, ii)
                if astNodeIdValid(e) && nodeKind(e) == nkCallArg && kidCount(e) > 1:
                    e = kid(e, 1)
                if astNodeIdValid(e) && nodeKind(e) == nkIntLit:
                    if nodeIntVal(e) > 2147483647 || nodeIntVal(e) < (-2147483647 - 1):
                        elemKey = "int64"
                elif astNodeIdValid(e) && nodeTypeCacheValid(e) && astRefNonNil(nodeTypeCache(e)):
                    let ek: str = typeKey nodeTypeCache(e)
                    if len(ek) > 0:
                        elemKey = ek
            if len(elemKey) > 0:
                iterKey = uirCoreTypeKeySeqName(elemKey)
    if (len(iterKey) == 0 || (iterKey == "node")) && uirCoreNodeIsStringLiteral(iterExpr):
        iterKey = "str"
    if (len(iterKey) == 0 || (iterKey == "node")) && astNodeIdValid(iterExpr) && nodeKind(iterExpr) == nkBracketExpr && kidCount(iterExpr) == 2:
        # Slices preserve the base container type key, e.g. `s[1..<3]` is still `str`.
        let base0: Node = kid(iterExpr, 0)
        var baseKey: str = ""
        if astNodeIdValid(base0) && nodeTypeCacheValid(base0) && astRefNonNil(nodeTypeCache(base0)):
            baseKey = typeKey nodeTypeCache(base0)
        if len(baseKey) == 0 && (base0 != nil) && (nodeKind(base0) == nkIdent || nodeKind(base0) == nkSymbol):
            let nm: str = plainName(base0)
            let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm)
            if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                baseKey = funcObjTypeKey(b.func, slot0)
            elif slot0 >= 0:
                baseKey = localTypeKey(b.env, slot0)
        if len(baseKey) == 0 && uirCoreNodeIsStringLiteral(base0):
            baseKey = "str"
        if len(baseKey) > 0:
            iterKey = baseKey
    if (len(iterKey) == 0 || (iterKey == "node")) && (iterExpr != nil):
        iterKey = caseInferExprTypeKey(b, iterExpr)
    if (len(iterKey) == 0 || (iterKey == "node")) && (iterExpr != nil):
        iterKey = exprTypeKeyShallow(b, iterExpr)
    if (len(iterKey) == 0 || (iterKey == "node")) && astNodeIdValid(iterExpr) && nodeTypeCacheValid(iterExpr) && astRefNonNil(nodeTypeCache(iterExpr)):
        let looseKey: str = uirCoreTypeKeyFromNodeLoose(nodeTypeCache(iterExpr))
        if len(looseKey) > 0:
            iterKey = looseKey

    iterKey = uirCoreTypeKeyStripIterWrappers(iterKey)
    var iterKeyBase: str = uirCoreTypeKeyBaseName(iterKey)
    if len(iterKeyBase) == 0:
        iterKeyBase = iterKey

    if uirCoreStrStartsWith(iterKeyBase, "seq_"):
        var iterPtr: UirExprId
        let iterSeqKey: str = iterKeyBase
        if astNodeIdValid(iterExpr) && nodeKind(iterExpr) == nkSeqLit && !(nodeTypeCacheValid(iterExpr) && astRefNonNil(nodeTypeCache(iterExpr))):
            let lit: Node = iterExpr
            let seqSlotName: str = blockBuilderNextTemp(b, "__for_seq")
            let seqSlot: int32 = localAdd(b.env, seqSlotName, uirCoreTypeI64())
            uirCoreSetLocalType(b.func, seqSlot, uirCoreTypeI64())
            let allocRes: Result[bool] = allocObjValueLocal(b, seqSlot, "seq")
            if ! uirCoreResultBoolIsOk(allocRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(allocRes))
            funcSetObjTypeKey(b.func, seqSlot, iterSeqKey)
            let litRes: Result[bool] = emitSeqLitToPtr(b, uirCoreLocal(seqSlot), iterSeqKey, lit)
            if ! uirCoreResultBoolIsOk(litRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(litRes))
            iterPtr = uirCoreLocal(seqSlot)
        else:
            let iterRes: Result[UirExprId] = lowerExprValue(b, iterExpr, uirCoreTypeI64())
            if ! IsOk[UirExprId](iterRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](iterRes))
            let iterTmpName: str = blockBuilderNextTemp(b, "__for_iter")
            let iterTmpSlot: int32 = localAdd(b.env, iterTmpName, uirCoreTypeI64())
            uirCoreSetLocalType(b.func, iterTmpSlot, uirCoreTypeI64())
            blockBuilderAddStmt(b, uirCoreStmtLet(iterTmpName, iterTmpSlot, Value[UirExprId](iterRes)))
            iterPtr = uirCoreLocal(iterTmpSlot)

        let elemKey: str = str(rawmemPtrAdd(rawmemAsVoid(iterSeqKey), 4))
        if len(elemKey) == 0:
            return Err[bool]("uirCore_builder: for seq missing element type")
        let elemTypeNode: Node = newIdent(elemKey, nodePos(forNode))
        let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, elemTypeNode)
        let sizeRes: Result[int32] = uirCoreSizeOfTypeNode(b.module, elemTypeNode)
        if ! IsOk[int32](sizeRes):
            return ErrInfo[bool](ErrorInfoOf[int32](sizeRes))
        let elemSize: int32 = Value[int32](sizeRes)

        let seqOt: UirCoreObjType = uirCoreGetObjType(b.module, "seq")
        var lenOff: int32 = -1
        var bufOff: int32 = -1
        for fi in 0..<seqOt.fields.len:
            let f: UirCoreObjField = seqOt.fields[fi]
            if (f.name == "len"):
                lenOff = f.offset
            elif (f.name == "buffer"):
                bufOff = f.offset
        if lenOff < 0 || bufOff < 0:
            return Err[bool]("uirCore_builder: seq layout mismatch")

        let lenAddr: UirExprId = (lenOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(lenOff)))
        let bufAddr: UirExprId = (bufOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(bufOff)))

        let lenName: str = blockBuilderNextTemp(b, "__for_len")
        let lenSlot: int32 = localAdd(b.env, lenName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, lenSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtLet(lenName, lenSlot, uirCoreLoad(lenAddr, uirCoreTypeI32())))

        let bufName: str = blockBuilderNextTemp(b, "__for_buf")
        let bufSlot: int32 = localAdd(b.env, bufName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, bufSlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(bufName, bufSlot, uirCoreLoad(bufAddr, uirCoreTypeI64())))

        var idxName: str = blockBuilderNextTemp(b, "__for_i")
        var valName: str = patNames[0]
        if patNames.len == 2:
            idxName = patNames[0]
            valName = patNames[1]

        let idxSlot: int32 = localAdd(b.env, idxName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, idxSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(idxName, idxSlot, uirCoreConstI64(0)))

        let valSlot: int32 = localAdd(b.env, valName, elemTy)
        uirCoreSetLocalType(b.func, valSlot, elemTy)
        blockBuilderAddStmt(b, uirCoreStmtVar(valName, valSlot, uirCoreConstI64(0)))

        let condLabel: str = blockBuilderNextLabel(b, "for_cond")
        let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
        let incLabel: str = blockBuilderNextLabel(b, "for_inc")
        let endLabel: str = blockBuilderNextLabel(b, "for_end")
        blockBuilderFinish(b, uirCoreTermBr(condLabel))

        blockBuilderStart(b, condLabel)
        let condExpr: UirExprId = uirCoreCmp(mcLt, uirCoreLocal(idxSlot), uirCoreLocal(lenSlot))
        blockBuilderFinish(b, uirCoreTermCbr(condExpr, bodyLabel, endLabel))

        blockBuilderStart(b, bodyLabel)
        # Load element from buffer plus computed byte offset.
        let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreLocal(idxSlot))
        let step: UirExprId = uirCoreConstI64(int64(elemSize))
        let off: UirExprId = (elemSize == 1) ? idx64 : uirCoreBin(mbMul, idx64, step)
        let addr: UirExprId = (elemSize == 0) ? uirCoreLocal(bufSlot) : uirCoreBin(mbAdd, uirCoreLocal(bufSlot), off)
        let elemVal: UirExprId = uirCoreLoad(addr, elemTy)
        blockBuilderAddStmt(b, uirCoreStmtAssign(valName, valSlot, elemVal))

        blockBuilderPushLoop(b, endLabel, incLabel)
        let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
        blockBuilderPopLoop(b)
        if ! uirCoreResultBoolIsOk(bodyTermRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyTermRes))
        let bodyTerminated: bool = uirCoreResultBoolValue(bodyTermRes)
        if ! bodyTerminated:
            blockBuilderFinish(b, uirCoreTermBr(incLabel))

        blockBuilderStart(b, incLabel)
        let incExpr: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(idxSlot), uirCoreConstI64(1))
        blockBuilderAddStmt(b, uirCoreStmtAssign(idxName, idxSlot, incExpr))
        blockBuilderFinish(b, uirCoreTermBr(condLabel))

        blockBuilderStart(b, endLabel)
        return Ok[bool](false)

    if isStringKey(iterKeyBase):
        let iterRes: Result[UirExprId] = lowerExprValue(b, iterExpr, uirCoreTypeI64())
        if ! IsOk[UirExprId](iterRes):
            return ErrInfo[bool](ErrorInfoOf[UirExprId](iterRes))
        let iterTmpName: str = blockBuilderNextTemp(b, "__for_iter")
        let iterTmpSlot: int32 = localAdd(b.env, iterTmpName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, iterTmpSlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(iterTmpName, iterTmpSlot, Value[UirExprId](iterRes)))
        let iterPtr: UirExprId = uirCoreLocal(iterTmpSlot)

        # String iteration: index-by-byte over a C string, returns char(i32) masked to 0..255.
        let lenName: str = blockBuilderNextTemp(b, "__for_strlen")
        let lenSlot: int32 = localAdd(b.env, lenName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, lenSlot, uirCoreTypeI32())
        var strlenArgs: UirExprId[]
        builderExprSeqAppend(strlenArgs, iterPtr)
        blockBuilderAddStmt(b, uirCoreStmtLet(lenName, lenSlot, uirCoreCall("cheng_strlen", strlenArgs)))

        var idxName: str = blockBuilderNextTemp(b, "__for_i")
        var chName: str = patNames[0]
        if patNames.len == 2:
            idxName = patNames[0]
            chName = patNames[1]

        let idxSlot: int32 = localAdd(b.env, idxName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, idxSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(idxName, idxSlot, uirCoreConstI64(0)))

        let chSlot: int32 = localAdd(b.env, chName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, chSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(chName, chSlot, uirCoreConstI64(0)))

        let condLabel: str = blockBuilderNextLabel(b, "for_cond")
        let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
        let incLabel: str = blockBuilderNextLabel(b, "for_inc")
        let endLabel: str = blockBuilderNextLabel(b, "for_end")
        blockBuilderFinish(b, uirCoreTermBr(condLabel))

        blockBuilderStart(b, condLabel)
        let condExpr: UirExprId = uirCoreCmp(mcLt, uirCoreLocal(idxSlot), uirCoreLocal(lenSlot))
        blockBuilderFinish(b, uirCoreTermCbr(condExpr, bodyLabel, endLabel))

        blockBuilderStart(b, bodyLabel)
        let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreLocal(idxSlot))
        let addr: UirExprId = uirCoreBin(mbAdd, iterPtr, idx64)
        let raw: UirExprId = uirCoreLoad(addr, uirCoreTypeI32())
        let chVal: UirExprId = uirCoreBin(mbAnd, raw, uirCoreConstI64(255))
        blockBuilderAddStmt(b, uirCoreStmtAssign(chName, chSlot, chVal))

        blockBuilderPushLoop(b, endLabel, incLabel)
        let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
        blockBuilderPopLoop(b)
        if ! uirCoreResultBoolIsOk(bodyTermRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyTermRes))
        let bodyTerminated: bool = uirCoreResultBoolValue(bodyTermRes)
        if ! bodyTerminated:
            blockBuilderFinish(b, uirCoreTermBr(incLabel))

        blockBuilderStart(b, incLabel)
        let incExpr: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(idxSlot), uirCoreConstI64(1))
        blockBuilderAddStmt(b, uirCoreStmtAssign(idxName, idxSlot, incExpr))
        blockBuilderFinish(b, uirCoreTermBr(condLabel))

        blockBuilderStart(b, endLabel)
        return Ok[bool](false)

    if uirCoreTypeKeyIsTableIter(iterKey):
        let iterRes: Result[UirExprId] = lowerExprValue(b, iterExpr, uirCoreTypeI64())
        if ! IsOk[UirExprId](iterRes):
            return ErrInfo[bool](ErrorInfoOf[UirExprId](iterRes))
        let iterTmpName: str = blockBuilderNextTemp(b, "__for_iter")
        let iterTmpSlot: int32 = localAdd(b.env, iterTmpName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, iterTmpSlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(iterTmpName, iterTmpSlot, Value[UirExprId](iterRes)))
        let iterPtr: UirExprId = uirCoreLocal(iterTmpSlot)

        # Inline table iteration: scan `states` and yield matching `keys`/`vals`.
        var tblObjName: str = ""
        if b.module != nil:
            tblObjName = uirCorePtrBaseObjTypeName(b.module, iterKey)
        if len(tblObjName) == 0:
            tblObjName = iterKeyBase
        if (iterExpr != nil) && (nodeKind(iterExpr) == nkIdent || nodeKind(iterExpr) == nkSymbol):
            let nm: str = plainName(iterExpr)
            let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm)
            if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                let objNm: str = funcObjTypeName(b.func, slot0)
                if len(objNm) > 0:
                    tblObjName = objNm

        if b.module != nil:
            let resolved: str = uirCorePtrBaseObjTypeName(b.module, tblObjName)
            if len(resolved) > 0:
                tblObjName = resolved
        if b.module == nil || len(tblObjName) == 0 || ! uirCoreHasObjType(b.module, tblObjName):
            return Err[bool]("uirCore_builder: unknown Table object type")
        let tblOt: UirCoreObjType = uirCoreGetObjType(b.module, tblObjName)
        var keysLenOff: int32 = -1
        var keysBufOff: int32 = -1
        var valsBufOff: int32 = -1
        var statesBufOff: int32 = -1
        for fi2 in 0..<tblOt.fields.len:
            let f: UirCoreObjField = tblOt.fields[fi2]
            if (f.name == "keys.len"):
                keysLenOff = f.offset
            elif (f.name == "keys.buffer"):
                keysBufOff = f.offset
            elif (f.name == "vals.buffer"):
                valsBufOff = f.offset
            elif (f.name == "states.buffer"):
                statesBufOff = f.offset
        if keysLenOff < 0 || keysBufOff < 0 || valsBufOff < 0 || statesBufOff < 0:
            return Err[bool]("uirCore_builder: Table layout mismatch")

        let capName: str = blockBuilderNextTemp(b, "__tbl_cap")
        let capSlot: int32 = localAdd(b.env, capName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, capSlot, uirCoreTypeI32())
        let capAddr: UirExprId = (keysLenOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(keysLenOff)))
        blockBuilderAddStmt(b, uirCoreStmtLet(capName, capSlot, uirCoreLoad(capAddr, uirCoreTypeI32())))

        let keysBufName: str = blockBuilderNextTemp(b, "__tbl_kbuf")
        let keysBufSlot: int32 = localAdd(b.env, keysBufName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, keysBufSlot, uirCoreTypeI64())
        let keysBufAddr: UirExprId = (keysBufOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(keysBufOff)))
        blockBuilderAddStmt(b, uirCoreStmtLet(keysBufName, keysBufSlot, uirCoreLoad(keysBufAddr, uirCoreTypeI64())))

        let valsBufName: str = blockBuilderNextTemp(b, "__tbl_vbuf")
        let valsBufSlot: int32 = localAdd(b.env, valsBufName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, valsBufSlot, uirCoreTypeI64())
        let valsBufAddr: UirExprId = (valsBufOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(valsBufOff)))
        blockBuilderAddStmt(b, uirCoreStmtLet(valsBufName, valsBufSlot, uirCoreLoad(valsBufAddr, uirCoreTypeI64())))

        let statesBufName: str = blockBuilderNextTemp(b, "__tbl_sbuf")
        let statesBufSlot: int32 = localAdd(b.env, statesBufName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, statesBufSlot, uirCoreTypeI64())
        let statesBufAddr: UirExprId = (statesBufOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(statesBufOff)))
        blockBuilderAddStmt(b, uirCoreStmtLet(statesBufName, statesBufSlot, uirCoreLoad(statesBufAddr, uirCoreTypeI64())))

        let keyName: str = patNames[0]
        let keySlot: int32 = localAdd(b.env, keyName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, keySlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtVar(keyName, keySlot, uirCoreConstI64(0)))

        var hasVal: bool = false
        var valName: str = ""
        var valSlot: int32 = -1
        var valTy: UirCoreType = uirCoreTypeI64()
        var valSize: int32 = 8
        if patNames.len == 2:
            hasVal = true
            valName = patNames[1]
            var valKey: str = uirCoreTypeKeyTableValKey(iterKey)
            if (len(valKey) == 0) && astNodeIdValid(iterExpr) && nodeTypeCacheValid(iterExpr) && astRefNonNil(nodeTypeCache(iterExpr)):
                valKey = uirCoreTypeKeyTableValKey(typeKey(nodeTypeCache(iterExpr)))
            if len(valKey) > 0:
                let valTypeNode: Node = newIdent(valKey, nodePos(forNode))
                let valTy2: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, valTypeNode)
                if valTy2.kind != mtVoid:
                    valTy = valTy2
                    let valSize2: int32 = uirCoreTypeSize(valTy)
                    if valSize2 > 0:
                        valSize = valSize2
            valSlot = localAdd(b.env, valName, valTy)
            uirCoreSetLocalType(b.func, valSlot, valTy)
            blockBuilderAddStmt(b, uirCoreStmtVar(valName, valSlot, uirCoreConstI64(0)))

        let idxName: str = blockBuilderNextTemp(b, "__tbl_i")
        let idxSlot: int32 = localAdd(b.env, idxName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, idxSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(idxName, idxSlot, uirCoreConstI64(0)))

        let curIdxName: str = blockBuilderNextTemp(b, "__tbl_cur_i")
        let curIdxSlot: int32 = localAdd(b.env, curIdxName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, curIdxSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(curIdxName, curIdxSlot, uirCoreConstI64(0)))

        let scanLabel: str = blockBuilderNextLabel(b, "for_scan")
        let loadLabel: str = blockBuilderNextLabel(b, "for_load")
        let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
        let endLabel: str = blockBuilderNextLabel(b, "for_end")
        blockBuilderFinish(b, uirCoreTermBr(scanLabel))

        blockBuilderStart(b, scanLabel)
        let scanCond: UirExprId = uirCoreCmp(mcLt, uirCoreLocal(idxSlot), uirCoreLocal(capSlot))
        blockBuilderFinish(b, uirCoreTermCbr(scanCond, loadLabel, endLabel))

        blockBuilderStart(b, loadLabel)
        blockBuilderAddStmt(b, uirCoreStmtAssign(curIdxName, curIdxSlot, uirCoreLocal(idxSlot)))
        let curIdx64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreLocal(curIdxSlot))
        let stAddr: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(statesBufSlot), curIdx64)
        let stVal: UirExprId = uirCoreLoad(stAddr, uirCoreTypeU8())
        let incExpr: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(idxSlot), uirCoreConstI64(1))
        blockBuilderAddStmt(b, uirCoreStmtAssign(idxName, idxSlot, incExpr))
        let isUsed: UirExprId = uirCoreCmp(mcNe, stVal, uirCoreConstI64(0))
        blockBuilderFinish(b, uirCoreTermCbr(isUsed, bodyLabel, scanLabel))

        blockBuilderStart(b, bodyLabel)
        let keyOff2: UirExprId = uirCoreBin(mbMul, curIdx64, uirCoreConstI64(8))
        let keyAddr2: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(keysBufSlot), keyOff2)
        let keyVal: UirExprId = uirCoreLoad(keyAddr2, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtAssign(keyName, keySlot, keyVal))
        if hasVal:
            let valOff2: UirExprId = uirCoreBin(mbMul, curIdx64, uirCoreConstI64(int64(valSize)))
            let valAddr2: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(valsBufSlot), valOff2)
            let valVal: UirExprId = uirCoreLoad(valAddr2, valTy)
            blockBuilderAddStmt(b, uirCoreStmtAssign(valName, valSlot, valVal))

        blockBuilderPushLoop(b, endLabel, scanLabel)
        let bodyTermRes2: Result[bool] = lowerStmtList(b, bodyNode)
        blockBuilderPopLoop(b)
        if ! uirCoreResultBoolIsOk(bodyTermRes2):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyTermRes2))
        let bodyTerminated2: bool = uirCoreResultBoolValue(bodyTermRes2)
        if ! bodyTerminated2:
            blockBuilderFinish(b, uirCoreTermBr(scanLabel))

        blockBuilderStart(b, endLabel)
        return Ok[bool](false)

    let mapFlavor0: int32 = uirCoreHashMapIterFlavorFromTypeKey(iterKey)
    if mapFlavor0 != 0:
        let iterRes: Result[UirExprId] = lowerExprValue(b, iterExpr, uirCoreTypeI64())
        if ! IsOk[UirExprId](iterRes):
            return ErrInfo[bool](ErrorInfoOf[UirExprId](iterRes))
        let iterTmpName: str = blockBuilderNextTemp(b, "__for_iter")
        let iterTmpSlot: int32 = localAdd(b.env, iterTmpName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, iterTmpSlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(iterTmpName, iterTmpSlot, Value[UirExprId](iterRes)))
        let iterPtr: UirExprId = uirCoreLocal(iterTmpSlot)

        var mapObjName: str = ""
        if b.module != nil:
            mapObjName = uirCorePtrBaseObjTypeName(b.module, iterKey)
        if (iterExpr != nil) && (nodeKind(iterExpr) == nkIdent || nodeKind(iterExpr) == nkSymbol):
            let nm: str = plainName(iterExpr)
            let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm)
            if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                let objNm: str = funcObjTypeName(b.func, slot0)
                if len(objNm) > 0:
                    mapObjName = objNm
        if b.module != nil:
            let resolved: str = uirCorePtrBaseObjTypeName(b.module, mapObjName)
            if len(resolved) > 0:
                mapObjName = resolved

        var mapFlavor: int32 = mapFlavor0
        if mapFlavor == 0:
            mapFlavor = uirCoreHashMapIterFlavorFromTypeKey(mapObjName)
        if mapFlavor == 0:
            return Err[bool]("uirCore_builder: unsupported HashMap iter type")

        var keysLenOff: int32 = -1
        var keysBufOff: int32 = -1
        var valsBufOff: int32 = -1
        let hasMapObjLayout: bool = b.module != nil && len(mapObjName) > 0 &&
                                    uirCoreHasObjType(b.module, mapObjName)
        if hasMapObjLayout:
            let mapOt: UirCoreObjType = uirCoreGetObjType(b.module, mapObjName)
            for fiMap in 0..<mapOt.fields.len:
                let f: UirCoreObjField = mapOt.fields[fiMap]
                if (f.name == "keys.len"):
                    keysLenOff = f.offset
                elif (f.name == "keys.buffer"):
                    keysBufOff = f.offset
                elif (f.name == "vals.buffer"):
                    valsBufOff = f.offset
        if keysLenOff < 0 || keysBufOff < 0 || valsBufOff < 0:
            # Fallback to std/hashmaps stable layout:
            # HashMap layout fallback: keys seq plus vals seq.
            keysLenOff = 0
            keysBufOff = 8
            valsBufOff = 24

        let capName: str = blockBuilderNextTemp(b, "__map_cap")
        let capSlot: int32 = localAdd(b.env, capName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, capSlot, uirCoreTypeI32())
        let capAddr: UirExprId = (keysLenOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(keysLenOff)))
        blockBuilderAddStmt(b, uirCoreStmtLet(capName, capSlot, uirCoreLoad(capAddr, uirCoreTypeI32())))

        let keysBufName: str = blockBuilderNextTemp(b, "__map_kbuf")
        let keysBufSlot: int32 = localAdd(b.env, keysBufName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, keysBufSlot, uirCoreTypeI64())
        let keysBufAddr: UirExprId = (keysBufOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(keysBufOff)))
        blockBuilderAddStmt(b, uirCoreStmtLet(keysBufName, keysBufSlot, uirCoreLoad(keysBufAddr, uirCoreTypeI64())))

        let valsBufName: str = blockBuilderNextTemp(b, "__map_vbuf")
        let valsBufSlot: int32 = localAdd(b.env, valsBufName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, valsBufSlot, uirCoreTypeI64())
        let valsBufAddr: UirExprId = (valsBufOff == 0) ? iterPtr : uirCoreBin(mbAdd, iterPtr, uirCoreConstI64(int64(valsBufOff)))
        blockBuilderAddStmt(b, uirCoreStmtLet(valsBufName, valsBufSlot, uirCoreLoad(valsBufAddr, uirCoreTypeI64())))

        let keyName: str = patNames[0]
        let keySlot: int32 = localAdd(b.env, keyName, uirCoreTypeI64())
        uirCoreSetLocalType(b.func, keySlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtVar(keyName, keySlot, uirCoreConstI64(0)))

        var hasVal: bool = false
        var valName: str = ""
        var valSlot: int32 = -1
        var valTy: UirCoreType = uirCoreTypeI32()
        var valSize: int32 = 4
        if patNames.len == 2:
            hasVal = true
            valName = patNames[1]
            if mapFlavor == 2:
                valTy = uirCoreTypeI64()
                let valTyNode: Node = newIdent("seq_int32", nodePos(forNode))
                valTy = uirCoreTypeFromNodeWithModule(b.module, valTyNode)
                let valSizeRes: Result[int32] = uirCoreSizeOfTypeNode(b.module, valTyNode)
                if IsOk[int32](valSizeRes):
                    valSize = Value[int32](valSizeRes)
                else:
                    valSize = 8
            valSlot = localAdd(b.env, valName, valTy)
            uirCoreSetLocalType(b.func, valSlot, valTy)
            blockBuilderAddStmt(b, uirCoreStmtVar(valName, valSlot, uirCoreConstI64(0)))

        let idxName: str = blockBuilderNextTemp(b, "__map_i")
        let idxSlot: int32 = localAdd(b.env, idxName, uirCoreTypeI32())
        uirCoreSetLocalType(b.func, idxSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(idxName, idxSlot, uirCoreConstI64(0)))

        let condLabel: str = blockBuilderNextLabel(b, "for_cond")
        let loadLabel: str = blockBuilderNextLabel(b, "for_load")
        let bodyLabel: str = blockBuilderNextLabel(b, "for_body")
        let incLabel: str = blockBuilderNextLabel(b, "for_inc")
        let endLabel: str = blockBuilderNextLabel(b, "for_end")
        blockBuilderFinish(b, uirCoreTermBr(condLabel))

        blockBuilderStart(b, condLabel)
        let condExpr: UirExprId = uirCoreCmp(mcLt, uirCoreLocal(idxSlot), uirCoreLocal(capSlot))
        blockBuilderFinish(b, uirCoreTermCbr(condExpr, loadLabel, endLabel))

        blockBuilderStart(b, loadLabel)
        let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreLocal(idxSlot))
        let keyOff: UirExprId = uirCoreBin(mbMul, idx64, uirCoreConstI64(8))
        let keyAddr: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(keysBufSlot), keyOff)
        let keyVal: UirExprId = uirCoreLoad(keyAddr, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtAssign(keyName, keySlot, keyVal))
        let hasEntry: UirExprId = uirCoreCmp(mcNe, uirCoreLocal(keySlot), uirCoreConstI64(0))
        blockBuilderFinish(b, uirCoreTermCbr(hasEntry, bodyLabel, incLabel))

        blockBuilderStart(b, bodyLabel)
        if hasVal:
            let stepExpr: UirExprId = uirCoreConstI64(int64(valSize))
            let valOff: UirExprId = (valSize == 1) ? idx64 : uirCoreBin(mbMul, idx64, stepExpr)
            let valAddr: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(valsBufSlot), valOff)
            let valVal: UirExprId = uirCoreLoad(valAddr, valTy)
            blockBuilderAddStmt(b, uirCoreStmtAssign(valName, valSlot, valVal))

        blockBuilderPushLoop(b, endLabel, incLabel)
        let bodyTermRes3: Result[bool] = lowerStmtList(b, bodyNode)
        blockBuilderPopLoop(b)
        if ! uirCoreResultBoolIsOk(bodyTermRes3):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyTermRes3))
        let bodyTerminated3: bool = uirCoreResultBoolValue(bodyTermRes3)
        if ! bodyTerminated3:
            blockBuilderFinish(b, uirCoreTermBr(incLabel))

        blockBuilderStart(b, incLabel)
        let incExpr2: UirExprId = uirCoreBin(mbAdd, uirCoreLocal(idxSlot), uirCoreConstI64(1))
        blockBuilderAddStmt(b, uirCoreStmtAssign(idxName, idxSlot, incExpr2))
        blockBuilderFinish(b, uirCoreTermBr(condLabel))

        blockBuilderStart(b, endLabel)
        return Ok[bool](false)

    let k: str = ((iterExpr != nil)) ? intToStr(int32(nodeKind(iterExpr))) : "0"
    let line: str = ((iterExpr != nil)) ? intToStr(nodePosLine(iterExpr)) : "0"
    let col: str = ((iterExpr != nil)) ? intToStr(nodePosCol(iterExpr)) : "0"
    let keyDbg: str = iterKey
    var extra: str = ""
    if astNodeIdValid(iterExpr) && nodeKind(iterExpr) == nkInfix && kidCount(iterExpr) > 0:
        extra = " op=" + backendOpName(kid(iterExpr, 0))
    return Err[bool]("uirCore_builder: for unsupported iter expression (kind=nk#" + k + " @" + line + ":" + col + " key='" + keyDbg + "'" + extra + ")")

fn casePatternCore(p0: Node): Node =
    var p: Node = p0
    while astNodeIdValid(p) && astNodeKind(p) == nkPar && astKidCount(p) > 0:
        p = astKidAt(p, 0)
    if astNodeIdValid(p) && astNodeKind(p) == nkPattern && astKidCount(p) > 0:
        p = astKidAt(p, 0)
        while astNodeIdValid(p) && astNodeKind(p) == nkPar && astKidCount(p) > 0:
            p = astKidAt(p, 0)
    return p

fn casePatternTypeNode(p0: Node): Node =
    var p: Node = p0
    while astNodeIdValid(p) && astNodeKind(p) == nkPar && astKidCount(p) > 0:
        p = astKidAt(p, 0)
    if astNodeIdValid(p) && astNodeKind(p) == nkPattern && astKidCount(p) > 1:
        return astKidAt(p, 1)
    return nil

fn casePatternIsWildcard(p0: Node): bool =
    let core: Node = casePatternCore(p0)
    if (core != nil) && (astNodeKind(core) == nkIdent || astNodeKind(core) == nkSymbol):
        return (astPlainName(core) == "_")
    return false

fn caseInferExprTypeKey(b: BlockBuilder, n0: Node): str =
    if (b == nil):
        return ""
    var n: Node = n0
    while astNodeIdValid(n) && nodeKind(n) == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    if (n == nil):
        return ""
    if nodeKind(n) == nkBracketExpr && kidCount(n) == 2:
        let baseNode: Node = kid(n, 0)
        var idxNode: Node = kid(n, 1)
        while astNodeIdValid(idxNode) && nodeKind(idxNode) == nkPar && kidCount(idxNode) > 0:
            idxNode = kid(idxNode, 0)
        if astNodeIdValid(idxNode) && nodeKind(idxNode) == nkCallArg:
            if kidCount(idxNode) > 1:
                idxNode = kid(idxNode, 1)
            elif kidCount(idxNode) > 0:
                idxNode = kid(idxNode, 0)
        let debugBracketInfer: bool = (getEnv "BACKEND_DEBUG_BRACKET_INFER" == "1")
        var dbgTarget: bool = false
        if debugBracketInfer:
            if (baseNode != nil) && (nodeKind(baseNode) == nkIdent || nodeKind(baseNode) == nkSymbol) && (plainName(baseNode) == "root"):
                if uirCoreNodeIsStringLiteral(idxNode) && (nodeStrVal(idxNode) == "source_addrs"):
                    dbgTarget = true
            if dbgTarget:
                echo("[backend] debugBracketInfer: root['source_addrs'] start")
        if astNodeIdValid(idxNode) && nodeKind(idxNode) == nkInfix && kidCount(idxNode) >= 3:
            let opNode: Node = kid(idxNode, 0)
            let op: str = backendOpName(opNode)
            if op == ".." || op == "..<":
                let bk0: str = caseInferExprTypeKey(b, baseNode)
                if uirCoreNodeHasStringCtx(bk0, baseNode):
                    return "str"
                if uirCoreStrStartsWith(bk0, "seq_") || uirCoreStrStartsWith(bk0, "seq_fixed_"):
                    return bk0
        var baseKey: str = caseInferExprTypeKey(b, baseNode)
        let seqKey: str = uirCoreSeqLikeKeyFromExpr(b, baseNode)
        if len(seqKey) > 0:
            baseKey = seqKey
        if dbgTarget:
            echo("[backend] debugBracketInfer: baseKey='" + baseKey + "' idxKind=nk#" +
                (((idxNode != nil)) ? intToStr(int32(nodeKind(idxNode))) : "-1"))
        if len(baseKey) > 0:
            baseKey = uirCoreNormalizeObjLookupKey(b.module, baseKey)
            if uirCoreStrStartsWith(baseKey, "seq_"):
                return str(rawmemPtrAdd(rawmemAsVoid(baseKey), 4))
            if uirCoreNodeHasStringCtx(baseKey, baseNode):
                return "char"
        if b.module != nil:
            var argNodes: Node[]
            astNodeSeqAppend(argNodes, baseNode)
            astNodeSeqAppend(argNodes, idxNode)
            var hintSig: str = ""
            if nodeTypeCacheValid(n) && astRefNonNil(nodeTypeCache(n)):
                hintSig = typeKey nodeTypeCache(n)
            let callee0: UirCoreFunc = uirCoreResolveCalleeFuncBestEffort(b, "[]", argNodes, hintSig)
            if dbgTarget:
                let calleeName: str = ((callee0 != nil)) ? uirCoreFuncNameOf(callee0) : ""
                echo("[backend] debugBracketInfer: resolve '[]' hint='" + hintSig + "' callee='" + calleeName + "'")
            if (callee0 != nil):
                var outKey: str = ""
                if uirCoreFuncParamsLen(callee0) > 0:
                    let p0: UirCoreParam = uirCoreFuncParamAt(callee0, 0)
                    if (p0.name == "__ret"):
                        outKey = funcObjTypeKey(callee0, p0.slot)
                if len(outKey) == 0 && len(uirCoreFuncRetTypeKeyOf(callee0)) > 0:
                    outKey = uirCoreFuncRetTypeKeyOf(callee0)
                if len(outKey) > 0:
                    if dbgTarget:
                        echo("[backend] debugBracketInfer: outKey='" + outKey + "'")
                    return outKey
    if nodeKind(n) == nkInfix && kidCount(n) >= 3:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        if op == "+":
            let lhsNode: Node = kid(n, 1)
            let rhsNode: Node = kid(n, 2)
            let lk: str = caseInferExprTypeKey(b, lhsNode)
            let rk: str = caseInferExprTypeKey(b, rhsNode)
            if uirCoreNodeHasStringCtx(lk, lhsNode) || uirCoreNodeHasStringCtx(rk, rhsNode):
                return "str"
    if nodeTypeCacheValid(n) && astRefNonNil(nodeTypeCache(n)):
        return typeKey nodeTypeCache(n)
    if uirCoreNodeIsStringLiteral(n):
        return "str"
    if nodeKind(n) == nkIdent || nodeKind(n) == nkSymbol:
        let nm: str = plainName(n)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm)
        if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
            return funcObjTypeKey(b.func, slot0)
        if slot0 >= 0:
            return localTypeKey(b.env, slot0)
        if uirCoreDupGlobalNamesHas(nm) && uirCoreFuncIdValid(b.func):
            let f0: UirCoreFunc = b.func
            let sym0: str = uirCoreMaybeMangleDupGlobalName(nm, uirCoreFuncOriginFileOf(f0))
            let gk1: str = uirCoreGlobalTypeKeyGet(sym0)
            if len(gk1) > 0:
                return gk1
        let gk0: str = uirCoreGlobalTypeKeyByBaseUnique(b.module, nm)
        if len(gk0) > 0:
            return gk0
        return ""
    if nodeKind(n) == nkDotExpr && kidCount(n) > 1:
        let baseNode: Node = kid(n, 0)
        let fieldNode: Node = kid(n, 1)
        let fieldName: str = backendStripSpaces(plainName(fieldNode))
        let dbgDotFieldFilter: str = getEnv "BACKEND_DEBUG_DOT_FIELD"
        let dbgDotField: bool = len(dbgDotFieldFilter) > 0 && fieldName == dbgDotFieldFilter
        var parentKey: str = uirCoreStripRefVarKeyOnce(caseInferExprTypeKey(b, baseNode))
        if dbgDotField:
            var slotDbg: int32 = -1
            var localKeyDbg: str = ""
            var objKeyDbg: str = ""
            var objNameDbg: str = ""
            if astNodeIdValid(baseNode) && (nodeKind(baseNode) == nkIdent || nodeKind(baseNode) == nkSymbol):
                let baseNameDbg: str = plainName(baseNode)
                slotDbg = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, baseNameDbg)
                if slotDbg >= 0:
                    localKeyDbg = localTypeKey(b.env, slotDbg)
                    objKeyDbg = funcObjTypeKey(b.func, slotDbg)
                    objNameDbg = funcObjTypeName(b.func, slotDbg)
            echo("[backend] debugDotField: field='" + fieldName +
                 "' baseKind=nk#" + intToStr(int32(nodeKind(baseNode))) +
                 " slot=" + intToStr(slotDbg) +
                 " localKey='" + localKeyDbg +
                 "' objKey='" + objKeyDbg +
                 "' objName='" + objNameDbg +
                 "' parentKey0='" + parentKey + "'")
        if len(parentKey) > 0 && len(fieldName) > 0:
            var fieldKey: str = uirCoreObjFieldTypeKeyGet(parentKey, fieldName)
            if len(fieldKey) == 0 && ((parentKey == "tuple") || uirCoreStrStartsWith(parentKey, "tuple_")):
                let ti: int32 = uirCoreTupleFieldIndexGet(parentKey, fieldName)
                if ti >= 0:
                    let altFieldName: str = uirCoreIndexedName("f", ti)
                    fieldKey = uirCoreObjFieldTypeKeyGet(parentKey, altFieldName)
            if len(fieldKey) == 0:
                let pk: str = uirCoreStripPtrKeyOnce(parentKey)
                if len(pk) > 0 && !(pk == parentKey):
                    fieldKey = uirCoreObjFieldTypeKeyGet(pk, fieldName)
            if len(fieldKey) == 0 && b.module != nil:
                if uirCoreStrStartsWith(parentKey, "seq_") && uirCoreHasObjType(b.module, "seq"):
                    fieldKey = uirCoreObjFieldTypeKeyGet("seq", fieldName)
                elif uirCoreStrStartsWith(parentKey, "seq_fixed_") && uirCoreHasObjType(b.module, "seq"):
                    fieldKey = uirCoreObjFieldTypeKeyGet("seq", fieldName)
                elif uirCoreStrStartsWith(parentKey, "Table_") && uirCoreHasObjType(b.module, "Table"):
                    fieldKey = uirCoreObjFieldTypeKeyGet("Table", fieldName)
            if len(fieldKey) == 0 && b.module != nil:
                fieldKey = uirCoreFieldTypeKeyFromCurrentRoot(b.module, parentKey, fieldName)
            if dbgDotField:
                let entryDbg1: str = uirCoreObjFieldTypeKeyDebugEntry(parentKey, fieldName)
                echo("[backend] debugDotField: field='" + fieldName +
                     "' parentKey='" + parentKey +
                     "' fieldKey='" + fieldKey +
                     "' entry='" + entryDbg1 + "'")
            if len(fieldKey) > 0:
                return fieldKey

    if nodeKind(n) == nkCall && b.module != nil && kidCount(n) > 0:
        let calleeNode: Node = kid(n, 0)
        var name: str = ""
        var typeArgs: Node[]
        if astNodeIdValid(calleeNode) && nodeKind(calleeNode) == nkBracketExpr && kidCount(calleeNode) > 0:
            let base: Node = kid(calleeNode, 0)
            name = backendStripSpaces(plainName(base))
            for ti in 1..<kidCount(calleeNode):
                let t: Node = kid(calleeNode, ti)
                if astNodeIdValid(t) && nodeKind(t) != nkEmpty:
                    astNodeSeqAppend(typeArgs, t)
        else:
            name = backendStripSpaces(plainName(calleeNode))
        var callName: str = name
        if typeArgs.len > 0:
            callName = mangleInstance(name, typeArgs)
        var argNodes: Node[]
        for ai in 1..<kidCount(n):
            var argNode: Node = kid(n, ai)
            if astNodeIdValid(argNode) && nodeKind(argNode) == nkCallArg:
                if kidCount(argNode) > 1:
                    argNode = kid(argNode, 1)
                elif kidCount(argNode) > 0:
                    argNode = kid(argNode, 0)
            astNodeSeqAppend(argNodes, argNode)
        let callee0: UirCoreFunc = uirCoreResolveCalleeFuncBestEffort(b, callName, argNodes, "")
        var outKey: str = ""
        if (callee0 != nil):
            if uirCoreFuncParamsLen(callee0) > 0:
                let p0: UirCoreParam = uirCoreFuncParamAt(callee0, 0)
                if (p0.name == "__ret"):
                    outKey = funcObjTypeKey(callee0, p0.slot)
            if len(outKey) == 0 && len(uirCoreFuncRetTypeKeyOf(callee0)) > 0:
                outKey = uirCoreFuncRetTypeKeyOf(callee0)
        if len(outKey) == 0 && (callName == "Value") && argNodes.len == 1 && b.module != nil:
            let arg0: Node = argNodes[0]
            var parentKey: str = uirCoreStripRefVarKeyOnce(caseInferExprTypeKey(b, arg0))
            if len(parentKey) > 0:
                var fieldKey: str = uirCoreObjFieldTypeKeyGet(parentKey, "value")
                if len(fieldKey) == 0:
                    let pk: str = uirCoreStripPtrKeyOnce(parentKey)
                    if len(pk) > 0 && !(pk == parentKey):
                        fieldKey = uirCoreObjFieldTypeKeyGet(pk, "value")
                if len(fieldKey) > 0:
                    outKey = fieldKey
        if len(outKey) == 0 && (callName == "Value"):
            let innerKey: str = uirCoreInferValueCallInnerKey(b, n)
            if len(innerKey) > 0:
                outKey = innerKey
        if (getEnv "BACKEND_DEBUG_TYPEKEY_CALL" == "1") && (callName == "Value"):
            var a0k: str = ""
            if argNodes.len > 0:
                a0k = uirCoreInferNodeTypeKeyForOverload(b, argNodes[0])
            var calleeName: str = ""
            var calleeFile: str = ""
            if (callee0 != nil):
                calleeName = uirCoreFuncNameOf(callee0)
                calleeFile = uirCoreFuncOriginFileOf(callee0)
            echo("[backend] debugTypeKeyCall: callName='" + callName + "' arg0Key='" + a0k +
                "' callee='" + calleeName + "' file='" + calleeFile + "' retKey='" + outKey + "'")
        if len(outKey) > 0:
            return outKey
    if nodeKind(n) == nkTupleLit:
        var tupleTy: Node = newNode(nkTupleTy, nodePos(n))
        for i in 0..<kidCount(n):
            var elem: Node = kid(n, i)
            if astNodeIdValid(elem) && nodeKind(elem) == nkCallArg && kidCount(elem) > 1:
                elem = kid(elem, 1)
            var ek: str = ""
            if astNodeIdValid(elem) && nodeTypeCacheValid(elem) && astRefNonNil(nodeTypeCache(elem)):
                ek = typeKey nodeTypeCache(elem)
            if len(ek) == 0:
                ek = "int64"
            addSon(tupleTy, newIdent(ek, nodePos(n)))
        return typeKey(tupleTy)
    if nodeKind(n) == nkSeqLit:
        if kidCount(n) > 0:
            var elemKey: str = "int32"
            for ii in 0..<kidCount(n):
                var e: Node = kid(n, ii)
                if astNodeIdValid(e) && nodeKind(e) == nkCallArg && kidCount(e) > 1:
                    e = kid(e, 1)
                if astNodeIdValid(e) && nodeKind(e) == nkIntLit:
                    if nodeIntVal(e) > 2147483647 || nodeIntVal(e) < (-2147483647 - 1):
                        elemKey = "int64"
                elif astNodeIdValid(e) && nodeTypeCacheValid(e) && astRefNonNil(nodeTypeCache(e)):
                    let ek: str = typeKey nodeTypeCache(e)
                    if len(ek) > 0:
                        elemKey = ek
            if len(elemKey) > 0:
                return uirCoreTypeKeySeqName(elemKey)
    return ""

fn caseComputeSetBits(pat0: Node): Result[int64] =
    var pat: Node = pat0
    while astNodeIdValid(pat) && nodeKind(pat) == nkPar && kidCount(pat) > 0:
        pat = kid(pat, 0)
    if !astNodeIdValid(pat) || nodeKind(pat) != nkCurly:
        return Err[int64]("uirCore_builder: case set pattern expects {}")
    var bits: int64 = 0
    for i in 0..<kidCount(pat):
        var item: Node = kid(pat, i)
        while astNodeIdValid(item) && nodeKind(item) == nkPar && kidCount(item) > 0:
            item = kid(item, 0)
        if (item == nil):
            continue
        var startVal: int64 = 0
        var endVal: int64 = 0
        var hasRange: bool = false
        var exclusive: bool = false
        if nodeKind(item) == nkInfix && kidCount(item) >= 3:
            let opNode: Node = kid(item, 0)
            let op: str = backendOpName(opNode)
            if op == ".." || op == "..<":
                hasRange = true
                exclusive = op == "..<"
                let lhs: Node = kid(item, 1)
                let rhs: Node = kid(item, 2)
                if !astNodeIdValid(lhs) || nodeKind(lhs) != nkIntLit || !astNodeIdValid(rhs) || nodeKind(rhs) != nkIntLit:
                    return Err[int64]("uirCore_builder: case set range expects int literals")
                startVal = nodeIntVal(lhs)
                endVal = nodeIntVal(rhs)
        if !hasRange:
            if nodeKind(item) != nkIntLit:
                return Err[int64]("uirCore_builder: case set pattern expects int literals")
            startVal = nodeIntVal(item)
            endVal = nodeIntVal(item)
        if exclusive:
            endVal = endVal - 1
        for v in startVal..endVal:
            if v < 0 || v >= 64:
                return Err[int64]("uirCore_builder: case set pattern out of 0..63")
            bits = bits | (int64(1) << v)
    return Ok[int64](bits)

fn caseMatchTuplePattern(b: BlockBuilder, pat: Node, selPtr: UirExprId, selKey: str): Result[UirExprId] =
    if (b == nil) || b.module == nil:
        return Err[UirExprId]("uirCore_builder: case tuple match missing module")
    if !astNodeIdValid(pat) || nodeKind(pat) != nkTupleLit:
        return Err[UirExprId]("uirCore_builder: case tuple match expects tuple literal")
    var tupleObj: str = ""
    if len(selKey) > 0 && uirCoreHasObjType(b.module, selKey):
        tupleObj = selKey
    if len(tupleObj) == 0:
        var tupleTy: Node = newNode(nkTupleTy, nodePos(pat))
        for i in 0..<kidCount(pat):
            let elemPat: Node = kid(pat, i)
            var tyNode: Node = casePatternTypeNode(elemPat)
            if !astNodeIdValid(tyNode) || nodeKind(tyNode) == nkEmpty:
                tyNode = newIdent("int64", nodePos(pat))
            addSon(tupleTy, tyNode)
        tupleObj = typeNodeObjTypeName(b.module, tupleTy)
    if len(tupleObj) == 0 || !uirCoreHasObjType(b.module, tupleObj):
        return Err[UirExprId]("uirCore_builder: unknown tuple object type")
    let ot: UirCoreObjType = uirCoreGetObjType(b.module, tupleObj)
    if ot.fields.len < kidCount(pat):
        return Err[UirExprId]("uirCore_builder: tuple pattern length mismatch")
    var out: UirExprId = uirCoreConstI64(1)
    for i2 in 0..<kidCount(pat):
        let elemPat2: Node = kid(pat, i2)
        if casePatternIsWildcard(elemPat2):
            continue
        let core: Node = casePatternCore(elemPat2)
        if (core != nil) && (nodeKind(core) == nkIdent || nodeKind(core) == nkSymbol):
            let tn: Node = casePatternTypeNode(elemPat2)
            if astNodeIdValid(tn) && nodeKind(tn) != nkEmpty && !(plainName(core) == "_"):
                continue
        let f: UirCoreObjField = ot.fields[i2]
        var addr: UirExprId = selPtr
        if f.offset != 0:
            addr = uirCoreBin(mbAdd, selPtr, uirCoreConstI64(int64(f.offset)))
        let loaded: UirExprId = uirCoreLoad(addr, f.ty)
        let loaded64: UirExprId = uirCoreCast(uirCoreTypeI64(), loaded)
        let litRes: Result[UirExprId] = lowerExprValue(b, elemPat2, uirCoreTypeI64())
        if !IsOk[UirExprId](litRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](litRes))
        let cond: UirExprId = uirCoreCmp(mcEq, loaded64, Value[UirExprId](litRes))
        out = uirCoreBin(mbAnd, out, cond)
    return Ok[UirExprId](out)

fn caseMatchSeqPattern(b: BlockBuilder, pat: Node, selPtr: UirExprId, selKey: str): Result[UirExprId] =
    if (b == nil) || b.module == nil:
        return Err[UirExprId]("uirCore_builder: case seq match missing module")
    if !astNodeIdValid(pat) || nodeKind(pat) != nkSeqLit:
        return Err[UirExprId]("uirCore_builder: case seq match expects seq literal")
    if len(selKey) == 0 || !uirCoreStrStartsWith(selKey, "seq_"):
        return Err[UirExprId]("uirCore_builder: case seq match missing selector type")
    let elemKey: str = str(rawmemPtrAdd(rawmemAsVoid(selKey), 4))
    if len(elemKey) == 0:
        return Err[UirExprId]("uirCore_builder: case seq match missing element type")
    let elemTypeNode: Node = newIdent(elemKey, nodePos(pat))
    let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, elemTypeNode)
    let sizeRes: Result[int32] = uirCoreSizeOfTypeNode(b.module, elemTypeNode)
    if !IsOk[int32](sizeRes):
        return ErrInfo[UirExprId](ErrorInfoOf[int32](sizeRes))
    let elemSize: int32 = Value[int32](sizeRes)

    let seqOt: UirCoreObjType = uirCoreGetObjType(b.module, "seq")
    var lenOff: int32 = -1
    var bufOff: int32 = -1
    for fi in 0..<seqOt.fields.len:
        let f: UirCoreObjField = seqOt.fields[fi]
        if (f.name == "len"):
            lenOff = f.offset
        elif (f.name == "buffer"):
            bufOff = f.offset
    if lenOff < 0 || bufOff < 0:
        return Err[UirExprId]("uirCore_builder: seq layout mismatch")
    let lenAddr: UirExprId = (lenOff == 0) ? selPtr : uirCoreBin(mbAdd, selPtr, uirCoreConstI64(int64(lenOff)))
    let bufAddr: UirExprId = (bufOff == 0) ? selPtr : uirCoreBin(mbAdd, selPtr, uirCoreConstI64(int64(bufOff)))
    let lenVal: UirExprId = uirCoreLoad(lenAddr, uirCoreTypeI32())
    let bufVal: UirExprId = uirCoreLoad(bufAddr, uirCoreTypeI64())

    let count: int32 = kidCount(pat)
    var out: UirExprId = uirCoreCmp(mcEq, lenVal, uirCoreConstI64(int64(count)))
    if count == 0:
        return Ok[UirExprId](out)
    for i in 0..<count:
        var elemNode: Node = kid(pat, i)
        if astNodeIdValid(elemNode) && nodeKind(elemNode) == nkCallArg && kidCount(elemNode) > 1:
            elemNode = kid(elemNode, 1)
        if casePatternIsWildcard(elemNode):
            continue
        let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreConstI64(int64(i)))
        let step: UirExprId = uirCoreConstI64(int64(elemSize))
        let off: UirExprId = (elemSize == 1) ? idx64 : uirCoreBin(mbMul, idx64, step)
        let addr: UirExprId = (elemSize == 0) ? bufVal : uirCoreBin(mbAdd, bufVal, off)
        let loaded: UirExprId = uirCoreLoad(addr, elemTy)
        let loaded64: UirExprId = uirCoreCast(uirCoreTypeI64(), loaded)
        let litRes: Result[UirExprId] = lowerExprValue(b, elemNode, uirCoreTypeI64())
        if !IsOk[UirExprId](litRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](litRes))
        let eqExpr: UirExprId = uirCoreCmp(mcEq, loaded64, Value[UirExprId](litRes))
        out = uirCoreBin(mbAnd, out, eqExpr)
    return Ok[UirExprId](out)

fn caseMatchObjPattern(b: BlockBuilder, pat: Node, selPtr: UirExprId, selKey: str): Result[UirExprId] =
    if (b == nil) || b.module == nil:
        return Err[UirExprId]("uirCore_builder: case object match missing module")
    if !astNodeIdValid(pat) || nodeKind(pat) != nkCall || kidCount(pat) == 0:
        return Err[UirExprId]("uirCore_builder: case object match expects call pattern")
    let callee: Node = kid(pat, 0)
    var patPlain: str = ""
    var patKey: str = ""
    var objName: str = ""
    if (callee != nil):
        patPlain = backendStripSpaces(plainName(callee))
        patKey = typeKey(callee)
        objName = patKey
        if len(objName) == 0:
            objName = patPlain
    if len(objName) == 0 || !uirCoreHasObjType(b.module, objName):
        if len(selKey) > 0 && uirCoreHasObjType(b.module, selKey):
            objName = selKey
        else:
            let line: str = intToStr(nodePosLine(pat))
            let col: str = intToStr(nodePosCol(pat))
            return Err[UirExprId]("uirCore_builder: case object match unknown type (pat=" + patPlain +
                                " key=" + patKey + " @" + line + ":" + col + ")")
    let ot: UirCoreObjType = uirCoreGetObjType(b.module, objName)
    var out: UirExprId = uirCoreConstI64(1)
    for ai in 1..<kidCount(pat):
        let arg: Node = kid(pat, ai)
        if (arg == nil):
            continue
        if nodeKind(arg) == nkCallArg && kidCount(arg) > 1:
            let nameNode: Node = kid(arg, 0)
            let valNode: Node = kid(arg, 1)
            if (nameNode != nil) && (nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol):
                let fieldName: str = backendStripSpaces(plainName(nameNode))
                var found: bool = false
                for fi in 0..<ot.fields.len:
                    let f: UirCoreObjField = ot.fields[fi]
                    if (f.name == fieldName):
                        found = true
                        var addr: UirExprId = selPtr
                        if f.offset != 0:
                            addr = uirCoreBin(mbAdd, selPtr, uirCoreConstI64(int64(f.offset)))
                        let loaded: UirExprId = uirCoreLoad(addr, f.ty)
                        let loaded64: UirExprId = uirCoreCast(uirCoreTypeI64(), loaded)
                        if casePatternIsWildcard(valNode):
                            break
                        let valCore: Node = casePatternCore(valNode)
                        if (valCore != nil) && (nodeKind(valCore) == nkIdent || nodeKind(valCore) == nkSymbol):
                            if !(plainName(valCore) == "_"):
                                # Binding subpattern: always matches.
                                break
                        let litRes: Result[UirExprId] = lowerExprValue(b, valCore, uirCoreTypeI64())
                        if !IsOk[UirExprId](litRes):
                            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](litRes))
                        let cond: UirExprId = uirCoreCmp(mcEq, loaded64, Value[UirExprId](litRes))
                        out = uirCoreBin(mbAnd, out, cond)
                        break
                if !found:
                    return Err[UirExprId]("uirCore_builder: case object match unknown field")
        else:
            let fieldIdx: int32 = ai - 1
            if fieldIdx >= 0 && fieldIdx < ot.fields.len:
                let f: UirCoreObjField = ot.fields[fieldIdx]
                var addr2: UirExprId = selPtr
                if f.offset != 0:
                    addr2 = uirCoreBin(mbAdd, selPtr, uirCoreConstI64(int64(f.offset)))
                let loaded2: UirExprId = uirCoreLoad(addr2, f.ty)
                let loaded64_2: UirExprId = uirCoreCast(uirCoreTypeI64(), loaded2)
                if casePatternIsWildcard(arg):
                    continue
                let core: Node = casePatternCore(arg)
                if (core != nil) && (nodeKind(core) == nkIdent || nodeKind(core) == nkSymbol):
                    if !(plainName(core) == "_"):
                        # Binding subpattern: always matches.
                        continue
                let litRes2: Result[UirExprId] = lowerExprValue(b, core, uirCoreTypeI64())
                if !IsOk[UirExprId](litRes2):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](litRes2))
                let cond2: UirExprId = uirCoreCmp(mcEq, loaded64_2, Value[UirExprId](litRes2))
                out = uirCoreBin(mbAnd, out, cond2)
    return Ok[UirExprId](out)

fn caseMatchPattern(b: BlockBuilder, pat0: Node, selVal: UirExprId, selKey: str): Result[UirExprId] =
    if (pat0 == nil):
        return Err[UirExprId]("uirCore_builder: nil case pattern")
    if casePatternIsWildcard(pat0):
        return Ok[UirExprId](uirCoreConstI64(1))
    let core: Node = casePatternCore(pat0)
    if (core == nil):
        return Err[UirExprId]("uirCore_builder: nil case pattern")

    let typeNode: Node = casePatternTypeNode(pat0)
    if astNodeIdValid(typeNode) && nodeKind(typeNode) != nkEmpty:
        if nodeKind(core) == nkIdent || nodeKind(core) == nkSymbol:
            if !(plainName(core) == "_"):
                # Typed binding pattern: always matches.
                return Ok[UirExprId](uirCoreConstI64(1))

    if nodeKind(core) == nkTupleLit:
        return caseMatchTuplePattern(b, core, selVal, selKey)
    if nodeKind(core) == nkSeqLit:
        return caseMatchSeqPattern(b, core, selVal, selKey)
    if nodeKind(core) == nkCurly:
        let bitsRes: Result[int64] = caseComputeSetBits(core)
        if !IsOk[int64](bitsRes):
            return ErrInfo[UirExprId](ErrorInfoOf[int64](bitsRes))
        let bits: UirExprId = uirCoreConstI64(Value[int64](bitsRes))
        let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), selVal)
        let mask: UirExprId = uirCoreBin(mbShl, uirCoreConstI64(1), idx64)
        return Ok[UirExprId](uirCoreCmp(mcNe, uirCoreBin(mbAnd, bits, mask), uirCoreConstI64(0)))
    if nodeKind(core) == nkCall:
        return caseMatchObjPattern(b, core, selVal, selKey)
    if nodeKind(core) == nkInfix && kidCount(core) >= 3:
        let opNode: Node = kid(core, 0)
        let op: str = backendOpName(opNode)
        if op == ".." || op == "..<":
            let aRes: Result[UirExprId] = lowerExprValue(b, kid(core, 1), uirCoreTypeI64())
            if !IsOk[UirExprId](aRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](aRes))
            let bRes: Result[UirExprId] = lowerExprValue(b, kid(core, 2), uirCoreTypeI64())
            if !IsOk[UirExprId](bRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](bRes))
            let sel64: UirExprId = uirCoreCast(uirCoreTypeI64(), selVal)
            let geExpr: UirExprId = uirCoreCmp(mcGe, sel64, Value[UirExprId](aRes))
            var hiExpr: UirExprId
            if op == "..":
                hiExpr = uirCoreCmp(mcLe, sel64, Value[UirExprId](bRes))
            else:
                hiExpr = uirCoreCmp(mcLt, sel64, Value[UirExprId](bRes))
            return Ok[UirExprId](uirCoreBin(mbAnd, geExpr, hiExpr))

    # Fallback: treat pattern as a value equality check.
    let patRes: Result[UirExprId] = lowerExprValue(b, core, uirCoreTypeI64())
    if !IsOk[UirExprId](patRes):
        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](patRes))
    let sel64: UirExprId = uirCoreCast(uirCoreTypeI64(), selVal)
    return Ok[UirExprId](uirCoreCmp(mcEq, sel64, Value[UirExprId](patRes)))

fn lowerCaseAssign(b: BlockBuilder, caseNode: Node, name: str, slot: int32): Result[bool] =
    if !astNodeIdValid(caseNode) || nodeKind(caseNode) != nkCase:
        return Err[bool]("uirCore_builder: invalid case assign")
    if kidCount(caseNode) < 1:
        return Err[bool]("uirCore_builder: case expects selector")
    let slotTy: UirCoreType = localType(b.env, slot)
    # Default to 0 so a missing else doesn't leave it uninitialized.
    blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreConstI64(0)))

    let selNode: Node = kid(caseNode, 0)
    let selTy: UirCoreType = inferExprTypeWithGlobals(b.env, b.module, b.func, selNode, uirCoreTypeI64())
    let selRes: Result[UirExprId] = lowerExprValue(b, selNode, selTy)
    if !IsOk[UirExprId](selRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](selRes))
    let selName: str = blockBuilderNextTemp(b, "__case_sel")
    let selSlot: int32 = localAdd(b.env, selName, selTy)
    uirCoreSetLocalType(b.func, selSlot, selTy)
    blockBuilderAddStmt(b, uirCoreStmtLet(selName, selSlot, Value[UirExprId](selRes)))
    let selVal: UirExprId = uirCoreLocal(selSlot)
    let selKey: str = caseInferExprTypeKey(b, selNode)

    let endLabel: str = blockBuilderNextLabel(b, "case_end")
    let firstTest: str = blockBuilderNextLabel(b, "case_test")
    blockBuilderFinish(b, uirCoreTermBr(firstTest))
    blockBuilderStart(b, firstTest)

    for i in 1..<kidCount(caseNode):
        let br: Node = kid(caseNode, i)
        if (br == nil):
            continue
        if nodeKind(br) == nkOfBranch:
            if kidCount(br) == 0:
                return Err[bool]("uirCore_builder: empty of-branch")
            let bodyRaw: Node = kid(br, kidCount(br) - 1)
            var bodyNode: Node = bodyRaw
            if astNodeIdValid(bodyNode) && nodeKind(bodyNode) != nkStmtList:
                var wrap: Node = newNode(nkStmtList, nodePos(bodyNode))
                addSon(wrap, bodyNode)
                bodyNode = wrap
            var guardExpr: Node = astInvalidNodeId()
            var patEnd: int32 = kidCount(br) - 1
            if kidCount(br) >= 2:
                let maybeGuard: Node = kid(br, kidCount(br) - 2)
                if astNodeIdValid(maybeGuard) && nodeKind(maybeGuard) == nkGuard && kidCount(maybeGuard) > 0:
                    guardExpr = kid(maybeGuard, 0)
                    patEnd = kidCount(br) - 2
            if patEnd <= 0:
                return Err[bool]("uirCore_builder: of-branch missing patterns")

            var cond: UirExprId = nil
            for pi in 0..<patEnd:
                let pat: Node = kid(br, pi)
                let condRes: Result[UirExprId] = caseMatchPattern(b, pat, selVal, selKey)
                if !IsOk[UirExprId](condRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](condRes))
                if (cond == nil):
                    cond = Value[UirExprId](condRes)
                else:
                    cond = uirCoreBin(mbOr, cond, Value[UirExprId](condRes))
            if (cond == nil):
                cond = uirCoreConstI64(0)

            let matchLabel: str = blockBuilderNextLabel(b, "case_match")
            let nextLabel: str = blockBuilderNextLabel(b, "case_next")
            blockBuilderFinish(b, uirCoreTermCbr(cond, matchLabel, nextLabel))

            blockBuilderStart(b, matchLabel)
            # Typed binding patterns: assign selector to the bound name before evaluating guard/body.
            for bi in 0..<patEnd:
                let pat2: Node = kid(br, bi)
                let core2: Node = casePatternCore(pat2)
                let tyNode2: Node = casePatternTypeNode(pat2)
                if (core2 != nil) && astNodeIdValid(tyNode2) && nodeKind(tyNode2) != nkEmpty &&
                   (nodeKind(core2) == nkIdent || nodeKind(core2) == nkSymbol) && !(plainName(core2) == "_"):
                    let bindName: str = plainName(core2)
                    let bindTy: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, tyNode2)
                    let bindSlot: int32 = localAdd(b.env, bindName, bindTy)
                    uirCoreSetLocalType(b.func, bindSlot, bindTy)
                    blockBuilderAddStmt(b, uirCoreStmtAssign(bindName, bindSlot, uirCoreCast(bindTy, selVal)))

            if astNodeIdValid(guardExpr) && nodeKind(guardExpr) != nkEmpty:
                let execLabel: str = blockBuilderNextLabel(b, "case_exec")
                let guardRes: Result[bool] = lowerCondBranch(b, guardExpr, execLabel, nextLabel)
                if !uirCoreResultBoolIsOk(guardRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(guardRes))
                blockBuilderStart(b, execLabel)

            # Assign value from the last expression in the branch body.
            if !astNodeIdValid(bodyNode) || nodeKind(bodyNode) != nkStmtList || kidCount(bodyNode) == 0:
                blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreConstI64(0)))
                blockBuilderFinish(b, uirCoreTermBr(endLabel))
                blockBuilderStart(b, nextLabel)
                continue
            for si in 0..<kidCount(bodyNode):
                if si + 1 >= kidCount(bodyNode):
                    break
                let stmt: Node = kid(bodyNode, si)
                let termRes: Result[bool] = lowerStmt(b, stmt)
                if !uirCoreResultBoolIsOk(termRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(termRes))
                if uirCoreResultBoolValue(termRes):
                    return Ok[bool](true)
            let last: Node = kid(bodyNode, kidCount(bodyNode) - 1)
            let valRes: Result[UirExprId] = lowerExprValue(b, last, slotTy)
            if !IsOk[UirExprId](valRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes))
            blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreCast(slotTy, Value[UirExprId](valRes))))
            blockBuilderFinish(b, uirCoreTermBr(endLabel))
            blockBuilderStart(b, nextLabel)
        elif nodeKind(br) == nkElse:
            if kidCount(br) == 0:
                return Err[bool]("uirCore_builder: else branch missing body")
            var bodyNode2: Node = kid(br, 0)
            if astNodeIdValid(bodyNode2) && nodeKind(bodyNode2) != nkStmtList:
                var wrap2: Node = newNode(nkStmtList, nodePos(bodyNode2))
                addSon(wrap2, bodyNode2)
                bodyNode2 = wrap2
            if !astNodeIdValid(bodyNode2) || nodeKind(bodyNode2) != nkStmtList || kidCount(bodyNode2) == 0:
                blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreConstI64(0)))
            else:
                for sj in 0..<kidCount(bodyNode2):
                    if sj + 1 >= kidCount(bodyNode2):
                        break
                    let stmt2: Node = kid(bodyNode2, sj)
                    let termRes2: Result[bool] = lowerStmt(b, stmt2)
                    if !uirCoreResultBoolIsOk(termRes2):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(termRes2))
                    if uirCoreResultBoolValue(termRes2):
                        return Ok[bool](true)
                let last2: Node = kid(bodyNode2, kidCount(bodyNode2) - 1)
                let valRes2: Result[UirExprId] = lowerExprValue(b, last2, slotTy)
                if !IsOk[UirExprId](valRes2):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes2))
                blockBuilderAddStmt(b, uirCoreStmtAssign(name, slot, uirCoreCast(slotTy, Value[UirExprId](valRes2))))
            blockBuilderFinish(b, uirCoreTermBr(endLabel))
            blockBuilderStart(b, endLabel)
            return Ok[bool](false)

    blockBuilderFinish(b, uirCoreTermBr(endLabel))
    blockBuilderStart(b, endLabel)
    return Ok[bool](false)

fn lowerCaseStmt(b: BlockBuilder, caseNode: Node): Result[bool] =
    if !astNodeIdValid(caseNode) || nodeKind(caseNode) != nkCase:
        return Err[bool]("uirCore_builder: invalid case")
    if kidCount(caseNode) < 1:
        return Err[bool]("uirCore_builder: case expects selector")
    let selNode: Node = kid(caseNode, 0)
    let selTy: UirCoreType = inferExprTypeWithGlobals(b.env, b.module, b.func, selNode, uirCoreTypeI64())
    let selRes: Result[UirExprId] = lowerExprValue(b, selNode, selTy)
    if !IsOk[UirExprId](selRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](selRes))
    let selName: str = blockBuilderNextTemp(b, "__case_sel")
    let selSlot: int32 = localAdd(b.env, selName, selTy)
    uirCoreSetLocalType(b.func, selSlot, selTy)
    blockBuilderAddStmt(b, uirCoreStmtLet(selName, selSlot, Value[UirExprId](selRes)))
    let selVal: UirExprId = uirCoreLocal(selSlot)
    let selKey: str = caseInferExprTypeKey(b, selNode)

    let endLabel: str = blockBuilderNextLabel(b, "case_end")
    var needsEnd: bool = false
    var allTerminated: bool = true
    let firstTest: str = blockBuilderNextLabel(b, "case_test")
    blockBuilderFinish(b, uirCoreTermBr(firstTest))
    blockBuilderStart(b, firstTest)

    for i in 1..<kidCount(caseNode):
        let br: Node = kid(caseNode, i)
        if (br == nil):
            continue
        if nodeKind(br) == nkOfBranch:
            if kidCount(br) == 0:
                return Err[bool]("uirCore_builder: empty of-branch")
            let bodyRaw: Node = kid(br, kidCount(br) - 1)
            var bodyNode: Node = bodyRaw
            if astNodeIdValid(bodyNode) && nodeKind(bodyNode) != nkStmtList:
                var wrap: Node = newNode(nkStmtList, nodePos(bodyNode))
                addSon(wrap, bodyNode)
                bodyNode = wrap
            var guardExpr: Node = astInvalidNodeId()
            var patEnd: int32 = kidCount(br) - 1
            if kidCount(br) >= 2:
                let maybeGuard: Node = kid(br, kidCount(br) - 2)
                if astNodeIdValid(maybeGuard) && nodeKind(maybeGuard) == nkGuard && kidCount(maybeGuard) > 0:
                    guardExpr = kid(maybeGuard, 0)
                    patEnd = kidCount(br) - 2
            if patEnd <= 0:
                return Err[bool]("uirCore_builder: of-branch missing patterns")

            var cond: UirExprId = nil
            for pi in 0..<patEnd:
                let pat: Node = kid(br, pi)
                let condRes: Result[UirExprId] = caseMatchPattern(b, pat, selVal, selKey)
                if !IsOk[UirExprId](condRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](condRes))
                if (cond == nil):
                    cond = Value[UirExprId](condRes)
                else:
                    cond = uirCoreBin(mbOr, cond, Value[UirExprId](condRes))
            if (cond == nil):
                cond = uirCoreConstI64(0)

            let matchLabel: str = blockBuilderNextLabel(b, "case_match")
            let nextLabel: str = blockBuilderNextLabel(b, "case_next")
            blockBuilderFinish(b, uirCoreTermCbr(cond, matchLabel, nextLabel))

            blockBuilderStart(b, matchLabel)
            # Typed binding patterns: assign selector to the bound name before evaluating guard/body.
            for bi in 0..<patEnd:
                let pat2: Node = kid(br, bi)
                let core2: Node = casePatternCore(pat2)
                let tyNode2: Node = casePatternTypeNode(pat2)
                if (core2 != nil) && astNodeIdValid(tyNode2) && nodeKind(tyNode2) != nkEmpty &&
                   (nodeKind(core2) == nkIdent || nodeKind(core2) == nkSymbol) && !(plainName(core2) == "_"):
                    let bindName: str = plainName(core2)
                    let bindTy: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, tyNode2)
                    let bindSlot: int32 = localAdd(b.env, bindName, bindTy)
                    uirCoreSetLocalType(b.func, bindSlot, bindTy)
                    blockBuilderAddStmt(b, uirCoreStmtAssign(bindName, bindSlot, uirCoreCast(bindTy, selVal)))

            if astNodeIdValid(guardExpr) && nodeKind(guardExpr) != nkEmpty:
                let execLabel: str = blockBuilderNextLabel(b, "case_exec")
                let guardRes: Result[bool] = lowerCondBranch(b, guardExpr, execLabel, nextLabel)
                if !uirCoreResultBoolIsOk(guardRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(guardRes))
                blockBuilderStart(b, execLabel)

            let bodyTermRes: Result[bool] = lowerStmtList(b, bodyNode)
            if !uirCoreResultBoolIsOk(bodyTermRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyTermRes))
            let bodyTerminated: bool = uirCoreResultBoolValue(bodyTermRes)
            if !bodyTerminated:
                needsEnd = true
                allTerminated = false
                blockBuilderFinish(b, uirCoreTermBr(endLabel))
            blockBuilderStart(b, nextLabel)
        elif nodeKind(br) == nkElse:
            if kidCount(br) == 0:
                return Err[bool]("uirCore_builder: else branch missing body")
            var bodyNode2: Node = kid(br, 0)
            if astNodeIdValid(bodyNode2) && nodeKind(bodyNode2) != nkStmtList:
                var wrap2: Node = newNode(nkStmtList, nodePos(bodyNode2))
                addSon(wrap2, bodyNode2)
                bodyNode2 = wrap2
            let elseTermRes: Result[bool] = lowerStmtList(b, bodyNode2)
            if !uirCoreResultBoolIsOk(elseTermRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(elseTermRes))
            let elseTerminated: bool = uirCoreResultBoolValue(elseTermRes)
            if !elseTerminated:
                needsEnd = true
                allTerminated = false
                blockBuilderFinish(b, uirCoreTermBr(endLabel))
            if needsEnd:
                blockBuilderStart(b, endLabel)
                return Ok[bool](false)
            if allTerminated:
                return Ok[bool](true)
            blockBuilderStart(b, endLabel)
            return Ok[bool](false)

    # No else: fallthrough.
    blockBuilderFinish(b, uirCoreTermBr(endLabel))
    blockBuilderStart(b, endLabel)
    return Ok[bool](false)

fn lowerDestructureSeq(b: BlockBuilder, kind: NodeKind, pat: Node, init: Node): Result[bool] =
    if (b == nil) || b.module == nil:
        return Err[bool]("uirCore_builder: seq destructure missing module")
    if !astNodeIdValid(pat) || nodeKind(pat) != nkSeqLit:
        return Err[bool]("uirCore_builder: seq destructure expects seq pattern")
    if !astNodeIdValid(init) || nodeKind(init) == nkEmpty:
        return Err[bool]("uirCore_builder: seq destructure expects init")
    let seqKey: str = caseInferExprTypeKey(b, init)
    if !uirCoreStrStartsWith(seqKey, "seq_"):
        return Err[bool]("uirCore_builder: seq destructure missing element type")
    let elemKey: str = str(rawmemPtrAdd(rawmemAsVoid(seqKey), 4))
    let elemTypeNode: Node = newIdent(elemKey, nodePos(pat))
    let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, elemTypeNode)
    let sizeRes: Result[int32] = uirCoreSizeOfTypeNode(b.module, elemTypeNode)
    if !IsOk[int32](sizeRes):
        return ErrInfo[bool](ErrorInfoOf[int32](sizeRes))
    let elemSize: int32 = Value[int32](sizeRes)

    let initRes: Result[UirExprId] = lowerExprValue(b, init, uirCoreTypeI64())
    if !IsOk[UirExprId](initRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](initRes))
    let seqName: str = blockBuilderNextTemp(b, "__pat_seq")
    let seqSlot: int32 = localAdd(b.env, seqName, uirCoreTypeI64())
    uirCoreSetLocalType(b.func, seqSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(seqName, seqSlot, Value[UirExprId](initRes)))
    let seqPtr: UirExprId = uirCoreLocal(seqSlot)

    let seqOt: UirCoreObjType = uirCoreGetObjType(b.module, "seq")
    var lenOff: int32 = -1
    var bufOff: int32 = -1
    for fi in 0..<seqOt.fields.len:
        let f: UirCoreObjField = seqOt.fields[fi]
        if (f.name == "len"):
            lenOff = f.offset
        elif (f.name == "buffer"):
            bufOff = f.offset
    if lenOff < 0 || bufOff < 0:
        return Err[bool]("uirCore_builder: seq layout mismatch")
    let bufAddr: UirExprId = (bufOff == 0) ? seqPtr : uirCoreBin(mbAdd, seqPtr, uirCoreConstI64(int64(bufOff)))
    let bufVal: UirExprId = uirCoreLoad(bufAddr, uirCoreTypeI64())

    for i in 0..<kidCount(pat):
        var elemPat: Node = kid(pat, i)
        if astNodeIdValid(elemPat) && nodeKind(elemPat) == nkCallArg && kidCount(elemPat) > 1:
            elemPat = kid(elemPat, 1)
        if (elemPat != nil) && (nodeKind(elemPat) == nkIdent || nodeKind(elemPat) == nkSymbol) && !(plainName(elemPat) == "_"):
            let nm: str = plainName(elemPat)
            let slot: int32 = localAdd(b.env, nm, elemTy)
            uirCoreSetLocalType(b.func, slot, elemTy)
            let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreConstI64(int64(i)))
            let step: UirExprId = uirCoreConstI64(int64(elemSize))
            let off: UirExprId = (elemSize == 1) ? idx64 : uirCoreBin(mbMul, idx64, step)
            let addr: UirExprId = (elemSize == 0) ? bufVal : uirCoreBin(mbAdd, bufVal, off)
            let loaded: UirExprId = uirCoreLoad(addr, elemTy)
            if kind == nkLet:
                blockBuilderAddStmt(b, uirCoreStmtLet(nm, slot, loaded))
            else:
                blockBuilderAddStmt(b, uirCoreStmtVar(nm, slot, loaded))
    return Ok[bool](false)

fn tupleTypeElemTypeNode(tupleType0: Node, idx: int32): Node =
    var tupleType: Node = tupleType0
    while astNodeIdValid(tupleType) && nodeKind(tupleType) == nkPar && kidCount(tupleType) > 0:
        tupleType = kid(tupleType, 0)
    if astNodeIdValid(tupleType) && nodeKind(tupleType) == nkVarTy && kidCount(tupleType) > 0:
        tupleType = kid(tupleType, 0)
    if !astNodeIdValid(tupleType) || nodeKind(tupleType) != nkTupleTy:
        return nil
    if idx < 0 || idx >= kidCount(tupleType):
        return nil
    let elem: Node = kid(tupleType, idx)
    if astNodeIdValid(elem) && nodeKind(elem) == nkIdentDefs && kidCount(elem) > 1:
        return kid(elem, 1)
    return elem

fn tupleLitElemValueNode(tupleLit0: Node, idx: int32): Node =
    var tupleLit: Node = tupleLit0
    while astNodeIdValid(tupleLit) && nodeKind(tupleLit) == nkPar && kidCount(tupleLit) > 0:
        tupleLit = kid(tupleLit, 0)
    if !astNodeIdValid(tupleLit) || nodeKind(tupleLit) != nkTupleLit:
        return nil
    if idx < 0 || idx >= kidCount(tupleLit):
        return nil
    var elem: Node = kid(tupleLit, idx)
    if astNodeIdValid(elem) && nodeKind(elem) == nkCallArg && kidCount(elem) > 1:
        elem = kid(elem, 1)
    elif astNodeIdValid(elem) && nodeKind(elem) == nkCallArg && kidCount(elem) > 0:
        elem = kid(elem, 0)
    return elem

fn inferTupleTypeNodeFromTupleLitBestEffort(lit0: Node): Node =
    var lit: Node = lit0
    while astNodeIdValid(lit) && nodeKind(lit) == nkPar && kidCount(lit) > 0:
        lit = kid(lit, 0)
    if !astNodeIdValid(lit) || nodeKind(lit) != nkTupleLit:
        return nil
    if nodeTypeCacheValid(lit) && astRefNonNil(nodeTypeCache(lit)):
        let tc: Node = nodeTypeCache(lit)
        if astNodeIdValid(tc) && nodeKind(tc) == nkTupleTy:
            return tc
    var tupleTy: Node = newNode(nkTupleTy, nodePos(lit))
    for i in 0..<kidCount(lit):
        var elem: Node = kid(lit, i)
        if astNodeIdValid(elem) && nodeKind(elem) == nkCallArg && kidCount(elem) > 1:
            elem = kid(elem, 1)
        var elemTy: Node = astInvalidNodeId()
        if astNodeIdValid(elem) && nodeTypeCacheValid(elem) && astRefNonNil(nodeTypeCache(elem)):
            elemTy = nodeTypeCache(elem)
        if !astNodeIdValid(elemTy) || nodeKind(elemTy) == nkEmpty:
            if astNodeIdValid(elem) && nodeKind(elem) == nkTupleLit:
                elemTy = inferTupleTypeNodeFromTupleLitBestEffort(elem)
            elif uirCoreNodeIsStringLiteral(elem):
                elemTy = newIdent("str", nodePos(lit))
            elif astNodeIdValid(elem) && nodeKind(elem) == nkCharLit:
                elemTy = newIdent("char", nodePos(lit))
            elif astNodeIdValid(elem) && nodeKind(elem) == nkBoolLit:
                elemTy = newIdent("bool", nodePos(lit))
            elif astNodeIdValid(elem) && nodeKind(elem) == nkFloatLit:
                elemTy = newIdent("float64", nodePos(lit))
            else:
                elemTy = newIdent("int64", nodePos(lit))
        addSon(tupleTy, elemTy)
    return tupleTy

fn inferTupleTypeNodeFromTuplePatternBestEffort(pat0: Node): Node =
    var pat: Node = pat0
    while astNodeIdValid(pat) && nodeKind(pat) == nkPar && kidCount(pat) > 0:
        pat = kid(pat, 0)
    if !astNodeIdValid(pat) || nodeKind(pat) != nkTupleLit:
        return nil
    var tupleTy: Node = newNode(nkTupleTy, nodePos(pat))
    for i in 0..<kidCount(pat):
        let elemPat: Node = kid(pat, i)
        var elemTy: Node = casePatternTypeNode(elemPat)
        if !astNodeIdValid(elemTy) || nodeKind(elemTy) == nkEmpty:
            elemTy = newIdent("int64", nodePos(pat))
        addSon(tupleTy, elemTy)
    return tupleTy

fn lowerDestructureTupleFromPtr(b: BlockBuilder, kind: NodeKind, pat: Node, typeNode: Node, init: Node, tupleObj: str, tupPtr: UirExprId): Result[bool] =
    if (b == nil) || b.module == nil:
        return Err[bool]("uirCore_builder: tuple destructure missing module")
    if !astNodeIdValid(pat) || nodeKind(pat) != nkTupleLit:
        return Err[bool]("uirCore_builder: tuple destructure expects tuple pattern")
    var tupleObj2: str = tupleObj

    var initCore0: Node = init
    while astNodeIdValid(initCore0) && nodeKind(initCore0) == nkPar && kidCount(initCore0) > 0:
        initCore0 = kid(initCore0, 0)

    if len(tupleObj2) == 0 || !uirCoreHasObjType(b.module, tupleObj2):
        var tupleType: Node = typeNode
        if !astNodeIdValid(tupleType) || nodeKind(tupleType) == nkEmpty:
            if astNodeIdValid(initCore0) && nodeTypeCacheValid(initCore0) && astRefNonNil(nodeTypeCache(initCore0)):
                let tc: Node = nodeTypeCache(initCore0)
                if astNodeIdValid(tc) && nodeKind(tc) == nkTupleTy:
                    tupleType = tc
            elif astNodeIdValid(initCore0) && nodeKind(initCore0) == nkTupleLit:
                tupleType = inferTupleTypeNodeFromTupleLitBestEffort(initCore0)
        if !astNodeIdValid(tupleType) || nodeKind(tupleType) == nkEmpty:
            tupleType = inferTupleTypeNodeFromTuplePatternBestEffort(pat)
        if astNodeIdValid(tupleType) && nodeKind(tupleType) != nkEmpty:
            tupleObj2 = typeNodeObjTypeName(b.module, tupleType)

    if len(tupleObj2) == 0 || !uirCoreHasObjType(b.module, tupleObj2):
        let posNode: Node = pat
        let line: str = intToStr(nodePosLine(posNode))
        let col: str = intToStr(nodePosCol(posNode))
        let key: str = caseInferExprTypeKey(b, init)
        return Err[bool]("uirCore_builder: tuple destructure unknown tuple type @" + line + ":" + col + " key=" + key)
    let ot: UirCoreObjType = uirCoreGetObjType(b.module, tupleObj2)

    let initCore: Node = initCore0

    for i in 0..<kidCount(pat):
        if ! (i < ot.fields.len):
            break
        var elemPat0: Node = kid(pat, i)
        if astNodeIdValid(elemPat0) && nodeKind(elemPat0) == nkCallArg && kidCount(elemPat0) > 1:
            elemPat0 = kid(elemPat0, 1)
        let core: Node = casePatternCore(elemPat0)

        var elemTypeNode: Node = tupleTypeElemTypeNode(typeNode, i)
        let patElemTy: Node = casePatternTypeNode(elemPat0)
        if astNodeIdValid(patElemTy) && nodeKind(patElemTy) != nkEmpty:
            elemTypeNode = patElemTy
        if (!astNodeIdValid(elemTypeNode) || nodeKind(elemTypeNode) == nkEmpty) && astNodeIdValid(initCore) && nodeTypeCacheValid(initCore) && astRefNonNil(nodeTypeCache(initCore)):
            elemTypeNode = tupleTypeElemTypeNode(nodeTypeCache(initCore), i)

        var elemInitNode: Node = astInvalidNodeId()
        if astNodeIdValid(initCore) && nodeKind(initCore) == nkTupleLit:
            elemInitNode = tupleLitElemValueNode(initCore, i)

        if (core != nil) && (nodeKind(core) == nkIdent || nodeKind(core) == nkSymbol) && !(plainName(core) == "_"):
            let f: UirCoreObjField = ot.fields[i]
            var addr: UirExprId = tupPtr
            if f.offset != 0:
                addr = uirCoreBin(mbAdd, tupPtr, uirCoreConstI64(int64(f.offset)))
            let loaded: UirExprId = uirCoreLoad(addr, f.ty)
            let nm: str = plainName(core)
            let slot: int32 = localAdd(b.env, nm, f.ty)
            uirCoreSetLocalType(b.func, slot, f.ty)
            if kind == nkLet:
                blockBuilderAddStmt(b, uirCoreStmtLet(nm, slot, loaded))
            else:
                blockBuilderAddStmt(b, uirCoreStmtVar(nm, slot, loaded))
            continue

        if (core != nil) && (nodeKind(core) == nkIntLit || nodeKind(core) == nkBoolLit || nodeKind(core) == nkCharLit || nodeKind(core) == nkNilLit):
            let fLit: UirCoreObjField = ot.fields[i]
            var addrLit: UirExprId = tupPtr
            if fLit.offset != 0:
                addrLit = uirCoreBin(mbAdd, tupPtr, uirCoreConstI64(int64(fLit.offset)))
            let loadedLit: UirExprId = uirCoreLoad(addrLit, fLit.ty)
            let loaded64: UirExprId = uirCoreCast(uirCoreTypeI64(), loadedLit)
            var wantLit: UirExprId = uirCoreConstI64(0)
            if nodeKind(core) == nkIntLit:
                wantLit = uirCoreConstI64(nodeIntVal(core))
            elif nodeKind(core) == nkCharLit:
                if len(nodeStrVal(core)) > 0:
                    wantLit = uirCoreConstI64(int64(nodeStrVal(core)[0]))
            elif nodeKind(core) == nkBoolLit:
                let nameLit: str = backendStripSpaces(nodeIdent(core))
                wantLit = uirCoreConstI64((nameLit == "true") ? 1 : 0)
            # nkNilLit stays 0
            let condLit: UirExprId = uirCoreCmp(mcEq, loaded64, wantLit)
            var argsLit: UirExprId[]
            builderExprSeqAppend(argsLit, condLit)
            let msgLabel: str = uirCoreAddCString(b.module, "literal tuple pattern mismatch")
            builderExprSeqAppend(argsLit, uirCoreGlobalAddr(msgLabel))
            blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall("assert", argsLit)))
            continue

        if astNodeIdValid(core) && nodeKind(core) == nkTupleLit:
            let f2: UirCoreObjField = ot.fields[i]
            var addr2: UirExprId = tupPtr
            if f2.offset != 0:
                addr2 = uirCoreBin(mbAdd, tupPtr, uirCoreConstI64(int64(f2.offset)))
            let loaded2: UirExprId = uirCoreLoad(addr2, f2.ty)
            let loadedPtr: UirExprId = uirCoreCast(uirCoreTypeI64(), loaded2)

            var innerTypeNode: Node = elemTypeNode
            if !astNodeIdValid(innerTypeNode) || nodeKind(innerTypeNode) == nkEmpty:
                if astNodeIdValid(elemInitNode) && nodeTypeCacheValid(elemInitNode) && astRefNonNil(nodeTypeCache(elemInitNode)):
                    let tc2: Node = nodeTypeCache(elemInitNode)
                    if astNodeIdValid(tc2) && nodeKind(tc2) == nkTupleTy:
                        innerTypeNode = tc2
                elif astNodeIdValid(elemInitNode) && nodeKind(elemInitNode) == nkTupleLit:
                    innerTypeNode = inferTupleTypeNodeFromTupleLitBestEffort(elemInitNode)
            if !astNodeIdValid(innerTypeNode) || nodeKind(innerTypeNode) == nkEmpty:
                innerTypeNode = inferTupleTypeNodeFromTuplePatternBestEffort(core)

            var innerObj: str = ""
            if astNodeIdValid(innerTypeNode) && nodeKind(innerTypeNode) != nkEmpty:
                innerObj = typeNodeObjTypeName(b.module, innerTypeNode)
            if len(innerObj) == 0 && (elemInitNode != nil):
                let innerKey: str = caseInferExprTypeKey(b, elemInitNode)
                if len(innerKey) > 0 && uirCoreHasObjType(b.module, innerKey):
                    innerObj = innerKey
            if len(innerObj) == 0 || !uirCoreHasObjType(b.module, innerObj):
                return Err[bool]("uirCore_builder: tuple destructure unknown inner tuple type")

            let innerName: str = blockBuilderNextTemp(b, "__pat_tup")
            let innerSlot: int32 = localAdd(b.env, innerName, uirCoreTypeI64())
            uirCoreSetLocalType(b.func, innerSlot, uirCoreTypeI64())
            blockBuilderAddStmt(b, uirCoreStmtLet(innerName, innerSlot, loadedPtr))

            let innerRes: Result[bool] = lowerDestructureTupleFromPtr(b, kind, core, innerTypeNode, elemInitNode, innerObj, uirCoreLocal(innerSlot))
            if !uirCoreResultBoolIsOk(innerRes):
                return innerRes
    return Ok[bool](false)

fn lowerDestructureTuple(b: BlockBuilder, kind: NodeKind, pat: Node, typeNode: Node, init: Node): Result[bool] =
    if (b == nil) || b.module == nil:
        return Err[bool]("uirCore_builder: tuple destructure missing module")
    if !astNodeIdValid(pat) || nodeKind(pat) != nkTupleLit:
        return Err[bool]("uirCore_builder: tuple destructure expects tuple pattern")
    if !astNodeIdValid(init) || nodeKind(init) == nkEmpty:
        return Err[bool]("uirCore_builder: tuple destructure expects init")
    var initCore: Node = init
    while astNodeIdValid(initCore) && nodeKind(initCore) == nkPar && kidCount(initCore) > 0:
        initCore = kid(initCore, 0)

    var tupleType: Node = typeNode
    if !astNodeIdValid(tupleType) || nodeKind(tupleType) == nkEmpty:
        if astNodeIdValid(initCore) && nodeTypeCacheValid(initCore) && astRefNonNil(nodeTypeCache(initCore)):
            let tc: Node = nodeTypeCache(initCore)
            if astNodeIdValid(tc) && nodeKind(tc) == nkTupleTy:
                tupleType = tc
        elif astNodeIdValid(initCore) && nodeKind(initCore) == nkTupleLit:
            tupleType = inferTupleTypeNodeFromTupleLitBestEffort(initCore)
    if !astNodeIdValid(tupleType) || nodeKind(tupleType) == nkEmpty:
        tupleType = inferTupleTypeNodeFromTuplePatternBestEffort(pat)

    var tupleObj: str = ""
    if astNodeIdValid(tupleType) && nodeKind(tupleType) != nkEmpty:
        tupleObj = typeNodeObjTypeName(b.module, tupleType)
    if len(tupleObj) == 0:
        let k: str = caseInferExprTypeKey(b, initCore)
        if len(k) > 0 && uirCoreHasObjType(b.module, k):
            tupleObj = k
    if len(tupleObj) == 0 || !uirCoreHasObjType(b.module, tupleObj):
        let posNode: Node = pat
        let line: str = intToStr(nodePosLine(posNode))
        let col: str = intToStr(nodePosCol(posNode))
        let key: str = caseInferExprTypeKey(b, initCore)
        return Err[bool]("uirCore_builder: tuple destructure unknown tuple type @" + line + ":" + col + " key=" + key)

    # Stage1 may clear typeCache for tuple literals. Ensure tuple literals used as destructure init
    # are lowered with the same tuple type/layout selected for this destructure.
    var restoreTupleLitTypeCache: bool = false
    var savedTupleLitTypeCacheValid: bool = false
    var savedTupleLitTypeCache: Node = astInvalidNodeId()
    if astNodeIdValid(initCore) && nodeKind(initCore) == nkTupleLit &&
       (!nodeTypeCacheValid(initCore) || astRefIsNil(nodeTypeCache(initCore))) &&
       astNodeIdValid(tupleType) && nodeKind(tupleType) != nkEmpty:
        let wantObj: str = typeNodeObjTypeName(b.module, tupleType)
        if len(wantObj) > 0 && (wantObj == tupleObj):
            restoreTupleLitTypeCache = true
            savedTupleLitTypeCacheValid = nodeTypeCacheValid(initCore)
            savedTupleLitTypeCache = nodeTypeCache(initCore)
            nodeSetTypeCacheValid(initCore, true)
            nodeSetTypeCache(initCore, tupleType)

    let initRes: Result[UirExprId] = lowerExprValue(b, init, uirCoreTypeI64())
    if restoreTupleLitTypeCache:
        nodeSetTypeCacheValid(initCore, savedTupleLitTypeCacheValid)
        nodeSetTypeCache(initCore, savedTupleLitTypeCache)
    if !IsOk[UirExprId](initRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](initRes))
    let tupName: str = blockBuilderNextTemp(b, "__pat_tup")
    let tupSlot: int32 = localAdd(b.env, tupName, uirCoreTypeI64())
    uirCoreSetLocalType(b.func, tupSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(tupName, tupSlot, Value[UirExprId](initRes)))
    let tupPtr: UirExprId = uirCoreLocal(tupSlot)
    return lowerDestructureTupleFromPtr(b, kind, pat, typeNode, init, tupleObj, tupPtr)

fn lowerDestructureObject(b: BlockBuilder, kind: NodeKind, pat: Node, init: Node): Result[bool] =
    if (b == nil) || b.module == nil:
        return Err[bool]("uirCore_builder: object destructure missing module")
    if !astNodeIdValid(pat) || nodeKind(pat) != nkCall || kidCount(pat) == 0:
        return Err[bool]("uirCore_builder: object destructure expects call pattern")
    if !astNodeIdValid(init) || nodeKind(init) == nkEmpty:
        return Err[bool]("uirCore_builder: object destructure expects init")
    let callee: Node = kid(pat, 0)
    var patPlain: str = ""
    var patKey: str = ""
    var objName: str = ""
    var initKey: str = ""
    if (callee != nil):
        patPlain = backendStripSpaces(plainName(callee))
        patKey = typeKey(callee)
        objName = patKey
        if len(objName) == 0:
            objName = patPlain
    if len(objName) == 0 || !uirCoreHasObjType(b.module, objName):
        initKey = caseInferExprTypeKey(b, init)
        if len(initKey) > 0 && uirCoreHasObjType(b.module, initKey):
            objName = initKey
    if len(objName) == 0 || !uirCoreHasObjType(b.module, objName):
        let line: str = intToStr(nodePosLine(pat))
        let col: str = intToStr(nodePosCol(pat))
        return Err[bool]("uirCore_builder: object destructure unknown type (pat=" + patPlain +
                         " key=" + patKey + " initKey=" + initKey + " @" + line + ":" + col + ")")
    let ot: UirCoreObjType = uirCoreGetObjType(b.module, objName)
    let initRes: Result[UirExprId] = lowerExprValue(b, init, uirCoreTypeI64())
    if !IsOk[UirExprId](initRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](initRes))
    let objTmp: str = blockBuilderNextTemp(b, "__pat_obj")
    let objSlot: int32 = localAdd(b.env, objTmp, uirCoreTypeI64())
    uirCoreSetLocalType(b.func, objSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(objTmp, objSlot, Value[UirExprId](initRes)))
    let objPtr: UirExprId = uirCoreLocal(objSlot)

    let debug: bool = (getEnv "BACKEND_DEBUG_DESTRUCTURE" == "1")
    if debug:
        let line: str = intToStr(nodePosLine(pat))
        let col: str = intToStr(nodePosCol(pat))
        var msgParts: str[]
        add(msgParts, "[backend] destructure obj @")
        add(msgParts, line)
        add(msgParts, ":")
        add(msgParts, col)
        add(msgParts, " objName=")
        add(msgParts, objName)
        add(msgParts, " patPlain=")
        add(msgParts, patPlain)
        add(msgParts, " patKey=")
        add(msgParts, patKey)
        add(msgParts, " initKey=")
        add(msgParts, initKey)
        add(msgParts, " fields=")
        add(msgParts, intToStr(ot.fields.len))
        add(msgParts, " nkCallArg=")
        add(msgParts, intToStr(int32(nkCallArg)))
        echo fmt(msgParts)

    for ai in 1..<kidCount(pat):
        let arg: Node = kid(pat, ai)
        if debug:
            let ak: str = ((arg != nil)) ? intToStr(int32(nodeKind(arg))) : "nil"
            let ac: str = ((arg != nil)) ? intToStr(kidCount(arg)) : "0"
            let an: str = ((arg != nil)) ? plainName(arg) : ""
            var msg3Parts: str[]
            add(msg3Parts, "[backend] destructure arg#")
            add(msg3Parts, intToStr(ai))
            add(msg3Parts, " kind=nk#")
            add(msg3Parts, ak)
            add(msg3Parts, " kids=")
            add(msg3Parts, ac)
            add(msg3Parts, " name=")
            add(msg3Parts, an)
            echo fmt(msg3Parts)
        if (arg != nil):
            let fieldIdx: int32 = ai - 1
            var corePos: Node = arg
            while astNodeIdValid(corePos) && nodeKind(corePos) == nkPar && kidCount(corePos) > 0:
                corePos = kid(corePos, 0)
            if astNodeIdValid(corePos) && nodeKind(corePos) == nkPattern && kidCount(corePos) > 0:
                corePos = kid(corePos, 0)
            if fieldIdx >= 0 && fieldIdx < ot.fields.len &&
               (corePos != nil) && (nodeKind(corePos) == nkIdent || nodeKind(corePos) == nkSymbol) &&
               !(plainName(corePos) == "_"):
                let nm: str = plainName(corePos)
                let f: UirCoreObjField = ot.fields[fieldIdx]
                var addr: UirExprId = objPtr
                if f.offset != 0:
                    addr = uirCoreBin(mbAdd, objPtr, uirCoreConstI64(int64(f.offset)))
                let loaded: UirExprId = uirCoreLoad(addr, f.ty)
                let slot: int32 = localAdd(b.env, nm, f.ty)
                uirCoreSetLocalType(b.func, slot, f.ty)
                if debug:
                    var bindMsgParts: str[]
                    add(bindMsgParts, "[backend] destructure bind ")
                    add(bindMsgParts, nm)
                    add(bindMsgParts, " slot=")
                    add(bindMsgParts, intToStr(slot))
                    add(bindMsgParts, " field=")
                    add(bindMsgParts, f.name)
                    echo fmt(bindMsgParts)
                if kind == nkLet:
                    blockBuilderAddStmt(b, uirCoreStmtLet(nm, slot, loaded))
                else:
                    blockBuilderAddStmt(b, uirCoreStmtVar(nm, slot, loaded))
                continue
        if astNodeIdValid(arg) && nodeKind(arg) == nkCallArg:
            var nameNode: Node = astInvalidNodeId()
            var valNode: Node = astInvalidNodeId()
            if kidCount(arg) > 1:
                nameNode = kid(arg, 0)
                valNode = kid(arg, 1)
            elif kidCount(arg) > 0:
                valNode = kid(arg, 0)
            var fieldName: str = ""
            if (nameNode != nil) && (nodeKind(nameNode) == nkIdent || nodeKind(nameNode) == nkSymbol):
                fieldName = backendStripSpaces(plainName(nameNode))
            else:
                fieldName = backendStripSpaces(plainName(arg))
            var core: Node = valNode
            while astNodeIdValid(core) && nodeKind(core) == nkPar && kidCount(core) > 0:
                core = kid(core, 0)
            if astNodeIdValid(core) && nodeKind(core) == nkCallArg && kidCount(core) > 1:
                core = kid(core, 1)
            if astNodeIdValid(core) && nodeKind(core) == nkPattern && kidCount(core) > 0:
                core = kid(core, 0)
            if debug:
                let nk: str = ((nameNode != nil)) ? intToStr(int32(nodeKind(nameNode))) : "nil"
                let vk: str = ((valNode != nil)) ? intToStr(int32(nodeKind(valNode))) : "nil"
                let ck: str = ((core != nil)) ? intToStr(int32(nodeKind(core))) : "nil"
                let nn: str = ((nameNode != nil)) ? plainName(nameNode) : ""
                let vn: str = ((valNode != nil)) ? plainName(valNode) : ""
                let cn: str = ((core != nil)) ? plainName(core) : ""
                var msg2Parts: str[]
                add(msg2Parts, "[backend] destructure field nk#")
                add(msg2Parts, nk)
                add(msg2Parts, " name=")
                add(msg2Parts, nn)
                add(msg2Parts, " val nk#")
                add(msg2Parts, vk)
                add(msg2Parts, " val=")
                add(msg2Parts, vn)
                add(msg2Parts, " core nk#")
                add(msg2Parts, ck)
                add(msg2Parts, " core=")
                add(msg2Parts, cn)
                add(msg2Parts, " field=")
                add(msg2Parts, fieldName)
                echo fmt(msg2Parts)
            if len(fieldName) > 0 &&
               (core != nil) && (nodeKind(core) == nkIdent || nodeKind(core) == nkSymbol) && !(plainName(core) == "_"):
                for fi in 0..<ot.fields.len:
                    let f: UirCoreObjField = ot.fields[fi]
                    if (f.name == fieldName):
                        var addr: UirExprId = objPtr
                        if f.offset != 0:
                            addr = uirCoreBin(mbAdd, objPtr, uirCoreConstI64(int64(f.offset)))
                        let loaded: UirExprId = uirCoreLoad(addr, f.ty)
                        let nm: str = plainName(core)
                        let slot: int32 = localAdd(b.env, nm, f.ty)
                        uirCoreSetLocalType(b.func, slot, f.ty)
                        if kind == nkLet:
                            blockBuilderAddStmt(b, uirCoreStmtLet(nm, slot, loaded))
                        else:
                            blockBuilderAddStmt(b, uirCoreStmtVar(nm, slot, loaded))
                        break
    return Ok[bool](false)

fn lowerSeqCapAssignFallback(b: BlockBuilder, lhs: Node, rhs: Node): Result[bool] =
    if (b == nil) || b.module == nil || !uirCoreFuncIdValid(b.func) || (lhs == nil) || (rhs == nil):
        return Ok[bool](false)
    if nodeKind(lhs) != nkDotExpr || kidCount(lhs) < 2:
        return Ok[bool](false)
    let base: Node = kid(lhs, 0)
    let member: Node = kid(lhs, 1)
    if (base == nil) || (member == nil) || (nodeKind(member) != nkIdent && nodeKind(member) != nkSymbol):
        return Ok[bool](false)
    let memberName: str = backendStripSpaces(plainName(member))
    if !(memberName == "cap"):
        return Ok[bool](false)
    let dbgSeqCap: bool = (getEnv "BACKEND_DEBUG_SEQ_CAP_ASSIGN" == "1")

    # Keep low-level seq internals on raw header writes in non-dict modes.
    # In dict helper-closure mode we must lower these too, otherwise
    # `reserve/setLen` can leak as undefined helper symbols.
    let fcur: UirCoreFunc = b.func
    let fp0: str = uirCoreFuncOriginFileOf(fcur)
    let fp: str = (len(fp0) > 0) ? fp0 : ""
    if (len(fp) > 0 && strContains(fp, "src/std/seqs.cheng")) ||
       (len(fp) > 0 && strContains(fp, "src/stage1/seqs_mono_")):
        if !uirCoreDictHelperClosureEnabled():
            if dbgSeqCap:
                echo("[backend] seq.cap skip internal @" + fp + ":" + intToStr(nodePosLine(lhs)) + ":" + intToStr(nodePosCol(lhs)))
            return Ok[bool](false)

    var baseKey: str = caseInferExprTypeKey(b, base)
    if len(baseKey) == 0:
        baseKey = exprTypeKeyShallow(b, base)
    if (len(baseKey) == 0) && (nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol):
        let nm0: str = plainName(base)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm0)
        if slot0 >= 0 && uirCoreFuncIdValid(b.func):
            let ol0: int32 = funcFindObjLocal(b.func, slot0)
            if ol0 >= 0:
                baseKey = funcObjTypeKey(b.func, slot0)
            else:
                baseKey = localTypeKey(b.env, slot0)
        if len(baseKey) == 0:
            let g0: str = uirCoreGlobalObjTypeGet(nm0)
            if len(g0) > 0:
                baseKey = g0
        if len(baseKey) == 0:
            let g1: str = uirCoreGlobalTypeKeyGet(nm0)
            if len(g1) > 0:
                baseKey = g1
    if len(baseKey) == 0:
        return Ok[bool](false)
    baseKey = uirCoreNormalizeObjLookupKey(b.module, baseKey)
    if dbgSeqCap:
        var nmDbg: str = ""
        if (base != nil) && (nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol):
            nmDbg = plainName(base)
        echo("[backend] seq.cap probe @" + fp + ":" + intToStr(nodePosLine(lhs)) + ":" + intToStr(nodePosCol(lhs)) +
             " base=" + nmDbg + " key=" + baseKey)
    if !uirCoreStrStartsWith(baseKey, "seq_") && !uirCoreStrStartsWith(baseKey, "seq_fixed_") && !(baseKey == "seq"):
        if dbgSeqCap:
            echo("[backend] seq.cap miss non-seq key")
        return Ok[bool](false)
    if !uirCoreHasObjType(b.module, "seq"):
        return Ok[bool](false)

    var elemKey: str = ""
    if uirCoreStrStartsWith(baseKey, "seq_"):
        elemKey = str(rawmemPtrAdd(rawmemAsVoid(baseKey), 4))
    elif uirCoreStrStartsWith(baseKey, "seq_fixed_"):
        elemKey = str(rawmemPtrAdd(rawmemAsVoid(baseKey), 10))
    if (len(elemKey) == 0) && astNodeIdValid(base) && nodeTypeCacheValid(base) && astRefNonNil(nodeTypeCache(base)):
        var t0: Node = nodeTypeCache(base)
        while astNodeIdValid(t0) && nodeKind(t0) == nkPar && kidCount(t0) > 0:
            t0 = kid(t0, 0)
        while astNodeIdValid(t0) && nodeKind(t0) == nkVarTy && kidCount(t0) > 0:
            t0 = kid(t0, 0)
            while astNodeIdValid(t0) && nodeKind(t0) == nkPar && kidCount(t0) > 0:
                t0 = kid(t0, 0)
        if astNodeIdValid(t0) && nodeKind(t0) == nkBracketExpr && kidCount(t0) > 1:
            let b0: str = backendStripSpaces(plainName(kid(t0, 0)))
            if (b0 == "seq") || (b0 == "seq_fixed"):
                elemKey = typeKey(kid(t0, 1))
    if len(elemKey) == 0:
        if dbgSeqCap:
            echo("[backend] seq.cap miss elem key")
        return Ok[bool](false)

    let elemNode: Node = newIdent(elemKey, nodePos(lhs))
    let elemSizeRes: Result[int32] = uirCoreSizeOfTypeNode(b.module, elemNode)
    if !IsOk[int32](elemSizeRes):
        return ErrInfo[bool](ErrorInfoOf[int32](elemSizeRes))
    let elemSize: int32 = Value[int32](elemSizeRes)
    if elemSize <= 0:
        return Err[bool]("uirCore_builder: seq.cap assignment unknown element size")

    let baseRes: Result[UirExprId] = lowerExprValue(b, base, uirCoreTypeI64())
    if !IsOk[UirExprId](baseRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](baseRes))
    let baseTmp: str = blockBuilderNextTemp(b, "__seq_cap_base")
    let baseSlot: int32 = localAdd(b.env, baseTmp, uirCoreTypeI64())
    uirCoreSetLocalType(b.func, baseSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(baseTmp, baseSlot, Value[UirExprId](baseRes)))
    let basePtr: UirExprId = uirCoreLocal(baseSlot)

    let newCapRes: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI32())
    if !IsOk[UirExprId](newCapRes):
        return ErrInfo[bool](ErrorInfoOf[UirExprId](newCapRes))
    let newCapTmp: str = blockBuilderNextTemp(b, "__seq_cap_new")
    let newCapSlot: int32 = localAdd(b.env, newCapTmp, uirCoreTypeI32())
    uirCoreSetLocalType(b.func, newCapSlot, uirCoreTypeI32())
    blockBuilderAddStmt(b, uirCoreStmtLet(newCapTmp, newCapSlot, Value[UirExprId](newCapRes)))
    let newCapVal: UirExprId = uirCoreLocal(newCapSlot)

    let seqOt: UirCoreObjType = uirCoreGetObjType(b.module, "seq")
    var capOff: int32 = -1
    var bufOff: int32 = -1
    for fi in 0..<seqOt.fields.len:
        let f: UirCoreObjField = seqOt.fields[fi]
        if (f.name == "cap"):
            capOff = f.offset
        elif (f.name == "buffer"):
            bufOff = f.offset
    if capOff < 0 || bufOff < 0:
        return Err[bool]("uirCore_builder: seq layout mismatch")

    let capAddr: UirExprId = (capOff == 0) ? basePtr : uirCoreBin(mbAdd, basePtr, uirCoreConstI64(int64(capOff)))
    let bufAddr: UirExprId = (bufOff == 0) ? basePtr : uirCoreBin(mbAdd, basePtr, uirCoreConstI64(int64(bufOff)))

    let oldCapTmp: str = blockBuilderNextTemp(b, "__seq_cap_old")
    let oldCapSlot: int32 = localAdd(b.env, oldCapTmp, uirCoreTypeI32())
    uirCoreSetLocalType(b.func, oldCapSlot, uirCoreTypeI32())
    blockBuilderAddStmt(b, uirCoreStmtLet(oldCapTmp, oldCapSlot, uirCoreLoad(capAddr, uirCoreTypeI32())))
    let oldCapVal: UirExprId = uirCoreLocal(oldCapSlot)

    let oldBufTmp: str = blockBuilderNextTemp(b, "__seq_buf_old")
    let oldBufSlot: int32 = localAdd(b.env, oldBufTmp, uirCoreTypeI64())
    uirCoreSetLocalType(b.func, oldBufSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(oldBufTmp, oldBufSlot, uirCoreLoad(bufAddr, uirCoreTypeI64())))
    let oldBufVal: UirExprId = uirCoreLocal(oldBufSlot)

    let growLabel: str = blockBuilderNextLabel(b, "seq_cap_grow")
    let hasBufLabel: str = blockBuilderNextLabel(b, "seq_cap_has_buf")
    let hasOldCapLabel: str = blockBuilderNextLabel(b, "seq_cap_has_oldcap")
    let doZeroLabel: str = blockBuilderNextLabel(b, "seq_cap_zero")
    let joinLabel: str = blockBuilderNextLabel(b, "seq_cap_join")
    let growCond: UirExprId = uirCoreCmp(mcGt, newCapVal, oldCapVal)
    blockBuilderFinish(b, uirCoreTermCbr(growCond, growLabel, joinLabel))

    blockBuilderStart(b, growLabel)
    blockBuilderAddStmt(b, uirCoreStmtStore(capAddr, newCapVal, uirCoreTypeI32()))
    let bytesTmp: str = blockBuilderNextTemp(b, "__seq_cap_bytes")
    let bytesSlot: int32 = localAdd(b.env, bytesTmp, uirCoreTypeI64())
    uirCoreSetLocalType(b.func, bytesSlot, uirCoreTypeI64())
    let newCap64: UirExprId = uirCoreCast(uirCoreTypeI64(), newCapVal)
    let newBytes: UirExprId = uirCoreBin(mbMul, newCap64, uirCoreConstI64(int64(elemSize)))
    blockBuilderAddStmt(b, uirCoreStmtLet(bytesTmp, bytesSlot, newBytes))
    let bytesVal: UirExprId = uirCoreLocal(bytesSlot)

    var reallocArgs: UirExprId[]
    builderExprSeqAppend(reallocArgs, oldBufVal)
    builderExprSeqAppend(reallocArgs, bytesVal)
    let newBufTmp: str = blockBuilderNextTemp(b, "__seq_buf_new")
    let newBufSlot: int32 = localAdd(b.env, newBufTmp, uirCoreTypeI64())
    uirCoreSetLocalType(b.func, newBufSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(newBufTmp, newBufSlot, uirCoreCall("realloc", reallocArgs)))
    let newBufVal: UirExprId = uirCoreLocal(newBufSlot)
    blockBuilderAddStmt(b, uirCoreStmtStore(bufAddr, newBufVal, uirCoreTypeI64()))

    let hasBufCond: UirExprId = uirCoreCmp(mcNe, newBufVal, uirCoreConstI64(0))
    blockBuilderFinish(b, uirCoreTermCbr(hasBufCond, hasBufLabel, joinLabel))

    blockBuilderStart(b, hasBufLabel)
    let hasOldCapCond: UirExprId = uirCoreCmp(mcGe, oldCapVal, uirCoreConstI64(0))
    blockBuilderFinish(b, uirCoreTermCbr(hasOldCapCond, hasOldCapLabel, joinLabel))

    blockBuilderStart(b, hasOldCapLabel)
    let oldCap64: UirExprId = uirCoreCast(uirCoreTypeI64(), oldCapVal)
    let oldBytes: UirExprId = uirCoreBin(mbMul, oldCap64, uirCoreConstI64(int64(elemSize)))
    let needZeroCond: UirExprId = uirCoreCmp(mcGt, bytesVal, oldBytes)
    blockBuilderFinish(b, uirCoreTermCbr(needZeroCond, doZeroLabel, joinLabel))

    blockBuilderStart(b, doZeroLabel)
    let zeroAddr: UirExprId = uirCoreBin(mbAdd, newBufVal, oldBytes)
    let zeroBytes: UirExprId = uirCoreBin(mbSub, bytesVal, oldBytes)
    var zeroArgs: UirExprId[]
    builderExprSeqAppend(zeroArgs, zeroAddr)
    builderExprSeqAppend(zeroArgs, zeroBytes)
    blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall("zeroMem", zeroArgs)))
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))

    blockBuilderStart(b, joinLabel)
    if dbgSeqCap:
        echo("[backend] seq.cap lowered ok @" + fp + ":" + intToStr(nodePosLine(lhs)) + ":" + intToStr(nodePosCol(lhs)))
    return Ok[bool](true)

fn lowerStmt(b: BlockBuilder, stmt: Node): Result[bool] =
    if (stmt == nil):
        return Ok[bool](false)
    if b != nil:
        blockBuilderFuncRef(b)
    let dbgPipeStmt: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    case nodeKind(stmt)
    of nkLet, nkVar:
        let frefLet: UirCoreFunc = blockBuilderFuncRef(b)
        var pat: Node = astInvalidNodeId()
        if kidCount(stmt) > 0:
            pat = kid(stmt, 0)
        var init: Node = astInvalidNodeId()
        if kidCount(stmt) > 2:
            init = kid(stmt, 2)
        var nameNode: Node = pat
        var typeNode: Node = astInvalidNodeId()
        if kidCount(stmt) > 1:
            typeNode = kid(stmt, 1)
        if astNodeIdValid(pat) && nodeKind(pat) == nkPattern && kidCount(pat) > 0:
            nameNode = kid(pat, 0)
            if kidCount(pat) > 1:
                typeNode = kid(pat, 1)
        var nameCore: Node = nameNode
        while astNodeIdValid(nameCore) && nodeKind(nameCore) == nkPar && kidCount(nameCore) > 0:
            nameCore = kid(nameCore, 0)
        if astNodeIdValid(nameCore) && nodeKind(nameCore) == nkSeqLit:
            return lowerDestructureSeq(b, nodeKind(stmt), nameCore, init)
        if astNodeIdValid(nameCore) && nodeKind(nameCore) == nkTupleLit:
            return lowerDestructureTuple(b, nodeKind(stmt), nameCore, typeNode, init)
        if astNodeIdValid(nameCore) && nodeKind(nameCore) == nkCall:
            return lowerDestructureObject(b, nodeKind(stmt), nameCore, init)
        if (nameCore != nil) && (nodeKind(nameCore) == nkIntLit || nodeKind(nameCore) == nkBoolLit ||
                               nodeKind(nameCore) == nkCharLit || nodeKind(nameCore) == nkNilLit):
            if !astNodeIdValid(init) || nodeKind(init) == nkEmpty:
                return Err[bool]("uirCore_builder: literal pattern expects init")
            let tmpName: str = blockBuilderNextTemp(b, "__pat_lit")
            let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
            uirCoreSetLocalType(frefLet, tmpSlot, uirCoreTypeI64())
            let initRes: Result[UirExprId] = lowerExprValue(b, init, uirCoreTypeI64())
            if !IsOk[UirExprId](initRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](initRes))
            blockBuilderAddStmt(b, uirCoreStmtLet(tmpName, tmpSlot, Value[UirExprId](initRes)))
            var want: UirExprId = uirCoreConstI64(0)
            if nodeKind(nameCore) == nkIntLit:
                want = uirCoreConstI64(nodeIntVal(nameCore))
            elif nodeKind(nameCore) == nkCharLit:
                if len(nodeStrVal(nameCore)) > 0:
                    want = uirCoreConstI64(int64(nodeStrVal(nameCore)[0]))
            elif nodeKind(nameCore) == nkBoolLit:
                let nameLit: str = backendStripSpaces(nodeIdent(nameCore))
                want = uirCoreConstI64((nameLit == "true") ? 1 : 0)
            # nkNilLit stays 0
            let cond: UirExprId = uirCoreCmp(mcEq, uirCoreLocal(tmpSlot), want)
            var args: UirExprId[]
            builderExprSeqAppend(args, cond)
            let msgLabel: str = uirCoreAddCString(b.module, "literal pattern mismatch")
            builderExprSeqAppend(args, uirCoreGlobalAddr(msgLabel))
            blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall("assert", args)))
            return Ok[bool](false)
        if (nameCore == nil) ||(nodeKind(nameCore) != nkIdent && nodeKind(nameCore) != nkSymbol):
            return Err[bool]("uirCore_builder: let/var expects identifier")
        nameNode = nameCore
        let name: str = plainName(nameNode)
        if (getEnv "BACKEND_DEBUG_LET" == "1") &&
           ((backendStripSpaces(name) == "snapRes") || (backendStripSpaces(name) == "tlv")):
            var fnNm: str = ""
            var fp: str = ""
            if uirCoreFuncIdValid(frefLet):
                fnNm = uirCoreFuncNameOf(frefLet)
                fp = uirCoreFuncOriginFileOf(frefLet)
            let initKind: str = ((init != nil)) ? intToStr(int32(nodeKind(init))) : "nil"
            let tKind: str = ((typeNode != nil)) ? intToStr(int32(nodeKind(typeNode))) : "nil"
            echo("[backend] debugLet: fn=" + fnNm + " file=" + fp + " name='" + name + "'" +
                 " stmtKids=" + intToStr(kidCount(stmt)) + " typeKind=nk#" + tKind + " initKind=nk#" + initKind +
                 " @" + intToStr(nodePosLine(stmt)) + ":" + intToStr(nodePosCol(stmt)))
        var declType: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, typeNode)
        if !astNodeIdValid(typeNode) || nodeKind(typeNode) == nkEmpty:
            declType = inferExprTypeWithGlobals(b.env, b.module, frefLet, init, declType)
        elif isAddrCall(init) && declType.kind == mtI32:
            declType = uirCoreTypeI64()
        var objTypeName: str = typeNodeObjTypeName(b.module, typeNode)
        var isObjValue: bool = typeNodeIsObjValue(b.module, typeNode)
        if len(objTypeName) == 0 && (init != nil):
            var initCore0: Node = init
            while astNodeIdValid(initCore0) && nodeKind(initCore0) == nkPar && kidCount(initCore0) > 0:
                initCore0 = kid(initCore0, 0)
            if astNodeIdValid(initCore0) && nodeTypeCacheValid(initCore0) && astRefNonNil(nodeTypeCache(initCore0)):
                objTypeName = typeNodeObjTypeName(b.module, nodeTypeCache(initCore0))
                isObjValue = typeNodeIsObjValue(b.module, nodeTypeCache(initCore0))
            if len(objTypeName) == 0 && (initCore0 != nil):
                var initKey: str = caseInferExprTypeKey(b, initCore0)
                if len(initKey) == 0:
                    initKey = uirCoreInferNodeTypeKeyForOverload(b, initCore0)
                if (len(initKey) == 0) && nodeKind(initCore0) == nkCall:
                    initKey = uirCoreInferValueCallInnerKey(b, initCore0)
                if len(initKey) > 0:
                    var key3: str = initKey
                    key3 = uirCoreStripRefVarKeyOnce(key3)
                    key3 = uirCoreStripPtrKeyOnce(key3)
                    if len(key3) > 0:
                        let canon3: str = uirCoreObjAliasCanon(key3)
                        if len(canon3) > 0:
                            key3 = canon3
                        let objFromKey3: str = uirCoreObjTypeFromTypeKey(b.module, key3)
                        if len(objFromKey3) > 0:
                            objTypeName = objFromKey3
                            let aliasTy2: UirCoreType = uirCoreTryGetTypeAlias(b.module, key3)
                            isObjValue = aliasTy2.kind == mtVoid
                            if objTypeName == "seq" || objTypeName == "Table":
                                isObjValue = true
        if len(objTypeName) > 0:
            declType = uirCoreTypeI64()
        let slot: int32 = localAdd(b.env, name, declType)
        uirCoreSetLocalType(frefLet, slot, declType)
        var declKey: str = ""
        if astNodeIdValid(typeNode) && nodeKind(typeNode) != nkEmpty:
            declKey = uirCoreTypeKeyFromNodeLoose(typeNode)
        elif (init != nil):
            var initCoreKey: Node = init
            while astNodeIdValid(initCoreKey) && nodeKind(initCoreKey) == nkPar && kidCount(initCoreKey) > 0:
                initCoreKey = kid(initCoreKey, 0)
            if astNodeIdValid(initCoreKey) && nodeTypeCacheValid(initCoreKey) && astRefNonNil(nodeTypeCache(initCoreKey)):
                declKey = uirCoreTypeKeyFromNodeLoose(nodeTypeCache(initCoreKey))
            if len(declKey) == 0:
                declKey = caseInferExprTypeKey(b, initCoreKey)
            if len(declKey) == 0:
                declKey = uirCoreInferNodeTypeKeyForOverload(b, initCoreKey)
            if (len(declKey) == 0) && astNodeIdValid(initCoreKey) && nodeKind(initCoreKey) == nkCall:
                declKey = uirCoreInferValueCallInnerKey(b, initCoreKey)
            if len(declKey) > 0:
                # Normalize away `var/ref` wrappers; keep `ptr_` when present.
                declKey = uirCoreStripRefVarKeyOnce(declKey)
        if len(declKey) > 0:
            localSetTypeKey(b.env, slot, declKey)
        if len(objTypeName) == 0 && len(declKey) > 0:
            let objFromDeclKey: str = uirCoreObjTypeFromTypeKey(b.module, declKey)
            if len(objFromDeclKey) > 0:
                objTypeName = objFromDeclKey
        if len(objTypeName) == 0 && astNodeIdValid(typeNode) && nodeKind(typeNode) == nkBracketExpr:
            let synthDeclKey: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(b.module, typeNode)
            if len(synthDeclKey) > 0:
                if len(declKey) == 0:
                    declKey = synthDeclKey
                    localSetTypeKey(b.env, slot, declKey)
                objTypeName = uirCoreObjTypeFromTypeKey(b.module, synthDeclKey)
                if len(objTypeName) > 0:
                    isObjValue = true
        var initCoreNew: Node = init
        while astNodeIdValid(initCoreNew) && nodeKind(initCoreNew) == nkPar && kidCount(initCoreNew) > 0:
            initCoreNew = kid(initCoreNew, 0)
        if astNodeIdValid(initCoreNew) && nodeKind(initCoreNew) == nkCall && uirCoreCallIsNamed(initCoreNew, "new"):
            var allocTypeNode: Node = astInvalidNodeId()
            if kidCount(initCoreNew) > 1:
                allocTypeNode = kid(initCoreNew, 1)
                if astNodeIdValid(allocTypeNode) && nodeKind(allocTypeNode) == nkCallArg:
                    if kidCount(allocTypeNode) > 1:
                        allocTypeNode = kid(allocTypeNode, 1)
                    elif kidCount(allocTypeNode) > 0:
                        allocTypeNode = kid(allocTypeNode, 0)
                while astNodeIdValid(allocTypeNode) && nodeKind(allocTypeNode) == nkPar && kidCount(allocTypeNode) > 0:
                    allocTypeNode = kid(allocTypeNode, 0)
            var newObjTypeName: str = ""
            if astNodeIdValid(allocTypeNode):
                newObjTypeName = typeNodeObjTypeName(b.module, allocTypeNode)
                if len(newObjTypeName) == 0:
                    let synthNewKey: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(b.module, allocTypeNode)
                    if len(synthNewKey) > 0:
                        newObjTypeName = uirCoreObjTypeFromTypeKey(b.module, synthNewKey)
                        if len(declKey) == 0:
                            declKey = synthNewKey
                    if len(newObjTypeName) == 0:
                        var newKey: str = uirCoreTypeKeyFromNodeLoose(allocTypeNode)
                        if len(newKey) == 0:
                            newKey = caseInferExprTypeKey(b, allocTypeNode)
                        if len(newKey) > 0:
                            newKey = uirCoreStripRefVarKeyOnce(newKey)
                            newKey = uirCoreStripPtrKeyOnce(newKey)
                            let canonKey: str = uirCoreObjAliasCanon(newKey)
                            if len(canonKey) > 0:
                                newKey = canonKey
                            newObjTypeName = uirCoreObjTypeFromTypeKey(b.module, newKey)
                            if len(declKey) == 0:
                                declKey = newKey
            if len(newObjTypeName) > 0:
                objTypeName = newObjTypeName
            if len(objTypeName) > 0:
                isObjValue = false
            if len(declKey) > 0:
                localSetTypeKey(b.env, slot, declKey)
        let dbgLetNameFilter: str = os.getEnvDefault("BACKEND_DEBUG_LET_NAME", "")
        if (getEnv "BACKEND_DEBUG_LET" == "1") &&
           (len(dbgLetNameFilter) == 0 || backendStripSpaces(name) == dbgLetNameFilter):
            var fnNmDbg: str = ""
            var fpDbg: str = ""
            if uirCoreFuncIdValid(frefLet):
                fnNmDbg = uirCoreFuncNameOf(frefLet)
                fpDbg = uirCoreFuncOriginFileOf(frefLet)
            os.writeLine(os.get_stderr(),
                         "[backend] debugLetState: fn=" + fnNmDbg +
                         " file=" + fpDbg +
                         " name=" + name +
                         " objType=" + objTypeName +
                         " isObjValue=" + (isObjValue ? "1" : "0") +
                         " declKey=" + declKey +
                         " declTy=" + uirCoreTypeKindNameLocal(declType) +
                         " initKind=nk#" + (((init != nil)) ? intToStr(int32(nodeKind(init))) : "nil"))
            os.c_fflush(os.get_stderr())
        if (getEnv "BACKEND_DEBUG_LET" == "1") && (backendStripSpaces(name) == "tlv"):
            var fnNm2: str = ""
            if uirCoreFuncIdValid(frefLet):
                fnNm2 = uirCoreFuncNameOf(frefLet)
            let caseKeyDbg: str = caseInferExprTypeKey(b, init)
            let inferKeyDbg: str = uirCoreInferNodeTypeKeyForOverload(b, init)
            echo("[backend] debugLetInfer: fn=" + fnNm2 + " name='" + name +
                 "' declTy=nk#" + intToStr(int32(declType.kind)) +
                 " objTypeName='" + objTypeName + "' isObjValue=" + (isObjValue ? "1" : "0") +
                 " declKey='" + declKey + "' caseKey='" + caseKeyDbg + "' inferKey='" + inferKeyDbg + "'")
        if len(objTypeName) > 0:
            if isObjValue:
                let allocRes: Result[bool] = allocObjValueLocal(b, slot, objTypeName)
                if ! uirCoreResultBoolIsOk(allocRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(allocRes))
            else:
                funcSetObjLocal(frefLet, slot, objTypeName, -1)
            var kLocal: str = declKey
            if len(kLocal) == 0:
                kLocal = objTypeName
            if len(objTypeName) > 0 && !(objTypeName == "seq") && (len(kLocal) == 0 || !uirCoreHasObjType(b.module, kLocal)):
                kLocal = objTypeName
            if len(kLocal) > 0:
                funcSetObjTypeKey(frefLet, slot, kLocal)
        if !astNodeIdValid(init) || nodeKind(init) == nkEmpty:
            if isObjValue:
                let initRes2: Result[bool] = emitObjDefaultInit(b, slot, objTypeName)
                if ! uirCoreResultBoolIsOk(initRes2):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(initRes2))
                let sfi: SeqFixedInit = seqFixedInitInfo(typeNode)
                if sfi.elemType != nil && sfi.capExpr != nil:
                    let seqInitRes: Result[bool] = emitSeqFixedReserveInitToPtr(b, uirCoreLocal(slot), sfi)
                    if !uirCoreResultBoolIsOk(seqInitRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(seqInitRes))
                return Ok[bool](false)
            if isStringKey(declKey):
                let label0: str = uirCoreAddCString(b.module, "")
                if nodeKind(stmt) == nkLet:
                    blockBuilderAddStmt(b, uirCoreStmtLet(name, slot, uirCoreGlobalAddr(label0)))
                else:
                    blockBuilderAddStmt(b, uirCoreStmtVar(name, slot, uirCoreGlobalAddr(label0)))
                return Ok[bool](false)
            if nodeKind(stmt) == nkLet:
                blockBuilderAddStmt(b, uirCoreStmtLet(name, slot, uirCoreConstI64(0)))
            else:
                blockBuilderAddStmt(b, uirCoreStmtVar(name, slot, uirCoreConstI64(0)))
            return Ok[bool](false)
        var initCoreStr: Node = init
        while astNodeIdValid(initCoreStr) && nodeKind(initCoreStr) == nkPar && kidCount(initCoreStr) > 0:
            initCoreStr = kid(initCoreStr, 0)
        if astNodeIdValid(initCoreStr) && nodeKind(initCoreStr) == nkNilLit && isSemanticStrKey(declKey):
            if !uirCoreSkipSemStdDuplicateRelaxEnabled():
                return Err[bool]("uirCore_builder: semantic str cannot be initialized with nil")
        if isControlExprId(init):
            if isObjValue:
                var initCore3: Node = init
                while astNodeIdValid(initCore3) && nodeKind(initCore3) == nkPar && kidCount(initCore3) > 0:
                    initCore3 = kid(initCore3, 0)
                if astNodeIdValid(initCore3) && nodeKind(initCore3) == nkIf:
                    let ifRes: Result[bool] = lowerIfAssignObjValue(b, initCore3, name, slot)
                    if !uirCoreResultBoolIsOk(ifRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(ifRes))
                    return Ok[bool](false)
                return Err[bool]("uirCore_builder: object init via control expr not supported")
            let assignRes: Result[bool] = lowerAssignValue(b, init, name, slot)
            if ! uirCoreResultBoolIsOk(assignRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(assignRes))
            return Ok[bool](false)
        if isObjValue:
            let assignRes2: Result[bool] = lowerAssignValue(b, init, name, slot)
            if ! uirCoreResultBoolIsOk(assignRes2):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(assignRes2))
            return Ok[bool](false)
        let initRes: Result[UirExprId] = lowerExprValue(b, init, declType)
        if ! IsOk[UirExprId](initRes):
            return ErrInfo[bool](ErrorInfoOf[UirExprId](initRes))
        var initCore2: Node = init
        while astNodeIdValid(initCore2) && nodeKind(initCore2) == nkPar && kidCount(initCore2) > 0:
            initCore2 = kid(initCore2, 0)
        if (initCore2 != nil) && (nodeKind(initCore2) == nkIdent || nodeKind(initCore2) == nkSymbol):
            let initName: str = plainName(initCore2)
            if moduleHasFuncByBase(b.module, initName):
                let f1: UirCoreFunc = moduleFindFuncByBaseUnique(b.module, initName)
                if (f1 != nil):
                    localSetCallTarget(b.env, slot, uirCoreFuncNameOf(f1))
        if nodeKind(stmt) == nkLet:
            blockBuilderAddStmt(b, uirCoreStmtLet(name, slot, Value[UirExprId](initRes)))
        else:
            blockBuilderAddStmt(b, uirCoreStmtVar(name, slot, Value[UirExprId](initRes)))
        return Ok[bool](false)
    of nkAsgn:
        if kidCount(stmt) < 2:
            return Err[bool]("uirCore_builder: assignment expects lhs/rhs")
        let lhs: Node = kid(stmt, 0)
        let rhs: Node = kid(stmt, 1)
        let dbgAssign: bool = (getEnv "BACKEND_DEBUG_ASSIGN" == "1")
        if dbgAssign && (b != nil) && uirCoreFuncIdValid(b.func):
            let fDbgAssign: UirCoreFunc = b.func
            os.writeLine(os.get_stderr(),
                "[backend] debugAssign: fn=" + uirCoreFuncNameOf(fDbgAssign) +
                " file=" + uirCoreFuncOriginFileOf(fDbgAssign) +
                " lhsKind=nk#" + intToStr(int32(nodeKind(lhs))) +
                " rhsKind=nk#" + intToStr(int32(nodeKind(rhs))) +
                " @" + intToStr(nodePosLine(stmt)) + ":" + intToStr(nodePosCol(stmt)))
            os.c_fflush os.get_stderr()
        let seqCapAssignRes: Result[bool] = lowerSeqCapAssignFallback(b, lhs, rhs)
        if !uirCoreResultBoolIsOk(seqCapAssignRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(seqCapAssignRes))
        if uirCoreResultBoolValue(seqCapAssignRes):
            return Ok[bool](false)
        if astNodeIdValid(lhs) && nodeKind(lhs) == nkBracketExpr:
            if kidCount(lhs) == 1:
                let addrNode: Node = kid(lhs, 0)
                let ptrKey0: str = exprTypeKeyShallow(b, addrNode)
                var elemKey0: str = ""
                if nodeTypeCacheValid(lhs) && astRefNonNil(nodeTypeCache(lhs)):
                    elemKey0 = backendStripSpaces(typeKey nodeTypeCache(lhs))
                    if uirCoreStrStartsWith(elemKey0, "ptr_"):
                        elemKey0 = backendStripSpaces(str(rawmemPtrAdd(rawmemAsVoid(elemKey0), 4)))
                let addrRes: Result[UirExprId] = lowerExprPtrValue(b, addrNode)
                if ! IsOk[UirExprId](addrRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](addrRes))
                if (getEnv "BACKEND_DEBUG_DEREF_STORE" == "1") && (b != nil) && uirCoreFuncIdValid(b.func):
                    let fDbg0: UirCoreFunc = b.func
                    let fpDbg0: str = uirCoreFuncOriginFileOf(fDbg0)
                    let fpDbg1: str = (len(fpDbg0) > 0) ? fpDbg0 : ""
                    echo("[backend] debugBracketStore: fn=" + uirCoreFuncNameOf(fDbg0) + " @" + fpDbg1 + ":" +
                         intToStr(nodePosLine(lhs)) + ":" + intToStr(nodePosCol(lhs)) + " lhsKind=nk#" +
                         intToStr(int32(nodeKind(lhs))) + " ptrKey0='" + ptrKey0 + "' elemKey0='" + elemKey0 + "'")
                if isByteTypeKey(elemKey0) || isBytePtrTypeKey(ptrKey0):
                    let valRes0: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI32())
                    if ! IsOk[UirExprId](valRes0):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes0))
                    let storeTy: UirCoreType = byteUirTypeFromElemOrPtrKey(elemKey0, ptrKey0)
                    lowerByteStoreNilChecked(b, Value[UirExprId](addrRes), Value[UirExprId](valRes0), uirCoreTypeI32(), storeTy)
                else:
                    if uirCoreStrStartsWith(ptrKey0, "ptr_"):
                        let baseKey0: str = str(rawmemPtrAdd(rawmemAsVoid(ptrKey0), 4))
                        let objTypeName0: str = uirCorePtrBaseObjTypeName(b.module, baseKey0)
                        if len(objTypeName0) > 0:
                            let aliasTy0: UirCoreType = uirCoreTryGetTypeAlias(b.module, objTypeName0)
                            if aliasTy0.kind == mtVoid:
                                let dstPtr: UirExprId = Value[UirExprId](addrRes)
                                var rhs0: Node = rhs
                                while astNodeIdValid(rhs0) && nodeKind(rhs0) == nkPar && kidCount(rhs0) > 0:
                                    rhs0 = kid(rhs0, 0)
                                if astNodeIdValid(rhs0) && nodeKind(rhs0) == nkCall:
                                    let callRes: Result[UirExprId] = lowerCallWithLeadingArg(b, rhs0, dstPtr)
                                    if !IsOk[UirExprId](callRes):
                                        return ErrInfo[bool](ErrorInfoOf[UirExprId](callRes))
                                    return Ok[bool](false)
                                let srcRes: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI64())
                                if !IsOk[UirExprId](srcRes):
                                    return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes))
                                let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName0, Value[UirExprId](srcRes))
                                if !uirCoreResultBoolIsOk(copyRes):
                                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes))
                                return Ok[bool](false)
                    let storeType: UirCoreType = inferExprTypeWithGlobals(b.env, b.module, b.func, rhs, uirCoreTypeI32())
                    let valRes: Result[UirExprId] = lowerExprValue(b, rhs, storeType)
                    if ! IsOk[UirExprId](valRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes))
                    blockBuilderAddStmt(b, uirCoreStmtStore(Value[UirExprId](addrRes),
                                                 Value[UirExprId](valRes),
                                                 storeType))
                return Ok[bool](false)
            if kidCount(lhs) == 2:
                let base0: Node = kid(lhs, 0)
                var idx0: Node = kid(lhs, 1)
                while astNodeIdValid(idx0) && nodeKind(idx0) == nkPar && kidCount(idx0) > 0:
                    idx0 = kid(idx0, 0)

                var baseObj: str = ""
                var baseKey2: str = ""
                if astNodeIdValid(base0) && nodeTypeCacheValid(base0) && astRefNonNil(nodeTypeCache(base0)):
                    baseKey2 = typeKey nodeTypeCache(base0)
                    baseObj = typeNodeObjTypeName(b.module, nodeTypeCache(base0))
                if (base0 != nil) && (nodeKind(base0) == nkIdent || nodeKind(base0) == nkSymbol):
                    let nm: str = plainName(base0)
                    let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, nm)
                    if slot0 >= 0 && funcFindObjLocal(b.func, slot0) >= 0:
                        baseObj = funcObjTypeName(b.func, slot0)
                        baseKey2 = funcObjTypeKey(b.func, slot0)
                    elif slot0 >= 0 && len(baseKey2) == 0:
                        baseKey2 = localTypeKey(b.env, slot0)
                    if len(baseObj) == 0:
                        let gObj0: str = uirCoreGlobalObjTypeGet(nm)
                        if len(gObj0) > 0:
                            baseObj = gObj0
                    if len(baseKey2) == 0:
                        let gKey0: str = uirCoreGlobalTypeKeyGet(nm)
                        if len(gKey0) > 0:
                            baseKey2 = gKey0

                var basePtrOverride: UirExprId = uirCoreConstI64(0)
                var haveBasePtrOverride: bool = false
                var daBase0: DotAccess
                let dotBaseRes0: Result[bool] = uirCoreTryLowerDotAccess(b, base0, &daBase0)
                if !IsOk[bool](dotBaseRes0):
                    return ErrInfo[bool](ErrorInfoOf[bool](dotBaseRes0))
                if Value[bool](dotBaseRes0):
                    if daBase0.fieldTy.kind == mtVoid && len(daBase0.objTypeName) > 0:
                        haveBasePtrOverride = true
                        basePtrOverride = daBase0.addr
                        if len(baseObj) == 0:
                            baseObj = daBase0.objTypeName
                        if len(baseKey2) == 0:
                            baseKey2 = daBase0.objTypeName
                    # Some stage1 pipelines omit typeCache on dot expressions. Recover a stable
                    # generic type key (e.g. `seq_T`) so indexed assignment can be lowered as a
                    # builtin seq store instead of falling back to `[]=` overload resolution.
                    let inferredKey2: str = caseInferExprTypeKey(b, base0)
                    if len(inferredKey2) > 0:
                        if uirCoreStrStartsWith(inferredKey2, "seq_") && !uirCoreStrStartsWith(baseKey2, "seq_"):
                            baseKey2 = inferredKey2
                        elif uirCoreStrStartsWith(inferredKey2, "seq_fixed_") && !uirCoreStrStartsWith(baseKey2, "seq_fixed_"):
                            baseKey2 = inferredKey2
                        elif uirCoreStrStartsWith(inferredKey2, "Table_") && !uirCoreStrStartsWith(baseKey2, "Table_"):
                            baseKey2 = inferredKey2
                        elif len(baseKey2) == 0:
                            baseKey2 = inferredKey2

                var objName: str = baseObj
                if len(objName) == 0:
                    objName = baseKey2
                if uirCoreStrStartsWith(objName, "var_ref_"):
                    objName = str(rawmemPtrAdd(rawmemAsVoid(objName), 8))
                elif uirCoreStrStartsWith(objName, "var_") || uirCoreStrStartsWith(objName, "ref_"):
                    objName = str(rawmemPtrAdd(rawmemAsVoid(objName), 4))

                if uirCoreStrStartsWith(objName, "array_") && b.module != nil && uirCoreHasObjType(b.module, objName):
                    var basePtrRes: Result[UirExprId]
                    if haveBasePtrOverride:
                        basePtrRes = Ok[UirExprId](basePtrOverride)
                    else:
                        basePtrRes = lowerExprValue(b, base0, uirCoreTypeI64())
                    if !IsOk[UirExprId](basePtrRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](basePtrRes))
                    let idxRes32: Result[UirExprId] = lowerExprValue(b, idx0, uirCoreTypeI32())
                    if !IsOk[UirExprId](idxRes32):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](idxRes32))
                    let basePtr: UirExprId = Value[UirExprId](basePtrRes)
                    let ot: UirCoreObjType = uirCoreGetObjType(b.module, objName)
                    if ot.fields.len == 0:
                        return Err[bool]("uirCore_builder: array type has no fields: " + objName)
                    let idx32: UirExprId = Value[UirExprId](idxRes32)
                    let arrLen32: UirExprId = uirCoreCast(uirCoreTypeI32(), uirCoreConstI64(int64(ot.fields.len)))
                    var bcArgs: UirExprId[]
                    builderExprSeqAppend(bcArgs, arrLen32)
                    builderExprSeqAppend(bcArgs, idx32)
                    blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall("cheng_bounds_check", bcArgs)))
                    let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), idx32)
                    let f0: UirCoreObjField = ot.fields[0]
                    let elemTy: UirCoreType = f0.ty
                    let elemSize: int32 = uirCoreTypeSize(elemTy)
                    if elemSize <= 0:
                        return Err[bool]("uirCore_builder: array element size unsupported: " + objName)
                    var stride: int64 = int64(alignUpPow2(elemSize, uirCoreTypeAlignPow2(elemTy)))
                    if ot.fields.len > 1:
                        let f1: UirCoreObjField = ot.fields[1]
                        let d: int32 = f1.offset - f0.offset
                        if d > 0:
                            stride = int64(d)
                    let off: UirExprId = (stride == 1) ? idx64 : uirCoreBin(mbMul, idx64, uirCoreConstI64(stride))
                    let addr: UirExprId = uirCoreBin(mbAdd, basePtr, off)
                    # `array[T]` currently uses pointer slots when `T` is an object value.
                    # Store via owned backing memory to avoid dangling stack pointers from
                    # assignments like `arr[i] = localObj`.
                    var elemObjName: str = ""
                    if (rhs != nil) && (nodeKind(rhs) == nkIdent || nodeKind(rhs) == nkSymbol):
                        let srcNm0: str = plainName(rhs)
                        let srcSlot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, srcNm0)
                        if srcSlot0 >= 0 && funcFindObjLocal(b.func, srcSlot0) >= 0:
                            elemObjName = funcObjTypeName(b.func, srcSlot0)
                    if (len(elemObjName) == 0) &&
                       astNodeIdValid(rhs) && nodeTypeCacheValid(rhs) && astRefNonNil(nodeTypeCache(rhs)):
                        elemObjName = typeNodeObjTypeName(b.module, nodeTypeCache(rhs))
                    if len(elemObjName) == 0:
                        var rhsKey0: str = caseInferExprTypeKey(b, rhs)
                        if len(rhsKey0) == 0:
                            rhsKey0 = exprTypeKeyShallow(b, rhs)
                        if len(rhsKey0) > 0:
                            rhsKey0 = uirCoreStripRefVarKeyOnce(rhsKey0)
                            rhsKey0 = uirCoreStripPtrKeyOnce(rhsKey0)
                            elemObjName = uirCoreObjTypeFromTypeKey(b.module, rhsKey0)
                    if len(elemObjName) > 0 && uirCoreHasObjType(b.module, elemObjName):
                        let srcRes0: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI64())
                        if !IsOk[UirExprId](srcRes0):
                            return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes0))
                        let otElem: UirCoreObjType = uirCoreGetObjType(b.module, elemObjName)
                        if otElem.size <= 0:
                            return Err[bool]("uirCore_builder: array object element has invalid size: " + elemObjName)
                        let oldPtr: UirExprId = uirCoreLoad(addr, uirCoreTypeI64())
                        var allocArgs: UirExprId[]
                        builderExprSeqAppend(allocArgs, oldPtr)
                        builderExprSeqAppend(allocArgs, uirCoreConstI64(int64(otElem.size)))
                        let newPtrName: str = blockBuilderNextTemp(b, "__arr_obj_ptr")
                        let newPtrSlot: int32 = localAdd(b.env, newPtrName, uirCoreTypeI64())
                        uirCoreSetLocalType(b.func, newPtrSlot, uirCoreTypeI64())
                        blockBuilderAddStmt(b, uirCoreStmtLet(newPtrName, newPtrSlot, uirCoreCall("realloc", allocArgs)))
                        let newPtr: UirExprId = uirCoreLocal(newPtrSlot)
                        blockBuilderAddStmt(b, uirCoreStmtStore(addr, newPtr, uirCoreTypeI64()))
                        let copyLabel: str = blockBuilderNextLabel(b, "arr_obj_copy")
                        let joinLabel: str = blockBuilderNextLabel(b, "arr_obj_join")
                        let hasPtr: UirExprId = uirCoreCmp(mcNe, newPtr, uirCoreConstI64(0))
                        blockBuilderFinish(b, uirCoreTermCbr(hasPtr, copyLabel, joinLabel))
                        blockBuilderStart(b, copyLabel)
                        let copyResObj: Result[bool] = emitObjCopyPtrs(b, newPtr, elemObjName, Value[UirExprId](srcRes0))
                        if !uirCoreResultBoolIsOk(copyResObj):
                            return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyResObj))
                        blockBuilderFinish(b, uirCoreTermBr(joinLabel))
                        blockBuilderStart(b, joinLabel)
                        return Ok[bool](false)
                    let valRes: Result[UirExprId] = lowerExprValue(b, rhs, elemTy)
                    if !IsOk[UirExprId](valRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes))
                    blockBuilderAddStmt(b, uirCoreStmtStore(addr, Value[UirExprId](valRes), elemTy))
                    return Ok[bool](false)

                # Index assignment for dynamic `seq[T]`: lower to runtime `cheng_seq_set`.
                var seqKey: str = baseKey2
                seqKey = uirCoreStripRefVarKeyOnce(seqKey)
                seqKey = uirCoreStripPtrKeyOnce(seqKey)
                if uirCoreStrStartsWith(seqKey, "seq_") && b.module != nil:
                    let elemKey: str = str(rawmemPtrAdd(rawmemAsVoid(seqKey), 4))
                    if len(elemKey) == 0:
                        return Err[bool]("uirCore_builder: seq index store missing element type")
                    let elemTypeNode: Node = newIdent(elemKey, nodePos(lhs))
                    let sizeRes: Result[int32] = uirCoreSizeOfTypeNode(b.module, elemTypeNode)
                    if !IsOk[int32](sizeRes):
                        return ErrInfo[bool](ErrorInfoOf[int32](sizeRes))
                    let elemSize: int32 = Value[int32](sizeRes)
                    let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(b.module, elemTypeNode)

                    var baseRes3: Result[UirExprId]
                    if haveBasePtrOverride:
                        baseRes3 = Ok[UirExprId](basePtrOverride)
                    else:
                        baseRes3 = lowerExprValue(b, base0, uirCoreTypeI64())
                    if !IsOk[UirExprId](baseRes3):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](baseRes3))
                    let seqName: str = blockBuilderNextTemp(b, "__seq_base")
                    let seqSlot: int32 = localAdd(b.env, seqName, uirCoreTypeI64())
                    uirCoreSetLocalType(b.func, seqSlot, uirCoreTypeI64())
                    blockBuilderAddStmt(b, uirCoreStmtLet(seqName, seqSlot, Value[UirExprId](baseRes3)))
                    let seqPtr: UirExprId = uirCoreLocal(seqSlot)

                    let idxRes3: Result[UirExprId] = lowerExprValue(b, idx0, uirCoreTypeI32())
                    if !IsOk[UirExprId](idxRes3):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](idxRes3))
                    let elemSize32: UirExprId = uirCoreCast(uirCoreTypeI32(), uirCoreConstI64(int64(elemSize)))
                    var args3: UirExprId[]
                    builderExprSeqAppend(args3, seqPtr)
                    builderExprSeqAppend(args3, Value[UirExprId](idxRes3))
                    builderExprSeqAppend(args3, elemSize32)
                    let ptrExpr: UirExprId = uirCoreCall("cheng_seq_set_grow", args3)
                    if (elemKey == "bool"):
                        let valResB: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI32())
                        if !IsOk[UirExprId](valResB):
                            return ErrInfo[bool](ErrorInfoOf[UirExprId](valResB))
                        lowerByteStoreNilChecked(b, ptrExpr, Value[UirExprId](valResB), uirCoreTypeI32(), uirCoreTypeU8())
                        return Ok[bool](false)
                    let elemObjName: str = typeNodeObjTypeName(b.module, elemTypeNode)
                    if len(elemObjName) > 0 && typeNodeIsObjValue(b.module, elemTypeNode):
                        let srcRes0: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI64())
                        if !IsOk[UirExprId](srcRes0):
                            return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes0))
                        let copyRes0: Result[bool] = emitObjCopyPtrs(b, ptrExpr, elemObjName, Value[UirExprId](srcRes0))
                        if !uirCoreResultBoolIsOk(copyRes0):
                            return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes0))
                        return Ok[bool](false)
                    let valRes: Result[UirExprId] = lowerExprValue(b, rhs, elemTy)
                    if !IsOk[UirExprId](valRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes))
                    blockBuilderAddStmt(b, uirCoreStmtStore(ptrExpr, Value[UirExprId](valRes), elemTy))
                    return Ok[bool](false)
            if kidCount(lhs) == 2:
                let base1: Node = kid(lhs, 0)
                let idx1: Node = kid(lhs, 1)
                let callNode: Node = newNode(nkCall, nodePos(lhs))
                nodeSetTypeCache(callNode, nodeTypeCache(lhs))
                nodeSetTypeCacheValid(callNode, nodeTypeCacheValid(lhs))
                addSon(callNode, newIdent("[]=", nodePos(lhs)))
                addSon(callNode, base1)
                addSon(callNode, idx1)
                addSon(callNode, rhs)
                let callRes: Result[UirExprId] = lowerExprValue(b, callNode, uirCoreTypeI64())
                if !IsOk[UirExprId](callRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](callRes))
                blockBuilderAddStmt(b, uirCoreStmtExpr(Value[UirExprId](callRes)))
                return Ok[bool](false)
            return Err[bool]("uirCore_builder: indexed assignment not supported")
        if (lhs != nil) && (nodeKind(lhs) == nkHiddenDeref || nodeKind(lhs) == nkDerefExpr) && kidCount(lhs) > 0:
            let addrNode2: Node = kid(lhs, 0)
            # Prefer local type keys for deref stores; typeCache can be incomplete for ptr locals.
            var ptrKey1: str = ""
            if (addrNode2 != nil) && (nodeKind(addrNode2) == nkIdent || nodeKind(addrNode2) == nkSymbol):
                let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, plainName(addrNode2))
                if slot0 >= 0:
                    ptrKey1 = localTypeKey(b.env, slot0)
            if len(ptrKey1) == 0:
                ptrKey1 = exprTypeKeyShallow(b, addrNode2)
            var elemKey1: str = ""
            if nodeTypeCacheValid(lhs) && astRefNonNil(nodeTypeCache(lhs)):
                elemKey1 = backendStripSpaces(typeKey nodeTypeCache(lhs))
                if uirCoreStrStartsWith(elemKey1, "ptr_"):
                    elemKey1 = backendStripSpaces(str(rawmemPtrAdd(rawmemAsVoid(elemKey1), 4)))
            if (getEnv "BACKEND_DEBUG_DEREF_STORE" == "1") && (b != nil) && uirCoreFuncIdValid(b.func):
                let fDbg: UirCoreFunc = b.func
                let fpDbg: str = uirCoreFuncOriginFileOf(fDbg)
                let fpDbg2: str = (len(fpDbg) > 0) ? fpDbg : ""
                echo("[backend] debugDerefStore: fn=" + uirCoreFuncNameOf(fDbg) + " @" + fpDbg2 + ":" +
                     intToStr(nodePosLine(lhs)) + ":" + intToStr(nodePosCol(lhs)) + " lhsKind=nk#" +
                     intToStr(int32(nodeKind(lhs))) + " ptrKey1='" + ptrKey1 + "' elemKey1='" + elemKey1 + "'")
            let addrRes2: Result[UirExprId] = lowerExprPtrValue(b, addrNode2)
            if ! IsOk[UirExprId](addrRes2):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](addrRes2))
            if isByteTypeKey(elemKey1) || isBytePtrTypeKey(ptrKey1):
                let valRes2a: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI32())
                if ! IsOk[UirExprId](valRes2a):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes2a))
                let storeTy2: UirCoreType = byteUirTypeFromElemOrPtrKey(elemKey1, ptrKey1)
                lowerByteStoreNilChecked(b, Value[UirExprId](addrRes2), Value[UirExprId](valRes2a), uirCoreTypeI32(), storeTy2)
            else:
                var storeType2: UirCoreType = uirCoreTypeVoid()
                # Some stage1 pipelines may keep a bare `ptr` key without an inner type.
                # Treat it as pointer-sized to avoid truncating pointer values.
                if isPtrKey(ptrKey1):
                    storeType2 = uirCoreTypeI64()
                if uirCoreStrStartsWith(ptrKey1, "ptr_"):
                    let baseKey1: str = str(rawmemPtrAdd(rawmemAsVoid(ptrKey1), 4))
                    let objTypeName1: str = uirCorePtrBaseObjTypeName(b.module, baseKey1)
                    if len(objTypeName1) > 0:
                        let aliasTy1: UirCoreType = uirCoreTryGetTypeAlias(b.module, objTypeName1)
                        if aliasTy1.kind == mtVoid:
                            let dstPtr: UirExprId = Value[UirExprId](addrRes2)
                            var rhs0: Node = rhs
                            while astNodeIdValid(rhs0) && nodeKind(rhs0) == nkPar && kidCount(rhs0) > 0:
                                rhs0 = kid(rhs0, 0)
                            if astNodeIdValid(rhs0) && nodeKind(rhs0) == nkCall:
                                let callRes: Result[UirExprId] = lowerCallWithLeadingArg(b, rhs0, dstPtr)
                                if !IsOk[UirExprId](callRes):
                                    return ErrInfo[bool](ErrorInfoOf[UirExprId](callRes))
                                return Ok[bool](false)
                            let srcRes: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI64())
                            if !IsOk[UirExprId](srcRes):
                                return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes))
                            let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, objTypeName1, Value[UirExprId](srcRes))
                            if !uirCoreResultBoolIsOk(copyRes):
                                return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes))
                            return Ok[bool](false)
                    if len(baseKey1) > 0:
                        let baseKey1Trim: str = backendStripSpaces(baseKey1)
                        if isPtrRefVarLikeKey(baseKey1Trim):
                            storeType2 = uirCoreTypeI64()
                        else:
                            let baseTypeNode: Node = newIdent(baseKey1Trim, nodePos(lhs))
                            storeType2 = uirCoreTypeFromNodeWithModule(b.module, baseTypeNode)
                            if storeType2.kind == mtVoid:
                                storeType2 = uirCoreTypeI64()
                    else:
                        storeType2 = uirCoreTypeI64()
                if storeType2.kind == mtVoid:
                    storeType2 = inferExprTypeWithGlobals(b.env, b.module, b.func, rhs, uirCoreTypeI32())
                let valRes2: Result[UirExprId] = lowerExprValue(b, rhs, storeType2)
                if ! IsOk[UirExprId](valRes2):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes2))
                blockBuilderAddStmt(b, uirCoreStmtStore(Value[UirExprId](addrRes2),
                                             Value[UirExprId](valRes2),
                                             storeType2))
            return Ok[bool](false)
        if astNodeIdValid(lhs) && nodeKind(lhs) == nkDotExpr:
            let dotFieldName: str = (kidCount(lhs) > 1) ? backendStripSpaces(plainName(kid(lhs, 1))) : ""
            if dbgAssign && (b != nil) && uirCoreFuncIdValid(b.func):
                os.writeLine(os.get_stderr(),
                    "[backend] debugAssign: dot-lhs before lower field='" + dotFieldName +
                    "' @" + intToStr(nodePosLine(lhs)) + ":" + intToStr(nodePosCol(lhs)))
                os.c_fflush os.get_stderr()
            var da: DotAccess
            let dotLhsRes: Result[bool] = uirCoreTryLowerDotAccess(b, lhs, &da)
            if !IsOk[bool](dotLhsRes):
                return Err[bool]("uirCore_builder: dot lhs lower failed field='" + dotFieldName +
                                 "' err=" + Error(dotLhsRes))
            if !Value[bool](dotLhsRes):
                return Err[bool]("uirCore_builder: dot lhs expects field access")
            if dbgAssign:
                os.writeLine(os.get_stderr(),
                    "[backend] debugAssign: dot-lhs lowered fieldTy=nk#" + intToStr(int32(da.fieldTy.kind)) +
                    " objType='" + da.objTypeName + "'")
                os.c_fflush os.get_stderr()
            if da.fieldTy.kind == mtVoid:
                # Composite (inlined) object field assignment: copy from rhs pointer to dst field storage.
                var objNm: str = da.objTypeName
                if (rhs != nil) && (nodeKind(rhs) == nkIdent || nodeKind(rhs) == nkSymbol):
                    let srcSlot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, plainName(rhs))
                    if srcSlot0 >= 0:
                        objNm = funcObjTypeName(b.func, srcSlot0)
                if len(objNm) == 0 && astNodeIdValid(rhs) && nodeTypeCacheValid(rhs) && astRefNonNil(nodeTypeCache(rhs)):
                    objNm = typeNodeObjTypeName(b.module, nodeTypeCache(rhs))
                if len(objNm) == 0:
                    return Err[bool]("uirCore_builder: object field assignment missing type")
                let srcRes: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI64())
                if !IsOk[UirExprId](srcRes):
                    return Err[bool]("uirCore_builder: object dot lhs rhs lower failed field='" + dotFieldName +
                                     "' obj='" + objNm + "' err=" + Error(srcRes))
                let copyRes: Result[bool] = emitObjCopyPtrs(b, da.addr, objNm, Value[UirExprId](srcRes))
                if !uirCoreResultBoolIsOk(copyRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes))
                return Ok[bool](false)
            if nodeTypeCacheValid(lhs) && astRefNonNil(nodeTypeCache(lhs)):
                let objNm: str = typeNodeObjTypeName(b.module, nodeTypeCache(lhs))
                if len(objNm) > 0 && typeNodeIsObjValue(b.module, nodeTypeCache(lhs)):
                    let srcRes: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI64())
                    if !IsOk[UirExprId](srcRes):
                        return Err[bool]("uirCore_builder: typed object dot lhs rhs lower failed field='" + dotFieldName +
                                         "' obj='" + objNm + "' err=" + Error(srcRes))
                    let copyRes: Result[bool] = emitObjCopyPtrs(b, da.addr, objNm, Value[UirExprId](srcRes))
                    if !uirCoreResultBoolIsOk(copyRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes))
                    return Ok[bool](false)
            let valRes: Result[UirExprId] = lowerExprValue(b, rhs, da.fieldTy)
            if ! IsOk[UirExprId](valRes):
                return Err[bool]("uirCore_builder: scalar dot lhs rhs lower failed field='" + dotFieldName +
                                 "' obj='" + da.objTypeName + "' err=" + Error(valRes))
            blockBuilderAddStmt(b, uirCoreStmtStore(da.addr, Value[UirExprId](valRes), da.fieldTy))
            return Ok[bool](false)
        if (lhs == nil) ||(nodeKind(lhs) != nkIdent && nodeKind(lhs) != nkSymbol):
            return Err[bool]("uirCore_builder: assignment expects identifier")
        let name2: str = backendStripSpaces(plainName(lhs))
        let slot2: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, b.func, name2)
        uirCoreMarkImplicitResultUse(b, name2, slot2)
        if slot2 < 0:
            let mod: UirCoreModule = b.module
            var gName: str = name2
            var gi: int32 = moduleGlobalIndex(mod, gName)
            if gi < 0 && uirCoreFuncIdValid(b.func) && uirCoreDupGlobalNamesHas(name2):
                let f2: UirCoreFunc = b.func
                let g2: str = uirCoreMaybeMangleDupGlobalName(name2, uirCoreFuncOriginFileOf(f2))
                if len(g2) > 0:
                    gName = g2
                    gi = moduleGlobalIndex(mod, gName)
            if gi < 0 && uirCoreDupGlobalNamesHas(name2):
                let gi2: int32 = moduleFindGlobalIndexByBaseUnique(mod, name2)
                if gi2 >= 0 && gi2 < uirCoreModuleGlobalsLen(mod):
                    let g2: UirCoreGlobal = uirCoreModuleGlobalAt(mod, gi2)
                    if len(g2.name) > 0:
                        gName = g2.name
                        gi = gi2
            if gi < 0 && uirCoreStrStartsWith(name2, "__cheng_"):
                var declTy: UirCoreType = inferExprTypeWithGlobals(b.env, mod, b.func, rhs, uirCoreTypeI32())
                if declTy.kind == mtVoid:
                    declTy = uirCoreTypeI32()
                var originFile2: str = ""
                if uirCoreFuncIdValid(b.func):
                    let f2: UirCoreFunc = b.func
                    originFile2 = uirCoreFuncOriginFileOf(f2)
                uirCoreAddGlobal(mod, name2, declTy, 0, false, originFile2)
                gName = name2
                gi = moduleGlobalIndex(mod, gName)
            if gi < 0:
                return Err[bool]("uirCore_builder: assignment to unknown local/global")
            let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod, gi)
            let gObj: str = uirCoreGlobalObjTypeGet(gName)
            if len(gObj) > 0:
                let dstPtr: UirExprId = uirCoreLoad(uirCoreGlobalAddr(gName), uirCoreTypeI64())
                if isControlExprId(rhs):
                    let tmpName: str = blockBuilderNextTemp(b, "__global_obj_assign")
                    let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
                    uirCoreSetLocalType(b.func, tmpSlot, uirCoreTypeI64())
                    localSetTypeKey(b.env, tmpSlot, gObj)
                    let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, gObj)
                    if !uirCoreResultBoolIsOk(allocRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(allocRes))
                    let tmpRes: Result[bool] = lowerAssignValue(b, rhs, tmpName, tmpSlot)
                    if !uirCoreResultBoolIsOk(tmpRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(tmpRes))
                    let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, gObj, uirCoreLocal(tmpSlot))
                    if !uirCoreResultBoolIsOk(copyRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes))
                    return Ok[bool](false)
                var rhs0: Node = rhs
                while astNodeIdValid(rhs0) && nodeKind(rhs0) == nkPar && kidCount(rhs0) > 0:
                    rhs0 = kid(rhs0, 0)
                if astNodeIdValid(rhs0) && nodeKind(rhs0) == nkCall:
                    let callRes: Result[UirExprId] = lowerCallWithLeadingArg(b, rhs0, dstPtr)
                    if !IsOk[UirExprId](callRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](callRes))
                    return Ok[bool](false)
                let srcRes: Result[UirExprId] = lowerExprValue(b, rhs, uirCoreTypeI64())
                if !IsOk[UirExprId](srcRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes))
                let copyRes2: Result[bool] = emitObjCopyPtrs(b, dstPtr, gObj, Value[UirExprId](srcRes))
                if !uirCoreResultBoolIsOk(copyRes2):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes2))
                return Ok[bool](false)
            let gKey: str = uirCoreGlobalTypeKeyGet(gName)
            if isControlExprId(rhs):
                let tmpName: str = blockBuilderNextTemp(b, "__global_assign")
                let tmpSlot: int32 = localAdd(b.env, tmpName, g.ty)
                uirCoreSetLocalType(b.func, tmpSlot, g.ty)
                if len(gKey) > 0:
                    localSetTypeKey(b.env, tmpSlot, gKey)
                let tmpRes: Result[bool] = lowerAssignValue(b, rhs, tmpName, tmpSlot)
                if !uirCoreResultBoolIsOk(tmpRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(tmpRes))
                blockBuilderAddStmt(b, uirCoreStmtStore(uirCoreGlobalAddr(gName), uirCoreLocal(tmpSlot), g.ty))
                return Ok[bool](false)
            let rhsCoreGlobal: Node = uirCoreStripParExpr(rhs)
            if astNodeIdValid(rhsCoreGlobal) && nodeKind(rhsCoreGlobal) == nkNilLit && isSemanticStrKey(gKey):
                if !uirCoreSkipSemStdDuplicateRelaxEnabled():
                    return Err[bool]("uirCore_builder: semantic str cannot be assigned nil")
            let valRes: Result[UirExprId] = lowerExprValue(b, rhs, g.ty)
            if ! IsOk[UirExprId](valRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes))
            blockBuilderAddStmt(b, uirCoreStmtStore(uirCoreGlobalAddr(gName), Value[UirExprId](valRes), g.ty))
            return Ok[bool](false)

        # For object-value locals, allow a user-defined `=` overload (compile-time resolved).
        let olIdxAssign: int32 = funcFindObjLocal(b.func, slot2)
        if olIdxAssign >= 0 && b.module != nil && uirCoreFuncIdValid(b.func):
            let frefAssign: UirCoreFunc = b.func
            let dstOlAssign: UirCoreObjLocal = uirCoreFuncObjLocalAt(frefAssign, olIdxAssign)
            if dstOlAssign.frameOff >= 0:
                let aliasTyAssign: UirCoreType = uirCoreTryGetTypeAlias(b.module, dstOlAssign.objTypeName)
                if aliasTyAssign.kind == mtVoid:
                    var argNodesAssign: Node[]
                    argNodesAssign.cap = 2
                    add(argNodesAssign, lhs)
                    add(argNodesAssign, rhs)
                    var candEq: UirCoreFunc = uirCoreResolveCalleeFuncBestEffort(b, "=", argNodesAssign, "")
                    if (candEq != nil):
                        # Assignment overloads must not require an implicit `__ret` and must take `var` as the first arg.
                        if uirCoreFuncParamsLen(candEq) > 0:
                            let pFirst: UirCoreParam = uirCoreFuncParamAt(candEq, 0)
                            if (pFirst.name == "__ret"):
                                candEq = nil
                        if (candEq != nil) && uirCoreFuncParamsLen(candEq) > 0:
                            let p0: UirCoreParam = uirCoreFuncParamAt(candEq, 0)
                            if !uirCoreParamIsVarKey(p0.typeKey):
                                candEq = nil
                        if (candEq != nil) && uirCoreFuncRetTypeOf(candEq).kind == mtVoid:
                            var argsEq: UirExprId[]
                            for aiEq in 0..<argNodesAssign.len:
                                let argNode: Node = argNodesAssign[aiEq]
                                var wantVarAddr: bool = false
                                if (candEq != nil) && aiEq >= 0 && aiEq < uirCoreFuncParamsLen(candEq):
                                    let pEq: UirCoreParam = uirCoreFuncParamAt(candEq, aiEq)
                                    wantVarAddr = uirCoreParamWantsVarAddr(b.module, pEq.typeKey)
                                if wantVarAddr:
                                    let addrRes: Result[UirExprId] = lowerVarArgAddr(b, argNode)
                                    if !IsOk[UirExprId](addrRes):
                                        return ErrInfo[bool](ErrorInfoOf[UirExprId](addrRes))
                                    builderExprSeqAppend(argsEq, Value[UirExprId](addrRes))
                                else:
                                    # Call argument lowering should not depend on the call's return type.
                                    let argRes: Result[UirExprId] = lowerExprValue(b, argNode, uirCoreTypeI64())
                                    if !IsOk[UirExprId](argRes):
                                        return ErrInfo[bool](ErrorInfoOf[UirExprId](argRes))
                                    builderExprSeqAppend(argsEq, Value[UirExprId](argRes))
                            blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall(uirCoreFuncNameOf(candEq), argsEq)))
                            return Ok[bool](false)
        let rhsAssignRes: Result[bool] = lowerAssignValue(b, rhs, name2, slot2)
        if ! uirCoreResultBoolIsOk(rhsAssignRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(rhsAssignRes))
        return Ok[bool](false)
    of nkReturn:
        if dbgPipeStmt:
            let fDbgRetStmt0: os.File = os.get_stderr()
            os.writeLine(fDbgRetStmt0, "[backend] stage1: lower_stmt_return_enter")
            os.c_fflush fDbgRetStmt0
        let fref2: UirCoreFunc = blockBuilderFuncRef(b)
        var retType2: UirCoreType = uirCoreTypeVoid()
        var retName2: str = ""
        var retOrigin2: str = ""
        var dynIdx2: int32 = -1
        var key2: int64 = 0
        if uirCoreFuncIdValid(fref2):
            retType2 = uirCoreFuncRetTypeOf(fref2)
            retName2 = uirCoreFuncNameOf(fref2)
            retOrigin2 = uirCoreFuncOriginFileOf(fref2)
            dynIdx2 = uirCoreFindFuncDynIndex(fref2)
            key2 = uirCoreFuncNameCacheKey(fref2)
        else:
            retType2 = uirCoreFuncRetTypeOfPtrKey((b != nil) ? b.funcShadowPtr : int64(0))
            retName2 = uirCoreFuncNameOfPtrKey((b != nil) ? b.funcShadowPtr : int64(0))
            retOrigin2 = uirCoreFuncOriginFileOfPtrKey((b != nil) ? b.funcShadowPtr : int64(0))
            dynIdx2 = uirCoreFindFuncDynIndexByPtrKey((b != nil) ? b.funcShadowPtr : int64(0))
            key2 = (b != nil) ? b.funcShadowPtr : int64(0)
        if retType2.kind == mtVoid && b != nil && b.env != nil:
            let hiddenScalarSlot: int32 = localIndex(b.env, "__result")
            if hiddenScalarSlot >= 0:
                retType2 = localType(b.env, hiddenScalarSlot)
                if len(retName2) == 0:
                    retName2 = "__result"
            if retType2.kind == mtVoid:
                let hiddenObjSlot: int32 = localIndex(b.env, "__ret")
                if hiddenObjSlot >= 0:
                    let hiddenObjTy: UirCoreType = localType(b.env, hiddenObjSlot)
                    if hiddenObjTy.kind == mtVoid:
                        retType2 = uirCoreTypeI64()
                    else:
                        retType2 = hiddenObjTy
                    if len(retName2) == 0:
                        retName2 = "__ret"
        let dbgRetMismatch: bool = envIsTrue "BACKEND_DEBUG_RET_MISMATCH"
        if dbgRetMismatch && retName2 == "osDebugFileReadKV":
            let hiddenScalarSlotDbg: int32 = (b != nil && b.env != nil) ? localIndex(b.env, "__result") : -1
            let hiddenObjSlotDbg: int32 = (b != nil && b.env != nil) ? localIndex(b.env, "__ret") : -1
            let hiddenObjNameDbg: str = (hiddenObjSlotDbg >= 0) ? funcObjTypeName(fref2, hiddenObjSlotDbg) : ""
            os.writeLine(os.get_stderr(),
                         "[backend] ret_dbg_return fn=" + retName2 +
                         " origin=" + retOrigin2 +
                         " key=" + int64ToStr(key2) +
                         " dyn_idx=" + intToStr(dynIdx2) +
                         " ret_kind=" + intToStr(int32(retType2.kind)) +
                         " result_slot=" + intToStr(hiddenScalarSlotDbg) +
                         " ret_slot=" + intToStr(hiddenObjSlotDbg) +
                         " ret_obj=" + hiddenObjNameDbg)
            os.c_fflush(os.get_stderr())
        var exprNode: Node = astInvalidNodeId()
        if kidCount(stmt) > 0:
            exprNode = kid(stmt, 0)
        if retType2.kind == mtVoid:
            if astNodeIdValid(exprNode) && nodeKind(exprNode) != nkEmpty:
                return Err[bool]("uirCore_builder: void return cannot have a value")
            let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
            if ! uirCoreResultBoolIsOk(deferRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
            blockBuilderFinish(b, uirCoreTermRet(nil))
            return Ok[bool](true)
        if dbgPipeStmt:
            let fDbgRetStmt1: os.File = os.get_stderr()
            os.writeLine(fDbgRetStmt1, "[backend] stage1: lower_stmt_return_after_type")
            os.c_fflush fDbgRetStmt1
        let retSlot3: int32 = localIndex(b.env, "__ret")
        if retSlot3 >= 0:
            let objRetName: str = funcObjTypeName(fref2, retSlot3)
            var objRetKey: str = funcObjTypeKey(fref2, retSlot3)
            if envIsTrue "BACKEND_DEBUG_RETURN_OBJ":
                os.writeLine(os.get_stderr(),
                             "[backend] debugReturnObj: fn=" + retName2 +
                             " ret_slot=" + intToStr(retSlot3) +
                             " ret_obj=" + objRetName +
                             " ret_key=" + objRetKey)
                os.c_fflush(os.get_stderr())
            if b != nil && b.env != nil:
                let slotRetKey: str = localTypeKey(b.env, retSlot3)
                if len(objRetKey) == 0:
                    objRetKey = slotRetKey
                elif !uirCoreStrStartsWith(objRetKey, "seq_") && uirCoreStrStartsWith(slotRetKey, "seq_"):
                    objRetKey = slotRetKey
            if dbgPipeStmt && uirCoreFuncIdValid(fref2):
                let fnDbgRet: str = uirCoreFuncNameOf(fref2)
                if fnDbgRet == "ErrorOk" || fnDbgRet == "ErrorNew" || fnDbgRet == "ErrorCode":
                    os.writeLine(os.get_stderr(),
                                 "[backend] dbg_return_obj fn=" + fnDbgRet +
                                 " ret_slot=" + intToStr(retSlot3) +
                                 " ret_obj=" + objRetName +
                                 " ret_key=" + objRetKey +
                                 " ret_ty=" + uirCoreTypeKindNameLocal(retType2) +
                                 " origin=" + uirCoreFuncOriginFileOf(fref2))
                    os.c_fflush(os.get_stderr())
            if len(objRetName) > 0:
                if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
                    return Err[bool]("uirCore_builder: return expects value")
                var expr0: Node = exprNode
                while astNodeIdValid(expr0) && nodeKind(expr0) == nkPar && kidCount(expr0) > 0:
                    expr0 = kid(expr0, 0)
                if astNodeIdValid(expr0) && (nodeKind(expr0) == nkSeqLit || nodeKind(expr0) == nkComprehension):
                    if !uirCoreStrStartsWith(objRetKey, "seq_") && nodeTypeCacheValid(expr0) && astRefNonNil(nodeTypeCache(expr0)):
                        let exprTypeKey0: str = backendStripSpaces(typeKey(nodeTypeCache(expr0)))
                        if uirCoreStrStartsWith(exprTypeKey0, "seq_"):
                            objRetKey = exprTypeKey0
                    if !uirCoreStrStartsWith(objRetKey, "seq_"):
                        let exprTypeKey1: str = backendStripSpaces(typeKey(expr0))
                        if uirCoreStrStartsWith(exprTypeKey1, "seq_"):
                            objRetKey = exprTypeKey1
                if astNodeIdValid(expr0) && nodeKind(expr0) == nkSeqLit && uirCoreStrStartsWith(objRetKey, "seq_"):
                    let key: str = objRetKey
                    let litRes: Result[bool] = emitSeqLitToPtr(b, uirCoreLocal(retSlot3), key, expr0)
                    if ! uirCoreResultBoolIsOk(litRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(litRes))
                    let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                    if ! uirCoreResultBoolIsOk(deferRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
                    blockBuilderFinish(b, uirCoreTermRet(uirCoreLocal(retSlot3)))
                    return Ok[bool](true)
                if astNodeIdValid(expr0) && nodeKind(expr0) == nkComprehension && uirCoreStrStartsWith(objRetKey, "seq_"):
                    let key2: str = objRetKey
                    let compRes: Result[bool] = emitSeqComprehensionToPtr(b, "__ret", uirCoreLocal(retSlot3), key2, expr0)
                    if !uirCoreResultBoolIsOk(compRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(compRes))
                    let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                    if ! uirCoreResultBoolIsOk(deferRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
                    blockBuilderFinish(b, uirCoreTermRet(uirCoreLocal(retSlot3)))
                    return Ok[bool](true)
                if astNodeIdValid(expr0) && nodeKind(expr0) == nkTupleLit &&
                   (objRetName == "tuple" || uirCoreStrStartsWith(objRetName, "tuple_")):
                    # Tuple literal typeCache may be cleared by earlier stage1 passes.
                    # Store directly into the typed return slot to keep field layout stable.
                    let litRes: Result[bool] = emitTupleLitToPtr(b, uirCoreLocal(retSlot3), objRetName, expr0)
                    if !uirCoreResultBoolIsOk(litRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(litRes))
                    let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                    if !uirCoreResultBoolIsOk(deferRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
                    blockBuilderFinish(b, uirCoreTermRet(uirCoreLocal(retSlot3)))
                    return Ok[bool](true)
                if astNodeIdValid(expr0) && nodeKind(expr0) == nkCall:
                    let callRes: Result[UirExprId] = lowerCallWithLeadingArg(b, expr0, uirCoreLocal(retSlot3))
                    if ! IsOk[UirExprId](callRes):
                        return ErrInfo[bool](ErrorInfoOf[UirExprId](callRes))
                    let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                    if ! uirCoreResultBoolIsOk(deferRes):
                        return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
                    blockBuilderFinish(b, uirCoreTermRet(Value[UirExprId](callRes)))
                    return Ok[bool](true)
                if (expr0 != nil) && (nodeKind(expr0) == nkIdent || nodeKind(expr0) == nkSymbol):
                    let srcName: str = plainName(expr0)
                    let srcSlot: int32 = uirCoreResolveLocalSlotOrImplicitResult(b.env, fref2, srcName)
                    if envIsTrue "BACKEND_DEBUG_RETURN_OBJ":
                        let srcObjDbg: str = (srcSlot >= 0) ? funcObjTypeName(fref2, srcSlot) : ""
                        let srcKeyDbg: str = (srcSlot >= 0) ? funcObjTypeKey(fref2, srcSlot) : ""
                        os.writeLine(os.get_stderr(),
                                     "[backend] debugReturnObj: ident src=" + srcName +
                                     " slot=" + intToStr(srcSlot) +
                                     " src_obj=" + srcObjDbg +
                                     " src_key=" + srcKeyDbg)
                        os.c_fflush(os.get_stderr())
                    if dbgPipeStmt && uirCoreFuncIdValid(fref2):
                        let fnDbgSrc: str = uirCoreFuncNameOf(fref2)
                        if fnDbgSrc == "ErrorOk" || fnDbgSrc == "ErrorNew" || fnDbgSrc == "ErrorCode":
                            let srcObjDbg: str = (srcSlot >= 0) ? funcObjTypeName(fref2, srcSlot) : ""
                            let srcKeyDbg: str = (srcSlot >= 0) ? funcObjTypeKey(fref2, srcSlot) : ""
                            let srcTyDbg: str = (srcSlot >= 0) ? uirCoreTypeKindNameLocal(localType(b.env, srcSlot)) : ""
                            os.writeLine(os.get_stderr(),
                                         "[backend] dbg_return_ident fn=" + fnDbgSrc +
                                         " name=" + srcName +
                                         " slot=" + intToStr(srcSlot) +
                                         " obj=" + srcObjDbg +
                                         " key=" + srcKeyDbg +
                                         " ty=" + srcTyDbg)
                            os.c_fflush(os.get_stderr())
                    if srcSlot >= 0:
                        let copyRes: Result[bool] = emitObjCopy(b, retSlot3, objRetName, srcSlot)
                        if ! uirCoreResultBoolIsOk(copyRes):
                            return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes))
                        let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                        if ! uirCoreResultBoolIsOk(deferRes):
                            return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
                        blockBuilderFinish(b, uirCoreTermRet(uirCoreLocal(retSlot3)))
                        return Ok[bool](true)
                let srcRes: Result[UirExprId] = lowerExprValue(b, expr0, uirCoreTypeI64())
                if ! IsOk[UirExprId](srcRes):
                    return ErrInfo[bool](ErrorInfoOf[UirExprId](srcRes))
                let tmpName: str = blockBuilderNextTemp(b, "__ret_src")
                let tmpSlot: int32 = localAdd(b.env, tmpName, uirCoreTypeI64())
                uirCoreSetLocalType(fref2, tmpSlot, uirCoreTypeI64())
                blockBuilderAddStmt(b, uirCoreStmtLet(tmpName, tmpSlot, Value[UirExprId](srcRes)))
                let copyRes2: Result[bool] = emitObjCopy(b, retSlot3, objRetName, tmpSlot)
                if ! uirCoreResultBoolIsOk(copyRes2):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(copyRes2))
                let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
                if ! uirCoreResultBoolIsOk(deferRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
                blockBuilderFinish(b, uirCoreTermRet(uirCoreLocal(retSlot3)))
                return Ok[bool](true)
        if !astNodeIdValid(exprNode) || nodeKind(exprNode) == nkEmpty:
            return Err[bool]("uirCore_builder: return expects value")
        if isControlExprId(exprNode):
            let retName: str = blockBuilderNextTemp(b, "__ret")
            let slot: int32 = localAdd(b.env, retName, retType2)
            uirCoreSetLocalType(fref2, slot, retType2)
            let assignRes: Result[bool] = lowerAssignValue(b, exprNode, retName, slot)
            if ! uirCoreResultBoolIsOk(assignRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(assignRes))
            let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
            if ! uirCoreResultBoolIsOk(deferRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
            blockBuilderFinish(b, uirCoreTermRet(uirCoreLocal(slot)))
            return Ok[bool](true)
        let retRes: Result[UirExprId] = lowerExprValue(b, exprNode, retType2)
        if ! IsOk[UirExprId](retRes):
            return ErrInfo[bool](ErrorInfoOf[UirExprId](retRes))
        let deferRes: Result[bool] = blockBuilderEmitDefers(b, 0)
        if ! uirCoreResultBoolIsOk(deferRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
        blockBuilderFinish(b, uirCoreTermRet(Value[UirExprId](retRes)))
        return Ok[bool](true)
    of nkIf:
        let ifRes: Result[bool] = lowerIfStmt(b, stmt)
        if ! uirCoreResultBoolIsOk(ifRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(ifRes))
        return ifRes
    of nkWhile:
        let whileRes: Result[bool] = lowerWhileStmt(b, stmt)
        if ! uirCoreResultBoolIsOk(whileRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(whileRes))
        return whileRes
    of nkFor:
        let forRes: Result[bool] = lowerForStmt(b, stmt)
        if ! uirCoreResultBoolIsOk(forRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(forRes))
        return forRes
    of nkCase:
        let caseRes: Result[bool] = lowerCaseStmt(b, stmt)
        if !uirCoreResultBoolIsOk(caseRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(caseRes))
        return caseRes
    of nkBreak:
        let ctx: LoopContext = blockBuilderPeekLoop(b)
        if (ctx == nil):
            return Err[bool]("uirCore_builder: break outside loop")
        let deferRes: Result[bool] = blockBuilderEmitDefers(b, ctx.deferDepth)
        if ! uirCoreResultBoolIsOk(deferRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
        blockBuilderFinish(b, uirCoreTermBr(ctx.breakLabel))
        return Ok[bool](true)
    of nkContinue:
        let ctx2: LoopContext = blockBuilderPeekLoop(b)
        if (ctx2 == nil):
            return Err[bool]("uirCore_builder: continue outside loop")
        let deferRes: Result[bool] = blockBuilderEmitDefers(b, ctx2.deferDepth)
        if ! uirCoreResultBoolIsOk(deferRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(deferRes))
        blockBuilderFinish(b, uirCoreTermBr(ctx2.continueLabel))
        return Ok[bool](true)
    of nkDefer:
        let frame: DeferFrame = blockBuilderPeekDefer(b)
        if (frame == nil):
            return Err[bool]("uirCore_builder: defer outside stmt list")
        if kidCount(stmt) < 1:
            return Err[bool]("uirCore_builder: invalid defer")
        let body: Node = kid(stmt, 0)
        if !astNodeIdValid(body) || nodeKind(body) != nkStmtList:
            return Err[bool]("uirCore_builder: defer expects stmt list body")
        astNodeSeqAppend(frame.bodies, body)
        return Ok[bool](false)
    of nkBlock:
        if kidCount(stmt) < 2:
            return Err[bool]("uirCore_builder: invalid block")
        let body: Node = kid(stmt, 1)
        let blockRes: Result[bool] = lowerStmtList(b, body)
        if ! uirCoreResultBoolIsOk(blockRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(blockRes))
        return blockRes
    else:
        # Expression statements discard the value; lower as pointer-sized.
        let exprRes2: Result[UirExprId] = lowerExprValue(b, stmt, uirCoreTypeI64())
        if ! IsOk[UirExprId](exprRes2):
            return ErrInfo[bool](ErrorInfoOf[UirExprId](exprRes2))
        blockBuilderAddStmt(b, uirCoreStmtExpr(Value[UirExprId](exprRes2)))
        return Ok[bool](false)

fn lowerStmtList(b: BlockBuilder, listNode: Node): Result[bool] =
    if !astNodeIdValid(listNode) || nodeKind(listNode) != nkStmtList:
        return Err[bool]("uirCore_builder: expected stmt list")
    let dbgPipeList: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    if (b != nil) && b.env != nil:
        localEnvPushScope(b.env)
    blockBuilderPushDefer(b)
    for i in 0..<kidCount(listNode):
        let stmt: Node = kid(listNode, i)
        if dbgPipeList:
            let fDbgList0: os.File = os.get_stderr()
            os.writeLine(fDbgList0, "[backend] stage1: lower_stmt_list_item_enter")
            os.c_fflush fDbgList0
        if (getEnv "BACKEND_DEBUG_STMTLIST" == "1") && (b != nil) && uirCoreFuncIdValid(b.func):
            let fStmt0: UirCoreFunc = b.func
            os.writeLine(os.get_stderr(),
                "[backend] debugStmtList: fn=" + uirCoreFuncNameOf(fStmt0) +
                " file=" + uirCoreFuncOriginFileOf(fStmt0) +
                " idx=" + intToStr(i) +
                " kind=nk#" + intToStr(int32(nodeKind(stmt))) +
                " @" + intToStr(nodePosLine(stmt)) + ":" + intToStr(nodePosCol(stmt)))
            os.c_fflush os.get_stderr()
        let termRes: Result[bool] = lowerStmt(b, stmt)
        if dbgPipeList:
            let fDbgList1: os.File = os.get_stderr()
            os.writeLine(fDbgList1, "[backend] stage1: lower_stmt_list_item_exit")
            os.c_fflush fDbgList1
        if ! uirCoreResultBoolIsOk(termRes):
            var fnNameStmt: str = ""
            var fpStmt: str = ""
            if (b != nil) && uirCoreFuncIdValid(b.func):
                let fStmt: UirCoreFunc = b.func
                fnNameStmt = uirCoreFuncNameOf(fStmt)
                fpStmt = uirCoreFuncOriginFileOf(fStmt)
            let idxText: str = intToStr(i)
            let kindText: str = intToStr(int32(nodeKind(stmt)))
            let lineText: str = intToStr(nodePosLine(stmt))
            let colText: str = intToStr(nodePosCol(stmt))
            let errText: str = Error(termRes)
            let fallbackMsgStmt: str =
                "uirCore_builder: stmt lower failed fn=" + fnNameStmt +
                " file=" + fpStmt +
                " idx=" + idxText +
                " kind=nk#" + kindText +
                " @" + lineText + ":" + colText +
                " err=" + errText
            os.writeLine(os.get_stderr(), fallbackMsgStmt)
            os.c_fflush os.get_stderr()
            blockBuilderPopDefer(b)
            if (b != nil) && b.env != nil:
                localEnvPopScope(b.env)
            return Err[bool](fallbackMsgStmt)
        let terminated: bool = uirCoreResultBoolValue(termRes)
        if terminated:
            if dbgPipeList:
                let fDbgList2: os.File = os.get_stderr()
                os.writeLine(fDbgList2, "[backend] stage1: lower_stmt_list_terminated")
                os.c_fflush fDbgList2
            # It's legal (but unreachable) to have trailing statements after a terminator.
            # Stop lowering at the first terminator.
            blockBuilderPopDefer(b)
            if (b != nil) && b.env != nil:
                localEnvPopScope(b.env)
            if dbgPipeList:
                let fDbgList3: os.File = os.get_stderr()
                os.writeLine(fDbgList3, "[backend] stage1: lower_stmt_list_return_true")
                os.c_fflush fDbgList3
            return Ok[bool](true)
    let frame: DeferFrame = blockBuilderPopDefer(b)
    if (frame != nil) && frame.bodies.len > 0:
        var frames: DeferFrame[]
        deferFrameSeqAppend(frames, frame)
        let emitRes: Result[bool] = emitDeferFrames(b, frames)
        if ! uirCoreResultBoolIsOk(emitRes):
            if (b != nil) && b.env != nil:
                localEnvPopScope(b.env)
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(emitRes))
    if (b != nil) && b.env != nil:
        localEnvPopScope(b.env)
    if dbgPipeList:
        let fDbgList4: os.File = os.get_stderr()
        os.writeLine(fDbgList4, "[backend] stage1: lower_stmt_list_return_false")
        os.c_fflush fDbgList4
    return Ok[bool](false)

fn uirCoreNameFromNodeSafe(n: Node): str =
    if (n == nil):
        return ""
    let nid: AstNodeId = n
    if astNodeIdValid(nid):
        let k: NodeKind = astNodeKind(nid)
        if k == nkIdent || k == nkSymbol || k == nkPattern || k == nkDotExpr ||
           k == nkBracketExpr || k == nkPostfix:
            let v: str = backendStripSpaces(astPlainName(nid))
            if len(v) > 0:
                return v
    return backendStripSpaces(plainName(n))

fn uirCoreFuncDeclNameSafe(funcNode: Node): str =
    if (funcNode == nil):
        return ""
    let fid: AstNodeId = funcNode
    if astNodeIdValid(fid):
        let nameId: AstNodeId = astKidAt(fid, 0)
        if astNodeIdValid(nameId):
            let nameKind: NodeKind = astNodeKind(nameId)
            if nameKind == nkIdent || nameKind == nkSymbol:
                let ident0: str = astNodeIdent(nameId)
                let ident1: str = backendStripSpaces(ident0)
                if len(ident1) > 0:
                    return ident1
            let plain0: str = astPlainName(nameId)
            let plain1: str = backendStripSpaces(plain0)
            if len(plain1) > 0:
                return plain1
    let nameNode: Node = kid(funcNode, 0)
    if (nameNode == nil):
        return ""
    return uirCoreNameFromNodeSafe(nameNode)

fn uirCoreFuncNameNodeAccept(nameNode: Node): bool =
    if (nameNode == nil):
        return false
    let k: NodeKind = nodeKind(nameNode)
    return k == nkIdent || k == nkSymbol || k == nkPattern ||
           k == nkDotExpr || k == nkBracketExpr || k == nkPostfix

fn uirCoreBuildFuncHeader(module: UirCoreModule, funcNode: Node, originFile: str = "",
                            overloaded: ptr = nil,
                            funcNameHint: str = ""): Result[UirCoreFunc] =
    let dbgOwnStrStep: bool = envIsTrue "BACKEND_DEBUG_OWNSTR_STEP"
    let dbgRawmemHeader: bool = envIsTrue "BACKEND_DEBUG_RAWMEM_HEADER"
    let dbgDollarOverload: bool = envIsTrue "BACKEND_DEBUG_DOLLAR_OVERLOAD"
    if (funcNode == nil) || (nodeKind(funcNode) != nkFnDecl && nodeKind(funcNode) != nkIteratorDecl):
        return Err[UirCoreFunc]("uirCore_builder: invalid func node")
    let nameNode: Node = kid(funcNode, 0)
    let funcNameRaw: str = (len(funcNameHint) > 0) ? funcNameHint : uirCoreFuncDeclNameSafe(funcNode)
    if len(funcNameRaw) == 0:
        return Err[UirCoreFunc]("uirCore_builder: function name expected")
    if dbgOwnStrStep:
        os.writeLine(os.get_stderr(),
                     "[backend] ownstr_header_enter fn=" + funcNameRaw +
                     " file=" + originFile +
                     " node=" + intToStr(astNodeIndex(funcNode)))
        os.c_fflush(os.get_stderr())
    if dbgOwnStrStep: stage1Trace("backend: ownstr_step func_header funcName")
    let funcName: str = funcNameRaw
    if dbgOwnStrStep: stage1Trace("backend: ownstr_step func_header originFile")
    let originFileStable: str = originFile
    if dbgOwnStrStep: stage1Trace("backend: ownstr_step func_header symName")
    var symName: str = funcName
    if dbgOwnStrStep: stage1Trace("backend: ownstr_step func_header baseSym")
    var baseSym: str = backendSanitizeLinkName(symName)
    let paramsNode: Node = kid(funcNode, 1)
    let retNode: Node = kid(funcNode, 2)
    var retType: UirCoreType = uirCoreTypeVoid()
    if astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty:
        retType = uirCoreTypeFromNodeWithModule(module, retNode)
    var retTypeKey: str = ""
    if astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty:
        retTypeKey = uirCoreTypeKeyForOverload(retNode)
    if dbgOwnStrStep: stage1Trace("backend: ownstr_step func_header retTypeKey")
    var objRetTypeName: str = ""
    if astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty:
        var nm: str = typeNodeObjTypeName(module, retNode)
        let objFromRetKey: str = uirCoreDirectObjValueTypeNameFromKey(module, retTypeKey)
        let retLooseKey: str = uirCoreTypeKeyFromNodeLoose(retNode)
        let objFromLooseKey: str = uirCoreDirectObjValueTypeNameFromKey(module, retLooseKey)
        let retIsObjValue: bool = typeNodeIsObjValue(module, retNode) ||
            len(objFromRetKey) > 0 || len(objFromLooseKey) > 0
        if len(nm) == 0:
            if len(objFromRetKey) > 0:
                nm = objFromRetKey
            elif len(objFromLooseKey) > 0:
                nm = objFromLooseKey
        if len(nm) > 0 && retIsObjValue:
            objRetTypeName = nm
            # Object returns use an implicit `__ret` pointer.
            retType = uirCoreTypeI64()
    var body: Node = kid(funcNode, 3)
    if astNodeIdValid(body) && nodeKind(body) == nkBlock && kidCount(body) > 1:
        let inner: Node = kid(body, 1)
        if astNodeIdValid(inner) && nodeKind(inner) == nkStmtList:
            body = inner
    var hasImportc: bool = false
    var importcLinkName: str = ""
    var hasExportc: bool = false
    var exportcLinkName: str = ""
    uirCoreParseImportcLinkNameId(funcNode, &hasImportc, &importcLinkName)
    uirCoreParseExportcLinkNameId(funcNode, &hasExportc, &exportcLinkName)
    if dbgOwnStrStep: stage1Trace("backend: ownstr_step func_header importcLinkName")
    if hasImportc:
        let sourceLinkName: str = uirCoreImportcLinkNameFromSource(originFileStable, funcName)
        if len(sourceLinkName) > 0:
            importcLinkName = sourceLinkName
        importcLinkName = uirCoreNormalizeImportcLinkName(funcName, importcLinkName)
    if !hasImportc:
        if dbgOwnStrStep: stage1Trace("backend: ownstr_step func_header remangleSym")
        symName = uirCoreMaybeMangleDupFnBase(funcName, originFileStable)
        if dbgOwnStrStep: stage1Trace("backend: ownstr_step func_header remangleBase")
        baseSym = backendSanitizeLinkName(symName)

    var isExtern: bool = false
    if !astNodeIdValid(body) || nodeKind(body) == nkEmpty:
        if (funcName == "main"):
            return Err[UirCoreFunc]("uirCore_builder: main must have a body")
        if !hasImportc:
            # Forward decl (no body, no importc). Ignore; a later definition will provide the body.
            return Ok[UirCoreFunc](nil)
        isExtern = true

    let f: UirCoreFunc = uirCoreNewFunc(symName, retType)
    uirCoreFuncInitHeaderMeta(f, retTypeKey, originFileStable,
                              astNodeDeclOrdinal(funcNode), astNodeIndex(funcNode), isExtern)

    var sigParamKeys: str[]
    var paramBase: int32 = 0
    if len(objRetTypeName) > 0:
        let retSlot: int32 = 0
        let kret: str = (astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty) ? typeKey(retNode) : ""
        funcAddObjLocalKnownNew(f, retSlot, objRetTypeName, -1, kret)
        uirCoreAddParam(f, "__ret", retSlot, uirCoreTypeI64(), "")
        paramBase = 1

    var paramOrdinal: int32 = 0
    if astNodeIdValid(paramsNode) && nodeKind(paramsNode) == nkFormalParams:
        for pi in 0..<kidCount(paramsNode):
            let defs: Node = kid(paramsNode, pi)
            if !astNodeIdValid(defs) || nodeKind(defs) != nkIdentDefs || kidCount(defs) < 2:
                return Err[UirCoreFunc]("uirCore_builder: invalid param")
            let typeNode: Node = identDefsType(defs)
            if !astNodeIdValid(typeNode):
                return Err[UirCoreFunc]("uirCore_builder: param expects type")
            let namesN: int32 = identDefsNameCount(defs)
            if namesN <= 0:
                return Err[UirCoreFunc]("uirCore_builder: param expects identifier")
            let objTypeName: str = typeNodeObjTypeName(module, typeNode)
            var ptype: UirCoreType = uirCoreTypeFromNodeWithModule(module, typeNode)
            if len(objTypeName) > 0:
                # Represent object values as pointers to storage in MIR.
                ptype = uirCoreTypeI64()
            let pk2: str = uirCoreTypeKeyForOverload(typeNode)
            for ni in 0..<namesN:
                let pnameNode: Node = kid(defs, ni)
                if (pnameNode == nil) || (nodeKind(pnameNode) != nkIdent && nodeKind(pnameNode) != nkSymbol):
                    return Err[UirCoreFunc]("uirCore_builder: param expects identifier")
                let pname: str = uirCoreNameFromNodeSafe(pnameNode)
                if dbgOwnStrStep:
                    os.writeLine(os.get_stderr(),
                                 "[backend] ownstr_header_param fn=" + funcName +
                                 " pname=" + pname +
                                 " slot=" + intToStr(paramBase + paramOrdinal) +
                                 " typeKey=" + pk2)
                    os.c_fflush(os.get_stderr())
                let slot: int32 = paramBase + paramOrdinal
                paramOrdinal = paramOrdinal + 1
                builderStrSeqAppend(sigParamKeys, pk2)
                if len(objTypeName) > 0:
                    funcAddObjLocalKnownNew(f, slot, objTypeName, -1, pk2)
                # Default args are lowered by stage1 C-profile lowering (call-site expansion).
                uirCoreAddParam(f, pname, slot, ptype, pk2)
                if dbgRawmemHeader && uirCoreStrStartsWith(funcName, "rawmem"):
                    os.writeLine(os.get_stderr(),
                                 "[backend] rawmem_header fn=" + funcName +
                                 " pname=" + pname +
                                 " slot=" + intToStr(slot) +
                                 " typeKey=" + pk2 +
                                 " obj=" + objTypeName +
                                 " ty=" + uirCoreTypeKindName(ptype))
                    os.c_fflush(os.get_stderr())

    if uirCoreShouldMangleOverloadFn(funcName, overloaded):
        if dbgDollarOverload && funcName == "$" && strContains(originFileStable, "src/std/strings.cheng"):
            os.writeLine(os.get_stderr(),
                "[backend] dollar_header origin=" + originFileStable +
                " ret='" + retTypeKey +
                "' params='" + $sigParamKeys + "'")
            os.c_fflush(os.get_stderr())
        uirCoreFuncSetName(f, uirCoreMangleOverloadName(baseSym, retTypeKey, sigParamKeys))
        if !hasImportc:
            uirCoreFuncSetLinkName(f, uirCoreFuncNameOf(f))
    else:
        uirCoreFuncSetName(f, symName)
        if hasImportc:
            uirCoreFuncSetLinkName(f, importcLinkName)
        else:
            uirCoreFuncSetLinkName(f, baseSym)
    if hasImportc:
        uirCoreFuncSetLinkName(f, importcLinkName)
    elif hasExportc:
        if len(exportcLinkName) > 0:
            uirCoreFuncSetLinkName(f, exportcLinkName)
        uirCoreFuncSetExported(f, true)
    return Ok[UirCoreFunc](f)

fn uirCoreBuildFunc(module: UirCoreModule, funcNode: Node, originFile: str = "",
                overloaded: ptr = nil,
                funcNameHint: str = ""): Result[UirCoreFunc] =
    let dbgPipeFunc: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    let dbgBootFunc: bool = envIsTrue "BACKEND_DEBUG_BOOT"
    let dbgRawmemState: bool = envIsTrue "BACKEND_DEBUG_RAWMEM_STATE"
    let dbgDollarOverload: bool = envIsTrue "BACKEND_DEBUG_DOLLAR_OVERLOAD"
    let dbgRetMismatch: bool = envIsTrue "BACKEND_DEBUG_RET_MISMATCH"
    let dbgRetFuncName: str = os.getEnvDefault("BACKEND_DEBUG_FUNC_RET_NAME", "")
    if (funcNode == nil) || (nodeKind(funcNode) != nkFnDecl && nodeKind(funcNode) != nkIteratorDecl):
        return Err[UirCoreFunc]("uirCore_builder: invalid func node")
    crashTraceSetPhase(cstring("uir.build_func"))
    if crashTraceEnabled():
        crashTraceMark(cstring("uir.func"), astNodeIndex(funcNode), nodePosLine(funcNode), nodePosCol(funcNode), kidCount(funcNode))
    let nameNode: Node = kid(funcNode, 0)
    let funcNameRaw: str = (len(funcNameHint) > 0) ? funcNameHint : uirCoreFuncDeclNameSafe(funcNode)
    if len(funcNameRaw) == 0:
        return Err[UirCoreFunc]("uirCore_builder: function name expected")
    let funcName: str = funcNameRaw
    if dbgPipeFunc:
        let fDbgFunc0: os.File = os.get_stderr()
        os.writeLine(fDbgFunc0, "[backend] stage1: build_func_enter")
        os.c_fflush fDbgFunc0
    let originFileStable: str = originFile
    var symName: str = funcName
    var baseSym: str = backendSanitizeLinkName(symName)
    let paramsNode: Node = kid(funcNode, 1)
    let retNode: Node = kid(funcNode, 2)
    var retType: UirCoreType = uirCoreTypeVoid()
    if astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty:
        retType = uirCoreTypeFromNodeWithModule(module, retNode)
    var retTypeKey: str = ""
    if astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty:
        retTypeKey = uirCoreTypeKeyForOverload(retNode)
    var objRetTypeName: str = ""
    if astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty:
        var nm: str = typeNodeObjTypeName(module, retNode)
        let objFromRetKey: str = uirCoreDirectObjValueTypeNameFromKey(module, retTypeKey)
        let retLooseKey: str = uirCoreTypeKeyFromNodeLoose(retNode)
        let objFromLooseKey: str = uirCoreDirectObjValueTypeNameFromKey(module, retLooseKey)
        let retIsObjValue: bool = typeNodeIsObjValue(module, retNode) ||
            len(objFromRetKey) > 0 || len(objFromLooseKey) > 0
        if len(nm) == 0:
            if len(objFromRetKey) > 0:
                nm = objFromRetKey
            elif len(objFromLooseKey) > 0:
                nm = objFromLooseKey
        if len(nm) > 0 && len(retTypeKey) > 0:
            # Type keys may include module prefixes (e.g. `json_JsonNode`) that differ from the
            # canonical object type name (`JsonNode`). Preserve var/ref/ptr wrappers for overloads.
            let aliasKey: str = uirCoreTypeKeyStripIterWrappers(retTypeKey)
            if len(aliasKey) > 0 && !(aliasKey == nm):
                if !uirCoreStrStartsWith(aliasKey, "seq_") && !uirCoreStrStartsWith(aliasKey, "seq_fixed_") &&
                   !uirCoreStrStartsWith(aliasKey, "Table_") && !uirCoreStrStartsWith(aliasKey, "set_"):
                    uirCoreObjAliasPut(aliasKey, nm)
        if len(nm) > 0 && retIsObjValue:
            objRetTypeName = nm
            # Object returns use an implicit `__ret` pointer.
            retType = uirCoreTypeI64()
    if len(dbgRetFuncName) > 0 && funcName == dbgRetFuncName:
        let retNodeKindDbg: str = astNodeIdValid(retNode) ? ("nk#" + intToStr(int32(nodeKind(retNode)))) : "nil"
        let retNodeKeyDbg: str = astNodeIdValid(retNode) ? backendStripSpaces(typeKey(retNode)) : ""
        let retNodeLooseDbg: str = astNodeIdValid(retNode) ? uirCoreTypeKeyFromNodeLoose(retNode) : ""
        let retNodeObjDbg: str = astNodeIdValid(retNode) ? typeNodeObjTypeName(module, retNode) : ""
        let retNodeIsObjDbg: bool = astNodeIdValid(retNode) ? typeNodeIsObjValue(module, retNode) : false
        os.writeLine(os.get_stderr(),
                     "[backend] debugFuncRet: fn=" + funcName +
                     " retNodeKind=" + retNodeKindDbg +
                     " retTypeKind=" + intToStr(int32(retType.kind)) +
                     " retTypeKey=" + retTypeKey +
                     " nodeKey=" + retNodeKeyDbg +
                     " nodeLoose=" + retNodeLooseDbg +
                     " nodeObj=" + retNodeObjDbg +
                     " nodeIsObj=" + (retNodeIsObjDbg ? "1" : "0") +
                     " objRetTypeName=" + objRetTypeName)
        os.c_fflush(os.get_stderr())
    if dbgRetMismatch && funcName == "osDebugFileReadKV":
        let retNodeKindDbg: int32 = astNodeIdValid(retNode) ? int32(nodeKind(retNode)) : int32(nkEmpty)
        os.writeLine(os.get_stderr(),
                     "[backend] ret_dbg_build fn=" + funcName +
                     " file=" + originFileStable +
                     " ret_kind=" + intToStr(int32(retType.kind)) +
                     " ret_key=" + retTypeKey +
                     " obj_ret=" + objRetTypeName +
                     " ret_node_kind=nk#" + intToStr(retNodeKindDbg))
        os.c_fflush(os.get_stderr())
    var body: Node = kid(funcNode, 3)
    if astNodeIdValid(body) && nodeKind(body) == nkBlock && kidCount(body) > 1:
        let inner: Node = kid(body, 1)
        if astNodeIdValid(inner) && nodeKind(inner) == nkStmtList:
            body = inner
    var hasImportc: bool = false
    var importcLinkName: str = ""
    var hasExportc: bool = false
    var exportcLinkName: str = ""
    uirCoreParseImportcLinkNameId(funcNode, &hasImportc, &importcLinkName)
    uirCoreParseExportcLinkNameId(funcNode, &hasExportc, &exportcLinkName)
    if hasImportc:
        let sourceLinkName: str = uirCoreImportcLinkNameFromSource(originFileStable, funcName)
        if len(sourceLinkName) > 0:
            importcLinkName = sourceLinkName
        importcLinkName = uirCoreNormalizeImportcLinkName(funcName, importcLinkName)
    if !hasImportc:
        symName = uirCoreMaybeMangleDupFnBase(funcName, originFileStable)
        baseSym = backendSanitizeLinkName(symName)
    if !astNodeIdValid(body) || nodeKind(body) == nkEmpty:
        if (funcName == "main"):
            return Err[UirCoreFunc]("uirCore_builder: main must have a body")
        if !hasImportc:
            # Forward decl (no body, no importc). Ignore; a later definition will provide the body.
            return Ok[UirCoreFunc](nil)
        let envExtern: LocalEnv = localEnvNew()
        let fExtern: UirCoreFunc = uirCoreNewFunc(symName, retType)
        uirCoreFuncInitHeaderMeta(fExtern, retTypeKey, originFileStable,
                                  astNodeDeclOrdinal(funcNode), astNodeIndex(funcNode), true)
        var sigParamKeys: str[]
        if len(objRetTypeName) > 0:
            let retSlotExtern: int32 = localAdd(envExtern, "__ret", uirCoreTypeI64())
            let kretExtern: str = (astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty) ? uirCoreTypeKeyForOverload(retNode) : ""
            funcAddObjLocalKnownNew(fExtern, retSlotExtern, objRetTypeName, -1, kretExtern)
            if len(kretExtern) > 0:
                localSetTypeKey(envExtern, retSlotExtern, kretExtern)
            uirCoreAddParam(fExtern, "__ret", retSlotExtern, uirCoreTypeI64(), "")
        if astNodeIdValid(paramsNode) && nodeKind(paramsNode) == nkFormalParams:
            for pi in 0..<kidCount(paramsNode):
                let defs: Node = kid(paramsNode, pi)
                if !astNodeIdValid(defs) || nodeKind(defs) != nkIdentDefs || kidCount(defs) < 2:
                    return Err[UirCoreFunc]("uirCore_builder: invalid param")
                let typeNode: Node = identDefsType(defs)
                if !astNodeIdValid(typeNode):
                    return Err[UirCoreFunc]("uirCore_builder: param expects type")
                let namesN: int32 = identDefsNameCount(defs)
                if namesN <= 0:
                    return Err[UirCoreFunc]("uirCore_builder: param expects identifier")
                let ptype: UirCoreType = uirCoreTypeFromNodeWithModule(module, typeNode)
                let pk: str = uirCoreTypeKeyForOverload(typeNode)
                for ni in 0..<namesN:
                    let pnameNode: Node = kid(defs, ni)
                    if (pnameNode == nil) ||(nodeKind(pnameNode) != nkIdent && nodeKind(pnameNode) != nkSymbol):
                        return Err[UirCoreFunc]("uirCore_builder: param expects identifier")
                    let pname: str = uirCoreNameFromNodeSafe(pnameNode)
                    let slot: int32 = localAdd(envExtern, pname, ptype)
                    builderStrSeqAppend(sigParamKeys, pk)
                    if len(pk) > 0:
                        localSetTypeKey(envExtern, slot, pk)
                    # Default args are lowered by stage1 C-profile lowering (call-site expansion).
                    uirCoreAddParam(fExtern, pname, slot, ptype, pk)
        if uirCoreShouldMangleOverloadFn(funcName, overloaded):
            if dbgDollarOverload && funcName == "$" && strContains(originFileStable, "src/std/strings.cheng"):
                os.writeLine(os.get_stderr(),
                    "[backend] dollar_extern origin=" + originFileStable +
                    " ret='" + retTypeKey +
                    "' params='" + $sigParamKeys + "'")
                os.c_fflush(os.get_stderr())
            uirCoreFuncSetName(fExtern, uirCoreMangleOverloadName(baseSym, retTypeKey, sigParamKeys))
            if !hasImportc:
                uirCoreFuncSetLinkName(fExtern, uirCoreFuncNameOf(fExtern))
        else:
            uirCoreFuncSetName(fExtern, symName)
            if hasImportc:
                uirCoreFuncSetLinkName(fExtern, importcLinkName)
            else:
                uirCoreFuncSetLinkName(fExtern, baseSym)
        if hasImportc:
            uirCoreFuncSetLinkName(fExtern, importcLinkName)
        elif hasExportc:
            if len(exportcLinkName) > 0:
                uirCoreFuncSetLinkName(fExtern, exportcLinkName)
            uirCoreFuncSetExported(fExtern, true)
        return Ok[UirCoreFunc](fExtern)
    if astNodeIdValid(body) && nodeKind(body) != nkStmtList:
        let wrapped: Node = newNode(nkStmtList, nodePos(body))
        addSon(wrapped, body)
        body = wrapped
    let env: LocalEnv = localEnvNew()
    let f: UirCoreFunc = uirCoreNewFunc(symName, retType)
    if dbgBootFunc && funcName == "main":
        uirCoreDebugBuildMainState("new", f)
    uirCoreFuncInitHeaderMeta(f, retTypeKey, originFileStable,
                              astNodeDeclOrdinal(funcNode), astNodeIndex(funcNode), false)
    if dbgBootFunc && funcName == "main":
        uirCoreDebugBuildMainState("after_retkey", f)
    if dbgBootFunc && funcName == "main":
        uirCoreDebugBuildMainState("after_origin", f)
        uirCoreDebugBuildMainState("after_decl", f)
        uirCoreDebugBuildMainState("after_ast", f)
    if dbgPipeFunc:
        let fDbgFunc1: os.File = os.get_stderr()
        os.writeLine(fDbgFunc1, "[backend] stage1: build_func_before_bb")
        os.c_fflush fDbgFunc1
    let bb: BlockBuilder = blockBuilderNew(env, module, f)
    if dbgRetMismatch && funcName == "osDebugFileReadKV":
        os.writeLine(os.get_stderr(),
                     "[backend] ret_dbg_bb fn=" + funcName +
                     " ptr=" + int64ToStr(uirCoreFuncPtrKey(f)) +
                     " dyn_key=" + int64ToStr(uirCoreFuncNameCacheKey(f)) +
                     " ret_kind=" + intToStr(int32(uirCoreFuncRetTypeOf(f).kind)) +
                     " ret_key=" + uirCoreFuncRetTypeKeyOf(f))
        os.c_fflush(os.get_stderr())
    if dbgPipeFunc:
        let fDbgFunc2: os.File = os.get_stderr()
        os.writeLine(fDbgFunc2, "[backend] stage1: build_func_after_bb")
        os.c_fflush fDbgFunc2
    var sigParamKeys2: str[]
    var paramBase: int32 = 0
    var hiddenResultSlot: int32 = -1
    if len(objRetTypeName) > 0:
        let retSlot: int32 = localAdd(env, "__ret", uirCoreTypeI64())
        hiddenResultSlot = retSlot
        let kret: str = (astNodeIdValid(retNode) && nodeKind(retNode) != nkEmpty) ? uirCoreTypeKeyForOverload(retNode) : ""
        funcAddObjLocalKnownNew(f, retSlot, objRetTypeName, -1, kret)
        if len(kret) > 0:
            localSetTypeKey(env, retSlot, kret)
        uirCoreAddParam(f, "__ret", retSlot, uirCoreTypeI64(), "")
        blockBuilderAddStmt(bb, uirCoreStmtParam("__ret", retSlot, 0))
        paramBase = 1
    var paramOrdinal2: int32 = 0
    if astNodeIdValid(paramsNode) && nodeKind(paramsNode) == nkFormalParams:
        for pi in 0..<kidCount(paramsNode):
            let defs: Node = kid(paramsNode, pi)
            if !astNodeIdValid(defs) || nodeKind(defs) != nkIdentDefs || kidCount(defs) < 2:
                return Err[UirCoreFunc]("uirCore_builder: invalid param")
            let typeNode: Node = identDefsType(defs)
            if !astNodeIdValid(typeNode):
                return Err[UirCoreFunc]("uirCore_builder: param expects type")
            let namesN: int32 = identDefsNameCount(defs)
            if namesN <= 0:
                return Err[UirCoreFunc]("uirCore_builder: param expects identifier")
            let objTypeName: str = typeNodeObjTypeName(module, typeNode)
            var ptype: UirCoreType = uirCoreTypeFromNodeWithModule(module, typeNode)
            if len(objTypeName) > 0:
                # Represent object values as pointers to storage in MIR.
                ptype = uirCoreTypeI64()
            let pk2: str = uirCoreTypeKeyForOverload(typeNode)
            for ni in 0..<namesN:
                let pnameNode: Node = kid(defs, ni)
                if (pnameNode == nil) ||(nodeKind(pnameNode) != nkIdent && nodeKind(pnameNode) != nkSymbol):
                    return Err[UirCoreFunc]("uirCore_builder: param expects identifier")
                let pname: str = uirCoreNameFromNodeSafe(pnameNode)
                let slot: int32 = localAdd(env, pname, ptype)
                builderStrSeqAppend(sigParamKeys2, pk2)
                if len(pk2) > 0:
                    localSetTypeKey(env, slot, pk2)
                if len(objTypeName) > 0:
                    if len(pk2) > 0:
                        let aliasKey2: str = uirCoreTypeKeyStripIterWrappers(pk2)
                        if len(aliasKey2) > 0 && !(aliasKey2 == objTypeName):
                            if !uirCoreStrStartsWith(aliasKey2, "seq_") && !uirCoreStrStartsWith(aliasKey2, "seq_fixed_") &&
                               !uirCoreStrStartsWith(aliasKey2, "Table_") && !uirCoreStrStartsWith(aliasKey2, "set_"):
                                uirCoreObjAliasPut(aliasKey2, objTypeName)
                    funcAddObjLocalKnownNew(f, slot, objTypeName, -1, pk2)
                # Default args are lowered by stage1 C-profile lowering (call-site expansion).
                uirCoreAddParam(f, pname, slot, ptype, pk2)
                blockBuilderAddStmt(bb, uirCoreStmtParam(pname, slot, paramBase + paramOrdinal2))
                paramOrdinal2 = paramOrdinal2 + 1

    if retType.kind != mtVoid:
        if dbgPipeFunc:
            let fDbgRet0: os.File = os.get_stderr()
            os.writeLine(fDbgRet0, "[backend] stage1: build_func_ret_init_enter")
            os.c_fflush fDbgRet0
        if len(objRetTypeName) > 0:
            let initRetRes: Result[bool] = emitObjDefaultInitPtrs(bb, uirCoreLocal(hiddenResultSlot), objRetTypeName)
            if !uirCoreResultBoolIsOk(initRetRes):
                return ErrInfo[UirCoreFunc](uirCoreResultBoolErrorInfo(initRetRes))
        elif hiddenResultSlot < 0:
            if dbgPipeFunc:
                let fDbgRet1: os.File = os.get_stderr()
                os.writeLine(fDbgRet1, "[backend] stage1: build_func_ret_slot_pre")
                os.c_fflush fDbgRet1
            hiddenResultSlot = localAdd(env, "__result", retType)
            if dbgPipeFunc:
                let fDbgRet2: os.File = os.get_stderr()
                os.writeLine(fDbgRet2, "[backend] stage1: build_func_ret_slot_post")
                os.c_fflush fDbgRet2
            uirCoreSetLocalType(f, hiddenResultSlot, retType)
            if dbgPipeFunc:
                let fDbgRet3: os.File = os.get_stderr()
                os.writeLine(fDbgRet3, "[backend] stage1: build_func_ret_type_post")
                os.c_fflush fDbgRet3
            if len(retTypeKey) > 0:
                localSetTypeKey(env, hiddenResultSlot, retTypeKey)
                if dbgPipeFunc:
                    let fDbgRet4: os.File = os.get_stderr()
                    os.writeLine(fDbgRet4, "[backend] stage1: build_func_ret_typekey_post")
                    os.c_fflush fDbgRet4
            if isSemanticStrKey(retTypeKey):
                let label0: str = uirCoreAddCString(module, "")
                blockBuilderAddStmt(bb, uirCoreStmtVar("__result", hiddenResultSlot, uirCoreGlobalAddr(label0)))
            else:
                if dbgPipeFunc:
                    let fDbgRet5: os.File = os.get_stderr()
                    os.writeLine(fDbgRet5, "[backend] stage1: build_func_ret_stmt_pre")
                    os.c_fflush fDbgRet5
                blockBuilderAddStmt(bb, uirCoreStmtVar("__result", hiddenResultSlot, uirCoreConstI64(0)))
                if dbgPipeFunc:
                    let fDbgRet6: os.File = os.get_stderr()
                    os.writeLine(fDbgRet6, "[backend] stage1: build_func_ret_stmt_post")
                    os.c_fflush fDbgRet6
    if dbgRetMismatch && funcName == "osDebugFileReadKV":
        let resultSlotDbg: int32 = localIndex(env, "__result")
        let retSlotDbg: int32 = localIndex(env, "__ret")
        let retObjDbg: str = (retSlotDbg >= 0) ? funcObjTypeName(f, retSlotDbg) : ""
        os.writeLine(os.get_stderr(),
                     "[backend] ret_dbg_slots fn=" + funcName +
                     " result_slot=" + intToStr(resultSlotDbg) +
                     " ret_slot=" + intToStr(retSlotDbg) +
                     " ret_obj=" + retObjDbg +
                     " hidden_slot=" + intToStr(hiddenResultSlot))
        os.c_fflush(os.get_stderr())
        if dbgPipeFunc:
            let fDbgRet7: os.File = os.get_stderr()
            os.writeLine(fDbgRet7, "[backend] stage1: build_func_ret_init_done")
            os.c_fflush fDbgRet7

    if dbgPipeFunc:
        let fDbgName0: os.File = os.get_stderr()
        os.writeLine(fDbgName0, "[backend] stage1: build_func_name_pre")
        os.c_fflush fDbgName0
    if uirCoreShouldMangleOverloadFn(funcName, overloaded):
        if dbgDollarOverload && funcName == "$" && strContains(originFileStable, "src/std/strings.cheng"):
            os.writeLine(os.get_stderr(),
                "[backend] dollar_build origin=" + originFileStable +
                " ret='" + retTypeKey +
                "' params='" + $sigParamKeys2 + "'")
            os.c_fflush(os.get_stderr())
        uirCoreFuncSetName(f, uirCoreMangleOverloadName(baseSym, retTypeKey, sigParamKeys2))
        if !hasImportc:
            uirCoreFuncSetLinkName(f, uirCoreFuncNameOf(f))
    else:
        uirCoreFuncSetName(f, symName)
        if hasImportc:
            uirCoreFuncSetLinkName(f, importcLinkName)
        else:
            uirCoreFuncSetLinkName(f, baseSym)
    if hasImportc:
        uirCoreFuncSetLinkName(f, importcLinkName)
    elif hasExportc:
        if len(exportcLinkName) > 0:
            uirCoreFuncSetLinkName(f, exportcLinkName)
        uirCoreFuncSetExported(f, true)
    if dbgPipeFunc:
        let fDbgName1: os.File = os.get_stderr()
        os.writeLine(fDbgName1, "[backend] stage1: build_func_name_post")
        os.c_fflush fDbgName1
    if dbgRawmemState && uirCoreStrStartsWith(funcName, "rawmem"):
        os.writeLine(os.get_stderr(),
                     "[backend] rawmem_state fn=" + funcName +
                     " dyn_idx=" + intToStr(uirCoreFindFuncDynIndex(f)) +
                     " key=" + int64ToStr(uirCoreFuncNameCacheKey(f)) +
                     " ret_kind=" + intToStr(int32(uirCoreFuncRetTypeOf(f).kind)) +
                     " ret_key=" + uirCoreFuncRetTypeKeyOf(f))
        os.c_fflush(os.get_stderr())

    # Multi-statement function body can implicitly return its last expression.
    if astNodeIdValid(body) && nodeKind(body) == nkStmtList && kidCount(body) > 1 && retType.kind != mtVoid:
        let lastIdx: int32 = kidCount(body) - 1
        let lastStmt: Node = kid(body, lastIdx)
        if isImplicitReturnExprId(lastStmt):
            let body2: Node = newNode(nkStmtList, nodePos(body))
            for si in 0..<lastIdx:
                addSon(body2, kid(body, si))
            let retStmt2: Node = newNode(nkReturn, nodePos(lastStmt))
            addSon(retStmt2, lastStmt)
            addSon(body2, retStmt2)
            body = body2

    # Single-expression function body can implicitly return its value.
    if astNodeIdValid(body) && nodeKind(body) == nkStmtList && kidCount(body) == 1 && retType.kind != mtVoid:
        let onlyStmt: Node = kid(body, 0)
        if isImplicitReturnExprId(onlyStmt):
            var retStmt: Node = newNode(nkReturn, nodePos(onlyStmt))
            addSon(retStmt, onlyStmt)
            let termRes: Result[bool] = lowerStmt(bb, retStmt)
            if ! uirCoreResultBoolIsOk(termRes):
                let fallbackMsg0: str = "uirCore_builder: implicit return lower failed"
                os.writeLine(os.get_stderr(), fallbackMsg0)
                os.c_fflush os.get_stderr()
                return Err[UirCoreFunc](fallbackMsg0)
            if ! uirCoreResultBoolValue(termRes):
                return Err[UirCoreFunc]("uirCore_builder: implicit return did not terminate")
            # Built bodies must not depend on later read-side extern healing.
            uirCoreFuncSetExtern(f, false)
            return Ok[UirCoreFunc](f)

    if dbgPipeFunc:
        let fDbgFunc3: os.File = os.get_stderr()
        os.write(fDbgFunc3, "[backend] stage1: build_func_before_body_lower fn=")
        os.writeLine(fDbgFunc3, funcName)
        os.c_fflush fDbgFunc3
    let bodyRes: Result[bool] = lowerStmtList(bb, body)
    if dbgPipeFunc:
        let fDbgFunc35: os.File = os.get_stderr()
        os.write(fDbgFunc35, "[backend] stage1: build_func_after_body_call fn=")
        os.writeLine(fDbgFunc35, funcName)
        os.c_fflush fDbgFunc35
    if dbgPipeFunc:
        let fDbgFunc355: os.File = os.get_stderr()
        os.writeLine(fDbgFunc355, "[backend] stage1: build_func_bodyres_ok_check_enter")
        os.c_fflush fDbgFunc355
    let bodyOk: bool = uirCoreResultBoolIsOk(bodyRes)
    if dbgPipeFunc:
        let fDbgFunc356: os.File = os.get_stderr()
        os.writeLine(fDbgFunc356, "[backend] stage1: build_func_bodyres_ok_check_exit")
        os.c_fflush fDbgFunc356
    if ! bodyOk:
        return ErrInfo[UirCoreFunc](uirCoreResultBoolErrorInfo(bodyRes))
    if dbgPipeFunc:
        let fDbgFunc357: os.File = os.get_stderr()
        os.writeLine(fDbgFunc357, "[backend] stage1: build_func_bodyres_value_enter")
        os.c_fflush fDbgFunc357
    let terminated: bool = uirCoreResultBoolValue(bodyRes)
    if dbgPipeFunc:
        let fDbgFunc358: os.File = os.get_stderr()
        os.writeLine(fDbgFunc358, "[backend] stage1: build_func_bodyres_value_exit")
        os.c_fflush fDbgFunc358
    if dbgPipeFunc:
        let fDbgFunc4: os.File = os.get_stderr()
        os.write(fDbgFunc4, "[backend] stage1: build_func_after_body_lower fn=")
        os.writeLine(fDbgFunc4, funcName)
        os.c_fflush fDbgFunc4
    if ! terminated && retType.kind == mtVoid:
        blockBuilderFinish(bb, uirCoreTermRet(nil))
        # Built bodies must not depend on later read-side extern healing.
        uirCoreFuncSetExtern(f, false)
        return Ok[UirCoreFunc](f)
    if ! terminated:
        if bb.implicitResultUsed && hiddenResultSlot >= 0:
            let deferRes: Result[bool] = blockBuilderEmitDefers(bb, 0)
            if !uirCoreResultBoolIsOk(deferRes):
                return ErrInfo[UirCoreFunc](uirCoreResultBoolErrorInfo(deferRes))
            blockBuilderFinish(bb, uirCoreTermRet(uirCoreLocal(hiddenResultSlot)))
            # Built bodies must not depend on later read-side extern healing.
            uirCoreFuncSetExtern(f, false)
            return Ok[UirCoreFunc](f)
        let line: str = intToStr(nodePosLine(nameNode))
        let col: str = intToStr(nodePosCol(nameNode))
        return Err[UirCoreFunc](uirCoreMissingReturnMsg(funcName, originFileStable, line, col))
    if dbgBootFunc && funcName == "main":
        let externDbgMainDone: bool = uirCoreFuncIsExtern(f)
        echo("[backend] dbg_build_main.done dyn_id=" + intToStr(uirCoreFuncDynId(f)) +
             " obj_extern=" + (externDbgMainDone ? "1" : "0") +
             " dyn_extern=" + (externDbgMainDone ? "1" : "0") +
             " blocks=" + intToStr(uirCoreFuncBlocksLen(f)) +
             " name=" + uirCoreFuncNameOf(f) +
             " link=" + uirCoreFuncLinkNameOf(f))
    # Built bodies must not depend on later read-side extern healing.
    uirCoreFuncSetExtern(f, false)
    return Ok[UirCoreFunc](f)

fn uirCoreBuildFuncHeaderId(module: UirCoreModule, funcNodeId: AstNodeId, originFile: str = "",
                            overloaded: ptr = nil,
                            funcNameHint: str = ""): Result[UirCoreFunc] =
    return uirCoreBuildFuncHeader(module, funcNodeId, originFile, overloaded, funcNameHint)

fn uirCoreBuildFuncId(module: UirCoreModule, funcNodeId: AstNodeId, originFile: str = "",
                      overloaded: ptr = nil,
                      funcNameHint: str = ""): Result[UirCoreFunc] =
    return uirCoreBuildFunc(module, funcNodeId, originFile, overloaded, funcNameHint)

fn uirCoreFindMainId(rootId: AstNodeId): AstNodeId =
    if !astNodeIdValid(rootId):
        return astInvalidNodeId()
    for i in 0..<astKidCount(rootId):
        let nId: AstNodeId = astKidAt(rootId, i)
        if !astNodeIdValid(nId):
            continue
        if astNodeKind(nId) != nkFnDecl:
            continue
        let nameNodeId: AstNodeId = astKidAt(nId, 0)
        if astNodeIdValid(nameNodeId) && astPlainName(nameNodeId) == "main":
            return nId
    return astInvalidNodeId()

fn uirCoreFindMain(root: Node): Node =
    return uirCoreFindMainId(root)

fn uirCoreUnresolvedCallTargetMsg(baseName0: str, fnName0: str, fp0: str, line0: str, col0: str): str =
    # Keep this error-path message constant under stage0/selfhost.
    # Earlier bootstrap builds lowered the richer formatter back into a long
    # concat chain, which can recurse/overflow before surfacing the real miss.
    return "uirCore_builder: unresolved call target"

fn uirCoreMissingReturnMsg(funcName0: str, fp0: str, line0: str, col0: str): str =
    let prefix0: str = "uirCore_builder: missing return: "
    let partLoc0: str = " "
    let partColon0: str = ":"
    let total0: int32 = len(prefix0) + len(funcName0) + len(partLoc0) + len(fp0) +
        len(partColon0) + len(line0) + len(partColon0) + len(col0)
    let msg0: str = newStringAlloc(total0)
    let msgPtr0: ptr = rawmemAsVoid(msg0)
    if msgPtr0 == nil:
        return "uirCore_builder: missing return"
    var idx0: int32 = 0
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(msgPtr0, idx0), rawmemAsVoid(prefix0), len(prefix0))
    idx0 = idx0 + len(prefix0)
    if len(funcName0) > 0:
        rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(msgPtr0, idx0), rawmemAsVoid(funcName0), len(funcName0))
        idx0 = idx0 + len(funcName0)
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(msgPtr0, idx0), rawmemAsVoid(partLoc0), len(partLoc0))
    idx0 = idx0 + len(partLoc0)
    if len(fp0) > 0:
        rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(msgPtr0, idx0), rawmemAsVoid(fp0), len(fp0))
        idx0 = idx0 + len(fp0)
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(msgPtr0, idx0), rawmemAsVoid(partColon0), len(partColon0))
    idx0 = idx0 + len(partColon0)
    if len(line0) > 0:
        rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(msgPtr0, idx0), rawmemAsVoid(line0), len(line0))
        idx0 = idx0 + len(line0)
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(msgPtr0, idx0), rawmemAsVoid(partColon0), len(partColon0))
    idx0 = idx0 + len(partColon0)
    if len(col0) > 0:
        rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(msgPtr0, idx0), rawmemAsVoid(col0), len(col0))
    return msg0

fn ctxAddGlobalInit(ctx: UirCoreBuildCtx, name: str, ty: UirCoreType, objTypeName: str, initNode: Node, filePath: str,
                    seqFixedElemType: Node = astInvalidNodeId(), seqFixedCapExpr: Node = astInvalidNodeId()) =
    if (ctx == nil) || len(name) == 0:
        return
    ctxAppendGlobalInitStr(&ctx.globalInitNames, uirCoreOwnStr(name))
    ctxAppendGlobalInitType(&ctx.globalInitTypes, ty)
    ctxAppendGlobalInitStr(&ctx.globalInitObjTypeNames, uirCoreOwnStr(objTypeName))
    ctxAppendGlobalInitNode(&ctx.globalInitNodes, initNode)
    ctxAppendGlobalInitStr(&ctx.globalInitFilePaths, uirCoreOwnStr(filePath))
    ctxAppendGlobalInitNode(&ctx.globalInitSeqFixedElemTypes, seqFixedElemType)
    ctxAppendGlobalInitNode(&ctx.globalInitSeqFixedCapExprs, seqFixedCapExpr)

fn uirCoreParseModuleWithLoweredTypesId(filePath: str, content: str, outRootId: var AstNodeId): bool =
    # AST node ids are arena-local and reused after `releaseNodeArena()`.
    # Clear node-id keyed caches before every reparse so routine/type identity
    # does not leak across files and break predeclare matching.
    uirCoreTopLevelRoutineNameCacheReset()
    uirCoreTypeNodeObjNameCacheReset()
    let tokens: Token[] = lexTokens(content, filePath)
    let parsedRoot0: AstNodeId = parseModuleId(tokens, filePath)
    let parsedRoot1: AstNodeId = uirCoreApplyAstPluginHooksId(filePath, parsedRoot0)
    if !astNodeIdValid(parsedRoot1):
        return false
    let root: AstNodeId = uirCoreApplyMirPluginHooksId(filePath, parsedRoot1)
    if !astNodeIdValid(root):
        return false
    var diags: Diagnostic[]
    diags.buffer = nil
    diags.len = 0
    diags.cap = 16
    type_syntax_lowering.lowerTypeSyntaxId(root, &diags, filePath)
    if hasError diags:
        printDiagnostics diags
        return false
    outRootId = root
    return true

fn uirCoreParseModuleWithLoweredTypes(filePath: str, content: str, outRoot: var Node): bool =
    var rootId: AstNodeId = astInvalidNodeId()
    if !uirCoreParseModuleWithLoweredTypesId(filePath, content, rootId):
        return false
    outRoot = rootId
    return true

fn uirCoreFnTaskNodeMatches(task: UirFnTask, nId: AstNodeId): bool =
    if task == nil || !astNodeIdValid(nId):
        return false
    let nKind: NodeKind = astNodeKind(nId)
    if nKind != nkFnDecl && nKind != nkIteratorDecl:
        return false
    let nodeDeclOrdinal: int32 = astNodeDeclOrdinal(nId)
    let nodeBodyTokStart: int32 = astNodeDeferredBodyStartTok(nId)
    let nodeBodyTokEnd: int32 = astNodeDeferredBodyEndTok(nId)
    let stableDeclMatch: bool =
        task.declOrdinal >= 0 && nodeDeclOrdinal >= 0 && nodeDeclOrdinal == task.declOrdinal
    let stableBodyStartMatch: bool =
        task.bodyTokStart >= 0 && nodeBodyTokStart >= 0 && nodeBodyTokStart == task.bodyTokStart
    let stableBodyEndMatch: bool =
        task.bodyTokEnd >= 0 && nodeBodyTokEnd >= 0 && nodeBodyTokEnd == task.bodyTokEnd
    if stableDeclMatch && (stableBodyStartMatch || stableBodyEndMatch):
        return true
    let nodeName: str = uirCoreTopLevelRoutineNameId(nId)
    if len(task.routineName) > 0 && nodeName != task.routineName:
        return false
    let nodeTextId: int32 = uirCoreTopLevelRoutineNameTextId(nId)
    if task.nameTextId > 0 && nodeTextId > 0 && nodeTextId != task.nameTextId:
        return false
    if task.declOrdinal >= 0 && nodeDeclOrdinal >= 0 && nodeDeclOrdinal != task.declOrdinal:
        return false
    if task.bodyTokStart >= 0 && nodeBodyTokStart >= 0 && nodeBodyTokStart != task.bodyTokStart:
        return false
    if task.bodyTokEnd >= 0 && nodeBodyTokEnd >= 0 && nodeBodyTokEnd != task.bodyTokEnd:
        return false
    return true

fn uirCoreRecoverFnTaskNode(task: UirFnTask): AstNodeId =
    if task == nil:
        return astInvalidNodeId()
    var hasImportcCurrent: bool = false
    var importcLinkCurrent: str = ""
    if astNodeIdValid(task.funcNode):
        uirCoreParseImportcLinkNameId(task.funcNode, &hasImportcCurrent, &importcLinkCurrent)
    let forceFreshImportcNode: bool =
        hasImportcCurrent && task.bodyTokStart < 0 && task.bodyTokEnd < 0
    if !forceFreshImportcNode && uirCoreFnTaskNodeMatches(task, task.funcNode):
        return task.funcNode
    let originFile: str = backendStripSpaces(task.originFile)
    if len(originFile) == 0 || !frontend_lib.stage1_fileExists(originFile):
        return task.funcNode
    var content: str = ""
    if !frontend_lib.stage1_readFileInto(originFile, &content):
        return task.funcNode
    var rootId: AstNodeId = astInvalidNodeId()
    if !uirCoreParseModuleWithLoweredTypesId(originFile, content, rootId):
        return task.funcNode
    let prevParsedRoot: Node = uirCore_currentParsedRoot
    uirCore_currentParsedRoot = rootId
    defer:
        uirCore_currentParsedRoot = prevParsedRoot
    for i in 0..<astKidCount(rootId):
        let candId: AstNodeId = astKidAt(rootId, i)
        if uirCoreFnTaskNodeMatches(task, candId):
            return candId
    if len(task.routineName) > 0:
        for i in 0..<astKidCount(rootId):
            let candId: AstNodeId = astKidAt(rootId, i)
            if !astNodeIdValid(candId):
                continue
            let candKind: NodeKind = astNodeKind(candId)
            if candKind != nkFnDecl && candKind != nkIteratorDecl:
                continue
            if uirCoreTopLevelRoutineNameId(candId) == task.routineName:
                return candId
    return task.funcNode

fn uirCoreConsumeFile(mod: UirCoreModule, ctx: UirCoreBuildCtx, filePath: str): Result[str[]] =
    if len(filePath) == 0:
        return Err[str[]]("uirCore_builder: empty file path")
    if ! frontend_lib.stage1_fileExists(filePath):
        return Err[str[]]("uirCore_builder: import file not found")
    var content: str = ""
    let _readOk: bool = frontend_lib.stage1_readFileInto(filePath, &content)
    var rootId: AstNodeId = astInvalidNodeId()
    if !uirCoreParseModuleWithLoweredTypesId(filePath, content, rootId):
        releaseNodeArena()
        return Err[str[]]("uirCore_builder: stage1 errors")
    let root: Node = rootId
    let prevParsedRoot: Node = uirCore_currentParsedRoot
    uirCore_currentParsedRoot = root
    defer:
        uirCore_currentParsedRoot = prevParsedRoot
    let rawImports: str[] = uirCoreCollectImportPathsId(rootId)
    var imports: str[]
    for ii in 0..<rawImports.len:
        let impPath: str = rawImports[ii]
        let resolvedRes: Result[str] = resolveImportToFilePath(impPath, filePath)
        if ! IsOk[str](resolvedRes):
            releaseNodeArena()
            return ErrInfo[str[]](ErrorInfoOf[str](resolvedRes))
        add(imports, Value[str](resolvedRes))
    uirCoreDirectImportCacheStore(filePath, imports)
    let tdRes: Result[bool] = uirCoreConsumeTypeDecls(mod, root)
    if ! uirCoreResultBoolIsOk(tdRes):
        releaseNodeArena()
        return ErrInfo[str[]](uirCoreResultBoolErrorInfo(tdRes))
    for i in 0..<astKidCount(rootId):
        let nId: AstNodeId = astKidAt(rootId, i)
        if !astNodeIdValid(nId):
            continue
        let nKind: NodeKind = astNodeKind(nId)
        if nKind == nkVar || nKind == nkLet || nKind == nkConst:
            var patId: AstNodeId = astInvalidNodeId()
            if astKidCount(nId) > 0:
                patId = astKidAt(nId, 0)
            var initId: AstNodeId = astInvalidNodeId()
            if astKidCount(nId) > 2:
                initId = astKidAt(nId, 2)
            var nameNodeId: AstNodeId = patId
            var typeNodeId: AstNodeId = astInvalidNodeId()
            if astKidCount(nId) > 1:
                typeNodeId = astKidAt(nId, 1)
            if astNodeIdValid(patId):
                if astNodeKind(patId) == nkPattern && astKidCount(patId) > 0:
                    nameNodeId = astKidAt(patId, 0)
                    if astKidCount(patId) > 1:
                        typeNodeId = astKidAt(patId, 1)
            if !astNodeIdValid(nameNodeId):
                releaseNodeArena()
                return Err[str[]]("uirCore_builder: global expects identifier")
            let nameNodeKind: NodeKind = astNodeKind(nameNodeId)
            if nameNodeKind != nkIdent && nameNodeKind != nkSymbol:
                releaseNodeArena()
                return Err[str[]]("uirCore_builder: global expects identifier")
            let name: str = astPlainName(nameNodeId)
            if moduleHasFunc(mod, name) || moduleHasGlobal(mod, name) ||
               uirCoreFindTypeAlias(mod, name) >= 0 || uirCoreFindObjType(mod, name) >= 0:
                releaseNodeArena()
                return Err[str[]]("uirCore_builder: duplicate global name")
            var declType: UirCoreType = uirCoreTypeFromNodeWithModule(mod, typeNodeId)
            if !astNodeIdValid(typeNodeId):
                declType = inferExprTypeWithGlobals(nil, mod, nil, initId, declType)
            elif astNodeKind(typeNodeId) == nkEmpty:
                declType = inferExprTypeWithGlobals(nil, mod, nil, initId, declType)
            var hasInit: bool = false
            var initVal: int64 = 0
            if astNodeIdValid(initId):
                let initKind: NodeKind = astNodeKind(initId)
                if initKind != nkEmpty:
                    if initKind == nkIntLit:
                        hasInit = true
                        initVal = astNodeIntVal(initId)
                    elif initKind == nkBoolLit:
                        hasInit = true
                        let v: str = backendStripSpaces(astNodeIdent(initId))
                        initVal = (v == "true") ? 1 : 0
                    elif initKind == nkNilLit:
                        hasInit = true
                        if astNodeIdValid(typeNodeId):
                            if astNodeKind(typeNodeId) != nkEmpty:
                                let gk: str = uirCoreTypeKeyFromNodeLoose(typeNodeId)
                                if isSemanticStrKey(gk):
                                    let lineGlobalInit: str = intToStr(astNodePosLine(initId))
                                    let colGlobalInit: str = intToStr(astNodePosCol(initId))
                                    if !uirCoreSkipSemStdDuplicateRelaxEnabled():
                                        releaseNodeArena()
                                        return Err[str[]]("uirCore_builder: global semantic str cannot be nil; use \"\" @" +
                                                          lineGlobalInit + ":" + colGlobalInit)
                        initVal = 0
                    else:
                        releaseNodeArena()
                        return Err[str[]]("uirCore_builder: unsupported global initializer")
            uirCoreAddGlobal(mod, name, declType, initVal, hasInit, filePath)
            continue
        if nKind == nkFnDecl:
            let fRes: Result[UirCoreFunc] = uirCoreBuildFuncId(mod, nId, filePath)
            if ! IsOk[UirCoreFunc](fRes):
                releaseNodeArena()
                return ErrInfo[str[]](ErrorInfoOf[UirCoreFunc](fRes))
            let f: UirCoreFunc = Value[UirCoreFunc](fRes)
            if (f == nil):
                continue
            let stableName: str = uirCoreTopLevelRoutineNameId(nId)
            let stableOriginFile: str = filePath
            let stableDeclOrdinal: int32 = astNodeDeclOrdinal(nId)
            let stableSourceAstIndex: int32 = astNodeIndex(nId)
            uirCoreFuncInitHeaderMeta(f, uirCoreFuncRetTypeKeyOf(f), stableOriginFile,
                                      stableDeclOrdinal, stableSourceAstIndex,
                                      uirCoreFuncIsExtern(f))
            let sameRoutineIdx: int32 = uirCoreModuleFuncSameOriginIndex(
                mod, stableName, stableOriginFile,
                stableDeclOrdinal, stableSourceAstIndex)
            if sameRoutineIdx >= 0:
                let exSame: UirCoreFunc = uirCoreModuleFuncAt(mod, sameRoutineIdx)
                if !uirCoreFuncIdValid(exSame) || uirCoreFuncBlocksLen(exSame) == 0:
                    uirCoreModuleSetFuncAt(mod, sameRoutineIdx, f)
                continue
            if moduleHasFunc(mod, stableName) || moduleHasGlobal(mod, stableName) ||
               uirCoreFindTypeAlias(mod, stableName) >= 0 || uirCoreFindObjType(mod, stableName) >= 0:
                if uirCoreSkipSemStdDuplicateRelaxEnabled():
                    continue
                releaseNodeArena()
                return Err[str[]]("uirCore_builder: duplicate function name: " + stableName)
            if stableName == "main":
                if (ctx != nil) && ctx.foundMain:
                    releaseNodeArena()
                    return Err[str[]]("uirCore_builder: multiple main functions")
                if (ctx != nil):
                    ctx.foundMain = true
                    if envIsTrue "BACKEND_DEBUG_STAGE1_PIPE":
                        let fDbgMainSet0: os.File = os.get_stderr()
                        os.writeLine(fDbgMainSet0, "[backend] stage1: found_main_set_imports")
                        os.c_fflush fDbgMainSet0
            uirCoreAddFunc(mod, f)
    releaseNodeArena()
    return Ok[str[]](imports)

fn uirCoreBuildModuleFromFile(path: str): Result[UirCoreModule] =
    if len(path) == 0:
        return Err[UirCoreModule]("uirCore_builder: empty path")
    uirCoreGlobalObjTypesReset()
    uirCoreGlobalTypeKeysReset()
    uirCoreInlineObjFieldTypesReset()
    uirCoreObjFieldTypeKeysReset()
    uirCoreTupleFieldIndicesReset()
    uirCoreObjAliasesReset()
    backendStripCacheReset()
    uirCoreDupFnBasesReset()
    uirCoreDupGlobalNamesReset()
    uirCorePredeclareMetaReset()
    uirCoreTopLevelPathCacheReset()
    uirCoreCalleeCandidatesReset()
    uirCoreGlobalBaseUniqueCacheReset()
    uirCoreFuncBaseUniqueCacheReset()
    uirCoreTypeNodeObjNameCacheReset()
    uirCoreTypeKeyObjNameCacheReset()
    uirCoreFindTypeDeclByNameCacheReset(astInvalidNodeId())
    uirCoreFieldTypeKeyFromCurrentRootCacheReset(nil, astInvalidNodeId())
    uirCoreOverloadInferCacheReset()
    uirCoreOverloadTypeKeyCacheReset()
    let mod: UirCoreModule = uirCoreNewModule("arm64-apple-darwin")
    ensureBuiltinObjTypes(mod)
    var ctx: UirCoreBuildCtx
    new ctx
    ctx.foundMain = false
    ctx.traceEnabled = stage1TraceEnabled()
    ctx.traceFnCount = 0
    ctx.traceGlobalCount = 0
    ctx.globalInitNames = []
    ctx.globalInitTypes = []
    ctx.globalInitObjTypeNames = []
    ctx.globalInitNodes = []
    ctx.globalInitFilePaths = []
    ctx.globalInitSeqFixedElemTypes = []
    ctx.globalInitSeqFixedCapExprs = []

    # Pass 1: collect full import closure.
    var queue: str[]
    add(queue, path)
    var files: str[]
    var fileImportStart: int32[]
    var fileImportLen: int32[]
    var fileImportPool: str[]
    var fileIndex: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(128)
    var dupGlobalNameIndex: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(2048)
    var dupGlobalNames: str[]
    var dupGlobalCounts: int32[]
    for qi in 0..<queue.len:
        let filePath: str = queue[qi]
        if len(filePath) == 0:
            return Err[UirCoreModule]("uirCore_builder: empty file path")
        var seen: bool = false
        let seenIdx: int32 = uirCoreHashMapStrIntGetCompatLocal(fileIndex, filePath, seen)
        if seen && seenIdx >= 0:
            continue
        add(files, filePath)
        hashmaps.hashMapStrIntPut(fileIndex, filePath, files.len - 1)
        if ! frontend_lib.stage1_fileExists(filePath):
            return Err[UirCoreModule]("uirCore_builder: import file not found")
        var content: str = ""
        let _readOk: bool = frontend_lib.stage1_readFileInto(filePath, &content)
        var rootId: AstNodeId = astInvalidNodeId()
        if !uirCoreParseModuleWithLoweredTypesId(filePath, content, rootId):
            releaseNodeArena()
            return Err[UirCoreModule]("uirCore_builder: stage1 errors")
        let rawImports: str[] = uirCoreCollectImportPathsId(rootId)
        var declScanQueue: AstNodeId[]
        add(declScanQueue, rootId)
        while declScanQueue.len > 0:
            let n0Id: AstNodeId = declScanQueue[declScanQueue.len - 1]
            declScanQueue.len = declScanQueue.len - 1
            if !astNodeIdValid(n0Id):
                continue
            let n0Kind: NodeKind = astNodeKind(n0Id)
            if n0Kind == nkEmpty:
                continue
            if n0Kind == nkStmtList || n0Kind == nkModule:
                for ni in 0..<astKidCount(n0Id):
                    add(declScanQueue, astKidAt(n0Id, ni))
                continue
            if n0Kind != nkVar && n0Kind != nkLet && n0Kind != nkConst:
                continue
            var pat0Id: AstNodeId = astInvalidNodeId()
            if astKidCount(n0Id) > 0:
                pat0Id = astKidAt(n0Id, 0)
            var nameNode0Id: AstNodeId = pat0Id
            if astNodeIdValid(pat0Id):
                if astNodeKind(pat0Id) == nkPattern && astKidCount(pat0Id) > 0:
                    nameNode0Id = astKidAt(pat0Id, 0)
            if !astNodeIdValid(nameNode0Id):
                continue
            let nameNode0Kind: NodeKind = astNodeKind(nameNode0Id)
            if nameNode0Kind != nkIdent && nameNode0Kind != nkSymbol:
                continue
            let globalName0: str = backendStripSpaces(astPlainName(nameNode0Id))
            if len(globalName0) == 0:
                continue
            var foundDupG: bool = false
            let rawG: int32 = uirCoreHashMapStrIntGetCompatLocal(dupGlobalNameIndex, globalName0, foundDupG)
            let gIdx0: int32 = rawG - 1
            if foundDupG && rawG > 0 && gIdx0 >= 0 && gIdx0 < dupGlobalCounts.len:
                dupGlobalCounts[gIdx0] = dupGlobalCounts[gIdx0] + 1
            else:
                let newG: int32 = dupGlobalNames.len
                add(dupGlobalNames, globalName0)
                add(dupGlobalCounts, 1)
                hashmaps.hashMapStrIntPut(dupGlobalNameIndex, globalName0, newG + 1)
        var imports: str[]
        for ii0 in 0..<rawImports.len:
            let impPath: str = rawImports[ii0]
            let resolvedRes: Result[str] = resolveImportToFilePath(impPath, filePath)
            if ! IsOk[str](resolvedRes):
                releaseNodeArena()
                return ErrInfo[UirCoreModule](ErrorInfoOf[str](resolvedRes))
            add(imports, Value[str](resolvedRes))
        uirCoreDirectImportCacheStore(filePath, imports)
        let importStart: int32 = fileImportPool.len
        add(fileImportStart, importStart)
        add(fileImportLen, imports.len)
        for ii in 0..<imports.len:
            add(fileImportPool, imports[ii])
        releaseNodeArena()
        for ii in 0..<imports.len:
            add(queue, imports[ii])

    for gi in 0..<dupGlobalNames.len:
        if dupGlobalCounts[gi] > 1:
            uirCoreDupGlobalNamesAdd(dupGlobalNames[gi])

    # Pass 1b: consume type declarations in import order (imports before importers).
    # This avoids spurious "unresolved type dependencies" when a file's type decls
    # reference imported aliases/object types (e.g. HashMapStrInt, ByteReader, UirCoreModule).
    var indeg: int32[]
    indeg.len = files.len
    var depHead: int32[]
    depHead.len = files.len
    for hi in 0..<depHead.len:
        depHead[hi] = -1
    var depTo: int32[]
    var depNext: int32[]
    for fi0 in 0..<files.len:
        let impStart: int32 = fileImportStart[fi0]
        let impLen: int32 = fileImportLen[fi0]
        for ji in 0..<impLen:
            let impPath: str = fileImportPool[impStart + ji]
            var found: bool = false
            let impIdx: int32 = uirCoreHashMapStrIntGetCompatLocal(fileIndex, impPath, found)
            if found && impIdx >= 0 && impIdx < files.len && impIdx != fi0:
                indeg[fi0] = indeg[fi0] + 1
                let edgeIdx: int32 = depTo.len
                add(depTo, fi0)
                add(depNext, depHead[impIdx])
                depHead[impIdx] = edgeIdx

    var ready: int32[]
    for i0 in 0..<files.len:
        if indeg[i0] == 0:
            add(ready, i0)

    var typeFiles: str[]
    while ready.len > 0:
        let idx0: int32 = ready[ready.len - 1]
        ready.len = ready.len - 1
        add(typeFiles, files[idx0])
        var edge: int32 = depHead[idx0]
        while edge >= 0:
            let depIdx: int32 = depTo[edge]
            let newDeg: int32 = indeg[depIdx] - 1
            indeg[depIdx] = newDeg
            if newDeg == 0:
                add(ready, depIdx)
            edge = depNext[edge]

    # Cycles should not exist in a well-formed program, but keep building a best-effort
    # order to avoid crashing; type resolution may still fail later with a real error.
    if typeFiles.len < files.len:
        for ci0 in 0..<files.len:
            let fp0: str = files[ci0]
            if !seqContainsStr(typeFiles, fp0):
                add(typeFiles, fp0)

    var pendingTypeFiles: str[] = typeFiles
    var typePass: int32 = 0
    while pendingTypeFiles.len > 0:
        if typePass > typeFiles.len + 8:
            return Err[UirCoreModule]("uirCore_builder: cross-file type dependency resolution exceeded iteration limit")
        var nextPendingTypeFiles: str[]
        var progressedTypeFiles: bool = false
        for tf0 in 0..<pendingTypeFiles.len:
            let filePath: str = pendingTypeFiles[tf0]
            if len(filePath) == 0:
                return Err[UirCoreModule]("uirCore_builder: empty file path")
            if ! frontend_lib.stage1_fileExists(filePath):
                return Err[UirCoreModule]("uirCore_builder: import file not found")
            var content: str = ""
            let _readOk: bool = frontend_lib.stage1_readFileInto(filePath, &content)
            var rootId: AstNodeId = astInvalidNodeId()
            if !uirCoreParseModuleWithLoweredTypesId(filePath, content, rootId):
                releaseNodeArena()
                return Err[UirCoreModule]("uirCore_builder: stage1 errors")
            let root: Node = rootId
            let prevParsedRootTypePass: Node = uirCore_currentParsedRoot
            uirCore_currentParsedRoot = root
            uirCorePredeclareGlobalsForTypes(mod, root)
            let tdRes: Result[bool] = uirCoreConsumeTypeDecls(mod, root, true)
            uirCore_currentParsedRoot = prevParsedRootTypePass
            if !uirCoreResultBoolIsOk(tdRes):
                releaseNodeArena()
                return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(tdRes))
            if uirCoreResultBoolValue(tdRes):
                add(nextPendingTypeFiles, filePath)
            else:
                progressedTypeFiles = true
            releaseNodeArena()
        if nextPendingTypeFiles.len == 0:
            break
        if !progressedTypeFiles:
            let failPath: str = nextPendingTypeFiles[0]
            if len(failPath) == 0:
                return Err[UirCoreModule]("uirCore_builder: unresolved type dependencies")
            var failContent: str = ""
            let _readFailOk: bool = frontend_lib.stage1_readFileInto(failPath, &failContent)
            var failRootId: AstNodeId = astInvalidNodeId()
            if !uirCoreParseModuleWithLoweredTypesId(failPath, failContent, failRootId):
                releaseNodeArena()
                return Err[UirCoreModule]("uirCore_builder: stage1 errors")
            let failRoot: Node = failRootId
            uirCorePredeclareGlobalsForTypes(mod, failRoot)
            let failRes: Result[bool] = uirCoreConsumeTypeDecls(mod, failRoot, false)
            if !uirCoreResultBoolIsOk(failRes):
                releaseNodeArena()
                return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(failRes))
            releaseNodeArena()
            return Err[UirCoreModule]("uirCore_builder: unresolved type dependencies")
        pendingTypeFiles = nextPendingTypeFiles
        typePass = typePass + 1

    # Pass 2: predeclare function signatures across all files first.
    for fi in 0..<files.len:
        let filePath: str = files[fi]
        if len(filePath) == 0:
            return Err[UirCoreModule]("uirCore_builder: empty file path")
        if ! frontend_lib.stage1_fileExists(filePath):
            return Err[UirCoreModule]("uirCore_builder: import file not found")
        var content: str = ""
        let _readOk: bool = frontend_lib.stage1_readFileInto(filePath, &content)
        var rootId: AstNodeId = astInvalidNodeId()
        if !uirCoreParseModuleWithLoweredTypesId(filePath, content, rootId):
            releaseNodeArena()
            return Err[UirCoreModule]("uirCore_builder: stage1 errors")
        for pi in 0..<astKidCount(rootId):
            let nId: AstNodeId = astKidAt(rootId, pi)
            let ownPath: str = astNodeStrVal(nId)
            let stmtPath: str = (len(ownPath) > 0) ? ownPath : astNodeStrVal(rootId)
            let res: Result[bool] = uirCorePredeclareTopLevelFromRootId(mod, rootId, stmtPath, nId, nil)
            if !uirCoreResultBoolIsOk(res):
                releaseNodeArena()
                return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(res))
        releaseNodeArena()

    # Pass 3: lower all top-level declarations now that types + signatures exist.
    # Keep pass-3 AST arena alive until global_init is lowered. ctx global-init
    # stores AST node ids (init expressions / seq-fixed metadata), and releasing
    # the arena per-file here leaves dangling ids that can crash in global_init.
    for fi2 in 0..<files.len:
        let filePath: str = files[fi2]
        if len(filePath) == 0:
            return Err[UirCoreModule]("uirCore_builder: empty file path")
        if ! frontend_lib.stage1_fileExists(filePath):
            return Err[UirCoreModule]("uirCore_builder: import file not found")
        var content: str = ""
        let _readOk: bool = frontend_lib.stage1_readFileInto(filePath, &content)
        var rootId: AstNodeId = astInvalidNodeId()
        if !uirCoreParseModuleWithLoweredTypesId(filePath, content, rootId):
            releaseNodeArena()
            return Err[UirCoreModule]("uirCore_builder: stage1 errors")
        for ti in 0..<astKidCount(rootId):
            let nId: AstNodeId = astKidAt(rootId, ti)
            let ownPath2: str = astNodeStrVal(nId)
            let stmtPath: str = (len(ownPath2) > 0) ? ownPath2 : astNodeStrVal(rootId)
            let res: Result[bool] = uirCoreConsumeTopLevelFromRootId(mod, ctx, rootId, stmtPath, nId, nil)
            if ! uirCoreResultBoolIsOk(res):
                releaseNodeArena()
                return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(res))
    let allowNoMain: bool = envIsTrue "BACKEND_ALLOW_NO_MAIN" || backendAllowNoMainByEmit()
    if ! ctx.foundMain && !allowNoMain:
        return Err[UirCoreModule]("uirCore_builder: main not found")
    let noMainInitRes0: Result[bool] = uirCoreRejectNoMainGlobalInit(ctx, allowNoMain)
    if !uirCoreResultBoolIsOk(noMainInitRes0):
        return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(noMainInitRes0))

    if ctx.globalInitNames.len > 0 && !backendSkipGlobalInit():
        var initFunc: UirCoreFunc = nil
        let initRes: Result[bool] = uirCoreBuildGlobalInitFunc(mod, ctx, initFunc)
        if !uirCoreResultBoolIsOk(initRes):
            return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(initRes))
        if initFunc == nil:
            return Err[UirCoreModule]("uirCore_builder: global init builder returned nil")
        uirCoreAddFunc(mod, initFunc)
        if ctx.foundMain:
            uirCoreInjectGlobalInitCall(mod, "__cheng_global_init")

    releaseNodeArena()
    uirCoreApplyUirPluginHooks(path, mod)
    uirCoreNormalizeModule(mod)
    return uirCoreOkModule(mod)

fn uirCoreGlobalInitChunkSize(): int32 =
    let raw: str = backendStripSpaces(os.getEnvDefault("BACKEND_GLOBAL_INIT_CHUNK_SIZE", "64"))
    let parsed: int32 = uirCoreParseInt32(raw, 64)
    if parsed <= 0:
        return 64
    return parsed

fn uirCoreGlobalInitDebugWrite(enabled: bool, dbgFile: os.File, msg: str) =
    if !enabled || (dbgFile == nil):
        return
    os.writeLine(dbgFile, msg)
    os.c_fflush dbgFile

fn uirCoreGlobalInitEnsureNameAvailable(mod: UirCoreModule, initName: str): Result[bool] =
    if len(initName) == 0:
        return Err[bool]("uirCore_builder: empty global init name")
    if moduleHasFunc(mod, initName) || moduleHasGlobal(mod, initName) ||
       uirCoreFindTypeAlias(mod, initName) >= 0 || uirCoreFindObjType(mod, initName) >= 0:
        return Err[bool]("uirCore_builder: global init name conflicts: " + initName)
    return Ok[bool](true)

fn uirCoreBuildGlobalInitPhaseChunk(mod: UirCoreModule, ctx: UirCoreBuildCtx,
                                    phaseKind: int32, phaseLabel: str, helperBase: str,
                                    startIndex: int32, chunkSize: int32, chunkOrdinal: int32,
                                    dbgGlobalInitIndex: bool, fDbgGlobalInitIndex: os.File,
                                    outNextIndex: var int32, outFunc: var UirCoreFunc): Result[bool] =
    if (mod == nil) || (ctx == nil):
        return Err[bool]("uirCore_builder: invalid global init phase chunk args")
    outNextIndex = startIndex
    outFunc = nil
    if startIndex < 0 || startIndex > ctx.globalInitNames.len:
        return Err[bool]("uirCore_builder: invalid global init chunk start")
    let helperName: str = helperBase + "_" + intToStr(chunkOrdinal)
    var i: int32 = startIndex
    var emitted: int32 = 0
    var f: UirCoreFunc = nil
    var env: LocalEnv = nil
    var b: BlockBuilder = nil
    while i < ctx.globalInitNames.len:
        let hasObj: bool = len(ctx.globalInitObjTypeNames[i]) > 0
        let initNode: Node = ctx.globalInitNodes[i]
        let hasInitExpr: bool = astNodeIdValid(initNode) && nodeKind(initNode) != nkEmpty
        var matchesPhase: bool = false
        if phaseKind == 1:
            matchesPhase = !hasObj && hasInitExpr
        elif phaseKind == 2:
            matchesPhase = hasObj
        elif phaseKind == 3:
            matchesPhase = hasObj && hasInitExpr
        else:
            return Err[bool]("uirCore_builder: invalid global init phase kind")
        if !matchesPhase:
            i = i + 1
            continue
        if emitted == 0:
            let nameRes: Result[bool] = uirCoreGlobalInitEnsureNameAvailable(mod, helperName)
            if !uirCoreResultBoolIsOk(nameRes):
                return ErrInfo[bool](uirCoreResultBoolErrorInfo(nameRes))
            f = uirCoreNewFunc(helperName, uirCoreTypeVoid())
            uirCoreFuncInitHeaderMeta(f, uirCoreFuncRetTypeKeyOf(f),
                                      "<global_init:" + phaseLabel + ">",
                                      uirCoreFuncDeclOrdinalOf(f),
                                      uirCoreFuncSourceAstIndexOf(f),
                                      uirCoreFuncIsExtern(f))
            env = localEnvNew()
            b = blockBuilderNew(env, mod, f)
        var dbgLineParts: str[]
        add(dbgLineParts, "[backend] global_init phase=")
        add(dbgLineParts, phaseLabel)
        add(dbgLineParts, " chunk=")
        add(dbgLineParts, intToStr(chunkOrdinal))
        add(dbgLineParts, " i=")
        add(dbgLineParts, intToStr(i))
        add(dbgLineParts, " emitted=")
        add(dbgLineParts, intToStr(emitted))
        add(dbgLineParts, " name=")
        add(dbgLineParts, ctx.globalInitNames[i])
        if hasObj:
            add(dbgLineParts, " obj=")
            add(dbgLineParts, ctx.globalInitObjTypeNames[i])
        uirCoreGlobalInitDebugWrite(dbgGlobalInitIndex, fDbgGlobalInitIndex, fmt(dbgLineParts))
        if phaseKind == 1:
            let valRes: Result[UirExprId] = lowerExprValue(b, initNode, ctx.globalInitTypes[i])
            if !IsOk[UirExprId](valRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](valRes))
            blockBuilderAddStmt(b, uirCoreStmtStore(uirCoreGlobalAddr(ctx.globalInitNames[i]),
                                                 Value[UirExprId](valRes), ctx.globalInitTypes[i]))
        elif phaseKind == 2:
            let ot: UirCoreObjType = uirCoreGetObjType(mod, ctx.globalInitObjTypeNames[i])
            if ot.size <= 0:
                return Err[bool]("uirCore_builder: global init missing object layout: " + ctx.globalInitObjTypeNames[i])
            let tmpName: str = blockBuilderNextTemp(b, "__gobj")
            let tmpSlot: int32 = localAdd(env, tmpName, uirCoreTypeI64())
            uirCoreSetLocalType(f, tmpSlot, uirCoreTypeI64())
            var allocArgs: UirExprId[]
            builderExprSeqAppend(allocArgs, uirCoreConstI64(int64(ot.size)))
            blockBuilderAddStmt(b, uirCoreStmtLet(tmpName, tmpSlot, uirCoreCall("alloc", allocArgs)))
            var zeroArgs: UirExprId[]
            builderExprSeqAppend(zeroArgs, uirCoreLocal(tmpSlot))
            builderExprSeqAppend(zeroArgs, uirCoreConstI64(0))
            builderExprSeqAppend(zeroArgs, uirCoreConstI64(int64(ot.size)))
            blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall("setMem", zeroArgs)))
            let seqFixedElemType: Node = ctx.globalInitSeqFixedElemTypes[i]
            let seqFixedCapExpr: Node = ctx.globalInitSeqFixedCapExprs[i]
            if astNodeIdValid(seqFixedElemType) && astNodeIdValid(seqFixedCapExpr):
                var sfi: SeqFixedInit
                sfi.elemType = seqFixedElemType
                sfi.capExpr = seqFixedCapExpr
                let seqInitRes: Result[bool] = emitSeqFixedReserveInitToPtr(b, uirCoreLocal(tmpSlot), sfi)
                if !uirCoreResultBoolIsOk(seqInitRes):
                    return ErrInfo[bool](uirCoreResultBoolErrorInfo(seqInitRes))
            blockBuilderAddStmt(b, uirCoreStmtStore(uirCoreGlobalAddr(ctx.globalInitNames[i]),
                                                 uirCoreLocal(tmpSlot), uirCoreTypeI64()))
        else:
            var initCore: Node = initNode
            while astNodeIdValid(initCore) && nodeKind(initCore) == nkPar && kidCount(initCore) > 0:
                initCore = kid(initCore, 0)
            if !astNodeIdValid(initCore) || nodeKind(initCore) != nkCall:
                return Err[bool]("uirCore_builder: global object init expects call: " + ctx.globalInitNames[i])
            let lead: UirExprId = uirCoreLoad(uirCoreGlobalAddr(ctx.globalInitNames[i]), uirCoreTypeI64())
            let callRes: Result[UirExprId] = lowerCallWithLeadingArg(b, initCore, lead)
            if !IsOk[UirExprId](callRes):
                return ErrInfo[bool](ErrorInfoOf[UirExprId](callRes))
        emitted = emitted + 1
        i = i + 1
        if emitted >= chunkSize:
            break
    outNextIndex = i
    if emitted == 0 || (f == nil) || (b == nil):
        return Ok[bool](false)
    blockBuilderFinish(b, uirCoreTermRet(nil))
    outFunc = f
    return Ok[bool](true)

fn uirCoreBuildGlobalInitWrapperFunc(mod: UirCoreModule, helperNames: str[],
                                     outFunc: var UirCoreFunc): Result[bool] =
    if (mod == nil):
        return Err[bool]("uirCore_builder: invalid global init wrapper args")
    outFunc = nil
    let initName: str = "__cheng_global_init"
    let nameRes: Result[bool] = uirCoreGlobalInitEnsureNameAvailable(mod, initName)
    if !uirCoreResultBoolIsOk(nameRes):
        return ErrInfo[bool](uirCoreResultBoolErrorInfo(nameRes))
    let f: UirCoreFunc = uirCoreNewFunc(initName, uirCoreTypeVoid())
    uirCoreFuncInitHeaderMeta(f, uirCoreFuncRetTypeKeyOf(f), "<global_init>",
                              uirCoreFuncDeclOrdinalOf(f), uirCoreFuncSourceAstIndexOf(f),
                              uirCoreFuncIsExtern(f))
    let env: LocalEnv = localEnvNew()
    let b: BlockBuilder = blockBuilderNew(env, mod, f)
    for i in 0..<helperNames.len:
        var helperArgs: UirExprId[]
        blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall(helperNames[i], helperArgs)))
    blockBuilderFinish(b, uirCoreTermRet(nil))
    outFunc = f
    return Ok[bool](true)

fn uirCoreBuildGlobalInitFunc(mod: UirCoreModule, ctx: UirCoreBuildCtx, outFunc: var UirCoreFunc): Result[bool] =
    if (mod == nil) || (ctx == nil) || ctx.globalInitNames.len == 0:
        return Err[bool]("uirCore_builder: no global init work")
    let dbgGlobalInitIndex: bool = envIsTrue "BACKEND_DEBUG_GLOBAL_INIT_INDEX"
    var fDbgGlobalInitIndex: os.File = nil
    if dbgGlobalInitIndex:
        fDbgGlobalInitIndex = os.get_stderr()
        uirCoreGlobalInitDebugWrite(true, fDbgGlobalInitIndex,
                                    "[backend] global_init enter total=" + intToStr(ctx.globalInitNames.len))
    let chunkSize: int32 = uirCoreGlobalInitChunkSize()
    var helperNames: str[]
    var startIndex: int32 = 0
    var chunkOrdinal: int32 = 0
    while startIndex < ctx.globalInitNames.len:
        var nextIndex: int32 = startIndex
        var phaseFunc: UirCoreFunc = nil
        let phaseRes: Result[bool] = uirCoreBuildGlobalInitPhaseChunk(
            mod, ctx, 1, "const", "__cheng_global_init_const",
            startIndex, chunkSize, chunkOrdinal, dbgGlobalInitIndex, fDbgGlobalInitIndex,
            nextIndex, phaseFunc)
        if !uirCoreResultBoolIsOk(phaseRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(phaseRes))
        if phaseFunc == nil:
            break
        uirCoreAddFunc(mod, phaseFunc)
        add(helperNames, uirCoreOwnStr("__cheng_global_init_const_" + intToStr(chunkOrdinal)))
        startIndex = nextIndex
        chunkOrdinal = chunkOrdinal + 1
    startIndex = 0
    chunkOrdinal = 0
    while startIndex < ctx.globalInitNames.len:
        var nextIndex2: int32 = startIndex
        var phaseFunc2: UirCoreFunc = nil
        let phaseRes2: Result[bool] = uirCoreBuildGlobalInitPhaseChunk(
            mod, ctx, 2, "heap", "__cheng_global_init_heap",
            startIndex, chunkSize, chunkOrdinal, dbgGlobalInitIndex, fDbgGlobalInitIndex,
            nextIndex2, phaseFunc2)
        if !uirCoreResultBoolIsOk(phaseRes2):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(phaseRes2))
        if phaseFunc2 == nil:
            break
        uirCoreAddFunc(mod, phaseFunc2)
        add(helperNames, uirCoreOwnStr("__cheng_global_init_heap_" + intToStr(chunkOrdinal)))
        startIndex = nextIndex2
        chunkOrdinal = chunkOrdinal + 1
    startIndex = 0
    chunkOrdinal = 0
    while startIndex < ctx.globalInitNames.len:
        var nextIndex3: int32 = startIndex
        var phaseFunc3: UirCoreFunc = nil
        let phaseRes3: Result[bool] = uirCoreBuildGlobalInitPhaseChunk(
            mod, ctx, 3, "ctor", "__cheng_global_init_ctor",
            startIndex, chunkSize, chunkOrdinal, dbgGlobalInitIndex, fDbgGlobalInitIndex,
            nextIndex3, phaseFunc3)
        if !uirCoreResultBoolIsOk(phaseRes3):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(phaseRes3))
        if phaseFunc3 == nil:
            break
        uirCoreAddFunc(mod, phaseFunc3)
        add(helperNames, uirCoreOwnStr("__cheng_global_init_ctor_" + intToStr(chunkOrdinal)))
        startIndex = nextIndex3
        chunkOrdinal = chunkOrdinal + 1
    var wrapperFunc: UirCoreFunc = nil
    let wrapperRes: Result[bool] = uirCoreBuildGlobalInitWrapperFunc(mod, helperNames, wrapperFunc)
    if !uirCoreResultBoolIsOk(wrapperRes):
        return ErrInfo[bool](uirCoreResultBoolErrorInfo(wrapperRes))
    if wrapperFunc == nil:
        return Err[bool]("uirCore_builder: global init wrapper missing")
    if dbgGlobalInitIndex:
        uirCoreGlobalInitDebugWrite(true, fDbgGlobalInitIndex,
                                    "[backend] global_init done chunk_size=" + intToStr(chunkSize) +
                                    " helpers=" + intToStr(helperNames.len))
    outFunc = wrapperFunc
    return Ok[bool](true)

fn uirCoreRejectNoMainGlobalInit(ctx: UirCoreBuildCtx, allowNoMain: bool): Result[bool] =
    if ctx == nil || !allowNoMain || ctx.foundMain || backendSkipGlobalInit():
        return Ok[bool](true)
    if ctx.globalInitNames.len <= 0:
        return Ok[bool](true)
    return Err[bool]("uirCore_builder: top-level global init is unsupported for no-main/object-first builds; " +
                     "move initialization into an explicit entry/init function or compile as a whole program")

fn uirCoreInjectGlobalInitCall(mod: UirCoreModule, initName: str) =
    if (mod == nil) || len(initName) == 0:
        return
    let dbgGlobalInit: bool = (getEnv "BACKEND_DEBUG_GLOBAL_INIT" == "1")
    for i in 0..<uirCoreModuleFuncsLen(mod):
        let f: UirCoreFunc = uirCoreModuleFuncAt(mod, i)
        let nameNorm: str = backendStripSpaces(((f != nil)) ? uirCoreFuncNameOf(f) : "")
        let linkNorm: str = backendStripSpaces(((f != nil)) ? uirCoreFuncLinkNameOf(f) : "")
        let nameIsMain: bool = (len(nameNorm) == 4 &&
                                nameNorm[0] == 'm' && nameNorm[1] == 'a' &&
                                nameNorm[2] == 'i' && nameNorm[3] == 'n')
        let linkIsMain: bool = (len(linkNorm) == 4 &&
                                linkNorm[0] == 'm' && linkNorm[1] == 'a' &&
                                linkNorm[2] == 'i' && linkNorm[3] == 'n')
        if dbgGlobalInit && (f != nil) &&
           (uirCoreStrIndexOf(uirCoreFuncNameOf(f), "main") >= 0 ||
            (len(uirCoreFuncLinkNameOf(f)) > 0 && uirCoreStrIndexOf(uirCoreFuncLinkNameOf(f), "main") >= 0)):
            echo("[backend] debugGlobalInit: cand name='" + uirCoreFuncNameOf(f) +
                 "' link='" + uirCoreFuncLinkNameOf(f) +
                 "' extern=" + (uirCoreFuncIsExtern(f) ? "1" : "0") +
                 " blocks=" + intToStr(uirCoreFuncBlocksLen(f)) +
                 " nameIsMain=" + (nameIsMain ? "1" : "0") +
                 " linkIsMain=" + (linkIsMain ? "1" : "0"))
        if (f != nil) && !uirCoreFuncIsExtern(f) &&
           (nameIsMain || linkIsMain) &&
           uirCoreFuncBlocksLen(f) > 0:
            let entry: UirBlockId = uirCoreFuncBlockAt(f, 0)
            if (entry == nil):
                if dbgGlobalInit:
                    echo("[backend] debugGlobalInit: main entry nil")
                return

            # Insert after initial parameter loads so argc/argv survive the init call.
            let entryStmtLen: int32 = uirCoreBlockStmtsLen(entry)
            for insertAt in 0..<entryStmtLen:
                let st: UirStmtId = uirCoreBlockStmtAt(entry, insertAt)
                if uirCoreStmtKindOf(st) != msParam:
                    break

            if insertAt < entryStmtLen:
                let s0: UirStmtId = uirCoreBlockStmtAt(entry, insertAt)
                if uirCoreStmtKindOf(s0) == msExpr:
                    let e0: UirExprId = uirCoreStmtExprOf(s0)
                    if e0 > 0 && uirCoreExprKindOf(e0) == meCall &&
                       (uirCoreExprCalleeOf(e0) == initName):
                        if dbgGlobalInit:
                            echo("[backend] debugGlobalInit: already inserted at=" + intToStr(insertAt))
                        return

            var args: UirExprId[]
            let call: UirExprId = uirCoreCall(initName, args)
            let stmt: UirStmtId = uirCoreStmtExpr(call)
            var out: UirStmtId[]
            for si in 0..<entryStmtLen:
                if si == insertAt:
                    add(out, stmt)
                add(out, uirCoreBlockStmtAt(entry, si))
            if insertAt == entryStmtLen:
                add(out, stmt)
            uirCoreBlockSetStmts(entry, out)
            if dbgGlobalInit:
                echo("[backend] debugGlobalInit: inserted at=" + intToStr(insertAt) +
                     " total=" + intToStr(uirCoreBlockStmtsLen(entry)))
            return
    if dbgGlobalInit:
        echo("[backend] debugGlobalInit: main not found")

fn uirCoreBuildModuleFromRootId(rootInputId: AstNodeId, rootTag: str = "", target: str = ""): Result[UirCoreModule] =
    if !astNodeIdValid(rootInputId):
        return Err[UirCoreModule]("uirCore_builder: empty root")
    crashTraceSetPhase(cstring("uir.root"))
    let effectiveRootTag: str = len(rootTag) > 0 ? rootTag : astNodeStrVal(rootInputId)
    let astRootId: AstNodeId = uirCoreApplyAstPluginHooksId(effectiveRootTag, rootInputId)
    if !astNodeIdValid(astRootId):
        return Err[UirCoreModule]("uirCore_builder: ast plugin rejected root module")
    let rootIdForDup: AstNodeId = uirCoreApplyMirPluginHooksId(effectiveRootTag, astRootId)
    if !astNodeIdValid(rootIdForDup):
        return Err[UirCoreModule]("uirCore_builder: mir plugin rejected root module")
    if crashTraceEnabled():
        crashTraceMark(cstring("uir.root"), astNodeIndex(rootIdForDup), astKidCount(rootIdForDup), len(target), 0)
    let root: Node = rootIdForDup
    if (root == nil):
        return Err[UirCoreModule]("uirCore_builder: invalid root id")
    let prevParsedRoot: Node = uirCore_currentParsedRoot
    uirCore_currentParsedRoot = root
    defer:
        uirCore_currentParsedRoot = prevParsedRoot
    let prof: UirCoreProfileState = uirCoreProfileInit()
    let dbgLower: bool = (os.getEnvDefault("BACKEND_DEBUG_MIR_LOWER", "") == "1")
    let dbgSummary: bool = (os.getEnvDefault("BACKEND_DEBUG_MODULE_SUMMARY", "") == "1")
    let dbgPipeCount: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    let dbgConst: bool = (os.getEnvDefault("BACKEND_DEBUG_STAGE1_CONST", "") == "1")
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: uir_root_enter")
        os.c_fflush os.get_stderr()
    if dbgPipeCount:
        let fDbgPipe: os.File = os.get_stderr()
        os.write(fDbgPipe, "[backend] stage1: uir_root_kids=")
        os.write(fDbgPipe, intToStr(astKidCount(rootIdForDup)))
        os.write(fDbgPipe, "\n")
        os.c_fflush fDbgPipe
    if dbgPipeCount:
        let fDbgPipeR0: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR0, "[backend] stage1: uir_reset_0")
        os.c_fflush fDbgPipeR0
    uirCoreGlobalObjTypesReset()
    if dbgPipeCount:
        let fDbgPipeR1: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR1, "[backend] stage1: uir_reset_1")
        os.c_fflush fDbgPipeR1
    uirCoreGlobalTypeKeysReset()
    if dbgPipeCount:
        let fDbgPipeR2: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR2, "[backend] stage1: uir_reset_2")
        os.c_fflush fDbgPipeR2
    uirCoreInlineObjFieldTypesReset()
    if dbgPipeCount:
        let fDbgPipeR3: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR3, "[backend] stage1: uir_reset_3")
        os.c_fflush fDbgPipeR3
    uirCoreObjFieldTypeKeysReset()
    if dbgPipeCount:
        let fDbgPipeR4: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR4, "[backend] stage1: uir_reset_4")
        os.c_fflush fDbgPipeR4
    uirCoreTupleFieldIndicesReset()
    if dbgPipeCount:
        let fDbgPipeR5: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR5, "[backend] stage1: uir_reset_5")
        os.c_fflush fDbgPipeR5
    uirCoreObjAliasesReset()
    backendStripCacheReset()
    uirCoreOwnStrCacheReset()
    uirCorePredeclareMetaReset()
    uirCoreTopLevelPathCacheReset()
    if dbgPipeCount:
        let fDbgPipeR6: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR6, "[backend] stage1: uir_reset_6")
        os.c_fflush fDbgPipeR6
    uirCoreCalleeCandidatesReset()
    uirCoreGlobalBaseUniqueCacheReset()
    uirCoreFuncBaseUniqueCacheReset()
    uirCoreTypeNodeObjNameCacheReset()
    uirCoreTypeKeyObjNameCacheReset()
    uirCoreFindTypeDeclByNameCacheReset(astInvalidNodeId())
    uirCoreFieldTypeKeyFromCurrentRootCacheReset(nil, astInvalidNodeId())
    uirCoreOverloadInferCacheReset()
    uirCoreOverloadTypeKeyCacheReset()
    uirCoreLegacyGenericBracketCacheReset()
    uirCoreLooseTypeKeyCacheReset()
    if dbgPipeCount:
        let fDbgPipeR7: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR7, "[backend] stage1: uir_reset_7")
        os.c_fflush fDbgPipeR7
    let effectiveTarget: str = len(target) > 0 ? target : "arm64-apple-darwin"
    let mod: UirCoreModule = uirCoreNewModule(effectiveTarget)
    if dbgPipeCount:
        let fDbgPipeR8: os.File = os.get_stderr()
        os.writeLine(fDbgPipeR8, "[backend] stage1: uir_reset_8")
        os.c_fflush fDbgPipeR8
    uirCoreReservePoolsForBuild(astKidCount(rootIdForDup))
    uirCoreProfileStep(prof, "reset")
    if dbgPipeCount:
        let fDbgPipeCtx0: os.File = os.get_stderr()
        os.writeLine(fDbgPipeCtx0, "[backend] stage1: uir_ctx_alloc_pre")
        os.c_fflush fDbgPipeCtx0
    var ctx: UirCoreBuildCtx
    new ctx
    if dbgPipeCount:
        let fDbgPipeCtx1: os.File = os.get_stderr()
        os.writeLine(fDbgPipeCtx1, "[backend] stage1: uir_ctx_alloc_post")
        os.c_fflush fDbgPipeCtx1
    ctx.foundMain = false
    ctx.traceEnabled = stage1TraceEnabled()
    ctx.traceFnCount = 0
    ctx.traceGlobalCount = 0
    var overloadedFnBases: hashsets.HashSetStr = hashsets.hashSetStrInit(8)
    var overloadedFnBasesPtr: ptr = nil
    if ctx.traceEnabled:
        stage1Trace("backend: uir build start files=" + intToStr(astKidCount(rootIdForDup)))
    if dbgPipeCount:
        let fDbgPipeDup0: os.File = os.get_stderr()
        os.writeLine(fDbgPipeDup0, "[backend] stage1: uir_dups_pre")
        os.c_fflush fDbgPipeDup0
    let skipDupScan: bool = envIsTrue "BACKEND_STAGE1_DISABLE_DUP_SCAN"
    if skipDupScan:
        overloadedFnBasesPtr = nil
    else:
        overloadedFnBasesPtr = &overloadedFnBases
        overloadedFnBases = uirCoreComputeOverloadedFnBasesId(rootIdForDup)
        uirCoreDupFnBasesSet(uirCoreComputeDuplicateFnBasesId(rootIdForDup, &overloadedFnBases))
        uirCoreDupGlobalNamesSet(uirCoreComputeDuplicateGlobalNamesId(rootIdForDup))
    if dbgPipeCount:
        let fDbgPipeDup1: os.File = os.get_stderr()
        os.writeLine(fDbgPipeDup1, "[backend] stage1: uir_dups_post")
        # NOTE: keep this marker write lightweight; avoid extra libc flush here
        # while bisecting stage0 crash points on unstable runtimes.
    if dbgPipeCount:
        let fDbgPipeMark0: os.File = os.get_stderr()
        os.writeLine(fDbgPipeMark0, "[backend] stage1: uir_after_dups_mark_0")
        os.c_fflush fDbgPipeMark0
    # Stage0 bootstrap stability: skip this profile checkpoint.
    if dbgPipeCount:
        let fDbgPipeStage0: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage0, "[backend] stage1: uir_stage_after_dups")
        os.c_fflush fDbgPipeStage0
    if dbgPipeCount:
        let fDbgPipeMark1: os.File = os.get_stderr()
        os.writeLine(fDbgPipeMark1, "[backend] stage1: uir_after_dups_mark_1")
        os.c_fflush fDbgPipeMark1
    ctx.globalInitNames = []
    ctx.globalInitTypes = []
    ctx.globalInitObjTypeNames = []
    ctx.globalInitNodes = []
    ctx.globalInitFilePaths = []
    ctx.globalInitSeqFixedElemTypes = []
    ctx.globalInitSeqFixedCapExprs = []
    if dbgPipeCount:
        let fDbgPipeMark2: os.File = os.get_stderr()
        os.writeLine(fDbgPipeMark2, "[backend] stage1: uir_after_dups_mark_2")
        os.c_fflush fDbgPipeMark2
    if dbgPipeCount:
        let fDbgPipeStage1: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage1, "[backend] stage1: uir_stage_before_ensure_builtin_obj_types")
        os.c_fflush fDbgPipeStage1
    ensureBuiltinObjTypes(mod)
    if dbgPipeCount:
        let fDbgPipeStage2: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage2, "[backend] stage1: uir_stage_after_ensure_builtin_obj_types")
        os.c_fflush fDbgPipeStage2
    if (getEnv "BACKEND_DEBUG_TYPES" == "1"):
        let hs: str = uirCoreHasObjType(mod, "seq") ? "1" : "0"
        let ht: str = uirCoreHasObjType(mod, "Table") ? "1" : "0"
        echo("[backend] debug: builtin_obj_after_ensure seq=" + hs + " table=" + ht)
    if dbgPipeCount:
        let fDbgPipeStage3: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage3, "[backend] stage1: uir_stage_before_predeclare_globals_for_types")
        os.c_fflush fDbgPipeStage3
    uirCorePredeclareGlobalsForTypes(mod, root)
    if dbgPipeCount:
        let fDbgPipeStage4: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage4, "[backend] stage1: uir_stage_after_predeclare_globals_for_types")
        os.c_fflush fDbgPipeStage4
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: after_predeclare_globals_for_types")
        os.c_fflush os.get_stderr()
    uirCoreProfileStep(prof, "predeclare_globals_for_types")
    if dbgPipeCount:
        let fDbgPipeStage5: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage5, "[backend] stage1: uir_stage_before_consume_type_decls")
        os.c_fflush fDbgPipeStage5
    let tdRes: Result[bool] = uirCoreConsumeTypeDecls(mod, root)
    if ! uirCoreResultBoolIsOk(tdRes):
        return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(tdRes))
    if dbgPipeCount:
        let fDbgPipeStage6: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage6, "[backend] stage1: uir_stage_after_consume_type_decls")
        os.c_fflush fDbgPipeStage6
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: after_consume_type_decls")
        os.c_fflush os.get_stderr()
    uirCoreProfileStep(prof, "consume_type_decls")
    if dbgPipeCount:
        let fDbgPipeStage7: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage7, "[backend] stage1: uir_stage_before_predeclare_globals_for_lowering")
        os.c_fflush fDbgPipeStage7
    uirCorePredeclareGlobalsForLowering(mod, root)
    if dbgPipeCount:
        let fDbgPipeStage8: os.File = os.get_stderr()
        os.writeLine(fDbgPipeStage8, "[backend] stage1: uir_stage_after_predeclare_globals_for_lowering")
        os.c_fflush fDbgPipeStage8
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: after_predeclare_globals_for_lowering")
        os.c_fflush os.get_stderr()
    uirCoreProfileStep(prof, "predeclare_globals_for_lowering")
    var reachableStore: hashsets.HashSetStr = hashsets.hashSetStrInit(64)
    var reachablePtr: ptr = nil
    # Reachability pruning is correctness-sensitive for larger multi-package
    # programs (can under-approximate and drop needed symbols), so keep it
    # opt-in until closure proves complete on external workloads.
    let buildTrackReachRaw: str = backendStripSpaces(os.getEnvDefault("BACKEND_BUILD_TRACK", ""))
    let buildTrackReach: str = len(buildTrackReachRaw) > 0 ? buildTrackReachRaw : "dev"
    let reachableOverrideRaw: str = backendStripSpaces(os.getEnvDefault("BACKEND_STAGE1_REACHABLE", ""))
    var reachableEnabled: bool = false
    if buildTrackReach == "release":
        reachableEnabled = false
    if len(reachableOverrideRaw) > 0:
        reachableEnabled = uirCoreIsOne(reachableOverrideRaw)
    if reachableEnabled:
        reachableStore = uirCoreComputeReachableFnsId(mod, rootIdForDup)
        reachablePtr = &reachableStore
    if dbgPipeCount:
        let fDbgPipeReach0: os.File = os.get_stderr()
        os.writeLine(fDbgPipeReach0, "[backend] stage1: uir_stage_after_reachable")
        os.c_fflush fDbgPipeReach0
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: after_reachable")
        os.c_fflush os.get_stderr()
    uirCoreProfileStep(prof, "reachable")
    if dbgPipeCount:
        let fDbgPipePre0: os.File = os.get_stderr()
        os.writeLine(fDbgPipePre0, "[backend] stage1: uir_stage_before_predeclare_top_level")
        os.c_fflush fDbgPipePre0
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: before_predeclare_top_level")
        os.c_fflush os.get_stderr()
    # Predeclare function signatures so lowering can infer object returns across order boundaries.
    var lastFilePath: str = astNodeStrVal(rootIdForDup)
    let rootKidCount: int32 = astKidCount(rootIdForDup)
    if dbgPipeCount:
        let fDbgPipeRootCount: os.File = os.get_stderr()
        os.writeLine(fDbgPipeRootCount, "[backend] stage1: root_kid_count=" + intToStr(rootKidCount))
        os.c_fflush fDbgPipeRootCount
    for pi in 0..<astKidCount(rootIdForDup):
        let nId: AstNodeId = astKidAt(rootIdForDup, pi)
        let ownPath: str = astNodeStrVal(nId)
        if len(ownPath) > 0:
            lastFilePath = ownPath
        let filePath: str = (len(ownPath) > 0) ? ownPath : lastFilePath
        if dbgPipeCount:
            var prePipeName: str = ""
            let prePipeKind: NodeKind = astNodeKind(nId)
            if astKidCount(nId) > 0:
                let prePipeNameNodeId: AstNodeId = astKidAt(nId, 0)
                if astNodeIdValid(prePipeNameNodeId):
                    let prePipeNameKind: NodeKind = astNodeKind(prePipeNameNodeId)
                    if prePipeNameKind == nkIdent || prePipeNameKind == nkSymbol:
                        prePipeName = backendStripSpaces(astPlainName(prePipeNameNodeId))
            let fDbgPipePreItem: os.File = os.get_stderr()
            os.writeLine(fDbgPipePreItem, "[backend] stage1: predeclare_item idx=" + intToStr(pi + 1) + "/" + intToStr(rootKidCount) +
                                          " kind=nk#" + intToStr(int32(prePipeKind)) +
                                          " name=" + prePipeName +
                                          " file=" + filePath)
            os.c_fflush fDbgPipePreItem
        if ctx.traceEnabled:
            var preName: str = ""
            let preKind: NodeKind = astNodeKind(nId)
            if astKidCount(nId) > 0:
                let preNameNodeId: AstNodeId = astKidAt(nId, 0)
                if astNodeIdValid(preNameNodeId):
                    let preNameKind: NodeKind = astNodeKind(preNameNodeId)
                    if preNameKind == nkIdent || preNameKind == nkSymbol:
                        preName = backendStripSpaces(astPlainName(preNameNodeId))
            stage1Trace("backend: uir predeclare " + intToStr(pi + 1) + "/" + intToStr(rootKidCount) +
                        " file=" + filePath + " kind=nk#" + intToStr(int32(preKind)) +
                        " name=" + preName)
        let res: Result[bool] = uirCorePredeclareTopLevelFromRootId(mod, rootIdForDup, filePath, nId, reachablePtr, overloadedFnBasesPtr)
        if !uirCoreResultBoolIsOk(res):
            if (os.getEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1"):
                let infoPre: ErrorInfo = uirCoreResultBoolErrorInfo(res)
                let fDbgPre: os.File = os.get_stderr()
                os.writeLine(fDbgPre, "[backend] stage1: predeclare_fail idx=" + intToStr(pi + 1) +
                                      "/" + intToStr(rootKidCount) +
                                      " file='" + filePath + "' code=" + intToStr(ErrorCodeOf(infoPre)))
                os.c_fflush fDbgPre
            return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(res))
        if dbgPipeCount:
            let fDbgPipePreDone: os.File = os.get_stderr()
            os.writeLine(fDbgPipePreDone, uirCoreResultBoolValue(res) ? "[backend] stage1: predeclare_item_done=1" : "[backend] stage1: predeclare_item_done=0")
            os.writeLine(fDbgPipePreDone, "[backend] stage1: predeclare_item_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
            os.c_fflush fDbgPipePreDone
    uirCoreProfileStep(prof, "predeclare_top_level")
    if dbgPipeCount:
        let fDbgPipePre1: os.File = os.get_stderr()
        os.writeLine(fDbgPipePre1, "[backend] stage1: uir_stage_after_predeclare_top_level")
        os.c_fflush fDbgPipePre1
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: after_predeclare_top_level")
        os.c_fflush os.get_stderr()
    if dbgSummary:
        echo("[uir] predeclare funcs=" + intToStr(uirCoreModuleFuncsLen(mod)) +
             " globals=" + intToStr(uirCoreModuleGlobalsLen(mod)) +
             " cstrs=" + intToStr(uirCoreModuleCStringsLen(mod)))
    lastFilePath = astNodeStrVal(rootIdForDup)
    let fnTaskSnapshot: UirCoreSharedSnapshot = uirCoreBuildSharedSnapshot(mod)
    var fnTaskCount: int32 = 0
    if dbgPipeCount:
        let fDbgPipeLower0: os.File = os.get_stderr()
        os.writeLine(fDbgPipeLower0, "[backend] stage1: uir_stage_before_lower_top_level")
        os.c_fflush fDbgPipeLower0
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: before_lower_top_level")
        os.c_fflush os.get_stderr()
    for i in 0..<astKidCount(rootIdForDup):
        let nId: AstNodeId = astKidAt(rootIdForDup, i)
        if !astNodeIdValid(nId):
            continue
        let ownPath2: str = astNodeStrVal(nId)
        if len(ownPath2) > 0:
            lastFilePath = ownPath2
        let filePath: str = (len(ownPath2) > 0) ? ownPath2 : lastFilePath
        var nameDbg: str = ""
        var kindDbg: int32 = -1
        let nKind: NodeKind = astNodeKind(nId)
        kindDbg = int32(nKind)
        var nameDbgEligible: bool = false
        if nKind == nkFnDecl || nKind == nkIteratorDecl:
            nameDbgEligible = true
        elif nKind == nkTypeDecl || nKind == nkConceptDecl:
            nameDbgEligible = true
        elif nKind == nkTraitDecl:
            nameDbgEligible = true
        if nameDbgEligible:
            let nameKidCount: int32 = astKidCount(nId)
            if nameKidCount > 0:
                let nameNodeId: AstNodeId = astKidAt(nId, 0)
                if astNodeIdValid(nameNodeId):
                    let nameNodeKind: NodeKind = astNodeKind(nameNodeId)
                    if nameNodeKind == nkIdent || nameNodeKind == nkSymbol:
                        let namePlain: str = astPlainName(nameNodeId)
                        nameDbg = backendStripSpaces(namePlain)
        if dbgLower:
            let fDbg: os.File = os.get_stderr()
            os.write(fDbg, "uirCore_lower_dbg\t")
            os.write(fDbg, intToStr(i + 1))
            os.write(fDbg, "/")
            os.write(fDbg, intToStr(rootKidCount))
            os.write(fDbg, "\tfile=")
            os.write(fDbg, filePath)
            os.write(fDbg, "\tkind=nk#")
            os.write(fDbg, intToStr(kindDbg))
            if len(nameDbg) > 0:
                os.write(fDbg, "\tname=")
                os.write(fDbg, nameDbg)
            os.writeLine(fDbg, "")
            os.c_fflush fDbg
        if ctx.traceEnabled:
            var traceLineParts: str[]
            add(traceLineParts, "backend: uir lower ")
            add(traceLineParts, intToStr(i + 1))
            add(traceLineParts, "/")
            add(traceLineParts, intToStr(rootKidCount))
            add(traceLineParts, " file=")
            add(traceLineParts, filePath)
            if len(nameDbg) > 0:
                add(traceLineParts, " name=")
                add(traceLineParts, nameDbg)
            stage1Trace(fmt(traceLineParts))
        if dbgPipeCount:
            let fDbgPipeLowerItem: os.File = os.get_stderr()
            os.writeLine(fDbgPipeLowerItem, "[backend] stage1: lower_item idx=" + intToStr(i + 1) + "/" + intToStr(rootKidCount) +
                                           " kind=nk#" + intToStr(kindDbg) +
                                           " name=" + nameDbg +
                                           " file=" + filePath)
            os.c_fflush fDbgPipeLowerItem
        if nKind == nkFnDecl || nKind == nkIteratorDecl:
            let taskRes: Result[UirFnTask] = uirCorePrepareTopLevelRoutineTaskFromRootId(
                mod, rootIdForDup, filePath, nId, i, reachablePtr)
            if !IsOk[UirFnTask](taskRes):
                return ErrInfo[UirCoreModule](ErrorInfoOf[UirFnTask](taskRes))
            let task: UirFnTask = taskRes.value
            if task == nil:
                if dbgPipeCount:
                    let fDbgPipeFnSkip: os.File = os.get_stderr()
                    os.writeLine(fDbgPipeFnSkip, "[backend] stage1: lower_item_done=0")
                    os.writeLine(fDbgPipeFnSkip, "[backend] stage1: lower_item_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
                    os.writeLine(fDbgPipeFnSkip, (ctx.foundMain ? "[backend] stage1: lower_item_found_main=1" : "[backend] stage1: lower_item_found_main=0"))
                    os.c_fflush fDbgPipeFnSkip
                if ctx.traceEnabled:
                    var doneLineSkipParts: str[]
                    add(doneLineSkipParts, "backend: uir lower done ")
                    add(doneLineSkipParts, intToStr(i + 1))
                    add(doneLineSkipParts, "/")
                    add(doneLineSkipParts, intToStr(rootKidCount))
                    add(doneLineSkipParts, " file=")
                    add(doneLineSkipParts, filePath)
                    if len(nameDbg) > 0:
                        add(doneLineSkipParts, " name=")
                        add(doneLineSkipParts, nameDbg)
                    stage1Trace(fmt(doneLineSkipParts))
                if dbgLower:
                    let fDbgDoneSkip: os.File = os.get_stderr()
                    os.write(fDbgDoneSkip, "uirCore_lower_done\t")
                    os.write(fDbgDoneSkip, intToStr(i + 1))
                    os.write(fDbgDoneSkip, "/")
                    os.write(fDbgDoneSkip, intToStr(rootKidCount))
                    os.writeLine(fDbgDoneSkip, "")
                    os.c_fflush fDbgDoneSkip
            else:
                fnTaskCount = fnTaskCount + 1
                let taskIdx: int32 = task.taskOrdinal + 1
                let taskKind: NodeKind = astNodeKind(task.funcNode)
                let taskKindDbg: int32 = int32(taskKind)
                let taskName: str = task.routineName
                let taskFile: str = task.originFile
                let taskExecRes: Result[UirFnTaskResult] =
                    uirCoreExecuteFnTask(mod, task, overloadedFnBasesPtr, fnTaskSnapshot)
                if !IsOk[UirFnTaskResult](taskExecRes):
                    let taskInfo: ErrorInfo = ErrorInfoOf[UirFnTaskResult](taskExecRes)
                    let fallbackMsgTask: str =
                        IsError(taskInfo) ? ErrorFormat(taskInfo) : "uirCore_builder: fn task failed"
                    os.writeLine(os.get_stderr(), fallbackMsgTask)
                    os.c_fflush os.get_stderr()
                    return ErrInfo[UirCoreModule](taskInfo)
                let taskMergeRes: Result[bool] = uirCoreMergeFnTaskResult(mod, ctx, taskExecRes.value)
                if !IsOk[bool](taskMergeRes):
                    let mergeInfo: ErrorInfo = uirCoreResultBoolErrorInfo(taskMergeRes)
                    let fallbackMsgMerge: str =
                        IsError(mergeInfo) ? ErrorFormat(mergeInfo) : "uirCore_builder: fn task merge failed"
                    os.writeLine(os.get_stderr(), fallbackMsgMerge)
                    os.c_fflush os.get_stderr()
                    return ErrInfo[UirCoreModule](mergeInfo)
                if dbgPipeCount:
                    let fDbgPipeFnTaskDone: os.File = os.get_stderr()
                    os.writeLine(fDbgPipeFnTaskDone, uirCoreResultBoolValue(taskMergeRes) ? "[backend] stage1: lower_item_done=1" : "[backend] stage1: lower_item_done=0")
                    os.writeLine(fDbgPipeFnTaskDone, "[backend] stage1: lower_item_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
                    os.writeLine(fDbgPipeFnTaskDone, (ctx.foundMain ? "[backend] stage1: lower_item_found_main=1" : "[backend] stage1: lower_item_found_main=0"))
                    os.c_fflush fDbgPipeFnTaskDone
                if ctx.traceEnabled:
                    var doneLineTaskParts: str[]
                    add(doneLineTaskParts, "backend: uir lower done ")
                    add(doneLineTaskParts, intToStr(taskIdx))
                    add(doneLineTaskParts, "/")
                    add(doneLineTaskParts, intToStr(rootKidCount))
                    add(doneLineTaskParts, " file=")
                    add(doneLineTaskParts, taskFile)
                    if len(taskName) > 0:
                        add(doneLineTaskParts, " name=")
                        add(doneLineTaskParts, taskName)
                    stage1Trace(fmt(doneLineTaskParts))
                if dbgLower:
                    let fDbgDoneTask: os.File = os.get_stderr()
                    os.write(fDbgDoneTask, "uirCore_lower_done\t")
                    os.write(fDbgDoneTask, intToStr(taskIdx))
                    os.write(fDbgDoneTask, "/")
                    os.write(fDbgDoneTask, intToStr(rootKidCount))
                    os.writeLine(fDbgDoneTask, "")
                    os.c_fflush fDbgDoneTask
            continue
        let res: Result[bool] = uirCoreConsumeTopLevelFromRootId(mod, ctx, rootIdForDup, filePath, nId, reachablePtr, overloadedFnBasesPtr)
        if ! uirCoreResultBoolIsOk(res):
            # Stage0/strict selfhost hardening: some failing builder paths still
            # materialize a corrupted ErrorInfo.msg, and formatting it can segfault
            # before we print the real failing top-level location.
            let fallbackMsg0: str = "uirCore_builder: lower top-level failed"
            os.writeLine(os.get_stderr(), fallbackMsg0)
            os.c_fflush os.get_stderr()
            return Err[UirCoreModule](fallbackMsg0)
        if dbgPipeCount:
            let fDbgPipeLowerDone: os.File = os.get_stderr()
            os.writeLine(fDbgPipeLowerDone, uirCoreResultBoolValue(res) ? "[backend] stage1: lower_item_done=1" : "[backend] stage1: lower_item_done=0")
            os.writeLine(fDbgPipeLowerDone, "[backend] stage1: lower_item_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
            os.writeLine(fDbgPipeLowerDone, (ctx.foundMain ? "[backend] stage1: lower_item_found_main=1" : "[backend] stage1: lower_item_found_main=0"))
            os.c_fflush fDbgPipeLowerDone
        if ctx.traceEnabled:
            var doneLineParts: str[]
            add(doneLineParts, "backend: uir lower done ")
            add(doneLineParts, intToStr(i + 1))
            add(doneLineParts, "/")
            add(doneLineParts, intToStr(rootKidCount))
            add(doneLineParts, " file=")
            add(doneLineParts, filePath)
            if len(nameDbg) > 0:
                add(doneLineParts, " name=")
                add(doneLineParts, nameDbg)
            stage1Trace(fmt(doneLineParts))
        if dbgLower:
            let fDbgDone: os.File = os.get_stderr()
            os.write(fDbgDone, "uirCore_lower_done\t")
            os.write(fDbgDone, intToStr(i + 1))
            os.write(fDbgDone, "/")
            os.write(fDbgDone, intToStr(rootKidCount))
            os.writeLine(fDbgDone, "")
            os.c_fflush fDbgDone
    uirCoreProfileStep(prof, "lower_top_level")
    if dbgPipeCount:
        let fDbgPipeLower1: os.File = os.get_stderr()
        os.writeLine(fDbgPipeLower1, "[backend] stage1: uir_stage_after_lower_top_level")
        os.c_fflush fDbgPipeLower1
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: after_lower_top_level")
        os.c_fflush os.get_stderr()
    if dbgPipeCount:
        let fDbgFnTasks0: os.File = os.get_stderr()
        os.writeLine(fDbgFnTasks0, "[backend] stage1: fn_task_count=" + intToStr(fnTaskCount))
        os.c_fflush fDbgFnTasks0
    uirCoreProfileStep(prof, "fn_tasks")
    if !ctx.foundMain:
        for fiMain in 0..<uirCoreModuleFuncsLen(mod):
            let fMain: UirCoreFunc = uirCoreModuleFuncAt(mod, fiMain)
            if fMain == nil:
                continue
            let fnNameMain: str = uirCoreFuncNameOf(fMain)
            let linkNameMain: str = uirCoreFuncLinkNameOf(fMain)
            if fnNameMain == "main" || linkNameMain == "main" || linkNameMain == "_main":
                ctx.foundMain = true
                break
    if dbgSummary:
        echo("[uir] lower funcs=" + intToStr(uirCoreModuleFuncsLen(mod)) +
             " globals=" + intToStr(uirCoreModuleGlobalsLen(mod)) +
             " cstrs=" + intToStr(uirCoreModuleCStringsLen(mod)))
    if ctx.traceEnabled:
        stage1Trace("backend: uir lower done funcs=" + intToStr(ctx.traceFnCount) +
            " globals=" + intToStr(ctx.traceGlobalCount) + " inits=" + intToStr(ctx.globalInitNames.len))
    let allowNoMain: bool = envIsTrue "BACKEND_ALLOW_NO_MAIN" || backendAllowNoMainByEmit()
    if dbgPipeCount:
        let fDbgMainGate0: os.File = os.get_stderr()
        os.writeLine(fDbgMainGate0, ctx.foundMain ? "[backend] stage1: found_main=1" : "[backend] stage1: found_main=0")
        os.writeLine(fDbgMainGate0, allowNoMain ? "[backend] stage1: allow_no_main=1" : "[backend] stage1: allow_no_main=0")
        os.c_fflush fDbgMainGate0
    if ! ctx.foundMain && !allowNoMain:
        return Err[UirCoreModule]("uirCore_builder: main not found")
    let noMainInitRes: Result[bool] = uirCoreRejectNoMainGlobalInit(ctx, allowNoMain)
    if dbgPipeCount:
        let fDbgMainGate1: os.File = os.get_stderr()
        os.writeLine(fDbgMainGate1, uirCoreResultBoolIsOk(noMainInitRes) ? "[backend] stage1: no_main_init_ok" : "[backend] stage1: no_main_init_err")
        os.c_fflush fDbgMainGate1
    if !uirCoreResultBoolIsOk(noMainInitRes):
        return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(noMainInitRes))

    if ctx.globalInitNames.len > 0 && !backendSkipGlobalInit():
        if ctx.traceEnabled:
            stage1Trace("backend: uir global_init build start")
        var initFunc: UirCoreFunc = nil
        let initRes: Result[bool] = uirCoreBuildGlobalInitFunc(mod, ctx, initFunc)
        if !uirCoreResultBoolIsOk(initRes):
            return ErrInfo[UirCoreModule](uirCoreResultBoolErrorInfo(initRes))
        if initFunc == nil:
            return Err[UirCoreModule]("uirCore_builder: global init builder returned nil")
        uirCoreAddFunc(mod, initFunc)
        if ctx.foundMain:
            uirCoreInjectGlobalInitCall(mod, "__cheng_global_init")
        if ctx.traceEnabled:
            stage1Trace("backend: uir global_init build done")
    if !envIsTrue "BACKEND_STAGE1_SKIP_PROFILE_GLOBAL_INIT_STEP":
        uirCoreProfileStep(prof, "global_init")
    let fineProfile: bool = envIsTrue "BACKEND_PROFILE_FINE"
    if fineProfile:
        uirCoreProfileStep(prof, "post_global_init")
    if dbgPipeCount:
        let fDbgAfterGlobalInit: os.File = os.get_stderr()
        os.writeLine(fDbgAfterGlobalInit, "[backend] stage1: after_global_init_profile")
        os.c_fflush fDbgAfterGlobalInit
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: after_global_init")
        os.c_fflush os.get_stderr()
    if fineProfile:
        uirCoreProfileStep(prof, "post_global_init_dbgpipe")
    if dbgSummary:
        echo("[uir] global_init funcs=" + intToStr(uirCoreModuleFuncsLen(mod)) +
             " globals=" + intToStr(uirCoreModuleGlobalsLen(mod)) +
             " cstrs=" + intToStr(uirCoreModuleCStringsLen(mod)))
    if fineProfile:
        uirCoreProfileStep(prof, "post_global_init_summary")

    let skipFixups: bool = envIsTrue "BACKEND_SKIP_UIR_FIXUPS"
    if dbgPipeCount:
        let fDbgFixPhase0: os.File = os.get_stderr()
        os.writeLine(fDbgFixPhase0, "[backend] stage1: fixups_phase_enter0")
        os.c_fflush fDbgFixPhase0
    if ctx.traceEnabled:
        if !skipFixups:
            stage1Trace("backend: uir fixups start")
        else:
            stage1Trace("backend: uir fixups skipped")
    if dbgPipeCount:
        let fDbgFixPhase1: os.File = os.get_stderr()
        os.writeLine(fDbgFixPhase1, "[backend] stage1: fixups_phase_enter1_after_trace")
        os.c_fflush fDbgFixPhase1
    # Stage0 crash hardening: skip profiling in fixups window.
    if dbgPipeCount:
        let fDbgFixPhase2: os.File = os.get_stderr()
        os.writeLine(fDbgFixPhase2, "[backend] stage1: fixups_phase_enter2_after_pre_profile")
        os.c_fflush fDbgFixPhase2
    if dbgPipeCount:
        let fDbgFix0: os.File = os.get_stderr()
        os.writeLine(fDbgFix0, "[backend] stage1: fixups_call_pre")
        os.c_fflush fDbgFix0
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: before_fixups")
        os.c_fflush os.get_stderr()
    # Stage0 crash hardening: skip profiling in fixups window.
    var fixErr: str = ""
    var fixOk: bool = true
    if !skipFixups:
        fixOk = uirCoreBuildMissingRoutinesFromUirId(mod, rootIdForDup, overloadedFnBasesPtr, nil)
    if dbgPipeCount:
        let fDbgFix1: os.File = os.get_stderr()
        os.writeLine(fDbgFix1, "[backend] stage1: fixups_call_post_v2")
        os.writeLine(fDbgFix1, "[backend] stage1: fixups_skip_value=" + (skipFixups ? "1" : "0"))
        if skipFixups:
            os.writeLine(fDbgFix1, "[backend] stage1: fixups_skipped_env=1")
        os.c_fflush fDbgFix1
    if !fixOk:
        if dbgPipeCount:
            let fDbgFixErr: os.File = os.get_stderr()
            os.writeLine(fDbgFixErr, "[backend] stage1: fixups_result_err")
            os.c_fflush fDbgFixErr
        if len(fixErr) == 0:
            fixErr = "uirCore_builder: fixups failed"
        return Err[UirCoreModule](fixErr)
    if dbgPipeCount:
        let fDbgFixOk: os.File = os.get_stderr()
        os.writeLine(fDbgFixOk, "[backend] stage1: fixups_result_ok")
        os.c_fflush fDbgFixOk
    if dbgConst:
        os.writeLine(os.get_stderr(), "[backend] const: after_fixups")
        os.c_fflush os.get_stderr()
    let skipNormalize: bool = envIsTrue "BACKEND_SKIP_UIR_NORMALIZE"
    if ctx.traceEnabled:
        if !skipFixups:
            stage1Trace("backend: uir fixups done")
        if !skipNormalize:
            stage1Trace("backend: uir normalize start")
        else:
            stage1Trace("backend: uir normalize skipped")
    if dbgPipeCount:
        let fDbgFixProf0: os.File = os.get_stderr()
        os.writeLine(fDbgFixProf0, "[backend] stage1: fixups_profile_pre")
        os.c_fflush fDbgFixProf0
    # Stage0 crash hardening: skip fixups profile step.
    if dbgPipeCount:
        let fDbgFixProf1: os.File = os.get_stderr()
        os.writeLine(fDbgFixProf1, "[backend] stage1: fixups_profile_post")
        os.c_fflush fDbgFixProf1
    if dbgSummary:
        echo("[uir] fixups funcs=" + intToStr(uirCoreModuleFuncsLen(mod)) +
             " globals=" + intToStr(uirCoreModuleGlobalsLen(mod)) +
             " cstrs=" + intToStr(uirCoreModuleCStringsLen(mod)))
    if dbgPipeCount:
        let fDbgNorm0: os.File = os.get_stderr()
        os.writeLine(fDbgNorm0, "[backend] stage1: normalize_skip_value=" + (skipNormalize ? "1" : "0"))
        os.c_fflush fDbgNorm0
    if !skipNormalize:
        if dbgPipeCount:
            let fDbgNorm1: os.File = os.get_stderr()
            os.writeLine(fDbgNorm1, "[backend] stage1: normalize_pre")
            os.c_fflush fDbgNorm1
        if dbgConst:
            os.writeLine(os.get_stderr(), "[backend] const: before_normalize")
            os.c_fflush os.get_stderr()
        uirCoreApplyUirPluginHooks(effectiveRootTag, mod)
        if dbgPipeCount:
            let fDbgNorm2: os.File = os.get_stderr()
            os.writeLine(fDbgNorm2, "[backend] stage1: normalize_hooks_post")
            os.c_fflush fDbgNorm2
        uirCoreNormalizeModule(mod)
        if dbgPipeCount:
            let fDbgNorm3: os.File = os.get_stderr()
            os.writeLine(fDbgNorm3, "[backend] stage1: normalize_post")
            os.c_fflush fDbgNorm3
        if dbgConst:
            os.writeLine(os.get_stderr(), "[backend] const: after_normalize")
            os.c_fflush os.get_stderr()
    if dbgSummary:
        echo("[uir] normalize funcs=" + intToStr(uirCoreModuleFuncsLen(mod)) +
             " globals=" + intToStr(uirCoreModuleGlobalsLen(mod)) +
             " cstrs=" + intToStr(uirCoreModuleCStringsLen(mod)))
    if ctx.traceEnabled && !skipNormalize:
        stage1Trace("backend: uir normalize done")
    uirCoreProfileStep(prof, "normalize")
    # Optional memory-pressure release for selfhost bootstrap bring-up.
    # Keep default off because some stage0/compat combinations still depend on
    # arena-backed string lifetimes during downstream codegen.
    if envIsTrue "STAGE1_RELEASE_ARENA_AFTER_BUILD":
        releaseNodeArena()
        releaseLexStrings()
    if envIsTrue "BACKEND_DEBUG_BOOT":
        var mainFoundAtEnd: bool = false
        for fiEnd in 0..<uirCoreModuleFuncsLen(mod):
            let fEnd: UirCoreFunc = uirCoreModuleFuncAt(mod, fiEnd)
            if fEnd == nil:
                continue
            let fnNameEnd: str = uirCoreFuncNameOf(fEnd)
            let linkNameEnd: str = uirCoreFuncLinkNameOf(fEnd)
            if fnNameEnd == "main" || fnNameEnd == "backendMain" ||
               linkNameEnd == "main" || linkNameEnd == "_main":
                echo("[backend] module_end main_candidate idx=" + intToStr(fiEnd) +
                     " name=" + fnNameEnd +
                     " link=" + linkNameEnd +
                     " blocks=" + intToStr(uirCoreFuncBlocksLen(fEnd)) +
                     " extern=" + (uirCoreFuncIsExtern(fEnd) ? "1" : "0"))
                mainFoundAtEnd = true
                break
        if !mainFoundAtEnd:
            echo("[backend] module_end main_candidate=missing funcs=" +
                 intToStr(uirCoreModuleFuncsLen(mod)))
    return uirCoreOkModule(mod)

fn uirCoreBuildModuleFromRoot(rootInput: Node): Result[UirCoreModule] =
    if (rootInput == nil):
        return Err[UirCoreModule]("uirCore_builder: empty root")
    let rootInputId: AstNodeId = rootInput
    return uirCoreBuildModuleFromRootId(rootInputId, astNodeStrVal(rootInputId), "")

fn uirCoreBuildModuleFromFileStage1(inPath: str, target: str = ""): Result[UirCoreModule] =
    if len(inPath) == 0:
        return Err[UirCoreModule]("uirCore_builder: empty path")
    crashTraceSetPhase(cstring("uir.file"))
    if crashTraceEnabled():
        crashTraceMark(cstring("uir.file"), len(inPath), len(target), 0, 0)
    if false && os.getEnvDefault("BACKEND_DEBUG_INPUT_PATH", "") == "1":
        let b0: int32 = len(inPath) > 0 ? int32(inPath[0]) : -1
        echo("[backend] stage1 input_path='" + inPath + "' len=" + intToStr(len(inPath)) +
             " b0=" + intToStr(b0))
    let dbgPipe: bool = false
    let dbgConstFile: bool = false
    var dbgFile: os.File = nil
    if dbgPipe:
        dbgFile = os.get_stderr()
        os.writeLine(dbgFile, "[backend] stage1: enter")
        os.c_fflush dbgFile
    if dbgConstFile:
        os.writeLine(os.get_stderr(), "[backend] const: file_enter")
        os.c_fflush os.get_stderr()
    # Keep node/lex pools alive for MIR/codegen string ownership.
    releaseNodeArena()
    releaseLexStrings()
    initNodeArena()
    initLexStringPool()
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: pools_ready")
        os.c_fflush dbgFile

    var eagerContent: str = ""
    let eagerReadOk: bool = frontend_lib.stage1_readFileInto(inPath, &eagerContent)
    if !eagerReadOk && len(eagerContent) == 0:
        return Err[UirCoreModule]("uirCore_builder: input file not found")
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: file_exists_ok")
        os.c_fflush dbgFile

    let profOn: bool = envIsTrue "STAGE1_PROFILE"
    var profStart: int64 = 0
    if profOn:
        profStart = cheng_monotime_ns()
    var profMark: int64 = 0
    var profLex: int64 = 0
    var profLoad: int64 = 0
    var profOutlineParse: int64 = 0
    var profMaterializeBodies: int64 = 0
    var profMergeModule: int64 = 0
    var profFnTasks: int64 = 0
    var profSem: int64 = 0
    var profMono: int64 = 0
    var profOwn: int64 = 0

    if profOn:
        profMark = cheng_monotime_ns()
    # Avoid unconditional string concat during bootstrap (stage0-built stage1 can miscompile
    # large init-time concatenations and crash before any diagnostics).
    stage1Trace "internal: lex+parse"
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: lex_parse_start")
        os.c_fflush dbgFile
    let size: int64 = fileSize inPath
    let mtime: int64 = fileMtime inPath
    let effectiveSize: int64 = (size > 0 || len(eagerContent) == 0) ? size : int64(len(eagerContent))
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: file_meta_ok")
        os.writeLine(dbgFile, (effectiveSize > 0) ? "[backend] stage1: file_size_nonzero" : "[backend] stage1: file_size_zero")
        os.c_fflush dbgFile
    var tokens: Token[]
    var lexDiags: Diagnostic[]
    lexDiags.buffer = nil
    lexDiags.len = 0
    lexDiags.cap = 0
    let cacheHit: bool = loadTokenCacheInto(inPath, effectiveSize, mtime, &tokens)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: token_cache_checked")
        os.c_fflush dbgFile
    if cacheHit:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: token_cache_hit")
            os.c_fflush dbgFile
    else:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: token_cache_miss")
            os.c_fflush dbgFile
        if len(eagerContent) == 0:
            let _readOk: bool = frontend_lib.stage1_readFileInto(inPath, &eagerContent)
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: file_read_done")
            os.writeLine(dbgFile, (len(eagerContent) > 0) ? "[backend] stage1: file_read_nonempty" : "[backend] stage1: file_read_empty")
            os.c_fflush dbgFile
        if len(eagerContent) == 0:
            return Err[UirCoreModule]("uirCore_builder: unable to read input file")
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: lex_start")
            os.c_fflush dbgFile
        var lexResTokens: Token[] = []
        var lexResDiags: Diagnostic[] = []
        let _lexOk: bool = lexInto(eagerContent, inPath, &lexResTokens, &lexResDiags)
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: lex_done")
            os.c_fflush dbgFile
        releaseString eagerContent
        tokens = lexResTokens
        lexDiags = lexResDiags
    var diags: Diagnostic[]
    diags.buffer = nil
    diags.len = 0
    diags.cap = 16
    if lexDiags.len > 0:
        appendDiagnostics(&diags, lexDiags)
    else:
        if ! cacheHit:
            writeTokenCache(inPath, size, mtime, tokens)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: token_count=" + intToStr(tokens.len))
        os.c_fflush dbgFile
    dumpTokens(inPath, tokens)
    let parseMode: str = uirCoreStage1ParseModeNormalized()
    let outlineMode: bool = parseMode == "outline"
    if outlineMode:
        stage1Trace "internal: outline_parse"
    let outlineParseStart: int64 = profOn ? cheng_monotime_ns() : int64(0)
    var userRootId: AstNodeId = astInvalidNodeId()
    if outlineMode:
        userRootId = parseModuleOutlineWithDiagnosticsId(tokens, inPath, &diags)
    else:
        userRootId = parseModuleWithDiagnosticsId(tokens, inPath, &diags)
    var userRoot: Node = userRootId
    if profOn:
        profOutlineParse = cheng_monotime_ns() - outlineParseStart
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: parsed_user_module")
        os.writeLine(dbgFile, "[backend] stage1: parse_mode=" + parseMode)
        os.writeLine(dbgFile, "[backend] stage1: user_root_kids=" + intToStr(astKidCount(userRootId)))
        os.c_fflush dbgFile
    uirCoreDebugDumpStringLiteralStage("post_parse_user", userRootId)

    if (userRoot != nil):
        let inPathTag: str = normalizeImportPath inPath
        if envIsTrue "STAGE1_TRACE_IMPORTS":
            stage1Trace("import: inPathTag=" + inPathTag)
            stage1Trace("import: repoRoot=" + os.getCurrentDir())
        var tagPath: str = inPath
        if len inPathTag > 0:
            tagPath = inPathTag
        if len inPathTag > 0:
            nodeSetStrVal(userRoot, inPathTag)
        tagModuleChildrenId(userRootId, tagPath)

    if profOn:
        profLex = cheng_monotime_ns() - profMark
        profMark = cheng_monotime_ns()

    stage1Trace "internal: load system/imports"
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: imports_start")
        os.c_fflush dbgFile
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: imports_repo_root_start")
        os.c_fflush dbgFile
    var repoRoot: str = uirCoreResolveRepoRoot(inPath)
    if len(repoRoot) == 0:
        repoRoot = "."
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: imports_repo_root_done")
        os.c_fflush dbgFile
    var importVisited: StrSetList = strSetListInit(16)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: imports_visited_init_done")
        os.c_fflush dbgFile
    var importCache: NodeCache = nodeCacheInit(128)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: imports_cache_init_done")
        os.c_fflush dbgFile
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: load_system_module_start")
        os.c_fflush dbgFile
    var sysRootId: AstNodeId = loadSystemModuleId(inPath, &diags)
    var sysRoot: Node = sysRootId
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: load_system_module_done")
        os.writeLine(dbgFile, "[backend] stage1: sys_root_kids=" + intToStr(astKidCount(sysRootId)))
        os.c_fflush dbgFile
    if (sysRoot != nil):
        let sysResolved: str = resolveImportPath("system", "", repoRoot)
        if len sysResolved > 0:
            let sysCanon: str = canonicalizeResolvedPath(sysResolved, repoRoot)
            var sysTag: str = sysResolved
            if len sysCanon > 0:
                sysTag = sysCanon
            setAddStr(&importVisited, sysTag)
            tagModuleChildrenId(sysRootId, sysTag)
        else:
            tagModuleChildrenId(sysRootId, "src/std/system.cheng")
        var sysAliases: str[]
        sysAliases.buffer = nil
        sysAliases.len = 0
        sysAliases.cap = 8
        collectImportAliasesId(sysRootId, &sysAliases)
        if sysAliases.len > 0:
            sysRootId = lowerModuleQualifiersId(sysRootId, sysAliases)
            sysRoot = sysRootId
        let sysImported: AstNodeId[] = loadImportsId(sysRoot, "src/std", repoRoot, &diags, &importVisited,
            &importCache)
        for si in 0..<sysImported.len:
            addSon(sysRoot, sysImported[si])

    stage1Trace "internal: merge_module"
    let mergeStart: int64 = profOn ? cheng_monotime_ns() : int64(0)
    var root0Id: AstNodeId = astInvalidNodeId()
    if (userRoot == nil):
        root0Id = mergeModulesId(sysRoot, userRootId)
    else:
        let userDir: str = uirCorePathDirName(inPath)
        let imported: AstNodeId[] = loadImportsId(userRootId, userDir, repoRoot, &diags, &importVisited, &importCache)
        var aliases: str[]
        aliases.buffer = nil
        aliases.len = 0
        aliases.cap = 8
        collectImportAliasesId(userRootId, &aliases)
        if aliases.len > 0:
            userRootId = lowerModuleQualifiersId(userRootId, aliases)
            userRoot = userRootId
        root0Id = astNewNodeId(nkModule, astNodePos(userRootId))
        astSetNodeStrVal(root0Id, astNodeStrVal(userRootId))
        astSetNodeIdent(root0Id, astNodeIdent(userRootId))
        if (sysRoot != nil):
            for sj in 0..<kidCount sysRoot:
                astAddKid(root0Id, kid(sysRoot, sj))
        for ii in 0..<imported.len:
            astAddKid(root0Id, imported[ii])
        for ui in 0..<astKidCount(userRootId):
            astAddKid(root0Id, astKidAt(userRootId, ui))
    var root0: Node = root0Id
    if dbgPipe:
        os.write(dbgFile, "[backend] stage1: merged_root_kids=")
        os.write(dbgFile, intToStr(astKidCount(root0Id)))
        os.write(dbgFile, "\n")
        os.c_fflush dbgFile
    if profOn:
        profMergeModule = cheng_monotime_ns() - mergeStart

    if outlineMode && (userRoot != nil):
        stage1Trace "internal: materialize_bodies"
        let materializeStart: int64 = profOn ? cheng_monotime_ns() : int64(0)
        let _materializedUserFns: int32 = materializeModuleRoutineBodiesFromTokensId(tokens, inPath, userRootId, &diags)
        if profOn:
            profMaterializeBodies = cheng_monotime_ns() - materializeStart
        uirCoreDebugDumpStringLiteralStage("post_materialize_user", userRootId)

    tokens = []
    lexDiags = []
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: imports_done")
        os.c_fflush dbgFile

    if profOn:
        profLoad = cheng_monotime_ns() - profMark
        profMark = cheng_monotime_ns()

    if uirCoreStage1StdNoPointerPrecheckId(root0Id, inPath, diags):
        if hasError diags:
            printDiagnostics diags
        else:
            echo rawPointerForbidMessage("std policy: pointer types are forbidden in standard library")
        return Err[UirCoreModule]("uirCore_builder: stage1 errors")
    if uirCoreStage1NoPointerNonCAbiPrecheckId(root0Id, inPath, diags):
        if hasError diags:
            printDiagnostics diags
        else:
            echo rawPointerForbidMessage("no-pointer policy: pointer types are forbidden in user modules")
        return Err[UirCoreModule]("uirCore_builder: stage1 errors")
    if uirCoreFileLikelyUsesRawSpawn(inPath):
        echo "spawn raw function pointer is forbidden in default API; use std/async_rt_legacy.spawn"
        return Err[UirCoreModule]("uirCore_builder: stage1 errors")
    type_syntax_lowering.lowerTypeSyntaxId(root0Id, &diags, inPath)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: type_syntax_done")
        os.c_fflush dbgFile

    let ffiOutPtrLowered: bool = uirCoreLowerFfiOutPtrAnnotationsId(root0Id, &diags)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: ffi_out_ptrs_lowered=" + (ffiOutPtrLowered ? "1" : "0"))
        os.c_fflush dbgFile
    if hasError diags:
        printDiagnostics diags
        return Err[UirCoreModule]("uirCore_builder: stage1 ffi_out_ptrs lowering failed")
    let ffiShadowOk: bool = uirCoreValidateFfiShadowAnnotationsId(root0Id, &diags)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: ffi_shadow_annotations_ok=" + (ffiShadowOk ? "1" : "0"))
        os.c_fflush dbgFile
    if !ffiShadowOk || hasError(diags):
        printDiagnostics(diags)
        return Err[UirCoreModule]("uirCore_builder: stage1 ffi shadow annotation validation failed")

    let mm0: str = memMode()
    let strictOn0: bool = orcStrictEnabled()
    let ownDiags: bool = ownershipDiagnosticsEnabled()
    let borrowIrMode: str = uirCoreBorrowIrNormalized()
    let genericLoweringMode: str = uirCoreGenericLoweringNormalized()
    if !uirCoreBorrowIrSupported(borrowIrMode):
        return Err[UirCoreModule]("uirCore_builder: invalid BORROW_IR (expected mir|stage1): " + borrowIrMode)
    if !uirCoreGenericLoweringSupported(genericLoweringMode):
        return Err[UirCoreModule]("uirCore_builder: invalid GENERIC_LOWERING (expected mir_dict): " + genericLoweringMode)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: borrow_ir=" + borrowIrMode)
        os.writeLine(dbgFile, "[backend] stage1: generic_lowering=" + genericLoweringMode)
        os.c_fflush dbgFile
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: pre_env_trace_flag_eval_start")
        os.c_fflush dbgFile
    let traceImports: bool = envIsTrue "STAGE1_TRACE_IMPORTS"
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: pre_env_trace_flag_eval_done value=" + (traceImports ? "1" : "0"))
        os.c_fflush dbgFile
    if traceImports:
        stage1Trace("import: mm=" + mm0)
        stage1Trace("import: mm_strict=" + (strictOn0 ? "1" : "0"))
        stage1Trace("import: own_diags=" + (ownDiags ? "1" : "0"))
        stage1Trace("import: borrow_ir=" + borrowIrMode)
        stage1Trace("import: generic_lowering=" + genericLoweringMode)
    let removedSkipSemRaw: str = strutil.strip(os.getEnvDefault("STAGE1_SKIP_SEM", ""))
    if len(removedSkipSemRaw) > 0:
        return Err[UirCoreModule]("backend_driver: removed env STAGE1_SKIP_SEM, use STAGE1_SEM_FIXED_0=0")
    let removedSkipOwnershipRaw: str = strutil.strip(os.getEnvDefault("STAGE1_SKIP_OWNERSHIP", ""))
    if len(removedSkipOwnershipRaw) > 0:
        return Err[UirCoreModule]("backend_driver: removed env STAGE1_SKIP_OWNERSHIP, use STAGE1_OWNERSHIP_FIXED_0=0")
    let fixedSemRaw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("STAGE1_SEM_FIXED_0", "")))
    if len(fixedSemRaw) > 0 && !(fixedSemRaw == "0" || fixedSemRaw == "false" || fixedSemRaw == "no"):
        return Err[UirCoreModule]("backend_driver: STAGE1_SEM_FIXED_0 is fixed=0")
    let fixedOwnershipRaw: str = strutil.toLowerAscii(strutil.strip(os.getEnvDefault("STAGE1_OWNERSHIP_FIXED_0", "")))
    if len(fixedOwnershipRaw) > 0 && !(fixedOwnershipRaw == "0" || fixedOwnershipRaw == "false" || fixedOwnershipRaw == "no"):
        return Err[UirCoreModule]("backend_driver: STAGE1_OWNERSHIP_FIXED_0 is fixed=0")
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: pre_skip_flags_start")
        os.c_fflush dbgFile
    let skipSem: bool = false
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: pre_skip_flags_after_skip_sem value=" + (skipSem ? "1" : "0"))
        os.c_fflush dbgFile
    let skipMono: bool = uirCoreShouldSkipMonoPass()
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: pre_skip_flags_after_skip_mono value=" + (skipMono ? "1" : "0"))
        os.c_fflush dbgFile
    let mmIsOrc: bool = uirCoreIsOrcMode(mm0)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: pre_skip_flags_after_mm_is_orc value=" + (mmIsOrc ? "1" : "0"))
        os.c_fflush dbgFile
    if ! skipSem:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: semantics_start")
            os.c_fflush dbgFile
            os.writeLine(dbgFile, "[backend] stage1: semantics_pretrace")
            os.c_fflush dbgFile
        stage1Trace "internal: semantics"
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: semantics_precheck")
            os.c_fflush dbgFile
        checkSemanticsId(root0Id, diags, ownDiags, mmIsOrc && strictOn0)
        if profOn:
            profSem = cheng_monotime_ns() - profMark
            profMark = cheng_monotime_ns()
        if ownDiags && ownershipHintsEnabled() && mmIsOrc && strictOn0:
            if hasHint diags:
                printHints diags
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: semantics_done")
            os.c_fflush dbgFile
        if dbgConstFile:
            os.writeLine(os.get_stderr(), "[backend] const: semantics_done")
            os.c_fflush os.get_stderr()
    else:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: semantics_skipped")
            os.c_fflush dbgFile

    stage1Trace "internal: monomorphize"
    var root: Node = root0
    if ! skipMono:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_start")
            os.c_fflush dbgFile
        let monoRoot0Id: AstNodeId = monomorphizeId(root0, &diags)
        root = monoRoot0Id
        uirCoreDebugDumpStringLiteralStage("post_mono_root", monoRoot0Id)
        let dbgTypeDeclName: str = os.getEnvDefault("BACKEND_DEBUG_ROOT_TYPEDECL", "")
        if len(dbgTypeDeclName) > 0:
            os.writeLine(os.get_stderr(),
                         "[backend] debugRootTypeDecl: name=" + dbgTypeDeclName +
                         " present=" + (uirCoreDebugRootHasTypeDecl(root, dbgTypeDeclName) ? "1" : "0"))
            os.c_fflush(os.get_stderr())
        if profOn:
            profMono = cheng_monotime_ns() - profMark
            profMark = cheng_monotime_ns()
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_done")
            os.c_fflush dbgFile
        if dbgConstFile:
            os.writeLine(os.get_stderr(), "[backend] const: mono_done")
            os.c_fflush os.get_stderr()
    else:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_skipped")
            os.c_fflush dbgFile
    if dbgPipe:
        let errFlag: bool = hasError(diags)
        os.writeLine(dbgFile, "[backend] stage1: mono_diag_count=" + intToStr(diags.len) +
                     " has_error=" + (errFlag ? "1" : "0"))
        if diags.len > 0:
            let d0: Diagnostic = diags[0]
            os.writeLine(dbgFile, "[backend] stage1: mono_diag0 sev=" + intToStr(int32(d0.severity)) +
                         " file='" + diagFilename(d0) +
                         "' line=" + intToStr(d0.line) +
                         " col=" + intToStr(d0.col) +
                         " msg='" + diagMessage(d0) + "'")
        if (root != nil) && ! errFlag:
            let rootIdDbg: AstNodeId = root
            var seenMonoNames: hashmaps.HashMapStrInt = hashmaps.hashMapStrIntInit(512)
            var dupMonoNames: int32 = 0
            for di in 0..<astKidCount(rootIdDbg):
                let dnId: AstNodeId = astKidAt(rootIdDbg, di)
                if !astNodeIdValid(dnId):
                    continue
                let dnKind: NodeKind = astNodeKind(dnId)
                if dnKind != nkFnDecl && dnKind != nkIteratorDecl:
                    continue
                if astKidCount(dnId) <= 0:
                    continue
                let dname: str = backendStripSpaces(astPlainName(astKidAt(dnId, 0)))
                if len(dname) == 0:
                    continue
                var foundCnt: bool = false
                let rawCnt: int32 = uirCoreHashMapStrIntGetCompatLocal(seenMonoNames, dname, foundCnt)
                let nextCnt: int32 = (foundCnt ? rawCnt : 0) + 1
                hashmaps.hashMapStrIntPut(seenMonoNames, dname, nextCnt)
                if foundCnt && rawCnt == 1 && dupMonoNames < 12:
                    os.writeLine(dbgFile, "[backend] stage1: mono_dup_fn '" + dname + "'")
                    dupMonoNames = dupMonoNames + 1
            os.writeLine(dbgFile, "[backend] stage1: mono_dup_fn_count=" + intToStr(dupMonoNames))
        os.c_fflush dbgFile
    if hasError diags:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: error_diag_dump_start")
            os.writeLine(dbgFile, "[backend] stage1: error_diag_count")
            os.writeLine(dbgFile, intToStr(diags.len))
            for edi in 0..<diags.len:
                let ed: Diagnostic = diags[edi]
                os.write(dbgFile, "[backend] stage1: error_diag[")
                os.write(dbgFile, intToStr(edi))
                os.write(dbgFile, "] sev=")
                os.write(dbgFile, intToStr(int32(ed.severity)))
                os.write(dbgFile, " file='")
                os.write(dbgFile, diagFilename(ed))
                os.write(dbgFile, "' line=")
                os.write(dbgFile, intToStr(ed.line))
                os.write(dbgFile, " col=")
                os.write(dbgFile, intToStr(ed.col))
                os.write(dbgFile, " msg='")
                os.write(dbgFile, diagMessage(ed))
                os.writeLine(dbgFile, "'")
            os.writeLine(dbgFile, "[backend] stage1: error_diag_dump_end")
            os.c_fflush dbgFile
        printDiagnostics diags
        return Err[UirCoreModule]("uirCore_builder: stage1 errors")

    # Stage0 stability: default to skipping c_profile lowering unless explicitly
    # opted back in via STAGE1_SKIP_CPROFILE=0.
    let skipCProfileEnv: str = getEnv "STAGE1_SKIP_CPROFILE"
    let skipCProfile: bool = (len(skipCProfileEnv) == 0) || uirCoreIsOne(skipCProfileEnv)
    if skipCProfile:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: c_profile_skipped")
            os.c_fflush dbgFile
    else:
        stage1Trace "internal: c-profile lowering"
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: c_profile_start")
            os.c_fflush dbgFile
        root = lowerCProfile(root, &diags)
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: c_profile_done")
            os.c_fflush dbgFile
        if hasError diags:
            printDiagnostics diags
            return Err[UirCoreModule]("uirCore_builder: c-profile lowering failed")
    let genericMode: str = uirCoreGenericModeNormalized()
    let genericBudget: int32 = uirCoreGenericSpecBudget()
    let forceMonoDict: bool = envIsTrue "STAGE1_FORCE_MONO_DICT"
    var monoAfterCProfile: bool = false
    if genericMode == "dict" || genericMode == "dictionary":
        monoAfterCProfile = forceMonoDict
    else:
        # Keep non-standard mode behavior conservative for direct builder callers.
        monoAfterCProfile = genericBudget > 0
    if !skipMono && !skipCProfile && monoAfterCProfile:
        # c_profile lowering can introduce new generic helper callsites
        # (e.g. Result/Option helpers). Run a second mono pass to ensure
        # all late-introduced generic calls are fully instantiated.
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_after_cprofile_start")
            os.c_fflush dbgFile
        let monoRoot1Id: AstNodeId = monomorphizeId(root, &diags)
        root = monoRoot1Id
        let dbgTypeDeclName2: str = os.getEnvDefault("BACKEND_DEBUG_ROOT_TYPEDECL", "")
        if len(dbgTypeDeclName2) > 0:
            os.writeLine(os.get_stderr(),
                         "[backend] debugRootTypeDecl: after_cprofile name=" + dbgTypeDeclName2 +
                         " present=" + (uirCoreDebugRootHasTypeDecl(root, dbgTypeDeclName2) ? "1" : "0"))
            os.c_fflush(os.get_stderr())
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: mono_after_cprofile_done")
            os.c_fflush dbgFile
        if hasError diags:
            printDiagnostics diags
            return Err[UirCoreModule]("uirCore_builder: stage1 errors")
    elif dbgPipe && !skipMono:
        os.writeLine(dbgFile, "[backend] stage1: mono_after_cprofile_skipped")
        os.c_fflush dbgFile

    let arcOn: bool = arcEnabled()
    let skipOwnership: bool = false
    let ownershipEngine: str = uirCoreOwnershipEngineNormalized()
    let borrowStageLabel: str = borrowIrMode == "mir" ? "mir_borrow" : "ownership"
    if borrowIrMode == "mir":
        stage1Trace "internal: mir_borrow"
    else:
        stage1Trace "internal: ownership"
    if skipOwnership:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: " + borrowStageLabel + "_skipped")
            os.c_fflush dbgFile
        if borrowIrMode == "mir":
            stage1Trace "internal: mir_borrow skipped"
        else:
            stage1Trace "internal: ownership skipped"
        setOwnershipEnabled false
    else:
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: " + borrowStageLabel + "_start")
            os.writeLine(dbgFile, "[backend] stage1: " + borrowStageLabel + "_engine=" + ownershipEngine)
            os.c_fflush dbgFile
        if ownershipEngine == "legacy":
            setOwnershipEnabled arcOn
            ownershipAnalyzeId(root)
            setOwnershipEnabled false
            if profOn:
                profOwn = cheng_monotime_ns() - profMark
                profMark = cheng_monotime_ns()
        else:
            setOwnershipEnabled false
        if dbgPipe:
            os.writeLine(dbgFile, "[backend] stage1: " + borrowStageLabel + "_done")
            os.c_fflush dbgFile
        if dbgConstFile:
            os.writeLine(os.get_stderr(), "[backend] const: borrow_done")
            os.c_fflush os.get_stderr()

    if profOn:
        var profParts: str[]
        add(profParts, "[stage1] profile: lex=")
        add(profParts, int64ToStr(profLex / 1000000))
        add(profParts, "ms load=")
        add(profParts, int64ToStr(profLoad / 1000000))
        add(profParts, "ms sem=")
        add(profParts, int64ToStr(profSem / 1000000))
        add(profParts, "ms mono=")
        add(profParts, int64ToStr(profMono / 1000000))
        add(profParts, "ms ownership=")
        add(profParts, int64ToStr(profOwn / 1000000))
        add(profParts, "ms outline_parse=")
        add(profParts, int64ToStr(profOutlineParse / 1000000))
        add(profParts, "ms materialize_bodies=")
        add(profParts, int64ToStr(profMaterializeBodies / 1000000))
        add(profParts, "ms merge_module=")
        add(profParts, int64ToStr(profMergeModule / 1000000))
        add(profParts, "ms borrow_ir=")
        add(profParts, borrowIrMode)
        add(profParts, " generic_lowering=")
        add(profParts, genericLoweringMode)
        add(profParts, " total=")
        add(profParts, int64ToStr((cheng_monotime_ns() - profStart) / 1000000))
        add(profParts, "ms")
        let profLine: str = fmt(profParts)
        echo profLine

    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: uirCore_build_start")
        os.c_fflush dbgFile
    if dbgConstFile:
        os.writeLine(os.get_stderr(), "[backend] const: before_uir_root_build")
        os.c_fflush os.get_stderr()
    stage1Trace "internal: fn_tasks"
    let fnTasksStart: int64 = profOn ? cheng_monotime_ns() : int64(0)
    let rootTagForBuild: str = astNodeStrVal(root)
    let uirCoreRes: Result[UirCoreModule] = uirCoreBuildModuleFromRootId(root, rootTagForBuild, target)
    if profOn:
        profFnTasks = cheng_monotime_ns() - fnTasksStart
    if !IsOk[UirCoreModule](uirCoreRes):
        let info0: ErrorInfo = ErrorInfoOf[UirCoreModule](uirCoreRes)
        return ErrInfo[UirCoreModule](info0)
    # Stage0 compatibility: avoid Value[T] on ref-heavy result payloads.
    let mod: UirCoreModule = uirCoreRes.value
    if dbgConstFile:
        os.writeLine(os.get_stderr(), "[backend] const: after_uir_root_build")
        os.c_fflush os.get_stderr()
    if dbgPipe:
        var externCountDbg: int32 = 0
        var zeroBlockNonExternCountDbg: int32 = 0
        for fi in 0..<uirCoreModuleFuncsLen(mod):
            let fDbg: UirCoreFunc = uirCoreModuleFuncAt(mod, fi)
            if (fDbg != nil) && uirCoreFuncIsExtern(fDbg):
                externCountDbg = externCountDbg + 1
            if (fDbg != nil) && !uirCoreFuncIsExtern(fDbg) && uirCoreFuncBlocksLen(fDbg) == 0:
                zeroBlockNonExternCountDbg = zeroBlockNonExternCountDbg + 1
        os.writeLine(dbgFile, "[backend] stage1: uir_module_counts funcs=" + intToStr(uirCoreModuleFuncsLen(mod)) +
                     " extern_funcs=" + intToStr(externCountDbg) +
                     " zero_block_nonextern_funcs=" + intToStr(zeroBlockNonExternCountDbg) +
                     " globals=" + intToStr(uirCoreModuleGlobalsLen(mod)) +
                     " cstrs=" + intToStr(uirCoreModuleCStringsLen(mod)))
        let dbgExternList: bool = envIsTrue "BACKEND_DEBUG_MODULE_EXTERNS"
        if dbgExternList:
            var shownExtern: int32 = 0
            var shownZeroBlock: int32 = 0
            for fi2 in 0..<uirCoreModuleFuncsLen(mod):
                let fDbg2: UirCoreFunc = uirCoreModuleFuncAt(mod, fi2)
                if (fDbg2 == nil):
                    continue
                if uirCoreFuncIsExtern(fDbg2):
                    if shownExtern < 160:
                        os.writeLine(dbgFile, "[backend] stage1: extern_fn[" + intToStr(shownExtern) + "] name=" +
                                     uirCoreFuncNameOf(fDbg2) + " link=" + uirCoreFuncLinkNameOf(fDbg2) +
                                     " file=" + uirCoreFuncOriginFileOf(fDbg2))
                    shownExtern = shownExtern + 1
                elif uirCoreFuncBlocksLen(fDbg2) == 0:
                    if shownZeroBlock < 80:
                        os.writeLine(dbgFile, "[backend] stage1: zero_block_fn[" + intToStr(shownZeroBlock) + "] name=" +
                                     uirCoreFuncNameOf(fDbg2) + " link=" + uirCoreFuncLinkNameOf(fDbg2) +
                                     " file=" + uirCoreFuncOriginFileOf(fDbg2))
                    shownZeroBlock = shownZeroBlock + 1
            os.writeLine(dbgFile, "[backend] stage1: extern_fn_total=" + intToStr(shownExtern))
            os.writeLine(dbgFile, "[backend] stage1: zero_block_fn_total=" + intToStr(shownZeroBlock))
        os.c_fflush dbgFile
    let _phaseStats: UirCorePhaseContractStats =
        uirCoreApplyOwnershipPhaseContract(mod, skipOwnership, borrowIrMode)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: phase_contract_done")
        os.writeLine(dbgFile, "[backend] stage1: tail_enter_pre_nil")
        os.c_fflush dbgFile
    if (mod == nil):
        return Err[UirCoreModule]("uir core module ok(nil) is forbidden")
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: tail_after_nil_check")
        os.writeLine(dbgFile, "[backend] stage1: tail_before_ok_ctor")
        os.c_fflush dbgFile
    let okRes: Result[UirCoreModule] = Ok_UirCoreModule(mod)
    if dbgPipe:
        os.writeLine(dbgFile, "[backend] stage1: tail_after_ok_ctor")
        os.c_fflush dbgFile
    return okRes

fn uirCoreBuildModuleFromFileStage1OrPanic(inPath: str, target: str = ""): UirCoreModule =
    let uirCoreRes: Result[UirCoreModule] = uirCoreBuildModuleFromFileStage1(inPath, target)
    if !IsOk[UirCoreModule](uirCoreRes):
        let info0: ErrorInfo = ErrorInfoOf[UirCoreModule](uirCoreRes)
        panic(ErrorMessage(info0))
    let mod: UirCoreModule = uirCoreRes.value
    if mod == nil:
        panic("uirCore_builder: build ok(nil) input=" + inPath)
    return mod

fn uirCoreBuildModuleFromFileStage1RawOrPanic(inRaw: cstring, targetRaw: cstring): UirCoreModule =
    frontend_lib.stage1_setMainInputRaw(inRaw)
    var inPath: str = ""
    if inRaw != nil:
        inPath = str(inRaw)
    var target: str = ""
    if targetRaw != nil:
        target = str(targetRaw)
    let mod: UirCoreModule = uirCoreBuildModuleFromFileStage1OrPanic(inPath, target)
    frontend_lib.stage1_clearMainInputRaw()
    return mod

fn uirCoreBuildModuleFromFileStage1TargetFirst(target: str, inPath: str): Result[UirCoreModule] =
    return uirCoreBuildModuleFromFileStage1(inPath, target)

fn uirCoreBuildModuleFromFileStage1TargetFirstOrPanic(target: str, inPath: str): UirCoreModule =
    return uirCoreBuildModuleFromFileStage1OrPanic(inPath, target)

fn uirCoreBuildModuleFromFileStage1HostOnlyOrPanic(inPath: str): UirCoreModule =
    return uirCoreBuildModuleFromFileStage1OrPanic(inPath, "arm64-apple-darwin")
