                            countNode0 = kid(countNode0, 0)
                    let countRes0: Result[UirExprId] = lowerExprValue(b, countNode0, uirCoreTypeI32())
                    if !IsOk[UirExprId](countRes0):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](countRes0))
                    let bytes64_0: UirExprId = uirCoreBin(uirCoreBinOpMul(),
                        uirCoreCast(uirCoreTypeI64(), Value[UirExprId](countRes0)),
                        uirCoreConstI64(int64(elemSize0)))
