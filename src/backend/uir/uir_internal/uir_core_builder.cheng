                let fn0: str = uirCoreCurrentFuncName(b)
                let line0: str = uirCoreNodePosLineOrZero(node)
                let col0: str = uirCoreNodePosColOrZero(node)
                echo("[backend] debug: Node-call fn=" + fn0 + " " + fp0 + ":" + line0 + ":" + col0 +
                     " kids=" + intToStr(kidCount(node)))
