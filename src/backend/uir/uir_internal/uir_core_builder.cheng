    return uirCoreStripPtrKeyOnce(key0)

fn uirCoreCallArgParamIndex(calleeFunc: UirCoreFunc, argIndex: int32): int32 =
    if (calleeFunc != nil) && uirCoreFuncParamsLen(calleeFunc) > 0:
        let pFirst: UirCoreParam = uirCoreFuncParamAt(calleeFunc, 0)
        if uirCoreNameOf(pFirst) == "__ret":
            return argIndex + 1
    return argIndex

fn uirCoreCallArgParamTypeKey(calleeFunc: UirCoreFunc, argIndex: int32): str =
    let pi2: int32 = uirCoreCallArgParamIndex(calleeFunc, argIndex)
    if (calleeFunc != nil) && pi2 >= 0 && pi2 < uirCoreFuncParamsLen(calleeFunc):
        return uirCoreTypeKeyOf(uirCoreFuncParamAt(calleeFunc, pi2))
    return ""

fn uirCoreLowerResolvedCallArg(b: BlockBuilder, calleeFunc: UirCoreFunc,
                               argIndex: int32, argNode: Node): Result[UirExprId] =
    let paramTypeKey: str = uirCoreCallArgParamTypeKey(calleeFunc, argIndex)
    let wantVarAddr: bool =
        len(paramTypeKey) > 0 &&
        uirCoreParamWantsVarAddr(blockBuilderModule(b), paramTypeKey)
    if wantVarAddr:
        return lowerVarArgAddr(b, argNode)
    return lowerExprValue(b, argNode, uirCoreTypeI64())

fn uirCoreLowerExprValueWithTypeKeyHint(b: BlockBuilder, node0: Node,
                                        wantType: UirCoreType, typeKey0: str): Result[UirExprId] =
    let typeKey: str = uirCoreParamKeyCanon(typeKey0)
    let dbgSemStrHint: bool = (getEnv("BACKEND_DEBUG_SEMSTR_HINT") == "1")
    if dbgSemStrHint:
        let nDbg: Node = uirCoreCallArgValueNode(uirCoreStripParExpr(node0))
        echo("[backend] debugSemStrHint: typeKey=" + typeKey +
             " kind=nk#" + uirCoreNodeKindOrNil(nDbg) +
             " name='" + uirCoreNodePlainNameOrEmpty(nDbg) + "'" +
             " str='" + uirCoreNodeStrValOrEmpty(nDbg) + "'")
    if (b != nil) && blockBuilderModule(b) != nil && isSemanticStrKey(typeKey):
        let node: Node = uirCoreCallArgValueNode(uirCoreStripParExpr(node0))
        if astNodeIdValid(node) && uirCoreNodeIsStringLiteral(node):
            let objTypeName: str = uirCoreSemanticStrObjTypeName(blockBuilderModule(b), typeKey)
            if dbgSemStrHint:
                echo("[backend] debugSemStrHint: semantic_str_literal objType=" + objTypeName)
            if len(objTypeName) > 0:
                return lowerSemanticStrLiteralValue(b, nodeStrVal(node), objTypeName, typeKey)
    return lowerExprValue(b, node0, wantType)

fn uirCoreLowerSemanticStrLiteralNode(b: BlockBuilder, node0: Node, typeKey0: str): Result[UirExprId] =
    if (b == nil) || blockBuilderModule(b) == nil:
        return Err[UirExprId]("uirCore_builder: semantic str literal missing builder/module")
    let node: Node = uirCoreCallArgValueNode(uirCoreStripParExpr(node0))
    if !astNodeIdValid(node) || !uirCoreNodeIsStringLiteral(node):
        return Err[UirExprId]("uirCore_builder: semantic str literal expects string literal node")
    let typeKey: str = uirCoreParamKeyCanon(typeKey0)
    let objTypeName: str = uirCoreSemanticStrObjTypeName(blockBuilderModule(b), typeKey)
    if len(objTypeName) == 0:
        return Err[UirExprId]("uirCore_builder: semantic str literal missing object type")
    return lowerSemanticStrLiteralValue(b, nodeStrVal(node), objTypeName, typeKey)

fn uirCoreLowerAssertMsgLiteralValue(b: BlockBuilder, value: str): Result[UirExprId] =
    if (b != nil) && blockBuilderModule(b) != nil:
        let objTypeName: str = uirCoreSemanticStrObjTypeName(blockBuilderModule(b), "str")
        if len(objTypeName) > 0:
            return lowerSemanticStrLiteralValue(b, value, objTypeName, "str")
    if (b == nil) || blockBuilderModule(b) == nil:
        return Err[UirExprId]("uirCore_builder: assert message lowering missing builder/module")
    let label: str = uirCoreAddCString(blockBuilderModule(b), value)
    return Ok[UirExprId](uirCoreGlobalAddr(label))

fn uirCoreResolveCallInternalByBaseOrDefault(b: BlockBuilder, callNode: Node, baseName: str,
                                             argNodes: Node[], hint: str, defaultName: str): Result[str] =
    let mod0: UirCoreModule = blockBuilderModule(b)
    if (mod0 != nil):
        let cand: UirCoreFunc = uirCoreResolveCalleeFuncBestEffortByNode(b, callNode, baseName, argNodes, hint)
        if cand != nil:
            return Ok[str](uirCoreCallSymbolForFunc(cand))
        if moduleHasFuncByBase(mod0, baseName):
            let calleeRes: Result[UirCoreFunc] = uirCoreResolveCalleeFunc(b, callNode, baseName, argNodes)
            if !IsOk[UirCoreFunc](calleeRes):
                return ErrInfo[str](ErrorInfoOf[UirCoreFunc](calleeRes))
            return Ok[str](uirCoreCallSymbolForFunc(Value[UirCoreFunc](calleeRes)))
    return Ok[str](defaultName)

fn uirCoreIfElseLabel(b: BlockBuilder, hasElse: bool): str =
    if hasElse:
        return blockBuilderNextLabel(b, "if_else")
    return ""

fn uirCoreIfNextCondLabel(b: BlockBuilder, isLast: bool): str =
    if !isLast:
        return blockBuilderNextLabel(b, "if_cond")
    return ""

fn uirCoreIfFalseLabelForExpr(isLast: bool, elseLabel: str, nextCondLabel: str): str =
    if isLast:
        return elseLabel
    return nextCondLabel

fn uirCoreIfFalseLabelForStmt(isLast: bool, hasElse: bool, elseLabel: str,
                              nextCondLabel: str, joinLabel: str): str =
    if !isLast:
        return nextCondLabel
    if hasElse:
        return elseLabel
    return joinLabel

fn uirCoreWhileDebugStmtName(st: Node): str =
    if (st != nil) && (nodeKind(st) == astNodeKindLet() || nodeKind(st) == astNodeKindVar()) && kidCount(st) > 0:
        return plainName(kid(st, 0))
    return ""

fn uirCoreObjectCallAssignFailMessage(name: str, objTypeName: str, fref: UirCoreFunc,
                                      node: Node, callRes: Result[UirExprId]): str =
    return "uirCore_builder: object call assign failed dst=" + name +
        " obj=" + objTypeName + " fn=" + uirCoreFuncNameOf(fref) +
        " " + uirCoreFuncOriginFileOf(fref) +
        " @" + intToStr(nodePosLine(node)) + ":" + intToStr(nodePosCol(node)) +
        " err=" + Error(callRes)

fn uirCoreSeqSliceBaseKey(b: BlockBuilder, base0: Node): str =
    let cachedKey0: str = uirCoreNodeTypeCacheKeyOrEmpty(base0)
    if len(cachedKey0) > 0:
        return cachedKey0
    if (base0 != nil) && (nodeKind(base0) == astNodeKindIdent() || nodeKind(base0) == astNodeKindSymbol()):
        let nm: str = plainName(base0)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        if slot0 >= 0 && funcFindObjLocal(blockBuilderFuncRef(b), slot0) >= 0:
            return funcObjTypeKey(blockBuilderFuncRef(b), slot0)
    return ""

fn uirCoreSliceVecCallName(typeKey0: str, pos0: PackedPos): str =
    let elemKey: str = rawmemStrFromOffset(typeKey0, 4)
    let typeArg0: Node = newIdent(elemKey, pos0)
    var typeArgs2: Node[]
    astNodeSeqAppend(typeArgs2, typeArg0)
    return mangleInstance("__cheng_slice_vec", typeArgs2)

fn uirCoreTypeCacheObjNameOrEmpty(module: UirCoreModule, n: Node): str =
    if astNodeIdValid(n) && nodeTypeCacheValid(n) && astRefNonNil(nodeTypeCache(n)):
        return typeNodeObjTypeName(module, nodeTypeCache(n))
    return ""

fn uirCoreTypeCacheKindOrZero(n: Node): str =
    if astNodeIdValid(n) && nodeTypeCacheValid(n) && astRefNonNil(nodeTypeCache(n)):
        return intToStr(int32(nodeKind(nodeTypeCache(n))))
    return "0"

fn uirCoreObjectValueAssignUnsupportedMessage(b: BlockBuilder, name: str, objTypeName: str,
                                              exprNode: Node, node: Node): str =
    return "uirCore_builder: object value assignment not supported: " + name +
        " (obj=" + objTypeName + " rhsKind=nk#" + uirCoreNodeKindOrZero(node) +
        " tcObj=" + uirCoreTypeCacheObjNameOrEmpty(blockBuilderModule(b), node) +
        " tcKind=nk#" + uirCoreTypeCacheKindOrZero(node) +
        " fn=" + uirCoreCurrentFuncName(b) + " " + uirCoreCurrentFuncOriginFile(b) + ":" +
        uirCoreNodePosLineOrZero(exprNode) + ":" + uirCoreNodePosColOrZero(exprNode) + ")"

fn uirCoreVarTargetObjTypeName(module: UirCoreModule, baseKey0: str): str =
    if len(baseKey0) == 0 || module == nil:
        return ""
    let obj0: str = uirCoreObjTypeFromTypeKey(module, baseKey0)
    if len(obj0) > 0:
        return obj0
    if (baseKey0 == "seq" || uirCoreStrStartsWith(baseKey0, "seq_") || uirCoreStrStartsWith(baseKey0, "seq_fixed_")) &&
       uirCoreHasObjType(module, "seq"):
        return "seq"
    if (baseKey0 == "Table" || uirCoreStrStartsWith(baseKey0, "Table_")) &&
       uirCoreHasObjType(module, "Table"):
        return "Table"
    return ""

fn uirCoreIterExprLocalKey(b: BlockBuilder, iterExpr: Node): str =
    if (iterExpr != nil) && (nodeKind(iterExpr) == astNodeKindIdent() || nodeKind(iterExpr) == astNodeKindSymbol()):
        let nm: str = plainName(iterExpr)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        if slot0 >= 0 && funcFindObjLocal(blockBuilderFuncRef(b), slot0) >= 0:
            return funcObjTypeKey(blockBuilderFuncRef(b), slot0)
        if slot0 >= 0:
            return localTypeKey(blockBuilderEnv(b), slot0)
    return ""

fn uirCoreIterExprSliceBaseKey(b: BlockBuilder, iterExpr: Node): str =
    if astNodeIdValid(iterExpr) && nodeKind(iterExpr) == astNodeKindBracketExpr() && kidCount(iterExpr) == 2:
        let base0: Node = kid(iterExpr, 0)
        let cachedKey0: str = uirCoreNodeTypeCacheKeyOrEmpty(base0)
        if len(cachedKey0) > 0:
            return cachedKey0
        let localKey0: str = uirCoreIterExprLocalKey(b, base0)
        if len(localKey0) > 0:
            return localKey0
        if uirCoreNodeIsStringLiteral(base0):
            return "str"
    return ""

fn uirCoreIterExprKeyRaw(b: BlockBuilder, iterExpr: Node): str =
    let cachedKey0: str = uirCoreNodeTypeCacheKeyOrEmpty(iterExpr)
    if len(cachedKey0) > 0 && !(cachedKey0 == "node"):
        return cachedKey0
    let localKey0: str = uirCoreIterExprLocalKey(b, iterExpr)
    if len(localKey0) > 0 && !(localKey0 == "node"):
        return localKey0
    if astNodeIdValid(iterExpr) && nodeKind(iterExpr) == astNodeKindSeqLit() && kidCount(iterExpr) > 0:
        let elemKey: str = uirCoreSeqLitBestEffortElemKey(iterExpr)
        if len(elemKey) > 0:
            return uirCoreTypeKeySeqName(elemKey)
    if uirCoreNodeIsStringLiteral(iterExpr):
        return "str"
    let sliceBaseKey0: str = uirCoreIterExprSliceBaseKey(b, iterExpr)
    if len(sliceBaseKey0) > 0 && !(sliceBaseKey0 == "node"):
        return sliceBaseKey0
    let inferredKey0: str = caseInferExprTypeKey(b, iterExpr)
    if len(inferredKey0) > 0 && !(inferredKey0 == "node"):
        return inferredKey0
    let shallowKey0: str = exprTypeKeyShallow(b, iterExpr)
    if len(shallowKey0) > 0 && !(shallowKey0 == "node"):
        return shallowKey0
    if astNodeIdValid(iterExpr) && nodeTypeCacheValid(iterExpr) && astRefNonNil(nodeTypeCache(iterExpr)):
        let looseKey0: str = uirCoreTypeKeyFromNodeLoose(nodeTypeCache(iterExpr))
        if len(looseKey0) > 0:
            return looseKey0
    return cachedKey0

fn uirCoreIterExprKey(b: BlockBuilder, iterExpr: Node): str =
    return uirCoreTypeKeyStripIterWrappers(uirCoreIterExprKeyRaw(b, iterExpr))

fn uirCoreIterExprKeyBase(b: BlockBuilder, iterExpr: Node): str =
    let iterKey0: str = uirCoreIterExprKey(b, iterExpr)
    let iterKeyBase0: str = uirCoreTypeKeyBaseName(iterKey0)
    if len(iterKeyBase0) > 0:
        return iterKeyBase0
    return iterKey0

fn uirCoreForHasValuePat(patNames: str[]): bool =
    return patNames.len == 2

fn uirCoreForHasValuePat2(patCount: int32): bool =
    return patCount == 2

fn uirCoreForIndexName(b: BlockBuilder, patNames: str[], tempPrefix: str): str =
    if uirCoreForHasValuePat(patNames):
        return patNames[0]
    return blockBuilderNextTemp(b, tempPrefix)

fn uirCoreForIndexName2(b: BlockBuilder, patCount: int32, patName0: str, tempPrefix: str): str =
    if uirCoreForHasValuePat2(patCount):
        return patName0
    return blockBuilderNextTemp(b, tempPrefix)

fn uirCoreForValueName(patNames: str[]): str =
    if uirCoreForHasValuePat(patNames):
        return patNames[1]
    return patNames[0]

fn uirCoreForValueName2(patCount: int32, patName0: str, patName1: str): str =
    if uirCoreForHasValuePat2(patCount):
        return patName1
    return patName0

fn uirCoreForSecondNameOrEmpty(patNames: str[]): str =
    if uirCoreForHasValuePat(patNames):
        return patNames[1]
    return ""

fn uirCoreForSecondNameOrEmpty2(patCount: int32, patName1: str): str =
    if uirCoreForHasValuePat2(patCount):
        return patName1
    return ""

fn uirCoreIterExprObjTypeName(b: BlockBuilder, iterExpr: Node): str =
    if (iterExpr != nil) && (nodeKind(iterExpr) == astNodeKindIdent() || nodeKind(iterExpr) == astNodeKindSymbol()):
        let nm: str = plainName(iterExpr)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        if slot0 >= 0 && funcFindObjLocal(blockBuilderFuncRef(b), slot0) >= 0:
            return funcObjTypeName(blockBuilderFuncRef(b), slot0)
    return ""

fn uirCorePtrBaseObjTypeNameOrEmpty(module: UirCoreModule, key: str): str =
    if module != nil:
        return uirCorePtrBaseObjTypeName(module, key)
    return ""

fn uirCoreTableIterObjName(b: BlockBuilder, iterExpr: Node, iterKey: str, iterKeyBase: str): str =
    let keyObjName0: str = uirCorePtrBaseObjTypeNameOrEmpty(blockBuilderModule(b), iterKey)
    let baseObjName0: str = uirCoreFirstNonEmptyStr(keyObjName0, iterKeyBase)
    let localObjName0: str = uirCoreIterExprObjTypeName(b, iterExpr)
    let candidate0: str = uirCoreFirstNonEmptyStr(localObjName0, baseObjName0)
    if blockBuilderModule(b) != nil:
        let resolved0: str = uirCorePtrBaseObjTypeName(blockBuilderModule(b), candidate0)
        if len(resolved0) > 0:
            return resolved0
    return candidate0

fn uirCoreTableIterValKey(iterExpr: Node, iterKey: str): str =
    let directKey0: str = uirCoreTypeKeyTableValKey(iterKey)
    if len(directKey0) > 0:
        return directKey0
    if astNodeIdValid(iterExpr) && nodeTypeCacheValid(iterExpr) && astRefNonNil(nodeTypeCache(iterExpr)):
        return uirCoreTypeKeyTableValKey(typeKey(nodeTypeCache(iterExpr)))
    return ""

fn uirCoreHashMapIterObjName(b: BlockBuilder, iterExpr: Node, iterKey: str): str =
    let keyObjName0: str = uirCorePtrBaseObjTypeNameOrEmpty(blockBuilderModule(b), iterKey)
    let baseObjName0: str = uirCoreFirstNonEmptyStr(keyObjName0, iterKey)
    let localObjName0: str = uirCoreIterExprObjTypeName(b, iterExpr)
    let candidate0: str = uirCoreFirstNonEmptyStr(localObjName0, baseObjName0)
    if blockBuilderModule(b) != nil:
        let resolved0: str = uirCorePtrBaseObjTypeName(blockBuilderModule(b), candidate0)
        if len(resolved0) > 0:
            return resolved0
    return candidate0

fn uirCoreForUnsupportedIterExtra(iterExpr: Node): str =
    if astNodeIdValid(iterExpr) && nodeKind(iterExpr) == astNodeKindInfix() && kidCount(iterExpr) > 0:
        return " op=" + backendOpName(kid(iterExpr, 0))
    return ""

fn typeNodeObjTypeNameCore(module: UirCoreModule, typeNode: Node): str =
    if (module == nil) || (typeNode == nil):
        return ""
    if nodeKind(typeNode) == astNodeKindVarTy() && kidCount(typeNode) > 0:
        return typeNodeObjTypeName(module, kid(typeNode, 0))
    if (nodeKind(typeNode) == astNodeKindRefTy() || nodeKind(typeNode) == astNodeKindPtrTy()) && kidCount(typeNode) > 0:
        return typeNodeObjTypeName(module, kid(typeNode, 0))
    if nodeKind(typeNode) == astNodeKindDotExpr() && kidCount(typeNode) > 1:
        return typeNodeObjTypeName(module, kid(typeNode, 1))
    let kind: NodeKind = nodeKind(typeNode)
    if kind == astNodeKindIdent() || kind == astNodeKindSymbol():
        let cachedTypeNode: Node = uirCoreTypeNodeCacheFallback(typeNode)
        let textId: int32 = typeNodeCanonicalIdentId(typeNode)
        if textId > 0:
            var textCached: bool
            let textCachedVal: str = uirCoreTypeTextObjNameCacheGet(module, textId, textCached)
            if textCached:
                if len(textCachedVal) > 0:
                    return textCachedVal
                if astNodeIdValid(cachedTypeNode):
                    let fallbackObj0: str = typeNodeObjTypeName(module, cachedTypeNode)
                    if len(fallbackObj0) > 0:
                        uirCoreTypeTextObjNameCachePut(module, textId, fallbackObj0)
                        return fallbackObj0
        let nm: str = typeNodeCanonicalName(typeNode)
        var nmCached: bool
        let nmCachedVal: str = uirCoreTypeKeyObjNameCacheGet(module, nm, nmCached)
        if nmCached:
            if len(nmCachedVal) > 0:
                if textId > 0:
                    uirCoreTypeTextObjNameCachePut(module, textId, nmCachedVal)
                return nmCachedVal
            if astNodeIdValid(cachedTypeNode):
                let fallbackObj1: str = typeNodeObjTypeName(module, cachedTypeNode)
                if len(fallbackObj1) > 0:
                    uirCoreTypeKeyObjNameCachePut(module, nm, fallbackObj1)
                    if textId > 0:
                        uirCoreTypeTextObjNameCachePut(module, textId, fallbackObj1)
                    return fallbackObj1
        if uirCoreStrStartsWith(nm, "seq_") && uirCoreHasObjType(module, "seq"):
            uirCoreTypeKeyObjNameCachePut(module, nm, "seq")
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, "seq")
            return "seq"
        if uirCoreStrStartsWith(nm, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
            uirCoreTypeKeyObjNameCachePut(module, nm, "seq")
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, "seq")
            return "seq"
        if uirCoreStrStartsWith(nm, "Table_") && uirCoreHasObjType(module, "Table"):
            uirCoreTypeKeyObjNameCachePut(module, nm, "Table")
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, "Table")
            return "Table"
        if uirCoreStrStartsWith(nm, "SeqUninit_") && ensureSeqUninitObjType(module, nm):
            uirCoreTypeKeyObjNameCachePut(module, nm, nm)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, nm)
            return nm
        if uirCoreStrStartsWith(nm, "Option_") && ensureOptionObjType(module, nm):
            uirCoreTypeKeyObjNameCachePut(module, nm, nm)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, nm)
            return nm
        if uirCoreStrStartsWith(nm, "Result_") && ensureResultObjType(module, nm):
            uirCoreTypeKeyObjNameCachePut(module, nm, nm)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, nm)
            return nm
        if uirCoreStrStartsWith(nm, "__cheng_tables_Entry_"):
            if ensureTablesEntryObjType(module, nm):
                uirCoreTypeKeyObjNameCachePut(module, nm, nm)
                if textId > 0:
                    uirCoreTypeTextObjNameCachePut(module, textId, nm)
                return nm
        if uirCoreHasObjType(module, nm):
            uirCoreTypeKeyObjNameCachePut(module, nm, nm)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, nm)
            return nm
        let canon: str = uirCoreObjAliasCanon(nm)
        if len(canon) > 0 && !(canon == nm) && uirCoreHasObjType(module, canon):
            uirCoreTypeKeyObjNameCachePut(module, nm, canon)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, canon)
            return canon
        let resolvedObj0: str = uirCoreObjTypeFromTypeKey(module, nm)
        if len(resolvedObj0) > 0:
            uirCoreTypeKeyObjNameCachePut(module, nm, resolvedObj0)
            if textId > 0:
                uirCoreTypeTextObjNameCachePut(module, textId, resolvedObj0)
            return resolvedObj0
        if astNodeIdValid(cachedTypeNode):
            let fallbackObj2: str = typeNodeObjTypeName(module, cachedTypeNode)
            if len(fallbackObj2) > 0:
                uirCoreTypeKeyObjNameCachePut(module, nm, fallbackObj2)
                if textId > 0:
                    uirCoreTypeTextObjNameCachePut(module, textId, fallbackObj2)
                return fallbackObj2
        uirCoreTypeKeyObjNameCachePut(module, nm, "")
        if textId > 0:
            uirCoreTypeTextObjNameCachePut(module, textId, "")
        return ""
    if kind == astNodeKindBracketExpr() && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if base != nil:
            let nm3: str = typeNodeCanonicalName(base)
            if (nm3 == "seq") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if (nm3 == "seq_fixed") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if (nm3 == "Table") && uirCoreHasObjType(module, "Table"):
                return "Table"
            let legacyInstName: str = uirCoreLegacyGenericBracketInstName(typeNode)
            if len(legacyInstName) > 0:
                var legacyCached: bool
                let legacyCachedVal: str = uirCoreTypeKeyObjNameCacheGet(module, legacyInstName, legacyCached)
                if legacyCached:
                    if len(legacyCachedVal) == 0:
                        let synthLegacy: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(module, typeNode)
                        if len(synthLegacy) > 0:
                            uirCoreTypeKeyObjNameCachePut(module, legacyInstName, synthLegacy)
                            return synthLegacy
                    return legacyCachedVal
                if uirCoreStrStartsWith(legacyInstName, "Result_") && ensureResultObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                if uirCoreStrStartsWith(legacyInstName, "Option_") && ensureOptionObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                if uirCoreStrStartsWith(legacyInstName, "SeqUninit_") && ensureSeqUninitObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                if uirCoreStrStartsWith(legacyInstName, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                if uirCoreHasObjType(module, legacyInstName):
                    uirCoreTypeKeyObjNameCachePut(module, legacyInstName, legacyInstName)
                    return legacyInstName
                uirCoreTypeKeyObjNameCachePut(module, legacyInstName, "")
            var instArgs: Node[]
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if astNodeIdValid(a) && nodeKind(a) != astNodeKindEmpty():
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm3, instArgs)
                var instCached: bool
                let instCachedVal: str = uirCoreTypeKeyObjNameCacheGet(module, instName, instCached)
                if instCached:
                    if len(instCachedVal) == 0:
                        let synthInstCached: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(module, typeNode)
                        if len(synthInstCached) > 0:
                            uirCoreTypeKeyObjNameCachePut(module, instName, synthInstCached)
                            return synthInstCached
                    return instCachedVal
                if (nm3 == "array"):
                    if ensureArrayObjTypeFromTypeExpr(module, typeNode, instName):
                        uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                        return instName
                if (nm3 == "SeqUninit") && ensureSeqUninitObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                if (nm3 == "Option") && ensureOptionObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                if (nm3 == "Result") && ensureResultObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                if (nm3 == "seq") && uirCoreHasObjType(module, "seq"):
                    uirCoreTypeKeyObjNameCachePut(module, instName, "seq")
                    return "seq"
                if (nm3 == "seq_fixed") && uirCoreHasObjType(module, "seq"):
                    uirCoreTypeKeyObjNameCachePut(module, instName, "seq")
                    return "seq"
                if (nm3 == "Table") && uirCoreHasObjType(module, "Table"):
                    uirCoreTypeKeyObjNameCachePut(module, instName, "Table")
                    return "Table"
                if uirCoreHasObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                let synthInstName: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(module, typeNode)
                if len(synthInstName) > 0:
                    uirCoreTypeKeyObjNameCachePut(module, instName, synthInstName)
                    return synthInstName
                if (nm3 == "__cheng_tables_Entry") && ensureTablesEntryObjType(module, instName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, instName)
                    return instName
                let prefix: str = uirCoreAppendChar(instName, '_')
                let foundName: str = uirCoreUniqueObjTypeNameByPrefix(module, prefix)
                if len(foundName) > 0 && uirCoreHasObjType(module, foundName):
                    uirCoreTypeKeyObjNameCachePut(module, instName, foundName)
                    return foundName
                uirCoreTypeKeyObjNameCachePut(module, instName, "")
        let looseKey0: str = uirCoreTypeKeyFromNodeLoose(typeNode)
        if len(looseKey0) > 0:
            if uirCoreHasObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
            let canonLoose0: str = uirCoreObjAliasCanon(looseKey0)
            if len(canonLoose0) > 0 && !(canonLoose0 == looseKey0) && uirCoreHasObjType(module, canonLoose0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, canonLoose0)
                return canonLoose0
            if uirCoreStrStartsWith(looseKey0, "seq_") && uirCoreHasObjType(module, "seq"):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, "seq")
                return "seq"
            if uirCoreStrStartsWith(looseKey0, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, "seq")
                return "seq"
            if uirCoreStrStartsWith(looseKey0, "Table_") && uirCoreHasObjType(module, "Table"):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, "Table")
                return "Table"
            if uirCoreStrStartsWith(looseKey0, "SeqUninit_") && ensureSeqUninitObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
            if uirCoreStrStartsWith(looseKey0, "Option_") && ensureOptionObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
            if uirCoreStrStartsWith(looseKey0, "Result_") && ensureResultObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
            if uirCoreStrStartsWith(looseKey0, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, looseKey0):
                uirCoreTypeKeyObjNameCachePut(module, looseKey0, looseKey0)
                return looseKey0
        return ""
    if kind == astNodeKindTupleTy():
        let key: str = typeKey(typeNode)
        # Record tuple field labels (if any) so `t.foo` can resolve to `fN` fields.
        if len(key) > 0:
            for ti in 0..<kidCount(typeNode):
                let elemNode0: Node = kid(typeNode, ti)
                let fieldLabel0: str = uirCoreTupleElemFieldLabel(elemNode0)
                let elemTypeNode0: Node = uirCoreTupleElemTypeNode(elemNode0)
                let elemTypeKey0: str = uirCoreTupleElemTypeKey(elemTypeNode0)
                let fName0: str = uirCoreConcat2("f", intToStr(ti))
                if len(elemTypeKey0) > 0:
                    uirCoreObjFieldTypeKeyPut(key, fName0, elemTypeKey0)
                    if len(fieldLabel0) > 0:
                        uirCoreObjFieldTypeKeyPut(key, fieldLabel0, elemTypeKey0)
                if len(fieldLabel0) > 0:
                    uirCoreTupleFieldIndexPut(key, fieldLabel0, ti)
        if len(key) > 0 && ! uirCoreHasObjType(module, key):
            var fields: UirCoreObjField[]
            var offset: int32
            var maxAlignPow2: int32
            for i in 0..<kidCount(typeNode):
                let elemNode: Node = kid(typeNode, i)
                var elemTypeNode: Node = elemNode
                if astNodeIdValid(elemNode) && nodeKind(elemNode) == astNodeKindIdentDefs() && kidCount(elemNode) > 1:
                    elemTypeNode = kid(elemNode, 1)
                if !astNodeIdValid(elemTypeNode) || nodeKind(elemTypeNode) == astNodeKindEmpty():
                    return ""
                let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(module, elemTypeNode)
                let fieldSize: int32 = uirCoreTypeSize(elemTy)
                if fieldSize <= 0:
                    return ""
                let alignPow2: int32 = uirCoreTypeAlignPow2(elemTy)
                if alignPow2 > maxAlignPow2:
                    maxAlignPow2 = alignPow2
                offset = alignUpPow2(offset, alignPow2)
                uirCoreAppendObjFieldNamed(fields, uirCoreConcat2("f", intToStr(i)), elemTy, offset)
                offset = offset + fieldSize
            uirCoreAddObjTypeParts(module, key, maxAlignPow2, alignUpPow2(offset, maxAlignPow2), fields)
        if len(key) > 0 && uirCoreHasObjType(module, key):
            uirCoreTypeKeyObjNameCachePut(module, key, key)
            return key
        return ""
    let nodeKey0: str = typeKey(typeNode)
    if len(nodeKey0) > 0:
        var keyCached: bool
        let keyCachedVal: str = uirCoreTypeKeyObjNameCacheGet(module, nodeKey0, keyCached)
        if keyCached:
            return keyCachedVal
        if uirCoreHasObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        let canon0: str = uirCoreObjAliasCanon(nodeKey0)
        if len(canon0) > 0 && !(canon0 == nodeKey0) && uirCoreHasObjType(module, canon0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, canon0)
            return canon0
        if uirCoreStrStartsWith(nodeKey0, "seq_") && uirCoreHasObjType(module, "seq"):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, "seq")
            return "seq"
        if uirCoreStrStartsWith(nodeKey0, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, "seq")
            return "seq"
        if uirCoreStrStartsWith(nodeKey0, "Table_") && uirCoreHasObjType(module, "Table"):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, "Table")
            return "Table"
        if uirCoreStrStartsWith(nodeKey0, "SeqUninit_") && ensureSeqUninitObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        if uirCoreStrStartsWith(nodeKey0, "Option_") && ensureOptionObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        if uirCoreStrStartsWith(nodeKey0, "Result_") && ensureResultObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        if uirCoreStrStartsWith(nodeKey0, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, nodeKey0):
            uirCoreTypeKeyObjNameCachePut(module, nodeKey0, nodeKey0)
            return nodeKey0
        uirCoreTypeKeyObjNameCachePut(module, nodeKey0, "")
    return ""

fn typeNodeObjTypeName(module: UirCoreModule, typeNode: Node): str =
    if (module == nil) || (typeNode == nil):
        return ""
    if uirCoreTypeNodeObjNameCacheNeedsReset(module):
        uirCoreTypeNodeObjNameCacheReset(module)
    if astNodeIdValid(typeNode):
        uirCoreTypeNodeObjNameCacheEnsure(typeNode)
        let idx0: int32 = int32(typeNode)
        if idx0 >= 0 && idx0 < uirCoreTypeNodeObjNameCacheReadyLen() && uirCoreTypeNodeObjNameCacheReadyAt(idx0) != int8(0):
            let cachedRes0: str = uirCoreTypeNodeObjNameCacheValueAt(idx0)
            if len(cachedRes0) > 0:
                return cachedRes0
            let cachedTypeNode0: Node = uirCoreTypeNodeCacheFallback(typeNode)
            if astNodeIdValid(cachedTypeNode0):
                let fallbackRes0: str = typeNodeObjTypeName(module, cachedTypeNode0)
                if len(fallbackRes0) > 0:
                    uirCoreTypeNodeObjNameCacheSetValueAt(idx0, fallbackRes0)
                    return fallbackRes0
            return cachedRes0
    let res: str = typeNodeObjTypeNameCore(module, typeNode)
    if astNodeIdValid(typeNode):
        uirCoreTypeNodeObjNameCacheEnsure(typeNode)
        let idx1: int32 = int32(typeNode)
        if idx1 >= 0 && idx1 < uirCoreTypeNodeObjNameCacheValuesLen() && idx1 < uirCoreTypeNodeObjNameCacheReadyLen():
            uirCoreTypeNodeObjNameCacheSetValueAt(idx1, res)
            uirCoreTypeNodeObjNameCacheSetReadyAt(idx1, int8(1))
    return res

fn uirCoreNewAllocExprForTypeNode(b: BlockBuilder, allocTypeNode0: Node): Result[UirExprId] =
    var allocTypeNode: Node = allocTypeNode0
    while astNodeIdValid(allocTypeNode) && nodeKind(allocTypeNode) == astNodeKindVarTy() && kidCount(allocTypeNode) > 0:
        allocTypeNode = kid(allocTypeNode, 0)
    if astNodeIdValid(allocTypeNode) && nodeKind(allocTypeNode) == astNodeKindRefTy() && kidCount(allocTypeNode) > 0:
        allocTypeNode = kid(allocTypeNode, 0)
    if !astNodeIdValid(allocTypeNode) || nodeKind(allocTypeNode) == astNodeKindEmpty():
        return Err[UirExprId]("uirCore_builder: new missing type info")
    var size: int64
    let dbgNew: bool = (getEnv("BACKEND_DEBUG_NEW") == "1")
    var innerObjName: str = typeNodeObjTypeName(blockBuilderModule(b), allocTypeNode)
    let allocKeyLoose: str = uirCoreTypeKeyFromNodeLoose(allocTypeNode)
    let allocKeyRaw: str = backendStripSpaces(typeKey(allocTypeNode))
    if len(innerObjName) == 0 && astNodeIdValid(allocTypeNode) && nodeKind(allocTypeNode) == astNodeKindBracketExpr():
        let synthAllocKey: str = uirCoreEnsureGenericTypeInstFromCurrentRoot(blockBuilderModule(b), allocTypeNode)
        if len(synthAllocKey) > 0:
            innerObjName = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), synthAllocKey)
    if dbgNew:
        os.WriteLine(os.Get_stderr(),
                     "[backend] debugNewAlloc: keyLoose=" + allocKeyLoose +
                     " keyRaw=" + allocKeyRaw +
                     " objName=" + innerObjName +
                     " kind=nk#" + intToStr(int32(nodeKind(allocTypeNode))) +
                     " @" + intToStr(nodePosLine(allocTypeNode)) + ":" + intToStr(nodePosCol(allocTypeNode)))
        os.C_fflush(os.Get_stderr())
    if len(innerObjName) > 0 && blockBuilderModule(b) != nil && uirCoreHasObjType(blockBuilderModule(b), innerObjName):
        let otNew: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), innerObjName)
        size = int64(uirCoreSizeOf(otNew))
        if dbgNew:
            os.WriteLine(os.Get_stderr(),
                         "[backend] debugNewAlloc: size_from_obj=" + intToStr(uirCoreSizeOf(otNew)))
            os.C_fflush(os.Get_stderr())
    else:
        let szRes: Result[int32] = uirCoreSizeOfTypeNode(blockBuilderModule(b), allocTypeNode)
        if !IsOk[int32](szRes):
            return ErrInfo[UirExprId](ErrorInfoOf[int32](szRes))
        size = int64(Value[int32](szRes))
        if dbgNew:
            os.WriteLine(os.Get_stderr(),
                         "[backend] debugNewAlloc: size_from_type=" + intToStr(Value[int32](szRes)))
            os.C_fflush(os.Get_stderr())
    let tmpName: str = blockBuilderNextTemp(b, "__new_p")
    let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
    uirCoreSetLocalType(blockBuilderFuncRef(b), tmpSlot, uirCoreTypeI64())
    var allocArgs: UirExprId[]
    builderExprSeqAppend(allocArgs, uirCoreConstI64(size))
    blockBuilderAddStmt(b, uirCoreStmtLet(tmpName, tmpSlot, uirCoreCall("alloc", allocArgs)))
    var zeroArgs: UirExprId[]
    builderExprSeqAppend(zeroArgs, uirCoreLocal(tmpSlot))
    builderExprSeqAppend(zeroArgs, uirCoreConstI64(size))
    blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall("zeroMem", zeroArgs)))
    return Ok[UirExprId](uirCoreLocal(tmpSlot))

fn typeNodeIsObjValue(module: UirCoreModule, typeNode: Node): bool =
    if (module == nil) || (typeNode == nil):
        return false
    if nodeKind(typeNode) == astNodeKindVarTy() && kidCount(typeNode) > 0:
        return typeNodeIsObjValue(module, kid(typeNode, 0))
    if nodeKind(typeNode) == astNodeKindDotExpr() && kidCount(typeNode) > 1:
        return typeNodeIsObjValue(module, kid(typeNode, 1))
    if nodeKind(typeNode) == astNodeKindTupleTy():
        let nm: str = typeNodeObjTypeName(module, typeNode)
        return len(nm) > 0
    let kind: NodeKind = nodeKind(typeNode)
    if kind == astNodeKindIdent() || kind == astNodeKindSymbol():
        let cachedTypeNode: Node = uirCoreTypeNodeCacheFallback(typeNode)
        let nm: str = typeNodeCanonicalName(typeNode)
        if uirCoreHasObjType(module, nm):
            # Ref-like types are represented as pointer aliases + object layout.
            let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, nm)
            if uirCoreTypeKindOf(aliasTy) != uirCoreTypeKindVoid():
                return false
            if astNodeIdValid(typeNode) && nodeTypeCacheValid(typeNode) && astRefNonNil(nodeTypeCache(typeNode)):
                let tc: Node = nodeTypeCache(typeNode)
                if nodeKind(tc) == astNodeKindRefTy() || nodeKind(tc) == astNodeKindPtrTy():
                    return false
            return true
        if uirCoreStrStartsWith(nm, "seq_") && uirCoreHasObjType(module, "seq"):
            return true
        if uirCoreStrStartsWith(nm, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
            return true
        if uirCoreStrStartsWith(nm, "Table_") && uirCoreHasObjType(module, "Table"):
            return true
        if uirCoreStrStartsWith(nm, "SeqUninit_") && ensureSeqUninitObjType(module, nm):
            return true
        if uirCoreStrStartsWith(nm, "Option_") && ensureOptionObjType(module, nm):
            return true
        if uirCoreStrStartsWith(nm, "Result_") && ensureResultObjType(module, nm):
            return true
        if uirCoreStrStartsWith(nm, "__cheng_tables_Entry_"):
            return ensureTablesEntryObjType(module, nm)
        if astNodeIdValid(cachedTypeNode):
            return typeNodeIsObjValue(module, cachedTypeNode)
        return false
    if kind == astNodeKindBracketExpr() && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if base != nil:
            let nm2: str = typeNodeCanonicalName(base)
            if (nm2 == "seq") && uirCoreHasObjType(module, "seq"):
                return true
            if (nm2 == "seq_fixed") && uirCoreHasObjType(module, "seq"):
                return true
            if (nm2 == "Table") && uirCoreHasObjType(module, "Table"):
                return true
            let legacyInstName: str = uirCoreLegacyGenericBracketInstName(typeNode)
            if len(legacyInstName) > 0:
                if uirCoreStrStartsWith(legacyInstName, "Result_") && ensureResultObjType(module, legacyInstName):
                    return true
                if uirCoreStrStartsWith(legacyInstName, "Option_") && ensureOptionObjType(module, legacyInstName):
                    return true
                if uirCoreStrStartsWith(legacyInstName, "SeqUninit_") && ensureSeqUninitObjType(module, legacyInstName):
                    return true
                if uirCoreStrStartsWith(legacyInstName, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, legacyInstName):
                    return true
                if uirCoreHasObjType(module, legacyInstName):
                    return true
            var instArgs: Node[]
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if astNodeIdValid(a) && nodeKind(a) != astNodeKindEmpty():
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm2, instArgs)
                if (nm2 == "array") && ensureArrayObjTypeFromTypeExpr(module, typeNode, instName):
                    return true
                if (nm2 == "SeqUninit") && ensureSeqUninitObjType(module, instName):
                    return true
                if (nm2 == "Option") && ensureOptionObjType(module, instName):
                    return true
                if (nm2 == "Result") && ensureResultObjType(module, instName):
                    return true
                if uirCoreHasObjType(module, instName):
                    return true
                if len(uirCoreEnsureGenericTypeInstFromCurrentRoot(module, typeNode)) > 0:
                    return true
                if (nm2 == "__cheng_tables_Entry") && ensureTablesEntryObjType(module, instName):
                    return true
                let looseKey0: str = uirCoreTypeKeyFromNodeLoose(typeNode)
                if len(looseKey0) > 0:
                    if uirCoreHasObjType(module, looseKey0):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "seq_") && uirCoreHasObjType(module, "seq"):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "Table_") && uirCoreHasObjType(module, "Table"):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "SeqUninit_") && ensureSeqUninitObjType(module, looseKey0):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "Option_") && ensureOptionObjType(module, looseKey0):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "Result_") && ensureResultObjType(module, looseKey0):
                        return true
                    if uirCoreStrStartsWith(looseKey0, "__cheng_tables_Entry_"):
                        return ensureTablesEntryObjType(module, looseKey0)
                return false
        return false
    let nodeKey0: str = typeKey(typeNode)
    if len(nodeKey0) > 0:
        if uirCoreHasObjType(module, nodeKey0):
            let aliasTy0: UirCoreType = uirCoreTryGetTypeAlias(module, nodeKey0)
            if uirCoreTypeKindOf(aliasTy0) == uirCoreTypeKindVoid():
                return true
        if uirCoreStrStartsWith(nodeKey0, "seq_") && uirCoreHasObjType(module, "seq"):
            return true
        if uirCoreStrStartsWith(nodeKey0, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
            return true
        if uirCoreStrStartsWith(nodeKey0, "Table_") && uirCoreHasObjType(module, "Table"):
            return true
        if uirCoreStrStartsWith(nodeKey0, "SeqUninit_") && ensureSeqUninitObjType(module, nodeKey0):
            return true
        if uirCoreStrStartsWith(nodeKey0, "Option_") && ensureOptionObjType(module, nodeKey0):
            return true
        if uirCoreStrStartsWith(nodeKey0, "Result_") && ensureResultObjType(module, nodeKey0):
            return true
        if uirCoreStrStartsWith(nodeKey0, "__cheng_tables_Entry_"):
            return ensureTablesEntryObjType(module, nodeKey0)
    let cachedTypeNode0: Node = uirCoreTypeNodeCacheFallback(typeNode)
    if astNodeIdValid(cachedTypeNode0):
        return typeNodeIsObjValue(module, cachedTypeNode0)
    return false

fn ensureBuiltinObjTypes(module: UirCoreModule) =
    if (module == nil):
        return
    if ! uirCoreHasObjType(module, "seq"):
        var fields: UirCoreObjField[]
        uirCoreAppendObjFieldNamed(fields, "len", uirCoreTypeI32(), 0)
        uirCoreAppendObjFieldNamed(fields, "cap", uirCoreTypeI32(), 4)
        uirCoreAppendObjFieldNamed(fields, "buffer", uirCoreTypeI64(), 8)
        uirCoreAddObjTypeParts(module, "seq", 3, 16, fields)
    if ! uirCoreHasObjType(module, "Table"):
        # stdlib `tables.Table[V]` (generic) has a stable layout independent of V:
        #   keys: seq[str]      (inlined as keys.len/cap/buffer)
        #   vals: seq[V]        (inlined as vals.len/cap/buffer)
        #   states: seq[uint8]  (inlined as states.len/cap/buffer)
        #   len: int32
        var fields2: UirCoreObjField[]
        uirCoreAppendObjFieldNamed(fields2, "keys.len", uirCoreTypeI32(), 0)
        uirCoreAppendObjFieldNamed(fields2, "keys.cap", uirCoreTypeI32(), 4)
        uirCoreAppendObjFieldNamed(fields2, "keys.buffer", uirCoreTypeI64(), 8)
        uirCoreAppendObjFieldNamed(fields2, "vals.len", uirCoreTypeI32(), 16)
        uirCoreAppendObjFieldNamed(fields2, "vals.cap", uirCoreTypeI32(), 20)
        uirCoreAppendObjFieldNamed(fields2, "vals.buffer", uirCoreTypeI64(), 24)
        uirCoreAppendObjFieldNamed(fields2, "states.len", uirCoreTypeI32(), 32)
        uirCoreAppendObjFieldNamed(fields2, "states.cap", uirCoreTypeI32(), 36)
        uirCoreAppendObjFieldNamed(fields2, "states.buffer", uirCoreTypeI64(), 40)
        uirCoreAppendObjFieldNamed(fields2, "len", uirCoreTypeI32(), 48)
        uirCoreAddObjTypeParts(module, "Table", 3, 56, fields2)

fn ensureArrayObjTypeFromTypeExpr(module: UirCoreModule, arrType: Node, arrName: str): bool =
    if (module == nil) || (arrType == nil) || len(arrName) == 0:
        return false
    if uirCoreHasObjType(module, arrName):
        return true
    if nodeKind(arrType) != astNodeKindBracketExpr() || kidCount(arrType) < 3:
        return false
    let base: Node = kid(arrType, 0)
    if (base == nil) || (nodeKind(base) != astNodeKindIdent() && nodeKind(base) != astNodeKindSymbol()):
        return false
    let baseName: str = backendStripSpaces(plainName(base))
    if !(baseName == "array"):
        return false
    let arg1: Node = kid(arrType, 1)
    let arg2: Node = kid(arrType, 2)
    if !astNodeIdValid(arg1) || !astNodeIdValid(arg2) || nodeKind(arg1) == astNodeKindEmpty() || nodeKind(arg2) == astNodeKindEmpty():
        return false

    let c1: int32 = tryResolveArrayCount(module, arg1)
    let c2: int32 = tryResolveArrayCount(module, arg2)
    var count: int32 = -1
    var elemTypeNode: Node = astInvalidNodeId()
    if c1 > 0 && c2 <= 0:
        count = c1
        elemTypeNode = arg2
    elif c2 > 0 && c1 <= 0:
        count = c2
        elemTypeNode = arg1
    elif c1 > 0 && c2 > 0:
        # Ambiguous; prefer `array[Count, ElemType]`.
        count = c1
        elemTypeNode = arg2
    if count <= 0 || !astNodeIdValid(elemTypeNode) || nodeKind(elemTypeNode) == astNodeKindEmpty():
        return false

    # If element type isn't resolved yet, defer array layout creation so we don't
    # lock in an incorrect element representation (e.g. unknown object types default to i32).
    if nodeKind(elemTypeNode) == astNodeKindIdent() || nodeKind(elemTypeNode) == astNodeKindSymbol():
        let elemName: str = backendStripSpaces(plainName(elemTypeNode))
        if len(elemName) > 0 && !isBuiltinTypeName(elemName):
            if !uirCoreHasObjType(module, elemName):
                let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, elemName)
                if uirCoreTypeKindOf(aliasTy) == uirCoreTypeKindVoid():
                    return false

    var elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(module, elemTypeNode)
    let elemObjName: str = typeNodeObjTypeName(module, elemTypeNode)
    if len(elemObjName) > 0 && typeNodeIsObjValue(module, elemTypeNode):
        elemTy = uirCoreTypeI64()
    let elemSize: int32 = uirCoreTypeSize(elemTy)
    if elemSize <= 0:
        return false
    let elemAlignPow2: int32 = uirCoreTypeAlignPow2(elemTy)
    let stride: int32 = alignUpPow2(elemSize, elemAlignPow2)
    if stride <= 0:
        return false
    var fields: UirCoreObjField[]
    var off: int32
    for i in 0..<count:
        uirCoreAppendObjFieldNamed(fields, uirCoreIndexedName("e", i), elemTy, off)
        off = off + stride
    uirCoreAddObjTypeParts(module, arrName, elemAlignPow2, alignUpPow2(off, elemAlignPow2), fields)
    return true

fn uirCoreDeclFileAt(declFiles: str[], idx: int32): str =
    if idx >= 0 && idx < declFiles.len:
        return declFiles[idx]
    return ""

fn uirCoreStableRoutineNameFromDeclName(nm: str, nId: AstNodeId): str =
    if len(nm) > 0:
        return nm
    return uirCoreTopLevelRoutineNameId(nId)

fn uirCoreTopLevelHeadNameOrEmptyId(nId: AstNodeId): str =
    if astKidCount(nId) > 0:
        let nameNodeId: AstNodeId = astKidAt(nId, 0)
        if astNodeIdValid(nameNodeId):
            let nameKind: NodeKind = astNodeKind(nameNodeId)
            if nameKind == astNodeKindIdent() || nameKind == astNodeKindSymbol():
                return backendStripSpaces(astPlainName(nameNodeId))
    return ""

fn uirCoreBuildMissingRoutinesFromUirId(mod: UirCoreModule, rootId: AstNodeId, overloaded: ptr = nil, errOut: ptr = nil): bool =
    if mod == nil || !astNodeIdValid(rootId):
        return true
    stage1Trace("backend: uir fixups.id enter")
    let traceOn: bool = stage1TraceEnabled()
    let dbgPipe: bool = (os.GetEnvDefault("BACKEND_DEBUG_STAGE1_PIPE", "") == "1")
    let dbgConstFix: bool = (os.GetEnvDefault("BACKEND_DEBUG_STAGE1_CONST", "") == "1")
    var dbgFile: os.File = nil
    if dbgPipe:
        dbgFile = os.Get_stderr()
        os.WriteLine(dbgFile, "[backend] stage1: fixups_enter")
        os.C_fflush(dbgFile)
    let declCap: int32 = uirCoreCountFnDeclsMangledId(rootId)
    var declNames: str[]
    var declNodes: int32[]
    var declFiles: str[]
    if declCap > 0:
        setLen(declNames, declCap)
        setLen(declNodes, declCap)
        setLen(declFiles, declCap)
    var declCount: int32
    let rootFilePath: str = uirCoreNormalizeTopLevelPath(astNodeStrVal(rootId), "")
    uirCoreIndexFnDeclsMangledId(rootId, overloaded, declNames, declNodes, declFiles, declCount, rootFilePath)
    if declCount >= 0 && declCount < declNames.len:
        setLen(declNames, declCount)
    if declCount >= 0 && declCount < declNodes.len:
        setLen(declNodes, declCount)
    if declCount >= 0 && declCount < declFiles.len:
        setLen(declFiles, declCount)
    if dbgConstFix:
        os.WriteLine(os.Get_stderr(), "[backend] const: fixups_after_index")
        os.C_fflush(os.Get_stderr())
    if traceOn:
        stage1Trace("backend: uir fixups.id indexed decl_nodes=" + intToStr(declNodes.len))
    if dbgPipe:
        os.WriteLine(dbgFile, "[backend] stage1: fixups_indexed decl_nodes=" + intToStr(declNodes.len))
        os.C_fflush(dbgFile)

    var existingFuncs: str[]
    let existingCap: int32 = uirCoreModuleFuncsLen(mod) + declNames.len + 8
    if existingCap > 0:
        setLen(existingFuncs, existingCap)
    var existingFuncCount: int32
    for fi0 in 0..<uirCoreModuleFuncsLen(mod):
        let f0: UirCoreFunc = uirCoreModuleFuncAt(mod, fi0)
        if uirCoreFuncIdValid(f0) && len(uirCoreFuncNameOf(f0)) > 0:
            if !uirCoreStrListHas(existingFuncs, existingFuncCount, uirCoreFuncNameOf(f0)):
                uirCoreFixedStrAppend(existingFuncs, &existingFuncCount, uirCoreFuncNameOf(f0))
    if dbgPipe:
        os.WriteLine(dbgFile, "[backend] stage1: fixups_existing_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
        os.C_fflush(dbgFile)
    if dbgConstFix:
        os.WriteLine(os.Get_stderr(), "[backend] const: fixups_after_existing")
        os.C_fflush(os.Get_stderr())
    if traceOn:
        stage1Trace("backend: uir fixups.id existing_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))

    var seen: str[]
    if declNames.len > 0:
        setLen(seen, declNames.len)
    var seenCount: int32
    var queue: str[]
    if declNames.len > 0:
        setLen(queue, declNames.len)
    var queueCount: int32
    for fi in 0..<uirCoreModuleFuncsLen(mod):
        let f0: UirCoreFunc = uirCoreModuleFuncAt(mod, fi)
        uirCoreMaybeEnqueueFromFunc(mod, declNames, seen, seenCount, queue, queueCount, f0)
    if traceOn:
        stage1Trace("backend: uir fixups.id queue_seeded=" + intToStr(queueCount))
    if dbgPipe:
        os.WriteLine(dbgFile, "[backend] stage1: fixups_queue_seeded=" + intToStr(queueCount))
        os.C_fflush(dbgFile)
    if dbgConstFix:
        os.WriteLine(os.Get_stderr(), "[backend] const: fixups_after_queue_seeded")
        os.C_fflush(os.Get_stderr())

    var builtAny: bool
    var qi: int32
    if dbgConstFix:
        os.WriteLine(os.Get_stderr(), "[backend] const: fixups_before_loop")
        os.C_fflush(os.Get_stderr())
    while qi < queueCount:
        if dbgConstFix:
            if qi == 0:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter0_enter")
                os.C_fflush(os.Get_stderr())
            elif qi == 1:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter1_enter")
                os.C_fflush(os.Get_stderr())
            elif qi == 2:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter2_enter")
                os.C_fflush(os.Get_stderr())
        let shouldLogIter: bool = qi < 4 || ((qi % 32) == 0)
        if dbgPipe && shouldLogIter:
            os.WriteLine(dbgFile, "[backend] stage1: fixups_iter qi=" + intToStr(qi) + " queue=" + intToStr(queueCount))
            os.C_fflush(dbgFile)
        let nm: str = queue[qi]
        qi = qi + 1
        if len(nm) == 0:
            continue
        if uirCoreStrListHas(existingFuncs, existingFuncCount, nm):
            continue
        let idx: int32 = uirCoreDeclIndexFind(declNames, nm)
        if idx < 0 || idx >= declNodes.len:
            continue
        let nId: AstNodeId = AstNodeId(declNodes[idx])
        if !astNodeIdValid(nId):
            continue
        if uirCoreFuncSigHasUnresolvedGenericsId(nId):
            continue
        let fp: str = uirCoreDeclFileAt(declFiles, idx)
        if dbgConstFix:
            if qi == 1:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter0_before_build_func")
                os.C_fflush(os.Get_stderr())
            elif qi == 2:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter1_before_build_func")
                os.C_fflush(os.Get_stderr())
            elif qi == 3:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter2_before_build_func")
                os.C_fflush(os.Get_stderr())
        let fRes: Result[UirCoreFunc] = uirCoreBuildFuncId(mod, nId, fp, overloaded, "", nil)
        if ! IsOk[UirCoreFunc](fRes):
            let infoBuild: ErrorInfo = ErrorInfoOf[UirCoreFunc](fRes)
            let msgBuild: str = uirCoreFixupsBuildFuncErrorMessage(nm, infoBuild)
            if dbgPipe:
                os.WriteLine(dbgFile, "[backend] stage1: fixups_build_func_err " + msgBuild)
                os.C_fflush(dbgFile)
            uirCoreCopyErrOutStr(errOut, msgBuild)
            return false
        if dbgConstFix:
            if qi == 1:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter0_after_build_func")
                os.C_fflush(os.Get_stderr())
            elif qi == 2:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter1_after_build_func")
                os.C_fflush(os.Get_stderr())
            elif qi == 3:
                os.WriteLine(os.Get_stderr(), "[backend] const: fixups_iter2_after_build_func")
                os.C_fflush(os.Get_stderr())
        let f: UirCoreFunc = Value[UirCoreFunc](fRes)
        if !uirCoreFuncIdValid(f):
            continue
        let stableName: str = uirCoreStableRoutineNameFromDeclName(nm, nId)
        let stableOriginFile: str = fp
        let stableDeclOrdinal: int32 = astNodeDeclOrdinal(nId)
        let stableSourceAstIndex: int32 = astNodeIndex(nId)
        uirCoreFuncInitHeaderMeta(f, uirCoreFuncRetTypeKeyOf(f), stableOriginFile,
                                  stableDeclOrdinal, stableSourceAstIndex,
                                  uirCoreFuncIsExtern(f))
        let sameRoutineIdx: int32 = uirCoreModuleFuncSameOriginIndex(
            mod, stableName, stableOriginFile,
            stableDeclOrdinal, stableSourceAstIndex)
        if sameRoutineIdx >= 0:
            let exSame: UirCoreFunc = uirCoreModuleFuncAt(mod, sameRoutineIdx)
            if !uirCoreFuncIdValid(exSame) || uirCoreFuncBlocksLen(exSame) == 0:
                uirCoreModuleSetFuncAt(mod, sameRoutineIdx, f)
                if !uirCoreStrListHas(existingFuncs, existingFuncCount, stableName):
                    uirCoreFixedStrAppend(existingFuncs, &existingFuncCount, stableName)
                builtAny = true
                uirCoreMaybeEnqueueFromFunc(mod, declNames, seen, seenCount, queue, queueCount, f)
            continue
        if moduleHasFunc(mod, stableName) || moduleHasGlobal(mod, stableName) ||
           uirCoreFindTypeAlias(mod, stableName) >= 0 || uirCoreFindObjType(mod, stableName) >= 0:
            if dbgPipe:
                os.WriteLine(dbgFile, "[backend] stage1: fixups_duplicate_err name=" + stableName)
                os.C_fflush(dbgFile)
            uirCoreCopyErrOutStr(errOut, uirCoreDuplicateFunctionNameErrorMessage(stableName))
            return false
        uirCoreAddFunc(mod, f)
        if !uirCoreStrListHas(existingFuncs, existingFuncCount, stableName):
            uirCoreFixedStrAppend(existingFuncs, &existingFuncCount, stableName)
        builtAny = true
        uirCoreMaybeEnqueueFromFunc(mod, declNames, seen, seenCount, queue, queueCount, f)
    if traceOn:
        stage1Trace("backend: uir fixups.id done built_any=" + (builtAny ? "1" : "0") + " queue=" + intToStr(queueCount))
    if dbgPipe:
        os.WriteLine(dbgFile, "[backend] stage1: fixups_done built_any=" + (builtAny ? "1" : "0") + " queue=" + intToStr(queueCount))
        os.C_fflush(dbgFile)
    return true

fn uirCoreInferCtorSuffixFromTypeCache(b: BlockBuilder, callNode: Node, objPrefix: str): str =
    if (b == nil) || blockBuilderModule(b) == nil || (callNode == nil) || len(objPrefix) == 0:
        return ""
    if nodeTypeCacheValid(callNode) && astRefNonNil(nodeTypeCache(callNode)):
        let tc: Node = nodeTypeCache(callNode)
        let objName0: str = typeNodeObjTypeName(blockBuilderModule(b), tc)
        if len(objName0) > 0 && uirCoreStrStartsWith(objName0, objPrefix):
            let suffix0: str = rawmemStrFromOffset(objName0, len(objPrefix))
            if len(suffix0) > 0:
                return suffix0
        let key0: str = typeKey(tc)
        if len(key0) > 0 && uirCoreStrStartsWith(key0, objPrefix):
            let suffix1: str = rawmemStrFromOffset(key0, len(objPrefix))
            if len(suffix1) > 0:
                return suffix1
    return ""

fn uirCoreSizeOfTypeNode(module: UirCoreModule, typeNode: Node): Result[int32] =
    if !astNodeIdValid(typeNode) || nodeKind(typeNode) == astNodeKindEmpty():
        return Err[int32]("uirCore_builder: sizeof expects a type/expression")
    if nodeKind(typeNode) == astNodeKindPtrTy() || nodeKind(typeNode) == astNodeKindRefTy() || nodeKind(typeNode) == astNodeKindFnTy() || nodeKind(typeNode) == astNodeKindVarTy():
        return Ok[int32](8)
    if nodeKind(typeNode) == astNodeKindTupleTy():
        let nm: str = typeNodeObjTypeName(module, typeNode)
        if len(nm) > 0 && (module != nil) && uirCoreHasObjType(module, nm):
            let ot: UirCoreObjType = uirCoreGetObjType(module, nm)
            return Ok[int32](uirCoreSizeOf(ot))
        return Err[int32]("uirCore_builder: sizeof unknown tuple type")
    if nodeKind(typeNode) == astNodeKindIdent() || nodeKind(typeNode) == astNodeKindSymbol():
        let nm: str = backendStripSpaces(plainName(typeNode))
        if nm == "bool" || nm == "char" || nm == "int8" || nm == "uint8" || nm == "i8" || nm == "u8":
            return Ok[int32](1)
        if nm == "int16" || nm == "uint16" || nm == "i16" || nm == "u16":
            return Ok[int32](2)
        if nm == "int32" || nm == "uint32" || nm == "i32" || nm == "u32" || nm == "float32":
            return Ok[int32](4)
        if nm == "int" || nm == "uint" || nm == "NI" || nm == "NU":
            let bits: int32 = uirCoreIntBitsDefault32()
            if bits == 64:
                return Ok[int32](8)
            return Ok[int32](4)
        if nm == "int64" || nm == "uint64" || nm == "i64" || nm == "u64" || nm == "float64":
            return Ok[int32](8)
        if isStringOrPtrKey(nm):
            return Ok[int32](8)
        if uirCoreStrStartsWith(nm, "ptr_") || uirCoreStrStartsWith(nm, "ref_") || uirCoreStrStartsWith(nm, "fn_"):
            return Ok[int32](8)
        if uirCoreStrStartsWith(nm, "seq_") || uirCoreStrStartsWith(nm, "seq_fixed_") || uirCoreStrStartsWith(nm, "Table_"):
            return Ok[int32](8)
        if uirCoreStrStartsWith(nm, "set_"):
            return Ok[int32](8)
        if nm == "void":
            return Ok[int32](0)
        if (module != nil):
            let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, nm)
            if uirCoreTypeKindOf(aliasTy) == uirCoreTypeKindF64():
                return Ok[int32](8)
            if uirCoreTypeKindOf(aliasTy) == uirCoreTypeKindF32():
                return Ok[int32](4)
            if uirCoreTypeKindOf(aliasTy) == uirCoreTypeKindI64():
                return Ok[int32](8)
            if uirCoreTypeKindOf(aliasTy) == uirCoreTypeKindI32():
                return Ok[int32](4)
            if uirCoreTypeKindOf(aliasTy) == uirCoreTypeKindI16():
                return Ok[int32](2)
            if uirCoreTypeKindOf(aliasTy) == uirCoreTypeKindI8():
                return Ok[int32](1)
            let objAliasName: str = typeNodeObjTypeName(module, typeNode)
            if len(objAliasName) > 0 && uirCoreHasObjType(module, objAliasName):
                let otAlias: UirCoreObjType = uirCoreGetObjType(module, objAliasName)
                return Ok[int32](uirCoreSizeOf(otAlias))
            let resolvedTy: UirCoreType = uirCoreTypeFromNodeWithModule(module, typeNode)
            let resolvedSize: int32 = uirCoreTypeSize(resolvedTy)
            if uirCoreTypeKindOf(resolvedTy) != uirCoreTypeKindVoid() && resolvedSize >= 0:
                return Ok[int32](resolvedSize)
        if (module != nil) && uirCoreHasObjType(module, nm):
            let ot2: UirCoreObjType = uirCoreGetObjType(module, nm)
            return Ok[int32](uirCoreSizeOf(ot2))
        # Bare generic params (`T`/`V`/`K`) lower as pointer-sized runtime values.
        # This must work outside skip-mono too because std generic helpers such as
        # `seqs.SetLen[T]` still evaluate `sizeof T` during ordinary lowering.
        if uirCoreLooksLikeTypeParamName(nm):
            return Ok[int32](8)
        if getEnv("BACKEND_SIZEOF_UNKNOWN_FALLBACK") == "1":
            return Ok[int32](8)
        let line2: str = intToStr(nodePosLine(typeNode))
        let col2: str = intToStr(nodePosCol(typeNode))
        return Err[int32]("uirCore_builder: sizeof unknown type '" + nm + "' @" + line2 + ":" + col2)
    if nodeKind(typeNode) == astNodeKindBracketExpr() && kidCount(typeNode) > 0:
        let base: Node = kid(typeNode, 0)
        if (base != nil) && (nodeKind(base) == astNodeKindIdent() || nodeKind(base) == astNodeKindSymbol()):
            let nm2: str = backendStripSpaces(plainName(base))
            if nm2 == "seq" && (module != nil) && uirCoreHasObjType(module, "seq"):
                let ot3: UirCoreObjType = uirCoreGetObjType(module, "seq")
                return Ok[int32](uirCoreSizeOf(ot3))
            if (module != nil) && uirCoreHasObjType(module, nm2):
                let ot4: UirCoreObjType = uirCoreGetObjType(module, nm2)
                return Ok[int32](uirCoreSizeOf(ot4))
            var instArgs: Node[]
            for ai in 1..<kidCount(typeNode):
                let a: Node = kid(typeNode, ai)
                if astNodeIdValid(a) && nodeKind(a) != astNodeKindEmpty():
                    add(instArgs, a)
            if instArgs.len > 0:
                let instName: str = mangleInstance(nm2, instArgs)
                if (module != nil) && uirCoreHasObjType(module, instName):
                    let ot5: UirCoreObjType = uirCoreGetObjType(module, instName)
                    return Ok[int32](uirCoreSizeOf(ot5))
    let k: str = intToStr(int32(nodeKind(typeNode)))
    let line: str = intToStr(nodePosLine(typeNode))
    let col: str = intToStr(nodePosCol(typeNode))
    return Err[int32]("uirCore_builder: sizeof unsupported type (nk#" + k + " @" + line + ":" + col + ")")

fn uirCoreSizeOfExprOrTypeNode(b: BlockBuilder, argNode0: Node): Result[int32] =
    if b == nil:
        return uirCoreSizeOfTypeNode(nil, argNode0)
    var szRes: Result[int32] = uirCoreSizeOfTypeNode(blockBuilderModule(b), argNode0)
    # `sizeof` is frequently used on fields/locals where typeCache may be missing
    # or cleared by earlier lowering. Recover the byte size from resolved object/local
    # metadata before falling back to a hard error.
    if !IsOk[int32](szRes) && astNodeIdValid(argNode0):
        var da0: DotAccess
        let dotRes0: Result[bool] = uirCoreTryLowerDotAccess(b, argNode0, &da0)
        if IsOk[bool](dotRes0) && Value[bool](dotRes0):
            if uirCoreTypeKindOf(dotAccessFieldTy(da0)) == uirCoreTypeKindI32():
                szRes = Ok[int32](4)
            elif uirCoreTypeKindOf(dotAccessFieldTy(da0)) == uirCoreTypeKindI64():
                szRes = Ok[int32](8)
            elif uirCoreTypeKindOf(dotAccessFieldTy(da0)) == uirCoreTypeKindVoid() && len(dotAccessObjTypeName(da0)) > 0 &&
                 blockBuilderModule(b) != nil && uirCoreHasObjType(blockBuilderModule(b), dotAccessObjTypeName(da0)):
                let ot0: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), dotAccessObjTypeName(da0))
                szRes = Ok[int32](uirCoreSizeOf(ot0))
        elif nodeKind(argNode0) == astNodeKindIdent() || nodeKind(argNode0) == astNodeKindSymbol():
            let nm: str = plainName(argNode0)
            let slot: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
            if slot >= 0:
                let olIdx: int32 = funcFindObjLocal(blockBuilderFuncRef(b), slot)
                if olIdx >= 0:
                    let objNm: str = funcObjTypeName(blockBuilderFuncRef(b), slot)
                    if len(objNm) > 0 && blockBuilderModule(b) != nil && uirCoreHasObjType(blockBuilderModule(b), objNm):
                        let ot1: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), objNm)
                        szRes = Ok[int32](uirCoreSizeOf(ot1))
                else:
                    let ty0: UirCoreType = localType(blockBuilderEnv(b), slot)
                    if uirCoreTypeKindOf(ty0) == uirCoreTypeKindI64():
                        szRes = Ok[int32](8)
                    elif uirCoreTypeKindOf(ty0) == uirCoreTypeKindI32():
                        szRes = Ok[int32](4)
                    elif uirCoreTypeKindOf(ty0) == uirCoreTypeKindVoid():
                        szRes = Ok[int32](0)
            else:
                let gi0: int32 = moduleGlobalIndex(blockBuilderModule(b), nm)
                if gi0 >= 0:
                    let mod0: UirCoreModule = blockBuilderModule(b)
                    let g0: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, gi0)
                    if uirCoreTypeKindOf(uirCoreTypeOf(g0)) == uirCoreTypeKindI64():
                        szRes = Ok[int32](8)
                    elif uirCoreTypeKindOf(uirCoreTypeOf(g0)) == uirCoreTypeKindI32():
                        szRes = Ok[int32](4)
                    elif uirCoreTypeKindOf(uirCoreTypeOf(g0)) == uirCoreTypeKindVoid():
                        szRes = Ok[int32](0)
    if !IsOk[int32](szRes) && astNodeIdValid(argNode0) && nodeTypeCacheValid(argNode0) && astRefNonNil(nodeTypeCache(argNode0)):
        szRes = uirCoreSizeOfTypeNode(blockBuilderModule(b), nodeTypeCache(argNode0))
    return szRes

fn uirCoreFieldLookupDebugKey(parentName: str, fieldName: str): str =
    return uirCoreConcat2(uirCoreConcat2(parentName, "::"), fieldName)

fn uirCoreCanonicalObjLookupKey(key0: str): str =
    let canon: str = uirCoreObjAliasCanon(key0)
    if len(canon) > 0:
        return canon
    return key0

fn uirCoreResolveObjTypeKeyDirect(module: UirCoreModule, key: str): str =
    if module == nil || len(key) == 0:
        return ""
    if uirCoreHasObjType(module, key):
        return key
    let uniq0: str = uirCoreFindObjTypeByBaseUnique(module, key)
    if len(uniq0) > 0:
        return uniq0
    if uirCoreStrStartsWith(key, "seq_") && uirCoreHasObjType(module, "seq"):
        return "seq"
    if uirCoreStrStartsWith(key, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
        return "seq"
    if uirCoreStrStartsWith(key, "Table_") && uirCoreHasObjType(module, "Table"):
        return "Table"
    if uirCoreStrStartsWith(key, "Option_") && ensureOptionObjType(module, key):
        return key
    if uirCoreStrStartsWith(key, "Result_") && ensureResultObjType(module, key):
        return key
    if uirCoreStrStartsWith(key, "__cheng_tables_Entry_") && ensureTablesEntryObjType(module, key):
        return key
    let layout0: str = uirCorePtrBaseObjTypeName(module, key)
    if len(layout0) > 0:
        return layout0
    return ""

fn uirCoreResolveObjTypeKeyBase(module: UirCoreModule, key: str): str =
    if module == nil || len(key) == 0:
        return ""
    let base: str = uirCoreTypeKeyBaseName(key)
    if len(base) == 0 || base == key:
        return ""
    let baseName: str = uirCoreCanonicalObjLookupKey(base)
    let resolved0: str = uirCoreResolveObjTypeKeyDirect(module, baseName)
    if len(resolved0) > 0:
        return resolved0
    let rootObj1: str = uirCoreObjTypeFromCurrentRootDecl(module, baseName)
    if len(rootObj1) > 0:
        return rootObj1
    return ""

fn inferInlineObjFieldTypeName(module: UirCoreModule, parent: UirCoreObjType, fieldName: str, baseOff: int32): str =
    # Match a nested/inlined field by layout against known object types.
    # Example: `Table.keys.*`/`Table.vals.*`/`Table.states.*` matches
    # builtin `seq` (len/cap/buffer) at baseOff.
    if (module == nil) || len(fieldName) == 0 || baseOff < 0:
        return ""
    let rootDeclaredKey: str = uirCoreFieldTypeKeyFromCurrentRoot(module, uirCoreNameOf(parent), fieldName)
    if len(rootDeclaredKey) > 0:
        let rootDeclaredObj0: str = uirCoreObjTypeFromTypeKey(module, rootDeclaredKey)
        if len(rootDeclaredObj0) > 0:
            return rootDeclaredObj0
    let mapped: str = uirCoreInlineObjFieldTypeGet(uirCoreNameOf(parent), fieldName)
    if len(mapped) > 0:
        if (getEnv("BACKEND_DEBUG_OVERLOAD_DOT") == "1") && uirCoreNameOf(parent) == "ProtoBuffer" && fieldName == "out":
            echo("[backend] debugOverloadDot: inferInline mapped parent='ProtoBuffer' field='out' mapped='" + mapped + "'")
        return mapped
    # Prefer declared field type keys over structural matching to avoid
    # aliasing to an unrelated object type with the same flattened layout.
    let declaredKey: str = uirCoreObjFieldTypeKeyGet(uirCoreNameOf(parent), fieldName)
    if (getEnv("BACKEND_DEBUG_OVERLOAD_DOT") == "1") && uirCoreNameOf(parent) == "ProtoBuffer" && fieldName == "out":
        let lookupKeyDbg: str = uirCoreFieldLookupDebugKey(uirCoreNameOf(parent), fieldName)
        let scanEntry: str = uirCoreObjFieldTypeKeyDebugEntry(uirCoreNameOf(parent), fieldName)
        if len(scanEntry) > 0:
            echo("[backend] debugOverloadDot: scan fieldKeyMap key='" + lookupKeyDbg + "' " + scanEntry)
        else:
            echo("[backend] debugOverloadDot: scan fieldKeyMap key='" + lookupKeyDbg + "' missing")
        echo("[backend] debugOverloadDot: lookupKey len=" + intToStr(len(lookupKeyDbg)) +
             " parentLen=" + intToStr(len(uirCoreNameOf(parent))) + " fieldLen=" + intToStr(len(fieldName)))
        echo("[backend] debugOverloadDot: inferInline declaredKey parent='ProtoBuffer' field='out' key='" + declaredKey + "'")
    if len(declaredKey) > 0:
        let declaredObj: str = uirCoreObjTypeFromTypeKey(module, declaredKey)
        if (getEnv("BACKEND_DEBUG_OVERLOAD_DOT") == "1") && uirCoreNameOf(parent) == "ProtoBuffer" && fieldName == "out":
            echo("[backend] debugOverloadDot: inferInline declaredObj parent='ProtoBuffer' field='out' obj='" + declaredObj + "'")
        if len(declaredObj) > 0:
            return declaredObj
    if len(rootDeclaredKey) > 0 && !(rootDeclaredKey == declaredKey):
        let rootDeclaredObj: str = uirCoreObjTypeFromTypeKey(module, rootDeclaredKey)
        if len(rootDeclaredObj) > 0:
            return rootDeclaredObj
    let prefix: str = uirCoreAppendChar(fieldName, '.')
    for ti in 0..<uirCoreModuleObjTypesLen(module):
        let cand: UirCoreObjType = uirCoreModuleObjTypeAt(module, ti)
        if len(uirCoreNameOf(cand)) == 0 || uirCoreFieldsLen(cand) == 0:
            continue
        var ok: bool = true
        for ci in 0..<uirCoreFieldsLen(cand):
            let cf: UirCoreObjField = uirCoreFieldAt(cand, ci)
            let wantName: str = uirCoreConcat2(prefix, uirCoreNameOf(cf))
            let wantOff: int32 = baseOff + uirCoreOffsetOf(cf)
            var found: bool
            for pi in 0..<uirCoreFieldsLen(parent):
                let pf: UirCoreObjField = uirCoreFieldAt(parent, pi)
                if (uirCoreNameOf(pf) == wantName) && uirCoreOffsetOf(pf) == wantOff && uirCoreTypeKindOf(uirCoreTypeOf(pf)) == uirCoreTypeKindOf(uirCoreTypeOf(cf)):
                    found = true
                    break
            if !found:
                ok = false
                break
        if ok:
            return uirCoreNameOf(cand)
    return ""

fn uirCoreInferInlineObjFieldOverloadKey(module: UirCoreModule,
                                         parent: UirCoreObjType,
                                         fieldName: str, baseOff: int32): str =
    if module == nil || len(fieldName) == 0 || baseOff < 0:
        return ""
    let declaredKey: str = uirCoreObjFieldTypeKeyGet(uirCoreNameOf(parent), fieldName)
    if len(declaredKey) > 0:
        return declaredKey
    let rootDeclaredKey: str = uirCoreFieldTypeKeyFromCurrentRoot(module, uirCoreNameOf(parent), fieldName)
    if len(rootDeclaredKey) > 0:
        return rootDeclaredKey
    let mapped: str = uirCoreInlineObjFieldTypeGet(uirCoreNameOf(parent), fieldName)
    if len(mapped) > 0:
        return mapped
    return inferInlineObjFieldTypeName(module, parent, fieldName, baseOff)

fn uirCoreObjTypeFromTypeKey(module: UirCoreModule, typeKey0: str): str =
    if (module == nil) || len(typeKey0) == 0:
        return ""
    var foundRawCached: bool
    let rawCached: str = uirCoreTypeKeyObjNameCacheGet(module, typeKey0, foundRawCached)
    if foundRawCached:
        return rawCached
    let strippedKey: str = uirCoreTypeKeyStripIterWrappers(typeKey0)
    if len(strippedKey) == 0:
        uirCoreTypeKeyObjNameCachePut(module, typeKey0, "")
        return ""
    if !(strippedKey == typeKey0):
        var foundKeyCached: bool
        let keyCached: str = uirCoreTypeKeyObjNameCacheGet(module, strippedKey, foundKeyCached)
        if foundKeyCached:
            uirCoreTypeKeyObjNameCachePut(module, typeKey0, keyCached)
            return keyCached
    let key: str = uirCoreCanonicalObjLookupKey(strippedKey)
    if !(key == strippedKey):
        var foundCanonCached: bool
        let canonCached: str = uirCoreTypeKeyObjNameCacheGet(module, key, foundCanonCached)
        if foundCanonCached:
            uirCoreTypeKeyObjNameCachePutMirrors(module, typeKey0, strippedKey, canonCached)
            return canonCached
    let resolved0: str = uirCoreResolveObjTypeKeyDirect(module, key)
    if len(resolved0) > 0:
        uirCoreTypeKeyObjNameCachePutMirrors(module, typeKey0, key, resolved0)
        return resolved0
    let resolved1: str = uirCoreResolveObjTypeKeyBase(module, key)
    uirCoreTypeKeyObjNameCachePutMirrors(module, typeKey0, key, resolved1)
    return resolved1

fn uirCoreDirectObjValueTypeNameFromKey(module: UirCoreModule, typeKey0: str): str =
    if (module == nil) || len(typeKey0) == 0:
        return ""
    var foundRawCached: bool
    let rawCached: str = uirCoreTypeKeyObjNameCacheGet(module, typeKey0, foundRawCached)
    if foundRawCached:
        return rawCached
    let key: str = uirCoreTypeKeyStripIterWrappers(typeKey0)
    if len(key) == 0:
        uirCoreTypeKeyObjNameCachePut(module, typeKey0, "")
        return ""
    if !(key == typeKey0):
        var foundKeyCached: bool
        let keyCached: str = uirCoreTypeKeyObjNameCacheGet(module, key, foundKeyCached)
        if foundKeyCached:
            uirCoreTypeKeyObjNameCachePut(module, typeKey0, keyCached)
            return keyCached
    let resolved: str = uirCoreObjTypeFromTypeKey(module, key)
    uirCoreTypeKeyObjNameCachePutMirrors(module, typeKey0, key, resolved)
    return resolved

fn uirCoreSemanticStrObjTypeName(module: UirCoreModule, typeKey0: str): str =
    let resolved: str = uirCoreDirectObjValueTypeNameFromKey(module, typeKey0)
    if len(resolved) > 0:
        return resolved
    if (module != nil) && isSemanticStrKey(typeKey0) && uirCoreHasObjType(module, "str"):
        let key: str = uirCoreTypeKeyStripIterWrappers(typeKey0)
        uirCoreTypeKeyObjNameCachePutMirrors(module, typeKey0, key, "str")
        return "str"
    return ""

fn uirCoreTypeNodeObjValueNameFast(module: UirCoreModule, typeNode: Node,
                                   typeKeyHint0: str,
                                   looseKeyHint0: str): str =
    if module == nil || !astNodeIdValid(typeNode) || nodeKind(typeNode) == astNodeKindEmpty():
        return ""
    var foundNodeCached: bool
    let nodeCached: str = uirCoreTypeNodeObjNameCacheTryGetFast(module, typeNode, foundNodeCached)
    if foundNodeCached:
        return nodeCached
    let typeNodeKind: NodeKind = nodeKind(typeNode)
    let typeTextId: int32 =
        (typeNodeKind == astNodeKindIdent() || typeNodeKind == astNodeKindSymbol()) ? typeNodeCanonicalIdentId(typeNode) : 0
    if typeTextId > 0:
        var foundTextCached: bool
        let textCached: str = uirCoreTypeTextObjNameCacheGet(module, typeTextId, foundTextCached)
        if foundTextCached:
            uirCoreTypeNodeObjNameCachePutFast(module, typeNode, textCached)
            return textCached
    let typeKeyHint: str = len(typeKeyHint0) > 0 ? typeKeyHint0 : uirCoreTypeKeyForOverload(typeNode)
    if len(typeKeyHint) > 0:
        let objFromKey: str = uirCoreDirectObjValueTypeNameFromKey(module, typeKeyHint)
        if len(objFromKey) > 0:
            if typeTextId > 0:
                uirCoreTypeTextObjNameCachePut(module, typeTextId, objFromKey)
            uirCoreTypeNodeObjNameCachePutFast(module, typeNode, objFromKey)
            return objFromKey
    let looseKeyHint: str = len(looseKeyHint0) > 0 ? looseKeyHint0 : uirCoreTypeKeyFromNodeLoose(typeNode)
    if len(looseKeyHint) > 0:
        let objFromLooseKey: str = uirCoreDirectObjValueTypeNameFromKey(module, looseKeyHint)
        if len(objFromLooseKey) > 0:
            if typeTextId > 0:
                uirCoreTypeTextObjNameCachePut(module, typeTextId, objFromLooseKey)
            uirCoreTypeNodeObjNameCachePutFast(module, typeNode, objFromLooseKey)
            return objFromLooseKey
    let objFromNode: str = typeNodeObjTypeName(module, typeNode)
    if typeTextId > 0:
        uirCoreTypeTextObjNameCachePut(module, typeTextId, objFromNode)
    uirCoreTypeNodeObjNameCachePutFast(module, typeNode, objFromNode)
    return objFromNode

fn uirCoreTypeNodeObjValueNameFastDefault(module: UirCoreModule, typeNode: Node): str =
    return uirCoreTypeNodeObjValueNameFast(module, typeNode, "", "")

fn uirCoreTypeNodeObjValueNameFastWithTypeKey(module: UirCoreModule, typeNode: Node,
                                              typeKeyHint0: str): str =
    return uirCoreTypeNodeObjValueNameFast(module, typeNode, typeKeyHint0, "")

fn uirCoreDotObjTypeNameFromKey(module: UirCoreModule, key0: str): str =
    if (module == nil):
        return ""
    let key: str = uirCoreTypeKeyStripIterWrappers(uirCoreStripRefVarKeyOnce(key0))
    if len(key) == 0:
        return ""
    let recoveredObjKey0: str = uirCoreRecoverLegacyGenericObjKey(module, key)
    if len(recoveredObjKey0) > 0:
        return recoveredObjKey0
    let obj0: str = uirCoreObjTypeFromTypeKey(module, key)
    if len(obj0) > 0:
        return obj0
    let rootObj0: str = uirCoreObjTypeFromCurrentRootDecl(module, key)
    if len(rootObj0) > 0:
        return rootObj0
    if uirCoreStrStartsWith(key, "array_"):
        for i0 in 6..<len(key):
            if key[i0] == '_':
                let suffix: str = rawmemStrFromOffset(key, i0 + 1)
                let suffixObj: str = uirCoreDotObjTypeNameFromKey(module, suffix)
                if len(suffixObj) > 0:
                    return suffixObj
    return ""

fn uirCoreIndexedElemObjTypeNameFromKey(module: UirCoreModule, key0: str): str =
    if (module == nil):
        return ""
    let key: str = uirCoreTypeKeyStripIterWrappers(key0)
    if len(key) == 0:
        return ""
    if uirCoreStrStartsWith(key, "seq_"):
        let elemKey: str = uirCoreTypeKeyStripIterWrappers(rawmemStrFromOffset(key, 4))
        if len(elemKey) > 0:
            let elemObj: str = uirCoreDotObjTypeNameFromKey(module, elemKey)
            if len(elemObj) > 0:
                return elemObj
            if uirCoreStrStartsWith(elemKey, "seq_") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if uirCoreStrStartsWith(elemKey, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if uirCoreStrStartsWith(elemKey, "Table_") && uirCoreHasObjType(module, "Table"):
                return "Table"
    elif uirCoreStrStartsWith(key, "seq_fixed_"):
        let elemKey2: str = uirCoreTypeKeyStripIterWrappers(rawmemStrFromOffset(key, 10))
        if len(elemKey2) > 0:
            let elemObj2: str = uirCoreDotObjTypeNameFromKey(module, elemKey2)
            if len(elemObj2) > 0:
                return elemObj2
            if uirCoreStrStartsWith(elemKey2, "seq_") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if uirCoreStrStartsWith(elemKey2, "seq_fixed_") && uirCoreHasObjType(module, "seq"):
                return "seq"
            if uirCoreStrStartsWith(elemKey2, "Table_") && uirCoreHasObjType(module, "Table"):
                return "Table"
    return uirCoreDotObjTypeNameFromKey(module, key)

fn uirCoreGlobalObjTypeNameFromSymbol(module: UirCoreModule, symName: str): str =
    if (module == nil) || len(symName) == 0:
        return ""
    let obj0: str = uirCoreGlobalObjTypeGet(symName)
    if len(obj0) > 0:
        return obj0
    return uirCoreDotObjTypeNameFromKey(module, uirCoreGlobalTypeKeyGet(symName))

fn uirCoreInferValueCallInnerKey(b: BlockBuilder, callNode: Node): str =
    if (b == nil) || !astNodeIdValid(callNode) || nodeKind(callNode) != astNodeKindCall() || kidCount(callNode) <= 1:
        return ""
    let dbgValueInner: bool = (getEnv("BACKEND_DEBUG_VALUE_CALLSITE") == "1")
    let calleeName0: str = uirCoreCallCalleeName(callNode)
    let valueLikeCall0: bool = (calleeName0 == "Value") ||
        uirCoreStrStartsWith(calleeName0, "Value_") ||
        uirCoreStrStartsWith(calleeName0, "Value__")
    if dbgValueInner:
        let line0: str = intToStr(nodePosLine(callNode))
        let col0: str = intToStr(nodePosCol(callNode))
        echo("[backend] debugValueInner: callee='" + calleeName0 + "' valueLike=" +
             (valueLikeCall0 ? "1" : "0") + " @" + line0 + ":" + col0)
    # Relaxed fallback: some stage1 paths keep callee names qualified/mangled.
    # For unary calls whose first arg is a Result helper wrapper, still recover the inner value key.
    if !valueLikeCall0 && kidCount(callNode) != 2:
        return ""
    var arg0: Node = kid(callNode, 1)
    if astNodeIdValid(arg0) && nodeKind(arg0) == astNodeKindCallArg() && kidCount(arg0) > 1:
        arg0 = kid(arg0, 1)
    var argKey0: str = caseInferExprTypeKey(b, arg0)
    if len(argKey0) == 0:
        argKey0 = uirCoreInferNodeTypeKeyForOverload(b, arg0)
    if (len(argKey0) == 0) && astNodeIdValid(arg0) && nodeTypeCacheValid(arg0) && astRefNonNil(nodeTypeCache(arg0)):
        argKey0 = typeKey(nodeTypeCache(arg0))
        if len(argKey0) == 0:
            argKey0 = uirCoreTypeKeyFromNodeLoose(nodeTypeCache(arg0))
    if (len(argKey0) == 0) && (arg0 != nil) && (nodeKind(arg0) == astNodeKindIdent() || nodeKind(arg0) == astNodeKindSymbol()):
        let nm0: str = backendStripSpaces(plainName(arg0))
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm0)
        if slot0 >= 0:
            argKey0 = localTypeKey(blockBuilderEnv(b), slot0)
        if (len(argKey0) == 0) && blockBuilderModule(b) != nil:
            argKey0 = uirCoreGlobalTypeKeyByBaseUnique(blockBuilderModule(b), nm0)
    if len(argKey0) > 0:
        argKey0 = uirCoreTypeKeyStripIterWrappers(argKey0)
    if len(argKey0) > 0 && uirCoreStrStartsWith(argKey0, "Result_"):
        let valKey0: str = rawmemStrFromOffset(argKey0, 7)
        if dbgValueInner:
            echo("[backend] debugValueInner: argKey='" + argKey0 + "' valKey='" + valKey0 + "'")
        if len(valKey0) > 0:
            return valKey0
    if blockBuilderModule(b) != nil && len(argKey0) > 0:
        let objName0: str = uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), argKey0)
        if len(objName0) > 0:
            let valueKey0: str = uirCoreObjFieldTypeKeyGet(objName0, "value")
            if len(valueKey0) > 0:
                return valueKey0
    return ""

fn uirCoreResolveGlobalObjTypeName(b: BlockBuilder, baseName0: str): str =
    if (b == nil) || blockBuilderModule(b) == nil || len(baseName0) == 0:
        return ""
    let mod0: UirCoreModule = blockBuilderModule(b)
    let debugDot: bool = (getEnv("BACKEND_DEBUG_DOT") == "1")
    let baseName: str = backendStripSpaces(baseName0)
    if len(baseName) == 0:
        return ""
    let obj0: str = uirCoreGlobalObjTypeGet(baseName)
    if len(obj0) > 0:
        return obj0
    let key0: str = uirCoreGlobalTypeKeyGet(baseName)
    let obj1: str = uirCoreDotObjTypeNameFromKey(mod0, key0)
    if len(obj1) > 0:
        return obj1
    let gi0: int32 = moduleGlobalIndex(mod0, baseName)
    if debugDot:
        echo("[backend] debugDot: globalObjProbe base='" + baseName + "' obj0='" + obj0 +
             "' key0='" + key0 + "' obj1='" + obj1 + "' gi0=" + intToStr(gi0))
    if gi0 >= 0 && gi0 < uirCoreModuleGlobalsLen(mod0):
        let g0: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, gi0)
        let gObj0: str = uirCoreGlobalObjTypeNameFromSymbol(mod0, uirCoreNameOf(g0))
        if len(gObj0) > 0:
            return gObj0
        let gKey0: str = uirCoreGlobalTypeKeyGet(uirCoreNameOf(g0))
        let gObj1: str = uirCoreDotObjTypeNameFromKey(mod0, gKey0)
        if debugDot:
            echo("[backend] debugDot: globalObjProbe exact uirCoreNameOf(g)='" + uirCoreNameOf(g0) +
                 "' gObj0='" + gObj0 + "' gKey0='" + gKey0 + "' gObj1='" + gObj1 +
                 "' g.origin='" + uirCoreGlobalOriginFileOf(g0) + "' uirCoreTypeOf(g)=nk#" + intToStr(int32(uirCoreTypeKindOf(uirCoreTypeOf(g0)))) + "'")
        if len(gObj1) > 0:
            return gObj1
    if uirCoreFuncIdValid(blockBuilderFuncRef(b)) && uirCoreDupGlobalNamesHas(baseName):
        let f0: UirCoreFunc = blockBuilderFuncRef(b)
        let sym0: str = uirCoreMaybeMangleDupGlobalName(baseName, uirCoreFuncOriginFileOf(f0))
        if debugDot:
            echo("[backend] debugDot: globalObjProbe dup base='" + baseName + "' sym0='" + sym0 + "'")
        if len(sym0) > 0 && !(sym0 == baseName):
            let mObj0: str = uirCoreGlobalObjTypeNameFromSymbol(mod0, sym0)
            if len(mObj0) > 0:
                return mObj0
            let mKey0: str = uirCoreGlobalTypeKeyGet(sym0)
            let mObj1: str = uirCoreDotObjTypeNameFromKey(mod0, mKey0)
            if debugDot:
                echo("[backend] debugDot: globalObjProbe dup sym0='" + sym0 +
                     "' mObj0='" + mObj0 + "' mKey0='" + mKey0 + "' mObj1='" + mObj1 + "'")
            if len(mObj1) > 0:
                return mObj1
            let mGi0: int32 = moduleGlobalIndex(mod0, sym0)
            if mGi0 >= 0 && mGi0 < uirCoreModuleGlobalsLen(mod0):
                let mg0: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, mGi0)
                let mgObj0: str = uirCoreGlobalObjTypeNameFromSymbol(mod0, uirCoreNameOf(mg0))
                if len(mgObj0) > 0:
                    return mgObj0
                let mgKey0: str = uirCoreGlobalTypeKeyGet(uirCoreNameOf(mg0))
                let mgObj1: str = uirCoreDotObjTypeNameFromKey(mod0, mgKey0)
                if debugDot:
                    echo("[backend] debugDot: globalObjProbe dup-index uirCoreNameOf(mg)='" + uirCoreNameOf(mg0) +
                         "' mgObj0='" + mgObj0 + "' mgKey0='" + mgKey0 + "' mgObj1='" + mgObj1 + "'")
                if len(mgObj1) > 0:
                    return mgObj1
    let uniqGi: int32 = moduleFindGlobalIndexByBaseUnique(mod0, baseName)
    if uniqGi >= 0 && uniqGi < uirCoreModuleGlobalsLen(mod0):
        let ug: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, uniqGi)
        let uObj0: str = uirCoreGlobalObjTypeNameFromSymbol(mod0, uirCoreNameOf(ug))
        if len(uObj0) > 0:
            return uObj0
        let uKey0: str = uirCoreGlobalTypeKeyGet(uirCoreNameOf(ug))
        let uObj1: str = uirCoreDotObjTypeNameFromKey(mod0, uKey0)
        if len(uObj1) > 0:
            return uObj1
    let uniqKey: str = uirCoreGlobalTypeKeyByBaseUnique(mod0, baseName)
    let uniqObj: str = uirCoreDotObjTypeNameFromKey(mod0, uniqKey)
    if debugDot:
        echo("[backend] debugDot: globalObjProbe uniq base='" + baseName +
             "' uniqGi=" + intToStr(uniqGi) + " uniqKey='" + uniqKey + "' uniqObj='" + uniqObj + "'")
    if len(uniqObj) > 0:
        return uniqObj
    return ""

fn uirCoreBracketBaseKeyFromDotAccess(b: BlockBuilder, base0: Node): str =
    if b == nil || base0 == nil:
        return ""
    var da0: DotAccess
    let dotKeyRes0: Result[bool] = uirCoreTryLowerDotAccess(b, base0, &da0)
    if !IsOk[bool](dotKeyRes0):
        return ""
    if Value[bool](dotKeyRes0) && uirCoreTypeKindOf(dotAccessFieldTy(da0)) == uirCoreTypeKindVoid() && len(dotAccessObjTypeName(da0)) > 0:
        return dotAccessObjTypeName(da0)
    return ""

fn uirCoreBracketBaseKeyInitial(b: BlockBuilder, base0: Node): str =
    if b == nil || base0 == nil:
        return ""
    if nodeKind(base0) == astNodeKindIdent() || nodeKind(base0) == astNodeKindSymbol():
        let slot0Name: str = backendStripSpaces(plainName(base0))
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), slot0Name)
        if slot0 >= 0:
            let localKey0: str = localTypeKey(blockBuilderEnv(b), slot0)
            if len(localKey0) > 0:
                return localKey0
    let shallowKey: str = exprTypeKeyShallow(b, base0)
    if len(shallowKey) > 0:
        return shallowKey
    let dotKey0: str = uirCoreBracketBaseKeyFromDotAccess(b, base0)
    if len(dotKey0) > 0:
        return dotKey0
    if nodeKind(base0) == astNodeKindIdent() || nodeKind(base0) == astNodeKindSymbol():
        let base0Name: str = backendStripSpaces(plainName(base0))
        return uirCoreResolveGlobalObjTypeName(b, base0Name)
    return ""

fn uirCoreBracketParentObjTypeName(b: BlockBuilder, parentNode0: Node): str =
    if b == nil || parentNode0 == nil:
        return ""
    let parentKey0: str = caseInferExprTypeKey(b, parentNode0)
    let parentObj0: str = uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), parentKey0)
    if len(parentObj0) > 0:
        return parentObj0
    if nodeKind(parentNode0) == astNodeKindIdent() || nodeKind(parentNode0) == astNodeKindSymbol():
        let parentName0: str = backendStripSpaces(plainName(parentNode0))
        return uirCoreResolveGlobalObjTypeName(b, parentName0)
    return ""

fn uirCoreBracketParentFieldKey(b: BlockBuilder, base0: Node, key0: str): str =
    if b == nil || !astNodeIdValid(base0) || nodeKind(base0) != astNodeKindDotExpr() || kidCount(base0) <= 1:
        return ""
    if len(key0) == 0 || !(key0 == "seq" || key0 == "Table"):
        return ""
    let parentNode0: Node = kid(base0, 0)
    let memberNode0: Node = kid(base0, 1)
    let memberName0: str = backendStripSpaces(plainName(memberNode0))
    let parentObj0: str = uirCoreBracketParentObjTypeName(b, parentNode0)
    if len(parentObj0) == 0 || len(memberName0) == 0:
        return ""
    return backendStripSpaces(uirCoreObjFieldTypeKeyGet(parentObj0, memberName0))

fn uirCoreBracketBaseResolvedKey(b: BlockBuilder, base0: Node): str =
    let initialKey: str = uirCoreBracketBaseKeyInitial(b, base0)
    if len(initialKey) == 0:
        return ""
    if (base0 == nil) || !(initialKey == "seq" || initialKey == "Table"):
        return initialKey
    let refinedKey: str = caseInferExprTypeKey(b, base0)
    if len(refinedKey) > 0 && !(refinedKey == initialKey):
        let fieldKey0: str = uirCoreBracketParentFieldKey(b, base0, refinedKey)
        if len(fieldKey0) > 0:
            return fieldKey0
        return refinedKey
    let fieldKey1: str = uirCoreBracketParentFieldKey(b, base0, initialKey)
    if len(fieldKey1) > 0:
        return fieldKey1
    return initialKey

fn uirCoreIndexedElemObjTypeNameOrEmpty(module: UirCoreModule, key0: str): str =
    if len(key0) > 0:
        return uirCoreIndexedElemObjTypeNameFromKey(module, key0)
    return ""

fn uirCoreDotResolveBracketBaseObjTypeName(b: BlockBuilder, base: Node, dotNode: Node,
                                           debugDot: bool): str =
    if (b == nil) || !astNodeIdValid(base) || nodeKind(base) != astNodeKindBracketExpr() || kidCount(base) != 2:
        return ""
    let base0: Node = kid(base, 0)
    if astNodeIdValid(base0) && nodeTypeCacheValid(base0) && astRefNonNil(nodeTypeCache(base0)):
        var t0: Node = nodeTypeCache(base0)
        while astNodeIdValid(t0) && nodeKind(t0) == astNodeKindPar() && kidCount(t0) > 0:
            t0 = kid(t0, 0)
        if astNodeIdValid(t0) && nodeKind(t0) == astNodeKindVarTy() && kidCount(t0) > 0:
            t0 = kid(t0, 0)
        if (t0 != nil) && (nodeKind(t0) == astNodeKindRefTy() || nodeKind(t0) == astNodeKindPtrTy()) && kidCount(t0) > 0:
            t0 = kid(t0, 0)
        if astNodeIdValid(t0) && nodeKind(t0) == astNodeKindBracketExpr() && kidCount(t0) > 0:
            let tyBase: Node = kid(t0, 0)
            if (tyBase != nil) && (nodeKind(tyBase) == astNodeKindIdent() || nodeKind(tyBase) == astNodeKindSymbol()):
                let tyName: str = backendStripSpaces(plainName(tyBase))
                if (tyName == "array") && kidCount(t0) >= 3:
                    let arg1: Node = kid(t0, 1)
                    let arg2: Node = kid(t0, 2)
                    let c1: int32 = tryResolveArrayCount(blockBuilderModule(b), arg1)
                    let c2: int32 = tryResolveArrayCount(blockBuilderModule(b), arg2)
                    var elemTypeNode: Node = astInvalidNodeId()
                    if c1 > 0 && c2 <= 0:
                        elemTypeNode = arg2
                    elif c2 > 0 && c1 <= 0:
                        elemTypeNode = arg1
                    elif c1 > 0 && c2 > 0:
                        elemTypeNode = arg2
                    if astNodeIdValid(elemTypeNode) && nodeKind(elemTypeNode) != astNodeKindEmpty():
                        let objTypeName0: str = typeNodeObjTypeName(blockBuilderModule(b), elemTypeNode)
                        if len(objTypeName0) > 0:
                            return objTypeName0
                elif (tyName == "seq") && kidCount(t0) >= 2:
                    let elemTypeNode2: Node = kid(t0, 1)
                    if astNodeIdValid(elemTypeNode2) && nodeKind(elemTypeNode2) != astNodeKindEmpty():
                        let objTypeName1: str = typeNodeObjTypeName(blockBuilderModule(b), elemTypeNode2)
                        if len(objTypeName1) > 0:
                            return objTypeName1
                elif (tyName == "seq_fixed") && kidCount(t0) >= 2:
                    let elemTypeNode3: Node = kid(t0, 1)
                    if astNodeIdValid(elemTypeNode3) && nodeKind(elemTypeNode3) != astNodeKindEmpty():
                        let objTypeName2: str = typeNodeObjTypeName(blockBuilderModule(b), elemTypeNode3)
                        if len(objTypeName2) > 0:
                            return objTypeName2
    let key0: str = uirCoreBracketBaseResolvedKey(b, base0)
    let objTypeName: str = uirCoreIndexedElemObjTypeNameOrEmpty(blockBuilderModule(b), key0)
    if debugDot && len(objTypeName) == 0:
        var bKind: int32 = -1
        if (base0 != nil):
            bKind = int32(nodeKind(base0))
        let lineD: str = intToStr(nodePosLine(dotNode))
        let colD: str = intToStr(nodePosCol(dotNode))
        echo("[backend] debugDot: bracket-dot missing objTypeName key0='" + key0 +
            "' base0Kind=nk#" + intToStr(bKind) + " @" + lineD + ":" + colD)
    return objTypeName

fn uirCoreDotResolveCallBaseObjTypeName(b: BlockBuilder, base: Node, debugDot: bool): str =
    if (b == nil) || !astNodeIdValid(base) || nodeKind(base) != astNodeKindCall() || blockBuilderModule(b) == nil:
        return ""
    let callName: str = uirCoreCallNameForReachability(blockBuilderModule(b), base)
    if debugDot:
        echo("[backend] debugDot: call-dot callName='" + callName + "'")
    if len(callName) > 0:
        var callee0: UirCoreFunc = moduleFindFunc(blockBuilderModule(b), callName)
        if (callee0 == nil):
            callee0 = moduleFindFuncByBaseUnique(blockBuilderModule(b), callName)
        if (callee0 != nil) && len(uirCoreFuncRetTypeKeyOf(callee0)) > 0:
            let key: str = uirCoreFuncRetTypeKeyOf(callee0)
            let objTypeName0: str = uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), key)
            if debugDot:
                echo("[backend] debugDot: call-dot callee retTypeKey='" + uirCoreFuncRetTypeKeyOf(callee0) +
                     "' objTypeFromRet='" + objTypeName0 + "'")
            if len(objTypeName0) > 0:
                return objTypeName0
    if kidCount(base) > 1:
        let valKey0: str = uirCoreInferValueCallInnerKey(b, base)
        if debugDot:
            echo("[backend] debugDot: call-dot valKey='" + valKey0 + "'")
        if len(valKey0) > 0:
            let objTypeName1: str = uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), valKey0)
            if debugDot:
                echo("[backend] debugDot: call-dot objTypeFromVal='" + objTypeName1 + "'")
            if len(objTypeName1) > 0:
                return objTypeName1
    let callKey2: str = caseInferExprTypeKey(b, base)
    if debugDot:
        echo("[backend] debugDot: call-dot callExprKey='" + callKey2 + "'")
    if len(callKey2) > 0:
        let objTypeName2: str = uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), callKey2)
        if debugDot:
            echo("[backend] debugDot: call-dot objTypeFromExprKey='" + objTypeName2 + "'")
        return objTypeName2
    return ""

fn uirCoreDotResolveHiddenDerefBaseObjTypeName(b: BlockBuilder, base: Node): str =
    if (b == nil) || !astNodeIdValid(base) ||
       !((nodeKind(base) == astNodeKindHiddenDeref() || nodeKind(base) == astNodeKindDerefExpr()) && kidCount(base) > 0):
        return ""
    let inner: Node = kid(base, 0)
    if astNodeIdValid(inner) && nodeTypeCacheValid(inner) && astRefNonNil(nodeTypeCache(inner)):
        return typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(inner))
    if (inner != nil) && (nodeKind(inner) == astNodeKindIdent() || nodeKind(inner) == astNodeKindSymbol()):
        let slot2: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), plainName(inner))
        if slot2 >= 0:
            let objTypeName0: str = funcObjTypeName(blockBuilderFuncRef(b), slot2)
            if len(objTypeName0) > 0:
                return objTypeName0
            let key2: str = localTypeKey(blockBuilderEnv(b), slot2)
            let objTypeName1: str = uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), key2)
            if len(objTypeName1) > 0:
                return objTypeName1
    if (inner != nil) && blockBuilderModule(b) != nil:
        let key3: str = exprTypeKeyShallow(b, inner)
        return uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), key3)
    return ""

fn uirCoreNormalizeDotFieldName(b: BlockBuilder, dotNode: Node, base: Node, baseName: str,
                                objTypeName: str, ot: UirCoreObjType, field: Node): str =
    var fieldName: str = uirCoreMemberName(field)
    if len(fieldName) == 0:
        fieldName = uirCoreGuessIdentNameFromSource(blockBuilderFuncRef(b), field)
    if len(fieldName) == 0:
        fieldName = uirCoreGuessDotFieldNameFromSource(blockBuilderFuncRef(b), dotNode)
    let seqLikeObj: bool = (uirCoreNameOf(ot) == "seq") || (objTypeName == "seq") ||
        uirCoreStrStartsWith(objTypeName, "seq_") || uirCoreStrStartsWith(objTypeName, "seq_fixed_")
    var seqGuessBaseName: str = baseName
    if len(seqGuessBaseName) == 0 && astNodeIdValid(base) &&
       (nodeKind(base) == astNodeKindHiddenDeref() || nodeKind(base) == astNodeKindDerefExpr()) && kidCount(base) > 0:
        seqGuessBaseName = backendStripSpaces(plainName(kid(base, 0)))
    if len(fieldName) == 0 && seqLikeObj:
        fieldName = uirCoreGuessSeqBuiltinFieldFromSource(blockBuilderFuncRef(b), dotNode, seqGuessBaseName)
    let seqFieldName: str = uirCoreSeqBuiltinFieldName(fieldName)
    if seqLikeObj && (seqFieldName == "len" || seqFieldName == "cap" || seqFieldName == "buffer"):
        return seqFieldName
    if fieldName == "data" && uirCoreNameOf(ot) == "seq":
        return "buffer"
    return fieldName

fn uirCoreMakeDotAccessRaw(basePtr: UirExprId, fieldTy: UirCoreType,
                           objTypeName: str, offset: int32): DotAccess =
    var addr: UirExprId = basePtr
    if offset != 0:
        addr = uirCoreBin(uirCoreBinOpAdd(), basePtr, uirCoreConstI64(int64(offset)))
    var da: DotAccess
    dotAccessSetAddr(da, addr)
    dotAccessSetFieldTy(da, fieldTy)
    dotAccessSetObjTypeName(da, objTypeName)
    return da

fn uirCoreMakeDotAccessForField(module: UirCoreModule, ot: UirCoreObjType, basePtr: UirExprId,
                                fieldTy: UirCoreType, fieldName: str, offset: int32): DotAccess =
    return uirCoreMakeDotAccessRaw(basePtr, fieldTy,
                                   inferInlineObjFieldTypeName(module, ot, fieldName, offset),
                                   offset)

fn uirCoreObjFieldIndexByName(ot: UirCoreObjType, fieldName: str): int32 =
    for fi in 0..<uirCoreFieldsLen(ot):
        let f: UirCoreObjField = uirCoreFieldAt(ot, fi)
        if uirCoreNameOf(f) == fieldName:
            return fi
    return -1

fn uirCoreTupleAliasFieldIndex(base: Node, objTypeName: str, fieldName: str): int32 =
    var ti: int32 = uirCoreTupleFieldIndexGet(objTypeName, fieldName)
    if ti >= 0 || ti == -2:
        return ti
    if astNodeIdValid(base) && nodeTypeCacheValid(base) && astRefNonNil(nodeTypeCache(base)):
        var tc: Node = nodeTypeCache(base)
        while astNodeIdValid(tc) && nodeKind(tc) == astNodeKindPar() && kidCount(tc) > 0:
            tc = kid(tc, 0)
        if astNodeIdValid(tc) && nodeKind(tc) == astNodeKindVarTy() && kidCount(tc) > 0:
            tc = kid(tc, 0)
        if (tc != nil) && (nodeKind(tc) == astNodeKindRefTy() || nodeKind(tc) == astNodeKindPtrTy()) && kidCount(tc) > 0:
            tc = kid(tc, 0)
        if astNodeIdValid(tc) && nodeKind(tc) == astNodeKindTupleTy():
            for tj in 0..<kidCount(tc):
                let elem: Node = kid(tc, tj)
                if astNodeIdValid(elem) && nodeKind(elem) == astNodeKindIdentDefs() && kidCount(elem) > 0:
                    let nameNode: Node = kid(elem, 0)
                    if (nameNode != nil) && (nodeKind(nameNode) == astNodeKindIdent() || nodeKind(nameNode) == astNodeKindSymbol()):
                        let lbl: str = backendStripSpaces(plainName(nameNode))
                        if len(lbl) > 0 && (lbl == fieldName):
                            uirCoreTupleFieldIndexPut(objTypeName, fieldName, tj)
                            return tj
    return ti

fn uirCoreObjInlineFieldBaseOffset(ot: UirCoreObjType, fieldName: str): int32 =
    let fieldLenPrefix: int32 = len(fieldName)
    if fieldLenPrefix <= 0:
        return -1
    var baseOff: int32 = -1
    for fj in 0..<uirCoreFieldsLen(ot):
        let f2: UirCoreObjField = uirCoreFieldAt(ot, fj)
        if len(uirCoreNameOf(f2)) <= fieldLenPrefix:
            continue
        if !uirCoreStrEqAt(uirCoreNameOf(f2), 0, fieldName):
            continue
        if uirCoreNameOf(f2)[fieldLenPrefix] != '.':
            continue
        if baseOff < 0 || uirCoreOffsetOf(f2) < baseOff:
            baseOff = uirCoreOffsetOf(f2)
    return baseOff

fn uirCoreDebugDotFail(b: BlockBuilder, base: Node, baseName: str, objTypeName: str,
                       basePtrRes: Result[UirExprId]) =
    var bKind2: int32 = -1
    if (base != nil):
        bKind2 = int32(nodeKind(base))
    let okPtr: bool = IsOk[UirExprId](basePtrRes)
    echo("[backend] debugDot: dotFail objTypeName='" + objTypeName + "' baseKind=nk#" +
        intToStr(bKind2) + " basePtrOk=" + uirCoreDebugBool01(okPtr) +
        " moduleNil=" + uirCoreDebugBool01((b == nil) || blockBuilderModule(b) == nil))
    if len(baseName) > 0 && (b != nil) && blockBuilderEnv(b) != nil:
        let dbgSlot: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), baseName)
        var dbgMsgParts: str[]
        add(dbgMsgParts, "[backend] debugDot: baseName='")
        add(dbgMsgParts, baseName)
        add(dbgMsgParts, "' slot=")
        add(dbgMsgParts, intToStr(dbgSlot))
        if dbgSlot >= 0 && uirCoreFuncIdValid(blockBuilderFuncRef(b)):
            let fObj: str = funcObjTypeName(blockBuilderFuncRef(b), dbgSlot)
            let fKey: str = funcObjTypeKey(blockBuilderFuncRef(b), dbgSlot)
            let lKey: str = localTypeKey(blockBuilderEnv(b), dbgSlot)
            let lKey0: str = uirCoreStripRefVarKeyOnce(lKey)
            add(dbgMsgParts, " funcObjTypeName='")
            add(dbgMsgParts, fObj)
            add(dbgMsgParts, "' funcObjTypeKey='")
            add(dbgMsgParts, fKey)
            add(dbgMsgParts, "' localTypeKey='")
            add(dbgMsgParts, lKey)
            add(dbgMsgParts, "' localTypeKeyStrip='")
            add(dbgMsgParts, lKey0)
            add(dbgMsgParts, "'")
            let hasObj: bool = len(lKey0) > 0 && uirCoreHasObjType(blockBuilderModule(b), lKey0)
            add(dbgMsgParts, " hasObj=")
            add(dbgMsgParts, uirCoreDebugBool01(hasObj))
            if !hasObj && blockBuilderModule(b) != nil && len(lKey0) > 0:
                let modDbg: UirCoreModule = blockBuilderModule(b)
                let pref0: str = uirCoreAppendChar(lKey0, '_')
                var shown0: int32
                for oi0 in 0..<uirCoreModuleObjTypesLen(modDbg):
                    let ot0: UirCoreObjType = uirCoreModuleObjTypeAt(modDbg, oi0)
                    if len(uirCoreNameOf(ot0)) == 0:
                        continue
                    if uirCoreNameOf(ot0) == lKey0 || uirCoreStrStartsWith(uirCoreNameOf(ot0), pref0):
                        echo("[backend] debugDot: localKeyCandidate key='" + lKey0 +
                             "' cand='" + uirCoreNameOf(ot0) + "'")
                        shown0 = shown0 + 1
                        if shown0 >= 6:
                            break
        echo fmt(dbgMsgParts)
        let altName: str = uirCoreConcat2(baseName, "Res")
        let altSlot: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), altName)
        if altSlot >= 0:
            let altKey: str = localTypeKey(blockBuilderEnv(b), altSlot)
            echo("[backend] debugDot: altName='" + altName + "' slot=" + intToStr(altSlot) +
                 " localTypeKey='" + altKey + "'")
    if astNodeIdValid(base) && nodeTypeCacheValid(base) && astRefNonNil(nodeTypeCache(base)):
        let tc: Node = nodeTypeCache(base)
        let tcKind2: str = intToStr(int32(nodeKind(tc)))
        let tcName: str = backendStripSpaces(plainName(tc))
        let tcKey: str = typeKey(tc)
        let tcObj: str = typeNodeObjTypeName(blockBuilderModule(b), tc)
        echo("[backend] debugDot: nodeTypeCache(base) kind=nk#" + tcKind2 + " name='" + tcName +
            "' key='" + tcKey + "' objTypeName='" + tcObj + "'")
    if !okPtr:
        echo("[backend] debugDot: dotFail basePtrErr=" + Error(basePtrRes))

fn uirCoreTryResolveDotBaseFromLocal(b: BlockBuilder, base: Node, baseName: var str,
                                     objTypeName: var str, basePtrRes: var Result[UirExprId]) =
    if (base == nil) || !((nodeKind(base) == astNodeKindIdent()) || (nodeKind(base) == astNodeKindSymbol())):
        return
    baseName = backendStripSpaces(plainName(base))
    let slot: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), baseName)
    uirCoreMarkImplicitResultUse(b, baseName, slot)
    if slot < 0:
        return
    objTypeName = funcObjTypeName(blockBuilderFuncRef(b), slot)
    if len(objTypeName) > 0:
        basePtrRes = Ok[UirExprId](uirCoreLocal(slot))
        return
    let key: str = localTypeKey(blockBuilderEnv(b), slot)
    let objFromKey0: str = uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), key)
    if len(objFromKey0) > 0:
        objTypeName = objFromKey0
        basePtrRes = Ok[UirExprId](uirCoreLocal(slot))

fn uirCoreResolveDotBaseFallback(b: BlockBuilder, base: Node, dotNode: Node, baseName: str,
                                 debugDot: bool, objTypeName: var str, basePtrRes: var Result[UirExprId]) =
    if astNodeIdValid(base) && nodeKind(base) == astNodeKindBracketExpr() && kidCount(base) == 2:
        let bracketObjTypeName: str = uirCoreDotResolveBracketBaseObjTypeName(b, base, dotNode, debugDot)
        if len(bracketObjTypeName) > 0:
            objTypeName = bracketObjTypeName
    if len(objTypeName) == 0 && len(baseName) > 0:
        let gObj: str = uirCoreResolveGlobalObjTypeName(b, baseName)
        if len(gObj) > 0:
            objTypeName = gObj
    var da0: DotAccess
    let dotBaseRes: Result[bool] = uirCoreTryLowerDotAccess(b, base, &da0)
    if IsOk[bool](dotBaseRes) && Value[bool](dotBaseRes):
        if len(dotAccessObjTypeName(da0)) > 0:
            objTypeName = dotAccessObjTypeName(da0)
            basePtrRes = Ok[UirExprId](dotAccessAddr(da0))
        elif uirCoreTypeKindOf(dotAccessFieldTy(da0)) == uirCoreTypeKindVoid():
            basePtrRes = Ok[UirExprId](dotAccessAddr(da0))
    if astNodeIdValid(base) && nodeTypeCacheValid(base) && astRefNonNil(nodeTypeCache(base)):
        let cachedObjTypeName: str = typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(base))
        if len(cachedObjTypeName) > 0:
            objTypeName = cachedObjTypeName
    if len(objTypeName) == 0 && astNodeIdValid(base) && nodeKind(base) == astNodeKindCall() && blockBuilderModule(b) != nil:
        objTypeName = uirCoreDotResolveCallBaseObjTypeName(b, base, debugDot)
    if len(objTypeName) == 0 && (base != nil) &&
       (nodeKind(base) == astNodeKindHiddenDeref() || nodeKind(base) == astNodeKindDerefExpr()) && kidCount(base) > 0:
        objTypeName = uirCoreDotResolveHiddenDerefBaseObjTypeName(b, base)
    if !IsOk[UirExprId](basePtrRes):
        basePtrRes = lowerExprValue(b, base, uirCoreTypeI64())

fn uirCoreFirstNonEmptyStr(primary: str, fallback: str): str =
    if len(primary) > 0:
        return primary
    return fallback

fn uirCoreDotBaseName(base: Node): str =
    if (base != nil) && (nodeKind(base) == astNodeKindIdent() || nodeKind(base) == astNodeKindSymbol()):
        return backendStripSpaces(plainName(base))
    return ""

fn uirCoreResolveDotBaseLocalSlot(b: BlockBuilder, baseName: str): int32 =
    if b == nil || len(baseName) == 0:
        return -1
    let slot: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), baseName)
    uirCoreMarkImplicitResultUse(b, baseName, slot)
    return slot

fn uirCoreResolveDotBaseLocalObjTypeNameFromSlot(b: BlockBuilder, slot: int32): str =
    if b == nil || slot < 0 || blockBuilderEnv(b) == nil || !uirCoreFuncIdValid(blockBuilderFuncRef(b)):
        return ""
    let objTypeName0: str = funcObjTypeName(blockBuilderFuncRef(b), slot)
    if len(objTypeName0) > 0:
        return objTypeName0
    let key: str = localTypeKey(blockBuilderEnv(b), slot)
    return uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), key)

fn uirCoreResolveDotBaseNestedObjTypeName(b: BlockBuilder, base: Node): str =
    if b == nil || base == nil:
        return ""
    var da0: DotAccess
    let dotBaseRes: Result[bool] = uirCoreTryLowerDotAccess(b, base, &da0)
    if IsOk[bool](dotBaseRes) && Value[bool](dotBaseRes) && len(dotAccessObjTypeName(da0)) > 0:
        return dotAccessObjTypeName(da0)
    return ""

fn uirCoreResolveDotBaseNestedPtrRes(b: BlockBuilder, base: Node): Result[UirExprId] =
    if b == nil || base == nil:
        return Err[UirExprId]("")
    var da0: DotAccess
    let dotBaseRes: Result[bool] = uirCoreTryLowerDotAccess(b, base, &da0)
    if IsOk[bool](dotBaseRes) && Value[bool](dotBaseRes):
        if len(dotAccessObjTypeName(da0)) > 0 || uirCoreTypeKindOf(dotAccessFieldTy(da0)) == uirCoreTypeKindVoid():
            return Ok[UirExprId](dotAccessAddr(da0))
    return Err[UirExprId]("")

fn uirCoreResolveDotBaseNonLocalObjTypeName(b: BlockBuilder, base: Node, dotNode: Node,
                                            baseName: str, debugDot: bool): str =
    if astNodeIdValid(base) && nodeKind(base) == astNodeKindBracketExpr() && kidCount(base) == 2:
        let bracketObjTypeName: str = uirCoreDotResolveBracketBaseObjTypeName(b, base, dotNode, debugDot)
        if len(bracketObjTypeName) > 0:
            return bracketObjTypeName
    if len(baseName) > 0:
        let gObj: str = uirCoreResolveGlobalObjTypeName(b, baseName)
        if len(gObj) > 0:
            return gObj
    return uirCoreResolveDotBaseNestedObjTypeName(b, base)

fn uirCoreResolveDotBaseCachedObjTypeName(b: BlockBuilder, base: Node): str =
    if b == nil || base == nil || !astNodeIdValid(base) || !nodeTypeCacheValid(base) || !astRefNonNil(nodeTypeCache(base)):
        return ""
    return typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(base))

fn uirCoreResolveDotBaseCallObjTypeName(b: BlockBuilder, base: Node, debugDot: bool): str =
    if b == nil || base == nil || !astNodeIdValid(base) || nodeKind(base) != astNodeKindCall() || blockBuilderModule(b) == nil:
        return ""
    return uirCoreDotResolveCallBaseObjTypeName(b, base, debugDot)

fn uirCoreResolveDotBaseHiddenDerefObjTypeName(b: BlockBuilder, base: Node): str =
    if b == nil || base == nil || !astNodeIdValid(base):
        return ""
    if (nodeKind(base) == astNodeKindHiddenDeref() || nodeKind(base) == astNodeKindDerefExpr()) && kidCount(base) > 0:
        return uirCoreDotResolveHiddenDerefBaseObjTypeName(b, base)
    return ""

fn uirCoreResolveDotBaseSeqObjTypeName(b: BlockBuilder, base: Node): str =
    if b == nil || blockBuilderModule(b) == nil:
        return ""
    return uirCoreDotResolveSeqBaseObjTypeName(blockBuilderModule(b), exprTypeKeyShallow(b, base))

fn uirCoreIntToF64BitsHelperName(vty: UirCoreType): str =
    if uirCoreTypeIsUnsigned(vty):
        return "cheng_u64_to_f64_bits"
    return "cheng_i64_to_f64_bits"

fn uirCoreFloatBitsToWideIntHelperName(srcIsF64: bool, isUnsigned: bool): str =
    if srcIsF64:
        if isUnsigned:
            return "cheng_f64_bits_to_u64"
        return "cheng_f64_bits_to_i64"
    if isUnsigned:
        return "cheng_f32_bits_to_u64"
    return "cheng_f32_bits_to_i64"

fn uirCoreResolveDotBasePtrRes(b: BlockBuilder, base: Node, localSlot: int32,
                               localObjTypeName: str): Result[UirExprId] =
    if localSlot >= 0 && len(localObjTypeName) > 0:
        return Ok[UirExprId](uirCoreLocal(localSlot))
    let nestedPtrRes: Result[UirExprId] = uirCoreResolveDotBaseNestedPtrRes(b, base)
    if IsOk[UirExprId](nestedPtrRes):
        return nestedPtrRes
    return lowerExprValue(b, base, uirCoreTypeI64())

fn uirCoreDotExprInferredObjTypeName(b: BlockBuilder, dotNode: Node): str =
    if b == nil:
        return ""
    let dotKey0: str = caseInferExprTypeKey(b, dotNode)
    if len(dotKey0) > 0:
        return uirCoreObjTypeFromTypeKey(blockBuilderModule(b), dotKey0)
    let dotKey1: str = exprTypeKeyShallow(b, dotNode)
    if len(dotKey1) > 0:
        return uirCoreObjTypeFromTypeKey(blockBuilderModule(b), dotKey1)
    return ""

fn uirCoreDotResolveSeqBaseObjTypeName(module: UirCoreModule, baseKey0: str): str =
    if module == nil:
        return ""
    let seqKey0: str = backendStripSpaces(baseKey0)
    if (uirCoreStrStartsWith(seqKey0, "seq_") || uirCoreStrStartsWith(seqKey0, "seq_fixed_")) &&
       uirCoreHasObjType(module, "seq"):
        return "seq"
    return ""

fn uirCoreResolveDotFieldAccess(module: UirCoreModule, base: Node, objTypeName: str,
                                ot: UirCoreObjType, basePtr: UirExprId,
                                fieldName: str): Result[DotAccess] =
    let dbgDotLowerFilter: str = getEnv("BACKEND_DEBUG_DOT_LOWER")
    let dbgDotLower: bool = len(dbgDotLowerFilter) > 0 && dbgDotLowerFilter == (objTypeName + "::" + fieldName)
    let fieldIdx: int32 = uirCoreObjFieldIndexByName(ot, fieldName)
    if dbgDotLower:
        echo("[backend] debugDotLower: resolve parent='" + objTypeName +
             "' ot='" + uirCoreNameOf(ot) +
             "' fields=" + intToStr(uirCoreFieldsLen(ot)) +
             " field='" + fieldName +
             "' fieldIdx=" + intToStr(fieldIdx) + "'")
        var dbgShownFields: int32
        for fiDbg in 0..<uirCoreFieldsLen(ot):
            let fDbg: UirCoreObjField = uirCoreFieldAt(ot, fiDbg)
            echo("[backend] debugDotLower: field[" + intToStr(fiDbg) +
                 "] name='" + uirCoreNameOf(fDbg) +
                 "' ty=nk#" + intToStr(int32(uirCoreTypeKindOf(uirCoreTypeOf(fDbg)))) +
                 " off=" + intToStr(uirCoreOffsetOf(fDbg)) + "'")
            dbgShownFields = dbgShownFields + 1
            if dbgShownFields >= 6:
                break
    if fieldIdx >= 0:
        let f: UirCoreObjField = uirCoreFieldAt(ot, fieldIdx)
        if dbgDotLower:
            echo("[backend] debugDotLower: direct field='" + fieldName +
                 "' ty=nk#" + intToStr(int32(uirCoreTypeKindOf(uirCoreTypeOf(f)))) +
                 " off=" + intToStr(uirCoreOffsetOf(f)) + "'")
        let inferredObjName: str = inferInlineObjFieldTypeName(module, ot, fieldName, uirCoreOffsetOf(f))
        if dbgDotLower:
            echo("[backend] debugDotLower: inferred obj='" + inferredObjName + "'")
        return Ok[DotAccess](uirCoreMakeDotAccessRaw(basePtr, uirCoreTypeOf(f), inferredObjName, uirCoreOffsetOf(f)))
    if ((objTypeName == "tuple") || uirCoreStrStartsWith(objTypeName, "tuple_")):
        let ti: int32 = uirCoreTupleAliasFieldIndex(base, objTypeName, fieldName)
        if ti == -2:
            return Err[DotAccess]("uirCore_builder: ambiguous tuple field")
        if ti >= 0:
            let altFieldName: str = uirCoreIndexedName("f", ti)
            let altIdx: int32 = uirCoreObjFieldIndexByName(ot, altFieldName)
            if altIdx >= 0:
                let f2: UirCoreObjField = uirCoreFieldAt(ot, altIdx)
                return Ok[DotAccess](uirCoreMakeDotAccessRaw(basePtr, uirCoreTypeOf(f2), "", uirCoreOffsetOf(f2)))
    let baseOff: int32 = uirCoreObjInlineFieldBaseOffset(ot, fieldName)
    if dbgDotLower:
        echo("[backend] debugDotLower: inline baseOff=" + intToStr(baseOff) + "'")
    if baseOff >= 0:
        let inferredInlineObjName: str = inferInlineObjFieldTypeName(module, ot, fieldName, baseOff)
        if dbgDotLower:
            echo("[backend] debugDotLower: inline inferred obj='" + inferredInlineObjName + "'")
        return Ok[DotAccess](uirCoreMakeDotAccessRaw(basePtr, uirCoreTypeVoid(),
                                                     inferredInlineObjName,
                                                     baseOff))
    return Err[DotAccess]("uirCore_builder: unknown object field")

fn uirCoreTryLowerDotAccess(b: BlockBuilder, node0: Node, out: ptr): Result[bool] =
    if out == nil:
        return Ok[bool](false)
    var node: Node = node0
    while astNodeIdValid(node) && nodeKind(node) == astNodeKindPar() && kidCount(node) > 0:
        node = kid(node, 0)
    if !astNodeIdValid(node) || nodeKind(node) != astNodeKindDotExpr():
        return Ok[bool](false)
    let daRes: Result[DotAccess] = lowerDotAccess(b, node)
    if !IsOk[DotAccess](daRes):
        return ErrInfo[bool](ErrorInfoOf[DotAccess](daRes))
    if !dotAccessWriteToPtr(out, Value[DotAccess](daRes)):
        return Ok[bool](false)
    return Ok[bool](true)

fn lowerDotAccess(b: BlockBuilder, dotNode: Node): Result[DotAccess] =
    if (b == nil) || !astNodeIdValid(dotNode) || nodeKind(dotNode) != astNodeKindDotExpr() || kidCount(dotNode) < 2:
        return Err[DotAccess]("uirCore_builder: invalid dot expr")
    let debugDot: bool = (getEnv("BACKEND_DEBUG_DOT") == "1")
    var base: Node = kid(dotNode, 0)
    let field: Node = kid(dotNode, 1)
    while astNodeIdValid(base) && nodeKind(base) == astNodeKindPar() && kidCount(base) > 0:
        base = kid(base, 0)
    if (field == nil) || (nodeKind(field) != astNodeKindIdent() && nodeKind(field) != astNodeKindSymbol()):
        return Err[DotAccess]("uirCore_builder: dot field expects identifier")
    let baseName: str = uirCoreDotBaseName(base)
    let localSlot: int32 = uirCoreResolveDotBaseLocalSlot(b, baseName)
    let localObjTypeName: str = uirCoreResolveDotBaseLocalObjTypeNameFromSlot(b, localSlot)
    let nonLocalObjTypeName: str = uirCoreResolveDotBaseNonLocalObjTypeName(b, base, dotNode, baseName, debugDot)
    let cachedObjTypeName: str = uirCoreResolveDotBaseCachedObjTypeName(b, base)
    let callObjTypeName: str = uirCoreResolveDotBaseCallObjTypeName(b, base, debugDot)
    let hiddenDerefObjTypeName: str = uirCoreResolveDotBaseHiddenDerefObjTypeName(b, base)
    let seqObjTypeName: str = uirCoreResolveDotBaseSeqObjTypeName(b, base)
    let objTypeName0: str = uirCoreFirstNonEmptyStr(localObjTypeName, nonLocalObjTypeName)
    let objTypeName1: str = uirCoreFirstNonEmptyStr(cachedObjTypeName, objTypeName0)
    let objTypeName2: str = uirCoreFirstNonEmptyStr(objTypeName1, callObjTypeName)
    let objTypeName3: str = uirCoreFirstNonEmptyStr(objTypeName2, hiddenDerefObjTypeName)
    let objTypeName: str = uirCoreFirstNonEmptyStr(objTypeName3, seqObjTypeName)
    let basePtrRes: Result[UirExprId] = uirCoreResolveDotBasePtrRes(b, base, localSlot, localObjTypeName)
    if len(objTypeName) == 0 || ! IsOk[UirExprId](basePtrRes):
        if debugDot:
            uirCoreDebugDotFail(b, base, baseName, objTypeName, basePtrRes)
        return Err[DotAccess]("uirCore_builder: dot base is not an object/ref")
    let basePtr: UirExprId = Value[UirExprId](basePtrRes)
    let ot: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), objTypeName)
    if len(uirCoreNameOf(ot)) == 0:
        return Err[DotAccess]("uirCore_builder: unknown object type")
    let fieldName: str = uirCoreNormalizeDotFieldName(b, dotNode, base, baseName, objTypeName, ot, field)
    let daRes0: Result[DotAccess] = uirCoreResolveDotFieldAccess(blockBuilderModule(b), base, objTypeName, ot, basePtr, fieldName)
    if !IsOk[DotAccess](daRes0):
        return ErrInfo[DotAccess](ErrorInfoOf[DotAccess](daRes0))
    var da0: DotAccess = Value[DotAccess](daRes0)
    if uirCoreTypeKindOf(dotAccessFieldTy(da0)) == uirCoreTypeKindVoid() && len(dotAccessObjTypeName(da0)) == 0:
        if nodeTypeCacheValid(dotNode) && astRefNonNil(nodeTypeCache(dotNode)):
            let dotObj0: str = typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(dotNode))
            if len(dotObj0) > 0:
                dotAccessSetObjTypeName(da0, dotObj0)
        if len(dotAccessObjTypeName(da0)) == 0:
            let dotObj1: str = uirCoreDotExprInferredObjTypeName(b, dotNode)
            if len(dotObj1) > 0:
                dotAccessSetObjTypeName(da0, dotObj1)
    return Ok[DotAccess](da0)

fn uirCoreCallEffectiveArgCount(callNode: Node): int32 =
    return uirCoreCallNodeEffectiveArgCount(callNode)

fn uirCoreCallNodeEffectiveArgCount(callNode: Node): int32 =
    if !astNodeIdValid(callNode) || nodeKind(callNode) != astNodeKindCall():
        return 0
    var n: int32
    for i in 1..<kidCount(callNode):
        var arg: Node = kid(callNode, i)
        if astNodeIdValid(arg) && nodeKind(arg) == astNodeKindCallArg():
            if kidCount(arg) > 1:
                arg = kid(arg, 1)
            elif kidCount(arg) > 0:
                arg = kid(arg, 0)
        if astNodeIdValid(arg) && nodeKind(arg) != astNodeKindEmpty():
            n = n + 1
    return n

fn uirCoreCurrentFuncName(b: BlockBuilder): str =
    if (b != nil) && uirCoreFuncIdValid(blockBuilderFuncRef(b)):
        return uirCoreFuncNameOf(blockBuilderFuncRef(b))
    return ""

fn uirCoreCurrentFuncOriginFile(b: BlockBuilder): str =
    if (b != nil) && uirCoreFuncIdValid(blockBuilderFuncRef(b)):
        return uirCoreFuncOriginFileOf(blockBuilderFuncRef(b))
    return ""

fn uirCoreFuncLinkNameOrName(f1: UirCoreFunc): str =
    if len(uirCoreFuncLinkNameOf(f1)) > 0:
        return uirCoreFuncLinkNameOf(f1)
    return uirCoreFuncNameOf(f1)

fn uirCoreCallNameWithTypeArgs(name: str, typeArgs: Node[]): str =
    if typeArgs.len > 0:
        return mangleInstance(name, typeArgs)
    return name

fn uirCoreLeadObjTypeName(b: BlockBuilder, callNode: Node, lead: UirExprId,
                          fallback0: str): str =
    if (b != nil) && nodeTypeCacheValid(callNode) && astRefNonNil(nodeTypeCache(callNode)):
        let cachedObj0: str = typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(callNode))
        if len(cachedObj0) > 0:
            return cachedObj0
    if (b != nil) && uirCoreFuncIdValid(blockBuilderFuncRef(b)) && (lead != nil) && uirCoreExprKindOf(lead) == uirCoreExprKindLocal():
        let leadSlot0: int32 = uirCoreExprLocalIndexOf(lead)
        if leadSlot0 >= 0 && funcFindObjLocal(blockBuilderFuncRef(b), leadSlot0) >= 0:
            let funcObj0: str = funcObjTypeName(blockBuilderFuncRef(b), leadSlot0)
            if len(funcObj0) > 0:
                return funcObj0
    if (b != nil) && len(fallback0) > 0 && uirCoreHasObjType(blockBuilderModule(b), fallback0):
        return fallback0
    return ""

fn uirCoreLeadObjTypeNameDefault(b: BlockBuilder, callNode: Node, lead: UirExprId): str =
    return uirCoreLeadObjTypeName(b, callNode, lead, "")

fn uirCoreValueCopySourceKey(b: BlockBuilder, srcNode0: Node): str =
    if b == nil || srcNode0 == nil:
        return ""
    let key0: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, srcNode0))
    if uirCoreStrStartsWith(key0, "ptr_"):
        return rawmemStrFromOffset(key0, 4)
    return key0

fn uirCoreResultCtorKind(callNode: Node, helperCallNameL: str): int32 =
    if !astNodeIdValid(callNode) || kidCount(callNode) != 2:
        return 0
    if uirCoreStrStartsWith(helperCallNameL, "Ok_"):
        return 1
    if uirCoreStrStartsWith(helperCallNameL, "Err_"):
        return 2
    if uirCoreStrStartsWith(helperCallNameL, "ErrInfo_"):
        return 3
    if helperCallNameL == "Ok":
        return 1
    if helperCallNameL == "Err":
        return 2
    if helperCallNameL == "ErrInfo":
        return 3
    return 0

fn uirCoreResultCtorSuffix(b: BlockBuilder, callNode: Node, helperCallNameL: str,
                           ctorKindL: int32): str =
    if ctorKindL <= 0:
        return ""
    if uirCoreStrStartsWith(helperCallNameL, "Ok_"):
        return rawmemStrFromOffset(helperCallNameL, 3)
    if uirCoreStrStartsWith(helperCallNameL, "Err_"):
        return rawmemStrFromOffset(helperCallNameL, 4)
    if uirCoreStrStartsWith(helperCallNameL, "ErrInfo_"):
        return rawmemStrFromOffset(helperCallNameL, 8)
    return uirCoreInferCtorSuffixFromTypeCache(b, callNode, "Result_")

fn uirCoreOptionCtorKind(callNode: Node, helperCallNameL: str): int32 =
    if !astNodeIdValid(callNode):
        return 0
    if kidCount(callNode) == 2 && (uirCoreStrStartsWith(helperCallNameL, "Some_") || helperCallNameL == "Some"):
        return 1
    if kidCount(callNode) == 1 && (uirCoreStrStartsWith(helperCallNameL, "None_") || helperCallNameL == "None"):
        return 2
    return 0

fn uirCoreNodePosLineOrZero(n: Node): str =
    if n != nil:
        return intToStr(nodePosLine(n))
    return "0"

fn uirCoreNodePosColOrZero(n: Node): str =
    if n != nil:
        return intToStr(nodePosCol(n))
    return "0"

fn uirCoreNodeKindOrZero(n: Node): str =
