    let rawArgCount1: int32 = uirCoreCallRawArgCount(callNode)

    # Some stage1 paths can rewrite `base[idx]` into `[](base, idx)`.
    # Even when this call is (incorrectly) seen as an object-return call, seq subscripting
    # should still lower via builtin bracket handling.
    if name == "[]" && typeArgs.len == 0 && rawArgCount1 == 2:
        let baseArgBr: Node = uirCoreCallArgNode(callNode, 0)
        let idxArgBr: Node = uirCoreCallArgNode(callNode, 1)
        let baseKeyBr: str = uirCoreSeqLikeKeyFromExpr(b, baseArgBr)
        if uirCoreStrStartsWith(baseKeyBr, "seq_") || uirCoreStrStartsWith(baseKeyBr, "seq_fixed_"):
            let brNode: Node = newNode(astNodeKindBracketExpr(), nodePos(callNode))
            nodeSetTypeCacheValid(brNode, nodeTypeCacheValid(callNode))
            nodeSetTypeCache(brNode, nodeTypeCache(callNode))
            addSon(brNode, baseArgBr)
            addSon(brNode, idxArgBr)
            return lowerExprValue(b, brNode, uirCoreTypeI64())

    # builtin: TableInit[V](cap?) -> Table[V]
    # Stage1 C codegen treats TableInit as an intrinsic struct literal; implement
    # the same behavior here to avoid relying on a monomorphized helper function.
    if blockBuilderModule(b) != nil && ((name == "TableInit") || uirCoreStrStartsWith(callName, "TableInit_")):
        let retKeyHint: str = uirCoreInferCallRetKeyHint(callNode)
        if (len(retKeyHint) > 0 && uirCoreStrStartsWith(retKeyHint, "Table_")) && uirCoreHasObjType(blockBuilderModule(b), "Table"):
            var capNode: Node = astInvalidNodeId()
            if rawArgCount1 > 0:
                capNode = uirCoreCallArgNode(callNode, 0)
            var capExpr: UirExprId = uirCoreConstI64(64)
            if astNodeIdValid(capNode) && nodeKind(capNode) != astNodeKindEmpty():
                let capRes: Result[UirExprId] = lowerExprValue(b, capNode, uirCoreTypeI32())
                if ! IsOk[UirExprId](capRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](capRes))
                capExpr = Value[UirExprId](capRes)

            let initName: str = uirCoreResolvedTableInitFuncName(blockBuilderModule(b))

            var initArgs: UirExprId[]
            builderExprSeqAppend(initArgs, lead)
            builderExprSeqAppend(initArgs, capExpr)
            blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall(initName, initArgs)))

            let ot: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), "Table")
            var lenOff: int32 = 16
            for fi in 0..<uirCoreFieldsLen(ot):
                let f: UirCoreObjField = uirCoreFieldAt(ot, fi)
                if (uirCoreNameOf(f) == "len"):
                    lenOff = uirCoreOffsetOf(f)
