                    let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
                    uirCoreSetLocalType(blockBuilderFuncRef(b), tmpSlot, uirCoreTypeI64())
                    localSetTypeKey(blockBuilderEnv(b), tmpSlot, objCand)
                    funcSetObjTypeKey(blockBuilderFuncRef(b), tmpSlot, objCand)
                    let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objCand)
                    if ! uirCoreResultBoolIsOk(allocRes):
                        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
                    return lowerCallWithLeadingArg(b, node, uirCoreLocal(tmpSlot))
        # Object-return calls use an implicit leading `__ret` pointer argument.
        if nodeTypeCacheValid(node) && astRefNonNil(nodeTypeCache(node)) &&
           !(callName0 == "Value" && kidCount(node) == 2):
            let retObjName: str = typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(node))
            if len(retObjName) > 0 && typeNodeIsObjValue(blockBuilderModule(b), nodeTypeCache(node)):
                if getEnv("BACKEND_DEBUG_OBJRET_CALL") == "1":
                    echo("[backend] debugObjRetCall: callName0='" + callName0 + "' retObj='" + retObjName + "'")
                let tmpName: str = blockBuilderNextTemp(b, "__callret")
                let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
                uirCoreSetLocalType(blockBuilderFuncRef(b), tmpSlot, uirCoreTypeI64())
                localSetTypeKey(blockBuilderEnv(b), tmpSlot, retObjName)
                funcSetObjTypeKey(blockBuilderFuncRef(b), tmpSlot, retObjName)
                let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, retObjName)
                if ! uirCoreResultBoolIsOk(allocRes):
                    return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
                # If the callee is a function pointer (e.g. `svc.handler(req)` or `handlerFn(req)`),
