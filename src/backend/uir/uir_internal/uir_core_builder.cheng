                    let _ensOption0: bool = ensureOptionObjType(blockBuilderModule(b), uirCoreOptionObjNameFromSuffix(optionSuffix0))
                if uirCoreHasObjType(blockBuilderModule(b), uirCoreOptionObjNameFromSuffix(optionSuffix0)):
                    var ctorCall1: Node = newNode(astNodeKindCall(), nodePos(node))
                    addSon(ctorCall1, newIdent(uirCoreOptionObjNameFromSuffix(optionSuffix0), nodePos(node)))
