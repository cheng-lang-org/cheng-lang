                var castArg: Node = argNode0
                if astNodeIdValid(argNode0) && nodeKind(argNode0) == astNodeKindCallArg():
                    if kidCount(argNode0) > 1:
                        castArg = kid(argNode0, 1)
                    elif kidCount(argNode0) > 0:
                        castArg = kid(argNode0, 0)
                let castRes: Result[UirExprId] = lowerExprValue(b, castArg, uirCoreTypeI64())
                if ! IsOk[UirExprId](castRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](castRes))
                return Ok[UirExprId](uirCoreCast(aliasTy, Value[UirExprId](castRes)))
        if blockBuilderModule(b) != nil && uirCoreHasObjType(blockBuilderModule(b), callName0):
            let ot0: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), callName0)
            if (getEnv("BACKEND_DEBUG_OBJCAST") == "1") && (callName0 == "Node"):
