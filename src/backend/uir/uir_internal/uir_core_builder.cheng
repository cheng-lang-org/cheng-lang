                    let k0: str = uirCoreNodeKindOrNil(ch0)
                    let extra0: str = uirCoreDebugNodeCallKidExtra(ch0)
                    echo("[backend] debug:  kid#" + intToStr(di0) + " kind=" + k0 + extra0)
            var hasNamedArgs: bool
            var hasFieldNamedArgs: bool
            for nai in 1..<kidCount(node):
