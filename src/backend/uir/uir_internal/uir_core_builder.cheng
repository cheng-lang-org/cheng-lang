            return lowerObjConstructorCallPositional(b, node, callName0)
        # Some stage1 wrappers (for example `Foo__wrap_name`) construct object values via the implicit `__ret`.
        # Their return type is encoded in the name prefix before `__wrap_`.
        if blockBuilderModule(b) != nil:
