            var lenAddr: UirExprId = lead
            if lenOff != 0:
                lenAddr = uirCoreBin(uirCoreBinOpAdd(), lead, uirCoreConstI64(int64(lenOff)))
            blockBuilderAddStmt(b, uirCoreStmtStore(lenAddr, uirCoreConstI64(0), uirCoreTypeI32()))
            return Ok[UirExprId](lead)

    # Object-return calls can still target a function pointer field/local; reuse the
    # normal indirect-call helper instead of carrying a second manual lowering path.
    if (b != nil) && blockBuilderModule(b) != nil && uirCoreCallCalleeLooksIndirect(b, calleeNode):
        let indRes0: Result[UirExprId] =
            uirCoreLowerIndirectCall(b, callNode, calleeNode, uirCoreCollectCallArgNodes(callNode),
                                     true, lead, "debugIndirect(objret.lead)")
        if !IsOk[UirExprId](indRes0):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](indRes0))
        blockBuilderAddStmt(b, uirCoreStmtExpr(Value[UirExprId](indRes0)))
        return Ok[UirExprId](lead)

    var calleeFunc: UirCoreFunc = nil
    var callInternal: str = callName
    let mod2: UirCoreModule = blockBuilderModule(b)
    if (mod2 != nil):
        let hint: str = uirCoreInferCallRetKeyHint(callNode)
        let cand: UirCoreFunc = uirCoreResolveCalleeFuncBestEffortByNode(b, callNode, callName, uirCoreCollectCallArgNodes(callNode), hint)
        if (cand != nil):
            calleeFunc = cand
            callInternal = uirCoreCallSymbolForFunc(cand)
        elif moduleHasFuncByBase(mod2, callName):
            let calleeRes: Result[UirCoreFunc] = uirCoreResolveCalleeFunc(b, callNode, callName, uirCoreCollectCallArgNodes(callNode))
            if !IsOk[UirCoreFunc](calleeRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirCoreFunc](calleeRes))
            calleeFunc = Value[UirCoreFunc](calleeRes)
            callInternal = uirCoreCallSymbolForFunc(calleeFunc)
    if len(callInternal) == 0 && len(callName) > 0:
        callInternal = callName

    var args: UirExprId[]
    builderExprSeqAppend(args, lead)
    var haveFirstArgExpr: bool
    var firstArgExpr: UirExprId = int32(0)
    var paramStart: int32
    if (calleeFunc != nil) && uirCoreFuncParamsLen(calleeFunc) > 0:
        let pFirst: UirCoreParam = uirCoreFuncParamAt(calleeFunc, 0)
        if (uirCoreNameOf(pFirst) == "__ret"):
            paramStart = 1
    for vi3 in 0..<rawArgCount1:
        let argNode3: Node = uirCoreCallArgNode(callNode, vi3)
        var wantVarAddr: bool
        let paramTypeKey3: str = uirCoreCallArgParamTypeKey(calleeFunc, vi3)
        let pi3: int32 = paramStart + vi3
        if (calleeFunc != nil) && pi3 >= 0 && pi3 < uirCoreFuncParamsLen(calleeFunc):
            let p0: UirCoreParam = uirCoreFuncParamAt(calleeFunc, pi3)
            wantVarAddr = uirCoreParamWantsVarAddr(mod2, uirCoreTypeKeyOf(p0))
        if wantVarAddr:
            let addrRes: Result[UirExprId] = lowerVarArgAddr(b, argNode3)
            if !IsOk[UirExprId](addrRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](addrRes))
            if vi3 == 0:
                haveFirstArgExpr = true
                firstArgExpr = Value[UirExprId](addrRes)
            builderExprSeqAppend(args, Value[UirExprId](addrRes))
        else:
            if astNodeIdValid(argNode3) && uirCoreNodeIsStringLiteral(uirCoreCallArgValueNode(uirCoreStripParExpr(argNode3))) &&
               isSemanticStrKey(paramTypeKey3):
                let argRes2: Result[UirExprId] = uirCoreLowerSemanticStrLiteralNode(b, argNode3, paramTypeKey3)
                if !IsOk[UirExprId](argRes2):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](argRes2))
                if vi3 == 0:
                    haveFirstArgExpr = true
                    firstArgExpr = Value[UirExprId](argRes2)
                builderExprSeqAppend(args, Value[UirExprId](argRes2))
            else:
                let argRes2: Result[UirExprId] = uirCoreLowerExprValueWithTypeKeyHint(b, argNode3, uirCoreTypeI64(), paramTypeKey3)
                if !IsOk[UirExprId](argRes2):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](argRes2))
                if vi3 == 0:
                    haveFirstArgExpr = true
                    firstArgExpr = Value[UirExprId](argRes2)
                builderExprSeqAppend(args, Value[UirExprId](argRes2))
    let valueLikeCall0: bool = (callInternal == "Value") || (callName == "Value") ||
        ((calleeFunc != nil) && len(uirCoreFuncLinkNameOf(calleeFunc)) > 0 && (uirCoreFuncLinkNameOf(calleeFunc) == "Value"))
    if valueLikeCall0 && haveFirstArgExpr && blockBuilderModule(b) != nil:
        var srcPtr1: UirExprId = firstArgExpr
        if rawArgCount1 > 0:
            let valueArg0: Node = uirCoreCallArgNode(callNode, 0)
            if astRefNonNil(valueArg0):
                var srcKey1: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, valueArg0))
                if uirCoreStrStartsWith(srcKey1, "ptr_"):
                    srcKey1 = rawmemStrFromOffset(srcKey1, 4)
                var valueOff1: int32 = -1
                let srcObj1: str = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), srcKey1)
                if len(srcObj1) > 0 && uirCoreHasObjType(blockBuilderModule(b), srcObj1):
                    let srcOt1: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), srcObj1)
                    for sfi1 in 0..<uirCoreFieldsLen(srcOt1):
                        let sf1: UirCoreObjField = uirCoreFieldAt(srcOt1, sfi1)
                        if (uirCoreNameOf(sf1) == "value") || uirCoreStrStartsWith(uirCoreNameOf(sf1), "value."):
                            if valueOff1 < 0 || uirCoreOffsetOf(sf1) < valueOff1:
                                valueOff1 = uirCoreOffsetOf(sf1)
                if valueOff1 < 0 && uirCoreStrStartsWith(srcKey1, "Result_"):
                    valueOff1 = 0
                if valueOff1 > 0:
                    srcPtr1 = uirCoreBin(uirCoreBinOpAdd(), srcPtr1, uirCoreConstI64(int64(valueOff1)))
        let dstObj1: str = uirCoreLeadObjTypeNameDefault(b, callNode, lead)
        if len(dstObj1) > 0:
            let copyRes1: Result[bool] = emitObjCopyPtrs(b, lead, dstObj1, srcPtr1)
            if !uirCoreResultBoolIsOk(copyRes1):
                return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes1))
            return Ok[UirExprId](lead)
        blockBuilderAddStmt(b, uirCoreStmtStore(lead, uirCoreLoad(srcPtr1, uirCoreTypeI64()), uirCoreTypeI64()))
        return Ok[UirExprId](lead)
    if callInternal == "Value" && getEnv("BACKEND_DEBUG_VALUE_CALLSITE") == "1":
        let fnDbg2: str = uirCoreCurrentFuncName(b)
        echo("[backend] debugValueCallsite: fn=" + fnDbg2 +
             " name='" + name + "' callName='" + callName + "' argc=" + intToStr(rawArgCount1))
    if len(callInternal) == 0:
        return Err[UirExprId]("uirCore_builder: empty call symbol")
    blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall(callInternal, args)))
    return Ok[UirExprId](lead)

fn lowerInExpr(b: BlockBuilder, lhsNode0: Node, rhsNode0: Node, negate: bool): Result[UirExprId] =
    if (b == nil):
        return Err[UirExprId]("uirCore_builder: in missing builder")
    var lhsNode: Node = lhsNode0
    while astNodeIdValid(lhsNode) && nodeKind(lhsNode) == astNodeKindPar() && kidCount(lhsNode) > 0:
        lhsNode = kid(lhsNode, 0)
    var rhsNode: Node = rhsNode0
    while astNodeIdValid(rhsNode) && nodeKind(rhsNode) == astNodeKindPar() && kidCount(rhsNode) > 0:
        rhsNode = kid(rhsNode, 0)
    if (lhsNode == nil) || (rhsNode == nil):
        return Err[UirExprId]("uirCore_builder: in expects lhs/rhs")

    # Evaluate LHS once (as i64) and reuse it in all branches.
    let lhsRes0: Result[UirExprId] = lowerExprValue(b, lhsNode, uirCoreTypeI64())
    if ! IsOk[UirExprId](lhsRes0):
        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](lhsRes0))
    let lhsTmpName: str = blockBuilderNextTemp(b, "__in_lhs")
    let lhsTmpSlot: int32 = localAdd(blockBuilderEnv(b), lhsTmpName, uirCoreTypeI64())
    uirCoreSetLocalType(blockBuilderFuncRef(b), lhsTmpSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(lhsTmpName, lhsTmpSlot, Value[UirExprId](lhsRes0)))
    let lhsTmp: UirExprId = uirCoreLocal(lhsTmpSlot)

    # Range membership: `x in a..b` / `a..<b`
    if nodeKind(rhsNode) == astNodeKindInfix() && kidCount(rhsNode) >= 3:
        let opNode: Node = kid(rhsNode, 0)
        let op: str = backendOpName(opNode)
        if op == ".." || op == "..<":
            let startRes: Result[UirExprId] = lowerExprValue(b, kid(rhsNode, 1), uirCoreTypeI64())
            if ! IsOk[UirExprId](startRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](startRes))
            let endRes: Result[UirExprId] = lowerExprValue(b, kid(rhsNode, 2), uirCoreTypeI64())
            if ! IsOk[UirExprId](endRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](endRes))
            let geExpr: UirExprId = uirCoreCmp(uirCoreCmpGe(), lhsTmp, Value[UirExprId](startRes))
            var leExpr: UirExprId
            if op == "..":
                leExpr = uirCoreCmp(uirCoreCmpLe(), lhsTmp, Value[UirExprId](endRes))
            else:
                leExpr = uirCoreCmp(uirCoreCmpLt(), lhsTmp, Value[UirExprId](endRes))
            let inExpr: UirExprId = uirCoreBin(uirCoreBinOpAnd(), geExpr, leExpr)
            if negate:
                return Ok[UirExprId](uirCoreCmp(uirCoreCmpEq(), inExpr, uirCoreConstI64(0)))
            return Ok[UirExprId](inExpr)

    # Literal membership: tuple/bracket/seq literals lowered as a chain of `==` checks.
    if nodeKind(rhsNode) == astNodeKindTupleLit() || nodeKind(rhsNode) == astNodeKindBracket() || nodeKind(rhsNode) == astNodeKindSeqLit():
        if kidCount(rhsNode) == 0:
            if negate:
                return Ok[UirExprId](uirCoreConstI64(1))
            return Ok[UirExprId](uirCoreConstI64(0))
        var out: UirExprId = nil
        for i in 0..<kidCount(rhsNode):
            var elemNode: Node = kid(rhsNode, i)
            if astNodeIdValid(elemNode) && nodeKind(elemNode) == astNodeKindCallArg() && kidCount(elemNode) > 1:
                elemNode = kid(elemNode, 1)
            let elemRes: Result[UirExprId] = lowerExprValue(b, elemNode, uirCoreTypeI64())
            if ! IsOk[UirExprId](elemRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](elemRes))
            let eqExpr: UirExprId = uirCoreCmp(uirCoreCmpEq(), lhsTmp, Value[UirExprId](elemRes))
            if (out == nil):
                out = eqExpr
            else:
                out = uirCoreBin(uirCoreBinOpOr(), out, eqExpr)
        if (out == nil):
            out = uirCoreConstI64(0)
        if negate:
            return Ok[UirExprId](uirCoreCmp(uirCoreCmpEq(), out, uirCoreConstI64(0)))
        return Ok[UirExprId](out)

    let rhsKey: str = uirCoreInExprRhsKey(b, rhsNode)

    # set[T] is represented as a uint64 bitset.
    if nodeKind(rhsNode) == astNodeKindCurly() || uirCoreStrStartsWith(rhsKey, "set_"):
        let rhsRes: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI64())
        if ! IsOk[UirExprId](rhsRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsRes))
        let bits: UirExprId = uirCoreCast(uirCoreTypeI64(), Value[UirExprId](rhsRes))
        let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), lhsTmp)
        let mask: UirExprId = uirCoreBin(uirCoreBinOpShl(), uirCoreConstI64(1), idx64)
        let inExpr: UirExprId = uirCoreCmp(uirCoreCmpNe(), uirCoreBin(uirCoreBinOpAnd(), bits, mask), uirCoreConstI64(0))
        if negate:
            return Ok[UirExprId](uirCoreCmp(uirCoreCmpEq(), inExpr, uirCoreConstI64(0)))
        return Ok[UirExprId](inExpr)

    # seq[T] membership: scan seq buffer.
    if uirCoreStrStartsWith(rhsKey, "seq_"):
        let elemKey: str = rawmemStrFromOffset(rhsKey, 4)
        if len(elemKey) == 0:
            return Err[UirExprId]("uirCore_builder: in seq missing element type")
        let elemTypeNode: Node = newIdent(elemKey, nodePos(rhsNode))
        let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(blockBuilderModule(b), elemTypeNode)
        let sizeRes: Result[int32] = uirCoreSizeOfTypeNode(blockBuilderModule(b), elemTypeNode)
        if ! IsOk[int32](sizeRes):
            return ErrInfo[UirExprId](ErrorInfoOf[int32](sizeRes))
        let elemSize: int32 = Value[int32](sizeRes)

        let rhsRes: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI64())
        if ! IsOk[UirExprId](rhsRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsRes))
        let seqTmpName: str = blockBuilderNextTemp(b, "__in_seq")
        let seqTmpSlot: int32 = localAdd(blockBuilderEnv(b), seqTmpName, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), seqTmpSlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(seqTmpName, seqTmpSlot, Value[UirExprId](rhsRes)))
        let seqPtr: UirExprId = uirCoreLocal(seqTmpSlot)

        let seqOt: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), "seq")
        var lenOff: int32 = -1
        var bufOff: int32 = -1
        for fi in 0..<uirCoreFieldsLen(seqOt):
            let f: UirCoreObjField = uirCoreFieldAt(seqOt, fi)
            if (uirCoreNameOf(f) == "len"):
                lenOff = uirCoreOffsetOf(f)
            elif (uirCoreNameOf(f) == "buffer"):
                bufOff = uirCoreOffsetOf(f)
        if lenOff < 0 || bufOff < 0:
            return Err[UirExprId]("uirCore_builder: seq layout mismatch")

        let lenAddr: UirExprId = (lenOff == 0) ? seqPtr : uirCoreBin(uirCoreBinOpAdd(), seqPtr, uirCoreConstI64(int64(lenOff)))
        let bufAddr: UirExprId = (bufOff == 0) ? seqPtr : uirCoreBin(uirCoreBinOpAdd(), seqPtr, uirCoreConstI64(int64(bufOff)))

        let lenName: str = blockBuilderNextTemp(b, "__in_len")
        let lenSlot: int32 = localAdd(blockBuilderEnv(b), lenName, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), lenSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtLet(lenName, lenSlot, uirCoreLoad(lenAddr, uirCoreTypeI32())))

        let bufName: str = blockBuilderNextTemp(b, "__in_buf")
        let bufSlot: int32 = localAdd(blockBuilderEnv(b), bufName, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), bufSlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(bufName, bufSlot, uirCoreLoad(bufAddr, uirCoreTypeI64())))

        let idxName: str = blockBuilderNextTemp(b, "__in_i")
        let idxSlot: int32 = localAdd(blockBuilderEnv(b), idxName, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), idxSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(idxName, idxSlot, uirCoreConstI64(0)))

        let resName: str = blockBuilderNextTemp(b, "__in_res")
        let resSlot: int32 = localAdd(blockBuilderEnv(b), resName, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), resSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(resName, resSlot, uirCoreConstI64(0)))

        let condLabel: str = blockBuilderNextLabel(b, "in_cond")
        let bodyLabel: str = blockBuilderNextLabel(b, "in_body")
        let incLabel: str = blockBuilderNextLabel(b, "in_inc")
        let foundLabel: str = blockBuilderNextLabel(b, "in_found")
        let endLabel: str = blockBuilderNextLabel(b, "in_end")
        blockBuilderFinish(b, uirCoreTermBr(condLabel))

        blockBuilderStart(b, condLabel)
        let condExpr: UirExprId = uirCoreCmp(uirCoreCmpLt(), uirCoreLocal(idxSlot), uirCoreLocal(lenSlot))
        blockBuilderFinish(b, uirCoreTermCbr(condExpr, bodyLabel, endLabel))

        blockBuilderStart(b, bodyLabel)
        let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreLocal(idxSlot))
        let step: UirExprId = uirCoreConstI64(int64(elemSize))
        let off: UirExprId = (elemSize == 1) ? idx64 : uirCoreBin(uirCoreBinOpMul(), idx64, step)
        let addr: UirExprId = (elemSize == 0) ? uirCoreLocal(bufSlot) : uirCoreBin(uirCoreBinOpAdd(), uirCoreLocal(bufSlot), off)
        let elemVal: UirExprId = uirCoreLoad(addr, elemTy)
        let lhsCast: UirExprId = uirCoreCast(elemTy, lhsTmp)
        let eqExpr: UirExprId = uirCoreCmp(uirCoreCmpEq(), elemVal, lhsCast)
        blockBuilderFinish(b, uirCoreTermCbr(eqExpr, foundLabel, incLabel))

        blockBuilderStart(b, foundLabel)
        blockBuilderAddStmt(b, uirCoreStmtAssign(resName, resSlot, uirCoreConstI64(1)))
        blockBuilderFinish(b, uirCoreTermBr(endLabel))

        blockBuilderStart(b, incLabel)
        let incExpr: UirExprId = uirCoreBin(uirCoreBinOpAdd(), uirCoreLocal(idxSlot), uirCoreConstI64(1))
        blockBuilderAddStmt(b, uirCoreStmtAssign(idxName, idxSlot, incExpr))
        blockBuilderFinish(b, uirCoreTermBr(condLabel))

        blockBuilderStart(b, endLabel)
        if negate:
            return Ok[UirExprId](uirCoreCmp(uirCoreCmpEq(), uirCoreLocal(resSlot), uirCoreConstI64(0)))
        return Ok[UirExprId](uirCoreLocal(resSlot))

    # str membership: char/substring search.
    if uirCoreNodeHasStringCtx(rhsKey, rhsNode):
        let rhsRes: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI64())
        if ! IsOk[UirExprId](rhsRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsRes))
        let hayName: str = blockBuilderNextTemp(b, "__in_hay")
        let haySlot: int32 = localAdd(blockBuilderEnv(b), hayName, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), haySlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(hayName, haySlot, Value[UirExprId](rhsRes)))
        let hayPtr: UirExprId = uirCoreLocal(haySlot)

        var lhsIsStr: bool = uirCoreNodeIsStringLiteral(lhsNode)
        if !lhsIsStr && nodeTypeCacheValid(lhsNode) && astRefNonNil(nodeTypeCache(lhsNode)):
            let lk: str = typeKey(nodeTypeCache(lhsNode))
            if isStringKey(lk):
                lhsIsStr = true

        if ! lhsIsStr:
            # char in str
            let lenName: str = blockBuilderNextTemp(b, "__in_strlen")
            let lenSlot: int32 = localAdd(blockBuilderEnv(b), lenName, uirCoreTypeI32())
            uirCoreSetLocalType(blockBuilderFuncRef(b), lenSlot, uirCoreTypeI32())
            var strlenArgs: UirExprId[]
            builderExprSeqAppend(strlenArgs, hayPtr)
            blockBuilderAddStmt(b, uirCoreStmtLet(lenName, lenSlot, uirCoreCall("cheng_strlen", strlenArgs)))

            let idxName: str = blockBuilderNextTemp(b, "__in_i")
            let idxSlot: int32 = localAdd(blockBuilderEnv(b), idxName, uirCoreTypeI32())
            uirCoreSetLocalType(blockBuilderFuncRef(b), idxSlot, uirCoreTypeI32())
            blockBuilderAddStmt(b, uirCoreStmtVar(idxName, idxSlot, uirCoreConstI64(0)))

            let resName: str = blockBuilderNextTemp(b, "__in_res")
            let resSlot: int32 = localAdd(blockBuilderEnv(b), resName, uirCoreTypeI32())
            uirCoreSetLocalType(blockBuilderFuncRef(b), resSlot, uirCoreTypeI32())
            blockBuilderAddStmt(b, uirCoreStmtVar(resName, resSlot, uirCoreConstI64(0)))

            let condLabel: str = blockBuilderNextLabel(b, "in_cond")
            let bodyLabel: str = blockBuilderNextLabel(b, "in_body")
            let incLabel: str = blockBuilderNextLabel(b, "in_inc")
            let foundLabel: str = blockBuilderNextLabel(b, "in_found")
            let endLabel: str = blockBuilderNextLabel(b, "in_end")
            blockBuilderFinish(b, uirCoreTermBr(condLabel))

            blockBuilderStart(b, condLabel)
            let condExpr: UirExprId = uirCoreCmp(uirCoreCmpLt(), uirCoreLocal(idxSlot), uirCoreLocal(lenSlot))
            blockBuilderFinish(b, uirCoreTermCbr(condExpr, bodyLabel, endLabel))

            blockBuilderStart(b, bodyLabel)
            let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreLocal(idxSlot))
            let addr: UirExprId = uirCoreBin(uirCoreBinOpAdd(), hayPtr, idx64)
            let raw: UirExprId = uirCoreLoad(addr, uirCoreTypeI32())
            let chVal: UirExprId = uirCoreBin(uirCoreBinOpAnd(), raw, uirCoreConstI64(255))
            let needle: UirExprId = uirCoreCast(uirCoreTypeI32(), lhsTmp)
            let eqExpr: UirExprId = uirCoreCmp(uirCoreCmpEq(), chVal, needle)
            blockBuilderFinish(b, uirCoreTermCbr(eqExpr, foundLabel, incLabel))

            blockBuilderStart(b, foundLabel)
            blockBuilderAddStmt(b, uirCoreStmtAssign(resName, resSlot, uirCoreConstI64(1)))
            blockBuilderFinish(b, uirCoreTermBr(endLabel))

            blockBuilderStart(b, incLabel)
            let incExpr: UirExprId = uirCoreBin(uirCoreBinOpAdd(), uirCoreLocal(idxSlot), uirCoreConstI64(1))
            blockBuilderAddStmt(b, uirCoreStmtAssign(idxName, idxSlot, incExpr))
            blockBuilderFinish(b, uirCoreTermBr(condLabel))

            blockBuilderStart(b, endLabel)
            if negate:
                return Ok[UirExprId](uirCoreCmp(uirCoreCmpEq(), uirCoreLocal(resSlot), uirCoreConstI64(0)))
            return Ok[UirExprId](uirCoreLocal(resSlot))

        # str in str
        let needleName: str = blockBuilderNextTemp(b, "__in_need")
        let needleSlot: int32 = localAdd(blockBuilderEnv(b), needleName, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), needleSlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(needleName, needleSlot, lhsTmp))
        let needlePtr: UirExprId = uirCoreLocal(needleSlot)

        let nName: str = blockBuilderNextTemp(b, "__in_n")
        let nSlot: int32 = localAdd(blockBuilderEnv(b), nName, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), nSlot, uirCoreTypeI32())
        var nArgs: UirExprId[]
        builderExprSeqAppend(nArgs, hayPtr)
        blockBuilderAddStmt(b, uirCoreStmtLet(nName, nSlot, uirCoreCall("cheng_strlen", nArgs)))

        let mName: str = blockBuilderNextTemp(b, "__in_m")
        let mSlot: int32 = localAdd(blockBuilderEnv(b), mName, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), mSlot, uirCoreTypeI32())
        var mArgs: UirExprId[]
        builderExprSeqAppend(mArgs, needlePtr)
        blockBuilderAddStmt(b, uirCoreStmtLet(mName, mSlot, uirCoreCall("cheng_strlen", mArgs)))

        let resName2: str = blockBuilderNextTemp(b, "__in_res")
        let resSlot2: int32 = localAdd(blockBuilderEnv(b), resName2, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), resSlot2, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(resName2, resSlot2, uirCoreConstI64(0)))

        let checkEmpty: str = blockBuilderNextLabel(b, "in_check_empty")
        let checkLong: str = blockBuilderNextLabel(b, "in_check_long")
        let initLabel: str = blockBuilderNextLabel(b, "in_init")
        let outerCond: str = blockBuilderNextLabel(b, "in_outer_cond")
        let outerBody: str = blockBuilderNextLabel(b, "in_outer_body")
        let innerCond: str = blockBuilderNextLabel(b, "in_inner_cond")
        let innerBody: str = blockBuilderNextLabel(b, "in_inner_body")
        let matchLabel: str = blockBuilderNextLabel(b, "in_match")
        let endLabel2: str = blockBuilderNextLabel(b, "in_end")
        blockBuilderFinish(b, uirCoreTermBr(checkEmpty))

        blockBuilderStart(b, checkEmpty)
        let emptyCond: UirExprId = uirCoreCmp(uirCoreCmpEq(), uirCoreLocal(mSlot), uirCoreConstI64(0))
        blockBuilderFinish(b, uirCoreTermCbr(emptyCond, matchLabel, checkLong))

        blockBuilderStart(b, checkLong)
        let longCond: UirExprId = uirCoreCmp(uirCoreCmpGt(), uirCoreLocal(mSlot), uirCoreLocal(nSlot))
        blockBuilderFinish(b, uirCoreTermCbr(longCond, endLabel2, initLabel))

        blockBuilderStart(b, initLabel)
        let iName: str = blockBuilderNextTemp(b, "__in_i")
        let iSlot: int32 = localAdd(blockBuilderEnv(b), iName, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), iSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(iName, iSlot, uirCoreConstI64(0)))

        let jName: str = blockBuilderNextTemp(b, "__in_j")
        let jSlot: int32 = localAdd(blockBuilderEnv(b), jName, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), jSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtVar(jName, jSlot, uirCoreConstI64(0)))

        let limName: str = blockBuilderNextTemp(b, "__in_lim")
        let limSlot: int32 = localAdd(blockBuilderEnv(b), limName, uirCoreTypeI32())
        uirCoreSetLocalType(blockBuilderFuncRef(b), limSlot, uirCoreTypeI32())
        blockBuilderAddStmt(b, uirCoreStmtLet(limName, limSlot, uirCoreBin(uirCoreBinOpSub(), uirCoreLocal(nSlot), uirCoreLocal(mSlot))))

        blockBuilderFinish(b, uirCoreTermBr(outerCond))

        blockBuilderStart(b, outerCond)
        let outerOk: UirExprId = uirCoreCmp(uirCoreCmpLe(), uirCoreLocal(iSlot), uirCoreLocal(limSlot))
        blockBuilderFinish(b, uirCoreTermCbr(outerOk, outerBody, endLabel2))

        blockBuilderStart(b, outerBody)
        blockBuilderAddStmt(b, uirCoreStmtAssign(jName, jSlot, uirCoreConstI64(0)))
        blockBuilderFinish(b, uirCoreTermBr(innerCond))

        blockBuilderStart(b, innerCond)
        let innerOk: UirExprId = uirCoreCmp(uirCoreCmpLt(), uirCoreLocal(jSlot), uirCoreLocal(mSlot))
        blockBuilderFinish(b, uirCoreTermCbr(innerOk, innerBody, matchLabel))

        blockBuilderStart(b, innerBody)
        let ij: UirExprId = uirCoreBin(uirCoreBinOpAdd(), uirCoreLocal(iSlot), uirCoreLocal(jSlot))
        let ij64: UirExprId = uirCoreCast(uirCoreTypeI64(), ij)
        let hAddr: UirExprId = uirCoreBin(uirCoreBinOpAdd(), hayPtr, ij64)
        let hRaw: UirExprId = uirCoreLoad(hAddr, uirCoreTypeI32())
        let hCh: UirExprId = uirCoreBin(uirCoreBinOpAnd(), hRaw, uirCoreConstI64(255))
        let j64: UirExprId = uirCoreCast(uirCoreTypeI64(), uirCoreLocal(jSlot))
        let nAddr: UirExprId = uirCoreBin(uirCoreBinOpAdd(), needlePtr, j64)
        let nRaw: UirExprId = uirCoreLoad(nAddr, uirCoreTypeI32())
        let nCh: UirExprId = uirCoreBin(uirCoreBinOpAnd(), nRaw, uirCoreConstI64(255))
        let eqExpr2: UirExprId = uirCoreCmp(uirCoreCmpEq(), hCh, nCh)
        let stepJ: str = blockBuilderNextLabel(b, "in_step_j")
        let stepI: str = blockBuilderNextLabel(b, "in_step_i")
        blockBuilderFinish(b, uirCoreTermCbr(eqExpr2, stepJ, stepI))

        blockBuilderStart(b, stepJ)
        blockBuilderAddStmt(b, uirCoreStmtAssign(jName, jSlot, uirCoreBin(uirCoreBinOpAdd(), uirCoreLocal(jSlot), uirCoreConstI64(1))))
        blockBuilderFinish(b, uirCoreTermBr(innerCond))

        blockBuilderStart(b, stepI)
        blockBuilderAddStmt(b, uirCoreStmtAssign(iName, iSlot, uirCoreBin(uirCoreBinOpAdd(), uirCoreLocal(iSlot), uirCoreConstI64(1))))
        blockBuilderFinish(b, uirCoreTermBr(outerCond))

        blockBuilderStart(b, matchLabel)
        blockBuilderAddStmt(b, uirCoreStmtAssign(resName2, resSlot2, uirCoreConstI64(1)))
        blockBuilderFinish(b, uirCoreTermBr(endLabel2))

        blockBuilderStart(b, endLabel2)
        if negate:
            return Ok[UirExprId](uirCoreCmp(uirCoreCmpEq(), uirCoreLocal(resSlot2), uirCoreConstI64(0)))
        return Ok[UirExprId](uirCoreLocal(resSlot2))

    # Table membership: `key in Table[V]` => `TableHas[V](t, key)`
    if uirCoreStrStartsWith(rhsKey, "Table_"):
        let rhsRes: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI64())
        if ! IsOk[UirExprId](rhsRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsRes))
        let tblName: str = blockBuilderNextTemp(b, "__in_tbl")
        let tblSlot: int32 = localAdd(blockBuilderEnv(b), tblName, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), tblSlot, uirCoreTypeI64())
        blockBuilderAddStmt(b, uirCoreStmtLet(tblName, tblSlot, Value[UirExprId](rhsRes)))
        let valKey: str = rawmemStrFromOffset(rhsKey, 6)
        let callName: str = uirCoreConcat2("TableHas_", valKey)
        var args: UirExprId[]
        builderExprSeqAppend(args, uirCoreLocal(tblSlot))
        builderExprSeqAppend(args, lhsTmp)
        let hasExpr: UirExprId = uirCoreCall(callName, args)
        if negate:
            return Ok[UirExprId](uirCoreCmp(uirCoreCmpEq(), hasExpr, uirCoreConstI64(0)))
        return Ok[UirExprId](hasExpr)

    let line: str = intToStr(nodePosLine(rhsNode))
    let col: str = intToStr(nodePosCol(rhsNode))
    return Err[UirExprId]("uirCore_builder: unsupported 'in' rhs (key=" + rhsKey + " @" + line + ":" + col + ")")

fn exprTypeKeyShallow(b: BlockBuilder, n0: Node): str =
    if (b == nil):
        return ""
    var n: Node = n0
    while astNodeIdValid(n) && nodeKind(n) == astNodeKindPar() && kidCount(n) > 0:
        n = kid(n, 0)
    if (n == nil):
        return ""
    if nodeKind(n) != astNodeKindDotExpr() && nodeTypeCacheValid(n) && astRefNonNil(nodeTypeCache(n)):
        return typeKey(nodeTypeCache(n))
    if nodeKind(n) == astNodeKindDotExpr() && kidCount(n) > 1:
        let base: Node = kid(n, 0)
        let field: Node = kid(n, 1)
        if (base != nil) && (field != nil) && (nodeKind(field) == astNodeKindIdent() || nodeKind(field) == astNodeKindSymbol()) && blockBuilderModule(b) != nil:
            var parentKey: str = backendStripSpaces(exprTypeKeyShallow(b, base))
            let parentObj: str = uirCoreDotObjTypeNameFromKey(blockBuilderModule(b), parentKey)
            if len(parentObj) > 0:
                let fieldName: str = backendStripSpaces(plainName(field))
                var fieldKey: str = backendStripSpaces(uirCoreObjFieldTypeKeyGet(parentObj, fieldName))
                if len(fieldKey) == 0:
                    fieldKey = uirCoreFieldTypeKeyFromCurrentRoot(blockBuilderModule(b), parentObj, fieldName)
                if len(fieldKey) > 0:
                    return fieldKey
    if nodeKind(n) == astNodeKindFloatLit():
        return "float64"
    if nodeKind(n) == astNodeKindIdent() || nodeKind(n) == astNodeKindSymbol():
        let nm: str = plainName(n)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        if slot0 >= 0:
            return localTypeKey(blockBuilderEnv(b), slot0)
    if nodeKind(n) == astNodeKindCall() && kidCount(n) > 0:
        let callee0: Node = kid(n, 0)
        # Type conversion call: pointer/ref/var type constructors can show up without a typeCache.
        if (callee0 != nil) && (nodeKind(callee0) == astNodeKindPtrTy() || nodeKind(callee0) == astNodeKindRefTy() || nodeKind(callee0) == astNodeKindVarTy()):
            return typeKey(callee0)
    return ""

fn lowerByteLoadNilChecked(b: BlockBuilder, addrExpr: UirExprId, byteTy: UirCoreType, wantType: UirCoreType): UirExprId =
    let addrName: str = blockBuilderNextTemp(b, "__byte_p")
    let addrSlot: int32 = localAdd(blockBuilderEnv(b), addrName, uirCoreTypeI64())
    uirCoreSetLocalType(blockBuilderFuncRef(b), addrSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(addrName, addrSlot, addrExpr))

    let resName: str = blockBuilderNextTemp(b, "__byte_res")
    let resSlot: int32 = localAdd(blockBuilderEnv(b), resName, wantType)
    uirCoreSetLocalType(blockBuilderFuncRef(b), resSlot, wantType)

    let thenLabel: str = blockBuilderNextLabel(b, "byte_then")
    let elseLabel: str = blockBuilderNextLabel(b, "byte_else")
    let joinLabel: str = blockBuilderNextLabel(b, "byte_join")
    let okCond: UirExprId = uirCoreCmp(uirCoreCmpNe(), uirCoreLocal(addrSlot), uirCoreConstI64(0))
    blockBuilderFinish(b, uirCoreTermCbr(okCond, thenLabel, elseLabel))

    blockBuilderStart(b, thenLabel)
    var loaded: UirExprId = uirCoreLoad(uirCoreLocal(addrSlot), byteTy)
    if uirCoreTypeKindOf(wantType) != uirCoreTypeKindOf(byteTy) || uirCoreTypeIsUnsigned(wantType) != uirCoreTypeIsUnsigned(byteTy):
        loaded = uirCoreCast(wantType, loaded)
    blockBuilderAddStmt(b, uirCoreStmtAssign(resName, resSlot, loaded))
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))

    blockBuilderStart(b, elseLabel)
    blockBuilderAddStmt(b, uirCoreStmtAssign(resName, resSlot, uirCoreConstI64(0)))
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))

    blockBuilderStart(b, joinLabel)
    return uirCoreLocal(resSlot)

fn lowerByteStoreNilChecked(b: BlockBuilder, addrExpr: UirExprId, valExpr: UirExprId, valType: UirCoreType, storeTy: UirCoreType) =
    let addrName: str = blockBuilderNextTemp(b, "__byte_p")
    let addrSlot: int32 = localAdd(blockBuilderEnv(b), addrName, uirCoreTypeI64())
    uirCoreSetLocalType(blockBuilderFuncRef(b), addrSlot, uirCoreTypeI64())
    blockBuilderAddStmt(b, uirCoreStmtLet(addrName, addrSlot, addrExpr))

    let valName: str = blockBuilderNextTemp(b, "__byte_v")
    let valSlot: int32 = localAdd(blockBuilderEnv(b), valName, valType)
    uirCoreSetLocalType(blockBuilderFuncRef(b), valSlot, valType)
    blockBuilderAddStmt(b, uirCoreStmtLet(valName, valSlot, valExpr))

    let thenLabel: str = blockBuilderNextLabel(b, "byte_then")
    let elseLabel: str = blockBuilderNextLabel(b, "byte_else")
    let joinLabel: str = blockBuilderNextLabel(b, "byte_join")
    let okCond: UirExprId = uirCoreCmp(uirCoreCmpNe(), uirCoreLocal(addrSlot), uirCoreConstI64(0))
    blockBuilderFinish(b, uirCoreTermCbr(okCond, thenLabel, elseLabel))

    blockBuilderStart(b, thenLabel)
    blockBuilderAddStmt(b, uirCoreStmtStore(uirCoreLocal(addrSlot), uirCoreLocal(valSlot), storeTy))
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))

    blockBuilderStart(b, elseLabel)
    blockBuilderFinish(b, uirCoreTermBr(joinLabel))

    blockBuilderStart(b, joinLabel)

fn lowerToF64Bits(b: BlockBuilder, n0: Node): Result[UirExprId] =
    if (b == nil):
        return Err[UirExprId]("uirCore_builder: float op missing builder")
    var n: Node = n0
    while astNodeIdValid(n) && nodeKind(n) == astNodeKindPar() && kidCount(n) > 0:
        n = kid(n, 0)
    if (n == nil):
        return Err[UirExprId]("uirCore_builder: float op expects operand")
    if nodeKind(n) == astNodeKindFloatLit():
        if len(nodeStrVal(n)) > 0:
            return Ok[UirExprId](uirCoreConstI64(cheng_parse_f64_bits(nodeStrVal(n))))
        # Some stages may synthesize float literals without a raw string; default to 0.0 bits.
        return Ok[UirExprId](uirCoreConstI64(0))
    var key: str = exprTypeKeyShallow(b, n)
    if len(key) == 0 && nodeKind(n) == astNodeKindInfix() && kidCount(n) >= 3:
        key = exprTypeKeyShallow(b, kid(n, 1))
        if len(key) == 0:
            key = exprTypeKeyShallow(b, kid(n, 2))
    if isFloat64Key(key):
        let valRes2: Result[UirExprId] = lowerExprValue(b, n, uirCoreTypeF64())
        if ! IsOk[UirExprId](valRes2):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes2))
        return Ok[UirExprId](uirCoreCast(uirCoreTypeI64(), Value[UirExprId](valRes2)))
    if nodeKind(n) == astNodeKindPrefix() && kidCount(n) > 1:
        let opNode: Node = kid(n, 0)
        let op: str = backendOpName(opNode)
        if op == "-" || op == "+":
            let rhs: Node = kid(n, 1)
            var rhsKey: str = exprTypeKeyShallow(b, rhs)
            if len(rhsKey) == 0 && astNodeIdValid(rhs) && nodeKind(rhs) == astNodeKindInfix() && kidCount(rhs) >= 3:
                rhsKey = exprTypeKeyShallow(b, kid(rhs, 1))
                if len(rhsKey) == 0:
                    rhsKey = exprTypeKeyShallow(b, kid(rhs, 2))
            if isFloat64Key(rhsKey):
                let valRes3: Result[UirExprId] = lowerExprValue(b, n, uirCoreTypeF64())
                if ! IsOk[UirExprId](valRes3):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes3))
                return Ok[UirExprId](uirCoreCast(uirCoreTypeI64(), Value[UirExprId](valRes3)))
    if nodeKind(n) == astNodeKindIntLit():
        return Ok[UirExprId](uirCoreConstI64(cheng_i64_to_f64_bits(nodeIntVal(n))))
    let valRes: Result[UirExprId] = lowerExprValue(b, n, uirCoreTypeI64())
    if ! IsOk[UirExprId](valRes):
        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes))
    var val: UirExprId = Value[UirExprId](valRes)
    let vty: UirCoreType = inferExprTypeWithGlobals(blockBuilderEnv(b), blockBuilderModule(b), blockBuilderFuncRef(b), n, uirCoreTypeI32())
    if uirCoreTypeKindOf(vty) == uirCoreTypeKindI32() || uirCoreTypeKindOf(vty) == uirCoreTypeKindF32():
        val = uirCoreCast(uirCoreTypeI64(), val)
    var args: UirExprId[]
    builderExprSeqAppend(args, val)
    return Ok[UirExprId](uirCoreCall("cheng_i64_to_f64_bits", args))

fn lowerToF32Bits(b: BlockBuilder, n0: Node): Result[UirExprId] =
    if (b == nil):
        return Err[UirExprId]("uirCore_builder: float32 op missing builder")
    var n: Node = n0
    while astNodeIdValid(n) && nodeKind(n) == astNodeKindPar() && kidCount(n) > 0:
        n = kid(n, 0)
    if (n == nil):
        return Err[UirExprId]("uirCore_builder: float32 op expects operand")
    if nodeKind(n) == astNodeKindFloatLit():
        var bits64: int64
        if len(nodeStrVal(n)) > 0:
            bits64 = cheng_parse_f64_bits(nodeStrVal(n))
        var argsLit: UirExprId[]
        builderExprSeqAppend(argsLit, uirCoreConstI64(bits64))
        return Ok[UirExprId](uirCoreCall("cheng_f64_bits_to_f32_bits", argsLit))
    if nodeKind(n) == astNodeKindCall() && kidCount(n) > 0:
        let calleeNode: Node = kid(n, 0)
        let calleeName: str = backendStripSpaces(plainName(calleeNode))
        if calleeName == "float32":
            let vRes0: Result[UirExprId] = lowerExprValue(b, n, uirCoreTypeF32())
            if !IsOk[UirExprId](vRes0):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](vRes0))
            return Ok[UirExprId](uirCoreCast(uirCoreTypeI32(), Value[UirExprId](vRes0)))
        if calleeName == "float64" || calleeName == "float":
            let bits64ResCall: Result[UirExprId] = lowerToF64Bits(b, n)
            if !IsOk[UirExprId](bits64ResCall):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](bits64ResCall))
            var argsCall: UirExprId[]
            builderExprSeqAppend(argsCall, Value[UirExprId](bits64ResCall))
            return Ok[UirExprId](uirCoreCall("cheng_f64_bits_to_f32_bits", argsCall))

    var key: str = exprTypeKeyShallow(b, n)
    if len(key) == 0 && nodeKind(n) == astNodeKindInfix() && kidCount(n) >= 3:
        key = exprTypeKeyShallow(b, kid(n, 1))
        if len(key) == 0:
            key = exprTypeKeyShallow(b, kid(n, 2))
    if isFloat32Key(key):
        let vRes: Result[UirExprId] = lowerExprValue(b, n, uirCoreTypeF32())
        if !IsOk[UirExprId](vRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](vRes))
        return Ok[UirExprId](uirCoreCast(uirCoreTypeI32(), Value[UirExprId](vRes)))
    if isFloat64Key(key):
        let bits64Res0: Result[UirExprId] = lowerToF64Bits(b, n)
        if !IsOk[UirExprId](bits64Res0):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](bits64Res0))
        var args64_0: UirExprId[]
        builderExprSeqAppend(args64_0, Value[UirExprId](bits64Res0))
        return Ok[UirExprId](uirCoreCall("cheng_f64_bits_to_f32_bits", args64_0))
    if nodeKind(n) == astNodeKindIntLit():
        var argsInt: UirExprId[]
        builderExprSeqAppend(argsInt, uirCoreConstI64(cheng_i64_to_f64_bits(nodeIntVal(n))))
        return Ok[UirExprId](uirCoreCall("cheng_f64_bits_to_f32_bits", argsInt))

    let vty: UirCoreType = inferExprTypeWithGlobals(blockBuilderEnv(b), blockBuilderModule(b), blockBuilderFuncRef(b), n, uirCoreTypeI32())
    if uirCoreTypeKindOf(vty) == uirCoreTypeKindF32():
        let vRes2: Result[UirExprId] = lowerExprValue(b, n, uirCoreTypeF32())
        if !IsOk[UirExprId](vRes2):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](vRes2))
        return Ok[UirExprId](uirCoreCast(uirCoreTypeI32(), Value[UirExprId](vRes2)))
    if uirCoreTypeKindOf(vty) == uirCoreTypeKindF64():
        let bits64Res1: Result[UirExprId] = lowerToF64Bits(b, n)
        if !IsOk[UirExprId](bits64Res1):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](bits64Res1))
        var args64_1: UirExprId[]
        builderExprSeqAppend(args64_1, Value[UirExprId](bits64Res1))
        return Ok[UirExprId](uirCoreCall("cheng_f64_bits_to_f32_bits", args64_1))

    let valRes: Result[UirExprId] = lowerExprValue(b, n, uirCoreTypeI64())
    if !IsOk[UirExprId](valRes):
        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes))
    var val: UirExprId = Value[UirExprId](valRes)
    if uirCoreTypeKindOf(vty) == uirCoreTypeKindI32():
        val = uirCoreCast(uirCoreTypeI64(), val)
    var upArgs: UirExprId[]
    builderExprSeqAppend(upArgs, val)
    var downArgs: UirExprId[]
    builderExprSeqAppend(downArgs, uirCoreCall(uirCoreIntToF64BitsHelperName(vty), upArgs))
    return Ok[UirExprId](uirCoreCall("cheng_f64_bits_to_f32_bits", downArgs))

fn lowerObjConstructorCall(b: BlockBuilder, callNode: Node, objTypeName: str): Result[UirExprId] =
    let fref0: UirCoreFunc = blockBuilderFuncRef(b)
    if (b == nil) || blockBuilderModule(b) == nil || !uirCoreFuncIdValid(fref0):
        return Err[UirExprId]("uirCore_builder: object constructor missing builder/module")
    if !astNodeIdValid(callNode) || nodeKind(callNode) != astNodeKindCall():
        return Err[UirExprId]("uirCore_builder: invalid object constructor call")
    if len(objTypeName) == 0 || !uirCoreHasObjType(blockBuilderModule(b), objTypeName):
        return Err[UirExprId]("uirCore_builder: unknown object constructor type")
    let ot: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), objTypeName)

    let tmpName: str = blockBuilderNextTemp(b, "__obj")
    let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
    uirCoreSetLocalType(fref0, tmpSlot, uirCoreTypeI64())
    localSetTypeKey(blockBuilderEnv(b), tmpSlot, objTypeName)
    let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objTypeName)
    if ! uirCoreResultBoolIsOk(allocRes):
        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
    let initRes: Result[bool] = emitObjDefaultInit(b, tmpSlot, objTypeName)
    if ! uirCoreResultBoolIsOk(initRes):
        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes))

    let basePtr: UirExprId = uirCoreLocal(tmpSlot)
    for ai in 1..<kidCount(callNode):
        let arg0: Node = kid(callNode, ai)
        if !astNodeIdValid(arg0) || nodeKind(arg0) != astNodeKindCallArg() || kidCount(arg0) < 2:
            return Err[UirExprId]("uirCore_builder: object constructor expects named args")
        let keyNode: Node = kid(arg0, 0)
        let valNode: Node = kid(arg0, 1)
        if (keyNode == nil) || (nodeKind(keyNode) != astNodeKindIdent() && nodeKind(keyNode) != astNodeKindSymbol()):
            return Err[UirExprId]("uirCore_builder: object constructor field expects identifier")
        let fieldName: str = backendStripSpaces(plainName(keyNode))

        let fieldIdx: int32 = uirCoreObjFieldIndexByName(ot, fieldName)
        if fieldIdx >= 0:
            let field: UirCoreObjField = uirCoreFieldAt(ot, fieldIdx)
            var addr: UirExprId = basePtr
            if uirCoreOffsetOf(field) != 0:
                addr = uirCoreBin(uirCoreBinOpAdd(), basePtr, uirCoreConstI64(int64(uirCoreOffsetOf(field))))
            let valRes: Result[UirExprId] = lowerExprValue(b, valNode, uirCoreTypeOf(field))
            if ! IsOk[UirExprId](valRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes))
            blockBuilderAddStmt(b, uirCoreStmtStore(addr, Value[UirExprId](valRes), uirCoreTypeOf(field)))
            continue

        let prefix: str = uirCoreAppendChar(fieldName, '.')
        var hasPrefix: bool
        var minOff: int32 = 2147483647
        for fi2 in 0..<uirCoreFieldsLen(ot):
            let f2: UirCoreObjField = uirCoreFieldAt(ot, fi2)
            if uirCoreStrStartsWith(uirCoreNameOf(f2), prefix):
                hasPrefix = true
                if uirCoreOffsetOf(f2) < minOff:
                    minOff = uirCoreOffsetOf(f2)
        if !hasPrefix:
            let line: str = intToStr(nodePosLine(keyNode))
            let col: str = intToStr(nodePosCol(keyNode))
            if (getEnv("BACKEND_DEBUG_OBJCTOR") == "1"):
                let calleeDbg: str = backendStripSpaces(plainName(kid(callNode, 0)))
                echo("[backend] debugObjCtorUnknown: objType='" + objTypeName + "' field='" + fieldName +
                     "' callee='" + calleeDbg + "' @" + line + ":" + col)
            return Err[UirExprId]("uirCore_builder: unknown object field '" + fieldName + "' @" + line + ":" + col)

        var dstObjName: str = uirCoreInlineObjFieldTypeGet(objTypeName, fieldName)
        let fieldKey0: str = backendStripSpaces(uirCoreObjFieldTypeKeyGet(objTypeName, fieldName))
        if len(fieldKey0) > 0:
            dstObjName = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), fieldKey0)
            if len(dstObjName) == 0 && uirCoreHasObjType(blockBuilderModule(b), fieldKey0):
                dstObjName = fieldKey0
            if len(dstObjName) == 0:
                let fieldCanon: str = uirCoreObjAliasCanon(fieldKey0)
                if len(fieldCanon) > 0 && uirCoreHasObjType(blockBuilderModule(b), fieldCanon):
                    dstObjName = fieldCanon

        let srcObjName: str = uirCoreNestedCtorSrcObjName(b, fref0, valNode, dstObjName)
        if (getEnv("BACKEND_DEBUG_NESTED_CTOR") == "1") &&
           (((objTypeName == "GossipsubContext") && (fieldName == "params")) ||
            ((objTypeName == "Cid") && (fieldName == "codec"))):
            let kDbg: str = uirCoreMaybeCaseInferExprTypeKey(b, valNode)
            let vkDbg: str = uirCoreNodeKindOrNil(valNode)
            let kDbg2: str = uirCoreMaybeInferNodeTypeKeyForOverload(b, valNode)
            let oDbg2: str = uirCoreObjTypeFromKeyOrEmpty(blockBuilderModule(b), kDbg2)
            echo("[backend] debugNestedCtor: ctor=" + objTypeName + " field=" + fieldName +
                 " valKind=nk#" + vkDbg + " key='" + kDbg + "' srcObjName='" + srcObjName + "'")
            echo("[backend] debugNestedCtor: ctor=" + objTypeName + " field=" + fieldName +
                 " inferKey='" + kDbg2 + "' inferObj='" + oDbg2 + "'")
        if len(srcObjName) == 0:
            let fkDbg: str = backendStripSpaces(uirCoreObjFieldTypeKeyGet(objTypeName, fieldName))
            let vkDbg2: str = uirCoreNodeKindOrNil(valNode)
            return Err[UirExprId]("uirCore_builder: object constructor field '" + fieldName + "' expects object value" +
                                " (obj=" + objTypeName + " fieldKey=" + fkDbg +
                                " inlineObj=" + dstObjName + " valKind=nk#" + vkDbg2 + ")")
        let srcRes: Result[UirExprId] = lowerExprValue(b, valNode, uirCoreTypeI64())
        if ! IsOk[UirExprId](srcRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](srcRes))
        var dstPtr: UirExprId = basePtr
        if minOff != 0 && minOff != 2147483647:
            dstPtr = uirCoreBin(uirCoreBinOpAdd(), basePtr, uirCoreConstI64(int64(minOff)))
        let copyRes: Result[bool] = emitObjCopyPtrs(b, dstPtr, srcObjName, Value[UirExprId](srcRes))
        if ! uirCoreResultBoolIsOk(copyRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes))
    return Ok[UirExprId](uirCoreLocal(tmpSlot))

fn lowerObjConstructorCallPositional(b: BlockBuilder, callNode: Node, objTypeName: str): Result[UirExprId] =
    let fref0: UirCoreFunc = blockBuilderFuncRef(b)
    if (b == nil) || blockBuilderModule(b) == nil || !uirCoreFuncIdValid(fref0):
        return Err[UirExprId]("uirCore_builder: object constructor missing builder/module")
    if !astNodeIdValid(callNode) || nodeKind(callNode) != astNodeKindCall():
        return Err[UirExprId]("uirCore_builder: invalid object constructor call")
    if len(objTypeName) == 0 || !uirCoreHasObjType(blockBuilderModule(b), objTypeName):
        return Err[UirExprId]("uirCore_builder: unknown object constructor type")
    let ot: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), objTypeName)
    let argCount: int32 = kidCount(callNode) - 1
    if (getEnv("BACKEND_DEBUG_OBJCTOR") == "1") && (objTypeName == "Option_PublicKey"):
        let fnNameDbg: str = uirCoreCurrentFuncName(b)
        echo("[backend] debugObjCtor: obj=" + objTypeName +
             " argc=" + intToStr(argCount) + " fields=" + intToStr(uirCoreFieldsLen(ot)) +
             " fn=" + fnNameDbg)
    if argCount == 0:
        let tmpName: str = blockBuilderNextTemp(b, "__obj")
        let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
        uirCoreSetLocalType(fref0, tmpSlot, uirCoreTypeI64())
        localSetTypeKey(blockBuilderEnv(b), tmpSlot, objTypeName)
        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objTypeName)
        if !uirCoreResultBoolIsOk(allocRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
        let initRes: Result[bool] = emitObjDefaultInit(b, tmpSlot, objTypeName)
        if !uirCoreResultBoolIsOk(initRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes))
        return Ok[UirExprId](uirCoreLocal(tmpSlot))
    if argCount > 0 && argCount <= uirCoreFieldsLen(ot):
        let tmpName: str = blockBuilderNextTemp(b, "__obj")
        let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), tmpSlot, uirCoreTypeI64())
        localSetTypeKey(blockBuilderEnv(b), tmpSlot, objTypeName)
        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objTypeName)
        if !uirCoreResultBoolIsOk(allocRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
        let initRes: Result[bool] = emitObjDefaultInit(b, tmpSlot, objTypeName)
        if !uirCoreResultBoolIsOk(initRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes))
        let dstPtr: UirExprId = uirCoreLocal(tmpSlot)

        for fi0 in 0..<argCount:
            let f0: UirCoreObjField = uirCoreFieldAt(ot, fi0)
            var valNode0: Node = kid(callNode, 1 + fi0)
            if astNodeIdValid(valNode0) && nodeKind(valNode0) == astNodeKindCallArg() && kidCount(valNode0) > 1:
                valNode0 = kid(valNode0, 1)
            let valRes0: Result[UirExprId] = lowerExprValue(b, valNode0, uirCoreTypeOf(f0))
            if !IsOk[UirExprId](valRes0):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes0))
            var addr0: UirExprId = dstPtr
            if uirCoreOffsetOf(f0) != 0:
                addr0 = uirCoreBin(uirCoreBinOpAdd(), dstPtr, uirCoreConstI64(int64(uirCoreOffsetOf(f0))))
            blockBuilderAddStmt(b, uirCoreStmtStore(addr0, Value[UirExprId](valRes0), uirCoreTypeOf(f0)))
        return Ok[UirExprId](uirCoreLocal(tmpSlot))

    if argCount <= uirCoreFieldsLen(ot) + 1:
        var dstNode: Node = kid(callNode, 1)
        if astNodeIdValid(dstNode) && nodeKind(dstNode) == astNodeKindCallArg() && kidCount(dstNode) > 1:
            dstNode = kid(dstNode, 1)
        let dstRes: Result[UirExprId] = lowerExprValue(b, dstNode, uirCoreTypeI64())
        if ! IsOk[UirExprId](dstRes):
            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](dstRes))
        let dstPtr: UirExprId = Value[UirExprId](dstRes)
        let initRes: Result[bool] = emitObjDefaultInitPtrs(b, dstPtr, objTypeName)
        if !uirCoreResultBoolIsOk(initRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes))

        let argFields: int32 = argCount - 1
        for fi in 0..<argFields:
            let f: UirCoreObjField = uirCoreFieldAt(ot, fi)
            var valNode: Node = kid(callNode, 2 + fi)
            if astNodeIdValid(valNode) && nodeKind(valNode) == astNodeKindCallArg() && kidCount(valNode) > 1:
                valNode = kid(valNode, 1)
            let valRes: Result[UirExprId] = lowerExprValue(b, valNode, uirCoreTypeOf(f))
            if ! IsOk[UirExprId](valRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes))
            var addr: UirExprId = dstPtr
            if uirCoreOffsetOf(f) != 0:
                addr = uirCoreBin(uirCoreBinOpAdd(), dstPtr, uirCoreConstI64(int64(uirCoreOffsetOf(f))))
            blockBuilderAddStmt(b, uirCoreStmtStore(addr, Value[UirExprId](valRes), uirCoreTypeOf(f)))
        return Ok[UirExprId](dstPtr)

    # Too many args for a positional object constructor.
    if argCount > uirCoreFieldsLen(ot) + 1:
        let line1: str = intToStr(nodePosLine(callNode))
        let col1: str = intToStr(nodePosCol(callNode))
        let fnName1: str = uirCoreCurrentFuncName(b)
        let fp1: str = uirCoreCurrentFuncOriginFile(b)
        return Err[UirExprId]("uirCore_builder: object constructor '" + objTypeName +
                            "' expects all fields (or dst + all fields)" +
                            " (argc=" + intToStr(argCount) + " fields=" + intToStr(uirCoreFieldsLen(ot)) +
                            " fn=" + fnName1 + " " + fp1 + ":" + line1 + ":" + col1 + ")")
    return Err[UirExprId]("uirCore_builder: object constructor internal error")

fn uirCoreLowerObjLocalLvalueAddr(b: BlockBuilder, idx: int32): Result[UirExprId] =
    if (b == nil) || !uirCoreFuncIdValid(blockBuilderFuncRef(b)) || idx < 0:
        return Err[UirExprId]("uirCore_builder: invalid object local lvalue")
    let fref: UirCoreFunc = blockBuilderFuncRef(b)
    let olIdx: int32 = funcFindObjLocal(fref, idx)
    if olIdx < 0:
        return Ok[UirExprId](uirCoreAddr(idx))
    let ol: UirCoreObjLocal = uirCoreFuncObjLocalAt(fref, olIdx)
    var key0: str = uirCoreTypeKeyOf(ol)
    if len(key0) == 0:
        key0 = localTypeKey(blockBuilderEnv(b), idx)
    var baseKey0: str = key0
    var step0: int32
    var nextVarBase0: str = uirCoreParamVarBaseKey(baseKey0)
    while len(nextVarBase0) > 0 && step0 < 4:
        baseKey0 = nextVarBase0
        step0 = step0 + 1
        nextVarBase0 = uirCoreParamVarBaseKey(baseKey0)
    var aliasTy0: UirCoreType = uirCoreTypeVoid()
    if blockBuilderModule(b) != nil && len(baseKey0) > 0:
        aliasTy0 = uirCoreTryGetTypeAlias(blockBuilderModule(b), baseKey0)
    let isPtrLike0: bool = (len(baseKey0) > 0 &&
                           (uirCoreStrStartsWith(baseKey0, "ptr_") || uirCoreStrStartsWith(baseKey0, "ref_"))) ||
                          uirCoreTypeKindOf(aliasTy0) != uirCoreTypeKindVoid()
    if isPtrLike0:
        return Ok[UirExprId](uirCoreAddr(idx))
    if uirCoreFrameOffOf(ol) >= 0:
        return Ok[UirExprId](uirCoreLocal(idx))
    return Ok[UirExprId](uirCoreAddr(idx))

fn uirCoreLowerNamedLvalueAddr(b: BlockBuilder, nameNode: Node, errPrefix: str,
                               resolveFuncSymbol: bool): Result[UirExprId] =
    if (b == nil) || (nameNode == nil) || (nodeKind(nameNode) != astNodeKindIdent() && nodeKind(nameNode) != astNodeKindSymbol()):
        return Err[UirExprId](errPrefix + " expects lvalue")
    let nm: str = plainName(nameNode)
    let idx: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
    uirCoreMarkImplicitResultUse(b, nm, idx)
    if idx >= 0:
        return uirCoreLowerObjLocalLvalueAddr(b, idx)
    let gi: int32 = moduleGlobalIndex(blockBuilderModule(b), nm)
    if gi >= 0:
        let gObj: str = uirCoreGlobalObjTypeGet(nm)
        if len(gObj) > 0:
            return Ok[UirExprId](uirCoreLoad(uirCoreGlobalAddr(nm), uirCoreTypeI64()))
        return Ok[UirExprId](uirCoreGlobalAddr(nm))
    if resolveFuncSymbol && (blockBuilderModule(b) != nil) && moduleHasFuncByBase(blockBuilderModule(b), nm):
        let callerFile: str = uirCoreCurrentFuncOriginFile(b)
        let f1: UirCoreFunc = moduleFindFuncByBasePreferOrigin(blockBuilderModule(b), nm, callerFile)
        if (f1 == nil):
            return Err[UirExprId]("uirCore_builder: ambiguous function reference")
        let sym: str = uirCoreFuncLinkNameOrName(f1)
        return Ok[UirExprId](uirCoreGlobalAddr(sym))
    return Ok[UirExprId](uirCoreGlobalAddr(nm))

fn uirCoreLowerLvalueAddr(b: BlockBuilder, argNode0: Node, errPrefix: str,
                          resolveFuncSymbol: bool): Result[UirExprId] =
    if (b == nil):
        return Err[UirExprId](errPrefix + " missing builder")
    var argNode: Node = argNode0
    while astNodeIdValid(argNode) && nodeKind(argNode) == astNodeKindPar() && kidCount(argNode) > 0:
        argNode = kid(argNode, 0)
    var da: DotAccess
    let dotRes: Result[bool] = uirCoreTryLowerDotAccess(b, argNode, &da)
    if !IsOk[bool](dotRes):
        return ErrInfo[UirExprId](ErrorInfoOf[bool](dotRes))
    if Value[bool](dotRes):
        return Ok[UirExprId](dotAccessAddr(da))
    if astNodeIdValid(argNode) && nodeKind(argNode) == astNodeKindBracketExpr() && kidCount(argNode) == 1:
        return lowerExprValue(b, kid(argNode, 0), uirCoreTypeI64())
    if (argNode != nil) && (nodeKind(argNode) == astNodeKindHiddenDeref() || nodeKind(argNode) == astNodeKindDerefExpr()) &&
       kidCount(argNode) > 0:
        return lowerExprValue(b, kid(argNode, 0), uirCoreTypeI64())
    if (argNode == nil) || (nodeKind(argNode) != astNodeKindIdent() && nodeKind(argNode) != astNodeKindSymbol()):
        return Err[UirExprId](errPrefix + " expects lvalue")
    return uirCoreLowerNamedLvalueAddr(b, argNode, errPrefix, resolveFuncSymbol)

fn lowerVarArgAddr(b: BlockBuilder, argNode0: Node): Result[UirExprId] =
    if (b == nil):
        return Err[UirExprId]("uirCore_builder: var arg missing builder")
    var argNode: Node = argNode0
    while astNodeIdValid(argNode) && nodeKind(argNode) == astNodeKindPar() && kidCount(argNode) > 0:
        argNode = kid(argNode, 0)
    if astNodeIdValid(argNode) && nodeKind(argNode) == astNodeKindCall() && kidCount(argNode) > 0:
        let calleeNode: Node = kid(argNode, 0)
        if (calleeNode != nil) && (nodeKind(calleeNode) == astNodeKindIdent() || nodeKind(calleeNode) == astNodeKindSymbol()):
            let name: str = backendStripSpaces(plainName(calleeNode))
            if name == "__addr":
                return lowerExprValue(b, argNode, uirCoreTypeI64())
    let addrRes: Result[UirExprId] = uirCoreLowerLvalueAddr(b, argNode,
                                                            "uirCore_builder: var arg",
                                                            false)
    if !IsOk[UirExprId](addrRes):
        if (argNode == nil) || (nodeKind(argNode) != astNodeKindIdent() && nodeKind(argNode) != astNodeKindSymbol()):
            let k: str = uirCoreNodeKindOrZero(argNode)
            let line: str = uirCoreNodePosLineOrZero(argNode)
            let col: str = uirCoreNodePosColOrZero(argNode)
            return Err[UirExprId]("uirCore_builder: var arg expects lvalue (got nk#" + k +
                                  " @" + line + ":" + col + ")")
        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](addrRes))
    return addrRes

fn lowerExprPtrValue(b: BlockBuilder, n: Node): Result[UirExprId] =
    # Pointer-context expression lowering (used by deref stores like `*p = v`).
    # `lowerExprValue` loads through `var_` slots to produce the underlying value.
    # For stores, we need the address:
    # - `var T` where T is a scalar: the slot already holds the target address; do not load.
    # - `var ptr_T`: the slot holds the address of a pointer value; load once to get ptr_T.
    if (n == nil):
        return Err[UirExprId]("uirCore_builder: nil ptr expr")
    var node: Node = n
    while astNodeIdValid(node) && nodeKind(node) == astNodeKindPar() && kidCount(node) > 0:
        node = kid(node, 0)
    if (node == nil):
        return Err[UirExprId]("uirCore_builder: nil ptr expr")
    if nodeKind(node) == astNodeKindIdent() || nodeKind(node) == astNodeKindSymbol():
        let nm: str = backendStripSpaces(plainName(node))
        let idx: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        uirCoreMarkImplicitResultUse(b, nm, idx)
        if idx >= 0:
            let key0: str = localTypeKey(blockBuilderEnv(b), idx)
            if len(key0) > 0:
                let baseKey: str = uirCoreParamVarBaseKey(key0)
                if len(baseKey) > 0:
                    if uirCoreStrStartsWith(baseKey, "ptr_"):
                        return Ok[UirExprId](uirCoreLoad(uirCoreLocal(idx), uirCoreTypeI64()))
                    return Ok[UirExprId](uirCoreLocal(idx))
    return lowerExprValue(b, node, uirCoreTypeI64())

fn lowerSpawnEntryArg(b: BlockBuilder, argNode0: Node): Result[UirExprId] =
    if (b == nil):
        return Err[UirExprId]("uirCore_builder: spawn entry missing builder")
    var argNode: Node = argNode0
    while astNodeIdValid(argNode) && nodeKind(argNode) == astNodeKindPar() && kidCount(argNode) > 0:
        argNode = kid(argNode, 0)
    if !astNodeIdValid(argNode) || nodeKind(argNode) == astNodeKindNilLit():
        return Ok[UirExprId](uirCoreConstI64(0))
    let baseRes: Result[UirExprId] = lowerExprValue(b, argNode, uirCoreTypeI64())
    if IsOk[UirExprId](baseRes):
        return baseRes
    if nodeKind(argNode) == astNodeKindIdent() || nodeKind(argNode) == astNodeKindSymbol():
        let msg: str = Error(baseRes)
        if len(msg) > 0 && uirCoreStrStartsWith(msg, "uirCore_builder: unknown local/global: "):
            let nm: str = backendStripSpaces(plainName(argNode))
            if len(nm) > 0:
                var sym: str = nm
                if uirCoreDupFnBasesHas(nm) && uirCoreFuncIdValid(blockBuilderFuncRef(b)):
                    let f0: UirCoreFunc = blockBuilderFuncRef(b)
                    let m0: str = uirCoreMaybeMangleDupFnBase(nm, uirCoreFuncOriginFileOf(f0))
                    if len(m0) > 0:
                        sym = m0
                return Ok[UirExprId](uirCoreGlobalAddr(sym))
    return baseRes

fn lowerExprGuardNode(n: Node): Node =
    var node: Node = n
    while astNodeIdValid(node) && nodeKind(node) == astNodeKindPar() && kidCount(node) > 0:
        node = kid(node, 0)
    while astNodeIdValid(node) && nodeKind(node) == astNodeKindCallArg() && kidCount(node) > 0:
        node = kid(node, kidCount(node) - 1)
    return node

fn lowerExprGuardFailMsg(b: BlockBuilder, node: Node, reason: str): str =
    let fnName: str = uirCoreCurrentFuncName(b)
    let filePath: str = uirCoreCurrentFuncOriginFile(b)
    let line: str = intToStr(nodePosLine(node))
    let col: str = intToStr(nodePosCol(node))
    return "uirCore_builder: " + reason + " (fn=" + fnName + " " + filePath + ":" + line + ":" + col + ")"

fn lowerExprGuardEnter(b: BlockBuilder, n: Node): Result[bool] =
    if b == nil:
        return Ok[bool](true)
    if blockBuilderExprLowerDepth(b) < 0:
        blockBuilderSetExprLowerDepth(b, 0)
    let maxDepth: int32 = 4096
    let node: Node = lowerExprGuardNode(n)
    if blockBuilderExprLowerDepth(b) >= maxDepth:
        return Err[bool](lowerExprGuardFailMsg(b, node, "lowerExpr recursion depth overflow depth=" +
                         intToStr(blockBuilderExprLowerDepth(b))))
    if node != nil:
        for si in 0..<blockBuilderExprLowerStackLen(b):
            if blockBuilderExprLowerStackAt(b, si) == node:
                return Err[bool](lowerExprGuardFailMsg(b, node, "lowerExpr recursion cycle depth=" +
                                 intToStr(blockBuilderExprLowerDepth(b))))
        blockBuilderExprLowerPush(b, node)
    blockBuilderExprLowerDepthInc(b)
    return Ok[bool](true)

fn lowerExprGuardLeave(b: BlockBuilder, n: Node) =
    if b == nil:
        return
    if blockBuilderExprLowerDepth(b) > 0:
        blockBuilderExprLowerDepthDec(b)
    let node: Node = lowerExprGuardNode(n)
    if node == nil || blockBuilderExprLowerStackLen(b) == 0:
        return
    let topIdx: int32 = blockBuilderExprLowerStackLen(b) - 1
    if blockBuilderExprLowerStackAt(b, topIdx) == node:
        blockBuilderExprLowerStackSetLen(b, topIdx)
        return
    for si in 0..<blockBuilderExprLowerStackLen(b):
        if blockBuilderExprLowerStackAt(b, si) == node:
            let lastIdx: int32 = blockBuilderExprLowerStackLen(b) - 1
            blockBuilderExprLowerStackSetAt(b, si, blockBuilderExprLowerStackAt(b, lastIdx))
            blockBuilderExprLowerStackSetLen(b, lastIdx)
            break

fn lowerExprValue(b: BlockBuilder, n: Node, wantType: UirCoreType): Result[UirExprId] =
    if b != nil:
        blockBuilderFuncRef(b)
    let guardRes: Result[bool] = lowerExprGuardEnter(b, n)
    if !uirCoreResultBoolIsOk(guardRes):
        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(guardRes))
    let outRes: Result[UirExprId] = lowerExprValueCore(b, n, wantType)
    lowerExprGuardLeave(b, n)
    return outRes

fn lowerExprValueCore(b: BlockBuilder, n: Node, wantType: UirCoreType): Result[UirExprId] =
    if (n == nil):
        return Err[UirExprId]("uirCore_builder: nil expr")
    var node: Node = n
    while astNodeIdValid(node) && nodeKind(node) == astNodeKindPar() && kidCount(node) > 0:
        node = kid(node, 0)
    while astNodeIdValid(node) && nodeKind(node) == astNodeKindCallArg() && kidCount(node) > 0:
        node = kid(node, kidCount(node) - 1)
    if (node == nil):
        return Err[UirExprId]("uirCore_builder: nil expr")
    if nodeKind(node) == astNodeKindHiddenDeref() || nodeKind(node) == astNodeKindDerefExpr():
        if kidCount(node) == 0:
            return Err[UirExprId]("uirCore_builder: deref expects operand")
        let addrNode: Node = kid(node, 0)
        let elemKey: str = uirCoreDerefElemKey(node)
        let ptrKey: str = exprTypeKeyShallow(b, addrNode)
        if isByteTypeKey(elemKey) || isBytePtrTypeKey(ptrKey):
            let addrRes: Result[UirExprId] = lowerExprValue(b, addrNode, uirCoreTypeI64())
            if !IsOk[UirExprId](addrRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](addrRes))
            let byteTy: UirCoreType = byteUirTypeFromElemOrPtrKey(elemKey, ptrKey)
            let loaded: UirExprId = lowerByteLoadNilChecked(b, Value[UirExprId](addrRes), byteTy, wantType)
            return Ok[UirExprId](loaded)
        if uirCoreStrStartsWith(ptrKey, "ptr_"):
            # Pointer-to-object deref is a no-op in MIR because object values are represented as pointers.
            # Example: `seq[T]*` is lowered as an i64 pointer to the seq storage; `*p` yields the same pointer.
            let baseKey: str = rawmemStrFromOffset(ptrKey, 4)
            if (b != nil) && blockBuilderModule(b) != nil && len(baseKey) > 0:
                let objTypeName: str = uirCorePtrBaseObjTypeName(blockBuilderModule(b), baseKey)
                if len(objTypeName) > 0:
                    let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(blockBuilderModule(b), objTypeName)
                    if uirCoreTypeKindOf(aliasTy) == uirCoreTypeKindVoid():
                        return lowerExprValue(b, addrNode, uirCoreTypeI64())
            let addrRes2: Result[UirExprId] = lowerExprValue(b, addrNode, uirCoreTypeI64())
            if !IsOk[UirExprId](addrRes2):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](addrRes2))
            return Ok[UirExprId](uirCoreLoad(Value[UirExprId](addrRes2), wantType))
        # Object values are represented as pointers in MIR; deref is a no-op.
        return lowerExprValue(b, addrNode, uirCoreTypeI64())
    if uirCoreNodeIsStringLiteral(node):
        let value: str = nodeStrVal(node)
        let valueKey: str = caseInferExprTypeKey(b, node)
        if isSemanticStrKey(valueKey):
            let valueObj: str = uirCoreSemanticStrObjTypeName(blockBuilderModule(b), valueKey)
            if len(valueObj) > 0:
                return lowerSemanticStrLiteralValue(b, value, valueObj, valueKey)
        if os.GetEnvDefault("BACKEND_DEBUG_CSTRING_LOWERING", "") == "1":
            echo("[uir.strlit.lower] len=" + intToStr(len(value)))
            if len(value) > 0:
                echo(value)
        let label: str = uirCoreAddCString(blockBuilderModule(b), value)
        return Ok[UirExprId](uirCoreGlobalAddr(label))
    if nodeKind(node) == astNodeKindFloatLit():
        if len(nodeStrVal(node)) > 0:
            return Ok[UirExprId](uirCoreCast(uirCoreTypeF64(), uirCoreConstI64(cheng_parse_f64_bits(nodeStrVal(node)))))
        # Some stages may synthesize float literals without a raw string; default to 0.0 bits.
        return Ok[UirExprId](uirCoreCast(uirCoreTypeF64(), uirCoreConstI64(0)))
    if nodeKind(node) == astNodeKindDotExpr():
        # Dot-call sugar (no-paren) for a zero-arg receiver method.
        # Example: `seq.reset` is lowered as `freeSeq[T](seq)` (where T is inferred from `seq[T]`).
        if kidCount(node) == 2:
            let base0: Node = kid(node, 0)
            let member0: Node = kid(node, 1)
            if (base0 != nil) && (member0 != nil) && (nodeKind(member0) == astNodeKindIdent() || nodeKind(member0) == astNodeKindSymbol()):
                let memberName0: str = uirCoreMemberName(member0)
                if memberName0 == "reset":
                    let baseKey0: str = exprTypeKeyShallow(b, base0)
                    if uirCoreStrStartsWith(baseKey0, "seq_"):
                        let elemKey0: str = rawmemStrFromOffset(baseKey0, 4)
                        if len(elemKey0) == 0:
                            return Err[UirExprId]("uirCore_builder: seq.reset missing element type")
                        let baseRes0: Result[UirExprId] = lowerExprValue(b, base0, uirCoreTypeI64())
                        if !IsOk[UirExprId](baseRes0):
                            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](baseRes0))
                        let typeArg0: Node = newIdent(elemKey0, nodePos(node))
                        var typeArgs0: Node[]
                        astNodeSeqAppend(typeArgs0, typeArg0)
                        var callName0: str = mangleInstance("freeSeq", typeArgs0)
                        var callInternal0: str = callName0
                        if blockBuilderModule(b) != nil:
                            var argNodes0: Node[]
                            astNodeSeqAppend(argNodes0, base0)
                            let cand0: UirCoreFunc = uirCoreResolveCalleeFuncBestEffortByNode(b, node, callName0, argNodes0, "")
                            if (cand0 != nil):
                                callInternal0 = uirCoreCallSymbolForFunc(cand0)
                            else:
                                let cand1: UirCoreFunc = uirCoreResolveCalleeFuncBestEffortByNode(b, node, "freeSeq", argNodes0, "")
                                if (cand1 != nil):
                                    callInternal0 = uirCoreCallSymbolForFunc(cand1)
                        if len(callInternal0) == 0:
                            callInternal0 = callName0
                        var args0: UirExprId[]
                        builderExprSeqAppend(args0, Value[UirExprId](baseRes0))
                        return Ok[UirExprId](uirCoreCall(callInternal0, args0))
        var da: DotAccess
        let dotValRes: Result[bool] = uirCoreTryLowerDotAccess(b, node, &da)
        if !IsOk[bool](dotValRes):
            return ErrInfo[UirExprId](ErrorInfoOf[bool](dotValRes))
        if !Value[bool](dotValRes):
            return Err[UirExprId]("uirCore_builder: dot value expects field access")
        if uirCoreTypeKindOf(dotAccessFieldTy(da)) == uirCoreTypeKindVoid():
            return Ok[UirExprId](dotAccessAddr(da))
        if nodeTypeCacheValid(node) && astRefNonNil(nodeTypeCache(node)):
            let objNm: str = typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(node))
            if len(objNm) > 0 && typeNodeIsObjValue(blockBuilderModule(b), nodeTypeCache(node)):
                # Object values in MIR are pointers to their storage; dot returns the field address.
                return Ok[UirExprId](dotAccessAddr(da))
        return Ok[UirExprId](uirCoreLoad(dotAccessAddr(da), dotAccessFieldTy(da)))
    if nodeKind(node) == astNodeKindBracketExpr():
        # Generic bracket expressions used as values (e.g. `T()`).
        # Note: prefix-deref `*p` is also represented as `astNodeKindBracketExpr()` with a single child.
        if kidCount(node) == 2:
            let base0: Node = kid(node, 0)
            if (base0 != nil) && (nodeKind(base0) == astNodeKindIdent() || nodeKind(base0) == astNodeKindSymbol()):
                let baseName: str = backendStripSpaces(plainName(base0))
                if baseName == "default":
                    let typeArg0: Node = kid(node, 1)
                    if (typeArg0 != nil) && (nodeKind(typeArg0) == astNodeKindIdent() || nodeKind(typeArg0) == astNodeKindSymbol()):
                        let tn: str = backendStripSpaces(plainName(typeArg0))
                        if isSemanticStrKey(tn):
                            let objNmStr: str = uirCoreDirectObjValueTypeNameFromKey(blockBuilderModule(b), tn)
                            if len(objNmStr) > 0:
                                return lowerSemanticStrLiteralValue(b, "", objNmStr, tn)
                        if isStringKey(tn):
                            let label0: str = uirCoreAddCString(blockBuilderModule(b), "")
                            return Ok[UirExprId](uirCoreGlobalAddr(label0))
                    let mod0: UirCoreModule = blockBuilderModule(b)
                    if (mod0 != nil):
                        let objNm: str = typeNodeObjTypeName(mod0, typeArg0)
                        if len(objNm) > 0 && typeNodeIsObjValue(mod0, typeArg0):
                            let tmpName: str = blockBuilderNextTemp(b, "__default")
                            let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
                            uirCoreSetLocalType(blockBuilderFuncRef(b), tmpSlot, uirCoreTypeI64())
                            let tk0: str = typeKey(typeArg0)
                            if len(tk0) > 0:
                                localSetTypeKey(blockBuilderEnv(b), tmpSlot, tk0)
                                funcSetObjTypeKey(blockBuilderFuncRef(b), tmpSlot, tk0)
                            let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, objNm)
                            if !uirCoreResultBoolIsOk(allocRes):
                                return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
                            let initRes: Result[bool] = emitObjDefaultInit(b, tmpSlot, objNm)
                            if !uirCoreResultBoolIsOk(initRes):
                                return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes))
                            return Ok[UirExprId](uirCoreLocal(tmpSlot))
                    return Ok[UirExprId](uirCoreConstI64(0))

            # Slice: `str/seq[T][a..b]` / `a..<b`
            var idx0: Node = kid(node, 1)
            while astNodeIdValid(idx0) && nodeKind(idx0) == astNodeKindPar() && kidCount(idx0) > 0:
                idx0 = kid(idx0, 0)
            if astNodeIdValid(idx0) && nodeKind(idx0) == astNodeKindInfix() && kidCount(idx0) >= 3:
                let opNode: Node = kid(idx0, 0)
                let op: str = backendOpName(opNode)
                if op == ".." || op == "..<":
                    let baseKey: str = uirCoreBaseExprKeyForSlice(b, base0)

                    let startRes: Result[UirExprId] = lowerExprValue(b, kid(idx0, 1), uirCoreTypeI64())
                    if !IsOk[UirExprId](startRes):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](startRes))
                    let stopRes: Result[UirExprId] = lowerExprValue(b, kid(idx0, 2), uirCoreTypeI64())
                    if !IsOk[UirExprId](stopRes):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](stopRes))
                    let exclusive: UirExprId = (op == "..<") ? uirCoreConstI64(1) : uirCoreConstI64(0)
                    let start32: UirExprId = uirCoreCast(uirCoreTypeI32(), Value[UirExprId](startRes))
                    let stop32: UirExprId = uirCoreCast(uirCoreTypeI32(), Value[UirExprId](stopRes))

                    if uirCoreNodeHasStringCtx(baseKey, base0):
                        let baseRes: Result[UirExprId] = lowerExprValue(b, base0, uirCoreTypeI64())
                        if !IsOk[UirExprId](baseRes):
                            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](baseRes))
                        var args: UirExprId[]
                        builderExprSeqAppend(args, Value[UirExprId](baseRes))
                        builderExprSeqAppend(args, start32)
                        builderExprSeqAppend(args, stop32)
                        builderExprSeqAppend(args, exclusive)
                        return Ok[UirExprId](uirCoreCall("__cheng_slice_string", args))

                    if uirCoreStrStartsWith(baseKey, "seq_"):
                        let elemKey: str = rawmemStrFromOffset(baseKey, 4)
                        if len(elemKey) == 0:
                            return Err[UirExprId]("uirCore_builder: seq slice missing element type")
                        let typeArg0: Node = newIdent(elemKey, nodePos(node))
                        var typeArgs2: Node[]
                        astNodeSeqAppend(typeArgs2, typeArg0)
                        let callName2: str = mangleInstance("__cheng_slice_vec", typeArgs2)

                        let tmpName: str = blockBuilderNextTemp(b, "__slice_seq")
                        let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
                        uirCoreSetLocalType(blockBuilderFuncRef(b), tmpSlot, uirCoreTypeI64())
                        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, "seq")
                        if !uirCoreResultBoolIsOk(allocRes):
                            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
                        funcSetObjTypeKey(blockBuilderFuncRef(b), tmpSlot, baseKey)

                        let baseRes2: Result[UirExprId] = lowerExprValue(b, base0, uirCoreTypeI64())
                        if !IsOk[UirExprId](baseRes2):
                            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](baseRes2))
                        var args2: UirExprId[]
                        builderExprSeqAppend(args2, uirCoreLocal(tmpSlot))
                        builderExprSeqAppend(args2, Value[UirExprId](baseRes2))
                        builderExprSeqAppend(args2, start32)
                        builderExprSeqAppend(args2, stop32)
                        builderExprSeqAppend(args2, exclusive)
                        return Ok[UirExprId](uirCoreCall(callName2, args2))

            # Indexing: currently support fixed-size `array[N, T]` (object value).
            let baseInfoRes: Result[UirCoreIndexBaseInfo] = uirCoreIndexBaseInfoBuild(b, base0)
            if !IsOk[UirCoreIndexBaseInfo](baseInfoRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirCoreIndexBaseInfo](baseInfoRes))
            let baseInfo: UirCoreIndexBaseInfo = Value[UirCoreIndexBaseInfo](baseInfoRes)
            let strKey0: str = uirCoreStripPtrKeyOnce(uirCoreStripRefVarKeyOnce(indexBaseInfoBaseKey(baseInfo)))
            if uirCoreNodeHasStringCtx(strKey0, base0):
                var idx1: Node = kid(node, 1)
                while astNodeIdValid(idx1) && nodeKind(idx1) == astNodeKindPar() && kidCount(idx1) > 0:
                    idx1 = kid(idx1, 0)
                if (idx1 == nil):
                    return Err[UirExprId]("uirCore_builder: string subscript expects index")
                let baseRes: Result[UirExprId] = lowerExprValue(b, base0, uirCoreTypeI64())
                if !IsOk[UirExprId](baseRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](baseRes))
                let idxRes: Result[UirExprId] = lowerExprValue(b, idx1, uirCoreTypeI64())
                if !IsOk[UirExprId](idxRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](idxRes))
                let addr: UirExprId = uirCoreBin(uirCoreBinOpAdd(), Value[UirExprId](baseRes), Value[UirExprId](idxRes))
                return Ok[UirExprId](uirCoreLoad(addr, uirCoreTypeU8()))

            let objName: str = uirCoreStripRefVarKeyOnce(uirCoreFirstNonEmptyStr(indexBaseInfoBaseObj(baseInfo), indexBaseInfoBaseKey(baseInfo)))

            # Indexing for dynamic `seq[T]`: lower to runtime `cheng_seq_get`.
            let seqKey: str = uirCoreStripPtrKeyOnce(uirCoreStripRefVarKeyOnce(indexBaseInfoBaseKey(baseInfo)))
            if uirCoreStrStartsWith(seqKey, "seq_") && blockBuilderModule(b) != nil:
                let elemKey: str = rawmemStrFromOffset(seqKey, 4)
                if len(elemKey) == 0:
                    return Err[UirExprId]("uirCore_builder: seq subscript missing element type")
                let elemIsSemanticStr: bool = isSemanticStrKey(elemKey)
                let elemTypeNode: Node = newIdent(elemKey, nodePos(node))
                let sizeRes: Result[int32] = uirCoreSizeOfTypeNode(blockBuilderModule(b), elemTypeNode)
                if !IsOk[int32](sizeRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[int32](sizeRes))
                let elemSize: int32 = Value[int32](sizeRes)
                let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(blockBuilderModule(b), elemTypeNode)
                let elemKey0: str = uirCoreTypeKeyFromNodeLoose(elemTypeNode)
                let elemIsSemanticStr: bool = isSemanticStrKey(elemKey0)
                let elemObjName0: str = uirCoreSeqElemObjTypeName(blockBuilderModule(b), elemTypeNode, elemKey0, elemIsSemanticStr)

                let baseRes3: Result[UirExprId] = uirCoreIndexBasePtrOrLower(b, baseInfo, base0)
                if !IsOk[UirExprId](baseRes3):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](baseRes3))
                let seqName: str = blockBuilderNextTemp(b, "__seq_base")
                let seqSlot: int32 = localAdd(blockBuilderEnv(b), seqName, uirCoreTypeI64())
                uirCoreSetLocalType(blockBuilderFuncRef(b), seqSlot, uirCoreTypeI64())
                blockBuilderAddStmt(b, uirCoreStmtLet(seqName, seqSlot, Value[UirExprId](baseRes3)))
                let seqPtr: UirExprId = uirCoreLocal(seqSlot)

                var lenOff: int32
                var bufOff: int32 = 8
                if uirCoreHasObjType(blockBuilderModule(b), "seq"):
                    let seqOt: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), "seq")
                    var lenFound: bool
                    var bufFound: bool
                    for fi in 0..<uirCoreFieldsLen(seqOt):
                        let f: UirCoreObjField = uirCoreFieldAt(seqOt, fi)
                        if (uirCoreNameOf(f) == "len"):
                            lenOff = uirCoreOffsetOf(f)
                            lenFound = true
                        elif (uirCoreNameOf(f) == "buffer"):
                            bufOff = uirCoreOffsetOf(f)
                            bufFound = true
                    if !lenFound || !bufFound:
                        return Err[UirExprId]("uirCore_builder: seq layout mismatch")

                let lenAddr: UirExprId = (lenOff == 0) ? seqPtr : uirCoreBin(uirCoreBinOpAdd(), seqPtr, uirCoreConstI64(int64(lenOff)))
                let bufAddr: UirExprId = (bufOff == 0) ? seqPtr : uirCoreBin(uirCoreBinOpAdd(), seqPtr, uirCoreConstI64(int64(bufOff)))
                let lenVal: UirExprId = uirCoreLoad(lenAddr, uirCoreTypeI32())
                let bufVal: UirExprId = uirCoreLoad(bufAddr, uirCoreTypeI64())
                let idxRes3: Result[UirExprId] = lowerExprValue(b, idx0, uirCoreTypeI32())
                if !IsOk[UirExprId](idxRes3):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](idxRes3))
                var elemSize32: UirExprId = uirCoreCast(uirCoreTypeI32(), uirCoreConstI64(int64(elemSize)))
                if elemIsSemanticStr:
                    var elemSizeArgs0: UirExprId[]
                    elemSize32 = uirCoreCall("cheng_seq_string_elem_bytes_compat", elemSizeArgs0)
                var args3: UirExprId[]
                builderExprSeqAppend(args3, bufVal)
                builderExprSeqAppend(args3, lenVal)
                builderExprSeqAppend(args3, Value[UirExprId](idxRes3))
                builderExprSeqAppend(args3, elemSize32)
                let ptrExpr: UirExprId = uirCoreCall("cheng_seq_get", args3)
                if elemIsSemanticStr:
                    return Ok[UirExprId](ptrExpr)
                if (elemKey == "bool"):
                    let loaded: UirExprId = lowerByteLoadNilChecked(b, ptrExpr, uirCoreTypeU8(), wantType)
                    return Ok[UirExprId](loaded)
                if (elemKey == "char"):
                    let raw: UirExprId = uirCoreLoad(ptrExpr, uirCoreTypeI32())
                    let chVal: UirExprId = uirCoreBin(uirCoreBinOpAnd(), raw, uirCoreConstI64(255))
                    if uirCoreTypeKindOf(wantType) == uirCoreTypeKindI32():
                        return Ok[UirExprId](chVal)
                    return Ok[UirExprId](uirCoreCast(wantType, chVal))
                let elemObjName: str = typeNodeObjTypeName(blockBuilderModule(b), elemTypeNode)
                if len(elemObjName) > 0 && typeNodeIsObjValue(blockBuilderModule(b), elemTypeNode):
                    # Object values in MIR are pointers to storage. For `seq[T]` where `T` is an
                    # object value, `cheng_seq_get` already returns the element address.
                    return Ok[UirExprId](ptrExpr)
                let loaded: UirExprId = uirCoreLoad(ptrExpr, elemTy)
                if uirCoreTypeKindOf(wantType) != uirCoreTypeKindOf(elemTy) || uirCoreTypeIsUnsigned(wantType) != uirCoreTypeIsUnsigned(elemTy):
                    return Ok[UirExprId](uirCoreCast(wantType, loaded))
                return Ok[UirExprId](loaded)

            if uirCoreStrStartsWith(objName, "array_") && blockBuilderModule(b) != nil && uirCoreHasObjType(blockBuilderModule(b), objName):
                let basePtrRes: Result[UirExprId] = uirCoreIndexBasePtrOrLower(b, baseInfo, base0)
                if !IsOk[UirExprId](basePtrRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](basePtrRes))
                let idxRes32: Result[UirExprId] = lowerExprValue(b, idx0, uirCoreTypeI32())
                if !IsOk[UirExprId](idxRes32):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](idxRes32))
                let basePtr: UirExprId = Value[UirExprId](basePtrRes)
                let idx32: UirExprId = Value[UirExprId](idxRes32)

                let ot: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), objName)
                if uirCoreFieldsLen(ot) == 0:
                    return Err[UirExprId]("uirCore_builder: array type has no fields")
                let arrLen32: UirExprId = uirCoreCast(uirCoreTypeI32(), uirCoreConstI64(int64(uirCoreFieldsLen(ot))))
                var bcArgs: UirExprId[]
                builderExprSeqAppend(bcArgs, arrLen32)
                builderExprSeqAppend(bcArgs, idx32)
                blockBuilderAddStmt(b, uirCoreStmtExpr(uirCoreCall("cheng_bounds_check", bcArgs)))
                let idx64: UirExprId = uirCoreCast(uirCoreTypeI64(), idx32)
                let f0: UirCoreObjField = uirCoreFieldAt(ot, 0)
                let elemTy: UirCoreType = uirCoreTypeOf(f0)
                let elemSize: int32 = uirCoreTypeSize(elemTy)
                if elemSize <= 0:
                    return Err[UirExprId]("uirCore_builder: array element size unsupported")
                var stride: int64 = int64(alignUpPow2(elemSize, uirCoreTypeAlignPow2(elemTy)))
                if uirCoreFieldsLen(ot) > 1:
                    let f1: UirCoreObjField = uirCoreFieldAt(ot, 1)
                    let d: int32 = uirCoreOffsetOf(f1) - uirCoreOffsetOf(f0)
                    if d > 0:
                        stride = int64(d)
                let off: UirExprId = (stride == 1) ? idx64 : uirCoreBin(uirCoreBinOpMul(), idx64, uirCoreConstI64(stride))
                let addr: UirExprId = uirCoreBin(uirCoreBinOpAdd(), basePtr, off)
                let loaded: UirExprId = uirCoreLoad(addr, elemTy)
                if uirCoreTypeKindOf(wantType) != uirCoreTypeKindOf(elemTy) || uirCoreTypeIsUnsigned(wantType) != uirCoreTypeIsUnsigned(elemTy):
                    return Ok[UirExprId](uirCoreCast(wantType, loaded))
                return Ok[UirExprId](loaded)

            # Fallback: treat `base[idx]` as an operator call `[](base, idx)`.
            let callNode: Node = newNode(astNodeKindCall(), nodePos(node))
            nodeSetTypeCache(callNode, nodeTypeCache(node))
            nodeSetTypeCacheValid(callNode, nodeTypeCacheValid(node))
            addSon(callNode, newIdent("[]", nodePos(node)))
            addSon(callNode, base0)
            addSon(callNode, idx0)
            return lowerExprValue(b, callNode, wantType)
        if kidCount(node) == 1:
            let addrNode: Node = kid(node, 0)
            let ptrKey0: str = exprTypeKeyShallow(b, addrNode)
            let addrRes: Result[UirExprId] = lowerExprValue(b, addrNode, uirCoreTypeI64())
            if ! IsOk[UirExprId](addrRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](addrRes))
            if isBytePtrTypeKey(ptrKey0):
                let byteTy: UirCoreType = byteUirTypeFromPtrTypeKey(ptrKey0)
                let loaded: UirExprId = lowerByteLoadNilChecked(b, Value[UirExprId](addrRes), byteTy, wantType)
                return Ok[UirExprId](loaded)
            if uirCoreStrStartsWith(ptrKey0, "ptr_"):
                let baseKey0: str = rawmemStrFromOffset(ptrKey0, 4)
                let objTypeName0: str = uirCorePtrBaseObjTypeName(blockBuilderModule(b), baseKey0)
                if len(objTypeName0) > 0:
                    let aliasTy0: UirCoreType = uirCoreTryGetTypeAlias(blockBuilderModule(b), objTypeName0)
                    if uirCoreTypeKindOf(aliasTy0) == uirCoreTypeKindVoid():
                        return Ok[UirExprId](Value[UirExprId](addrRes))
            return Ok[UirExprId](uirCoreLoad(Value[UirExprId](addrRes), wantType))
        return Err[UirExprId]("uirCore_builder: subscript is not supported")
    if nodeKind(node) == astNodeKindCurly():
        # Minimal set literal lowering: `set[int32]` as a uint64 bitset.
        # Current implementation supports only constant ordinal elements and constant ranges.
        let mod0: UirCoreModule = blockBuilderModule(b)
        var bits: int64
        for i in 0..<kidCount(node):
            var item: Node = kid(node, i)
            while astNodeIdValid(item) && nodeKind(item) == astNodeKindPar() && kidCount(item) > 0:
                item = kid(item, 0)
            if (item == nil):
                continue
            let fnName: str = uirCoreCurrentFuncName(b)
            let fp: str = uirCoreCurrentFuncOriginFile(b)
            let line: str = intToStr(nodePosLine(item))
            let col: str = intToStr(nodePosCol(item))
            var startVal: int64
            var endVal: int64
            var hasRange: bool
            var exclusive: bool
            if nodeKind(item) == astNodeKindInfix() && kidCount(item) >= 3:
                let opNode: Node = kid(item, 0)
                let op: str = backendOpName(opNode)
                if op == ".." || op == "..<":
                    hasRange = true
                    exclusive = op == "..<"
                    var lhs0: Node = kid(item, 1)
                    var rhs0: Node = kid(item, 2)
                    while astNodeIdValid(lhs0) && nodeKind(lhs0) == astNodeKindPar() && kidCount(lhs0) > 0:
                        lhs0 = kid(lhs0, 0)
                    while astNodeIdValid(rhs0) && nodeKind(rhs0) == astNodeKindPar() && kidCount(rhs0) > 0:
                        rhs0 = kid(rhs0, 0)
                    var okL: bool
                    var okR: bool
                    if astNodeIdValid(lhs0) && nodeKind(lhs0) == astNodeKindIntLit():
                        startVal = nodeIntVal(lhs0)
                        okL = true
                    elif astNodeIdValid(lhs0) && nodeKind(lhs0) == astNodeKindCharLit():
                        if len(nodeStrVal(lhs0)) > 0:
                            startVal = int64(nodeStrVal(lhs0)[0])
                        okL = true
                    elif (lhs0 != nil) && (nodeKind(lhs0) == astNodeKindIdent() || nodeKind(lhs0) == astNodeKindSymbol()):
                        let nm: str = plainName(lhs0)
                        let gi: int32 = moduleGlobalIndex(mod0, nm)
                        if gi >= 0:
                            let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, gi)
                            if uirCoreGlobalHasInit(g):
                                startVal = uirCoreGlobalInitOf(g)
                                okL = true
                    if astNodeIdValid(rhs0) && nodeKind(rhs0) == astNodeKindIntLit():
                        endVal = nodeIntVal(rhs0)
                        okR = true
                    elif astNodeIdValid(rhs0) && nodeKind(rhs0) == astNodeKindCharLit():
                        if len(nodeStrVal(rhs0)) > 0:
                            endVal = int64(nodeStrVal(rhs0)[0])
                        okR = true
                    elif (rhs0 != nil) && (nodeKind(rhs0) == astNodeKindIdent() || nodeKind(rhs0) == astNodeKindSymbol()):
                        let nm2: str = plainName(rhs0)
                        let gi2: int32 = moduleGlobalIndex(mod0, nm2)
                        if gi2 >= 0:
                            let g2: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, gi2)
                            if uirCoreGlobalHasInit(g2):
                                endVal = uirCoreGlobalInitOf(g2)
                                okR = true
                    if !okL || !okR:
                        return Err[UirExprId]("uirCore_builder: set range expects const ordinals")
            if hasRange:
                var v: int64 = startVal
                var stop: int64 = endVal
                if exclusive:
                    stop = stop - 1
                let __for_start_v_1 = v
                for __for_v_1 in __for_start_v_1..stop:
                    v = __for_v_1
                    if v >= 0 && v < 64:
                        bits = bits | (int64(1) << int32(v))
                    v = v + 1
                continue
            var v2: int64
            var okItem: bool
            if nodeKind(item) == astNodeKindIntLit():
                v2 = nodeIntVal(item)
                okItem = true
            elif nodeKind(item) == astNodeKindCharLit():
                if len(nodeStrVal(item)) > 0:
                    v2 = int64(nodeStrVal(item)[0])
                okItem = true
            elif nodeKind(item) == astNodeKindIdent() || nodeKind(item) == astNodeKindSymbol():
                let nm3: str = plainName(item)
                let gi3: int32 = moduleGlobalIndex(mod0, nm3)
                if gi3 >= 0:
                    let g3: UirCoreGlobal = uirCoreModuleGlobalAt(mod0, gi3)
                    if uirCoreGlobalHasInit(g3):
                        v2 = uirCoreGlobalInitOf(g3)
                        okItem = true
            if !okItem:
                return Err[UirExprId]("uirCore_builder: set literal expects const ordinals")
            if v2 >= 0 && v2 < 64:
                bits = bits | (int64(1) << int32(v2))
        return Ok[UirExprId](uirCoreConstI64(bits))
    if nodeKind(node) == astNodeKindTupleLit():
        var tupleType: Node = astInvalidNodeId()
        if nodeTypeCacheValid(node) && astRefNonNil(nodeTypeCache(node)):
            tupleType = nodeTypeCache(node)
        else:
            # Stage1 may clear typeCache for tuple literals. Infer a best-effort element type list.
            tupleType = uirCoreTupleLitBestEffortType(node)
        let tupleObj: str = typeNodeObjTypeName(blockBuilderModule(b), tupleType)
        if len(tupleObj) == 0 || ! typeNodeIsObjValue(blockBuilderModule(b), tupleType):
            return Err[UirExprId]("uirCore_builder: tuple literal unsupported type")
        let tmpName: str = blockBuilderNextTemp(b, "__tuple")
        let slot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), slot, uirCoreTypeI64())
        let allocRes: Result[bool] = allocObjValueLocal(b, slot, tupleObj)
        if ! uirCoreResultBoolIsOk(allocRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))
        let ot: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), tupleObj)
        for i in 0..<kidCount(node):
            var elemNode: Node = kid(node, i)
            if astNodeIdValid(elemNode) && nodeKind(elemNode) == astNodeKindCallArg() && kidCount(elemNode) > 1:
                elemNode = kid(elemNode, 1)
            let fieldName: str = uirCoreIndexedName("f", i)
            for fi in 0..<uirCoreFieldsLen(ot):
                let f: UirCoreObjField = uirCoreFieldAt(ot, fi)
                if (uirCoreNameOf(f) == fieldName):
                    let valRes: Result[UirExprId] = lowerExprValue(b, elemNode, uirCoreTypeOf(f))
                    if ! IsOk[UirExprId](valRes):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes))
                    let basePtr: UirExprId = uirCoreLocal(slot)
                    var addr: UirExprId = basePtr
                    if uirCoreOffsetOf(f) != 0:
                        addr = uirCoreBin(uirCoreBinOpAdd(), basePtr, uirCoreConstI64(int64(uirCoreOffsetOf(f))))
                    blockBuilderAddStmt(b, uirCoreStmtStore(addr, Value[UirExprId](valRes), uirCoreTypeOf(f)))
                    break
        return Ok[UirExprId](uirCoreLocal(slot))
    if nodeKind(node) == astNodeKindSeqLit():
        let frefSeq: UirCoreFunc = blockBuilderFuncRef(b)
        if (b == nil) || blockBuilderModule(b) == nil || !uirCoreFuncIdValid(frefSeq):
            return Err[UirExprId]("uirCore_builder: seq literal missing builder/module")
        let seqTypeKey0: str = uirCoreNodeTypeKeyOrEmpty(node)
        let count: int32 = kidCount(node)

        let tmpName: str = blockBuilderNextTemp(b, "__seq")
        let slot: int32 = localAdd(blockBuilderEnv(b), tmpName, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), slot, uirCoreTypeI64())
        if len(seqTypeKey0) > 0:
            localSetTypeKey(blockBuilderEnv(b), slot, seqTypeKey0)
        let allocRes: Result[bool] = allocObjValueLocal(b, slot, "seq")
        if ! uirCoreResultBoolIsOk(allocRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes))

        let seqOt: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), "seq")
        var lenOff: int32 = -1
        var capOff: int32 = -1
        var bufOff: int32 = -1
        for fi in 0..<uirCoreFieldsLen(seqOt):
            let f: UirCoreObjField = uirCoreFieldAt(seqOt, fi)
            if (uirCoreNameOf(f) == "len"):
                lenOff = uirCoreOffsetOf(f)
            elif (uirCoreNameOf(f) == "cap"):
                capOff = uirCoreOffsetOf(f)
            elif (uirCoreNameOf(f) == "buffer"):
                bufOff = uirCoreOffsetOf(f)
        if lenOff < 0 || capOff < 0 || bufOff < 0:
            return Err[UirExprId]("uirCore_builder: seq layout mismatch")

        let basePtr: UirExprId = uirCoreLocal(slot)
        let lenAddr: UirExprId = (lenOff == 0) ? basePtr : uirCoreBin(uirCoreBinOpAdd(), basePtr, uirCoreConstI64(int64(lenOff)))
        let capAddr: UirExprId = (capOff == 0) ? basePtr : uirCoreBin(uirCoreBinOpAdd(), basePtr, uirCoreConstI64(int64(capOff)))
        let bufAddr: UirExprId = (bufOff == 0) ? basePtr : uirCoreBin(uirCoreBinOpAdd(), basePtr, uirCoreConstI64(int64(bufOff)))
        blockBuilderAddStmt(b, uirCoreStmtStore(lenAddr, uirCoreConstI64(0), uirCoreTypeI32()))
        blockBuilderAddStmt(b, uirCoreStmtStore(capAddr, uirCoreConstI64(0), uirCoreTypeI32()))
        blockBuilderAddStmt(b, uirCoreStmtStore(bufAddr, uirCoreConstI64(0), uirCoreTypeI64()))

        if count > 0:
            if !nodeTypeCacheValid(node) || astRefIsNil(nodeTypeCache(node)):
                    return Err[UirExprId]("uirCore_builder: seq literal requires type")
            var elemType: Node = astInvalidNodeId()
            let litType: Node = nodeTypeCache(node)
            if astNodeIdValid(litType) && nodeKind(litType) == astNodeKindBracketExpr() && kidCount(litType) > 1:
                let base: Node = kid(litType, 0)
                if (base != nil) && (nodeKind(base) == astNodeKindIdent() || nodeKind(base) == astNodeKindSymbol()):
                    let nm: str = backendStripSpaces(plainName(base))
                    if nm == "seq":
                        elemType = kid(litType, 1)
            if (elemType == nil):
                return Err[UirExprId]("uirCore_builder: seq literal unsupported type")
            let elemKey: str = uirCoreTypeKeyFromNodeLoose(elemType)
            let elemIsSemanticStr: bool = isSemanticStrKey(elemKey)
            let elemObjName: str = uirCoreSeqElemObjTypeName(blockBuilderModule(b), elemType, elemKey, elemIsSemanticStr)
            var elemSize: int32
            var elemUirTy: UirCoreType = uirCoreTypeI64()
            if len(elemObjName) > 0 && uirCoreHasObjType(blockBuilderModule(b), elemObjName):
                let elemOt: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), elemObjName)
                if uirCoreSizeOf(elemOt) <= 0:
                    return Err[UirExprId]("uirCore_builder: seq literal element object size unsupported: " + elemObjName)
                elemSize = uirCoreSizeOf(elemOt)
            else:
                let sizeRes: Result[int32] = uirCoreSizeOfTypeNode(blockBuilderModule(b), elemType)
                if ! IsOk[int32](sizeRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[int32](sizeRes))
                elemSize = Value[int32](sizeRes)
                elemUirTy = uirCoreTypeFromNodeWithModule(blockBuilderModule(b), elemType)
            var elemSize32: UirExprId = uirCoreCast(uirCoreTypeI32(), uirCoreConstI64(int64(elemSize)))
            if elemIsSemanticStr:
                var elemSizeArgs0: UirExprId[]
                elemSize32 = uirCoreCall("cheng_seq_string_elem_bytes_compat", elemSizeArgs0)
            for i in 0..<count:
                var elemNode: Node = kid(node, i)
                if astNodeIdValid(elemNode) && nodeKind(elemNode) == astNodeKindCallArg() && kidCount(elemNode) > 1:
                    elemNode = kid(elemNode, 1)
                var growArgs: UirExprId[]
                builderExprSeqAppend(growArgs, basePtr)
                builderExprSeqAppend(growArgs, uirCoreCast(uirCoreTypeI32(), uirCoreConstI64(int64(i))))
                builderExprSeqAppend(growArgs, elemSize32)
                let addr: UirExprId = uirCoreCall("cheng_seq_set_grow", growArgs)
                if len(elemObjName) > 0:
                    if elemIsSemanticStr:
                        let valResObj: Result[UirExprId] = uirCoreLowerExprValueWithTypeKeyHint(b, elemNode, uirCoreTypeI64(), elemKey)
                        if ! IsOk[UirExprId](valResObj):
                            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valResObj))
                        let copyRes: Result[bool] = emitObjCopyPtrs(b, addr, elemObjName, Value[UirExprId](valResObj))
                        if ! uirCoreResultBoolIsOk(copyRes):
                            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes))
                    else:
                        let valResObj: Result[UirExprId] = lowerExprValue(b, elemNode, uirCoreTypeI64())
                        if ! IsOk[UirExprId](valResObj):
                            return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valResObj))
                        let copyRes: Result[bool] = emitObjCopyPtrs(b, addr, elemObjName, Value[UirExprId](valResObj))
                        if ! uirCoreResultBoolIsOk(copyRes):
                            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes))
                else:
                    let valRes: Result[UirExprId] = lowerExprValue(b, elemNode, elemUirTy)
                    if ! IsOk[UirExprId](valRes):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes))
                    blockBuilderAddStmt(b, uirCoreStmtStore(addr, Value[UirExprId](valRes), elemUirTy))

        return Ok[UirExprId](uirCoreLocal(slot))
    if nodeKind(node) == astNodeKindComprehension():
        let frefComp: UirCoreFunc = blockBuilderFuncRef(b)
        if (b == nil) || blockBuilderModule(b) == nil || !uirCoreFuncIdValid(frefComp):
            return Err[UirExprId]("uirCore_builder: comprehension missing builder/module")
        let seqTypeKey0: str = uirCoreNodeTypeKeyOrEmpty(node)
        if len(seqTypeKey0) == 0 || !uirCoreStrStartsWith(seqTypeKey0, "seq_"):
            return Err[UirExprId]("uirCore_builder: comprehension requires seq type")
        let tmpName0: str = blockBuilderNextTemp(b, "__seq_comp")
        let slot0: int32 = localAdd(blockBuilderEnv(b), tmpName0, uirCoreTypeI64())
        uirCoreSetLocalType(blockBuilderFuncRef(b), slot0, uirCoreTypeI64())
        localSetTypeKey(blockBuilderEnv(b), slot0, seqTypeKey0)
        let allocRes0: Result[bool] = allocObjValueLocal(b, slot0, "seq")
        if !uirCoreResultBoolIsOk(allocRes0):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(allocRes0))
        let compRes0: Result[bool] = emitSeqComprehensionToPtr(b, tmpName0, uirCoreLocal(slot0), seqTypeKey0, node)
        if !uirCoreResultBoolIsOk(compRes0):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(compRes0))
        return Ok[UirExprId](uirCoreLocal(slot0))
    if isControlExprId(node):
        let tmpName: str = blockBuilderNextTemp(b, "__tmp")
        let tmpSlot: int32 = localAdd(blockBuilderEnv(b), tmpName, wantType)
        uirCoreSetLocalType(blockBuilderFuncRef(b), tmpSlot, wantType)
        let assignRes: Result[bool] = lowerAssignValue(b, node, tmpName, tmpSlot)
        if ! uirCoreResultBoolIsOk(assignRes):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(assignRes))
        return Ok[UirExprId](uirCoreLocal(tmpSlot))
    if nodeKind(node) == astNodeKindIntLit():
        return Ok[UirExprId](uirCoreConstI64(nodeIntVal(node)))
    if nodeKind(node) == astNodeKindBoolLit():
        let name: str = backendStripSpaces(nodeIdent(node))
        if name == "true":
            return Ok[UirExprId](uirCoreConstI64(1))
        return Ok[UirExprId](uirCoreConstI64(0))
    if nodeKind(node) == astNodeKindCharLit():
        if len(nodeStrVal(node)) > 0:
            let c: char = nodeStrVal(node)[0]
            return Ok[UirExprId](uirCoreConstI64(int64(c)))
        return Ok[UirExprId](uirCoreConstI64(0))
    if nodeKind(node) == astNodeKindNilLit():
        return Ok[UirExprId](uirCoreConstI64(0))
    if nodeKind(node) == astNodeKindIdent() || nodeKind(node) == astNodeKindSymbol():
        let nm: str = plainName(node)
        let idx: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        uirCoreMarkImplicitResultUse(b, nm, idx)
        if idx >= 0:
            let key0: str = localTypeKey(blockBuilderEnv(b), idx)
            if len(key0) > 0 && blockBuilderModule(b) != nil:
                let baseKey0: str = uirCoreParamVarBaseKey(key0)
                let canon: str = uirCoreObjAliasCanon(baseKey0)
                let baseKey: str = (len(canon) > 0) ? canon : baseKey0
                if len(baseKey) > 0:
                    var wantLoad: bool = true
                    if uirCoreHasObjType(blockBuilderModule(b), baseKey):
                        # Object values are represented as pointers to storage; `var Obj` passes the
                        # pointer itself (no extra indirection). Ref-like aliases still use an
                        # extra indirection and must be loaded.
                        let aliasTy0: UirCoreType = uirCoreTryGetTypeAlias(blockBuilderModule(b), baseKey)
                        wantLoad = uirCoreTypeKindOf(aliasTy0) != uirCoreTypeKindVoid()
                    elif ((baseKey == "seq") || uirCoreStrStartsWith(baseKey, "seq_") || uirCoreStrStartsWith(baseKey, "seq_fixed_")) &&
                         uirCoreHasObjType(blockBuilderModule(b), "seq"):
                        wantLoad = false
                    elif ((baseKey == "Table") || uirCoreStrStartsWith(baseKey, "Table_")) && uirCoreHasObjType(blockBuilderModule(b), "Table"):
                        wantLoad = false
                    if wantLoad:
                        let baseTy: UirCoreType = uirCoreTypeFromTypeKeyName(baseKey)
                        let loaded: UirExprId = uirCoreLoad(uirCoreLocal(idx), baseTy)
                        if uirCoreTypeKindOf(wantType) != uirCoreTypeKindOf(baseTy) || uirCoreTypeIsUnsigned(wantType) != uirCoreTypeIsUnsigned(baseTy):
                            return Ok[UirExprId](uirCoreCast(wantType, loaded))
                        return Ok[UirExprId](loaded)
            if uirCoreTypeKindOf(wantType) != uirCoreTypeKindI64():
                let olIdx: int32 = funcFindObjLocal(blockBuilderFuncRef(b), idx)
                if olIdx >= 0:
                    let fref: UirCoreFunc = blockBuilderFuncRef(b)
                    let ol: UirCoreObjLocal = uirCoreFuncObjLocalAt(fref, olIdx)
                    if uirCoreFrameOffOf(ol) >= 0:
                        let wantNm: str = uirCoreTypeKindName(wantType)
                        let line: str = intToStr(nodePosLine(node))
                        let col: str = intToStr(nodePosCol(node))
                        let fp: str = uirCoreFuncOriginFileOf(fref)
                        return Err[UirExprId]("uirCore_builder: object value must use field access: " + nm +
                                               " (obj=" + dotAccessObjTypeName(ol) + " want=" + wantNm +
                                               " fn=" + uirCoreFuncNameOf(fref) + " " + fp + ":" + line + ":" + col + ")")
            return Ok[UirExprId](uirCoreLocal(idx))
        let mod: UirCoreModule = blockBuilderModule(b)
        var gi: int32 = moduleGlobalIndex(mod, nm)
        if gi < 0 && uirCoreFuncIdValid(blockBuilderFuncRef(b)) && uirCoreDupGlobalNamesHas(nm):
            let f2: UirCoreFunc = blockBuilderFuncRef(b)
            let gName: str = uirCoreMaybeMangleDupGlobalName(nm, uirCoreFuncOriginFileOf(f2))
            if len(gName) > 0:
                gi = moduleGlobalIndex(mod, gName)
        if gi < 0 && uirCoreDupGlobalNamesHas(nm):
            let gi2: int32 = moduleFindGlobalIndexByBaseUnique(mod, nm)
            if gi2 >= 0 && gi2 < uirCoreModuleGlobalsLen(mod):
                let g2: UirCoreGlobal = uirCoreModuleGlobalAt(mod, gi2)
                return Ok[UirExprId](uirCoreLoad(uirCoreGlobalAddr(uirCoreNameOf(g2)), uirCoreTypeOf(g2)))
        if gi >= 0:
            let g: UirCoreGlobal = uirCoreModuleGlobalAt(mod, gi)
            return Ok[UirExprId](uirCoreLoad(uirCoreGlobalAddr(uirCoreNameOf(g)), uirCoreTypeOf(g)))
        let fnRefName: str = uirCoreBestEffortDupFnRefName(mod, blockBuilderFuncRef(b), nm)
        if moduleHasFuncByBase(mod, fnRefName):
            let callerFile: str = uirCoreCurrentFuncOriginFile(b)
            let f1: UirCoreFunc = moduleFindFuncByBasePreferOrigin(mod, fnRefName, callerFile)
            if (f1 == nil):
                return Err[UirExprId]("uirCore_builder: ambiguous function reference")
            let sym: str = uirCoreFuncLinkNameOrName(f1)
            return Ok[UirExprId](uirCoreGlobalAddr(sym))
        # Some generic-size paths arrive here after stage1 has already stripped the
        # surrounding `sizeof(...)` shell. Preserve the intended pointer-sized
        # generic/builtin type lowering instead of hard-failing on the bare type token.
        let builtinSize: int32 = uirCoreBuiltinTypeNameSize(nm)
        if builtinSize >= 0:
            let sizeExpr: UirExprId = uirCoreConstI64(int64(builtinSize))
            if uirCoreTypeKindOf(wantType) != uirCoreTypeKindI64() || uirCoreTypeIsUnsigned(wantType):
                return Ok[UirExprId](uirCoreCast(wantType, sizeExpr))
            return Ok[UirExprId](sizeExpr)
        let fnName: str = uirCoreCurrentFuncName(b)
        let fp: str = uirCoreCurrentFuncOriginFile(b)
        if (getEnv("BACKEND_DEBUG_UNKNOWN_NAME") == "1"):
            let wantNm: str = uirCoreTypeKindName(wantType)
            let tcKey: str = uirCoreNodeTypeCacheKeyOrEmpty(node)
            echo("[backend] debugUnknownName: ident='" + nm + "' want=" + wantNm +
                 " typeCacheKey='" + tcKey + "' fn=" + fnName)
        return Err[UirExprId]("uirCore_builder: unknown local/global")
    if nodeKind(node) == astNodeKindCall() && kidCount(node) > 0:
        let calleeNode: Node = kid(node, 0)
        if (calleeNode == nil):
            return Err[UirExprId]("uirCore_builder: call expects callee")
        if kidCount(node) == 2 &&
           (nodeKind(calleeNode) == astNodeKindPtrTy() || nodeKind(calleeNode) == astNodeKindRefTy() || nodeKind(calleeNode) == astNodeKindVarTy() ||
            nodeKind(calleeNode) == astNodeKindFnTy() || nodeKind(calleeNode) == astNodeKindTupleTy() || nodeKind(calleeNode) == astNodeKindSetTy()):
            var argNode0: Node = kid(node, 1)
            if astNodeIdValid(argNode0) && nodeKind(argNode0) == astNodeKindCallArg() && kidCount(argNode0) > 1:
                argNode0 = kid(argNode0, 1)
            let castRes: Result[UirExprId] = lowerExprValue(b, argNode0, uirCoreTypeI64())
            if ! IsOk[UirExprId](castRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](castRes))
            let castType: UirCoreType = uirCoreTypeFromNodeWithModule(blockBuilderModule(b), calleeNode)
            return Ok[UirExprId](uirCoreCast(castType, Value[UirExprId](castRes)))
        if (nodeKind(calleeNode) == astNodeKindIdent() || nodeKind(calleeNode) == astNodeKindSymbol()) && kidCount(node) == 2:
            let name0: str = backendStripSpaces(plainName(calleeNode))
            if name0 == "sizeof":
                var argNode0: Node = kid(node, 1)
                if astNodeIdValid(argNode0) && nodeKind(argNode0) == astNodeKindCallArg() && kidCount(argNode0) > 1:
                    argNode0 = kid(argNode0, 1)
                let szRes: Result[int32] = uirCoreSizeOfExprOrTypeNode(b, argNode0)
                if !IsOk[int32](szRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[int32](szRes))
                return Ok[UirExprId](uirCoreConstI64(int64(Value[int32](szRes))))
            if name0 == "new":
                var argNode0: Node = kid(node, 1)
                if astNodeIdValid(argNode0) && nodeKind(argNode0) == astNodeKindCallArg() && kidCount(argNode0) > 1:
                    argNode0 = kid(argNode0, 1)
                let allocResExpr: Result[UirExprId] = uirCoreNewAllocExprForTypeNode(b, argNode0)
                if !IsOk[UirExprId](allocResExpr):
                    if (argNode0 == nil):
                        return Err[UirExprId]("uirCore_builder: new expects type expr")
                    let k: str = intToStr(int32(nodeKind(argNode0)))
                    let line: str = intToStr(nodePosLine(argNode0))
                    let col: str = intToStr(nodePosCol(argNode0))
                    return Err[UirExprId]("uirCore_builder: new expects type expr (got nk#" + k + " @" + line + ":" + col + ")")
                return allocResExpr
        # Method-call sugar: `obj.method(args)` -> `method(obj, args)` when `method` is not a real field.
        # Avoid treating these as function-pointer field calls (e.g. `times.now().format("unix")`).
        if blockBuilderModule(b) != nil:
            var methodExpr0: UirExprId
            let methodRes0: Result[bool] = uirCoreTryLowerMethodSugarCall(b, node, calleeNode, wantType, methodExpr0)
            if !IsOk[bool](methodRes0):
                return ErrInfo[UirExprId](ErrorInfoOf[bool](methodRes0))
            if Value[bool](methodRes0):
                return Ok[UirExprId](methodExpr0)
        var typeArgs: Node[]
        let resolvedName0: str = uirCoreResolveCalleeNameAndTypeArgs(calleeNode, &typeArgs)
        let typeArgCount0: int32 = uirCoreCalleeTypeArgCount(calleeNode)
        let singleTypeArg0: Node = uirCoreCalleeSingleTypeArg(calleeNode)
        if len(resolvedName0) == 0:
            if nodeKind(calleeNode) != astNodeKindIdent() && nodeKind(calleeNode) != astNodeKindSymbol():
                return Err[UirExprId]("uirCore_builder: call expects identifier callee")
        let baseName0: str = (len(resolvedName0) > 0) ? resolvedName0 : backendStripSpaces(plainName(calleeNode))
        let name: str = uirCoreResolvedLocalCallTargetOrBase(blockBuilderEnv(b), baseName0)
        if name == "elemSize" && astNodeIdValid(singleTypeArg0) && uirCoreCallNodeEffectiveArgCount(node) == 0:
            let szRes0: Result[int32] = uirCoreSizeOfTypeNode(blockBuilderModule(b), singleTypeArg0)
            if !IsOk[int32](szRes0):
                return ErrInfo[UirExprId](ErrorInfoOf[int32](szRes0))
            let sizeExpr0: UirExprId = uirCoreConstI64(int64(Value[int32](szRes0)))
            if uirCoreTypeKindOf(wantType) != uirCoreTypeKindI64():
                return Ok[UirExprId](uirCoreCast(wantType, sizeExpr0))
            return Ok[UirExprId](sizeExpr0)
        # Intrinsics: lower common runtime helpers as pure MIR operations to avoid call overhead.
        if name == "ptr_add":
            if kidCount(node) != 3:
                return Err[UirExprId]("uirCore_builder: ptr_add expects two arguments")
            var baseNode: Node = kid(node, 1)
            if astNodeIdValid(baseNode) && nodeKind(baseNode) == astNodeKindCallArg():
                if kidCount(baseNode) > 1:
                    baseNode = kid(baseNode, 1)
                elif kidCount(baseNode) > 0:
                    baseNode = kid(baseNode, 0)
            var offNode: Node = kid(node, 2)
            if astNodeIdValid(offNode) && nodeKind(offNode) == astNodeKindCallArg():
                if kidCount(offNode) > 1:
                    offNode = kid(offNode, 1)
                elif kidCount(offNode) > 0:
                    offNode = kid(offNode, 0)
            if (baseNode == nil) || (offNode == nil):
                return Err[UirExprId]("uirCore_builder: ptr_add expects non-nil arguments")
            let baseRes: Result[UirExprId] = lowerExprValue(b, baseNode, uirCoreTypeI64())
            if !IsOk[UirExprId](baseRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](baseRes))
            let offRes: Result[UirExprId] = lowerExprValue(b, offNode, uirCoreTypeI32())
            if !IsOk[UirExprId](offRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](offRes))
            let off64: UirExprId = uirCoreCast(uirCoreTypeI64(), Value[UirExprId](offRes))
            let sum: UirExprId = uirCoreBin(uirCoreBinOpAdd(), Value[UirExprId](baseRes), off64)
            if uirCoreTypeKindOf(wantType) != uirCoreTypeKindI64():
                return Ok[UirExprId](uirCoreCast(wantType, sum))
            return Ok[UirExprId](sum)
        if name == "xor_0" || name == "bitand_0" || name == "bitor_0" ||
           name == "shl_0" || name == "shr_0" || name == "mul_0" ||
           name == "div_0" || name == "mod_0":
            if kidCount(node) != 3:
                return Err[UirExprId]("uirCore_builder: numeric intrinsic expects two arguments")
            var lhsNode: Node = kid(node, 1)
            if astNodeIdValid(lhsNode) && nodeKind(lhsNode) == astNodeKindCallArg():
                if kidCount(lhsNode) > 1:
                    lhsNode = kid(lhsNode, 1)
                elif kidCount(lhsNode) > 0:
                    lhsNode = kid(lhsNode, 0)
            var rhsNode: Node = kid(node, 2)
            if astNodeIdValid(rhsNode) && nodeKind(rhsNode) == astNodeKindCallArg():
                if kidCount(rhsNode) > 1:
                    rhsNode = kid(rhsNode, 1)
                elif kidCount(rhsNode) > 0:
                    rhsNode = kid(rhsNode, 0)
            if (lhsNode == nil) || (rhsNode == nil):
                return Err[UirExprId]("uirCore_builder: numeric intrinsic expects non-nil arguments")
            let lhsRes: Result[UirExprId] = lowerExprValue(b, lhsNode, uirCoreTypeI32())
            if !IsOk[UirExprId](lhsRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](lhsRes))
            let rhsRes: Result[UirExprId] = lowerExprValue(b, rhsNode, uirCoreTypeI32())
            if !IsOk[UirExprId](rhsRes):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](rhsRes))
            var op: UirCoreBinOp = uirCoreBinOpAdd()
            if name == "xor_0":
                op = uirCoreBinOpXor()
            elif name == "bitand_0":
                op = uirCoreBinOpAnd()
            elif name == "bitor_0":
                op = uirCoreBinOpOr()
            elif name == "shl_0":
                op = uirCoreBinOpShl()
            elif name == "shr_0":
                op = uirCoreBinOpShr()
            elif name == "mul_0":
                op = uirCoreBinOpMul()
            elif name == "div_0":
                op = uirCoreBinOpSdiv()
            elif name == "mod_0":
                op = uirCoreBinOpSmod()
            let out0: UirExprId = uirCoreBin(op, Value[UirExprId](lhsRes), Value[UirExprId](rhsRes))
            if uirCoreTypeKindOf(wantType) != uirCoreTypeKindI32():
                return Ok[UirExprId](uirCoreCast(wantType, out0))
            return Ok[UirExprId](out0)
        var seqArgNode0: Node = astInvalidNodeId()
        if (name == "add" || name == "seqAdd") && kidCount(node) == 3:
            seqArgNode0 = kid(node, 1)
            if astNodeIdValid(seqArgNode0) && nodeKind(seqArgNode0) == astNodeKindCallArg() && kidCount(seqArgNode0) > 1:
                seqArgNode0 = kid(seqArgNode0, 1)
        let seqAddIntrinsicEnabled: bool =
            ((getEnv("BACKEND_SEQ_ADD_INTRINSIC")) == "1") ||
            (astNodeIdValid(seqArgNode0) && len(uirCoreSeqLikeKeyFromExpr(b, seqArgNode0)) > 0)
        if seqAddIntrinsicEnabled && (name == "add" || name == "seqAdd") && kidCount(node) == 3:
            # Backend intrinsic: append to seq without relying on monomorphized stdlib helpers.
            # `seqAdd` is a legacy alias used by older std/web call sites.
            if (b == nil) || blockBuilderModule(b) == nil || !uirCoreHasObjType(blockBuilderModule(b), "seq"):
                return Err[UirExprId]("uirCore_builder: seq intrinsic missing layout")
            var valArgNode0: Node = kid(node, 2)
            if astNodeIdValid(valArgNode0) && nodeKind(valArgNode0) == astNodeKindCallArg() && kidCount(valArgNode0) > 1:
                valArgNode0 = kid(valArgNode0, 1)
            if (seqArgNode0 == nil) || (valArgNode0 == nil):
                return Err[UirExprId]("uirCore_builder: seq intrinsic expects non-nil arguments")
            var elemTypeNode: Node = astInvalidNodeId()
            if typeArgCount0 == 1:
                elemTypeNode = singleTypeArg0
            elif typeArgCount0 > 1:
                return Err[UirExprId]("uirCore_builder: seq intrinsic expects at most one type argument")
            if !astNodeIdValid(elemTypeNode) || nodeKind(elemTypeNode) == astNodeKindEmpty():
                let seqKey0: str = uirCoreSeqElemKeyFromSeqLikeKey(uirCoreSeqLikeKeyFromExpr(b, seqArgNode0))
                if len(seqKey0) > 0:
                    elemTypeNode = newIdent(seqKey0, nodePos(node))
            if (!astNodeIdValid(elemTypeNode) || nodeKind(elemTypeNode) == astNodeKindEmpty()):
                let valKey0: str = uirCoreSeqInferElemTypeKeyFromValue(b, valArgNode0)
                if len(valKey0) > 0:
                    elemTypeNode = newIdent(valKey0, nodePos(node))
            if astNodeIdValid(elemTypeNode) && nodeKind(elemTypeNode) != astNodeKindEmpty():
                let sizeRes: Result[int32] = uirCoreSizeOfTypeNode(blockBuilderModule(b), elemTypeNode)
                if !IsOk[int32](sizeRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[int32](sizeRes))
                let elemSize: int32 = Value[int32](sizeRes)
                if elemSize <= 0:
                    return Err[UirExprId]("uirCore_builder: seq intrinsic element size unsupported")
                let elemTy: UirCoreType = uirCoreTypeFromNodeWithModule(blockBuilderModule(b), elemTypeNode)
                let elemKey: str = uirCoreTypeKeyFromNodeLoose(elemTypeNode)
                let elemIsSemanticStr: bool = isSemanticStrKey(elemKey)
                let elemObjName0: str = uirCoreSeqElemObjTypeName(blockBuilderModule(b), elemTypeNode, elemKey, elemIsSemanticStr)

                let seqPtrRes0: Result[UirExprId] = lowerExprValue(b, seqArgNode0, uirCoreTypeI64())
                if !IsOk[UirExprId](seqPtrRes0):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](seqPtrRes0))
