        return intToStr(int32(nodeKind(n)))
    return "0"

fn uirCoreOptionCtorSuffix(b: BlockBuilder, callNode: Node, helperCallNameL: str,
                           optionCtorKindL: int32): str =
    if optionCtorKindL <= 0:
        return ""
    if kidCount(callNode) == 2 && uirCoreStrStartsWith(helperCallNameL, "Some_"):
        return rawmemStrFromOffset(helperCallNameL, 5)
    if kidCount(callNode) == 1 && uirCoreStrStartsWith(helperCallNameL, "None_"):
        return rawmemStrFromOffset(helperCallNameL, 5)
    return uirCoreInferCtorSuffixFromTypeCache(b, callNode, "Option_")

fn uirCoreResultObjNameFromSuffix(resultSuffix0: str): str =
    if len(resultSuffix0) == 0:
        return ""
    return "Result_" + resultSuffix0

fn uirCoreOptionObjNameFromSuffix(optionSuffix0: str): str =
    if len(optionSuffix0) == 0:
        return ""
    return "Option_" + optionSuffix0

fn uirCoreResultValueKeyFromBaseKey(baseKey: str): str =
    if uirCoreStrStartsWith(baseKey, "Result_"):
        return rawmemStrFromOffset(baseKey, 7)
    return ""

fn uirCoreResolvedTableInitFuncName(module: UirCoreModule): str =
    if module == nil:
        return "__cheng_tables_initSlots"
    let initFn: UirCoreFunc = moduleFindFuncByBaseUnique(module, "__cheng_tables_initSlots")
    if initFn != nil:
        return uirCoreFuncNameOf(initFn)
    return "__cheng_tables_initSlots"

fn uirCoreInExprCallRhsKey(b: BlockBuilder, rhsNode: Node): str =
    if b == nil || blockBuilderModule(b) == nil || !astNodeIdValid(rhsNode) || nodeKind(rhsNode) != astNodeKindCall() || kidCount(rhsNode) <= 0:
        return ""
    let calleeNode: Node = kid(rhsNode, 0)
    var typeArgs: Node[]
    let name: str = uirCoreResolveCalleeNameAndTypeArgs(calleeNode, &typeArgs)
    if name == "elemSize" && typeArgs.len == 1 && uirCoreCallNodeEffectiveArgCount(rhsNode) == 0:
        return "int32"
    let callName: str = uirCoreCallNameWithTypeArgs(name, typeArgs)
    var argNodes: Node[]
    for ai in 1..<kidCount(rhsNode):
        var argNode: Node = kid(rhsNode, ai)
        if astNodeIdValid(argNode) && nodeKind(argNode) == astNodeKindCallArg() && kidCount(argNode) > 1:
            argNode = kid(argNode, 1)
        astNodeSeqAppend(argNodes, argNode)
    let callee0: UirCoreFunc = uirCoreResolveCalleeFuncBestEffortByNode(b, rhsNode, callName, argNodes, "")
    if callee0 != nil:
        if uirCoreFuncParamsLen(callee0) > 0:
            let p0: UirCoreParam = uirCoreFuncParamAt(callee0, 0)
            if uirCoreNameOf(p0) == "__ret":
                let retKey0: str = funcObjTypeKey(callee0, uirCoreSlotOf(p0))
                if len(retKey0) > 0:
                    return retKey0
        let retKey1: str = uirCoreFuncRetTypeKeyOf(callee0)
        if len(retKey1) > 0:
            return retKey1
    return ""

fn uirCoreInExprRhsKey(b: BlockBuilder, rhsNode: Node): str =
    if b == nil || rhsNode == nil:
        return ""
    if nodeTypeCacheValid(rhsNode) && astRefNonNil(nodeTypeCache(rhsNode)):
        let cachedKey: str = typeKey(nodeTypeCache(rhsNode))
        if len(cachedKey) > 0:
            return cachedKey
    if nodeKind(rhsNode) == astNodeKindIdent() || nodeKind(rhsNode) == astNodeKindSymbol():
        let nm: str = plainName(rhsNode)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        if slot0 >= 0 && funcFindObjLocal(blockBuilderFuncRef(b), slot0) >= 0:
            let objKey0: str = funcObjTypeKey(blockBuilderFuncRef(b), slot0)
            if len(objKey0) > 0:
                return objKey0
        if slot0 >= 0:
            let localKey0: str = localTypeKey(blockBuilderEnv(b), slot0)
            if len(localKey0) > 0:
                return localKey0
    return uirCoreInExprCallRhsKey(b, rhsNode)

fn uirCoreNodeKindOrNil(n: Node): str =
    if n != nil:
        return intToStr(int32(nodeKind(n)))
    return "nil"

fn uirCoreNodeTypeCacheKeyOrEmpty(n: Node): str =
    if nodeTypeCacheValid(n) && astRefNonNil(nodeTypeCache(n)):
        return typeKey(nodeTypeCache(n))
    return ""

fn uirCoreMaybeCaseInferExprTypeKey(b: BlockBuilder, n: Node): str =
    if b != nil && n != nil:
        return caseInferExprTypeKey(b, n)
    return ""

fn uirCoreMaybeInferNodeTypeKeyForOverload(b: BlockBuilder, n: Node): str =
    if b != nil && n != nil:
        return uirCoreInferNodeTypeKeyForOverload(b, n)
    return ""

fn uirCoreObjTypeFromKeyOrEmpty(module: UirCoreModule, key0: str): str =
    if module != nil && len(key0) > 0:
        return uirCoreObjTypeFromTypeKey(module, key0)
    return ""

fn uirCoreDerefElemKey(node: Node): str =
    if nodeTypeCacheValid(node) && astRefNonNil(nodeTypeCache(node)):
        let elemKey0: str = backendStripSpaces(typeKey(nodeTypeCache(node)))
        if uirCoreStrStartsWith(elemKey0, "ptr_"):
            return backendStripSpaces(rawmemStrFromOffset(elemKey0, 4))
        return elemKey0
    return ""

fn uirCoreNestedCtorSrcObjName(b: BlockBuilder, fref0: UirCoreFunc, valNode: Node,
                               dstObjName: str): str =
    if astNodeIdValid(valNode) && nodeTypeCacheValid(valNode) && astRefNonNil(nodeTypeCache(valNode)):
        let cachedObj0: str = typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(valNode))
        if len(cachedObj0) > 0:
            return cachedObj0
    if (valNode != nil) && (nodeKind(valNode) == astNodeKindIdent() || nodeKind(valNode) == astNodeKindSymbol()):
        let nm: str = plainName(valNode)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), fref0, nm)
        if slot0 >= 0:
            let localObj0: str = funcObjTypeName(fref0, slot0)
            if len(localObj0) > 0:
                return localObj0
    if (valNode != nil) && (b != nil) && blockBuilderModule(b) != nil:
        let key0: str = caseInferExprTypeKey(b, valNode)
        if len(key0) > 0:
            let obj0: str = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), key0)
            if len(obj0) > 0:
                return obj0
            let tn0: Node = newIdent(key0, nodePos(valNode))
            let nodeObj0: str = typeNodeObjTypeName(blockBuilderModule(b), tn0)
            if len(nodeObj0) > 0:
                return nodeObj0
    if (valNode != nil) && (b != nil) && blockBuilderModule(b) != nil:
        let key1: str = uirCoreInferNodeTypeKeyForOverload(b, valNode)
        let obj1: str = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), key1)
        if len(obj1) > 0:
            return obj1
    if astNodeIdValid(valNode) && nodeKind(valNode) == astNodeKindCall() && kidCount(valNode) > 1 && (b != nil) && blockBuilderModule(b) != nil:
        let valKey0: str = uirCoreInferValueCallInnerKey(b, valNode)
        let obj2: str = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), valKey0)
        if len(obj2) > 0:
            return obj2
    return dstObjName

fn uirCoreBaseExprKeyForSlice(b: BlockBuilder, base0: Node): str =
    if b == nil || base0 == nil:
        return ""
    if astNodeIdValid(base0) && nodeTypeCacheValid(base0) && astRefNonNil(nodeTypeCache(base0)):
        let cachedKey: str = typeKey(nodeTypeCache(base0))
        if len(cachedKey) > 0:
            return cachedKey
    if nodeKind(base0) == astNodeKindIdent() || nodeKind(base0) == astNodeKindSymbol():
        let nm: str = plainName(base0)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        if slot0 >= 0 && funcFindObjLocal(blockBuilderFuncRef(b), slot0) >= 0:
            let objKey0: str = funcObjTypeKey(blockBuilderFuncRef(b), slot0)
            if len(objKey0) > 0:
                return objKey0
        if slot0 >= 0:
            let localKey0: str = localTypeKey(blockBuilderEnv(b), slot0)
            if len(localKey0) > 0:
                return localKey0
    let callKey0: str = uirCoreInExprCallRhsKey(b, base0)
    if len(callKey0) > 0:
        return callKey0
    if uirCoreNodeIsStringLiteral(base0):
        return "str"
    return ""

fn uirCoreIndexBaseInfoBuild(b: BlockBuilder, base0: Node): Result[UirCoreIndexBaseInfo] =
    var info: UirCoreIndexBaseInfo
    indexBaseInfoSetBasePtrOverride(info, uirCoreConstI64(0))
    indexBaseInfoSetHaveBasePtrOverride(info, false)
    if astNodeIdValid(base0) && nodeTypeCacheValid(base0) && astRefNonNil(nodeTypeCache(base0)):
        indexBaseInfoSetBaseKey(info, typeKey(nodeTypeCache(base0)))
        indexBaseInfoSetBaseObj(info, typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(base0)))
    if (base0 != nil) && (nodeKind(base0) == astNodeKindIdent() || nodeKind(base0) == astNodeKindSymbol()):
        let nm: str = plainName(base0)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm)
        if slot0 >= 0 && funcFindObjLocal(blockBuilderFuncRef(b), slot0) >= 0:
            indexBaseInfoSetBaseObj(info, funcObjTypeName(blockBuilderFuncRef(b), slot0))
            indexBaseInfoSetBaseKey(info, funcObjTypeKey(blockBuilderFuncRef(b), slot0))
        elif slot0 >= 0 && len(indexBaseInfoBaseKey(info)) == 0:
            indexBaseInfoSetBaseKey(info, localTypeKey(blockBuilderEnv(b), slot0))
        elif slot0 < 0 && len(indexBaseInfoBaseKey(info)) == 0:
            let gk0: str = uirCoreGlobalTypeKeyByBaseUnique(blockBuilderModule(b), nm)
            if len(gk0) > 0:
                indexBaseInfoSetBaseKey(info, gk0)
            let gObj0: str = uirCoreGlobalObjTypeGet(nm)
            if len(gObj0) > 0:
                indexBaseInfoSetBaseObj(info, gObj0)
                if len(indexBaseInfoBaseKey(info)) == 0:
                    indexBaseInfoSetBaseKey(info, gObj0)
    let seqBaseKey0: str = uirCoreSeqLikeKeyFromExpr(b, base0)
    if len(seqBaseKey0) > 0:
        indexBaseInfoSetBaseKey(info, seqBaseKey0)
        if len(indexBaseInfoBaseObj(info)) == 0 && blockBuilderModule(b) != nil && uirCoreHasObjType(blockBuilderModule(b), "seq"):
            indexBaseInfoSetBaseObj(info, "seq")

    var da: DotAccess
    let dotBaseRes1: Result[bool] = uirCoreTryLowerDotAccess(b, base0, &da)
    if !IsOk[bool](dotBaseRes1):
        return ErrInfo[UirCoreIndexBaseInfo](ErrorInfoOf[bool](dotBaseRes1))
    if Value[bool](dotBaseRes1):
        if uirCoreTypeKindOf(dotAccessFieldTy(da)) == uirCoreTypeKindVoid() && len(dotAccessObjTypeName(da)) > 0:
            indexBaseInfoSetHaveBasePtrOverride(info, true)
            indexBaseInfoSetBasePtrOverride(info, dotAccessAddr(da))
            if len(indexBaseInfoBaseObj(info)) == 0:
                indexBaseInfoSetBaseObj(info, dotAccessObjTypeName(da))
            if len(indexBaseInfoBaseKey(info)) == 0:
                indexBaseInfoSetBaseKey(info, dotAccessObjTypeName(da))
        let inferredKey2: str = caseInferExprTypeKey(b, base0)
        if len(inferredKey2) > 0:
            if uirCoreStrStartsWith(inferredKey2, "seq_") && !uirCoreStrStartsWith(indexBaseInfoBaseKey(info), "seq_"):
                indexBaseInfoSetBaseKey(info, inferredKey2)
            elif uirCoreStrStartsWith(inferredKey2, "seq_fixed_") && !uirCoreStrStartsWith(indexBaseInfoBaseKey(info), "seq_fixed_"):
                indexBaseInfoSetBaseKey(info, inferredKey2)
            elif uirCoreStrStartsWith(inferredKey2, "Table_") && !uirCoreStrStartsWith(indexBaseInfoBaseKey(info), "Table_"):
                indexBaseInfoSetBaseKey(info, inferredKey2)
            elif len(indexBaseInfoBaseKey(info)) == 0:
                indexBaseInfoSetBaseKey(info, inferredKey2)
        let seqBaseKey1: str = uirCoreSeqLikeKeyFromExpr(b, base0)
        if len(seqBaseKey1) > 0:
            indexBaseInfoSetBaseKey(info, seqBaseKey1)
            if len(indexBaseInfoBaseObj(info)) == 0 && blockBuilderModule(b) != nil && uirCoreHasObjType(blockBuilderModule(b), "seq"):
                indexBaseInfoSetBaseObj(info, "seq")
    return Ok[UirCoreIndexBaseInfo](info)

fn uirCoreIndexBasePtrOrLower(b: BlockBuilder, baseInfo: UirCoreIndexBaseInfo, base0: Node): Result[UirExprId] =
    if indexBaseInfoHaveBasePtrOverride(baseInfo):
        return Ok[UirExprId](indexBaseInfoBasePtrOverride(baseInfo))
    return lowerExprValue(b, base0, uirCoreTypeI64())

fn lowerCallWithLeadingArg(b: BlockBuilder, callNode: Node, lead: UirExprId): Result[UirExprId] =
    if (b == nil) || !astNodeIdValid(callNode) || nodeKind(callNode) != astNodeKindCall() || kidCount(callNode) == 0:
        return Err[UirExprId]("uirCore_builder: expected call")
    let calleeNode: Node = kid(callNode, 0)
    if (calleeNode == nil):
        return Err[UirExprId]("uirCore_builder: call expects callee")
    var typeArgs: Node[]
    var name: str = uirCoreResolveCalleeNameAndTypeArgs(calleeNode, &typeArgs)
    if len(name) == 0:
        if nodeKind(calleeNode) != astNodeKindIdent() && nodeKind(calleeNode) != astNodeKindSymbol():
            let fnName: str = uirCoreCurrentFuncName(b)
            let fp: str = uirCoreCurrentFuncOriginFile(b)
            let line: str = intToStr(nodePosLine(callNode))
            let col: str = intToStr(nodePosCol(callNode))
            let k: str = intToStr(int32(nodeKind(calleeNode)))
            return Err[UirExprId]("uirCore_builder: call expects identifier callee (kind=nk#" + k +
                                 " fn=" + fnName + " " + fp + ":" + line + ":" + col + ")")
        name = backendStripSpaces(plainName(calleeNode))
    let localCalleeIdx: int32 = localIndex(blockBuilderEnv(b), name)
    if localCalleeIdx >= 0:
        let target: str = localCallTarget(blockBuilderEnv(b), localCalleeIdx)
        if len(target) > 0:
            name = target

    if name == "Value" && kidCount(callNode) == 2 && blockBuilderModule(b) != nil:
        let srcNode0: Node = uirCoreCallArgNode(callNode, 0)
        if (srcNode0 != nil):
            let srcRes0: Result[UirExprId] = lowerExprValue(b, srcNode0, uirCoreTypeI64())
            if IsOk[UirExprId](srcRes0):
                var srcPtr0: UirExprId = Value[UirExprId](srcRes0)
                let srcKey0: str = uirCoreValueCopySourceKey(b, srcNode0)
                var valueOff0: int32 = -1
                let srcObj0: str = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), srcKey0)
                if len(srcObj0) > 0 && uirCoreHasObjType(blockBuilderModule(b), srcObj0):
                    let srcOt0: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), srcObj0)
                    for sfi in 0..<uirCoreFieldsLen(srcOt0):
                        let sf0: UirCoreObjField = uirCoreFieldAt(srcOt0, sfi)
                        if (uirCoreNameOf(sf0) == "value") || uirCoreStrStartsWith(uirCoreNameOf(sf0), "value."):
                            if valueOff0 < 0 || uirCoreOffsetOf(sf0) < valueOff0:
                                valueOff0 = uirCoreOffsetOf(sf0)
                if valueOff0 < 0 && uirCoreStrStartsWith(srcKey0, "Result_"):
                    valueOff0 = 0
                if valueOff0 > 0:
                    srcPtr0 = uirCoreBin(uirCoreBinOpAdd(), srcPtr0, uirCoreConstI64(int64(valueOff0)))
                let dstObj0: str = uirCoreLeadObjTypeNameDefault(b, callNode, lead)
                if len(dstObj0) > 0:
                    let copyRes0: Result[bool] = emitObjCopyPtrs(b, lead, dstObj0, srcPtr0)
                    if !uirCoreResultBoolIsOk(copyRes0):
                        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes0))
                    if getEnv("BACKEND_DEBUG_VALUE_LOWER") == "1":
                        let fnDbg1: str = uirCoreCurrentFuncName(b)
                        echo("[backend] debugValueLower: fn=" + fnDbg1 + " dstObj=" + dstObj0)
                    return Ok[UirExprId](lead)

    if name == "ErrorInfoOf" && kidCount(callNode) == 2 && blockBuilderModule(b) != nil:
        let srcNode1: Node = uirCoreCallArgNode(callNode, 0)
        if (srcNode1 != nil):
            let srcRes1: Result[UirExprId] = lowerExprValue(b, srcNode1, uirCoreTypeI64())
            if IsOk[UirExprId](srcRes1):
                var srcPtr1: UirExprId = Value[UirExprId](srcRes1)
                let srcKey1: str = uirCoreValueCopySourceKey(b, srcNode1)
                var errOff1: int32 = -1
                let srcObj1: str = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), srcKey1)
                if len(srcObj1) > 0 && uirCoreHasObjType(blockBuilderModule(b), srcObj1):
                    let srcOt1: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), srcObj1)
                    for sfi1 in 0..<uirCoreFieldsLen(srcOt1):
                        let sf1: UirCoreObjField = uirCoreFieldAt(srcOt1, sfi1)
                        if (uirCoreNameOf(sf1) == "err") || uirCoreStrStartsWith(uirCoreNameOf(sf1), "err."):
                            if errOff1 < 0 || uirCoreOffsetOf(sf1) < errOff1:
                                errOff1 = uirCoreOffsetOf(sf1)
                if errOff1 > 0:
                    srcPtr1 = uirCoreBin(uirCoreBinOpAdd(), srcPtr1, uirCoreConstI64(int64(errOff1)))
                let dstObj1: str = uirCoreLeadObjTypeName(b, callNode, lead, "ErrorInfo")
                if len(dstObj1) > 0:
                    let copyRes1: Result[bool] = emitObjCopyPtrs(b, lead, dstObj1, srcPtr1)
                    if !uirCoreResultBoolIsOk(copyRes1):
                        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes1))
                    return Ok[UirExprId](lead)

    let callName: str = uirCoreCallNameWithTypeArgs(name, typeArgs)
    let helperCallNameL: str = uirCoreStripLeadingUnderscores(callName)

    if uirCoreDictHelperClosureEnabled() && blockBuilderModule(b) != nil:
        if kidCount(callNode) == 2:
            let ctorKindL: int32 = uirCoreResultCtorKind(callNode, helperCallNameL)
            let resultSuffixL: str = uirCoreResultCtorSuffix(b, callNode, helperCallNameL, ctorKindL)
            if ctorKindL > 0 && len(resultSuffixL) > 0:
                let resultObjNameL: str = uirCoreConcat2("Result_", resultSuffixL)
                if !uirCoreHasObjType(blockBuilderModule(b), resultObjNameL):
                    let _ensResultL: bool = ensureResultObjType(blockBuilderModule(b), resultObjNameL)
                if uirCoreHasObjType(blockBuilderModule(b), resultObjNameL):
                    var payloadNodeL: Node = kid(callNode, 1)
                    if astNodeIdValid(payloadNodeL) && nodeKind(payloadNodeL) == astNodeKindCallArg():
                        if kidCount(payloadNodeL) > 1:
                            payloadNodeL = kid(payloadNodeL, 1)
                        elif kidCount(payloadNodeL) > 0:
                            payloadNodeL = kid(payloadNodeL, 0)
                    var payloadExprL: Node = payloadNodeL
                    if ctorKindL == 2:
                        var errCtorL: Node = newNode(astNodeKindCall(), nodePos(callNode))
                        addSon(errCtorL, newIdent("ErrorInfo", nodePos(callNode)))
                        var errCodeArgL: Node = newNode(astNodeKindCallArg(), nodePos(callNode))
                        addSon(errCodeArgL, newIdent("code", nodePos(callNode)))
                        addSon(errCodeArgL, newIntLit(0, nodePos(callNode)))
                        addSon(errCtorL, errCodeArgL)
                        var errMsgArgL: Node = newNode(astNodeKindCallArg(), nodePos(callNode))
                        addSon(errMsgArgL, newIdent("msg", nodePos(callNode)))
                        addSon(errMsgArgL, payloadNodeL)
                        addSon(errCtorL, errMsgArgL)
                        payloadExprL = errCtorL

                    var ctorCallL: Node = newNode(astNodeKindCall(), nodePos(callNode))
                    addSon(ctorCallL, newIdent(resultObjNameL, nodePos(callNode)))
                    var okArgL: Node = newNode(astNodeKindCallArg(), nodePos(callNode))
                    addSon(okArgL, newIdent("ok", nodePos(callNode)))
                    if ctorKindL == 1:
                        addSon(okArgL, newBoolLit(true, nodePos(callNode)))
                    else:
                        addSon(okArgL, newBoolLit(false, nodePos(callNode)))
                    addSon(ctorCallL, okArgL)
                    var payloadArgL: Node = newNode(astNodeKindCallArg(), nodePos(callNode))
                    if ctorKindL == 1:
                        addSon(payloadArgL, newIdent("value", nodePos(callNode)))
                    else:
                        addSon(payloadArgL, newIdent("err", nodePos(callNode)))
                    addSon(payloadArgL, payloadExprL)
                    addSon(ctorCallL, payloadArgL)
                    let ctorResL: Result[UirExprId] = lowerObjConstructorCall(b, ctorCallL, resultObjNameL)
                    if !IsOk[UirExprId](ctorResL):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](ctorResL))
                    let copyResL: Result[bool] = emitObjCopyPtrs(b, lead, resultObjNameL, Value[UirExprId](ctorResL))
                    if !uirCoreResultBoolIsOk(copyResL):
                        return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyResL))
                    return Ok[UirExprId](lead)

        let optionCtorKindL: int32 = uirCoreOptionCtorKind(callNode, helperCallNameL)
        let optionSuffixL: str = uirCoreOptionCtorSuffix(b, callNode, helperCallNameL, optionCtorKindL)
        if optionCtorKindL > 0 && len(optionSuffixL) > 0:
            let optionObjNameL: str = uirCoreConcat2("Option_", optionSuffixL)
            if !uirCoreHasObjType(blockBuilderModule(b), optionObjNameL):
                let _ensOptionL: bool = ensureOptionObjType(blockBuilderModule(b), optionObjNameL)
            if uirCoreHasObjType(blockBuilderModule(b), optionObjNameL):
                var ctorCallOptL: Node = newNode(astNodeKindCall(), nodePos(callNode))
                addSon(ctorCallOptL, newIdent(optionObjNameL, nodePos(callNode)))
                var hasArgOptL: Node = newNode(astNodeKindCallArg(), nodePos(callNode))
                addSon(hasArgOptL, newIdent("has", nodePos(callNode)))
                addSon(hasArgOptL, newBoolLit(optionCtorKindL == 1, nodePos(callNode)))
                addSon(ctorCallOptL, hasArgOptL)
                if optionCtorKindL == 1:
                    var payloadNodeOptL: Node = kid(callNode, 1)
                    if astNodeIdValid(payloadNodeOptL) && nodeKind(payloadNodeOptL) == astNodeKindCallArg():
                        if kidCount(payloadNodeOptL) > 1:
                            payloadNodeOptL = kid(payloadNodeOptL, 1)
                        elif kidCount(payloadNodeOptL) > 0:
                            payloadNodeOptL = kid(payloadNodeOptL, 0)
                    var payloadArgOptL: Node = newNode(astNodeKindCallArg(), nodePos(callNode))
                    addSon(payloadArgOptL, newIdent("value", nodePos(callNode)))
                    addSon(payloadArgOptL, payloadNodeOptL)
                    addSon(ctorCallOptL, payloadArgOptL)
                let ctorResOptL: Result[UirExprId] = lowerObjConstructorCall(b, ctorCallOptL, optionObjNameL)
                if !IsOk[UirExprId](ctorResOptL):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](ctorResOptL))
                let copyResOptL: Result[bool] = emitObjCopyPtrs(b, lead, optionObjNameL, Value[UirExprId](ctorResOptL))
                if !uirCoreResultBoolIsOk(copyResOptL):
                    return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyResOptL))
                return Ok[UirExprId](lead)

    if blockBuilderModule(b) != nil && uirCoreHasObjType(blockBuilderModule(b), callName):
        var hasNamedArgs: bool
        let rawArgCount0: int32 = uirCoreCallRawArgCount(callNode)
        for ni in 0..<rawArgCount0:
            let an: Node = uirCoreCallRawArgNode(callNode, ni)
            if astNodeIdValid(an) && nodeKind(an) == astNodeKindCallArg():
                hasNamedArgs = true
                break

        if hasNamedArgs:
            let initRes: Result[bool] = emitObjDefaultInitPtrs(b, lead, callName)
            if !uirCoreResultBoolIsOk(initRes):
                return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes))
            let ot: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), callName)
            for vi in 0..<rawArgCount0:
                let arg0: Node = uirCoreCallRawArgNode(callNode, vi)
                if !astNodeIdValid(arg0) || nodeKind(arg0) != astNodeKindCallArg() || kidCount(arg0) < 2:
                    return Err[UirExprId]("uirCore_builder: object constructor expects named args")
                let keyNode: Node = kid(arg0, 0)
                let valNode: Node = kid(arg0, 1)
                if (keyNode == nil) || (nodeKind(keyNode) != astNodeKindIdent() && nodeKind(keyNode) != astNodeKindSymbol()):
                    return Err[UirExprId]("uirCore_builder: object constructor field expects identifier")
                let fieldName: str = backendStripSpaces(plainName(keyNode))

                let fieldIdx: int32 = uirCoreObjFieldIndexByName(ot, fieldName)
                if fieldIdx >= 0:
                    let field: UirCoreObjField = uirCoreFieldAt(ot, fieldIdx)
                    var addr: UirExprId = lead
                    if uirCoreOffsetOf(field) != 0:
                        addr = uirCoreBin(uirCoreBinOpAdd(), lead, uirCoreConstI64(int64(uirCoreOffsetOf(field))))
                    let valRes: Result[UirExprId] = lowerExprValue(b, valNode, uirCoreTypeOf(field))
                    if !IsOk[UirExprId](valRes):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes))
                    blockBuilderAddStmt(b, uirCoreStmtStore(addr, Value[UirExprId](valRes), uirCoreTypeOf(field)))
                    continue

                let prefix: str = uirCoreAppendChar(fieldName, '.')
                var hasPrefix: bool
                var minOff: int32 = 2147483647
                for fi2 in 0..<uirCoreFieldsLen(ot):
                    let f2: UirCoreObjField = uirCoreFieldAt(ot, fi2)
                    if uirCoreStrStartsWith(uirCoreNameOf(f2), prefix):
                        hasPrefix = true
                        if uirCoreOffsetOf(f2) < minOff:
                            minOff = uirCoreOffsetOf(f2)
                if !hasPrefix:
                    let line: str = intToStr(nodePosLine(keyNode))
                    let col: str = intToStr(nodePosCol(keyNode))
                    return Err[UirExprId]("uirCore_builder: unknown object constructor field: " + fieldName +
                                        " (" + callName + " @" + line + ":" + col + ")")

                var dstAddr: UirExprId = lead
                if minOff != 0:
                    dstAddr = uirCoreBin(uirCoreBinOpAdd(), lead, uirCoreConstI64(int64(minOff)))

                var objNm: str = inferInlineObjFieldTypeName(blockBuilderModule(b), ot, fieldName, minOff)
                if len(objNm) == 0 && astNodeIdValid(valNode) && nodeTypeCacheValid(valNode) && astRefNonNil(nodeTypeCache(valNode)):
                    objNm = typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(valNode))
                if len(objNm) == 0 && (valNode != nil) && (nodeKind(valNode) == astNodeKindIdent() || nodeKind(valNode) == astNodeKindSymbol()):
                    let srcSlot: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), plainName(valNode))
                    if srcSlot >= 0:
                        objNm = funcObjTypeName(blockBuilderFuncRef(b), srcSlot)
                if len(objNm) == 0 && (valNode != nil) && (b != nil) && blockBuilderModule(b) != nil:
                    let key3: str = caseInferExprTypeKey(b, valNode)
                    if len(key3) > 0:
                        let tn3: Node = newIdent(key3, nodePos(valNode))
                        objNm = typeNodeObjTypeName(blockBuilderModule(b), tn3)
                    if (getEnv("BACKEND_DEBUG_NESTED_CTOR") == "1") && (callName == "GossipsubContext") && (fieldName == "params"):
                        let canon3: str = uirCoreObjAliasCanon(key3)
                        echo("[backend] debugNestedCtorLead: ctor=" + callName + " field=" + fieldName +
                             " key3='" + key3 + "' canon='" + canon3 + "' objNm='" + objNm + "'" +
                             " aliasReady=" + (uirCoreObjAliasReadyFlag() ? "1" : "0"))
                if len(objNm) == 0:
                    let line3: str = uirCoreNodePosLineOrZero(valNode)
                    let col3: str = uirCoreNodePosColOrZero(valNode)
                    let k3: str = uirCoreNodeKindOrZero(valNode)
                    let fnName3: str = uirCoreCurrentFuncName(b)
                    let fp3: str = uirCoreCurrentFuncOriginFile(b)
                    return Err[UirExprId]("uirCore_builder: object constructor nested field expects object value" +
                                        " (ctor=" + callName + " field=" + fieldName + " valKind=nk#" + k3 +
                                        " fn=" + fnName3 + " " + fp3 + ":" + line3 + ":" + col3 + ")")

                let srcRes: Result[UirExprId] = lowerExprValue(b, valNode, uirCoreTypeI64())
                if !IsOk[UirExprId](srcRes):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](srcRes))
                let copyRes: Result[bool] = emitObjCopyPtrs(b, dstAddr, objNm, Value[UirExprId](srcRes))
                if !uirCoreResultBoolIsOk(copyRes):
                    return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes))
            return Ok[UirExprId](lead)

        let ot2: UirCoreObjType = uirCoreGetObjType(blockBuilderModule(b), callName)
        let argCount: int32 = rawArgCount0
        if argCount == 0:
            let initRes2: Result[bool] = emitObjDefaultInitPtrs(b, lead, callName)
            if !uirCoreResultBoolIsOk(initRes2):
                return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes2))
            return Ok[UirExprId](lead)
        if argCount == uirCoreFieldsLen(ot2) + 1:
            return lowerObjConstructorCallPositional(b, callNode, callName)
        if argCount > uirCoreFieldsLen(ot2):
            let line0: str = intToStr(nodePosLine(callNode))
            let col0: str = intToStr(nodePosCol(callNode))
            let fnName0: str = uirCoreCurrentFuncName(b)
            let fp0: str = uirCoreCurrentFuncOriginFile(b)
            return Err[UirExprId]("uirCore_builder: object constructor '" + callName + "' expects all fields" +
                                " (argc=" + intToStr(argCount) + " fields=" + intToStr(uirCoreFieldsLen(ot2)) +
                                " fn=" + fnName0 + " " + fp0 + ":" + line0 + ":" + col0 + ")")

        # If the object layout inlines nested object fields (e.g. `value.len/value.cap/value.buffer`),
        # stage1 may still call the constructor positionally using the top-level field list
        # (e.g. `Option[T](has, value)`). Support this by mapping args to top-level fields and
        # copying composite fields as a group.
        var groupNames: str[]
        var groupIsComposite: bool[]
        var groupOffsets: int32[]
        var groupTypeEncodings: int32[]
        var groupObjNames: str[]
        var fiG: int32
        for __for_guard_fiG in 0..<uirCoreFieldsLen(ot2):
            if !(fiG < uirCoreFieldsLen(ot2)):
                break
            let fG: UirCoreObjField = uirCoreFieldAt(ot2, fiG)
            let nmG: str = uirCoreNameOf(fG)
            let dotAt: int32 = uirCoreStrIndexOf(nmG, ".")
            if dotAt > 0:
                let group: str = uirCoreStrTake(nmG, dotAt)
                let prefix: str = uirCoreAppendChar(group, '.')
                var minOff: int32 = 2147483647
                for fjG in fiG..<uirCoreFieldsLen(ot2):
                    let f2G: UirCoreObjField = uirCoreFieldAt(ot2, fjG)
                    if !uirCoreStrStartsWith(uirCoreNameOf(f2G), prefix):
                        break
                    if uirCoreOffsetOf(f2G) < minOff:
                        minOff = uirCoreOffsetOf(f2G)
                if minOff == 2147483647:
                    minOff = uirCoreOffsetOf(fG)
                add(groupNames, group)
                add(groupIsComposite, true)
                add(groupOffsets, minOff)
                add(groupTypeEncodings, uirCoreEncodeType(uirCoreTypeVoid()))
                let objNmG: str = inferInlineObjFieldTypeName(blockBuilderModule(b), ot2, group, minOff)
                add(groupObjNames, objNmG)
                fiG = fjG
                continue
            add(groupNames, nmG)
            add(groupIsComposite, false)
            add(groupOffsets, uirCoreOffsetOf(fG))
            add(groupTypeEncodings, uirCoreEncodeType(uirCoreTypeOf(fG)))
            add(groupObjNames, "")
            fiG = fiG + 1

        let initRes2: Result[bool] = emitObjDefaultInitPtrs(b, lead, callName)
        if !uirCoreResultBoolIsOk(initRes2):
            return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(initRes2))
        if groupNames.len > 0 && groupNames.len < uirCoreFieldsLen(ot2) && argCount <= groupNames.len:
            for gi in 0..<argCount:
                let isComposite: bool = groupIsComposite[gi]
                let off: int32 = groupOffsets[gi]
                var dstAddr: UirExprId = lead
                if off != 0:
                    dstAddr = uirCoreBin(uirCoreBinOpAdd(), lead, uirCoreConstI64(int64(off)))
                let argNode: Node = uirCoreCallArgNode(callNode, gi)
                if !isComposite:
                    let tyG: UirCoreType = uirCoreDecodeType(groupTypeEncodings[gi])
                    let valResG: Result[UirExprId] = lowerExprValue(b, argNode, tyG)
                    if !IsOk[UirExprId](valResG):
                        return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valResG))
                    blockBuilderAddStmt(b, uirCoreStmtStore(dstAddr, Value[UirExprId](valResG), tyG))
                    continue

                var objNm0: str = groupObjNames[gi]
                if len(objNm0) == 0 && astNodeIdValid(argNode) && nodeTypeCacheValid(argNode) && astRefNonNil(nodeTypeCache(argNode)):
                    objNm0 = typeNodeObjTypeName(blockBuilderModule(b), nodeTypeCache(argNode))
                if len(objNm0) == 0 && (argNode != nil) && (nodeKind(argNode) == astNodeKindIdent() || nodeKind(argNode) == astNodeKindSymbol()):
                    let srcSlot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), plainName(argNode))
                    if srcSlot0 >= 0:
                        objNm0 = funcObjTypeName(blockBuilderFuncRef(b), srcSlot0)
                if len(objNm0) == 0 && (argNode != nil) && (b != nil) && blockBuilderModule(b) != nil:
                    let key0: str = caseInferExprTypeKey(b, argNode)
                    if len(key0) > 0:
                        let tn0: Node = newIdent(key0, nodePos(argNode))
                        objNm0 = typeNodeObjTypeName(blockBuilderModule(b), tn0)
                if len(objNm0) == 0:
                    return Err[UirExprId]("uirCore_builder: object constructor nested field expects object value" +
                                        " (ctor=" + callName + " field=" + groupNames[gi] + ")")
                let srcRes0: Result[UirExprId] = lowerExprValue(b, argNode, uirCoreTypeI64())
                if !IsOk[UirExprId](srcRes0):
                    return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](srcRes0))
                let copyRes0: Result[bool] = emitObjCopyPtrs(b, dstAddr, objNm0, Value[UirExprId](srcRes0))
                if !uirCoreResultBoolIsOk(copyRes0):
                    return ErrInfo[UirExprId](uirCoreResultBoolErrorInfo(copyRes0))
            return Ok[UirExprId](lead)

        for fi3 in 0..<argCount:
            let f3: UirCoreObjField = uirCoreFieldAt(ot2, fi3)
            let valNode2: Node = uirCoreCallArgNode(callNode, fi3)
            let valRes2: Result[UirExprId] = lowerExprValue(b, valNode2, uirCoreTypeOf(f3))
            if !IsOk[UirExprId](valRes2):
                return ErrInfo[UirExprId](ErrorInfoOf[UirExprId](valRes2))
            var addr2: UirExprId = lead
            if uirCoreOffsetOf(f3) != 0:
                addr2 = uirCoreBin(uirCoreBinOpAdd(), lead, uirCoreConstI64(int64(uirCoreOffsetOf(f3))))
            blockBuilderAddStmt(b, uirCoreStmtStore(addr2, Value[UirExprId](valRes2), uirCoreTypeOf(f3)))
