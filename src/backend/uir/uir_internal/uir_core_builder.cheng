                    let indRes0: Result[UirExprId] =
                        uirCoreLowerIndirectCall(b, node, calleeNode, argNodes0,
                                                 true, uirCoreLocal(tmpSlot), "debugIndirect(objret)")
                    if !IsOk[UirExprId](indRes0):
