        if blockBuilderModule(b) != nil && name == "Value" && uirCoreCallNodeEffectiveArgCount(node) == 1:
            let baseNode: Node = uirCoreCallArgNode(node, 0)
            if (baseNode != nil):
                let baseKey0: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, baseNode))
                let baseKey: str = uirCoreStripPtrKeyOnce(baseKey0)
                let objName1: str = uirCoreObjTypeFromTypeKey(blockBuilderModule(b), baseKey)
