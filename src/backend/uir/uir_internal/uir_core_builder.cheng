fn uirCoreErrorInfoMessage(info: ErrorInfo, fallbackMsg: str): str =
    if IsError(info):
        return ErrorFormat(info)
    return fallbackMsg

fn uirCoreCopyErrOutStr(errOut: ptr, msg: str) =
    if errOut == nil:
        return
    memCopyCompat(errOut, &msg, int32(sizeof(str)))

fn uirCoreFixupsBuildFuncErrorMessage(nm: str, infoBuild: ErrorInfo): str =
    return "uirCore_builder: fixups build func failed name=" + nm +
           " code=" + intToStr(ErrorCodeOf(infoBuild))

fn uirCoreDuplicateFunctionNameErrorMessage(name: str): str =
    return "uirCore_builder: duplicate function name: " + name

fn uirCoreDebugBool01(v: bool): str =
    if v:
        return "1"
    return "0"

fn uirCoreCStringOrEmpty(raw: cstring): str =
    if raw != nil:
        return str(raw)
    return ""

fn uirCoreTokenTextByIdOrEmpty(textId: int32): str =
    if textId > 0:
        return tokenTextById(textId)
    return ""

fn uirCoreDebugStringLiteralTraceEnabled(): bool =
    return os.GetEnvDefault("BACKEND_DEBUG_STR_LIT_PATH", "") == "1"

fn uirCoreDebugFindFirstStringLiteralId(rootId: AstNodeId): AstNodeId =
    if !astNodeIdValid(rootId):
        return astInvalidNodeId()
    if uirCoreNodeIsStringLiteral(rootId):
        return rootId
    for i in 0..<astKidCount(rootId):
        let foundId: AstNodeId = uirCoreDebugFindFirstStringLiteralId(astKidAt(rootId, i))
        if astNodeIdValid(foundId):
            return foundId
    return astInvalidNodeId()

fn uirCoreDebugCountStringLiteralsId(rootId: AstNodeId): int32 =
    if !astNodeIdValid(rootId):
        return 0
    var total: int32 = uirCoreNodeIsStringLiteral(rootId) ? 1 : 0
    for i in 0..<astKidCount(rootId):
        total = total + uirCoreDebugCountStringLiteralsId(astKidAt(rootId, i))
    return total

fn uirCoreTopLevelItemNameDbg(nId: AstNodeId): str =
    if !astNodeIdValid(nId):
        return ""
    if !astNodeIsFnDecl(nId) && !astNodeIsIteratorDecl(nId) &&
       !astNodeIsTypeDecl(nId) && !astNodeIsConceptDecl(nId) &&
       !astNodeIsTraitDecl(nId):
        return ""
    if astKidCount(nId) <= 0:
        return ""
    let nameNodeId: AstNodeId = astKidAt(nId, 0)
    if !astNodeIdValid(nameNodeId):
        return ""
    if !astNodeIsIdentOrSymbol(nameNodeId):
        return ""
    return backendStripSpaces(astPlainName(nameNodeId))

fn uirCoreDebugDumpStringLiteralStage(tag: str, rootId: AstNodeId) =
    if !uirCoreDebugStringLiteralTraceEnabled():
        return
    let count: int32 = uirCoreDebugCountStringLiteralsId(rootId)
    let firstId: AstNodeId = uirCoreDebugFindFirstStringLiteralId(rootId)
    if !astNodeIdValid(firstId):
        echo("[backend.strlit] " + tag + " count=" + intToStr(count) + " first=<missing>")
        return
    let value: str = astNodeStrVal(firstId)
    echo("[backend.strlit] " + tag +
         " count=" + intToStr(count) +
         " len=" + intToStr(len(value)) +
         " line=" + intToStr(astNodePosLine(firstId)) +
         " col=" + intToStr(astNodePosCol(firstId)) +
         " value='" + value + "'")

fn backendLowerAscii(s: str): str =
    let n: int32 = len(s)
    if n <= 0:
        return ""
    let out: str = newStringAlloc(n)
    for i in 0..<n:
        let ch: char = s[i]
        if ch >= 'A' && ch <= 'Z':
            out[i] = char(int32(ch) + 32)
        else:
            out[i] = ch
    return out

fn backendTrimAsciiSpace(text: str): str =
    let n: int32 = len(text)
    if n <= 0:
        return ""
    var start: int32
    while start < n:
        let ch: char = text[start]
        if ch != ' ' && ch != '\t' && ch != '\n' && ch != '\r':
            break
        start = start + 1
    var stop: int32 = n
    while stop > start:
        let ch2: char = text[stop - 1]
        if ch2 != ' ' && ch2 != '\t' && ch2 != '\n' && ch2 != '\r':
            break
        stop = stop - 1
    return strSubView(text, start, stop - start)

fn uirCoreOkModule(mod: UirCoreModule): Result[UirCoreModule] =
    # Use shared constructor from uir_core_types to avoid stage0-specific
    # return-value instability on large Result payloads.
    return Ok_UirCoreModule(mod)

fn uirCoreResultBoolIsOk(r: Result[bool]): bool =
    return IsOk[bool](r)

fn uirCoreResultBoolValue(r: Result[bool]): bool =
    return Value[bool](r)

fn uirCoreResultBoolErrorInfo(r: Result[bool]): ErrorInfo =
    return ErrorInfoOf[bool](r)

