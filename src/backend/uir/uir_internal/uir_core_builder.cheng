fn uirCoreDebugStringLiteralTraceEnabled(): bool =
    return os.getEnvDefault("BACKEND_DEBUG_STR_LIT_PATH", "") == "1"

fn uirCoreDebugFindFirstStringLiteralId(rootId: AstNodeId): AstNodeId =
    if !astNodeIdValid(rootId):
        return astInvalidNodeId()
    if astNodeKind(rootId) == nkStrLit:
        return rootId
    for i in 0..<astKidCount(rootId):
        let foundId: AstNodeId = uirCoreDebugFindFirstStringLiteralId(astKidAt(rootId, i))
        if astNodeIdValid(foundId):
            return foundId
    return astInvalidNodeId()

fn uirCoreDebugCountStringLiteralsId(rootId: AstNodeId): int32 =
    if !astNodeIdValid(rootId):
        return 0
    var total: int32 = astNodeKind(rootId) == nkStrLit ? 1 : 0
    for i in 0..<astKidCount(rootId):
        total = total + uirCoreDebugCountStringLiteralsId(astKidAt(rootId, i))
    return total

fn uirCoreDebugDumpStringLiteralStage(tag: str, rootId: AstNodeId) =
    if !uirCoreDebugStringLiteralTraceEnabled():
        return
    let count: int32 = uirCoreDebugCountStringLiteralsId(rootId)
    let firstId: AstNodeId = uirCoreDebugFindFirstStringLiteralId(rootId)
    if !astNodeIdValid(firstId):
        echo("[backend.strlit] " + tag + " count=" + intToStr(count) + " first=<missing>")
        return
    let value: str = astNodeStrVal(firstId)
    echo("[backend.strlit] " + tag +
         " count=" + intToStr(count) +
         " len=" + intToStr(len(value)) +
         " line=" + intToStr(astNodePosLine(firstId)) +
         " col=" + intToStr(astNodePosCol(firstId)) +
         " value='" + value + "'")

fn builderFuncSeqAppend(seqInst: var UirCoreFunc[], val: UirCoreFunc) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    seqInst.len = needLen
    seqInst[idx] = val

fn ctxAppendGlobalInitStr(seqInst: str[]*, val: str) =
    if seqInst == nil:
        return
    let idx: int32 = seqInst->len
    let needLen: int32 = idx + 1
    if seqInst->buffer == nil || seqInst->cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

fn ctxAppendGlobalInitType(seqInst: UirCoreType[]*, val: UirCoreType) =
    if seqInst == nil:
        return
    let idx: int32 = seqInst->len
    let needLen: int32 = idx + 1
    if seqInst->buffer == nil || seqInst->cap < needLen:
        cheng__seqGrowToRaw(&seqInst->buffer, &seqInst->cap, needLen, int32(sizeof UirCoreType))
    seqInst->len = needLen
    seqInst[idx] = val

fn ctxAppendGlobalInitNode(seqInst: Node[]*, val: Node) =
    if seqInst == nil:
        return
    let idx: int32 = seqInst->len
    let needLen: int32 = idx + 1
    if seqInst->buffer == nil || seqInst->cap < needLen:
        cheng__seqGrowToRaw(&seqInst->buffer, &seqInst->cap, needLen, int32(sizeof Node))
    seqInst->len = needLen
    seqInst[idx] = val

fn backendLowerAscii(s: str): str =
    return strutils.toLowerAscii(s)

fn uirCoreOkModule(mod: UirCoreModule): Result[UirCoreModule] =
    # Use shared constructor from uir_core_types to avoid stage0-specific
    # return-value instability on large Result payloads.
    return Ok_UirCoreModule(mod)

fn uirCoreResultBoolIsOk(r: Result[bool]): bool =
    return r.ok

fn uirCoreResultBoolValue(r: Result[bool]): bool =
    return r.value

fn uirCoreResultBoolErrorInfo(r: Result[bool]): ErrorInfo =
    return r.err

