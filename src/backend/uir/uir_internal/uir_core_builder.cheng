fn uirCoreDebugRootHasTypeDecl(root: Node, typeName: str): bool =
    if !astNodeIdValid(root) || len(typeName) == 0:
        return false
    for i in 0..<astKidCount(root):
        let nId: AstNodeId = astKidAt(root, i)
        if !astNodeIdValid(nId) || !astNodeIsTypeDecl(nId) || astKidCount(nId) <= 0:
            continue
        let nameId: AstNodeId = astKidAt(nId, 0)
        if astNodeIdValid(nameId) &&
           astNodeIsIdentOrSymbol(nameId) &&
           backendStripSpaces(astPlainName(nameId)) == typeName:
            return true
    return false

type
    UirCoreProfileState = ref
        enabled: bool
        startNs: int64
        lastNs: int64

fn uirCoreProfileInit(): UirCoreProfileState =
    let enabled: bool = envIsTrue("UIR_PROFILE")
    if !enabled:
        return nil
    var p: UirCoreProfileState
    new p
    p.enabled = true
    p.startNs = cheng_monotime_ns()
    p.lastNs = p.startNs
    return p

fn uirCoreProfileStep(p: UirCoreProfileState, name: str) =
    if p == nil || !p.enabled:
        return
    let now: int64 = cheng_monotime_ns()
    let stepMs: int64 = (now - p.lastNs) / 1000000
    let totalMs: int64 = (now - p.startNs) / 1000000
    p.lastNs = now
    # Write directly to stderr to avoid fork-buffer duplication.
    let f: os.File = os.Get_stderr()
    os.Write(f, "uir_profile\t")
    os.Write(f, name)
    os.Write(f, "\tstep_ms=")
    os.Write(f, int64ToStr(stepMs))
    os.Write(f, "\ttotal_ms=")
    os.WriteLine(f, int64ToStr(totalMs))
    os.C_fflush(f)

fn uirCoreFuncNameStableLocal(f: UirCoreFunc): str =
    return uirCoreFuncNameOf(f)

fn uirCoreOwnershipEngineNormalized(): str =
    let raw: str = backendLowerAscii(backendStripSpaces(getEnv("STAGE1_OWNERSHIP_ENGINE")))
    if len(raw) == 0:
        return "scan"
    if raw == "legacy":
        return "legacy"
    if raw == "scan":
        return "scan"
    return "scan"

var uirCore_lowerTopLevelPreparedLastCounted: bool
var uirCore_lowerTopLevelPreparedLastErr: ErrorInfo
var uirCore_lowerTopLevelPreparedLastErrOk: bool

fn uirCoreLowerTopLevelPreparedFail(info: ErrorInfo): bool =
    uirCore_lowerTopLevelPreparedLastCounted = false
    uirCore_lowerTopLevelPreparedLastErr = info
    uirCore_lowerTopLevelPreparedLastErrOk = true
    return false

fn uirCoreLowerTopLevelPreparedDone(counted: bool): bool =
    uirCore_lowerTopLevelPreparedLastCounted = counted
    uirCore_lowerTopLevelPreparedLastErrOk = false
    return true

fn uirCoreLowerTopLevelPrepared(mod: UirCoreModule, ctx: UirCoreBuildCtx,
                                rootIdForDup: AstNodeId,
                                filePath: str,
                                nId: AstNodeId,
                                itemIdx: int32,
                                rootKidCount: int32,
                                nameDbg: str,
                                reachablePtr: HashSetStrPtr,
                                overloadedFnBasesPtr: ptr,
                                fnTaskSnapshot: UirCoreSharedSnapshot,
                                dbgLower: bool,
                                dbgPipeCount: bool): bool =
    uirCore_lowerTopLevelPreparedLastCounted = false
    uirCore_lowerTopLevelPreparedLastErrOk = false
    let kindDbg: int32 = int32(astNodeKind(nId))
    if dbgLower:
        let fDbg: os.File = os.Get_stderr()
        os.Write(fDbg, "uirCore_lower_dbg\t")
        os.Write(fDbg, intToStr(itemIdx + 1))
        os.Write(fDbg, "/")
        os.Write(fDbg, intToStr(rootKidCount))
        os.Write(fDbg, "\tfile=")
        os.Write(fDbg, filePath)
        os.Write(fDbg, "\tkind=nk#")
        os.Write(fDbg, intToStr(kindDbg))
        if len(nameDbg) > 0:
            os.Write(fDbg, "\tname=")
            os.Write(fDbg, nameDbg)
        os.WriteLine(fDbg, "")
        os.C_fflush(fDbg)
    if uirCoreBuildCtxTraceEnabled(ctx):
        var traceLineParts: str[]
        add(traceLineParts, "backend: uir lower ")
        add(traceLineParts, intToStr(itemIdx + 1))
        add(traceLineParts, "/")
        add(traceLineParts, intToStr(rootKidCount))
        add(traceLineParts, " file=")
        add(traceLineParts, filePath)
        if len(nameDbg) > 0:
            add(traceLineParts, " name=")
            add(traceLineParts, nameDbg)
        stage1Trace(fmt(traceLineParts))
    if dbgPipeCount:
        let fDbgPipeLowerItem: os.File = os.Get_stderr()
        os.WriteLine(fDbgPipeLowerItem, "[backend] stage1: lower_item idx=" + intToStr(itemIdx + 1) + "/" + intToStr(rootKidCount) +
                                       " kind=nk#" + intToStr(kindDbg) +
                                       " name=" + nameDbg +
                                       " file=" + filePath)
        os.C_fflush(fDbgPipeLowerItem)
    if astNodeIsFnDecl(nId) || astNodeIsIteratorDecl(nId):
        let taskRes: Result[UirFnTask] = uirCorePrepareTopLevelRoutineTaskFromRootId(
            mod, rootIdForDup, filePath, nId, itemIdx, reachablePtr)
        if !IsOk[UirFnTask](taskRes):
            return uirCoreLowerTopLevelPreparedFail(ErrorInfoOf[UirFnTask](taskRes))
        let task: UirFnTask = Value[UirFnTask](taskRes)
        if task == nil:
            if dbgPipeCount:
                let fDbgPipeFnSkip: os.File = os.Get_stderr()
                os.WriteLine(fDbgPipeFnSkip, "[backend] stage1: lower_item_done=0")
                os.WriteLine(fDbgPipeFnSkip, "[backend] stage1: lower_item_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
                os.WriteLine(fDbgPipeFnSkip, (uirCoreBuildCtxFoundMain(ctx) ? "[backend] stage1: lower_item_found_main=1" : "[backend] stage1: lower_item_found_main=0"))
                os.C_fflush(fDbgPipeFnSkip)
            if uirCoreBuildCtxTraceEnabled(ctx):
                var doneLineSkipParts: str[]
                add(doneLineSkipParts, "backend: uir lower done ")
                add(doneLineSkipParts, intToStr(itemIdx + 1))
                add(doneLineSkipParts, "/")
                add(doneLineSkipParts, intToStr(rootKidCount))
                add(doneLineSkipParts, " file=")
                add(doneLineSkipParts, filePath)
                if len(nameDbg) > 0:
                    add(doneLineSkipParts, " name=")
                    add(doneLineSkipParts, nameDbg)
                stage1Trace(fmt(doneLineSkipParts))
            if dbgLower:
                let fDbgDoneSkip: os.File = os.Get_stderr()
                os.Write(fDbgDoneSkip, "uirCore_lower_done\t")
                os.Write(fDbgDoneSkip, intToStr(itemIdx + 1))
                os.Write(fDbgDoneSkip, "/")
                os.Write(fDbgDoneSkip, intToStr(rootKidCount))
                os.WriteLine(fDbgDoneSkip, "")
                os.C_fflush(fDbgDoneSkip)
            return uirCoreLowerTopLevelPreparedDone(false)
        let taskIdx: int32 = uirCoreFnTaskTaskOrdinal(task) + 1
        let taskName: str = uirCoreFnTaskRoutineName(task)
        let taskFile: str = uirCoreFnTaskOriginFile(task)
        let taskMergeRes: Result[bool] =
            uirCoreExecuteAndMergeFnTask(mod, ctx, task, overloadedFnBasesPtr, fnTaskSnapshot)
        if !IsOk[bool](taskMergeRes):
            let mergeInfo: ErrorInfo = uirCoreResultBoolErrorInfo(taskMergeRes)
            os.WriteLine(os.Get_stderr(), uirCoreErrorInfoMessage(mergeInfo, "uirCore_builder: fn task failed"))
            os.C_fflush(os.Get_stderr())
            return uirCoreLowerTopLevelPreparedFail(mergeInfo)
        if dbgPipeCount:
            let fDbgPipeFnTaskDone: os.File = os.Get_stderr()
            os.WriteLine(fDbgPipeFnTaskDone, uirCoreResultBoolValue(taskMergeRes) ? "[backend] stage1: lower_item_done=1" : "[backend] stage1: lower_item_done=0")
            os.WriteLine(fDbgPipeFnTaskDone, "[backend] stage1: lower_item_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
            os.WriteLine(fDbgPipeFnTaskDone, (uirCoreBuildCtxFoundMain(ctx) ? "[backend] stage1: lower_item_found_main=1" : "[backend] stage1: lower_item_found_main=0"))
            os.C_fflush(fDbgPipeFnTaskDone)
        if uirCoreBuildCtxTraceEnabled(ctx):
            var doneLineTaskParts: str[]
            add(doneLineTaskParts, "backend: uir lower done ")
            add(doneLineTaskParts, intToStr(taskIdx))
            add(doneLineTaskParts, "/")
            add(doneLineTaskParts, intToStr(rootKidCount))
            add(doneLineTaskParts, " file=")
            add(doneLineTaskParts, taskFile)
            if len(taskName) > 0:
                add(doneLineTaskParts, " name=")
                add(doneLineTaskParts, taskName)
            stage1Trace(fmt(doneLineTaskParts))
        if dbgLower:
            let fDbgDoneTask: os.File = os.Get_stderr()
            os.Write(fDbgDoneTask, "uirCore_lower_done\t")
            os.Write(fDbgDoneTask, intToStr(taskIdx))
            os.Write(fDbgDoneTask, "/")
            os.Write(fDbgDoneTask, intToStr(rootKidCount))
            os.WriteLine(fDbgDoneTask, "")
            os.C_fflush(fDbgDoneTask)
        return uirCoreLowerTopLevelPreparedDone(true)
    let res: Result[bool] = uirCoreConsumeTopLevelFromRootId(mod, ctx, rootIdForDup, filePath, nId, reachablePtr, overloadedFnBasesPtr)
    if ! uirCoreResultBoolIsOk(res):
        os.WriteLine(os.Get_stderr(), "uirCore_builder: lower top-level failed")
        os.C_fflush(os.Get_stderr())
        let fallbackRes0: Result[bool] = Err[bool]("uirCore_builder: lower top-level failed")
        let fallbackInfo0: ErrorInfo = ErrorInfoOf[bool](fallbackRes0)
        return uirCoreLowerTopLevelPreparedFail(fallbackInfo0)
    if dbgPipeCount:
        let fDbgPipeLowerDone: os.File = os.Get_stderr()
        os.WriteLine(fDbgPipeLowerDone, uirCoreResultBoolValue(res) ? "[backend] stage1: lower_item_done=1" : "[backend] stage1: lower_item_done=0")
        os.WriteLine(fDbgPipeLowerDone, "[backend] stage1: lower_item_funcs=" + intToStr(uirCoreModuleFuncsLen(mod)))
        os.WriteLine(fDbgPipeLowerDone, (uirCoreBuildCtxFoundMain(ctx) ? "[backend] stage1: lower_item_found_main=1" : "[backend] stage1: lower_item_found_main=0"))
        os.C_fflush(fDbgPipeLowerDone)
    if uirCoreBuildCtxTraceEnabled(ctx):
        var doneLineParts: str[]
        add(doneLineParts, "backend: uir lower done ")
        add(doneLineParts, intToStr(itemIdx + 1))
        add(doneLineParts, "/")
        add(doneLineParts, intToStr(rootKidCount))
        add(doneLineParts, " file=")
        add(doneLineParts, filePath)
        if len(nameDbg) > 0:
            add(doneLineParts, " name=")
            add(doneLineParts, nameDbg)
        stage1Trace(fmt(doneLineParts))
    if dbgLower:
        let fDbgDone: os.File = os.Get_stderr()
        os.Write(fDbgDone, "uirCore_lower_done\t")
        os.Write(fDbgDone, intToStr(itemIdx + 1))
        os.Write(fDbgDone, "/")
        os.Write(fDbgDone, intToStr(rootKidCount))
        os.WriteLine(fDbgDone, "")
        os.C_fflush(fDbgDone)
    return uirCoreLowerTopLevelPreparedDone(false)

fn uirCoreLowerTopLevelRoot(mod: UirCoreModule, ctx: UirCoreBuildCtx,
                            rootIdForDup: AstNodeId,
                            initialLastFilePath: str,
                            rootKidCount: int32,
                            reachablePtr: HashSetStrPtr,
                            overloadedFnBasesPtr: ptr,
                            fnTaskSnapshot: UirCoreSharedSnapshot,
                            dbgLower: bool,
                            dbgPipeCount: bool): Result[int32] =
    var lastFilePath: str = initialLastFilePath
    var fnTaskCount: int32
    for i in 0..<astKidCount(rootIdForDup):
        let nId: AstNodeId = astKidAt(rootIdForDup, i)
        if !astNodeIdValid(nId):
            continue
        let ownPath2: str = astNodeStrVal(nId)
        if len(ownPath2) > 0:
            lastFilePath = ownPath2
        let filePath: str = (len(ownPath2) > 0) ? ownPath2 : lastFilePath
        let nKind: NodeKind = astNodeKind(nId)
        let nameDbg: str = uirCoreTopLevelItemNameDbg(nId)
        let itemOk: bool = uirCoreLowerTopLevelPrepared(
            mod, ctx, rootIdForDup, filePath, nId, i, rootKidCount, nameDbg,
            reachablePtr, overloadedFnBasesPtr, fnTaskSnapshot, dbgLower, dbgPipeCount)
        if !itemOk:
            if uirCore_lowerTopLevelPreparedLastErrOk:
                return ErrInfo[int32](uirCore_lowerTopLevelPreparedLastErr)
            return Err[int32]("uirCore_builder: lower top-level item failed")
        if uirCore_lowerTopLevelPreparedLastCounted:
            fnTaskCount = fnTaskCount + 1
        if (dbgLower || dbgPipeCount) && (i + 1) == rootKidCount:
            let fDbgPipeLowerLastDone: os.File = os.Get_stderr()
            os.WriteLine(fDbgPipeLowerLastDone, "[backend] stage1: lower_last_item_counted")
            os.C_fflush(fDbgPipeLowerLastDone)
    if dbgLower || dbgPipeCount:
        let fDbgPipeLowerLoopExit: os.File = os.Get_stderr()
        os.WriteLine(fDbgPipeLowerLoopExit, "[backend] stage1: lower_loop_exit")
        os.C_fflush(fDbgPipeLowerLoopExit)
    return Ok[int32](fnTaskCount)

fn uirCoreOwnershipProofNodeWeight(n: Node): int32 =
    if astNodeIsAsgn(n) || astNodeIsFastAsgn(n) || astNodeIsCall(n) ||
       astNodeIsReturn(n) || astNodeIsYield(n) ||
       astNodeIsDerefExpr(n) || astNodeIsHiddenDeref(n) || astNodeIsDotExpr(n) || astNodeIsBracketExpr(n):
        return 2
    if astNodeIsVar(n) || astNodeIsLet(n) || astNodeIsFor(n) || astNodeIsWhile(n) ||
       astNodeIsIf(n) || astNodeIsWhen(n) || astNodeIsCase(n) || astNodeIsStmtList(n) || astNodeIsBlock(n):
        return 1
    return 0

fn uirCoreOwnershipProofCount(n: Node): int32 =
    if (n == nil):
        return 0
    var total: int32 = uirCoreOwnershipProofNodeWeight(n)
    for i in 0..<kidCount(n):
        total = total + uirCoreOwnershipProofCount(kid(n, i))
    return total

fn uirCoreFuncSyntheticByName(funcName: str): bool =
    if len(funcName) == 0:
        return true
    if uirCoreStrStartsWith(funcName, "__cheng_"):
        return true
    if uirCoreStrIndexOf(funcName, "__cheng_mod_") >= 0:
        return true
    if uirCoreStrIndexOf(funcName, uirCoreFuncSigMarker()) >= 0:
        return true
    return false

fn uirCoreFuncOwnershipProofScore(func: UirCoreFunc): int32 =
    if !uirCoreFuncIdValid(func) || uirCoreFuncIsExtern(func):
        return 0
    if uirCoreFuncBlocksLen(func) <= 0:
        return 0
    var score: int32
    for bi in 0..<uirCoreFuncBlocksLen(func):
        let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
        if !uirCoreBlockIdValid(blk):
            continue
        score = score + uirCoreBlockStmtsLen(blk)
        let term0: UirCoreTerm = uirCoreBlockTermOf(blk)
        if uirCoreTermKindOf(term0) == uirCoreTermKindRet() && uirCoreExprIdValid(uirCoreTermRetExprOf(term0)):
            score = score + 1
        elif uirCoreTermKindOf(term0) == uirCoreTermKindCbr() && uirCoreExprIdValid(uirCoreTermCondExprOf(term0)):
            score = score + 1
    return score

fn uirCoreApplyOwnershipPhaseContract(module: UirCoreModule, skipOwnership: bool, borrowIrMode: str) =
    if module == nil:
        return
    for i in 0..<uirCoreModuleFuncsLen(module):
        let f: UirCoreFunc = uirCoreModuleFuncAt(module, i)
        if f == nil || uirCoreFuncIsExtern(f):
            continue
        if skipOwnership:
            if borrowIrMode == "mir":
                uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), false, true, "mir_borrow_skipped")
            else:
                uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), false, true, "ownership_skipped")
            continue
        let proofCount: int32 = uirCoreFuncOwnershipProofScore(f)
        if proofCount > 0 && !uirCoreFuncSyntheticByName(uirCoreFuncNameOf(f)):
            uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), true, true, "")
            continue
        if proofCount == 0:
            uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), false, true, "high_uir_ownership_no_proof")
        else:
            uirCoreFuncSetPhaseContract(f, uirCorePhaseLowTag(), false, true, "high_uir_ownership_synthetic")
    return

fn emitDeferFrame(b: BlockBuilder, frame: DeferFrame): Result[bool] =
    if frame == nil || deferFrameBodiesLen(frame) <= 0:
        return Ok[bool](false)
    let __for_start_bi = deferFrameBodiesLen(frame) - 1
    for __for_rev_bi in 0..(__for_start_bi - (0)):
        let bi = __for_start_bi - __for_rev_bi
        let body: Node = deferFrameBodyAt(frame, bi)
        if !astNodeIdValid(body) || nodeKind(body) != astNodeKindStmtList():
            return Err[bool]("uirCore_builder: invalid defer body")
        let bodyRes: Result[bool] = lowerStmtList(b, body)
        if !uirCoreResultBoolIsOk(bodyRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(bodyRes))
        if uirCoreResultBoolValue(bodyRes):
            return Err[bool]("uirCore_builder: defer body terminated")
    return Ok[bool](false)

fn blockBuilderEmitDefers(b: BlockBuilder, minDepth: int32): Result[bool] =
    if b == nil:
        return Ok[bool](false)
    var md: int32 = minDepth
    if md < 0:
        md = 0
    if md >= blockBuilderDeferStackLen(b):
        return Ok[bool](false)
    let __for_start_i = blockBuilderDeferStackLen(b) - 1
    for __for_rev_i in 0..(__for_start_i - (md)):
        let i = __for_start_i - __for_rev_i
        let emitRes: Result[bool] = emitDeferFrame(b, blockBuilderDeferStackAt(b, i))
        if !uirCoreResultBoolIsOk(emitRes):
            return ErrInfo[bool](uirCoreResultBoolErrorInfo(emitRes))
        if uirCoreResultBoolValue(emitRes):
            return Err[bool]("uirCore_builder: defer body terminated")
    return Ok[bool](false)

fn alignUpPow2(value: int32, alignPow2: int32): int32 =
    if alignPow2 <= 0:
        return value
    let align: int32 = 1 << alignPow2
    let rem: int32 = value % align
    if rem == 0:
        return value
    return value + (align - rem)

fn uirCoreConcat2(left0: str, right0: str): str =
    let nLeft: int32 = len(left0)
    let nRight: int32 = len(right0)
    if nLeft <= 0:
        return right0
    if nRight <= 0:
        return left0
    let out: str = newStringAlloc(nLeft + nRight)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    rawmem_support.RawmemCopy(outPtr, rawmemAsVoid(left0), nLeft)
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(outPtr, nLeft), rawmemAsVoid(right0), nRight)
    return out

fn uirCoreAppendChar(left0: str, ch: char): str =
    let nLeft: int32 = len(left0)
    let out: str = newStringAlloc(nLeft + 1)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    if nLeft > 0:
        rawmem_support.RawmemCopy(outPtr, rawmemAsVoid(left0), nLeft)
    rawmemWriteChar(outPtr, nLeft, ch)
    return out

fn uirCoreIndexedName(prefix0: str, idx: int32): str =
    return uirCoreConcat2(prefix0, intToStr(idx))

fn uirCoreArrayObjName(capacity: int32, elemKey0: str): str =
    return uirCoreJoinWithChar(uirCoreIndexedName("array_", capacity), '_', elemKey0)

fn uirCoreTypeKeyObjNameCachePutMirrors(module: UirCoreModule, rawKey: str,
                                        normalizedKey: str, objName: str) =
    if module == nil:
        return
    if len(rawKey) > 0:
        uirCoreTypeKeyObjNameCachePut(module, rawKey, objName)
    if len(normalizedKey) > 0 && !(normalizedKey == rawKey):
        uirCoreTypeKeyObjNameCachePut(module, normalizedKey, objName)

fn uirCoreTypeNodeObjNameCachePutFast(module: UirCoreModule, typeNode: Node, objName: str) =
    if module == nil || !astNodeIdValid(typeNode):
        return
    if uirCoreTypeNodeObjNameCacheNeedsReset(module):
        uirCoreTypeNodeObjNameCacheReset(module)
    uirCoreTypeNodeObjNameCacheEnsure(typeNode)
    let idx: int32 = int32(typeNode)
    if idx < 0 || idx >= uirCoreTypeNodeObjNameCacheValuesLen() || idx >= uirCoreTypeNodeObjNameCacheReadyLen():
        return
    uirCoreTypeNodeObjNameCacheSetValueAt(idx, objName)
    uirCoreTypeNodeObjNameCacheSetReadyAt(idx, int8(1))

fn uirCoreTypeNodeObjNameCacheTryGetFast(module: UirCoreModule, typeNode: Node,
                                         found: var bool): str =
    found = false
    if module == nil || !astNodeIdValid(typeNode):
        return ""
    if uirCoreTypeNodeObjNameCacheNeedsReset(module):
        uirCoreTypeNodeObjNameCacheReset(module)
    uirCoreTypeNodeObjNameCacheEnsure(typeNode)
    let idx: int32 = int32(typeNode)
    if idx < 0 || idx >= uirCoreTypeNodeObjNameCacheValuesLen() || idx >= uirCoreTypeNodeObjNameCacheReadyLen():
        return ""
    if uirCoreTypeNodeObjNameCacheReadyAt(idx) == int8(0):
        return ""
    found = true
    return uirCoreTypeNodeObjNameCacheValueAt(idx)

fn uirCoreUniqueObjTypeNameByPrefix(module: UirCoreModule, prefix: str): str =
    if module == nil || len(prefix) == 0:
        return ""
    var foundIdx: int32 = -1
    var foundCount: int32
    for oi in 0..<uirCoreModuleObjTypesLen(module):
        let ot: UirCoreObjType = uirCoreModuleObjTypeAt(module, oi)
        if len(uirCoreNameOf(ot)) > 0 && uirCoreStrStartsWith(uirCoreNameOf(ot), prefix):
            foundIdx = oi
            foundCount = foundCount + 1
            if foundCount > 1:
                return ""
    if foundCount != 1 || foundIdx < 0:
        return ""
    return uirCoreNameOf(uirCoreModuleObjTypeAt(module, foundIdx))

fn uirCoreTupleElemFieldLabel(elemNode0: Node): str =
    if !astNodeIdValid(elemNode0) || nodeKind(elemNode0) != astNodeKindIdentDefs() || kidCount(elemNode0) <= 0:
        return ""
    let nameNode0: Node = kid(elemNode0, 0)
    if (nameNode0 != nil) && (nodeKind(nameNode0) == astNodeKindIdent() || nodeKind(nameNode0) == astNodeKindSymbol()):
        return backendStripSpaces(plainName(nameNode0))
    return ""

fn uirCoreTupleElemTypeNode(elemNode0: Node): Node =
    if astNodeIdValid(elemNode0) && nodeKind(elemNode0) == astNodeKindIdentDefs() && kidCount(elemNode0) > 1:
        return kid(elemNode0, 1)
    return elemNode0

fn uirCoreTupleElemTypeKey(elemTypeNode0: Node): str =
    if astNodeIdValid(elemTypeNode0) && nodeKind(elemTypeNode0) == astNodeKindDotExpr() && kidCount(elemTypeNode0) > 1:
        let dotKey: str = typeKey(kid(elemTypeNode0, 1))
        if len(dotKey) > 0:
            return dotKey
    let elemKey: str = typeKey(elemTypeNode0)
    if len(elemKey) > 0:
        return elemKey
    if elemTypeNode0 != nil:
        return backendStripSpaces(plainName(elemTypeNode0))
    return ""

fn uirCoreCallArgValueNode(node0: Node): Node =
    if astNodeIdValid(node0) && nodeKind(node0) == astNodeKindCallArg():
        if kidCount(node0) > 1:
            return kid(node0, 1)
        if kidCount(node0) > 0:
            return kid(node0, kidCount(node0) - 1)
    return node0

fn uirCoreCallRawArgCount(callNode: Node): int32 =
    if !astNodeIdValid(callNode) || nodeKind(callNode) != astNodeKindCall():
        return 0
    return kidCount(callNode) - 1

fn uirCoreCallRawArgNode(callNode: Node, argIdx: int32): Node =
    if !astNodeIdValid(callNode) || nodeKind(callNode) != astNodeKindCall():
        return astInvalidNodeId()
    let kidIdx: int32 = argIdx + 1
    if kidIdx < 1 || kidIdx >= kidCount(callNode):
        return astInvalidNodeId()
    return kid(callNode, kidIdx)

fn uirCoreCallArgNode(callNode: Node, argIdx: int32): Node =
    return uirCoreCallArgValueNode(uirCoreCallRawArgNode(callNode, argIdx))

fn uirCoreCalleeSingleTypeArg(calleeNode: Node): Node =
    if astNodeIdValid(calleeNode) && nodeKind(calleeNode) == astNodeKindBracketExpr() && kidCount(calleeNode) == 2:
        let typeArg0: Node = kid(calleeNode, 1)
        if astNodeIdValid(typeArg0) && nodeKind(typeArg0) != astNodeKindEmpty():
            return typeArg0
    if uirCoreNodeIsFieldDot(calleeNode):
        let member0: Node = uirCoreDotFieldNode(calleeNode)
        if astNodeIdValid(member0) && nodeKind(member0) == astNodeKindBracketExpr() && kidCount(member0) == 2:
            let typeArg1: Node = kid(member0, 1)
            if astNodeIdValid(typeArg1) && nodeKind(typeArg1) != astNodeKindEmpty():
                return typeArg1
    return astInvalidNodeId()

fn uirCoreCalleeTypeArgCount(calleeNode: Node): int32 =
    if astNodeIdValid(calleeNode) && nodeKind(calleeNode) == astNodeKindBracketExpr() && kidCount(calleeNode) > 1:
        return kidCount(calleeNode) - 1
    if uirCoreNodeIsFieldDot(calleeNode):
        let member0: Node = uirCoreDotFieldNode(calleeNode)
        if astNodeIdValid(member0) && nodeKind(member0) == astNodeKindBracketExpr() && kidCount(member0) > 1:
            return kidCount(member0) - 1
    return 0

fn uirCoreNodeTypeKeyOrEmpty(n: Node): str =
    if astNodeIdValid(n) && nodeTypeCacheValid(n) && astRefNonNil(nodeTypeCache(n)):
        let cachedKey: str = backendStripSpaces(typeKey(nodeTypeCache(n)))
        if len(cachedKey) > 0:
            return cachedKey
    if astNodeIdValid(n):
        return backendStripSpaces(typeKey(n))
    return ""

fn uirCoreBestEffortElemTypeKey(node0: Node, defaultKey: str): str =
    let elem0: Node = uirCoreCallArgValueNode(node0)
    let cachedKey: str = uirCoreNodeTypeKeyOrEmpty(elem0)
    if len(cachedKey) > 0:
        return cachedKey
    if uirCoreNodeIsStringLiteral(elem0):
        return "str"
    if astNodeIdValid(elem0) && nodeKind(elem0) == astNodeKindCharLit():
        return "char"
    if astNodeIdValid(elem0) && nodeKind(elem0) == astNodeKindBoolLit():
        return "bool"
    return defaultKey

fn uirCoreSingleNodeSeq(node0: Node): Node[] =
    var out: Node[]
    if astNodeIdValid(node0):
        astNodeSeqAppend(out, node0)
    return out

fn uirCoreTupleLitBestEffortType(tupleNode0: Node): Node =
    var ty: Node = newNode(astNodeKindTupleTy(), nodePos(tupleNode0))
    for i0 in 0..<kidCount(tupleNode0):
        let ek: str = uirCoreBestEffortElemTypeKey(kid(tupleNode0, i0), "int64")
        addSon(ty, newIdent(ek, nodePos(tupleNode0)))
    return ty

fn uirCoreSeqLitBestEffortElemKey(seqNode0: Node): str =
    if !astNodeIdValid(seqNode0) || kidCount(seqNode0) <= 0:
        return ""
    var chosenIndex: int32 = -1
    var sawWideInt: bool
    var i0: int32 = kidCount(seqNode0) - 1
    while i0 >= 0:
        let elem0: Node = uirCoreCallArgValueNode(kid(seqNode0, i0))
        let cachedKey: str = uirCoreNodeTypeKeyOrEmpty(elem0)
        if len(cachedKey) > 0:
            chosenIndex = i0
            break
        if astNodeIdValid(elem0) && nodeKind(elem0) == astNodeKindIntLit():
            if nodeIntVal(elem0) > 2147483647 || nodeIntVal(elem0) < (-2147483647 - 1):
                sawWideInt = true
                break
        i0 = i0 - 1
    if chosenIndex >= 0:
        return uirCoreBestEffortElemTypeKey(kid(seqNode0, chosenIndex), "int32")
    if sawWideInt:
        return "int64"
    return "int32"

fn uirCoreBestEffortDupFnRefName(module: UirCoreModule, fref: UirCoreFunc, baseName: str): str =
    if module == nil || len(baseName) == 0:
        return ""
    if uirCoreDupFnBasesHas(baseName) && uirCoreFuncIdValid(fref):
        let mangledRef: str = uirCoreMaybeMangleDupFnBase(baseName, uirCoreFuncOriginFileOf(fref))
        if len(mangledRef) > 0 && moduleHasFuncByBase(module, mangledRef):
            return mangledRef
    return baseName

fn uirCoreSeqInferElemTypeKeyFromValue(b: BlockBuilder, valNode0: Node): str =
    let valKey0: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, valNode0))
    if isPtrKey(valKey0) || uirCoreStrStartsWith(valKey0, "ptr_"):
        return "ptr"
    return valKey0

fn uirCoreDebugNodeCallKidKeyExtra(ch0: Node): str =
    if astNodeIdValid(ch0) && nodeKind(ch0) == astNodeKindCallArg() && kidCount(ch0) > 0:
        let kn0: Node = kid(ch0, 0)
        if (kn0 != nil) && (nodeKind(kn0) == astNodeKindIdent() || nodeKind(kn0) == astNodeKindSymbol()):
            return " key=" + plainName(kn0)
    return ""

fn uirCoreDebugNodeCallKidExtra(ch0: Node): str =
    if astNodeIdValid(ch0) && nodeKind(ch0) == astNodeKindCallArg():
        return " callarg_kids=" + intToStr(kidCount(ch0)) + uirCoreDebugNodeCallKidKeyExtra(ch0)
    if (ch0 != nil) && (nodeKind(ch0) == astNodeKindIdent() || nodeKind(ch0) == astNodeKindSymbol()):
        return " name=" + plainName(ch0)
    return ""

fn uirCoreResolvedLocalCallTargetOrBase(env: LocalEnv, baseName0: str): str =
    let localCalleeIdx: int32 = localIndex(env, baseName0)
    if localCalleeIdx >= 0:
        let target0: str = localCallTarget(env, localCalleeIdx)
        if len(target0) > 0:
            return target0
    return baseName0

fn uirCoreFuncNameOrEmpty(f0: UirCoreFunc): str =
