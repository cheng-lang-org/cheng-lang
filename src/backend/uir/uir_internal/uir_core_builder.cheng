        let mangled0: str = uirCoreMaybeMangleDupGlobalName(name0, uirCoreFuncOriginFileOf(blockBuilderFuncRef(b)))
        if len(mangled0) > 0 && moduleGlobalIndex(mod, mangled0) >= 0:
            return mangled0
