fn uirCoreAnnotationFirstStrArgOrEmpty(annNode: Node): str =
    if astNodeIdValid(annNode) && nodeKind(annNode) == astNodeKindAnnotation() && kidCount(annNode) > 1:
        let arg0: Node = kid(annNode, 1)
        if astNodeIdValid(arg0) && nodeKind(arg0) == astNodeKindStrLit():
            return nodeStrVal(arg0)
    return ""

fn uirCoreFindPragmaLinkNameOrEmpty(funcNode: Node, pragmaName: str): str =
    if !astNodeIdValid(funcNode):
        return ""
    for ki in 0..<kidCount(funcNode):
        let kidNode: Node = kid(funcNode, ki)
        if !astNodeIdValid(kidNode):
            continue
        if nodeKind(kidNode) == astNodeKindAnnotation():
            if uirCoreAnnotationNameOrEmpty(kidNode) == pragmaName:
                return uirCoreAnnotationFirstStrArgOrEmpty(kidNode)
        elif nodeKind(kidNode) == astNodeKindPragma():
            for pi in 0..<kidCount(kidNode):
                let annNode: Node = kid(kidNode, pi)
                if uirCoreAnnotationNameOrEmpty(annNode) == pragmaName:
                    return uirCoreAnnotationFirstStrArgOrEmpty(annNode)
    return ""

fn uirCoreHasPragmaAnnotation(funcNode: Node, pragmaName: str): bool =
    if !astNodeIdValid(funcNode):
        return false
    for ki in 0..<kidCount(funcNode):
        let kidNode: Node = kid(funcNode, ki)
        if !astNodeIdValid(kidNode):
            continue
        if nodeKind(kidNode) == astNodeKindAnnotation():
            if uirCoreAnnotationNameOrEmpty(kidNode) == pragmaName:
                return true
        elif nodeKind(kidNode) == astNodeKindPragma():
            for pi in 0..<kidCount(kidNode):
                if uirCoreAnnotationNameOrEmpty(kid(kidNode, pi)) == pragmaName:
                    return true
    return false

fn uirCoreFuncHasImportc(funcNode: Node): bool =
    return uirCoreHasPragmaAnnotation(funcNode, "importc")

fn uirCoreFuncHasExportc(funcNode: Node): bool =
    return uirCoreHasPragmaAnnotation(funcNode, "exportc")

fn uirCoreFuncImportcLinkName(funcNode: Node, originFile: str, funcName: str): str =
    if !uirCoreFuncHasImportc(funcNode):
        return ""
    let sourceLinkName0: str = uirCoreImportcLinkNameFromSource(originFile, funcName)
    if len(sourceLinkName0) > 0:
        return uirCoreNormalizeImportcLinkName(funcName, sourceLinkName0)
    let rawLinkName0: str = uirCoreFindPragmaLinkNameOrEmpty(funcNode, "importc")
    return uirCoreNormalizeImportcLinkName(funcName, rawLinkName0)

fn uirCoreFuncExportcLinkNameOrEmpty(funcNode: Node): str =
    return uirCoreFindPragmaLinkNameOrEmpty(funcNode, "exportc")

fn uirCoreNodeKindDbgOrNil(n: Node): str =
    if astNodeIdValid(n):
        return "nk#" + intToStr(int32(nodeKind(n)))
    return "nil"

fn uirCoreTypeNodeObjTypeNameOrEmpty(module: UirCoreModule, n: Node): str =
