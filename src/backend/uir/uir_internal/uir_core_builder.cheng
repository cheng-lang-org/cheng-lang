fn uirCoreTypeFromTypeKeyForPredeclare(module: UirCoreModule, typeKey0: str): UirCoreType =
    let typeKey: str = backendStripSpaces(typeKey0)
    if len(typeKey) == 0:
        return uirCoreTypeI64()
    if typeKey == "void":
        return uirCoreTypeVoid()
    let builtinTy: UirCoreType = uirCoreTypeFromCanonicalNameOrDefault(typeKey, uirCoreTypeVoid())
    if uirCoreTypeKindOf(builtinTy) != uirCoreTypeKindVoid():
        return builtinTy
    if module != nil:
        let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, typeKey)
        if uirCoreTypeKindOf(aliasTy) != uirCoreTypeKindVoid():
            return aliasTy
        if len(uirCoreDirectObjValueTypeNameFromKey(module, typeKey)) > 0:
            return uirCoreTypeI64()
    return uirCoreTypeI64()

fn uirCorePredeclareObjTypeNameFromTypeKey(module: UirCoreModule, typeKey0: str): str =
    let typeKey: str = backendStripSpaces(typeKey0)
    if module == nil || len(typeKey) == 0:
        return ""
    let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(module, typeKey)
    if uirCoreTypeKindOf(aliasTy) != uirCoreTypeKindVoid():
        return ""
    return uirCoreDirectObjValueTypeNameFromKey(module, typeKey)

fn uirCorePredeclareObjTypeName(module: UirCoreModule, typeNode: Node,
                                typeKey0: str): str =
    if module == nil || !astNodeIdValid(typeNode) || nodeKind(typeNode) == astNodeKindEmpty():
        return ""
    let typeKey: str = len(typeKey0) > 0 ? typeKey0 : uirCoreTypeKeyForOverload(typeNode)
    let objFromKey: str = uirCorePredeclareObjTypeNameFromTypeKey(module, typeKey)
    if len(objFromKey) > 0:
        return objFromKey
    let kind: NodeKind = nodeKind(typeNode)
    if kind == astNodeKindTupleTy() || kind == astNodeKindBracketExpr():
        return uirCoreTypeNodeObjValueNameFastWithTypeKey(module, typeNode, typeKey)
    return ""

