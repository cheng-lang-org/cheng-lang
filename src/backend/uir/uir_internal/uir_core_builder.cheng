        # Structural Result-like builtins: prefer field-based lowering over missing monomorphized helpers.
        if blockBuilderModule(b) != nil && uirCoreCallNodeEffectiveArgCount(node) == 1:
            let arg0: Node = uirCoreCallArgNode(node, 0)
            if (arg0 != nil):
                var arg0Key: str = uirCoreStripRefVarKeyOnce(uirCoreInferNodeTypeKeyForOverload(b, arg0))
                arg0Key = uirCoreStripPtrKeyOnce(arg0Key)
                if uirCoreHasObjType(blockBuilderModule(b), arg0Key):
