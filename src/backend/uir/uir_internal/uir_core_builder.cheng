            if astNodeIdValid(elemTypeNode0) && nodeKind(elemTypeNode0) != astNodeKindEmpty():
                let elemSizeRes0: Result[int32] = uirCoreSizeOfTypeNode(blockBuilderModule(b), elemTypeNode0)
                if !IsOk[int32](elemSizeRes0):
                    return ErrInfo[UirExprId](ErrorInfoOf[int32](elemSizeRes0))
