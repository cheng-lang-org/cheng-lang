                            funcSetObjTypeKey(blockBuilderFuncRef(b), tmpSlot, retKeySig)
                        else:
                            localSetTypeKey(blockBuilderEnv(b), tmpSlot, retObjName)
                            funcSetObjTypeKey(blockBuilderFuncRef(b), tmpSlot, retObjName)
                        let allocRes: Result[bool] = allocObjValueLocal(b, tmpSlot, retObjName)
                        if ! uirCoreResultBoolIsOk(allocRes):
