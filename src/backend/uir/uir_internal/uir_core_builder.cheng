                    return Ok[UirExprId](bytes32_0)
        if kidCount(node) == 2 && blockBuilderModule(b) != nil:
            let aliasTy: UirCoreType = uirCoreTryGetTypeAlias(blockBuilderModule(b), callName0)
            if uirCoreTypeKindOf(aliasTy) != uirCoreTypeKindVoid():
