# Shared builder-local type-key helper routines split from uir_core_builder.
import std/system
import std/rawmem_support
import std/seqs
import stage1/ast
import stage1/token
import stage1/monomorphize
import backend/uir/uir_internal/uir_core_builder_text_helpers

fn uir_core_builder_type_key_helpers_add(dst: var Node[], val: Node) =
    seqs.add(dst, val)

fn uir_core_builder_type_key_helpers_add(dst: var int32[], val: int32) =
    seqs.add(dst, val)

fn uir_core_builder_type_key_helpers_add(dst: var str[], val: str) =
    seqs.add(dst, val)

var
    uirCoreOverloadTypeKeyCacheEpoch: int32[]
    uirCoreOverloadTypeKeyCacheVals: str[]
    uirCoreOverloadTypeKeyCacheRound: int32 = 1

fn typeNodeCanonicalIdentId(typeNode: Node): int32 =
    if !astNodeIdValid(typeNode):
        return 0
    let rawId: int32 = nodeIdentId(typeNode)
    if rawId <= 0:
        return 0
    return tokenTextTrimmedCanonicalId(rawId)

fn typeNodeCanonicalName(typeNode: Node): str =
    let textId: int32 = typeNodeCanonicalIdentId(typeNode)
    if textId > 0:
        return tokenTextById(textId)
    return backendStripSpaces(plainName(typeNode))

fn uirCoreJoinWithCharFill(out: str, left0: str, sep: char, right0: str, nLeft: int32, nRight: int32): str =
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    rawmem_support.rawmemCopy(outPtr, rawmemAsVoid(left0), nLeft)
    rawmemWriteChar(outPtr, nLeft, sep)
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(outPtr, nLeft + 1), rawmemAsVoid(right0), nRight)
    return out

fn uirCoreJoinWithChar(left0: str, sep: char, right0: str): str =
    let nLeft: int32 = len(left0)
    let nRight: int32 = len(right0)
    if nLeft <= 0:
        return right0
    if nRight <= 0:
        return left0
    return uirCoreJoinWithCharFill(newStringAlloc(nLeft + 1 + nRight), left0, sep, right0, nLeft, nRight)

fn uirCoreTypeKeyPrefixedFill(out: str, prefix0: str, inner0: str, nPrefix: int32, nInner: int32): str =
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    if nPrefix > 0:
        rawmem_support.rawmemCopy(outPtr, rawmemAsVoid(prefix0), nPrefix)
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(outPtr, nPrefix), rawmemAsVoid(inner0), nInner)
    return out

fn uirCoreTypeKeyPrefixed(prefix0: str, inner0: str, fallback0: str): str =
    if len(inner0) <= 0:
        return fallback0
    return uirCoreTypeKeyPrefixedFill(newStringAlloc(len(prefix0) + len(inner0)), prefix0, inner0, len(prefix0), len(inner0))

fn uirCoreTypeKeySeqName(inner0: str): str =
    return uirCoreTypeKeyPrefixed("seq_", inner0, "seq")

fn uirCoreConcat2Fill(out: str, left0: str, right0: str, nLeft: int32, nRight: int32): str =
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    rawmem_support.rawmemCopy(outPtr, rawmemAsVoid(left0), nLeft)
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(outPtr, nLeft), rawmemAsVoid(right0), nRight)
    return out

fn uirCoreConcat2(left0: str, right0: str): str =
    let nLeft: int32 = len(left0)
    let nRight: int32 = len(right0)
    if nLeft <= 0:
        return right0
    if nRight <= 0:
        return left0
    return uirCoreConcat2Fill(newStringAlloc(nLeft + nRight), left0, right0, nLeft, nRight)

fn uirCoreAppendCharFill(out: str, left0: str, ch: char, nLeft: int32): str =
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    if nLeft > 0:
        rawmem_support.rawmemCopy(outPtr, rawmemAsVoid(left0), nLeft)
    rawmemWriteChar(outPtr, nLeft, ch)
    return out

fn uirCoreAppendChar(left0: str, ch: char): str =
    return uirCoreAppendCharFill(newStringAlloc(len(left0) + 1), left0, ch, len(left0))

fn uirCoreIndexedName(prefix0: str, idx: int32): str =
    return uirCoreConcat2(prefix0, intToStr(idx))

fn uirCoreArrayObjName(capacity: int32, elemKey0: str): str =
    return uirCoreJoinWithChar(uirCoreIndexedName("array_", capacity), '_', elemKey0)

fn uirCoreTypeKeyBestEffort(typeNode: Node): str =
    let fastKey: str = uirCoreTypeKeyForOverloadFast(typeNode)
    if len(fastKey) > 0:
        return fastKey
    let fallbackKey: str = uirCoreTypeKeyFallbackText(typeNode)
    if len(fallbackKey) > 0:
        return fallbackKey
    let looseKey: str = backendStripSpaces(typeKey(typeNode))
    if len(looseKey) > 0:
        return looseKey
    return typeNodeCanonicalName(typeNode)

fn uirCoreTypeKeyFallbackBase(baseNode: Node): str =
    let baseKey: str = uirCoreTypeKeyFallbackText(baseNode)
    if len(baseKey) > 0:
        return baseKey
    return typeNodeCanonicalName(baseNode)

fn uirCoreTypeKeyFallbackBracketStart(baseNode: Node): str =
    let baseKey: str = uirCoreTypeKeyFallbackBase(baseNode)
    if len(baseKey) > 0:
        return baseKey
    return "inst"

fn uirCoreTypeKeyFallbackBracketTail(typeNode: Node, idx: int32, out0: str): str =
    if idx >= kidCount(typeNode):
        return out0
    let argKey: str = uirCoreTypeKeyFallbackText(kid(typeNode, idx))
    if len(argKey) > 0:
        return uirCoreTypeKeyFallbackBracketTail(typeNode, idx + 1, uirCoreJoinWithChar(out0, '_', argKey))
    return uirCoreTypeKeyFallbackBracketTail(typeNode, idx + 1, out0)

fn uirCoreTypeKeyFallbackTupleTail(typeNode: Node, idx: int32, out0: str): str =
    if idx >= kidCount(typeNode):
        return out0
    let argKey: str = uirCoreTypeKeyFallbackText(kid(typeNode, idx))
    if len(argKey) > 0:
        return uirCoreTypeKeyFallbackTupleTail(typeNode, idx + 1, uirCoreJoinWithChar(out0, '_', argKey))
    return uirCoreTypeKeyFallbackTupleTail(typeNode, idx + 1, out0)

fn uirCoreTypeKeyForOverloadTupleTail(typeNode: Node, idx: int32, out0: str): str =
    if idx >= kidCount(typeNode):
        return out0
    let argKey: str = uirCoreTypeKeyForOverloadFast(kid(typeNode, idx))
    if len(argKey) == 0:
        return ""
    return uirCoreTypeKeyForOverloadTupleTail(typeNode, idx + 1, uirCoreJoinWithChar(out0, '_', argKey))

fn uirCoreBracketSurfaceSliceElemKey(typeNode0: Node): str =
    var typeNode: Node = typeNode0
    while astNodeIdValid(typeNode) && nodeKind(typeNode) == nkPar && kidCount(typeNode) > 0:
        typeNode = kid(typeNode, 0)
    if !astNodeIdValid(typeNode) || nodeKind(typeNode) != nkBracketExpr || kidCount(typeNode) <= 0:
        return ""
    let elemNode: Node = kid(typeNode, 0)
    if kidCount(typeNode) > 1:
        let tailNode: Node = kid(typeNode, 1)
        if astNodeIdValid(tailNode) && nodeKind(tailNode) != nkEmpty:
            return ""
    return uirCoreTypeKeyBestEffort(elemNode)

fn uirCoreTypeKeyFallbackText(typeNode0: Node): str =
    var typeNode: Node = typeNode0
    while astNodeIdValid(typeNode) && nodeKind(typeNode) == nkPar && kidCount(typeNode) > 0:
        typeNode = kid(typeNode, 0)
    if typeNode == nil:
        return ""
    if nodeKind(typeNode) == nkEmpty:
        return ""
    let cachedKey: str = backendStripSpaces(typeKey(typeNode))
    if len(cachedKey) > 0 && !(cachedKey == "node"):
        return cachedKey
    if nodeKind(typeNode) == nkDotExpr && kidCount(typeNode) > 1:
        let lhsKey: str = uirCoreTypeKeyFallbackText(kid(typeNode, 0))
        let rhsKey: str = uirCoreTypeKeyFallbackText(kid(typeNode, 1))
        if len(rhsKey) > 0:
            if len(lhsKey) > 0:
                return uirCoreJoinWithChar(lhsKey, '.', rhsKey)
            return rhsKey
    if nodeKind(typeNode) == nkVarTy && kidCount(typeNode) > 0:
        let innerKey: str = uirCoreTypeKeyFallbackText(kid(typeNode, 0))
        return uirCoreTypeKeyPrefixed("var_", innerKey, "var")
    if nodeKind(typeNode) == nkRefTy && kidCount(typeNode) > 0:
        let innerKey: str = uirCoreTypeKeyFallbackText(kid(typeNode, 0))
        return uirCoreTypeKeyPrefixed("ref_", innerKey, "ref")
    if nodeKind(typeNode) == nkPtrTy && kidCount(typeNode) > 0:
        let innerKey: str = uirCoreTypeKeyFallbackText(kid(typeNode, 0))
        return uirCoreTypeKeyPrefixed("ptr_", innerKey, "ptr")
    if nodeKind(typeNode) == nkBracketExpr && kidCount(typeNode) > 0:
        let baseNode: Node = kid(typeNode, 0)
        let baseKey: str = uirCoreTypeKeyFallbackBase(baseNode)
        if kidCount(typeNode) == 2:
            let sliceElemKey: str = uirCoreBracketSurfaceSliceElemKey(typeNode)
            if len(sliceElemKey) > 0:
                return uirCoreTypeKeySeqName(sliceElemKey)
        if kidCount(typeNode) == 2:
            let argKey: str = uirCoreTypeKeyFallbackText(kid(typeNode, 1))
            if len(baseKey) > 0 && len(argKey) > 0:
                return (baseKey == "seq_fixed") ? uirCoreTypeKeySeqName(argKey) : uirCoreJoinWithChar(baseKey, '_', argKey)
        return uirCoreTypeKeyFallbackBracketTail(typeNode, 1, uirCoreTypeKeyFallbackBracketStart(baseNode))
    if nodeKind(typeNode) == nkTupleTy:
        return uirCoreTypeKeyFallbackTupleTail(typeNode, 0, "tuple")
    let nm: str = typeNodeCanonicalName(typeNode)
    if len(nm) > 0:
        return nm
    return uirCoreTypeKeyPrefixed("nk", intToStr(int32(nodeKind(typeNode))), "nk")

fn uirCoreTypeKeyForOverloadFast(typeNode0: Node): str =
    var typeNode: Node = typeNode0
    while astNodeIdValid(typeNode) && nodeKind(typeNode) == nkPar && kidCount(typeNode) > 0:
        typeNode = kid(typeNode, 0)
    if !astNodeIdValid(typeNode) || nodeKind(typeNode) == nkEmpty:
        return ""
    let kind: NodeKind = nodeKind(typeNode)
    if kind == nkIdent || kind == nkSymbol:
        return typeNodeCanonicalName(typeNode)
    if kind == nkDotExpr && kidCount(typeNode) > 1:
        let rhsKey: str = uirCoreTypeKeyForOverloadFast(kid(typeNode, 1))
        if len(rhsKey) > 0:
            return rhsKey
        return typeNodeCanonicalName(kid(typeNode, 1))
    if kind == nkVarTy && kidCount(typeNode) > 0:
        let innerKey: str = uirCoreTypeKeyForOverloadFast(kid(typeNode, 0))
        return uirCoreTypeKeyPrefixed("var_", innerKey, "var")
    if kind == nkRefTy && kidCount(typeNode) > 0:
        let innerKey: str = uirCoreTypeKeyForOverloadFast(kid(typeNode, 0))
        return uirCoreTypeKeyPrefixed("ref_", innerKey, "ref")
    if kind == nkPtrTy && kidCount(typeNode) > 0:
        let innerKey: str = uirCoreTypeKeyForOverloadFast(kid(typeNode, 0))
        return uirCoreTypeKeyPrefixed("ptr_", innerKey, "ptr")
    if kind == nkBracketExpr && kidCount(typeNode) > 0:
        let baseNode: Node = kid(typeNode, 0)
        let baseName: str = typeNodeCanonicalName(baseNode)
        if len(baseName) > 0:
            if kidCount(typeNode) == 2:
                let sliceElemKey: str = uirCoreBracketSurfaceSliceElemKey(typeNode)
                if len(sliceElemKey) > 0:
                    return uirCoreTypeKeySeqName(sliceElemKey)
            if kidCount(typeNode) == 2:
                let argKey: str = uirCoreTypeKeyForOverloadFast(kid(typeNode, 1))
                if len(argKey) > 0:
                    return (baseName == "seq_fixed") ? uirCoreTypeKeySeqName(argKey) : uirCoreJoinWithChar(baseName, '_', argKey)
            var instArgs: Node[]
            instArgs.cap = 4
            for ai in 1..<kidCount(typeNode):
                let arg: Node = kid(typeNode, ai)
                if astNodeIdValid(arg) && nodeKind(arg) != nkEmpty:
                    uir_core_builder_type_key_helpers_add(instArgs, arg)
            if instArgs.len > 0:
                let instName: str = mangleInstance(baseName, instArgs)
                if len(instName) > 0:
                    return instName
        return ""
    if kind == nkTupleTy:
        return uirCoreTypeKeyForOverloadTupleTail(typeNode, 0, "tuple")
    return ""

fn uirCoreOverloadTypeKeyCacheReset() =
    let nextRound: int32 = uirCoreOverloadTypeKeyCacheRound + 1
    if nextRound > 0:
        uirCoreOverloadTypeKeyCacheRound = nextRound
        return
    uirCoreOverloadTypeKeyCacheRound = 1
    uirCoreOverloadTypeKeyCacheEpoch.len = 0
    uirCoreOverloadTypeKeyCacheVals.len = 0

fn uirCoreOverloadTypeKeyCacheTryGet(n: Node, found: var bool): str =
    found = false
    if !astNodeIdValid(n):
        return ""
    let idx: int32 = n - 1
    if idx < 0 || idx >= uirCoreOverloadTypeKeyCacheEpoch.len || idx >= uirCoreOverloadTypeKeyCacheVals.len:
        return ""
    if uirCoreOverloadTypeKeyCacheEpoch[idx] != uirCoreOverloadTypeKeyCacheRound:
        return ""
    found = true
    return uirCoreOverloadTypeKeyCacheVals[idx]

fn uirCoreOverloadTypeKeyCachePut(n: Node, key: str) =
    if !astNodeIdValid(n):
        return
    let idx: int32 = n - 1
    if idx < 0:
        return
    while idx >= uirCoreOverloadTypeKeyCacheEpoch.len:
        uir_core_builder_type_key_helpers_add(uirCoreOverloadTypeKeyCacheEpoch, int32(0))
    while idx >= uirCoreOverloadTypeKeyCacheVals.len:
        uir_core_builder_type_key_helpers_add(uirCoreOverloadTypeKeyCacheVals, "")
    uirCoreOverloadTypeKeyCacheEpoch[idx] = uirCoreOverloadTypeKeyCacheRound
    uirCoreOverloadTypeKeyCacheVals[idx] = key

fn uirCoreTypeKeyForOverload(typeNode0: Node): str =
    var foundCached: bool = false
    let cachedKey: str = uirCoreOverloadTypeKeyCacheTryGet(typeNode0, foundCached)
    if foundCached:
        return cachedKey
    let fastKey: str = uirCoreTypeKeyForOverloadFast(typeNode0)
    if len(fastKey) > 0:
        uirCoreOverloadTypeKeyCachePut(typeNode0, fastKey)
        return fastKey
    let looseKey: str = uirCoreTypeKeyFromNodeLoose(typeNode0)
    if len(looseKey) > 0:
        uirCoreOverloadTypeKeyCachePut(typeNode0, looseKey)
        return looseKey
    let fallbackKey: str = uirCoreTypeKeyFallbackText(typeNode0)
    uirCoreOverloadTypeKeyCachePut(typeNode0, fallbackKey)
    return fallbackKey
