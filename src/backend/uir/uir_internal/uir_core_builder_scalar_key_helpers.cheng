# Shared builder-local scalar/type-key predicate helpers split from uir_core_builder.
import std/rawmem_support
import stage1/ast
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_text_helpers
import backend/uir/uir_internal/uir_core_builder_string_utils
import backend/uir/uir_internal/uir_core_builder_symbol_state

var
    uirCore_paramKeyCanon_recent_ptr: int64
    uirCore_paramKeyCanon_recent_raw: str
    uirCore_paramKeyCanon_recent_norm: str
    uirCore_paramKeyCanon_recent_valid: bool

    uirCore_paramVarBase_recent_ptr: int64
    uirCore_paramVarBase_recent_raw: str
    uirCore_paramVarBase_recent_base: str
    uirCore_paramVarBase_recent_valid: bool

    uirCore_paramWantsVarAddr_recent_module: UirCoreModule
    uirCore_paramWantsVarAddr_recent_ptr: int64
    uirCore_paramWantsVarAddr_recent_raw: str
    uirCore_paramWantsVarAddr_recent_val: bool
    uirCore_paramWantsVarAddr_recent_valid: bool

fn uirCoreScalarKeyPtrKey(s: str): int64 =
    if !uirCoreStrPtrSane(s):
        return 0
    return int64(strDataPtr(s))

fn uirCoreParamKeyCanon(paramKey0: str): str =
    if len(paramKey0) == 0:
        return ""
    let ptrKey: int64 = uirCoreScalarKeyPtrKey(paramKey0)
    if uirCore_paramKeyCanon_recent_valid:
        if ptrKey != 0 && ptrKey == uirCore_paramKeyCanon_recent_ptr:
            return uirCore_paramKeyCanon_recent_norm
        if len(uirCore_paramKeyCanon_recent_raw) > 0 && uirCore_paramKeyCanon_recent_raw == paramKey0:
            return uirCore_paramKeyCanon_recent_norm
    let norm: str = backendStripSpaces(paramKey0)
    uirCore_paramKeyCanon_recent_ptr = ptrKey
    uirCore_paramKeyCanon_recent_raw = paramKey0
    uirCore_paramKeyCanon_recent_norm = norm
    uirCore_paramKeyCanon_recent_valid = true
    return norm

fn isFloat64Key(key0: str): bool =
    if len(key0) == 0:
        return false
    let key: str = uirCoreParamKeyCanon(key0)
    return (key == "float64") || (key == "float")

fn isFloat32Key(key0: str): bool =
    if len(key0) == 0:
        return false
    let key: str = uirCoreParamKeyCanon(key0)
    return key == "float32"

fn isIntegralUirType(ty: UirCoreType): bool =
    return ty.kind == mtI8 || ty.kind == mtI16 || ty.kind == mtI32 || ty.kind == mtI64

fn isStringKey(key0: str): bool =
    if len(key0) == 0:
        return false
    let key: str = uirCoreParamKeyCanon(key0)
    return (key == "str") || (key == "string") || (key == "cstring")

fn isSemanticStrKey(key0: str): bool =
    if len(key0) == 0:
        return false
    let key: str = uirCoreParamKeyCanon(key0)
    return (key == "str") || (key == "string")

fn uirCoreNodeIsStringLiteral(node: Node): bool =
    return astNodeIdValid(node) && nodeKind(node) == nkStrLit

fn uirCoreNodeHasStringCtx(key0: str, node: Node): bool =
    return isStringKey(key0) || uirCoreNodeIsStringLiteral(node)

fn uirCoreNodeHasSemanticStrCtx(key0: str, node: Node): bool =
    return isSemanticStrKey(key0) || uirCoreNodeIsStringLiteral(node)

fn isPtrKey(key0: str): bool =
    if len(key0) == 0:
        return false
    let key: str = uirCoreParamKeyCanon(key0)
    return (key == "ptr") || (key == ("void" + "*"))

fn isStringOrPtrKey(key0: str): bool =
    return isStringKey(key0) || isPtrKey(key0)

fn isPtrRefVarBareKey(key0: str): bool =
    if len(key0) == 0:
        return false
    let key: str = uirCoreParamKeyCanon(key0)
    return (key == "ptr") || (key == "ref") || (key == "var")

fn isPtrRefVarLikeKey(key0: str): bool =
    if len(key0) == 0:
        return false
    let key: str = uirCoreParamKeyCanon(key0)
    return uirCoreStrStartsWith(key, "ptr_") || uirCoreStrStartsWith(key, "ref_") ||
           uirCoreStrStartsWith(key, "var_") || uirCoreStrStartsWith(key, "var_ref_") ||
           isPtrRefVarBareKey(key)

fn uirCoreParamIsVarKey(paramKey0: str): bool =
    if len(paramKey0) == 0:
        return false
    let key: str = uirCoreParamKeyCanon(paramKey0)
    return (key == "var") || uirCoreStrStartsWith(key, "var_") || uirCoreStrStartsWith(key, "var_ref_")

fn uirCoreParamVarBaseKey(paramKey0: str): str =
    if len(paramKey0) == 0:
        return ""
    let ptrKey: int64 = uirCoreScalarKeyPtrKey(paramKey0)
    if uirCore_paramVarBase_recent_valid:
        if ptrKey != 0 && ptrKey == uirCore_paramVarBase_recent_ptr:
            return uirCore_paramVarBase_recent_base
        if len(uirCore_paramVarBase_recent_raw) > 0 && uirCore_paramVarBase_recent_raw == paramKey0:
            return uirCore_paramVarBase_recent_base
    let key: str = uirCoreParamKeyCanon(paramKey0)
    if uirCoreStrStartsWith(key, "var_ref_"):
        let baseKey: str = rawmemStrFromOffset(key, 8)
        uirCore_paramVarBase_recent_ptr = ptrKey
        uirCore_paramVarBase_recent_raw = paramKey0
        uirCore_paramVarBase_recent_base = baseKey
        uirCore_paramVarBase_recent_valid = true
        return baseKey
    if uirCoreStrStartsWith(key, "var_"):
        let baseKey2: str = rawmemStrFromOffset(key, 4)
        uirCore_paramVarBase_recent_ptr = ptrKey
        uirCore_paramVarBase_recent_raw = paramKey0
        uirCore_paramVarBase_recent_base = baseKey2
        uirCore_paramVarBase_recent_valid = true
        return baseKey2
    uirCore_paramVarBase_recent_ptr = ptrKey
    uirCore_paramVarBase_recent_raw = paramKey0
    uirCore_paramVarBase_recent_base = ""
    uirCore_paramVarBase_recent_valid = true
    return ""

fn uirCoreParamWantsVarAddr(module: UirCoreModule, paramKey0: str): bool =
    if len(paramKey0) == 0:
        return false
    let ptrKey: int64 = uirCoreScalarKeyPtrKey(paramKey0)
    if uirCore_paramWantsVarAddr_recent_valid &&
       uirCore_paramWantsVarAddr_recent_module == module:
        if ptrKey != 0 && ptrKey == uirCore_paramWantsVarAddr_recent_ptr:
            return uirCore_paramWantsVarAddr_recent_val
        if len(uirCore_paramWantsVarAddr_recent_raw) > 0 &&
           uirCore_paramWantsVarAddr_recent_raw == paramKey0:
            return uirCore_paramWantsVarAddr_recent_val
    let key: str = uirCoreParamKeyCanon(paramKey0)
    if len(key) == 0:
        return false
    if key == "var":
        uirCore_paramWantsVarAddr_recent_module = module
        uirCore_paramWantsVarAddr_recent_ptr = ptrKey
        uirCore_paramWantsVarAddr_recent_raw = paramKey0
        uirCore_paramWantsVarAddr_recent_val = true
        uirCore_paramWantsVarAddr_recent_valid = true
        return true
    let baseKey: str = uirCoreParamVarBaseKey(key)
    if len(baseKey) == 0:
        let out0: bool = uirCoreParamIsVarKey(key)
        uirCore_paramWantsVarAddr_recent_module = module
        uirCore_paramWantsVarAddr_recent_ptr = ptrKey
        uirCore_paramWantsVarAddr_recent_raw = paramKey0
        uirCore_paramWantsVarAddr_recent_val = out0
        uirCore_paramWantsVarAddr_recent_valid = true
        return out0
    if module == nil:
        uirCore_paramWantsVarAddr_recent_module = module
        uirCore_paramWantsVarAddr_recent_ptr = ptrKey
        uirCore_paramWantsVarAddr_recent_raw = paramKey0
        uirCore_paramWantsVarAddr_recent_val = true
        uirCore_paramWantsVarAddr_recent_valid = true
        return true
    if uirCoreHasObjType(module, baseKey):
        uirCore_paramWantsVarAddr_recent_module = module
        uirCore_paramWantsVarAddr_recent_ptr = ptrKey
        uirCore_paramWantsVarAddr_recent_raw = paramKey0
        uirCore_paramWantsVarAddr_recent_val = true
        uirCore_paramWantsVarAddr_recent_valid = true
        return true
    if uirCoreStrStartsWith(baseKey, "seq_") && uirCoreHasObjType(module, "seq"):
        uirCore_paramWantsVarAddr_recent_module = module
        uirCore_paramWantsVarAddr_recent_ptr = ptrKey
        uirCore_paramWantsVarAddr_recent_raw = paramKey0
        uirCore_paramWantsVarAddr_recent_val = false
        uirCore_paramWantsVarAddr_recent_valid = true
        return false
    uirCore_paramWantsVarAddr_recent_module = module
    uirCore_paramWantsVarAddr_recent_ptr = ptrKey
    uirCore_paramWantsVarAddr_recent_raw = paramKey0
    uirCore_paramWantsVarAddr_recent_val = true
    uirCore_paramWantsVarAddr_recent_valid = true
    return true

fn uirCoreStripRefVarKeyOnce(key0: str): str =
    let key: str = uirCoreParamKeyCanon(key0)
    if len(key) == 0:
        return ""
    if uirCoreStrStartsWith(key, "ref_"):
        return rawmemStrFromOffset(key, 4)
    let varBase: str = uirCoreParamVarBaseKey(key)
    if len(varBase) > 0:
        return varBase
    return key

fn uirCoreStripPtrKeyOnce(key0: str): str =
    let key: str = uirCoreParamKeyCanon(key0)
    if len(key) == 0:
        return ""
    if uirCoreStrStartsWith(key, "ptr_"):
        return rawmemStrFromOffset(key, 4)
    return key

fn uirCoreNormalizeObjLookupKey(module: UirCoreModule, key0: str): str =
    var key: str = uirCoreStripRefVarKeyOnce(key0)
    if len(key) == 0:
        return ""
    if module != nil:
        let canon: str = uirCoreObjAliasCanon(key)
        if len(canon) > 0:
            key = canon
    return uirCoreStripPtrKeyOnce(key)

fn uirCoreStripParExpr(n0: Node): Node =
    var n: Node = n0
    while astNodeIdValid(n) && nodeKind(n) == nkPar && kidCount(n) > 0:
        n = kid(n, 0)
    return n

fn uirCoreIsNilExpr(n0: Node): bool =
    let n: Node = uirCoreStripParExpr(n0)
    return astNodeIdValid(n) && nodeKind(n) == nkNilLit

fn isByteTypeKey(key: str): bool =
    if len(key) == 0:
        return false
    return (key == "bool") || (key == "char") ||
           (key == "int8") || (key == "uint8") ||
           (key == "i8") || (key == "u8")

fn isBytePtrTypeKey(key: str): bool =
    if len(key) == 0:
        return false
    if ! uirCoreStrStartsWith(key, "ptr_"):
        return false
    let elemKey: str = rawmemStrFromOffset(key, 4)
    return isByteTypeKey(elemKey)

fn byteUirTypeFromKey(key0: str): UirCoreType =
    if len(key0) == 0:
        return uirCoreTypeU8()
    let key: str = uirCoreParamKeyCanon(key0)
    if (key == "int8") || (key == "i8"):
        return uirCoreTypeI8()
    return uirCoreTypeU8()

fn byteUirTypeFromPtrTypeKey(ptrKey0: str): UirCoreType =
    if len(ptrKey0) == 0:
        return uirCoreTypeU8()
    let ptrKey: str = uirCoreParamKeyCanon(ptrKey0)
    if !uirCoreStrStartsWith(ptrKey, "ptr_"):
        return uirCoreTypeU8()
    let elemKey: str = rawmemStrFromOffset(ptrKey, 4)
    return byteUirTypeFromKey(elemKey)

fn byteUirTypeFromElemOrPtrKey(elemKey0: str, ptrKey0: str): UirCoreType =
    if len(elemKey0) > 0:
        var elemKey: str = uirCoreParamKeyCanon(elemKey0)
        if uirCoreStrStartsWith(elemKey, "ptr_"):
            elemKey = uirCoreParamKeyCanon(rawmemStrFromOffset(elemKey, 4))
        return byteUirTypeFromKey(elemKey)
    return byteUirTypeFromPtrTypeKey(ptrKey0)

fn uirCorePtrBaseObjTypeName(mod: UirCoreModule, baseKey0: str): str =
    if (mod == nil) || len(baseKey0) == 0:
        return ""
    if uirCoreHasObjType(mod, baseKey0):
        return baseKey0
    if (uirCoreStrStartsWith(baseKey0, "seq_") || uirCoreStrStartsWith(baseKey0, "seq_fixed_")) && uirCoreHasObjType(mod, "seq"):
        return "seq"
    if uirCoreStrStartsWith(baseKey0, "Table_") && uirCoreHasObjType(mod, "Table"):
        return "Table"
    let __for_start_i = len(baseKey0) - 1
    for __for_rev_i in 0..(__for_start_i - (0)):
        let i = __for_start_i - __for_rev_i
        if baseKey0[i] == '.':
            let sub: str = rawmemStrFromOffset(baseKey0, i + 1)
            if len(sub) > 0 && uirCoreHasObjType(mod, sub):
                return sub
            break
    return ""
