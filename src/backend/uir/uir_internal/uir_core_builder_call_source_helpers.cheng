# Shared builder-local AST call/source helper routines split from uir_core_builder.
import std/os
import std/seqs
import stage1/ast
import stage1/lexer
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_text_helpers

fn uirCoreAppendNode(seqInst: Node[]*, val: Node) =
    if seqInst == nil:
        return
    let idx: int32 = seqInst->len
    let needLen: int32 = idx + 1
    if seqInst->buffer == nil || seqInst->cap < needLen:
        cheng__seqGrowToRaw(&seqInst->buffer, &seqInst->cap, needLen, int32(sizeof Node))
    seqInst->len = needLen
    seqInst[idx] = val

fn uirCoreNodeIsFieldDot(node: Node): bool =
    return astNodeIdValid(node) && nodeKind(node) == nkDotExpr && kidCount(node) > 1

fn uirCoreDotBaseNode(dotNode: Node): Node =
    if !uirCoreNodeIsFieldDot(dotNode):
        return nil
    return kid(dotNode, 0)

fn uirCoreDotFieldNode(dotNode: Node): Node =
    if !uirCoreNodeIsFieldDot(dotNode):
        return nil
    return kid(dotNode, 1)

fn uirCoreAppendBracketTypeArgs(typeArgs: Node[]*, bracketNode: Node) =
    if typeArgs == nil || !astNodeIdValid(bracketNode) || nodeKind(bracketNode) != nkBracketExpr:
        return
    for ti in 1..<kidCount(bracketNode):
        let t: Node = kid(bracketNode, ti)
        if astNodeIdValid(t) && nodeKind(t) != nkEmpty:
            uirCoreAppendNode(typeArgs, t)

fn uirCoreResolveCalleeNameAndTypeArgs(calleeNode: Node, typeArgs: Node[]*): str =
    if !astNodeIdValid(calleeNode):
        return ""
    if nodeKind(calleeNode) == nkBracketExpr && kidCount(calleeNode) > 0:
        let base: Node = kid(calleeNode, 0)
        uirCoreAppendBracketTypeArgs(typeArgs, calleeNode)
        return backendStripSpaces(plainName(base))
    if uirCoreNodeIsFieldDot(calleeNode):
        let member: Node = uirCoreDotFieldNode(calleeNode)
        if astNodeIdValid(member) && nodeKind(member) == nkBracketExpr && kidCount(member) > 0:
            let base2: Node = kid(member, 0)
            uirCoreAppendBracketTypeArgs(typeArgs, member)
            return backendStripSpaces(plainName(base2))
        return backendStripSpaces(plainName(member))
    if nodeKind(calleeNode) == nkIdent || nodeKind(calleeNode) == nkSymbol:
        return backendStripSpaces(plainName(calleeNode))
    return ""

fn uirCoreCallIsNamed(callNode: Node, calleeName: str): bool =
    if !astNodeIdValid(callNode) || nodeKind(callNode) != nkCall || len(calleeName) == 0 || kidCount(callNode) <= 0:
        return false
    let calleeNode: Node = kid(callNode, 0)
    return uirCoreResolveCalleeNameAndTypeArgs(calleeNode, nil) == calleeName

fn uirCoreCollectCallArgNodes(callNode: Node): Node[] =
    var out: Node[]
    if !astNodeIdValid(callNode) || nodeKind(callNode) != nkCall:
        return out
    for ai in 1..<kidCount(callNode):
        var argNode: Node = kid(callNode, ai)
        if astNodeIdValid(argNode) && nodeKind(argNode) == nkCallArg:
            if kidCount(argNode) > 1:
                argNode = kid(argNode, 1)
            elif kidCount(argNode) > 0:
                argNode = kid(argNode, 0)
        uirCoreAppendNode(&out, argNode)
    return out

fn uirCoreCallCalleeName(callNode: Node): str =
    if !astNodeIdValid(callNode) || nodeKind(callNode) != nkCall || kidCount(callNode) == 0:
        return ""
    let callee: Node = kid(callNode, 0)
    if (callee == nil):
        return ""
    var typeArgs: Node[]
    let directName: str = uirCoreResolveCalleeNameAndTypeArgs(callee, &typeArgs)
    if len(directName) > 0:
        return directName
    if nodeKind(callee) == nkBracketExpr && kidCount(callee) > 0:
        let base: Node = kid(callee, 0)
        if (base != nil) && (nodeKind(base) == nkIdent || nodeKind(base) == nkSymbol):
            return backendStripSpaces(plainName(base))
    return ""

fn uirCoreMemberName(n: Node): str =
    if !astNodeIdValid(n):
        return ""
    let nm0: str = backendStripSpaces(plainName(n))
    if len(nm0) > 0:
        return nm0
    let sv0: str = nodeStrVal(n)
    if len(sv0) > 0:
        return backendStripSpaces(sv0)
    if nodeKind(n) == nkBracketExpr && kidCount(n) > 0:
        let base0: Node = kid(n, 0)
        let baseNm0: str = uirCoreMemberName(base0)
        if len(baseNm0) > 0:
            return baseNm0
    if kidCount(n) == 1:
        return uirCoreMemberName(kid(n, 0))
    if kidCount(n) > 1:
        let tail0: Node = kid(n, kidCount(n) - 1)
        let tailNm0: str = uirCoreMemberName(tail0)
        if len(tailNm0) > 0:
            return tailNm0
        let head0: Node = kid(n, 0)
        let headNm0: str = uirCoreMemberName(head0)
        if len(headNm0) > 0:
            return headNm0
    return ""

fn uirCoreGuessDotFieldNameFromSource(func0: UirCoreFunc, dotNode: Node): str =
    if func0 == nil:
        return ""
    let fp: str = uirCoreFuncOriginFileOf(func0)
    if len(fp) == 0:
        return ""
    let lineNo: int32 = nodePosLine(dotNode)
    let colNo: int32 = nodePosCol(dotNode)
    if lineNo <= 0 || colNo <= 0:
        return ""
    let src: str = os.readFile(fp)
    if len(src) == 0:
        return ""
    var curLine: int32 = 1
    var lineStart: int32 = 0
    var i: int32 = 0
    while i < len(src) && curLine < lineNo:
        if src[i] == '\n':
            curLine = curLine + 1
            lineStart = i + 1
        i = i + 1
    if curLine != lineNo:
        return ""
    var dotIdx: int32 = lineStart + colNo - 1
    if dotIdx < lineStart || dotIdx >= len(src):
        return ""
    var fieldStartIdx: int32 = -1
    if src[dotIdx] == '.':
        fieldStartIdx = dotIdx + 1
    elif src[dotIdx] == '-' && dotIdx + 1 < len(src) && src[dotIdx + 1] == '>':
        fieldStartIdx = dotIdx + 2
    if fieldStartIdx < 0:
        var lineEnd: int32 = dotIdx
        while lineEnd < len(src) && src[lineEnd] != '\n':
            lineEnd = lineEnd + 1
        var leftOp: int32 = dotIdx
        while leftOp >= lineStart:
            if src[leftOp] == '.':
                break
            if src[leftOp] == '-' && leftOp + 1 < lineEnd && src[leftOp + 1] == '>':
                break
            leftOp = leftOp - 1
        var rightOp: int32 = dotIdx
        while rightOp < lineEnd:
            if src[rightOp] == '.':
                break
            if src[rightOp] == '-' && rightOp + 1 < lineEnd && src[rightOp + 1] == '>':
                break
            rightOp = rightOp + 1
        let leftOk: bool = leftOp >= lineStart &&
            (src[leftOp] == '.' || (src[leftOp] == '-' && leftOp + 1 < lineEnd && src[leftOp + 1] == '>'))
        let rightOk: bool = rightOp < lineEnd &&
            (src[rightOp] == '.' || (src[rightOp] == '-' && rightOp + 1 < lineEnd && src[rightOp + 1] == '>'))
        if leftOk:
            if !rightOk:
                dotIdx = leftOp
            elif (dotIdx - leftOp) <= (rightOp - dotIdx):
                dotIdx = leftOp
            else:
                dotIdx = rightOp
        elif rightOk:
            dotIdx = rightOp
        else:
            return ""
        if src[dotIdx] == '.':
            fieldStartIdx = dotIdx + 1
        elif src[dotIdx] == '-' && dotIdx + 1 < lineEnd && src[dotIdx + 1] == '>':
            fieldStartIdx = dotIdx + 2
        else:
            return ""
    while fieldStartIdx < len(src) && (src[fieldStartIdx] == ' ' || src[fieldStartIdx] == '\t'):
        fieldStartIdx = fieldStartIdx + 1
    let start: int32 = fieldStartIdx
    while fieldStartIdx < len(src):
        let c: char = src[fieldStartIdx]
        let okIdent: bool =
            (c >= 'a' && c <= 'z') ||
            (c >= 'A' && c <= 'Z') ||
            (c >= '0' && c <= '9') ||
            c == '_'
        if !okIdent:
            break
        fieldStartIdx = fieldStartIdx + 1
    if fieldStartIdx <= start:
        return ""
    return sliceRange(src, start, fieldStartIdx - 1)

fn uirCoreGuessIdentNameFromSource(func0: UirCoreFunc, identNode: Node): str =
    if func0 == nil || !astNodeIdValid(identNode):
        return ""
    let fp: str = uirCoreFuncOriginFileOf(func0)
    if len(fp) == 0:
        return ""
    let lineNo: int32 = nodePosLine(identNode)
    let colNo: int32 = nodePosCol(identNode)
    if lineNo <= 0 || colNo <= 0:
        return ""
    let src: str = os.readFile(fp)
    if len(src) == 0:
        return ""
    var curLine: int32 = 1
    var lineStart: int32 = 0
    var i: int32 = 0
    while i < len(src) && curLine < lineNo:
        if src[i] == '\n':
            curLine = curLine + 1
            lineStart = i + 1
        i = i + 1
    if curLine != lineNo:
        return ""
    var lineEnd: int32 = lineStart
    while lineEnd < len(src) && src[lineEnd] != '\n':
        lineEnd = lineEnd + 1
    var idx: int32 = lineStart + colNo - 1
    if idx < lineStart:
        idx = lineStart
    if idx >= lineEnd:
        idx = lineEnd - 1
    while idx < lineEnd && (src[idx] == ' ' || src[idx] == '\t'):
        idx = idx + 1
    let start: int32 = idx
    while idx < lineEnd:
        let c: char = src[idx]
        let okIdent: bool =
            (c >= 'a' && c <= 'z') ||
            (c >= 'A' && c <= 'Z') ||
            (c >= '0' && c <= '9') ||
            c == '_'
        if !okIdent:
            break
        idx = idx + 1
    if idx <= start:
        return ""
    return sliceRange(src, start, idx - 1)

fn uirCoreSeqBuiltinFieldName(fieldName0: str): str =
    let fieldName: str = backendStripSpaces(fieldName0)
    if fieldName == "data":
        return "buffer"
    return fieldName

fn uirCoreGuessSeqBuiltinFieldFromSource(func0: UirCoreFunc, dotNode: Node, baseName0: str): str =
    if func0 == nil || !astNodeIdValid(dotNode):
        return ""
    let baseName: str = backendStripSpaces(baseName0)
    if len(baseName) == 0:
        return ""
    let fp: str = uirCoreFuncOriginFileOf(func0)
    if len(fp) == 0:
        return ""
    let lineNo: int32 = nodePosLine(dotNode)
    let colNo: int32 = nodePosCol(dotNode)
    if lineNo <= 0 || colNo <= 0:
        return ""
    let src: str = os.readFile(fp)
    if len(src) == 0:
        return ""
    var curLine: int32 = 1
    var lineStart: int32 = 0
    var i: int32 = 0
    while i < len(src) && curLine < lineNo:
        if src[i] == '\n':
            curLine = curLine + 1
            lineStart = i + 1
        i = i + 1
    if curLine != lineNo:
        return ""
    var lineEnd: int32 = lineStart
    while lineEnd < len(src) && src[lineEnd] != '\n':
        lineEnd = lineEnd + 1
    let anchor: int32 = lineStart + colNo - 1
    var bestFieldStart: int32 = -1
    var bestFieldEnd: int32 = -1
    var bestDist: int32 = -1
    let baseLen: int32 = len(baseName)
    var idx: int32 = lineStart
    while idx < lineEnd:
        var matched: bool = true
        if idx + baseLen >= lineEnd:
            break
        for bi in 0..<baseLen:
            if src[idx + bi] != baseName[bi]:
                matched = false
                break
        if !matched:
            idx = idx + 1
            continue
        var fieldStart: int32 = -1
        if src[idx + baseLen] == '.':
            fieldStart = idx + baseLen + 1
        elif idx + baseLen + 1 < lineEnd && src[idx + baseLen] == '-' && src[idx + baseLen + 1] == '>':
            fieldStart = idx + baseLen + 2
        if fieldStart < 0:
            idx = idx + 1
            continue
        var fieldEnd: int32 = fieldStart
        while fieldEnd < lineEnd:
            let c: char = src[fieldEnd]
            let okIdent: bool =
                (c >= 'a' && c <= 'z') ||
                (c >= 'A' && c <= 'Z') ||
                (c >= '0' && c <= '9') ||
                c == '_'
            if !okIdent:
                break
            fieldEnd = fieldEnd + 1
        if fieldEnd > fieldStart:
            let cand: str = sliceRange(src, fieldStart, fieldEnd - 1)
            let builtin: str = uirCoreSeqBuiltinFieldName(cand)
            if len(builtin) > 0:
                let dotPos: int32 = idx + baseLen
                var dist: int32 = dotPos - anchor
                if dist < 0:
                    dist = -dist
                if bestDist < 0 || dist < bestDist:
                    bestDist = dist
                    bestFieldStart = fieldStart
                    bestFieldEnd = fieldEnd - 1
        idx = idx + 1
    if bestFieldStart >= 0 && bestFieldEnd >= bestFieldStart:
        return uirCoreSeqBuiltinFieldName(sliceRange(src, bestFieldStart, bestFieldEnd))
    return ""
