        return backendStripSpaces(plainName(arg))
    return ""

fn uirCoreLenArgKey(b: BlockBuilder, arg0: Node): str =
    let inferred0: str = caseInferExprTypeKey(b, arg0)
    if len(inferred0) > 0:
        return inferred0
    if (arg0 != nil) && (nodeKind(arg0) == astNodeKindIdent() || nodeKind(arg0) == astNodeKindSymbol()):
        let nm0: str = plainName(arg0)
        let slot0: int32 = uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), nm0)
        if slot0 >= 0 && uirCoreFuncIdValid(blockBuilderFuncRef(b)):
            let olIdx0: int32 = funcFindObjLocal(blockBuilderFuncRef(b), slot0)
            if olIdx0 >= 0:
                return funcObjTypeName(blockBuilderFuncRef(b), slot0)
            let ty0: UirCoreType = localType(blockBuilderEnv(b), slot0)
            if uirCoreTypeKindOf(ty0) == uirCoreTypeKindI64():
                return "str"
    return ""

fn uirCoreBestRetObjTypeName(module: UirCoreModule, callee0: UirCoreFunc, p0: UirCoreParam): str =
    let objNm0: str = funcObjTypeName(callee0, uirCoreSlotOf(p0))
    if len(objNm0) > 0:
        return objNm0
    let kret0: str = funcObjTypeKey(callee0, uirCoreSlotOf(p0))
    if len(kret0) > 0:
        let objNm1: str = uirCoreDirectObjValueTypeNameFromKey(module, kret0)
        if len(objNm1) > 0:
            return objNm1
        let objNm2: str = uirCoreObjTypeFromTypeKey(module, kret0)
        if len(objNm2) > 0:
            return objNm2
    if len(uirCoreTypeKeyOf(p0)) > 0:
        let objNm3: str = uirCoreDirectObjValueTypeNameFromKey(module, uirCoreTypeKeyOf(p0))
        if len(objNm3) > 0:
            return objNm3
        let objNm4: str = uirCoreObjTypeFromTypeKey(module, uirCoreTypeKeyOf(p0))
        if len(objNm4) > 0:
            return objNm4
    let funcRetKey0: str = uirCoreFuncRetTypeKeyOf(callee0)
    if len(funcRetKey0) > 0:
        let objNm5: str = uirCoreDirectObjValueTypeNameFromKey(module, funcRetKey0)
        if len(objNm5) > 0:
            return objNm5
        let objNm6: str = uirCoreObjTypeFromTypeKey(module, funcRetKey0)
        if len(objNm6) > 0:
            return objNm6
    return ""

fn uirCoreCalleeOutKey(callee0: UirCoreFunc): str =
    if callee0 != nil:
        if uirCoreFuncParamsLen(callee0) > 0:
            let p0: UirCoreParam = uirCoreFuncParamAt(callee0, 0)
            if uirCoreNameOf(p0) == "__ret":
                let retKey0: str = funcObjTypeKey(callee0, uirCoreSlotOf(p0))
                if len(retKey0) > 0:
                    return retKey0
        let retKey1: str = uirCoreFuncRetTypeKeyOf(callee0)
        if len(retKey1) > 0:
            return retKey1
    return ""

fn uirCoreNamedNodeLocalSlotOrNeg1(b: BlockBuilder, n: Node): int32 =
    if (b != nil) && (blockBuilderEnv(b) != nil) && astNodeIdValid(n) &&
       (nodeKind(n) == astNodeKindIdent() || nodeKind(n) == astNodeKindSymbol()):
        return uirCoreResolveLocalSlotOrImplicitResult(blockBuilderEnv(b), blockBuilderFuncRef(b), plainName(n))
    return -1

fn uirCoreNodeLocalTypeKeyOrEmpty(b: BlockBuilder, n: Node): str =
    let slot0: int32 = uirCoreNamedNodeLocalSlotOrNeg1(b, n)
    if slot0 >= 0:
        return localTypeKey(blockBuilderEnv(b), slot0)
