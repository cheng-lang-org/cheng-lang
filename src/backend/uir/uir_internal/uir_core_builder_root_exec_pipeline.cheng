fn uirCoreCallArgFieldName(arg: Node, nameNode: Node): str =
    if astNodeIdValid(nameNode) && (nodeKind(nameNode) == astNodeKindIdent() || nodeKind(nameNode) == astNodeKindSymbol()):
        return backendStripSpaces(plainName(nameNode))
