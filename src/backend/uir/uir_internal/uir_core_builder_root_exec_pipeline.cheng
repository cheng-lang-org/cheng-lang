        return funcObjTypeName(blockBuilderFuncRef(b), slot0)
    return ""

fn uirCoreCaseBracketBaseKey(b: BlockBuilder, baseNode: Node): str =
    let baseKey0: str = caseInferExprTypeKey(b, baseNode)
    let seqKey0: str = uirCoreSeqLikeKeyFromExpr(b, baseNode)
    return uirCoreFirstNonEmptyStr(seqKey0, baseKey0)

fn uirCoreCaseDotFieldKey(b: BlockBuilder, parentKey: str, fieldName: str): str =
    if len(parentKey) == 0 || len(fieldName) == 0:
        return ""
    let directKey0: str = uirCoreObjFieldTypeKeyGet(parentKey, fieldName)
    if len(directKey0) > 0:
        return directKey0
    if (parentKey == "tuple") || uirCoreStrStartsWith(parentKey, "tuple_"):
        let ti0: int32 = uirCoreTupleFieldIndexGet(parentKey, fieldName)
        if ti0 >= 0:
            let altFieldName0: str = uirCoreIndexedName("f", ti0)
            let altKey0: str = uirCoreObjFieldTypeKeyGet(parentKey, altFieldName0)
            if len(altKey0) > 0:
                return altKey0
    let pk0: str = uirCoreStripPtrKeyOnce(parentKey)
    if len(pk0) > 0 && !(pk0 == parentKey):
        let ptrKey0: str = uirCoreObjFieldTypeKeyGet(pk0, fieldName)
        if len(ptrKey0) > 0:
            return ptrKey0
    if blockBuilderModule(b) != nil:
        if uirCoreStrStartsWith(parentKey, "seq_") && uirCoreHasObjType(blockBuilderModule(b), "seq"):
            let seqKey0: str = uirCoreObjFieldTypeKeyGet("seq", fieldName)
            if len(seqKey0) > 0:
                return seqKey0
        elif uirCoreStrStartsWith(parentKey, "seq_fixed_") && uirCoreHasObjType(blockBuilderModule(b), "seq"):
            let seqFixedKey0: str = uirCoreObjFieldTypeKeyGet("seq", fieldName)
            if len(seqFixedKey0) > 0:
                return seqFixedKey0
        elif uirCoreStrStartsWith(parentKey, "Table_") && uirCoreHasObjType(blockBuilderModule(b), "Table"):
            let tableKey0: str = uirCoreObjFieldTypeKeyGet("Table", fieldName)
            if len(tableKey0) > 0:
                return tableKey0
        return uirCoreFieldTypeKeyFromCurrentRoot(blockBuilderModule(b), parentKey, fieldName)
    return ""

fn uirCoreCaseCallResolvedOutKey(b: BlockBuilder, callNode: Node, callName: str,
                                 callee0: UirCoreFunc): str =
    let calleeKey0: str = uirCoreCalleeOutKey(callee0)
    if len(calleeKey0) > 0:
        return calleeKey0
    if (callName == "Value") && kidCount(callNode) == 2 && blockBuilderModule(b) != nil:
        var argNode0: Node = kid(callNode, 1)
        if astNodeIdValid(argNode0) && nodeKind(argNode0) == astNodeKindCallArg():
            if kidCount(argNode0) > 1:
                argNode0 = kid(argNode0, 1)
            elif kidCount(argNode0) > 0:
                argNode0 = kid(argNode0, 0)
        let parentKey0: str = uirCoreStripRefVarKeyOnce(caseInferExprTypeKey(b, argNode0))
        let fieldKey0: str = uirCoreCaseDotFieldKey(b, parentKey0, "value")
        if len(fieldKey0) > 0:
            return fieldKey0
    if callName == "Value":
        let innerKey0: str = uirCoreInferValueCallInnerKey(b, callNode)
        if len(innerKey0) > 0:
            return innerKey0
    return ""

fn uirCoreDebugTypeKeyCallArg0Key(b: BlockBuilder, callNode: Node): str =
    if kidCount(callNode) > 1:
