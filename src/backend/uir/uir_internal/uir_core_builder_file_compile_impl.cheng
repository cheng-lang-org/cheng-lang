# Thin facade for current-source file compile entrypoints.
#
# Keep builder-bearing roots off the active import surface by routing the
# heavy stage1->UIR file pipeline through file_exec_impl.
import std/result
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_internal/uir_core_builder_file_exec_impl

fn uirCoreFileCompileImplBuildModuleFromFileStage1(inPath: str, target: str): Result[UirCoreModule] =
    return uirCoreFileExecImplBuildModuleFromFileStage1(inPath, target)

fn uirCoreFileCompileImplBuildModuleFromFileStage1OrPanic(inPath: str, target: str): UirCoreModule =
    return uirCoreFileExecImplBuildModuleFromFileStage1OrPanic(inPath, target)
