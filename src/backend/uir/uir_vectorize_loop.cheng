# UIR loop vectorization: deterministic reassociation pass for loop-carried arithmetic.
import backend/uir/uir_types
import backend/uir/uir_internal/uir_core_types
import backend/uir/uir_loop_analysis
import backend/uir/uir_vec_cost
import std/seqs
import std/strutils
import std/os
import std/system

fn add(dst: var UirExpr[], val: UirExpr) =
    seqs.add(dst, val)

fn uirLoopVecWriteBlock(seqInst: UirBlockId[]*, idx: int32, val: UirBlockId) =
    if seqInst == nil || idx < 0 || idx >= seqInst->len:
        return
    uirCoreWriteBlock(seqInst, idx, val)

fn uirLoopVecPolicyNormalize(policy: str): str =
    let raw: str = strutils.toLowerAscii(strutils.strip(policy))
    if raw == "":
        return "autovec"
    return raw

fn uirLoopVecAssocBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirLoopVecExprKeyInner(expr: UirExpr, depth: ptr): str =
    if expr <= 0:
        return "nil"
    if depth == nil:
        return "depth_nil"
    if load(depth) >= 128:
        return "depth_limit"
    store(depth, load(depth) + 1)
    let kind: UirExprKind = uirExprKindOf(expr)
    var key: str = "k" + intToStr(int32(kind))
    if kind == meConstI64:
        key = key + ":v" + intToStr(int32(uirExprConstValueOf(expr) & 2147483647))
    elif kind == meLocal || kind == meAddr:
        key = key + ":l" + intToStr(uirExprLocalIndexOf(expr))
    elif kind == meGlobalAddr:
        key = key + ":g" + uirExprGlobalNameOf(expr)
    elif kind == meBin:
        key = key + ":b" + intToStr(int32(uirExprBinOpOf(expr))) + "(" +
              uirLoopVecExprKeyInner(uirExprLhsOf(expr), depth) + "," +
              uirLoopVecExprKeyInner(uirExprRhsOf(expr), depth) + ")"
    elif kind == meCmp:
        key = key + ":c" + intToStr(int32(uirExprCmpOpOf(expr))) + "(" +
              uirLoopVecExprKeyInner(uirExprLhsOf(expr), depth) + "," +
              uirLoopVecExprKeyInner(uirExprRhsOf(expr), depth) + ")"
    elif kind == meCast:
        key = key + ":cast(" + uirLoopVecExprKeyInner(uirExprCastExprOf(expr), depth) + ")"
    elif kind == meLoad:
        key = key + ":load(" + uirLoopVecExprKeyInner(uirExprAddrExprOf(expr), depth) + ")"
    elif kind == meCall:
        key = key + ":call(" + uirExprCalleeOf(expr) + ")"
    store(depth, load(depth) - 1)
    return key

fn uirLoopVecExprKey(expr: UirExpr): str =
    var depth: int32 = 0
    return uirLoopVecExprKeyInner(expr, &depth)

fn uirLoopVecExprPureLeaf(expr: UirExpr): bool =
    if expr <= 0:
        return false
    let kind: UirExprKind = uirExprKindOf(expr)
    if kind == meConstI64 || kind == meLocal || kind == meAddr || kind == meGlobalAddr:
        return true
    return false

fn uirLoopVecCollectAssoc(expr: UirExpr, op: UirBinOp, out: UirExpr[]): bool =
    if expr <= 0:
        return false
    if uirExprKindOf(expr) == meBin && uirExprBinOpOf(expr) == op:
        if !uirLoopVecCollectAssoc(uirExprLhsOf(expr), op, out):
            return false
        if !uirLoopVecCollectAssoc(uirExprRhsOf(expr), op, out):
            return false
        return true
    if !uirLoopVecExprPureLeaf(expr):
        return false
    add(out, expr)
    return true

fn uirLoopVecBuildBalanced(op: UirBinOp, terms: UirExpr[], lo: int32, hi: int32): UirExpr =
    if hi <= lo:
        return nil
    if hi - lo == 1:
        return terms[lo]
    let mid: int32 = lo + ((hi - lo) / 2)
    let lhs: UirExpr = uirLoopVecBuildBalanced(op, terms, lo, mid)
    let rhs: UirExpr = uirLoopVecBuildBalanced(op, terms, mid, hi)
    return uirCoreBin(op, lhs, rhs)

fn uirLoopVecRebalanceExpr(expr: UirExpr, width: int32, changedExprs: ptr): UirExpr =
    if expr <= 0:
        return nil
    let kind: UirExprKind = uirExprKindOf(expr)
    var cur: UirExprId = expr
    if kind == meBin || kind == meCmp:
        uirCoreExprSetLhs(cur, uirLoopVecRebalanceExpr(uirCoreExprLhsOf(cur), width, changedExprs))
        uirCoreExprSetRhs(cur, uirLoopVecRebalanceExpr(uirCoreExprRhsOf(cur), width, changedExprs))
    elif kind == meCall:
        for ai in 0..<uirCoreExprArgsLen(cur):
            uirCoreExprSetArgAt(cur, ai, uirLoopVecRebalanceExpr(uirCoreExprArgAt(cur, ai), width, changedExprs))
    elif kind == meCast:
        uirCoreExprSetCastExpr(cur, uirLoopVecRebalanceExpr(uirCoreExprCastExprOf(cur), width, changedExprs))
    elif kind == meLoad:
        uirCoreExprSetAddrExpr(cur, uirLoopVecRebalanceExpr(uirCoreExprAddrExprOf(cur), width, changedExprs))

    if kind != meBin:
        return cur
    let op: UirBinOp = uirExprBinOpOf(cur)
    if !uirLoopVecAssocBin(op):
        return cur
    var terms: UirExpr[]
    if !uirLoopVecCollectAssoc(cur, op, terms):
        return cur
    if terms.len < width:
        return cur
    let beforeKey: str = uirLoopVecExprKey(cur)
    let cand: UirExpr = uirLoopVecBuildBalanced(op, terms, 0, terms.len)
    let afterKey: str = uirLoopVecExprKey(cand)
    if uirStrCmp(beforeKey, afterKey) == 0:
        return cur
    if changedExprs != nil:
        *changedExprs = *changedExprs + 1
    return cand

fn uirVectorizeLoops(module: UirModule, maxWidth: int32, policy: str): bool =
    if module == nil:
        return false
    let policyNorm: str = uirLoopVecPolicyNormalize(policy)
    if policyNorm == "none" || policyNorm == "slp":
        return false
    let loops: UirLoopInfo = uirAnalyzeLoops(module)
    let restrictToLoopWindows: bool = loops.loopCount > 0
    let d: UirVecCostDecision = uirDecideVecWidth(module, maxWidth)
    if !d.enable || d.width <= 1:
        return false
    var changed: bool = false
    var vectorizedBlocks: int32 = 0
    var vectorizedExprs: int32 = 0
    for fi in 0..<uirModuleFuncsLen(module):
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if funcView == nil || uirFuncIsExtern(funcView):
            continue
        if restrictToLoopWindows && !uirLoopInfoHasLoopInFunc(loops, fi):
            continue
        let func: UirCoreFunc = funcView
        let blockCount: int32 = uirCoreFuncBlocksLen(func)
        for bi in 0..<blockCount:
            if restrictToLoopWindows && !uirLoopInfoBlockIsInLoopWindow(loops, fi, bi):
                continue
            let blkView: UirLowerBlock = uirCoreFuncBlockAt(func, bi)
            if blkView <= 0:
                continue
            var blk: UirBlockId = blkView
            let beforeExprs: int32 = vectorizedExprs
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            for si in 0..<stmtCount:
                var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                st = uirCoreStmtWithExpr(st, uirLoopVecRebalanceExpr(uirCoreStmtExprOf(st), d.width, &vectorizedExprs))
                if uirCoreStmtKindOf(st) == msStore:
                    st = uirCoreStmtWithAddrExpr(st, uirLoopVecRebalanceExpr(uirCoreStmtAddrExprOf(st), d.width, &vectorizedExprs))
                uirCoreBlockSetStmtAt(blk, si, st)
            let term: UirCoreTerm = uirCoreBlockTermOf(blk)
            if uirCoreTermKindOf(term) == mtRet:
                uirCoreBlockSetTerm(blk, uirCoreTermWithRetExpr(
                    term, uirLoopVecRebalanceExpr(uirCoreTermRetExprOf(term), d.width, &vectorizedExprs)))
            elif uirCoreTermKindOf(term) == mtCbr:
                uirCoreBlockSetTerm(blk, uirCoreTermWithCondExpr(
                    term, uirLoopVecRebalanceExpr(uirCoreTermCondExprOf(term), d.width, &vectorizedExprs)))
            if vectorizedExprs > beforeExprs:
                vectorizedBlocks = vectorizedBlocks + 1
                changed = true
            uirCoreFuncSetBlockAt(func, bi, blk)
    if os.getEnvDefault("UIR_SIMD_REPORT", "0") == "1":
        let f: os.File = os.get_stderr()
        os.write(f, "simd_loop_report\tpolicy=")
        os.write(f, policyNorm)
        os.write(f, "\twidth=")
        os.write(f, intToStr(d.width))
        os.write(f, "\tloops=")
        os.write(f, intToStr(loops.loopCount))
        os.write(f, "\tbackedges=")
        os.write(f, intToStr(loops.backEdgeCount))
        os.write(f, "\treducible=")
        os.write(f, intToStr(loops.reducibleCount))
        os.write(f, "\tvec_blocks=")
        os.write(f, intToStr(vectorizedBlocks))
        os.write(f, "\tvec_exprs=")
        os.write(f, intToStr(vectorizedExprs))
        os.write(f, "\tscore=")
        os.writeLine(f, intToStr(d.score))
        os.c_fflush f
    return changed
