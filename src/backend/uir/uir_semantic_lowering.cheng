import backend/uir/uir_internal/uir_core_types

fn uirSemanticRustReportLine(report: UirRustReportV1): str =
    if report == nil:
        return "rust_uir_report\tmono_items_total=0\tmono_items_uir=0\tmono_items_llvm_fallback=0\tunsafe_regions=0\tborrow_proof_items=0\tms=0"
    return "rust_uir_report\tmono_items_total=" + intToStr(report.monoItemsTotal) +
           "\tmono_items_uir=" + intToStr(report.monoItemsUir) +
           "\tmono_items_llvm_fallback=" + intToStr(report.monoItemsLlvmFallback) +
           "\tunsafe_regions=" + intToStr(report.unsafeRegions) +
           "\tborrow_proof_items=" + intToStr(report.borrowProofItems) +
           "\tms=" + intToStr(report.elapsedMs)

fn uirSemanticGenericsReportLine(frontend: str, report: UirRustReportV1): str =
    if frontend == "rust":
        let total: int32 = report != nil ? report.monoItemsTotal : 0
        return "generics_report\tir=uir\tmode=rustc_mono\tinstances_total=" + intToStr(total) +
               "\trustc_mono_items=" + intToStr(total)
    return ""

fn uirSemanticBuildFallbackResult(reason: str, rustReport: UirRustReportV1): UirSemanticCompileResultV1 =
    let out: UirSemanticCompileResultV1 = uirSemanticCompileResultV1New()
    out.ok = true
    out.fallbackUsed = true
    out.fallbackReason = reason
    out.rustReport = rustReport
    out.reportText = "status=fallback\nfallback_reason=" + reason + "\n" + uirSemanticRustReportLine(rustReport) +
                     "\n" + uirSemanticGenericsReportLine("rust", rustReport)
    return out

fn uirSemanticParseBoolDefault(raw: str, defaultValue: bool = false): bool =
    var out: bool = defaultValue
    cmdline.ParseBool(strutils.Strip(raw), out)
    return out

fn uirSemanticParseIntDefault(raw: str, defaultValue: int32 = 0): int32 =
    var out: int32 = defaultValue
    cmdline.ParseInt32(strutils.Strip(raw), out)
    return out

fn uirSemanticParseI64Default(raw: str, defaultValue: int64 = 0): int64 =
    var out: int64 = 0
    if uirSemanticParseI64Decimal(raw, out):
        return out
    if uirSemanticParseI64Hex(raw, out):
        return out
    return defaultValue

fn uirSemanticAppendStr(seqInst: var str[], val: str) =
    let idx: int32 = seqInst.len
    let needLen: int32 = idx + 1
    if seqInst.buffer == nil || seqInst.cap < needLen:
        reserve(seqInst, needLen)
    setLen(seqInst, needLen)
    seqInst[idx] = val

