import std/system

importc fn driver_c_build_module_stage1_direct(input_path: cstring, target: cstring): void*

fn uirBootstrapBuildActiveModulePtrs(input_raw: cstring, target_raw: cstring): void* =
    if input_raw == nil:
        return nil
    return driver_c_build_module_stage1_direct(input_raw, target_raw)
