import cheng/web/std/server_http

type
    ServerMiddleware = fn (req: HttpRequest, next: ServerHandler): HttpResponse

fn applyMiddleware(handler: ServerHandler, chain: seq[ServerMiddleware]): ServerHandler =
    if handler == nil:
        return nil
    if len(chain) == 0:
        return handler
    var current = handler
    var i: int32 = len(chain) - 1
    while i >= 0:
        let currMw = chain[i]
        if currMw != nil:
            let nextHandler = current
            current = fn (req: HttpRequest): HttpResponse =
                return currMw(req, nextHandler)
        i = i - 1
    return current
