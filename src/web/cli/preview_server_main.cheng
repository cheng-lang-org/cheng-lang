import cmdline
import web/cli/preview_server

@importc("cheng_native_server_main")
fn cheng_native_server_main(argc: int32, argv: ptr): int32

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    if ! preview_server.initPreviewServer():
        return preview_server.previewServerExitCode()
    return cheng_native_server_main(argc, argv)
