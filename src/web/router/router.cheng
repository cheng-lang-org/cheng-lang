import cheng/web/std/web_url
import std/strings

type
    RouteSegmentKind = enum
        rsStatic
        rsParam
        rsSplat

    RouteSegment =
        kind: RouteSegmentKind
        token: str

    RoutePattern =
        raw: str
        segments: seq[RouteSegment]

    RouteParam =
        key: str
        value: str

    RouteParams =
        items: seq[RouteParam]

    QueryParam =
        key: str
        value: str

    QueryParams =
        items: seq[QueryParam]

    RouteEntry =
        id: int32
        path: str
        file: str

    RoutePathInfo =
        raw: str
        path: str
        query: str
        hash: str
        queryParams: QueryParams

    Route =
        id: int32
        pattern: RoutePattern

    RouteMatch =
        ok: bool
        id: int32
        params: RouteParams

fn startsWithAt(s: str, prefix: str, start: int32): bool =
    if s == nil || prefix == nil:
        return false
    if start < 0 || len(prefix) == 0:
        return false
    if start + len(prefix) > len(s):
        return false
    var i: int32 = 0
    while i < len(prefix):
        if charAt(s, start + i) != charAt(prefix, i):
            return false
        i = i + 1
    return true

fn endsWith(s: str, suffix: str): bool =
    if s == nil || suffix == nil:
        return false
    let sLen: int32 = len(s)
    let pLen: int32 = len(suffix)
    if pLen == 0 || sLen < pLen:
        return false
    var i: int32 = 0
    while i < pLen:
        if charAt(s, sLen - pLen + i) != charAt(suffix, i):
            return false
        i = i + 1
    return true

fn stripSuffix(name: str, suffix: str): str =
    if ! endsWith(name, suffix):
        return name
    return substr(name, 0, len(name) - len(suffix))

fn stripQueryHash(path: str): str =
    if path == nil:
        return ""
    var endIdx: int32 = len(path)
    var i: int32 = 0
    while i < len(path):
        let c: char = charAt(path, i)
        if c == '?' || c == '#':
            endIdx = i
            break
        i = i + 1
    if endIdx == len(path):
        return path
    return substr(path, 0, endIdx)

fn parsePathInfo(raw: str): RoutePathInfo =
    var out: RoutePathInfo
    var src: str = raw
    if src == nil || len(src) == 0:
        src = "/"
    out.raw = src
    var queryIdx: int32 = -1
    var hashIdx: int32 = -1
    var i: int32 = 0
    while i < len(src):
        let c: char = charAt(src, i)
        if c == '?' && queryIdx < 0 && hashIdx < 0:
            queryIdx = i
        elif c == '#' && hashIdx < 0:
            hashIdx = i
            break
        i = i + 1
    if queryIdx >= 0:
        let endIdx = if hashIdx >= 0: hashIdx else: len(src)
        out.query = substr(src, queryIdx + 1, endIdx - queryIdx - 1)
    if hashIdx >= 0:
        out.hash = substr(src, hashIdx + 1, len(src) - hashIdx - 1)
    var pathEnd: int32 = len(src)
    if queryIdx >= 0 && queryIdx < pathEnd:
        pathEnd = queryIdx
    if hashIdx >= 0 && hashIdx < pathEnd:
        pathEnd = hashIdx
    if pathEnd <= 0:
        out.path = "/"
    else:
        out.path = cleanPath(substr(src, 0, pathEnd))
    out.queryParams = parseQueryParams(out.query)
    return out

fn cleanPath(path: str): str =
    let stripped = stripQueryHash(path)
    if stripped == nil || len(stripped) == 0:
        return "/"
    return stripped

fn indexOfChar(s: str, target: char, start: int32): int32 =
    if s == nil:
        return -1
    var i: int32 = start
    while i < len(s):
        if charAt(s, i) == target:
            return i
        i = i + 1
    return -1

fn addQueryParam(params: var QueryParams, key: str, value: str) =
    if key == nil || len(key) == 0:
        return
    var item: QueryParam
    item.key = key
    item.value = value
    params.items.add(item)

fn parseQueryParams(query: str): QueryParams =
    var out: QueryParams
    out.items = newSeq[QueryParam]()
    if query == nil || len(query) == 0:
        return out
    var start: int32 = 0
    var i: int32 = 0
    while i <= len(query):
        if i == len(query) || charAt(query, i) == '&':
            let size: int32 = i - start
            if size > 0:
                let eq = indexOfChar(query, '=', start)
                if eq >= 0 && eq < i:
                    let rawKey = substr(query, start, eq - start)
                    let rawValue = substr(query, eq + 1, i - eq - 1)
                    let key = urlDecodeComponent(rawKey)
                    let value = urlDecodeComponent(rawValue)
                    addQueryParam(out, key, value)
                else:
                    let rawKey = substr(query, start, size)
                    let key = urlDecodeComponent(rawKey)
                    addQueryParam(out, key, "")
            start = i + 1
        i = i + 1
    return out

fn queryGet(params: QueryParams, key: str): str =
    if key == nil:
        return ""
    var i: int32 = 0
    while i < len(params.items):
        let item = params.items[i]
        if item.key == key:
            return item.value
        i = i + 1
    return ""

fn splitPath(path: str): seq[str] =
    let clean = cleanPath(path)
    var out: seq[str] = newSeq[str]()
    var start: int32 = 0
    while start < len(clean) && charAt(clean, start) == '/':
        start = start + 1
    var i: int32 = start
    while i <= len(clean):
        if i == len(clean) || charAt(clean, i) == '/':
            let size: int32 = i - start
            if size > 0:
                out.add(substr(clean, start, size))
            start = i + 1
        i = i + 1
    return out

fn joinSegments(segs: seq[str], start: int32, stop: int32): str =
    if start >= stop:
        return ""
    var out: str = ""
    var i: int32 = start
    while i < stop:
        if len(out) > 0:
            out = out + "/"
        out = out + segs[i]
        i = i + 1
    return out

fn parseSegment(seg: str): RouteSegment =
    var out: RouteSegment
    out.kind = rsStatic
    out.token = seg
    if seg == nil || len(seg) == 0:
        return out
    if seg == "*":
        out.kind = rsSplat
        out.token = "splat"
        return out
    if charAt(seg, 0) == '[' && charAt(seg, len(seg) - 1) == ']':
        let inner = substr(seg, 1, len(seg) - 2)
        if startsWithAt(inner, "...", 0):
            out.kind = rsSplat
            out.token = substr(inner, 3, len(inner) - 3)
            if len(out.token) == 0:
                out.token = "rest"
        else:
            out.kind = rsParam
            out.token = inner
        return out
    return out

fn parseRoutePattern(raw: str): RoutePattern =
    var out: RoutePattern
    out.raw = raw
    out.segments = newSeq[RouteSegment]()
    let parts = splitPath(raw)
    var i: int32 = 0
    while i < len(parts):
        out.segments.add(parseSegment(parts[i]))
        i = i + 1
    return out

fn newRoute(id: int32, raw: str): Route =
    var out: Route
    out.id = id
    out.pattern = parseRoutePattern(raw)
    return out

fn addParam(params: var RouteParams, key: str, value: str) =
    var p: RouteParam
    p.key = key
    p.value = value
    params.items.add(p)

fn paramGet(params: RouteParams, key: str): str =
    var i: int32 = 0
    while i < len(params.items):
        let item = params.items[i]
        if item.key == key:
            return item.value
        i = i + 1
    return ""

fn matchPattern(pattern: RoutePattern, path: str): RouteMatch =
    var out: RouteMatch
    out.ok = false
    out.id = -1
    out.params.items = newSeq[RouteParam]()
    let segs = pattern.segments
    let parts = splitPath(path)
    var i: int32 = 0
    var j: int32 = 0
    while i < len(segs):
        let seg = segs[i]
        if seg.kind == rsSplat:
            let rest = joinSegments(parts, j, len(parts))
            addParam(out.params, seg.token, rest)
            j = len(parts)
            i = len(segs)
            break
        if j >= len(parts):
            return out
        if seg.kind == rsStatic:
            if parts[j] != seg.token:
                return out
        elif seg.kind == rsParam:
            addParam(out.params, seg.token, parts[j])
        i = i + 1
        j = j + 1
    if j != len(parts):
        return out
    out.ok = true
    return out

fn matchRoutes(routes: seq[Route], path: str): RouteMatch =
    var i: int32 = 0
    while i < len(routes):
        var res = matchPattern(routes[i].pattern, path)
        if res.ok:
            res.id = routes[i].id
            return res
        i = i + 1
    var miss: RouteMatch
    miss.ok = false
    miss.id = -1
    miss.params.items = newSeq[RouteParam]()
    return miss

fn filePathToRoute(path: str): str =
    if path == nil || len(path) == 0:
        return "/"
    var p = path
    if startsWithAt(p, "./", 0):
        p = substr(p, 2, len(p) - 2)
    p = stripSuffix(p, ".cwc")
    p = stripSuffix(p, ".cheng")
    if endsWith(p, "/index"):
        p = substr(p, 0, len(p) - len("/index"))
    elif p == "index":
        p = ""
    if len(p) == 0:
        return "/"
    if charAt(p, 0) != '/':
        p = "/" + p
    return p
