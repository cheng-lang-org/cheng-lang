module option
type
    Option[T] =
        has: bool
        value: T
fn Some(value: T): Option[T] =
    Option[T](has: true, value: value)
fn None(): Option[T] =
    var out: Option[T]
    out.has = false
    return out
fn some(value: T): Option[T] =
    Option[T](has: true, value: value)
fn none(t: typedesc[T]): Option[T] =
    t
    var out: Option[T]
    out.has = false
    return out
fn IsSome(opt: Option[T]): bool =
    opt.has
fn Get(opt: Option[T]): T =
    opt.value
