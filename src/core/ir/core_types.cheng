import std/strformat

type
    NameId = int32

    ModuleId = int32

    FuncId = int32

    BlockId = int32

    TypeId = int32

    ValueId = int32

    StackSlotId = int32

type
    AbiClass = enum
        AbiNone,
        AbiScalar,
        AbiPointer,
        AbiAggregate,
        AbiVector

type
    LayoutKind = enum
        LayoutInvalid,
        LayoutVoid,
        LayoutI1,
        LayoutI8,
        LayoutI16,
        LayoutI32,
        LayoutI64,
        LayoutFixedBytes,
        LayoutArray,
        LayoutRecord,
        LayoutPointer

type
    OwnershipKind = enum
        OwnInvalid,
        OwnPlain,
        OwnMove,
        OwnBorrowShared,
        OwnBorrowUnique

type
    AliasClass = enum
        AliasUnknown,
        AliasUnique,
        AliasNoAlias,
        AliasMayAlias

type
    EscapeKind = enum
        EscapeInvalid,
        EscapeNone,
        EscapeArg,
        EscapeReturn,
        EscapeGlobal

type
    ValueKind = enum
        ValueInvalid,
        ValueImmediate,
        ValueStack,
        ValueAddress,
        ValueBorrow,
        ValuePhi,
        ValueCallResult

type
    HirExprKind = enum
        HirInvalid,
        HirIntLiteral,
        HirBytesLiteral,
        HirNameRef,
        HirCall,
        HirField,
        HirIndex,
        HirBorrow,
        HirMove

type
    MirOpKind = enum
        MirInvalid,
        MirConst,
        MirMove,
        MirBorrow,
        MirLoad,
        MirStore,
        MirAddrOf,
        MirCall,
        MirPhi,
        MirRet,
        MirTrap

type
    CallConv = enum
        CallInvalid,
        CallInternal,
        CallC

type
    LirInsnKind = enum
        LirInvalid,
        LirMove,
        LirLoad,
        LirStore,
        LirCall,
        LirRet,
        LirTrap

type
    BodyOpKind = enum
        BodyOpInvalid,
        BodyOpLoadConst,
        BodyOpCall,
        BodyOpBinOp,
        BodyOpCmp,
        BodyOpBranch,
        BodyOpReturn,
        BodyOpLoadLocal,
        BodyOpStoreLocal,
        BodyOpCopyLocal,
        BodyOpResultProject

type
    LocalType = enum
        LocalInvalid,
        LocalI32,
        LocalF64,
        LocalStr,
        LocalPtr

const
    BodyOpInvalidTag = 0
    BodyOpLoadConstTag = 1
    BodyOpCallTag = 2
    BodyOpBinOpTag = 3
    BodyOpCmpTag = 4
    BodyOpBranchTag = 5
    BodyOpReturnTag = 6
    BodyOpLoadLocalTag = 7
    BodyOpStoreLocalTag = 8
    BodyOpCopyLocalTag = 9
    BodyOpResultProjectTag = 10
    BodyOpStrEqLiteralTag = 11
    AbiScalarTag = 1
    AbiAggregateTag = 3
    LayoutFixedBytesTag = 7
    OwnPlainTag = 1
    AliasUnknownTag = 0
    EscapeInvalidTag = 0
    EscapeNoneTag = 1
    LocalInvalidTag = 0
    LocalI32Tag = 1
    LocalF64Tag = 2
    LocalStrTag = 3
    LocalPtrTag = 4
    LocalAggregateTag = 5
    BodyBranchIfLocalNilReturnI32ConstTag = 1
    BodyBranchIfLocalLeZeroReturnI32ConstTag = 2
    BodyBranchIfLocalLeZeroReturnCallNoargTag = 3
    BodyBranchIfLocalLeZeroCallArg0ReturnI32ConstTag = 4
    BodyLoadLocalPtrDerefI32Tag = 1
    BodyTermInvalidTag = 0
    BodyTermReturnTag = 1
    BodyTermBrTag = 2
    BodyTermCbrTag = 3
    BodyCondInvalidTag = 0
    BodyCondLocalNonZeroTag = 1
    BodyCondLocalZeroTag = 2
    BodyCondI32EqTag = 3
    BodyCondI32NeTag = 4
    BodyCondI32LtTag = 5
    BodyCondI32LeTag = 6
    BodyCondI32GtTag = 7
    BodyCondI32GeTag = 8
    BodyResultProjectInvalidTag = 0
    BodyResultProjectIsErrTag = 1
    BodyResultProjectErrorStrTag = 2
    BodyResultProjectValueStrTag = 3
    ResultStrOkOffset = 0
    ResultStrValueOffset = 8
    ResultStrErrCodeOffset = 32
    ResultStrErrMsgOffset = 40
    ResultStrSizeBytes = 64
    ResultStrAlignBytes = 16

type
    TypeLayout =
        kind: LayoutKind
        abiClass: AbiClass
        size: int32
        align: int32
        fixedCount: int32
        fieldCount: int32
        isTriviallyMoveable: bool
        isTriviallyDrop: bool

    Place =
        baseValue: ValueId
        typeId: TypeId
        offset: int32
        fieldOrdinal: int32
        ownership: OwnershipKind
        aliasClass: AliasClass
        escapeKind: EscapeKind

    BorrowFact =
        ownerValue: ValueId
        place: Place
        borrowKind: OwnershipKind
        aliasClass: AliasClass
        escapeKind: EscapeKind
        scopeDepth: int32

    MirValue =
        id: ValueId
        typeId: TypeId
        kind: ValueKind
        ownership: OwnershipKind
        aliasClass: AliasClass
        escapeKind: EscapeKind
        stackSlot: StackSlotId
        immLo: int64
        immHi: int64

    MirOp =
        kind: MirOpKind
        result: ValueId
        src0: ValueId
        src1: ValueId
        src2: ValueId
        place: Place
        callConv: CallConv
        calleeNameId: NameId
        trapTextId: NameId

    MirStackSlot =
        id: StackSlotId
        typeId: TypeId
        offset: int32
        size: int32
        align: int32
        noAlias: bool

    MirBlock =
        id: BlockId
        opStart: int32
        opCount: int32

    MirFunction = ref
        id: FuncId
        nameId: NameId
        paramCount: int32
        resultTypeId: TypeId
        stackSlots: MirStackSlot[]
        values: MirValue[]
        borrowFacts: BorrowFact[]
        ops: MirOp[]
        blocks: MirBlock[]

    LirInsn =
        kind: LirInsnKind
        dstReg: int32
        srcReg0: int32
        srcReg1: int32
        stackSlot: StackSlotId
        callConv: CallConv
        calleeNameId: NameId

    BodyOp =
        kind: int32
        operands: int32[]
        target: int32

    BodyBlock =
        id: int32
        opStart: int32
        opCount: int32
        termIndex: int32

    BodyTerm =
        kind: int32
        conditionKind: int32
        resultSlot: int32
        lhsSlot: int32
        rhsSlot: int32
        trueBlock: int32
        falseBlock: int32
        operands: int32[]

    LocalSlot =
        id: int32
        name: str
        typeKind: int32
        stackOffset: int32
        sizeBytes: int32
        alignBytes: int32
        ownership: OwnershipKind
        aliasClass: AliasClass
        escapeKind: EscapeKind
        noAlias: bool

    CallOp =
        targetSymbol: str
        argSlots: int32[]
        resultSlot: int32
        relocWordOffset: int32

    CStringLiteralEntry =
        id: int32
        text: str
        dataLabel: str

    BodyIR =
        ops: BodyOp[]
        callSequence: CallOp[]
        localSlots: LocalSlot[]
        blocks: BodyBlock[]
        terms: BodyTerm[]
        cstringLiterals: CStringLiteralEntry[]

    BodyIRFlatSoA =
        opKinds: int32[]
        opTargets: int32[]
        opOperandStarts: int32[]
        opOperandCounts: int32[]
        operands: int32[]
        callTargetSymbols: str[]
        callResultSlots: int32[]
        callRelocWordOffsets: int32[]
        callArgStarts: int32[]
        callArgCounts: int32[]
        callArgSlots: int32[]
        localIds: int32[]
        localTypeKinds: int32[]
        localStackOffsets: int32[]
        localSizeBytes: int32[]
        localAlignBytes: int32[]
        localOwnershipKinds: int32[]
        localAliasClasses: int32[]
        localEscapeKinds: int32[]
        localNoAliasFlags: int32[]
        blockIds: int32[]
        blockOpStarts: int32[]
        blockOpCounts: int32[]
        blockTermIndices: int32[]
        termKinds: int32[]
        termCondKinds: int32[]
        termResultSlots: int32[]
        termLhsSlots: int32[]
        termRhsSlots: int32[]
        termTrueBlocks: int32[]
        termFalseBlocks: int32[]
        cstringIds: int32[]
        cstringTexts: str[]
        cstringDataLabels: str[]

    BodyIRDodSoAContractReport =
        ok: bool
        indexWidthBits: int32
        independentArrayCount: int32
        flatScalarArrayCount: int32
        flatStringArrayCount: int32
        nestedPayloadArrayCount: int32
        opCount: int32
        callCount: int32
        localCount: int32
        blockCount: int32
        termCount: int32
        cstringCount: int32
        localRefCount: int32
        blockRefCount: int32
        termRefCount: int32
        callRefCount: int32
        cstringRefCount: int32
        encodedParamRefCount: int32
        invalidRefCount: int32
        pointerKeyCount: int32
        firstInvalidRefOwner: str
        firstInvalidRefValue: int32
        firstInvalidRefLimit: int32

    LirFunction = ref
        id: FuncId
        nameId: NameId
        stackSlots: MirStackSlot[]
        insns: LirInsn[]

fn InvalidTypeId(): TypeId =
    return -1

fn InvalidValueId(): ValueId =
    return -1

fn InvalidStackSlotId(): StackSlotId =
    return -1

fn CallArgSlotMissing(): int32 =
    return 0 - 2147483647

fn CallArgSlotConstTrue(): int32 =
    return 0 - 2147483646

fn CallArgSlotConstFalse(): int32 =
    return 0 - 2147483645

fn CallArgSlotIsConst(slot: int32): bool =
    return slot == CallArgSlotConstTrue() ||
           slot == CallArgSlotConstFalse()

fn CallArgSlotConstI32Value(slot: int32): int32 =
    if slot == CallArgSlotConstTrue():
        return 1
    if slot == CallArgSlotConstFalse():
        return 0
    return 0

fn TypeLayoutInvalid(): TypeLayout =
    var out: TypeLayout
    return out

fn TypeLayoutScalar(kind: int32, size: int32, align: int32): TypeLayout =
    var out: TypeLayout
    out.kind = kind
    out.abiClass = AbiScalarTag
    out.size = size
    out.align = align
    out.isTriviallyMoveable = true
    out.isTriviallyDrop = true
    return out

fn TypeLayoutFixedBytes(size: int32, align: int32): TypeLayout =
    var out: TypeLayout
    out.kind = LayoutFixedBytesTag
    out.abiClass = AbiAggregateTag
    out.size = size
    out.align = align
    out.fixedCount = size
    out.isTriviallyMoveable = true
    out.isTriviallyDrop = true
    return out

fn PlaceRoot(baseValue: ValueId, typeId: TypeId): Place =
    var out: Place
    out.baseValue = baseValue
    out.typeId = typeId
    out.fieldOrdinal = -1
    out.ownership = OwnPlainTag
    out.aliasClass = AliasUnknownTag
    out.escapeKind = EscapeInvalidTag
    return out

fn IsOwnershipNoAlias(ownership: OwnershipKind, alias: AliasClass): bool =
    return (ownership == OwnBorrowUnique || ownership == OwnMove || ownership == OwnPlain) &&
           (alias == AliasNoAlias || alias == AliasUnique)

fn MirFunctionNew(nameId: NameId): MirFunction =
    var out: MirFunction
    out.id = -1
    out.nameId = nameId
    out.paramCount = 0
    out.resultTypeId = InvalidTypeId()
    out.stackSlots = []
    out.values = []
    out.borrowFacts = []
    out.ops = []
    out.blocks = []
    return out

fn LirFunctionNew(nameId: NameId): LirFunction =
    var out: LirFunction
    out.id = -1
    out.nameId = nameId
    out.stackSlots = []
    out.insns = []
    return out

fn BodyIRNew(): BodyIR =
    var out: BodyIR
    return out

fn BodyIRAppendCStringLiteral(bodyIR: var BodyIR,
                               text: str,
                               dataLabel: str): int32 =
    var entry: CStringLiteralEntry
    entry.id = bodyIR.cstringLiterals.len
    entry.text = text
    entry.dataLabel = dataLabel
    add(bodyIR.cstringLiterals, entry)
    return entry.id

fn BodyIRAppendBlock(bodyIR: var BodyIR,
                     opStart: int32,
                     opCount: int32,
                     termIndex: int32): int32 =
    var block: BodyBlock
    block.id = bodyIR.blocks.len
    block.opStart = opStart
    block.opCount = opCount
    block.termIndex = termIndex
    add(bodyIR.blocks, block)
    return block.id

fn BodyIRAppendTerm(bodyIR: var BodyIR, term: BodyTerm): int32 =
    let termIndex = bodyIR.terms.len
    add(bodyIR.terms, term)
    return termIndex

fn BodyIRLocalTypePlainNoAliasProof(typeKind: int32): bool =
    return typeKind == LocalI32Tag ||
           typeKind == LocalF64Tag

fn BodyIRApplyLocalSlotDefaultProof(slot: var LocalSlot) =
    slot.ownership = OwnPlain
    slot.aliasClass = AliasUnknown
    slot.escapeKind = EscapeNone
    slot.noAlias = false
    if BodyIRLocalTypePlainNoAliasProof(slot.typeKind):
        slot.aliasClass = AliasNoAlias
        slot.noAlias = true

fn BodyIRFlattenSoA(bodyIR: BodyIR): BodyIRFlatSoA =
    var out: BodyIRFlatSoA
    for opIndex in 0..<bodyIR.ops.len:
        let op = bodyIR.ops[opIndex]
        add(out.opKinds, op.kind)
        add(out.opTargets, op.target)
        add(out.opOperandStarts, out.operands.len)
        add(out.opOperandCounts, op.operands.len)
        for operandIndex in 0..<op.operands.len:
            add(out.operands, op.operands[operandIndex])
    for callIndex in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[callIndex]
        add(out.callTargetSymbols, callOp.targetSymbol)
        add(out.callResultSlots, callOp.resultSlot)
        add(out.callRelocWordOffsets, callOp.relocWordOffset)
        add(out.callArgStarts, out.callArgSlots.len)
        add(out.callArgCounts, callOp.argSlots.len)
        for argIndex in 0..<callOp.argSlots.len:
            add(out.callArgSlots, callOp.argSlots[argIndex])
    for localIndex in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[localIndex]
        add(out.localIds, slot.id)
        add(out.localTypeKinds, slot.typeKind)
        add(out.localStackOffsets, slot.stackOffset)
        add(out.localSizeBytes, slot.sizeBytes)
        add(out.localAlignBytes, slot.alignBytes)
        add(out.localOwnershipKinds, int32(slot.ownership))
        add(out.localAliasClasses, int32(slot.aliasClass))
        add(out.localEscapeKinds, int32(slot.escapeKind))
        if slot.noAlias:
            add(out.localNoAliasFlags, 1)
        else:
            add(out.localNoAliasFlags, 0)
    for blockIndex in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[blockIndex]
        add(out.blockIds, block.id)
        add(out.blockOpStarts, block.opStart)
        add(out.blockOpCounts, block.opCount)
        add(out.blockTermIndices, block.termIndex)
    for termIndex in 0..<bodyIR.terms.len:
        let term = bodyIR.terms[termIndex]
        add(out.termKinds, term.kind)
        add(out.termCondKinds, term.condKind)
        add(out.termResultSlots, term.resultSlot)
        add(out.termLhsSlots, term.lhsSlot)
        add(out.termRhsSlots, term.rhsSlot)
        add(out.termTrueBlocks, term.trueBlock)
        add(out.termFalseBlocks, term.falseBlock)
    for literalIndex in 0..<bodyIR.cstringLiterals.len:
        let literal = bodyIR.cstringLiterals[literalIndex]
        add(out.cstringIds, literal.id)
        add(out.cstringTexts, literal.text)
        add(out.cstringDataLabels, literal.dataLabel)
    return out

fn BodyIRFlatSoAScalarArrayCount(): int32 =
    return 32

fn BodyIRFlatSoAStringArrayCount(): int32 =
    return 3

fn BodyIRFlatSoAIsAligned(flat: BodyIRFlatSoA): bool =
    if flat.opKinds.len != flat.opTargets.len ||
       flat.opKinds.len != flat.opOperandStarts.len ||
       flat.opKinds.len != flat.opOperandCounts.len:
        return false
    if flat.callTargetSymbols.len != flat.callResultSlots.len ||
       flat.callTargetSymbols.len != flat.callRelocWordOffsets.len ||
       flat.callTargetSymbols.len != flat.callArgStarts.len ||
       flat.callTargetSymbols.len != flat.callArgCounts.len:
        return false
    if flat.localIds.len != flat.localTypeKinds.len ||
       flat.localIds.len != flat.localStackOffsets.len ||
       flat.localIds.len != flat.localSizeBytes.len ||
       flat.localIds.len != flat.localAlignBytes.len ||
       flat.localIds.len != flat.localOwnershipKinds.len ||
       flat.localIds.len != flat.localAliasClasses.len ||
       flat.localIds.len != flat.localEscapeKinds.len ||
       flat.localIds.len != flat.localNoAliasFlags.len:
        return false
    if flat.blockIds.len != flat.blockOpStarts.len ||
       flat.blockIds.len != flat.blockOpCounts.len ||
       flat.blockIds.len != flat.blockTermIndices.len:
        return false
    if flat.termKinds.len != flat.termCondKinds.len ||
       flat.termKinds.len != flat.termResultSlots.len ||
       flat.termKinds.len != flat.termLhsSlots.len ||
       flat.termKinds.len != flat.termRhsSlots.len ||
       flat.termKinds.len != flat.termTrueBlocks.len ||
       flat.termKinds.len != flat.termFalseBlocks.len:
        return false
    if flat.cstringIds.len != flat.cstringTexts.len ||
       flat.cstringIds.len != flat.cstringDataLabels.len:
        return false
    return true

fn bodyIRDodBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn bodyIRDodBodyOpKindValid(kind: int32): bool =
    return kind >= BodyOpLoadConstTag && kind <= BodyOpStrEqLiteralTag

fn bodyIRDodBodyTermKindValid(kind: int32): bool =
    return kind >= BodyTermReturnTag && kind <= BodyTermCbrTag

fn bodyIRDodBodyCondKindValid(kind: int32): bool =
    return kind >= BodyCondLocalNonZeroTag && kind <= BodyCondI32GeTag

fn bodyIRDodMarkInvalid(report: var BodyIRDodSoAContractReport,
                         owner: str,
                         value: int32,
                         limit: int32) =
    if report.invalidRefCount == 0:
        report.firstInvalidRefOwner = owner
        report.firstInvalidRefValue = value
        report.firstInvalidRefLimit = limit
    report.invalidRefCount = report.invalidRefCount + 1
    report.ok = false

fn bodyIRDodCheckLocalRef(report: var BodyIRDodSoAContractReport,
                           owner: str,
                           value: int32,
                           limit: int32) =
    report.localRefCount = report.localRefCount + 1
    if value < 0 || value >= limit:
        bodyIRDodMarkInvalid(report, owner, value, limit)

fn bodyIRDodCheckMaybeLocalRef(report: var BodyIRDodSoAContractReport,
                                owner: str,
                                value: int32,
                                limit: int32) =
    if value < 0:
        return
    bodyIRDodCheckLocalRef(report, owner, value, limit)

fn bodyIRDodCheckCallArgRef(report: var BodyIRDodSoAContractReport,
                             owner: str,
                             value: int32,
                             limit: int32) =
    if value == CallArgSlotMissing():
        bodyIRDodMarkInvalid(report, owner, value, limit)
        return
    if value < 0:
        if CallArgSlotIsConst(value):
            report.encodedParamRefCount = report.encodedParamRefCount + 1
            return
        bodyIRDodMarkInvalid(report, owner, value, limit)
        return
    bodyIRDodCheckLocalRef(report, owner, value, limit)

fn bodyIRDodCheckBlockRef(report: var BodyIRDodSoAContractReport,
                           owner: str,
                           value: int32,
                           limit: int32) =
    report.blockRefCount = report.blockRefCount + 1
    if value < 0 || value >= limit:
        bodyIRDodMarkInvalid(report, owner, value, limit)

fn bodyIRDodCheckTermRef(report: var BodyIRDodSoAContractReport,
                          owner: str,
                          value: int32,
                          limit: int32) =
    report.termRefCount = report.termRefCount + 1
    if value < 0 || value >= limit:
        bodyIRDodMarkInvalid(report, owner, value, limit)

fn bodyIRDodCheckCallRef(report: var BodyIRDodSoAContractReport,
                          owner: str,
                          value: int32,
                          limit: int32) =
    report.callRefCount = report.callRefCount + 1
    if value < 0 || value >= limit:
        bodyIRDodMarkInvalid(report, owner, value, limit)

fn bodyIRDodCheckCStringRef(report: var BodyIRDodSoAContractReport,
                             owner: str,
                             value: int32,
                             limit: int32) =
    report.cstringRefCount = report.cstringRefCount + 1
    if value < 0 || value >= limit:
        bodyIRDodMarkInvalid(report, owner, value, limit)

fn bodyIRDodCheckLocalSlots(bodyIR: BodyIR,
                             report: var BodyIRDodSoAContractReport) =
    for localIndex in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[localIndex]
        if slot.id != localIndex:
            bodyIRDodMarkInvalid(report,
                                 Fmt"localSlots[{localIndex}].id",
                                 slot.id,
                                 bodyIR.localSlots.len)

fn bodyIRDodCheckCStringLiterals(bodyIR: BodyIR,
                                  report: var BodyIRDodSoAContractReport) =
    for literalIndex in 0..<bodyIR.cstringLiterals.len:
        let literal = bodyIR.cstringLiterals[literalIndex]
        if literal.id != literalIndex:
            bodyIRDodMarkInvalid(report,
                                 Fmt"cstringLiterals[{literalIndex}].id",
                                 literal.id,
                                 bodyIR.cstringLiterals.len)

fn bodyIRDodCheckBlocks(bodyIR: BodyIR,
                         report: var BodyIRDodSoAContractReport) =
    for blockIndex in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[blockIndex]
        if block.id != blockIndex:
            bodyIRDodMarkInvalid(report,
                                 Fmt"blocks[{blockIndex}].id",
                                 block.id,
                                 bodyIR.blocks.len)
        if block.opStart < 0 ||
           block.opCount < 0 ||
           block.opStart + block.opCount > bodyIR.ops.len:
            bodyIRDodMarkInvalid(report,
                                 Fmt"blocks[{blockIndex}].opRange",
                                 block.opStart,
                                 bodyIR.ops.len)
        bodyIRDodCheckTermRef(report,
                              Fmt"blocks[{blockIndex}].termIndex",
                              block.termIndex,
                              bodyIR.terms.len)

fn bodyIRDodCheckTerm(bodyIR: BodyIR,
                       report: var BodyIRDodSoAContractReport,
                       termIndex: int32) =
    let term = bodyIR.terms[termIndex]
    if !bodyIRDodBodyTermKindValid(term.kind):
        bodyIRDodMarkInvalid(report,
                             Fmt"terms[{termIndex}].kind",
                             term.kind,
                             BodyTermCbrTag)
        return
    bodyIRDodCheckMaybeLocalRef(report,
                                Fmt"terms[{termIndex}].resultSlot",
                                term.resultSlot,
                                bodyIR.localSlots.len)
    bodyIRDodCheckMaybeLocalRef(report,
                                Fmt"terms[{termIndex}].lhsSlot",
                                term.lhsSlot,
                                bodyIR.localSlots.len)
    bodyIRDodCheckMaybeLocalRef(report,
                                Fmt"terms[{termIndex}].rhsSlot",
                                term.rhsSlot,
                                bodyIR.localSlots.len)
    if term.kind == BodyTermBrTag:
        bodyIRDodCheckBlockRef(report,
                               Fmt"terms[{termIndex}].trueBlock",
                               term.trueBlock,
                               bodyIR.blocks.len)
    elif term.kind == BodyTermCbrTag:
        if !bodyIRDodBodyCondKindValid(term.conditionKind):
            bodyIRDodMarkInvalid(report,
                                 Fmt"terms[{termIndex}].conditionKind",
                                 term.conditionKind,
                                 BodyCondI32GeTag)
        bodyIRDodCheckBlockRef(report,
                               Fmt"terms[{termIndex}].trueBlock",
                               term.trueBlock,
                               bodyIR.blocks.len)
        bodyIRDodCheckBlockRef(report,
                               Fmt"terms[{termIndex}].falseBlock",
                               term.falseBlock,
                               bodyIR.blocks.len)

fn bodyIRDodCheckTerms(bodyIR: BodyIR,
                        report: var BodyIRDodSoAContractReport) =
    for termIndex in 0..<bodyIR.terms.len:
        bodyIRDodCheckTerm(bodyIR, report, termIndex)

fn bodyIRDodCheckCallSequence(bodyIR: BodyIR,
                               report: var BodyIRDodSoAContractReport) =
    for callIndex in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[callIndex]
        bodyIRDodCheckMaybeLocalRef(report,
                                    Fmt"callSequence[{callIndex}].resultSlot",
                                    callOp.resultSlot,
                                    bodyIR.localSlots.len)
        for argIndex in 0..<callOp.argSlots.len:
            bodyIRDodCheckCallArgRef(report,
                                     Fmt"callSequence[{callIndex}].argSlots[{argIndex}]",
                                     callOp.argSlots[argIndex],
                                     bodyIR.localSlots.len)

fn bodyIRDodCheckOpTarget(bodyIR: BodyIR,
                           report: var BodyIRDodSoAContractReport,
                           opIndex: int32,
                           op: BodyOp) =
    if op.kind == BodyOpReturnTag ||
       op.kind == BodyOpBranchTag ||
       op.kind == BodyOpCallTag:
        bodyIRDodCheckMaybeLocalRef(report,
                                    Fmt"ops[{opIndex}].target",
                                    op.target,
                                    bodyIR.localSlots.len)
        return
    bodyIRDodCheckLocalRef(report,
                           Fmt"ops[{opIndex}].target",
                           op.target,
                           bodyIR.localSlots.len)

fn bodyIRDodCheckOp(bodyIR: BodyIR,
                     report: var BodyIRDodSoAContractReport,
                     opIndex: int32) =
    let op = bodyIR.ops[opIndex]
    if !bodyIRDodBodyOpKindValid(op.kind):
        bodyIRDodMarkInvalid(report,
                             Fmt"ops[{opIndex}].kind",
                             op.kind,
                             BodyOpStrEqLiteralTag)
        return
    bodyIRDodCheckOpTarget(bodyIR, report, opIndex, op)
    if op.kind == BodyOpCallTag:
        if op.operands.len != 1:
            bodyIRDodMarkInvalid(report,
                                 Fmt"ops[{opIndex}].callOrdinal",
                                 -1,
                                 bodyIR.callSequence.len)
            return
        bodyIRDodCheckCallRef(report,
                              Fmt"ops[{opIndex}].callOrdinal",
                              op.operands[0],
                              bodyIR.callSequence.len)
        if op.operands[0] >= 0 && op.operands[0] < bodyIR.callSequence.len:
            let callOp = bodyIR.callSequence[op.operands[0]]
            if op.target != callOp.resultSlot:
                bodyIRDodMarkInvalid(report,
                                     Fmt"ops[{opIndex}].target_result_mismatch",
                                     op.target,
                                     callOp.resultSlot)
    elif op.kind == BodyOpLoadLocalTag:
        if op.operands.len >= 3 && op.operands[0] == BodyLoadLocalPtrDerefI32Tag:
            bodyIRDodCheckLocalRef(report,
                                   Fmt"ops[{opIndex}].ptrSource",
                                   op.operands[1],
                                   bodyIR.localSlots.len)
        elif op.operands.len >= 1:
            bodyIRDodCheckLocalRef(report,
                                   Fmt"ops[{opIndex}].source",
                                   op.operands[0],
                                   bodyIR.localSlots.len)
        else:
            bodyIRDodMarkInvalid(report,
                                 Fmt"ops[{opIndex}].source",
                                 -1,
                                 bodyIR.localSlots.len)
    elif op.kind == BodyOpStoreLocalTag ||
         op.kind == BodyOpCopyLocalTag:
        if op.operands.len < 1:
            bodyIRDodMarkInvalid(report,
                                 Fmt"ops[{opIndex}].source",
                                 -1,
                                 bodyIR.localSlots.len)
        else:
            bodyIRDodCheckLocalRef(report,
                                   Fmt"ops[{opIndex}].source",
                                   op.operands[0],
                                   bodyIR.localSlots.len)
    elif op.kind == BodyOpBinOpTag:
        if op.operands.len < 4:
            bodyIRDodMarkInvalid(report,
                                 Fmt"ops[{opIndex}].binop_arity",
                                 op.operands.len,
                                 4)
        for operandIndex in 2..<op.operands.len:
            bodyIRDodCheckLocalRef(report,
                                   Fmt"ops[{opIndex}].operands[{operandIndex}]",
                                   op.operands[operandIndex],
                                   bodyIR.localSlots.len)
    elif op.kind == BodyOpCmpTag:
        if op.operands.len < 3:
            bodyIRDodMarkInvalid(report,
                                 Fmt"ops[{opIndex}].cmp_arity",
                                 op.operands.len,
                                 3)
        for operandIndex in 1..<op.operands.len:
            bodyIRDodCheckLocalRef(report,
                                   Fmt"ops[{opIndex}].operands[{operandIndex}]",
                                   op.operands[operandIndex],
                                   bodyIR.localSlots.len)
    elif op.kind == BodyOpBranchTag:
        if op.operands.len >= 2:
            bodyIRDodCheckLocalRef(report,
                                   Fmt"ops[{opIndex}].branchSlot",
                                   op.operands[1],
                                   bodyIR.localSlots.len)
    elif op.kind == BodyOpResultProjectTag:
        if op.operands.len < 2:
            bodyIRDodMarkInvalid(report,
                                 Fmt"ops[{opIndex}].projectSource",
                                 -1,
                                 bodyIR.localSlots.len)
        else:
            bodyIRDodCheckLocalRef(report,
                                   Fmt"ops[{opIndex}].projectSource",
                                   op.operands[1],
                                   bodyIR.localSlots.len)
    elif op.kind == BodyOpStrEqLiteralTag:
        if op.operands.len < 2:
            bodyIRDodMarkInvalid(report,
                                 Fmt"ops[{opIndex}].cstringLiteral",
                                 -1,
                                 bodyIR.cstringLiterals.len)
        else:
            bodyIRDodCheckLocalRef(report,
                                   Fmt"ops[{opIndex}].strSlot",
                                   op.operands[0],
                                   bodyIR.localSlots.len)
            bodyIRDodCheckCStringRef(report,
                                     Fmt"ops[{opIndex}].cstringLiteral",
                                     op.operands[1],
                                     bodyIR.cstringLiterals.len)

fn bodyIRDodCheckOps(bodyIR: BodyIR,
                      report: var BodyIRDodSoAContractReport) =
    for opIndex in 0..<bodyIR.ops.len:
        bodyIRDodCheckOp(bodyIR, report, opIndex)

fn BodyIRDodSoAContractCheck(bodyIR: BodyIR): BodyIRDodSoAContractReport =
    var report: BodyIRDodSoAContractReport
    report.ok = true
    report.indexWidthBits = 32
    report.independentArrayCount = 6
    report.flatScalarArrayCount = BodyIRFlatSoAScalarArrayCount()
    report.flatStringArrayCount = BodyIRFlatSoAStringArrayCount()
    report.nestedPayloadArrayCount = 0
    report.opCount = bodyIR.ops.len
    report.callCount = bodyIR.callSequence.len
    report.localCount = bodyIR.localSlots.len
    report.blockCount = bodyIR.blocks.len
    report.termCount = bodyIR.terms.len
    report.cstringCount = bodyIR.cstringLiterals.len
    bodyIRDodCheckLocalSlots(bodyIR, report)
    bodyIRDodCheckCStringLiterals(bodyIR, report)
    bodyIRDodCheckCallSequence(bodyIR, report)
    bodyIRDodCheckOps(bodyIR, report)
    bodyIRDodCheckBlocks(bodyIR, report)
    bodyIRDodCheckTerms(bodyIR, report)
    let flat = BodyIRFlattenSoA(bodyIR)
    if !BodyIRFlatSoAIsAligned(flat):
        bodyIRDodMarkInvalid(report,
                             "flat_soa_alignment",
                             0,
                             1)
    if report.pointerKeyCount != 0:
        report.ok = false
    return report

fn BodyIRDodSoAContractReportText(report: BodyIRDodSoAContractReport): str =
    return Fmt"""
    body_ir_dod_soa_ok={bodyIRDodBoolText(report.ok)}
    body_ir_dod_soa_index_width_bits={report.indexWidthBits}
    body_ir_dod_soa_independent_array_count={report.independentArrayCount}
    body_ir_dod_soa_arrays=ops,callSequence,localSlots,blocks,terms,cstringLiterals
    body_ir_dod_soa_flat_scalar_array_count={report.flatScalarArrayCount}
    body_ir_dod_soa_flat_string_array_count={report.flatStringArrayCount}
    body_ir_dod_soa_nested_payload_array_count={report.nestedPayloadArrayCount}
    body_ir_dod_soa_op_count={report.opCount}
    body_ir_dod_soa_call_count={report.callCount}
    body_ir_dod_soa_local_count={report.localCount}
    body_ir_dod_soa_block_count={report.blockCount}
    body_ir_dod_soa_term_count={report.termCount}
    body_ir_dod_soa_cstring_count={report.cstringCount}
    body_ir_dod_soa_local_ref_count={report.localRefCount}
    body_ir_dod_soa_block_ref_count={report.blockRefCount}
    body_ir_dod_soa_term_ref_count={report.termRefCount}
    body_ir_dod_soa_call_ref_count={report.callRefCount}
    body_ir_dod_soa_cstring_ref_count={report.cstringRefCount}
    body_ir_dod_soa_encoded_param_ref_count={report.encodedParamRefCount}
    body_ir_dod_soa_invalid_ref_count={report.invalidRefCount}
    body_ir_dod_soa_pointer_key_count={report.pointerKeyCount}
    body_ir_dod_soa_no_naked_pointer_key={bodyIRDodBoolText(report.pointerKeyCount == 0)}
    body_ir_dod_soa_first_invalid_ref_owner={report.firstInvalidRefOwner}
    body_ir_dod_soa_first_invalid_ref_value={report.firstInvalidRefValue}
    body_ir_dod_soa_first_invalid_ref_limit={report.firstInvalidRefLimit}
    """
