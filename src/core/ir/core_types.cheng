import cheng/core/lang/intern as langintern

type
    ModuleId = int32

    FuncId = int32

    BlockId = int32

    TypeId = int32

    ValueId = int32

    StackSlotId = int32

type
    AbiClass = enum
        AbiNone,
        AbiScalar,
        AbiPointer,
        AbiAggregate,
        AbiVector

type
    LayoutKind = enum
        LayoutInvalid,
        LayoutVoid,
        LayoutI1,
        LayoutI8,
        LayoutI16,
        LayoutI32,
        LayoutI64,
        LayoutFixedBytes,
        LayoutArray,
        LayoutRecord,
        LayoutPointer

type
    OwnershipKind = enum
        OwnInvalid,
        OwnPlain,
        OwnMove,
        OwnBorrowShared,
        OwnBorrowUnique

type
    AliasClass = enum
        AliasUnknown,
        AliasUnique,
        AliasNoAlias,
        AliasMayAlias

type
    EscapeKind = enum
        EscapeInvalid,
        EscapeNone,
        EscapeArg,
        EscapeReturn,
        EscapeGlobal

type
    ValueKind = enum
        ValueInvalid,
        ValueImmediate,
        ValueStack,
        ValueAddress,
        ValueBorrow,
        ValuePhi,
        ValueCallResult

type
    HirExprKind = enum
        HirInvalid,
        HirIntLiteral,
        HirBytesLiteral,
        HirNameRef,
        HirCall,
        HirField,
        HirIndex,
        HirBorrow,
        HirMove

type
    MirOpKind = enum
        MirInvalid,
        MirConst,
        MirMove,
        MirBorrow,
        MirLoad,
        MirStore,
        MirAddrOf,
        MirCall,
        MirPhi,
        MirRet,
        MirTrap

type
    CallConv = enum
        CallInvalid,
        CallInternal,
        CallC

type
    LirInsnKind = enum
        LirInvalid,
        LirMove,
        LirLoad,
        LirStore,
        LirCall,
        LirRet,
        LirTrap

type
    TypeLayout =
        kind: LayoutKind
        abiClass: AbiClass
        size: int32
        align: int32
        fixedCount: int32
        fieldCount: int32
        isTriviallyMoveable: bool
        isTriviallyDrop: bool

    Place =
        baseValue: ValueId
        typeId: TypeId
        offset: int32
        fieldOrdinal: int32
        ownership: OwnershipKind
        aliasClass: AliasClass
        escapeKind: EscapeKind

    BorrowFact =
        ownerValue: ValueId
        place: Place
        borrowKind: OwnershipKind
        aliasClass: AliasClass
        escapeKind: EscapeKind
        scopeDepth: int32

    MirValue =
        id: ValueId
        typeId: TypeId
        kind: ValueKind
        ownership: OwnershipKind
        aliasClass: AliasClass
        escapeKind: EscapeKind
        stackSlot: StackSlotId
        immLo: int64
        immHi: int64

    MirOp =
        kind: MirOpKind
        result: ValueId
        src0: ValueId
        src1: ValueId
        src2: ValueId
        place: Place
        callConv: CallConv
        calleeNameId: langintern.InternId
        trapTextId: langintern.InternId

    MirStackSlot =
        id: StackSlotId
        typeId: TypeId
        offset: int32
        size: int32
        align: int32
        noAlias: bool

    MirBlock =
        id: BlockId
        opStart: int32
        opCount: int32

    MirFunction = ref
        id: FuncId
        nameId: langintern.InternId
        paramCount: int32
        resultTypeId: TypeId
        stackSlots: MirStackSlot[]
        values: MirValue[]
        borrowFacts: BorrowFact[]
        ops: MirOp[]
        blocks: MirBlock[]

    LirInsn =
        kind: LirInsnKind
        dstReg: int32
        srcReg0: int32
        srcReg1: int32
        stackSlot: StackSlotId
        callConv: CallConv
        calleeNameId: langintern.InternId

    LirFunction = ref
        id: FuncId
        nameId: langintern.InternId
        stackSlots: MirStackSlot[]
        insns: LirInsn[]

fn InvalidTypeId(): TypeId =
    return -1

fn InvalidValueId(): ValueId =
    return -1

fn InvalidStackSlotId(): StackSlotId =
    return -1

fn TypeLayoutInvalid(): TypeLayout =
    var out: TypeLayout
    out.kind = LayoutInvalid
    out.abiClass = AbiNone
    out.size = 0
    out.align = 0
    out.fixedCount = 0
    out.fieldCount = 0
    out.isTriviallyMoveable = false
    out.isTriviallyDrop = false
    return out

fn TypeLayoutScalar(kind: LayoutKind, size: int32, align: int32): TypeLayout =
    var out: TypeLayout
    out.kind = kind
    out.abiClass = AbiScalar
    out.size = size
    out.align = align
    out.fixedCount = 0
    out.fieldCount = 0
    out.isTriviallyMoveable = true
    out.isTriviallyDrop = true
    return out

fn TypeLayoutFixedBytes(size: int32, align: int32): TypeLayout =
    return TypeLayout(
        kind: LayoutFixedBytes,
        abiClass: AbiAggregate,
        size: size,
        align: align,
        fixedCount: size,
        fieldCount: 0,
        isTriviallyMoveable: true,
        isTriviallyDrop: true
    )

fn PlaceRoot(baseValue: ValueId, typeId: TypeId): Place =
    return Place(
        baseValue: baseValue,
        typeId: typeId,
        offset: 0,
        fieldOrdinal: -1,
        ownership: OwnPlain,
        aliasClass: AliasUnknown,
        escapeKind: EscapeInvalid
    )

fn MirFunctionNew(nameId: langintern.InternId): MirFunction =
    var out: MirFunction = new(MirFunction)
    out.id = -1
    out.nameId = nameId
    out.paramCount = 0
    out.resultTypeId = InvalidTypeId()
    out.stackSlots = []
    out.values = []
    out.borrowFacts = []
    out.ops = []
    out.blocks = []
    return out

fn LirFunctionNew(nameId: langintern.InternId): LirFunction =
    var out: LirFunction = new(LirFunction)
    out.id = -1
    out.nameId = nameId
    out.stackSlots = []
    out.insns = []
    return out
