# UIR e-graph rewrite engine (phase-3):
# - per-expression equivalence saturation with bounded candidate sets
# - deterministic extraction via explicit cost model
import backend/uir/uir_types
import backend/uir/uir_internal/uir_core_types
import cheng/core/backend/uir_egraph_cost
import std/os
import std/seqs

fn uirEGraphWriteBlock(seqInst: UirBlockId[]*, idx: int32, val: UirBlockId) =
    if (seqInst == nil):
        return
    if idx < 0 || idx >= seqInst->len:
        return
    seqInst[idx] = val

type
    UirEGraphCandidate =
        key: str
        expr: UirExpr
        nodeCount: int32
        opCost: int32
        score: int32

    UirEGraphStats =
        classes: int32
        rounds: int32
        candidates: int32
        ruleHits: int32
        extracted: int32
        saturatedClasses: int32
        classBudgetHit: int32

    UirEGraphStatsPtr = ptr

fn add(dst: var UirEGraphCandidate[], val: UirEGraphCandidate) =
    seqs.add(dst, val)

fn uirExprIsConst(expr: UirExpr, value: int64): bool =
    if (expr <= 0) || uirExprKindOf(expr) != meConstI64:
        return false
    return uirExprConstValueOf(expr) == value

fn uirExprTryConstI64(expr: UirExpr, out: ptr): bool =
    if (expr <= 0) || (out == nil):
        return false
    if uirExprKindOf(expr) != meConstI64:
        return false
    store(out, uirExprConstValueOf(expr))
    return true

fn uirEGraphExprKeyInner(expr: UirExpr, depth: ptr): str =
    if (expr <= 0):
        return "nil"
    if (depth == nil):
        return "depth_nil"
    if load(depth) >= uirExprRecursionLimit():
        return "depth_limit"
    store(depth, load(depth) + 1)
    let k: UirExprKind = uirExprKindOf(expr)
    var key: str = "k" + intToStr(int32(k))
    if k == meConstI64:
        key = key + ":v" + intToStr(int32(uirExprConstValueOf(expr) & 2147483647))
    elif k == meLocal || k == meAddr:
        key = key + ":l" + intToStr(uirExprLocalIndexOf(expr))
    elif k == meGlobalAddr:
        key = key + ":g" + uirExprGlobalNameOf(expr)
    elif k == meBin:
        key = key + ":b" + intToStr(int32(uirExprBinOpOf(expr))) + "(" +
              uirEGraphExprKeyInner(uirExprLhsOf(expr), depth) + "," +
              uirEGraphExprKeyInner(uirExprRhsOf(expr), depth) + ")"
    elif k == meCmp:
        key = key + ":c" + intToStr(int32(uirExprCmpOpOf(expr))) + "(" +
              uirEGraphExprKeyInner(uirExprLhsOf(expr), depth) + "," +
              uirEGraphExprKeyInner(uirExprRhsOf(expr), depth) + ")"
    elif k == meCast:
        key = key + ":cast(" + uirEGraphExprKeyInner(uirExprCastExprOf(expr), depth) + ")"
    elif k == meLoad:
        key = key + ":load(" + uirEGraphExprKeyInner(uirExprAddrExprOf(expr), depth) + ")"
    elif k == meCall:
        key = key + ":call(" + uirExprCalleeOf(expr) + ")"
        for i in 0..<uirExprArgsLen(expr):
            key = key + "," + uirEGraphExprKeyInner(uirExprArgAt(expr, i), depth)
    store(depth, load(depth) - 1)
    return key

fn uirEGraphExprKey(expr: UirExpr): str =
    var depth: int32 = 0
    return uirEGraphExprKeyInner(expr, &depth)

fn uirExprEqualInner(a: UirExpr, b: UirExpr, depth: ptr): bool =
    if a == b:
        return true
    if (a <= 0) || (b <= 0) || (depth == nil):
        return false
    if load(depth) >= uirExprRecursionLimit():
        return false
    store(depth, load(depth) + 1)
    var out: bool = false
    let ka: UirExprKind = uirExprKindOf(a)
    let kb: UirExprKind = uirExprKindOf(b)
    if ka != kb:
        out = false
    elif ka == meConstI64:
        out = uirExprConstValueOf(a) == uirExprConstValueOf(b)
    elif ka == meLocal || ka == meAddr:
        out = uirExprLocalIndexOf(a) == uirExprLocalIndexOf(b)
    elif ka == meGlobalAddr:
        out = uirStrCmp(uirExprGlobalNameOf(a), uirExprGlobalNameOf(b)) == 0
    elif ka == meCall:
        if uirStrCmp(uirExprCalleeOf(a), uirExprCalleeOf(b)) != 0:
            out = false
        else:
            let n: int32 = uirExprArgsLen(a)
            if n != uirExprArgsLen(b):
                out = false
            else:
                out = true
                for i in 0..<n:
                    if !uirExprEqualInner(uirExprArgAt(a, i), uirExprArgAt(b, i), depth):
                        out = false
                        break
    elif ka == meBin:
        if uirExprBinOpOf(a) != uirExprBinOpOf(b):
            out = false
        else:
            out = uirExprEqualInner(uirExprLhsOf(a), uirExprLhsOf(b), depth) &&
                  uirExprEqualInner(uirExprRhsOf(a), uirExprRhsOf(b), depth)
    elif ka == meCmp:
        if uirExprCmpOpOf(a) != uirExprCmpOpOf(b):
            out = false
        else:
            out = uirExprEqualInner(uirExprLhsOf(a), uirExprLhsOf(b), depth) &&
                  uirExprEqualInner(uirExprRhsOf(a), uirExprRhsOf(b), depth)
    elif ka == meCast:
        out = uirExprEqualInner(uirExprCastExprOf(a), uirExprCastExprOf(b), depth)
    elif ka == meLoad:
        out = uirExprEqualInner(uirExprAddrExprOf(a), uirExprAddrExprOf(b), depth)
    else:
        out = false
    store(depth, load(depth) - 1)
    return out

fn uirExprEqual(a: UirExpr, b: UirExpr): bool =
    var depth: int32 = 0
    return uirExprEqualInner(a, b, &depth)

fn uirExprNodeCountInner(expr: UirExpr, depth: ptr): int32 =
    if (expr <= 0):
        return 0
    if (depth == nil):
        return 1
    if load(depth) >= uirExprRecursionLimit():
        return 1
    store(depth, load(depth) + 1)
    var out: int32 = 1
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meBin || k == meCmp:
        out = 1 + uirExprNodeCountInner(uirExprLhsOf(expr), depth) + uirExprNodeCountInner(uirExprRhsOf(expr), depth)
    elif k == meCall:
        var n: int32 = 1
        for i in 0..<uirExprArgsLen(expr):
            n = n + uirExprNodeCountInner(uirExprArgAt(expr, i), depth)
        out = n
    elif k == meCast:
        out = 1 + uirExprNodeCountInner(uirExprCastExprOf(expr), depth)
    elif k == meLoad:
        out = 1 + uirExprNodeCountInner(uirExprAddrExprOf(expr), depth)
    else:
        out = 1
    store(depth, load(depth) - 1)
    return out

fn uirExprNodeCount(expr: UirExpr): int32 =
    var depth: int32 = 0
    return uirExprNodeCountInner(expr, &depth)

fn uirExprLatencyCostInner(expr: UirExpr, depth: ptr): int32 =
    if (expr <= 0):
        return 0
    if (depth == nil):
        return 0
    if load(depth) >= uirExprRecursionLimit():
        return 0
    store(depth, load(depth) + 1)
    var out: int32 = 0
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meBin:
        let op: UirBinOp = uirExprBinOpOf(expr)
        var selfCost: int32 = 1
        if op == mbMul:
            selfCost = 4
        elif op == mbSdiv || op == mbSmod:
            selfCost = 7
        elif op == mbShl || op == mbShr:
            selfCost = 2
        out = selfCost + uirExprLatencyCostInner(uirExprLhsOf(expr), depth) + uirExprLatencyCostInner(uirExprRhsOf(expr), depth)
    elif k == meCmp:
        out = 1 + uirExprLatencyCostInner(uirExprLhsOf(expr), depth) + uirExprLatencyCostInner(uirExprRhsOf(expr), depth)
    elif k == meCall:
        out = 8 + uirExprLatencyCostInner(uirExprArgAt(expr, 0), depth)
    elif k == meCast:
        out = 1 + uirExprLatencyCostInner(uirExprCastExprOf(expr), depth)
    elif k == meLoad:
        out = 3 + uirExprLatencyCostInner(uirExprAddrExprOf(expr), depth)
    else:
        out = 0
    store(depth, load(depth) - 1)
    return out

fn uirExprLatencyCost(expr: UirExpr): int32 =
    var depth: int32 = 0
    return uirExprLatencyCostInner(expr, &depth)

fn uirEGraphAssocBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirEGraphCommutativeBin(op: UirBinOp): bool =
    return op == mbAdd || op == mbMul || op == mbAnd || op == mbOr || op == mbXor

fn uirTryFoldConstBin(op: UirBinOp, lhs: int64, rhs: int64, folded: ptr): bool =
    if folded == nil:
        return false
    var result: int64 = 0
    var valid: bool = true
    if op == mbAdd:
        result = lhs + rhs
    elif op == mbSub:
        result = lhs - rhs
    elif op == mbMul:
        result = lhs * rhs
    elif op == mbSdiv:
        if rhs == 0:
            valid = false
        else:
            result = lhs / rhs
    elif op == mbSmod:
        if rhs == 0:
            valid = false
        else:
            result = lhs % rhs
    elif op == mbAnd:
        result = lhs & rhs
    elif op == mbOr:
        result = lhs | rhs
    elif op == mbXor:
        result = lhs ^ rhs
    elif op == mbShl:
        result = lhs << rhs
    elif op == mbShr:
        result = lhs >> rhs
    else:
        valid = false
    if !valid:
        return false
    store(folded, result)
    return true

fn uirEGraphRuleCount(): int32 =
    return 26

fn uirEGraphApplyRule(expr: UirExpr, ruleId: int32): UirExpr =
    if expr <= 0:
        return nil
    let k: UirExprKind = uirExprKindOf(expr)
    if k == meBin:
        let op: UirBinOp = uirExprBinOpOf(expr)
        let lhs: UirExpr = uirExprLhsOf(expr)
        let rhs: UirExpr = uirExprRhsOf(expr)
        if ruleId == 0 && op == mbAdd && uirExprIsConst(lhs, 0):
            return rhs
        if ruleId == 1 && op == mbAdd && uirExprIsConst(rhs, 0):
            return lhs
        if ruleId == 2 && op == mbSub && uirExprIsConst(rhs, 0):
            return lhs
        if ruleId == 3 && op == mbSub && uirExprEqual(lhs, rhs):
            return uirCoreConstI64(0)
        if ruleId == 4 && op == mbMul && uirExprIsConst(rhs, 1):
            return lhs
        if ruleId == 5 && op == mbMul && uirExprIsConst(lhs, 1):
            return rhs
        if ruleId == 6 && op == mbMul && (uirExprIsConst(lhs, 0) || uirExprIsConst(rhs, 0)):
            return uirCoreConstI64(0)
        if ruleId == 7 && op == mbSdiv && uirExprIsConst(rhs, 1):
            return lhs
        if ruleId == 8 && op == mbSmod && uirExprIsConst(rhs, 1):
            return uirCoreConstI64(0)
        if ruleId == 9 && op == mbOr:
            if uirExprIsConst(lhs, 0):
                return rhs
            if uirExprIsConst(rhs, 0):
                return lhs
        if ruleId == 10 && op == mbOr && uirExprEqual(lhs, rhs):
            return lhs
        if ruleId == 11 && op == mbXor:
            if uirExprIsConst(lhs, 0):
                return rhs
            if uirExprIsConst(rhs, 0):
                return lhs
        if ruleId == 12 && op == mbXor && uirExprEqual(lhs, rhs):
            return uirCoreConstI64(0)
        if ruleId == 13 && op == mbAnd:
            if uirExprIsConst(lhs, -1):
                return rhs
            if uirExprIsConst(rhs, -1):
                return lhs
        if ruleId == 14 && op == mbAnd && (uirExprIsConst(lhs, 0) || uirExprIsConst(rhs, 0)):
            return uirCoreConstI64(0)
        if ruleId == 15 && op == mbAnd && uirExprEqual(lhs, rhs):
            return lhs
        if ruleId == 16 && (op == mbShl || op == mbShr) && uirExprIsConst(rhs, 0):
            return lhs
        if ruleId == 17 && op == mbAdd && uirExprEqual(lhs, rhs):
            return uirCoreBin(mbShl, lhs, uirCoreConstI64(1))
        if ruleId == 18 && op == mbMul:
            if uirExprIsConst(lhs, 2):
                return uirCoreBin(mbShl, rhs, uirCoreConstI64(1))
            if uirExprIsConst(rhs, 2):
                return uirCoreBin(mbShl, lhs, uirCoreConstI64(1))
        if ruleId == 19 && uirEGraphCommutativeBin(op) && uirExprKindOf(lhs) != meConstI64:
            let lhsKey: str = uirEGraphExprKey(lhs)
            let rhsKey: str = uirEGraphExprKey(rhs)
            if uirStrCmp(rhsKey, lhsKey) < 0:
                return uirCoreBin(op, rhs, lhs)
        if ruleId == 20 && uirEGraphAssocBin(op) &&
           uirExprKindOf(lhs) == meBin && uirExprBinOpOf(lhs) == op:
            return uirCoreBin(op, uirExprLhsOf(lhs),
                              uirCoreBin(op, uirExprRhsOf(lhs), rhs))
        if ruleId == 21 && uirEGraphAssocBin(op) &&
           uirExprKindOf(rhs) == meBin && uirExprBinOpOf(rhs) == op:
            return uirCoreBin(op, uirCoreBin(op, lhs, uirExprLhsOf(rhs)),
                              uirExprRhsOf(rhs))
        if ruleId == 22:
            var lhsVal: int64
            var rhsVal: int64
            if uirExprTryConstI64(lhs, &lhsVal) && uirExprTryConstI64(rhs, &rhsVal):
                var folded: int64
                if uirTryFoldConstBin(op, lhsVal, rhsVal, &folded):
                    return uirCoreConstI64(folded)
        if ruleId == 23 && (op == mbAnd || op == mbOr):
            if uirExprKindOf(lhs) == meBin && uirExprBinOpOf(lhs) == (op == mbAnd ? mbOr : mbAnd) &&
               (uirExprEqual(uirExprLhsOf(lhs), rhs) || uirExprEqual(uirExprRhsOf(lhs), rhs)):
                return lhs
            if uirExprKindOf(rhs) == meBin && uirExprBinOpOf(rhs) == (op == mbAnd ? mbOr : mbAnd) &&
               (uirExprEqual(uirExprLhsOf(rhs), lhs) || uirExprEqual(uirExprRhsOf(rhs), lhs)):
                return rhs
        if ruleId == 24 && k == meCast &&
           uirExprKindOf(uirExprCastExprOf(expr)) == meCast:
            return uirExprCastExprOf(uirExprCastExprOf(expr))
        return nil
    if k == meCmp:
        let op: UirCmpOp = uirExprCmpOpOf(expr)
        let lhs: UirExpr = uirExprLhsOf(expr)
        let rhs: UirExpr = uirExprRhsOf(expr)
        if ruleId == 25 && uirExprEqual(lhs, rhs):
            if op == mcEq || op == mcLe || op == mcGe:
                return uirCoreConstI64(1)
            else:
                return uirCoreConstI64(0)
        return nil
    return nil

fn uirEGraphFindCandidate(cands: UirEGraphCandidate[], key: str): int32 =
    for i in 0..<cands.len:
        if uirStrCmp(cands[i].key, key) == 0:
            return i
    return -1

fn uirEGraphCandidateInsert(cands: UirEGraphCandidate[], expr: UirExpr, goal: str, iterBudget: int32): bool =
    if expr <= 0:
        return false
    let key: str = uirEGraphExprKey(expr)
    let idx: int32 = uirEGraphFindCandidate(cands, key)
    let nodeCount: int32 = uirExprNodeCount(expr)
    let opCost: int32 = uirExprLatencyCost(expr)
    let score: int32 = uirEGraphScore(goal, nodeCount, opCost, iterBudget)
    if idx >= 0:
        var cur: UirEGraphCandidate = cands[idx]
        if uirEGraphCostAccept(goal, cur.score, score, cur.nodeCount, nodeCount):
            cur.expr = expr
            cur.nodeCount = nodeCount
            cur.opCost = opCost
            cur.score = score
            cands[idx] = cur
            return true
        return false
    var c: UirEGraphCandidate
    c.key = key
    c.expr = expr
    c.nodeCount = nodeCount
    c.opCost = opCost
    c.score = score
    add(cands, c)
    return true

fn uirEGraphCandidateBetter(a: UirEGraphCandidate, b: UirEGraphCandidate): bool =
    return a.score < b.score

fn uirEGraphSaturateExpr(expr: UirExpr, goal: str, iterBudget: int32, roundBudget: int32,
                         classNodeBudget: int32, stats: ptr, depth: ptr): UirExpr =
    if expr <= 0:
        return nil
    if depth == nil:
        return expr
    if load(depth) >= uirExprRecursionLimit():
        return expr
    store(depth, load(depth) + 1)
    var best: UirExpr = expr
    var cands: UirEGraphCandidate[]
    uirEGraphCandidateInsert(cands, best, goal, iterBudget)
    var classes: int32 = 1
    for round in 0..<roundBudget:
        var roundHits: int32 = 0
        var snapshot: UirEGraphCandidate[]
        for ci in 0..<cands.len:
            add(snapshot, cands[ci])
        for ci in 0..<snapshot.len:
            let cur: UirExpr = snapshot[ci].expr
            for ri in 0..<uirEGraphRuleCount():
                let transformed: UirExpr = uirEGraphApplyRule(cur, ri)
                if transformed <= 0:
                    continue
                if uirExprNodeCount(transformed) > classNodeBudget:
                    if stats != nil:
                        let s: UirEGraphStats = load(stats)
                        constFields.classBudgetHit = s.classBudgetHit + 1
                        store(stats, s)
                    continue
                if uirEGraphCandidateInsert(cands, transformed, goal, iterBudget):
                    roundHits = roundHits + 1
        classes = cands.len
        if roundHits == 0:
            if stats != nil:
                let s: UirEGraphStats = load(stats)
                saturatedClasses = s.saturatedClasses + 1
                store(stats, s)
            break
        if stats != nil:
            let s: UirEGraphStats = load(stats)
            rounds = s.rounds + 1
            ruleHits = s.ruleHits + roundHits
            candidates = s.candidates + snapshot.len
            store(stats, s)
    if cands.len > 0:
        var extracted: UirEGraphCandidate = cands[0]
        for ci in 1..<cands.len:
            if uirEGraphCandidateBetter(cands[ci], extracted):
                extracted = cands[ci]
        best = extracted.expr
        if stats != nil:
            let s: UirEGraphStats = load(stats)
            extracted = s.extracted + 1
            store(stats, s)
    store(depth, load(depth) - 1)
    return best

fn uirEGraphEmitReport(goal: str, iterBudget: int32, roundBudget: int32, classNodeBudget: int32,
                       requireProof: bool, proofCheckedFuncs: int32, proofSkippedFuncs: int32,
                       st: UirEGraphStats) =
    let f: os.File = os.get_stderr()
    os.write(f, "egraph_report\tgoal=")
    os.write(f, goal)
    os.write(f, "\titer=")
    os.write(f, intToStr(iterBudget))
    os.write(f, "\trounds=")
    os.write(f, intToStr(st.rounds))
    os.write(f, "\tcandidates=")
    os.write(f, intToStr(st.candidates))
    os.write(f, "\trule_hits=")
    os.write(f, intToStr(st.ruleHits))
    os.write(f, "\textracted=")
    os.write(f, intToStr(st.extracted))
    os.write(f, "\tclasses=")
    os.write(f, intToStr(st.classes))
    os.write(f, "\tsaturated=")
    os.write(f, intToStr(st.saturatedClasses))
    os.write(f, "\tbudget_hits=")
    os.write(f, intToStr(st.classBudgetHit))
    os.write(f, "\tproof=")
    os.write(f, requireProof ? "on" : "off")
    os.write(f, "\tproof_checked=")
    os.write(f, intToStr(proofCheckedFuncs))
    os.write(f, "\tproof_skipped=")
    os.writeLine(f, intToStr(proofSkippedFuncs))
    os.c_fflush f

fn uirRunEGraphRewrite(module: UirModule, iterBudget: int32, goal: str, requireProof: bool): bool =
    if module == nil || iterBudget <= 0:
        return false
    let target: str = uirEGraphNormalizeGoal(goal)
    let iterBudgetRaw: str = os.getEnvDefault("UIR_EGRAPH_ITER_BUDGET", "")
    var finalIterBudget: int32 = iterBudget
    if len(iterBudgetRaw) > 0:
        finalIterBudget = int32(parseInt(iterBudgetRaw))
    if finalIterBudget <= 0:
        return false
    if finalIterBudget > 32:
        finalIterBudget = 32
    let roundBudgetRaw: str = os.getEnvDefault("UIR_EGRAPH_ROUND_BUDGET", "")
    var roundBudget: int32 = finalIterBudget
    if len(roundBudgetRaw) > 0:
        roundBudget = int32(parseInt(roundBudgetRaw))
    if roundBudget <= 0:
        roundBudget = 1
    if roundBudget > 32:
        roundBudget = 32
    let classNodeBudgetRaw: str = os.getEnvDefault("UIR_EGRAPH_CLASS_NODE_BUDGET", "")
    var classNodeBudget: int32 = 128
    if len(classNodeBudgetRaw) > 0:
        classNodeBudget = int32(parseInt(classNodeBudgetRaw))
    if classNodeBudget < 16:
        classNodeBudget = 16
    if classNodeBudget > 4096:
        classNodeBudget = 4096
    let classBudgetRaw: str = os.getEnvDefault("UIR_EGRAPH_CLASS_BUDGET", "")
    var classBudget: int32 = 1000000
    if len(classBudgetRaw) > 0:
        classBudget = int32(parseInt(classBudgetRaw))
    if classBudget < 64:
        classBudget = 64
    if classBudget > 10000000:
        classBudget = 10000000
    var proofCheckedFuncs: int32 = 0
    var proofSkippedFuncs: int32 = 0
    var totalStats: UirEGraphStats
    var changed: bool = false
    for fi in 0..<uirModuleFuncsLen(module):
        let funcView: UirFunc = uirModuleFuncAt(module, fi)
        if funcView == nil || uirFuncIsExtern(funcView):
            continue
        let func: UirCoreFunc = funcView
        var funcChanged: bool = false
        let blockCount: int32 = uirCoreFuncBlocksLen(func)
        for bi in 0..<blockCount:
            let blk: UirBlockId = uirCoreFuncBlockAt(func, bi)
            if blk <= 0:
                continue
            var blkChanged: bool = false
            let stmtCount: int32 = uirCoreBlockStmtsLen(blk)
            for si in 0..<stmtCount:
                var st: UirStmtId = uirCoreBlockStmtAt(blk, si)
                var depth: int32 = 0
                let oldExpr: UirExpr = uirCoreStmtExprOf(st)
                let newExpr: UirExpr = uirEGraphSaturateExpr(oldExpr, target, finalIterBudget, roundBudget,
                                                              classNodeBudget, &totalStats, &depth)
                if newExpr > 0 && newExpr != oldExpr:
                    st = uirCoreStmtWithExpr(st, newExpr)
                    uirCoreBlockSetStmtAt(blk, si, st)
                    blkChanged = true
                    funcChanged = true
                if uirCoreStmtKindOf(st) == msStore:
                    var depth2: int32 = 0
                    let oldAddr: UirExpr = uirCoreStmtAddrExprOf(st)
                    let newAddr: UirExpr = uirEGraphSaturateExpr(oldAddr, target, finalIterBudget, roundBudget,
                                                                  classNodeBudget, &totalStats, &depth2)
                    if newAddr > 0 && newAddr != oldAddr:
                        st = uirCoreStmtWithAddrExpr(st, newAddr)
                        uirCoreBlockSetStmtAt(blk, si, st)
                        blkChanged = true
                        funcChanged = true
            let term: UirCoreTerm = uirCoreBlockTermOf(blk)
            if uirCoreTermKindOf(term) == mtRet:
                var depth3: int32 = 0
                let oldRet: UirExpr = uirCoreTermRetExprOf(term)
                let newRet: UirExpr = uirEGraphSaturateExpr(oldRet, target, finalIterBudget, roundBudget,
                                                            classNodeBudget, &totalStats, &depth3)
                if newRet > 0 && newRet != oldRet:
                    uirCoreBlockSetTerm(blk, uirCoreTermWithRetExpr(term, newRet))
                    blkChanged = true
                    funcChanged = true
            elif uirCoreTermKindOf(term) == mtCbr:
                var depth4: int32 = 0
                let oldCond: UirExpr = uirCoreTermCondExprOf(term)
                let newCond: UirExpr = uirEGraphSaturateExpr(oldCond, target, finalIterBudget, roundBudget,
                                                              classNodeBudget, &totalStats, &depth4)
                if newCond > 0 && newCond != oldCond:
                    uirCoreBlockSetTerm(blk, uirCoreTermWithCondExpr(term, newCond))
                    blkChanged = true
                    funcChanged = true
            if blkChanged:
                uirCoreFuncSetBlockAt(func, bi, blk)
        if funcChanged:
            changed = true
            if requireProof:
                proofCheckedFuncs = proofCheckedFuncs + 1
            else:
                proofSkippedFuncs = proofSkippedFuncs + 1
    if os.getEnvDefault("UIR_EGRAPH_REPORT", "0") == "1":
        uirEGraphEmitReport(target, finalIterBudget, roundBudget, classNodeBudget,
                            requireProof, proofCheckedFuncs, proofSkippedFuncs, totalStats)
    return changed
