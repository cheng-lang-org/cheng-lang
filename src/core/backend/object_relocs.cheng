type
    ObjectRelocKind = enum
        ObjectRelocAbs32
        ObjectRelocAbs64
        ObjectRelocBranch26
        ObjectRelocPage21
        ObjectRelocPageOff12

    ObjectReloc =
        sectionIndex: int32
        offset: int64
        symbolIndex: int32
        kind: ObjectRelocKind
        addend: int64
        pcRelative: bool

    ObjectRelocTable =
        items: ObjectReloc[]

fn ObjectRelocsInit(): ObjectRelocTable =
    var out: ObjectRelocTable
    return out

fn ObjectRelocsCount(table: ObjectRelocTable): int32 =
    return table.items.len

fn ObjectRelocsAt(table: ObjectRelocTable, index: int32): ObjectReloc =
    return table.items[index]

fn ObjectRelocsAdd(table: var ObjectRelocTable,
                    sectionIndex: int32,
                    offset: int64,
                    symbolIndex: int32,
                    kind: ObjectRelocKind,
                    addend: int64,
                    pcRelative: bool): int32 =
    add(table.items, ObjectReloc(sectionIndex: sectionIndex,
                                 offset: offset,
                                 symbolIndex: symbolIndex,
                                 kind: kind,
                                 addend: addend,
                                 pcRelative: pcRelative))
    return table.items.len - 1

fn ObjectRelocsCountForSection(table: ObjectRelocTable, sectionIndex: int32): int32 =
    var out = 0
    for i in 0..<table.items.len:
        if table.items[i].sectionIndex == sectionIndex:
            out = out + 1
    return out
