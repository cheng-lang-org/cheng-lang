import std/strings
import std/strutils as strutil
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/target_matrix as tmat
import cheng/core/lang/parser

type
    PrimaryObjectPlan =
        targetTriple: str
        objectFormat: str
        outputPath: str
        entryPath: str
        entrySymbol: str
        itemIds: int32[]
        symbolNames: str[]
        functionWordOffsets: int32[]
        functionWordCounts: int32[]
        functionBodyKinds: str[]
        instructionWords: int32[]
        dataLabels: str[]
        dataPayloadTexts: str[]
        relocSourceItemIds: int32[]
        relocWordOffsets: int32[]
        relocTargetSymbols: str[]
        missingReasons: str[]
        pipelineStage: str

    PrimarySourceCacheEntry =
        sourcePath: str
        lines: str[]
        decls: parser.NormalizedFunctionDecl[]
        ok: bool

fn PrimaryTargetSymbolName(targetTriple: str,
                             raw: str): str =
    if targetTriple == "arm64-apple-darwin" ||
       targetTriple == "aarch64-apple-ios" ||
       targetTriple == "arm64-apple-ios":
        return "_" + raw
    return raw

fn PrimarySanitizeSymbolPart(text: str): str =
    var out = ""
    for i in 0..<len(text):
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            out = out + strings.SliceBytes(text, i, 1)
        else:
            out = out + "_"
    return out

fn PrimarySymbolNameForFunction(targetTriple: str,
                                  symbolText: str,
                                  signatureLineNumber: int32,
                                  emitKind: creq.CompilerEmit): str =
    var raw = symbolText
    if len(raw) == 0:
        raw = "cheng_primary_unnamed"
    raw = PrimarySanitizeSymbolPart(raw)
    if signatureLineNumber > 0:
        raw = raw + "__L" + intToStr(signatureLineNumber)
    return PrimaryTargetSymbolName(targetTriple, raw)

fn PrimaryRuntimeEntryBridgeSymbol(linkPlan: slplan.SystemLinkPlanStub): str =
    var raw = "cheng_program_argv_entry"
    if linkPlan.moduleKind == slplan.SystemCompilerControlPlane:
        raw = "cheng_tooling_argv_entry"
    return PrimaryTargetSymbolName(linkPlan.targetTriple, raw)

fn PrimarySplitLines(text: str): str[] =
    var out: str[]
    var start = 0
    let n = len(text)
    var i = 0
    while i <= n:
        var lineEnd = false
        if i == n:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if !lineEnd:
            i = i + 1
            continue
        add(out, strings.SliceBytes(text, start, i - start))
        start = i + 1
        i = i + 1
    return out

fn PrimaryFindDeclLineIndex(decls: parser.NormalizedFunctionDecl[],
                              functionName: str): int32 =
    for i in 0..<decls.len:
        if decls[i].name == functionName:
            return decls[i].lineIndex
    var tailStart = 0
    var j = 0
    while j + 1 < len(functionName):
        if functionName[j] == ':' && functionName[j + 1] == ':':
            tailStart = j + 2
            j = j + 2
            continue
        j = j + 1
    if tailStart > 0 && tailStart < len(functionName):
        let tailName = strings.SliceBytes(functionName, tailStart, len(functionName) - tailStart)
        for i in 0..<decls.len:
            if decls[i].name == tailName:
                return decls[i].lineIndex
    return 0

fn PrimarySourceCacheIndex(entries: PrimarySourceCacheEntry[],
                             sourcePath: str): int32 =
    for i in 0..<entries.len:
        if entries[i].sourcePath == sourcePath:
            return i
    return -1

fn PrimarySourceCacheEnsure(entries: var PrimarySourceCacheEntry[],
                              sourcePath: str): int32 =
    let existing = PrimarySourceCacheIndex(entries, sourcePath)
    if existing >= 0:
        return existing
    let sourceText = chengpath.ReadTextFile("", sourcePath)
    var decls: parser.NormalizedFunctionDecl[]
    var declErr = ""
    var entry: PrimarySourceCacheEntry
    entry.sourcePath = sourcePath
    entry.lines = PrimarySplitLines(sourceText)
    entry.ok = parser.ParserReadNormalizedFunctionDecls(sourceText, decls, declErr)
    entry.decls = decls
    add(entries, entry)
    return entries.len - 1

fn PrimaryBodyTextAfterEquals(lineRaw: str): str =
    for i in 0..<len(lineRaw):
        if lineRaw[i] != '=':
            continue
        return chengpath.PathTrim(strings.SliceBytes(lineRaw, i + 1, len(lineRaw) - i - 1))
    return ""

fn PrimaryFunctionBodyLine(lines: str[],
                             declLineIndex: int32,
                             bodyLineNumber: var int32): str =
    bodyLineNumber = 0
    if declLineIndex <= 0 || declLineIndex > lines.len:
        return ""
    let declLine = lines[declLineIndex - 1]
    let inlineBody = PrimaryBodyTextAfterEquals(declLine)
    if len(inlineBody) > 0:
        bodyLineNumber = declLineIndex
        return inlineBody
    for i in declLineIndex..<lines.len:
        let bodyRaw = lines[i]
        let bodyTrim = chengpath.PathTrim(bodyRaw)
        if len(bodyTrim) <= 0:
            continue
        if !parser.ParserHasLeadingIndent(bodyRaw):
            break
        bodyLineNumber = i + 1
        return bodyTrim
    return ""

fn PrimaryFindResolvedCallIndex(lowering: lower.LoweringPlanStub,
                                  sourcePath: str,
                                  lineNumber: int32): int32 =
    if lineNumber <= 0:
        return -1
    var insideTargetSource = false
    for i in 0..<lowering.typedExprFacts.len:
        let factSourcePath = lowering.typedExprFacts[i].sourcePath
        if factSourcePath != sourcePath:
            if insideTargetSource:
                break
            continue
        insideTargetSource = true
        let factLineNumber = lowering.typedExprFacts[i].lineNumber
        if factLineNumber != lineNumber:
            if factLineNumber > lineNumber:
                break
            continue
        if !lowering.typedExprFacts[i].callResolved:
            continue
        if lowering.typedExprFacts[i].callTargetImportc:
            continue
        if len(lowering.typedExprFacts[i].callTarget) <= 0:
            continue
        return i
    return -1

fn PrimaryFunctionTargetSymbol(functionSymbolTexts: str[],
                                 allSymbolNames: str[],
                                 targetText: str): str =
    for i in 0..<functionSymbolTexts.len:
        if functionSymbolTexts[i] == targetText:
            return allSymbolNames[i]
    return ""

fn PrimaryFunctionBodyKind(bodyText: str,
                            callArgCount: int32,
                            targetSymbol: str): str =
    let trimmed = chengpath.PathTrim(bodyText)
    if trimmed == "return 0" || trimmed == "0":
        return "return_zero_i32"
    if len(targetSymbol) <= 0:
        return "unsupported"
    if callArgCount == 0:
        return "return_call_noarg_i32"
    if callArgCount == 1:
        return "return_call_arg0_i32"
    return "unsupported"

fn PrimaryFunctionWordCountForBodyKind(bodyKind: str): int32 =
    if bodyKind == "return_zero_i32":
        return 2
    if bodyKind == "return_call_noarg_i32":
        return 1
    if bodyKind == "return_call_arg0_i32":
        return 2
    return 0

fn PrimaryFunctionWordCount(bodyText: str,
                              callArgCount: int32,
                              targetSymbol: str): int32 =
    let bodyKind = PrimaryFunctionBodyKind(bodyText, callArgCount, targetSymbol)
    return PrimaryFunctionWordCountForBodyKind(bodyKind)

fn PrimaryObjectMissingReasons(linkPlan: slplan.SystemLinkPlanStub,
                                 lowering: lower.LoweringPlanStub,
                                 itemIds: int32[],
                                 instructionWords: int32[],
                                 bodySemanticsMissing: bool): str[] =
    var missing: str[]
    if linkPlan.missingReasons.len > 0:
        add(missing, "system_link_plan_not_ready_for_primary_object")
    if lowering.missingReasons.len > 0:
        add(missing, "lowering_plan_not_ready_for_primary_object")
    if itemIds.len <= 0:
        add(missing, "primary_object_items_missing")
    if instructionWords.len <= 0:
        add(missing, "primary_object_machine_words_missing")
    if bodySemanticsMissing:
        add(missing, "primary_object_body_semantics_missing")
    if linkPlan.emitKind == creq.EmitExe && len(linkPlan.entrySymbol) <= 0:
        add(missing, "primary_object_entry_symbol_missing")
    return missing

fn BuildPrimaryObjectPlan(linkPlan: slplan.SystemLinkPlanStub,
                            lowering: lower.LoweringPlanStub): Result[PrimaryObjectPlan] =
    var sourceCache: PrimarySourceCacheEntry[]
    var allSymbolNames: str[]
    var declLineIndices: int32[]
    var bodyTexts: str[]
    var bodyLineNumbers: int32[]
    var itemIds: int32[]
    var symbolNames: str[]
    var functionWordOffsets: int32[]
    var functionWordCounts: int32[]
    var functionBodyKinds: str[]
    var plan: PrimaryObjectPlan
    var totalWordCount: int32
    var bodySemanticsMissing = false
    allSymbolNames = []
    declLineIndices = []
    bodyTexts = []
    bodyLineNumbers = []
    itemIds = []
    symbolNames = []
    functionWordOffsets = []
    functionWordCounts = []
    functionBodyKinds = []
    for i in 0..<lowering.functionNames.len:
        let sourcePath = lowering.functionSourcePaths[i]
        let cacheIndex = PrimarySourceCacheEnsure(sourceCache, sourcePath)
        let sourceEntry = sourceCache[cacheIndex]
        var declLineIndex: int32
        var bodyLineNumber: int32
        var bodyText = ""
        if !sourceEntry.ok:
            bodySemanticsMissing = true
        else:
            declLineIndex = PrimaryFindDeclLineIndex(sourceEntry.decls, lowering.functionNames[i])
            bodyText = PrimaryFunctionBodyLine(sourceEntry.lines, declLineIndex, bodyLineNumber)
            if declLineIndex <= 0 || len(bodyText) <= 0:
                bodySemanticsMissing = true
        add(declLineIndices, declLineIndex)
        add(bodyTexts, bodyText)
        add(bodyLineNumbers, bodyLineNumber)
        add(allSymbolNames,
            PrimarySymbolNameForFunction(linkPlan.targetTriple,
                                           lowering.functionSymbolTexts[i],
                                           declLineIndex,
                                           linkPlan.emitKind))
    for i in 0..<lowering.functionNames.len:
        let bodyText = bodyTexts[i]
        let bodyLineNumber = bodyLineNumbers[i]
        let sourcePath = lowering.functionSourcePaths[i]
        let callIndex = PrimaryFindResolvedCallIndex(lowering, sourcePath, bodyLineNumber)
        var targetSymbol = ""
        var callArgCount = -1
        if callIndex >= 0:
            let fact = lowering.typedExprFacts[callIndex]
            callArgCount = fact.callArgCount
            targetSymbol = PrimaryFunctionTargetSymbol(lowering.functionSymbolTexts,
                                                         allSymbolNames,
                                                         fact.callTarget)
        let bodyKind = PrimaryFunctionBodyKind(bodyText, callArgCount, targetSymbol)
        let wordCount = PrimaryFunctionWordCountForBodyKind(bodyKind)
        if wordCount <= 0:
            bodySemanticsMissing = true
            continue
        add(itemIds, int32(100000 + i))
        add(symbolNames, allSymbolNames[i])
        add(functionWordOffsets, totalWordCount)
        add(functionWordCounts, wordCount)
        add(functionBodyKinds, bodyKind)
        totalWordCount = totalWordCount + wordCount
    if linkPlan.emitKind == creq.EmitExe && len(linkPlan.entrySymbol) > 0 && itemIds.len > 0:
        add(itemIds, int32(900000 + itemIds.len))
        add(symbolNames, PrimaryRuntimeEntryBridgeSymbol(linkPlan))
        add(functionWordOffsets, totalWordCount)
        add(functionWordCounts, 1)
        add(functionBodyKinds, "entry_bridge")
        totalWordCount = totalWordCount + 1
    plan.targetTriple = linkPlan.targetTriple
    plan.objectFormat = tmat.TargetPrimaryObjectFormat(linkPlan.targetTriple)
    if linkPlan.emitKind == creq.EmitObj:
        plan.outputPath = linkPlan.outputPath
    else:
        plan.outputPath = linkPlan.outputPath + ".primary.o"
    plan.entryPath = linkPlan.entryPath
    plan.entrySymbol = linkPlan.entrySymbol
    plan.itemIds = itemIds
    plan.symbolNames = symbolNames
    plan.functionWordOffsets = functionWordOffsets
    plan.functionWordCounts = functionWordCounts
    plan.functionBodyKinds = functionBodyKinds
    plan.instructionWords = []
    for i in 0..<totalWordCount:
        add(plan.instructionWords, 0)
    plan.dataLabels = []
    plan.dataPayloadTexts = []
    plan.relocSourceItemIds = []
    plan.relocWordOffsets = []
    plan.relocTargetSymbols = []
    plan.missingReasons = PrimaryObjectMissingReasons(linkPlan,
                                                        lowering,
                                                        itemIds,
                                                        plan.instructionWords,
                                                        bodySemanticsMissing)
    plan.pipelineStage = "lowering_plan_to_primary_object_plan"
    return Ok[PrimaryObjectPlan](plan)

fn PrimaryObjectPlanReport(plan: PrimaryObjectPlan): str =
    var symbolText = "-"
    if plan.symbolNames.len > 0:
        symbolText = strutil.Join(plan.symbolNames, ",")
    var out = ""
    out = out + "primary_object_format=" + plan.objectFormat + "\n"
    out = out + "primary_object_item_count=" + intToStr(plan.itemIds.len) + "\n"
    out = out + "primary_object_symbols=" + symbolText + "\n"
    out = out + "primary_object_instruction_word_count=" + intToStr(plan.instructionWords.len) + "\n"
    out = out + "primary_object_data_label_count=" + intToStr(plan.dataLabels.len) + "\n"
    out = out + "primary_object_reloc_count=" + intToStr(plan.relocSourceItemIds.len) + "\n"
    out = out + "primary_object_missing_reasons=" + slplan.SystemLinkPlanListText(plan.missingReasons) + "\n"
    out = out + "primary_object_pipeline_stage=" + plan.pipelineStage
    return out
