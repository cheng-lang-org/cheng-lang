type
    PrimaryObjectPlan =
        targetTriple: str
        objectFormat: str
        outputPath: str
        entryPath: str
        entrySymbol: str
        entryFunctionSymbol: str
        itemIds: int32[]
        symbolNames: str[]
        functionWordOffsets: int32[]
        functionWordCounts: int32[]
        functionBodyKinds: str[]
        functionStatementReturnModes: int32[]
        functionStatementReturnI32Values: int32[]
        functionStatementCallCounts: int32[]
        functionLocalSlotCounts: int32[]
        functionLocalStackByteCounts: int32[]
        functionBodyIRs: coreir.BodyIR[]
        functionTaskSchedule: str
        functionTaskJobCount: int32
        functionTaskCount: int32
        instructionWords: int32[]
        dataLabels: str[]
        dataPayloadTexts: str[]
        relocSourceItemIds: int32[]
        relocWordOffsets: int32[]
        relocTargetSymbols: str[]
        reachableFunctionCount: int32
        firstMissingFunction: str
        firstMissingBodyKind: str
        firstMissingTypedIrKind: str
        firstMissingLineNumber: int32
        missingReasons: str[]
        pipelineStage: str

    PrimaryFunctionCodegenTask =
        functionIndex: int32
        wordOffset: int32
        wordCount: int32
        bodyKind: str
        statementMode: int32
        statementI32Value: int32
        statementCallCount: int32

    PrimaryFunctionCodegenTaskPlan =
        schedule: str
        jobCount: int32
        tasks: PrimaryFunctionCodegenTask[]

fn PrimaryTargetSymbolName(targetTriple: str,
                             raw: str): str =
    if targetTriple == "arm64-apple-darwin" ||
       targetTriple == "aarch64-apple-ios" ||
       targetTriple == "arm64-apple-ios":
        if Len(raw) > 0:
            if raw[0] == '_':
                return raw
        if Len(raw) >= 2:
            if raw[0] == 'L':
                if raw[1] == '_':
                    return raw
        return Fmt"_{raw}"
    return raw

fn PrimarySanitizeSymbolPart(text: str): str =
    var out = ""
    for i in 0..<Len(text):
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            out = Fmt"{out}{strings.SliceBytes(text, i, 1)}"
        else:
            out = Fmt"{out}_"
    return out

fn PrimarySymbolNameForFunction(targetTriple: str,
                                  symbolText: str,
                                  signatureLineNumber: int32,
                                  emitKind: creq.CompilerEmit): str =
    var raw = symbolText
    var lineScoped = false
    if Len(raw) == 0:
        raw = "cheng_primary_unnamed"
    if Len(raw) >= 2:
        for i in 0..<(Len(raw) - 1):
            if raw[i] == ':' && raw[i + 1] == ':':
                lineScoped = true
    raw = PrimarySanitizeSymbolPart(raw)
    if lineScoped && signatureLineNumber > 0:
        raw = Fmt"{raw}__L{signatureLineNumber}"
    return PrimaryTargetSymbolName(targetTriple, raw)

fn PrimarySymbolNameForGlobalVar(targetTriple: str,
                                  ownerModulePath: str,
                                  varName: str): str =
    let raw = Fmt"{ownerModulePath}__{varName}"
    return PrimaryTargetSymbolName(targetTriple, PrimarySanitizeSymbolPart(raw))

fn PrimaryStringSeqHas(items: str[],
                        value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn PrimaryCStringLiteralDataLabel(functionSymbol: str,
                                  callOrdinal: int32): str =
    return Fmt"{functionSymbol}__cstring_{callOrdinal}"

fn PrimaryReturnStrLiteralDataLabel(functionSymbol: str): str =
    return Fmt"{functionSymbol}__return_str_literal"

fn PrimarySimpleStringLiteralContent(argsText: str,
                                     content: var str): bool =
    content = ""
    let trimmed = chengpath.PathTrim(argsText)
    if Len(trimmed) < 2:
        return false
    if trimmed[0] != Char(34) || trimmed[Len(trimmed) - 1] != Char(34):
        return false
    var escaped = false
    for i in 1..<(Len(trimmed) - 1):
        let ch = trimmed[i]
        if escaped:
            escaped = false
        elif ch == Char(92):
            escaped = true
        elif ch == Char(34):
            return false
    if escaped:
        return false
    content = strings.SliceBytes(trimmed, 1, Len(trimmed) - 2)
    return true

fn PrimaryRuntimeEntryBridgeSymbol(linkPlan: slplan.SystemLinkPlanStub): str =
    var raw = "cheng_program_argv_entry"
    if linkPlan.moduleKind == slplan.SystemCompilerControlPlane:
        raw = "cheng_tooling_argv_entry"
    return PrimaryTargetSymbolName(linkPlan.targetTriple, raw)

fn PrimaryExportRootMatches(root: str,
                             targetSymbol: str,
                             exportSymbol: str,
                             symbolText: str,
                             functionName: str): bool =
    if Len(root) <= 0:
        return false
    if root == targetSymbol ||
       root == exportSymbol ||
       root == symbolText ||
       root == functionName:
        return true
    if Len(root) > 1:
        if root[0] == '_':
            let raw = strings.SliceBytes(root, 1, Len(root) - 1)
            if raw == exportSymbol || raw == symbolText || raw == functionName:
                return true
    return false

fn PrimaryExportRootIndex(roots: str[],
                           targetSymbol: str,
                           exportSymbol: str,
                           symbolText: str,
                           functionName: str): int32 =
    for i in 0..<roots.len:
        if PrimaryExportRootMatches(roots[i],
                                    targetSymbol,
                                    exportSymbol,
                                    symbolText,
                                    functionName):
            return i
    return -1

fn PrimaryFunctionTailName(functionName: str): str =
    var tailStart = 0
    if Len(functionName) >= 2:
        for j in 0..<(Len(functionName) - 1):
            if functionName[j] == ':' && functionName[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < Len(functionName):
        return strings.SliceBytes(functionName, tailStart, Len(functionName) - tailStart)
    return functionName

fn PrimaryCallTargetTailName(targetText: str): str =
    var tailStart = 0
    for i in 0..<Len(targetText):
        if targetText[i] == '.':
            tailStart = i + 1
    if Len(targetText) >= 2:
        for j in 0..<(Len(targetText) - 1):
            if targetText[j] == ':' && targetText[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < Len(targetText):
        return strings.SliceBytes(targetText, tailStart, Len(targetText) - tailStart)
    return targetText

fn PrimaryObjectIrFunctionIndex(ir: var lower.PrimaryObjectIr,
                                 sourcePath: str,
                                 functionName: str): int32 =
    let tailName = PrimaryFunctionTailName(functionName)
    for i in 0..<ir.functions.len:
        if ir.functions[i].sourcePath != sourcePath:
            continue
        if ir.functions[i].functionName == functionName ||
           ir.functions[i].functionName == tailName:
            return i
    return -1

fn PrimaryFunctionTargetSymbol(functionSymbolTexts: str[],
                                 functionSourcePaths: str[],
                                 allSymbolNames: str[],
                                 targetSourcePath: str,
                                 targetText: str): str =
    for i in 0..<functionSymbolTexts.len:
        if functionSymbolTexts[i] == targetText:
            return allSymbolNames[i]
    let targetTail = PrimaryCallTargetTailName(targetText)
    for i in 0..<functionSymbolTexts.len:
        if i >= functionSourcePaths.len:
            continue
        if functionSourcePaths[i] != targetSourcePath:
            continue
        if i >= allSymbolNames.len:
            continue
        if PrimaryFunctionTailName(functionSymbolTexts[i]) == targetTail:
            return allSymbolNames[i]
    return ""

fn PrimaryFunctionTargetIndex(functionSymbolTexts: str[],
                               functionSourcePaths: str[],
                               targetSourcePath: str,
                               targetText: str): int32 =
    for i in 0..<functionSymbolTexts.len:
        if functionSymbolTexts[i] == targetText:
            return i
    let targetTail = PrimaryCallTargetTailName(targetText)
    for i in 0..<functionSymbolTexts.len:
        if i >= functionSourcePaths.len:
            continue
        if functionSourcePaths[i] != targetSourcePath:
            continue
        if PrimaryFunctionTailName(functionSymbolTexts[i]) == targetTail:
            return i
    return -1

fn PrimaryBoolSeqInit(count: int32,
                       value: bool): bool[] =
    var out: bool[]
    for _ in 0..<count:
        add(out, value)
    return out

fn PrimaryIntSeqInit(count: int32,
                      value: int32): int32[] =
    var out: int32[]
    for _ in 0..<count:
        add(out, value)
    return out

fn PrimaryLocalSlotSize(typeKind: int32): int32 =
    if typeKind == coreir.LocalI32Tag:
        return 4
    if typeKind == coreir.LocalF64Tag:
        return 8
    if typeKind == coreir.LocalStrTag:
        return 24
    if typeKind == coreir.LocalPtrTag:
        return 8
    return 0

fn PrimaryLocalSlotSizeOf(slot: coreir.LocalSlot): int32 =
    if slot.sizeBytes > 0:
        return slot.sizeBytes
    return PrimaryLocalSlotSize(slot.typeKind)

fn PrimaryAlignStackBytes(value: int32, align: int32): int32 =
    if align <= 1:
        return value
    let remainder = value % align
    if remainder == 0:
        return value
    return value + (align - remainder)

fn PrimaryBodyIrStackByteCount(bodyIR: coreir.BodyIR): int32 =
    var maxEnd: int32
    for i in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[i]
        let slotEnd = slot.stackOffset + PrimaryLocalSlotSizeOf(slot)
        if slotEnd > maxEnd:
            maxEnd = slotEnd
    return PrimaryAlignStackBytes(maxEnd, 16)

fn PrimaryBodyOpKindText(kind: int32): str =
    if kind == coreir.BodyOpLoadConstTag:
        return "load_const"
    if kind == coreir.BodyOpCallTag:
        return "call"
    if kind == coreir.BodyOpBinOpTag:
        return "bin_op"
    if kind == coreir.BodyOpCmpTag:
        return "cmp"
    if kind == coreir.BodyOpBranchTag:
        return "branch"
    if kind == coreir.BodyOpReturnTag:
        return "return"
    if kind == coreir.BodyOpLoadLocalTag:
        return "load_local"
    if kind == coreir.BodyOpStoreLocalTag:
        return "store_local"
    if kind == coreir.BodyOpCopyLocalTag:
        return "copy_local"
    return "invalid"

fn PrimaryBodyIrOpTargetsLocal(bodyIR: coreir.BodyIR,
                                op: coreir.BodyOp): bool =
    return op.target >= 0 && op.target < bodyIR.localSlots.len

fn PrimaryBodyIrLocalInitPrefixLen(bodyIR: coreir.BodyIR): int32 =
    var prefixLen: int32
    while prefixLen < bodyIR.ops.len:
        let op = bodyIR.ops[prefixLen]
        if (op.kind == coreir.BodyOpStoreLocalTag ||
            op.kind == coreir.BodyOpCopyLocalTag) &&
           PrimaryBodyIrOpTargetsLocal(bodyIR, op):
            prefixLen = prefixLen + 1
        elif op.kind == coreir.BodyOpLoadConstTag &&
             PrimaryBodyIrOpTargetsLocal(bodyIR, op):
            prefixLen = prefixLen + 1
        elif op.kind == coreir.BodyOpLoadConstTag &&
             prefixLen + 1 < bodyIR.ops.len &&
             (bodyIR.ops[prefixLen + 1].kind == coreir.BodyOpStoreLocalTag ||
              bodyIR.ops[prefixLen + 1].kind == coreir.BodyOpCopyLocalTag) &&
             PrimaryBodyIrOpTargetsLocal(bodyIR, bodyIR.ops[prefixLen + 1]):
            prefixLen = prefixLen + 1
        else:
            return prefixLen
    return prefixLen

fn PrimaryBodyIrHasCallOp(bodyIR: coreir.BodyIR): bool =
    for i in 0..<bodyIR.ops.len:
        if bodyIR.ops[i].kind == coreir.BodyOpCallTag:
            return true
    return false

fn PrimaryBodyIrMissingKind(bodyIR: coreir.BodyIR,
                             fallback: str): str =
    let localInitPrefixLen = PrimaryBodyIrLocalInitPrefixLen(bodyIR)
    if localInitPrefixLen > 0:
        if localInitPrefixLen < bodyIR.ops.len:
            return Fmt"body_ir_after_local_init_{PrimaryBodyOpKindText(bodyIR.ops[localInitPrefixLen].kind)}"
        return "body_ir_after_local_init_missing_op"
    if bodyIR.ops.len > 0:
        var callCount: int32
        var returnCount: int32
        for i in 0..<bodyIR.ops.len:
            if bodyIR.ops[i].kind == coreir.BodyOpCallTag:
                callCount = callCount + 1
            elif bodyIR.ops[i].kind == coreir.BodyOpReturnTag:
                returnCount = returnCount + 1
        return Fmt"body_ir_{PrimaryBodyOpKindText(bodyIR.ops[0].kind)}_ops_{bodyIR.ops.len}_calls_{callCount}_returns_{returnCount}_locals_{bodyIR.localSlots.len}"
    if bodyIR.localSlots.len > 0:
        return "body_ir_local_slots_missing_ops"
    return fallback

fn PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR: coreir.BodyIR): bool =
    let callCount = bodyIR.callSequence.len
    if callCount <= 0:
        return false
    if bodyIR.ops.len != callCount + 1:
        return false
    for i in 0..<callCount:
        let op = bodyIR.ops[i]
        if op.kind != coreir.BodyOpCallTag:
            return false
        if op.operands.len < 1:
            return false
        if op.operands[0] != i:
            return false
    let returnOp = bodyIR.ops[callCount]
    return returnOp.kind == coreir.BodyOpReturnTag &&
           returnOp.operands.len >= 1 &&
           returnOp.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsCallSequenceReturnPtr(bodyIR: coreir.BodyIR): bool =
    let callCount = bodyIR.callSequence.len
    if callCount <= 0:
        return false
    if bodyIR.ops.len != callCount + 1:
        return false
    for i in 0..<callCount:
        let op = bodyIR.ops[i]
        if op.kind != coreir.BodyOpCallTag:
            return false
        if op.operands.len < 1:
            return false
        if op.operands[0] != i:
            return false
    let returnOp = bodyIR.ops[callCount]
    return returnOp.kind == coreir.BodyOpReturnTag &&
           returnOp.operands.len == 1 &&
           returnOp.operands[0] == coreir.LocalPtrTag

fn PrimaryBodyIrIsCallSequenceReturnI32Const(bodyIR: coreir.BodyIR): bool =
    let callCount = bodyIR.callSequence.len
    if callCount <= 0:
        return false
    if bodyIR.ops.len != callCount + 1:
        return false
    for i in 0..<callCount:
        let op = bodyIR.ops[i]
        if op.kind != coreir.BodyOpCallTag:
            return false
        if op.operands.len < 1:
            return false
        if op.operands[0] != i:
            return false
    let returnOp = bodyIR.ops[callCount]
    return returnOp.kind == coreir.BodyOpReturnTag &&
           returnOp.operands.len >= 2 &&
           returnOp.operands[0] == PrimaryStatementReturnModeI32Const()

fn PrimaryBodyIrIsCallSequenceReturnStr(bodyIR: coreir.BodyIR): bool =
    let callCount = bodyIR.callSequence.len
    if callCount <= 0:
        return false
    if bodyIR.ops.len != callCount + 1:
        return false
    for i in 0..<callCount:
        let op = bodyIR.ops[i]
        if op.kind != coreir.BodyOpCallTag:
            return false
        if op.operands.len < 1:
            return false
        if op.operands[0] != i:
            return false
    let returnOp = bodyIR.ops[callCount]
    return returnOp.kind == coreir.BodyOpReturnTag &&
           returnOp.operands.len == 1 &&
           returnOp.operands[0] == coreir.LocalStrTag

fn PrimaryBodyIrIsCallSequenceReturnAggregate(bodyIR: coreir.BodyIR): bool =
    let callCount = bodyIR.callSequence.len
    if callCount <= 0:
        return false
    if bodyIR.ops.len != callCount + 1:
        return false
    for i in 0..<callCount:
        let op = bodyIR.ops[i]
        if op.kind != coreir.BodyOpCallTag:
            return false
        if op.operands.len < 1:
            return false
        if op.operands[0] != i:
            return false
    let returnOp = bodyIR.ops[callCount]
    return returnOp.kind == coreir.BodyOpReturnTag &&
           returnOp.operands.len == 1 &&
           returnOp.operands[0] == coreir.LocalAggregateTag

fn PrimaryBodyIrGuardBranchIndex(bodyIR: coreir.BodyIR): int32 =
    var branchIndex: int32 = -1
    for i in 0..<bodyIR.ops.len:
        let op = bodyIR.ops[i]
        if op.kind == coreir.BodyOpBranchTag:
            if branchIndex >= 0:
                return -1
            branchIndex = i
    return branchIndex

fn PrimaryBodyIrGuardBranchCallOrdinal(bodyIR: coreir.BodyIR): int32 =
    let branchIndex = PrimaryBodyIrGuardBranchIndex(bodyIR)
    if branchIndex < 0:
        return -1
    var callOrdinal: int32
    for i in 0..<branchIndex:
        if bodyIR.ops[i].kind != coreir.BodyOpCallTag:
            return -1
        callOrdinal = callOrdinal + 1
    return callOrdinal

fn PrimaryBodyIrWithoutGuardBranch(bodyIR: coreir.BodyIR): coreir.BodyIR =
    var out = bodyIR
    out.ops = []
    for i in 0..<bodyIR.ops.len:
        let op = bodyIR.ops[i]
        if op.kind != coreir.BodyOpBranchTag:
            add(out.ops, op)
    return out

fn PrimaryBodyIrIsCallSequenceGuardReturnInt32(bodyIR: coreir.BodyIR): bool =
    let callCount = bodyIR.callSequence.len
    if callCount <= 0 || bodyIR.ops.len != callCount + 2:
        return false
    let branchIndex = PrimaryBodyIrGuardBranchIndex(bodyIR)
    if branchIndex < 0 || branchIndex >= bodyIR.ops.len - 1:
        return false
    var seenCalls: int32
    for i in 0..<bodyIR.ops.len - 1:
        let op = bodyIR.ops[i]
        if i == branchIndex:
            if op.operands.len < 3:
                return false
            if op.operands[0] != coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag:
                return false
            let guardSlot = op.operands[1]
            if guardSlot < 0 || guardSlot >= bodyIR.localSlots.len:
                return false
            if bodyIR.localSlots[guardSlot].typeKind != coreir.LocalI32Tag:
                return false
        else:
            if op.kind != coreir.BodyOpCallTag:
                return false
            if op.operands.len < 1:
                return false
            if op.operands[0] != seenCalls:
                return false
            seenCalls = seenCalls + 1
    if seenCalls != callCount:
        return false
    let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
    if returnOp.kind != coreir.BodyOpReturnTag ||
       returnOp.operands.len != 1 ||
       returnOp.operands[0] != coreir.LocalI32Tag:
        return false
    let plainBodyIR = PrimaryBodyIrWithoutGuardBranch(bodyIR)
    return PrimaryBodyIrIsCallSequenceReturnInt32(plainBodyIR)

fn PrimaryBodyIrIsCallSequenceReturnSupported(bodyIR: coreir.BodyIR): bool =
    return PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnPtr(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnI32Const(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnStr(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnAggregate(bodyIR) ||
           PrimaryBodyIrIsCallSequenceGuardReturnInt32(bodyIR)

fn PrimaryBodyIrTermReturnsI32Slot(term: coreir.BodyTerm,
                                    slotIndex: int32): bool =
    if term.kind != coreir.BodyTermReturnTag:
        return false
    if term.resultSlot != slotIndex:
        return false
    return term.operands.len == 1 &&
           term.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsResultRequestDispatch(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 2 ||
       bodyIR.ops.len != 2 ||
       bodyIR.blocks.len != 3 ||
       bodyIR.terms.len != 3:
        return false
    let dispatchOp = bodyIR.ops[0]
    let unsupportedOp = bodyIR.ops[1]
    if dispatchOp.kind != coreir.BodyOpCallTag ||
       unsupportedOp.kind != coreir.BodyOpCallTag:
        return false
    if dispatchOp.operands.len != 1 ||
       unsupportedOp.operands.len != 1 ||
       dispatchOp.operands[0] != 0 ||
       unsupportedOp.operands[0] != 1:
        return false
    let dispatchSlot = bodyIR.callSequence[0].resultSlot
    let unsupportedSlot = bodyIR.callSequence[1].resultSlot
    if dispatchSlot < 0 || unsupportedSlot < 0:
        return false
    if dispatchOp.target != dispatchSlot ||
       unsupportedOp.target != unsupportedSlot:
        return false
    if dispatchSlot >= bodyIR.localSlots.len ||
       unsupportedSlot >= bodyIR.localSlots.len:
        return false
    if bodyIR.localSlots[dispatchSlot].typeKind != coreir.LocalI32Tag ||
       bodyIR.localSlots[unsupportedSlot].typeKind != coreir.LocalI32Tag:
        return false
    let entryBlock = bodyIR.blocks[0]
    let dispatchBlock = bodyIR.blocks[1]
    let unsupportedBlock = bodyIR.blocks[2]
    if entryBlock.opStart != 0 ||
       entryBlock.opCount != 0 ||
       dispatchBlock.opStart != 0 ||
       dispatchBlock.opCount != 1 ||
       unsupportedBlock.opStart != 1 ||
       unsupportedBlock.opCount != 1:
        return false
    if entryBlock.termIndex < 0 ||
       entryBlock.termIndex >= bodyIR.terms.len ||
       dispatchBlock.termIndex < 0 ||
       dispatchBlock.termIndex >= bodyIR.terms.len ||
       unsupportedBlock.termIndex < 0 ||
       unsupportedBlock.termIndex >= bodyIR.terms.len:
        return false
    let guardTerm = bodyIR.terms[entryBlock.termIndex]
    if guardTerm.kind != coreir.BodyTermCbrTag ||
       guardTerm.conditionKind != coreir.BodyCondLocalZeroTag ||
       guardTerm.lhsSlot != 0 - 1 - 1 ||
       guardTerm.resultSlot != 0 - 1 - 1 ||
       guardTerm.trueBlock != 2 ||
       guardTerm.falseBlock != 1:
        return false
    if guardTerm.operands.len < 3:
        return false
    if guardTerm.operands[0] != 0 ||
       guardTerm.operands[1] != 8 ||
       guardTerm.operands[2] != 208:
        return false
    if !PrimaryBodyIrTermReturnsI32Slot(bodyIR.terms[dispatchBlock.termIndex],
                                        dispatchSlot):
        return false
    return PrimaryBodyIrTermReturnsI32Slot(bodyIR.terms[unsupportedBlock.termIndex],
                                           unsupportedSlot)

fn PrimaryBodyIrIsPlainCallSequence(bodyIR: coreir.BodyIR): bool =
    let callCount = bodyIR.callSequence.len
    if callCount <= 0 || bodyIR.ops.len != callCount:
        return false
    for i in 0..<callCount:
        let op = bodyIR.ops[i]
        if op.kind != coreir.BodyOpCallTag:
            return false
        if op.operands.len < 1:
            return false
        if op.operands[0] != i:
            return false
        if op.target != bodyIR.callSequence[i].resultSlot:
            return false
    return true

fn PrimaryBodyIrTermReturnsI32(term: coreir.BodyTerm,
                                bodyIR: coreir.BodyIR): bool =
    if term.kind != coreir.BodyTermReturnTag:
        return false
    if term.operands.len <= 0:
        if term.resultSlot < 0 || term.resultSlot >= bodyIR.localSlots.len:
            return false
        return bodyIR.localSlots[term.resultSlot].typeKind == coreir.LocalI32Tag
    if term.operands[0] == coreir.LocalI32Tag:
        if term.resultSlot < 0 || term.resultSlot >= bodyIR.localSlots.len:
            return false
        return bodyIR.localSlots[term.resultSlot].typeKind == coreir.LocalI32Tag
    return term.operands[0] == PrimaryStatementReturnModeI32Const()

fn PrimaryBodyIrCbrConditionSupported(term: coreir.BodyTerm,
                                       bodyIR: coreir.BodyIR): bool =
    if term.kind != coreir.BodyTermCbrTag:
        return false
    if term.conditionKind != coreir.BodyCondLocalNonZeroTag &&
       term.conditionKind != coreir.BodyCondLocalZeroTag:
        return false
    var slotIndex = term.lhsSlot
    if slotIndex < 0:
        slotIndex = term.resultSlot
    if slotIndex < 0 || slotIndex >= bodyIR.localSlots.len:
        return false
    return bodyIR.localSlots[slotIndex].typeKind == coreir.LocalI32Tag

fn PrimaryBodyIrIsCallCfgReturnInt32(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len <= 0 ||
       bodyIR.ops.len <= 0 ||
       bodyIR.blocks.len <= 0 ||
       bodyIR.terms.len <= 0:
        return false
    for opIndex in 0..<bodyIR.ops.len:
        let op = bodyIR.ops[opIndex]
        if op.kind != coreir.BodyOpCallTag:
            return false
        if op.operands.len < 1:
            return false
        let callOrdinal = op.operands[0]
        if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
            return false
        if op.target != bodyIR.callSequence[callOrdinal].resultSlot:
            return false
    var returnTermCount: int32
    for blockIndex in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[blockIndex]
        if block.opStart < 0 ||
           block.opCount < 0 ||
           block.opStart + block.opCount > bodyIR.ops.len:
            return false
        if block.termIndex < 0 || block.termIndex >= bodyIR.terms.len:
            return false
        let term = bodyIR.terms[block.termIndex]
        if term.kind == coreir.BodyTermReturnTag:
            if !PrimaryBodyIrTermReturnsI32(term, bodyIR):
                return false
            returnTermCount = returnTermCount + 1
        elif term.kind == coreir.BodyTermBrTag:
            if term.trueBlock < 0 || term.trueBlock >= bodyIR.blocks.len:
                return false
            if term.trueBlock <= blockIndex:
                return false
        elif term.kind == coreir.BodyTermCbrTag:
            if !PrimaryBodyIrCbrConditionSupported(term, bodyIR):
                return false
            if term.trueBlock < 0 || term.trueBlock >= bodyIR.blocks.len ||
               term.falseBlock < 0 || term.falseBlock >= bodyIR.blocks.len:
                return false
            let nextBlock = blockIndex + 1
            if nextBlock >= bodyIR.blocks.len:
                return false
            if term.trueBlock == term.falseBlock:
                return false
            if term.trueBlock != nextBlock && term.falseBlock != nextBlock:
                return false
        else:
            return false
    return returnTermCount > 0

fn PrimaryBodyTermI32ConstReturn(term: coreir.BodyTerm,
                                  value: var int32): bool =
    value = 0
    if term.kind != coreir.BodyTermReturnTag:
        return false
    if term.operands.len < 2:
        return false
    if term.operands[0] != PrimaryStatementReturnModeI32Const():
        return false
    value = term.operands[1]
    return true

fn PrimaryBodyTermReturnOp(bodyIR: coreir.BodyIR,
                            term: coreir.BodyTerm,
                            op: var coreir.BodyOp): bool =
    if term.kind != coreir.BodyTermReturnTag:
        return false
    op = coreir.BodyOp()
    op.kind = coreir.BodyOpReturnTag
    op.target = term.resultSlot
    if term.operands.len > 0:
        for i in 0..<term.operands.len:
            add(op.operands, term.operands[i])
        return true
    if term.resultSlot >= 0 && term.resultSlot < bodyIR.localSlots.len:
        add(op.operands, bodyIR.localSlots[term.resultSlot].typeKind)
        return true
    return false

fn PrimaryBodyIrEntryBlockIndex(bodyIR: coreir.BodyIR): int32 =
    var fallback = -1
    for blockIndex in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[blockIndex]
        if block.opStart != 0:
            continue
        if fallback < 0:
            fallback = blockIndex
        if block.termIndex < 0 || block.termIndex >= bodyIR.terms.len:
            continue
        let term = bodyIR.terms[block.termIndex]
        if term.kind == coreir.BodyTermCbrTag ||
           term.kind == coreir.BodyTermBrTag:
            return blockIndex
    if fallback >= 0:
        return fallback
    return 0

fn PrimaryBodyIrNormalizeBlocksTerms(bodyIR: coreir.BodyIR): coreir.BodyIR =
    if bodyIR.blocks.len <= 0 || bodyIR.terms.len <= 0:
        return bodyIR
    var out = bodyIR
    out.ops = []
    var currentBlock: int32 = PrimaryBodyIrEntryBlockIndex(bodyIR)
    for _ in 0..<bodyIR.blocks.len:
        if currentBlock < 0 || currentBlock >= bodyIR.blocks.len:
            return bodyIR
        let block = bodyIR.blocks[currentBlock]
        if block.opStart < 0 || block.opCount < 0 ||
           block.opStart + block.opCount > bodyIR.ops.len ||
           block.termIndex < 0 || block.termIndex >= bodyIR.terms.len:
            return bodyIR
        for opIndex in block.opStart..<(block.opStart + block.opCount):
            let op = bodyIR.ops[opIndex]
            if op.kind != coreir.BodyOpCallTag:
                return bodyIR
            add(out.ops, op)
        let term = bodyIR.terms[block.termIndex]
        if term.kind == coreir.BodyTermReturnTag:
            var returnOp: coreir.BodyOp
            if !PrimaryBodyTermReturnOp(bodyIR, term, returnOp):
                return bodyIR
            add(out.ops, returnOp)
            return out
        if term.kind == coreir.BodyTermBrTag:
            let nextBlock = term.trueBlock
            if nextBlock < 0 || nextBlock == currentBlock:
                return bodyIR
            currentBlock = nextBlock
            continue
        if term.kind == coreir.BodyTermCbrTag:
            if term.conditionKind != coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag:
                return bodyIR
            if term.trueBlock < 0 || term.trueBlock >= bodyIR.blocks.len ||
               term.falseBlock < 0 || term.falseBlock >= bodyIR.blocks.len:
                return bodyIR
            let trueBlock = bodyIR.blocks[term.trueBlock]
            if trueBlock.opCount != 0 ||
               trueBlock.termIndex < 0 ||
               trueBlock.termIndex >= bodyIR.terms.len:
                return bodyIR
            var returnI32Value: int32
            if !PrimaryBodyTermI32ConstReturn(bodyIR.terms[trueBlock.termIndex],
                                              returnI32Value):
                return bodyIR
            var guardSlot = term.lhsSlot
            if guardSlot < 0:
                guardSlot = term.resultSlot
            if guardSlot < 0 || guardSlot >= bodyIR.localSlots.len:
                return bodyIR
            var branchOp: coreir.BodyOp
            branchOp.kind = coreir.BodyOpBranchTag
            branchOp.target = -1
            add(branchOp.operands, coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag)
            add(branchOp.operands, guardSlot)
            add(branchOp.operands, returnI32Value)
            add(out.ops, branchOp)
            if term.falseBlock == currentBlock:
                return bodyIR
            currentBlock = term.falseBlock
            continue
        return bodyIR
    return bodyIR

fn PrimaryBodyIrNormalizeCallSequenceReturn(bodyIR: coreir.BodyIR,
                                             bodyKind: str,
                                             statementMode: int32,
                                             statementI32Value: int32): coreir.BodyIR =
    var out = PrimaryBodyIrNormalizeBlocksTerms(bodyIR)
    if PrimaryBodyIrIsCallSequenceReturnSupported(out):
        return out
    if !PrimaryBodyIrIsPlainCallSequence(out):
        return out
    var returnMode = statementMode
    var returnI32Value = statementI32Value
    if returnMode == PrimaryStatementReturnModeNone():
        if bodyKind == texpr.BodyKindReturnZeroI32:
            returnMode = PrimaryStatementReturnModeI32Const()
            returnI32Value = 0
        elif bkind.BodyKindIsReturnI32Const(bodyKind):
            let parseRes = bkind.BodyKindParseReturnI32Const(bodyKind,
                                                             "primary_body_ir_normalize_call_sequence")
            if IsOk(parseRes):
                returnMode = PrimaryStatementReturnModeI32Const()
                returnI32Value = Value(parseRes)
    if returnMode == PrimaryStatementReturnModeI32Const():
        var returnOp: coreir.BodyOp
        returnOp.kind = coreir.BodyOpReturnTag
        returnOp.target = -1
        add(returnOp.operands, PrimaryStatementReturnModeI32Const())
        add(returnOp.operands, returnI32Value)
        add(out.ops, returnOp)
    return out

fn PrimaryBodyIrIsPtrNilGuardDerefReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 1:
        return false
    if bodyIR.ops.len != 4:
        return false
    let callOp = bodyIR.ops[0]
    let branchOp = bodyIR.ops[1]
    let loadOp = bodyIR.ops[2]
    let returnOp = bodyIR.ops[3]
    if callOp.kind != coreir.BodyOpCallTag ||
       branchOp.kind != coreir.BodyOpBranchTag ||
       loadOp.kind != coreir.BodyOpLoadLocalTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if branchOp.operands.len < 3:
        return false
    if loadOp.operands.len < 3:
        return false
    if returnOp.operands.len < 1:
        return false
    let resultSlot = bodyIR.callSequence[0].resultSlot
    return branchOp.operands[0] == coreir.BodyBranchIfLocalNilReturnI32ConstTag &&
           branchOp.operands[1] == resultSlot &&
           branchOp.operands[2] == 0 &&
           loadOp.operands[0] == coreir.BodyLoadLocalPtrDerefI32Tag &&
           loadOp.operands[1] == resultSlot &&
	           loadOp.operands[2] == coreir.LocalI32Tag &&
	           returnOp.target == resultSlot &&
	           returnOp.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsI32TwoCallGuardFirstReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 2:
        return false
    if bodyIR.ops.len != 4:
        return false
    let firstCallOp = bodyIR.ops[0]
    let secondCallOp = bodyIR.ops[1]
    let branchOp = bodyIR.ops[2]
    let returnOp = bodyIR.ops[3]
    if firstCallOp.kind != coreir.BodyOpCallTag ||
       secondCallOp.kind != coreir.BodyOpCallTag ||
       branchOp.kind != coreir.BodyOpBranchTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if branchOp.operands.len < 3:
        return false
    if returnOp.operands.len < 1:
        return false
    return branchOp.operands[0] == coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag &&
           branchOp.operands[1] == bodyIR.callSequence[1].resultSlot &&
           branchOp.operands[2] == 0 &&
           returnOp.target == bodyIR.callSequence[0].resultSlot &&
           returnOp.operands[0] == coreir.LocalI32Tag

