        entryFunctionSymbol: str
        itemIds: int32[]
        symbolNames: str[]
        functionWordOffsets: int32[]
        functionWordCounts: int32[]
        functionBodyKinds: str[]
        functionStatementReturnModes: int32[]
        functionStatementReturnI32Values: int32[]
        functionStatementCallCounts: int32[]
        functionBodyIRs: coreir.BodyIR[]
        instructionWords: int32[]
        dataLabels: str[]
        dataPayloadTexts: str[]
        relocSourceItemIds: int32[]
        relocWordOffsets: int32[]
        relocTargetSymbols: str[]
        dataRelocSourceItemIds: int32[]
        dataRelocWordOffsets: int32[]
        dataRelocTargetSymbols: str[]
        reachableFunctionCount: int32
        firstMissingFunction: str
        firstMissingBodyKind: str
        firstMissingTypedIrKind: str
        firstMissingLineNumber: int32
        firstMissingWordOffset: int32
        firstMissingWordRelOffset: int32
        firstMissingWordCount: int32
        firstMissingBodyIrOpCount: int32
        firstMissingBodyIrTermCount: int32
        firstMissingBodyIrBlockCount: int32
        firstMissingBodyIrCallCount: int32
        firstMissingBodyIrSlotCount: int32
        firstMissingBodyIrLastTermKind: int32
        firstMissingBodyIrLastTermResultSlot: int32
        firstMissingBodyIrLastTermOperand0: int32
        firstMissingBodyIrLastTermResultType: int32
        firstMissingBodyIrLastCallResultSlot: int32
        firstMissingBodyIrLastCallResultType: int32
        firstMissingBodyIrLastCallTarget: str
        firstMissingBodyIrLastCallTargetSourcePath: str
        firstMissingBodyIrFirstZeroOpIndex: int32
        firstMissingBodyIrFirstZeroOpKind: int32
        firstMissingBodyIrFirstZeroOpTarget: int32
        firstMissingBodyIrFirstZeroOpOperand0: int32
        firstMissingBodyIrFirstZeroOpOperand1: int32
        firstMissingBodyIrFirstZeroOpOperand2: int32
        firstMissingBodyIrFirstZeroOpOperand3: int32
        firstMissingBodyIrFirstZeroBaseSlotName: str
        firstMissingBodyIrFirstZeroBaseSlotType: int32
        firstMissingBodyIrFirstZeroBaseSlotSize: int32
        firstMissingBodyIrFirstZeroBaseSlotOffset: int32
