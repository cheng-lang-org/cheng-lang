fn PrimaryTargetSymbolName(targetTriple: str,
                             raw: str): str =
    if targetTriple == "arm64-apple-darwin" ||
       targetTriple == "aarch64-apple-ios" ||
       targetTriple == "arm64-apple-ios":
        if len(raw) > 0 && raw[0] == '_':
            return raw
        if len(raw) >= 2 && raw[0] == 'L' && raw[1] == '_':
            return raw
        return Fmt"_{raw}"
    return raw

fn PrimarySanitizeSymbolPart(text: str): str =
    var out = ""
    for i in 0..<len(text):
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            out = Fmt"{out}{strings.SliceBytes(text, i, 1)}"
        else:
            out = Fmt"{out}_"
    return out

fn PrimarySymbolNameForFunction(targetTriple: str,
                                  symbolText: str,
                                  signatureLineNumber: int32,
                                  emitKind: creq.CompilerEmit): str =
    var raw = symbolText
    var lineScoped = false
    if len(raw) == 0:
        raw = "cheng_primary_unnamed"
    if len(raw) >= 2:
        for i in 0..<(len(raw) - 1):
            if raw[i] == ':' && raw[i + 1] == ':':
                lineScoped = true
    raw = PrimarySanitizeSymbolPart(raw)
    if lineScoped && signatureLineNumber > 0:
        raw = Fmt"{raw}__L{strings.IntToStr(signatureLineNumber)}"
    return PrimaryTargetSymbolName(targetTriple, raw)

fn PrimaryRuntimeEntryBridgeSymbol(linkPlan: slplan.SystemLinkPlanStub): str =
    var raw = "cheng_program_argv_entry"
    if linkPlan.moduleKind == slplan.SystemCompilerControlPlane:
        raw = "cheng_tooling_argv_entry"
    return PrimaryTargetSymbolName(linkPlan.targetTriple, raw)

fn PrimaryStartsWith(text: str,
                      prefix: str): bool =
    if len(prefix) > len(text):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true

fn PrimaryPathTrimStart(text: str): int32 =
    var start: int32
    while start < len(text):
        let code = Int32(text[start])
        if code != 32 && code != 9 && code != 10 && code != 13:
            break
        start = start + 1
    return start

fn PrimaryPathTrimStop(text: str,
                         start: int32): int32 =
    var stop = len(text)
    while stop > start:
        let code = Int32(text[stop - 1])
        if code != 32 && code != 9 && code != 10 && code != 13:
            break
        stop = stop - 1
    return stop

fn PrimaryPathNormalizedStop(text: str,
                               start: int32,
                               stopRaw: int32): int32 =
    var stop = stopRaw
    while stop > start + 1:
        let last = text[stop - 1]
        if last != '/' && last != '\\':
            break
        stop = stop - 1
    return stop

fn PrimaryPathNormalizedEquals(left: str,
                                 right: str): bool =
    let leftStart = PrimaryPathTrimStart(left)
    let rightStart = PrimaryPathTrimStart(right)
    let leftStop = PrimaryPathNormalizedStop(left, leftStart, PrimaryPathTrimStop(left, leftStart))
    let rightStop = PrimaryPathNormalizedStop(right, rightStart, PrimaryPathTrimStop(right, rightStart))
    let leftLen = leftStop - leftStart
    let rightLen = rightStop - rightStart
    if leftLen != rightLen:
        return false
    for i in 0..<leftLen:
        if left[leftStart + i] != right[rightStart + i]:
            return false
    return true

fn PrimaryFunctionTailName(functionName: str): str =
    var tailStart = 0
    if len(functionName) >= 2:
        for j in 0..<(len(functionName) - 1):
            if functionName[j] == ':' && functionName[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < len(functionName):
        return strings.SliceBytes(functionName, tailStart, len(functionName) - tailStart)
    return functionName

fn PrimaryCallTargetTailName(targetText: str): str =
    var tailStart = 0
    for i in 0..<len(targetText):
        if targetText[i] == '.':
            tailStart = i + 1
    if len(targetText) >= 2:
        for j in 0..<(len(targetText) - 1):
            if targetText[j] == ':' && targetText[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < len(targetText):
        return strings.SliceBytes(targetText, tailStart, len(targetText) - tailStart)
    return targetText

fn PrimaryObjectIrFunctionIndex(ir: lower.PrimaryObjectIr,
                                  sourcePath: str,
                                  functionName: str): int32 =
    let tailName = PrimaryFunctionTailName(functionName)
    for i in 0..<ir.functions.len:
        if !PrimaryPathNormalizedEquals(ir.functions[i].sourcePath, sourcePath):
            continue
        if ir.functions[i].functionName == functionName ||
           ir.functions[i].functionName == tailName:
            return i
    return -1

fn PrimaryFunctionTargetSymbol(functionSymbolTexts: str[],
                                 functionSourcePaths: str[],
                                 allSymbolNames: str[],
                                 targetSourcePath: str,
                                 targetText: str): str =
    let targetTail = PrimaryCallTargetTailName(targetText)
    for i in 0..<functionSymbolTexts.len:
        if i >= functionSourcePaths.len:
            continue
        if !PrimaryPathNormalizedEquals(functionSourcePaths[i], targetSourcePath):
            continue
        if i >= allSymbolNames.len:
            continue
        if functionSymbolTexts[i] == targetText ||
           PrimaryFunctionTailName(functionSymbolTexts[i]) == targetTail:
            return allSymbolNames[i]
    return ""

fn PrimaryFunctionTargetIndex(functionSymbolTexts: str[],
                               functionSourcePaths: str[],
                               targetSourcePath: str,
                               targetText: str): int32 =
    let targetTail = PrimaryCallTargetTailName(targetText)
    for i in 0..<functionSymbolTexts.len:
        if i >= functionSourcePaths.len:
            continue
        if !PrimaryPathNormalizedEquals(functionSourcePaths[i], targetSourcePath):
            continue
        if functionSymbolTexts[i] == targetText ||
           PrimaryFunctionTailName(functionSymbolTexts[i]) == targetTail:
            return i
    return -1

fn PrimaryBoolSeqInit(count: int32,
                       value: bool): bool[] =
    var out: bool[]
    for _ in 0..<count:
        add(out, value)
    return out

fn PrimaryIntSeqInit(count: int32,
                      value: int32): int32[] =
    var out: int32[]
    for _ in 0..<count:
        add(out, value)
    return out

fn PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind: str): bool =
    return PrimaryStartsWith(bodyKind, texpr.BodyKindLetCallNoargReturnI32ConstPrefix)

fn PrimaryStatementReturnModeNone(): int32 =
    return 0

fn PrimaryStatementReturnModeI32Const(): int32 =
    return 1

fn PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len <= 0:
        return false
    if bodyIR.ops.len <= 0:
        return false
    let lastIndex = bodyIR.ops.len - 1
    let lastOp = bodyIR.ops[lastIndex]
    if lastOp.kind != coreir.BodyOpReturnTag:
        return false
    if lastOp.operands.len <= 0:
        return false
    if lastOp.operands[0] == coreir.LocalI32Tag:
        return true
    if lastOp.operands[0] == PrimaryStatementReturnModeI32Const():
        return true
    return false

fn PrimaryStatementReturnModeCallResultI32(): int32 =
    return 2

fn PrimaryStatementReturnModeI32GuardResultLeZero(): int32 =
    return 3

fn PrimaryStatementReturnModeStrLen(): int32 =
    return 4

fn PrimaryStatementReturnModeStrThenCallReturnI32Const0(): int32 =
    return 5

fn PrimaryStatementReturnModeStrI32GuardArg0Return0(): int32 =
    return 6

fn PrimaryStatementReturnModeStrI32GuardArg0ElseCallArg0Arg1ReturnResultI32(): int32 =
    return 7

fn PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0(): int32 =
    return texpr.StatementReturnModeCstringLiteralCallsReturnI32Const0

fn PrimaryBodyIrGeneralCfgWordCount(bodyIR: coreir.BodyIR): int32 =
    let frameBytes = PrimaryBodyIrFrameBytes(bodyIR)
    if frameBytes <= 0:
        return 0
    var count = PrimaryBodyIrPrologueWordCount(bodyIR)
    for i in 0..<bodyIR.ops.len:
        let opSize = PrimaryBodyIROpSizeAt(bodyIR, i)
        if opSize <= 0:
            return 0
        count = count + opSize
    for i in 0..<bodyIR.terms.len:
        let termSize = PrimaryBodyIRTermSize(bodyIR, i)
        if termSize <= 0:
            return 0
        count = count + termSize
    return count

fn PrimaryBodyIrExtractIntFromText(text: str): int32 =
    var out: int32
    var parenPos: int32
    parenPos = -1
    for i in 0..<len(text):
        if text[i] == '(':
            parenPos = i
    if parenPos >= 0:
        var j = parenPos + 1
        while j < len(text):
            let ch = text[j]
            if ch >= '0' && ch <= '9':
                out = out * 10 + int32(ch) - int32('0')
            elif out > 0:
                break
            j = j + 1
    if out == 0:
        var capturing = false
        for i in 0..<len(text):
            let ch = text[i]
            if ch >= '0' && ch <= '9':
                capturing = true
                out = out * 10 + int32(ch) - int32('0')
            elif capturing:
                break
    return out

fn PrimaryBodyIrParseCondition(
    conditionText: str,
    var lhsText: str,
    var rhsText: str,
    var cmpTag: int32
): bool =
    var opPos: int32 = -1
    var opLen: int32
    var tag: int32
    for i in 0..<len(conditionText):
        let ch = conditionText[i]
        if ch == '=' && i + 1 < len(conditionText) && conditionText[i + 1] == '=':
            opPos = i; opLen = 2; tag = coreir.BodyCondI32EqTag; break
        if ch == '!' && i + 1 < len(conditionText) && conditionText[i + 1] == '=':
            opPos = i; opLen = 2; tag = coreir.BodyCondI32NeTag; break
        if ch == '<' && i + 1 < len(conditionText) && conditionText[i + 1] == '=':
            opPos = i; opLen = 2; tag = coreir.BodyCondI32LeTag; break
        if ch == '>' && i + 1 < len(conditionText) && conditionText[i + 1] == '=':
            opPos = i; opLen = 2; tag = coreir.BodyCondI32GeTag; break
        if ch == '<' && (i + 1 >= len(conditionText) || conditionText[i + 1] != '='):
            opPos = i; opLen = 1; tag = coreir.BodyCondI32LtTag; break
        if ch == '>' && (i + 1 >= len(conditionText) || conditionText[i + 1] != '='):
            opPos = i; opLen = 1; tag = coreir.BodyCondI32GtTag; break
    if opPos < 0:
        return false
    lhsText = strings.SliceBytes(conditionText, 0, opPos)
    var lhsEnd = len(lhsText)
    while lhsEnd > 0 && lhsText[lhsEnd - 1] == ' ':
        lhsEnd = lhsEnd - 1
    lhsText = strings.SliceBytes(lhsText, 0, lhsEnd)
    var rhsRaw = strings.SliceBytes(conditionText, opPos + opLen, len(conditionText) - opPos - opLen)
    var rhsStart: int32
    while rhsStart < len(rhsRaw) && rhsRaw[rhsStart] == ' ':
        rhsStart = rhsStart + 1
    rhsText = strings.SliceBytes(rhsRaw, rhsStart, len(rhsRaw) - rhsStart)
    cmpTag = tag
    return true

fn PrimaryBodyIrNextLocalStackOffset(bodyIR: coreir.BodyIR,
                                      sizeBytes: int32,
                                      alignBytes: int32): int32 =
    var offset: int32 = 16
    for i in 0..<bodyIR.localSlots.len:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[i]):
            continue
        let slotSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[i])
        if slotSize <= 0:
            continue
        let slotEnd = bodyIR.localSlots[i].stackOffset + slotSize
        if slotEnd > offset:
            offset = slotEnd
    var align = alignBytes
    if align <= 0:
        align = 1
    if align > 16:
        align = 16
    return ((offset + align - 1) / align) * align

fn PrimaryBodyIrReflowLocalStackOffsets(bodyIR: var coreir.BodyIR) =
    var offset: int32 = 16
    for i in 0..<bodyIR.localSlots.len:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[i]):
            continue
        let slotSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[i])
        if slotSize <= 0:
            continue
        var align = bodyIR.localSlots[i].alignBytes
        if align <= 0:
            align = 1
        if align > 16:
            align = 16
        offset = ((offset + align - 1) / align) * align
        bodyIR.localSlots[i].stackOffset = offset
        offset = offset + slotSize

fn PrimaryBodyIrLocalSlotNewSized(bodyIR: var coreir.BodyIR,
                                   slotId: int32,
                                   name: str,
                                   typeKind: int32,
                                   sizeBytes: int32,
                                   alignBytes: int32) =
    var ls: coreir.LocalSlot
    ls.id = slotId
    ls.name = name
    ls.typeKind = typeKind
    ls.placeKind = coreir.BodyPlaceStackValueTag
    ls.ownership = coreir.OwnPlainTag
    ls.aliasClass = coreir.AliasUnknownTag
    ls.escapeKind = coreir.EscapeNoneTag
    ls.noAlias = false
    if typeKind == coreir.LocalI32Tag:
        ls.sizeBytes = 4
        ls.alignBytes = 4
    elif typeKind == coreir.LocalI64Tag:
        ls.sizeBytes = 8
        ls.alignBytes = 8
    elif typeKind == coreir.LocalF64Tag:
        ls.sizeBytes = 8
        ls.alignBytes = 8
    elif typeKind == coreir.LocalStrTag:
        ls.sizeBytes = 24
        ls.alignBytes = 8
    elif typeKind == coreir.LocalPtrTag:
        ls.sizeBytes = 8
        ls.alignBytes = 8
    elif typeKind == coreir.LocalAggregateTag:
        ls.sizeBytes = coreir.ResultStrSizeBytes
        ls.alignBytes = coreir.ResultStrAlignBytes
    if sizeBytes > 0:
        ls.sizeBytes = sizeBytes
    if alignBytes > 0:
        ls.alignBytes = alignBytes
    ls.stackOffset = PrimaryBodyIrNextLocalStackOffset(bodyIR, ls.sizeBytes, ls.alignBytes)
    add(bodyIR.localSlots, ls)

fn PrimaryBodyIrLocalSlotNew(bodyIR: var coreir.BodyIR,
                              slotId: int32,
                              name: str,
                              typeKind: int32) =
    PrimaryBodyIrLocalSlotNewSized(bodyIR, slotId, name, typeKind, 0, 0)

fn PrimaryBodyIrTypeKindFromText(typeRaw: str): int32 =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    if PrimaryStartsWith(normType, "var"):
        return coreir.LocalPtrTag
    if len(normType) > 0 && normType[len(normType) - 1] == '*':
        return coreir.LocalPtrTag
    if len(normType) > 3 &&
       strings.SliceBytes(normType, len(normType) - 3, 3) == "Ptr":
        return coreir.LocalPtrTag
    if normType == "int64" || normType == "uint64" || normType == "u64" || normType == "i64":
        return coreir.LocalI64Tag
    if normType == "float64" || normType == "f64":
        return coreir.LocalF64Tag
    if normType == "str":
        return coreir.LocalStrTag
    if normType == "cstring" || normType == "ptr" || normType == "void*":
        return coreir.LocalPtrTag
    if normType == "Bytes" ||
       normType == "bytes.Bytes" ||
       normType == "rawbytes.Bytes" ||
       normType == "ByteBuffer" ||
       normType == "buffer.ByteBuffer":
        return coreir.LocalAggregateTag
    if PrimaryStartsWith(normType, "Result["):
        return coreir.LocalAggregateTag
    if len(normType) > 0:
        var leafStart = 0
        for ci in 0..<len(normType):
            if normType[ci] == '.':
                leafStart = ci + 1
        let firstCh = normType[leafStart]
        if firstCh >= 'A' && firstCh <= 'Z':
            return coreir.LocalPtrTag
    return coreir.LocalI32Tag

fn PrimaryBodyIrTypeShapeFromText(typedIr: texpr.TypedExprIr,
                                   sourcePath: str,
                                   typeRaw: str,
                                   typeKind: var int32,
                                   sizeBytes: var int32,
                                   alignBytes: var int32) =
    typeKind = PrimaryBodyIrTypeKindFromText(typeRaw)
    sizeBytes = 0
    alignBytes = 0
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    let isVarOrPtrType = PrimaryStartsWith(normType, "var") ||
                         (len(normType) > 0 && normType[len(normType) - 1] == '*')
    if !isVarOrPtrType && texpr.TypedExprIrTypeIsEnum(typedIr, sourcePath, typeRaw):
        typeKind = coreir.LocalI32Tag
        sizeBytes = 4
        alignBytes = 4
        return
    var layoutSize: int32
    var layoutAlign: int32
    var layoutFieldCount: int32
    if !texpr.TypedExprIrLookupTypeLayout(typedIr,
                                          sourcePath,
                                          typeRaw,
                                          layoutSize,
                                          layoutAlign,
                                          layoutFieldCount):
        return
    if layoutSize <= 0 || layoutAlign <= 0:
        return
    sizeBytes = layoutSize
    alignBytes = layoutAlign
    if typeKind == coreir.LocalI32Tag &&
       (layoutFieldCount > 0 || layoutSize > 8):
        typeKind = coreir.LocalAggregateTag

fn PrimaryBodyIrTypeTextIsVarI32(typeRaw: str): bool =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    return normType == "varint32" || normType == "vari32" || normType == "varbool"

fn PrimaryBodyIrNameInList(names: str[], name: str): bool =
    for i in 0..<names.len:
        if names[i] == name:
            return true
    return false

fn PrimaryBodyIrReturnTypeIsVoid(typeRaw: str): bool =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    return normType == "" || normType == "void"

fn PrimaryBodyIrCallFullText(stmt: texpr.TypedExprIrStatement): str =
    if stmt.callArgCount > 0:
        return Fmt"{stmt.surfaceText}({stmt.callArgsText})"
    return Fmt"{stmt.surfaceText}()"

fn PrimaryBodyIrVarI32ValueSlotName(name: str): str =
    return Fmt"{name}#var_i32_value"

fn PrimaryBodyIrFindOrCreateSlot(bodyIR: var coreir.BodyIR,
                                  slotNames: var str[],
                                  name: str,
                                  typeKind: int32): int32 =
    for i in 0..<slotNames.len:
        if slotNames[i] == name:
            return i
    let newSlot = slotNames.len
    add(slotNames, name)
    PrimaryBodyIrLocalSlotNew(bodyIR, newSlot, name, typeKind)
    return newSlot

fn PrimaryBodyIrFindOrCreateSlotSized(bodyIR: var coreir.BodyIR,
                                       slotNames: var str[],
                                       name: str,
                                       typeKind: int32,
                                       sizeBytes: int32,
                                       alignBytes: int32): int32 =
    for i in 0..<slotNames.len:
        if slotNames[i] == name:
            if i < bodyIR.localSlots.len && sizeBytes > 0 && alignBytes > 0:
                var slot = bodyIR.localSlots[i]
                let currentSize = PrimaryLocalSlotSizeOf(slot)
                var changed = false
                if currentSize < sizeBytes:
                    slot.sizeBytes = sizeBytes
                    changed = true
                if slot.alignBytes < alignBytes:
                    slot.alignBytes = alignBytes
                    changed = true
                if slot.typeKind != typeKind &&
                   (slot.typeKind == coreir.LocalI32Tag ||
                    slot.typeKind == coreir.LocalAggregateTag ||
                    typeKind == coreir.LocalAggregateTag):
                    slot.typeKind = typeKind
                    changed = true
                if changed:
                    bodyIR.localSlots[i] = slot
                    PrimaryBodyIrReflowLocalStackOffsets(bodyIR)
            return i
    let newSlot = slotNames.len
    add(slotNames, name)
    PrimaryBodyIrLocalSlotNewSized(bodyIR, newSlot, name, typeKind, sizeBytes, alignBytes)
    return newSlot

fn PrimaryBodyIrFindOrCreateTypedSlot(bodyIR: var coreir.BodyIR,
                                       slotNames: var str[],
                                       typedIr: texpr.TypedExprIr,
                                       sourcePath: str,
                                       name: str,
                                       typeRaw: str): int32 =
    var typeKind: int32
    var sizeBytes: int32
    var alignBytes: int32
    PrimaryBodyIrTypeShapeFromText(typedIr, sourcePath, typeRaw, typeKind, sizeBytes, alignBytes)
    return PrimaryBodyIrFindOrCreateSlotSized(bodyIR,
                                              slotNames,
                                              name,
                                              typeKind,
                                              sizeBytes,
                                              alignBytes)

fn PrimaryBodyIrFindSlotIndex(slotNames: str[], name: str): int32 =
    for i in 0..<slotNames.len:
        if slotNames[i] == name:
            return i
    return -1

fn PrimaryBodyIrTypedGlobalType(typedIr: texpr.TypedExprIr,
                                 sourcePath: str,
                                 name: str): str =
    var found = ""
    for i in 0..<typedIr.globalNames.len:
        if i >= typedIr.globalSourcePaths.len || i >= typedIr.globalTypes.len:
            continue
        if typedIr.globalNames[i] != name:
            continue
        if PrimaryPathNormalizedEquals(typedIr.globalSourcePaths[i], sourcePath):
            return typedIr.globalTypes[i]
        if found == "":
            found = typedIr.globalTypes[i]
        else:
            found = ""
    return found

fn PrimaryBodyIrTypedGlobalSlotName(typedIr: texpr.TypedExprIr,
                                     sourcePath: str,
                                     name: str): str =
    var found = ""
    for i in 0..<typedIr.globalNames.len:
        if i >= typedIr.globalSourcePaths.len:
            continue
        if typedIr.globalNames[i] != name:
            continue
        let slotName = Fmt"{typedIr.globalSourcePaths[i]}::{name}"
        if PrimaryPathNormalizedEquals(typedIr.globalSourcePaths[i], sourcePath):
            return slotName
        if found == "":
            found = slotName
        else:
            found = ""
    return found

fn PrimaryBodyIrCanonicalArgName(argRaw: str): str =
    let arg = strutil.Strip(argRaw)
    var openPos: int32 = -1
    for i in 0..<len(arg):
        if arg[i] == '(':
            openPos = i
            break
    if openPos <= 0:
        return arg
    var tailStart: int32
    for i in 0..<openPos:
        if arg[i] == '.':
            tailStart = i + 1
    if tailStart <= 0:
        return arg
    return strings.SliceBytes(arg, tailStart, len(arg) - tailStart)

fn PrimaryBodyIrFindArgSlot(slotNames: str[], argName: str): int32 =
    let exact = PrimaryBodyIrFindSlotIndex(slotNames, argName)
    if exact >= 0:
        return exact
    let canonical = PrimaryBodyIrCanonicalArgName(argName)
    if canonical != argName:
        return PrimaryBodyIrFindSlotIndex(slotNames, canonical)
    return -1

fn PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR: var coreir.BodyIR,
                                           slotNames: var str[],
                                           typedIr: texpr.TypedExprIr,
                                           sourcePath: str,
                                           rootName: str,
                                           rootTypeRaw: str): int32 =
    let rootType = texpr.TypedExprNormalizeTypeText(rootTypeRaw)
    if rootName == "":
        return -1
    if rootType == "" || PrimaryStartsWith(rootType, "var"):
        return PrimaryBodyIrFindArgSlot(slotNames, rootName)
    return PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                              slotNames,
                                              typedIr,
                                              sourcePath,
                                              rootName,
                                              rootType)

fn PrimaryBodyIrBindingTypeForName(typedIr: texpr.TypedExprIr,
                                    typedFn: texpr.TypedExprIrFunction,
                                    irFunction: lower.PrimaryObjectIrFunction,
                                    lineNumber: int32,
                                    nameRaw: str): str =
    let name = strutil.Strip(nameRaw)
    if name == "":
        return ""
    for i in 0..<irFunction.paramNames.len:
        if i >= irFunction.paramTypes.len:
            continue
        if irFunction.paramNames[i] == name:
            return irFunction.paramTypes[i]
    var stmtEnd = typedFn.statementStart + typedFn.statementCount
    if stmtEnd > typedIr.statements.len:
        stmtEnd = typedIr.statements.len
    var foundType = ""
    for i in typedFn.statementStart..<stmtEnd:
        let stmt = typedIr.statements[i]
        if stmt.lineNumber >= lineNumber:
            continue
        if stmt.bindingName != name:
            continue
        if stmt.resultType != "" &&
           stmt.resultType != "unknown" &&
           stmt.resultType != "call_expr":
            foundType = stmt.resultType
    return foundType

fn PrimaryBodyIrMaterializeFieldArgSlot(bodyIR: var coreir.BodyIR,
                                         slotNames: var str[],
                                         typedIr: texpr.TypedExprIr,
                                         typedFn: texpr.TypedExprIrFunction,
                                         irFunction: lower.PrimaryObjectIrFunction,
                                         sourcePath: str,
                                         lineNumber: int32,
                                         argTextRaw: str,
                                         failureDetail0: var int32,
                                         failureDetail1: var int32): int32 =
    let argText = strutil.Strip(argTextRaw)
    if !texpr.TypedExprTextIsSimpleFieldPath(argText):
        failureDetail0 = 431
        return -1
    if strutil.Contains(argText, "->"):
        failureDetail0 = 431
        return -1
    let rootName = texpr.TypedExprAssignLhsRootName(argText)
    let fieldPath = texpr.TypedExprAssignFieldPath(argText)
    if rootName == "" || fieldPath == "":
        failureDetail0 = 432
        return -1
    let rootType = PrimaryBodyIrBindingTypeForName(typedIr,
                                                   typedFn,
                                                   irFunction,
                                                   lineNumber,
                                                   rootName)
    if rootType == "":
        failureDetail0 = 433
        return -1
    var fieldType = ""
    var fieldOffsetBytes: int32
    var fieldSizeBytes: int32
    var fieldAlignBytes: int32
    if !texpr.TypedExprIrLookupFieldPathMeta(typedIr,
                                             sourcePath,
                                             rootType,
                                             fieldPath,
                                             fieldType,
                                             fieldOffsetBytes,
                                             fieldSizeBytes,
                                             fieldAlignBytes):
        failureDetail0 = 434
        return -1
    let baseSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                          slotNames,
                                                          typedIr,
                                                          sourcePath,
                                                          rootName,
                                                          rootType)
    if baseSlot < 0:
        failureDetail0 = 435
        return -1
    let valueSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                       slotNames,
                                                       typedIr,
                                                       sourcePath,
                                                       Fmt"{argText}#field_arg",
                                                       fieldType)
    if valueSlot < 0 ||
       fieldOffsetBytes < 0 ||
       fieldSizeBytes <= 0 ||
       PrimaryLocalSlotSizeOf(bodyIR.localSlots[valueSlot]) < fieldSizeBytes:
        failureDetail0 = 436
        failureDetail1 = fieldSizeBytes
        return -1
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpFieldLoadTag
    op.target = valueSlot
    add(op.operands, baseSlot)
    add(op.operands, valueSlot)
    add(op.operands, fieldOffsetBytes)
    add(op.operands, fieldSizeBytes)
    add(bodyIR.ops, op)
    return valueSlot

fn PrimaryBodyIrAlignedOffset(offset: int32, alignRaw: int32): int32 =
    var align = alignRaw
    if align <= 0:
        align = 1
    return ((offset + align - 1) / align) * align

fn PrimaryBodyIrMarkParamSlot(bodyIR: var coreir.BodyIR,
                               slotId: int32,
                               paramSlot: int32) =
    if slotId < 0 || slotId >= bodyIR.localSlots.len:
        return
    bodyIR.localSlots[slotId].stackOffset = 0 - 1 - paramSlot

fn PrimaryBodyIrLocalIsParam(slot: coreir.LocalSlot): bool =
    return slot.stackOffset < 0

fn PrimaryBodyIrParamIndex(slot: coreir.LocalSlot): int32 =
    if slot.stackOffset >= 0:
        return -1
    return 0 - 1 - slot.stackOffset

fn PrimaryBodyIrParamCopyCount(bodyIR: coreir.BodyIR): int32 =
    var count: int32
    for i in 0..<bodyIR.localSlots.len:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[i]):
            count = count + 1
    return count

fn PrimaryBodyIrPrologueWordCount(bodyIR: coreir.BodyIR): int32 =
    var frameBytes = PrimaryBodyIrFrameBytes(bodyIR)
    var extraSub = 0
    while frameBytes > 4095:
        extraSub = extraSub + 1
        frameBytes = frameBytes - 4095
    return 4 + extraSub + PrimaryBodyIrParamSaveCount(bodyIR)

fn PrimaryBodyIrLocalReg(slotId: int32): int32 =
    var reg = a64.A64X9 + slotId
    if reg > 28:
        reg = a64.A64X9
    return reg

fn PrimaryBodyIrTypeIs64(typeKind: int32): bool =
    return typeKind == coreir.LocalStrTag ||
           typeKind == coreir.LocalPtrTag ||
           typeKind == coreir.LocalI64Tag ||
           typeKind == coreir.LocalAggregateTag ||
           typeKind == coreir.LocalF64Tag

fn PrimaryBodyIrSlotType(bodyIR: coreir.BodyIR, slotId: int32): int32 =
    if slotId < 0 || slotId >= bodyIR.localSlots.len:
        return coreir.LocalI32Tag
    return bodyIR.localSlots[slotId].typeKind

fn PrimaryLocalSlotSizeOf(slot: coreir.LocalSlot): int32 =
    if slot.sizeBytes > 0:
        return slot.sizeBytes
    if slot.typeKind == coreir.LocalI32Tag:
        return 4
    if slot.typeKind == coreir.LocalF64Tag ||
       slot.typeKind == coreir.LocalI64Tag ||
       slot.typeKind == coreir.LocalPtrTag:
        return 8
    if slot.typeKind == coreir.LocalStrTag:
        return 24
    if slot.typeKind == coreir.LocalAggregateTag:
        return coreir.ResultStrSizeBytes
    return 0

fn PrimaryCallOpRegisterArgCount(call: coreir.CallOp): int32 =
    if call.argSlots.len > 8:
        return 8
    return call.argSlots.len

fn PrimaryCallOpStackArgCount(call: coreir.CallOp): int32 =
    if call.argSlots.len <= 8:
        return 0
    return call.argSlots.len - 8

fn PrimaryCallOpStackArgBytes(call: coreir.CallOp): int32 =
    return PrimaryAlignStackBytes(PrimaryCallOpStackArgCount(call) * 8, 16)

fn PrimaryBodyIrCallArgIsCString(argSlot: int32): bool =
    return coreir.CallArgSlotIsCString(argSlot)

fn PrimaryBodyIrCallArgCStringId(argSlot: int32): int32 =
    return coreir.CallArgSlotCStringId(argSlot)

fn PrimaryBodyIrCallArgWordCount(bodyIR: coreir.BodyIR,
                                  argSlot: int32): int32 =
    if coreir.CallArgSlotIsConst(argSlot):
        return 1
    if coreir.CallArgSlotIsCString(argSlot):
        return 2
    if coreir.CallArgSlotIsAddress(argSlot):
        return 1
    return PrimaryBodyIrLoadSlotWordCount(bodyIR, argSlot)

fn PrimaryIncomingParamStackOffset(frameBytes: int32,
                                    paramSlot: int32): int32 =
    if paramSlot < 8:
        return -1
    return frameBytes + (paramSlot - 8) * 8

fn PrimaryBodyIrLocalStackOffset(bodyIR: coreir.BodyIR,
                                  slotIndex: int32,
                                  frameBytes: int32,
                                  paramSaveOffset: int32,
                                  paramSaveCount: int32): int32 =
    if slotIndex < 0 || slotIndex >= bodyIR.localSlots.len:
        return -1
    let slot = bodyIR.localSlots[slotIndex]
    if !PrimaryBodyIrLocalIsParam(slot):
        return slot.stackOffset
    let paramSlot = PrimaryBodyIrParamIndex(slot)
    if paramSlot < 0:
        return -1
    if paramSlot < 8:
        if paramSlot >= paramSaveCount:
            return -1
        return paramSaveOffset + paramSlot * 8
    return PrimaryIncomingParamStackOffset(frameBytes, paramSlot)

fn PrimaryBodyIrLoadSlotWordCount(bodyIR: coreir.BodyIR,
                                   slotIndex: int32): int32 =
    if slotIndex < 0 || slotIndex >= bodyIR.localSlots.len:
        return 0
    let slotType = bodyIR.localSlots[slotIndex].typeKind
    if slotType == coreir.LocalI32Tag ||
       slotType == coreir.LocalI64Tag ||
       slotType == coreir.LocalPtrTag ||
       slotType == coreir.LocalF64Tag:
        return 1
    if slotType == coreir.LocalStrTag ||
       slotType == coreir.LocalAggregateTag:
        return 1
    return 0

fn PrimaryBodyIrStoreSlotWordCount(bodyIR: coreir.BodyIR,
                                    slotIndex: int32): int32 =
    if slotIndex < 0 || slotIndex >= bodyIR.localSlots.len:
        return 0
    let slotType = bodyIR.localSlots[slotIndex].typeKind
    if slotType == coreir.LocalI32Tag ||
       slotType == coreir.LocalI64Tag ||
       slotType == coreir.LocalPtrTag ||
       slotType == coreir.LocalF64Tag:
        return 1
    return 0

fn PrimaryBodyIrTextIsI32Zero(textRaw: str): bool =
    let text = strutil.Strip(textRaw)
    return text == "0" || text == "int32(0)"

fn PrimaryBodyIrTextIsI32One(textRaw: str): bool =
    let text = strutil.Strip(textRaw)
    return text == "1" || text == "int32(1)"

fn PrimaryBodyIrTextIsStringLiteral(textRaw: str): bool =
    let text = strutil.Strip(textRaw)
    return len(text) >= 2 &&
           text[0] == '"' &&
           text[len(text) - 1] == '"'

fn PrimaryBodyIrStringLiteralPayload(textRaw: str): str =
    let text = strutil.Strip(textRaw)
    if !PrimaryBodyIrTextIsStringLiteral(text):
        return ""
    return strings.SliceBytes(text, 1, len(text) - 2)

fn PrimaryBodyIrCstringCastArgText(textRaw: str): str =
    let text = strutil.Strip(textRaw)
    if len(text) <= 9:
        return ""
    if !PrimaryStartsWith(text, "cstring("):
        return ""
    if text[len(text) - 1] != ')':
        return ""
    return strutil.Strip(strings.SliceBytes(text, 8, len(text) - 9))

fn PrimaryBodyIrConditionText(textRaw: str): str =
    var text = strutil.Strip(textRaw)
    if PrimaryStartsWith(text, "if "):
        text = strutil.Strip(strings.SliceBytes(text, 3, len(text) - 3))
    elif PrimaryStartsWith(text, "elif "):
        text = strutil.Strip(strings.SliceBytes(text, 5, len(text) - 5))
    if len(text) > 0 && text[len(text) - 1] == ':':
        text = strutil.Strip(strings.SliceBytes(text, 0, len(text) - 1))
    return text

fn PrimaryBodyIrAppendConditionTerm(bodyIR: var coreir.BodyIR,
                                     conditionSlot: int32,
                                     conditionKind: int32,
                                     currentBlockStart: var int32,
                                     pendingFalseTerm: var int32) =
    var term: coreir.BodyTerm
    term.kind = coreir.BodyTermCbrTag
    term.conditionKind = conditionKind
    term.lhsSlot = conditionSlot
    term.rhsSlot = -1
    term.trueBlock = -1
    term.falseBlock = -1
    term.resultSlot = -1
    let termIndex = coreir.BodyIRAppendTerm(bodyIR, term)
    let opCount = bodyIR.ops.len - currentBlockStart
    let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, opCount, termIndex)
    currentBlockStart = bodyIR.ops.len
    pendingFalseTerm = termIndex

fn PrimaryBodyIrAppendTypedStrLiteralCondition(bodyIR: var coreir.BodyIR,
                                                slotNames: var str[],
                                                stmt: texpr.TypedExprIrStatement,
                                                currentBlockStart: var int32,
                                                pendingFalseTerm: var int32): bool =
    if stmt.conditionKind != texpr.TypedExprIrCondStrEqLiteral &&
       stmt.conditionKind != texpr.TypedExprIrCondStrNeLiteral:
        return false
    let conditionLhsText = stmt.conditionLhsText
    let conditionLiteralText = stmt.conditionLiteralText
    let strSlot = PrimaryBodyIrFindArgSlot(slotNames, conditionLhsText)
    if strSlot < 0:
        return false
    if PrimaryBodyIrSlotType(bodyIR, strSlot) != coreir.LocalStrTag:
        return false
    let resultSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                   slotNames,
                                                   Fmt"{conditionLhsText}#str_eq_literal#{conditionLiteralText}",
                                                   coreir.LocalI32Tag)
    let literalId = coreir.BodyIRAppendCStringLiteral(bodyIR,
                                                      conditionLiteralText,
                                                      "")
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpStrEqLiteralTag
    op.target = resultSlot
    add(op.operands, strSlot)
    add(op.operands, literalId)
    add(bodyIR.ops, op)
    var condKind = coreir.BodyCondLocalNonZeroTag
    if stmt.conditionKind == texpr.TypedExprIrCondStrNeLiteral:
        condKind = coreir.BodyCondLocalZeroTag
    PrimaryBodyIrAppendConditionTerm(bodyIR,
                                     resultSlot,
                                     condKind,
                                     currentBlockStart,
                                     pendingFalseTerm)
    return true

fn PrimaryBodyIrSeedParamSlots(bodyIR: var coreir.BodyIR,
                                slotNames: var str[],
                                typedIr: texpr.TypedExprIr,
                                irFunction: lower.PrimaryObjectIrFunction) =
    for paramIndex in 0..<irFunction.paramNames.len:
        if paramIndex >= irFunction.paramTypes.len:
            return
        let paramName = irFunction.paramNames[paramIndex]
        if len(paramName) <= 0:
            continue
        let slotId = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                        slotNames,
                                                        typedIr,
                                                        irFunction.sourcePath,
                                                        paramName,
                                                        irFunction.paramTypes[paramIndex])
        PrimaryBodyIrMarkParamSlot(bodyIR, slotId, paramIndex)

fn PrimaryBodyIrCollectVarI32ParamNames(irFunction: lower.PrimaryObjectIrFunction): str[] =
    var out: str[]
    for paramIndex in 0..<irFunction.paramNames.len:
        if paramIndex >= irFunction.paramTypes.len:
            return out
        if PrimaryBodyIrTypeTextIsVarI32(irFunction.paramTypes[paramIndex]):
            add(out, irFunction.paramNames[paramIndex])
    return out

fn PrimaryBodyIrCallArgNames(callArgsText: str): str[] =
    var out: str[]
    let pieces = texpr.TypedExprSplitTopLevelCsv(callArgsText)
    for i in 0..<pieces.len:
        let name = strutil.Strip(pieces[i])
        if len(name) > 0:
            add(out, name)
    return out

fn PrimaryBodyIrTargetFunctionIndex(typedIr: texpr.TypedExprIr,
                                     sourcePath: str,
                                     functionName: str): int32 =
    let tailName = PrimaryCallTargetTailName(functionName)
    var found: int32
    found = -1
    for i in 0..<typedIr.functions.len:
        let candidateTailName = PrimaryCallTargetTailName(typedIr.functions[i].functionName)
        if sourcePath != "" &&
           !PrimaryPathNormalizedEquals(typedIr.functions[i].sourcePath, sourcePath):
            continue
        if typedIr.functions[i].functionName == functionName ||
           candidateTailName == functionName ||
           candidateTailName == tailName:
            if sourcePath != "":
                return i
            if found >= 0:
                return -1
            found = i
    return found

fn PrimaryBodyIrCallResultLayoutSourcePath(stmt: texpr.TypedExprIrStatement): str =
    if stmt.callTargetSourcePath != "":
        return stmt.callTargetSourcePath
    return stmt.sourcePath

fn PrimaryBodyIrResolvedCallResultType(typedIr: texpr.TypedExprIr,
                                        stmt: texpr.TypedExprIrStatement): str =
    var resultType = stmt.resultType
    var importcSourcePath = stmt.callTargetSourcePath
    if importcSourcePath == "":
        importcSourcePath = stmt.sourcePath
    let importcResultType = texpr.TypedExprIrLookupImportcReturnType(typedIr,
                                                                      importcSourcePath,
                                                                      stmt.callTarget)
    if importcResultType != "":
        return importcResultType
    let targetFnIndex = PrimaryBodyIrTargetFunctionIndex(typedIr,
                                                         stmt.callTargetSourcePath,
                                                         stmt.callTarget)
    if targetFnIndex >= 0 && targetFnIndex < typedIr.functions.len:
        resultType = typedIr.functions[targetFnIndex].returnType
    return resultType

fn PrimaryBodyIrTargetParamType(typedIr: texpr.TypedExprIr,
                                 stmt: texpr.TypedExprIrStatement,
                                 argIndex: int32): str =
    if stmt.callTargetImportc || argIndex < 0:
        return ""
    let fnIndex = PrimaryBodyIrTargetFunctionIndex(typedIr,
                                                  stmt.callTargetSourcePath,
                                                  stmt.callTarget)
    if fnIndex < 0 || fnIndex >= typedIr.functions.len:
        return ""
    let targetFn = typedIr.functions[fnIndex]
    var nodeEnd = targetFn.nodeStart + targetFn.nodeCount
    if nodeEnd > typedIr.nodes.len:
        nodeEnd = typedIr.nodes.len
    for nodeIndex in targetFn.nodeStart..<nodeEnd:
        let node = typedIr.nodes[nodeIndex]
        if node.opKind != texpr.TypedExprIrOpParamRef:
            continue
        if node.paramSlot != argIndex:
            continue
        return node.resultType
    return ""

fn PrimaryBodyIrTypeTextIsVarParam(typeRaw: str): bool =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    return PrimaryStartsWith(normType, "var")

fn PrimaryBodyIrTargetParamIsVarI32(typedIr: texpr.TypedExprIr,
                                     stmt: texpr.TypedExprIrStatement,
                                     argIndex: int32): bool =
    return PrimaryBodyIrTypeTextIsVarI32(PrimaryBodyIrTargetParamType(typedIr,
                                                                      stmt,
                                                                      argIndex))

fn PrimaryBodyIrAppendInvalidOp(bodyIR: var coreir.BodyIR,
                                lineNumber: int32,
                                statementKind: int32,
                                detail0: int32,
                                detail1: int32) =
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpInvalidTag
    op.target = lineNumber
    add(op.operands, statementKind)
    add(op.operands, detail0)
    add(op.operands, detail1)
    add(bodyIR.ops, op)

fn PrimaryBodyIrAppendVarI32Load(bodyIR: var coreir.BodyIR,
                                  addressSlot: int32,
                                  valueSlot: int32) =
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpIndexedLoadTag
    op.target = valueSlot
    add(op.operands, addressSlot)
    add(op.operands, valueSlot)
    add(bodyIR.ops, op)

fn PrimaryBodyIrAppendVarI32Store(bodyIR: var coreir.BodyIR,
                                   addressSlot: int32,
                                   valueSlot: int32) =
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpIndexedStoreTag
    op.target = addressSlot
    add(op.operands, addressSlot)
    add(op.operands, valueSlot)
    add(bodyIR.ops, op)

fn PrimaryBodyIrI32ValueSlotForText(bodyIR: var coreir.BodyIR,
                                     slotNames: var str[],
                                     varI32ParamNames: str[],
                                     textRaw: str): int32 =
    let text = strutil.Strip(textRaw)
    if len(text) <= 0:
        return -1
    let constVal = PrimaryBodyIrExtractIntFromText(text)
    if constVal != 0 || PrimaryBodyIrTextIsI32Zero(text):
        let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, coreir.LocalI32Tag)
        var constOp: coreir.BodyOp
        constOp.kind = coreir.BodyOpLoadConstTag
        constOp.target = slotId
        add(constOp.operands, coreir.LocalI32Tag)
        add(constOp.operands, constVal)
        add(bodyIR.ops, constOp)
        return slotId
    let slotId = PrimaryBodyIrFindArgSlot(slotNames, text)
    if slotId < 0:
        return -1
    if PrimaryBodyIrNameInList(varI32ParamNames, text):
        let valueSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                      slotNames,
                                                      PrimaryBodyIrVarI32ValueSlotName(text),
                                                      coreir.LocalI32Tag)
        PrimaryBodyIrAppendVarI32Load(bodyIR, slotId, valueSlot)
        return valueSlot
    if PrimaryBodyIrSlotType(bodyIR, slotId) != coreir.LocalI32Tag:
        return -1
    return slotId

fn PrimaryBodyIrScalarValueSlotForText(bodyIR: var coreir.BodyIR,
                                        slotNames: var str[],
                                        varI32ParamNames: str[],
                                        typedIr: texpr.TypedExprIr,
                                        sourcePath: str,
                                        textRaw: str,
                                        typeKind: int32): int32 =
    let text = strutil.Strip(textRaw)
    if len(text) <= 0:
        return -1
    let constVal = PrimaryBodyIrExtractIntFromText(text)
    if constVal != 0 || PrimaryBodyIrTextIsI32Zero(text):
        let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, typeKind)
        var constOp: coreir.BodyOp
        constOp.kind = coreir.BodyOpLoadConstTag
        constOp.target = slotId
        add(constOp.operands, typeKind)
        add(constOp.operands, constVal)
        add(bodyIR.ops, constOp)
        return slotId
    if typeKind == coreir.LocalI32Tag:
        var enumTypeName = ""
        var enumValue: int32
        if texpr.TypedExprIrLookupEnumConstValue(typedIr,
                                                sourcePath,
                                                text,
                                                enumTypeName,
                                                enumValue):
            let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, coreir.LocalI32Tag)
            var constOp: coreir.BodyOp
            constOp.kind = coreir.BodyOpLoadConstTag
            constOp.target = slotId
            add(constOp.operands, coreir.LocalI32Tag)
            add(constOp.operands, enumValue)
            add(bodyIR.ops, constOp)
            return slotId
    let slotId = PrimaryBodyIrFindArgSlot(slotNames, text)
    if slotId >= 0:
        if PrimaryBodyIrNameInList(varI32ParamNames, text):
            return PrimaryBodyIrI32ValueSlotForText(bodyIR, slotNames, varI32ParamNames, text)
        if PrimaryBodyIrSlotType(bodyIR, slotId) == typeKind:
            return slotId
        return -1
    let globalType = PrimaryBodyIrTypedGlobalType(typedIr, sourcePath, text)
    if globalType == "":
        return -1
    let globalTypeKind = PrimaryBodyIrTypeKindFromText(globalType)
    if globalTypeKind != typeKind:
        return -1
    let globalSlotName = PrimaryBodyIrTypedGlobalSlotName(typedIr, sourcePath, text)
    if globalSlotName == "":
        return -1
    let globalSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                   slotNames,
                                                   globalSlotName,
                                                   typeKind)
    bodyIR.localSlots[globalSlot].placeKind = coreir.BodyPlaceGlobalAddressTag
    let valueSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                  slotNames,
                                                  Fmt"{globalSlotName}#global_value",
                                                  typeKind)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpGlobalLoadTag
    op.target = valueSlot
    add(op.operands, globalSlot)
    add(bodyIR.ops, op)
    return valueSlot

fn PrimaryBodyIrAppendCallArgs(bodyIR: var coreir.BodyIR,
                                slotNames: var str[],
                                call: var coreir.CallOp,
                                typedIr: texpr.TypedExprIr,
                                typedFn: texpr.TypedExprIrFunction,
                                irFunction: lower.PrimaryObjectIrFunction,
                                stmt: texpr.TypedExprIrStatement,
                                varI32ParamNames: str[],
                                failureDetail0: var int32,
                                failureDetail1: var int32): bool =
    if stmt.callArgCount <= 0:
        return true
    let argNames = PrimaryBodyIrCallArgNames(stmt.callArgsText)
    for argIndex in 0..<argNames.len:
        let argName = argNames[argIndex]
        let targetParamType = PrimaryBodyIrTargetParamType(typedIr, stmt, argIndex)
        let targetNeedsAddress = PrimaryBodyIrTypeTextIsVarParam(targetParamType)
        if PrimaryBodyIrTextIsI32Zero(argName):
            if targetNeedsAddress:
                failureDetail0 = 11
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstFalse())
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif PrimaryBodyIrTextIsI32One(argName):
            if targetNeedsAddress:
                failureDetail0 = 12
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstTrue())
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif argName == "true":
            if targetNeedsAddress:
                failureDetail0 = 12
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstTrue())
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif argName == "false":
            if targetNeedsAddress:
                failureDetail0 = 13
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstFalse())
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif PrimaryBodyIrCstringCastArgText(argName) != "":
            if targetNeedsAddress:
                failureDetail0 = 21
                failureDetail1 = argIndex
                return false
            let castArg = PrimaryBodyIrCstringCastArgText(argName)
            if PrimaryBodyIrTextIsStringLiteral(castArg):
                let literalId = coreir.BodyIRAppendCStringLiteral(bodyIR,
