    let branchOp = bodyIR.ops[1]
    let commandCallOp = bodyIR.ops[2]
    let returnOp = bodyIR.ops[3]
    if countCallOp.kind != coreir.BodyOpCallTag ||
       branchOp.kind != coreir.BodyOpBranchTag ||
       commandCallOp.kind != coreir.BodyOpCallTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if countCallOp.operands.len < 1:
        return false
    if branchOp.operands.len < 3:
        return false
    if commandCallOp.operands.len < 1:
        return false
    if returnOp.operands.len < 1:
        return false
    return countCallOp.operands[0] == 0 &&
           branchOp.operands[0] == coreir.BodyBranchIfLocalLeZeroReturnCallNoargTag &&
           branchOp.operands[1] == bodyIR.callSequence[0].resultSlot &&
           branchOp.operands[2] == 1 &&
           commandCallOp.operands[0] == 2 &&
           returnOp.operands[0] == coreir.LocalI32Tag

