fn PrimaryObjectMissingReasons(linkPlan: slplan.SystemLinkPlanStub,
                                 lowering: lower.LoweringPlanStub,
                                 itemIds: int32[],
                                 instructionWords: int32[],
                                 bodySemanticsMissing: bool): str[] =
    var missing: str[]
    if linkPlan.missingReasons.len > 0:
        add(missing, "system_link_plan_not_ready_for_primary_object")
    if lowering.missingReasons.len > 0:
        add(missing, "lowering_plan_not_ready_for_primary_object")
    if itemIds.len <= 0:
        add(missing, "primary_object_items_missing")
    if instructionWords.len <= 0:
        add(missing, "primary_object_machine_words_missing")
    if bodySemanticsMissing:
        add(missing, "primary_object_body_semantics_missing")
    if linkPlan.emitKind == creq.EmitExe && len(linkPlan.entrySymbol) <= 0:
        add(missing, "primary_object_entry_symbol_missing")
    return missing

fn PrimaryObjectMissingLineNumber(lowering: var lower.LoweringPlanStub,
                                   irIndex: int32): int32 =
    if irIndex < 0 || irIndex >= lowering.primaryObjectIr.functions.len:
        return 0
    let irFunction = lowering.primaryObjectIr.functions[irIndex]
    if irFunction.bodyKind == texpr.BodyKindUnsupported &&
           irFunction.statements.len > 0:
        return irFunction.statements[0].lineNumber
    return irFunction.bodyLineNumber

fn PrimaryObjectMissingBodyKind(lowering: var lower.LoweringPlanStub,
                                 irIndex: int32,
                                 fallback: str): str =
    if irIndex < 0 || irIndex >= lowering.primaryObjectIr.functions.len:
        return fallback
    return PrimaryBodyIrMissingKind(lowering.primaryObjectIr.functions[irIndex].bodyIR,
                                    fallback)

fn PrimaryTypedIrFunctionIndex(ir: texpr.TypedExprIr,
                                sourcePath: str,
                                functionName: str): int32 =
    let tailName = PrimaryFunctionTailName(functionName)
    for i in 0..<ir.functions.len:
        if ir.functions[i].sourcePath != sourcePath:
            continue
        if ir.functions[i].functionName == functionName ||
           ir.functions[i].functionName == tailName:
            return i
    return -1

fn PrimaryObjectMissingTypedIrKind(lowering: var lower.LoweringPlanStub,
                                    irIndex: int32): str =
    if irIndex < 0 || irIndex >= lowering.primaryObjectIr.functions.len:
        return ""
    let irFunction = lowering.primaryObjectIr.functions[irIndex]
    if irFunction.bodyKind != texpr.BodyKindUnsupported:
        return ""
    let bodyIrKind = PrimaryBodyIrMissingKind(irFunction.bodyIR, "")
    if len(bodyIrKind) > 0:
        return bodyIrKind
    for stmtIndex in 0..<irFunction.statements.len:
        let stmt = irFunction.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtLetCall:
            return "stmt_let_call"
        if stmt.kind == texpr.TypedExprIrStmtIfCall:
            return "stmt_if_call"
        if stmt.kind == texpr.TypedExprIrStmtCall:
            return "stmt_call"
        if stmt.kind == texpr.TypedExprIrStmtResultIntrinsic:
            return "stmt_result_intrinsic"
    let typedIndex = PrimaryTypedIrFunctionIndex(lowering.typedIr,
                                                irFunction.sourcePath,
                                                irFunction.functionName)
    if typedIndex < 0 || typedIndex >= lowering.typedIr.functions.len:
        return ""
    let typedFunction = lowering.typedIr.functions[typedIndex]
    var nodeEnd = typedFunction.nodeStart + typedFunction.nodeCount
    if nodeEnd > lowering.typedIr.nodes.len:
        nodeEnd = lowering.typedIr.nodes.len
    for nodeIndex in typedFunction.nodeStart..<nodeEnd:
        if lowering.typedIr.nodes[nodeIndex].opKind == texpr.TypedExprIrOpLetCall:
            return "stmt_let_call"
    let stmtStart = typedFunction.statementStart
    let stmtEnd = stmtStart + typedFunction.statementCount
    if stmtStart >= 0 && stmtStart < lowering.typedIr.statements.len:
        var safeStmtEnd = stmtEnd
        if safeStmtEnd > lowering.typedIr.statements.len:
            safeStmtEnd = lowering.typedIr.statements.len
        for stmtIndex in stmtStart..<safeStmtEnd:
            if lowering.typedIr.statements[stmtIndex].kind == texpr.TypedExprIrStmtLetCall:
                return "stmt_let_call"
            if lowering.typedIr.statements[stmtIndex].kind == texpr.TypedExprIrStmtIfCall:
                return "stmt_if_call"
            if lowering.typedIr.statements[stmtIndex].kind == texpr.TypedExprIrStmtCall:
                return "stmt_call"
            if lowering.typedIr.statements[stmtIndex].kind == texpr.TypedExprIrStmtResultIntrinsic:
                return "stmt_result_intrinsic"
    return ""

fn BuildPrimaryObjectPlan(linkPlan: var slplan.SystemLinkPlanStub,
                            lowering: var lower.LoweringPlanStub): Result[PrimaryObjectPlan] =
    var allSymbolNames: str[]
    var itemIds: int32[]
    var symbolNames: str[]
    var functionWordOffsets: int32[]
    var functionWordCounts: int32[]
    var functionBodyKinds: str[]
    var functionStatementReturnModes: int32[]
    var functionStatementReturnI32Values: int32[]
    var functionStatementCallCounts: int32[]
    var functionLocalSlotCounts: int32[]
    var functionLocalStackByteCounts: int32[]
    var functionBodyIRs: coreir.BodyIR[]
    var relocSourceItemIds: int32[]
    var relocWordOffsets: int32[]
    var relocTargetSymbols: str[]
    var dataLabels: str[]
    var dataPayloadTexts: str[]
    var plan: PrimaryObjectPlan
    var totalWordCount: int32
    var entryFunctionSymbol = ""
    var bodySemanticsMissing = false
    var firstMissingFunction = ""
    var firstMissingBodyKind = ""
    var firstMissingTypedIrKind = ""
    var firstMissingLineNumber: int32
    var irIndexes: int32[]
    var wordCounts: int32[]
    var reachable: bool[]
    var frontier: int32[]
    allSymbolNames = []
    itemIds = []
    symbolNames = []
    functionWordOffsets = []
    functionWordCounts = []
    functionBodyKinds = []
    functionStatementReturnModes = []
    functionStatementReturnI32Values = []
    functionStatementCallCounts = []
    functionLocalSlotCounts = []
    functionLocalStackByteCounts = []
    functionBodyIRs = []
    relocSourceItemIds = []
    relocWordOffsets = []
    relocTargetSymbols = []
    dataLabels = []
    dataPayloadTexts = []
    irIndexes = PrimaryIntSeqInit(lowering.functionNames.len, -1)
    wordCounts = PrimaryIntSeqInit(lowering.functionNames.len, 0)
    reachable = PrimaryBoolSeqInit(lowering.functionNames.len, false)
    let exportRoots = slplan.SystemLinkPlanExportRootSymbols(linkPlan)
    var exportRootMatched = PrimaryBoolSeqInit(exportRoots.len, false)
    var exportedFunctionCount: int32
    if linkPlan.emitKind == creq.EmitObj:
        for i in 0..<lowering.functionExportedFlags.len:
            if lowering.functionExportedFlags[i] != 0:
                exportedFunctionCount = exportedFunctionCount + 1
    let emitObjectRootsAllFunctions = linkPlan.emitKind == creq.EmitObj &&
                                      exportedFunctionCount <= 0 &&
                                      exportRoots.len <= 0
    for i in 0..<lowering.functionNames.len:
        if i % 64 == 0:
            os.ProcessResourceGuardCheck()
        let sourcePath = lowering.functionSourcePaths[i]
        let irIndex = PrimaryObjectIrFunctionIndex(lowering.primaryObjectIr,
                                                   sourcePath,
                                                   lowering.functionNames[i])
        var signatureLineNumber: int32
        if irIndex >= 0:
            signatureLineNumber = lowering.primaryObjectIr.functions[irIndex].signatureLineNumber
            irIndexes[i] = irIndex
            let bodyIrWordCount = PrimaryBodyIrWordCount(lowering.primaryObjectIr.functions[irIndex].bodyIR)
            if bodyIrWordCount > 0:
                wordCounts[i] = bodyIrWordCount
            elif lowering.primaryObjectIr.functions[irIndex].bodyKind == texpr.BodyKindStatementSequence:
                wordCounts[i] = PrimaryStatementSequenceWordCount(lowering.primaryObjectIr.functions[irIndex].statementReturnMode)
            else:
                wordCounts[i] = PrimaryFunctionWordCountForBodyKind(lowering.primaryObjectIr.functions[irIndex].bodyKind)
        var symbolText = lowering.functionSymbolTexts[i]
        if i < lowering.functionExportedFlags.len &&
           i < lowering.functionExportSymbolNames.len &&
           lowering.functionExportedFlags[i] != 0 &&
           len(lowering.functionExportSymbolNames[i]) > 0:
            symbolText = lowering.functionExportSymbolNames[i]
        add(allSymbolNames,
            PrimarySymbolNameForFunction(linkPlan.targetTriple,
                                           symbolText,
                                           signatureLineNumber,
                                           linkPlan.emitKind))
        if i < lowering.functionEntryFlags.len && lowering.functionEntryFlags[i] != 0:
            entryFunctionSymbol = allSymbolNames[allSymbolNames.len - 1]
        var emitObjectRootExported = linkPlan.emitKind == creq.EmitObj &&
                                     i < lowering.functionExportedFlags.len &&
                                     lowering.functionExportedFlags[i] != 0
        if emitObjectRootExported && exportRoots.len > 0:
            var exportSymbol = ""
            if i < lowering.functionExportSymbolNames.len:
                exportSymbol = lowering.functionExportSymbolNames[i]
            let matchIndex = PrimaryExportRootIndex(exportRoots,
                                                    allSymbolNames[allSymbolNames.len - 1],
                                                    exportSymbol,
                                                    lowering.functionSymbolTexts[i],
                                                    lowering.functionNames[i])
            emitObjectRootExported = matchIndex >= 0
            if matchIndex >= 0 && matchIndex < exportRootMatched.len:
                exportRootMatched[matchIndex] = true
        if emitObjectRootsAllFunctions ||
           emitObjectRootExported ||
           (i < lowering.functionEntryFlags.len && lowering.functionEntryFlags[i] != 0):
            reachable[i] = true
            add(frontier, i)
    if linkPlan.emitKind == creq.EmitObj && exportRoots.len > 0:
        for rootIndex in 0..<exportRoots.len:
            if rootIndex < exportRootMatched.len && exportRootMatched[rootIndex]:
                continue
            bodySemanticsMissing = true
            if len(firstMissingFunction) <= 0:
                firstMissingFunction = Fmt"export_root:{exportRoots[rootIndex]}"
                firstMissingBodyKind = "missing_export_root"
                firstMissingTypedIrKind = ""
                firstMissingLineNumber = 0
    for passIndex in 0..<lowering.functionNames.len:
        if passIndex % 16 == 0:
            os.ProcessResourceGuardCheck()
        var nextFrontier: int32[]
        for frontierIndex in 0..<frontier.len:
            let currentIndex = frontier[frontierIndex]
            if currentIndex < 0 || currentIndex >= lowering.functionNames.len:
                continue
            let irIndex = irIndexes[currentIndex]
            if irIndex < 0:
                bodySemanticsMissing = true
                if len(firstMissingFunction) <= 0:
                    firstMissingFunction = lowering.functionNames[currentIndex]
                    firstMissingBodyKind = "missing_primary_object_ir"
                    firstMissingTypedIrKind = ""
                    firstMissingLineNumber = 0
                continue
            if wordCounts[currentIndex] <= 0:
                bodySemanticsMissing = true
                if len(firstMissingFunction) <= 0:
                    firstMissingFunction = lowering.functionNames[currentIndex]
                    firstMissingBodyKind = PrimaryObjectMissingBodyKind(lowering,
                                                                        irIndex,
                                                                        lowering.primaryObjectIr.functions[irIndex].bodyKind)
                    firstMissingTypedIrKind = PrimaryObjectMissingTypedIrKind(lowering, irIndex)
                    firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                continue
            let irFunction = lowering.primaryObjectIr.functions[irIndex]
            if irFunction.signatureLineNumber <= 0:
                bodySemanticsMissing = true
                if len(firstMissingFunction) <= 0:
                    firstMissingFunction = lowering.functionNames[currentIndex]
                    firstMissingBodyKind = PrimaryObjectMissingBodyKind(lowering,
                                                                        irIndex,
                                                                        irFunction.bodyKind)
                    firstMissingTypedIrKind = PrimaryObjectMissingTypedIrKind(lowering, irIndex)
                    firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                continue
            let bodyKind = irFunction.bodyKind
            let statementMode = irFunction.statementReturnMode
            let bodyIrRequiresCalls = PrimaryBodyIrRequiresCallSequence(irFunction.bodyIR)
            if PrimaryBodyRequiresCallSequence(bodyKind, statementMode) || bodyIrRequiresCalls:
                var callSequenceReady = true
                if irFunction.callSequence.len <= 0:
                    callSequenceReady = false
                    bodySemanticsMissing = true
                    if len(firstMissingFunction) <= 0:
                        firstMissingFunction = lowering.functionNames[currentIndex]
                        firstMissingBodyKind = "missing_call_sequence"
                        firstMissingTypedIrKind = ""
                        firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                if callSequenceReady:
                    for callOrdinal in 0..<irFunction.callSequence.len:
                        let callOp = irFunction.callSequence[callOrdinal]
                        if callOp.importc:
                            continue
                        let targetIndex = PrimaryFunctionTargetIndex(lowering.functionSymbolTexts,
                                                                      lowering.functionSourcePaths,
                                                                      callOp.targetSourcePath,
                                                                      callOp.targetSymbol)
                        if targetIndex < 0 || targetIndex >= reachable.len:
                            callSequenceReady = false
                            bodySemanticsMissing = true
                            if len(firstMissingFunction) <= 0:
                                firstMissingFunction = lowering.functionNames[currentIndex]
                                firstMissingBodyKind = "missing_call_target"
                                firstMissingTypedIrKind = ""
                                firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                            break
                        if !reachable[targetIndex]:
                            reachable[targetIndex] = true
                            add(nextFrontier, targetIndex)
                if !callSequenceReady:
                    continue
        frontier = nextFrontier
    if linkPlan.emitKind == creq.EmitExe:
        for i in 0..<lowering.functionNames.len:
            if i % 64 == 0:
                os.ProcessResourceGuardCheck()
            if i >= reachable.len || reachable[i]:
                continue
            let irIndex = irIndexes[i]
            if irIndex < 0 || wordCounts[i] <= 0:
                continue
            let bodyKind = lowering.primaryObjectIr.functions[irIndex].bodyKind
            if PrimaryBodyRequiresCallSequence(bodyKind,
                                               lowering.primaryObjectIr.functions[irIndex].statementReturnMode) ||
               PrimaryBodyIrRequiresCallSequence(lowering.primaryObjectIr.functions[irIndex].bodyIR):
                continue
            reachable[i] = true
    for i in 0..<lowering.functionNames.len:
        if i % 64 == 0:
            os.ProcessResourceGuardCheck()
        if i >= reachable.len || !reachable[i]:
            continue
        let irIndex = irIndexes[i]
        if irIndex < 0:
            bodySemanticsMissing = true
            if len(firstMissingFunction) <= 0:
                firstMissingFunction = lowering.functionNames[i]
                firstMissingBodyKind = "missing_primary_object_ir"
                firstMissingTypedIrKind = ""
                firstMissingLineNumber = 0
            continue
        let irFunction = lowering.primaryObjectIr.functions[irIndex]
        let bodyKind = irFunction.bodyKind
        let statementMode = irFunction.statementReturnMode
        let bodyIrRequiresCalls = PrimaryBodyIrRequiresCallSequence(irFunction.bodyIR)
        if PrimaryBodyRequiresCallSequence(bodyKind, statementMode) || bodyIrRequiresCalls:
            var callSequenceReady = true
            if irFunction.callSequence.len <= 0:
                callSequenceReady = false
                bodySemanticsMissing = true
                if len(firstMissingFunction) <= 0:
                    firstMissingFunction = lowering.functionNames[i]
                    firstMissingBodyKind = "missing_call_sequence"
                    firstMissingTypedIrKind = ""
                    firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
            if callSequenceReady:
                for callOrdinal in 0..<irFunction.callSequence.len:
                    let callOp = irFunction.callSequence[callOrdinal]
                    if callOp.importc:
                        if len(callOp.importcSymbol) <= 0:
                            callSequenceReady = false
                            bodySemanticsMissing = true
                            if len(firstMissingFunction) <= 0:
                                firstMissingFunction = lowering.functionNames[i]
                                firstMissingBodyKind = "missing_call_sequence"
                                firstMissingTypedIrKind = ""
                                firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                            break
                    else:
                        let targetIndex = PrimaryFunctionTargetIndex(lowering.functionSymbolTexts,
                                                                      lowering.functionSourcePaths,
                                                                      callOp.targetSourcePath,
                                                                      callOp.targetSymbol)
                        if targetIndex < 0 ||
                           targetIndex >= allSymbolNames.len ||
                           targetIndex >= reachable.len ||
                           !reachable[targetIndex]:
                            callSequenceReady = false
                            bodySemanticsMissing = true
                            if len(firstMissingFunction) <= 0:
                                firstMissingFunction = lowering.functionNames[i]
                                firstMissingBodyKind = "missing_call_target"
                                firstMissingTypedIrKind = ""
                                firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                            break
            if !callSequenceReady:
                continue
        let wordCount = wordCounts[i]
        if wordCount <= 0:
            bodySemanticsMissing = true
            if len(firstMissingFunction) <= 0:
                firstMissingFunction = lowering.functionNames[i]
                firstMissingBodyKind = PrimaryObjectMissingBodyKind(lowering,
                                                                    irIndex,
                                                                    bodyKind)
                firstMissingTypedIrKind = PrimaryObjectMissingTypedIrKind(lowering, irIndex)
                firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
            continue
        if PrimaryBodyRequiresCallSequence(bodyKind, statementMode) || bodyIrRequiresCalls:
            var requiredCallCount = PrimaryStatementSequenceRequiredCallCount(statementMode)
            if bodyIrRequiresCalls:
                requiredCallCount = irFunction.callSequence.len
            elif requiredCallCount <= 0:
                requiredCallCount = 1
                if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
                    requiredCallCount = 2
                elif bodyKind == texpr.BodyKindBackendDriverRootFromCmdline:
                    requiredCallCount = 3
                elif bodyKind == texpr.BodyKindBackendDriverCommandDispatch:
                    requiredCallCount = 6
                elif bodyKind == texpr.BodyKindResultRequestDispatch:
                    requiredCallCount = 2
            if irFunction.callSequence.len < requiredCallCount:
                bodySemanticsMissing = true
                if len(firstMissingFunction) <= 0:
                    firstMissingFunction = lowering.functionNames[i]
                    firstMissingBodyKind = "missing_call_sequence"
                    firstMissingTypedIrKind = ""
                    firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                continue
        let itemId = int32(100000 + i)
        let wordOffset = totalWordCount
        var planStatementMode = PrimaryStatementSequenceReturnMode(bodyKind)
        var planStatementI32Value = PrimaryStatementSequenceI32Value(bodyKind)
        if bodyKind == texpr.BodyKindStatementSequence:
            planStatementMode = statementMode
            planStatementI32Value = irFunction.statementReturnI32Value
        let bodyIrStatementModeForPlan = PrimaryBodyIrStatementReturnMode(irFunction.bodyIR)
        if bodyIrStatementModeForPlan != PrimaryStatementReturnModeNone():
            planStatementMode = bodyIrStatementModeForPlan
            planStatementI32Value = PrimaryBodyIrStatementI32Value(irFunction.bodyIR)
        add(itemIds, itemId)
        add(symbolNames, allSymbolNames[i])
        add(functionWordOffsets, wordOffset)
        add(functionWordCounts, wordCount)
        add(functionBodyKinds, PrimaryPlanBodyKind(bodyKind))
        add(functionStatementReturnModes, planStatementMode)
        add(functionStatementReturnI32Values, planStatementI32Value)
        add(functionStatementCallCounts, irFunction.callSequence.len)
        add(functionLocalSlotCounts, irFunction.bodyIR.localSlots.len)
        add(functionLocalStackByteCounts, PrimaryBodyIrStackByteCount(irFunction.bodyIR))
        if bodyKind == texpr.BodyKindRuntimeSetCmdLine &&
           i < lowering.functionOwnerModulePaths.len:
            let argcLabel = PrimarySymbolNameForGlobalVar(linkPlan.targetTriple,
                                                          lowering.functionOwnerModulePaths[i],
                                                          "cheng_saved_argc")
            let argcPadLabel = PrimarySymbolNameForGlobalVar(linkPlan.targetTriple,
                                                             lowering.functionOwnerModulePaths[i],
                                                             "cheng_saved_argc_pad")
            let argvLabel = PrimarySymbolNameForGlobalVar(linkPlan.targetTriple,
                                                          lowering.functionOwnerModulePaths[i],
                                                          "cheng_saved_argv")
            if !PrimaryStringSeqHas(dataLabels, argcLabel):
                add(dataLabels, argcLabel)
                add(dataPayloadTexts, "zero:4")
            if !PrimaryStringSeqHas(dataLabels, argcPadLabel):
                add(dataLabels, argcPadLabel)
                add(dataPayloadTexts, "zero:4")
            if !PrimaryStringSeqHas(dataLabels, argvLabel):
                add(dataLabels, argvLabel)
                add(dataPayloadTexts, "zero:8")
        if PrimaryBodyIrStatementReturnMode(irFunction.bodyIR) == PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
            for callOrdinal in 0..<irFunction.callSequence.len:
                var literalContent = ""
                if !PrimarySimpleStringLiteralContent(irFunction.callSequence[callOrdinal].argsText,
                                                       literalContent):
                    bodySemanticsMissing = true
                    if len(firstMissingFunction) <= 0:
                        firstMissingFunction = lowering.functionNames[i]
                        firstMissingBodyKind = "missing_cstring_literal"
                        firstMissingTypedIrKind = ""
                        firstMissingLineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                    continue
        if PrimaryBodyRequiresCallSequence(bodyKind, planStatementMode) || bodyIrRequiresCalls:
            var relocCallCount = PrimaryStatementSequenceRequiredCallCount(planStatementMode)
            if bodyIrRequiresCalls:
                relocCallCount = irFunction.callSequence.len
            elif relocCallCount <= 0:
                relocCallCount = 1
                if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
                    relocCallCount = 2
                elif bodyKind == texpr.BodyKindBackendDriverRootFromCmdline:
                    relocCallCount = 3
                elif bodyKind == texpr.BodyKindBackendDriverCommandDispatch:
                    relocCallCount = 6
                elif bodyKind == texpr.BodyKindResultRequestDispatch:
                    relocCallCount = 2
            for callOrdinal in 0..<relocCallCount:
                let callOp = irFunction.callSequence[callOrdinal]
                var targetSymbol = ""
                if callOp.importc:
                    targetSymbol = PrimaryTargetSymbolName(linkPlan.targetTriple,
                                                           callOp.importcSymbol)
                else:
                    let targetIndex = PrimaryFunctionTargetIndex(lowering.functionSymbolTexts,
                                                                  lowering.functionSourcePaths,
                                                                  callOp.targetSourcePath,
                                                                  callOp.targetSymbol)
                    if targetIndex >= 0 &&
                       targetIndex < allSymbolNames.len &&
                       targetIndex < reachable.len &&
                       reachable[targetIndex]:
                        targetSymbol = allSymbolNames[targetIndex]
                var relocWordOffset = PrimaryCallSequenceRelocWordOffset(bodyKind,
                                                                         planStatementMode,
                                                                         wordOffset,
                                                                         callOrdinal)
                if bodyIrRequiresCalls:
                    relocWordOffset = PrimaryBodyIrRelocWordOffset(irFunction.bodyIR,
                                                                   wordOffset,
                                                                   callOrdinal)
                add(relocSourceItemIds, itemId)
                add(relocWordOffsets, relocWordOffset)
                add(relocTargetSymbols, targetSymbol)
        elif bodyKind == texpr.BodyKindCstringToStrCopy:
            add(relocSourceItemIds, itemId)
            add(relocWordOffsets, wordOffset + 5)
            add(relocTargetSymbols, PrimaryTargetSymbolName(linkPlan.targetTriple, "cheng_cstrlen"))
            add(relocSourceItemIds, itemId)
            add(relocWordOffsets, wordOffset + 11)
            add(relocTargetSymbols, PrimaryTargetSymbolName(linkPlan.targetTriple, "driver_c_new_string_copy_n"))
        add(functionBodyIRs, irFunction.bodyIR)
        totalWordCount = totalWordCount + wordCount
    if linkPlan.emitKind == creq.EmitExe &&
       len(linkPlan.entrySymbol) > 0 &&
       len(entryFunctionSymbol) > 0 &&
       itemIds.len > 0:
        add(itemIds, int32(900000 + itemIds.len))
        add(symbolNames, PrimaryRuntimeEntryBridgeSymbol(linkPlan))
        add(functionWordOffsets, totalWordCount)
        add(functionWordCounts, texpr.BodyKindEntryBridgeWordCount)
        add(functionBodyKinds, texpr.BodyKindEntryBridge)
        add(functionStatementReturnModes, PrimaryStatementReturnModeNone())
        add(functionStatementReturnI32Values, 0)
        add(functionStatementCallCounts, 0)
        add(functionLocalSlotCounts, 0)
        add(functionLocalStackByteCounts, 0)
        add(functionBodyIRs, coreir.BodyIR())
        totalWordCount = totalWordCount + texpr.BodyKindEntryBridgeWordCount
    plan.targetTriple = linkPlan.targetTriple
    plan.objectFormat = tmat.TargetPrimaryObjectFormat(linkPlan.targetTriple)
    if linkPlan.emitKind == creq.EmitObj:
        plan.outputPath = linkPlan.outputPath
    else:
        plan.outputPath = Fmt"{linkPlan.outputPath}.primary.o"
    plan.entryPath = linkPlan.entryPath
    plan.entrySymbol = linkPlan.entrySymbol
    plan.entryFunctionSymbol = entryFunctionSymbol
    plan.itemIds = itemIds
    plan.symbolNames = symbolNames
    plan.functionWordOffsets = functionWordOffsets
    plan.functionWordCounts = functionWordCounts
    plan.functionBodyKinds = functionBodyKinds
    plan.functionStatementReturnModes = functionStatementReturnModes
    plan.functionStatementReturnI32Values = functionStatementReturnI32Values
    plan.functionStatementCallCounts = functionStatementCallCounts
    plan.functionLocalSlotCounts = functionLocalSlotCounts
    plan.functionLocalStackByteCounts = functionLocalStackByteCounts
    plan.functionBodyIRs = functionBodyIRs
    var instructionWords: int32[]
    for i in 0..<totalWordCount:
        if i % 4096 == 0:
            os.ProcessResourceGuardCheck()
        add(instructionWords, 0)
    for i in 0..<functionBodyKinds.len:
        if i % 64 == 0:
            os.ProcessResourceGuardCheck()
        var bodyIR = coreir.BodyIR()
        if i < functionBodyIRs.len:
            bodyIR = functionBodyIRs[i]
        let wordOffset = functionWordOffsets[i]
        let bodyKind = functionBodyKinds[i]
        let statementMode = functionStatementReturnModes[i]
        let statementI32Value = functionStatementReturnI32Values[i]
        let bodyIrStatementMode = PrimaryBodyIrStatementReturnMode(bodyIR)
        if bodyIrStatementMode == PrimaryStatementReturnModeI32Const():
            PrimaryFillLetCallNoargReturnI32Const(instructionWords,
                                                  wordOffset,
                                                  PrimaryBodyIrStatementI32Value(bodyIR))
        elif bodyIrStatementMode == PrimaryStatementReturnModeCallResultI32():
            PrimaryFillLetCallNoargReturnResultI32(instructionWords, wordOffset)
        elif bodyIrStatementMode == PrimaryStatementReturnModeI32GuardResultLeZero():
            PrimaryFillLetCallNoargGuardResultI32(instructionWords, wordOffset)
        elif bodyIrStatementMode == PrimaryStatementReturnModeStrLen():
            PrimaryFillLetCallNoargStrReturnLenI32(instructionWords, wordOffset)
        elif bodyIrStatementMode == PrimaryStatementReturnModeStrThenCallReturnI32Const0():
            PrimaryFillLetCallNoargStrThenCallArg0ReturnI32Const0(instructionWords, wordOffset)
        elif bodyIrStatementMode == PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
            PrimaryFillCstringLiteralCallsReturnI32Const0(instructionWords,
                                                          wordOffset,
                                                          bodyIR.callSequence.len)
        elif PrimaryBodyIrIsI32TwoCallGuardFirstReturn(bodyIR):
            PrimaryFillI32TwoCallGuardFirstReturn(instructionWords, wordOffset)
        elif PrimaryBodyIrIsI32GuardThenCommandReturn(bodyIR):
            PrimaryFillI32GuardThenCommandReturn(instructionWords, wordOffset)
        elif PrimaryBodyIrIsStrCallConstThenCallArg0ReturnI32(bodyIR):
            PrimaryFillStrCallConstThenCallArg0ReturnI32(instructionWords, wordOffset)
        elif PrimaryBodyIrIsStrI32GuardCallArg0ThenDispatchReturnI32(bodyIR):
            PrimaryFillStrI32GuardCallArg0ThenDispatchReturnI32(instructionWords, wordOffset)
        elif PrimaryBodyIrIsI32LetCallThenReturnCallArg0(bodyIR):
            PrimaryFillI32LetCallThenReturnCallArg0(instructionWords, wordOffset)
        elif PrimaryBodyIrIsArg0I32LetCallThenReturnCallArg0Arg1(bodyIR):
            PrimaryFillArg0I32LetCallThenReturnCallArg0Arg1(instructionWords, wordOffset)
        elif PrimaryBodyIrIsArg0AggregateCallThenReturnCallArg0Arg1(bodyIR):
            PrimaryFillArg0AggregateCallThenReturnCallArg0Arg1(instructionWords, wordOffset)
        elif PrimaryBodyIrIsArg0SeqCallThenReturnCallArg0Arg1(bodyIR):
            PrimaryFillArg0SeqCallThenReturnCallArg0Arg1(instructionWords, wordOffset)
        elif PrimaryBodyIrIsStrLetCallThenCallArg0ReturnI32(bodyIR):
            PrimaryFillStrLetCallThenCallArg0ReturnI32(instructionWords, wordOffset)
        elif PrimaryBodyIrIsI32GuardHelpThenCommandReturn(bodyIR):
            PrimaryFillI32GuardHelpThenCommandReturn(instructionWords, wordOffset)
        elif PrimaryBodyIrIsPtrNilGuardDerefReturn(bodyIR):
            PrimaryFillPtrNilGuardDerefReturn(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindStatementSequence:
            if statementMode == PrimaryStatementReturnModeI32Const():
                PrimaryFillLetCallNoargReturnI32Const(instructionWords, wordOffset, statementI32Value)
            elif statementMode == PrimaryStatementReturnModeCallResultI32():
                PrimaryFillLetCallNoargReturnResultI32(instructionWords, wordOffset)
            elif statementMode == PrimaryStatementReturnModeI32GuardResultLeZero():
                PrimaryFillLetCallNoargGuardResultI32(instructionWords, wordOffset)
            elif statementMode == PrimaryStatementReturnModeStrLen():
                PrimaryFillLetCallNoargStrReturnLenI32(instructionWords, wordOffset)
            elif statementMode == PrimaryStatementReturnModeStrThenCallReturnI32Const0():
                PrimaryFillLetCallNoargStrThenCallArg0ReturnI32Const0(instructionWords, wordOffset)
            elif statementMode == PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
                PrimaryFillCstringLiteralCallsReturnI32Const0(instructionWords,
                                                              wordOffset,
                                                              functionStatementCallCounts[i])
        elif bodyKind == texpr.BodyKindEntryBridge:
            PrimaryFillEntryBridge(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindReturnZeroI32:
            PrimaryFillReturnI32Const(instructionWords, wordOffset, 0)
        elif chengpath.TextStartsWith(bodyKind, texpr.BodyKindReturnI32ConstPrefix):
            PrimaryFillReturnI32Const(instructionWords,
                                      wordOffset,
                                      PrimaryStatementSequenceI32Value(bodyKind))
        elif bodyKind == texpr.BodyKindReturnI32Arg0:
            PrimarySetInstructionWord(instructionWords, wordOffset, -698416192)
        elif bodyKind == texpr.BodyKindReturnI32Arg1:
            PrimarySetInstructionWord(instructionWords, wordOffset, 704709600)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnI32Arg2:
            PrimarySetInstructionWord(instructionWords, wordOffset, 704775136)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnI32Arg3:
            PrimarySetInstructionWord(instructionWords, wordOffset, 704840672)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnCallArg0TruePassthrough:
            PrimarySetInstructionWord(instructionWords, wordOffset, 1384120353)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, 335544320)
        elif texpr.TypedExprIsReturnCallBodyKind(bodyKind):
            PrimarySetInstructionWord(instructionWords, wordOffset, 335544320)
        elif PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
            PrimaryFillLetCallNoargReturnI32Const(instructionWords,
                                                  wordOffset,
                                                  PrimaryStatementSequenceI32Value(bodyKind))
        elif texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(bodyKind):
            PrimaryFillLetCallNoargReturnResultI32(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32:
            PrimaryFillLetCallNoargGuardResultI32(instructionWords, wordOffset)
        elif texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
            PrimaryFillLetCallNoargStrReturnLenI32(instructionWords, wordOffset)
        elif texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
            PrimaryFillLetCallNoargStrThenCallArg0ReturnI32Const0(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindReturnStrArg0:
            PrimaryFillReturnStrArg0(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindReturnStrEmpty:
            PrimaryFillReturnStrEmpty(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindCstringToStrCopy:
            PrimaryFillCstringToStrCopy(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindIfArg0LeZeroReturnI32Const0ElseI32Const7:
            PrimarySetInstructionWord(instructionWords, wordOffset, 1895825439)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, 1409286252)
            PrimaryFillReturnI32Const(instructionWords, wordOffset + 2, 0)
            PrimaryFillReturnI32Const(instructionWords, wordOffset + 4, 7)
        elif bodyKind == texpr.BodyKindReturnF64MulArgs:
            PrimarySetInstructionWord(instructionWords, wordOffset, 509675520)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnI32AddArgs:
            PrimarySetInstructionWord(instructionWords, wordOffset, 184614912)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnI32SubArgs:
            PrimarySetInstructionWord(instructionWords, wordOffset, 1258356736)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnI32MulArgs:
            PrimarySetInstructionWord(instructionWords, wordOffset, 453082112)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnI32AsrArgs:
            PrimarySetInstructionWord(instructionWords, wordOffset, 448866304)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnI32MaddArgs:
            PrimarySetInstructionWord(instructionWords, wordOffset, 453052416)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindReturnU64Arg0AndConst4NotZero:
            PrimarySetInstructionWord(instructionWords, wordOffset, -226619361)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, 446629856)
            PrimarySetInstructionWord(instructionWords, wordOffset + 2, -698416192)
        elif bodyKind == texpr.BodyKindReturnU64Arg0OrConst4:
            PrimarySetInstructionWord(instructionWords, wordOffset, -1300365312)
            PrimarySetInstructionWord(instructionWords, wordOffset + 1, -698416192)
        elif bodyKind == texpr.BodyKindStrLenFastI32:
            PrimaryFillStrLenFast(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindMainF64MulCheckExit:
            PrimaryFillMainF64MulCheckExit(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindRuntimeSetCmdLine:
            PrimaryFillRuntimeSetCmdLine(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindBackendDriverRootFromCmdline:
            PrimaryFillBackendDriverRootFromCmdline(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindBackendDriverCommandDispatch:
            PrimaryFillBackendDriverCommandDispatch(instructionWords, wordOffset)
        elif bodyKind == texpr.BodyKindResultRequestDispatch:
            PrimaryFillResultRequestDispatch(instructionWords, wordOffset)
    plan.instructionWords = instructionWords
    plan.dataLabels = dataLabels
    plan.dataPayloadTexts = dataPayloadTexts
    plan.relocSourceItemIds = relocSourceItemIds
    plan.relocWordOffsets = relocWordOffsets
    plan.relocTargetSymbols = relocTargetSymbols
    plan.reachableFunctionCount = 0
    for i in 0..<reachable.len:
        if i % 256 == 0:
            os.ProcessResourceGuardCheck()
        if reachable[i]:
            plan.reachableFunctionCount = plan.reachableFunctionCount + 1
    plan.firstMissingFunction = firstMissingFunction
    plan.firstMissingBodyKind = firstMissingBodyKind
    plan.firstMissingTypedIrKind = firstMissingTypedIrKind
    plan.firstMissingLineNumber = firstMissingLineNumber
    plan.missingReasons = PrimaryObjectMissingReasons(linkPlan,
                                                        lowering,
                                                        itemIds,
                                                        plan.instructionWords,
                                                        bodySemanticsMissing)
    plan.pipelineStage = "lowering_plan_to_primary_object_plan"
    return Ok[PrimaryObjectPlan](plan)


fn PrimaryObjectPlanIntListText(items: int32[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if i > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{strings.IntToStr(items[i])}"
    return out

fn PrimaryObjectPlanAppendLine(out: var str, key: str, value: str) =
    out = Fmt"{out}{key}={value}\n"

fn PrimaryObjectPlanReport(plan: PrimaryObjectPlan): str =
    var symbolText = "-"
    if plan.symbolNames.len > 0:
        symbolText = strutil.Join(plan.symbolNames, ",")
    var bodyKindText = "-"
    if plan.functionBodyKinds.len > 0:
        bodyKindText = strutil.Join(plan.functionBodyKinds, ",")
    var statementReturnModeText = "-"
    if plan.functionStatementReturnModes.len > 0:
        statementReturnModeText = PrimaryObjectPlanIntListText(plan.functionStatementReturnModes)
    var statementCallCountText = "-"
    if plan.functionStatementCallCounts.len > 0:
        statementCallCountText = PrimaryObjectPlanIntListText(plan.functionStatementCallCounts)
    var localSlotCountText = "-"
    if plan.functionLocalSlotCounts.len > 0:
        localSlotCountText = PrimaryObjectPlanIntListText(plan.functionLocalSlotCounts)
    var localStackByteCountText = "-"
    if plan.functionLocalStackByteCounts.len > 0:
        localStackByteCountText = PrimaryObjectPlanIntListText(plan.functionLocalStackByteCounts)
    var bodyIrOpCountText = "-"
    var bodyIrReturnCountText = "-"
    if plan.functionBodyIRs.len > 0:
        var opCounts: int32[]
        var returnCounts: int32[]
        for i in 0..<plan.functionBodyIRs.len:
            add(opCounts, plan.functionBodyIRs[i].ops.len)
            var returnCount: int32
            for opIndex in 0..<plan.functionBodyIRs[i].ops.len:
                if plan.functionBodyIRs[i].ops[opIndex].kind == coreir.BodyOpReturnTag:
                    returnCount = returnCount + 1
            add(returnCounts, returnCount)
        bodyIrOpCountText = PrimaryObjectPlanIntListText(opCounts)
        bodyIrReturnCountText = PrimaryObjectPlanIntListText(returnCounts)
    var relocTargetText = "-"
    if plan.relocTargetSymbols.len > 0:
        relocTargetText = strutil.Join(plan.relocTargetSymbols, ",")
    var relocWordOffsetText = "-"
    if plan.relocWordOffsets.len > 0:
        relocWordOffsetText = PrimaryObjectPlanIntListText(plan.relocWordOffsets)
    var wordOffsetText = "-"
    if plan.functionWordOffsets.len > 0:
        wordOffsetText = PrimaryObjectPlanIntListText(plan.functionWordOffsets)
    var wordCountText = "-"
    if plan.functionWordCounts.len > 0:
        wordCountText = PrimaryObjectPlanIntListText(plan.functionWordCounts)
    var firstMissingFunction = "-"
    if len(plan.firstMissingFunction) > 0:
        firstMissingFunction = plan.firstMissingFunction
    var firstMissingBodyKind = "-"
    if len(plan.firstMissingBodyKind) > 0:
        firstMissingBodyKind = plan.firstMissingBodyKind
    var firstMissingTypedIrKind = "-"
    if len(plan.firstMissingTypedIrKind) > 0:
        firstMissingTypedIrKind = plan.firstMissingTypedIrKind
    var out = ""
    PrimaryObjectPlanAppendLine(out, "primary_object_format", plan.objectFormat)
    PrimaryObjectPlanAppendLine(out, "primary_object_item_count", strings.IntToStr(plan.itemIds.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_reachable_function_count", strings.IntToStr(plan.reachableFunctionCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_symbols", symbolText)
    PrimaryObjectPlanAppendLine(out, "primary_object_body_kinds", bodyKindText)
    PrimaryObjectPlanAppendLine(out, "primary_object_statement_return_modes", statementReturnModeText)
    PrimaryObjectPlanAppendLine(out, "primary_object_statement_call_counts", statementCallCountText)
    PrimaryObjectPlanAppendLine(out, "primary_object_local_slot_counts", localSlotCountText)
    PrimaryObjectPlanAppendLine(out, "primary_object_local_stack_byte_counts", localStackByteCountText)
    PrimaryObjectPlanAppendLine(out, "primary_object_body_ir_op_counts", bodyIrOpCountText)
    PrimaryObjectPlanAppendLine(out, "primary_object_body_ir_return_counts", bodyIrReturnCountText)
    PrimaryObjectPlanAppendLine(out, "primary_object_word_offsets", wordOffsetText)
    PrimaryObjectPlanAppendLine(out, "primary_object_word_counts", wordCountText)
    PrimaryObjectPlanAppendLine(out, "primary_object_instruction_word_count", strings.IntToStr(plan.instructionWords.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_data_label_count", strings.IntToStr(plan.dataLabels.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_reloc_count", strings.IntToStr(plan.relocSourceItemIds.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_reloc_word_offsets", relocWordOffsetText)
    PrimaryObjectPlanAppendLine(out, "primary_object_reloc_target_symbols", relocTargetText)
    PrimaryObjectPlanAppendLine(out, "primary_object_entry_function_symbol", plan.entryFunctionSymbol)
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_function", firstMissingFunction)
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_body_kind", firstMissingBodyKind)
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_typed_ir_kind", firstMissingTypedIrKind)
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_line_number", strings.IntToStr(plan.firstMissingLineNumber))
    PrimaryObjectPlanAppendLine(out, "primary_object_missing_reasons", slplan.SystemLinkPlanListText(plan.missingReasons))
    out = Fmt"{out}primary_object_pipeline_stage={plan.pipelineStage}"
    return out
