fn PrimaryFillCstringLiteralCallsReturnI32Const0(words: var int32[],
                                                 wordOffset: int32,
                                                 callCount: int32) =
    PrimarySetInstructionWord(words, wordOffset, -1447068675)
    PrimarySetInstructionWord(words, wordOffset + 1, -1862269955)
    for callOrdinal in 0..<callCount:
        let callWordOffset = wordOffset + 2 + callOrdinal * 3
        PrimarySetInstructionWord(words, callWordOffset, -1879048192)
        PrimarySetInstructionWord(words, callWordOffset + 1, -1862270976)
        PrimarySetInstructionWord(words, callWordOffset + 2, -1811939328)
    let returnWordOffset = wordOffset + 2 + callCount * 3
    PrimarySetInstructionWord(words, returnWordOffset, 1384120320)
    PrimarySetInstructionWord(words, returnWordOffset + 1, -1463714819)
    PrimarySetInstructionWord(words, returnWordOffset + 2, -698416192)

