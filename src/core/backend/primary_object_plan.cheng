    words[wordOffset + 2] = -1191181824
    words[wordOffset + 3] = -1879048176
    words[wordOffset + 4] = -1862270448
    words[wordOffset + 5] = -117439999
    words[wordOffset + 6] = a64.A64EncRet()
    return true

fn PrimaryFillRuntimeParamCountWords(words: var int32[],
