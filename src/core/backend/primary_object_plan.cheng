    words[wordOffset + 13] = -1186982944
    words[wordOffset + 14] = -113242114
    words[wordOffset + 15] = Value(a64.A64EncAddImm(true, a64.A64SP, a64.A64SP, 32))
    words[wordOffset + 16] = a64.A64EncRet()
    return true

