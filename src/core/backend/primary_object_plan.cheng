fn PrimaryFillInstructionWordsForFunction(words: var int32[],
                                          wordOffset: int32,
                                          wordCount: int32,
                                          bodyKind: str): bool =
    if wordCount <= 0:
        return false
    if bodyKind == PrimaryBodyKindCallIndirectVoidBridge():
        if wordCount != 4:
            return false
        return PrimaryFillCallIndirectVoidBridgeWords(words, wordOffset)
    if bodyKind == PrimaryBodyKindCallIndirectI32Bridge():
        if wordCount != 6:
            return false
        return PrimaryFillCallIndirectI32BridgeWords(words, wordOffset)
    if bodyKind == texpr.BodyKindReturnVoid:
        if wordOffset < 0 || wordOffset >= words.len || wordCount != 1:
            return false
        words[wordOffset] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnZeroI32:
        if wordCount != 2:
            return false
        return PrimaryFillReturnI32ConstWords(words, wordOffset, 0)
    if PrimaryStartsWith(bodyKind, texpr.BodyKindReturnI32ConstPrefix):
        if wordCount != 2:
            return false
        return PrimaryFillReturnI32ConstWords(words, wordOffset, PrimaryReturnI32ConstValue(bodyKind))
    if bodyKind == texpr.BodyKindReturnI32Arg0:
        if wordOffset < 0 || wordOffset >= words.len || wordCount != 1:
            return false
        words[wordOffset] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnI32AddArgs ||
       bodyKind == texpr.BodyKindReturnI32SubArgs ||
       bodyKind == texpr.BodyKindReturnI32MulArgs ||
       bodyKind == texpr.BodyKindReturnI32AsrArgs ||
       bodyKind == texpr.BodyKindReturnI32MaddArgs:
        if wordCount != 2:
            return false
        return PrimaryFillReturnI32BinaryWords(words, wordOffset, bodyKind)
    if bodyKind == texpr.BodyKindReturnF64MulArgs:
        if wordCount != 2:
            return false
        return PrimaryFillReturnF64MulWords(words, wordOffset)
    if texpr.TypedExprIsReturnCallBodyKind(bodyKind):
        if wordOffset < 0 || wordOffset >= words.len || wordCount <= 0:
            return false
        words[wordOffset] = a64.A64EncBPlaceholder()
        if wordCount == 2 && wordOffset + 1 < words.len:
            words[wordOffset + 1] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindEntryBridge:
        if wordCount != texpr.BodyKindEntryBridgeWordCount:
            return false
        return PrimaryFillEntryBridgeWords(words, wordOffset)
    if bodyKind == texpr.BodyKindRuntimeSetCmdLine:
        if wordCount != 7:
            return false
        return PrimaryFillRuntimeSetCmdLineWords(words, wordOffset)
    if bodyKind == texpr.BodyKindRuntimeParamCount:
        if wordCount != 6:
            return false
        return PrimaryFillRuntimeParamCountWords(words, wordOffset)
    if bodyKind == texpr.BodyKindRuntimeParamStrCopyBridge:
        if wordCount != 35:
            return false
        return PrimaryFillRuntimeParamStrCopyBridgeWords(words, wordOffset)
    if bodyKind == texpr.BodyKindReturnStrArg0:
        if wordCount != 7:
            return false
        return PrimaryFillReturnStrArg0Words(words, wordOffset)
    if bodyKind == texpr.BodyKindReturnComposite16Arg0:
        if wordCount != 5:
            return false
        if wordOffset < 0 || wordOffset + 4 >= words.len:
            return false
        words[wordOffset] = Value(a64.A64EncLdrImm(true, a64.A64X9, a64.A64X0, int64(0)))
        words[wordOffset + 1] = Value(a64.A64EncLdrImm(true, a64.A64X10, a64.A64X0, int64(8)))
        words[wordOffset + 2] = Value(a64.A64EncStrImm(true, a64.A64X9, a64.A64X8, int64(0)))
        words[wordOffset + 3] = Value(a64.A64EncStrImm(true, a64.A64X10, a64.A64X8, int64(8)))
        words[wordOffset + 4] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnComposite16Field0Arg0:
        if wordCount != 5:
            return false
        if wordOffset < 0 || wordOffset + 4 >= words.len:
            return false
        words[wordOffset] = Value(a64.A64EncLdrImm(true, a64.A64X9, a64.A64X0, int64(0)))
        words[wordOffset + 1] = Value(a64.A64EncLdrImm(true, a64.A64X10, a64.A64X0, int64(8)))
        words[wordOffset + 2] = Value(a64.A64EncStrImm(true, a64.A64X9, a64.A64X8, int64(0)))
        words[wordOffset + 3] = Value(a64.A64EncStrImm(true, a64.A64X10, a64.A64X8, int64(8)))
        words[wordOffset + 4] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnSeqLenArg0:
        if wordCount != 2:
            return false
        if wordOffset < 0 || wordOffset + 1 >= words.len:
            return false
        words[wordOffset] = Value(a64.A64EncLdrImm(false, a64.A64X0, a64.A64X0, int64(0)))
        words[wordOffset + 1] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnBytesLenArg0:
        if wordCount != 2:
            return false
        if wordOffset < 0 || wordOffset + 1 >= words.len:
            return false
        words[wordOffset] = Value(a64.A64EncLdrImm(false, a64.A64X0, a64.A64X0, int64(8)))
        words[wordOffset + 1] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnCharArg0:
        if wordCount != 1:
            return false
        if wordOffset < 0 || wordOffset >= words.len:
            return false
        words[wordOffset] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnI64FromI32Arg0:
        if wordCount != 2:
            return false
        if wordOffset < 0 || wordOffset + 1 >= words.len:
            return false
        words[wordOffset] = a64.A64EncSxtw(a64.A64X0, a64.A64X0)
        words[wordOffset + 1] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnBoolI32Arg0Range0To31:
        if wordCount != 3:
            return false
        if wordOffset < 0 || wordOffset + 2 >= words.len:
            return false
        words[wordOffset] = Value(a64.A64EncCmpImm(false, a64.A64X0, 32))
        words[wordOffset + 1] = Value(a64.A64EncCset(a64.A64X0, a64.A64CondLO))
        words[wordOffset + 2] = a64.A64EncRet()
        return true
    if bodyKind == texpr.BodyKindReturnStrEmpty:
        if wordCount != 4:
            return false
        return PrimaryFillReturnStrEmptyWords(words, wordOffset)
    if bodyKind == texpr.BodyKindStrLenFastI32:
        if wordCount != 8:
            return false
        return PrimaryFillStrLenFastWords(words, wordOffset)
    if bodyKind == texpr.BodyKindStatementSequence:
        return wordCount <= 0
    return false

fn PrimaryBodyIRLoadSlotToReg(words: var int32[],
                               offset: int32,
                               bodyIR: coreir.BodyIR,
                               slotIndex: int32,
                               reg: int32,
                               frameBytes: int32,
                               paramSaveOffset: int32,
                               paramSaveCount: int32): int32 =
    if offset < 0 || offset >= words.len:
        return -1
    let stackOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                   slotIndex,
                                                   frameBytes,
                                                   paramSaveOffset,
                                                   paramSaveCount)
    if stackOffset < 0:
        return -1
    let slotType = PrimaryBodyIrSlotType(bodyIR, slotIndex)
    if slotType == coreir.LocalI32Tag:
        words[offset] = Value(a64.A64EncLdrImm(false, reg, a64.A64SP, int64(stackOffset)))
        return offset + 1
    if slotType == coreir.LocalI64Tag ||
       slotType == coreir.LocalPtrTag:
        words[offset] = Value(a64.A64EncLdrImm(true, reg, a64.A64SP, int64(stackOffset)))
        return offset + 1
    if slotType == coreir.LocalStrTag ||
       slotType == coreir.LocalAggregateTag:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[slotIndex]):
            words[offset] = Value(a64.A64EncLdrImm(true, reg, a64.A64SP, int64(stackOffset)))
            return offset + 1
        return PrimaryBodyIRFillStackAddressToReg(words, offset, reg, stackOffset)
    return -1

fn PrimaryBodyIRStoreRegToSlot(words: var int32[],
                                offset: int32,
                                bodyIR: coreir.BodyIR,
                                slotIndex: int32,
                                reg: int32,
                                frameBytes: int32,
                                paramSaveOffset: int32,
                                paramSaveCount: int32): int32 =
    if offset < 0 || offset >= words.len:
        return -1
    let stackOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                   slotIndex,
                                                   frameBytes,
                                                   paramSaveOffset,
                                                   paramSaveCount)
    if stackOffset < 0:
        return -1
    let slotType = PrimaryBodyIrSlotType(bodyIR, slotIndex)
    if slotType == coreir.LocalI32Tag:
        words[offset] = Value(a64.A64EncStrImm(false, reg, a64.A64SP, int64(stackOffset)))
        return offset + 1
    if slotType == coreir.LocalI64Tag ||
       slotType == coreir.LocalPtrTag:
        words[offset] = Value(a64.A64EncStrImm(true, reg, a64.A64SP, int64(stackOffset)))
        return offset + 1
    return -1

fn PrimaryBodyIRLoadStrValueAddressToReg(words: var int32[],
                                          offset: int32,
                                          bodyIR: coreir.BodyIR,
                                          slotIndex: int32,
                                          reg: int32,
                                          frameBytes: int32,
                                          paramSaveOffset: int32,
                                          paramSaveCount: int32): int32 =
    if offset < 0 || offset >= words.len:
        return -1
    if PrimaryBodyIrSlotType(bodyIR, slotIndex) != coreir.LocalStrTag:
        return -1
    let stackOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                   slotIndex,
                                                   frameBytes,
                                                   paramSaveOffset,
                                                   paramSaveCount)
    if stackOffset < 0:
        return -1
    if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[slotIndex]):
        words[offset] = Value(a64.A64EncLdrImm(true,
                                               reg,
                                               a64.A64SP,
                                               int64(stackOffset)))
        return offset + 1
    return PrimaryBodyIRFillStackAddressToReg(words, offset, reg, stackOffset)

fn PrimaryBodyIRStrEqLiteralWordCount(bodyIR: coreir.BodyIR,
                                       op: coreir.BodyOp): int32 =
    if op.operands.len < 2:
        return 0
    if op.target < 0 || op.target >= bodyIR.localSlots.len:
        return 0
    if bodyIR.localSlots[op.target].typeKind != coreir.LocalI32Tag:
        return 0
    let strSlot = op.operands[0]
    if strSlot < 0 ||
       strSlot >= bodyIR.localSlots.len ||
       bodyIR.localSlots[strSlot].typeKind != coreir.LocalStrTag:
        return 0
    let literalId = op.operands[1]
    if literalId < 0 || literalId >= bodyIR.cstringLiterals.len:
        return 0
    let literalLen = len(bodyIR.cstringLiterals[literalId].text)
    if literalLen > 4095:
        return 0
    return 9 + literalLen * 3

fn PrimaryBodyIRFillStrEqLiteralOp(words: var int32[],
                                    offset: int32,
                                    bodyIR: coreir.BodyIR,
                                    op: coreir.BodyOp,
                                    frameBytes: int32,
                                    paramSaveOffset: int32,
                                    paramSaveCount: int32): int32 =
    if op.operands.len < 2:
        return -1
    let literalId = op.operands[1]
    if literalId < 0 || literalId >= bodyIR.cstringLiterals.len:
        return -1
    let literalText = bodyIR.cstringLiterals[literalId].text
    let literalLen = len(literalText)
    let wordCount = PrimaryBodyIRStrEqLiteralWordCount(bodyIR, op)
    if wordCount <= 0 || offset < 0 || offset + wordCount > words.len:
        return -1
    let failIndex = offset + wordCount - 2
    let storeIndex = offset + wordCount - 1
    var pos = PrimaryBodyIRLoadStrValueAddressToReg(words,
                                                    offset,
                                                    bodyIR,
                                                    op.operands[0],
                                                    a64.A64X10,
                                                    frameBytes,
                                                    paramSaveOffset,
                                                    paramSaveCount)
    if pos < 0 || pos + 3 >= words.len:
        return -1
    words[pos] = Value(a64.A64EncLdrImm(true, a64.A64X9, a64.A64X10, int64(0)))
    pos = pos + 1
    words[pos] = Value(a64.A64EncLdrImm(false, a64.A64X11, a64.A64X10, int64(8)))
    pos = pos + 1
    words[pos] = Value(a64.A64EncCmpImm(false, a64.A64X11, literalLen))
    pos = pos + 1
    words[pos] = Value(a64.A64EncBCond(int64(failIndex - pos), a64.A64CondNE))
    pos = pos + 1
    for byteIndex in 0..<literalLen:
        if pos + 2 >= words.len:
            return -1
        words[pos] = Value(a64.A64EncLdrbImm(a64.A64X11, a64.A64X9, byteIndex))
        pos = pos + 1
        words[pos] = Value(a64.A64EncCmpImm(false, a64.A64X11, int32(literalText[byteIndex])))
        pos = pos + 1
        words[pos] = Value(a64.A64EncBCond(int64(failIndex - pos), a64.A64CondNE))
        pos = pos + 1
    if pos + 3 >= words.len:
        return -1
    words[pos] = a64.A64EncMovz(false, a64.A64X11, 1, 0)
    pos = pos + 1
    words[pos] = Value(a64.A64EncBImm(int64(storeIndex - pos)))
    pos = pos + 1
    words[pos] = a64.A64EncMovz(false, a64.A64X11, 0, 0)
    pos = pos + 1
    return PrimaryBodyIRStoreRegToSlot(words,
                                       pos,
                                       bodyIR,
                                       op.target,
                                       a64.A64X11,
                                       frameBytes,
                                       paramSaveOffset,
                                       paramSaveCount)

fn PrimaryBodyIRCopySlot(words: var int32[],
                          offset: int32,
                          bodyIR: coreir.BodyIR,
                          sourceSlotIndex: int32,
                          targetSlotIndex: int32,
                          frameBytes: int32,
                          paramSaveOffset: int32,
                          paramSaveCount: int32): int32 =
    if sourceSlotIndex < 0 || sourceSlotIndex >= bodyIR.localSlots.len ||
       targetSlotIndex < 0 || targetSlotIndex >= bodyIR.localSlots.len:
        return -1
    let sourceOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                    sourceSlotIndex,
                                                    frameBytes,
                                                    paramSaveOffset,
                                                    paramSaveCount)
    let targetOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                    targetSlotIndex,
                                                    frameBytes,
                                                    paramSaveOffset,
                                                    paramSaveCount)
    if sourceOffset < 0 || targetOffset < 0:
        return -1
    let slotSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[targetSlotIndex])
    if slotSize == 4:
        if offset + 1 >= words.len:
            return -1
        words[offset] = Value(a64.A64EncLdrImm(false, a64.A64X9, a64.A64SP, int64(sourceOffset)))
        words[offset + 1] = Value(a64.A64EncStrImm(false, a64.A64X9, a64.A64SP, int64(targetOffset)))
        return offset + 2
    if slotSize <= 0 || slotSize % 8 != 0:
        return -1
    var pos = offset
    for copyIndex in 0..<(slotSize / 8):
        if pos + 1 >= words.len:
            return -1
        words[pos] = Value(a64.A64EncLdrImm(true, a64.A64X9, a64.A64SP, int64(sourceOffset + copyIndex * 8)))
        words[pos + 1] = Value(a64.A64EncStrImm(true, a64.A64X9, a64.A64SP, int64(targetOffset + copyIndex * 8)))
        pos = pos + 2
    return pos

fn PrimaryBodyIRFillStackAddressToReg(words: var int32[],
                                       offset: int32,
                                       reg: int32,
                                       stackOffsetRaw: int32): int32 =
    if offset < 0 || offset >= words.len || stackOffsetRaw < 0:
        return -1
    var pos = offset
    var remain = stackOffsetRaw
    if remain > 4095:
        words[pos] = Value(a64.A64EncAddImm(true, reg, a64.A64SP, 4095))
        pos = pos + 1
        remain = remain - 4095
        while remain > 4095:
            if pos >= words.len:
                return -1
            words[pos] = Value(a64.A64EncAddImm(true, reg, reg, 4095))
            pos = pos + 1
            remain = remain - 4095
        if pos >= words.len:
            return -1
        words[pos] = Value(a64.A64EncAddImm(true, reg, reg, remain))
        return pos + 1
    words[pos] = Value(a64.A64EncAddImm(true, reg, a64.A64SP, remain))
    return pos + 1

fn PrimaryBodyIRFillCallArgToReg(words: var int32[],
                                  offset: int32,
                                  bodyIR: coreir.BodyIR,
                                  argSlot: int32,
                                  passKind: int32,
                                  reg: int32,
                                  frameBytes: int32,
                                  paramSaveOffset: int32,
                                  paramSaveCount: int32): int32 =
    if offset < 0 || offset >= words.len:
        return -1
    if passKind == coreir.BodyCallPassGlobalAddressTag:
        if argSlot < 0 ||
           argSlot >= bodyIR.localSlots.len ||
           bodyIR.localSlots[argSlot].placeKind != coreir.BodyPlaceGlobalAddressTag:
            return -1
        return PrimaryBodyIRFillGlobalDataAddress(words, offset, reg)
    if coreir.CallArgSlotIsConst(argSlot):
        words[offset] = a64.A64EncMovz(false, reg, coreir.CallArgSlotConstI32Value(argSlot), 0)
        return offset + 1
    if coreir.CallArgSlotIsCString(argSlot):
        if offset + 1 >= words.len:
            return -1
        words[offset] = a64.A64EncAdrp(reg)
        words[offset + 1] = Value(a64.A64EncAddImm(true, reg, reg, 0))
        return offset + 2
    if coreir.CallArgSlotIsAddress(argSlot):
        let slotId = coreir.CallArgSlotAddressId(argSlot)
        let slotOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                       slotId,
                                                       frameBytes,
                                                       paramSaveOffset,
                                                       paramSaveCount)
        return PrimaryBodyIRFillStackAddressToReg(words, offset, reg, slotOffset)
    return PrimaryBodyIRLoadSlotToReg(words,
                                      offset,
                                      bodyIR,
                                      argSlot,
                                      reg,
                                      frameBytes,
                                      paramSaveOffset,
                                      paramSaveCount)

fn PrimaryBodyIRFillCallOp(words: var int32[],
                            offset: int32,
                            bodyIR: coreir.BodyIR,
                            op: coreir.BodyOp,
                            frameBytes: int32,
                            paramSaveOffset: int32,
                            paramSaveCount: int32): int32 =
    if op.operands.len <= 0:
        return -1
    let callOrdinal = op.operands[0]
    if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
        return -1
    let call = bodyIR.callSequence[callOrdinal]
    var pos = offset
    let stackArgBytes = PrimaryCallOpStackArgBytes(call)
    if stackArgBytes > 0:
        if pos >= words.len || stackArgBytes > 4095:
            return -1
        words[pos] = Value(a64.A64EncSubImm(true, a64.A64SP, a64.A64SP, stackArgBytes))
        pos = pos + 1
    let registerArgCount = PrimaryCallOpRegisterArgCount(call)
    for argIndex in 0..<registerArgCount:
        pos = PrimaryBodyIRFillCallArgToReg(words,
                                            pos,
                                            bodyIR,
                                            call.argSlots[argIndex],
                                            PrimaryCallOpArgPassKind(call, argIndex),
                                            argIndex,
                                            frameBytes,
                                            paramSaveOffset,
                                            paramSaveCount)
        if pos < 0:
            return -1
    let stackArgCount = PrimaryCallOpStackArgCount(call)
    for stackArgIndex in 0..<stackArgCount:
        let argIndex = stackArgIndex + 8
        pos = PrimaryBodyIRFillCallArgToReg(words,
                                            pos,
                                            bodyIR,
                                            call.argSlots[argIndex],
                                            PrimaryCallOpArgPassKind(call, argIndex),
                                            16,
                                            frameBytes,
                                            paramSaveOffset,
                                            paramSaveCount)
        if pos < 0 || pos >= words.len:
            return -1
        words[pos] = Value(a64.A64EncStrImm(true, 16, a64.A64SP, int64(stackArgIndex * 8)))
        pos = pos + 1
    if PrimaryBodyIRCallHasIndirectResult(bodyIR, call):
        let resultOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                        call.resultSlot,
                                                        frameBytes,
                                                        paramSaveOffset,
                                                        paramSaveCount)
        pos = PrimaryBodyIRFillStackAddressToReg(words, pos, a64.A64X8, resultOffset)
        if pos < 0:
            return -1
    if pos >= words.len:
        return -1
    words[pos] = a64.A64EncBlPlaceholder()
    pos = pos + 1
    if stackArgBytes > 0:
        if pos >= words.len:
            return -1
        words[pos] = Value(a64.A64EncAddImm(true, a64.A64SP, a64.A64SP, stackArgBytes))
        pos = pos + 1
    if PrimaryBodyIRCallStoresScalarResult(bodyIR, call):
        pos = PrimaryBodyIRStoreRegToSlot(words,
                                          pos,
                                          bodyIR,
                                          call.resultSlot,
                                          a64.A64X0,
                                          frameBytes,
                                          paramSaveOffset,
                                          paramSaveCount)
        if pos < 0:
            return -1
    return pos

fn PrimaryBodyIRFillBinOp(words: var int32[],
                           offset: int32,
                           bodyIR: coreir.BodyIR,
                           op: coreir.BodyOp,
                           frameBytes: int32,
                           paramSaveOffset: int32,
                           paramSaveCount: int32): int32 =
    if op.operands.len < 4:
        return -1
    let opType = op.operands[0]
    if opType != coreir.LocalI32Tag &&
       opType != coreir.LocalI64Tag:
        return -1
    let opIs64 = opType == coreir.LocalI64Tag
    var pos = PrimaryBodyIRLoadSlotToReg(words, offset, bodyIR, op.operands[2], a64.A64X9, frameBytes, paramSaveOffset, paramSaveCount)
    if pos < 0:
        return -1
    pos = PrimaryBodyIRLoadSlotToReg(words, pos, bodyIR, op.operands[3], a64.A64X10, frameBytes, paramSaveOffset, paramSaveCount)
    if pos < 0 || pos >= words.len:
        return -1
    let opKind = op.operands[1]
    if opKind == int32(texpr.TypedExprIrOpI32Add):
        words[pos] = a64.A64EncAddReg(opIs64, a64.A64X9, a64.A64X9, a64.A64X10)
        pos = pos + 1
    elif opKind == int32(texpr.TypedExprIrOpI32Sub):
        words[pos] = a64.A64EncSubReg(opIs64, a64.A64X9, a64.A64X9, a64.A64X10)
        pos = pos + 1
    elif opKind == int32(texpr.TypedExprIrOpI32Mul):
        words[pos] = a64.A64EncMul(opIs64, a64.A64X9, a64.A64X9, a64.A64X10)
        pos = pos + 1
    elif opKind == int32(texpr.TypedExprIrOpI32Asr):
        words[pos] = a64.A64EncAsrv(opIs64, a64.A64X9, a64.A64X9, a64.A64X10)
        pos = pos + 1
    elif opKind == int32(texpr.TypedExprIrOpI32Sdiv):
        words[pos] = a64.A64EncSdiv(opIs64, a64.A64X9, a64.A64X9, a64.A64X10)
        pos = pos + 1
    elif opKind == int32(texpr.TypedExprIrOpI32Madd):
        if op.operands.len < 5:
            return -1
        pos = PrimaryBodyIRLoadSlotToReg(words, pos, bodyIR, op.operands[4], 11, frameBytes, paramSaveOffset, paramSaveCount)
        if pos < 0 || pos >= words.len:
            return -1
        words[pos] = a64.A64EncMadd(opIs64, a64.A64X9, a64.A64X9, a64.A64X10, 11)
        pos = pos + 1
    else:
        return -1
    return PrimaryBodyIRStoreRegToSlot(words, pos, bodyIR, op.target, a64.A64X9, frameBytes, paramSaveOffset, paramSaveCount)

fn PrimaryBodyIRFillCmpOp(words: var int32[],
                           offset: int32,
                           bodyIR: coreir.BodyIR,
                           op: coreir.BodyOp,
                           frameBytes: int32,
                           paramSaveOffset: int32,
                           paramSaveCount: int32): int32 =
    if op.operands.len < 3:
        return -1
    var pos = PrimaryBodyIRLoadSlotToReg(words, offset, bodyIR, op.operands[1], a64.A64X9, frameBytes, paramSaveOffset, paramSaveCount)
    if pos < 0:
        return -1
    pos = PrimaryBodyIRLoadSlotToReg(words, pos, bodyIR, op.operands[2], a64.A64X10, frameBytes, paramSaveOffset, paramSaveCount)
    if pos < 0 || pos + 2 >= words.len:
        return -1
    let cmpIs64 = PrimaryBodyIrSlotType(bodyIR, op.operands[1]) == coreir.LocalI64Tag ||
                  PrimaryBodyIrSlotType(bodyIR, op.operands[1]) == coreir.LocalPtrTag ||
                  PrimaryBodyIrSlotType(bodyIR, op.operands[2]) == coreir.LocalI64Tag ||
                  PrimaryBodyIrSlotType(bodyIR, op.operands[2]) == coreir.LocalPtrTag
    words[pos] = a64.A64EncCmpReg(cmpIs64, a64.A64X9, a64.A64X10)
    words[pos + 1] = Value(a64.A64EncCset(a64.A64X9, PrimaryBodyCondArm64TrueCode(op.operands[0])))
    return PrimaryBodyIRStoreRegToSlot(words,
                                       pos + 2,
                                       bodyIR,
                                       op.target,
                                       a64.A64X9,
                                       frameBytes,
                                       paramSaveOffset,
                                       paramSaveCount)

fn PrimaryBodyIRCopyMemoryWordCount(byteCount: int32): int32 =
    if byteCount <= 0:
        return 0
    return byteCount * 2

fn PrimaryBodyIRFillCopyMemory(words: var int32[],
                                offset: int32,
                                sourceReg: int32,
                                sourceOffset: int32,
                                targetReg: int32,
                                targetOffset: int32,
                                byteCount: int32): int32 =
    if byteCount <= 0 ||
       sourceOffset < 0 ||
       targetOffset < 0 ||
       sourceOffset + byteCount - 1 > 4095 ||
       targetOffset + byteCount - 1 > 4095:
        return -1
    var pos = offset
    for copyIndex in 0..<byteCount:
        if pos + 1 >= words.len:
            return -1
        words[pos] = Value(a64.A64EncLdrbImm(a64.A64X11,
                                             sourceReg,
                                             sourceOffset + copyIndex))
        words[pos + 1] = Value(a64.A64EncStrbImm(a64.A64X11,
                                                 targetReg,
                                                 targetOffset + copyIndex))
        pos = pos + 2
    return pos

fn PrimaryBodyIRFillResultProjectOp(words: var int32[],
                                     offset: int32,
                                     bodyIR: coreir.BodyIR,
                                     op: coreir.BodyOp,
                                     frameBytes: int32,
                                     paramSaveOffset: int32,
                                     paramSaveCount: int32): int32 =
    if op.operands.len < 2:
        return -1
    let sourceOffset = PrimaryBodyIrLocalStackOffset(bodyIR, op.operands[1], frameBytes, paramSaveOffset, paramSaveCount)
    let targetOffset = PrimaryBodyIrLocalStackOffset(bodyIR, op.target, frameBytes, paramSaveOffset, paramSaveCount)
    if sourceOffset < 0 || targetOffset < 0:
        return -1
    if op.operands[0] == coreir.BodyResultProjectIsErrTag:
        if offset + 5 >= words.len:
            return -1
        words[offset] = Value(a64.A64EncLdrImm(false, a64.A64X9, a64.A64SP, int64(sourceOffset + coreir.ResultStrOkOffset)))
        words[offset + 1] = Value(a64.A64EncCmpImm(false, a64.A64X9, 0))
        words[offset + 2] = a64.A64EncMovz(false, a64.A64X9, 0, 0)
        words[offset + 3] = Value(a64.A64EncBCond(int64(2), a64.A64CondNE))
        words[offset + 4] = a64.A64EncMovz(false, a64.A64X9, 1, 0)
        words[offset + 5] = Value(a64.A64EncStrImm(false, a64.A64X9, a64.A64SP, int64(targetOffset)))
        return offset + 6
    var fieldOffset = coreir.ResultStrValueOffset
    var byteCount = 24
    if op.operands[0] == coreir.BodyResultProjectErrorStrTag:
        fieldOffset = coreir.ResultStrErrMsgOffset
    elif op.operands[0] != coreir.BodyResultProjectValueStrTag:
        return -1
    if op.operands.len >= 4:
        fieldOffset = op.operands[2]
        byteCount = op.operands[3]
    return PrimaryBodyIRFillCopyMemory(words,
                                       offset,
                                       a64.A64SP,
                                       sourceOffset + fieldOffset,
                                       a64.A64SP,
                                       targetOffset,
                                       byteCount)

fn PrimaryBodyIRGlobalOpIs64(bodyIR: coreir.BodyIR,
                              op: coreir.BodyOp): bool =
    if op.operands.len < 1 ||
       op.operands[0] < 0 ||
       op.operands[0] >= bodyIR.localSlots.len:
        return false
    let typeKind = bodyIR.localSlots[op.operands[0]].typeKind
    return typeKind == coreir.LocalI64Tag ||
           typeKind == coreir.LocalPtrTag

fn PrimaryBodyIRFillGlobalDataAddress(words: var int32[],
                                        offset: int32,
                                        reg: int32): int32 =
    if offset < 0 || offset + 1 >= words.len:
        return -1
    words[offset] = a64.A64EncAdrp(reg)
    words[offset + 1] = Value(a64.A64EncAddImm(true, reg, reg, 0))
    return offset + 2

fn PrimaryBodyIRFillGlobalLoadOp(words: var int32[],
                                  offset: int32,
                                  bodyIR: coreir.BodyIR,
                                  op: coreir.BodyOp,
                                  frameBytes: int32,
                                  paramSaveOffset: int32,
                                  paramSaveCount: int32): int32 =
    if op.operands.len < 1 ||
       op.target < 0 ||
       op.target >= bodyIR.localSlots.len:
        return -1
    let globalSlot = op.operands[0]
    if globalSlot < 0 ||
       globalSlot >= bodyIR.localSlots.len ||
       bodyIR.localSlots[globalSlot].typeKind != bodyIR.localSlots[op.target].typeKind:
        return -1
    var pos = PrimaryBodyIRFillGlobalDataAddress(words, offset, 16)
    if pos < 0 || pos >= words.len:
        return -1
    words[pos] = Value(a64.A64EncLdrImm(PrimaryBodyIRGlobalOpIs64(bodyIR, op),
                                        a64.A64X9,
                                        16,
                                        int64(0)))
    return PrimaryBodyIRStoreRegToSlot(words,
                                       pos + 1,
                                       bodyIR,
                                       op.target,
                                       a64.A64X9,
                                       frameBytes,
                                       paramSaveOffset,
                                       paramSaveCount)

fn PrimaryBodyIRFillGlobalStoreOp(words: var int32[],
                                   offset: int32,
                                   bodyIR: coreir.BodyIR,
                                   op: coreir.BodyOp,
                                   frameBytes: int32,
                                   paramSaveOffset: int32,
                                   paramSaveCount: int32): int32 =
    if op.operands.len < 1 ||
       op.target < 0 ||
       op.target >= bodyIR.localSlots.len:
        return -1
    let globalSlot = op.operands[0]
    if globalSlot < 0 ||
       globalSlot >= bodyIR.localSlots.len ||
       bodyIR.localSlots[globalSlot].typeKind != bodyIR.localSlots[op.target].typeKind:
        return -1
    var pos = PrimaryBodyIRFillGlobalDataAddress(words, offset, 16)
    pos = PrimaryBodyIRLoadSlotToReg(words,
                                     pos,
                                     bodyIR,
                                     op.target,
                                     a64.A64X9,
                                     frameBytes,
                                     paramSaveOffset,
                                     paramSaveCount)
    if pos < 0 || pos >= words.len:
        return -1
    words[pos] = Value(a64.A64EncStrImm(PrimaryBodyIRGlobalOpIs64(bodyIR, op),
                                        a64.A64X9,
                                        16,
                                        int64(0)))
    return pos + 1

fn PrimaryBodyIRFillBlockOp(words: var int32[],
                             offset: int32,
                             bodyIR: coreir.BodyIR,
                             bi: int32,
                             oi: int32): int32 =
    let _ = bi
    if offset < 0 || offset >= words.len || oi < 0 || oi >= bodyIR.ops.len:
        return -1
    let frameBytes = PrimaryBodyIrFrameBytes(bodyIR)
    let paramSaveOffset = PrimaryBodyIrParamSaveOffset(bodyIR)
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    let op = bodyIR.ops[oi]
    if op.kind == coreir.BodyOpCallTag:
        return PrimaryBodyIRFillCallOp(words, offset, bodyIR, op, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpLoadConstTag:
        if op.operands.len < 2 || offset + 1 >= words.len:
            return -1
        let constType = op.operands[0]
        if constType != coreir.LocalI32Tag &&
           constType != coreir.LocalI64Tag &&
           constType != coreir.LocalPtrTag:
            return -1
        words[offset] = a64.A64EncMovz(constType != coreir.LocalI32Tag,
                                       a64.A64X9,
                                       op.operands[1] & 65535,
                                       0)
        return PrimaryBodyIRStoreRegToSlot(words, offset + 1, bodyIR, op.target, a64.A64X9, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpCopyLocalTag ||
       op.kind == coreir.BodyOpStoreLocalTag:
        if op.operands.len < 1:
            return -1
        return PrimaryBodyIRCopySlot(words, offset, bodyIR, op.operands[0], op.target, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpBinOpTag:
        return PrimaryBodyIRFillBinOp(words, offset, bodyIR, op, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpCmpTag:
        return PrimaryBodyIRFillCmpOp(words, offset, bodyIR, op, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpResultProjectTag:
        return PrimaryBodyIRFillResultProjectOp(words, offset, bodyIR, op, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpStrEqLiteralTag:
        return PrimaryBodyIRFillStrEqLiteralOp(words, offset, bodyIR, op, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpGlobalLoadTag:
        return PrimaryBodyIRFillGlobalLoadOp(words, offset, bodyIR, op, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpGlobalStoreTag:
        return PrimaryBodyIRFillGlobalStoreOp(words, offset, bodyIR, op, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpFieldLoadTag:
        if op.operands.len < 4:
            return -1
        let baseSlot = op.operands[0]
        let valueSlot = op.operands[1]
        let byteOffset = op.operands[2]
        let byteCount = op.operands[3]
        if op.target != valueSlot ||
           baseSlot < 0 || baseSlot >= bodyIR.localSlots.len ||
           valueSlot < 0 || valueSlot >= bodyIR.localSlots.len ||
           byteOffset < 0 || byteCount <= 0 ||
           PrimaryLocalSlotSizeOf(bodyIR.localSlots[valueSlot]) < byteCount:
            return -1
        var pos = offset
        var sourceReg = a64.A64SP
        var sourceOffset = byteOffset
        if bodyIR.localSlots[baseSlot].typeKind == coreir.LocalPtrTag:
            pos = PrimaryBodyIRLoadSlotToReg(words,
                                             pos,
                                             bodyIR,
                                             baseSlot,
                                             a64.A64X9,
                                             frameBytes,
                                             paramSaveOffset,
                                             paramSaveCount)
            if pos < 0:
                return -1
            sourceReg = a64.A64X9
        else:
            let baseOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                           baseSlot,
                                                           frameBytes,
                                                           paramSaveOffset,
                                                           paramSaveCount)
            let baseSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[baseSlot])
            if baseOffset < 0:
                return -1
            if baseSize > 0 && byteOffset > baseSize - byteCount:
                return -1
            sourceOffset = baseOffset + byteOffset
        let targetOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                         valueSlot,
                                                         frameBytes,
                                                         paramSaveOffset,
                                                         paramSaveCount)
        if targetOffset < 0:
            return -1
        if byteCount % 8 == 0 &&
           sourceOffset % 8 == 0 &&
           targetOffset % 8 == 0:
            for copyIndex in 0..<(byteCount / 8):
                if pos + 1 >= words.len:
                    return -1
                words[pos] = Value(a64.A64EncLdrImm(true,
                                                    a64.A64X10,
                                                    sourceReg,
                                                    int64(sourceOffset + copyIndex * 8)))
                words[pos + 1] = Value(a64.A64EncStrImm(true,
                                                        a64.A64X10,
                                                        a64.A64SP,
                                                        int64(targetOffset + copyIndex * 8)))
                pos = pos + 2
            return pos
        if byteCount % 4 == 0 &&
           sourceOffset % 4 == 0 &&
           targetOffset % 4 == 0:
            for copyIndex in 0..<(byteCount / 4):
                if pos + 1 >= words.len:
                    return -1
                words[pos] = Value(a64.A64EncLdrImm(false,
                                                    a64.A64X10,
                                                    sourceReg,
                                                    int64(sourceOffset + copyIndex * 4)))
                words[pos + 1] = Value(a64.A64EncStrImm(false,
                                                        a64.A64X10,
                                                        a64.A64SP,
                                                        int64(targetOffset + copyIndex * 4)))
                pos = pos + 2
            return pos
        return -1
    if op.kind == coreir.BodyOpFieldStoreTag:
        if op.operands.len < 4:
            return -1
        let baseSlot = op.operands[0]
        let valueSlot = op.operands[1]
        let byteOffset = op.operands[2]
        let byteCount = op.operands[3]
        if op.target != baseSlot ||
           baseSlot < 0 || baseSlot >= bodyIR.localSlots.len ||
           valueSlot < 0 || valueSlot >= bodyIR.localSlots.len ||
           byteOffset < 0 || byteCount <= 0 ||
           PrimaryLocalSlotSizeOf(bodyIR.localSlots[valueSlot]) < byteCount:
            return -1
        let sourceOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                         valueSlot,
                                                         frameBytes,
                                                         paramSaveOffset,
                                                         paramSaveCount)
        var pos = offset
        if sourceOffset < 0:
            pos = PrimaryBodyIRLoadSlotToReg(words,
                                             pos,
                                             bodyIR,
                                             valueSlot,
                                             a64.A64X10,
                                             frameBytes,
                                             paramSaveOffset,
                                             paramSaveCount)
            if pos < 0 || pos >= words.len:
                return -1
            words[pos] = Value(a64.A64EncStrImm(true, a64.A64X10, a64.A64SP, int64(0)))
            return pos + 1
        var targetReg = a64.A64SP
        var targetOffset = byteOffset
        if bodyIR.localSlots[baseSlot].typeKind == coreir.LocalPtrTag:
            pos = PrimaryBodyIRLoadSlotToReg(words,
                                             pos,
                                             bodyIR,
                                             baseSlot,
                                             a64.A64X9,
                                             frameBytes,
                                             paramSaveOffset,
                                             paramSaveCount)
            if pos < 0:
                return -1
            targetReg = a64.A64X9
        else:
            let baseOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                           baseSlot,
                                                           frameBytes,
                                                           paramSaveOffset,
                                                           paramSaveCount)
            let baseSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[baseSlot])
            if baseOffset < 0:
                return -1
            if baseSize > 0 && byteOffset > baseSize - byteCount:
                return -1
            targetOffset = baseOffset + byteOffset
        if byteCount % 8 == 0 &&
           sourceOffset % 8 == 0 &&
           targetOffset % 8 == 0:
            for copyIndex in 0..<(byteCount / 8):
                if pos + 1 >= words.len:
                    return -1
                words[pos] = Value(a64.A64EncLdrImm(true,
                                                    a64.A64X10,
                                                    a64.A64SP,
                                                    int64(sourceOffset + copyIndex * 8)))
                words[pos + 1] = Value(a64.A64EncStrImm(true,
                                                        a64.A64X10,
                                                        targetReg,
                                                        int64(targetOffset + copyIndex * 8)))
                pos = pos + 2
            return pos
        if byteCount % 4 == 0 &&
           sourceOffset % 4 == 0 &&
           targetOffset % 4 == 0:
            for copyIndex in 0..<(byteCount / 4):
                if pos + 1 >= words.len:
                    return -1
                words[pos] = Value(a64.A64EncLdrImm(false,
                                                    a64.A64X10,
                                                    a64.A64SP,
                                                    int64(sourceOffset + copyIndex * 4)))
                words[pos + 1] = Value(a64.A64EncStrImm(false,
                                                        a64.A64X10,
                                                        targetReg,
                                                        int64(targetOffset + copyIndex * 4)))
                pos = pos + 2
            return pos
        return -1
    if op.kind == coreir.BodyOpIndexedLoadTag:
        if op.operands.len < 2:
            return -1
        var pos = PrimaryBodyIRLoadSlotToReg(words, offset, bodyIR, op.operands[0], a64.A64X9, frameBytes, paramSaveOffset, paramSaveCount)
        if pos < 0 || pos + 1 >= words.len:
            return -1
        let resultType = PrimaryBodyIrSlotType(bodyIR, op.operands[1])
        let is64 = resultType == coreir.LocalI64Tag || resultType == coreir.LocalPtrTag || resultType == coreir.LocalStrTag || resultType == coreir.LocalAggregateTag
        words[pos] = Value(a64.A64EncLdrImm(is64, a64.A64X10, a64.A64X9, int64(0)))
        return PrimaryBodyIRStoreRegToSlot(words, pos + 1, bodyIR, op.operands[1], a64.A64X10, frameBytes, paramSaveOffset, paramSaveCount)
    if op.kind == coreir.BodyOpIndexedStoreTag:
        if op.operands.len < 2:
            return -1
        var pos = PrimaryBodyIRLoadSlotToReg(words, offset, bodyIR, op.operands[0], a64.A64X9, frameBytes, paramSaveOffset, paramSaveCount)
        pos = PrimaryBodyIRLoadSlotToReg(words, pos, bodyIR, op.operands[1], a64.A64X10, frameBytes, paramSaveOffset, paramSaveCount)
        if pos < 0 || pos >= words.len:
            return -1
        if op.operands.len >= 3 &&
           op.operands[2] == coreir.BodyStoreLocalPtrDerefU8Tag:
            words[pos] = Value(a64.A64EncStrbImm(a64.A64X10, a64.A64X9, 0))
            return pos + 1
        let valueType = PrimaryBodyIrSlotType(bodyIR, op.operands[1])
        let is64 = valueType == coreir.LocalI64Tag || valueType == coreir.LocalPtrTag
        words[pos] = Value(a64.A64EncStrImm(is64, a64.A64X10, a64.A64X9, int64(0)))
        return pos + 1
    if op.kind == coreir.BodyOpLoadLocalTag:
        if op.operands.len >= 3 &&
           (op.operands[0] == coreir.BodyLoadLocalPtrDerefI32Tag ||
            op.operands[0] == coreir.BodyLoadLocalPtrDerefU8Tag):
            if op.operands[1] < 0 || op.operands[1] >= bodyIR.localSlots.len ||
               op.target < 0 || op.target >= bodyIR.localSlots.len:
                return -1
            var pos = PrimaryBodyIRLoadSlotToReg(words, offset, bodyIR, op.operands[1], a64.A64X9, frameBytes, paramSaveOffset, paramSaveCount)
            if pos < 0 || pos >= words.len:
                return -1
            if op.operands[0] == coreir.BodyLoadLocalPtrDerefU8Tag:
                words[pos] = Value(a64.A64EncLdrbImm(a64.A64X10, a64.A64X9, 0))
            else:
                words[pos] = Value(a64.A64EncLdrImm(false, a64.A64X10, a64.A64X9, int64(0)))
            return PrimaryBodyIRStoreRegToSlot(words, pos + 1, bodyIR, op.target, a64.A64X10, frameBytes, paramSaveOffset, paramSaveCount)
        if op.operands.len >= 1:
            if op.operands[0] < 0 || op.operands[0] >= bodyIR.localSlots.len ||
               op.target < 0 || op.target >= bodyIR.localSlots.len:
                return -1
            return PrimaryBodyIRCopySlot(words, offset, bodyIR, op.operands[0], op.target, frameBytes, paramSaveOffset, paramSaveCount)
        return -1
    if op.kind == coreir.BodyOpBranchTag:
        if op.operands.len < 3:
            return -1
        let guardSlot = op.operands[1]
        if guardSlot < 0 || guardSlot >= bodyIR.localSlots.len:
            return -1
        var pos = PrimaryBodyIRLoadSlotToReg(words, offset, bodyIR, guardSlot, a64.A64X9, frameBytes, paramSaveOffset, paramSaveCount)
        if pos < 0:
            return -1
        let subKind = op.operands[0]
        if subKind == coreir.BodyBranchIfLocalNilReturnI32ConstTag:
            let returnValue = op.operands[2]
            let restoreCount = PrimaryBodyIrFrameRestoreWordCount(bodyIR)
            if pos + 2 >= words.len:
                return -1
            words[pos] = Value(a64.A64EncCbnz(false, a64.A64X9, int64(2 + restoreCount)))
            words[pos + 1] = a64.A64EncMovz(false, 0, returnValue & 65535, 0)
            return PrimaryBodyIRFillFrameRestore(words, pos + 2, frameBytes)
        if subKind == coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag:
            let returnValue = op.operands[2]
            let restoreCount = PrimaryBodyIrFrameRestoreWordCount(bodyIR)
            if pos + 3 >= words.len:
                return -1
            words[pos] = Value(a64.A64EncCmpImm(false, a64.A64X9, 0))
            words[pos + 1] = Value(a64.A64EncBCond(int64(2 + restoreCount), a64.A64CondGT))
            words[pos + 2] = a64.A64EncMovz(false, 0, returnValue & 65535, 0)
            return PrimaryBodyIRFillFrameRestore(words, pos + 3, frameBytes)
        if subKind == coreir.BodyBranchIfLocalLeZeroReturnCallNoargTag:
            let restoreCount = PrimaryBodyIrFrameRestoreWordCount(bodyIR)
            if pos + 3 >= words.len:
                return -1
            words[pos] = Value(a64.A64EncCmpImm(false, a64.A64X9, 0))
            words[pos + 1] = Value(a64.A64EncBCond(int64(2 + restoreCount), a64.A64CondGT))
            words[pos + 2] = a64.A64EncBlPlaceholder()
            return PrimaryBodyIRFillFrameRestore(words, pos + 3, frameBytes)
        if subKind == coreir.BodyBranchIfLocalLeZeroCallArg0ReturnI32ConstTag:
            if op.operands.len < 4 || pos + 7 >= words.len:
                return -1
            let arg0Slot = op.operands[2]
            let returnValue = op.operands[3]
            if arg0Slot < 0 || arg0Slot >= bodyIR.localSlots.len:
                return -1
            let restoreCount = PrimaryBodyIrFrameRestoreWordCount(bodyIR)
            let argLoadWords = PrimaryBodyIrLoadSlotWordCount(bodyIR, arg0Slot)
            if argLoadWords <= 0:
                return -1
            words[pos] = Value(a64.A64EncCmpImm(false, a64.A64X9, 0))
            words[pos + 1] = Value(a64.A64EncBCond(int64(argLoadWords + restoreCount + 3), a64.A64CondGT))
            var skipLoad = PrimaryBodyIRLoadSlotToReg(words, pos + 2, bodyIR, arg0Slot, a64.A64X0, frameBytes, paramSaveOffset, paramSaveCount)
            words[skipLoad] = a64.A64EncBlPlaceholder()
            words[skipLoad + 1] = a64.A64EncMovz(false, 0, returnValue & 65535, 0)
            return PrimaryBodyIRFillFrameRestore(words, skipLoad + 2, frameBytes)
        return -1
    if op.kind == coreir.BodyOpReturnTag:
        words[offset] = a64.A64EncNop()
        return offset + 1
    return -1

fn PrimaryBodyIRFillBlockOps(words: var int32[], offset: int32, bodyIR: coreir.BodyIR, bi: int32, oi: int32, endOi: int32): int32 =
    if offset < 0:
        return -1
    if oi >= endOi:
        return offset
    let nextOffset = PrimaryBodyIRFillBlockOp(words, offset, bodyIR, bi, oi)
    if nextOffset < 0:
        return -1
    return PrimaryBodyIRFillBlockOps(words, nextOffset, bodyIR, bi, oi + 1, endOi)

fn PrimaryBodyIRFillBlockTerm(words: var int32[], offset: int32, bodyIR: coreir.BodyIR, bi: int32): int32 =
    if offset < 0 || offset >= words.len:
        return -1
    let frameBytes = PrimaryBodyIrFrameBytes(bodyIR)
    let paramSaveOffset = PrimaryBodyIrParamSaveOffset(bodyIR)
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    let block = bodyIR.blocks[bi]
    let termIndex = block.termIndex
    if termIndex < 0:
        return -1
    if termIndex >= bodyIR.terms.len:
        return -1
    let term = bodyIR.terms[termIndex]
    if term.kind == coreir.BodyTermCbrTag:
        let termSize = PrimaryBodyIRTermSize(bodyIR, termIndex)
        if termSize <= 0 || offset + termSize - 1 >= words.len:
            return -1
        let blockStart = PrimaryBodyIRBlockStart(bodyIR, bi)
        let termStart = blockStart + PrimaryBodyIROpRangeSize(bodyIR, block.opStart, block.opStart + block.opCount)
        let functionBase = offset - termStart
        let trueWord = functionBase + PrimaryBodyIRBlockStartOrNext(bodyIR, term.trueBlock, termStart + termSize)
        let falseWord = functionBase + PrimaryBodyIRBlockStartOrNext(bodyIR, term.falseBlock, termStart + termSize)
        var lhsSlot = term.lhsSlot
        if lhsSlot < 0:
            lhsSlot = term.resultSlot
        var pos = PrimaryBodyIRLoadSlotToReg(words,
                                             offset,
                                             bodyIR,
                                             lhsSlot,
                                             a64.A64X9,
                                             frameBytes,
                                             paramSaveOffset,
                                             paramSaveCount)
        if pos < 0 || pos >= words.len:
            return -1
        let lhsIs64 = PrimaryBodyIrSlotType(bodyIR, lhsSlot) == coreir.LocalI64Tag ||
                      PrimaryBodyIrSlotType(bodyIR, lhsSlot) == coreir.LocalPtrTag
        if term.conditionKind == coreir.BodyCondLocalNonZeroTag:
            words[pos] = Value(a64.A64EncCmpImm(lhsIs64, a64.A64X9, 0))
            let trueDelta = int64(trueWord - (pos + 1))
            let falseDelta = int64(falseWord - (pos + 2))
            words[pos + 1] = Value(a64.A64EncBCond(trueDelta, a64.A64CondNE))
            words[pos + 2] = Value(a64.A64EncBImm(falseDelta))
            return pos + 3
        if term.conditionKind == coreir.BodyCondLocalZeroTag:
            words[pos] = Value(a64.A64EncCmpImm(lhsIs64, a64.A64X9, 0))
            let trueDelta = int64(trueWord - (pos + 1))
            let falseDelta = int64(falseWord - (pos + 2))
            words[pos + 1] = Value(a64.A64EncBCond(trueDelta, a64.A64CondEQ))
            words[pos + 2] = Value(a64.A64EncBImm(falseDelta))
            return pos + 3
        if term.conditionKind >= coreir.BodyCondI32EqTag:
            if term.conditionKind <= coreir.BodyCondI32GeTag:
                let condCode = PrimaryBodyCondArm64TrueCode(term.conditionKind)
                if term.rhsSlot >= 0:
                    pos = PrimaryBodyIRLoadSlotToReg(words,
                                                     pos,
                                                     bodyIR,
                                                     term.rhsSlot,
                                                     a64.A64X10,
                                                     frameBytes,
                                                     paramSaveOffset,
                                                     paramSaveCount)
                    if pos < 0 || pos + 2 >= words.len:
                        return -1
                    let cmpIs64 = lhsIs64 ||
                                  PrimaryBodyIrSlotType(bodyIR, term.rhsSlot) == coreir.LocalI64Tag ||
                                  PrimaryBodyIrSlotType(bodyIR, term.rhsSlot) == coreir.LocalPtrTag
                    words[pos] = a64.A64EncCmpReg(cmpIs64, a64.A64X9, a64.A64X10)
                else:
                    var rhsConst = 0
                    if term.operands.len > 0:
                        rhsConst = term.operands[0]
                    if pos + 2 >= words.len:
                        return -1
                    words[pos] = Value(a64.A64EncCmpImm(lhsIs64, a64.A64X9, rhsConst))
                let trueDelta = int64(trueWord - (pos + 1))
                let falseDelta = int64(falseWord - (pos + 2))
                words[pos + 1] = Value(a64.A64EncBCond(trueDelta, condCode))
                words[pos + 2] = Value(a64.A64EncBImm(falseDelta))
                return pos + 3
        return -1
    if term.kind == coreir.BodyTermBrTag:
        let blockStart = PrimaryBodyIRBlockStart(bodyIR, bi)
        let termStart = blockStart + PrimaryBodyIROpRangeSize(bodyIR, block.opStart, block.opStart + block.opCount)
        let functionBase = offset - termStart
        let targetWord = functionBase + PrimaryBodyIRBlockStartOrNext(bodyIR, term.trueBlock, termStart + 1)
        let delta = int64(targetWord - offset)
        words[offset] = Value(a64.A64EncBImm(delta))
        return offset + 1
    if term.kind == coreir.BodyTermReturnTag:
        return PrimaryBodyIRFillBlockTermReturn(words,
                                                offset,
                                                term,
                                                bodyIR,
                                                frameBytes,
                                                paramSaveOffset,
                                                paramSaveCount)
    return -1

fn PrimaryBodyIRFillSpAdd(words: var int32[], offset: int32, frameBytesRaw: int32): int32 =
    var pos = offset
    var frameBytes = frameBytesRaw
    while frameBytes > 4095:
        if pos < 0 || pos >= words.len:
            return -1
        words[pos] = Value(a64.A64EncAddImm(true, a64.A64SP, a64.A64SP, 4095))
        pos = pos + 1
        frameBytes = frameBytes - 4095
    if frameBytes > 0:
        if pos < 0 || pos >= words.len:
            return -1
        words[pos] = Value(a64.A64EncAddImm(true, a64.A64SP, a64.A64SP, frameBytes))
        pos = pos + 1
    return pos

fn PrimaryBodyIRFillFrameRestore(words: var int32[], offset: int32, frameBytes: int32): int32 =
    if offset < 0 || offset >= words.len:
        return -1
    words[offset] = Value(a64.A64EncLdp64(a64.A64FP, a64.A64LR, a64.A64SP, int64(0)))
    var pos = PrimaryBodyIRFillSpAdd(words, offset + 1, frameBytes)
    if pos < 0 || pos >= words.len:
        return -1
    words[pos] = a64.A64EncRet()
    return pos + 1

fn PrimaryBodyIRFillBlockTermReturn(words: var int32[],
                                     offset: int32,
                                     term: coreir.BodyTerm,
                                     bodyIR: coreir.BodyIR,
                                     frameBytes: int32,
                                     paramSaveOffset: int32,
                                     paramSaveCount: int32): int32 =
    if offset < 0 || offset >= words.len:
        return -1
    if term.resultSlot >= 0 && term.resultSlot < bodyIR.localSlots.len:
        let resultType = bodyIR.localSlots[term.resultSlot].typeKind
        if resultType == coreir.LocalStrTag ||
           resultType == coreir.LocalAggregateTag:
            let sourceOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                             term.resultSlot,
                                                             frameBytes,
                                                             paramSaveOffset,
                                                             paramSaveCount)
            let returnBufferOffset = PrimaryBodyIrReturnBufferSaveOffset(bodyIR)
            let restoreCount = PrimaryBodyIrFrameRestoreWordCount(bodyIR)
            if sourceOffset < 0 || returnBufferOffset < 0 || offset + 6 + restoreCount > words.len:
                return -1
            words[offset] = Value(a64.A64EncLdrImm(true, a64.A64X8, a64.A64SP, int64(returnBufferOffset)))
            var pos = offset + 1
            for copyIndex in 0..<3:
                words[pos] = Value(a64.A64EncLdrImm(true,
                                                    a64.A64X9,
                                                    a64.A64SP,
                                                    int64(sourceOffset + copyIndex * 8)))
                words[pos + 1] = Value(a64.A64EncStrImm(true,
                                                        a64.A64X9,
                                                        a64.A64X8,
                                                        int64(copyIndex * 8)))
                pos = pos + 2
            return PrimaryBodyIRFillFrameRestore(words, pos, frameBytes)
        let loadPos = PrimaryBodyIRLoadSlotToReg(words,
                                                  offset,
                                                  bodyIR,
                                                  term.resultSlot,
                                                  a64.A64X0,
                                                  frameBytes,
                                                  paramSaveOffset,
                                                  paramSaveCount)
        if loadPos < 0:
            return -1
        return PrimaryBodyIRFillFrameRestore(words, loadPos, frameBytes)
    if term.resultSlot < 0 &&
       term.operands.len >= 1 &&
       term.operands[0] == coreir.LocalInvalidTag:
        return PrimaryBodyIRFillFrameRestore(words, offset, frameBytes)
    if offset + 3 >= words.len:
        return -1
    let hasOperands = term.operands.len >= 1
    if hasOperands:
        if term.operands[0] == PrimaryStatementReturnModeI32Const():
            if term.operands.len >= 2:
                words[offset] = a64.A64EncMovz(false, 0, term.operands[1] & 65535, 0)
            else:
                words[offset] = a64.A64EncMovz(false, 0, 0, 0)
        elif (term.operands[0] == coreir.LocalI32Tag ||
              term.operands[0] == coreir.LocalI64Tag ||
              term.operands[0] == coreir.LocalPtrTag) &&
             term.resultSlot >= 0:
            let nextOffset = PrimaryBodyIRLoadSlotToReg(words,
                                                        offset,
                                                        bodyIR,
                                                        term.resultSlot,
                                                        a64.A64X0,
                                                        frameBytes,
                                                        paramSaveOffset,
                                                        paramSaveCount)
            if nextOffset != offset + 1:
                return -1
        elif term.operands[0] == coreir.LocalPtrTag && term.resultSlot < 0:
            words[offset] = a64.A64EncMovz(true, 0, 0, 0)
        else:
            words[offset] = a64.A64EncMovz(false, 0, 0, 0)
    else:
        words[offset] = a64.A64EncMovz(false, 0, 0, 0)
    return PrimaryBodyIRFillFrameRestore(words, offset + 1, frameBytes)

fn PrimaryBodyIRFillBlock(words: var int32[], offset: int32, bodyIR: coreir.BodyIR, bi: int32): int32 =
    let block = bodyIR.blocks[bi]
    let afterOps = PrimaryBodyIRFillBlockOps(words, offset, bodyIR, bi, block.opStart, block.opStart + block.opCount)
    if afterOps < 0:
        return -1
    let afterTerm = PrimaryBodyIRFillBlockTerm(words, afterOps, bodyIR, bi)
    if afterTerm < 0:
        return -1
    return afterTerm

fn PrimaryBodyIRFillBlocks(words: var int32[], offset: int32, bodyIR: coreir.BodyIR, bi: int32, endBi: int32): int32 =
    if offset < 0:
        return -1
    if bi >= endBi:
        return offset
    let nextOffset = PrimaryBodyIRFillBlock(words, offset, bodyIR, bi)
    if nextOffset < 0:
        return -1
    return PrimaryBodyIRFillBlocks(words, nextOffset, bodyIR, bi + 1, endBi)

fn PrimaryBodyIRFillWords(words: var int32[], wordOffset: int32, wordCount: int32, bodyIR: coreir.BodyIR): int32 =
    let prologueCount = PrimaryBodyIrPrologueWordCount(bodyIR)
    let frameBytes = PrimaryBodyIrFrameBytes(bodyIR)
    let paramSaveOffset = PrimaryBodyIrParamSaveOffset(bodyIR)
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    if wordOffset < 0 ||
       wordCount < prologueCount ||
       wordOffset + wordCount > words.len ||
       frameBytes <= 0:
        return -1
    var prologuePos = wordOffset
    var remain = frameBytes
    while remain > 4095:
        words[prologuePos] = Value(a64.A64EncSubImm(true, a64.A64SP, a64.A64SP, 4095))
        prologuePos = prologuePos + 1
        remain = remain - 4095
    words[prologuePos] = Value(a64.A64EncSubImm(true, a64.A64SP, a64.A64SP, remain))
    prologuePos = prologuePos + 1
    words[prologuePos] = Value(a64.A64EncStp64(a64.A64FP, a64.A64LR, a64.A64SP, int64(0)))
    prologuePos = prologuePos + 1
    words[prologuePos] = Value(a64.A64EncAddImm(true, a64.A64FP, a64.A64SP, 0))
    prologuePos = prologuePos + 1
    var prologueOffset = prologuePos
    for paramIndex in 0..<paramSaveCount:
        if prologueOffset >= wordOffset + prologueCount:
            return -1
        words[prologueOffset] = Value(a64.A64EncStrImm(true,
                                                       paramIndex,
                                                       a64.A64SP,
                                                       int64(paramSaveOffset + paramIndex * 8)))
        prologueOffset = prologueOffset + 1
    let returnBufferOffset = PrimaryBodyIrReturnBufferSaveOffset(bodyIR)
    if returnBufferOffset < 0 || prologueOffset >= wordOffset + prologueCount:
        return -1
    words[prologueOffset] = Value(a64.A64EncStrImm(true, a64.A64X8, a64.A64SP, int64(returnBufferOffset)))
    prologueOffset = prologueOffset + 1
    let afterBlocks = PrimaryBodyIRFillBlocks(words, wordOffset + prologueCount, bodyIR, 0, bodyIR.blocks.len)
    return afterBlocks - wordOffset

fn PrimaryFillOneFunction(words: var int32[],
                           functionWordOffsets: int32[],
                           functionWordCounts: int32[],
                           functionBodyKinds: str[],
                           functionBodyIRs: coreir.BodyIR[],
                           i: int32): bool =
    if i >= functionWordOffsets.len || i >= functionWordCounts.len:
        return false
    let wordCount = functionWordCounts[i]
    let hasBodyIR = i < functionBodyIRs.len &&
                    (functionBodyIRs[i].ops.len > 0 || functionBodyIRs[i].terms.len > 0)
    if hasBodyIR:
        let bodyIR = functionBodyIRs[i]
        let offset = functionWordOffsets[i]
        let emitted = PrimaryBodyIRFillWords(words, offset, wordCount, bodyIR)
        if emitted >= 0:
            if emitted != wordCount:
                return false
            return true
        return false
    return PrimaryFillInstructionWordsForFunction(words,
                                                   functionWordOffsets[i],
                                                   functionWordCounts[i],
                                                   functionBodyKinds[i])

fn PrimaryFillInstructionWords(words: var int32[],
                               functionWordOffsets: int32[],
                               functionWordCounts: int32[],
                               functionBodyKinds: str[],
                               functionBodyIRs: coreir.BodyIR[],
                               failedIndex: var int32): bool =
    var ok = true
    failedIndex = -1
    for i in 0..<functionBodyKinds.len:
        if !PrimaryFillOneFunction(words,
                                    functionWordOffsets,
                                    functionWordCounts,
                                    functionBodyKinds,
                                    functionBodyIRs,
                                    i):
            ok = false
            failedIndex = i
    return ok

fn PrimaryFillFunctionChunk(words: int32[],
                             functionWordOffsets: int32[],
                             functionWordCounts: int32[],
                             functionBodyKinds: str[],
                             functionBodyIRs: coreir.BodyIR[],
                             startIndex: int32,
                             endIndex: int32,
                             failedIndex: var int32): bool =
    var ok = true
    failedIndex = -1
    var limit = endIndex
    if limit > functionBodyKinds.len:
        limit = functionBodyKinds.len
    for i in startIndex..<limit:
        if !PrimaryFillOneFunction(words,
                                    functionWordOffsets,
                                    functionWordCounts,
                                    functionBodyKinds,
                                    functionBodyIRs,
                                    i):
            ok = false
            failedIndex = i
    return ok

fn PrimaryFillInstructionWordsChunked(words: var int32[],
                                       functionWordOffsets: int32[],
                                       functionWordCounts: int32[],
                                       functionBodyKinds: str[],
                                       functionBodyIRs: coreir.BodyIR[],
                                       chunkCount: int32,
                                       failedIndex: var int32): bool =
    if chunkCount <= 1 || functionBodyKinds.len <= 1:
        return PrimaryFillInstructionWords(words,
                                            functionWordOffsets,
                                            functionWordCounts,
                                            functionBodyKinds,
                                            functionBodyIRs,
                                            failedIndex)
    var ok = true
    failedIndex = -1
    var chunkSize = functionBodyKinds.len / chunkCount
    if chunkSize <= 0:
        chunkSize = 1
    for chunkIndex in 0..<chunkCount:
        let startIndex = chunkIndex * chunkSize
        var endIndex = startIndex + chunkSize
        if chunkIndex == chunkCount - 1:
            endIndex = functionBodyKinds.len
        var chunkFailedIndex: int32
        chunkFailedIndex = -1
        if !PrimaryFillFunctionChunk(words,
                                      functionWordOffsets,
                                      functionWordCounts,
                                      functionBodyKinds,
                                      functionBodyIRs,
                                      startIndex,
                                      endIndex,
                                      chunkFailedIndex):
            ok = false
            if failedIndex < 0:
                failedIndex = chunkFailedIndex
    return ok

# -- Parallel fill: workers fill disjoint word ranges concurrently --

type
    PrimaryFillWorkerCtx = ref
        words: int32[]
        functionWordOffsets: int32[]
        functionWordCounts: int32[]
        functionBodyKinds: str[]
        functionBodyIRs: coreir.BodyIR[]
        startIndex: int32
        endIndex: int32
        ok: bool
        failedIndex: int32
        workerId: int32
        completedCount: atomic.I32
        errorCount: atomic.I32

fn PrimaryFillWorkerMain(ctx: ptr) =
    let w: PrimaryFillWorkerCtx = PrimaryFillWorkerCtx(ctx)
    var failedIndex: int32
    failedIndex = -1
    let chunkOk = PrimaryFillFunctionChunk(w.words,
                                            w.functionWordOffsets,
                                            w.functionWordCounts,
                                            w.functionBodyKinds,
                                            w.functionBodyIRs,
                                            w.startIndex,
                                            w.endIndex,
                                            failedIndex)
    w.ok = chunkOk
    if !chunkOk:
        if failedIndex < 0:
            failedIndex = w.startIndex
        w.failedIndex = failedIndex
        if w.errorCount != nil:
            let _ = atomic.AddI32(w.errorCount, 1)
    if w.completedCount != nil:
        let _ = atomic.AddI32(w.completedCount, 1)
    memRelease(w)

fn PrimaryFillInstructionWordsParallel(words: var int32[],
                                        functionWordOffsets: int32[],
                                        functionWordCounts: int32[],
                                        functionBodyKinds: str[],
                                        functionBodyIRs: coreir.BodyIR[],
                                        jobCount: int32,
                                        failedIndex: var int32): bool =
    if jobCount <= 1:
        return PrimaryFillInstructionWords(words,
                                            functionWordOffsets,
                                            functionWordCounts,
                                            functionBodyKinds,
                                            functionBodyIRs,
                                            failedIndex)
    let totalFunctions = functionBodyKinds.len
    if totalFunctions <= 0:
        failedIndex = -1
        return true
    let workerCount = jobCount
    let completedCount = atomic.NewI32(0)
    let errorCount = atomic.NewI32(0)
    if completedCount == nil || errorCount == nil:
        failedIndex = 0
        return false
    failedIndex = -1
    var ctxs: PrimaryFillWorkerCtx[]
    for workerId in 0..<workerCount:
        let start = (totalFunctions * workerId) / workerCount
        let finish = (totalFunctions * (workerId + 1)) / workerCount
        if start >= finish:
            continue
        let ctx = new(PrimaryFillWorkerCtx)
        if ctx == nil:
            failedIndex = start
            return false
        ctx.words = words
        ctx.functionWordOffsets = functionWordOffsets
        ctx.functionWordCounts = functionWordCounts
        ctx.functionBodyKinds = functionBodyKinds
        ctx.functionBodyIRs = functionBodyIRs
        ctx.startIndex = start
        ctx.endIndex = finish
        ctx.ok = true
        ctx.failedIndex = -1
        ctx.workerId = workerId
        ctx.completedCount = completedCount
        ctx.errorCount = errorCount
        add(ctxs, ctx)
    for ci in 0..<ctxs.len:
        memRetain(ctxs[ci])
        async.SpawnPtr(PrimaryFillWorkerMain, ctxs[ci])
    while atomic.LoadI32(completedCount) < ctxs.len:
        thread.Yield()
    let errors = atomic.LoadI32(errorCount)
    if errors > 0:
        for ci in 0..<ctxs.len:
            if !ctxs[ci].ok && failedIndex < 0:
                failedIndex = ctxs[ci].failedIndex
        if failedIndex < 0:
            failedIndex = 0
        return false
    return true


fn PrimaryBodyIrWordCount(bodyIR: coreir.BodyIR): int32 =
    return PrimaryBodyIrGeneralCfgWordCount(bodyIR)

fn PrimaryBodyIrIsEmissionSupported(bodyIR: coreir.BodyIR): bool =
    return bodyIR.ops.len > 0 || bodyIR.terms.len > 0

fn PrimaryBodyIrIsCallCfgReturnInt32(bodyIR: coreir.BodyIR): int32 =
    if bodyIR.callSequence.len <= 0:
        return 0
    if bodyIR.ops.len <= 0:
        return 0
    let lastIndex = bodyIR.ops.len - 1
    if bodyIR.ops[lastIndex].kind != coreir.BodyOpReturnTag:
        return 0
    return PrimaryBodyIrWordCount(bodyIR)

fn PrimaryBodyIrCallCfgReturnInt32WordCount(bodyIR: coreir.BodyIR): int32 =
    return PrimaryBodyIrIsCallCfgReturnInt32(bodyIR)

fn PrimaryBodyIrRequiresCallSequence(bodyIR: coreir.BodyIR): bool =
    return bodyIR.callSequence.len > 0

fn PrimaryBodyIrProjectOpSupported(bodyIR: coreir.BodyIR,
                                     op: coreir.BodyOp): bool =
    let _ = bodyIR
    return op.kind == coreir.BodyOpResultProjectTag &&
           op.operands.len >= 1

fn PrimaryBodyIrIsCallSequenceReturnSupported(bodyIR: coreir.BodyIR): bool =
    return PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR)

fn PrimaryBodyIrIsCallSequenceReturnI32Const(bodyIR: coreir.BodyIR): bool =
    if !PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR):
        return false
    let lastIndex = bodyIR.ops.len - 1
    let lastOp = bodyIR.ops[lastIndex]
    return lastOp.operands.len >= 2 &&
           lastOp.operands[0] == PrimaryStatementReturnModeI32Const()

fn PrimaryBodyIrIsCallSequenceGuardReturnInt32(bodyIR: coreir.BodyIR): bool =
    if !PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR):
        return false
    return bodyIR.ops.len >= 2 &&
           bodyIR.ops[0].kind == coreir.BodyOpCallTag

fn PrimaryBodyIrLoadConstOpSupported(bodyIR: coreir.BodyIR,
                                       op: coreir.BodyOp): bool =
    let _ = bodyIR
    return op.kind == coreir.BodyOpLoadConstTag &&
           op.operands.len >= 2 &&
           op.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrLocalCopyOpSupported(bodyIR: coreir.BodyIR,
                                       op: coreir.BodyOp): bool =
    let _ = bodyIR
    return op.kind == coreir.BodyOpCopyLocalTag &&
           op.operands.len >= 1

fn PrimaryBodyIrRelocWordOffset(bodyIR: coreir.BodyIR,
                                  itemId: int32,
                                  callOrdinal: int32): int32 =
    let _ = itemId
    if callOrdinal < 0:
        return -1
    var seenCall: int32
    for bi in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[bi]
        if block.opStart < 0 || block.opCount < 0:
            return -1
        var wordPos = PrimaryBodyIRBlockStart(bodyIR, bi)
        let opEnd = block.opStart + block.opCount
        if opEnd > bodyIR.ops.len:
            return -1
        for oi in block.opStart..<opEnd:
            let op = bodyIR.ops[oi]
            if op.kind == coreir.BodyOpCallTag:
                if seenCall == callOrdinal:
                    return wordPos + PrimaryBodyIRCallBlRelOffset(bodyIR, op)
                seenCall = seenCall + 1
            wordPos = wordPos + PrimaryBodyIROpSizeAt(bodyIR, oi)
    return -1

fn PrimaryBodyIrGeneralCfgRelocWordOffset(bodyIR: coreir.BodyIR,
                                            itemId: int32,
                                            callOrdinal: int32): int32 =
    return PrimaryBodyIrRelocWordOffset(bodyIR, itemId, callOrdinal)

fn PrimaryBodyIrAppendCStringDataLabels(bodyIR: coreir.BodyIR,
                                         functionSymbol: str,
                                         dataLabels: var str[],
                                         dataPayloadTexts: var str[],
                                         dataPayloadRawBytes: var int32[],
                                         dataPayloadRawByteCounts: var int32[]) =
    for literalIndex in 0..<bodyIR.cstringLiterals.len:
        add(dataLabels, PrimaryCStringLiteralDataLabel(functionSymbol, literalIndex))
        add(dataPayloadTexts, "-")
        let text = bodyIR.cstringLiterals[literalIndex].text
        var rawStart = dataPayloadRawBytes.len
        var byteCount: int32
        for ci in 0..<len(text):
            add(dataPayloadRawBytes, int32(text[ci]))
            byteCount = byteCount + 1
        add(dataPayloadRawBytes, 0)
        byteCount = byteCount + 1
        add(dataPayloadRawByteCounts, byteCount)

fn PrimaryObjectDataLabelIndex(dataLabels: str[],
                                label: str): int32 =
    for i in 0..<dataLabels.len:
        if dataLabels[i] == label:
            return i
    return -1

fn PrimaryGlobalDataLabel(targetTriple: str,
                           globalSlotName: str): str =
    return PrimaryTargetSymbolName(targetTriple,
                                   Fmt"cheng_global_{PrimarySanitizeSymbolPart(globalSlotName)}")

fn PrimaryBodyIrAppendGlobalDataLabels(bodyIR: coreir.BodyIR,
                                        targetTriple: str,
                                        dataLabels: var str[],
                                        dataPayloadTexts: var str[],
                                        dataPayloadRawByteCounts: var int32[]) =
    for slotIndex in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[slotIndex]
        if slot.placeKind != coreir.BodyPlaceGlobalAddressTag:
            continue
        if PrimaryBodyIrFunctionAddressSlotIndex(slot.name) >= 0:
            continue
        let label = PrimaryGlobalDataLabel(targetTriple, slot.name)
        if PrimaryObjectDataLabelIndex(dataLabels, label) >= 0:
            continue
        add(dataLabels, label)
        add(dataPayloadRawByteCounts, 0)
        if slot.sizeBytes > 0:
            add(dataPayloadTexts, Fmt"zero:{slot.sizeBytes}")
        else:
            add(dataPayloadTexts, "zero:8")

fn PrimaryBodyIrAppendCallCStringArgRelocs(bodyIR: coreir.BodyIR,
                                            call: coreir.CallOp,
                                            itemId: int32,
                                            targetTriple: str,
                                            functionSymbol: str,
                                            allSymbolNames: str[],
                                            callWordStart: int32,
                                            sourceItemIds: var int32[],
                                            wordOffsets: var int32[],
                                            targetSymbols: var str[]) =
    var pos = callWordStart
    if PrimaryCallOpStackArgBytes(call) > 0:
        pos = pos + 1
    let registerArgCount = PrimaryCallOpRegisterArgCount(call)
    for argIndex in 0..<registerArgCount:
        let argSlot = call.argSlots[argIndex]
        let passKind = PrimaryCallOpArgPassKind(call, argIndex)
        if coreir.CallArgSlotIsCString(argSlot):
            let literalId = coreir.CallArgSlotCStringId(argSlot)
            if literalId >= 0 && literalId < bodyIR.cstringLiterals.len:
                add(sourceItemIds, itemId)
                add(wordOffsets, pos)
                add(targetSymbols, PrimaryCStringLiteralDataLabel(functionSymbol, literalId))
        elif passKind == coreir.BodyCallPassGlobalAddressTag:
            if argSlot >= 0 &&
               argSlot < bodyIR.localSlots.len &&
               bodyIR.localSlots[argSlot].placeKind == coreir.BodyPlaceGlobalAddressTag:
                var targetSymbol = PrimaryGlobalDataLabel(targetTriple, bodyIR.localSlots[argSlot].name)
                let functionIndex = PrimaryBodyIrFunctionAddressSlotIndex(bodyIR.localSlots[argSlot].name)
                if functionIndex >= 0 && functionIndex < allSymbolNames.len:
                    targetSymbol = allSymbolNames[functionIndex]
                add(sourceItemIds, itemId)
                add(wordOffsets, pos)
                add(targetSymbols, targetSymbol)
        let argWords = PrimaryBodyIrCallArgWordCount(bodyIR, argSlot, passKind)
        if argWords <= 0:
            return
        pos = pos + argWords
    let stackArgCount = PrimaryCallOpStackArgCount(call)
    for stackArgIndex in 0..<stackArgCount:
        let argIndex = stackArgIndex + 8
        let argSlot = call.argSlots[argIndex]
        let passKind = PrimaryCallOpArgPassKind(call, argIndex)
        if coreir.CallArgSlotIsCString(argSlot):
            let literalId = coreir.CallArgSlotCStringId(argSlot)
            if literalId >= 0 && literalId < bodyIR.cstringLiterals.len:
                add(sourceItemIds, itemId)
                add(wordOffsets, pos)
                add(targetSymbols, PrimaryCStringLiteralDataLabel(functionSymbol, literalId))
        elif passKind == coreir.BodyCallPassGlobalAddressTag:
            if argSlot >= 0 &&
               argSlot < bodyIR.localSlots.len &&
               bodyIR.localSlots[argSlot].placeKind == coreir.BodyPlaceGlobalAddressTag:
                var targetSymbol = PrimaryGlobalDataLabel(targetTriple, bodyIR.localSlots[argSlot].name)
                let functionIndex = PrimaryBodyIrFunctionAddressSlotIndex(bodyIR.localSlots[argSlot].name)
                if functionIndex >= 0 && functionIndex < allSymbolNames.len:
                    targetSymbol = allSymbolNames[functionIndex]
                add(sourceItemIds, itemId)
                add(wordOffsets, pos)
                add(targetSymbols, targetSymbol)
        let argWords = PrimaryBodyIrCallArgWordCount(bodyIR, argSlot, passKind)
        if argWords <= 0:
            return
        pos = pos + argWords + 1

fn PrimaryBodyIrAppendCStringArgRelocs(bodyIR: coreir.BodyIR,
                                        itemId: int32,
                                        functionWordOffset: int32,
                                        targetTriple: str,
                                        functionSymbol: str,
                                        allSymbolNames: str[],
                                        sourceItemIds: var int32[],
                                        wordOffsets: var int32[],
                                        targetSymbols: var str[]) =
    for bi in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[bi]
        var wordPos = functionWordOffset + PrimaryBodyIRBlockStart(bodyIR, bi)
        let opEnd = block.opStart + block.opCount
        if block.opStart < 0 || opEnd > bodyIR.ops.len:
            return
        for oi in block.opStart..<opEnd:
            let op = bodyIR.ops[oi]
            if op.kind == coreir.BodyOpCallTag && op.operands.len > 0:
                let callOrdinal = op.operands[0]
                if callOrdinal >= 0 && callOrdinal < bodyIR.callSequence.len:
                    PrimaryBodyIrAppendCallCStringArgRelocs(bodyIR,
                                                            bodyIR.callSequence[callOrdinal],
                                                            itemId,
                                                            targetTriple,
                                                            functionSymbol,
                                                            allSymbolNames,
                                                            wordPos,
                                                            sourceItemIds,
                                                            wordOffsets,
                                                            targetSymbols)
            let opSize = PrimaryBodyIROpSizeAt(bodyIR, oi)
            if opSize <= 0:
                return
            wordPos = wordPos + opSize

fn PrimaryBodyCondArm64TrueCode(condTag: int32): int32 =
    if condTag == coreir.BodyCondI32EqTag:
        return 0
    if condTag == coreir.BodyCondI32NeTag:
        return 1
    if condTag == coreir.BodyCondI32LtTag:
        return 11
    if condTag == coreir.BodyCondI32LeTag:
        return 13
    if condTag == coreir.BodyCondI32GtTag:
        return 12
    if condTag == coreir.BodyCondI32GeTag:
        return 10
    if condTag == coreir.BodyCondLocalNonZeroTag:
        return 1
    if condTag == coreir.BodyCondLocalZeroTag:
        return 0
    return 1

fn PrimaryArm64CondBranchWord(fromWord: int32, toWord: int32, condCode: int32): int32 =
    let offset = toWord - fromWord
    return 0x54000000 + (offset << 5) + condCode

fn PrimaryBodyIRBlockStart(bodyIR: coreir.BodyIR, blockIndex: int32): int32 =
    let prologueSize = PrimaryBodyIrPrologueWordCount(bodyIR)
    let blockStart = prologueSize
    let bi = 0
    return PrimaryBodyIRBlockStartHelper(bodyIR, blockIndex, bi, blockStart)

fn PrimaryBodyIRBlockStartHelper(bodyIR: coreir.BodyIR, targetIndex: int32, bi: int32, pos: int32): int32 =
    if bi >= targetIndex || bi >= bodyIR.blocks.len:
        return pos
    let blockSize = PrimaryBodyIRBlockSize(bodyIR, bi)
    return PrimaryBodyIRBlockStartHelper(bodyIR, targetIndex, bi + 1, pos + blockSize)

fn PrimaryBodyIRBlockSize(bodyIR: coreir.BodyIR, blockIndex: int32): int32 =
    if blockIndex < 0 || blockIndex >= bodyIR.blocks.len:
        return 0
    let block = bodyIR.blocks[blockIndex]
    let opStart = block.opStart
    let opEnd = block.opStart + block.opCount
    let opSize = PrimaryBodyIROpRangeSize(bodyIR, opStart, opEnd)
    let termIndex = block.termIndex
    let termSize = PrimaryBodyIRTermSize(bodyIR, termIndex)
    return opSize + termSize

fn PrimaryBodyIRBlockStartOrNext(bodyIR: coreir.BodyIR,
                                  blockIndex: int32,
                                  nextWord: int32): int32 =
    if blockIndex >= 0:
        if blockIndex < bodyIR.blocks.len:
            return PrimaryBodyIRBlockStart(bodyIR, blockIndex)
    return nextWord

fn PrimaryBodyIROpRangeSize(bodyIR: coreir.BodyIR, opStart: int32, opEnd: int32): int32 =
    if opStart >= opEnd || opStart >= bodyIR.ops.len:
        return 0
    let firstSize = PrimaryBodyIROpSizeAt(bodyIR, opStart)
    return firstSize + PrimaryBodyIROpRangeSize(bodyIR, opStart + 1, opEnd)

fn PrimaryBodyIRCallHasIndirectResult(bodyIR: coreir.BodyIR,
                                       call: coreir.CallOp): bool =
    if call.resultSlot < 0 || call.resultSlot >= bodyIR.localSlots.len:
        return false
    let resultType = bodyIR.localSlots[call.resultSlot].typeKind
    return resultType == coreir.LocalStrTag ||
           resultType == coreir.LocalAggregateTag

fn PrimaryBodyIRCallStoresScalarResult(bodyIR: coreir.BodyIR,
                                        call: coreir.CallOp): bool =
    if call.resultSlot < 0 || call.resultSlot >= bodyIR.localSlots.len:
        return false
    let resultType = bodyIR.localSlots[call.resultSlot].typeKind
    return resultType == coreir.LocalI32Tag ||
           resultType == coreir.LocalI64Tag ||
           resultType == coreir.LocalPtrTag

fn PrimaryBodyIRCallBlRelOffset(bodyIR: coreir.BodyIR,
                                 op: coreir.BodyOp): int32 =
    if op.kind != coreir.BodyOpCallTag || op.operands.len <= 0:
        return -1
    let callOrdinal = op.operands[0]
    if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
        return -1
    let call = bodyIR.callSequence[callOrdinal]
    var offset: int32
    if PrimaryCallOpStackArgBytes(call) > 0:
        offset = offset + 1
    let registerArgCount = PrimaryCallOpRegisterArgCount(call)
    for argIndex in 0..<registerArgCount:
        let argWords = PrimaryBodyIrCallArgWordCount(bodyIR,
                                                     call.argSlots[argIndex],
                                                     PrimaryCallOpArgPassKind(call, argIndex))
        if argWords <= 0:
            return -1
        offset = offset + argWords
    let stackArgCount = PrimaryCallOpStackArgCount(call)
    for stackArgIndex in 0..<stackArgCount:
        let argIndex = stackArgIndex + 8
        let argWords = PrimaryBodyIrCallArgWordCount(bodyIR,
                                                     call.argSlots[argIndex],
                                                     PrimaryCallOpArgPassKind(call, argIndex))
        if argWords <= 0:
            return -1
        offset = offset + argWords + 1
    if PrimaryBodyIRCallHasIndirectResult(bodyIR, call):
        let resultOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                        call.resultSlot,
                                                        PrimaryBodyIrFrameBytes(bodyIR),
                                                        PrimaryBodyIrParamSaveOffset(bodyIR),
                                                        PrimaryBodyIrParamSaveCount(bodyIR))
        let resultAddressWords = PrimaryBodyIrStackAddressWordCount(resultOffset)
        if resultAddressWords <= 0:
            return -1
        offset = offset + resultAddressWords
    return offset

fn PrimaryBodyIRCallWordCount(bodyIR: coreir.BodyIR,
                               op: coreir.BodyOp): int32 =
    let blOffset = PrimaryBodyIRCallBlRelOffset(bodyIR, op)
    if blOffset < 0:
        return 0
    let call = bodyIR.callSequence[op.operands[0]]
    var count = blOffset + 1
    if PrimaryCallOpStackArgBytes(call) > 0:
        count = count + 1
    if PrimaryBodyIRCallStoresScalarResult(bodyIR, call):
        count = count + 1
    return count

fn PrimaryBodyIROpSizeAt(bodyIR: coreir.BodyIR,
                          opIndex: int32): int32 =
    if opIndex < 0 || opIndex >= bodyIR.ops.len:
        return 0
    let op = bodyIR.ops[opIndex]
    if op.kind == coreir.BodyOpInvalidTag:
        return 0
    if op.kind == coreir.BodyOpCallTag:
        return PrimaryBodyIRCallWordCount(bodyIR, op)
    if op.kind == coreir.BodyOpReturnTag:
        return 1
    if op.kind == coreir.BodyOpLoadConstTag:
        if op.operands.len >= 2:
            if op.operands[0] == coreir.LocalI32Tag ||
               op.operands[0] == coreir.LocalI64Tag ||
               op.operands[0] == coreir.LocalPtrTag:
                return 2
        return 0
    if op.kind == coreir.BodyOpCopyLocalTag ||
       op.kind == coreir.BodyOpStoreLocalTag:
        if op.operands.len < 1 || op.target < 0 || op.target >= bodyIR.localSlots.len ||
           op.operands[0] < 0 || op.operands[0] >= bodyIR.localSlots.len:
            return 0
        let slotSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[op.target])
        if slotSize <= 0 || slotSize % 8 != 0:
            if slotSize == 4:
                return 2
            return 0
        return (slotSize / 8) * 2
    if op.kind == coreir.BodyOpResultProjectTag:
        if op.operands.len < 2:
            return 0
        if op.operands[0] == coreir.BodyResultProjectIsErrTag:
            return 6
        if op.operands[0] == coreir.BodyResultProjectValueStrTag ||
           op.operands[0] == coreir.BodyResultProjectErrorStrTag:
            if op.operands.len >= 4:
                return PrimaryBodyIRCopyMemoryWordCount(op.operands[3])
            return 6
        return 0
    if op.kind == coreir.BodyOpBinOpTag:
        if op.operands.len < 4:
            return 0
        if op.operands[1] == int32(texpr.TypedExprIrOpI32Madd):
            if op.operands.len < 5:
                return 0
            return 5
        return 4
    if op.kind == coreir.BodyOpCmpTag:
        if op.operands.len < 3:
            return 0
        return 5
    if op.kind == coreir.BodyOpStrEqLiteralTag:
        return PrimaryBodyIRStrEqLiteralWordCount(bodyIR, op)
    if op.kind == coreir.BodyOpGlobalLoadTag ||
       op.kind == coreir.BodyOpGlobalStoreTag:
        if op.operands.len < 1 ||
           op.operands[0] < 0 ||
           op.operands[0] >= bodyIR.localSlots.len:
            return 0
        if op.target < 0 || op.target >= bodyIR.localSlots.len:
            return 0
        let globalType = bodyIR.localSlots[op.operands[0]].typeKind
        if globalType != coreir.LocalI32Tag &&
           globalType != coreir.LocalI64Tag &&
           globalType != coreir.LocalPtrTag:
            return 0
        if bodyIR.localSlots[op.target].typeKind != globalType:
            return 0
        return 4
    if op.kind == coreir.BodyOpIndexedLoadTag ||
       op.kind == coreir.BodyOpIndexedStoreTag:
        if op.operands.len < 2:
            return 0
        return 3
    if op.kind == coreir.BodyOpFieldLoadTag ||
       op.kind == coreir.BodyOpFieldStoreTag:
        if op.operands.len < 3:
            return 0
        let baseSlot = op.operands[0]
        let valueSlot = op.operands[1]
        let byteOffset = op.operands[2]
        var byteCount = 0
        if op.operands.len >= 4:
            byteCount = op.operands[3]
        if baseSlot < 0 || baseSlot >= bodyIR.localSlots.len ||
           valueSlot < 0 || valueSlot >= bodyIR.localSlots.len ||
           byteOffset < 0:
            return 0
        if byteCount <= 0:
            byteCount = 8
        let slotSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[valueSlot])
        if slotSize > 0 && slotSize < byteCount:
            return 0
        if op.kind == coreir.BodyOpFieldLoadTag && op.target != valueSlot:
            return 0
        if op.kind == coreir.BodyOpFieldStoreTag && op.target != baseSlot:
            return 0
        let frameBytes = PrimaryBodyIrFrameBytes(bodyIR)
        let paramSaveOffset = PrimaryBodyIrParamSaveOffset(bodyIR)
        let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
        var accessOffset = byteOffset
        var count: int32
        if bodyIR.localSlots[baseSlot].typeKind == coreir.LocalPtrTag:
            count = count + 1
        else:
            let baseOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                           baseSlot,
                                                           frameBytes,
                                                           paramSaveOffset,
                                                           paramSaveCount)
            if baseOffset < 0:
                accessOffset = byteOffset
                count = count + 1
            else:
                let baseSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[baseSlot])
                if baseSize > 0 && byteOffset > baseSize - byteCount:
                    return 0
                accessOffset = baseOffset + byteOffset
        let valueOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                        valueSlot,
                                                        frameBytes,
                                                        paramSaveOffset,
                                                        paramSaveCount)
        if valueOffset < 0:
            var extra2 = byteCount / 8
            if byteCount % 8 > 0:
                extra2 = extra2 + 1
            return count + extra2 * 2
        if byteCount % 8 == 0 &&
           accessOffset % 8 == 0 &&
           valueOffset % 8 == 0:
            return count + (byteCount / 8) * 2
        if byteCount % 4 == 0 &&
           accessOffset % 4 == 0 &&
           valueOffset % 4 == 0:
            return count + (byteCount / 4) * 2
        var extra = byteCount / 8
        if byteCount % 8 > 0:
            extra = extra + 1
        return count + extra * 2
    if op.kind == coreir.BodyOpLoadLocalTag:
        if op.operands.len >= 3 &&
           (op.operands[0] == coreir.BodyLoadLocalPtrDerefI32Tag ||
            op.operands[0] == coreir.BodyLoadLocalPtrDerefU8Tag):
            if op.operands.len < 2 || op.target < 0 || op.target >= bodyIR.localSlots.len:
                return 0
            return 3
        if op.operands.len >= 1:
            if op.operands[0] < 0 || op.operands[0] >= bodyIR.localSlots.len ||
               op.target < 0 || op.target >= bodyIR.localSlots.len:
                return 0
            let slotSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[op.target])
            if slotSize <= 0 || slotSize % 8 != 0:
                if slotSize == 4:
                    return 2
                return 0
            return (slotSize / 8) * 2
        return 0
    if op.kind == coreir.BodyOpBranchTag:
        if op.operands.len >= 3:
            let subKind = op.operands[0]
            let guardSlot = op.operands[1]
            if guardSlot < 0 || guardSlot >= bodyIR.localSlots.len:
                return 0
            let guardWords = PrimaryBodyIrLoadSlotWordCount(bodyIR, guardSlot)
            if guardWords <= 0:
                return 0
            let restoreCount = PrimaryBodyIrFrameRestoreWordCount(bodyIR)
            if subKind == coreir.BodyBranchIfLocalNilReturnI32ConstTag:
                return guardWords + 2 + restoreCount
            if subKind == coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag ||
               subKind == coreir.BodyBranchIfLocalLeZeroReturnCallNoargTag:
                return guardWords + 3 + restoreCount
            if subKind == coreir.BodyBranchIfLocalLeZeroCallArg0ReturnI32ConstTag:
                if op.operands.len < 4:
                    return 0
                let arg0Slot = op.operands[2]
                if arg0Slot < 0 || arg0Slot >= bodyIR.localSlots.len:
                    return 0
                let argWords = PrimaryBodyIrLoadSlotWordCount(bodyIR, arg0Slot)
                if argWords <= 0:
                    return 0
                return guardWords + argWords + 4 + restoreCount
        return 0
    if op.kind == coreir.BodyOpStrEqTag:
        if op.operands.len >= 2:
            return 32
        return 0
    return 0

fn PrimaryBodyIROpSize(op: coreir.BodyOp): int32 =
    if op.kind == coreir.BodyOpCallTag:
        return 5
    if op.kind == coreir.BodyOpReturnTag:
        return 1
    return 1

fn PrimaryBodyIRTermSize(bodyIR: coreir.BodyIR, termIndex: int32): int32 =
    if termIndex < 0 || termIndex >= bodyIR.terms.len:
        return 0
    let kind = bodyIR.terms[termIndex].kind
    if kind == coreir.BodyTermCbrTag:
        let term = bodyIR.terms[termIndex]
        if term.rhsSlot >= 0:
            return 5
        return 4
    if kind == coreir.BodyTermBrTag:
        return 1
    if kind == coreir.BodyTermReturnTag:
        let term = bodyIR.terms[termIndex]
        let restoreCount = PrimaryBodyIrFrameRestoreWordCount(bodyIR)
        if term.resultSlot < 0 &&
           term.operands.len >= 1 &&
           term.operands[0] == coreir.LocalInvalidTag:
            return restoreCount
        if term.resultSlot >= 0 && term.resultSlot < bodyIR.localSlots.len:
            let resultType = bodyIR.localSlots[term.resultSlot].typeKind
            if resultType == coreir.LocalStrTag ||
               resultType == coreir.LocalAggregateTag:
                return 7 + restoreCount
            let loadWords = PrimaryBodyIrLoadSlotWordCount(bodyIR, term.resultSlot)
            if loadWords <= 0:
                return 0
            return loadWords + restoreCount
        return 1 + restoreCount
    return 0

fn PrimaryBodyIREmitWord(bodyIR: coreir.BodyIR, wordOffset: int32): int32 =
    if wordOffset < 0 || wordOffset >= PrimaryBodyIrWordCount(bodyIR):
        return a64.A64EncRet()
    let prologueCount = PrimaryBodyIrPrologueWordCount(bodyIR)
    if wordOffset < prologueCount:
        return PrimaryBodyIREmitPrologueWord(wordOffset)
    return PrimaryBodyIREmitBlockWord(bodyIR, wordOffset - prologueCount, 0)

fn PrimaryBodyIREmitPrologueWord(index: int32): int32 =
    if index == 0:
        return Value(a64.A64EncSubImm(true, a64.A64SP, a64.A64SP, 32))
    if index == 1:
        return Value(a64.A64EncStp64(a64.A64FP, a64.A64LR, a64.A64SP, int64(0)))
    if index == 2:
        return Value(a64.A64EncAddImm(true, a64.A64FP, a64.A64SP, 0))
    return 0

fn PrimaryBodyIREmitBlockWord(bodyIR: coreir.BodyIR, relOffset: int32, blockIndex: int32): int32 =
    if blockIndex >= bodyIR.blocks.len:
        return a64.A64EncRet()
    let blockSize = PrimaryBodyIRBlockSize(bodyIR, blockIndex)
    if relOffset < blockSize:
        let block = bodyIR.blocks[blockIndex]
        let opEnd = block.opStart + block.opCount
        let opSize = PrimaryBodyIROpRangeSize(bodyIR, block.opStart, opEnd)
        if relOffset < opSize:
            return PrimaryBodyIREmitOpWord(bodyIR, relOffset, block.opStart, opEnd)
        let termRelOffset = relOffset - opSize
        let termIndex = block.termIndex
        if termIndex >= 0 && termIndex < bodyIR.terms.len:
            return PrimaryBodyIREmitTermWord(bodyIR.terms[termIndex], termRelOffset)
        return a64.A64EncRet()
    return PrimaryBodyIREmitBlockWord(bodyIR, relOffset - blockSize, blockIndex + 1)

fn PrimaryBodyIREmitOpWord(bodyIR: coreir.BodyIR, relOffset: int32, opStart: int32, opEnd: int32): int32 =
    if opStart >= opEnd || opStart >= bodyIR.ops.len:
        return a64.A64EncRet()
    let op = bodyIR.ops[opStart]
    let opSize = PrimaryBodyIROpSize(op)
    if relOffset < opSize:
        return PrimaryBodyIREmitOpInstruction(op, relOffset)
    return PrimaryBodyIREmitOpWord(bodyIR, relOffset - opSize, opStart + 1, opEnd)

fn PrimaryBodyIREmitOpInstruction(op: coreir.BodyOp, relOffset: int32): int32 =
    if op.kind == coreir.BodyOpCallTag:
        if relOffset == 0:
            return a64.A64EncMovz(false, 0, 0, 0)
        if relOffset == 1:
            return a64.A64EncMovz(false, 0, 0, 0)
        if relOffset == 2:
            return a64.A64EncMovz(false, 0, 0, 0)
        if relOffset == 3:
            return a64.A64EncBlPlaceholder()
        return 0
    if op.kind == coreir.BodyOpReturnTag:
        if relOffset == 0:
            if op.operands.len >= 1 && op.operands[0] == PrimaryStatementReturnModeI32Const():
                if op.operands.len >= 2:
                    return a64.A64EncMovz(false, 0, op.operands[1] & 65535, 0)
            return a64.A64EncMovz(false, 0, 0, 0)
        return a64.A64EncRet()
    if op.kind == coreir.BodyOpLoadConstTag:
        if op.operands.len >= 2 && op.operands[0] == coreir.LocalI32Tag:
            return a64.A64EncMovz(false, 0, op.operands[1] & 65535, 0)
        return a64.A64EncMovz(false, 0, 0, 0)
    return a64.A64EncRet()

fn PrimaryBodyIREmitTermWord(term: coreir.BodyTerm, relOffset: int32): int32 =
    if term.kind == coreir.BodyTermCbrTag:
        if relOffset == 0:
            return a64.A64EncMovz(false, 0, 0, 0)
        return 0
    if term.kind == coreir.BodyTermBrTag:
        if relOffset == 0:
            return a64.A64EncBPlaceholder()
        return 0
    return a64.A64EncRet()

fn PrimaryObjectPlanEmitBodyIRAt(bodyIR: coreir.BodyIR,
                                   words: var int32[],
                                   wordOffset: int32,
                                   emitted: var int32) =
    let totalWords = PrimaryBodyIrWordCount(bodyIR)
    emitted = PrimaryBodyIRFillWords(words, wordOffset, totalWords, bodyIR)

fn PrimaryBodyIREmitBodyIRWords(bodyIR: coreir.BodyIR, words: var int32[], wordOffset: int32, wi: int32, totalWords: int32) =
    if wi >= totalWords:
        return
    let word = PrimaryBodyIREmitWord(bodyIR, wi)
    words[wordOffset + wi] = word
    PrimaryBodyIREmitBodyIRWords(bodyIR, words, wordOffset, wi + 1, totalWords)

fn PrimaryBodyIrStatementReturnMode(bodyIR: coreir.BodyIR): int32 =
    if bodyIR.ops.len <= 0:
        return PrimaryStatementReturnModeNone()
    let lastOp = bodyIR.ops[bodyIR.ops.len - 1]
    if lastOp.kind != coreir.BodyOpReturnTag:
        return PrimaryStatementReturnModeNone()
    if lastOp.operands.len <= 0:
        return PrimaryStatementReturnModeNone()
    return lastOp.operands[0]

fn PrimaryBodyIrStackByteCount(bodyIR: coreir.BodyIR): int32 =
    var maxSlot: int32
    for i in 0..<bodyIR.localSlots.len:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[i]):
            continue
        let slotEnd = bodyIR.localSlots[i].stackOffset + PrimaryLocalSlotSizeOf(bodyIR.localSlots[i])
        if slotEnd > maxSlot:
            maxSlot = slotEnd
    if maxSlot < 32:
        maxSlot = 32
    return ((maxSlot + 15) / 16) * 16

fn PrimaryBodyIrParamSaveCount(bodyIR: coreir.BodyIR): int32 =
    var count: int32
    for i in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[i]
        if !PrimaryBodyIrLocalIsParam(slot):
            continue
        let paramSlot = PrimaryBodyIrParamIndex(slot)
        if paramSlot >= 0 && paramSlot < 8 && paramSlot + 1 > count:
            count = paramSlot + 1
    return count

fn PrimaryAlignStackBytes(bytes: int32, align: int32): int32 =
    return ((bytes + align - 1) / align) * align

fn PrimaryBodyIrParamSaveOffset(bodyIR: coreir.BodyIR): int32 =
    return PrimaryBodyIrStackByteCount(bodyIR)

fn PrimaryBodyIrReturnBufferSaveOffset(bodyIR: coreir.BodyIR): int32 =
    return PrimaryBodyIrStackByteCount(bodyIR) + PrimaryBodyIrParamSaveCount(bodyIR) * 8

fn PrimaryBodyIrFrameBytes(bodyIR: coreir.BodyIR): int32 =
    let localBytes = PrimaryBodyIrStackByteCount(bodyIR)
    let paramBytes = PrimaryBodyIrParamSaveCount(bodyIR) * 8
    return PrimaryAlignStackBytes(localBytes + paramBytes + 8, 16)

fn PrimaryObjectMissingReasons(linkPlan: slplan.SystemLinkPlanStub,
                                 lowering: lower.LoweringPlanStub,
                                 itemIds: int32[],
                                 instructionWords: int32[],
                                 bodySemanticsMissing: bool): str[] =
    var missing: str[]
    if linkPlan.missingReasons.len > 0:
        add(missing, "system_link_plan_not_ready_for_primary_object")
    if lowering.missingReasons.len > 0:
        add(missing, "lowering_plan_not_ready_for_primary_object")
    if itemIds.len <= 0:
        add(missing, "primary_object_items_missing")
    if instructionWords.len <= 0:
        add(missing, "primary_object_machine_words_missing")
    if bodySemanticsMissing:
        add(missing, "primary_object_body_semantics_missing")
    if linkPlan.emitKind == creq.EmitExe && len(linkPlan.entrySymbol) <= 0:
        add(missing, "primary_object_entry_symbol_missing")
    return missing

fn PrimaryObjectTypedIrFieldCount(typedIr: texpr.TypedExprIr,
                                   ownerType: str,
                                   fieldName: str): int32 =
    var count: int32
    for i in 0..<typedIr.typeFieldOwnerTypes.len:
        if i >= typedIr.typeFieldNames.len:
            continue
        if typedIr.typeFieldOwnerTypes[i] == ownerType &&
           typedIr.typeFieldNames[i] == fieldName:
            count = count + 1
    return count

fn PrimaryObjectTypedIrTypeDefAliasCount(typedIr: texpr.TypedExprIr,
                                          aliasName: str,
                                          targetType: str): int32 =
    var count: int32
    for i in 0..<typedIr.typeDefAliasNames.len:
        if i >= typedIr.typeDefAliasTargetTypes.len:
            continue
        if typedIr.typeDefAliasNames[i] == aliasName &&
           typedIr.typeDefAliasTargetTypes[i] == targetType:
            count = count + 1
    return count

fn PrimaryObjectTypedIrFieldMetric(typedIr: texpr.TypedExprIr,
                                    ownerType: str,
                                    fieldName: str,
                                    metric: str): int32 =
    for i in 0..<typedIr.typeFieldOwnerTypes.len:
        if i >= typedIr.typeFieldNames.len:
            continue
        if typedIr.typeFieldOwnerTypes[i] != ownerType:
            continue
        if typedIr.typeFieldNames[i] != fieldName:
            continue
        if metric == "type" && i < typedIr.typeFieldTypes.len:
            return 1
        if metric == "offset" && i < typedIr.typeFieldOffsetBytes.len:
            return typedIr.typeFieldOffsetBytes[i]
        if metric == "size" && i < typedIr.typeFieldSizeBytes.len:
            return typedIr.typeFieldSizeBytes[i]
        if metric == "align" && i < typedIr.typeFieldAlignBytes.len:
            return typedIr.typeFieldAlignBytes[i]
        return -1
    return -1

fn PrimaryObjectTypedIrFieldTypeText(typedIr: texpr.TypedExprIr,
                                      ownerType: str,
                                      fieldName: str): str =
    for i in 0..<typedIr.typeFieldOwnerTypes.len:
        if i >= typedIr.typeFieldNames.len:
            continue
        if typedIr.typeFieldOwnerTypes[i] != ownerType:
            continue
        if typedIr.typeFieldNames[i] != fieldName:
            continue
        if i < typedIr.typeFieldTypes.len:
            return typedIr.typeFieldTypes[i]
        return ""
    return ""

fn PrimaryObjectMissingLineNumber(lowering: lower.LoweringPlanStub,
                                   irIndex: int32): int32 =
    if irIndex < 0 || irIndex >= lowering.primaryObjectIr.functions.len:
        return 0
    let irFunction = lowering.primaryObjectIr.functions[irIndex]
    if irFunction.bodyKind == texpr.BodyKindUnsupported &&
       irFunction.statements.len > 0:
        return irFunction.statements[0].lineNumber
    return irFunction.bodyLineNumber

fn PrimaryObjectPlanCaptureBodyIrOpDetail(detail: var PrimaryObjectErrorBodyIrDetail,
                                           bodyIR: coreir.BodyIR,
                                           opIndex: int32) =
    if opIndex < 0 || opIndex >= bodyIR.ops.len:
        return
    let op = bodyIR.ops[opIndex]
    detail.firstZeroOpIndex = opIndex
    detail.firstZeroOpKind = op.kind
    detail.firstZeroOpTarget = op.target
    if op.operands.len > 0:
        detail.firstZeroOpOperand0 = op.operands[0]
    if op.operands.len > 1:
        detail.firstZeroOpOperand1 = op.operands[1]
    if op.operands.len > 2:
        detail.firstZeroOpOperand2 = op.operands[2]
    if op.operands.len > 3:
        detail.firstZeroOpOperand3 = op.operands[3]
    if op.kind == coreir.BodyOpCallTag && op.operands.len > 0:
        let callOrdinal = op.operands[0]
        if callOrdinal >= 0 && callOrdinal < bodyIR.callSequence.len:
            detail.firstZeroCallTarget = bodyIR.callSequence[callOrdinal].targetSymbol
    if op.operands.len > 0:
        let baseSlot = op.operands[0]
        if baseSlot >= 0 && baseSlot < bodyIR.localSlots.len:
            let slot = bodyIR.localSlots[baseSlot]
            detail.firstZeroBaseSlotName = slot.name
            detail.firstZeroBaseSlotType = slot.typeKind
            detail.firstZeroBaseSlotSize = PrimaryLocalSlotSizeOf(slot)
            detail.firstZeroBaseSlotOffset = slot.stackOffset
    if op.operands.len > 1:
        let valueSlot = op.operands[1]
        if valueSlot >= 0 && valueSlot < bodyIR.localSlots.len:
            let slot = bodyIR.localSlots[valueSlot]
            detail.firstZeroValueSlotName = slot.name
            detail.firstZeroValueSlotType = slot.typeKind
            detail.firstZeroValueSlotSize = PrimaryLocalSlotSizeOf(slot)
            detail.firstZeroValueSlotOffset = slot.stackOffset

fn PrimaryObjectPlanCaptureBodyIrWordDetail(detail: var PrimaryObjectErrorBodyIrDetail,
                                             bodyIR: coreir.BodyIR,
                                             relWordOffset: int32) =
    detail.firstZeroBlockIndex = -1
    detail.firstZeroWordInnerOffset = -1
    if relWordOffset < 0:
        return
    let prologueCount = PrimaryBodyIrPrologueWordCount(bodyIR)
    if relWordOffset < prologueCount:
        detail.firstZeroOpIndex = -2
        detail.firstZeroOpKind = -2
        detail.firstZeroWordInnerOffset = relWordOffset
        return
    var cursor = prologueCount
    for bi in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[bi]
        var opStart = block.opStart
        if opStart < 0:
            opStart = 0
        var opEnd = block.opStart + block.opCount
        if opEnd > bodyIR.ops.len:
            opEnd = bodyIR.ops.len
        for oi in opStart..<opEnd:
            let opSize = PrimaryBodyIROpSizeAt(bodyIR, oi)
            if opSize <= 0:
                continue
            if relWordOffset >= cursor && relWordOffset < cursor + opSize:
                detail.firstZeroBlockIndex = bi
                detail.firstZeroWordInnerOffset = relWordOffset - cursor
                PrimaryObjectPlanCaptureBodyIrOpDetail(detail, bodyIR, oi)
                return
            cursor = cursor + opSize
        let termSize = PrimaryBodyIRTermSize(bodyIR, block.termIndex)
        if termSize > 0:
            if relWordOffset >= cursor && relWordOffset < cursor + termSize:
                detail.firstZeroBlockIndex = bi
                detail.firstZeroTermIndex = block.termIndex
                detail.firstZeroWordInnerOffset = relWordOffset - cursor
                if block.termIndex >= 0 && block.termIndex < bodyIR.terms.len:
                    detail.firstZeroTermKind = bodyIR.terms[block.termIndex].kind
                return
            cursor = cursor + termSize

fn PrimaryObjectPlanCaptureBodyIrDetails(detail: var PrimaryObjectErrorBodyIrDetail,
                                          bodyIR: coreir.BodyIR) =
    detail.opCount = bodyIR.ops.len
    detail.termCount = bodyIR.terms.len
    detail.blockCount = bodyIR.blocks.len
    detail.callCount = bodyIR.callSequence.len
    detail.slotCount = bodyIR.localSlots.len
    detail.firstZeroOpIndex = -1
    detail.firstZeroTermIndex = -1
    detail.firstZeroBlockIndex = -1
    detail.firstZeroWordInnerOffset = -1
    for opIndex in 0..<bodyIR.ops.len:
        let op = bodyIR.ops[opIndex]
        if op.kind != coreir.BodyOpInvalidTag &&
           PrimaryBodyIROpSizeAt(bodyIR, opIndex) > 0:
            continue
        PrimaryObjectPlanCaptureBodyIrOpDetail(detail, bodyIR, opIndex)
        break
    for termIndex in 0..<bodyIR.terms.len:
        if PrimaryBodyIRTermSize(bodyIR, termIndex) > 0:
            continue
        let term = bodyIR.terms[termIndex]
        detail.firstZeroTermIndex = termIndex
        detail.firstZeroTermKind = term.kind
        break
    if bodyIR.terms.len > 0:
        let term = bodyIR.terms[bodyIR.terms.len - 1]
        detail.lastTermKind = term.kind
        detail.lastTermResultSlot = term.resultSlot
        if term.operands.len > 0:
            detail.lastTermOperand0 = term.operands[0]
        if term.resultSlot >= 0 && term.resultSlot < bodyIR.localSlots.len:
            detail.lastTermResultType = bodyIR.localSlots[term.resultSlot].typeKind
    if bodyIR.callSequence.len > 0:
        let call = bodyIR.callSequence[bodyIR.callSequence.len - 1]
        detail.lastCallTarget = call.targetSymbol
        detail.lastCallResultSlot = call.resultSlot
        if call.resultSlot >= 0 && call.resultSlot < bodyIR.localSlots.len:
            detail.lastCallResultType = bodyIR.localSlots[call.resultSlot].typeKind

fn PrimaryPathSuffixMatch(left: str,
                            right: str): bool =
    if PrimaryPathNormalizedEquals(left, right):
        return true
    var li = left.len - 1
    var ri = right.len - 1
    while li >= 0 && ri >= 0:
        if left[li] != right[ri]:
            break
        li = li - 1
        ri = ri - 1
    if ri < 0:
        if li < 0 || left[li] == '/' || left[li] == '\\':
            return true
    if li < 0:
        if ri < 0 || right[ri] == '/' || right[ri] == '\\':
            return true
    return false

fn PrimaryTypedIrFunctionIndex(ir: texpr.TypedExprIr,
                                sourcePath: str,
                                functionName: str): int32 =
    let tailName = PrimaryFunctionTailName(functionName)
    for i in 0..<ir.functions.len:
        if PrimaryPathNormalizedEquals(ir.functions[i].sourcePath, sourcePath):
            if ir.functions[i].functionName == functionName ||
               ir.functions[i].functionName == tailName:
                return i
    for i in 0..<ir.functions.len:
        if PrimaryPathSuffixMatch(ir.functions[i].sourcePath, sourcePath):
            if ir.functions[i].functionName == functionName ||
               ir.functions[i].functionName == tailName:
                return i
    var foundIndex: int32
    foundIndex = -1
    for i in 0..<ir.functions.len:
        if ir.functions[i].functionName == functionName ||
           ir.functions[i].functionName == tailName:
            if foundIndex >= 0:
                return -1
            foundIndex = i
    return foundIndex

fn PrimaryObjectMissingTypedIrKind(lowering: lower.LoweringPlanStub,
                                    irIndex: int32): str =
    if irIndex < 0 || irIndex >= lowering.primaryObjectIr.functions.len:
        return ""
    let irFunction = lowering.primaryObjectIr.functions[irIndex]
    if irFunction.bodyKind != texpr.BodyKindUnsupported:
        return ""
    for stmtIndex in 0..<irFunction.statements.len:
        let stmt = irFunction.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtLetCall:
            return "stmt_let_call"
        if stmt.kind == texpr.TypedExprIrStmtIfCall:
            return "stmt_if_call"
        if stmt.kind == texpr.TypedExprIrStmtCall:
            return "stmt_call"
        if stmt.kind == texpr.TypedExprIrStmtAssign:
            return "stmt_assign"
    let typedIndex = PrimaryTypedIrFunctionIndex(lowering.typedIr,
                                                irFunction.sourcePath,
                                                irFunction.functionName)
    if typedIndex < 0 || typedIndex >= lowering.typedIr.functions.len:
        return ""
    let typedFunction = lowering.typedIr.functions[typedIndex]
    var nodeEnd = typedFunction.nodeStart + typedFunction.nodeCount
    if nodeEnd > lowering.typedIr.nodes.len:
        nodeEnd = lowering.typedIr.nodes.len
    for nodeIndex in typedFunction.nodeStart..<nodeEnd:
        if lowering.typedIr.nodes[nodeIndex].opKind == texpr.TypedExprIrOpLetCall:
            return "stmt_let_call"
    let stmtStart = typedFunction.statementStart
    let stmtEnd = stmtStart + typedFunction.statementCount
    if stmtStart >= 0 && stmtStart < lowering.typedIr.statements.len:
        var safeStmtEnd = stmtEnd
        if safeStmtEnd > lowering.typedIr.statements.len:
            safeStmtEnd = lowering.typedIr.statements.len
        for stmtIndex in stmtStart..<safeStmtEnd:
            if lowering.typedIr.statements[stmtIndex].kind == texpr.TypedExprIrStmtLetCall:
                return "stmt_let_call"
            if lowering.typedIr.statements[stmtIndex].kind == texpr.TypedExprIrStmtIfCall:
                return "stmt_if_call"
            if lowering.typedIr.statements[stmtIndex].kind == texpr.TypedExprIrStmtCall:
                return "stmt_call"
            if lowering.typedIr.statements[stmtIndex].kind == texpr.TypedExprIrStmtAssign:
                return "stmt_assign"
    return ""

fn PrimaryBuildBodyIrForFunction(lowering: lower.LoweringPlanStub,
                                   irFn: lower.PrimaryObjectIrFunction,
                                   i: int32,
                                   tempBodyIRs: var coreir.BodyIR[],
                                   wordCounts: var int32[]) =
    var buildBodyIR = irFn.bodyKind == texpr.BodyKindUnsupported ||
                      irFn.bodyKind == texpr.BodyKindStatementSequence ||
                      wordCounts[i] <= 0
    if !buildBodyIR:
        buildBodyIR = PrimaryStatementSequenceReturnMode(irFn.bodyKind) != PrimaryStatementReturnModeNone()
    if buildBodyIR:
        if irFn.statements.len > 0 ||
           irFn.bodyKind == texpr.BodyKindUnsupported ||
           irFn.bodyKind == texpr.BodyKindStatementSequence:
            let typedFnIndex = irFn.typedFunctionIndex
            if typedFnIndex >= 0:
                var bodyIR = PrimaryBuildBodyIrFromTypedStatements(lowering,
                                                                   lowering.typedIr,
                                                                   typedFnIndex,
                                                                   irFn)
                PrimaryBodyIrPatchCallTargetSymbols(bodyIR,
                                                    irFn.callTargets,
                                                    irFn.callImportcSymbols)
                if bodyIR.ops.len > 0 || bodyIR.terms.len > 0:
                    tempBodyIRs[i] = bodyIR
                    wordCounts[i] = PrimaryBodyIrGeneralCfgWordCount(bodyIR)

fn PrimaryObjectPlanInitPhase(state: var PrimaryObjectPlanPhaseState,
                               linkPlan: slplan.SystemLinkPlanStub,
                               lowering: lower.LoweringPlanStub) =
    state.allSymbolNames = []
    state.itemIds = []
    state.symbolNames = []
    state.functionWordOffsets = []
    state.functionWordCounts = []
    state.functionBodyKinds = []
    state.functionInstructionBodyKinds = []
    state.functionStatementReturnModes = []
    state.functionStatementReturnI32Values = []
    state.functionStatementCallCounts = []
    state.functionBodyIRs = []
    state.relocSourceItemIds = []
    state.relocWordOffsets = []
    state.relocTargetSymbols = []
    state.dataLabels = []
    state.dataPayloadTexts = []
    state.dataRelocSourceItemIds = []
    state.dataRelocWordOffsets = []
    state.dataRelocTargetSymbols = []
    state.dataPayloadRawBytes = []
    state.dataPayloadRawByteCounts = []
    state.irIndexes = PrimaryIntSeqInit(lowering.functionNames.len, -1)
    state.wordCounts = PrimaryIntSeqInit(lowering.functionNames.len, 0)
    state.reachable = PrimaryBoolSeqInit(lowering.functionNames.len, false)
    state.frontier = []
    state.tempBodyIRs = []
    state.planBodyIRs = []
    for _ in 0..<lowering.functionNames.len:
        add(state.tempBodyIRs, coreir.BodyIRNew())
    state.exportedFunctionCount = 0
    if linkPlan.emitKind == creq.EmitObj:
        for i in 0..<lowering.functionExportedFlags.len:
            if lowering.functionExportedFlags[i] != 0:
                state.exportedFunctionCount = state.exportedFunctionCount + 1
    state.emitObjectRootsAllFunctions = linkPlan.emitKind == creq.EmitObj && state.exportedFunctionCount <= 0
    state.totalWordCount = 0
    state.entryFunctionSymbol = ""
    state.bodySemanticsMissing = false
    state.error.functionName = ""
    state.error.bodyKind = ""
    state.error.typedIrKind = ""
    state.error.lineNumber = 0
    state.error.callTargetOrdinal = -1
    state.error.callTarget = ""
    state.error.callTargetSourcePath = ""
    state.needsRuntimeCommandData = false

fn PrimaryObjectPlanLinkPhase(state: var PrimaryObjectPlanPhaseState,
                               linkPlan: slplan.SystemLinkPlanStub,
                               lowering: lower.LoweringPlanStub) =
    for i in 0..<lowering.functionNames.len:
        let sourcePath = lowering.functionSourcePaths[i]
        let irIndex = PrimaryObjectIrFunctionIndex(lowering.primaryObjectIr,
                                                   sourcePath,
                                                   lowering.functionNames[i])
        var signatureLineNumber: int32
        if irIndex >= 0:
            signatureLineNumber = lowering.primaryObjectIr.functions[irIndex].signatureLineNumber
            state.irIndexes[i] = irIndex
        var symbolText = lowering.functionSymbolTexts[i]
        if i < lowering.functionExportedFlags.len &&
           i < lowering.functionExportSymbolNames.len &&
           lowering.functionExportedFlags[i] != 0 &&
           len(lowering.functionExportSymbolNames[i]) > 0:
            symbolText = lowering.functionExportSymbolNames[i]
        add(state.allSymbolNames,
            PrimarySymbolNameForFunction(linkPlan.targetTriple,
                                           symbolText,
                                           signatureLineNumber,
                                           linkPlan.emitKind))
        if i < lowering.functionEntryFlags.len && lowering.functionEntryFlags[i] != 0:
            state.entryFunctionSymbol = state.allSymbolNames[state.allSymbolNames.len - 1]
        let emitObjectRootExported = linkPlan.emitKind == creq.EmitObj &&
                                     i < lowering.functionExportedFlags.len &&
                                     lowering.functionExportedFlags[i] != 0
        if state.emitObjectRootsAllFunctions ||
           emitObjectRootExported ||
           (i < lowering.functionEntryFlags.len && lowering.functionEntryFlags[i] != 0):
            state.reachable[i] = true
            add(state.frontier, i)

fn PrimaryObjectPlanLoweringPhase(state: var PrimaryObjectPlanPhaseState,
                                   lowering: lower.LoweringPlanStub) =
    for i in 0..<lowering.functionNames.len:
        let irIndex = state.irIndexes[i]
        if irIndex < 0:
            continue
        let irFn = lowering.primaryObjectIr.functions[irIndex]
        var bodyKind = irFn.bodyKind
        let specialBodyKind = PrimarySpecialExportBodyKindForFunction(lowering, i)
        if specialBodyKind != "":
            bodyKind = specialBodyKind
        state.wordCounts[i] = PrimaryFunctionWordCountForBodyKind(bodyKind)
        if state.wordCounts[i] <= 0 ||
           PrimaryStatementSequenceReturnMode(bodyKind) != PrimaryStatementReturnModeNone():
            PrimaryBuildBodyIrForFunction(lowering, irFn, i, state.tempBodyIRs, state.wordCounts)

fn PrimaryCallSequenceNeedsReloc(bodyKind: str, bodyIrCallCount: int32): bool =
    if bodyIrCallCount > 0:
        return true
    return texpr.TypedExprIsCallRelocBodyKind(bodyKind) ||
           PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind)

fn PrimaryCallSequenceRequiredCallCount(bodyKind: str,
                                          bodyIrCallCount: int32,
                                          callTargetsLen: int32): int32 =
    if bodyIrCallCount > 0:
        return bodyIrCallCount
    if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
        return 2
    if bodyKind == "str_i32_guard_arg0_return_0":
        return 4
    if bodyKind == "str_i32_guard_arg0_else_call_arg0_arg1_return_result_i32":
        return 5
    if bodyKind == texpr.BodyKindBackendDriverRunCommand:
        return 4
    return 1

fn PrimaryObjectPlanReachabilityPhase(state: var PrimaryObjectPlanPhaseState,
                                       lowering: lower.LoweringPlanStub,
                                       plan: var PrimaryObjectPlan) =
    for _ in 0..<lowering.functionNames.len:
        var nextFrontier: int32[]
        for frontierIndex in 0..<state.frontier.len:
            let currentIndex = state.frontier[frontierIndex]
            if currentIndex < 0 || currentIndex >= lowering.functionNames.len:
                continue
            let irIndex = state.irIndexes[currentIndex]
            if irIndex < 0:
                state.bodySemanticsMissing = true
                if len(state.error.functionName) <= 0:
                    state.error.functionName = lowering.functionNames[currentIndex]
                    state.error.bodyKind = "missing_primary_object_ir"
                    state.error.typedIrKind = ""
                    state.error.lineNumber = 0
                continue
            if state.wordCounts[currentIndex] <= 0:
                state.bodySemanticsMissing = true
                if len(state.error.functionName) <= 0:
                    state.error.functionName = lowering.functionNames[currentIndex]
                    state.error.bodyKind = lowering.primaryObjectIr.functions[irIndex].bodyKind
                    state.error.typedIrKind = PrimaryObjectMissingTypedIrKind(lowering, irIndex)
                    state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                    if currentIndex < state.tempBodyIRs.len:
                        PrimaryObjectPlanCaptureBodyIrDetails(plan.error.bodyIrDetail, state.tempBodyIRs[currentIndex])
                continue
            let irFunction = lowering.primaryObjectIr.functions[irIndex]
            if irFunction.signatureLineNumber <= 0:
                state.bodySemanticsMissing = true
                if len(state.error.functionName) <= 0:
                    state.error.functionName = lowering.functionNames[currentIndex]
                    state.error.bodyKind = irFunction.bodyKind
                    state.error.typedIrKind = PrimaryObjectMissingTypedIrKind(lowering, irIndex)
                    state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                continue
            let bodyKind = irFunction.bodyKind
            var bodyIrCallCount: int32
            if currentIndex < state.tempBodyIRs.len:
                bodyIrCallCount = state.tempBodyIRs[currentIndex].callSequence.len
                for slotIndex in 0..<state.tempBodyIRs[currentIndex].localSlots.len:
                    let functionIndex = PrimaryBodyIrFunctionAddressSlotIndex(state.tempBodyIRs[currentIndex].localSlots[slotIndex].name)
                    if functionIndex >= 0 &&
                       functionIndex < state.reachable.len &&
                       !state.reachable[functionIndex]:
                        state.reachable[functionIndex] = true
                        add(nextFrontier, functionIndex)
            if PrimaryCallSequenceNeedsReloc(bodyKind, bodyIrCallCount):
                var callSequenceReady = true
                var requiredCallCount = PrimaryCallSequenceRequiredCallCount(bodyKind,
                                                                               bodyIrCallCount,
                                                                               irFunction.callTargets.len)
                if (bodyIrCallCount <= 0 && irFunction.callTargets.len < requiredCallCount) ||
                   irFunction.callArgCounts.len != irFunction.callTargets.len ||
                   irFunction.callTargetSourcePaths.len != irFunction.callTargets.len ||
                   irFunction.callTargetImportcFlags.len != irFunction.callTargets.len ||
                   irFunction.callImportcSymbols.len != irFunction.callTargets.len:
                    callSequenceReady = false
                    state.bodySemanticsMissing = true
                    if len(state.error.functionName) <= 0:
                        state.error.functionName = lowering.functionNames[currentIndex]
                        state.error.bodyKind = "missing_call_sequence"
                        state.error.typedIrKind = ""
                        state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                if callSequenceReady:
                    var sourceOrdinal: int32
                    for callOrdinal in 0..<requiredCallCount:
                        var callSeqSym = ""
                        if bodyIrCallCount > 0:
                            if callOrdinal >= state.tempBodyIRs[currentIndex].callSequence.len:
                                callSequenceReady = false
                                state.bodySemanticsMissing = true
                                if len(state.error.functionName) <= 0:
                                    state.error.functionName = lowering.functionNames[currentIndex]
                                    state.error.bodyKind = "body_ir_call_sequence_drift"
                                    state.error.typedIrKind = ""
                                    state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                                break
                            callSeqSym = state.tempBodyIRs[currentIndex].callSequence[callOrdinal].targetSymbol
                            if PrimaryBodyIrDirectExternalCallTarget(callSeqSym):
                                continue
                        var expectedCallSequenceTarget = ""
                        if sourceOrdinal < irFunction.callTargetImportcFlags.len &&
                           irFunction.callTargetImportcFlags[sourceOrdinal] &&
                           sourceOrdinal < irFunction.callImportcSymbols.len &&
                           irFunction.callImportcSymbols[sourceOrdinal] != "":
                            expectedCallSequenceTarget = irFunction.callImportcSymbols[sourceOrdinal]
                        elif sourceOrdinal < irFunction.callTargets.len:
                            expectedCallSequenceTarget = irFunction.callTargets[sourceOrdinal]
                        if bodyIrCallCount > 0:
                            if expectedCallSequenceTarget != "" &&
                               callSeqSym != expectedCallSequenceTarget:
                                callSequenceReady = false
                                state.bodySemanticsMissing = true
                                if len(state.error.functionName) <= 0:
                                    state.error.functionName = lowering.functionNames[currentIndex]
                                    state.error.bodyKind = "body_ir_call_sequence_drift"
                                    state.error.typedIrKind = ""
                                    state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                                break
                        if sourceOrdinal < irFunction.callTargetImportcFlags.len &&
                           irFunction.callTargetImportcFlags[sourceOrdinal]:
                            sourceOrdinal = sourceOrdinal + 1
                            continue
                        let targetIndex = PrimaryFunctionTargetIndex(lowering.functionSymbolTexts,
                                                                      lowering.functionSourcePaths,
                                                                      irFunction.callTargetSourcePaths[sourceOrdinal],
                                                                      irFunction.callTargets[sourceOrdinal])
                        if targetIndex < 0 || targetIndex >= state.reachable.len:
                            callSequenceReady = false
                            state.bodySemanticsMissing = true
                            if len(state.error.functionName) <= 0:
                                state.error.functionName = lowering.functionNames[currentIndex]
                                state.error.bodyKind = "missing_call_target"
                                state.error.typedIrKind = ""
                                state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                                state.error.callTargetOrdinal = callOrdinal
                                if sourceOrdinal < irFunction.callTargets.len:
                                    state.error.callTarget = irFunction.callTargets[sourceOrdinal]
                                if sourceOrdinal < irFunction.callTargetSourcePaths.len:
                                    state.error.callTargetSourcePath = irFunction.callTargetSourcePaths[sourceOrdinal]
                            break
                        if !state.reachable[targetIndex]:
                            state.reachable[targetIndex] = true
                            add(nextFrontier, targetIndex)
                        sourceOrdinal = sourceOrdinal + 1
                if !callSequenceReady:
                    continue
        state.frontier = nextFrontier

fn PrimaryObjectPlanBuildItemsPhase(state: var PrimaryObjectPlanPhaseState,
                                     linkPlan: slplan.SystemLinkPlanStub,
                                     lowering: lower.LoweringPlanStub,
                                     plan: var PrimaryObjectPlan) =
    for i in 0..<lowering.functionNames.len:
        if i >= state.reachable.len || !state.reachable[i]:
            continue
        var targetSymbols: str[]
        let irIndex = state.irIndexes[i]
        if irIndex < 0:
            state.bodySemanticsMissing = true
            if len(state.error.functionName) <= 0:
                state.error.functionName = lowering.functionNames[i]
                state.error.bodyKind = "missing_primary_object_ir"
                state.error.typedIrKind = ""
                state.error.lineNumber = 0
            continue
        let irFunction = lowering.primaryObjectIr.functions[irIndex]
        var bodyKind = irFunction.bodyKind
        let specialBodyKind = PrimarySpecialExportBodyKindForFunction(lowering, i)
        if specialBodyKind != "":
            bodyKind = specialBodyKind
        var bodyIrCallCount: int32
        if i < state.tempBodyIRs.len:
            bodyIrCallCount = state.tempBodyIRs[i].callSequence.len
        if PrimaryCallSequenceNeedsReloc(bodyKind, bodyIrCallCount):
            var callSequenceReady = true
            var requiredCallCount = PrimaryCallSequenceRequiredCallCount(bodyKind,
                                                                           bodyIrCallCount,
                                                                           irFunction.callTargets.len)
            if bodyIrCallCount <= 0 && irFunction.callTargets.len < requiredCallCount:
                callSequenceReady = false
                state.bodySemanticsMissing = true
                if len(state.error.functionName) <= 0:
                    state.error.functionName = lowering.functionNames[i]
                    state.error.bodyKind = "missing_call_sequence"
                    state.error.typedIrKind = ""
                    state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
            if irFunction.callArgCounts.len != irFunction.callTargets.len ||
               irFunction.callTargetSourcePaths.len != irFunction.callTargets.len ||
               irFunction.callTargetImportcFlags.len != irFunction.callTargets.len ||
               irFunction.callImportcSymbols.len != irFunction.callTargets.len:
                callSequenceReady = false
                state.bodySemanticsMissing = true
                if len(state.error.functionName) <= 0:
                    state.error.functionName = lowering.functionNames[i]
                    state.error.bodyKind = "missing_call_sequence"
                    state.error.typedIrKind = ""
                    state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
            if callSequenceReady:
                var sourceOrdinal: int32
                for callOrdinal in 0..<requiredCallCount:
                    var targetSymbol = ""
                    if bodyIrCallCount > 0:
                        if callOrdinal >= state.tempBodyIRs[i].callSequence.len:
                            callSequenceReady = false
                            state.bodySemanticsMissing = true
                            if len(state.error.functionName) <= 0:
                                state.error.functionName = lowering.functionNames[i]
                                state.error.bodyKind = "body_ir_call_sequence_drift"
                                state.error.typedIrKind = ""
                                state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                            break
                        let callSeqSym = state.tempBodyIRs[i].callSequence[callOrdinal].targetSymbol
                        if PrimaryBodyIrDirectExternalCallTarget(callSeqSym):
                            targetSymbol = PrimaryTargetSymbolName(linkPlan.targetTriple,
                                                                   callSeqSym)
                        elif sourceOrdinal < irFunction.callTargetImportcFlags.len &&
                           irFunction.callTargetImportcFlags[sourceOrdinal] &&
                           sourceOrdinal < irFunction.callImportcSymbols.len:
                            targetSymbol = PrimaryTargetSymbolName(linkPlan.targetTriple,
                                                                   irFunction.callImportcSymbols[sourceOrdinal])
                            sourceOrdinal = sourceOrdinal + 1
                        elif len(callSeqSym) > 0:
                            var callTargetSourcePath = ""
                            if sourceOrdinal < irFunction.callTargetSourcePaths.len:
                                callTargetSourcePath = irFunction.callTargetSourcePaths[sourceOrdinal]
                            let targetIndex = PrimaryFunctionTargetIndex(lowering.functionSymbolTexts,
                                                                          lowering.functionSourcePaths,
                                                                          callTargetSourcePath,
                                                                          callSeqSym)
                            if targetIndex >= 0 &&
                               targetIndex < state.allSymbolNames.len &&
                               targetIndex < state.reachable.len &&
                               state.reachable[targetIndex]:
                                targetSymbol = state.allSymbolNames[targetIndex]
                            else:
                                targetSymbol = callSeqSym
                            sourceOrdinal = sourceOrdinal + 1
                        else:
                            targetSymbol = callSeqSym
                    elif callOrdinal < irFunction.callTargetImportcFlags.len && irFunction.callTargetImportcFlags[callOrdinal]:
                        if callOrdinal >= irFunction.callImportcSymbols.len:
                            callSequenceReady = false
                            state.bodySemanticsMissing = true
                            if len(state.error.functionName) <= 0:
                                state.error.functionName = lowering.functionNames[i]
                                state.error.bodyKind = "missing_call_sequence"
                                state.error.typedIrKind = ""
                                state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                            break
                        targetSymbol = PrimaryTargetSymbolName(linkPlan.targetTriple,
                                                               irFunction.callImportcSymbols[callOrdinal])
                    else:
                        let targetIndex = PrimaryFunctionTargetIndex(lowering.functionSymbolTexts,
                                                                      lowering.functionSourcePaths,
                                                                      irFunction.callTargetSourcePaths[callOrdinal],
                                                                      irFunction.callTargets[callOrdinal])
                        if targetIndex >= 0 &&
                           targetIndex < state.allSymbolNames.len &&
                           targetIndex < state.reachable.len &&
                           state.reachable[targetIndex]:
                            targetSymbol = state.allSymbolNames[targetIndex]
                        else:
                            callSequenceReady = false
                            state.bodySemanticsMissing = true
                            if len(state.error.functionName) <= 0:
                                state.error.functionName = lowering.functionNames[i]
                                state.error.bodyKind = "missing_call_target"
                                state.error.typedIrKind = ""
                                state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                                state.error.callTargetOrdinal = callOrdinal
                                if callOrdinal < irFunction.callTargets.len:
                                    state.error.callTarget = irFunction.callTargets[callOrdinal]
                                if callOrdinal < irFunction.callTargetSourcePaths.len:
                                    state.error.callTargetSourcePath = irFunction.callTargetSourcePaths[callOrdinal]
                            break
                    add(targetSymbols, targetSymbol)
            if !callSequenceReady:
                continue
        let wordCount = state.wordCounts[i]
        if wordCount <= 0:
            state.bodySemanticsMissing = true
            if len(state.error.functionName) <= 0:
                state.error.functionName = lowering.functionNames[i]
                state.error.bodyKind = bodyKind
                state.error.typedIrKind = PrimaryObjectMissingTypedIrKind(lowering, irIndex)
                state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                if i < state.tempBodyIRs.len:
                    PrimaryObjectPlanCaptureBodyIrDetails(plan.error.bodyIrDetail, state.tempBodyIRs[i])
            continue
        if PrimaryCallSequenceNeedsReloc(bodyKind, bodyIrCallCount):
            var requiredCallCount = PrimaryCallSequenceRequiredCallCount(bodyKind,
                                                                           bodyIrCallCount,
                                                                           targetSymbols.len)
            if targetSymbols.len < requiredCallCount:
                state.bodySemanticsMissing = true
                if len(state.error.functionName) <= 0:
                    state.error.functionName = lowering.functionNames[i]
                    state.error.bodyKind = "missing_call_sequence"
                    state.error.typedIrKind = ""
                    state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
                continue
        let itemId = int32(100000 + i)
        let wordOffset = state.totalWordCount
        add(state.itemIds, itemId)
        add(state.symbolNames, state.allSymbolNames[i])
        add(state.functionWordOffsets, wordOffset)
        add(state.functionWordCounts, wordCount)
        var planBodyKind = PrimaryPlanBodyKind(bodyKind)
        if i < state.tempBodyIRs.len:
            if state.tempBodyIRs[i].ops.len > 0 || state.tempBodyIRs[i].terms.len > 0:
                planBodyKind = texpr.BodyKindStatementSequence
        add(state.functionBodyKinds, planBodyKind)
        add(state.functionInstructionBodyKinds, bodyKind)
        add(state.functionStatementReturnModes, PrimaryStatementSequenceReturnMode(bodyKind))
        add(state.functionStatementReturnI32Values, PrimaryStatementSequenceI32Value(bodyKind))
        add(state.functionStatementCallCounts, irFunction.callTargets.len)
        add(state.functionBodyIRs, state.tempBodyIRs[i])
        add(state.planBodyIRs, state.tempBodyIRs[i])
        PrimaryBodyIrAppendGlobalDataLabels(state.tempBodyIRs[i],
                                            linkPlan.targetTriple,
                                            state.dataLabels,
                                            state.dataPayloadTexts,
                                            state.dataPayloadRawByteCounts)
        if state.tempBodyIRs[i].cstringLiterals.len > 0:
            PrimaryBodyIrAppendCStringDataLabels(state.tempBodyIRs[i],
                                                 state.allSymbolNames[i],
                                                 state.dataLabels,
                                                 state.dataPayloadTexts,
                                                 state.dataPayloadRawBytes,
                                                 state.dataPayloadRawByteCounts)
        PrimaryBodyIrAppendCStringArgRelocs(state.tempBodyIRs[i],
                                            itemId,
                                            wordOffset,
                                            linkPlan.targetTriple,
                                            state.allSymbolNames[i],
                                            state.allSymbolNames,
                                            state.dataRelocSourceItemIds,
                                            state.dataRelocWordOffsets,
                                            state.dataRelocTargetSymbols)
        if bodyKind == texpr.BodyKindRuntimeSetCmdLine ||
           bodyKind == texpr.BodyKindRuntimeParamCount ||
           bodyKind == texpr.BodyKindRuntimeParamStrCopyBridge:
            state.needsRuntimeCommandData = true
        if bodyIrCallCount <= 0 &&
           PrimaryCallSequenceNeedsReloc(bodyKind, bodyIrCallCount):
            var relocWordOffset = wordOffset
            if PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind) ||
               texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(bodyKind) ||
               bodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32:
                relocWordOffset = wordOffset + 2
            elif texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(bodyKind) ||
                 texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
                relocWordOffset = wordOffset + 3
            elif bodyKind == "str_i32_guard_arg0_return_0":
                relocWordOffset = wordOffset + 3
            elif bodyKind == "str_i32_guard_arg0_else_call_arg0_arg1_return_result_i32":
                relocWordOffset = wordOffset + 3
            elif bodyKind == texpr.BodyKindBackendDriverRunCommand:
                relocWordOffset = wordOffset + 2
            add(state.relocSourceItemIds, itemId)
            add(state.relocWordOffsets, relocWordOffset)
            add(state.relocTargetSymbols, targetSymbols[0])
            if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 5)
                add(state.relocTargetSymbols, targetSymbols[1])
            if bodyKind == "str_i32_guard_arg0_return_0":
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 5)
                add(state.relocTargetSymbols, targetSymbols[1])
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 6)
                add(state.relocTargetSymbols, targetSymbols[2])
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 10)
                add(state.relocTargetSymbols, targetSymbols[3])
            if bodyKind == "str_i32_guard_arg0_else_call_arg0_arg1_return_result_i32":
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 5)
                add(state.relocTargetSymbols, targetSymbols[1])
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 6)
                add(state.relocTargetSymbols, targetSymbols[2])
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 10)
                add(state.relocTargetSymbols, targetSymbols[3])
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 15)
                add(state.relocTargetSymbols, targetSymbols[4])
            if bodyKind == texpr.BodyKindBackendDriverRunCommand:
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 5)
                add(state.relocTargetSymbols, targetSymbols[1])
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 13)
                add(state.relocTargetSymbols, targetSymbols[2])
                add(state.relocSourceItemIds, itemId)
                add(state.relocWordOffsets, wordOffset + 15)
                add(state.relocTargetSymbols, targetSymbols[3])
        elif bodyKind == texpr.BodyKindCstringToStrCopy:
            add(state.relocSourceItemIds, itemId)
            add(state.relocWordOffsets, wordOffset + 5)
            add(state.relocTargetSymbols, PrimaryTargetSymbolName(linkPlan.targetTriple, "cheng_cstrlen"))
            add(state.relocSourceItemIds, itemId)
            add(state.relocWordOffsets, wordOffset + 11)
            add(state.relocTargetSymbols, PrimaryTargetSymbolName(linkPlan.targetTriple, "driver_c_new_string_copy_n"))
        elif bodyKind == texpr.BodyKindRuntimeParamStrCopyBridge:
            add(state.relocSourceItemIds, itemId)
            add(state.relocWordOffsets, wordOffset + 18)
            add(state.relocTargetSymbols, PrimaryTargetSymbolName(linkPlan.targetTriple, "strlen"))
        let birc = state.tempBodyIRs[i].callSequence.len
        if birc > 0:
            var bircTargetSymbols: str[]
            if targetSymbols.len >= birc:
                bircTargetSymbols = targetSymbols
            else:
                var sourceOrdinal: int32
                for co in 0..<birc:
                    var sym = state.tempBodyIRs[i].callSequence[co].targetSymbol
                    if PrimaryBodyIrDirectExternalCallTarget(sym):
                        sym = PrimaryTargetSymbolName(linkPlan.targetTriple, sym)
                    elif irFunction.callTargetImportcFlags.len > sourceOrdinal && irFunction.callTargetImportcFlags[sourceOrdinal]:
                        if irFunction.callImportcSymbols.len > sourceOrdinal:
                            sym = PrimaryTargetSymbolName(linkPlan.targetTriple, irFunction.callImportcSymbols[sourceOrdinal])
                        sourceOrdinal = sourceOrdinal + 1
                    elif irFunction.callTargetSourcePaths.len > sourceOrdinal && irFunction.callTargets.len > sourceOrdinal:
                        let targetIndex = PrimaryFunctionTargetIndex(lowering.functionSymbolTexts,
                                                                      lowering.functionSourcePaths,
                                                                      irFunction.callTargetSourcePaths[sourceOrdinal],
                                                                      irFunction.callTargets[sourceOrdinal])
                        if targetIndex >= 0 && targetIndex < state.allSymbolNames.len &&
                           targetIndex < state.reachable.len && state.reachable[targetIndex]:
                            sym = state.allSymbolNames[targetIndex]
                        sourceOrdinal = sourceOrdinal + 1
                    add(bircTargetSymbols, sym)
            for co in 0..<birc:
                let bro = PrimaryBodyIrGeneralCfgRelocWordOffset(state.tempBodyIRs[i], itemId, co)
                if bro >= 0 && co < bircTargetSymbols.len && len(bircTargetSymbols[co]) > 0:
                    add(state.relocSourceItemIds, itemId)
                    add(state.relocWordOffsets, wordOffset + bro)
                    add(state.relocTargetSymbols, bircTargetSymbols[co])
                elif bro < 0:
                    state.bodySemanticsMissing = true
                    if len(state.error.functionName) <= 0:
                        state.error.functionName = lowering.functionNames[i]
                        state.error.bodyKind = "body_ir_call_reloc_missing"
                        state.error.typedIrKind = ""
                        state.error.lineNumber = PrimaryObjectMissingLineNumber(lowering, irIndex)
        state.totalWordCount = state.totalWordCount + wordCount
    if linkPlan.emitKind == creq.EmitExe &&
       len(linkPlan.entrySymbol) > 0 &&
       len(state.entryFunctionSymbol) > 0 &&
       state.itemIds.len > 0:
        add(state.itemIds, int32(900000 + state.itemIds.len))
        add(state.symbolNames, PrimaryRuntimeEntryBridgeSymbol(linkPlan))
        add(state.functionWordOffsets, state.totalWordCount)
        add(state.functionWordCounts, texpr.BodyKindEntryBridgeWordCount)
        add(state.functionBodyKinds, texpr.BodyKindEntryBridge)
        add(state.functionInstructionBodyKinds, texpr.BodyKindEntryBridge)
        add(state.functionStatementReturnModes, PrimaryStatementReturnModeNone())
        add(state.functionStatementReturnI32Values, 0)
        add(state.functionStatementCallCounts, 0)
        add(state.functionBodyIRs, coreir.BodyIRNew())
        add(state.planBodyIRs, coreir.BodyIRNew())
        state.totalWordCount = state.totalWordCount + texpr.BodyKindEntryBridgeWordCount

fn PrimaryObjectPlanFillAndCheckPhase(state: var PrimaryObjectPlanPhaseState,
                                       linkPlan: slplan.SystemLinkPlanStub,
                                       lowering: lower.LoweringPlanStub,
                                       plan: var PrimaryObjectPlan) =
    plan.targetTriple = linkPlan.targetTriple
    plan.objectFormat = tmat.TargetPrimaryObjectFormat(linkPlan.targetTriple)
    if linkPlan.emitKind == creq.EmitObj:
        plan.outputPath = linkPlan.outputPath
    else:
        plan.outputPath = Fmt"{linkPlan.outputPath}.primary.o"
    plan.entryPath = linkPlan.entryPath
    plan.entrySymbol = linkPlan.entrySymbol
    plan.entryFunctionSymbol = state.entryFunctionSymbol
    plan.itemIds = state.itemIds
    plan.symbolNames = state.symbolNames
    plan.functionWordOffsets = state.functionWordOffsets
    plan.functionWordCounts = state.functionWordCounts
    plan.functionBodyKinds = state.functionBodyKinds
    plan.functionStatementReturnModes = state.functionStatementReturnModes
    plan.functionStatementReturnI32Values = state.functionStatementReturnI32Values
    plan.functionStatementCallCounts = state.functionStatementCallCounts
    plan.functionBodyIRs = state.functionBodyIRs
    plan.instructionWords = []
    for i in 0..<state.totalWordCount:
        add(plan.instructionWords, 0)
    var primaryFillFailedIndex: int32
    primaryFillFailedIndex = -1
    PrimaryFillInstructionWordsChunked(plan.instructionWords,
                                       state.functionWordOffsets,
                                       state.functionWordCounts,
                                       state.functionInstructionBodyKinds,
                                       state.planBodyIRs,
                                       linkPlan.jobCount,
                                       primaryFillFailedIndex)
    for functionIndex in 0..<state.functionBodyKinds.len:
        if functionIndex >= state.symbolNames.len ||
           functionIndex >= state.functionWordOffsets.len ||
           functionIndex >= state.functionWordCounts.len:
            continue
        let startWord = state.functionWordOffsets[functionIndex]
        let endWord = startWord + state.functionWordCounts[functionIndex]
        var replacedZero = false
        for wordIndex in startWord..<endWord:
            if wordIndex >= 0 && wordIndex < plan.instructionWords.len &&
               plan.instructionWords[wordIndex] == 0:
                replacedZero = true
        if replacedZero:
            state.bodySemanticsMissing = true
            if len(plan.error.functionName) <= 0:
                plan.error.functionName = state.symbolNames[functionIndex]
                plan.error.bodyKind = state.functionBodyKinds[functionIndex]
            var zeroItemId = state.itemIds[functionIndex]
            var cleanS: int32[]
            var cleanW: int32[]
            var cleanT: str[]
            for ri in 0..<state.relocSourceItemIds.len:
                if state.relocSourceItemIds[ri] != zeroItemId:
                    add(cleanS, state.relocSourceItemIds[ri])
                    add(cleanW, state.relocWordOffsets[ri])
                    add(cleanT, state.relocTargetSymbols[ri])
            state.relocSourceItemIds = cleanS
            state.relocWordOffsets = cleanW
            state.relocTargetSymbols = cleanT
            plan.error.wordOffset = startWord
            plan.error.wordCount = state.functionWordCounts[functionIndex]
            for wordIndex in startWord..<endWord:
                if wordIndex < 0 || wordIndex >= plan.instructionWords.len:
                    plan.error.wordRelOffset = wordIndex - startWord
                    break
                elif plan.instructionWords[wordIndex] == 0:
                    plan.error.wordRelOffset = wordIndex - startWord
                    break
            if functionIndex < state.planBodyIRs.len:
                PrimaryObjectPlanCaptureBodyIrDetails(plan.error.bodyIrDetail,
                                                       state.planBodyIRs[functionIndex])
                PrimaryObjectPlanCaptureBodyIrWordDetail(plan.error.bodyIrDetail,
                                                          state.planBodyIRs[functionIndex],
                                                          plan.error.wordRelOffset)
                if state.planBodyIRs[functionIndex].terms.len > 0:
                    let term = state.planBodyIRs[functionIndex].terms[state.planBodyIRs[functionIndex].terms.len - 1]
                    plan.error.bodyIrDetail.lastTermKind = term.kind
                    plan.error.bodyIrDetail.lastTermResultSlot = term.resultSlot
                    if term.operands.len > 0:
                        plan.error.bodyIrDetail.lastTermOperand0 = term.operands[0]
                    if term.resultSlot >= 0 && term.resultSlot < state.planBodyIRs[functionIndex].localSlots.len:
                        plan.error.bodyIrDetail.lastTermResultType = state.planBodyIRs[functionIndex].localSlots[term.resultSlot].typeKind
                if state.planBodyIRs[functionIndex].callSequence.len > 0:
                    let lastCallOrdinal = state.planBodyIRs[functionIndex].callSequence.len - 1
                    let call = state.planBodyIRs[functionIndex].callSequence[lastCallOrdinal]
                    plan.error.bodyIrDetail.lastCallTarget = call.targetSymbol
                    if functionIndex < lowering.primaryObjectIr.functions.len &&
                       lastCallOrdinal < lowering.primaryObjectIr.functions[functionIndex].callTargetSourcePaths.len:
                        plan.error.bodyIrDetail.lastCallTargetSourcePath = lowering.primaryObjectIr.functions[functionIndex].callTargetSourcePaths[lastCallOrdinal]
                    plan.error.bodyIrDetail.lastCallResultSlot = call.resultSlot
                    if call.resultSlot >= 0 && call.resultSlot < state.planBodyIRs[functionIndex].localSlots.len:
                        plan.error.bodyIrDetail.lastCallResultType = state.planBodyIRs[functionIndex].localSlots[call.resultSlot].typeKind
            break

fn PrimaryObjectPlanDiagnoseAndFinalizePhase(state: var PrimaryObjectPlanPhaseState,
                                              linkPlan: slplan.SystemLinkPlanStub,
                                              lowering: lower.LoweringPlanStub,
                                              plan: var PrimaryObjectPlan) =
    if state.needsRuntimeCommandData:
        add(state.dataLabels, PrimaryTargetSymbolName(linkPlan.targetTriple, "__cheng_saved_argc"))
        add(state.dataPayloadTexts, "zero:8")
        add(state.dataLabels, PrimaryTargetSymbolName(linkPlan.targetTriple, "__cheng_saved_argv"))
        add(state.dataPayloadTexts, "zero:8")
    plan.dataLabels = state.dataLabels
    plan.dataPayloadTexts = state.dataPayloadTexts
    plan.dataPayloadRawBytes = state.dataPayloadRawBytes
    plan.dataPayloadRawByteCounts = state.dataPayloadRawByteCounts
    plan.relocSourceItemIds = state.relocSourceItemIds
    plan.relocWordOffsets = state.relocWordOffsets
    plan.relocTargetSymbols = state.relocTargetSymbols
    plan.dataRelocSourceItemIds = state.dataRelocSourceItemIds
    plan.dataRelocWordOffsets = state.dataRelocWordOffsets
    plan.dataRelocTargetSymbols = state.dataRelocTargetSymbols
    plan.reachableFunctionCount = 0
    for i in 0..<state.reachable.len:
        if state.reachable[i]:
            plan.reachableFunctionCount = plan.reachableFunctionCount + 1
    if len(plan.error.functionName) <= 0:
        plan.error.functionName = state.error.functionName
        plan.error.bodyKind = state.error.bodyKind
        plan.error.typedIrKind = state.error.typedIrKind
        plan.error.lineNumber = state.error.lineNumber
        plan.error.callTargetOrdinal = state.error.callTargetOrdinal
        plan.error.callTarget = state.error.callTarget
        plan.error.callTargetSourcePath = state.error.callTargetSourcePath
    plan.typedIrTypeLayoutCount = lowering.typedIr.typeLayoutNames.len
    plan.typedIrTypeFieldCount = lowering.typedIr.typeFieldOwnerTypes.len
    plan.typedIrTypeFieldSourcePathCount = lowering.typedIr.typeFieldSourcePaths.len
    plan.typedIrTypeFieldNameCount = lowering.typedIr.typeFieldNames.len
    plan.typedIrTypeFieldTypeCount = lowering.typedIr.typeFieldTypes.len
    plan.typedIrTypeFieldOffsetCount = lowering.typedIr.typeFieldOffsetBytes.len
    plan.typedIrTypeFieldSizeCount = lowering.typedIr.typeFieldSizeBytes.len
    plan.typedIrTypeFieldAlignCount = lowering.typedIr.typeFieldAlignBytes.len
    plan.typedIrTypeDefAliasCount = lowering.typedIr.typeDefAliasNames.len
    plan.typedIrChengMemHeaderPtrAliasCount = PrimaryObjectTypedIrTypeDefAliasCount(lowering.typedIr,
                                                                                    "ChengMemHeaderPtr",
                                                                                    "ChengMemHeader*")
    plan.typedIrColdCsgTypeRowCount = lowering.typedIr.coldCsgTypeRows.len
    plan.typedIrLocalBindingCount = lowering.typedIr.localBindingNames.len
    plan.typedIrChengMemHeaderRcFieldCount = PrimaryObjectTypedIrFieldCount(lowering.typedIr,
                                                                            "ChengMemHeader",
                                                                            "rc")
    plan.typedIrChengMemHeaderRcFieldType = PrimaryObjectTypedIrFieldTypeText(lowering.typedIr,
                                                                              "ChengMemHeader",
                                                                              "rc")
    plan.typedIrChengMemHeaderRcFieldOffset = PrimaryObjectTypedIrFieldMetric(lowering.typedIr,
                                                                              "ChengMemHeader",
                                                                              "rc",
                                                                              "offset")
    plan.typedIrChengMemHeaderRcFieldSize = PrimaryObjectTypedIrFieldMetric(lowering.typedIr,
                                                                            "ChengMemHeader",
                                                                            "rc",
                                                                            "size")
    plan.typedIrChengMemHeaderRcFieldAlign = PrimaryObjectTypedIrFieldMetric(lowering.typedIr,
                                                                             "ChengMemHeader",
                                                                             "rc",
                                                                             "align")
    plan.missingReasons = PrimaryObjectMissingReasons(linkPlan,
                                                        lowering,
                                                        state.itemIds,
                                                        plan.instructionWords,
                                                        state.bodySemanticsMissing)
    plan.pipelineStage = "lowering_plan_to_primary_object_plan"

fn BuildPrimaryObjectPlan(linkPlan: slplan.SystemLinkPlanStub,
                            lowering: lower.LoweringPlanStub): PrimaryObjectPlan =
    var state: PrimaryObjectPlanPhaseState
    var plan: PrimaryObjectPlan
    PrimaryObjectPlanInitPhase(state, linkPlan, lowering)
    PrimaryObjectPlanLinkPhase(state, linkPlan, lowering)
    PrimaryObjectPlanLoweringPhase(state, lowering)
    PrimaryObjectPlanReachabilityPhase(state, lowering, plan)
    PrimaryObjectPlanBuildItemsPhase(state, linkPlan, lowering, plan)
    PrimaryObjectPlanFillAndCheckPhase(state, linkPlan, lowering, plan)
    PrimaryObjectPlanDiagnoseAndFinalizePhase(state, linkPlan, lowering, plan)
    return plan

fn PrimaryObjectPlanColdCsgV2HexDigit(value: int32): str =
    if value < 10:
        return strings.CharToStr(char(int32('0') + value))
    return strings.CharToStr(char(int32('A') + value - 10))

fn PrimaryObjectPlanColdCsgV2ByteHex(value: int32): str =
    let byteValue = value & 255
    return Fmt"{PrimaryObjectPlanColdCsgV2HexDigit((byteValue >> 4) & 15)}{PrimaryObjectPlanColdCsgV2HexDigit(byteValue & 15)}"

fn PrimaryObjectPlanColdCsgV2FixedHex(value: int32,
                                       digitCount: int32): str =
    let raw = uint32(value)
    var out = ""
    var shift = (digitCount - 1) * 4
    while shift >= 0:
        out = Fmt"{out}{PrimaryObjectPlanColdCsgV2HexDigit(int32((raw >> uint32(shift)) & uint32(15)))}"
        shift = shift - 4
    return out

fn PrimaryObjectPlanColdCsgV2U32LeHex(value: int32): str =
    let raw = uint32(value)
    return Fmt"{PrimaryObjectPlanColdCsgV2ByteHex(int32(raw & uint32(255)))}{PrimaryObjectPlanColdCsgV2ByteHex(int32((raw >> uint32(8)) & uint32(255)))}{PrimaryObjectPlanColdCsgV2ByteHex(int32((raw >> uint32(16)) & uint32(255)))}{PrimaryObjectPlanColdCsgV2ByteHex(int32((raw >> uint32(24)) & uint32(255)))}"

fn PrimaryObjectPlanColdCsgV2StringPayload(text: str): str =
    var out = PrimaryObjectPlanColdCsgV2U32LeHex(len(text))
    for i in 0..<len(text):
        out = Fmt"{out}{PrimaryObjectPlanColdCsgV2ByteHex(int32(text[i]))}"
    return out

fn PrimaryObjectPlanColdCsgV2ParseNonNegativeI32(text: str): int32 =
    if len(text) <= 0:
        return -1
    var value: int32
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return -1
        let digit = int32(ch) - int32('0')
        if value > 214748364 || (value == 214748364 && digit > 7):
            return -1
        value = value * 10 + digit
    return value

fn PrimaryObjectPlanColdCsgV2CStringPayloadByte(raw: str,
                                                 index: int32): int32 =
    if index < 0 || index >= len(raw):
        return 0
    let ch = raw[index]
    if ch == 'n':
        return 10
    if ch == 'r':
        return 13
    if ch == 't':
        return 9
    if ch == '0':
        return 0
    return int32(ch)

fn PrimaryObjectPlanColdCsgV2PayloadByteCount(payloadText: str): int32 =
    let zeroPrefix = "zero:"
    if strutil.StartsWith(payloadText, zeroPrefix):
        let raw = strings.SliceBytes(payloadText, len(zeroPrefix), len(payloadText) - len(zeroPrefix))
        return PrimaryObjectPlanColdCsgV2ParseNonNegativeI32(raw)
    let cstringPrefix = "cstring:"
    if strutil.StartsWith(payloadText, cstringPrefix):
        let raw = strings.SliceBytes(payloadText, len(cstringPrefix), len(payloadText) - len(cstringPrefix))
        var count: int32 = 1
        var escaped = false
        for i in 0..<len(raw):
            if escaped:
                escaped = false
                count = count + 1
            elif raw[i] == char(92):
                escaped = true
            else:
                count = count + 1
        if escaped:
            count = count + 1
        return count
    return -1

fn PrimaryObjectPlanColdCsgV2PayloadAlign(payloadText: str): int32 =
    let zeroPrefix = "zero:"
    if strutil.StartsWith(payloadText, zeroPrefix):
        let raw = strings.SliceBytes(payloadText, len(zeroPrefix), len(payloadText) - len(zeroPrefix))
        let count = PrimaryObjectPlanColdCsgV2ParseNonNegativeI32(raw)
        if count >= 8:
            return 8
        if count >= 4:
            return 4
    return 1

fn PrimaryObjectPlanColdCsgV2PayloadHex(payloadText: str,
                                         err: var str): str =
    let zeroPrefix = "zero:"
    if strutil.StartsWith(payloadText, zeroPrefix):
        let raw = strings.SliceBytes(payloadText, len(zeroPrefix), len(payloadText) - len(zeroPrefix))
        let count = PrimaryObjectPlanColdCsgV2ParseNonNegativeI32(raw)
        if count < 0:
            err = Fmt"cold csg v2 facts: invalid zero data payload: {payloadText}"
            return ""
        var out = ""
        for _ in 0..<count:
            out = Fmt"{out}00"
        return out
    let cstringPrefix = "cstring:"
    if strutil.StartsWith(payloadText, cstringPrefix):
        let raw = strings.SliceBytes(payloadText, len(cstringPrefix), len(payloadText) - len(cstringPrefix))
        var out = ""
        var escaped = false
        for i in 0..<len(raw):
            if escaped:
                out = Fmt"{out}{PrimaryObjectPlanColdCsgV2ByteHex(PrimaryObjectPlanColdCsgV2CStringPayloadByte(raw, i))}"
                escaped = false
            elif raw[i] == char(92):
                escaped = true
            else:
                out = Fmt"{out}{PrimaryObjectPlanColdCsgV2ByteHex(int32(raw[i]))}"
        if escaped:
            out = Fmt"{out}{PrimaryObjectPlanColdCsgV2ByteHex(int32(char(92)))}"
        return Fmt"{out}00"
    err = Fmt"cold csg v2 facts: unsupported data payload: {payloadText}"
    return ""

fn PrimaryObjectPlanColdCsgV2DataRawOffset(plan: PrimaryObjectPlan,
                                            index: int32): int32 =
    var out: int32
    for i in 0..<index:
        if i < plan.dataPayloadRawByteCounts.len:
            out = out + plan.dataPayloadRawByteCounts[i]
    return out

fn PrimaryObjectPlanColdCsgV2DataRecordPayload(plan: PrimaryObjectPlan,
                                                index: int32,
                                                err: var str): str =
    if index < 0 || index >= plan.dataLabels.len:
        err = "cold csg v2 facts: data index out of range"
        return ""
    let label = plan.dataLabels[index]
    var rawCount: int32
    if index < plan.dataPayloadRawByteCounts.len:
        rawCount = plan.dataPayloadRawByteCounts[index]
    if rawCount < 0:
        err = Fmt"cold csg v2 facts: negative raw data byte count at data index {strings.IntToStr(index)}"
        return ""
    var align = 1
    var byteCount = rawCount
    var payloadHex = ""
    if rawCount > 0:
        let rawOffset = PrimaryObjectPlanColdCsgV2DataRawOffset(plan, index)
        if rawOffset < 0 || rawOffset + rawCount > plan.dataPayloadRawBytes.len:
            err = Fmt"cold csg v2 facts: raw data payload truncated at data index {strings.IntToStr(index)}"
            return ""
        for bi in 0..<rawCount:
            let byteValue = plan.dataPayloadRawBytes[rawOffset + bi]
            if byteValue < 0 || byteValue > 255:
                err = Fmt"cold csg v2 facts: raw data byte out of range at data index {strings.IntToStr(index)}"
                return ""
            payloadHex = Fmt"{payloadHex}{PrimaryObjectPlanColdCsgV2ByteHex(byteValue)}"
    else:
        if index >= plan.dataPayloadTexts.len:
            err = Fmt"cold csg v2 facts: missing data payload text at data index {strings.IntToStr(index)}"
            return ""
        let payloadText = plan.dataPayloadTexts[index]
        byteCount = PrimaryObjectPlanColdCsgV2PayloadByteCount(payloadText)
        if byteCount < 0:
            err = Fmt"cold csg v2 facts: unsupported data payload at data index {strings.IntToStr(index)}"
            return ""
        align = PrimaryObjectPlanColdCsgV2PayloadAlign(payloadText)
        payloadHex = PrimaryObjectPlanColdCsgV2PayloadHex(payloadText, err)
        if len(err) > 0:
            return ""
    return Fmt"{PrimaryObjectPlanColdCsgV2U32LeHex(index)}{PrimaryObjectPlanColdCsgV2StringPayload(label)}{PrimaryObjectPlanColdCsgV2U32LeHex(align)}{PrimaryObjectPlanColdCsgV2U32LeHex(byteCount)}{payloadHex}"

fn PrimaryObjectPlanColdCsgV2FindItem(plan: PrimaryObjectPlan,
                                       itemId: int32): int32 =
    for i in 0..<plan.itemIds.len:
        if plan.itemIds[i] == itemId:
            return i
    return -1

fn PrimaryObjectPlanColdCsgV2FindSymbol(plan: PrimaryObjectPlan,
                                         symbolName: str): int32 =
    for i in 0..<plan.symbolNames.len:
        if plan.symbolNames[i] == symbolName:
            return i
    return -1

fn PrimaryObjectPlanColdCsgV2HasDefinedSymbol(plan: PrimaryObjectPlan,
                                               symbolName: str): bool =
    return PrimaryObjectPlanColdCsgV2FindSymbol(plan, symbolName) >= 0 ||
           PrimaryObjectDataLabelIndex(plan.dataLabels, symbolName) >= 0

fn PrimaryObjectPlanColdCsgV2AppendRecord(parts: var str[],
                                           kind: int32,
                                           payloadHex: str,
                                           err: var str): bool =
    if kind <= 0 || kind > 65535:
        err = Fmt"cold csg v2 facts: invalid record kind: {strings.IntToStr(kind)}"
        return false
    if len(payloadHex) % 2 != 0:
        err = Fmt"cold csg v2 facts: odd payload hex length for kind: {strings.IntToStr(kind)}"
        return false
    let payloadBytes = len(payloadHex) / 2
    add(parts, Fmt"R{PrimaryObjectPlanColdCsgV2FixedHex(kind, 4)}{PrimaryObjectPlanColdCsgV2FixedHex(payloadBytes, 8)}{payloadHex}\n")
    return true

fn PrimaryObjectPlanColdCsgV2Validate(plan: PrimaryObjectPlan,
                                       targetTriple: str,
                                       objectFormat: str,
                                       err: var str): bool =
    if targetTriple == "":
        err = "cold csg v2 facts: missing target triple"
        return false
    if objectFormat == "" || objectFormat == "unknown":
        err = Fmt"cold csg v2 facts: unsupported object format: {objectFormat}"
        return false
    if plan.targetTriple != "" && plan.targetTriple != targetTriple:
        err = Fmt"cold csg v2 facts: target triple mismatch plan={plan.targetTriple} requested={targetTriple}"
        return false
    if plan.objectFormat != "" && plan.objectFormat != objectFormat:
        err = Fmt"cold csg v2 facts: object format mismatch plan={plan.objectFormat} requested={objectFormat}"
        return false
    if plan.missingReasons.len > 0:
        let missingText = strutil.Join(plan.missingReasons, ",")
        err = Fmt"cold csg v2 facts: primary object plan not ready: {missingText}"
        return false
    let functionCount = plan.itemIds.len
    if plan.symbolNames.len != functionCount ||
       plan.functionWordOffsets.len != functionCount ||
       plan.functionWordCounts.len != functionCount ||
       plan.functionBodyKinds.len != functionCount:
        err = "cold csg v2 facts: primary object function arrays length mismatch"
        return false
    if plan.relocSourceItemIds.len != plan.relocWordOffsets.len ||
       plan.relocSourceItemIds.len != plan.relocTargetSymbols.len:
        err = "cold csg v2 facts: primary object reloc arrays length mismatch"
        return false
    if plan.dataRelocSourceItemIds.len != plan.dataRelocWordOffsets.len ||
       plan.dataRelocSourceItemIds.len != plan.dataRelocTargetSymbols.len:
        err = "cold csg v2 facts: primary object data reloc arrays length mismatch"
        return false
    if plan.dataPayloadTexts.len > plan.dataLabels.len ||
       plan.dataPayloadRawByteCounts.len > plan.dataLabels.len:
        err = "cold csg v2 facts: primary object data payload arrays length mismatch"
        return false
    for i in 0..<functionCount:
        let wordOffset = plan.functionWordOffsets[i]
        let wordCount = plan.functionWordCounts[i]
        if plan.itemIds[i] < 0:
            err = Fmt"cold csg v2 facts: negative item id at function index {strings.IntToStr(i)}"
            return false
        if wordOffset < 0 || wordCount < 0:
            err = Fmt"cold csg v2 facts: negative word range at function index {strings.IntToStr(i)}"
            return false
        if wordOffset + wordCount > plan.instructionWords.len:
            err = Fmt"cold csg v2 facts: function word range exceeds instruction words at function index {strings.IntToStr(i)}"
            return false
    for i in 0..<plan.relocSourceItemIds.len:
        if plan.relocSourceItemIds[i] < 0:
            err = Fmt"cold csg v2 facts: negative reloc source item id at reloc index {strings.IntToStr(i)}"
            return false
        let sourceIndex = PrimaryObjectPlanColdCsgV2FindItem(plan, plan.relocSourceItemIds[i])
        if sourceIndex < 0:
            err = Fmt"cold csg v2 facts: reloc source item missing at reloc index {strings.IntToStr(i)}"
            return false
        if plan.relocWordOffsets[i] < 0 || plan.relocWordOffsets[i] >= plan.instructionWords.len:
            err = Fmt"cold csg v2 facts: reloc word offset outside instruction words at reloc index {strings.IntToStr(i)}"
            return false
        if plan.relocWordOffsets[i] < plan.functionWordOffsets[sourceIndex] ||
           plan.relocWordOffsets[i] >= plan.functionWordOffsets[sourceIndex] + plan.functionWordCounts[sourceIndex]:
            err = Fmt"cold csg v2 facts: reloc word offset outside source function at reloc index {strings.IntToStr(i)}"
            return false
        if plan.relocTargetSymbols[i] == "":
            err = Fmt"cold csg v2 facts: empty reloc target symbol at reloc index {strings.IntToStr(i)}"
            return false
    var rawTotal: int32
    for i in 0..<plan.dataLabels.len:
        if plan.dataLabels[i] == "":
            err = Fmt"cold csg v2 facts: empty data label at data index {strings.IntToStr(i)}"
            return false
        if PrimaryObjectPlanColdCsgV2FindSymbol(plan, plan.dataLabels[i]) >= 0:
            err = Fmt"cold csg v2 facts: data label conflicts with function symbol: {plan.dataLabels[i]}"
            return false
        for j in i + 1..<plan.dataLabels.len:
            if plan.dataLabels[i] == plan.dataLabels[j]:
                err = Fmt"cold csg v2 facts: duplicate data label: {plan.dataLabels[i]}"
                return false
        var rawCount: int32
        if i < plan.dataPayloadRawByteCounts.len:
            rawCount = plan.dataPayloadRawByteCounts[i]
        if rawCount < 0:
            err = Fmt"cold csg v2 facts: negative raw data byte count at data index {strings.IntToStr(i)}"
            return false
        if rawCount > 0:
            let rawOffset = rawTotal
            rawTotal = rawTotal + rawCount
            if rawOffset < 0 || rawTotal > plan.dataPayloadRawBytes.len:
                err = Fmt"cold csg v2 facts: raw data payload truncated at data index {strings.IntToStr(i)}"
                return false
            for bi in rawOffset..<rawTotal:
                if plan.dataPayloadRawBytes[bi] < 0 || plan.dataPayloadRawBytes[bi] > 255:
                    err = Fmt"cold csg v2 facts: raw data byte out of range at data index {strings.IntToStr(i)}"
                    return false
        else:
            if i >= plan.dataPayloadTexts.len:
                err = Fmt"cold csg v2 facts: missing data payload text at data index {strings.IntToStr(i)}"
                return false
            if PrimaryObjectPlanColdCsgV2PayloadByteCount(plan.dataPayloadTexts[i]) < 0:
                err = Fmt"cold csg v2 facts: unsupported data payload at data index {strings.IntToStr(i)}"
                return false
    if rawTotal != plan.dataPayloadRawBytes.len:
        err = "cold csg v2 facts: unused raw data payload bytes"
        return false
    for i in 0..<plan.dataRelocSourceItemIds.len:
        let sourceItemId = plan.dataRelocSourceItemIds[i]
        if sourceItemId < 0:
            err = Fmt"cold csg v2 facts: negative data reloc source item id at reloc index {strings.IntToStr(i)}"
            return false
        let sourceIndex = PrimaryObjectPlanColdCsgV2FindItem(plan, sourceItemId)
        if sourceIndex < 0:
            err = Fmt"cold csg v2 facts: data reloc source item missing at reloc index {strings.IntToStr(i)}"
            return false
        let wordOffset = plan.dataRelocWordOffsets[i]
        if wordOffset < plan.functionWordOffsets[sourceIndex] ||
           wordOffset + 1 >= plan.functionWordOffsets[sourceIndex] + plan.functionWordCounts[sourceIndex]:
            err = Fmt"cold csg v2 facts: data reloc word offset outside source function at reloc index {strings.IntToStr(i)}"
            return false
        let targetSymbol = plan.dataRelocTargetSymbols[i]
        if targetSymbol == "":
            err = Fmt"cold csg v2 facts: empty data reloc target symbol at reloc index {strings.IntToStr(i)}"
            return false
        if !PrimaryObjectPlanColdCsgV2HasDefinedSymbol(plan, targetSymbol):
            err = Fmt"cold csg v2 facts: data reloc target symbol missing: {targetSymbol}"
            return false
    return true

fn PrimaryObjectPlanColdCsgV2FactsInto(plan: PrimaryObjectPlan,
                                        targetTriple: str,
                                        objectFormat: str,
                                        out: var str,
                                        err: var str): bool =
    if !PrimaryObjectPlanColdCsgV2Validate(plan, targetTriple, objectFormat, err):
        return false
    var parts: str[]
    add(parts, "CHENG_CSG_V2\n")
    if !PrimaryObjectPlanColdCsgV2AppendRecord(parts, 1, PrimaryObjectPlanColdCsgV2StringPayload(targetTriple), err):
        return false
    if !PrimaryObjectPlanColdCsgV2AppendRecord(parts, 2, PrimaryObjectPlanColdCsgV2StringPayload(objectFormat), err):
        return false
    if !PrimaryObjectPlanColdCsgV2AppendRecord(parts, 3, PrimaryObjectPlanColdCsgV2StringPayload(plan.entrySymbol), err):
        return false
    for i in 0..<plan.itemIds.len:
        let payload = Fmt"{PrimaryObjectPlanColdCsgV2U32LeHex(plan.itemIds[i])}{PrimaryObjectPlanColdCsgV2U32LeHex(plan.functionWordOffsets[i])}{PrimaryObjectPlanColdCsgV2U32LeHex(plan.functionWordCounts[i])}{PrimaryObjectPlanColdCsgV2StringPayload(plan.symbolNames[i])}{PrimaryObjectPlanColdCsgV2StringPayload(plan.functionBodyKinds[i])}"
        if !PrimaryObjectPlanColdCsgV2AppendRecord(parts, 4, payload, err):
            return false
    for i in 0..<plan.instructionWords.len:
        if !PrimaryObjectPlanColdCsgV2AppendRecord(parts, 5, PrimaryObjectPlanColdCsgV2U32LeHex(plan.instructionWords[i]), err):
            return false
    for i in 0..<plan.relocSourceItemIds.len:
        let payload = Fmt"{PrimaryObjectPlanColdCsgV2U32LeHex(plan.relocSourceItemIds[i])}{PrimaryObjectPlanColdCsgV2U32LeHex(plan.relocWordOffsets[i])}{PrimaryObjectPlanColdCsgV2StringPayload(plan.relocTargetSymbols[i])}"
        if !PrimaryObjectPlanColdCsgV2AppendRecord(parts, 6, payload, err):
            return false
    for i in 0..<plan.dataLabels.len:
        let payload = PrimaryObjectPlanColdCsgV2DataRecordPayload(plan, i, err)
        if len(err) > 0:
            return false
        if !PrimaryObjectPlanColdCsgV2AppendRecord(parts, 7, payload, err):
            return false
    for i in 0..<plan.dataRelocSourceItemIds.len:
        let payload = Fmt"{PrimaryObjectPlanColdCsgV2U32LeHex(plan.dataRelocSourceItemIds[i])}{PrimaryObjectPlanColdCsgV2U32LeHex(plan.dataRelocWordOffsets[i])}{PrimaryObjectPlanColdCsgV2U32LeHex(1)}{PrimaryObjectPlanColdCsgV2U32LeHex(0)}{PrimaryObjectPlanColdCsgV2StringPayload(plan.dataRelocTargetSymbols[i])}"
        if !PrimaryObjectPlanColdCsgV2AppendRecord(parts, 8, payload, err):
            return false
    out = strutil.Join(parts, "")
    return true

fn PrimaryObjectPlanIntListText(items: int32[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if i > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{strings.IntToStr(items[i])}"
    return out

fn PrimaryObjectPlanAppendLine(out: var str, key: str, value: str) =
    out = Fmt"{out}{key}={value}\n"

fn PrimaryObjectPlanReport(plan: PrimaryObjectPlan): str =
    var symbolText = "-"
    if plan.symbolNames.len > 0:
        symbolText = strutil.Join(plan.symbolNames, ",")
    var bodyKindText = "-"
    if plan.functionBodyKinds.len > 0:
        bodyKindText = strutil.Join(plan.functionBodyKinds, ",")
    var statementReturnModeText = "-"
    if plan.functionStatementReturnModes.len > 0:
        statementReturnModeText = PrimaryObjectPlanIntListText(plan.functionStatementReturnModes)
    var statementCallCountText = "-"
    if plan.functionStatementCallCounts.len > 0:
        statementCallCountText = PrimaryObjectPlanIntListText(plan.functionStatementCallCounts)
    var wordOffsetText = "-"
    if plan.functionWordOffsets.len > 0:
        wordOffsetText = PrimaryObjectPlanIntListText(plan.functionWordOffsets)
    var wordCountText = "-"
    if plan.functionWordCounts.len > 0:
        wordCountText = PrimaryObjectPlanIntListText(plan.functionWordCounts)
    var firstMissingFunction = "-"
    if len(plan.error.functionName) > 0:
        firstMissingFunction = plan.error.functionName
    var firstMissingBodyKind = "-"
    if len(plan.error.bodyKind) > 0:
        firstMissingBodyKind = plan.error.bodyKind
    var firstMissingTypedIrKind = "-"
    if len(plan.error.typedIrKind) > 0:
        firstMissingTypedIrKind = plan.error.typedIrKind
    var out = ""
    PrimaryObjectPlanAppendLine(out, "primary_object_format", plan.objectFormat)
    PrimaryObjectPlanAppendLine(out, "primary_object_item_count", strings.IntToStr(plan.itemIds.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_reachable_function_count", strings.IntToStr(plan.reachableFunctionCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_symbols", symbolText)
    PrimaryObjectPlanAppendLine(out, "primary_object_body_kinds", bodyKindText)
    PrimaryObjectPlanAppendLine(out, "primary_object_statement_return_modes", statementReturnModeText)
    PrimaryObjectPlanAppendLine(out, "primary_object_statement_call_counts", statementCallCountText)
    PrimaryObjectPlanAppendLine(out, "primary_object_word_offsets", wordOffsetText)
    PrimaryObjectPlanAppendLine(out, "primary_object_word_counts", wordCountText)
    PrimaryObjectPlanAppendLine(out, "primary_object_instruction_word_count", strings.IntToStr(plan.instructionWords.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_data_label_count", strings.IntToStr(plan.dataLabels.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_reloc_count", strings.IntToStr(plan.relocSourceItemIds.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_data_reloc_count", strings.IntToStr(plan.dataRelocSourceItemIds.len))
    PrimaryObjectPlanAppendLine(out, "primary_object_entry_function_symbol", plan.entryFunctionSymbol)
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_layout_count", strings.IntToStr(plan.typedIrTypeLayoutCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_field_count", strings.IntToStr(plan.typedIrTypeFieldCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_field_source_path_count", strings.IntToStr(plan.typedIrTypeFieldSourcePathCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_field_name_count", strings.IntToStr(plan.typedIrTypeFieldNameCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_field_type_count", strings.IntToStr(plan.typedIrTypeFieldTypeCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_field_offset_count", strings.IntToStr(plan.typedIrTypeFieldOffsetCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_field_size_count", strings.IntToStr(plan.typedIrTypeFieldSizeCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_field_align_count", strings.IntToStr(plan.typedIrTypeFieldAlignCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_type_def_alias_count", strings.IntToStr(plan.typedIrTypeDefAliasCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_cheng_mem_header_ptr_alias_count", strings.IntToStr(plan.typedIrChengMemHeaderPtrAliasCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_cold_csg_type_row_count", strings.IntToStr(plan.typedIrColdCsgTypeRowCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_local_binding_count", strings.IntToStr(plan.typedIrLocalBindingCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_cheng_mem_header_rc_field_count", strings.IntToStr(plan.typedIrChengMemHeaderRcFieldCount))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_cheng_mem_header_rc_field_type", plan.typedIrChengMemHeaderRcFieldType)
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_cheng_mem_header_rc_field_offset", strings.IntToStr(plan.typedIrChengMemHeaderRcFieldOffset))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_cheng_mem_header_rc_field_size", strings.IntToStr(plan.typedIrChengMemHeaderRcFieldSize))
    PrimaryObjectPlanAppendLine(out, "primary_object_typed_ir_cheng_mem_header_rc_field_align", strings.IntToStr(plan.typedIrChengMemHeaderRcFieldAlign))
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_function", firstMissingFunction)
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_body_kind", firstMissingBodyKind)
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_typed_ir_kind", firstMissingTypedIrKind)
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_line_number", strings.IntToStr(plan.error.lineNumber))
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_call_target_ordinal", strings.IntToStr(plan.error.callTargetOrdinal))
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_call_target", plan.error.callTarget)
    PrimaryObjectPlanAppendLine(out, "primary_object_first_missing_call_target_source_path", plan.error.callTargetSourcePath)
    PrimaryObjectPlanAppendLine(out, "primary_object_missing_reasons", slplan.SystemLinkPlanListText(plan.missingReasons))
    out = Fmt"{out}primary_object_pipeline_stage={plan.pipelineStage}"
    return out

fn PrimaryObjectPlanEmitCsgV2BinaryU16(out: var uint8[], v: int32) =
    add(out, uint8(v & 0xFF))
    add(out, uint8((v >> 8) & 0xFF))

fn PrimaryObjectPlanEmitCsgV2BinaryU32(out: var uint8[], v: int32) =
    add(out, uint8(v & 0xFF))
    add(out, uint8((v >> 8) & 0xFF))
    add(out, uint8((v >> 16) & 0xFF))
    add(out, uint8((v >> 24) & 0xFF))

fn PrimaryObjectPlanEmitCsgV2BinaryString(out: var uint8[], text: str) =
    PrimaryObjectPlanEmitCsgV2BinaryU32(out, len(text))
    for i in 0..<len(text):
        add(out, uint8(int32(text[i])))

fn PrimaryObjectPlanEmitCsgV2BinaryFacts(plan: PrimaryObjectPlan,
                                          targetTriple: str): uint8[] =
    var buf: uint8[]
    # Magic: "CHENGCSG" (8 bytes)
    add(buf, uint8(0x43))
    add(buf, uint8(0x48))
    add(buf, uint8(0x45))
    add(buf, uint8(0x4E))
    add(buf, uint8(0x47))
    add(buf, uint8(0x43))
    add(buf, uint8(0x53))
    add(buf, uint8(0x47))
    # Record kind 1: target triple
    PrimaryObjectPlanEmitCsgV2BinaryU16(buf, 1)
    PrimaryObjectPlanEmitCsgV2BinaryU32(buf, 4 + len(targetTriple))
    PrimaryObjectPlanEmitCsgV2BinaryString(buf, targetTriple)
    # Record kind 2: object format
    PrimaryObjectPlanEmitCsgV2BinaryU16(buf, 2)
    PrimaryObjectPlanEmitCsgV2BinaryU32(buf, 4 + len(plan.objectFormat))
    PrimaryObjectPlanEmitCsgV2BinaryString(buf, plan.objectFormat)
    # Record kind 3: entry symbol
    PrimaryObjectPlanEmitCsgV2BinaryU16(buf, 3)
    PrimaryObjectPlanEmitCsgV2BinaryU32(buf, 4 + len(plan.entrySymbol))
    PrimaryObjectPlanEmitCsgV2BinaryString(buf, plan.entrySymbol)
    # Record kind 4: functions
    for i in 0..<plan.itemIds.len:
        let funcPayloadSize = 12 + 4 + len(plan.symbolNames[i]) + 4 + len(plan.functionBodyKinds[i])
        PrimaryObjectPlanEmitCsgV2BinaryU16(buf, 4)
        PrimaryObjectPlanEmitCsgV2BinaryU32(buf, funcPayloadSize)
        PrimaryObjectPlanEmitCsgV2BinaryU32(buf, plan.itemIds[i])
        PrimaryObjectPlanEmitCsgV2BinaryU32(buf, plan.functionWordOffsets[i])
        PrimaryObjectPlanEmitCsgV2BinaryU32(buf, plan.functionWordCounts[i])
        PrimaryObjectPlanEmitCsgV2BinaryString(buf, plan.symbolNames[i])
        PrimaryObjectPlanEmitCsgV2BinaryString(buf, plan.functionBodyKinds[i])
    # Record kind 5: instruction words (batched)
    if plan.instructionWords.len > 0:
        PrimaryObjectPlanEmitCsgV2BinaryU16(buf, 5)
        PrimaryObjectPlanEmitCsgV2BinaryU32(buf, plan.instructionWords.len * 4)
        for i in 0..<plan.instructionWords.len:
            PrimaryObjectPlanEmitCsgV2BinaryU32(buf, plan.instructionWords[i])
    # Record kind 6: relocs
    for i in 0..<plan.relocSourceItemIds.len:
        let relPayloadSize = 8 + 4 + len(plan.relocTargetSymbols[i])
        PrimaryObjectPlanEmitCsgV2BinaryU16(buf, 6)
        PrimaryObjectPlanEmitCsgV2BinaryU32(buf, relPayloadSize)
        PrimaryObjectPlanEmitCsgV2BinaryU32(buf, plan.relocSourceItemIds[i])
        PrimaryObjectPlanEmitCsgV2BinaryU32(buf, plan.relocWordOffsets[i])
        PrimaryObjectPlanEmitCsgV2BinaryString(buf, plan.relocTargetSymbols[i])
    return buf

# ============================================================
# BodyIR-based section-binary CSG v2 writer
# Matches cold_csg_v2_format.h exactly: HEADER + SECTION INDEX
# + FUNCTION section + STRING section + TRAILER
# ============================================================

fn PrimaryBodyIrEmitCsgV2BinaryWord(buf: var uint8[], v: int32) =
    PrimaryObjectPlanEmitCsgV2BinaryU32(buf, v)

fn PrimaryBodyIrEmitCsgV2BinaryU32(buf: var uint8[], v: int32) =
    PrimaryObjectPlanEmitCsgV2BinaryU32(buf, v)

fn PrimaryBodyIrEmitCsgV2BinaryStr(buf: var uint8[], s: str) =
    PrimaryObjectPlanEmitCsgV2BinaryString(buf, s)

fn PrimaryBodyIrEmitCsgV2BinaryFindStringId(
    symbols: str[],
    baseId: int32,
    target: str,
): int32 =
    for j in 0..<symbols.len:
        if symbols[j] == target:
            return baseId + j
    return 0

fn PrimaryBodyIrEmitCsgV2BinaryFacts(
    bodyIR: coreir.BodyIR,
    functionName: str,
    targetTriple: str,
): uint8[] =
    var buf: uint8[]

    # Phase 1: collect unique call target symbols (dedup)
    var callTargetSymbols: str[]
    for ci in 0..<bodyIR.callSequence.len:
        let sym = bodyIR.callSequence[ci].targetSymbol
        var found = false
        for si in 0..<callTargetSymbols.len:
            if callTargetSymbols[si] == sym:
                found = true
                break
        if !found:
            add(callTargetSymbols, sym)

    let cstrCount = bodyIR.cstringLiterals.len

    # ------- HEADER (64 bytes) -------
    let magic = "CHENGCSG"
    for i in 0..<8:
        add(buf, uint8(int32(magic[i])))
    # version = 2 (u32 LE)
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 2)
    # target_triple: 32 bytes, null-padded
    let ttl = len(targetTriple)
    for i in 0..<32:
        add(buf, if i < ttl: uint8(int32(targetTriple[i])) else: uint8(0))
    # abi = 0 (u32 LE)
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 0)
    # pointer_width = 8 (u8)
    add(buf, uint8(8))
    # endianness = 0 LE (u8)
    add(buf, uint8(0))
    # reserved (14 bytes, total header = 64)
    for i in 0..<14:
        add(buf, uint8(0))

    # ------- SECTION INDEX placeholder -------
    # section_count(u32) + N * (kind(u32)+offset(u64)+size(u32))
    let sectionIndexStart = int32(buf.len)
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 2)  # 2 sections: function + string

    # Section index entry 0: function section (kind=1)
    let entry0KindPos = int32(buf.len)
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 1)
    let entry0OffPos = int32(buf.len)
    for i in 0..<8:
        add(buf, uint8(0))
    let entry0SizePos = int32(buf.len)
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 0)

    # Section index entry 1: string section (kind=5)
    let entry1KindPos = int32(buf.len)
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 5)
    let entry1OffPos = int32(buf.len)
    for i in 0..<8:
        add(buf, uint8(0))
    let entry1SizePos = int32(buf.len)
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 0)

    # ------- FUNCTION SECTION (kind=1) -------
    let functionSectionStart = int32(buf.len)

    # fn_count = 1
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 1)

    # Function name
    PrimaryBodyIrEmitCsgV2BinaryStr(buf, functionName)

    # param_count
    var paramCount: int32
    for li in 0..<bodyIR.localSlots.len:
        if bodyIR.localSlots[li].placeKind == coreir.BodyPlaceParamAddressTag:
            paramCount = paramCount + 1
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, paramCount)

    # params: each = kind(u32) size(u32) slot_index(u32) = 12 bytes
    for li in 0..<bodyIR.localSlots.len:
        if bodyIR.localSlots[li].placeKind == coreir.BodyPlaceParamAddressTag:
            let slot = bodyIR.localSlots[li]
            PrimaryBodyIrEmitCsgV2BinaryU32(buf, slot.typeKind)
            PrimaryBodyIrEmitCsgV2BinaryU32(buf, slot.sizeBytes)
            PrimaryBodyIrEmitCsgV2BinaryU32(buf, slot.id)

    # return_kind: type of the return term's result slot
    var returnKind: int32
    for ti in 0..<bodyIR.terms.len:
        if bodyIR.terms[ti].kind == coreir.BodyTermReturnTag:
            let retSlot = bodyIR.terms[ti].resultSlot
            if retSlot >= 0 && retSlot < bodyIR.localSlots.len:
                returnKind = bodyIR.localSlots[retSlot].typeKind
            break
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, returnKind)

    # frame_size = max(stackOffset + sizeBytes) across all locals
    var maxFrameOffset: int32
    for li in 0..<bodyIR.localSlots.len:
        let slotEnd = bodyIR.localSlots[li].stackOffset + bodyIR.localSlots[li].sizeBytes
        if slotEnd > maxFrameOffset:
            maxFrameOffset = slotEnd
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, maxFrameOffset)

    # op_count + ops
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, bodyIR.ops.len)
    for oi in 0..<bodyIR.ops.len:
        let op = bodyIR.ops[oi]
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, op.kind)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, op.target)
        let opA = if op.operands.len > 0: op.operands[0] else: 0
        let opB = if op.operands.len > 1: op.operands[1] else: 0
        let opC = if op.operands.len > 2: op.operands[2] else: 0
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, opA)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, opB)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, opC)

    # slot_count + slots
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, bodyIR.localSlots.len)
    for li in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[li]
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, slot.typeKind)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, slot.stackOffset)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, slot.sizeBytes)

    # block_count + blocks
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, bodyIR.blocks.len)
    for bi in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[bi]
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, block.opStart)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, block.opCount)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, block.termIndex)

    # term_count + terms
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, bodyIR.terms.len)
    for ti in 0..<bodyIR.terms.len:
        let term = bodyIR.terms[ti]
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, term.kind)
        # value: Return -> resultSlot, else first operand
        let termValue = if term.kind == coreir.BodyTermReturnTag: term.resultSlot
                        elif term.operands.len > 0: term.operands[0]
                        else: 0
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, termValue)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, 0)   # case_start
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, 0)   # case_count
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, term.trueBlock)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, term.falseBlock)

    # switch_count = 0 (no switch support yet)
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 0)

    # call_count
    let callCount = bodyIR.callSequence.len
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, callCount)

    # Pre-count flat call args
    var flatCallArgCount: int32
    for ci in 0..<callCount:
        flatCallArgCount = flatCallArgCount + bodyIR.callSequence[ci].argSlots.len

    # calls
    var argStart: int32
    for ci in 0..<callCount:
        let call = bodyIR.callSequence[ci]
        let targetId = PrimaryBodyIrEmitCsgV2BinaryFindStringId(
            callTargetSymbols, cstrCount, call.targetSymbol)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, targetId)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, argStart)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, call.argSlots.len)
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, call.resultSlot)
        argStart = argStart + call.argSlots.len

    # call_arg_count + call_args
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, flatCallArgCount)
    for ci in 0..<callCount:
        let call = bodyIR.callSequence[ci]
        for ai in 0..<call.argSlots.len:
            let argSlotIdx = call.argSlots[ai]
            let argOffset = if argSlotIdx >= 0 && argSlotIdx < bodyIR.localSlots.len:
                               bodyIR.localSlots[argSlotIdx].stackOffset
                            else: 0
            PrimaryBodyIrEmitCsgV2BinaryU32(buf, argSlotIdx)
            PrimaryBodyIrEmitCsgV2BinaryU32(buf, argOffset)

    # str_lit_count + str_lits
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, cstrCount)
    for li in 0..<cstrCount:
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, bodyIR.cstringLiterals[li].id)

    let functionSectionEnd = int32(buf.len)
    let functionSectionSize = functionSectionEnd - functionSectionStart

    # ------- STRING SECTION (kind=5) -------
    let stringSectionStart = int32(buf.len)
    let stringCount = cstrCount + callTargetSymbols.len
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, stringCount)

    # CStringLiteralEntry texts: each = id(u32) len(u32) + utf8
    for li in 0..<cstrCount:
        let literal = bodyIR.cstringLiterals[li]
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, literal.id)
        PrimaryBodyIrEmitCsgV2BinaryStr(buf, literal.text)

    # Call target symbol names: each = id(u32) len(u32) + utf8
    for si in 0..<callTargetSymbols.len:
        PrimaryBodyIrEmitCsgV2BinaryU32(buf, cstrCount + si)
        PrimaryBodyIrEmitCsgV2BinaryStr(buf, callTargetSymbols[si])

    let stringSectionEnd = int32(buf.len)
    let stringSectionSize = stringSectionEnd - stringSectionStart

    # ------- Patch SECTION INDEX with real offsets -------
    # Entry 0 (function): offset(u64) at entry0OffPos
    let funcOff = functionSectionStart
    buf[entry0OffPos]     = uint8(funcOff & 0xFF)
    buf[entry0OffPos + 1] = uint8((funcOff >> 8) & 0xFF)
    buf[entry0OffPos + 2] = uint8((funcOff >> 16) & 0xFF)
    buf[entry0OffPos + 3] = uint8((funcOff >> 24) & 0xFF)
    buf[entry0OffPos + 4] = uint8(0)
    buf[entry0OffPos + 5] = uint8(0)
    buf[entry0OffPos + 6] = uint8(0)
    buf[entry0OffPos + 7] = uint8(0)
    # Entry 0: size(u32) at entry0SizePos
    let funcSz = functionSectionSize
    buf[entry0SizePos]     = uint8(funcSz & 0xFF)
    buf[entry0SizePos + 1] = uint8((funcSz >> 8) & 0xFF)
    buf[entry0SizePos + 2] = uint8((funcSz >> 16) & 0xFF)
    buf[entry0SizePos + 3] = uint8((funcSz >> 24) & 0xFF)

    # Entry 1 (string): offset(u64) at entry1OffPos
    let strOff = stringSectionStart
    buf[entry1OffPos]     = uint8(strOff & 0xFF)
    buf[entry1OffPos + 1] = uint8((strOff >> 8) & 0xFF)
    buf[entry1OffPos + 2] = uint8((strOff >> 16) & 0xFF)
    buf[entry1OffPos + 3] = uint8((strOff >> 24) & 0xFF)
    buf[entry1OffPos + 4] = uint8(0)
    buf[entry1OffPos + 5] = uint8(0)
    buf[entry1OffPos + 6] = uint8(0)
    buf[entry1OffPos + 7] = uint8(0)
    # Entry 1: size(u32) at entry1SizePos
    let strSz = stringSectionSize
    buf[entry1SizePos]     = uint8(strSz & 0xFF)
    buf[entry1SizePos + 1] = uint8((strSz >> 8) & 0xFF)
    buf[entry1SizePos + 2] = uint8((strSz >> 16) & 0xFF)
    buf[entry1SizePos + 3] = uint8((strSz >> 24) & 0xFF)

    # ------- TRAILER (32 bytes) -------
    # section_count = 2 (u32) + hash 28 zero bytes
    PrimaryBodyIrEmitCsgV2BinaryU32(buf, 2)
    for i in 0..<28:
        add(buf, uint8(0))

    return buf

fn PrimaryObjectPlanWriteCsgV2BinaryFacts(path: str, plan: PrimaryObjectPlan, target: str) =
    if plan.functionBodyIRs.len <= 0:
        return
    let functionName = if plan.symbolNames.len > 0: plan.symbolNames[0] else: ""
    let facts = PrimaryBodyIrEmitCsgV2BinaryFacts(
        plan.functionBodyIRs[0], functionName, target)
    os.WriteFileBytes(path, facts)
