    return firstCallOp.operands[0] == 0 &&
           secondCallOp.operands[0] == 1 &&
           bodyIR.localSlots[resultSlot].typeKind == coreir.LocalAggregateTag &&
           bodyIR.localSlots[resultSlot].sizeBytes == 232 &&
           PrimaryBodyIrStackByteCount(bodyIR) == 256 &&
           bodyIR.callSequence[1].argSlots[0] < 0 &&
           bodyIR.callSequence[1].argSlots[1] == resultSlot &&
           returnOp.operands[0] == coreir.LocalI32Tag

