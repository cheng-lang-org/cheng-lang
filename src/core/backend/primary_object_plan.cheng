    PrimarySetInstructionWord(words, wordOffset + 2, -1811939328)
    PrimarySetInstructionWord(words, wordOffset + 3, PrimaryMovI32ConstWord(value))
    PrimarySetInstructionWord(words, wordOffset + 4, -1463714819)
    PrimarySetInstructionWord(words, wordOffset + 5, -698416192)

