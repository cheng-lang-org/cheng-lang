fn PrimaryTargetSymbolName(targetTriple: str,
                             raw: str): str =
    if targetTriple == "arm64-apple-darwin" ||
       targetTriple == "aarch64-apple-ios" ||
       targetTriple == "arm64-apple-ios":
        if len(raw) > 0 && raw[0] == '_':
            return raw
        if len(raw) >= 2 && raw[0] == 'L' && raw[1] == '_':
            return raw
        return Fmt"_{raw}"
    return raw


fn PrimarySanitizeSymbolPart(text: str): str =
    var out = ""
    for i in 0..<len(text):
        let ch = text[i]
        let digit = int32(ch) >= '0' && int32(ch) <= '9'
        let upper = int32(ch) >= 'A' && int32(ch) <= 'Z'
        let lower = int32(ch) >= 'a' && int32(ch) <= 'z'
        if digit || upper || lower || ch == '_':
            out = Fmt"{out}{strings.SliceBytes(text, i, 1)}"
        else:
            out = Fmt"{out}_"
    return out


fn PrimarySymbolNameForFunction(targetTriple: str,
                                  symbolText: str,
                                  signatureLineNumber: int32,
                                  emitKind: creq.CompilerEmit): str =
    var raw = symbolText
    var lineScoped = false
    if len(raw) == 0:
        raw = "cheng_primary_unnamed"
    if len(raw) >= 2:
        for i in 0..<(len(raw) - 1):
            if raw[i] == ':' && raw[i + 1] == ':':
                lineScoped = true
    raw = PrimarySanitizeSymbolPart(raw)
    if lineScoped && signatureLineNumber > 0:
        raw = Fmt"{raw}__L{strings.IntToStr(signatureLineNumber)}"
    return PrimaryTargetSymbolName(targetTriple, raw)


fn PrimaryRuntimeEntryBridgeSymbol(linkPlan: slplan.SystemLinkPlanStub): str =
    var raw = "cheng_program_argv_entry"
    if linkPlan.moduleKind == slplan.SystemCompilerControlPlane:
        raw = "cheng_tooling_argv_entry"
    return PrimaryTargetSymbolName(linkPlan.targetTriple, raw)


fn PrimaryStartsWith(text: str,
                      prefix: str): bool =
    if len(prefix) > len(text):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true


fn PrimaryPathTrimStart(text: str): int32 =
    var start: int32
    while start < len(text):
        let code = Int32(text[start])
        if code != 32 && code != 9 && code != 10 && code != 13:
            break
        start = start + 1
    return start


fn PrimaryPathTrimStop(text: str,
                         start: int32): int32 =
    var stop = len(text)
    while stop > start:
        let code = Int32(text[stop - 1])
        if code != 32 && code != 9 && code != 10 && code != 13:
            break
        stop = stop - 1
    return stop


fn PrimaryPathNormalizedStop(text: str,
                               start: int32,
                               stopRaw: int32): int32 =
    var stop = stopRaw
    while stop > start + 1:
        let last = text[stop - 1]
        if last != '/' && last != '\\':
            break
        stop = stop - 1
    return stop


fn PrimaryPathNormalizedEquals(left: str,
                                 right: str): bool =
    let leftStart = PrimaryPathTrimStart(left)
    let rightStart = PrimaryPathTrimStart(right)
    let leftStop = PrimaryPathNormalizedStop(left, leftStart, PrimaryPathTrimStop(left, leftStart))
    let rightStop = PrimaryPathNormalizedStop(right, rightStart, PrimaryPathTrimStop(right, rightStart))
    let leftLen = leftStop - leftStart
    let rightLen = rightStop - rightStart
    if leftLen != rightLen:
        return false
    for i in 0..<leftLen:
        if left[leftStart + i] != right[rightStart + i]:
            return false
    return true


fn PrimaryFunctionTailName(functionName: str): str =
    var tailStart = 0
    if len(functionName) >= 2:
        for j in 0..<(len(functionName) - 1):
            if functionName[j] == ':' && functionName[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < len(functionName):
        return strings.SliceBytes(functionName, tailStart, len(functionName) - tailStart)
    return functionName


fn PrimaryCallTargetTailName(targetText: str): str =
    var tailStart = 0
    for i in 0..<len(targetText):
        if targetText[i] == '.':
            tailStart = i + 1
    if len(targetText) >= 2:
        for j in 0..<(len(targetText) - 1):
            if targetText[j] == ':' && targetText[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < len(targetText):
        return strings.SliceBytes(targetText, tailStart, len(targetText) - tailStart)
    return targetText


fn PrimaryObjectIrFunctionIndex(ir: lower.PrimaryObjectIr,
                                  sourcePath: str,
                                  functionName: str): int32 =
    let tailName = PrimaryFunctionTailName(functionName)
    for i in 0..<ir.functions.len:
        if !PrimaryPathNormalizedEquals(ir.functions[i].sourcePath, sourcePath):
            continue
        if ir.functions[i].functionName == functionName ||
           ir.functions[i].functionName == tailName:
            return i
    return -1

fn PrimaryFunctionTargetSymbol(functionSymbolTexts: str[],
                                 functionSourcePaths: str[],
                                 allSymbolNames: str[],
                                 targetSourcePath: str,
                                 targetText: str): str =
    let targetTail = PrimaryCallTargetTailName(targetText)
    for i in 0..<functionSymbolTexts.len:
        if i >= functionSourcePaths.len:
            continue
        if !PrimaryPathNormalizedEquals(functionSourcePaths[i], targetSourcePath):
            continue
        if i >= allSymbolNames.len:
            continue
        if functionSymbolTexts[i] == targetText ||
           PrimaryFunctionTailName(functionSymbolTexts[i]) == targetTail:
            return allSymbolNames[i]
    return ""

fn PrimaryFunctionTargetIndex(functionSymbolTexts: str[],
                               functionSourcePaths: str[],
                               targetSourcePath: str,
                               targetText: str): int32 =
    let targetTail = PrimaryCallTargetTailName(targetText)
    for i in 0..<functionSymbolTexts.len:
        if i >= functionSourcePaths.len:
            continue
        if !PrimaryPathNormalizedEquals(functionSourcePaths[i], targetSourcePath):
            continue
        if functionSymbolTexts[i] == targetText ||
           PrimaryFunctionTailName(functionSymbolTexts[i]) == targetTail:
            return i
    return -1

fn PrimaryBoolSeqInit(count: int32,
                       value: bool): bool[] =
    var out: bool[]
    for _ in 0..<count:
        add(out, value)
    return out

fn PrimaryIntSeqInit(count: int32,
                      value: int32): int32[] =
    var out: int32[]
    for _ in 0..<count:
        add(out, value)
    return out

fn PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind: str): bool =
    return PrimaryStartsWith(bodyKind, texpr.BodyKindLetCallNoargReturnI32ConstPrefix)

fn PrimaryStatementReturnModeNone(): int32 =
    return 0

fn PrimaryStatementReturnModeI32Const(): int32 =
    return 1

fn PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len <= 0:
        return false
    if bodyIR.ops.len <= 0:
        return false
    let lastIndex = bodyIR.ops.len - 1
    let lastOp = bodyIR.ops[lastIndex]
    if lastOp.kind != coreir.BodyOpReturnTag:
        return false
    if lastOp.operands.len <= 0:
        return false
    if lastOp.operands[0] == coreir.LocalI32Tag:
        return true
    if lastOp.operands[0] == PrimaryStatementReturnModeI32Const():
        return true
    return false

fn PrimaryBodyIrIsI32TwoCallGuardFirstReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.ops.len != 4 || bodyIR.callSequence.len != 2:
        return false
    if bodyIR.ops[0].kind != coreir.BodyOpCallTag ||
       bodyIR.ops[1].kind != coreir.BodyOpCallTag ||
       bodyIR.ops[2].kind != coreir.BodyOpBranchTag ||
       bodyIR.ops[3].kind != coreir.BodyOpReturnTag:
        return false
    if bodyIR.ops[0].operands.len < 1 ||
       bodyIR.ops[1].operands.len < 1 ||
       bodyIR.ops[2].operands.len < 3 ||
       bodyIR.ops[3].operands.len < 1:
        return false
    if bodyIR.ops[0].operands[0] != 0 ||
       bodyIR.ops[1].operands[0] != 1:
        return false
    if bodyIR.ops[2].operands[0] != coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag:
        return false
    return bodyIR.ops[3].operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsI32GuardThenCommandReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.ops.len != 4 || bodyIR.callSequence.len != 2:
        return false
    if bodyIR.ops[0].kind != coreir.BodyOpCallTag ||
       bodyIR.ops[1].kind != coreir.BodyOpBranchTag ||
       bodyIR.ops[2].kind != coreir.BodyOpCallTag ||
       bodyIR.ops[3].kind != coreir.BodyOpReturnTag:
        return false
    if bodyIR.ops[0].operands.len < 1 ||
       bodyIR.ops[1].operands.len < 3 ||
       bodyIR.ops[2].operands.len < 1 ||
       bodyIR.ops[3].operands.len < 1:
        return false
    if bodyIR.ops[0].operands[0] != 0 ||
       bodyIR.ops[2].operands[0] != 1:
        return false
    if bodyIR.ops[1].operands[0] != coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag:
        return false
    return bodyIR.ops[3].operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsI32GuardHelpThenCommandReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.ops.len != 4 || bodyIR.callSequence.len != 3:
        return false
    if bodyIR.ops[0].kind != coreir.BodyOpCallTag ||
       bodyIR.ops[1].kind != coreir.BodyOpBranchTag ||
       bodyIR.ops[2].kind != coreir.BodyOpCallTag ||
       bodyIR.ops[3].kind != coreir.BodyOpReturnTag:
        return false
    if bodyIR.ops[0].operands.len < 1 ||
       bodyIR.ops[1].operands.len < 3 ||
       bodyIR.ops[2].operands.len < 1 ||
       bodyIR.ops[3].operands.len < 1:
        return false
    if bodyIR.ops[0].operands[0] != 0 ||
       bodyIR.ops[2].operands[0] != 2:
        return false
    if bodyIR.ops[1].operands[0] != coreir.BodyBranchIfLocalLeZeroReturnCallNoargTag:
        return false
    return bodyIR.ops[3].operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsStrCallConstThenCallArg0ReturnI32(bodyIR: coreir.BodyIR): bool =
    if bodyIR.ops.len != 3 || bodyIR.callSequence.len != 2:
        return false
    if bodyIR.ops[0].kind != coreir.BodyOpCallTag ||
       bodyIR.ops[1].kind != coreir.BodyOpCallTag ||
       bodyIR.ops[2].kind != coreir.BodyOpReturnTag:
        return false
    if bodyIR.ops[0].operands.len < 1 ||
       bodyIR.ops[1].operands.len < 1 ||
       bodyIR.ops[2].operands.len < 1:
        return false
    if bodyIR.ops[0].operands[0] != 0 ||
       bodyIR.ops[1].operands[0] != 1:
        return false
    if bodyIR.ops[0].target < 0 ||
       bodyIR.ops[0].target >= bodyIR.localSlots.len:
        return false
    if bodyIR.localSlots[bodyIR.ops[0].target].typeKind != coreir.LocalStrTag:
        return false
    return bodyIR.ops[2].operands[0] == coreir.LocalI32Tag

fn PrimaryStatementReturnModeCallResultI32(): int32 =
    return 2

fn PrimaryStatementReturnModeI32GuardResultLeZero(): int32 =
    return 3

fn PrimaryStatementReturnModeStrLen(): int32 =
    return 4

fn PrimaryStatementReturnModeStrThenCallReturnI32Const0(): int32 =
    return 5

fn PrimaryStatementReturnModeStrI32GuardArg0Return0(): int32 =
    return 6

fn PrimaryStatementReturnModeStrI32GuardArg0ElseCallArg0Arg1ReturnResultI32(): int32 =
    return 7

fn PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0(): int32 =
    return texpr.StatementReturnModeCstringLiteralCallsReturnI32Const0

fn PrimaryBodyIrGeneralCfgWordCount(bodyIR: coreir.BodyIR): int32 =
    let frameBytes = PrimaryBodyIrFrameBytes(bodyIR)
    if frameBytes <= 0:
        return 0
    var count = PrimaryBodyIrPrologueWordCount(bodyIR)
    for i in 0..<bodyIR.ops.len:
        let opSize = PrimaryBodyIROpSizeAt(bodyIR, i)
        if opSize <= 0:
            return 0
        count = count + opSize
    for i in 0..<bodyIR.terms.len:
        let termSize = PrimaryBodyIRTermSize(bodyIR, i)
        if termSize <= 0:
            return 0
        count = count + termSize
    return count

fn PrimaryBodyIrCharLiteralValue(textRaw: str): int32 =
    let text = strutil.Strip(textRaw)
    if len(text) < 3 || text[0] != '\'' || text[len(text) - 1] != '\'':
        return -1
    let payloadLen = len(text) - 2
    if payloadLen == 1:
        return int32(text[1])
    if payloadLen == 2 && text[1] == '\\':
        let esc = text[2]
        if esc == 'n':
            return 10
        if esc == 'r':
            return 13
        if esc == 't':
            return 9
        if esc == '0':
            return 0
        return int32(esc)
    return -1

fn PrimaryBodyIrExtractIntFromText(textRaw: str): int32 =
    let text = strutil.Strip(textRaw)
    let charValue = PrimaryBodyIrCharLiteralValue(text)
    if charValue >= 0:
        return charValue
    let int32Inner = PrimaryBodyIrWholeCallInnerForHead(text, "int32")
    if int32Inner != "":
        return PrimaryBodyIrExtractIntFromText(int32Inner)
    let int64Inner = PrimaryBodyIrWholeCallInnerForHead(text, "int64")
    if int64Inner != "":
        return PrimaryBodyIrExtractIntFromText(int64Inner)
    let uint8Inner = PrimaryBodyIrWholeCallInnerForHead(text, "uint8")
    if uint8Inner != "":
        return PrimaryBodyIrExtractIntFromText(uint8Inner)
    let uint64Inner = PrimaryBodyIrWholeCallInnerForHead(text, "uint64")
    if uint64Inner != "":
        return PrimaryBodyIrExtractIntFromText(uint64Inner)
    if text == "":
        return 0
    var sign: int32 = 1
    var start: int32
    if text[0] == '-':
        sign = -1
        start = 1
    if start >= len(text):
        return 0
    var out: int32
    for i in start..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return 0
        out = out * 10 + int32(ch) - int32('0')
    if sign < 0:
        return 0 - out
    return out

fn PrimaryBodyIrParseCondition(
    conditionText: str,
    var lhsText: str,
    var rhsText: str,
    var cmpTag: int32
): bool =
    var opPos: int32 = -1
    var opLen: int32
    var tag: int32
    for i in 0..<len(conditionText):
        let ch = conditionText[i]
        if ch == '=' && i + 1 < len(conditionText) && conditionText[i + 1] == '=':
            opPos = i; opLen = 2; tag = coreir.BodyCondI32EqTag; break
        if ch == '!' && i + 1 < len(conditionText) && conditionText[i + 1] == '=':
            opPos = i; opLen = 2; tag = coreir.BodyCondI32NeTag; break
        if ch == '<' && i + 1 < len(conditionText) && conditionText[i + 1] == '=':
            opPos = i; opLen = 2; tag = coreir.BodyCondI32LeTag; break
        if ch == '>' && i + 1 < len(conditionText) && conditionText[i + 1] == '=':
            opPos = i; opLen = 2; tag = coreir.BodyCondI32GeTag; break
        if ch == '<' && (i + 1 >= len(conditionText) || conditionText[i + 1] != '='):
            opPos = i; opLen = 1; tag = coreir.BodyCondI32LtTag; break
        if ch == '>' && (i + 1 >= len(conditionText) || conditionText[i + 1] != '='):
            opPos = i; opLen = 1; tag = coreir.BodyCondI32GtTag; break
    if opPos < 0:
        return false
    lhsText = strings.SliceBytes(conditionText, 0, opPos)
    var lhsEnd = len(lhsText)
    while lhsEnd > 0 && lhsText[lhsEnd - 1] == ' ':
        lhsEnd = lhsEnd - 1
    lhsText = strings.SliceBytes(lhsText, 0, lhsEnd)
    var rhsRaw = strings.SliceBytes(conditionText, opPos + opLen, len(conditionText) - opPos - opLen)
    var rhsStart: int32
    while rhsStart < len(rhsRaw) && rhsRaw[rhsStart] == ' ':
        rhsStart = rhsStart + 1
    rhsText = strings.SliceBytes(rhsRaw, rhsStart, len(rhsRaw) - rhsStart)
    cmpTag = tag
    return true

fn PrimaryBodyIrNextLocalStackOffset(bodyIR: coreir.BodyIR,
                                      sizeBytes: int32,
                                      alignBytes: int32): int32 =
    var offset: int32 = 16
    for i in 0..<bodyIR.localSlots.len:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[i]):
            continue
        let slotSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[i])
        if slotSize <= 0:
            continue
        let slotEnd = bodyIR.localSlots[i].stackOffset + slotSize
        if slotEnd > offset:
            offset = slotEnd
    var align = alignBytes
    if align <= 0:
        align = 1
    if align > 16:
        align = 16
    return ((offset + align - 1) / align) * align

fn PrimaryBodyIrReflowLocalStackOffsets(bodyIR: var coreir.BodyIR) =
    var offset: int32 = 16
    for i in 0..<bodyIR.localSlots.len:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[i]):
            continue
        let slotSize = PrimaryLocalSlotSizeOf(bodyIR.localSlots[i])
        if slotSize <= 0:
            continue
        var align = bodyIR.localSlots[i].alignBytes
        if align <= 0:
            align = 1
        if align > 16:
            align = 16
        offset = ((offset + align - 1) / align) * align
        bodyIR.localSlots[i].stackOffset = offset
        offset = offset + slotSize

fn PrimaryBodyIrLocalSlotNewSized(bodyIR: var coreir.BodyIR,
                                   slotId: int32,
                                   name: str,
                                   typeKind: int32,
                                   sizeBytes: int32,
                                   alignBytes: int32) =
    var ls: coreir.LocalSlot
    ls.id = slotId
    ls.name = name
    ls.typeKind = typeKind
    ls.placeKind = coreir.BodyPlaceStackValueTag
    ls.ownership = coreir.OwnPlainTag
    ls.aliasClass = coreir.AliasUnknownTag
    ls.escapeKind = coreir.EscapeNoneTag
    ls.noAlias = false
    if typeKind == coreir.LocalI32Tag:
        ls.sizeBytes = 4
        ls.alignBytes = 4
    elif typeKind == coreir.LocalI64Tag:
        ls.sizeBytes = 8
        ls.alignBytes = 8
    elif typeKind == coreir.LocalF64Tag:
        ls.sizeBytes = 8
        ls.alignBytes = 8
    elif typeKind == coreir.LocalStrTag:
        ls.sizeBytes = 24
        ls.alignBytes = 8
    elif typeKind == coreir.LocalPtrTag:
        ls.sizeBytes = 8
        ls.alignBytes = 8
    elif typeKind == coreir.LocalAggregateTag:
        ls.sizeBytes = coreir.ResultStrSizeBytes
        ls.alignBytes = coreir.ResultStrAlignBytes
    if sizeBytes > 0:
        ls.sizeBytes = sizeBytes
    if alignBytes > 0:
        ls.alignBytes = alignBytes
    ls.stackOffset = PrimaryBodyIrNextLocalStackOffset(bodyIR, ls.sizeBytes, ls.alignBytes)
    add(bodyIR.localSlots, ls)

fn PrimaryBodyIrLocalSlotNew(bodyIR: var coreir.BodyIR,
                              slotId: int32,
                              name: str,
                              typeKind: int32) =
    PrimaryBodyIrLocalSlotNewSized(bodyIR, slotId, name, typeKind, 0, 0)

fn PrimaryBodyIrTypeKindFromText(typeRaw: str): int32 =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    if PrimaryStartsWith(normType, "var"):
        return coreir.LocalPtrTag
    if PrimaryStartsWith(normType, "ref"):
        return coreir.LocalPtrTag
    if len(normType) > 0 && normType[len(normType) - 1] == '*':
        return coreir.LocalPtrTag
    if normType == "int64" || normType == "uint64" || normType == "u64" || normType == "i64":
        return coreir.LocalI64Tag
    if normType == "float64" || normType == "f64":
        return coreir.LocalF64Tag
    if normType == "str":
        return coreir.LocalStrTag
    if normType == "cstring" || normType == "ptr" || normType == "void*":
        return coreir.LocalPtrTag
    if normType == "Bytes" ||
       normType == "bytes.Bytes" ||
       normType == "rawbytes.Bytes" ||
       normType == "ByteBuffer" ||
       normType == "buffer.ByteBuffer":
        return coreir.LocalAggregateTag
    if PrimaryStartsWith(normType, "Result["):
        return coreir.LocalAggregateTag
    if PrimaryStartsWith(normType, "seq[") ||
       (len(normType) >= 2 && strings.SliceBytes(normType, len(normType) - 2, 2) == "[]"):
        return coreir.LocalAggregateTag
    if len(normType) > 0:
        var leafStart = 0
        for ci in 0..<len(normType):
            if normType[ci] == '.':
                leafStart = ci + 1
        let firstCh = normType[leafStart]
        if firstCh >= 'A' && firstCh <= 'Z':
            return coreir.LocalPtrTag
    return coreir.LocalI32Tag

fn PrimaryBodyIrPointeeTypeText(typeRaw: str): str =
    let typeText = texpr.TypedExprStripVarType(typeRaw)
    if typeText == "":
        return ""
    if len(typeText) > 0 && typeText[len(typeText) - 1] == '*':
        return strutil.Strip(strings.SliceBytes(typeText, 0, len(typeText) - 1))
    if len(typeText) > 3 &&
       strings.SliceBytes(typeText, 0, 3) == "ref" &&
       typeText[3] >= 'A' &&
       typeText[3] <= 'Z':
        return strutil.Strip(strings.SliceBytes(typeText, 3, len(typeText) - 3))
    return ""

fn PrimaryBodyIrPointeeTypeTextForSource(typedIr: texpr.TypedExprIr,
                                          sourcePath: str,
                                          typeRaw: str): str =
    let aliasTarget = texpr.TypedExprIrLookupTypeDefAliasTargetType(typedIr,
                                                                    sourcePath,
                                                                    typeRaw)
    if aliasTarget != "":
        let aliasPointee = PrimaryBodyIrPointeeTypeText(aliasTarget)
        if aliasPointee != "":
            return aliasPointee
    return PrimaryBodyIrPointeeTypeText(typeRaw)

fn PrimaryBodyIrTypeTextIsGenericPointer(typeRaw: str): bool =
    let typeText = texpr.TypedExprNormalizeTypeText(typeRaw)
    return typeText == "ptr" || typeText == "void*"

fn PrimaryBodyIrTypeShapeFromText(typedIr: texpr.TypedExprIr,
                                   sourcePath: str,
                                   typeRaw: str,
                                   typeKind: var int32,
                                   sizeBytes: var int32,
                                   alignBytes: var int32) =
    typeKind = PrimaryBodyIrTypeKindFromText(typeRaw)
    sizeBytes = 0
    alignBytes = 0
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    if PrimaryStartsWith(normType, "seq[") ||
       (len(normType) >= 2 && strings.SliceBytes(normType, len(normType) - 2, 2) == "[]"):
        typeKind = coreir.LocalAggregateTag
        sizeBytes = 16
        alignBytes = 8
        return
    let aliasTarget = texpr.TypedExprIrLookupTypeDefAliasTargetType(typedIr,
                                                                    sourcePath,
                                                                    typeRaw)
    if PrimaryBodyIrPointeeTypeText(aliasTarget) != "":
        typeKind = coreir.LocalPtrTag
        sizeBytes = 8
        alignBytes = 8
        return
    let isVarOrPtrType = PrimaryStartsWith(normType, "var") ||
                         (len(normType) > 0 && normType[len(normType) - 1] == '*')
    if !isVarOrPtrType && texpr.TypedExprIrTypeIsEnum(typedIr, sourcePath, typeRaw):
        typeKind = coreir.LocalI32Tag
        sizeBytes = 4
        alignBytes = 4
        return
    var layoutSize: int32
    var layoutAlign: int32
    var layoutFieldCount: int32
    if !texpr.TypedExprIrLookupTypeLayout(typedIr,
                                          sourcePath,
                                          typeRaw,
                                          layoutSize,
                                          layoutAlign,
                                          layoutFieldCount):
        return
    if typeKind == coreir.LocalPtrTag:
        sizeBytes = 8
        alignBytes = 8
        return
    if layoutSize <= 0 || layoutAlign <= 0:
        return
    sizeBytes = layoutSize
    alignBytes = layoutAlign
    if typeKind == coreir.LocalI32Tag &&
       (layoutFieldCount > 0 || layoutSize > 8):
        typeKind = coreir.LocalAggregateTag

fn PrimaryBodyIrTypeTextIsVarI32(typeRaw: str): bool =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    return normType == "varint32" || normType == "vari32" || normType == "varbool"

fn PrimaryBodyIrNameInList(names: str[], name: str): bool =
    for i in 0..<names.len:
        if names[i] == name:
            return true
    return false

fn PrimaryBodyIrReturnTypeIsVoid(typeRaw: str): bool =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    return normType == "" || normType == "void"

fn PrimaryBodyIrTypeTextIsSeqStr(typeRaw: str): bool =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    return normType == "str[]" || normType == "seq[str]"

fn PrimaryBodyIrCallFullText(stmt: texpr.TypedExprIrStatement): str =
    if stmt.callArgCount > 0:
        return Fmt"{stmt.surfaceText}({stmt.callArgsText})"
    return Fmt"{stmt.surfaceText}()"

fn PrimaryBodyIrVarI32ValueSlotName(name: str): str =
    return Fmt"{name}#var_i32_value"

fn PrimaryBodyIrFindOrCreateSlot(bodyIR: var coreir.BodyIR,
                                  slotNames: var str[],
                                  name: str,
                                  typeKind: int32): int32 =
    for i in 0..<slotNames.len:
        if slotNames[i] == name:
            return i
    let newSlot = slotNames.len
    add(slotNames, name)
    PrimaryBodyIrLocalSlotNew(bodyIR, newSlot, name, typeKind)
    return newSlot

fn PrimaryBodyIrFindOrCreateSlotSized(bodyIR: var coreir.BodyIR,
                                       slotNames: var str[],
                                       name: str,
                                       typeKind: int32,
                                       sizeBytes: int32,
                                       alignBytes: int32): int32 =
    for i in 0..<slotNames.len:
        if slotNames[i] == name:
            if i < bodyIR.localSlots.len && sizeBytes > 0 && alignBytes > 0:
                var slot = bodyIR.localSlots[i]
                let currentSize = PrimaryLocalSlotSizeOf(slot)
                var changed = false
                if currentSize < sizeBytes:
                    slot.sizeBytes = sizeBytes
                    changed = true
                if slot.alignBytes < alignBytes:
                    slot.alignBytes = alignBytes
                    changed = true
                if slot.typeKind != typeKind &&
                   (slot.typeKind == coreir.LocalI32Tag ||
                    slot.typeKind == coreir.LocalAggregateTag ||
                    typeKind == coreir.LocalAggregateTag):
                    slot.typeKind = typeKind
                    changed = true
                if changed:
                    bodyIR.localSlots[i] = slot
                    PrimaryBodyIrReflowLocalStackOffsets(bodyIR)
            return i
    let newSlot = slotNames.len
    add(slotNames, name)
    PrimaryBodyIrLocalSlotNewSized(bodyIR, newSlot, name, typeKind, sizeBytes, alignBytes)
    return newSlot

fn PrimaryBodyIrFindOrCreateTypedSlot(bodyIR: var coreir.BodyIR,
                                       slotNames: var str[],
                                       typedIr: texpr.TypedExprIr,
                                       sourcePath: str,
                                       name: str,
                                       typeRaw: str): int32 =
    var typeKind: int32
    var sizeBytes: int32
    var alignBytes: int32
    PrimaryBodyIrTypeShapeFromText(typedIr, sourcePath, typeRaw, typeKind, sizeBytes, alignBytes)
    return PrimaryBodyIrFindOrCreateSlotSized(bodyIR,
                                              slotNames,
                                              name,
                                              typeKind,
                                              sizeBytes,
                                              alignBytes)

fn PrimaryBodyIrFindSlotIndex(slotNames: str[], name: str): int32 =
    for i in 0..<slotNames.len:
        if slotNames[i] == name:
            return i
    return -1

fn PrimaryBodyIrTypedGlobalType(typedIr: texpr.TypedExprIr,
                                 sourcePath: str,
                                 name: str): str =
    var found = ""
    for i in 0..<typedIr.globalNames.len:
        if i >= typedIr.globalSourcePaths.len || i >= typedIr.globalTypes.len:
            continue
        if typedIr.globalNames[i] != name:
            continue
        if PrimaryPathNormalizedEquals(typedIr.globalSourcePaths[i], sourcePath):
            return typedIr.globalTypes[i]
        if found == "":
            found = typedIr.globalTypes[i]
        else:
            found = ""
    return found

fn PrimaryBodyIrTypedGlobalSlotName(typedIr: texpr.TypedExprIr,
                                     sourcePath: str,
                                     name: str): str =
    var found = ""
    for i in 0..<typedIr.globalNames.len:
        if i >= typedIr.globalSourcePaths.len:
            continue
        if typedIr.globalNames[i] != name:
            continue
        let slotName = Fmt"{typedIr.globalSourcePaths[i]}::{name}"
        if PrimaryPathNormalizedEquals(typedIr.globalSourcePaths[i], sourcePath):
            return slotName
        if found == "":
            found = slotName
        else:
            found = ""
    return found

fn PrimaryBodyIrTypedGlobalTypeExact(typedIr: texpr.TypedExprIr,
                                      sourcePath: str,
                                      name: str): str =
    for i in 0..<typedIr.globalNames.len:
        if i >= typedIr.globalSourcePaths.len || i >= typedIr.globalTypes.len:
            continue
        if typedIr.globalNames[i] != name:
            continue
        if PrimaryPathNormalizedEquals(typedIr.globalSourcePaths[i], sourcePath):
            return typedIr.globalTypes[i]
    return ""

fn PrimaryBodyIrTypedGlobalSlotNameExact(typedIr: texpr.TypedExprIr,
                                          sourcePath: str,
                                          name: str): str =
    for i in 0..<typedIr.globalNames.len:
        if i >= typedIr.globalSourcePaths.len:
            continue
        if typedIr.globalNames[i] != name:
            continue
        if PrimaryPathNormalizedEquals(typedIr.globalSourcePaths[i], sourcePath):
            return Fmt"{typedIr.globalSourcePaths[i]}::{name}"
    return ""

fn PrimaryBodyIrCanonicalArgName(argRaw: str): str =
    let arg = strutil.Strip(argRaw)
    var openPos: int32 = -1
    for i in 0..<len(arg):
        if arg[i] == '(':
            openPos = i
            break
    if openPos <= 0:
        return arg
    var tailStart: int32
    for i in 0..<openPos:
        if arg[i] == '.':
            tailStart = i + 1
    if tailStart <= 0:
        return arg
    return strings.SliceBytes(arg, tailStart, len(arg) - tailStart)

fn PrimaryBodyIrFindArgSlot(slotNames: str[], argName: str): int32 =
    let exact = PrimaryBodyIrFindSlotIndex(slotNames, argName)
    if exact >= 0:
        return exact
    let canonical = PrimaryBodyIrCanonicalArgName(argName)
    if canonical != argName:
        return PrimaryBodyIrFindSlotIndex(slotNames, canonical)
    return -1

fn PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR: var coreir.BodyIR,
                                           slotNames: var str[],
                                           typedIr: texpr.TypedExprIr,
                                           sourcePath: str,
                                           rootName: str,
                                           rootTypeRaw: str): int32 =
    let rootType = texpr.TypedExprNormalizeTypeText(rootTypeRaw)
    if rootName == "":
        return -1
    if rootType == "" || PrimaryStartsWith(rootType, "var"):
        return PrimaryBodyIrFindArgSlot(slotNames, rootName)
    return PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                              slotNames,
                                              typedIr,
                                              sourcePath,
                                              rootName,
                                              rootType)

fn PrimaryBodyIrAppendFieldLoadToSlot(bodyIR: var coreir.BodyIR,
                                       slotNames: var str[],
                                       typedIr: texpr.TypedExprIr,
                                       sourcePath: str,
                                       rootName: str,
                                       rootTypeRaw: str,
                                       fieldOffsetBytes: int32,
                                       fieldSizeBytes: int32,
                                       targetSlot: int32): bool =
    if rootName == "" ||
       targetSlot < 0 ||
       targetSlot >= bodyIR.localSlots.len:
        return false
    let baseSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                          slotNames,
                                                          typedIr,
                                                          sourcePath,
                                                          rootName,
                                                          rootTypeRaw)
    if baseSlot < 0 ||
       fieldOffsetBytes < 0 ||
       fieldSizeBytes <= 0 ||
       PrimaryLocalSlotSizeOf(bodyIR.localSlots[targetSlot]) < fieldSizeBytes:
        return false
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpFieldLoadTag
    op.target = targetSlot
    add(op.operands, baseSlot)
    add(op.operands, targetSlot)
    add(op.operands, fieldOffsetBytes)
    add(op.operands, fieldSizeBytes)
    add(bodyIR.ops, op)
    return true

fn PrimaryBodyIrBindingTypeForName(typedIr: texpr.TypedExprIr,
                                    typedFn: texpr.TypedExprIrFunction,
                                    irFunction: lower.PrimaryObjectIrFunction,
                                    lineNumber: int32,
                                    nameRaw: str): str =
    let name = strutil.Strip(nameRaw)
    if name == "":
        return ""
    for i in 0..<irFunction.paramNames.len:
        if i >= irFunction.paramTypes.len:
            continue
        if irFunction.paramNames[i] == name:
            return irFunction.paramTypes[i]
    let localBindingType = texpr.TypedExprIrLookupLocalBindingType(typedIr,
                                                                   typedFn.sourcePath,
                                                                   typedFn.functionName,
                                                                   lineNumber,
                                                                   name)
    if localBindingType != "":
        return localBindingType
    var stmtEnd = typedFn.statementStart + typedFn.statementCount
    if stmtEnd > typedIr.statements.len:
        stmtEnd = typedIr.statements.len
    var foundType = ""
    for i in typedFn.statementStart..<stmtEnd:
        let stmt = typedIr.statements[i]
        if stmt.lineNumber >= lineNumber:
            continue
        if stmt.bindingName != name:
            continue
        if stmt.resultType != "" &&
           stmt.resultType != "unknown" &&
           stmt.resultType != "call_expr":
            if foundType != "" &&
               !PrimaryBodyIrTypeTextIsGenericPointer(foundType) &&
               PrimaryBodyIrTypeTextIsGenericPointer(stmt.resultType):
                continue
            foundType = stmt.resultType
    return foundType

fn PrimaryBodyIrTextHasDot(text: str): bool =
    for i in 0..<len(text):
        if text[i] == '.':
            return true
    return false

fn PrimaryBodyIrLookupSingleFieldMeta(typedIr: texpr.TypedExprIr,
                                       ownerTypeRaw: str,
                                       fieldNameRaw: str,
                                       fieldType: var str,
                                       fieldOffsetBytes: var int32,
                                       fieldSizeBytes: var int32,
                                       fieldAlignBytes: var int32): bool =
    fieldType = ""
    fieldOffsetBytes = 0
    fieldSizeBytes = 0
    fieldAlignBytes = 0
    let ownerType = texpr.TypedExprStripVarType(ownerTypeRaw)
    let fieldName = strutil.Strip(fieldNameRaw)
    if ownerType == "" || fieldName == "":
        return false
    if PrimaryObjectTypedIrFieldCount(typedIr, ownerType, fieldName) != 1:
        return PrimaryBodyIrLookupColdCsgFieldMeta(typedIr,
                                                   ownerType,
                                                   fieldName,
                                                   fieldType,
                                                   fieldOffsetBytes,
                                                   fieldSizeBytes,
                                                   fieldAlignBytes)
    fieldType = PrimaryObjectTypedIrFieldTypeText(typedIr, ownerType, fieldName)
    fieldOffsetBytes = PrimaryObjectTypedIrFieldMetric(typedIr, ownerType, fieldName, "offset")
    fieldSizeBytes = PrimaryObjectTypedIrFieldMetric(typedIr, ownerType, fieldName, "size")
    fieldAlignBytes = PrimaryObjectTypedIrFieldMetric(typedIr, ownerType, fieldName, "align")
    if fieldType == "":
        return false
    if fieldOffsetBytes < 0:
        return false
    if fieldSizeBytes <= 0:
        return false
    if fieldAlignBytes <= 0:
        return false
    return true

fn PrimaryBodyIrColdCsgFieldShape(specRaw: str,
                                   fieldType: var str,
                                   fieldSizeBytes: var int32,
                                   fieldAlignBytes: var int32): bool =
    let spec = strutil.Strip(specRaw)
    fieldType = ""
    fieldSizeBytes = 0
    fieldAlignBytes = 0
    if spec == "i":
        fieldType = "int32"
        fieldSizeBytes = 4
        fieldAlignBytes = 4
        return true
    if spec == "s":
        fieldType = "str"
        fieldSizeBytes = 24
        fieldAlignBytes = 8
        return true
    if spec == "v":
        fieldType = "ptr"
        fieldSizeBytes = 8
        fieldAlignBytes = 8
        return true
    if len(spec) > 1 && spec[0] == 'a':
        let countText = strings.SliceBytes(spec, 1, len(spec) - 1)
        let count = int32(strutil.ParseInt(countText))
        if count <= 0:
            return false
        fieldType = Fmt"int32[{count}]"
        fieldSizeBytes = count * 4
        fieldAlignBytes = 4
        return true
    return false

fn PrimaryBodyIrColdCsgObjectSpecs(typedIr: texpr.TypedExprIr,
                                    typeRaw: str): str =
    let typeName = texpr.TypedExprStripVarType(typeRaw)
    let typeLeaf = texpr.TypedExprTypeLeafName(typeName)
    if typeName == "" && typeLeaf == "":
        return ""
    var foundSpecs = ""
    for i in 0..<typedIr.coldCsgTypeRows.len:
        let row = typedIr.coldCsgTypeRows[i]
        if row.rowKind != texpr.TypedExprColdCsgTypeObject:
            continue
        if row.typeName != typeName && row.typeName != typeLeaf:
            continue
        if foundSpecs != "" && foundSpecs != row.specs:
            return ""
        foundSpecs = row.specs
    return foundSpecs

fn PrimaryBodyIrLookupColdCsgObjectLayout(typedIr: texpr.TypedExprIr,
                                           typeRaw: str,
                                           sizeBytes: var int32,
                                           alignBytes: var int32,
                                           fieldCount: var int32): bool =
    sizeBytes = 0
    alignBytes = 1
    fieldCount = 0
    let specs = PrimaryBodyIrColdCsgObjectSpecs(typedIr, typeRaw)
    if specs == "":
        return false
    let parts = strutil.Split(specs, ',')
    var offset: int32
    var maxAlign: int32 = 1
    for i in 0..<parts.len:
        let part = strutil.Strip(parts[i])
        if part == "":
            continue
        let colon = texpr.TypedExprFindTopLevelTextToken(part, ":")
        if colon <= 0:
            return false
        var fieldType: str
        var fieldSize: int32
        var fieldAlign: int32
        if !PrimaryBodyIrColdCsgFieldShape(strings.SliceBytes(part,
                                                              colon + 1,
                                                              len(part) - colon - 1),
                                           fieldType,
                                           fieldSize,
                                           fieldAlign):
            return false
        offset = PrimaryBodyIrAlignedOffset(offset, fieldAlign)
        offset = offset + fieldSize
        if fieldAlign > maxAlign:
            maxAlign = fieldAlign
        fieldCount = fieldCount + 1
    sizeBytes = PrimaryBodyIrAlignedOffset(offset, maxAlign)
    alignBytes = maxAlign
    return sizeBytes > 0 && alignBytes > 0

fn PrimaryBodyIrLookupColdCsgFieldMeta(typedIr: texpr.TypedExprIr,
                                        ownerTypeRaw: str,
                                        fieldNameRaw: str,
                                        fieldType: var str,
                                        fieldOffsetBytes: var int32,
                                        fieldSizeBytes: var int32,
                                        fieldAlignBytes: var int32): bool =
    fieldType = ""
    fieldOffsetBytes = 0
    fieldSizeBytes = 0
    fieldAlignBytes = 0
    let fieldName = strutil.Strip(fieldNameRaw)
    let specs = PrimaryBodyIrColdCsgObjectSpecs(typedIr, ownerTypeRaw)
    if fieldName == "" || specs == "":
        return false
    let parts = strutil.Split(specs, ',')
    var offset: int32
    for i in 0..<parts.len:
        let part = strutil.Strip(parts[i])
        if part == "":
            continue
        let colon = texpr.TypedExprFindTopLevelTextToken(part, ":")
        if colon <= 0:
            return false
        let name = strutil.Strip(strings.SliceBytes(part, 0, colon))
        var currentType: str
        var currentSize: int32
        var currentAlign: int32
        if !PrimaryBodyIrColdCsgFieldShape(strings.SliceBytes(part,
                                                              colon + 1,
                                                              len(part) - colon - 1),
                                           currentType,
                                           currentSize,
                                           currentAlign):
            return false
        offset = PrimaryBodyIrAlignedOffset(offset, currentAlign)
        if name == fieldName:
            fieldType = currentType
            fieldOffsetBytes = offset
            fieldSizeBytes = currentSize
            fieldAlignBytes = currentAlign
            return true
        offset = offset + currentSize
    return false

fn PrimaryBodyIrMaterializeFieldArgSlot(bodyIR: var coreir.BodyIR,
                                         slotNames: var str[],
                                         typedIr: texpr.TypedExprIr,
                                         typedFn: texpr.TypedExprIrFunction,
                                         irFunction: lower.PrimaryObjectIrFunction,
                                         sourcePath: str,
                                         lineNumber: int32,
                                         argTextRaw: str,
                                         failureDetail0: var int32,
                                         failureDetail1: var int32): int32 =
    let argText = strutil.Strip(argTextRaw)
    if !texpr.TypedExprTextIsSimpleFieldPath(argText):
        failureDetail0 = 431
        return -1
    let rootName = texpr.TypedExprAssignLhsRootName(argText)
    let fieldPath = texpr.TypedExprAssignFieldPath(argText)
    if rootName == "" || fieldPath == "":
        failureDetail0 = 432
        return -1
    let rootType = PrimaryBodyIrBindingTypeForName(typedIr,
                                                   typedFn,
                                                   irFunction,
                                                   lineNumber,
                                                   rootName)
    if rootType == "":
        failureDetail0 = 433
        return -1
    var fieldType = ""
    var fieldOffsetBytes: int32
    var fieldSizeBytes: int32
    var fieldAlignBytes: int32
    var fieldMetaOk = PrimaryBodyIrLookupSingleFieldMeta(typedIr,
                                                         rootType,
                                                         fieldPath,
                                                         fieldType,
                                                         fieldOffsetBytes,
                                                         fieldSizeBytes,
                                                         fieldAlignBytes)
    if !fieldMetaOk && PrimaryBodyIrTextHasDot(fieldPath):
        fieldMetaOk = texpr.TypedExprIrLookupFieldPathMeta(typedIr,
                                                           sourcePath,
                                                           rootType,
                                                           fieldPath,
                                                           fieldType,
                                                           fieldOffsetBytes,
                                                           fieldSizeBytes,
                                                           fieldAlignBytes)
    if !fieldMetaOk:
        failureDetail0 = 434
        return -1
    let baseSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                          slotNames,
                                                          typedIr,
                                                          sourcePath,
                                                          rootName,
                                                          rootType)
    if baseSlot < 0:
        failureDetail0 = 435
        return -1
    let valueSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                       slotNames,
                                                       typedIr,
                                                       sourcePath,
                                                       Fmt"{argText}#field_arg",
                                                       fieldType)
    if valueSlot < 0:
        failureDetail0 = 436
        failureDetail1 = fieldSizeBytes
        return -1
    if !PrimaryBodyIrAppendFieldLoadToSlot(bodyIR,
                                           slotNames,
                                           typedIr,
                                           sourcePath,
                                           rootName,
                                           rootType,
                                           fieldOffsetBytes,
                                           fieldSizeBytes,
                                           valueSlot):
        failureDetail0 = 436
        failureDetail1 = fieldSizeBytes
        return -1
    return valueSlot

fn PrimaryBodyIrAlignedOffset(offset: int32, alignRaw: int32): int32 =
    var align = alignRaw
    if align <= 0:
        align = 1
    return ((offset + align - 1) / align) * align

fn PrimaryBodyIrMarkParamSlot(bodyIR: var coreir.BodyIR,
                               slotId: int32,
                               paramSlot: int32) =
    if slotId < 0 || slotId >= bodyIR.localSlots.len:
        return
    bodyIR.localSlots[slotId].stackOffset = 0 - 1 - paramSlot

fn PrimaryBodyIrLocalIsParam(slot: coreir.LocalSlot): bool =
    return slot.stackOffset < 0

fn PrimaryBodyIrParamIndex(slot: coreir.LocalSlot): int32 =
    if slot.stackOffset >= 0:
        return -1
    return 0 - 1 - slot.stackOffset

fn PrimaryBodyIrParamCopyCount(bodyIR: coreir.BodyIR): int32 =
    var count: int32
    for i in 0..<bodyIR.localSlots.len:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[i]):
            count = count + 1
    return count

fn PrimaryBodyIrStackAdjustWordCount(bytesRaw: int32): int32 =
    var bytes = bytesRaw
    var count: int32
    while bytes > 4095:
        count = count + 1
        bytes = bytes - 4095
    if bytes > 0:
        count = count + 1
    return count

fn PrimaryBodyIrStackAddressWordCount(offsetBytes: int32): int32 =
    if offsetBytes < 0:
        return 0
    if offsetBytes == 0:
        return 1
    return PrimaryBodyIrStackAdjustWordCount(offsetBytes)

fn PrimaryBodyIrPrologueWordCount(bodyIR: coreir.BodyIR): int32 =
    let frameBytes = PrimaryBodyIrFrameBytes(bodyIR)
    return PrimaryBodyIrStackAdjustWordCount(frameBytes) + 3 + PrimaryBodyIrParamSaveCount(bodyIR)

fn PrimaryBodyIrFrameRestoreWordCount(bodyIR: coreir.BodyIR): int32 =
    return PrimaryBodyIrStackAdjustWordCount(PrimaryBodyIrFrameBytes(bodyIR)) + 2

fn PrimaryBodyIrLocalReg(slotId: int32): int32 =
    var reg = a64.A64X9 + slotId
    if reg > 28:
        reg = a64.A64X9
    return reg

fn PrimaryBodyIrTypeIs64(typeKind: int32): bool =
    return typeKind == coreir.LocalStrTag ||
           typeKind == coreir.LocalPtrTag ||
           typeKind == coreir.LocalI64Tag ||
           typeKind == coreir.LocalAggregateTag ||
           typeKind == coreir.LocalF64Tag

fn PrimaryBodyIrSlotType(bodyIR: coreir.BodyIR, slotId: int32): int32 =
    if slotId < 0 || slotId >= bodyIR.localSlots.len:
        return coreir.LocalI32Tag
    return bodyIR.localSlots[slotId].typeKind

fn PrimaryLocalSlotSizeOf(slot: coreir.LocalSlot): int32 =
    if slot.sizeBytes > 0:
        return slot.sizeBytes
    if slot.typeKind == coreir.LocalI32Tag:
        return 4
    if slot.typeKind == coreir.LocalF64Tag ||
       slot.typeKind == coreir.LocalI64Tag ||
       slot.typeKind == coreir.LocalPtrTag:
        return 8
    if slot.typeKind == coreir.LocalStrTag:
        return 24
    if slot.typeKind == coreir.LocalAggregateTag:
        return coreir.ResultStrSizeBytes
    return 0

fn PrimaryCallOpRegisterArgCount(call: coreir.CallOp): int32 =
    if call.argSlots.len > 8:
        return 8
    return call.argSlots.len

fn PrimaryCallOpStackArgCount(call: coreir.CallOp): int32 =
    if call.argSlots.len <= 8:
        return 0
    return call.argSlots.len - 8

fn PrimaryCallOpStackArgBytes(call: coreir.CallOp): int32 =
    return PrimaryAlignStackBytes(PrimaryCallOpStackArgCount(call) * 8, 16)

fn PrimaryCallOpArgPassKind(call: coreir.CallOp,
                             argIndex: int32): int32 =
    if argIndex >= 0 && argIndex < call.argPassKinds.len:
        return call.argPassKinds[argIndex]
    return coreir.BodyCallPassStackValueTag

fn PrimaryBodyIrCallArgIsCString(argSlot: int32): bool =
    return coreir.CallArgSlotIsCString(argSlot)

fn PrimaryBodyIrCallArgCStringId(argSlot: int32): int32 =
    return coreir.CallArgSlotCStringId(argSlot)

fn PrimaryBodyIrCallArgWordCount(bodyIR: coreir.BodyIR,
                                  argSlot: int32,
                                  passKind: int32): int32 =
    if passKind == coreir.BodyCallPassGlobalAddressTag:
        if argSlot < 0 ||
           argSlot >= bodyIR.localSlots.len ||
           bodyIR.localSlots[argSlot].placeKind != coreir.BodyPlaceGlobalAddressTag:
            return 0
        return 2
    if coreir.CallArgSlotIsConst(argSlot):
        return 1
    if coreir.CallArgSlotIsCString(argSlot):
        return 2
    if coreir.CallArgSlotIsAddress(argSlot):
        let slotId = coreir.CallArgSlotAddressId(argSlot)
        let slotOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                       slotId,
                                                       PrimaryBodyIrFrameBytes(bodyIR),
                                                       PrimaryBodyIrParamSaveOffset(bodyIR),
                                                       PrimaryBodyIrParamSaveCount(bodyIR))
        return PrimaryBodyIrStackAddressWordCount(slotOffset)
    return PrimaryBodyIrLoadSlotWordCount(bodyIR, argSlot)

fn PrimaryIncomingParamStackOffset(frameBytes: int32,
                                    paramSlot: int32): int32 =
    if paramSlot < 8:
        return -1
    return frameBytes + (paramSlot - 8) * 8

fn PrimaryBodyIrLocalStackOffset(bodyIR: coreir.BodyIR,
                                  slotIndex: int32,
                                  frameBytes: int32,
                                  paramSaveOffset: int32,
                                  paramSaveCount: int32): int32 =
    if slotIndex < 0 || slotIndex >= bodyIR.localSlots.len:
        return -1
    let slot = bodyIR.localSlots[slotIndex]
    if !PrimaryBodyIrLocalIsParam(slot):
        return slot.stackOffset
    let paramSlot = PrimaryBodyIrParamIndex(slot)
    if paramSlot < 0:
        return -1
    if paramSlot < 8:
        if paramSlot >= paramSaveCount:
            return -1
        return paramSaveOffset + paramSlot * 8
    return PrimaryIncomingParamStackOffset(frameBytes, paramSlot)

fn PrimaryBodyIrLoadSlotWordCount(bodyIR: coreir.BodyIR,
                                   slotIndex: int32): int32 =
    if slotIndex < 0 || slotIndex >= bodyIR.localSlots.len:
        return 0
    let slotType = bodyIR.localSlots[slotIndex].typeKind
    if slotType == coreir.LocalI32Tag ||
       slotType == coreir.LocalI64Tag ||
       slotType == coreir.LocalPtrTag ||
       slotType == coreir.LocalF64Tag:
        return 1
    if slotType == coreir.LocalStrTag ||
       slotType == coreir.LocalAggregateTag:
        if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[slotIndex]):
            return 1
        let stackOffset = PrimaryBodyIrLocalStackOffset(bodyIR,
                                                       slotIndex,
                                                       PrimaryBodyIrFrameBytes(bodyIR),
                                                       PrimaryBodyIrParamSaveOffset(bodyIR),
                                                       PrimaryBodyIrParamSaveCount(bodyIR))
        return PrimaryBodyIrStackAddressWordCount(stackOffset)
    return 0

fn PrimaryBodyIrStoreSlotWordCount(bodyIR: coreir.BodyIR,
                                    slotIndex: int32): int32 =
    if slotIndex < 0 || slotIndex >= bodyIR.localSlots.len:
        return 0
    let slotType = bodyIR.localSlots[slotIndex].typeKind
    if slotType == coreir.LocalI32Tag ||
       slotType == coreir.LocalI64Tag ||
       slotType == coreir.LocalPtrTag ||
       slotType == coreir.LocalF64Tag:
        return 1
    return 0

fn PrimaryBodyIrTextIsI32Zero(textRaw: str): bool =
    let text = strutil.Strip(textRaw)
    return text == "0" || text == "int32(0)"

fn PrimaryBodyIrTextIsI32One(textRaw: str): bool =
    let text = strutil.Strip(textRaw)
    return text == "1" || text == "int32(1)"

fn PrimaryBodyIrTextIsStringLiteral(textRaw: str): bool =
    let text = strutil.Strip(textRaw)
    return len(text) >= 2 &&
           text[0] == '"' &&
           text[len(text) - 1] == '"'

fn PrimaryBodyIrStringLiteralPayload(textRaw: str): str =
    let text = strutil.Strip(textRaw)
    if !PrimaryBodyIrTextIsStringLiteral(text):
        return ""
    return strings.SliceBytes(text, 1, len(text) - 2)

fn PrimaryBodyIrCstringCastArgText(textRaw: str): str =
    let text = strutil.Strip(textRaw)
    if len(text) <= 9:
        return ""
    if !PrimaryStartsWith(text, "cstring("):
        return ""
    if text[len(text) - 1] != ')':
        return ""
    return strutil.Strip(strings.SliceBytes(text, 8, len(text) - 9))

fn PrimaryBodyIrPtrAddressArgName(textRaw: str): str =
    let text = strutil.Strip(textRaw)
    if len(text) > 1 && text[0] == '&':
        let rawName = strutil.Strip(strings.SliceBytes(text, 1, len(text) - 1))
        if rawName == "" ||
           PrimaryBodyIrTextHasCallSurface(rawName) ||
           (PrimaryBodyIrTextHasFieldOrIndex(rawName) && !texpr.TypedExprTextIsSimpleFieldPath(rawName)):
            return ""
        return rawName
    if len(text) <= 6:
        return ""
    if !PrimaryStartsWith(text, "ptr("):
        return ""
    if text[len(text) - 1] != ')':
        return ""
    let inner = strutil.Strip(strings.SliceBytes(text, 4, len(text) - 5))
    if len(inner) <= 1 || inner[0] != '&':
        return ""
    let name = strutil.Strip(strings.SliceBytes(inner, 1, len(inner) - 1))
    if name == "" ||
       PrimaryBodyIrTextHasCallSurface(name) ||
       (PrimaryBodyIrTextHasFieldOrIndex(name) && !texpr.TypedExprTextIsSimpleFieldPath(name)):
        return ""
    return name

fn PrimaryBodyIrFunctionAddressSlotName(functionIndex: int32): str =
    return Fmt"__cheng_function_address#{functionIndex}"

fn PrimaryBodyIrFunctionAddressSlotIndex(slotName: str): int32 =
    let prefix = "__cheng_function_address#"
    if len(slotName) <= len(prefix) || !PrimaryStartsWith(slotName, prefix):
        return -1
    return int32(strutil.ParseInt(strings.SliceBytes(slotName, len(prefix), len(slotName) - len(prefix))))

fn PrimaryBodyIrWholeCallInnerForHead(textRaw: str,
                                       headRaw: str): str =
    let text = strutil.Strip(textRaw)
    let head = strutil.Strip(headRaw)
    if text == "" || head == "":
        return ""
    let openPos = len(head)
    if len(text) <= openPos + 1 ||
       !PrimaryStartsWith(text, head) ||
       text[openPos] != '(' ||
       text[len(text) - 1] != ')':
        return ""
    let closePos = texpr.TypedExprFindMatchingParen(text, openPos)
    if closePos != len(text) - 1:
        return ""
    return strutil.Strip(strings.SliceBytes(text, openPos + 1, len(text) - openPos - 2))

fn PrimaryBodyIrUInt8PtrDerefPointerText(textRaw: str): str =
    let text = strutil.Strip(textRaw)
    if len(text) <= 4 || text[0] != '*' || text[1] != '(' || text[len(text) - 1] != ')':
        return ""
    let closePos = texpr.TypedExprFindMatchingParen(text, 1)
    if closePos != len(text) - 1:
        return ""
    let inner = strutil.Strip(strings.SliceBytes(text, 2, len(text) - 3))
    return PrimaryBodyIrWholeCallInnerForHead(inner, "UInt8Ptr")

fn PrimaryBodyIrCanonicalCallText(textRaw: str): str =
    let text = strutil.Strip(textRaw)
    var openPos: int32 = -1
    for i in 0..<len(text):
        if text[i] == '(':
            openPos = i
            break
    if openPos <= 0 || len(text) <= openPos + 1 || text[len(text) - 1] != ')':
        return text
    let closePos = texpr.TypedExprFindMatchingParen(text, openPos)
    if closePos != len(text) - 1:
        return text
    let head = strutil.Strip(strings.SliceBytes(text, 0, openPos))
    let inner = strings.SliceBytes(text, openPos + 1, len(text) - openPos - 2)
    let args = texpr.TypedExprSplitTopLevelCsv(inner)
    var out = Fmt"{head}("
    for i in 0..<args.len:
        if i > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{strutil.Strip(args[i])}"
    out = Fmt"{out})"
    return out

fn PrimaryBodyIrPtrExpressionSlot(bodyIR: var coreir.BodyIR,
                                   slotNames: str[],
                                   textRaw: str): int32 =
    let text = strutil.Strip(textRaw)
    if text == "":
        return -1
    var directSlot = PrimaryBodyIrFindArgSlot(slotNames, text)
    if directSlot < 0:
        let canonicalText = PrimaryBodyIrCanonicalCallText(text)
        if canonicalText != text:
            directSlot = PrimaryBodyIrFindArgSlot(slotNames, canonicalText)
    if directSlot >= 0 &&
       directSlot < bodyIR.localSlots.len &&
       PrimaryBodyIrSlotType(bodyIR, directSlot) == coreir.LocalPtrTag:
        return directSlot
    if directSlot >= 0 &&
       directSlot < bodyIR.localSlots.len &&
       PrimaryBodyIrWholeCallInnerForHead(text, "cheng_ptr_plus") != "":
        bodyIR.localSlots[directSlot].typeKind = coreir.LocalPtrTag
        bodyIR.localSlots[directSlot].sizeBytes = 8
        bodyIR.localSlots[directSlot].alignBytes = 8
        for ci in 0..<bodyIR.callSequence.len:
            if bodyIR.callSequence[ci].resultSlot == directSlot &&
               PrimaryCallTargetTailName(bodyIR.callSequence[ci].targetSymbol) == "cheng_ptr_plus":
                bodyIR.callSequence[ci].resultPassKind = coreir.BodyCallPassStackValueTag
        return directSlot
    let ptrPlusArgsText = PrimaryBodyIrWholeCallInnerForHead(text, "cheng_ptr_plus")
    if ptrPlusArgsText != "":
        let argNames = PrimaryBodyIrCallArgNames(ptrPlusArgsText)
        var callIndex = bodyIR.callSequence.len
        while callIndex > 0:
            callIndex = callIndex - 1
            if PrimaryCallTargetTailName(bodyIR.callSequence[callIndex].targetSymbol) != "cheng_ptr_plus":
                continue
            if bodyIR.callSequence[callIndex].argSlots.len != argNames.len:
                continue
            var argsMatch = true
            for ai in 0..<argNames.len:
                let argSlot = PrimaryBodyIrFindArgSlot(slotNames, PrimaryBodyIrCanonicalCallText(argNames[ai]))
                if argSlot < 0 || argSlot != bodyIR.callSequence[callIndex].argSlots[ai]:
                    argsMatch = false
                    break
            if !argsMatch:
                continue
            let resultSlot = bodyIR.callSequence[callIndex].resultSlot
            if resultSlot < 0 || resultSlot >= bodyIR.localSlots.len:
                return -1
            bodyIR.localSlots[resultSlot].typeKind = coreir.LocalPtrTag
            bodyIR.localSlots[resultSlot].sizeBytes = 8
            bodyIR.localSlots[resultSlot].alignBytes = 8
            bodyIR.callSequence[callIndex].resultPassKind = coreir.BodyCallPassStackValueTag
            return resultSlot
    let ptrInner = PrimaryBodyIrWholeCallInnerForHead(text, "ptr")
    if ptrInner != "":
        let innerSlot = PrimaryBodyIrFindArgSlot(slotNames, ptrInner)
        if innerSlot >= 0 &&
           innerSlot < bodyIR.localSlots.len &&
           PrimaryBodyIrSlotType(bodyIR, innerSlot) == coreir.LocalPtrTag:
            return innerSlot
    return -1

fn PrimaryBodyIrAppendUInt8PtrDerefLoad(bodyIR: var coreir.BodyIR,
                                         slotNames: var str[],
                                         textRaw: str,
                                         targetSlot: int32): bool =
    let pointerText = PrimaryBodyIrUInt8PtrDerefPointerText(textRaw)
    if pointerText == "":
        return false
    if targetSlot < 0 ||
       targetSlot >= bodyIR.localSlots.len ||
       PrimaryBodyIrSlotType(bodyIR, targetSlot) != coreir.LocalI32Tag:
        return false
    let pointerSlot = PrimaryBodyIrPtrExpressionSlot(bodyIR, slotNames, pointerText)
    if pointerSlot < 0:
        return false
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpLoadLocalTag
    op.target = targetSlot
    add(op.operands, coreir.BodyLoadLocalPtrDerefU8Tag)
    add(op.operands, pointerSlot)
    add(op.operands, 1)
    add(bodyIR.ops, op)
    return true

fn PrimaryBodyIrAppendUInt8PtrDerefStore(bodyIR: var coreir.BodyIR,
                                          slotNames: var str[],
                                          varI32ParamNames: str[],
                                          typedIr: texpr.TypedExprIr,
                                          sourcePath: str,
                                          lhsTextRaw: str,
                                          rhsTextRaw: str,
                                          failureDetail: var int32): bool =
    failureDetail = 0
    let pointerText = PrimaryBodyIrUInt8PtrDerefPointerText(lhsTextRaw)
    if pointerText == "":
        failureDetail = 711
        return false
    let pointerSlot = PrimaryBodyIrPtrExpressionSlot(bodyIR, slotNames, pointerText)
    if pointerSlot < 0:
        failureDetail = 712
        return false
    let valueSlot = PrimaryBodyIrLocalInitValueSlot(bodyIR,
                                                   slotNames,
                                                   varI32ParamNames,
                                                   typedIr,
                                                   sourcePath,
                                                   "uint8",
                                                   coreir.LocalI32Tag,
                                                   rhsTextRaw)
    if valueSlot < 0:
        failureDetail = 713
        return false
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpIndexedStoreTag
    op.target = pointerSlot
    add(op.operands, pointerSlot)
    add(op.operands, valueSlot)
    add(op.operands, coreir.BodyStoreLocalPtrDerefU8Tag)
    add(bodyIR.ops, op)
    return true

fn PrimaryBodyIrTypeCastInnerForTarget(textRaw: str,
                                        targetTypeRaw: str): str =
    let text = strutil.Strip(textRaw)
    let targetType = texpr.TypedExprNormalizeTypeText(targetTypeRaw)
    if text == "" || targetType == "":
        return ""
    var openPos: int32 = -1
    for i in 0..<len(text):
        if text[i] == '(':
            openPos = i
            break
    if openPos <= 0 || text[len(text) - 1] != ')':
        return ""
    let closePos = texpr.TypedExprFindMatchingParen(text, openPos)
    if closePos != len(text) - 1:
        return ""
    let head = texpr.TypedExprNormalizeTypeText(strings.SliceBytes(text, 0, openPos))
    var targetLeafStart: int32
    for i in 0..<len(targetType):
        if targetType[i] == '.':
            targetLeafStart = i + 1
    let targetLeaf = strings.SliceBytes(targetType, targetLeafStart, len(targetType) - targetLeafStart)
    if head == targetType ||
       head == targetLeaf ||
       head == "int64" ||
       head == "uint64" ||
       head == "ptr":
        return strutil.Strip(strings.SliceBytes(text, openPos + 1, len(text) - openPos - 2))
    return ""

fn PrimaryBodyIrSizeofConst(typedIr: texpr.TypedExprIr,
                             sourcePath: str,
                             textRaw: str): int32 =
    let typeText = PrimaryBodyIrWholeCallInnerForHead(textRaw, "sizeof")
    if typeText == "":
        return -1
    var typeKind: int32
    var sizeBytes: int32
    var alignBytes: int32
    PrimaryBodyIrTypeShapeFromText(typedIr,
                                   sourcePath,
                                   typeText,
                                   typeKind,
                                   sizeBytes,
                                   alignBytes)
    if sizeBytes > 0:
        return sizeBytes
    if typeKind == coreir.LocalI32Tag:
        return 4
    if typeKind == coreir.LocalI64Tag ||
       typeKind == coreir.LocalPtrTag ||
       typeKind == coreir.LocalF64Tag:
        return 8
    if typeKind == coreir.LocalStrTag:
        return 24
    if typeKind == coreir.LocalAggregateTag:
        return coreir.ResultStrSizeBytes
    return -1

fn PrimaryBodyIrConditionText(textRaw: str): str =
    var text = strutil.Strip(textRaw)
    if PrimaryStartsWith(text, "if "):
        text = strutil.Strip(strings.SliceBytes(text, 3, len(text) - 3))
    elif PrimaryStartsWith(text, "elif "):
        text = strutil.Strip(strings.SliceBytes(text, 5, len(text) - 5))
    elif PrimaryStartsWith(text, "while "):
        text = strutil.Strip(strings.SliceBytes(text, 6, len(text) - 6))
    if len(text) > 0 && text[len(text) - 1] == ':':
        text = strutil.Strip(strings.SliceBytes(text, 0, len(text) - 1))
    return text

fn PrimaryBodyIrConditionHasAnd(condText: str): bool =
    for i in 0..<len(condText) - 1:
        if condText[i] == '&' && condText[i + 1] == '&':
            return true
    return false

fn PrimaryBodyIrSplitAndConditions(condText: str): str[] =
    var parts: str[]
    var start: int32
    var i: int32
    while i < len(condText):
        if i + 1 < len(condText) && condText[i] == '&' && condText[i + 1] == '&':
            add(parts, strutil.Strip(strings.SliceBytes(condText, start, i - start)))
            start = i + 2
            i = i + 2
        else:
            i = i + 1
    if start < len(condText):
        add(parts, strutil.Strip(strings.SliceBytes(condText, start, len(condText) - start)))
    return parts

fn PrimaryBodyIrConditionOperandSlot(bodyIR: var coreir.BodyIR,
                                      slotNames: var str[],
                                      typedIr: texpr.TypedExprIr,
                                      sourcePath: str,
                                      textRaw: str,
                                      nextOpIndex: var int32): int32 =
    let text = strutil.Strip(textRaw)
    if text == "":
        return -1
    if text == "nil":
        let nilSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                    slotNames,
                                                    "nil#ptr_zero",
                                                    coreir.LocalPtrTag)
        var nilOp: coreir.BodyOp
        nilOp.kind = coreir.BodyOpLoadConstTag
        nilOp.target = nilSlot
        add(nilOp.operands, coreir.LocalPtrTag)
        add(nilOp.operands, 0)
        add(bodyIR.ops, nilOp)
        nextOpIndex = nextOpIndex + 1
        return nilSlot
    let constVal = PrimaryBodyIrExtractIntFromText(text)
    if constVal != 0 || PrimaryBodyIrTextIsI32Zero(text):
        let constSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                      slotNames,
                                                      text,
                                                      coreir.LocalI32Tag)
        var constOp: coreir.BodyOp
        constOp.kind = coreir.BodyOpLoadConstTag
        constOp.target = constSlot
        add(constOp.operands, coreir.LocalI32Tag)
        add(constOp.operands, constVal)
        add(bodyIR.ops, constOp)
        nextOpIndex = nextOpIndex + 1
        return constSlot
    let existingSlot = PrimaryBodyIrFindArgSlot(slotNames, text)
    if existingSlot >= 0:
        return existingSlot
    let globalType = PrimaryBodyIrTypedGlobalTypeExact(typedIr, sourcePath, text)
    if globalType != "":
        var globalTypeKind: int32
        var globalSizeBytes: int32
        var globalAlignBytes: int32
        PrimaryBodyIrTypeShapeFromText(typedIr,
                                       sourcePath,
                                       globalType,
                                       globalTypeKind,
                                       globalSizeBytes,
                                       globalAlignBytes)
        let globalSlotName = PrimaryBodyIrTypedGlobalSlotNameExact(typedIr, sourcePath, text)
        if globalSlotName == "":
            return -1
        let globalSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                       slotNames,
                                                       globalSlotName,
                                                       globalTypeKind)
        bodyIR.localSlots[globalSlot].placeKind = coreir.BodyPlaceGlobalAddressTag
        let valueSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                      slotNames,
                                                      Fmt"{globalSlotName}#global_value",
                                                      globalTypeKind)
        var op: coreir.BodyOp
        op.kind = coreir.BodyOpGlobalLoadTag
        op.target = valueSlot
        add(op.operands, globalSlot)
        add(bodyIR.ops, op)
        nextOpIndex = nextOpIndex + 1
        return valueSlot
    return PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, coreir.LocalI32Tag)

fn PrimaryBodyIrEmitConditionOps(bodyIR: var coreir.BodyIR,
                                   slotNames: var str[],
                                   typedIr: texpr.TypedExprIr,
                                   sourcePath: str,
                                   condText: str,
                                   lhsSlot: var int32,
                                   rhsSlot: var int32,
                                   cmpTag: var int32,
                                   nextOpIndex: var int32): bool =
    var cmpOpPos: int32
    cmpOpPos = -1
    var cmpOpLen: int32
    cmpOpLen = 0
    cmpTag = 0
    for ci in 0..<len(condText):
        let ch = condText[ci]
        if ch == '=':
            if ci + 1 < len(condText):
                if condText[ci + 1] == '=':
                    cmpOpPos = ci
                    cmpOpLen = 2
                    cmpTag = coreir.BodyCondI32EqTag
                    break
        if ch == '!':
            if ci + 1 < len(condText):
                if condText[ci + 1] == '=':
                    cmpOpPos = ci
                    cmpOpLen = 2
                    cmpTag = coreir.BodyCondI32NeTag
                    break
        if ch == '<':
            if ci + 1 < len(condText):
                if condText[ci + 1] == '=':
                    cmpOpPos = ci
                    cmpOpLen = 2
                    cmpTag = coreir.BodyCondI32LeTag
                    break
            cmpOpPos = ci
            cmpOpLen = 1
            cmpTag = coreir.BodyCondI32LtTag
            break
        if ch == '>':
            if ci + 1 < len(condText):
                if condText[ci + 1] == '=':
                    cmpOpPos = ci
                    cmpOpLen = 2
                    cmpTag = coreir.BodyCondI32GeTag
                    break
            cmpOpPos = ci
            cmpOpLen = 1
            cmpTag = coreir.BodyCondI32GtTag
            break
    if cmpOpPos < 0:
        return false
    var condLhs = strings.SliceBytes(condText, 0, cmpOpPos)
    var lhsEnd = len(condLhs)
    while lhsEnd > 0:
        if condLhs[lhsEnd - 1] != ' ':
            break
        lhsEnd = lhsEnd - 1
    if lhsEnd > 0:
        condLhs = strings.SliceBytes(condLhs, 0, lhsEnd)
    var condRhsRaw = strings.SliceBytes(condText, cmpOpPos + cmpOpLen, len(condText) - cmpOpPos - cmpOpLen)
    var rhsStartPos: int32
    rhsStartPos = 0
    while rhsStartPos < len(condRhsRaw):
        if condRhsRaw[rhsStartPos] != ' ':
            break
        rhsStartPos = rhsStartPos + 1
    var condRhs = condRhsRaw
    if rhsStartPos > 0:
        condRhs = strings.SliceBytes(condRhsRaw, rhsStartPos, len(condRhsRaw) - rhsStartPos)
    lhsSlot = PrimaryBodyIrConditionOperandSlot(bodyIR, slotNames, typedIr, sourcePath, condLhs, nextOpIndex)
    rhsSlot = PrimaryBodyIrConditionOperandSlot(bodyIR, slotNames, typedIr, sourcePath, condRhs, nextOpIndex)
    if lhsSlot < 0 || rhsSlot < 0:
        return false
    return true

fn PrimaryBodyIrAppendConditionTerm(bodyIR: var coreir.BodyIR,
                                     conditionSlot: int32,
                                     conditionKind: int32,
                                     currentBlockStart: var int32,
                                     pendingFalseTerm: var int32) =
    var term: coreir.BodyTerm
    term.kind = coreir.BodyTermCbrTag
    term.conditionKind = conditionKind
    term.lhsSlot = conditionSlot
    term.rhsSlot = -1
    term.trueBlock = -1
    term.falseBlock = -1
    term.resultSlot = -1
    let termIndex = coreir.BodyIRAppendTerm(bodyIR, term)
    let opCount = bodyIR.ops.len - currentBlockStart
    let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, opCount, termIndex)
    currentBlockStart = bodyIR.ops.len
    pendingFalseTerm = termIndex

fn PrimaryBodyIrAppendBoolConditionAssign(bodyIR: var coreir.BodyIR,
                                           slotNames: var str[],
                                           typedIr: texpr.TypedExprIr,
                                           sourcePath: str,
                                           rhsTextRaw: str,
                                           targetSlot: int32): bool =
    if targetSlot < 0 ||
       targetSlot >= bodyIR.localSlots.len ||
       PrimaryBodyIrSlotType(bodyIR, targetSlot) != coreir.LocalI32Tag:
        return false
    let rhsText = strutil.Strip(rhsTextRaw)
    if rhsText == "":
        return false
    var parts: str[]
    if PrimaryBodyIrConditionHasAnd(rhsText):
        parts = PrimaryBodyIrSplitAndConditions(rhsText)
    else:
        add(parts, rhsText)
    if parts.len <= 0:
        return false
    var dummyNextOpIndex: int32
    for partIndex in 0..<parts.len:
        let partText = strutil.Strip(parts[partIndex])
        if partText == "":
            return false
        var lhsSlot: int32
        var rhsSlot: int32
        var cmpTag: int32
        if !PrimaryBodyIrEmitConditionOps(bodyIR,
                                          slotNames,
                                          typedIr,
                                          sourcePath,
                                          partText,
                                          lhsSlot,
                                          rhsSlot,
                                          cmpTag,
                                          dummyNextOpIndex):
            return false
        var cmpTargetSlot = targetSlot
        if partIndex > 0:
            cmpTargetSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                          slotNames,
                                                          Fmt"{bodyIR.localSlots[targetSlot].name}#and_part#{partIndex}",
                                                          coreir.LocalI32Tag)
            if cmpTargetSlot < 0:
                return false
        var cmpOp: coreir.BodyOp
        cmpOp.kind = coreir.BodyOpCmpTag
        cmpOp.target = cmpTargetSlot
        add(cmpOp.operands, cmpTag)
        add(cmpOp.operands, lhsSlot)
        add(cmpOp.operands, rhsSlot)
        add(bodyIR.ops, cmpOp)
        if partIndex > 0:
            var andOp: coreir.BodyOp
            andOp.kind = coreir.BodyOpBinOpTag
            andOp.target = targetSlot
            add(andOp.operands, coreir.LocalI32Tag)
            add(andOp.operands, int32(texpr.TypedExprIrOpI32Mul))
            add(andOp.operands, targetSlot)
            add(andOp.operands, cmpTargetSlot)
            add(bodyIR.ops, andOp)
    return true

fn PrimaryBodyIrAppendTypedStrLiteralCondition(bodyIR: var coreir.BodyIR,
                                                slotNames: var str[],
                                                stmt: texpr.TypedExprIrStatement,
                                                currentBlockStart: var int32,
                                                pendingFalseTerm: var int32): bool =
    if stmt.conditionKind != texpr.TypedExprIrCondStrEqLiteral &&
       stmt.conditionKind != texpr.TypedExprIrCondStrNeLiteral:
        return false
    let conditionLhsText = stmt.conditionLhsText
    let conditionLiteralText = stmt.conditionLiteralText
    let strSlot = PrimaryBodyIrFindArgSlot(slotNames, conditionLhsText)
    if strSlot < 0:
        return false
    if PrimaryBodyIrSlotType(bodyIR, strSlot) != coreir.LocalStrTag:
        return false
    let resultSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                   slotNames,
                                                   Fmt"{conditionLhsText}#str_eq_literal#{conditionLiteralText}",
                                                   coreir.LocalI32Tag)
    let literalId = coreir.BodyIRAppendCStringLiteral(bodyIR,
                                                      conditionLiteralText,
                                                      "")
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpStrEqLiteralTag
    op.target = resultSlot
    add(op.operands, strSlot)
    add(op.operands, literalId)
    add(bodyIR.ops, op)
    var condKind = coreir.BodyCondLocalNonZeroTag
    if stmt.conditionKind == texpr.TypedExprIrCondStrNeLiteral:
        condKind = coreir.BodyCondLocalZeroTag
    PrimaryBodyIrAppendConditionTerm(bodyIR,
                                     resultSlot,
                                     condKind,
                                     currentBlockStart,
                                     pendingFalseTerm)
    return true

fn PrimaryBodyIrSeedParamSlots(bodyIR: var coreir.BodyIR,
                                slotNames: var str[],
                                typedIr: texpr.TypedExprIr,
                                irFunction: lower.PrimaryObjectIrFunction) =
    for paramIndex in 0..<irFunction.paramNames.len:
        if paramIndex >= irFunction.paramTypes.len:
            return
        let paramName = irFunction.paramNames[paramIndex]
        if len(paramName) <= 0:
            continue
        let slotId = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                        slotNames,
                                                        typedIr,
                                                        irFunction.sourcePath,
                                                        paramName,
                                                        irFunction.paramTypes[paramIndex])
        PrimaryBodyIrMarkParamSlot(bodyIR, slotId, paramIndex)

fn PrimaryBodyIrCollectVarI32ParamNames(irFunction: lower.PrimaryObjectIrFunction): str[] =
    var out: str[]
    for paramIndex in 0..<irFunction.paramNames.len:
        if paramIndex >= irFunction.paramTypes.len:
            return out
        if PrimaryBodyIrTypeTextIsVarI32(irFunction.paramTypes[paramIndex]):
            add(out, irFunction.paramNames[paramIndex])
    return out

fn PrimaryBodyIrCallArgNames(callArgsText: str): str[] =
    var out: str[]
    let pieces = texpr.TypedExprSplitTopLevelCsv(callArgsText)
    for i in 0..<pieces.len:
        let name = strutil.Strip(pieces[i])
        if len(name) > 0:
            add(out, name)
    return out

fn PrimaryBodyIrTargetFunctionIndex(typedIr: texpr.TypedExprIr,
                                     sourcePath: str,
                                     functionName: str): int32 =
    let tailName = PrimaryCallTargetTailName(functionName)
    var found: int32
    found = -1
    for i in 0..<typedIr.functions.len:
        let candidateTailName = PrimaryCallTargetTailName(typedIr.functions[i].functionName)
        if sourcePath != "" &&
           !PrimaryPathNormalizedEquals(typedIr.functions[i].sourcePath, sourcePath):
            continue
        if typedIr.functions[i].functionName == functionName ||
           candidateTailName == functionName ||
           candidateTailName == tailName:
            if sourcePath != "":
                return i
            if found >= 0:
                return -1
            found = i
    return found

fn PrimaryBodyIrCallResultLayoutSourcePath(stmt: texpr.TypedExprIrStatement): str =
    if stmt.callTargetSourcePath != "":
        return stmt.callTargetSourcePath
    return stmt.sourcePath

fn PrimaryBodyIrResolvedCallResultType(typedIr: texpr.TypedExprIr,
                                        stmt: texpr.TypedExprIrStatement): str =
    var resultType = stmt.resultType
    var importcSourcePath = stmt.callTargetSourcePath
    if importcSourcePath == "":
        importcSourcePath = stmt.sourcePath
    let importcResultType = texpr.TypedExprIrLookupImportcReturnType(typedIr,
                                                                      importcSourcePath,
                                                                      stmt.callTarget)
    if importcResultType != "":
        return importcResultType
    var targetSourcePath = stmt.callTargetSourcePath
    if targetSourcePath == "":
        targetSourcePath = stmt.sourcePath
    let targetFnIndex = PrimaryBodyIrTargetFunctionIndex(typedIr,
                                                         targetSourcePath,
                                                         stmt.callTarget)
    if targetFnIndex >= 0 && targetFnIndex < typedIr.functions.len:
        resultType = typedIr.functions[targetFnIndex].returnType
    else:
        let tailName = PrimaryCallTargetTailName(stmt.callTarget)
        var foundReturnType = ""
        for i in 0..<typedIr.functions.len:
            let candidateTailName = PrimaryCallTargetTailName(typedIr.functions[i].functionName)
            if typedIr.functions[i].functionName != stmt.callTarget &&
               candidateTailName != stmt.callTarget &&
               candidateTailName != tailName:
                continue
            if foundReturnType != "" &&
               foundReturnType != typedIr.functions[i].returnType:
                return resultType
            foundReturnType = typedIr.functions[i].returnType
        if foundReturnType != "":
            resultType = foundReturnType
    return resultType

fn PrimaryBodyIrTargetParamType(typedIr: texpr.TypedExprIr,
                                 stmt: texpr.TypedExprIrStatement,
                                 argIndex: int32): str =
    if stmt.callTargetImportc || argIndex < 0:
        return ""
    let fnIndex = PrimaryBodyIrTargetFunctionIndex(typedIr,
                                                  stmt.callTargetSourcePath,
                                                  stmt.callTarget)
    if fnIndex < 0 || fnIndex >= typedIr.functions.len:
        return ""
    let targetFn = typedIr.functions[fnIndex]
    var nodeEnd = targetFn.nodeStart + targetFn.nodeCount
    if nodeEnd > typedIr.nodes.len:
        nodeEnd = typedIr.nodes.len
    for nodeIndex in targetFn.nodeStart..<nodeEnd:
        let node = typedIr.nodes[nodeIndex]
        if node.opKind != texpr.TypedExprIrOpParamRef:
            continue
        if node.paramSlot != argIndex:
            continue
        return node.resultType
    return ""

fn PrimaryBodyIrTypeTextIsVarParam(typeRaw: str): bool =
    let normType = texpr.TypedExprNormalizeTypeText(typeRaw)
    return PrimaryStartsWith(normType, "var")

fn PrimaryBodyIrTargetParamIsVarI32(typedIr: texpr.TypedExprIr,
                                     stmt: texpr.TypedExprIrStatement,
                                     argIndex: int32): bool =
    return PrimaryBodyIrTypeTextIsVarI32(PrimaryBodyIrTargetParamType(typedIr,
                                                                      stmt,
                                                                      argIndex))

fn PrimaryBodyIrAppendInvalidOp(bodyIR: var coreir.BodyIR,
                                lineNumber: int32,
                                statementKind: int32,
                                detail0: int32,
                                detail1: int32) =
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpInvalidTag
    op.target = lineNumber
    add(op.operands, statementKind)
    add(op.operands, detail0)
    add(op.operands, detail1)
    add(bodyIR.ops, op)

fn PrimaryBodyIrAppendVarI32Load(bodyIR: var coreir.BodyIR,
                                  addressSlot: int32,
                                  valueSlot: int32) =
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpIndexedLoadTag
    op.target = valueSlot
    add(op.operands, addressSlot)
    add(op.operands, valueSlot)
    add(bodyIR.ops, op)

fn PrimaryBodyIrAppendVarI32Store(bodyIR: var coreir.BodyIR,
                                   addressSlot: int32,
                                   valueSlot: int32) =
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpIndexedStoreTag
    op.target = addressSlot
    add(op.operands, addressSlot)
    add(op.operands, valueSlot)
    add(bodyIR.ops, op)

fn PrimaryBodyIrI32ValueSlotForText(bodyIR: var coreir.BodyIR,
                                     slotNames: var str[],
                                     varI32ParamNames: str[],
                                     textRaw: str): int32 =
    let text = strutil.Strip(textRaw)
    if len(text) <= 0:
        return -1
    let constVal = PrimaryBodyIrExtractIntFromText(text)
    if constVal != 0 || PrimaryBodyIrTextIsI32Zero(text):
        let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, coreir.LocalI32Tag)
        var constOp: coreir.BodyOp
        constOp.kind = coreir.BodyOpLoadConstTag
        constOp.target = slotId
        add(constOp.operands, coreir.LocalI32Tag)
        add(constOp.operands, constVal)
        add(bodyIR.ops, constOp)
        return slotId
    let slotId = PrimaryBodyIrFindArgSlot(slotNames, text)
    if slotId < 0:
        return -1
    if PrimaryBodyIrNameInList(varI32ParamNames, text):
        let valueSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                      slotNames,
                                                      PrimaryBodyIrVarI32ValueSlotName(text),
                                                      coreir.LocalI32Tag)
        PrimaryBodyIrAppendVarI32Load(bodyIR, slotId, valueSlot)
        return valueSlot
    if PrimaryBodyIrSlotType(bodyIR, slotId) != coreir.LocalI32Tag:
        return -1
    return slotId

fn PrimaryBodyIrScalarValueSlotForText(bodyIR: var coreir.BodyIR,
                                        slotNames: var str[],
                                        varI32ParamNames: str[],
                                        typedIr: texpr.TypedExprIr,
                                        sourcePath: str,
                                        textRaw: str,
                                        typeKind: int32): int32 =
    let text = strutil.Strip(textRaw)
    if len(text) <= 0:
        return -1
    if typeKind == coreir.LocalPtrTag && text == "nil":
        let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                   slotNames,
                                                   "nil#ptr_zero",
                                                   coreir.LocalPtrTag)
        var nilOp: coreir.BodyOp
        nilOp.kind = coreir.BodyOpLoadConstTag
        nilOp.target = slotId
        add(nilOp.operands, coreir.LocalPtrTag)
        add(nilOp.operands, 0)
        add(bodyIR.ops, nilOp)
        return slotId
    if typeKind == coreir.LocalI32Tag &&
       (text == "true" || text == "false"):
        var boolValue: int32
        if text == "true":
            boolValue = 1
        let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, coreir.LocalI32Tag)
        var boolOp: coreir.BodyOp
        boolOp.kind = coreir.BodyOpLoadConstTag
        boolOp.target = slotId
        add(boolOp.operands, coreir.LocalI32Tag)
        add(boolOp.operands, boolValue)
        add(bodyIR.ops, boolOp)
        return slotId
    let constVal = PrimaryBodyIrExtractIntFromText(text)
    if constVal != 0 || PrimaryBodyIrTextIsI32Zero(text):
        let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, typeKind)
        var constOp: coreir.BodyOp
        constOp.kind = coreir.BodyOpLoadConstTag
        constOp.target = slotId
        add(constOp.operands, typeKind)
        add(constOp.operands, constVal)
        add(bodyIR.ops, constOp)
        return slotId
    if typeKind == coreir.LocalI32Tag:
        var enumTypeName = ""
        var enumValue: int32
        if texpr.TypedExprIrLookupEnumConstValue(typedIr,
                                                sourcePath,
                                                text,
                                                enumTypeName,
                                                enumValue):
            let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, coreir.LocalI32Tag)
            var constOp: coreir.BodyOp
            constOp.kind = coreir.BodyOpLoadConstTag
            constOp.target = slotId
            add(constOp.operands, coreir.LocalI32Tag)
            add(constOp.operands, enumValue)
            add(bodyIR.ops, constOp)
            return slotId
        let ptrDerefText = PrimaryBodyIrUInt8PtrDerefPointerText(text)
        if ptrDerefText != "":
            let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, coreir.LocalI32Tag)
            if !PrimaryBodyIrAppendUInt8PtrDerefLoad(bodyIR, slotNames, text, slotId):
                return -1
            return slotId
    if typeKind == coreir.LocalI32Tag || typeKind == coreir.LocalI64Tag:
        var binPos: int32 = -1
        var binKind: int32
        let addPos = texpr.TypedExprFindTopLevelTextToken(text, "+")
        let subPos = texpr.TypedExprFindTopLevelTextToken(text, "-")
        if addPos > 0:
            binPos = addPos
            binKind = int32(texpr.TypedExprIrOpI32Add)
        elif subPos > 0:
            binPos = subPos
            binKind = int32(texpr.TypedExprIrOpI32Sub)
        if binPos > 0 && binPos + 1 < len(text):
            let lhsText = strutil.Strip(strings.SliceBytes(text, 0, binPos))
            let rhsText = strutil.Strip(strings.SliceBytes(text,
                                                           binPos + 1,
                                                           len(text) - binPos - 1))
            if lhsText == "" || rhsText == "":
                return -1
            let lhsSlot = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                              slotNames,
                                                              varI32ParamNames,
                                                              typedIr,
                                                              sourcePath,
                                                              lhsText,
                                                              typeKind)
            let rhsSlot = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                              slotNames,
                                                              varI32ParamNames,
                                                              typedIr,
                                                              sourcePath,
                                                              rhsText,
                                                              typeKind)
            if lhsSlot < 0 || rhsSlot < 0:
                return -1
            let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, text, typeKind)
            var binOp: coreir.BodyOp
            binOp.kind = coreir.BodyOpBinOpTag
            binOp.target = slotId
            add(binOp.operands, typeKind)
            add(binOp.operands, binKind)
            add(binOp.operands, lhsSlot)
            add(binOp.operands, rhsSlot)
            add(bodyIR.ops, binOp)
            return slotId
    let slotId = PrimaryBodyIrFindArgSlot(slotNames, text)
    if slotId >= 0:
        if PrimaryBodyIrNameInList(varI32ParamNames, text):
            return PrimaryBodyIrI32ValueSlotForText(bodyIR, slotNames, varI32ParamNames, text)
        if PrimaryBodyIrSlotType(bodyIR, slotId) == typeKind:
            return slotId
        return -1
    let globalType = PrimaryBodyIrTypedGlobalType(typedIr, sourcePath, text)
    if globalType == "":
        return -1
    var globalTypeKind: int32
    var globalSizeBytes: int32
    var globalAlignBytes: int32
    PrimaryBodyIrTypeShapeFromText(typedIr,
                                   sourcePath,
                                   globalType,
                                   globalTypeKind,
                                   globalSizeBytes,
                                   globalAlignBytes)
    if globalTypeKind != typeKind:
        return -1
    let globalSlotName = PrimaryBodyIrTypedGlobalSlotName(typedIr, sourcePath, text)
    if globalSlotName == "":
        return -1
    let globalSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                   slotNames,
                                                   globalSlotName,
                                                   typeKind)
    bodyIR.localSlots[globalSlot].placeKind = coreir.BodyPlaceGlobalAddressTag
    let valueSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                  slotNames,
                                                  Fmt"{globalSlotName}#global_value",
                                                  typeKind)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpGlobalLoadTag
    op.target = valueSlot
    add(op.operands, globalSlot)
    add(bodyIR.ops, op)
    return valueSlot

fn PrimaryBodyIrAddressSlotForName(bodyIR: var coreir.BodyIR,
                                    slotNames: var str[],
                                    lowering: lower.LoweringPlanStub,
                                    typedIr: texpr.TypedExprIr,
                                    typedFn: texpr.TypedExprIrFunction,
                                    irFunction: lower.PrimaryObjectIrFunction,
                                    sourcePath: str,
                                    lineNumber: int32,
                                    nameRaw: str,
                                    rootTypeHintName: str,
                                    rootTypeHint: str,
                                    addressPassKind: var int32): int32 =
    let name = strutil.Strip(nameRaw)
    addressPassKind = coreir.BodyCallPassParamAddressTag
    if name == "":
        addressPassKind = -1
        return -1
    if texpr.TypedExprTextIsSimpleFieldPath(name):
        let rootName = texpr.TypedExprAssignLhsRootName(name)
        let fieldPath = texpr.TypedExprAssignFieldPath(name)
        if rootName == "" || fieldPath == "":
            addressPassKind = -2
            return -1
        var rootType = ""
        if rootTypeHintName == rootName && rootTypeHint != "":
            rootType = rootTypeHint
        if rootType == "":
            rootType = PrimaryBodyIrBindingTypeForName(typedIr,
                                                       typedFn,
                                                       irFunction,
                                                       lineNumber,
                                                       rootName)
        if rootType == "":
            addressPassKind = -3
            return -1
        if PrimaryBodyIrTypeTextIsGenericPointer(rootType):
            addressPassKind = -10
            return -1
        var ownerType = rootType
        let pointeeType = PrimaryBodyIrPointeeTypeTextForSource(typedIr,
                                                                sourcePath,
                                                                rootType)
        let passRootPointer = pointeeType != ""
        if passRootPointer:
            ownerType = pointeeType
            if ownerType == "":
                addressPassKind = -11
                return -1
        var fieldType = ""
        var fieldOffsetBytes: int32
        var fieldSizeBytes: int32
        var fieldAlignBytes: int32
        var fieldMetaOk = PrimaryBodyIrLookupSingleFieldMeta(typedIr,
                                                             ownerType,
                                                             fieldPath,
                                                             fieldType,
                                                             fieldOffsetBytes,
                                                             fieldSizeBytes,
                                                             fieldAlignBytes)
        if !fieldMetaOk && PrimaryBodyIrTextHasDot(fieldPath):
            fieldMetaOk = texpr.TypedExprIrLookupFieldPathMeta(typedIr,
                                                               sourcePath,
                                                               ownerType,
                                                               fieldPath,
                                                               fieldType,
                                                               fieldOffsetBytes,
                                                               fieldSizeBytes,
                                                               fieldAlignBytes)
        if !fieldMetaOk:
            if pointeeType == "":
                addressPassKind = -12
            elif ownerType == "ChengMemHeader" && fieldPath == "rc":
                addressPassKind = -13
            elif ownerType == "ChengMemHeader":
                addressPassKind = -14
            elif fieldPath == "rc":
                addressPassKind = -15
            else:
                addressPassKind = -4
            return -1
        if fieldOffsetBytes != 0:
            addressPassKind = -5
            return -1
        let rootSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                              slotNames,
                                                              typedIr,
                                                              sourcePath,
                                                              rootName,
                                                              rootType)
        if rootSlot < 0 || rootSlot >= bodyIR.localSlots.len:
            addressPassKind = -6
            return -1
        if passRootPointer:
            if PrimaryBodyIrSlotType(bodyIR, rootSlot) != coreir.LocalPtrTag:
                addressPassKind = -7
                return -1
            addressPassKind = coreir.BodyCallPassStackValueTag
        return rootSlot
    let localSlot = PrimaryBodyIrFindArgSlot(slotNames, name)
    if localSlot >= 0:
        return localSlot
    let bindingType = PrimaryBodyIrBindingTypeForName(typedIr,
                                                      typedFn,
                                                      irFunction,
                                                      lineNumber,
                                                      name)
    if bindingType != "":
        return PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                  slotNames,
                                                  typedIr,
                                                  sourcePath,
                                                  name,
                                                  bindingType)
    let functionIndex = PrimaryFunctionTargetIndex(lowering.functionSymbolTexts,
                                                   lowering.functionSourcePaths,
                                                   sourcePath,
                                                   name)
    if functionIndex >= 0:
        let functionSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                         slotNames,
                                                         PrimaryBodyIrFunctionAddressSlotName(functionIndex),
                                                         coreir.LocalPtrTag)
        bodyIR.localSlots[functionSlot].placeKind = coreir.BodyPlaceGlobalAddressTag
        return functionSlot
    let globalType = PrimaryBodyIrTypedGlobalType(typedIr, sourcePath, name)
    if globalType == "":
        addressPassKind = -8
        return -1
    let globalSlotName = PrimaryBodyIrTypedGlobalSlotName(typedIr, sourcePath, name)
    if globalSlotName == "":
        addressPassKind = -9
        return -1
    var typeKind: int32
    var sizeBytes: int32
    var alignBytes: int32
    PrimaryBodyIrTypeShapeFromText(typedIr,
                                   sourcePath,
                                   globalType,
                                   typeKind,
                                   sizeBytes,
                                   alignBytes)
    let globalSlot = PrimaryBodyIrFindOrCreateSlotSized(bodyIR,
                                                        slotNames,
                                                        globalSlotName,
                                                        typeKind,
                                                        sizeBytes,
                                                        alignBytes)
    bodyIR.localSlots[globalSlot].placeKind = coreir.BodyPlaceGlobalAddressTag
    return globalSlot

fn PrimaryBodyIrLocalInitConstSlot(bodyIR: var coreir.BodyIR,
                                    slotNames: var str[],
                                    nameRaw: str,
                                    typeKind: int32,
                                    value: int32): int32 =
    let name = strutil.Strip(nameRaw)
    if name == "":
        return -1
    let slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                               slotNames,
                                               name,
                                               typeKind)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpLoadConstTag
    op.target = slotId
    add(op.operands, typeKind)
    add(op.operands, value)
    add(bodyIR.ops, op)
    return slotId

fn PrimaryBodyIrLocalInitValueSlot(bodyIR: var coreir.BodyIR,
                                    slotNames: var str[],
                                    varI32ParamNames: str[],
                                    typedIr: texpr.TypedExprIr,
                                    sourcePath: str,
                                    targetTypeRaw: str,
                                    targetTypeKind: int32,
                                    textRaw: str): int32 =
    var text = strutil.Strip(textRaw)
    if text == "":
        return -1
    let castInner = PrimaryBodyIrTypeCastInnerForTarget(text, targetTypeRaw)
    if castInner != "":
        text = castInner
    if targetTypeKind == coreir.LocalStrTag &&
       PrimaryBodyIrTextIsStringLiteral(text):
        return -1
    let sizeofValue = PrimaryBodyIrSizeofConst(typedIr, sourcePath, text)
    if sizeofValue >= 0:
        return PrimaryBodyIrLocalInitConstSlot(bodyIR,
                                              slotNames,
                                              Fmt"{targetTypeRaw}({text})",
                                              targetTypeKind,
                                              sizeofValue)
    let directSlot = PrimaryBodyIrFindArgSlot(slotNames, text)
    if directSlot >= 0:
        if PrimaryBodyIrSlotType(bodyIR, directSlot) == targetTypeKind:
            return directSlot
        if targetTypeKind == coreir.LocalI64Tag &&
           PrimaryBodyIrSlotType(bodyIR, directSlot) == coreir.LocalI32Tag:
            return directSlot
        return -1
    return PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                               slotNames,
                                               varI32ParamNames,
                                               typedIr,
                                               sourcePath,
                                               text,
                                               targetTypeKind)

fn PrimaryBodyIrDirectExternalCallTarget(symbolRaw: str): bool =
    return symbolRaw == "driver_c_str_from_utf8_copy_bridge" ||
           symbolRaw == "cheng_malloc" ||
           symbolRaw == "setMem" ||
           symbolRaw == "cheng_seq_str_add"

fn PrimaryBodyIrAppendHeapObjectAllocZero(bodyIR: var coreir.BodyIR,
                                           slotNames: var str[],
                                           typedIr: texpr.TypedExprIr,
                                           sourcePath: str,
                                           objectTypeText: str,
                                           targetSlot: int32,
                                           callOrdinal: var int32): bool =
    if targetSlot < 0 ||
       targetSlot >= bodyIR.localSlots.len ||
       PrimaryBodyIrSlotType(bodyIR, targetSlot) != coreir.LocalPtrTag:
        return false
    if objectTypeText == "":
        return false
    var allocSize: int32
    var allocAlign: int32
    var fieldCount: int32
    if !texpr.TypedExprIrLookupTypeLayout(typedIr,
                                          sourcePath,
                                          objectTypeText,
                                          allocSize,
                                          allocAlign,
                                          fieldCount):
        if !PrimaryBodyIrLookupColdCsgObjectLayout(typedIr,
                                                   objectTypeText,
                                                   allocSize,
                                                   allocAlign,
                                                   fieldCount):
            return false
    if allocSize <= 0 || allocAlign <= 0:
        return false
    let sizeSlot = PrimaryBodyIrLocalInitConstSlot(bodyIR,
                                                   slotNames,
                                                   Fmt"{bodyIR.localSlots[targetSlot].name}#new_size",
                                                   coreir.LocalI32Tag,
                                                   allocSize)
    let zeroSlot = PrimaryBodyIrLocalInitConstSlot(bodyIR,
                                                   slotNames,
                                                   Fmt"{bodyIR.localSlots[targetSlot].name}#new_zero",
                                                   coreir.LocalI32Tag,
                                                   0)
    if sizeSlot < 0 || zeroSlot < 0:
        return false
    var allocCall: coreir.CallOp
    allocCall.targetSymbol = "cheng_malloc"
    allocCall.resultSlot = targetSlot
    allocCall.resultPassKind = coreir.BodyCallPassStackValueTag
    add(allocCall.argSlots, sizeSlot)
    add(allocCall.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(bodyIR.callSequence, allocCall)
    var allocOp: coreir.BodyOp
    allocOp.kind = coreir.BodyOpCallTag
    allocOp.target = targetSlot
    add(allocOp.operands, callOrdinal)
    add(bodyIR.ops, allocOp)
    callOrdinal = callOrdinal + 1
    var zeroCall: coreir.CallOp
    zeroCall.targetSymbol = "setMem"
    zeroCall.resultSlot = -1
    zeroCall.resultPassKind = coreir.BodyCallPassStackValueTag
    add(zeroCall.argSlots, targetSlot)
    add(zeroCall.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(zeroCall.argSlots, zeroSlot)
    add(zeroCall.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(zeroCall.argSlots, sizeSlot)
    add(zeroCall.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(bodyIR.callSequence, zeroCall)
    var zeroOp: coreir.BodyOp
    zeroOp.kind = coreir.BodyOpCallTag
    zeroOp.target = -1
    add(zeroOp.operands, callOrdinal)
    add(bodyIR.ops, zeroOp)
    callOrdinal = callOrdinal + 1
    return true

fn PrimaryBodyIrAppendNewObjectValue(bodyIR: var coreir.BodyIR,
                                      slotNames: var str[],
                                      typedIr: texpr.TypedExprIr,
                                      sourcePath: str,
                                      newExprTextRaw: str,
                                      targetSlot: int32,
                                      callOrdinal: var int32): bool =
    let newTypeText = PrimaryBodyIrWholeCallInnerForHead(newExprTextRaw, "new")
    return PrimaryBodyIrAppendHeapObjectAllocZero(bodyIR,
                                                  slotNames,
                                                  typedIr,
                                                  sourcePath,
                                                  newTypeText,
                                                  targetSlot,
                                                  callOrdinal)

fn PrimaryBodyIrFindTopLevelBrace(text: str): int32 =
    var parenDepth: int32
    var bracketDepth: int32
    for i in 0..<len(text):
        let ch = text[i]
        if ch == '(':
            parenDepth = parenDepth + 1
        elif ch == ')':
            parenDepth = parenDepth - 1
        elif ch == '[':
            bracketDepth = bracketDepth + 1
        elif ch == ']':
            bracketDepth = bracketDepth - 1
        elif ch == '{' && parenDepth == 0 && bracketDepth == 0:
            return i
    return -1

fn PrimaryBodyIrAppendObjectConstructorValue(bodyIR: var coreir.BodyIR,
                                              slotNames: var str[],
                                              varI32ParamNames: str[],
                                              typedIr: texpr.TypedExprIr,
                                              sourcePath: str,
                                              targetTypeRaw: str,
                                              rhsTextRaw: str,
                                              targetSlot: int32,
                                              callOrdinal: var int32): bool =
    let rhsText = strutil.Strip(rhsTextRaw)
    let bracePos = PrimaryBodyIrFindTopLevelBrace(rhsText)
    if bracePos <= 0 || len(rhsText) <= bracePos + 1 || rhsText[len(rhsText) - 1] != '}':
        return false
    let ctorType = texpr.TypedExprNormalizeTypeText(strutil.Strip(strings.SliceBytes(rhsText, 0, bracePos)))
    let targetType = texpr.TypedExprNormalizeTypeText(targetTypeRaw)
    if ctorType == "" || targetType == "" || ctorType != targetType:
        return false
    if !PrimaryBodyIrAppendHeapObjectAllocZero(bodyIR,
                                               slotNames,
                                               typedIr,
                                               sourcePath,
                                               ctorType,
                                               targetSlot,
                                               callOrdinal):
        return false
    let fieldsText = strings.SliceBytes(rhsText,
                                        bracePos + 1,
                                        len(rhsText) - bracePos - 2)
    let fieldItems = texpr.TypedExprSplitTopLevelCsv(fieldsText)
    for itemIndex in 0..<fieldItems.len:
        let item = strutil.Strip(fieldItems[itemIndex])
        if item == "":
            continue
        let colonPos = texpr.TypedExprFindTopLevelTextToken(item, ":")
        if colonPos <= 0:
            return false
        let fieldName = strutil.Strip(strings.SliceBytes(item, 0, colonPos))
        let valueText = strutil.Strip(strings.SliceBytes(item,
                                                        colonPos + 1,
                                                        len(item) - colonPos - 1))
        if fieldName == "" || valueText == "":
            return false
        var fieldType: str
        var fieldOffsetBytes: int32
        var fieldSizeBytes: int32
        var fieldAlignBytes: int32
        if !PrimaryBodyIrLookupSingleFieldMeta(typedIr,
                                               ctorType,
                                               fieldName,
                                               fieldType,
                                               fieldOffsetBytes,
                                               fieldSizeBytes,
                                               fieldAlignBytes):
            if !texpr.TypedExprIrLookupFieldPathMeta(typedIr,
                                                     sourcePath,
                                                     ctorType,
                                                     fieldName,
                                                     fieldType,
                                                     fieldOffsetBytes,
                                                     fieldSizeBytes,
                                                     fieldAlignBytes):
                return false
        var fieldTypeKind: int32
        var fieldShapeSize: int32
        var fieldShapeAlign: int32
        PrimaryBodyIrTypeShapeFromText(typedIr,
                                       sourcePath,
                                       fieldType,
                                       fieldTypeKind,
                                       fieldShapeSize,
                                       fieldShapeAlign)
        if fieldSizeBytes <= 0:
            fieldSizeBytes = fieldShapeSize
        if fieldSizeBytes <= 0:
            return false
        let valueSlot = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                            slotNames,
                                                            varI32ParamNames,
                                                            typedIr,
                                                            sourcePath,
                                                            valueText,
                                                            fieldTypeKind)
        if valueSlot < 0 ||
           PrimaryLocalSlotSizeOf(bodyIR.localSlots[valueSlot]) < fieldSizeBytes:
            return false
        var storeOp: coreir.BodyOp
        storeOp.kind = coreir.BodyOpFieldStoreTag
        storeOp.target = targetSlot
        add(storeOp.operands, targetSlot)
        add(storeOp.operands, valueSlot)
        add(storeOp.operands, fieldOffsetBytes)
        add(storeOp.operands, fieldSizeBytes)
        add(bodyIR.ops, storeOp)
    return true

fn PrimaryBodyIrAppendStringLiteralValue(bodyIR: var coreir.BodyIR,
                                         slotNames: var str[],
                                         literalTextRaw: str,
                                         targetSlot: int32,
                                         callOrdinal: var int32): bool =
    if targetSlot < 0 ||
       targetSlot >= bodyIR.localSlots.len ||
       PrimaryBodyIrSlotType(bodyIR, targetSlot) != coreir.LocalStrTag:
        return false
    if !PrimaryBodyIrTextIsStringLiteral(literalTextRaw):
        return false
    let literalPayload = PrimaryBodyIrStringLiteralPayload(literalTextRaw)
    let literalOrdinal = bodyIR.cstringLiterals.len
    let lenSlot = PrimaryBodyIrLocalInitConstSlot(bodyIR,
                                                  slotNames,
                                                  Fmt"{bodyIR.localSlots[targetSlot].name}#str_literal_len#{literalOrdinal}",
                                                  coreir.LocalI32Tag,
                                                  len(literalPayload))
    if lenSlot < 0:
        return false
    let literalId = coreir.BodyIRAppendCStringLiteral(bodyIR,
                                                      literalPayload,
                                                      "")
    var call: coreir.CallOp
    call.targetSymbol = "driver_c_str_from_utf8_copy_bridge"
    call.resultSlot = targetSlot
    call.resultPassKind = coreir.BodyCallPassSretResultTag
    add(call.argSlots, coreir.CallArgSlotCString(literalId))
    add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(call.argSlots, lenSlot)
    add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(bodyIR.callSequence, call)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    op.target = targetSlot
    add(op.operands, callOrdinal)
    add(bodyIR.ops, op)
    callOrdinal = callOrdinal + 1
    return true

fn PrimaryBodyIrAppendZeroLocalSlot(bodyIR: var coreir.BodyIR,
                                     slotNames: var str[],
                                     targetSlot: int32,
                                     callOrdinal: var int32): bool =
    if targetSlot < 0 || targetSlot >= bodyIR.localSlots.len:
        return false
    let byteCount = PrimaryLocalSlotSizeOf(bodyIR.localSlots[targetSlot])
    if byteCount <= 0:
        return false
    let zeroSlot = PrimaryBodyIrLocalInitConstSlot(bodyIR,
                                                   slotNames,
                                                   Fmt"{bodyIR.localSlots[targetSlot].name}#zero",
                                                   coreir.LocalI32Tag,
                                                   0)
    let sizeSlot = PrimaryBodyIrLocalInitConstSlot(bodyIR,
                                                   slotNames,
                                                   Fmt"{bodyIR.localSlots[targetSlot].name}#size",
                                                   coreir.LocalI32Tag,
                                                   byteCount)
    if zeroSlot < 0 || sizeSlot < 0:
        return false
    var call: coreir.CallOp
    call.targetSymbol = "setMem"
    call.resultSlot = -1
    call.resultPassKind = coreir.BodyCallPassStackValueTag
    add(call.argSlots, coreir.CallArgSlotAddress(targetSlot))
    add(call.argPassKinds, coreir.BodyCallPassParamAddressTag)
    add(call.argSlots, zeroSlot)
    add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(call.argSlots, sizeSlot)
    add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(bodyIR.callSequence, call)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    op.target = -1
    add(op.operands, callOrdinal)
    add(bodyIR.ops, op)
    callOrdinal = callOrdinal + 1
    return true

fn PrimaryBodyIrAppendSeqStrAddValueSlot(bodyIR: var coreir.BodyIR,
                                          seqSlot: int32,
                                          valueSlot: int32,
                                          callOrdinal: var int32): bool =
    if seqSlot < 0 ||
       seqSlot >= bodyIR.localSlots.len ||
       valueSlot < 0 ||
       valueSlot >= bodyIR.localSlots.len:
        return false
    if PrimaryBodyIrSlotType(bodyIR, seqSlot) != coreir.LocalAggregateTag ||
       PrimaryBodyIrSlotType(bodyIR, valueSlot) != coreir.LocalStrTag:
        return false
    var call: coreir.CallOp
    call.targetSymbol = "cheng_seq_str_add"
    call.resultSlot = -1
    call.resultPassKind = coreir.BodyCallPassStackValueTag
    add(call.argSlots, coreir.CallArgSlotAddress(seqSlot))
    add(call.argPassKinds, coreir.BodyCallPassParamAddressTag)
    add(call.argSlots, valueSlot)
    add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(bodyIR.callSequence, call)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    op.target = -1
    add(op.operands, callOrdinal)
    add(bodyIR.ops, op)
    callOrdinal = callOrdinal + 1
    return true

fn PrimaryBodyIrAppendSeqStrAddBuiltin(bodyIR: var coreir.BodyIR,
                                        slotNames: var str[],
                                        typedIr: texpr.TypedExprIr,
                                        typedFn: texpr.TypedExprIrFunction,
                                        irFunction: lower.PrimaryObjectIrFunction,
                                        stmt: texpr.TypedExprIrStatement,
                                        callOrdinal: var int32): bool =
    if stmt.callKind != texpr.TypedExprCallBuiltin ||
       stmt.callCallee != "add" ||
       stmt.callArgCount != 2:
        return false
    let argNames = PrimaryBodyIrCallArgNames(stmt.callArgsText)
    if argNames.len != 2:
        return false
    let seqName = strutil.Strip(argNames[0])
    let valueText = strutil.Strip(argNames[1])
    if seqName == "" || valueText == "":
        return false
    let seqType = PrimaryBodyIrBindingTypeForName(typedIr,
                                                  typedFn,
                                                  irFunction,
                                                  stmt.lineNumber,
                                                  seqName)
    if !PrimaryBodyIrTypeTextIsSeqStr(seqType):
        return false
    let seqSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                     slotNames,
                                                     typedIr,
                                                     stmt.sourcePath,
                                                     seqName,
                                                     seqType)
    if seqSlot < 0 || seqSlot >= bodyIR.localSlots.len:
        return false
    var valueSlot = PrimaryBodyIrFindArgSlot(slotNames, valueText)
    if valueSlot < 0 && PrimaryBodyIrTextIsStringLiteral(valueText):
        valueSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                  slotNames,
                                                  Fmt"{seqName}#add_value#{bodyIR.cstringLiterals.len}",
                                                  coreir.LocalStrTag)
        if valueSlot < 0 ||
           !PrimaryBodyIrAppendStringLiteralValue(bodyIR,
                                                  slotNames,
                                                  valueText,
                                                  valueSlot,
                                                  callOrdinal):
            return false
    if valueSlot < 0 ||
       valueSlot >= bodyIR.localSlots.len ||
       PrimaryBodyIrSlotType(bodyIR, valueSlot) != coreir.LocalStrTag:
        return false
    return PrimaryBodyIrAppendSeqStrAddValueSlot(bodyIR,
                                                 seqSlot,
                                                 valueSlot,
                                                 callOrdinal)

fn PrimaryBodyIrFmtLiteralPayload(textRaw: str): str =
    let text = strutil.Strip(textRaw)
    if len(text) < 5:
        return ""
    if !PrimaryStartsWith(text, "Fmt"):
        return ""
    var quotePos = 3
    while quotePos < len(text) && (text[quotePos] == ' ' || text[quotePos] == '\t'):
        quotePos = quotePos + 1
    if quotePos >= len(text) || text[quotePos] != '"':
        return ""
    if text[len(text) - 1] != '"':
        return ""
    return strings.SliceBytes(text, quotePos + 1, len(text) - quotePos - 2)

fn PrimaryBodyIrAppendFmtPieceSlot(bodyIR: var coreir.BodyIR,
                                    slotNames: var str[],
                                    targetSlot: int32,
                                    seqSlot: int32,
                                    pieceSlot: int32,
                                    callOrdinal: var int32): bool =
    let _ = targetSlot
    return PrimaryBodyIrAppendSeqStrAddValueSlot(bodyIR,
                                                 seqSlot,
                                                 pieceSlot,
                                                 callOrdinal)

fn PrimaryBodyIrAppendFmtLiteralPiece(bodyIR: var coreir.BodyIR,
                                       slotNames: var str[],
                                       targetSlot: int32,
                                       seqSlot: int32,
                                       literalText: str,
                                       pieceIndex: int32,
                                       callOrdinal: var int32): bool =
    let litSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                slotNames,
                                                Fmt"{bodyIR.localSlots[targetSlot].name}#fmt_lit#{pieceIndex}",
                                                coreir.LocalStrTag)
    if litSlot < 0:
        return false
    let quoted = Fmt"\"{literalText}\""
    if !PrimaryBodyIrAppendStringLiteralValue(bodyIR,
                                              slotNames,
                                              quoted,
                                              litSlot,
                                              callOrdinal):
        return false
    return PrimaryBodyIrAppendFmtPieceSlot(bodyIR,
                                           slotNames,
                                           targetSlot,
                                           seqSlot,
                                           litSlot,
                                           callOrdinal)

fn PrimaryBodyIrAppendFmtExprPiece(bodyIR: var coreir.BodyIR,
                                    slotNames: var str[],
                                    targetSlot: int32,
                                    seqSlot: int32,
                                    exprTextRaw: str,
                                    pieceIndex: int32,
                                    callOrdinal: var int32): bool =
    let exprText = strutil.Strip(exprTextRaw)
    if exprText == "":
        return false
    var valueSlot = PrimaryBodyIrFindArgSlot(slotNames, exprText)
    if valueSlot < 0 && PrimaryBodyIrTextIsStringLiteral(exprText):
        valueSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                  slotNames,
                                                  Fmt"{bodyIR.localSlots[targetSlot].name}#fmt_expr_lit#{pieceIndex}",
                                                  coreir.LocalStrTag)
        if valueSlot < 0 ||
           !PrimaryBodyIrAppendStringLiteralValue(bodyIR,
                                                  slotNames,
                                                  exprText,
                                                  valueSlot,
                                                  callOrdinal):
            return false
    if valueSlot < 0 ||
       valueSlot >= bodyIR.localSlots.len ||
       PrimaryBodyIrSlotType(bodyIR, valueSlot) != coreir.LocalStrTag:
        return false
    return PrimaryBodyIrAppendFmtPieceSlot(bodyIR,
                                           slotNames,
                                           targetSlot,
                                           seqSlot,
                                           valueSlot,
                                           callOrdinal)

fn PrimaryBodyIrAppendFmtLiteralValue(bodyIR: var coreir.BodyIR,
                                       slotNames: var str[],
                                       rhsText: str,
                                       targetSlot: int32,
                                       callOrdinal: var int32): bool =
    if targetSlot < 0 ||
       targetSlot >= bodyIR.localSlots.len ||
       PrimaryBodyIrSlotType(bodyIR, targetSlot) != coreir.LocalStrTag:
        return false
    let payload = PrimaryBodyIrFmtLiteralPayload(rhsText)
    if payload == "":
        return false
    let seqSlot = PrimaryBodyIrFindOrCreateSlotSized(bodyIR,
                                                     slotNames,
                                                     Fmt"{bodyIR.localSlots[targetSlot].name}#fmt_parts",
                                                     coreir.LocalAggregateTag,
                                                     16,
                                                     8)
    if seqSlot < 0:
        return false
    if !PrimaryBodyIrAppendZeroLocalSlot(bodyIR,
                                         slotNames,
                                         seqSlot,
                                         callOrdinal):
        return false
    var currentLiteral = ""
    var pieceIndex: int32
    var i: int32
    while i < len(payload):
        let ch = payload[i]
        if ch == '{':
            if i + 1 < len(payload) && payload[i + 1] == '{':
                currentLiteral = Fmt"{currentLiteral}{{"
                i = i + 2
                continue
            if len(currentLiteral) > 0:
                if !PrimaryBodyIrAppendFmtLiteralPiece(bodyIR,
                                                       slotNames,
                                                       targetSlot,
                                                       seqSlot,
                                                       currentLiteral,
                                                       pieceIndex,
                                                       callOrdinal):
                    return false
                pieceIndex = pieceIndex + 1
                currentLiteral = ""
            let exprStart = i + 1
            var exprEnd = -1
            var inExprString = false
            var inExprChar = false
            var parenDepth: int32
            var bracketDepth: int32
            var braceDepth: int32
            var cursor = exprStart
            while cursor < len(payload):
                let exprCh = payload[cursor]
                if !inExprChar && exprCh == '"' && (cursor <= 0 || payload[cursor - 1] != '\\'):
                    inExprString = !inExprString
                    cursor = cursor + 1
                    continue
                if !inExprString && exprCh == '\'' && (cursor <= 0 || payload[cursor - 1] != '\\'):
                    inExprChar = !inExprChar
                    cursor = cursor + 1
                    continue
                if inExprString || inExprChar:
                    cursor = cursor + 1
                    continue
                if exprCh == '(':
                    parenDepth = parenDepth + 1
                elif exprCh == ')':
                    if parenDepth > 0:
                        parenDepth = parenDepth - 1
                elif exprCh == '[':
                    bracketDepth = bracketDepth + 1
                elif exprCh == ']':
                    if bracketDepth > 0:
                        bracketDepth = bracketDepth - 1
                elif exprCh == '{':
                    braceDepth = braceDepth + 1
                elif exprCh == '}':
                    if parenDepth == 0 && bracketDepth == 0 && braceDepth == 0:
                        exprEnd = cursor
                        break
                    if braceDepth > 0:
                        braceDepth = braceDepth - 1
                cursor = cursor + 1
            if exprEnd < exprStart:
                return false
            let exprText = strings.SliceBytes(payload, exprStart, exprEnd - exprStart)
            if !PrimaryBodyIrAppendFmtExprPiece(bodyIR,
                                                slotNames,
                                                targetSlot,
                                                seqSlot,
                                                exprText,
                                                pieceIndex,
                                                callOrdinal):
                return false
            pieceIndex = pieceIndex + 1
            i = exprEnd + 1
            continue
        if ch == '}':
            if i + 1 < len(payload) && payload[i + 1] == '}':
                currentLiteral = Fmt"{currentLiteral}}}"
                i = i + 2
                continue
            return false
        currentLiteral = Fmt"{currentLiteral}{strings.CharToStr(ch)}"
        i = i + 1
    if len(currentLiteral) > 0 || pieceIndex == 0:
        if !PrimaryBodyIrAppendFmtLiteralPiece(bodyIR,
                                               slotNames,
                                               targetSlot,
                                               seqSlot,
                                               currentLiteral,
                                               pieceIndex,
                                               callOrdinal):
            return false
        pieceIndex = pieceIndex + 1
    let sepSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                slotNames,
                                                Fmt"{bodyIR.localSlots[targetSlot].name}#fmt_sep",
                                                coreir.LocalStrTag)
    if sepSlot < 0 ||
       !PrimaryBodyIrAppendStringLiteralValue(bodyIR,
                                              slotNames,
                                              "\"\"",
                                              sepSlot,
                                              callOrdinal):
        return false
    var call: coreir.CallOp
    call.targetSymbol = "cheng_strutils_join_bridge"
    call.resultSlot = targetSlot
    call.resultPassKind = coreir.BodyCallPassSretResultTag
    add(call.argSlots, seqSlot)
    add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(call.argSlots, sepSlot)
    add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
    add(bodyIR.callSequence, call)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    op.target = targetSlot
    add(op.operands, callOrdinal)
    add(bodyIR.ops, op)
    callOrdinal = callOrdinal + 1
    return true

fn PrimaryBodyIrAppendLocalDeclInitializer(bodyIR: var coreir.BodyIR,
                                            slotNames: var str[],
                                            varI32ParamNames: str[],
                                            typedIr: texpr.TypedExprIr,
                                            stmt: texpr.TypedExprIrStatement,
                                            targetSlot: int32,
                                            callOrdinal: var int32): bool =
    let rhsText = strutil.Strip(stmt.surfaceText)
    if rhsText == "" || targetSlot < 0 || targetSlot >= bodyIR.localSlots.len:
        return false
    let targetTypeKind = PrimaryBodyIrSlotType(bodyIR, targetSlot)
    if targetTypeKind == coreir.LocalPtrTag &&
       PrimaryBodyIrAppendObjectConstructorValue(bodyIR,
                                                 slotNames,
                                                 varI32ParamNames,
                                                 typedIr,
                                                 stmt.sourcePath,
                                                 stmt.resultType,
                                                 rhsText,
                                                 targetSlot,
                                                 callOrdinal):
        return true
    if targetTypeKind == coreir.LocalPtrTag &&
       PrimaryBodyIrWholeCallInnerForHead(rhsText, "new") != "":
        return PrimaryBodyIrAppendNewObjectValue(bodyIR,
                                                 slotNames,
                                                 typedIr,
                                                 stmt.sourcePath,
                                                 rhsText,
                                                 targetSlot,
                                                 callOrdinal)
    if targetTypeKind == coreir.LocalStrTag &&
       PrimaryBodyIrTextIsStringLiteral(rhsText):
        return PrimaryBodyIrAppendStringLiteralValue(bodyIR,
                                                     slotNames,
                                                     rhsText,
                                                     targetSlot,
                                                     callOrdinal)
    if targetTypeKind == coreir.LocalStrTag &&
       PrimaryBodyIrFmtLiteralPayload(rhsText) != "":
        return PrimaryBodyIrAppendFmtLiteralValue(bodyIR,
                                                  slotNames,
                                                  rhsText,
                                                  targetSlot,
                                                  callOrdinal)
    if targetTypeKind == coreir.LocalI32Tag &&
       PrimaryBodyIrUInt8PtrDerefPointerText(rhsText) != "":
        return PrimaryBodyIrAppendUInt8PtrDerefLoad(bodyIR,
                                                    slotNames,
                                                    rhsText,
                                                    targetSlot)
    if targetTypeKind == coreir.LocalI32Tag &&
       PrimaryBodyIrConditionHasAnd(rhsText):
        return PrimaryBodyIrAppendBoolConditionAssign(bodyIR,
                                                      slotNames,
                                                      typedIr,
                                                      stmt.sourcePath,
                                                      rhsText,
                                                      targetSlot)
    if stmt.assignValueFieldName != "":
        return PrimaryBodyIrAppendFieldLoadToSlot(bodyIR,
                                                  slotNames,
                                                  typedIr,
                                                  stmt.sourcePath,
                                                  stmt.assignValueRootName,
                                                  stmt.assignValueRootType,
                                                  stmt.assignValueFieldOffsetBytes,
                                                  stmt.assignValueFieldSizeBytes,
                                                  targetSlot)
    if targetTypeKind != coreir.LocalI32Tag &&
       targetTypeKind != coreir.LocalI64Tag &&
       targetTypeKind != coreir.LocalPtrTag:
        return false
    let addPos = texpr.TypedExprFindTopLevelTextToken(rhsText, "+")
    if addPos >= 0 &&
       (targetTypeKind == coreir.LocalI32Tag || targetTypeKind == coreir.LocalI64Tag):
        let lhsText = strutil.Strip(strings.SliceBytes(rhsText, 0, addPos))
        let rhsPart = strutil.Strip(strings.SliceBytes(rhsText,
                                                       addPos + 1,
                                                       len(rhsText) - addPos - 1))
        let lhsSlot = PrimaryBodyIrLocalInitValueSlot(bodyIR,
                                                      slotNames,
                                                      varI32ParamNames,
                                                      typedIr,
                                                      stmt.sourcePath,
                                                      stmt.resultType,
                                                      targetTypeKind,
                                                      lhsText)
        let rhsSlot = PrimaryBodyIrLocalInitValueSlot(bodyIR,
                                                      slotNames,
                                                      varI32ParamNames,
                                                      typedIr,
                                                      stmt.sourcePath,
                                                      stmt.resultType,
                                                      targetTypeKind,
                                                      rhsPart)
        if lhsSlot < 0 || rhsSlot < 0:
            return false
        var op: coreir.BodyOp
        op.kind = coreir.BodyOpBinOpTag
        op.target = targetSlot
        add(op.operands, targetTypeKind)
        add(op.operands, int32(texpr.TypedExprIrOpI32Add))
        add(op.operands, lhsSlot)
        add(op.operands, rhsSlot)
        add(bodyIR.ops, op)
        return true
    let valueSlot = PrimaryBodyIrLocalInitValueSlot(bodyIR,
                                                   slotNames,
                                                   varI32ParamNames,
                                                   typedIr,
                                                   stmt.sourcePath,
                                                   stmt.resultType,
                                                   targetTypeKind,
                                                   rhsText)
    if valueSlot < 0:
        return false
    if valueSlot == targetSlot:
        return true
    if targetTypeKind == coreir.LocalI64Tag &&
       PrimaryBodyIrSlotType(bodyIR, valueSlot) == coreir.LocalI32Tag:
        let zeroSlot = PrimaryBodyIrLocalInitConstSlot(bodyIR,
                                                       slotNames,
                                                       Fmt"{stmt.bindingName}#i64_zero",
                                                       coreir.LocalI64Tag,
                                                       0)
        if zeroSlot < 0:
            return false
        var widenOp: coreir.BodyOp
        widenOp.kind = coreir.BodyOpBinOpTag
        widenOp.target = targetSlot
        add(widenOp.operands, coreir.LocalI64Tag)
        add(widenOp.operands, int32(texpr.TypedExprIrOpI32Add))
        add(widenOp.operands, valueSlot)
        add(widenOp.operands, zeroSlot)
        add(bodyIR.ops, widenOp)
        return true
    if PrimaryBodyIrSlotType(bodyIR, valueSlot) != targetTypeKind:
        return false
    var copyOp: coreir.BodyOp
    copyOp.kind = coreir.BodyOpCopyLocalTag
    copyOp.target = targetSlot
    add(copyOp.operands, valueSlot)
    add(bodyIR.ops, copyOp)
    return true

fn PrimaryBodyIrAppendCallArgs(bodyIR: var coreir.BodyIR,
                                slotNames: var str[],
                                call: var coreir.CallOp,
                                lowering: lower.LoweringPlanStub,
                                typedIr: texpr.TypedExprIr,
                                typedFn: texpr.TypedExprIrFunction,
                                irFunction: lower.PrimaryObjectIrFunction,
                                stmt: texpr.TypedExprIrStatement,
                                varI32ParamNames: str[],
                                callOrdinal: var int32,
                                failureDetail0: var int32,
                                failureDetail1: var int32): bool =
    if stmt.callArgCount <= 0:
        return true
    let argNames = PrimaryBodyIrCallArgNames(stmt.callArgsText)
    for argIndex in 0..<argNames.len:
        let argName = argNames[argIndex]
        let targetParamType = PrimaryBodyIrTargetParamType(typedIr, stmt, argIndex)
        let targetNeedsAddress = PrimaryBodyIrTypeTextIsVarParam(targetParamType)
        if PrimaryBodyIrTextIsI32Zero(argName):
            if targetNeedsAddress:
                failureDetail0 = 11
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstFalse())
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif PrimaryBodyIrTextIsI32One(argName):
            if targetNeedsAddress:
                failureDetail0 = 12
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstTrue())
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif argName == "true":
            if targetNeedsAddress:
                failureDetail0 = 12
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstTrue())
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif argName == "false":
            if targetNeedsAddress:
                failureDetail0 = 13
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstFalse())
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif PrimaryBodyIrCstringCastArgText(argName) != "":
            if targetNeedsAddress:
                failureDetail0 = 21
                failureDetail1 = argIndex
                return false
            let castArg = PrimaryBodyIrCstringCastArgText(argName)
            if PrimaryBodyIrTextIsStringLiteral(castArg):
                let literalId = coreir.BodyIRAppendCStringLiteral(bodyIR,
                                                                  PrimaryBodyIrStringLiteralPayload(castArg),
                                                                  "")
                add(call.argSlots, coreir.CallArgSlotCString(literalId))
                add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
            else:
                let slotId = PrimaryBodyIrFindArgSlot(slotNames, castArg)
                if slotId < 0:
                    failureDetail0 = 22
                    failureDetail1 = argIndex
                    return false
                if PrimaryBodyIrSlotType(bodyIR, slotId) != coreir.LocalPtrTag:
                    failureDetail0 = 23
                    failureDetail1 = PrimaryBodyIrSlotType(bodyIR, slotId)
                    return false
                add(call.argSlots, slotId)
                add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif PrimaryBodyIrTextIsStringLiteral(argName):
            if targetNeedsAddress:
                failureDetail0 = 14
                failureDetail1 = argIndex
                return false
            if texpr.TypedExprNormalizeTypeText(targetParamType) == "str":
                let strSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                            slotNames,
                                                            Fmt"{stmt.callTarget}#arg#{argIndex}#str_literal#{bodyIR.cstringLiterals.len}",
                                                            coreir.LocalStrTag)
                if strSlot < 0 ||
                   !PrimaryBodyIrAppendStringLiteralValue(bodyIR,
                                                          slotNames,
                                                          argName,
                                                          strSlot,
                                                          callOrdinal):
                    failureDetail0 = 25
                    failureDetail1 = argIndex
                    return false
                add(call.argSlots, strSlot)
                add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
            else:
                let literalId = coreir.BodyIRAppendCStringLiteral(bodyIR,
                                                                  PrimaryBodyIrStringLiteralPayload(argName),
                                                                  "")
                add(call.argSlots, coreir.CallArgSlotCString(literalId))
                add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
        elif argName == "nil":
            if targetNeedsAddress:
                failureDetail0 = 15
                failureDetail1 = argIndex
                return false
            add(call.argSlots, coreir.CallArgSlotConstPtrNil())
            add(call.argPassKinds, coreir.BodyCallPassPtrNilTag)
        elif PrimaryBodyIrPtrAddressArgName(argName) != "":
            if targetNeedsAddress:
                failureDetail0 = 16
                failureDetail1 = argIndex
                return false
            let addressName = PrimaryBodyIrPtrAddressArgName(argName)
            if texpr.TypedExprTextIsSimpleFieldPath(addressName):
                let addressRootName = texpr.TypedExprAssignLhsRootName(addressName)
                let addressFieldPath = texpr.TypedExprAssignFieldPath(addressName)
                if addressRootName == stmt.assignRootName &&
                   addressFieldPath == stmt.assignFieldName &&
                   stmt.assignRootType != "" &&
                   stmt.assignFieldOffsetBytes == 0:
                    let rootSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                                          slotNames,
                                                                          typedIr,
                                                                          stmt.sourcePath,
                                                                          stmt.assignRootName,
                                                                          stmt.assignRootType)
                    if rootSlot < 0 || rootSlot >= bodyIR.localSlots.len:
                        failureDetail0 = 241
                        failureDetail1 = argIndex
                        return false
                    if PrimaryBodyIrPointeeTypeTextForSource(typedIr,
                                                             stmt.sourcePath,
                                                             stmt.assignRootType) != "":
                        add(call.argSlots, rootSlot)
                        add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
                    else:
                        add(call.argSlots, coreir.CallArgSlotAddress(rootSlot))
                        add(call.argPassKinds, coreir.BodyCallPassParamAddressTag)
                    continue
            var addressPassKind: int32
            let addressSlot = PrimaryBodyIrAddressSlotForName(bodyIR,
                                                              slotNames,
                                                              lowering,
                                                              typedIr,
                                                              typedFn,
                                                              irFunction,
                                                              stmt.sourcePath,
                                                              stmt.lineNumber,
                                                              addressName,
                                                              stmt.assignRootName,
                                                              stmt.assignRootType,
                                                              addressPassKind)
            if addressSlot < 0 || addressSlot >= bodyIR.localSlots.len:
                if addressPassKind < 0:
                    failureDetail0 = 2400 - addressPassKind
                else:
                    failureDetail0 = 24
                failureDetail1 = argIndex
                return false
            if addressPassKind == coreir.BodyCallPassStackValueTag:
                add(call.argSlots, addressSlot)
                add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
            elif bodyIR.localSlots[addressSlot].placeKind == coreir.BodyPlaceGlobalAddressTag:
                add(call.argSlots, addressSlot)
                add(call.argPassKinds, coreir.BodyCallPassGlobalAddressTag)
            else:
                add(call.argSlots, coreir.CallArgSlotAddress(addressSlot))
                add(call.argPassKinds, coreir.BodyCallPassParamAddressTag)
        else:
            var slotId = PrimaryBodyIrFindArgSlot(slotNames, argName)
            let fieldRootName = texpr.TypedExprAssignLhsRootName(argName)
            let fieldRootType = PrimaryBodyIrBindingTypeForName(typedIr,
                                                                typedFn,
                                                                irFunction,
                                                                stmt.lineNumber,
                                                                fieldRootName)
            if fieldRootType != "" && texpr.TypedExprTextIsSimpleFieldPath(argName):
                if targetNeedsAddress:
                    failureDetail0 = 32
                    failureDetail1 = argIndex
                    return false
                slotId = PrimaryBodyIrMaterializeFieldArgSlot(bodyIR,
                                                              slotNames,
                                                              typedIr,
                                                              typedFn,
                                                              irFunction,
                                                              stmt.sourcePath,
                                                              stmt.lineNumber,
                                                              argName,
                                                              failureDetail0,
                                                              failureDetail1)
                if slotId < 0:
                    if failureDetail0 == 0:
                        failureDetail0 = 43
                        failureDetail1 = argIndex
                    return false
                add(call.argSlots, slotId)
                add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
                continue
            if targetNeedsAddress:
                if slotId < 0:
                    let valueType = texpr.TypedExprStripVarType(targetParamType)
                    var layoutSourcePath = stmt.callTargetSourcePath
                    if layoutSourcePath == "":
                        layoutSourcePath = stmt.sourcePath
                    slotId = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                slotNames,
                                                                typedIr,
                                                                layoutSourcePath,
                                                                argName,
                                                                valueType)
                elif !(PrimaryBodyIrLocalIsParam(bodyIR.localSlots[slotId]) &&
                       PrimaryBodyIrSlotType(bodyIR, slotId) == coreir.LocalPtrTag):
                    let valueType = texpr.TypedExprStripVarType(targetParamType)
                    var layoutSourcePath = stmt.callTargetSourcePath
                    if layoutSourcePath == "":
                        layoutSourcePath = stmt.sourcePath
                    slotId = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                slotNames,
                                                                typedIr,
                                                                layoutSourcePath,
                                                                argName,
                                                                valueType)
                if slotId < 0:
                    failureDetail0 = 31
                    failureDetail1 = argIndex
                    return false
                if PrimaryBodyIrLocalIsParam(bodyIR.localSlots[slotId]) &&
                   PrimaryBodyIrSlotType(bodyIR, slotId) == coreir.LocalPtrTag:
                    add(call.argSlots, slotId)
                    add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
                else:
                    add(call.argSlots, coreir.CallArgSlotAddress(slotId))
                    add(call.argPassKinds, coreir.BodyCallPassParamAddressTag)
                continue
            elif PrimaryBodyIrNameInList(varI32ParamNames, argName):
                slotId = PrimaryBodyIrI32ValueSlotForText(bodyIR, slotNames, varI32ParamNames, argName)
            elif slotId < 0:
                if PrimaryBodyIrTextHasCallSurface(argName):
                    var binOpPos: int32
                    binOpPos = -1
                    for bi in 0..<len(argName):
                        if argName[bi] == '/':
                            binOpPos = bi
                            break
                    if binOpPos < 0:
                        for bi in 0..<len(argName):
                            if argName[bi] == '+':
                                binOpPos = bi
                                break
                    if binOpPos < 0:
                        for bi in 0..<len(argName):
                            if argName[bi] == '-':
                                binOpPos = bi
                                break
                    if binOpPos > 0 && binOpPos + 1 < len(argName):
                        let binLeftRaw = strings.SliceBytes(argName, 0, binOpPos)
                        let binLeftText = strutil.Strip(binLeftRaw)
                        let binRightRaw = strings.SliceBytes(argName,
                                                              binOpPos + 1,
                                                              len(argName) - binOpPos - 1)
                        let binRightText = strutil.Strip(binRightRaw)
                        if binLeftText != "" && binRightText != "":
                            let lhsSlot: int32 = PrimaryBodyIrFindArgSlot(slotNames,
                                                                          binLeftText)
                            let rhsSlot: int32 = PrimaryBodyIrFindArgSlot(slotNames,
                                                                          binRightText)
                            if lhsSlot >= 0 && rhsSlot >= 0:
                                var binOpKind: int32
                                binOpKind = 0
                                if argName[binOpPos] == '/':
                                    binOpKind = int32(texpr.TypedExprIrOpI32Sdiv)
                                elif argName[binOpPos] == '+':
                                    binOpKind = int32(texpr.TypedExprIrOpI32Add)
                                elif argName[binOpPos] == '-':
                                    binOpKind = int32(texpr.TypedExprIrOpI32Sub)
                                if binOpKind != 0:
                                    var binTypeKind: int32
                                    binTypeKind = bodyIR.localSlots[lhsSlot].typeKind
                                    let rhsTypeKind2 = bodyIR.localSlots[rhsSlot].typeKind
                                    if binTypeKind != rhsTypeKind2:
                                        if binTypeKind == coreir.LocalI32Tag && rhsTypeKind2 == coreir.LocalI64Tag:
                                            binTypeKind = coreir.LocalI64Tag
                                        elif binTypeKind == coreir.LocalI64Tag && rhsTypeKind2 == coreir.LocalI32Tag:
                                            binTypeKind = coreir.LocalI64Tag
                                    var binResultTag: int32
                                    binResultTag = coreir.LocalI32Tag
                                    if binTypeKind == coreir.LocalI64Tag:
                                        binResultTag = coreir.LocalI64Tag
                                    slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                                           slotNames,
                                                                           argName,
                                                                           binResultTag)
                                    if slotId >= 0:
                                        var binOp: coreir.BodyOp
                                        binOp.kind = coreir.BodyOpBinOpTag
                                        binOp.target = slotId
                                        add(binOp.operands, binTypeKind)
                                        add(binOp.operands, binOpKind)
                                        add(binOp.operands, lhsSlot)
                                        add(binOp.operands, rhsSlot)
                                        add(bodyIR.ops, binOp)
                    if slotId < 0:
                        slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                               slotNames,
                                                               argName,
                                                               coreir.LocalI32Tag)
                else:
                    slotId = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                                 slotNames,
                                                                 varI32ParamNames,
                                                                 typedIr,
                                                                 stmt.sourcePath,
                                                                 argName,
                                                                 coreir.LocalI32Tag)
                    if slotId < 0:
                        if PrimaryBodyIrTextHasFieldOrIndex(argName):
                            failureDetail0 = 44
                            failureDetail1 = argIndex
                            return false
                        slotId = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                               slotNames,
                                                               argName,
                                                               coreir.LocalI32Tag)
            if slotId < 0:
                failureDetail0 = 42
                failureDetail1 = argIndex
                return false
            add(call.argSlots, slotId)
            add(call.argPassKinds, coreir.BodyCallPassStackValueTag)
    return true

fn PrimaryBodyIrAppendCallOp(bodyIR: var coreir.BodyIR,
                              slotNames: var str[],
                              lowering: lower.LoweringPlanStub,
                              typedIr: texpr.TypedExprIr,
                              typedFn: texpr.TypedExprIrFunction,
                              irFunction: lower.PrimaryObjectIrFunction,
                              stmt: texpr.TypedExprIrStatement,
                              resultSlot: int32,
                              varI32ParamNames: str[],
                              callOrdinal: var int32): int32 =
    var call: coreir.CallOp
    call.targetSymbol = stmt.callTarget
    call.resultSlot = resultSlot
    call.resultPassKind = coreir.BodyCallPassStackValueTag
    if resultSlot >= 0 && resultSlot < bodyIR.localSlots.len:
        let resultType = bodyIR.localSlots[resultSlot].typeKind
        if resultType == coreir.LocalStrTag ||
           resultType == coreir.LocalAggregateTag:
            call.resultPassKind = coreir.BodyCallPassSretResultTag
    var failureDetail0: int32
    var failureDetail1: int32
    if !PrimaryBodyIrAppendCallArgs(bodyIR,
                                    slotNames,
                                    call,
                                    lowering,
                                    typedIr,
                                    typedFn,
                                    irFunction,
                                    stmt,
                                    varI32ParamNames,
                                    callOrdinal,
                                    failureDetail0,
                                    failureDetail1):
        PrimaryBodyIrAppendInvalidOp(bodyIR,
                                     stmt.lineNumber,
                                     int32(stmt.kind),
                                     failureDetail0,
                                     failureDetail1)
        return resultSlot
    add(bodyIR.callSequence, call)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    op.target = resultSlot
    add(op.operands, callOrdinal)
    add(bodyIR.ops, op)
    callOrdinal = callOrdinal + 1
    return resultSlot

fn PrimaryBodyIrPatchCallTargetSymbols(bodyIR: var coreir.BodyIR,
                                         callTargets: str[],
                                         callImportcSymbols: str[]) =
    var sourceOrdinal: int32
    for ci in 0..<bodyIR.callSequence.len:
        if PrimaryBodyIrDirectExternalCallTarget(bodyIR.callSequence[ci].targetSymbol):
            continue
        var targetSymbol = ""
        if sourceOrdinal < callImportcSymbols.len && len(callImportcSymbols[sourceOrdinal]) > 0:
            targetSymbol = callImportcSymbols[sourceOrdinal]
        elif sourceOrdinal < callTargets.len && len(callTargets[sourceOrdinal]) > 0:
            targetSymbol = callTargets[sourceOrdinal]
        if len(targetSymbol) > 0:
            bodyIR.callSequence[ci].targetSymbol = targetSymbol
        sourceOrdinal = sourceOrdinal + 1

fn PrimaryBodyIrAppendReturnTerm(bodyIR: var coreir.BodyIR,
                                  currentBlockStart: var int32,
                                  resultSlot: int32,
                                  resultTypeKind: int32,
                                  constValue: int32,
                                  hasConst: bool) =
    var retTerm: coreir.BodyTerm
    retTerm.kind = coreir.BodyTermReturnTag
    retTerm.resultSlot = resultSlot
    if hasConst:
        add(retTerm.operands, PrimaryStatementReturnModeI32Const())
        add(retTerm.operands, constValue)
    else:
        add(retTerm.operands, resultTypeKind)
    let retTermIndex = coreir.BodyIRAppendTerm(bodyIR, retTerm)
    let blockOpCount = bodyIR.ops.len - currentBlockStart
    let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, blockOpCount, retTermIndex)
    currentBlockStart = bodyIR.ops.len

fn PrimaryBuildBodyIrCfgAppendOp(bodyIR: var coreir.BodyIR,
                                    op: coreir.BodyOp): int32 =
    add(bodyIR.ops, op)
    return bodyIR.ops.len - 1

fn PrimaryBuildBodyIrCfgBeginBlock(bodyIR: var coreir.BodyIR,
                                     pendingBlockStart: var int32):
    pendingBlockStart = bodyIR.ops.len

fn PrimaryBuildBodyIrCfgEndBlockReturn(bodyIR: var coreir.BodyIR,
                                         pendingBlockStart: var int32,
                                         returnOperands: int32[]):
    let opStart = pendingBlockStart
    let opCount = bodyIR.ops.len - pendingBlockStart
    var term: coreir.BodyTerm
    term.kind = coreir.BodyTermReturnTag
    term.resultSlot = -1
    term.operands = returnOperands
    let termIndex = coreir.BodyIRAppendTerm(bodyIR, term)
    let _ = coreir.BodyIRAppendBlock(bodyIR, opStart, opCount, termIndex)
    pendingBlockStart = bodyIR.ops.len

fn PrimaryBuildBodyIrCfgEndBlockCbr(bodyIR: var coreir.BodyIR,
                                      pendingBlockStart: var int32,
                                      condSlot: int32,
                                      condKind: int32,
                                      lhsSlot: int32,
                                      rhsSlot: int32,
                                      rhsConst: int32): int32 =
    let opStart = pendingBlockStart
    let opCount = bodyIR.ops.len - pendingBlockStart
    var term: coreir.BodyTerm
    term.kind = coreir.BodyTermCbrTag
    term.conditionKind = condKind
    term.resultSlot = condSlot
    term.lhsSlot = lhsSlot
    term.rhsSlot = rhsSlot
    if rhsSlot < 0:
        add(term.operands, rhsConst)
    term.trueBlock = bodyIR.blocks.len + 1
    term.falseBlock = bodyIR.blocks.len + 2
    let termIndex = coreir.BodyIRAppendTerm(bodyIR, term)
    let _ = coreir.BodyIRAppendBlock(bodyIR, opStart, opCount, termIndex)
    pendingBlockStart = bodyIR.ops.len
    return termIndex

fn PrimaryBuildBodyIrCfgEndBlockBr(bodyIR: var coreir.BodyIR,
                                     pendingBlockStart: var int32):
    let opStart = pendingBlockStart
    let opCount = bodyIR.ops.len - pendingBlockStart
    var term: coreir.BodyTerm
    term.kind = coreir.BodyTermBrTag
    term.conditionKind = coreir.BodyCondInvalidTag
    term.resultSlot = -1
    term.lhsSlot = -1
    term.rhsSlot = -1
    term.trueBlock = -1
    term.falseBlock = -1
    let termIndex = coreir.BodyIRAppendTerm(bodyIR, term)
    let _ = coreir.BodyIRAppendBlock(bodyIR, opStart, opCount, termIndex)
    pendingBlockStart = bodyIR.ops.len

fn PrimaryBuildBodyIrCfgResolveBranchTargets(bodyIR: var coreir.BodyIR,
                                                blockTermTargets: var int32[]):
    for bi in 0..<bodyIR.terms.len:
        if bodyIR.terms[bi].kind == coreir.BodyTermCbrTag:
            if bi < blockTermTargets.len && blockTermTargets[bi] >= 0:
                bodyIR.terms[bi].falseBlock = blockTermTargets[bi]
            elif bodyIR.terms[bi].falseBlock >= bodyIR.blocks.len:
                bodyIR.terms[bi].trueBlock = -1
                bodyIR.terms[bi].falseBlock = -1
                bodyIR.terms[bi].kind = coreir.BodyTermBrTag

fn PrimaryBodyIrTextHasFieldOrIndex(text: str): bool =
    for i in 0..<len(text):
        if text[i] == '.' || text[i] == '[' || text[i] == ']':
            return true
    return false

fn PrimaryBodyIrTextHasCallSurface(text: str): bool =
    for i in 0..<len(text):
        if text[i] == '(' || text[i] == ')':
            return true
    return false

fn PrimaryBodyIrAppendI32Assign(bodyIR: var coreir.BodyIR,
                                 slotNames: var str[],
                                 varI32ParamNames: str[],
                                 lowering: lower.LoweringPlanStub,
                                 typedIr: texpr.TypedExprIr,
                                 typedFn: texpr.TypedExprIrFunction,
                                 irFunction: lower.PrimaryObjectIrFunction,
                                 stmt: texpr.TypedExprIrStatement,
                                 callOrdinal: var int32): bool =
    let lhsName = strutil.Strip(stmt.bindingName)
    let rhsText = strutil.Strip(stmt.surfaceText)
    if len(lhsName) <= 0 || len(rhsText) <= 0:
        return false
    let lhsPointerText = PrimaryBodyIrUInt8PtrDerefPointerText(lhsName)
    if lhsPointerText != "":
        var storeFailureDetail: int32
        if !PrimaryBodyIrAppendUInt8PtrDerefStore(bodyIR,
                                                  slotNames,
                                                  varI32ParamNames,
                                                  typedIr,
                                                  stmt.sourcePath,
                                                  lhsName,
                                                  rhsText,
                                                  storeFailureDetail):
            PrimaryBodyIrAppendInvalidOp(bodyIR,
                                         stmt.lineNumber,
                                         int32(stmt.kind),
                                         storeFailureDetail,
                                         0)
        return true
    var lhsGlobalType = PrimaryBodyIrTypedGlobalType(typedIr, stmt.sourcePath, lhsName)
    if lhsGlobalType == "" &&
       stmt.assignRootGlobalFlag &&
       stmt.assignRootType != "":
        lhsGlobalType = stmt.assignRootType
    if lhsGlobalType != "" && stmt.assignFieldName == "":
        var lhsGlobalTypeKind: int32
        var lhsGlobalTypeSizeBytes: int32
        var lhsGlobalTypeAlignBytes: int32
        PrimaryBodyIrTypeShapeFromText(typedIr,
                                       stmt.sourcePath,
                                       lhsGlobalType,
                                       lhsGlobalTypeKind,
                                       lhsGlobalTypeSizeBytes,
                                       lhsGlobalTypeAlignBytes)
        if lhsGlobalTypeKind != coreir.LocalI32Tag &&
           lhsGlobalTypeKind != coreir.LocalI64Tag &&
           lhsGlobalTypeKind != coreir.LocalPtrTag:
            return false
        var lhsGlobalSlotName = PrimaryBodyIrTypedGlobalSlotName(typedIr, stmt.sourcePath, lhsName)
        if lhsGlobalSlotName == "" &&
           stmt.assignRootGlobalFlag &&
           stmt.assignRootSourcePath != "":
            lhsGlobalSlotName = Fmt"{stmt.assignRootSourcePath}::{lhsName}"
        if lhsGlobalSlotName == "":
            return false
        var valueSlot: int32
        valueSlot = -1
        if stmt.assignValueOpKind == texpr.TypedExprIrOpI32Add ||
           stmt.assignValueOpKind == texpr.TypedExprIrOpI32Sub:
            if stmt.assignValueLhsText == "" || stmt.assignValueRhsText == "":
                return false
            let leftSlot = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                               slotNames,
                                                               varI32ParamNames,
                                                               typedIr,
                                                               stmt.sourcePath,
                                                               stmt.assignValueLhsText,
                                                               lhsGlobalTypeKind)
            let rightSlot = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                                slotNames,
                                                                varI32ParamNames,
                                                                typedIr,
                                                                stmt.sourcePath,
                                                                stmt.assignValueRhsText,
                                                                lhsGlobalTypeKind)
            if leftSlot < 0 || rightSlot < 0:
                return false
            valueSlot = leftSlot
            var op: coreir.BodyOp
            op.kind = coreir.BodyOpBinOpTag
            op.target = valueSlot
            add(op.operands, lhsGlobalTypeKind)
            add(op.operands, int32(stmt.assignValueOpKind))
            add(op.operands, leftSlot)
            add(op.operands, rightSlot)
            add(bodyIR.ops, op)
        else:
            valueSlot = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                            slotNames,
                                                            varI32ParamNames,
                                                            typedIr,
                                                            stmt.sourcePath,
                                                            rhsText,
                                                            lhsGlobalTypeKind)
        if valueSlot < 0:
            return false
        let globalSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                       slotNames,
                                                       lhsGlobalSlotName,
                                                       lhsGlobalTypeKind)
        bodyIR.localSlots[globalSlot].placeKind = coreir.BodyPlaceGlobalAddressTag
        var storeOp: coreir.BodyOp
        storeOp.kind = coreir.BodyOpGlobalStoreTag
        storeOp.target = valueSlot
        add(storeOp.operands, globalSlot)
        add(bodyIR.ops, storeOp)
        return true
    if stmt.assignFieldName == "" &&
       stmt.assignValueFieldName != "":
        if PrimaryBodyIrTextHasFieldOrIndex(lhsName):
            return false
        let lhsSlot = PrimaryBodyIrFindSlotIndex(slotNames, lhsName)
        let baseSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                              slotNames,
                                                              typedIr,
                                                              stmt.sourcePath,
                                                              stmt.assignValueRootName,
                                                              stmt.assignValueRootType)
        let byteCount = stmt.assignValueFieldSizeBytes
        if lhsSlot < 0 || baseSlot < 0 || byteCount <= 0 ||
           PrimaryLocalSlotSizeOf(bodyIR.localSlots[lhsSlot]) < byteCount:
            return false
        var loadOp: coreir.BodyOp
        loadOp.kind = coreir.BodyOpFieldLoadTag
        loadOp.target = lhsSlot
        add(loadOp.operands, baseSlot)
        add(loadOp.operands, lhsSlot)
        add(loadOp.operands, stmt.assignValueFieldOffsetBytes)
        add(loadOp.operands, byteCount)
        add(bodyIR.ops, loadOp)
        return true
    if stmt.assignFieldName != "":
        let baseSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                              slotNames,
                                                              typedIr,
                                                              stmt.sourcePath,
                                                              stmt.assignRootName,
                                                              stmt.assignRootType)
        var byteCount = stmt.assignFieldSizeBytes
        if baseSlot < 0 || byteCount <= 0:
            return false
        var valueSlot: int32
        valueSlot = -1
        if stmt.callTarget != "":
            let callResultType = PrimaryBodyIrResolvedCallResultType(typedIr, stmt)
            valueSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                           slotNames,
                                                           typedIr,
                                                           PrimaryBodyIrCallResultLayoutSourcePath(stmt),
                                                           rhsText,
                                                           callResultType)
            if valueSlot < 0 ||
               PrimaryLocalSlotSizeOf(bodyIR.localSlots[valueSlot]) < byteCount:
                return false
            let _ = PrimaryBodyIrAppendCallOp(bodyIR,
                                              slotNames,
                                              lowering,
                                              typedIr,
                                              typedFn,
                                              irFunction,
                                              stmt,
                                              valueSlot,
                                              varI32ParamNames,
                                              callOrdinal)
        elif stmt.assignValueFieldName != "":
            let valueBaseSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                                       slotNames,
                                                                       typedIr,
                                                                       stmt.sourcePath,
                                                                       stmt.assignValueRootName,
                                                                       stmt.assignValueRootType)
            let valueByteCount = stmt.assignValueFieldSizeBytes
            if valueBaseSlot < 0:
            if valueByteCount <= 0:
                valueByteCount = byteCount
            if valueByteCount != byteCount:
                return false
            valueSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                           slotNames,
                                                           typedIr,
                                                           stmt.sourcePath,
                                                           Fmt"{stmt.assignValueRootName}.{stmt.assignValueFieldName}#field_value",
                                                           stmt.assignValueFieldType)
            if PrimaryLocalSlotSizeOf(bodyIR.localSlots[valueSlot]) < valueByteCount:
                return false
            var loadOp: coreir.BodyOp
            loadOp.kind = coreir.BodyOpFieldLoadTag
            loadOp.target = valueSlot
            add(loadOp.operands, valueBaseSlot)
            add(loadOp.operands, valueSlot)
            add(loadOp.operands, stmt.assignValueFieldOffsetBytes)
            add(loadOp.operands, valueByteCount)
            add(bodyIR.ops, loadOp)
        elif byteCount == 4:
            valueSlot = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                            slotNames,
                                                            varI32ParamNames,
                                                            typedIr,
                                                            stmt.sourcePath,
                                                            rhsText,
                                                            coreir.LocalI32Tag)
        else:
            if rhsText == "[]" || rhsText == "{}":
                valueSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                           slotNames,
                                                           Fmt"{stmt.assignFieldName}_zero",
                                                           coreir.LocalAggregateTag)
            else:
                valueSlot = PrimaryBodyIrFindArgSlot(slotNames, rhsText)
        if valueSlot < 0 ||
           (rhsText != "[]" && rhsText != "{}" &&
            PrimaryLocalSlotSizeOf(bodyIR.localSlots[valueSlot]) < byteCount):
            return false
        var storeOp: coreir.BodyOp
        storeOp.kind = coreir.BodyOpFieldStoreTag
        storeOp.target = baseSlot
        add(storeOp.operands, baseSlot)
        add(storeOp.operands, valueSlot)
        add(storeOp.operands, stmt.assignFieldOffsetBytes)
        add(storeOp.operands, byteCount)
        add(bodyIR.ops, storeOp)
        return true
    if PrimaryBodyIrTextHasFieldOrIndex(lhsName):
        var dotPos: int32
        dotPos = -1
        for ci in 0..<len(lhsName):
            if lhsName[ci] == '.':
                dotPos = ci
        if dotPos < 0:
            return false
        let rootName = strutil.Strip(strings.SliceBytes(lhsName, 0, dotPos))
        var baseSlot = PrimaryBodyIrFindOrCreateFieldBaseSlot(bodyIR,
                                                              slotNames,
                                                              typedIr,
                                                              stmt.sourcePath,
                                                              rootName,
                                                              stmt.assignRootType)
        if baseSlot < 0:
            return false
        var valueSlot = PrimaryBodyIrFindArgSlot(slotNames, rhsText)
        if valueSlot < 0:
            valueSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                           slotNames,
                                                           typedIr,
                                                           stmt.sourcePath,
                                                           rhsText,
                                                           stmt.resultType)
        if valueSlot < 0:
            return false
        var storeOp: coreir.BodyOp
        storeOp.kind = coreir.BodyOpFieldStoreTag
        storeOp.target = baseSlot
        add(storeOp.operands, baseSlot)
        add(storeOp.operands, valueSlot)
        add(storeOp.operands, 0)
        add(storeOp.operands, 8)
        add(bodyIR.ops, storeOp)
        return true
    let lhsSlot = PrimaryBodyIrFindSlotIndex(slotNames, lhsName)
    if lhsSlot < 0:
        return false
    if PrimaryBodyIrSlotType(bodyIR, lhsSlot) == coreir.LocalStrTag &&
       PrimaryBodyIrFmtLiteralPayload(rhsText) != "":
        return PrimaryBodyIrAppendFmtLiteralValue(bodyIR,
                                                  slotNames,
                                                  rhsText,
                                                  lhsSlot,
                                                  callOrdinal)
    if PrimaryBodyIrSlotType(bodyIR, lhsSlot) == coreir.LocalI32Tag &&
       PrimaryBodyIrConditionHasAnd(rhsText):
        return PrimaryBodyIrAppendBoolConditionAssign(bodyIR,
                                                      slotNames,
                                                      typedIr,
                                                      stmt.sourcePath,
                                                      rhsText,
                                                      lhsSlot)
    let lhsIsVarI32 = PrimaryBodyIrNameInList(varI32ParamNames, lhsName)
    if stmt.callTarget != "":
        var resultSlot = lhsSlot
        var copyCallResultToLhs = false
        let resultTypeText = PrimaryBodyIrResolvedCallResultType(typedIr, stmt)
        if lhsIsVarI32:
            resultSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                       slotNames,
                                                       PrimaryBodyIrVarI32ValueSlotName(lhsName),
                                                       coreir.LocalI32Tag)
        elif PrimaryBodyIrSlotType(bodyIR, lhsSlot) == coreir.LocalStrTag ||
             PrimaryBodyIrSlotType(bodyIR, lhsSlot) == coreir.LocalAggregateTag:
            var tempResultType = resultTypeText
            if tempResultType == "" || tempResultType == "unknown":
                tempResultType = stmt.resultType
            if tempResultType == "" || tempResultType == "unknown":
                return false
            resultSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                            slotNames,
                                                            typedIr,
                                                            PrimaryBodyIrCallResultLayoutSourcePath(stmt),
                                                            Fmt"{lhsName}#call_result#{stmt.lineNumber}",
                                                            tempResultType)
            if resultSlot < 0:
                return false
            copyCallResultToLhs = true
        elif resultTypeText != "":
            var resultTypeKind: int32
            var resultSizeBytes: int32
            var resultAlignBytes: int32
            PrimaryBodyIrTypeShapeFromText(typedIr,
                                           PrimaryBodyIrCallResultLayoutSourcePath(stmt),
                                           resultTypeText,
                                           resultTypeKind,
                                           resultSizeBytes,
                                           resultAlignBytes)
            if resultTypeKind != PrimaryBodyIrSlotType(bodyIR, lhsSlot):
                return false
        let _ = PrimaryBodyIrAppendCallOp(bodyIR,
                                          slotNames,
                                          lowering,
                                          typedIr,
                                          typedFn,
                                          irFunction,
                                          stmt,
                                          resultSlot,
                                          varI32ParamNames,
                                          callOrdinal)
        if lhsIsVarI32:
            PrimaryBodyIrAppendVarI32Store(bodyIR, lhsSlot, resultSlot)
        elif copyCallResultToLhs:
            var copyOp: coreir.BodyOp
            copyOp.kind = coreir.BodyOpCopyLocalTag
            copyOp.target = lhsSlot
            add(copyOp.operands, resultSlot)
            add(bodyIR.ops, copyOp)
        return true
    if !lhsIsVarI32 && PrimaryBodyIrSlotType(bodyIR, lhsSlot) != coreir.LocalI32Tag:
        let rhsSlot = PrimaryBodyIrFindArgSlot(slotNames, rhsText)
        if rhsSlot >= 0:
            var copyOp: coreir.BodyOp
            copyOp.kind = coreir.BodyOpCopyLocalTag
            copyOp.target = lhsSlot
            add(copyOp.operands, rhsSlot)
            add(bodyIR.ops, copyOp)
            return true
        return false
    var targetSlot = lhsSlot
    if lhsIsVarI32:
        targetSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR,
                                                  slotNames,
                                                  PrimaryBodyIrVarI32ValueSlotName(lhsName),
                                                  coreir.LocalI32Tag)
    let addPos = texpr.TypedExprFindTopLevelTextToken(rhsText, "+")
    if addPos >= 0:
        let rhsLhs = strutil.Strip(strings.SliceBytes(rhsText, 0, addPos))
        let rhsRhs = strutil.Strip(strings.SliceBytes(rhsText,
                                                     addPos + 1,
                                                     len(rhsText) - addPos - 1))
        let lhsValueSlot = PrimaryBodyIrI32ValueSlotForText(bodyIR,
                                                            slotNames,
                                                            varI32ParamNames,
                                                            rhsLhs)
        let rhsValueSlot = PrimaryBodyIrI32ValueSlotForText(bodyIR,
                                                            slotNames,
                                                            varI32ParamNames,
                                                            rhsRhs)
        if lhsValueSlot < 0 || rhsValueSlot < 0:
            return false
        var op: coreir.BodyOp
        op.kind = coreir.BodyOpBinOpTag
        op.target = targetSlot
        add(op.operands, coreir.LocalI32Tag)
        add(op.operands, int32(texpr.TypedExprIrOpI32Add))
        add(op.operands, lhsValueSlot)
        add(op.operands, rhsValueSlot)
        add(bodyIR.ops, op)
    else:
        let valueSlot = PrimaryBodyIrScalarValueSlotForText(bodyIR,
                                                            slotNames,
                                                            varI32ParamNames,
                                                            typedIr,
                                                            stmt.sourcePath,
                                                            rhsText,
                                                            PrimaryBodyIrSlotType(bodyIR, targetSlot))
        if valueSlot < 0:
            return false
        if valueSlot != targetSlot:
            var copyOp: coreir.BodyOp
            copyOp.kind = coreir.BodyOpCopyLocalTag
            copyOp.target = targetSlot
            add(copyOp.operands, valueSlot)
            add(bodyIR.ops, copyOp)
    if lhsIsVarI32:
        PrimaryBodyIrAppendVarI32Store(bodyIR, lhsSlot, targetSlot)
    return true

fn PrimaryBodyIrStructuredBodyEnd(typedIr: texpr.TypedExprIr,
                                   stmtIndex: int32,
                                   stmtEndRaw: int32): int32 =
    var stmtEnd = stmtEndRaw
    if stmtEnd > typedIr.statements.len:
        stmtEnd = typedIr.statements.len
    if stmtIndex < 0 || stmtIndex >= stmtEnd:
        return stmtEnd
    let stmt = typedIr.statements[stmtIndex]
    var bodyEnd = stmtEnd
    for si in stmtIndex + 1..<stmtEnd:
        let scanStmt = typedIr.statements[si]
        if scanStmt.lineIndent > 0 && scanStmt.lineIndent <= stmt.lineIndent:
            bodyEnd = si
            break
    return bodyEnd

fn PrimaryBodyIrBuildForRangeLoop(bodyIR: var coreir.BodyIR,
                                    slotNames: var str[],
                                    nextOpIndex: var int32,
                                    currentBlockStart: var int32,
                                    typedIr: texpr.TypedExprIr,
                                    stmt: texpr.TypedExprIrStatement,
                                    stmtIndex: int32,
                                    stmtEnd: int32,
                                    pendingFalseTerm: var int32): int32 =
    let headerText = strutil.Strip(stmt.surfaceText)
    let forBodyEnd = PrimaryBodyIrStructuredBodyEnd(typedIr, stmtIndex, stmtEnd)
    var inPos = -1
    var endCheckN = len(headerText) - 3
    for ci in 0..<endCheckN:
        if headerText[ci] == ' ' && headerText[ci + 1] == 'i' && headerText[ci + 2] == 'n' && headerText[ci + 3] == ' ':
            inPos = ci
            break
    var rangeText = headerText
    if inPos > 0:
        var afterIn = inPos + 4
        var rangeLen = len(headerText) - afterIn
        rangeText = strings.SliceBytes(headerText, afterIn, rangeLen)
        var rLen = len(rangeText)
        if rLen > 0:
            var lastCh = rangeText[rLen - 1]
            if lastCh == ':':
                rangeText = strings.SliceBytes(rangeText, 0, rLen - 1)
        rangeText = strutil.Strip(rangeText)
    var rangeStart: int32
    var rangeEnd = rangeText
    var exclPos = -1
    var exclCheckN = len(rangeText) - 2
    for ci in 0..<exclCheckN:
        if rangeText[ci] == '.' && rangeText[ci + 1] == '.' && rangeText[ci + 2] == '<':
            exclPos = ci
            break
    if exclPos > 0:
        var startText = strings.SliceBytes(rangeText, 0, exclPos)
        var stripped = strutil.Strip(startText)
        rangeStart = PrimaryBodyIrExtractIntFromText(stripped)
        var afterExcl = exclPos + 3
        var endLen = len(rangeText) - afterExcl
        rangeEnd = strings.SliceBytes(rangeText, afterExcl, endLen)
        rangeEnd = strutil.Strip(rangeEnd)
    let idxSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, stmt.bindingName, coreir.LocalI32Tag)
    var initOp: coreir.BodyOp
    initOp.kind = coreir.BodyOpLoadConstTag
    initOp.target = idxSlot
    add(initOp.operands, coreir.LocalI32Tag)
    add(initOp.operands, rangeStart)
    add(bodyIR.ops, initOp)
    nextOpIndex = nextOpIndex + 1
    let boundSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, rangeEnd, coreir.LocalI32Tag)
    var cbrTerm: coreir.BodyTerm
    cbrTerm.kind = coreir.BodyTermCbrTag
    cbrTerm.conditionKind = coreir.BodyCondI32LtTag
    cbrTerm.lhsSlot = idxSlot
    cbrTerm.rhsSlot = boundSlot
    cbrTerm.resultSlot = -1
    cbrTerm.trueBlock = -1
    cbrTerm.falseBlock = -1
    let cbrIdx = coreir.BodyIRAppendTerm(bodyIR, cbrTerm)
    let blockCount = bodyIR.ops.len - currentBlockStart
    let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, blockCount, cbrIdx)
    currentBlockStart = bodyIR.ops.len
    pendingFalseTerm = cbrIdx
    return forBodyEnd

fn PrimaryBodyIrBuildWhileLoopHeader(bodyIR: var coreir.BodyIR,
                                      slotNames: var str[],
                                      nextOpIndex: var int32,
                                      currentBlockStart: var int32,
                                      typedIr: texpr.TypedExprIr,
                                      stmt: texpr.TypedExprIrStatement,
                                      stmtIndex: int32,
                                      stmtEnd: int32,
                                      pendingWhileHeaderBlock: var int32,
                                      pendingWhileCbrTerm: var int32): int32 =
    let whileBodyEnd = PrimaryBodyIrStructuredBodyEnd(typedIr, stmtIndex, stmtEnd)
    let condText = PrimaryBodyIrConditionText(stmt.surfaceText)
    var lhsSlot: int32
    var rhsSlot: int32
    var cmpTag: int32
    if !PrimaryBodyIrEmitConditionOps(bodyIR,
                                      slotNames,
                                      typedIr,
                                      stmt.sourcePath,
                                      condText,
                                      lhsSlot,
                                      rhsSlot,
                                      cmpTag,
                                      nextOpIndex):
        PrimaryBodyIrAppendInvalidOp(bodyIR,
                                     stmt.lineNumber,
                                     int32(stmt.kind),
                                     81,
                                     0)
        pendingWhileHeaderBlock = -1
        pendingWhileCbrTerm = -1
        return whileBodyEnd
    var cbrTerm: coreir.BodyTerm
    cbrTerm.kind = coreir.BodyTermCbrTag
    cbrTerm.conditionKind = cmpTag
    cbrTerm.lhsSlot = lhsSlot
    cbrTerm.rhsSlot = rhsSlot
    cbrTerm.resultSlot = -1
    cbrTerm.trueBlock = -1
    cbrTerm.falseBlock = -1
    let cbrTermIndex = coreir.BodyIRAppendTerm(bodyIR, cbrTerm)
    let cbrBlockOpCount = bodyIR.ops.len - currentBlockStart
    pendingWhileHeaderBlock = coreir.BodyIRAppendBlock(bodyIR,
                                                       currentBlockStart,
                                                       cbrBlockOpCount,
                                                       cbrTermIndex)
    pendingWhileCbrTerm = cbrTermIndex
    currentBlockStart = bodyIR.ops.len
    return whileBodyEnd

fn PrimaryBodyIrCloseWhileLoop(bodyIR: var coreir.BodyIR,
                                currentBlockStart: var int32,
                                pendingWhileHeaderBlock: int32,
                                pendingWhileCbrTerm: int32): bool =
    if pendingWhileHeaderBlock < 0 ||
       pendingWhileHeaderBlock >= bodyIR.blocks.len ||
       pendingWhileCbrTerm < 0 ||
       pendingWhileCbrTerm >= bodyIR.terms.len:
        return false
    var brTerm: coreir.BodyTerm
    brTerm.kind = coreir.BodyTermBrTag
    brTerm.trueBlock = pendingWhileHeaderBlock
    brTerm.falseBlock = -1
    brTerm.conditionKind = coreir.BodyCondInvalidTag
    brTerm.lhsSlot = -1
    brTerm.rhsSlot = -1
    brTerm.resultSlot = -1
    let brTermIndex = coreir.BodyIRAppendTerm(bodyIR, brTerm)
    let backBlockCount = bodyIR.ops.len - currentBlockStart
    let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, backBlockCount, brTermIndex)
    currentBlockStart = bodyIR.ops.len
    bodyIR.terms[pendingWhileCbrTerm].trueBlock = pendingWhileHeaderBlock + 1
    bodyIR.terms[pendingWhileCbrTerm].falseBlock = bodyIR.blocks.len
    return true

fn PrimaryBuildBodyIrFromTypedStatements(
    lowering: lower.LoweringPlanStub,
    typedIr: texpr.TypedExprIr,
    typedFnIndex: int32,
    irFunction: lower.PrimaryObjectIrFunction
): coreir.BodyIR =
    let typedFn = typedIr.functions[typedFnIndex]
    var stmtEnd = typedFn.statementStart + typedFn.statementCount
    if stmtEnd > typedIr.statements.len:
        stmtEnd = typedIr.statements.len
    var bodyIR = coreir.BodyIRNew()
    var slotNames: str[]
    var callOrdinal: int32
    var nextOpIndex: int32
    var currentBlockStart: int32
    var pendingFalseTerm: int32
    var skipStatementUntilIndex: int32
    var completedReturnLineNumber: int32
    var pendingForEndIdx: int32
    var pendingForIdxSlot: int32
    var pendingForHdrBlk: int32
    var pendingForCbrTerm: int32
    var pendingWhileEndIdx: int32
    var pendingWhileHeaderBlock: int32
    var pendingWhileCbrTerm: int32
    var pendingWhileLineNumber: int32
    var pendingCompoundFalseTerms: int32[]
    pendingFalseTerm = -1
    pendingCompoundFalseTerms = []
    skipStatementUntilIndex = -1
    completedReturnLineNumber = -1
    pendingForEndIdx = -1
    pendingForIdxSlot = -1
    pendingForHdrBlk = -1
    pendingForCbrTerm = -1
    pendingWhileEndIdx = -1
    pendingWhileHeaderBlock = -1
    pendingWhileCbrTerm = -1
    pendingWhileLineNumber = -1
    PrimaryBodyIrSeedParamSlots(bodyIR, slotNames, typedIr, irFunction)
    let varI32ParamNames = PrimaryBodyIrCollectVarI32ParamNames(irFunction)
    for stmtIndex in typedFn.statementStart..<stmtEnd:
        if pendingWhileEndIdx > 0 && stmtIndex >= pendingWhileEndIdx:
            if !PrimaryBodyIrCloseWhileLoop(bodyIR,
                                            currentBlockStart,
                                            pendingWhileHeaderBlock,
                                            pendingWhileCbrTerm):
                PrimaryBodyIrAppendInvalidOp(bodyIR,
                                             pendingWhileLineNumber,
                                             int32(texpr.TypedExprIrStmtWhile),
                                             82,
                                             0)
            pendingWhileEndIdx = -1
            pendingWhileHeaderBlock = -1
            pendingWhileCbrTerm = -1
            pendingWhileLineNumber = -1
        if pendingForEndIdx > 0 && stmtIndex >= pendingForEndIdx:
            var oneSlot = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, "_for_one", coreir.LocalI32Tag)
            var oneInit: coreir.BodyOp
            oneInit.kind = coreir.BodyOpLoadConstTag
            oneInit.target = oneSlot
            add(oneInit.operands, coreir.LocalI32Tag)
            add(oneInit.operands, 1)
            add(bodyIR.ops, oneInit)
            nextOpIndex = nextOpIndex + 1
            var incOp: coreir.BodyOp
            incOp.kind = coreir.BodyOpBinOpTag
            incOp.target = pendingForIdxSlot
            add(incOp.operands, coreir.LocalI32Tag)
            add(incOp.operands, int32(texpr.TypedExprIrOpI32Add))
            add(incOp.operands, pendingForIdxSlot)
            add(incOp.operands, oneSlot)
            add(bodyIR.ops, incOp)
            nextOpIndex = nextOpIndex + 1
            var brTerm: coreir.BodyTerm
            brTerm.kind = coreir.BodyTermBrTag
            brTerm.trueBlock = pendingForHdrBlk
            brTerm.falseBlock = -1
            brTerm.conditionKind = coreir.BodyCondInvalidTag
            brTerm.lhsSlot = -1
            brTerm.rhsSlot = -1
            brTerm.resultSlot = -1
            let brIdx = coreir.BodyIRAppendTerm(bodyIR, brTerm)
            let backBlockCount = bodyIR.ops.len - currentBlockStart
            let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, backBlockCount, brIdx)
            currentBlockStart = bodyIR.ops.len
            if pendingForCbrTerm >= 0 && pendingForCbrTerm < bodyIR.terms.len:
                bodyIR.terms[pendingForCbrTerm].falseBlock = bodyIR.blocks.len
            pendingForEndIdx = -1
            pendingForIdxSlot = -1
            pendingForHdrBlk = -1
            pendingForCbrTerm = -1
            pendingFalseTerm = -1
            pendingCompoundFalseTerms = []
        if stmtIndex <= skipStatementUntilIndex:
            continue
        let stmt = typedIr.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtUnsupported:
            PrimaryBodyIrAppendInvalidOp(bodyIR,
                                         stmt.lineNumber,
                                         int32(stmt.kind),
                                         64,
                                         0)
            nextOpIndex = nextOpIndex + 1
        elif stmt.kind == texpr.TypedExprIrStmtLocalDecl:
            let localSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                               slotNames,
                                                               typedIr,
                                                               stmt.sourcePath,
                                                               stmt.bindingName,
                                                               stmt.resultType)
            let localInitialized = PrimaryBodyIrAppendLocalDeclInitializer(bodyIR,
                                                                          slotNames,
                                                                          varI32ParamNames,
                                                                          typedIr,
                                                                          stmt,
                                                                          localSlot,
                                                                          callOrdinal)
            if !localInitialized && PrimaryBodyIrTypeTextIsSeqStr(stmt.resultType):
                let _ = PrimaryBodyIrAppendZeroLocalSlot(bodyIR,
                                                         slotNames,
                                                         localSlot,
                                                         callOrdinal)
        elif stmt.kind == texpr.TypedExprIrStmtResultIntrinsic:
            let argNames = PrimaryBodyIrCallArgNames(stmt.callArgsText)
            var sourceSlot: int32 = -1
            if argNames.len > 0:
                sourceSlot = PrimaryBodyIrFindArgSlot(slotNames, argNames[0])
            var targetSlot: int32 = -1
            if stmt.bindingName != "":
                targetSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                slotNames,
                                                                typedIr,
                                                                stmt.sourcePath,
                                                                stmt.bindingName,
                                                                stmt.resultType)
            let resultIntrinsicName = PrimaryCallTargetTailName(stmt.callCallee)
            var projectKind = coreir.BodyResultProjectInvalidTag
            var projectOffset: int32
            var projectByteCount: int32
            if resultIntrinsicName == "Value":
                var valueTypeKind: int32
                var valueSizeBytes: int32
                var valueAlignBytes: int32
                PrimaryBodyIrTypeShapeFromText(typedIr,
                                               stmt.sourcePath,
                                               stmt.resultType,
                                               valueTypeKind,
                                               valueSizeBytes,
                                               valueAlignBytes)
                projectKind = coreir.BodyResultProjectValueStrTag
                projectOffset = PrimaryBodyIrAlignedOffset(1, valueAlignBytes)
                projectByteCount = valueSizeBytes
            elif resultIntrinsicName == "Error":
                projectKind = coreir.BodyResultProjectErrorStrTag
                projectOffset = coreir.ResultStrErrMsgOffset
                projectByteCount = 24
            elif resultIntrinsicName == "IsErr":
                projectKind = coreir.BodyResultProjectIsErrTag
            if sourceSlot < 0 ||
               targetSlot < 0 ||
               projectKind == coreir.BodyResultProjectInvalidTag ||
               (projectKind != coreir.BodyResultProjectIsErrTag &&
                projectByteCount <= 0):
                PrimaryBodyIrAppendInvalidOp(bodyIR,
                                             stmt.lineNumber,
                                             int32(stmt.kind),
                                             61,
                                             projectKind)
            else:
                var op: coreir.BodyOp
                op.kind = coreir.BodyOpResultProjectTag
                op.target = targetSlot
                add(op.operands, projectKind)
                add(op.operands, sourceSlot)
                if projectKind != coreir.BodyResultProjectIsErrTag:
                    add(op.operands, projectOffset)
                    add(op.operands, projectByteCount)
                add(bodyIR.ops, op)
                nextOpIndex = nextOpIndex + 1
        elif stmt.kind == texpr.TypedExprIrStmtLetCall:
            var slotId: int32 = -1
            if len(stmt.bindingName) > 0:
                var resultTypeText = PrimaryBodyIrResolvedCallResultType(typedIr, stmt)
                if resultTypeText != "str":
                    for conditionStmtIndex in typedFn.statementStart..<stmtEnd:
                        let conditionStmt = typedIr.statements[conditionStmtIndex]
                        if conditionStmt.lineNumber <= stmt.lineNumber:
                            continue
                        if conditionStmt.kind != texpr.TypedExprIrStmtIf &&
                           conditionStmt.kind != texpr.TypedExprIrStmtElif:
                            continue
                        if conditionStmt.conditionKind != texpr.TypedExprIrCondStrEqLiteral &&
                           conditionStmt.conditionKind != texpr.TypedExprIrCondStrNeLiteral:
                            continue
                        if conditionStmt.conditionLhsText == stmt.bindingName:
                            resultTypeText = "str"
                            break
                slotId = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                            slotNames,
                                                            typedIr,
                                                            PrimaryBodyIrCallResultLayoutSourcePath(stmt),
                                                            stmt.bindingName,
                                                            resultTypeText)
            let targetStr = stmt.callTarget
            if len(targetStr) > 0:
                let _ = PrimaryBodyIrAppendCallOp(bodyIR,
                                                  slotNames,
                                                  lowering,
                                                  typedIr,
                                                  typedFn,
                                                  irFunction,
                                                  stmt,
                                                  slotId,
                                                  varI32ParamNames,
                                                  callOrdinal)
                nextOpIndex = nextOpIndex + 1
            else:
                PrimaryBodyIrAppendInvalidOp(bodyIR,
                                             stmt.lineNumber,
                                             int32(stmt.kind),
                                             62,
                                             0)
                nextOpIndex = nextOpIndex + 1
        elif stmt.kind == texpr.TypedExprIrStmtCall:
            if stmt.callKind == texpr.TypedExprCallBuiltin && stmt.callCallee == "add":
                if !PrimaryBodyIrAppendSeqStrAddBuiltin(bodyIR,
                                                        slotNames,
                                                        typedIr,
                                                        typedFn,
                                                        irFunction,
                                                        stmt,
                                                        callOrdinal):
                    PrimaryBodyIrAppendInvalidOp(bodyIR,
                                                 stmt.lineNumber,
                                                 int32(stmt.kind),
                                                 631,
                                                 0)
                nextOpIndex = nextOpIndex + 1
                continue
            let targetStr = stmt.callTarget
            if len(targetStr) > 0:
                var callLineHasReturn = false
                for lineStmtIndex in typedFn.statementStart..<stmtEnd:
                    let lineStmt = typedIr.statements[lineStmtIndex]
                    if lineStmt.lineNumber != stmt.lineNumber:
                        if lineStmt.lineNumber > stmt.lineNumber:
                            break
                        continue
                    if lineStmt.kind == texpr.TypedExprIrStmtReturn:
                        callLineHasReturn = true
                        break
                if callLineHasReturn:
                    continue
                var resultSlot: int32
                resultSlot = -1
                let fullCallText = PrimaryBodyIrCallFullText(stmt)
                var feedsSameLineAssign = false
                for assignStmtIndex in typedFn.statementStart..<stmtEnd:
                    let assignStmt = typedIr.statements[assignStmtIndex]
                    if assignStmt.lineNumber != stmt.lineNumber:
                        if assignStmt.lineNumber > stmt.lineNumber:
                            break
                        continue
                    if assignStmt.kind != texpr.TypedExprIrStmtAssign:
                        continue
                    if assignStmt.callTarget == stmt.callTarget &&
                       assignStmt.callTargetImportc == stmt.callTargetImportc &&
                       PrimaryPathNormalizedEquals(assignStmt.callTargetSourcePath,
                                                   stmt.callTargetSourcePath) &&
                       assignStmt.callArgCount == stmt.callArgCount &&
                       assignStmt.callArgsText == stmt.callArgsText:
                        feedsSameLineAssign = true
                        break
                if feedsSameLineAssign:
                    continue
                var feedsSameLineCall = false
                for lineStmtIndex2 in typedFn.statementStart..<stmtEnd:
                    let lineStmt2 = typedIr.statements[lineStmtIndex2]
                    if lineStmt2.lineNumber != stmt.lineNumber:
                        if lineStmt2.lineNumber > stmt.lineNumber:
                            break
                        continue
                    if lineStmtIndex2 == stmtIndex:
                        continue
                    if lineStmt2.kind != texpr.TypedExprIrStmtCall &&
                       lineStmt2.kind != texpr.TypedExprIrStmtLetCall:
                        continue
                    if strutil.Contains(lineStmt2.callArgsText, fullCallText):
                        feedsSameLineCall = true
                        break
                if feedsSameLineCall:
                    let callResultType = PrimaryBodyIrResolvedCallResultType(typedIr, stmt)
                    resultSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                    slotNames,
                                                                    typedIr,
                                                                    PrimaryBodyIrCallResultLayoutSourcePath(stmt),
                                                                    fullCallText,
                                                                    callResultType)
                let _ = PrimaryBodyIrAppendCallOp(bodyIR,
                                                  slotNames,
                                                  lowering,
                                                  typedIr,
                                                  typedFn,
                                                  irFunction,
                                                  stmt,
                                                  resultSlot,
                                                  varI32ParamNames,
                                                  callOrdinal)
                nextOpIndex = nextOpIndex + 1
            else:
                PrimaryBodyIrAppendInvalidOp(bodyIR,
                                             stmt.lineNumber,
                                             int32(stmt.kind),
                                             63,
                                             0)
                nextOpIndex = nextOpIndex + 1
        elif stmt.kind == texpr.TypedExprIrStmtAssign:
            var assignLineHasReturn = false
            for checkIdx in typedFn.statementStart..<stmtEnd:
                let checkStmt = typedIr.statements[checkIdx]
                if checkStmt.lineNumber != stmt.lineNumber:
                    if checkStmt.lineNumber > stmt.lineNumber:
                        break
                    continue
                if checkStmt.kind == texpr.TypedExprIrStmtReturn:
                    assignLineHasReturn = true
                    break
            if assignLineHasReturn:
                nextOpIndex = nextOpIndex + 1
                continue
            if !PrimaryBodyIrAppendI32Assign(bodyIR,
                                             slotNames,
                                             varI32ParamNames,
                                             lowering,
                                             typedIr,
                                             typedFn,
                                             irFunction,
                                             stmt,
                                             callOrdinal):
                var assignDetail = 0
                if PrimaryBodyIrUInt8PtrDerefPointerText(stmt.bindingName) != "":
                    assignDetail = 701
                elif PrimaryBodyIrConditionHasAnd(stmt.surfaceText):
                    assignDetail = 702
                elif stmt.bindingName == "":
                    assignDetail = 703
                elif stmt.surfaceText == "":
                    assignDetail = 704
                elif PrimaryBodyIrTextHasCallSurface(stmt.bindingName):
                    assignDetail = 705
                elif PrimaryBodyIrTextHasCallSurface(stmt.surfaceText):
                    assignDetail = 706
                PrimaryBodyIrAppendInvalidOp(bodyIR,
                                             stmt.lineNumber,
                                             int32(stmt.kind),
                                             assignDetail,
                                             0)
            nextOpIndex = nextOpIndex + 1
        elif stmt.kind == texpr.TypedExprIrStmtReturn:
            if stmt.lineNumber == completedReturnLineNumber:
                continue
            var handledReturnCall = false
            let returnText = stmt.surfaceText
            var valText = ""
            if len(returnText) > 0:
                if PrimaryStartsWith(returnText, "return "):
                    valText = strings.SliceBytes(returnText, 7, len(returnText) - 7)
                else:
                    valText = returnText
                valText = strutil.Strip(valText)
            var returnRootStmtIndex: int32
            returnRootStmtIndex = -1
            for lookaheadIndex in typedFn.statementStart..<stmtEnd:
                let lookaheadStmt = typedIr.statements[lookaheadIndex]
                if lookaheadStmt.lineNumber != stmt.lineNumber:
                    if lookaheadStmt.lineNumber > stmt.lineNumber:
                        break
                    continue
                if lookaheadStmt.kind != texpr.TypedExprIrStmtCall &&
                   lookaheadStmt.kind != texpr.TypedExprIrStmtLetCall:
                    continue
                if len(lookaheadStmt.callTarget) <= 0:
                    continue
                var lookaheadName = lookaheadStmt.bindingName
                if len(lookaheadName) <= 0:
                    lookaheadName = PrimaryBodyIrCallFullText(lookaheadStmt)
                if len(valText) > 0 && lookaheadName == valText:
                    returnRootStmtIndex = lookaheadIndex
                    break
                if returnRootStmtIndex < 0 && lookaheadStmt.returnRoot:
                    returnRootStmtIndex = lookaheadIndex
            if returnRootStmtIndex >= 0:
                let rootStmt = typedIr.statements[returnRootStmtIndex]
                for callStmtIndex in typedFn.statementStart..<stmtEnd:
                    let callStmt = typedIr.statements[callStmtIndex]
                    if callStmt.lineNumber != stmt.lineNumber:
                        continue
                    if callStmtIndex == returnRootStmtIndex:
                        continue
                    if callStmt.kind != texpr.TypedExprIrStmtCall &&
                       callStmt.kind != texpr.TypedExprIrStmtLetCall:
                        continue
                    if len(callStmt.callTarget) <= 0 &&
                       len(callStmt.surfaceText) <= 0:
                        continue
                    var dependencyName = callStmt.bindingName
                    if len(dependencyName) <= 0:
                        dependencyName = PrimaryBodyIrCallFullText(callStmt)
                    let resultSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                        slotNames,
                                                                        typedIr,
                                                                        callStmt.sourcePath,
                                                                        dependencyName,
                                                                        callStmt.resultType)
                    let _ = PrimaryBodyIrAppendCallOp(bodyIR,
                                                      slotNames,
                                                      lowering,
                                                      typedIr,
                                                      typedFn,
                                                      irFunction,
                                                      callStmt,
                                                      resultSlot,
                                                      varI32ParamNames,
                                                      callOrdinal)
                    nextOpIndex = nextOpIndex + 1
                for assignDepIndex in typedFn.statementStart..<stmtEnd:
                    let assignDepStmt = typedIr.statements[assignDepIndex]
                    if assignDepStmt.lineNumber != stmt.lineNumber:
                        continue
                    if assignDepStmt.kind != texpr.TypedExprIrStmtAssign:
                        continue
                    if assignDepStmt.assignValueOpKind == texpr.TypedExprIrOpUnsupported:
                        continue
                    var assignDepName = assignDepStmt.bindingName
                    if len(assignDepName) <= 0:
                        assignDepName = assignDepStmt.surfaceText
                    if len(assignDepName) <= 0:
                        continue
                    let lhsSlot = PrimaryBodyIrFindArgSlot(slotNames,
                                                           assignDepStmt.assignValueLhsText)
                    if lhsSlot < 0:
                        continue
                    let rhsSlot = PrimaryBodyIrFindArgSlot(slotNames,
                                                           assignDepStmt.assignValueRhsText)
                    if rhsSlot < 0:
                        continue
                    var opTypeKind = bodyIR.localSlots[lhsSlot].typeKind
                    let rhsTypeKind = bodyIR.localSlots[rhsSlot].typeKind
                    if opTypeKind != rhsTypeKind:
                        if opTypeKind == coreir.LocalI32Tag && rhsTypeKind == coreir.LocalI64Tag:
                            opTypeKind = coreir.LocalI64Tag
                        elif opTypeKind == coreir.LocalI64Tag && rhsTypeKind == coreir.LocalI32Tag:
                            opTypeKind = coreir.LocalI64Tag
                    let assignResultSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                              slotNames,
                                                                              typedIr,
                                                                              assignDepStmt.sourcePath,
                                                                              assignDepName,
                                                                              assignDepStmt.resultType)
                    var binOp: coreir.BodyOp
                    binOp.kind = coreir.BodyOpBinOpTag
                    binOp.target = assignResultSlot
                    add(binOp.operands, opTypeKind)
                    add(binOp.operands, int32(assignDepStmt.assignValueOpKind))
                    add(binOp.operands, lhsSlot)
                    add(binOp.operands, rhsSlot)
                    add(bodyIR.ops, binOp)
                    nextOpIndex = nextOpIndex + 1
                var rootResultTypeKind: int32
                var rootResultTypeSizeBytes: int32
                var rootResultTypeAlignBytes: int32
                PrimaryBodyIrTypeShapeFromText(typedIr,
                                               rootStmt.sourcePath,
                                               rootStmt.resultType,
                                               rootResultTypeKind,
                                               rootResultTypeSizeBytes,
                                               rootResultTypeAlignBytes)
                var rootResultName = rootStmt.bindingName
                if len(rootResultName) <= 0:
                    rootResultName = PrimaryBodyIrCallFullText(rootStmt)
                let rootResultSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                        slotNames,
                                                                        typedIr,
                                                                        rootStmt.sourcePath,
                                                                        rootResultName,
                                                                        rootStmt.resultType)
                let _ = PrimaryBodyIrAppendCallOp(bodyIR,
                                                  slotNames,
                                                  lowering,
                                                  typedIr,
                                                  typedFn,
                                                  irFunction,
                                                  rootStmt,
                                                  rootResultSlot,
                                                  varI32ParamNames,
                                                  callOrdinal)
                PrimaryBodyIrAppendReturnTerm(bodyIR,
                                              currentBlockStart,
                                              rootResultSlot,
                                              rootResultTypeKind,
                                              0,
                                              false)
                nextOpIndex = nextOpIndex + 1
                completedReturnLineNumber = stmt.lineNumber
                handledReturnCall = true
            if handledReturnCall:
                continue
            if len(returnText) > 0:
                let constVal = PrimaryBodyIrExtractIntFromText(valText)
                if valText == "" || valText == "return":
                    PrimaryBodyIrAppendReturnTerm(bodyIR,
                                                  currentBlockStart,
                                                  -1,
                                                  coreir.LocalInvalidTag,
                                                  0,
                                                  false)
                elif valText == "nil":
                    PrimaryBodyIrAppendReturnTerm(bodyIR,
                                                  currentBlockStart,
                                                  -1,
                                                  coreir.LocalPtrTag,
                                                  0,
                                                  false)
                elif constVal != 0 || PrimaryBodyIrTextIsI32Zero(valText):
                    PrimaryBodyIrAppendReturnTerm(bodyIR,
                                                  currentBlockStart,
                                                  -1,
                                                  coreir.LocalI32Tag,
                                                  constVal,
                                                  true)
                else:
                    var returnTypeKind: int32
                    var returnTypeSizeBytes: int32
                    var returnTypeAlignBytes: int32
                    PrimaryBodyIrTypeShapeFromText(typedIr,
                                                   typedFn.sourcePath,
                                                   typedFn.returnType,
                                                   returnTypeKind,
                                                   returnTypeSizeBytes,
                                                   returnTypeAlignBytes)
                    let valSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                     slotNames,
                                                                     typedIr,
                                                                     typedFn.sourcePath,
                                                                     valText,
                                                                     typedFn.returnType)
                    PrimaryBodyIrAppendReturnTerm(bodyIR,
                                                  currentBlockStart,
                                                  valSlot,
                                                  returnTypeKind,
                                                  0,
                                                  false)
        elif stmt.kind == texpr.TypedExprIrStmtIf:
            if PrimaryBodyIrAppendTypedStrLiteralCondition(bodyIR,
                                                           slotNames,
                                                           stmt,
                                                           currentBlockStart,
                                                           pendingFalseTerm):
                continue
            let condText = PrimaryBodyIrConditionText(stmt.surfaceText)
            if PrimaryBodyIrConditionHasAnd(condText):
                let subConds = PrimaryBodyIrSplitAndConditions(condText)
                for partIndex in 0..<subConds.len:
                    let subCondText = subConds[partIndex]
                    var lhsSlot: int32
                    var rhsSlot: int32
                    var cmpTag: int32
                    if !PrimaryBodyIrEmitConditionOps(bodyIR, slotNames, typedIr, stmt.sourcePath, subCondText, lhsSlot, rhsSlot, cmpTag, nextOpIndex):
                        continue
                    var cbrTerm: coreir.BodyTerm
                    cbrTerm.kind = coreir.BodyTermCbrTag
                    cbrTerm.conditionKind = cmpTag
                    cbrTerm.lhsSlot = lhsSlot
                    cbrTerm.rhsSlot = rhsSlot
                    cbrTerm.trueBlock = -1
                    cbrTerm.falseBlock = -1
                    cbrTerm.resultSlot = -1
                    if partIndex < subConds.len - 1:
                        cbrTerm.trueBlock = bodyIR.blocks.len + 1
                    let cbrTermIndex = coreir.BodyIRAppendTerm(bodyIR, cbrTerm)
                    let cbrBlockOpCount = bodyIR.ops.len - currentBlockStart
                    let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, cbrBlockOpCount, cbrTermIndex)
                    currentBlockStart = bodyIR.ops.len
                    if partIndex < subConds.len - 1:
                        add(pendingCompoundFalseTerms, cbrTermIndex)
                    else:
                        pendingFalseTerm = cbrTermIndex
            else:
                var lhsSlot: int32
                var rhsSlot: int32
                var cmpTag: int32
                if PrimaryBodyIrEmitConditionOps(bodyIR, slotNames, typedIr, stmt.sourcePath, condText, lhsSlot, rhsSlot, cmpTag, nextOpIndex):
                    var cbrTerm: coreir.BodyTerm
                    cbrTerm.kind = coreir.BodyTermCbrTag
                    cbrTerm.conditionKind = cmpTag
                    cbrTerm.lhsSlot = lhsSlot
                    cbrTerm.rhsSlot = rhsSlot
                    cbrTerm.trueBlock = -1
                    cbrTerm.falseBlock = -1
                    cbrTerm.resultSlot = -1
                    let cbrTermIndex = coreir.BodyIRAppendTerm(bodyIR, cbrTerm)
                    let cbrBlockOpCount = bodyIR.ops.len - currentBlockStart
                    let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, cbrBlockOpCount, cbrTermIndex)
                    currentBlockStart = bodyIR.ops.len
                    pendingFalseTerm = cbrTermIndex
        elif stmt.kind == texpr.TypedExprIrStmtElif:
            if pendingFalseTerm >= 0:
                bodyIR.terms[pendingFalseTerm].falseBlock = bodyIR.blocks.len
                for pcti in 0..<pendingCompoundFalseTerms.len:
                    if pendingCompoundFalseTerms[pcti] >= 0 &&
                       pendingCompoundFalseTerms[pcti] < bodyIR.terms.len:
                        bodyIR.terms[pendingCompoundFalseTerms[pcti]].falseBlock = bodyIR.blocks.len
                pendingCompoundFalseTerms = []
                if PrimaryBodyIrAppendTypedStrLiteralCondition(bodyIR,
                                                               slotNames,
                                                               stmt,
                                                               currentBlockStart,
                                                               pendingFalseTerm):
                    continue
                let condText = PrimaryBodyIrConditionText(stmt.surfaceText)
                var lhsSlot: int32
                var rhsSlot: int32
                var cmpTag: int32
                if PrimaryBodyIrEmitConditionOps(bodyIR, slotNames, typedIr, stmt.sourcePath, condText, lhsSlot, rhsSlot, cmpTag, nextOpIndex):
                    var elifCbrTerm: coreir.BodyTerm
                    elifCbrTerm.kind = coreir.BodyTermCbrTag
                    elifCbrTerm.conditionKind = cmpTag
                    elifCbrTerm.lhsSlot = lhsSlot
                    elifCbrTerm.rhsSlot = rhsSlot
                    elifCbrTerm.trueBlock = -1
                    elifCbrTerm.falseBlock = -1
                    elifCbrTerm.resultSlot = -1
                    let elifTermIndex = coreir.BodyIRAppendTerm(bodyIR, elifCbrTerm)
                    let elifBlockOpCount = bodyIR.ops.len - currentBlockStart
                    let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, elifBlockOpCount, elifTermIndex)
                    currentBlockStart = bodyIR.ops.len
                    pendingFalseTerm = elifTermIndex
        elif stmt.kind == texpr.TypedExprIrStmtElse:
            if pendingFalseTerm >= 0:
                bodyIR.terms[pendingFalseTerm].falseBlock = bodyIR.blocks.len
                for pcti in 0..<pendingCompoundFalseTerms.len:
                    if pendingCompoundFalseTerms[pcti] >= 0 &&
                       pendingCompoundFalseTerms[pcti] < bodyIR.terms.len:
                        bodyIR.terms[pendingCompoundFalseTerms[pcti]].falseBlock = bodyIR.blocks.len
                pendingCompoundFalseTerms = []
                pendingFalseTerm = -1
        elif stmt.kind == texpr.TypedExprIrStmtFor:
            let forBodyEnd = PrimaryBodyIrBuildForRangeLoop(bodyIR, slotNames, nextOpIndex, currentBlockStart, typedIr, stmt, stmtIndex, stmtEnd, pendingFalseTerm)
            pendingForEndIdx = forBodyEnd
            pendingForCbrTerm = pendingFalseTerm
            if pendingFalseTerm >= 0 && pendingFalseTerm < bodyIR.terms.len:
                pendingForIdxSlot = bodyIR.terms[pendingFalseTerm].lhsSlot
            var bi = bodyIR.blocks.len - 1
            while bi >= 0:
                if bodyIR.blocks[bi].termIndex == pendingFalseTerm:
                    pendingForHdrBlk = bi
                    break
                bi = bi - 1
        elif stmt.kind == texpr.TypedExprIrStmtWhile:
            let whileBodyEnd = PrimaryBodyIrBuildWhileLoopHeader(bodyIR,
                                                                 slotNames,
                                                                 nextOpIndex,
                                                                 currentBlockStart,
                                                                 typedIr,
                                                                 stmt,
                                                                 stmtIndex,
                                                                 stmtEnd,
                                                                 pendingWhileHeaderBlock,
                                                                 pendingWhileCbrTerm)
            if pendingWhileCbrTerm >= 0:
                pendingWhileEndIdx = whileBodyEnd
                pendingWhileLineNumber = stmt.lineNumber
            else:
                pendingWhileEndIdx = -1
                pendingWhileLineNumber = -1
    if pendingWhileEndIdx > 0:
        if !PrimaryBodyIrCloseWhileLoop(bodyIR,
                                        currentBlockStart,
                                        pendingWhileHeaderBlock,
                                        pendingWhileCbrTerm):
            PrimaryBodyIrAppendInvalidOp(bodyIR,
                                         pendingWhileLineNumber,
                                         int32(texpr.TypedExprIrStmtWhile),
                                         82,
                                         1)
        pendingWhileEndIdx = -1
        pendingWhileHeaderBlock = -1
        pendingWhileCbrTerm = -1
        pendingWhileLineNumber = -1
    if pendingForEndIdx > 0:
        var fos = PrimaryBodyIrFindOrCreateSlot(bodyIR, slotNames, "_for_one", coreir.LocalI32Tag)
        var foi: coreir.BodyOp
        foi.kind = coreir.BodyOpLoadConstTag
        foi.target = fos
        add(foi.operands, coreir.LocalI32Tag)
        add(foi.operands, 1)
        add(bodyIR.ops, foi)
        nextOpIndex = nextOpIndex + 1
        var incOp: coreir.BodyOp
        incOp.kind = coreir.BodyOpBinOpTag
        incOp.target = pendingForIdxSlot
        add(incOp.operands, coreir.LocalI32Tag)
        add(incOp.operands, int32(texpr.TypedExprIrOpI32Add))
        add(incOp.operands, pendingForIdxSlot)
        add(incOp.operands, fos)
        add(bodyIR.ops, incOp)
        nextOpIndex = nextOpIndex + 1
        var brTerm: coreir.BodyTerm
        brTerm.kind = coreir.BodyTermBrTag
        brTerm.trueBlock = pendingForHdrBlk
        brTerm.falseBlock = -1
        brTerm.conditionKind = coreir.BodyCondInvalidTag
        brTerm.lhsSlot = -1
        brTerm.rhsSlot = -1
        brTerm.resultSlot = -1
        let brIdx = coreir.BodyIRAppendTerm(bodyIR, brTerm)
        let backCount = bodyIR.ops.len - currentBlockStart
        let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, backCount, brIdx)
        currentBlockStart = bodyIR.ops.len
        if pendingForCbrTerm >= 0 && pendingForCbrTerm < bodyIR.terms.len:
            bodyIR.terms[pendingForCbrTerm].falseBlock = bodyIR.blocks.len
        pendingForEndIdx = -1
        pendingForIdxSlot = -1
        pendingForHdrBlk = -1
        pendingForCbrTerm = -1
        pendingFalseTerm = -1
        pendingCompoundFalseTerms = []
    if bodyIR.ops.len > currentBlockStart:
        if bodyIR.blocks.len <= 0:
            var fallbackTerm: coreir.BodyTerm
            fallbackTerm.kind = coreir.BodyTermReturnTag
            fallbackTerm.resultSlot = -1
            if bodyIR.ops.len > 0:
                if bodyIR.ops[bodyIR.ops.len - 1].kind == coreir.BodyOpReturnTag:
                    fallbackTerm.operands = bodyIR.ops[bodyIR.ops.len - 1].operands
            if fallbackTerm.operands.len <= 0 && PrimaryBodyIrReturnTypeIsVoid(typedFn.returnType):
                add(fallbackTerm.operands, coreir.LocalInvalidTag)
            add(bodyIR.terms, fallbackTerm)
            let _ = coreir.BodyIRAppendBlock(bodyIR, 0, bodyIR.ops.len, 0)
        else:
            let remainingOpCount = bodyIR.ops.len - currentBlockStart
            if remainingOpCount > 0:
                var remainTerm: coreir.BodyTerm
                remainTerm.kind = coreir.BodyTermReturnTag
                remainTerm.resultSlot = -1
                if bodyIR.ops.len > 0:
                    if bodyIR.ops[bodyIR.ops.len - 1].kind == coreir.BodyOpReturnTag:
                        remainTerm.operands = bodyIR.ops[bodyIR.ops.len - 1].operands
                if remainTerm.operands.len <= 0 && PrimaryBodyIrReturnTypeIsVoid(typedFn.returnType):
                    add(remainTerm.operands, coreir.LocalInvalidTag)
                let remainTermIndex = coreir.BodyIRAppendTerm(bodyIR, remainTerm)
                let _ = coreir.BodyIRAppendBlock(bodyIR, currentBlockStart, remainingOpCount, remainTermIndex)
    for ti in 0..<bodyIR.terms.len:
        let t = bodyIR.terms[ti]
        if t.kind == coreir.BodyTermCbrTag:
            if t.trueBlock < 0:
                if t.falseBlock < 0:
                    bodyIR.terms[ti].trueBlock = ti + 1
                    if ti + 2 < bodyIR.terms.len:
                        bodyIR.terms[ti].falseBlock = ti + 2
                    else:
                        bodyIR.terms[ti].falseBlock = ti + 1
                else:
                    bodyIR.terms[ti].trueBlock = ti + 1
            else:
                if t.falseBlock < 0:
                    if ti + 1 < bodyIR.terms.len:
                        bodyIR.terms[ti].falseBlock = ti + 1
                    else:
                        bodyIR.terms[ti].falseBlock = ti
    if bodyIR.blocks.len <= 0:
        if typedFn.returnType != "" && typedFn.returnType != "void":
            var returnTypeKind: int32
            returnTypeKind = coreir.LocalInvalidTag
            var returnTypeSize: int32
            var returnTypeAlign: int32
            PrimaryBodyIrTypeShapeFromText(typedIr,
                                           typedFn.sourcePath,
                                           typedFn.returnType,
                                           returnTypeKind,
                                           returnTypeSize,
                                           returnTypeAlign)
            let returnSlot = PrimaryBodyIrFindOrCreateTypedSlot(bodyIR,
                                                                slotNames,
                                                                typedIr,
                                                                typedFn.sourcePath,
                                                                "__unsupported_return",
                                                                typedFn.returnType)
            PrimaryBodyIrAppendReturnTerm(bodyIR,
                                          currentBlockStart,
                                          returnSlot,
                                          returnTypeKind,
                                          0,
                                          false)
        else:
            PrimaryBodyIrAppendReturnTerm(bodyIR,
                                          currentBlockStart,
                                          -1,
                                          coreir.LocalInvalidTag,
                                          0,
                                          false)
    return bodyIR


fn PrimaryCStringLiteralDataLabel(functionSymbol: str,
                                  callOrdinal: int32): str =
    return strutil.Join([functionSymbol, "__cheng_cstring_", strings.IntToStr(callOrdinal)], "")

fn PrimaryReturnStrLiteralDataLabel(functionSymbol: str): str =
    return strutil.Join([functionSymbol, "__cheng_return_str_literal"], "")

fn PrimaryStatementSequenceReturnMode(bodyKind: str): int32 =
    if PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
        return PrimaryStatementReturnModeI32Const()
    if texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(bodyKind):
        return PrimaryStatementReturnModeCallResultI32()
    if bodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32:
        return PrimaryStatementReturnModeI32GuardResultLeZero()
    if texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
        return PrimaryStatementReturnModeStrLen()
    if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
        return PrimaryStatementReturnModeStrThenCallReturnI32Const0()
    if bodyKind == "str_i32_guard_arg0_return_0":
        return PrimaryStatementReturnModeStrI32GuardArg0Return0()
    if bodyKind == "str_i32_guard_arg0_else_call_arg0_arg1_return_result_i32":
        return PrimaryStatementReturnModeStrI32GuardArg0ElseCallArg0Arg1ReturnResultI32()
    return PrimaryStatementReturnModeNone()

fn PrimaryStatementSequenceI32Value(bodyKind: str): int32 =
    if PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
        let prefix = texpr.BodyKindLetCallNoargReturnI32ConstPrefix
        let raw = strings.SliceBytes(bodyKind, len(prefix), len(bodyKind) - len(prefix))
        return int32(strutil.ParseInt(raw))
    if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
        return 0
    return 0

fn PrimaryPlanBodyKind(bodyKind: str): str =
    if PrimaryStatementSequenceReturnMode(bodyKind) != PrimaryStatementReturnModeNone():
        return texpr.BodyKindStatementSequence
    if PrimaryStartsWith(bodyKind, "stmt_"):
        return texpr.BodyKindStatementSequence
    return bodyKind

fn PrimaryBodyKindCallIndirectVoidBridge(): str =
    return "runtime_call_indirect_void_bridge"

fn PrimaryBodyKindCallIndirectI32Bridge(): str =
    return "runtime_call_indirect_i32_bridge"

fn PrimarySpecialExportBodyKindForFunction(lowering: lower.LoweringPlanStub,
                                            functionIndex: int32): str =
    if functionIndex < 0 || functionIndex >= lowering.functionExportSymbolNames.len:
        return ""
    let exportName = lowering.functionExportSymbolNames[functionIndex]
    if exportName == "__cheng_call_indirect_void":
        return PrimaryBodyKindCallIndirectVoidBridge()
    if exportName == "__cheng_call_indirect_i32":
        return PrimaryBodyKindCallIndirectI32Bridge()
    return ""

fn PrimaryFunctionWordCountForBodyKind(bodyKind: str): int32 =
    if bodyKind == PrimaryBodyKindCallIndirectVoidBridge():
        return 4
    if bodyKind == PrimaryBodyKindCallIndirectI32Bridge():
        return 6
    if bodyKind == texpr.BodyKindReturnVoid:
        return 1
    if bodyKind == texpr.BodyKindReturnZeroI32:
        return 2
    if PrimaryStartsWith(bodyKind, texpr.BodyKindReturnI32ConstPrefix):
        return 2
    if bodyKind == texpr.BodyKindReturnI32Arg0:
        return 1
    if bodyKind == texpr.BodyKindReturnI32Arg1 ||
       bodyKind == texpr.BodyKindReturnI32Arg2 ||
       bodyKind == texpr.BodyKindReturnI32Arg3:
        return 2
    if texpr.TypedExprIsReturnCallBodyKind(bodyKind):
        return 1
    if PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
        return 0
    if texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(bodyKind):
        return 0
    if bodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32:
        return 0
    if texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
        return 0
    if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
        return 0
    if bodyKind == "str_i32_guard_arg0_return_0":
        return 0
    if bodyKind == "str_i32_guard_arg0_else_call_arg0_arg1_return_result_i32":
        return 0
    if bodyKind == texpr.BodyKindReturnStrArg0:
        return 7
    if bodyKind == texpr.BodyKindReturnComposite16Arg0:
        return 5
    if bodyKind == texpr.BodyKindReturnComposite16Field0Arg0:
        return 5
    if bodyKind == texpr.BodyKindReturnSeqLenArg0:
        return 2
    if bodyKind == texpr.BodyKindReturnBytesLenArg0:
        return 2
    if bodyKind == texpr.BodyKindReturnCharArg0:
        return 1
    if bodyKind == texpr.BodyKindReturnI64FromI32Arg0:
        return 2
    if bodyKind == texpr.BodyKindReturnBoolI32Arg0Range0To31:
        return 3
    if bodyKind == texpr.BodyKindReturnStrEmpty:
        return 4
    if bodyKind == texpr.BodyKindCstringToStrCopy:
        return 32
    if bodyKind == texpr.BodyKindIfArg0LeZeroReturnI32Const0ElseI32Const7:
        return 6
    if bodyKind == texpr.BodyKindReturnF64MulArgs:
        return 2
    if bodyKind == texpr.BodyKindReturnI32AddArgs:
        return 2
    if bodyKind == texpr.BodyKindReturnI32SubArgs:
        return 2
    if bodyKind == texpr.BodyKindReturnI32MulArgs:
        return 2
    if bodyKind == texpr.BodyKindReturnI32AsrArgs:
        return 2
    if bodyKind == texpr.BodyKindReturnI32MaddArgs:
        return 2
    if bodyKind == texpr.BodyKindStrLenFastI32:
        return 8
    if bodyKind == texpr.BodyKindMainF64MulCheckExit:
        return 22
    if bodyKind == texpr.BodyKindRuntimeSetCmdLine:
        return 7
    if bodyKind == texpr.BodyKindRuntimeParamCount:
        return 6
    if bodyKind == texpr.BodyKindRuntimeParamStrCopyBridge:
        return 35
    return 0

fn PrimaryReturnI32ConstValue(bodyKind: str): int32 =
    if PrimaryStartsWith(bodyKind, texpr.BodyKindReturnI32ConstPrefix):
        let prefix = texpr.BodyKindReturnI32ConstPrefix
        let raw = strings.SliceBytes(bodyKind, len(prefix), len(bodyKind) - len(prefix))
        return int32(strutil.ParseInt(raw))
    return 0

fn PrimaryArm64MovW0ConstWord(value: int32): int32 =
    if value < 0 || value > texpr.BodyKindReturnI32ConstMax:
        return a64.A64EncMovz(false, 0, 0, 0)
    return a64.A64EncMovz(false, 0, value, 0)

fn PrimaryArm64BranchImm26(fromWord: int32, toWord: int32): int32 =
    return (toWord - fromWord) & 67108863

fn PrimaryArm64BranchImm19(fromWord: int32, toWord: int32): int32 =
    return (toWord - fromWord) & 524287

fn PrimaryArm64BWord(fromWord: int32, toWord: int32): int32 =
    return a64.A64EncBPlaceholder() + PrimaryArm64BranchImm26(fromWord, toWord)

fn PrimaryArm64CbnzW0Word(fromWord: int32, toWord: int32): int32 =
    return 889192448 + PrimaryArm64BranchImm19(fromWord, toWord) * 32

