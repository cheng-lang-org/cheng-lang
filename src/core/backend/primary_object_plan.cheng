        return false
    if secondCallOp.operands.len < 1:
        return false
    if returnOp.operands.len < 1:
        return false
    if bodyIR.callSequence[1].argSlots.len < 1:
        return false
    return firstCallOp.operands[0] == 0 &&
           firstCallOp.operands[1] == 1 &&
           secondCallOp.operands[0] == 1 &&
           bodyIR.callSequence[0].resultSlot >= 0 &&
           bodyIR.callSequence[1].argSlots[0] == bodyIR.callSequence[0].resultSlot &&
           returnOp.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsStrI32GuardCallArg0ThenDispatchReturnI32(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 5:
        return false
    if bodyIR.ops.len != 7:
        return false
    let strCallOp = bodyIR.ops[0]
    let useCallOp = bodyIR.ops[1]
    let countCallOp = bodyIR.ops[2]
    let branchOp = bodyIR.ops[3]
    let guardUseCallOp = bodyIR.ops[4]
    let dispatchCallOp = bodyIR.ops[5]
    let returnOp = bodyIR.ops[6]
    if strCallOp.kind != coreir.BodyOpCallTag ||
       useCallOp.kind != coreir.BodyOpCallTag ||
       countCallOp.kind != coreir.BodyOpCallTag ||
       branchOp.kind != coreir.BodyOpBranchTag ||
       guardUseCallOp.kind != coreir.BodyOpCallTag ||
       dispatchCallOp.kind != coreir.BodyOpCallTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if strCallOp.operands.len < 1:
        return false
    if useCallOp.operands.len < 1:
        return false
    if countCallOp.operands.len < 1:
        return false
    if branchOp.operands.len < 4:
        return false
    if guardUseCallOp.operands.len < 1:
        return false
    if dispatchCallOp.operands.len < 1:
        return false
    if returnOp.operands.len < 1:
        return false
    if bodyIR.callSequence[1].argSlots.len < 1 ||
       bodyIR.callSequence[3].argSlots.len < 1 ||
       bodyIR.callSequence[4].argSlots.len < 2:
        return false
    let strSlot = bodyIR.callSequence[0].resultSlot
    let countSlot = bodyIR.callSequence[2].resultSlot
    if strSlot < 0 || strSlot >= bodyIR.localSlots.len ||
       countSlot < 0 || countSlot >= bodyIR.localSlots.len:
        return false
    return strCallOp.operands[0] == 0 &&
           useCallOp.operands[0] == 1 &&
           countCallOp.operands[0] == 2 &&
           branchOp.operands[0] == coreir.BodyBranchIfLocalLeZeroCallArg0ReturnI32ConstTag &&
           branchOp.operands[1] == countSlot &&
           branchOp.operands[2] == 3 &&
           branchOp.operands[3] == 0 &&
           guardUseCallOp.operands[0] == 3 &&
           dispatchCallOp.operands[0] == 4 &&
           bodyIR.localSlots[strSlot].typeKind == coreir.LocalStrTag &&
           bodyIR.localSlots[countSlot].typeKind == coreir.LocalI32Tag &&
           bodyIR.callSequence[1].argSlots[0] == strSlot &&
           bodyIR.callSequence[3].argSlots[0] == strSlot &&
           bodyIR.callSequence[4].argSlots[0] == strSlot &&
           bodyIR.callSequence[4].argSlots[1] == countSlot &&
           returnOp.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrStatementReturnMode(bodyIR: coreir.BodyIR): int32 =
    if PrimaryBodyIrLocalInitPrefixLen(bodyIR) > 0:
        return PrimaryStatementReturnModeNone()
    if bodyIR.ops.len <= 0:
        return PrimaryStatementReturnModeNone()
    let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
    if returnOp.kind != coreir.BodyOpReturnTag:
        return PrimaryStatementReturnModeNone()
    if returnOp.operands.len <= 0:
        return PrimaryStatementReturnModeNone()
    let mode = returnOp.operands[0]
    if mode == PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
        let requiredCallCount = bodyIR.callSequence.len
        if requiredCallCount <= 0:
            return PrimaryStatementReturnModeNone()
        if bodyIR.ops.len != requiredCallCount + 1:
            return PrimaryStatementReturnModeNone()
        if returnOp.operands.len < 2:
            return PrimaryStatementReturnModeNone()
        if returnOp.operands[1] != 0:
            return PrimaryStatementReturnModeNone()
        for callIndex in 0..<requiredCallCount:
            let callOp = bodyIR.ops[callIndex]
            if callOp.kind != coreir.BodyOpCallTag:
                return PrimaryStatementReturnModeNone()
            if callOp.operands.len <= 0:
                return PrimaryStatementReturnModeNone()
            if callOp.operands[0] != callIndex:
                return PrimaryStatementReturnModeNone()
        return mode
    let requiredCallCount = PrimaryStatementSequenceRequiredCallCount(mode)
    if requiredCallCount <= 0:
        return PrimaryStatementReturnModeNone()
    if bodyIR.callSequence.len < requiredCallCount:
        return PrimaryStatementReturnModeNone()
    if bodyIR.ops.len != requiredCallCount + 1:
        return PrimaryStatementReturnModeNone()
    for callIndex in 0..<requiredCallCount:
        if bodyIR.ops[callIndex].kind != coreir.BodyOpCallTag:
            return PrimaryStatementReturnModeNone()
    if mode == PrimaryStatementReturnModeI32Const() ||
       mode == PrimaryStatementReturnModeStrThenCallReturnI32Const0():
        if returnOp.operands.len < 2:
            return PrimaryStatementReturnModeNone()
    return mode

fn PrimaryBodyIrStatementI32Value(bodyIR: coreir.BodyIR): int32 =
    if bodyIR.ops.len <= 0:
        return 0
    let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
    if returnOp.kind != coreir.BodyOpReturnTag:
        return 0
    if returnOp.operands.len < 2:
        return 0
    return returnOp.operands[1]

fn PrimaryCallOpRegisterArgCount(callOp: coreir.CallOp): int32 =
    if callOp.argSlots.len > 8:
        return 8
    return callOp.argSlots.len

fn PrimaryCallOpStackArgCount(callOp: coreir.CallOp): int32 =
    if callOp.argSlots.len <= 8:
        return 0
    return callOp.argSlots.len - 8

fn PrimaryCallOpStackArgBytes(callOp: coreir.CallOp): int32 =
    let stackArgCount = PrimaryCallOpStackArgCount(callOp)
    if stackArgCount <= 0:
        return 0
    return PrimaryAlignStackBytes(stackArgCount * 8, 16)

fn PrimaryCallOpStackPreCallWordCount(callOp: coreir.CallOp): int32 =
    let stackArgCount = PrimaryCallOpStackArgCount(callOp)
    if stackArgCount <= 0:
        return 0
    return 1 + stackArgCount * 2

fn PrimaryCallOpStackPostCallWordCount(callOp: coreir.CallOp): int32 =
    if PrimaryCallOpStackArgCount(callOp) <= 0:
        return 0
    return 1

fn PrimaryCallArgSlotIsConst(slotIndex: int32): bool =
    return coreir.CallArgSlotIsConst(slotIndex)

fn PrimaryCallArgConstMovWord(slotIndex: int32,
                               registerIndex: int32): int32 =
    if !PrimaryCallArgSlotIsConst(slotIndex):
        return 0
    return PrimaryArm64RegisterWord(PrimaryMovI32ConstWord(coreir.CallArgSlotConstI32Value(slotIndex)),
                                   registerIndex)

fn PrimaryBodyIrCallOpWordCount(bodyIR: coreir.BodyIR,
                                 callOp: coreir.CallOp): int32 =
    var wordCount = PrimaryCallOpRegisterArgCount(callOp)
    if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
        let resultSlot = bodyIR.localSlots[callOp.resultSlot]
        if resultSlot.typeKind == coreir.LocalStrTag ||
           resultSlot.typeKind == coreir.LocalAggregateTag:
            wordCount = wordCount + 1
    wordCount = wordCount + PrimaryCallOpStackPreCallWordCount(callOp)
    wordCount = wordCount + 1
    wordCount = wordCount + PrimaryCallOpStackPostCallWordCount(callOp)
    if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
        let resultSlot = bodyIR.localSlots[callOp.resultSlot]
        if resultSlot.typeKind == coreir.LocalI32Tag ||
           resultSlot.typeKind == coreir.LocalPtrTag:
            wordCount = wordCount + 1
    return wordCount

fn PrimaryBodyIrTermWordCount(term: coreir.BodyTerm,
                               epilogueWordCount: int32): int32 =
    if term.kind == coreir.BodyTermReturnTag:
        return epilogueWordCount + 2
    if term.kind == coreir.BodyTermBrTag:
        return 1
    if term.kind == coreir.BodyTermCbrTag:
        return 3
    return 0

fn PrimaryBodyIrParamSaveCount(bodyIR: coreir.BodyIR): int32 =
    var paramSaveCount: int32
    for callOrdinal in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[callOrdinal]
        for argIndex in 0..<callOp.argSlots.len:
            if PrimaryCallArgSlotIsConst(callOp.argSlots[argIndex]):
                continue
            if callOp.argSlots[argIndex] < 0:
                let paramSlot = 0 - callOp.argSlots[argIndex] - 1
                if paramSlot < 0:
                    return -1
                if paramSlot < 8 && paramSlot + 1 > paramSaveCount:
                    paramSaveCount = paramSlot + 1
    return paramSaveCount

fn PrimaryIncomingParamStackOffset(frameBytes: int32,
                                    paramSlot: int32): int32 =
    if paramSlot < 8:
        return -1
    return frameBytes + (paramSlot - 8) * 8

fn PrimaryBodyIrIncomingParamOffsetsSupported(bodyIR: coreir.BodyIR,
                                               frameBytes: int32): bool =
    for callOrdinal in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[callOrdinal]
        for argIndex in 0..<callOp.argSlots.len:
            if PrimaryCallArgSlotIsConst(callOp.argSlots[argIndex]):
                continue
            if callOp.argSlots[argIndex] < 0:
                let paramSlot = 0 - callOp.argSlots[argIndex] - 1
                if paramSlot >= 8:
                    let incomingOffset = PrimaryIncomingParamStackOffset(frameBytes,
                                                                         paramSlot)
                    if incomingOffset < 0 || incomingOffset > 32760:
                        return false
    return true

fn PrimaryArm64FramePrologueWordCount(frameBytes: int32): int32 =
    if frameBytes < 16 || frameBytes > 4095:
        return 0
    if frameBytes <= 512:
        return 2
    return 3

fn PrimaryArm64FrameEpilogueWordCount(frameBytes: int32): int32 =
    if frameBytes < 16 || frameBytes > 4095:
        return 0
    if frameBytes <= 512:
        return 2
    return 3

fn PrimaryBodyIrFrameByteCountWithParams(bodyIR: coreir.BodyIR): int32 =
    var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
    if frameBytes < 16:
        frameBytes = 16
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    if paramSaveCount < 0:
        return 0
    if paramSaveCount > 0:
        frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
    return frameBytes

fn PrimaryBodyIrGuardBranchExtraWordCount(bodyIR: coreir.BodyIR): int32 =
    if !PrimaryBodyIrIsCallSequenceGuardReturnInt32(bodyIR):
        return 0
    let frameBytes = PrimaryBodyIrFrameByteCountWithParams(bodyIR)
    if frameBytes <= 0:
        return 0
    let epilogueWordCount = PrimaryArm64FrameEpilogueWordCount(frameBytes)
    if epilogueWordCount <= 0:
        return 0
    return epilogueWordCount + 4

fn PrimaryBodyIrCallSequenceReturnInt32InsertWordIndex(bodyIR: coreir.BodyIR,
                                                        insertCallOrdinal: int32): int32 =
    if insertCallOrdinal < 0 || insertCallOrdinal > bodyIR.callSequence.len:
        return -1
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    if paramSaveCount < 0:
        return -1
    let frameBytes = PrimaryBodyIrFrameByteCountWithParams(bodyIR)
    if frameBytes <= 0:
        return -1
    let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
    if prologueWordCount <= 0:
        return -1
    var localWordIndex = prologueWordCount + paramSaveCount
    for currentCallOrdinal in 0..<bodyIR.callSequence.len:
        if currentCallOrdinal == insertCallOrdinal:
            return localWordIndex
        let callOp = bodyIR.callSequence[currentCallOrdinal]
        localWordIndex = localWordIndex + PrimaryCallOpRegisterArgCount(callOp)
        if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind == coreir.LocalStrTag ||
               resultSlot.typeKind == coreir.LocalAggregateTag:
                localWordIndex = localWordIndex + 1
        localWordIndex = localWordIndex + PrimaryCallOpStackPreCallWordCount(callOp)
        localWordIndex = localWordIndex + 1
        localWordIndex = localWordIndex + PrimaryCallOpStackPostCallWordCount(callOp)
        if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind == coreir.LocalI32Tag ||
               resultSlot.typeKind == coreir.LocalPtrTag:
                localWordIndex = localWordIndex + 1
    if insertCallOrdinal == bodyIR.callSequence.len:
        return localWordIndex
    return -1

fn PrimaryBodyIrCallSequenceReturnInt32WordCount(bodyIR: coreir.BodyIR): int32 =
    if bodyIR.ops.len <= 0:
        return 0
    let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
    let returnsI32Const = PrimaryBodyIrIsCallSequenceReturnI32Const(bodyIR)
    var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
    if frameBytes < 16:
        frameBytes = 16
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    if paramSaveCount < 0:
        return 0
    for callOrdinal in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[callOrdinal]
        let stackArgBytes = PrimaryCallOpStackArgBytes(callOp)
        if stackArgBytes > 512:
            return 0
        for argIndex in 0..<callOp.argSlots.len:
            let slotIndex = callOp.argSlots[argIndex]
            if slotIndex < 0:
                let paramSlot = 0 - slotIndex - 1
                if paramSlot < 0:
                    return 0
            elif slotIndex >= bodyIR.localSlots.len:
                return 0
            else:
                let argSlot = bodyIR.localSlots[slotIndex]
                if argSlot.typeKind != coreir.LocalI32Tag &&
                   argSlot.typeKind != coreir.LocalPtrTag &&
                   argSlot.typeKind != coreir.LocalStrTag &&
                   argSlot.typeKind != coreir.LocalAggregateTag:
                    return 0
        if callOp.resultSlot >= bodyIR.localSlots.len:
            return 0
        if callOp.resultSlot >= 0:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind != coreir.LocalI32Tag &&
               resultSlot.typeKind != coreir.LocalPtrTag &&
               resultSlot.typeKind != coreir.LocalStrTag &&
               resultSlot.typeKind != coreir.LocalAggregateTag:
                return 0
    if returnOp.target >= bodyIR.localSlots.len:
        return 0
    if returnOp.target < 0 && !returnsI32Const:
        let finalCallOp = bodyIR.callSequence[bodyIR.callSequence.len - 1]
        if finalCallOp.resultSlot >= 0 &&
           bodyIR.localSlots[finalCallOp.resultSlot].typeKind != coreir.LocalI32Tag &&
           bodyIR.localSlots[finalCallOp.resultSlot].typeKind != coreir.LocalPtrTag:
            return 0
    if paramSaveCount > 0:
        frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
    let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
    let epilogueWordCount = PrimaryArm64FrameEpilogueWordCount(frameBytes)
    if prologueWordCount <= 0 || epilogueWordCount <= 0:
        return 0
    if !PrimaryBodyIrIncomingParamOffsetsSupported(bodyIR, frameBytes):
        return 0
    var wordCount = prologueWordCount + paramSaveCount
    for callOrdinal in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[callOrdinal]
        wordCount = wordCount + PrimaryCallOpRegisterArgCount(callOp)
        if callOp.resultSlot >= 0:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind == coreir.LocalStrTag ||
               resultSlot.typeKind == coreir.LocalAggregateTag:
                wordCount = wordCount + 1
        wordCount = wordCount + PrimaryCallOpStackPreCallWordCount(callOp)
        wordCount = wordCount + 1
        wordCount = wordCount + PrimaryCallOpStackPostCallWordCount(callOp)
        if callOp.resultSlot >= 0:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind == coreir.LocalI32Tag ||
               resultSlot.typeKind == coreir.LocalPtrTag:
                wordCount = wordCount + 1
    if returnOp.target >= 0:
        if bodyIR.localSlots[returnOp.target].typeKind != coreir.LocalI32Tag &&
           bodyIR.localSlots[returnOp.target].typeKind != coreir.LocalPtrTag:
            return 0
        wordCount = wordCount + 1
    elif returnsI32Const:
        wordCount = wordCount + 1
    wordCount = wordCount + epilogueWordCount
    return wordCount

fn PrimaryBodyIrCallCfgReturnInt32WordCount(bodyIR: coreir.BodyIR): int32 =
    if !PrimaryBodyIrIsCallCfgReturnInt32(bodyIR):
        return 0
    var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
    if frameBytes < 16:
        frameBytes = 16
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    if paramSaveCount < 0:
        return 0
    for callOrdinal in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[callOrdinal]
        if PrimaryCallOpStackArgBytes(callOp) > 512:
            return 0
        for argIndex in 0..<callOp.argSlots.len:
            let slotIndex = callOp.argSlots[argIndex]
            if slotIndex >= bodyIR.localSlots.len:
                return 0
            if slotIndex >= 0:
                let argSlot = bodyIR.localSlots[slotIndex]
                if argSlot.typeKind != coreir.LocalI32Tag &&
                   argSlot.typeKind != coreir.LocalPtrTag &&
                   argSlot.typeKind != coreir.LocalStrTag &&
                   argSlot.typeKind != coreir.LocalAggregateTag:
                    return 0
        if callOp.resultSlot >= bodyIR.localSlots.len:
            return 0
    if paramSaveCount > 0:
        frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
    let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
    let epilogueWordCount = PrimaryArm64FrameEpilogueWordCount(frameBytes)
    if prologueWordCount <= 0 || epilogueWordCount <= 0:
        return 0
    if !PrimaryBodyIrIncomingParamOffsetsSupported(bodyIR, frameBytes):
        return 0
    var wordCount = prologueWordCount + paramSaveCount
    for blockIndex in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[blockIndex]
        for localOpIndex in 0..<block.opCount:
            let opIndex = block.opStart + localOpIndex
            let op = bodyIR.ops[opIndex]
            if op.kind != coreir.BodyOpCallTag || op.operands.len < 1:
                return 0
            let callOrdinal = op.operands[0]
            if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
                return 0
            let callOp = bodyIR.callSequence[callOrdinal]
            wordCount = wordCount + PrimaryBodyIrCallOpWordCount(bodyIR, callOp)
        let term = bodyIR.terms[block.termIndex]
        wordCount = wordCount + PrimaryBodyIrTermWordCount(term, epilogueWordCount)
    return wordCount

fn PrimaryBodyIrWordCount(bodyIR: coreir.BodyIR): int32 =
    if PrimaryBodyIrLocalInitPrefixLen(bodyIR) > 0:
        return 0
    if PrimaryBodyIrIsResultRequestDispatch(bodyIR):
        return 12
    if PrimaryBodyIrIsCallCfgReturnInt32(bodyIR):
        return PrimaryBodyIrCallCfgReturnInt32WordCount(bodyIR)
    if PrimaryBodyIrIsCallSequenceGuardReturnInt32(bodyIR):
        let plainBodyIR = PrimaryBodyIrWithoutGuardBranch(bodyIR)
        let plainWordCount = PrimaryBodyIrCallSequenceReturnInt32WordCount(plainBodyIR)
        let branchExtraWordCount = PrimaryBodyIrGuardBranchExtraWordCount(bodyIR)
        if plainWordCount <= 0 || branchExtraWordCount <= 0:
            return 0
        return plainWordCount + branchExtraWordCount
    if PrimaryBodyIrIsCallSequenceReturnStr(bodyIR) ||
       PrimaryBodyIrIsCallSequenceReturnAggregate(bodyIR):
        let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
        let returnTypeKind = returnOp.operands[0]
        let returnTarget = returnOp.target
        var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
        if frameBytes < 16:
            frameBytes = 16
        let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
        if paramSaveCount < 0:
            return 0
        for callOrdinal in 0..<bodyIR.callSequence.len:
            let callOp = bodyIR.callSequence[callOrdinal]
            let stackArgBytes = PrimaryCallOpStackArgBytes(callOp)
            if stackArgBytes > 512:
                return 0
            for argIndex in 0..<callOp.argSlots.len:
                let slotIndex = callOp.argSlots[argIndex]
                if slotIndex < 0:
                    let paramSlot = 0 - slotIndex - 1
                    if paramSlot < 0:
                        return 0
                elif slotIndex >= bodyIR.localSlots.len:
                    return 0
                else:
                    let argSlot = bodyIR.localSlots[slotIndex]
                    if argSlot.typeKind != coreir.LocalI32Tag &&
                       argSlot.typeKind != coreir.LocalPtrTag &&
                       argSlot.typeKind != coreir.LocalStrTag &&
                       argSlot.typeKind != coreir.LocalAggregateTag:
                        return 0
            if callOp.resultSlot >= bodyIR.localSlots.len:
                return 0
            if callOp.resultSlot >= 0:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind != coreir.LocalI32Tag &&
                   resultSlot.typeKind != coreir.LocalPtrTag &&
                   resultSlot.typeKind != coreir.LocalStrTag &&
                   resultSlot.typeKind != coreir.LocalAggregateTag:
                    return 0
        if returnTarget >= bodyIR.localSlots.len:
            return 0
        if returnTarget >= 0 &&
           bodyIR.localSlots[returnTarget].typeKind != returnTypeKind:
            return 0
        if returnTarget < 0 &&
           bodyIR.callSequence[bodyIR.callSequence.len - 1].resultSlot >= 0:
            return 0
        if paramSaveCount > 0:
            frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
        frameBytes = PrimaryAlignStackBytes(frameBytes + 8, 16)
        let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
        let epilogueWordCount = PrimaryArm64FrameEpilogueWordCount(frameBytes)
        if prologueWordCount <= 0 || epilogueWordCount <= 0:
            return 0
        if !PrimaryBodyIrIncomingParamOffsetsSupported(bodyIR, frameBytes):
            return 0
        var wordCount = prologueWordCount + paramSaveCount + 1
        for callOrdinal in 0..<bodyIR.callSequence.len:
            let callOp = bodyIR.callSequence[callOrdinal]
            wordCount = wordCount + PrimaryCallOpRegisterArgCount(callOp)
            var callWritesSret = false
            if callOp.resultSlot >= 0:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind == coreir.LocalStrTag ||
                   resultSlot.typeKind == coreir.LocalAggregateTag:
                    callWritesSret = true
            elif returnTarget < 0 && callOrdinal == bodyIR.callSequence.len - 1:
                callWritesSret = true
            if callWritesSret:
                wordCount = wordCount + 1
            wordCount = wordCount + PrimaryCallOpStackPreCallWordCount(callOp)
            wordCount = wordCount + 1
            wordCount = wordCount + PrimaryCallOpStackPostCallWordCount(callOp)
            if callOp.resultSlot >= 0:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind == coreir.LocalI32Tag ||
                   resultSlot.typeKind == coreir.LocalPtrTag:
                    wordCount = wordCount + 1
        if returnTarget >= 0:
            let copySize = bodyIR.localSlots[returnTarget].sizeBytes
            if copySize <= 0 || copySize % 8 != 0:
                return 0
            wordCount = wordCount + 1 + (copySize / 8) * 2
        wordCount = wordCount + epilogueWordCount
        return wordCount
    if PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR) ||
       PrimaryBodyIrIsCallSequenceReturnPtr(bodyIR) ||
       PrimaryBodyIrIsCallSequenceReturnI32Const(bodyIR):
        return PrimaryBodyIrCallSequenceReturnInt32WordCount(bodyIR)
    let statementMode = PrimaryBodyIrStatementReturnMode(bodyIR)
    if statementMode != PrimaryStatementReturnModeNone():
        if statementMode == PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
            return 5 + bodyIR.callSequence.len * 3
        return PrimaryStatementSequenceWordCount(statementMode)
    if PrimaryBodyIrIsI32TwoCallGuardFirstReturn(bodyIR):
        return 13
    if PrimaryBodyIrIsI32GuardThenCommandReturn(bodyIR):
        return 11
    if PrimaryBodyIrIsArg0I32LetCallThenReturnCallArg0Arg1(bodyIR):
        return 9
    if PrimaryBodyIrIsArg0AggregateCallThenReturnCallArg0Arg1(bodyIR):
        return 10
    if PrimaryBodyIrIsArg0SeqCallThenReturnCallArg0Arg1(bodyIR):
        return 10
    if PrimaryBodyIrIsStrCallConstThenCallArg0ReturnI32(bodyIR):
        return 9
    if PrimaryBodyIrIsStrI32GuardCallArg0ThenDispatchReturnI32(bodyIR):
        return 19
    if PrimaryBodyIrIsStrLetCallThenCallArg0ReturnI32(bodyIR):
        return 8
    if PrimaryBodyIrIsI32LetCallThenReturnCallArg0(bodyIR):
        return 6
    if PrimaryBodyIrIsI32GuardHelpThenCommandReturn(bodyIR):
        return 11
    if PrimaryBodyIrIsPtrNilGuardDerefReturn(bodyIR):
        return 10
    if PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR):
        let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
        var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
        if frameBytes < 16:
            frameBytes = 16
        let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
        if paramSaveCount < 0:
            return 0
        for callOrdinal in 0..<bodyIR.callSequence.len:
            let callOp = bodyIR.callSequence[callOrdinal]
            let stackArgBytes = PrimaryCallOpStackArgBytes(callOp)
            if stackArgBytes > 512:
                return 0
            for argIndex in 0..<callOp.argSlots.len:
                let slotIndex = callOp.argSlots[argIndex]
                if slotIndex < 0:
                    let paramSlot = 0 - slotIndex - 1
                    if paramSlot < 0:
                        return 0
                elif slotIndex >= bodyIR.localSlots.len:
                    return 0
                else:
                    let argSlot = bodyIR.localSlots[slotIndex]
                    if argSlot.typeKind != coreir.LocalI32Tag &&
                       argSlot.typeKind != coreir.LocalPtrTag &&
                       argSlot.typeKind != coreir.LocalStrTag &&
                       argSlot.typeKind != coreir.LocalAggregateTag:
                        return 0
            if callOp.resultSlot >= bodyIR.localSlots.len:
                return 0
            if callOp.resultSlot >= 0:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind != coreir.LocalI32Tag &&
                   resultSlot.typeKind != coreir.LocalPtrTag &&
                   resultSlot.typeKind != coreir.LocalStrTag &&
                   resultSlot.typeKind != coreir.LocalAggregateTag:
                    return 0
        if returnOp.target >= bodyIR.localSlots.len:
            return 0
        if returnOp.target < 0:
            let finalCallOp = bodyIR.callSequence[bodyIR.callSequence.len - 1]
            if finalCallOp.resultSlot >= 0 &&
               bodyIR.localSlots[finalCallOp.resultSlot].typeKind != coreir.LocalI32Tag:
                return 0
        if paramSaveCount > 0:
            frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
        let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
        let epilogueWordCount = PrimaryArm64FrameEpilogueWordCount(frameBytes)
        if prologueWordCount <= 0 || epilogueWordCount <= 0:
            return 0
        if !PrimaryBodyIrIncomingParamOffsetsSupported(bodyIR, frameBytes):
            return 0
        var wordCount = prologueWordCount + paramSaveCount
        for callOrdinal in 0..<bodyIR.callSequence.len:
            let callOp = bodyIR.callSequence[callOrdinal]
            wordCount = wordCount + PrimaryCallOpRegisterArgCount(callOp)
            if callOp.resultSlot >= 0:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind == coreir.LocalStrTag ||
                   resultSlot.typeKind == coreir.LocalAggregateTag:
                    wordCount = wordCount + 1
            wordCount = wordCount + PrimaryCallOpStackPreCallWordCount(callOp)
            wordCount = wordCount + 1
            wordCount = wordCount + PrimaryCallOpStackPostCallWordCount(callOp)
            if callOp.resultSlot >= 0:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind == coreir.LocalI32Tag ||
                   resultSlot.typeKind == coreir.LocalPtrTag:
                    wordCount = wordCount + 1
        if returnOp.target >= 0:
            if bodyIR.localSlots[returnOp.target].typeKind != coreir.LocalI32Tag:
                return 0
            wordCount = wordCount + 1
        wordCount = wordCount + epilogueWordCount
        return wordCount
    return 0

fn PrimaryBodyIrRequiresCallSequence(bodyIR: coreir.BodyIR): bool =
    if PrimaryBodyIrIsCallCfgReturnInt32(bodyIR):
        return true
    if PrimaryBodyIrIsResultRequestDispatch(bodyIR):
        return true
    if PrimaryBodyIrHasCallOp(bodyIR):
        return true
    let statementMode = PrimaryBodyIrStatementReturnMode(bodyIR)
    if statementMode != PrimaryStatementReturnModeNone():
        if statementMode == PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
            return bodyIR.callSequence.len > 0
        return PrimaryStatementSequenceRequiredCallCount(statementMode) > 0
    return PrimaryBodyIrIsPtrNilGuardDerefReturn(bodyIR) ||
           PrimaryBodyIrIsI32TwoCallGuardFirstReturn(bodyIR) ||
           PrimaryBodyIrIsI32GuardThenCommandReturn(bodyIR) ||
           PrimaryBodyIrIsI32LetCallThenReturnCallArg0(bodyIR) ||
           PrimaryBodyIrIsArg0I32LetCallThenReturnCallArg0Arg1(bodyIR) ||
           PrimaryBodyIrIsArg0AggregateCallThenReturnCallArg0Arg1(bodyIR) ||
           PrimaryBodyIrIsArg0SeqCallThenReturnCallArg0Arg1(bodyIR) ||
           PrimaryBodyIrIsStrLetCallThenCallArg0ReturnI32(bodyIR) ||
           PrimaryBodyIrIsI32GuardHelpThenCommandReturn(bodyIR) ||
           PrimaryBodyIrIsStrI32GuardCallArg0ThenDispatchReturnI32(bodyIR) ||
           PrimaryBodyIrIsStrCallConstThenCallArg0ReturnI32(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnPtr(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnI32Const(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnStr(bodyIR) ||
           PrimaryBodyIrIsCallSequenceReturnAggregate(bodyIR)

fn PrimaryBodyIrCallSequenceReturnInt32RelocWordOffset(bodyIR: coreir.BodyIR,
                                                        wordOffset: int32,
                                                        callOrdinal: int32): int32 =
    if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
        return -1
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    if paramSaveCount < 0:
        return -1
    var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
    if frameBytes < 16:
        frameBytes = 16
    if paramSaveCount > 0:
        frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
    let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
    if prologueWordCount <= 0:
        return -1
    var localWordIndex = prologueWordCount + paramSaveCount
    for currentCallOrdinal in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[currentCallOrdinal]
        localWordIndex = localWordIndex + PrimaryCallOpRegisterArgCount(callOp)
        if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind == coreir.LocalStrTag ||
               resultSlot.typeKind == coreir.LocalAggregateTag:
                localWordIndex = localWordIndex + 1
        localWordIndex = localWordIndex + PrimaryCallOpStackPreCallWordCount(callOp)
        if currentCallOrdinal == callOrdinal:
            return wordOffset + localWordIndex
        localWordIndex = localWordIndex + 1
        localWordIndex = localWordIndex + PrimaryCallOpStackPostCallWordCount(callOp)
        if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind == coreir.LocalI32Tag ||
               resultSlot.typeKind == coreir.LocalPtrTag:
                localWordIndex = localWordIndex + 1
    return -1

fn PrimaryBodyIrCallCfgBlockLocalWordOffset(bodyIR: coreir.BodyIR,
                                             targetBlockIndex: int32,
                                             prologueWordCount: int32,
                                             paramSaveCount: int32,
                                             epilogueWordCount: int32): int32 =
    if targetBlockIndex < 0 || targetBlockIndex >= bodyIR.blocks.len:
        return -1
    var localWordIndex = prologueWordCount + paramSaveCount
    for blockIndex in 0..<targetBlockIndex:
        let block = bodyIR.blocks[blockIndex]
        if block.opStart < 0 ||
           block.opCount < 0 ||
           block.opStart + block.opCount > bodyIR.ops.len ||
           block.termIndex < 0 ||
           block.termIndex >= bodyIR.terms.len:
            return -1
        for localOpIndex in 0..<block.opCount:
            let opIndex = block.opStart + localOpIndex
            let op = bodyIR.ops[opIndex]
            if op.kind != coreir.BodyOpCallTag || op.operands.len < 1:
                return -1
            let currentCallOrdinal = op.operands[0]
            if currentCallOrdinal < 0 || currentCallOrdinal >= bodyIR.callSequence.len:
                return -1
            let callOp = bodyIR.callSequence[currentCallOrdinal]
            localWordIndex = localWordIndex + PrimaryBodyIrCallOpWordCount(bodyIR, callOp)
        let term = bodyIR.terms[block.termIndex]
        localWordIndex = localWordIndex + PrimaryBodyIrTermWordCount(term, epilogueWordCount)
    return localWordIndex

fn PrimaryBodyIrRelocWordOffset(bodyIR: coreir.BodyIR,
                                 wordOffset: int32,
                                 callOrdinal: int32): int32 =
    if PrimaryBodyIrIsCallCfgReturnInt32(bodyIR):
        if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
            return -1
        let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
        if paramSaveCount < 0:
            return -1
        var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
        if frameBytes < 16:
            frameBytes = 16
        if paramSaveCount > 0:
            frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
        let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
        let epilogueWordCount = PrimaryArm64FrameEpilogueWordCount(frameBytes)
        if prologueWordCount <= 0 || epilogueWordCount <= 0:
            return -1
        var localWordIndex = prologueWordCount + paramSaveCount
        for blockIndex in 0..<bodyIR.blocks.len:
            let block = bodyIR.blocks[blockIndex]
            if block.opStart < 0 ||
               block.opCount < 0 ||
               block.opStart + block.opCount > bodyIR.ops.len ||
               block.termIndex < 0 ||
               block.termIndex >= bodyIR.terms.len:
                return -1
            for localOpIndex in 0..<block.opCount:
                let opIndex = block.opStart + localOpIndex
                let op = bodyIR.ops[opIndex]
                if op.kind != coreir.BodyOpCallTag || op.operands.len < 1:
                    return -1
                let currentCallOrdinal = op.operands[0]
                if currentCallOrdinal < 0 || currentCallOrdinal >= bodyIR.callSequence.len:
                    return -1
                let callOp = bodyIR.callSequence[currentCallOrdinal]
                localWordIndex = localWordIndex + PrimaryCallOpRegisterArgCount(callOp)
                if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
                    let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                    if resultSlot.typeKind == coreir.LocalStrTag ||
                       resultSlot.typeKind == coreir.LocalAggregateTag:
                        localWordIndex = localWordIndex + 1
                localWordIndex = localWordIndex + PrimaryCallOpStackPreCallWordCount(callOp)
                if currentCallOrdinal == callOrdinal:
                    return wordOffset + localWordIndex
                localWordIndex = localWordIndex + 1
                localWordIndex = localWordIndex + PrimaryCallOpStackPostCallWordCount(callOp)
                if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
                    let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                    if resultSlot.typeKind == coreir.LocalI32Tag ||
                       resultSlot.typeKind == coreir.LocalPtrTag:
                        localWordIndex = localWordIndex + 1
            let term = bodyIR.terms[block.termIndex]
            localWordIndex = localWordIndex + PrimaryBodyIrTermWordCount(term, epilogueWordCount)
        return -1
    if PrimaryBodyIrIsResultRequestDispatch(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 5
        if callOrdinal == 1:
            return wordOffset + 9
        return -1
    if PrimaryBodyIrIsCallSequenceGuardReturnInt32(bodyIR):
        let plainBodyIR = PrimaryBodyIrWithoutGuardBranch(bodyIR)
        var relocWordOffset = PrimaryBodyIrCallSequenceReturnInt32RelocWordOffset(plainBodyIR,
                                                                                  wordOffset,
                                                                                  callOrdinal)
        if relocWordOffset < 0:
            return -1
        let branchCallOrdinal = PrimaryBodyIrGuardBranchCallOrdinal(bodyIR)
        let branchExtraWordCount = PrimaryBodyIrGuardBranchExtraWordCount(bodyIR)
        if branchCallOrdinal < 0 || branchExtraWordCount <= 0:
            return -1
        if callOrdinal >= branchCallOrdinal:
            relocWordOffset = relocWordOffset + branchExtraWordCount
        return relocWordOffset
    if PrimaryBodyIrIsCallSequenceReturnStr(bodyIR) ||
       PrimaryBodyIrIsCallSequenceReturnAggregate(bodyIR):
        if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
            return -1
        let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
        let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
        if paramSaveCount < 0:
            return -1
        var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
        if frameBytes < 16:
            frameBytes = 16
        if paramSaveCount > 0:
            frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
        frameBytes = PrimaryAlignStackBytes(frameBytes + 8, 16)
        let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
        if prologueWordCount <= 0:
            return -1
        var localWordIndex = prologueWordCount + paramSaveCount + 1
        for currentCallOrdinal in 0..<bodyIR.callSequence.len:
            let callOp = bodyIR.callSequence[currentCallOrdinal]
            localWordIndex = localWordIndex + PrimaryCallOpRegisterArgCount(callOp)
            var callWritesSret = false
            if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind == coreir.LocalStrTag ||
                   resultSlot.typeKind == coreir.LocalAggregateTag:
                    callWritesSret = true
            elif returnOp.target < 0 && currentCallOrdinal == bodyIR.callSequence.len - 1:
                callWritesSret = true
            if callWritesSret:
                localWordIndex = localWordIndex + 1
            localWordIndex = localWordIndex + PrimaryCallOpStackPreCallWordCount(callOp)
            if currentCallOrdinal == callOrdinal:
                return wordOffset + localWordIndex
            localWordIndex = localWordIndex + 1
            localWordIndex = localWordIndex + PrimaryCallOpStackPostCallWordCount(callOp)
            if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind == coreir.LocalI32Tag ||
                   resultSlot.typeKind == coreir.LocalPtrTag:
                    localWordIndex = localWordIndex + 1
        return -1
    if PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR) ||
       PrimaryBodyIrIsCallSequenceReturnPtr(bodyIR) ||
       PrimaryBodyIrIsCallSequenceReturnI32Const(bodyIR):
        return PrimaryBodyIrCallSequenceReturnInt32RelocWordOffset(bodyIR,
                                                                   wordOffset,
                                                                  callOrdinal)
    let statementMode = PrimaryBodyIrStatementReturnMode(bodyIR)
    if statementMode != PrimaryStatementReturnModeNone():
        if statementMode == PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
            if callOrdinal >= 0 && callOrdinal < bodyIR.callSequence.len:
                return wordOffset + 4 + callOrdinal * 3
            return -1
        if callOrdinal == 0:
            return PrimaryStatementSequenceFirstRelocWordOffset(wordOffset, statementMode)
        if statementMode == PrimaryStatementReturnModeStrThenCallReturnI32Const0() &&
           callOrdinal == 1:
            return wordOffset + 5
        return -1
    if PrimaryBodyIrIsPtrNilGuardDerefReturn(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 2
    if PrimaryBodyIrIsI32TwoCallGuardFirstReturn(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 2
        if callOrdinal == 1:
            return wordOffset + 4
    if PrimaryBodyIrIsI32GuardThenCommandReturn(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 2
        if callOrdinal == 1:
            return wordOffset + 8
    if PrimaryBodyIrIsStrCallConstThenCallArg0ReturnI32(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 4
        if callOrdinal == 1:
            return wordOffset + 6
    if PrimaryBodyIrIsStrI32GuardCallArg0ThenDispatchReturnI32(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 3
        if callOrdinal == 1:
            return wordOffset + 5
        if callOrdinal == 2:
            return wordOffset + 6
        if callOrdinal == 3:
            return wordOffset + 10
        if callOrdinal == 4:
            return wordOffset + 16
    if PrimaryBodyIrIsI32LetCallThenReturnCallArg0(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 2
        if callOrdinal == 1:
            return wordOffset + 3
    if PrimaryBodyIrIsArg0I32LetCallThenReturnCallArg0Arg1(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 3
        if callOrdinal == 1:
            return wordOffset + 6
    if PrimaryBodyIrIsArg0AggregateCallThenReturnCallArg0Arg1(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 4
        if callOrdinal == 1:
            return wordOffset + 7
    if PrimaryBodyIrIsArg0SeqCallThenReturnCallArg0Arg1(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 4
        if callOrdinal == 1:
            return wordOffset + 7
    if PrimaryBodyIrIsStrLetCallThenCallArg0ReturnI32(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 3
        if callOrdinal == 1:
            return wordOffset + 5
    if PrimaryBodyIrIsI32GuardHelpThenCommandReturn(bodyIR):
        if callOrdinal == 0:
            return wordOffset + 2
        if callOrdinal == 1:
            return wordOffset + 5
        if callOrdinal == 2:
            return wordOffset + 8
    if PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR):
        if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
            return -1
        let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
        if paramSaveCount < 0:
            return -1
        var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
        if frameBytes < 16:
            frameBytes = 16
        if paramSaveCount > 0:
            frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
        let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
        if prologueWordCount <= 0:
            return -1
        var localWordIndex = prologueWordCount + paramSaveCount
        for currentCallOrdinal in 0..<bodyIR.callSequence.len:
            let callOp = bodyIR.callSequence[currentCallOrdinal]
            localWordIndex = localWordIndex + PrimaryCallOpRegisterArgCount(callOp)
            if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind == coreir.LocalStrTag ||
                   resultSlot.typeKind == coreir.LocalAggregateTag:
                    localWordIndex = localWordIndex + 1
            localWordIndex = localWordIndex + PrimaryCallOpStackPreCallWordCount(callOp)
            if currentCallOrdinal == callOrdinal:
                return wordOffset + localWordIndex
            localWordIndex = localWordIndex + 1
            localWordIndex = localWordIndex + PrimaryCallOpStackPostCallWordCount(callOp)
            if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
                let resultSlot = bodyIR.localSlots[callOp.resultSlot]
                if resultSlot.typeKind == coreir.LocalI32Tag ||
                   resultSlot.typeKind == coreir.LocalPtrTag:
                    localWordIndex = localWordIndex + 1
        return -1
    return -1

fn PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind: str): bool =
    return chengpath.TextStartsWith(bodyKind, texpr.BodyKindLetCallNoargReturnI32ConstPrefix)

fn PrimaryStatementReturnModeNone(): int32 =
    return texpr.StatementReturnModeNone

fn PrimaryStatementReturnModeI32Const(): int32 =
    return texpr.StatementReturnModeI32Const

fn PrimaryStatementReturnModeCallResultI32(): int32 =
    return texpr.StatementReturnModeCallResultI32

fn PrimaryStatementReturnModeI32GuardResultLeZero(): int32 =
    return texpr.StatementReturnModeI32GuardResultLeZero

fn PrimaryStatementReturnModeStrLen(): int32 =
    return texpr.StatementReturnModeStrLen

fn PrimaryStatementReturnModeStrThenCallReturnI32Const0(): int32 =
    return texpr.StatementReturnModeStrThenCallReturnI32Const0

fn PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0(): int32 =
    return texpr.StatementReturnModeCstringLiteralCallsReturnI32Const0

fn PrimaryStatementSequenceReturnMode(bodyKind: str): int32 =
    if PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
        return PrimaryStatementReturnModeI32Const()
    if texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(bodyKind):
        return PrimaryStatementReturnModeCallResultI32()
    if bodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32:
        return PrimaryStatementReturnModeI32GuardResultLeZero()
    if texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
        return PrimaryStatementReturnModeStrLen()
    if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
        return PrimaryStatementReturnModeStrThenCallReturnI32Const0()
    return PrimaryStatementReturnModeNone()

fn PrimaryStatementSequenceI32Value(bodyKind: str): int32 =
    if chengpath.TextStartsWith(bodyKind, texpr.BodyKindReturnI32ConstPrefix):
        let parseRes = bkind.BodyKindParseReturnI32Const(bodyKind, "primary_object_plan")
        if IsOk(parseRes):
            return Value(parseRes)
        return 0
    if PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
        let parseRes = bkind.BodyKindParseLetCallNoargReturnI32Const(bodyKind, "primary_object_plan")
        if IsOk(parseRes):
            return Value(parseRes)
        return 0
    if texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
        return 0
    return 0

fn PrimaryStatementSequenceWordCount(mode: int32): int32 =
    if mode == PrimaryStatementReturnModeI32Const():
        return 6
    if mode == PrimaryStatementReturnModeCallResultI32():
        return 5
    if mode == PrimaryStatementReturnModeI32GuardResultLeZero():
        return 10
    if mode == PrimaryStatementReturnModeStrLen():
        return 12
    if mode == PrimaryStatementReturnModeStrThenCallReturnI32Const0():
        return 9
    return 0

fn PrimaryStatementSequenceRequiredCallCount(mode: int32): int32 =
    if mode == PrimaryStatementReturnModeI32Const() ||
       mode == PrimaryStatementReturnModeCallResultI32() ||
       mode == PrimaryStatementReturnModeI32GuardResultLeZero() ||
       mode == PrimaryStatementReturnModeStrLen():
        return 1
    if mode == PrimaryStatementReturnModeStrThenCallReturnI32Const0():
        return 2
    return 0

fn PrimaryBodyRequiresCallSequence(bodyKind: str,
                                   statementMode: int32): bool =
    if bodyKind == texpr.BodyKindStatementSequence:
        return PrimaryStatementSequenceRequiredCallCount(statementMode) > 0
    if bodyKind == texpr.BodyKindBackendDriverRootFromCmdline:
        return true
    return texpr.TypedExprIsCallRelocBodyKind(bodyKind) ||
           PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind)

fn PrimaryStatementSequenceFirstRelocWordOffset(wordOffset: int32,
                                                 mode: int32): int32 =
    if mode == PrimaryStatementReturnModeI32Const() ||
       mode == PrimaryStatementReturnModeCallResultI32() ||
       mode == PrimaryStatementReturnModeI32GuardResultLeZero():
        return wordOffset + 2
    if mode == PrimaryStatementReturnModeStrLen() ||
       mode == PrimaryStatementReturnModeStrThenCallReturnI32Const0():
        return wordOffset + 3
    return wordOffset

fn PrimaryCallSequenceRelocWordOffset(bodyKind: str,
                                       statementMode: int32,
                                       wordOffset: int32,
                                       callOrdinal: int32): int32 =
    var mode = statementMode
    if bodyKind != texpr.BodyKindStatementSequence:
        mode = PrimaryStatementSequenceReturnMode(bodyKind)
    if bodyKind == texpr.BodyKindBackendDriverCommandDispatch:
        if callOrdinal >= 0 && callOrdinal < 6:
            return wordOffset + 131 + callOrdinal * 2
        return -1
    if bodyKind == texpr.BodyKindResultRequestDispatch:
        if callOrdinal == 0:
            return wordOffset + 5
        if callOrdinal == 1:
            return wordOffset + 9
        return -1
    if bodyKind == texpr.BodyKindBackendDriverRootFromCmdline:
        if callOrdinal == 0:
            return wordOffset + 4
        if callOrdinal == 1:
            return wordOffset + 18
        if callOrdinal == 2:
            return wordOffset + 33
        return -1
    if bodyKind == texpr.BodyKindReturnCallArg0TruePassthrough ||
       bodyKind == texpr.BodyKindReturnCallArg0Arg1TruePassthrough:
        if callOrdinal == 0:
            return wordOffset + 1
        return -1
    if mode == PrimaryStatementReturnModeNone():
        if callOrdinal != 0:
            return -1
        if PrimaryIsLetCallNoargReturnI32ConstBodyKind(bodyKind) ||
           texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(bodyKind) ||
           bodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32:
            return wordOffset + 2
        if texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
            return wordOffset + 3
        return wordOffset
    if callOrdinal == 0:
        return PrimaryStatementSequenceFirstRelocWordOffset(wordOffset, mode)
    if mode == PrimaryStatementReturnModeStrThenCallReturnI32Const0():
        if callOrdinal == 1:
            return wordOffset + 5
        return -1
    return -1

fn PrimaryPlanBodyKind(bodyKind: str): str =
    if PrimaryStatementSequenceReturnMode(bodyKind) != PrimaryStatementReturnModeNone():
        return texpr.BodyKindStatementSequence
    return bodyKind

fn PrimaryFunctionWordCountForBodyKind(bodyKind: str): int32 =
    return bkind.BodyKindExpectedWordCount(bodyKind)

fn PrimarySetInstructionWord(words: var int32[],
                              index: int32,
                              word: int32) =
    if index < 0 || index >= words.len:
        return
    words[index] = word

fn PrimaryMovI32ConstWord(value: int32): int32 =
    return 1384120320 + value * 32

fn PrimaryFillReturnI32Const(words: var int32[],
                              wordOffset: int32,
                              value: int32) =
    PrimarySetInstructionWord(words, wordOffset, PrimaryMovI32ConstWord(value))
    PrimarySetInstructionWord(words, wordOffset + 1, -698416192)

