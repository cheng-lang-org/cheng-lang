type
    PrimaryObjectPlan =
        targetTriple: str
        objectFormat: str
        outputPath: str
        entryPath: str
        entrySymbol: str
        entryFunctionSymbol: str
        itemIds: int32[]
        symbolNames: str[]
        functionWordOffsets: int32[]
        functionWordCounts: int32[]
        functionBodyKinds: str[]
        functionStatementReturnModes: int32[]
        functionStatementReturnI32Values: int32[]
        functionStatementCallCounts: int32[]
        functionLocalSlotCounts: int32[]
        functionLocalStackByteCounts: int32[]
        functionBodyIRs: coreir.BodyIR[]
        instructionWords: int32[]
        dataLabels: str[]
        dataPayloadTexts: str[]
        relocSourceItemIds: int32[]
        relocWordOffsets: int32[]
        relocTargetSymbols: str[]
        reachableFunctionCount: int32
        firstMissingFunction: str
        firstMissingBodyKind: str
        firstMissingTypedIrKind: str
        firstMissingLineNumber: int32
        missingReasons: str[]
        pipelineStage: str

fn PrimaryTargetSymbolName(targetTriple: str,
                             raw: str): str =
    if targetTriple == "arm64-apple-darwin" ||
       targetTriple == "aarch64-apple-ios" ||
       targetTriple == "arm64-apple-ios":
        if len(raw) > 0 && raw[0] == '_':
            return raw
        if len(raw) >= 2 && raw[0] == 'L' && raw[1] == '_':
            return raw
        return Fmt"_{raw}"
    return raw

fn PrimarySanitizeSymbolPart(text: str): str =
    var out = ""
    for i in 0..<len(text):
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            out = Fmt"{out}{strings.SliceBytes(text, i, 1)}"
        else:
            out = Fmt"{out}_"
    return out

fn PrimarySymbolNameForFunction(targetTriple: str,
                                  symbolText: str,
                                  signatureLineNumber: int32,
                                  emitKind: creq.CompilerEmit): str =
    var raw = symbolText
    var lineScoped = false
    if len(raw) == 0:
        raw = "cheng_primary_unnamed"
    if len(raw) >= 2:
        for i in 0..<(len(raw) - 1):
            if raw[i] == ':' && raw[i + 1] == ':':
                lineScoped = true
    raw = PrimarySanitizeSymbolPart(raw)
    if lineScoped && signatureLineNumber > 0:
        raw = Fmt"{raw}__L{strings.IntToStr(signatureLineNumber)}"
    return PrimaryTargetSymbolName(targetTriple, raw)

fn PrimarySymbolNameForGlobalVar(targetTriple: str,
                                  ownerModulePath: str,
                                  varName: str): str =
    let raw = Fmt"{ownerModulePath}__{varName}"
    return PrimaryTargetSymbolName(targetTriple, PrimarySanitizeSymbolPart(raw))

fn PrimaryStringSeqHas(items: str[],
                        value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn PrimaryCStringLiteralDataLabel(functionSymbol: str,
                                  callOrdinal: int32): str =
    return Fmt"{functionSymbol}__cstring_{intToStr(callOrdinal)}"

fn PrimarySimpleStringLiteralContent(argsText: str,
                                     content: var str): bool =
    content = ""
    let trimmed = chengpath.PathTrim(argsText)
    if len(trimmed) < 2:
        return false
    if trimmed[0] != char(34) || trimmed[len(trimmed) - 1] != char(34):
        return false
    var escaped = false
    for i in 1..<(len(trimmed) - 1):
        let ch = trimmed[i]
        if escaped:
            escaped = false
        elif ch == char(92):
            escaped = true
        elif ch == char(34):
            return false
    if escaped:
        return false
    content = strings.SliceBytes(trimmed, 1, len(trimmed) - 2)
    return true

fn PrimaryRuntimeEntryBridgeSymbol(linkPlan: slplan.SystemLinkPlanStub): str =
    var raw = "cheng_program_argv_entry"
    if linkPlan.moduleKind == slplan.SystemCompilerControlPlane:
        raw = "cheng_tooling_argv_entry"
    return PrimaryTargetSymbolName(linkPlan.targetTriple, raw)

fn PrimaryExportRootMatches(root: str,
                             targetSymbol: str,
                             exportSymbol: str,
                             symbolText: str,
                             functionName: str): bool =
    if len(root) <= 0:
        return false
    if root == targetSymbol ||
       root == exportSymbol ||
       root == symbolText ||
       root == functionName:
        return true
    if len(root) > 1 && root[0] == '_':
        let raw = strings.SliceBytes(root, 1, len(root) - 1)
        if raw == exportSymbol || raw == symbolText || raw == functionName:
            return true
    return false

fn PrimaryExportRootIndex(roots: str[],
                           targetSymbol: str,
                           exportSymbol: str,
                           symbolText: str,
                           functionName: str): int32 =
    for i in 0..<roots.len:
        if PrimaryExportRootMatches(roots[i],
                                    targetSymbol,
                                    exportSymbol,
                                    symbolText,
                                    functionName):
            return i
    return -1

fn PrimaryFunctionTailName(functionName: str): str =
    var tailStart = 0
    if len(functionName) >= 2:
        for j in 0..<(len(functionName) - 1):
            if functionName[j] == ':' && functionName[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < len(functionName):
        return strings.SliceBytes(functionName, tailStart, len(functionName) - tailStart)
    return functionName

fn PrimaryCallTargetTailName(targetText: str): str =
    var tailStart = 0
    for i in 0..<len(targetText):
        if targetText[i] == '.':
            tailStart = i + 1
    if len(targetText) >= 2:
        for j in 0..<(len(targetText) - 1):
            if targetText[j] == ':' && targetText[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < len(targetText):
        return strings.SliceBytes(targetText, tailStart, len(targetText) - tailStart)
    return targetText

fn PrimaryObjectIrFunctionIndex(ir: var lower.PrimaryObjectIr,
                                 sourcePath: str,
                                 functionName: str): int32 =
    let tailName = PrimaryFunctionTailName(functionName)
    for i in 0..<ir.functions.len:
        if ir.functions[i].sourcePath != sourcePath:
            continue
        if ir.functions[i].functionName == functionName ||
           ir.functions[i].functionName == tailName:
            return i
    return -1

fn PrimaryFunctionTargetSymbol(functionSymbolTexts: str[],
                                 functionSourcePaths: str[],
                                 allSymbolNames: str[],
                                 targetSourcePath: str,
                                 targetText: str): str =
    for i in 0..<functionSymbolTexts.len:
        if functionSymbolTexts[i] == targetText:
            return allSymbolNames[i]
    let targetTail = PrimaryCallTargetTailName(targetText)
    for i in 0..<functionSymbolTexts.len:
        if i >= functionSourcePaths.len:
            continue
        if functionSourcePaths[i] != targetSourcePath:
            continue
        if i >= allSymbolNames.len:
            continue
        if PrimaryFunctionTailName(functionSymbolTexts[i]) == targetTail:
            return allSymbolNames[i]
    return ""

fn PrimaryFunctionTargetIndex(functionSymbolTexts: str[],
                               functionSourcePaths: str[],
                               targetSourcePath: str,
                               targetText: str): int32 =
    for i in 0..<functionSymbolTexts.len:
        if functionSymbolTexts[i] == targetText:
            return i
    let targetTail = PrimaryCallTargetTailName(targetText)
    for i in 0..<functionSymbolTexts.len:
        if i >= functionSourcePaths.len:
            continue
        if functionSourcePaths[i] != targetSourcePath:
            continue
        if PrimaryFunctionTailName(functionSymbolTexts[i]) == targetTail:
            return i
    return -1

fn PrimaryBoolSeqInit(count: int32,
                       value: bool): bool[] =
    var out: bool[]
    for _ in 0..<count:
        add(out, value)
    return out

fn PrimaryIntSeqInit(count: int32,
                      value: int32): int32[] =
    var out: int32[]
    for _ in 0..<count:
        add(out, value)
    return out

fn PrimaryLocalSlotSize(typeKind: int32): int32 =
    if typeKind == coreir.LocalI32Tag:
        return 4
    if typeKind == coreir.LocalF64Tag:
        return 8
    if typeKind == coreir.LocalStrTag:
        return 24
    if typeKind == coreir.LocalPtrTag:
        return 8
    return 0

fn PrimaryLocalSlotSizeOf(slot: coreir.LocalSlot): int32 =
    if slot.sizeBytes > 0:
        return slot.sizeBytes
    return PrimaryLocalSlotSize(slot.typeKind)

fn PrimaryAlignStackBytes(value: int32, align: int32): int32 =
    if align <= 1:
        return value
    let remainder = value % align
    if remainder == 0:
        return value
    return value + (align - remainder)

fn PrimaryBodyIrStackByteCount(bodyIR: coreir.BodyIR): int32 =
    var maxEnd: int32
    for i in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[i]
        let slotEnd = slot.stackOffset + PrimaryLocalSlotSizeOf(slot)
        if slotEnd > maxEnd:
            maxEnd = slotEnd
    return PrimaryAlignStackBytes(maxEnd, 16)

fn PrimaryBodyOpKindText(kind: int32): str =
    if kind == coreir.BodyOpLoadConstTag:
        return "load_const"
    if kind == coreir.BodyOpCallTag:
        return "call"
    if kind == coreir.BodyOpBinOpTag:
        return "bin_op"
    if kind == coreir.BodyOpCmpTag:
        return "cmp"
    if kind == coreir.BodyOpBranchTag:
        return "branch"
    if kind == coreir.BodyOpReturnTag:
        return "return"
    if kind == coreir.BodyOpLoadLocalTag:
        return "load_local"
    if kind == coreir.BodyOpStoreLocalTag:
        return "store_local"
    if kind == coreir.BodyOpCopyLocalTag:
        return "copy_local"
    return "invalid"

fn PrimaryBodyIrOpTargetsLocal(bodyIR: coreir.BodyIR,
                                op: coreir.BodyOp): bool =
    return op.target >= 0 && op.target < bodyIR.localSlots.len

fn PrimaryBodyIrLocalInitPrefixLen(bodyIR: coreir.BodyIR): int32 =
    var prefixLen: int32
    while prefixLen < bodyIR.ops.len:
        let op = bodyIR.ops[prefixLen]
        if (op.kind == coreir.BodyOpStoreLocalTag ||
            op.kind == coreir.BodyOpCopyLocalTag) &&
           PrimaryBodyIrOpTargetsLocal(bodyIR, op):
            prefixLen = prefixLen + 1
        elif op.kind == coreir.BodyOpLoadConstTag &&
             PrimaryBodyIrOpTargetsLocal(bodyIR, op):
            prefixLen = prefixLen + 1
        elif op.kind == coreir.BodyOpLoadConstTag &&
             prefixLen + 1 < bodyIR.ops.len &&
             (bodyIR.ops[prefixLen + 1].kind == coreir.BodyOpStoreLocalTag ||
              bodyIR.ops[prefixLen + 1].kind == coreir.BodyOpCopyLocalTag) &&
             PrimaryBodyIrOpTargetsLocal(bodyIR, bodyIR.ops[prefixLen + 1]):
            prefixLen = prefixLen + 1
        else:
            return prefixLen
    return prefixLen

fn PrimaryBodyIrHasCallOp(bodyIR: coreir.BodyIR): bool =
    for i in 0..<bodyIR.ops.len:
        if bodyIR.ops[i].kind == coreir.BodyOpCallTag:
            return true
    return false

fn PrimaryBodyIrMissingKind(bodyIR: coreir.BodyIR,
                             fallback: str): str =
    let localInitPrefixLen = PrimaryBodyIrLocalInitPrefixLen(bodyIR)
    if localInitPrefixLen > 0:
        if localInitPrefixLen < bodyIR.ops.len:
            return Fmt"body_ir_after_local_init_{PrimaryBodyOpKindText(bodyIR.ops[localInitPrefixLen].kind)}"
        return "body_ir_after_local_init_missing_op"
    if bodyIR.ops.len > 0:
        return Fmt"body_ir_{PrimaryBodyOpKindText(bodyIR.ops[0].kind)}"
    if bodyIR.localSlots.len > 0:
        return "body_ir_local_slots_missing_ops"
    return fallback

fn PrimaryBodyIrIsPtrNilGuardDerefReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 1:
        return false
    if bodyIR.ops.len != 4:
        return false
    let callOp = bodyIR.ops[0]
    let branchOp = bodyIR.ops[1]
    let loadOp = bodyIR.ops[2]
    let returnOp = bodyIR.ops[3]
    if callOp.kind != coreir.BodyOpCallTag ||
       branchOp.kind != coreir.BodyOpBranchTag ||
       loadOp.kind != coreir.BodyOpLoadLocalTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if branchOp.operands.len < 3 ||
       loadOp.operands.len < 3 ||
       returnOp.operands.len < 1:
        return false
    let resultSlot = bodyIR.callSequence[0].resultSlot
    return branchOp.operands[0] == coreir.BodyBranchIfLocalNilReturnI32ConstTag &&
           branchOp.operands[1] == resultSlot &&
           branchOp.operands[2] == 0 &&
           loadOp.operands[0] == coreir.BodyLoadLocalPtrDerefI32Tag &&
           loadOp.operands[1] == resultSlot &&
	           loadOp.operands[2] == coreir.LocalI32Tag &&
	           returnOp.target == resultSlot &&
	           returnOp.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsI32TwoCallGuardFirstReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 2:
        return false
    if bodyIR.ops.len != 4:
        return false
    let firstCallOp = bodyIR.ops[0]
    let secondCallOp = bodyIR.ops[1]
    let branchOp = bodyIR.ops[2]
    let returnOp = bodyIR.ops[3]
    if firstCallOp.kind != coreir.BodyOpCallTag ||
       secondCallOp.kind != coreir.BodyOpCallTag ||
       branchOp.kind != coreir.BodyOpBranchTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if branchOp.operands.len < 3 ||
       returnOp.operands.len < 1:
        return false
    return branchOp.operands[0] == coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag &&
           branchOp.operands[1] == bodyIR.callSequence[1].resultSlot &&
           branchOp.operands[2] == 0 &&
           returnOp.target == bodyIR.callSequence[0].resultSlot &&
           returnOp.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsI32GuardHelpThenCommandReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 3:
        return false
    if bodyIR.ops.len != 4:
        return false
    let countCallOp = bodyIR.ops[0]
    let branchOp = bodyIR.ops[1]
    let commandCallOp = bodyIR.ops[2]
    let returnOp = bodyIR.ops[3]
    if countCallOp.kind != coreir.BodyOpCallTag ||
       branchOp.kind != coreir.BodyOpBranchTag ||
       commandCallOp.kind != coreir.BodyOpCallTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if countCallOp.operands.len < 1 ||
       branchOp.operands.len < 3 ||
       commandCallOp.operands.len < 1 ||
       returnOp.operands.len < 1:
        return false
    return countCallOp.operands[0] == 0 &&
           branchOp.operands[0] == coreir.BodyBranchIfLocalLeZeroReturnCallNoargTag &&
           branchOp.operands[1] == bodyIR.callSequence[0].resultSlot &&
           branchOp.operands[2] == 1 &&
           commandCallOp.operands[0] == 2 &&
           returnOp.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsI32GuardThenCommandReturn(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 2:
        return false
    if bodyIR.ops.len != 4:
        return false
    let countCallOp = bodyIR.ops[0]
    let branchOp = bodyIR.ops[1]
    let commandCallOp = bodyIR.ops[2]
    let returnOp = bodyIR.ops[3]
    if countCallOp.kind != coreir.BodyOpCallTag ||
       branchOp.kind != coreir.BodyOpBranchTag ||
       commandCallOp.kind != coreir.BodyOpCallTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if countCallOp.operands.len < 1 ||
       branchOp.operands.len < 3 ||
       commandCallOp.operands.len < 1 ||
       returnOp.operands.len < 1:
        return false
    return countCallOp.operands[0] == 0 &&
           branchOp.operands[0] == coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag &&
           branchOp.operands[1] == bodyIR.callSequence[0].resultSlot &&
           branchOp.operands[2] == 0 &&
           commandCallOp.operands[0] == 1 &&
           returnOp.operands[0] == coreir.LocalI32Tag

fn PrimaryBodyIrIsI32LetCallThenReturnCallArg0(bodyIR: coreir.BodyIR): bool =
    if bodyIR.callSequence.len != 2:
        return false
    if bodyIR.ops.len != 3:
        return false
    let firstCallOp = bodyIR.ops[0]
    let secondCallOp = bodyIR.ops[1]
    let returnOp = bodyIR.ops[2]
    if firstCallOp.kind != coreir.BodyOpCallTag ||
       secondCallOp.kind != coreir.BodyOpCallTag ||
       returnOp.kind != coreir.BodyOpReturnTag:
        return false
    if firstCallOp.operands.len != 1 ||
       secondCallOp.operands.len != 1 ||
       returnOp.operands.len < 1:
        return false
    if bodyIR.callSequence[1].argSlots.len < 1:
        return false
    let resultSlot = bodyIR.callSequence[0].resultSlot
    if resultSlot < 0 || resultSlot >= bodyIR.localSlots.len:
        return false
    return firstCallOp.operands[0] == 0 &&
           secondCallOp.operands[0] == 1 &&
           bodyIR.localSlots[resultSlot].typeKind == coreir.LocalI32Tag &&
           bodyIR.callSequence[1].argSlots[0] == bodyIR.callSequence[0].resultSlot &&
           returnOp.operands[0] == coreir.LocalI32Tag

