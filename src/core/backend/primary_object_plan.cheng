    term.rhsSlot = rhsSlot
    if rhsSlot < 0:
        add(term.operands, rhsConst)
    term.trueBlock = bodyIR.blocks.len + 1
    term.falseBlock = bodyIR.blocks.len + 2
    let termIndex = coreir.BodyIRAppendTerm(bodyIR, term)
    let _ = coreir.BodyIRAppendBlock(bodyIR, opStart, opCount, termIndex)
    pendingBlockStart = bodyIR.ops.len
