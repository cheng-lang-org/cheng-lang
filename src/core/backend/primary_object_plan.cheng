fn PrimaryArm64FrameStpWord(frameBytes: int32): int32 =
    if frameBytes < 16 || frameBytes > 512:
        return 0
    var word = -1447068675
    var cursor = 16
    for _ in 0..<32:
        if cursor < frameBytes:
            word = word - 65536
            cursor = cursor + 16
    if cursor != frameBytes:
        return 0
    return word

fn PrimaryArm64FrameLdpWord(frameBytes: int32): int32 =
    if frameBytes < 16 || frameBytes > 512:
        return 0
    var word = -1463714819
    var cursor = 16
    for _ in 0..<32:
        if cursor < frameBytes:
            word = word + 65536
            cursor = cursor + 16
    if cursor != frameBytes:
        return 0
    return word

fn PrimaryArm64OffsetWord(baseWord: int32,
                           offsetBytes: int32,
                           scaleBytes: int32,
                           maxSteps: int32): int32 =
    if offsetBytes < 0 || scaleBytes <= 0 || maxSteps <= 0:
        return 0
    var word = baseWord
    var cursor = 0
    for _ in 0..<maxSteps:
        if cursor < offsetBytes:
            word = word + 1024
            cursor = cursor + scaleBytes
    if cursor != offsetBytes:
        return 0
    return word

fn PrimaryArm64RegisterWord(baseWord: int32,
                             registerIndex: int32): int32 =
    if registerIndex < 0 || registerIndex > 30:
        return 0
    var word = baseWord
    var cursor = 0
    for _ in 0..<31:
        if cursor < registerIndex:
            word = word + 1
            cursor = cursor + 1
    if cursor != registerIndex:
        return 0
    return word

fn PrimaryArm64RegisterShift5Word(baseWord: int32,
                                    registerIndex: int32): int32 =
    if registerIndex < 0 || registerIndex > 30:
        return 0
    var word = baseWord
    var cursor = 0
    for _ in 0..<31:
        if cursor < registerIndex:
            word = word + 32
            cursor = cursor + 1
    if cursor != registerIndex:
        return 0
    return word

fn PrimaryArm64CmpWRegZeroWord(registerIndex: int32): int32 =
    return PrimaryArm64RegisterShift5Word(1895825439, registerIndex)

fn PrimaryArm64BCondGtWord(instructionDelta: int32): int32 =
    if instructionDelta <= 0 || instructionDelta > 262143:
        return 0
    var word = 1409286156
    var cursor: int32
    for _ in 0..<262144:
        if cursor < instructionDelta:
            word = word + 32
            cursor = cursor + 1
    if cursor != instructionDelta:
        return 0
    return word

fn PrimaryArm64BWord(instructionDelta: int32): int32 =
    if instructionDelta <= 0 || instructionDelta > 67108863:
        return 0
    return 335544320 + instructionDelta

fn PrimaryArm64BCondWord(instructionDelta: int32,
                          conditionCode: int32): int32 =
    if instructionDelta <= 0 || instructionDelta > 262143:
        return 0
    if conditionCode < 0 || conditionCode > 15:
        return 0
    return 1409286144 + conditionCode + instructionDelta * 32

fn PrimaryArm64SpSubWord(offsetBytes: int32): int32 =
    return PrimaryArm64OffsetWord(-788528129, offsetBytes, 1, 4095)

fn PrimaryArm64SpAddWord(offsetBytes: int32): int32 =
    return PrimaryArm64OffsetWord(-1862269953, offsetBytes, 1, 4095)

fn PrimaryFillArm64FrameEpilogue(words: var int32[],
                                  emitIndex: var int32,
                                  frameBytes: int32) =
    if frameBytes <= 512:
        let frameLdpWord = PrimaryArm64FrameLdpWord(frameBytes)
        if frameLdpWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  frameLdpWord)
        emitIndex = emitIndex + 1
    else:
        PrimarySetInstructionWord(words, emitIndex, -1455391747)
        emitIndex = emitIndex + 1
        let frameAddWord = PrimaryArm64SpAddWord(frameBytes)
        if frameAddWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  frameAddWord)
        emitIndex = emitIndex + 1

fn PrimaryFillBodyIrCallOp(words: var int32[],
                            emitIndex: var int32,
                            bodyIR: coreir.BodyIR,
                            callOp: coreir.CallOp,
                            frameBytes: int32,
                            paramSaveCount: int32,
                            paramSaveOffset: int32) =
    let registerArgCount = PrimaryCallOpRegisterArgCount(callOp)
    for argIndex in 0..<registerArgCount:
        let slotIndex = callOp.argSlots[argIndex]
        if PrimaryCallArgSlotIsConst(slotIndex):
            let constMovWord = PrimaryCallArgConstMovWord(slotIndex, argIndex)
            if constMovWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      constMovWord)
            emitIndex = emitIndex + 1
        elif slotIndex >= 0 && slotIndex < bodyIR.localSlots.len:
            let slot = bodyIR.localSlots[slotIndex]
            if slot.typeKind == coreir.LocalI32Tag:
                let loadBaseWord = PrimaryArm64RegisterWord(-1186987104,
                                                            argIndex)
                if loadBaseWord == 0:
                    return
                let loadWord = PrimaryArm64OffsetWord(loadBaseWord,
                                                      slot.stackOffset,
                                                      4,
                                                      4095)
                if loadWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          loadWord)
            elif slot.typeKind == coreir.LocalPtrTag:
                let loadBaseWord = PrimaryArm64RegisterWord(-113245280,
                                                            argIndex)
                if loadBaseWord == 0:
                    return
                let loadWord = PrimaryArm64OffsetWord(loadBaseWord,
                                                      slot.stackOffset,
                                                      8,
                                                      4095)
                if loadWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          loadWord)
            else:
                let addrBaseWord = PrimaryArm64RegisterWord(-1862270048,
                                                            argIndex)
                if addrBaseWord == 0:
                    return
                let addrWord = PrimaryArm64OffsetWord(addrBaseWord,
                                                      slot.stackOffset,
                                                      1,
                                                      4095)
                if addrWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          addrWord)
            emitIndex = emitIndex + 1
        elif slotIndex < 0:
            let paramSlot = 0 - slotIndex - 1
            if paramSlot < 0:
                return
            var paramOffset = PrimaryIncomingParamStackOffset(frameBytes,
                                                              paramSlot)
            if paramSlot < 8:
                if paramSlot >= paramSaveCount:
                    return
                paramOffset = paramSaveOffset + paramSlot * 8
            if paramOffset < 0:
                return
            let loadParamBaseWord = PrimaryArm64RegisterWord(-113245280,
                                                             argIndex)
            if loadParamBaseWord == 0:
                return
            let loadParamWord = PrimaryArm64OffsetWord(loadParamBaseWord,
                                                       paramOffset,
                                                       8,
                                                       4095)
            if loadParamWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      loadParamWord)
            emitIndex = emitIndex + 1
    if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
        let resultSlot = bodyIR.localSlots[callOp.resultSlot]
        if resultSlot.typeKind == coreir.LocalStrTag ||
           resultSlot.typeKind == coreir.LocalAggregateTag:
            let resultSretWord = PrimaryArm64OffsetWord(-1862270040,
                                                        resultSlot.stackOffset,
                                                        1,
                                                        4095)
            if resultSretWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      resultSretWord)
            emitIndex = emitIndex + 1
    let stackArgCount = PrimaryCallOpStackArgCount(callOp)
    let stackArgBytes = PrimaryCallOpStackArgBytes(callOp)
    if stackArgCount > 0:
        let subSpWord = PrimaryArm64SpSubWord(stackArgBytes)
        if subSpWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  subSpWord)
        emitIndex = emitIndex + 1
        for stackArgIndex in 0..<stackArgCount:
            let argIndex = stackArgIndex + 8
            if argIndex >= callOp.argSlots.len:
                return
            let slotIndex = callOp.argSlots[argIndex]
            if PrimaryCallArgSlotIsConst(slotIndex):
                let constMovWord = PrimaryCallArgConstMovWord(slotIndex, 16)
                if constMovWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          constMovWord)
                emitIndex = emitIndex + 1
            elif slotIndex >= 0 && slotIndex < bodyIR.localSlots.len:
                let slot = bodyIR.localSlots[slotIndex]
                if slot.typeKind == coreir.LocalI32Tag:
                    let loadStackArgWord = PrimaryArm64OffsetWord(-1186987088,
                                                                  slot.stackOffset,
                                                                  4,
                                                                  4095)
                    if loadStackArgWord == 0:
                        return
                    PrimarySetInstructionWord(words,
                                              emitIndex,
                                              loadStackArgWord)
                elif slot.typeKind == coreir.LocalPtrTag:
                    let loadStackArgWord = PrimaryArm64OffsetWord(-113245264,
                                                                  slot.stackOffset,
                                                                  8,
                                                                  4095)
                    if loadStackArgWord == 0:
                        return
                    PrimarySetInstructionWord(words,
                                              emitIndex,
                                              loadStackArgWord)
                else:
                    let addrStackArgWord = PrimaryArm64OffsetWord(-1862270032,
                                                                  slot.stackOffset,
                                                                  1,
                                                                  4095)
                    if addrStackArgWord == 0:
                        return
                    PrimarySetInstructionWord(words,
                                              emitIndex,
                                              addrStackArgWord)
                emitIndex = emitIndex + 1
            elif slotIndex < 0:
                let paramSlot = 0 - slotIndex - 1
                if paramSlot < 0:
                    return
                var paramOffset = PrimaryIncomingParamStackOffset(frameBytes,
                                                                  paramSlot)
                if paramSlot < 8:
                    if paramSlot >= paramSaveCount:
                        return
                    paramOffset = paramSaveOffset + paramSlot * 8
                if paramOffset < 0:
                    return
                let loadStackParamWord = PrimaryArm64OffsetWord(-113245264,
                                                                paramOffset,
                                                                8,
                                                                4095)
                if loadStackParamWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          loadStackParamWord)
                emitIndex = emitIndex + 1
            else:
                return
            let stackStoreWord = PrimaryArm64OffsetWord(-117439504,
                                                        stackArgIndex * 8,
                                                        8,
                                                        4095)
            if stackStoreWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      stackStoreWord)
            emitIndex = emitIndex + 1
    PrimarySetInstructionWord(words, emitIndex, -1811939328)
    emitIndex = emitIndex + 1
    if stackArgCount > 0:
        let addSpWord = PrimaryArm64SpAddWord(stackArgBytes)
        if addSpWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  addSpWord)
        emitIndex = emitIndex + 1
    if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
        let resultSlot = bodyIR.localSlots[callOp.resultSlot]
        if resultSlot.typeKind == coreir.LocalI32Tag:
            let storeWord = PrimaryArm64OffsetWord(-1191181408,
                                                   resultSlot.stackOffset,
                                                   4,
                                                   4095)
            if storeWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      storeWord)
            emitIndex = emitIndex + 1
        elif resultSlot.typeKind == coreir.LocalPtrTag:
            let storeWord = PrimaryArm64OffsetWord(-117439584,
                                                   resultSlot.stackOffset,
                                                   8,
                                                   4095)
            if storeWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      storeWord)
            emitIndex = emitIndex + 1

fn PrimaryFillCallCfgReturnInt32Term(words: var int32[],
                                      emitIndex: var int32,
                                      bodyIR: coreir.BodyIR,
                                      term: coreir.BodyTerm,
                                      frameBytes: int32) =
    var returnsConst = false
    var constValue: int32
    if term.operands.len >= 2 &&
       term.operands[0] == PrimaryStatementReturnModeI32Const():
        returnsConst = true
        constValue = term.operands[1]
    if returnsConst:
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  PrimaryMovI32ConstWord(constValue))
        emitIndex = emitIndex + 1
    else:
        let returnSlotIndex = term.resultSlot
        if returnSlotIndex < 0 || returnSlotIndex >= bodyIR.localSlots.len:
            return
        let returnSlot = bodyIR.localSlots[returnSlotIndex]
        if returnSlot.typeKind != coreir.LocalI32Tag:
            return
        let returnLoadWord = PrimaryArm64OffsetWord(-1186987104,
                                                    returnSlot.stackOffset,
                                                    4,
                                                    4095)
        if returnLoadWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  returnLoadWord)
        emitIndex = emitIndex + 1
    PrimaryFillArm64FrameEpilogue(words, emitIndex, frameBytes)
    PrimarySetInstructionWord(words, emitIndex, -698416192)
    emitIndex = emitIndex + 1

fn PrimaryFillCallCfgReturnInt32(words: var int32[],
                                  wordOffset: int32,
                                  bodyIR: coreir.BodyIR) =
    if !PrimaryBodyIrIsCallCfgReturnInt32(bodyIR):
        return
    var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
    if frameBytes < 16:
        frameBytes = 16
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    if paramSaveCount < 0:
        return
    var paramSaveOffset = frameBytes
    if paramSaveCount > 0:
        frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
    if !PrimaryBodyIrIncomingParamOffsetsSupported(bodyIR, frameBytes):
        return
    let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
    let epilogueWordCount = PrimaryArm64FrameEpilogueWordCount(frameBytes)
    if prologueWordCount <= 0 || epilogueWordCount <= 0:
        return
    var emitIndex = wordOffset
    if frameBytes <= 512:
        let frameStpWord = PrimaryArm64FrameStpWord(frameBytes)
        if frameStpWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  frameStpWord)
        emitIndex = emitIndex + 1
    else:
        let frameSubWord = PrimaryArm64SpSubWord(frameBytes)
        if frameSubWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  frameSubWord)
        emitIndex = emitIndex + 1
        PrimarySetInstructionWord(words, emitIndex, -1459586051)
        emitIndex = emitIndex + 1
    PrimarySetInstructionWord(words, emitIndex, -1862269955)
    emitIndex = emitIndex + 1
    for paramIndex in 0..<paramSaveCount:
        let saveOffset = paramSaveOffset + paramIndex * 8
        let saveBaseWord = PrimaryArm64RegisterWord(-117439584,
                                                    paramIndex)
        if saveBaseWord == 0:
            return
        let saveWord = PrimaryArm64OffsetWord(saveBaseWord,
                                              saveOffset,
                                              8,
                                              4095)
        if saveWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  saveWord)
        emitIndex = emitIndex + 1
    for blockIndex in 0..<bodyIR.blocks.len:
        let expectedLocalOffset = PrimaryBodyIrCallCfgBlockLocalWordOffset(bodyIR,
                                                                           blockIndex,
                                                                           prologueWordCount,
                                                                           paramSaveCount,
                                                                           epilogueWordCount)
        if expectedLocalOffset < 0 || emitIndex != wordOffset + expectedLocalOffset:
            return
        let block = bodyIR.blocks[blockIndex]
        for localOpIndex in 0..<block.opCount:
            let opIndex = block.opStart + localOpIndex
            if opIndex < 0 || opIndex >= bodyIR.ops.len:
                return
            let op = bodyIR.ops[opIndex]
            if op.kind != coreir.BodyOpCallTag || op.operands.len < 1:
                return
            let callOrdinal = op.operands[0]
            if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
                return
            let callOp = bodyIR.callSequence[callOrdinal]
            let beforeCallEmitIndex = emitIndex
            PrimaryFillBodyIrCallOp(words,
                                    emitIndex,
                                    bodyIR,
                                    callOp,
                                    frameBytes,
                                    paramSaveCount,
                                    paramSaveOffset)
            let expectedAfterCall = beforeCallEmitIndex + PrimaryBodyIrCallOpWordCount(bodyIR, callOp)
            if emitIndex != expectedAfterCall:
                return
        if block.termIndex < 0 || block.termIndex >= bodyIR.terms.len:
            return
        let term = bodyIR.terms[block.termIndex]
        if term.kind == coreir.BodyTermReturnTag:
            let beforeReturnEmitIndex = emitIndex
            PrimaryFillCallCfgReturnInt32Term(words,
                                              emitIndex,
                                              bodyIR,
                                              term,
                                              frameBytes)
            if emitIndex != beforeReturnEmitIndex + epilogueWordCount + 2:
                return
        elif term.kind == coreir.BodyTermBrTag:
            let targetLocalOffset = PrimaryBodyIrCallCfgBlockLocalWordOffset(bodyIR,
                                                                             term.trueBlock,
                                                                             prologueWordCount,
                                                                             paramSaveCount,
                                                                             epilogueWordCount)
            if targetLocalOffset < 0:
                return
            let branchDelta = wordOffset + targetLocalOffset - emitIndex
            let branchWord = PrimaryArm64BWord(branchDelta)
            if branchWord == 0:
                return
            PrimarySetInstructionWord(words, emitIndex, branchWord)
            emitIndex = emitIndex + 1
        elif term.kind == coreir.BodyTermCbrTag:
            var guardSlotIndex = term.lhsSlot
            if guardSlotIndex < 0:
                guardSlotIndex = term.resultSlot
            if guardSlotIndex < 0 || guardSlotIndex >= bodyIR.localSlots.len:
                return
            let guardSlot = bodyIR.localSlots[guardSlotIndex]
            if guardSlot.typeKind != coreir.LocalI32Tag:
                return
            let guardLoadBaseWord = PrimaryArm64RegisterWord(-1186987104, 9)
            if guardLoadBaseWord == 0:
                return
            let guardLoadWord = PrimaryArm64OffsetWord(guardLoadBaseWord,
                                                       guardSlot.stackOffset,
                                                       4,
                                                       4095)
            if guardLoadWord == 0:
                return
            PrimarySetInstructionWord(words, emitIndex, guardLoadWord)
            emitIndex = emitIndex + 1
            let cmpWord = PrimaryArm64CmpWRegZeroWord(9)
            if cmpWord == 0:
                return
            PrimarySetInstructionWord(words, emitIndex, cmpWord)
            emitIndex = emitIndex + 1
            let nextBlock = blockIndex + 1
            var branchTargetBlock: int32 = -1
            var conditionCode: int32 = -1
            if term.trueBlock == nextBlock:
                branchTargetBlock = term.falseBlock
                if term.conditionKind == coreir.BodyCondLocalNonZeroTag:
                    conditionCode = 0
                elif term.conditionKind == coreir.BodyCondLocalZeroTag:
                    conditionCode = 1
            elif term.falseBlock == nextBlock:
                branchTargetBlock = term.trueBlock
                if term.conditionKind == coreir.BodyCondLocalNonZeroTag:
                    conditionCode = 1
                elif term.conditionKind == coreir.BodyCondLocalZeroTag:
                    conditionCode = 0
            if branchTargetBlock < 0 || conditionCode < 0:
                return
            let targetLocalOffset = PrimaryBodyIrCallCfgBlockLocalWordOffset(bodyIR,
                                                                             branchTargetBlock,
                                                                             prologueWordCount,
                                                                             paramSaveCount,
                                                                             epilogueWordCount)
            if targetLocalOffset < 0:
                return
            let branchDelta = wordOffset + targetLocalOffset - emitIndex
            let branchWord = PrimaryArm64BCondWord(branchDelta, conditionCode)
            if branchWord == 0:
                return
            PrimarySetInstructionWord(words, emitIndex, branchWord)
            emitIndex = emitIndex + 1
        else:
            return

fn PrimaryFillCallSequenceReturnBodyIr(words: var int32[],
                                        wordOffset: int32,
                                        bodyIR: coreir.BodyIR) =
    if bodyIR.ops.len <= 0:
        return
    let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
    if returnOp.operands.len <= 0:
        return
    let returnTypeKind = returnOp.operands[0]
    let returnTarget = returnOp.target
    var returnsI32Const = false
    if returnOp.operands.len >= 2:
        if returnTypeKind == PrimaryStatementReturnModeI32Const():
            returnsI32Const = true
    let returnsComposite = returnTypeKind == coreir.LocalStrTag ||
                            returnTypeKind == coreir.LocalAggregateTag
    var frameBytes = PrimaryBodyIrStackByteCount(bodyIR)
    if frameBytes < 16:
        frameBytes = 16
    let paramSaveCount = PrimaryBodyIrParamSaveCount(bodyIR)
    if paramSaveCount < 0:
        return
    var paramSaveOffset = frameBytes
    if paramSaveCount > 0:
        frameBytes = PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
    var sretSaveOffset = frameBytes
    if returnsComposite:
        frameBytes = PrimaryAlignStackBytes(frameBytes + 8, 16)
    if !PrimaryBodyIrIncomingParamOffsetsSupported(bodyIR, frameBytes):
        return
    let prologueWordCount = PrimaryArm64FramePrologueWordCount(frameBytes)
    let epilogueWordCount = PrimaryArm64FrameEpilogueWordCount(frameBytes)
    if prologueWordCount <= 0 || epilogueWordCount <= 0:
        return
    var emitIndex = wordOffset
    if frameBytes <= 512:
        let frameStpWord = PrimaryArm64FrameStpWord(frameBytes)
        if frameStpWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  frameStpWord)
        emitIndex = emitIndex + 1
    else:
        let frameSubWord = PrimaryArm64SpSubWord(frameBytes)
        if frameSubWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  frameSubWord)
        emitIndex = emitIndex + 1
        PrimarySetInstructionWord(words, emitIndex, -1459586051)
        emitIndex = emitIndex + 1
    PrimarySetInstructionWord(words, emitIndex, -1862269955)
    emitIndex = emitIndex + 1
    for paramIndex in 0..<paramSaveCount:
        let saveOffset = paramSaveOffset + paramIndex * 8
        let saveBaseWord = PrimaryArm64RegisterWord(-117439584,
                                                    paramIndex)
        if saveBaseWord == 0:
            return
        let saveWord = PrimaryArm64OffsetWord(saveBaseWord,
                                              saveOffset,
                                              8,
                                              4095)
        if saveWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  saveWord)
        emitIndex = emitIndex + 1
    if returnsComposite:
        let sretSaveWord = PrimaryArm64OffsetWord(-117439576,
                                                  sretSaveOffset,
                                                  8,
                                                  4095)
        if sretSaveWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  sretSaveWord)
        emitIndex = emitIndex + 1
    for callOrdinal in 0..<bodyIR.callSequence.len:
        let callOp = bodyIR.callSequence[callOrdinal]
        let registerArgCount = PrimaryCallOpRegisterArgCount(callOp)
        for argIndex in 0..<registerArgCount:
            let slotIndex = callOp.argSlots[argIndex]
            if PrimaryCallArgSlotIsConst(slotIndex):
                let constMovWord = PrimaryCallArgConstMovWord(slotIndex, argIndex)
                if constMovWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          constMovWord)
                emitIndex = emitIndex + 1
            elif slotIndex >= 0 && slotIndex < bodyIR.localSlots.len:
                let slot = bodyIR.localSlots[slotIndex]
                if slot.typeKind == coreir.LocalI32Tag:
                    let loadBaseWord = PrimaryArm64RegisterWord(-1186987104,
                                                                argIndex)
                    if loadBaseWord == 0:
                        return
                    let loadWord = PrimaryArm64OffsetWord(loadBaseWord,
                                                          slot.stackOffset,
                                                          4,
                                                          4095)
                    if loadWord == 0:
                        return
                    PrimarySetInstructionWord(words,
                                              emitIndex,
                                              loadWord)
                elif slot.typeKind == coreir.LocalPtrTag:
                    let loadBaseWord = PrimaryArm64RegisterWord(-113245280,
                                                                argIndex)
                    if loadBaseWord == 0:
                        return
                    let loadWord = PrimaryArm64OffsetWord(loadBaseWord,
                                                          slot.stackOffset,
                                                          8,
                                                          4095)
                    if loadWord == 0:
                        return
                    PrimarySetInstructionWord(words,
                                              emitIndex,
                                              loadWord)
                else:
                    let addrBaseWord = PrimaryArm64RegisterWord(-1862270048,
                                                                argIndex)
                    if addrBaseWord == 0:
                        return
                    let addrWord = PrimaryArm64OffsetWord(addrBaseWord,
                                                          slot.stackOffset,
                                                          1,
                                                          4095)
                    if addrWord == 0:
                        return
                    PrimarySetInstructionWord(words,
                                              emitIndex,
                                              addrWord)
                emitIndex = emitIndex + 1
            elif slotIndex < 0:
                let paramSlot = 0 - slotIndex - 1
                if paramSlot < 0:
                    return
                var paramOffset = PrimaryIncomingParamStackOffset(frameBytes,
                                                                  paramSlot)
                if paramSlot < 8:
                    if paramSlot >= paramSaveCount:
                        return
                    paramOffset = paramSaveOffset + paramSlot * 8
                if paramOffset < 0:
                    return
                let loadParamBaseWord = PrimaryArm64RegisterWord(-113245280,
                                                                 argIndex)
                if loadParamBaseWord == 0:
                    return
                let loadParamWord = PrimaryArm64OffsetWord(loadParamBaseWord,
                                                           paramOffset,
                                                           8,
                                                           4095)
                if loadParamWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          loadParamWord)
                emitIndex = emitIndex + 1
        var callWritesSret = false
        if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind == coreir.LocalStrTag ||
               resultSlot.typeKind == coreir.LocalAggregateTag:
                callWritesSret = true
                let resultSretWord = PrimaryArm64OffsetWord(-1862270040,
                                                            resultSlot.stackOffset,
                                                            1,
                                                            4095)
                if resultSretWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          resultSretWord)
        elif returnsComposite && returnTarget < 0 && callOrdinal == bodyIR.callSequence.len - 1:
            callWritesSret = true
            let savedSretWord = PrimaryArm64OffsetWord(-113245272,
                                                       sretSaveOffset,
                                                       8,
                                                       4095)
            if savedSretWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      savedSretWord)
        if callWritesSret:
            emitIndex = emitIndex + 1
        let stackArgCount = PrimaryCallOpStackArgCount(callOp)
        let stackArgBytes = PrimaryCallOpStackArgBytes(callOp)
        if stackArgCount > 0:
            let subSpWord = PrimaryArm64SpSubWord(stackArgBytes)
            if subSpWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      subSpWord)
            emitIndex = emitIndex + 1
            for stackArgIndex in 0..<stackArgCount:
                let argIndex = stackArgIndex + 8
                if argIndex >= callOp.argSlots.len:
                    return
                let slotIndex = callOp.argSlots[argIndex]
                if PrimaryCallArgSlotIsConst(slotIndex):
                    let constMovWord = PrimaryCallArgConstMovWord(slotIndex, 16)
                    if constMovWord == 0:
                        return
                    PrimarySetInstructionWord(words,
                                              emitIndex,
                                              constMovWord)
                    emitIndex = emitIndex + 1
                elif slotIndex >= 0 && slotIndex < bodyIR.localSlots.len:
                    let slot = bodyIR.localSlots[slotIndex]
                    if slot.typeKind == coreir.LocalI32Tag:
                        let loadStackArgWord = PrimaryArm64OffsetWord(-1186987088,
                                                                      slot.stackOffset,
                                                                      4,
                                                                      4095)
                        if loadStackArgWord == 0:
                            return
                        PrimarySetInstructionWord(words,
                                                  emitIndex,
                                                  loadStackArgWord)
                    elif slot.typeKind == coreir.LocalPtrTag:
                        let loadStackArgWord = PrimaryArm64OffsetWord(-113245264,
                                                                      slot.stackOffset,
                                                                      8,
                                                                      4095)
                        if loadStackArgWord == 0:
                            return
                        PrimarySetInstructionWord(words,
                                                  emitIndex,
                                                  loadStackArgWord)
                    else:
                        let addrStackArgWord = PrimaryArm64OffsetWord(-1862270032,
                                                                      slot.stackOffset,
                                                                      1,
                                                                      4095)
                        if addrStackArgWord == 0:
                            return
                        PrimarySetInstructionWord(words,
                                                  emitIndex,
                                                  addrStackArgWord)
                    emitIndex = emitIndex + 1
                elif slotIndex < 0:
                    let paramSlot = 0 - slotIndex - 1
                    if paramSlot < 0:
                        return
                    var paramOffset = PrimaryIncomingParamStackOffset(frameBytes,
                                                                      paramSlot)
                    if paramSlot < 8:
                        if paramSlot >= paramSaveCount:
                            return
                        paramOffset = paramSaveOffset + paramSlot * 8
                    if paramOffset < 0:
                        return
                    let loadStackParamWord = PrimaryArm64OffsetWord(-113245264,
                                                                    paramOffset,
                                                                    8,
                                                                    4095)
                    if loadStackParamWord == 0:
                        return
                    PrimarySetInstructionWord(words,
                                              emitIndex,
                                              loadStackParamWord)
                    emitIndex = emitIndex + 1
                else:
                    return
                let stackStoreWord = PrimaryArm64OffsetWord(-117439504,
                                                            stackArgIndex * 8,
                                                            8,
                                                            4095)
                if stackStoreWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          stackStoreWord)
                emitIndex = emitIndex + 1
        PrimarySetInstructionWord(words, emitIndex, -1811939328)
        emitIndex = emitIndex + 1
        if stackArgCount > 0:
            let addSpWord = PrimaryArm64SpAddWord(stackArgBytes)
            if addSpWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      addSpWord)
            emitIndex = emitIndex + 1
        if callOp.resultSlot >= 0 && callOp.resultSlot < bodyIR.localSlots.len:
            let resultSlot = bodyIR.localSlots[callOp.resultSlot]
            if resultSlot.typeKind == coreir.LocalI32Tag:
                let storeWord = PrimaryArm64OffsetWord(-1191181408,
                                                       resultSlot.stackOffset,
                                                       4,
                                                       4095)
                if storeWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          storeWord)
                emitIndex = emitIndex + 1
            elif resultSlot.typeKind == coreir.LocalPtrTag:
                let storeWord = PrimaryArm64OffsetWord(-117439584,
                                                       resultSlot.stackOffset,
                                                       8,
                                                       4095)
                if storeWord == 0:
                    return
                PrimarySetInstructionWord(words,
                                          emitIndex,
                                          storeWord)
                emitIndex = emitIndex + 1
    if returnTypeKind == coreir.LocalI32Tag:
        if returnsI32Const:
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      PrimaryMovI32ConstWord(returnOp.operands[1]))
            emitIndex = emitIndex + 1
        elif returnTarget >= 0 && returnTarget < bodyIR.localSlots.len:
            let returnSlot = bodyIR.localSlots[returnTarget]
            let returnLoadWord = PrimaryArm64OffsetWord(-1186987104,
                                                        returnSlot.stackOffset,
                                                        4,
                                                        4095)
            if returnLoadWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      returnLoadWord)
            emitIndex = emitIndex + 1
    elif returnTypeKind == coreir.LocalPtrTag:
        if returnTarget >= 0 && returnTarget < bodyIR.localSlots.len:
            let returnSlot = bodyIR.localSlots[returnTarget]
            let returnLoadWord = PrimaryArm64OffsetWord(-113245280,
                                                        returnSlot.stackOffset,
                                                        8,
                                                        4095)
            if returnLoadWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      returnLoadWord)
            emitIndex = emitIndex + 1
    elif returnsComposite &&
         returnTarget >= 0 &&
         returnTarget < bodyIR.localSlots.len:
        let returnSlot = bodyIR.localSlots[returnTarget]
        let loadSavedSretWord = PrimaryArm64OffsetWord(-113245263,
                                                       sretSaveOffset,
                                                       8,
                                                       4095)
        if loadSavedSretWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  loadSavedSretWord)
        emitIndex = emitIndex + 1
        let copyChunks = returnSlot.sizeBytes / 8
        for copyIndex in 0..<copyChunks:
            let sourceOffset = returnSlot.stackOffset + copyIndex * 8
            let targetOffset = copyIndex * 8
            let copyLoadWord = PrimaryArm64OffsetWord(-113245264,
                                                      sourceOffset,
                                                      8,
                                                      4095)
            if copyLoadWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      copyLoadWord)
            emitIndex = emitIndex + 1
            let copyStoreWord = PrimaryArm64OffsetWord(-117439952,
                                                       targetOffset,
                                                       8,
                                                       4095)
            if copyStoreWord == 0:
                return
            PrimarySetInstructionWord(words,
                                      emitIndex,
                                      copyStoreWord)
            emitIndex = emitIndex + 1
    if frameBytes <= 512:
        let frameLdpWord = PrimaryArm64FrameLdpWord(frameBytes)
        if frameLdpWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  frameLdpWord)
        emitIndex = emitIndex + 1
    else:
        PrimarySetInstructionWord(words, emitIndex, -1455391747)
        emitIndex = emitIndex + 1
        let frameAddWord = PrimaryArm64SpAddWord(frameBytes)
        if frameAddWord == 0:
            return
        PrimarySetInstructionWord(words,
                                  emitIndex,
                                  frameAddWord)
        emitIndex = emitIndex + 1
    PrimarySetInstructionWord(words, emitIndex, -698416192)

fn PrimaryFillCallSequenceGuardReturnBodyIr(words: var int32[],
                                             wordOffset: int32,
                                             bodyIR: coreir.BodyIR) =
    if !PrimaryBodyIrIsCallSequenceGuardReturnInt32(bodyIR):
        return
    let plainBodyIR = PrimaryBodyIrWithoutGuardBranch(bodyIR)
    let plainWordCount = PrimaryBodyIrCallSequenceReturnInt32WordCount(plainBodyIR)
    let branchExtraWordCount = PrimaryBodyIrGuardBranchExtraWordCount(bodyIR)
    if plainWordCount <= 0 || branchExtraWordCount <= 0:
        return
    let branchCallOrdinal = PrimaryBodyIrGuardBranchCallOrdinal(bodyIR)
    let insertWordIndex = PrimaryBodyIrCallSequenceReturnInt32InsertWordIndex(plainBodyIR,
                                                                              branchCallOrdinal)
    if insertWordIndex < 0:
        return
    var tempWords: int32[]
    for _ in 0..<plainWordCount:
        add(tempWords, 0)
    PrimaryFillCallSequenceReturnBodyIr(tempWords, 0, plainBodyIR)
    for i in 0..<insertWordIndex:
        if i >= tempWords.len:
            return
        PrimarySetInstructionWord(words,
                                  wordOffset + i,
                                  tempWords[i])
    let branchIndex = PrimaryBodyIrGuardBranchIndex(bodyIR)
    if branchIndex < 0 || branchIndex >= bodyIR.ops.len:
        return
    let branchOp = bodyIR.ops[branchIndex]
    if branchOp.operands.len < 3:
        return
    let guardSlotIndex = branchOp.operands[1]
    if guardSlotIndex < 0 || guardSlotIndex >= bodyIR.localSlots.len:
        return
    let guardSlot = bodyIR.localSlots[guardSlotIndex]
    if guardSlot.typeKind != coreir.LocalI32Tag:
        return
    let frameBytes = PrimaryBodyIrFrameByteCountWithParams(bodyIR)
    if frameBytes <= 0:
        return
    var emitIndex = wordOffset + insertWordIndex
    let guardLoadBaseWord = PrimaryArm64RegisterWord(-1186987104, 9)
    if guardLoadBaseWord == 0:
        return
    let guardLoadWord = PrimaryArm64OffsetWord(guardLoadBaseWord,
                                               guardSlot.stackOffset,
                                               4,
                                               4095)
    if guardLoadWord == 0:
        return
    PrimarySetInstructionWord(words, emitIndex, guardLoadWord)
    emitIndex = emitIndex + 1
    let cmpWord = PrimaryArm64CmpWRegZeroWord(9)
    if cmpWord == 0:
        return
    PrimarySetInstructionWord(words, emitIndex, cmpWord)
    emitIndex = emitIndex + 1
    let branchWord = PrimaryArm64BCondGtWord(branchExtraWordCount - 2)
    if branchWord == 0:
        return
    PrimarySetInstructionWord(words, emitIndex, branchWord)
    emitIndex = emitIndex + 1
    PrimarySetInstructionWord(words,
                              emitIndex,
                              PrimaryMovI32ConstWord(branchOp.operands[2]))
    emitIndex = emitIndex + 1
    PrimaryFillArm64FrameEpilogue(words, emitIndex, frameBytes)
    PrimarySetInstructionWord(words, emitIndex, -698416192)
    emitIndex = emitIndex + 1
    if emitIndex != wordOffset + insertWordIndex + branchExtraWordCount:
        return
    for i in insertWordIndex..<plainWordCount:
        if i >= tempWords.len:
            return
        PrimarySetInstructionWord(words,
                                  wordOffset + i + branchExtraWordCount,
                                  tempWords[i])

fn PrimaryFillBackendDriverCommandDispatch(words: var int32[],
                                             wordOffset: int32) =
