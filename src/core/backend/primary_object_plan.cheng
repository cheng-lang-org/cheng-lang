    if wordOffset < 0 || wordOffset + 34 >= words.len:
        return false
    words[wordOffset] = Value(a64.A64EncSubImm(true, a64.A64SP, a64.A64SP, 32))
    words[wordOffset + 1] = -117437464
    words[wordOffset + 2] = -117436418
    words[wordOffset + 3] = -1879048176
    words[wordOffset + 4] = -1862270448
    words[wordOffset + 5] = -1186987511
    words[wordOffset + 6] = 1895825439
    words[wordOffset + 7] = 1409286827
    words[wordOffset + 8] = 1795751967
    words[wordOffset + 9] = 1409286762
    words[wordOffset + 10] = -1879048176
    words[wordOffset + 11] = -1862270448
    words[wordOffset + 12] = -113245686
    words[wordOffset + 13] = -1275067926
    words[wordOffset + 14] = -1824490485
    words[wordOffset + 15] = -127174336
    words[wordOffset + 16] = -1275068032
    words[wordOffset + 17] = -117438496
    words[wordOffset + 18] = a64.A64EncBlPlaceholder()
    words[wordOffset + 19] = -113244183
    words[wordOffset + 20] = -113243160
    words[wordOffset + 21] = -117440247
    words[wordOffset + 22] = -1191180032
    words[wordOffset + 23] = -1191178977
    words[wordOffset + 24] = -1191177953
    words[wordOffset + 25] = -113242114
    words[wordOffset + 26] = Value(a64.A64EncAddImm(true, a64.A64SP, a64.A64SP, 32))
    words[wordOffset + 27] = a64.A64EncRet()
