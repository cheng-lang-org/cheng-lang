import std/strutils as strutils
import std/rawmem_support
import cheng/core/tooling/bootstrap_contracts as contracts

type
    V3BackendTarget = enum
        v3BackendArm64AppleDarwin
        v3BackendX8664AppleDarwin
        v3BackendAarch64UnknownLinuxGnu
        v3BackendX8664UnknownLinuxGnu
        v3BackendAarch64PcWindowsMsvc
        v3BackendX8664PcWindowsMsvc
        v3BackendWasm32UnknownUnknown

    V3BackendLinker = enum
        v3BackendLinkerBootstrapMaterialize
        v3BackendLinkerSystemLink

    V3BackendSourceRole = enum
        v3BackendBootstrapContractSource
        v3BackendCompilerEntrySource
        v3BackendBackendDriverEntrySource
        v3BackendCompilerRuntimeSource
        v3BackendCompilerSupportMatrixSource
        v3BackendCompilerRequestSource
        v3BackendLangParserSource
        v3BackendSystemLinkPlanSource
        v3BackendLoweringPlanSource
        v3BackendPrimaryObjectPlanSource
        v3BackendObjectPlanSource
        v3BackendNativeLinkPlanSource
        v3BackendSystemLinkExecSource
        v3BackendRuntimeCoreSource
        v3BackendRuntimeCompilerSource
        v3BackendRuntimeDebugSource
        v3BackendToolingSource

    V3BackendSourceUnit =
        role: V3BackendSourceRole
        path: str

    V3BackendBuildPlan =
        target: V3BackendTarget
        targetTriple: str
        linker: V3BackendLinker
        entryPath: str
        outputPath: str
        stage2CompilerPath: str
        sourceUnits: V3BackendSourceUnit[]

fn v3BackendRootPath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    let rootLen: int32 = len(rootDir)
    let relLen: int32 = len(rel)
    if rootDir[rootDir.len - 1] == '/':
        let out: str = newStringAlloc(rootLen + relLen)
        let outPtr: ptr = strDataPtr(out)
        rawmem_support.RawmemCopy(outPtr, strDataPtr(rootDir), rootLen)
        rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(outPtr, rootLen), strDataPtr(rel), relLen)
        return out
    let out: str = newStringAlloc(rootLen + 1 + relLen)
    let outPtr: ptr = strDataPtr(out)
    rawmem_support.RawmemCopy(outPtr, strDataPtr(rootDir), rootLen)
    rawmem_support.RawmemSet(rawmem_support.RawmemPtrAdd(outPtr, rootLen), int32('/'), 1)
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(outPtr, rootLen + 1), strDataPtr(rel), relLen)
    return out

fn v3BackendBuildPlanJoinLines(rows: str[]): str =
    return strutils.Join(rows, "\n")

fn v3BackendBuildPlanDefaultEntryPath(rootDir: str): str =
    return v3BackendRootPath(rootDir, "src/core/tooling/compiler_main.cheng")

fn v3BackendBuildPlanBackendDriverEntryPath(rootDir: str): str =
    return v3BackendRootPath(rootDir, "src/core/tooling/backend_driver_main.cheng")

fn v3BackendBuildPlanDefaultSourceUnitCount(): int32 =
    return 21

fn v3BackendBuildPlanDefaultLinkMode(): str =
    return v3BackendLinkerText(v3BackendLinkerSystemLink)

fn v3BackendTargetFromTriple(targetTriple: str): V3BackendTarget =
    if targetTriple == "wasm32-unknown-unknown":
        return v3BackendWasm32UnknownUnknown
    if targetTriple == "x86_64-apple-darwin":
        return v3BackendX8664AppleDarwin
    if targetTriple == "aarch64-unknown-linux-gnu":
        return v3BackendAarch64UnknownLinuxGnu
    if targetTriple == "x86_64-unknown-linux-gnu":
        return v3BackendX8664UnknownLinuxGnu
    if targetTriple == "aarch64-pc-windows-msvc":
        return v3BackendAarch64PcWindowsMsvc
    if targetTriple == "x86_64-pc-windows-msvc":
        return v3BackendX8664PcWindowsMsvc
    return v3BackendArm64AppleDarwin

fn v3BackendBuildPlanDefaultForTarget(rootDir: str, targetTriple: str): V3BackendBuildPlan =
    var units: V3BackendSourceUnit[]
    units = []
    add(units, V3BackendSourceUnit(role: v3BackendBootstrapContractSource, path: contracts.V3BootstrapStage1SourcePath(rootDir)))
    add(units, V3BackendSourceUnit(role: v3BackendCompilerEntrySource, path: v3BackendRootPath(rootDir, "src/core/tooling/compiler_main.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendCompilerRuntimeSource, path: v3BackendRootPath(rootDir, "src/core/tooling/compiler_runtime.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendCompilerSupportMatrixSource, path: v3BackendRootPath(rootDir, "src/core/tooling/support_matrix.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendCompilerRequestSource, path: v3BackendRootPath(rootDir, "src/core/tooling/compiler_request.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "src/core/tooling/compiler_world.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "src/core/tooling/compiler_csg.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "src/core/tooling/compiler_world_libp2p.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "src/core/tooling/compiler_equivalence.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "src/core/tooling/compiler_publish_gate.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendLangParserSource, path: v3BackendRootPath(rootDir, "src/core/lang/parser.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendSystemLinkPlanSource, path: v3BackendRootPath(rootDir, "src/core/backend/system_link_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendLoweringPlanSource, path: v3BackendRootPath(rootDir, "src/core/backend/lowering_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendPrimaryObjectPlanSource, path: v3BackendRootPath(rootDir, "src/core/backend/primary_object_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendObjectPlanSource, path: v3BackendRootPath(rootDir, "src/core/backend/object_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendNativeLinkPlanSource, path: v3BackendRootPath(rootDir, "src/core/backend/native_link_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendSystemLinkExecSource, path: v3BackendRootPath(rootDir, "src/core/backend/system_link_exec.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendRuntimeCoreSource, path: v3BackendRootPath(rootDir, "src/core/runtime/core_runtime.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendRuntimeCompilerSource, path: v3BackendRootPath(rootDir, "src/core/runtime/compiler_runtime.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendRuntimeDebugSource, path: v3BackendRootPath(rootDir, "src/core/runtime/debug_runtime.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "src/core/tooling/bootstrap_contracts.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "src/core/backend/build_plan.cheng")))
    return V3BackendBuildPlan(
        target: v3BackendTargetFromTriple(targetTriple),
        targetTriple: targetTriple,
        linker: v3BackendLinkerSystemLink,
        entryPath: v3BackendBuildPlanDefaultEntryPath(rootDir),
        outputPath: v3BackendRootPath(rootDir, "artifacts/backend_driver/cheng"),
        stage2CompilerPath: v3BackendRootPath(rootDir, "artifacts/bootstrap/cheng.stage2"),
        sourceUnits: units
    )

fn v3BackendBuildPlanDefault(rootDir: str): V3BackendBuildPlan =
    return v3BackendBuildPlanDefaultForTarget(rootDir, contracts.V3BootstrapDefaultTarget())

