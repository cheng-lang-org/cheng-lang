fn v3BackendBuildPlanBackendDriver(rootDir: str): V3BackendBuildPlan =
    return v3BackendBuildPlanBackendDriverForTarget(rootDir, contracts.V3BootstrapDefaultTarget())

fn v3BackendTargetText(target: V3BackendTarget): str =
    if target == v3BackendX8664AppleDarwin:
        return "x86_64-apple-darwin"
    if target == v3BackendAarch64UnknownLinuxGnu:
        return "aarch64-unknown-linux-gnu"
    if target == v3BackendX8664UnknownLinuxGnu:
        return "x86_64-unknown-linux-gnu"
    if target == v3BackendAarch64PcWindowsMsvc:
        return "aarch64-pc-windows-msvc"
    if target == v3BackendX8664PcWindowsMsvc:
        return "x86_64-pc-windows-msvc"
    if target == v3BackendWasm32UnknownUnknown:
        return "wasm32-unknown-unknown"
    return "arm64-apple-darwin"

fn v3BackendSourceRoleText(role: V3BackendSourceRole): str =
    if role == v3BackendBootstrapContractSource:
        return "bootstrap_contract_source"
    if role == v3BackendCompilerEntrySource:
        return "compiler_entry_source"
    if role == v3BackendBackendDriverEntrySource:
        return "backend_driver_entry_source"
    if role == v3BackendCompilerRuntimeSource:
        return "compiler_runtime_source"
    if role == v3BackendCompilerSupportMatrixSource:
        return "compiler_support_matrix_source"
    if role == v3BackendCompilerRequestSource:
        return "compiler_request_source"
    if role == v3BackendLangParserSource:
        return "lang_parser_source"
    if role == v3BackendSystemLinkPlanSource:
        return "backend_system_link_plan_source"
    if role == v3BackendLoweringPlanSource:
        return "backend_lowering_plan_source"
    if role == v3BackendPrimaryObjectPlanSource:
        return "backend_primary_object_plan_source"
    if role == v3BackendObjectPlanSource:
        return "backend_object_plan_source"
    if role == v3BackendNativeLinkPlanSource:
        return "backend_native_link_plan_source"
    if role == v3BackendSystemLinkExecSource:
        return "backend_system_link_exec_source"
    if role == v3BackendRuntimeCoreSource:
        return "runtime_core_runtime_source"
    if role == v3BackendRuntimeCompilerSource:
        return "runtime_compiler_runtime_source"
    if role == v3BackendRuntimeDebugSource:
        return "runtime_debug_runtime_source"
    return "tooling_source"

fn v3BackendLinkerText(linker: V3BackendLinker): str =
    if linker == v3BackendLinkerBootstrapMaterialize:
        return "bootstrap_materialize"
    return "system_link"

fn v3BackendBuildPlanReport(plan: V3BackendBuildPlan): str =
    var rows: str[]
    add(rows, "target=" + plan.targetTriple)
    add(rows, "linker=" + v3BackendLinkerText(plan.linker))
    add(rows, "stage2_compiler=" + plan.stage2CompilerPath)
    add(rows, "entry=" + plan.entryPath)
    add(rows, "output=" + plan.outputPath)
    for i in 0..<plan.sourceUnits.len:
        let unit: V3BackendSourceUnit = plan.sourceUnits[i]
        var line = "source["
        line = line + intToStr(i)
        line = line + "]="
        line = line + v3BackendSourceRoleText(unit.role)
        line = line + ":"
        line = line + unit.path
        add(rows, line)
    return v3BackendBuildPlanJoinLines(rows)

fn V3BackendBuildPlanDefault(rootDir: str): V3BackendBuildPlan =
    return v3BackendBuildPlanDefault(rootDir)

fn V3BackendBuildPlanBackendDriver(rootDir: str): V3BackendBuildPlan =
    return v3BackendBuildPlanBackendDriver(rootDir)

fn V3BackendBuildPlanBackendDriverForTarget(rootDir: str, targetTriple: str): V3BackendBuildPlan =
    return v3BackendBuildPlanBackendDriverForTarget(rootDir, targetTriple)

fn V3BackendBuildPlanReport(plan: V3BackendBuildPlan): str =
    return v3BackendBuildPlanReport(plan)
