import std/strutils as strutils
import std/rawmem_support
import cheng/core/tooling/bootstrap_contracts as contracts

type
    BackendTarget = enum
        BackendArm64AppleDarwin
        BackendX8664AppleDarwin
        BackendAarch64UnknownLinuxGnu
        BackendX8664UnknownLinuxGnu
        BackendAarch64PcWindowsMsvc
        BackendX8664PcWindowsMsvc
        BackendWasm32UnknownUnknown

    BackendLinker = enum
        BackendLinkerBootstrapMaterialize
        BackendLinkerSystemLink

    BackendSourceRole = enum
        BackendBootstrapContractSource
        BackendCompilerEntrySource
        BackendBackendDriverEntrySource
        BackendCompilerRuntimeSource
        BackendCompilerSupportMatrixSource
        BackendCompilerRequestSource
        BackendLangParserSource
        BackendLangTypedExprSource
        BackendSystemLinkPlanSource
        BackendLoweringPlanSource
        BackendPrimaryObjectPlanSource
        BackendPrimaryObjectEmitSource
        BackendDirectObjectEmitSource
        BackendObjectBufferSource
        BackendObjectSymbolsSource
        BackendObjectRelocsSource
        BackendMachOObjectWriterSource
        BackendObjectPlanSource
        BackendNativeLinkPlanSource
        BackendNativeLinkExecSource
        BackendSystemLinkExecSource
        BackendSystemLinkExecRuntimeSource
        BackendLineMapSource
        BackendRuntimeCoreSource
        BackendRuntimeCompilerSource
        BackendRuntimeDebugSource
        BackendToolingSource

    BackendSourceUnit =
        role: BackendSourceRole
        path: str

    BackendBuildPlan =
        target: BackendTarget
        targetTriple: str
        linker: BackendLinker
        entryPath: str
        outputPath: str
        stage2CompilerPath: str
        sourceUnits: BackendSourceUnit[]

fn BackendRootPath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    let rootLen: int32 = len(rootDir)
    let relLen: int32 = len(rel)
    if rootDir[rootDir.len - 1] == '/':
        let out: str = newStringAlloc(rootLen + relLen)
        let outPtr: ptr = strDataPtr(out)
        rawmem_support.RawmemCopy(outPtr, strDataPtr(rootDir), rootLen)
        rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(outPtr, rootLen), strDataPtr(rel), relLen)
        return out
    let out: str = newStringAlloc(rootLen + 1 + relLen)
    let outPtr: ptr = strDataPtr(out)
    rawmem_support.RawmemCopy(outPtr, strDataPtr(rootDir), rootLen)
    rawmem_support.RawmemSet(rawmem_support.RawmemPtrAdd(outPtr, rootLen), int32('/'), 1)
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(outPtr, rootLen + 1), strDataPtr(rel), relLen)
    return out

fn BackendBuildPlanJoinLines(rows: str[]): str =
    return strutils.Join(rows, "\n")

fn BackendBuildPlanDefaultEntryPath(rootDir: str): str =
    return BackendRootPath(rootDir, "src/core/tooling/compiler_main.cheng")

fn BackendBuildPlanBackendDriverEntryPath(rootDir: str): str =
    return BackendRootPath(rootDir, "src/core/tooling/backend_driver_dispatch_min.cheng")

fn BackendBuildPlanDefaultSourceUnitCount(): int32 =
    return 36

fn BackendBuildPlanDefaultLinkMode(): str =
    return BackendLinkerText(BackendLinkerSystemLink)

fn BackendTargetFromTriple(targetTriple: str): BackendTarget =
    if targetTriple == "wasm32-unknown-unknown":
        return BackendWasm32UnknownUnknown
    if targetTriple == "x86_64-apple-darwin":
        return BackendX8664AppleDarwin
    if targetTriple == "aarch64-unknown-linux-gnu":
        return BackendAarch64UnknownLinuxGnu
    if targetTriple == "x86_64-unknown-linux-gnu":
        return BackendX8664UnknownLinuxGnu
    if targetTriple == "aarch64-pc-windows-msvc":
        return BackendAarch64PcWindowsMsvc
    if targetTriple == "x86_64-pc-windows-msvc":
        return BackendX8664PcWindowsMsvc
    return BackendArm64AppleDarwin

fn BackendBuildPlanSharedCompilerSourceUnits(rootDir: str): BackendSourceUnit[] =
    var units: BackendSourceUnit[]
    units = []
    add(units, BackendSourceUnit(role: BackendBootstrapContractSource, path: contracts.BootstrapStage1SourcePath(rootDir)))
    add(units, BackendSourceUnit(role: BackendCompilerRuntimeSource, path: BackendRootPath(rootDir, "src/core/tooling/compiler_runtime.cheng")))
    add(units, BackendSourceUnit(role: BackendCompilerRequestSource, path: BackendRootPath(rootDir, "src/core/tooling/compiler_request.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/compiler_world.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/compiler_csg.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/compiler_world_libp2p.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/compiler_equivalence.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/compiler_publish_gate.cheng")))
    add(units, BackendSourceUnit(role: BackendLangParserSource, path: BackendRootPath(rootDir, "src/core/lang/parser.cheng")))
    add(units, BackendSourceUnit(role: BackendLangTypedExprSource, path: BackendRootPath(rootDir, "src/core/lang/typed_expr.cheng")))
    add(units, BackendSourceUnit(role: BackendSystemLinkPlanSource, path: BackendRootPath(rootDir, "src/core/backend/system_link_plan.cheng")))
    add(units, BackendSourceUnit(role: BackendLoweringPlanSource, path: BackendRootPath(rootDir, "src/core/backend/lowering_plan.cheng")))
    add(units, BackendSourceUnit(role: BackendPrimaryObjectPlanSource, path: BackendRootPath(rootDir, "src/core/backend/primary_object_plan.cheng")))
    add(units, BackendSourceUnit(role: BackendPrimaryObjectEmitSource, path: BackendRootPath(rootDir, "src/core/backend/primary_object_emit.cheng")))
    add(units, BackendSourceUnit(role: BackendDirectObjectEmitSource, path: BackendRootPath(rootDir, "src/core/backend/direct_object_emit.cheng")))
    add(units, BackendSourceUnit(role: BackendObjectBufferSource, path: BackendRootPath(rootDir, "src/core/backend/object_buffer.cheng")))
    add(units, BackendSourceUnit(role: BackendObjectSymbolsSource, path: BackendRootPath(rootDir, "src/core/backend/object_symbols.cheng")))
    add(units, BackendSourceUnit(role: BackendObjectRelocsSource, path: BackendRootPath(rootDir, "src/core/backend/object_relocs.cheng")))
    add(units, BackendSourceUnit(role: BackendMachOObjectWriterSource, path: BackendRootPath(rootDir, "src/core/backend/macho_object_writer.cheng")))
    add(units, BackendSourceUnit(role: BackendObjectPlanSource, path: BackendRootPath(rootDir, "src/core/backend/object_plan.cheng")))
    add(units, BackendSourceUnit(role: BackendNativeLinkPlanSource, path: BackendRootPath(rootDir, "src/core/backend/native_link_plan.cheng")))
    add(units, BackendSourceUnit(role: BackendNativeLinkExecSource, path: BackendRootPath(rootDir, "src/core/backend/native_link_exec.cheng")))
    add(units, BackendSourceUnit(role: BackendSystemLinkExecSource, path: BackendRootPath(rootDir, "src/core/backend/system_link_exec.cheng")))
    add(units, BackendSourceUnit(role: BackendSystemLinkExecRuntimeSource, path: BackendRootPath(rootDir, "src/core/backend/system_link_exec_runtime.cheng")))
    add(units, BackendSourceUnit(role: BackendSystemLinkExecRuntimeSource, path: BackendRootPath(rootDir, "src/core/backend/system_link_exec_runtime_direct.cheng")))
    add(units, BackendSourceUnit(role: BackendLineMapSource, path: BackendRootPath(rootDir, "src/core/backend/line_map.cheng")))
    add(units, BackendSourceUnit(role: BackendRuntimeCoreSource, path: BackendRootPath(rootDir, "src/core/runtime/core_runtime.cheng")))
    add(units, BackendSourceUnit(role: BackendRuntimeCompilerSource, path: BackendRootPath(rootDir, "src/core/runtime/compiler_runtime.cheng")))
    add(units, BackendSourceUnit(role: BackendRuntimeDebugSource, path: BackendRootPath(rootDir, "src/core/runtime/debug_runtime.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/backend_driver_dispatch_min.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/bootstrap_contracts.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/debug_tools_gate.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/export_visibility_gate.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/tooling/object_debug_report.cheng")))
    add(units, BackendSourceUnit(role: BackendToolingSource, path: BackendRootPath(rootDir, "src/core/backend/build_plan.cheng")))
    return units

fn BackendBuildPlanDefaultForTarget(rootDir: str, targetTriple: str): BackendBuildPlan =
    var units = BackendBuildPlanSharedCompilerSourceUnits(rootDir)
    # Prepend the compiler entry point
    var finalUnits: BackendSourceUnit[]
    finalUnits = []
    add(finalUnits, BackendSourceUnit(role: BackendCompilerEntrySource, path: BackendRootPath(rootDir, "src/core/tooling/compiler_main.cheng")))
    for i in 0..<units.len:
        add(finalUnits, units[i])
    return BackendBuildPlan(
        target: BackendTargetFromTriple(targetTriple),
        targetTriple: targetTriple,
        linker: BackendLinkerSystemLink,
        entryPath: BackendBuildPlanDefaultEntryPath(rootDir),
        outputPath: BackendRootPath(rootDir, "artifacts/backend_driver/cheng"),
        stage2CompilerPath: BackendRootPath(rootDir, "artifacts/bootstrap/cheng.stage2"),
        sourceUnits: finalUnits
    )

fn BackendBuildPlanDefault(rootDir: str): BackendBuildPlan =
    return BackendBuildPlanDefaultForTarget(rootDir, contracts.BootstrapDefaultTarget())

fn BackendBuildPlanBackendDriverForTarget(rootDir: str, targetTriple: str): BackendBuildPlan =
    var units = BackendBuildPlanSharedCompilerSourceUnits(rootDir)
    var finalUnits: BackendSourceUnit[]
    finalUnits = []
    add(finalUnits, BackendSourceUnit(role: BackendBackendDriverEntrySource, path: BackendBuildPlanBackendDriverEntryPath(rootDir)))
    for i in 0..<units.len:
        add(finalUnits, units[i])
    return BackendBuildPlan(
        target: BackendTargetFromTriple(targetTriple),
        targetTriple: targetTriple,
        linker: BackendLinkerSystemLink,
        entryPath: BackendBuildPlanBackendDriverEntryPath(rootDir),
        outputPath: BackendRootPath(rootDir, "artifacts/backend_driver/cheng"),
        stage2CompilerPath: BackendRootPath(rootDir, "artifacts/bootstrap/cheng.stage2"),
        sourceUnits: finalUnits
    )

fn BackendBuildPlanBackendDriver(rootDir: str): BackendBuildPlan =
    return BackendBuildPlanBackendDriverForTarget(rootDir, contracts.BootstrapDefaultTarget())

fn BackendTargetText(target: BackendTarget): str =
    if target == BackendX8664AppleDarwin:
        return "x86_64-apple-darwin"
    if target == BackendAarch64UnknownLinuxGnu:
        return "aarch64-unknown-linux-gnu"
    if target == BackendX8664UnknownLinuxGnu:
        return "x86_64-unknown-linux-gnu"
    if target == BackendAarch64PcWindowsMsvc:
        return "aarch64-pc-windows-msvc"
    if target == BackendX8664PcWindowsMsvc:
        return "x86_64-pc-windows-msvc"
    if target == BackendWasm32UnknownUnknown:
        return "wasm32-unknown-unknown"
    return "arm64-apple-darwin"

fn BackendSourceRoleText(role: BackendSourceRole): str =
    if role == BackendBootstrapContractSource:
        return "bootstrap_contract_source"
    if role == BackendCompilerEntrySource:
        return "compiler_entry_source"
    if role == BackendBackendDriverEntrySource:
        return "backend_driver_entry_source"
    if role == BackendCompilerRuntimeSource:
        return "compiler_runtime_source"
    if role == BackendCompilerSupportMatrixSource:
        return "compiler_support_matrix_source"
    if role == BackendCompilerRequestSource:
        return "compiler_request_source"
    if role == BackendLangParserSource:
        return "lang_parser_source"
    if role == BackendLangTypedExprSource:
        return "lang_typed_expr_source"
    if role == BackendSystemLinkPlanSource:
        return "backend_system_link_plan_source"
    if role == BackendLoweringPlanSource:
        return "backend_lowering_plan_source"
    if role == BackendPrimaryObjectPlanSource:
        return "backend_primary_object_plan_source"
    if role == BackendPrimaryObjectEmitSource:
        return "backend_primary_object_emit_source"
    if role == BackendDirectObjectEmitSource:
        return "backend_direct_object_emit_source"
    if role == BackendObjectBufferSource:
        return "backend_object_buffer_source"
    if role == BackendObjectSymbolsSource:
        return "backend_object_symbols_source"
    if role == BackendObjectRelocsSource:
        return "backend_object_relocs_source"
    if role == BackendMachOObjectWriterSource:
        return "backend_macho_object_writer_source"
    if role == BackendObjectPlanSource:
        return "backend_object_plan_source"
    if role == BackendNativeLinkPlanSource:
        return "backend_native_link_plan_source"
    if role == BackendNativeLinkExecSource:
        return "backend_native_link_exec_source"
    if role == BackendSystemLinkExecSource:
        return "backend_system_link_exec_source"
    if role == BackendSystemLinkExecRuntimeSource:
        return "backend_system_link_exec_runtime_source"
    if role == BackendLineMapSource:
        return "backend_line_map_source"
    if role == BackendRuntimeCoreSource:
        return "runtime_core_runtime_source"
    if role == BackendRuntimeCompilerSource:
        return "runtime_compiler_runtime_source"
    if role == BackendRuntimeDebugSource:
        return "runtime_debug_runtime_source"
    return "tooling_source"

fn BackendLinkerText(linker: BackendLinker): str =
    if linker == BackendLinkerBootstrapMaterialize:
        return "bootstrap_materialize"
    return "system_link"

fn BackendBuildPlanReport(plan: BackendBuildPlan): str =
    var rows: str[]
    add(rows, Fmt"target={plan.targetTriple}")
    add(rows, Fmt"linker={BackendLinkerText(plan.linker)}")
    add(rows, Fmt"stage2_compiler={plan.stage2CompilerPath}")
    add(rows, Fmt"entry={plan.entryPath}")
    add(rows, Fmt"output={plan.outputPath}")
    for i in 0..<plan.sourceUnits.len:
        let unit: BackendSourceUnit = plan.sourceUnits[i]
        let indexText = intToStr(i)
        let roleText = BackendSourceRoleText(unit.role)
        add(rows, Fmt"source[{indexText}]={roleText}:{unit.path}")
    return BackendBuildPlanJoinLines(rows)
