# Minimal ELF64 AArch64 linker (Linux/Android): links backend-emitted `.o` into an executable.
# Scope (v1):
# - Input objects: ELF ET_REL emitted by our backend (elf_object_writer.cheng).
# - Relocations supported: R_AARCH64_CALL26, R_AARCH64_ADR_PREL_PG_HI21, R_AARCH64_ADD_ABS_LO12_NC.
# - Undefined symbols: supported only for CALL26 (functions); resolved via GOT slots + DT_RELA (GLOB_DAT) + local stubs.
# - Output format: ET_DYN PIE + PT_INTERP + PT_DYNAMIC (no section headers).
import std/bytes
import std/hashmaps
import std/os
import std/result
import std/seqs
import std/strings
import std/strformat
import cheng/core/backend/aarch64_encode
import cheng/core/backend/linker_shared_core

type
    ElfObjReloc = ref
        off: uint64
        symIndex: uint32
        rtype: uint32
        addend: int64

    ElfObjSymbol = ref
        name: str
        bind: uint8
        stType: uint8
        shndx: uint16
        value: uint64
        size: uint64

    ElfObjFile = ref
        path: str
        buf: bytes.ByteBuffer
        # Section indices (Elf64_Shdr table index; 0 = none).
        textShndx: uint16
        rodataShndx: uint16
        dataShndx: uint16
        bssShndx: uint16
        # Section raw data + alignment.
        text: uint8[]
        rodata: uint8[]
        data: uint8[]
        bssSize: uint64
        textAlign: uint64
        rodataAlign: uint64
        dataAlign: uint64
        bssAlign: uint64
        # Relocations (only .rela.text for now).
        relocsText: ElfObjReloc[]
        symbols: ElfObjSymbol[]

    ElfLinkDef = ref
        name: str
        kind: int32 # 0=text,1=rodata,2=data,3=bss
        off: uint64 # offset within its combined section

    ElfLinkObjLayout = ref
        textOff: uint64
        rodataOff: uint64
        dataOff: uint64
        bssOff: uint64

const
    ELF_PAGE_SIZE: uint64 = uint64(0x1000)

    # ELF ident
    ELF_LK_ELFCLASS64: uint8 = 2
    ELF_LK_ELFDATA2LSB: uint8 = 1
    ELF_LK_EV_CURRENT: uint32 = 1

    # e_type
    ELF_LK_ET_REL: uint16 = 1
    ELF_LK_ET_DYN: uint16 = 3

    ELF_LK_EM_AARCH64: uint16 = 183

    # section types
    ELF_LK_SHT_NULL: uint32 = 0
    ELF_LK_SHT_SYMTAB: uint32 = 2
    ELF_LK_SHT_STRTAB: uint32 = 3
    ELF_LK_SHT_RELA: uint32 = 4
    ELF_LK_SHT_NOBITS: uint32 = 8

    ELF_LK_SHN_UNDEF: uint16 = 0

    # symbol bind/type
    ELF_LK_STB_LOCAL: uint8 = 0
    ELF_LK_STB_GLOBAL: uint8 = 1
    ELF_LK_STT_NOTYPE: uint8 = 0
    ELF_LK_STT_FUNC: uint8 = 2

    # Program header types
    ELF_LK_PT_NULL: uint32 = 0
    ELF_LK_PT_LOAD: uint32 = 1
    ELF_LK_PT_DYNAMIC: uint32 = 2
    ELF_LK_PT_INTERP: uint32 = 3
    ELF_LK_PT_PHDR: uint32 = 6
    ELF_LK_PT_GNU_STACK: uint32 = 0x6474e551

    # Program header flags
    ELF_LK_PF_X: uint32 = 1
    ELF_LK_PF_W: uint32 = 2
    ELF_LK_PF_R: uint32 = 4

    # Dynamic tags
    ELF_LK_DT_NULL: int64 = 0
    ELF_LK_DT_NEEDED: int64 = 1
    ELF_LK_DT_PLTGOT: int64 = 3
    ELF_LK_DT_HASH: int64 = 4
    ELF_LK_DT_STRTAB: int64 = 5
    ELF_LK_DT_SYMTAB: int64 = 6
    ELF_LK_DT_RELA: int64 = 7
    ELF_LK_DT_RELASZ: int64 = 8
    ELF_LK_DT_RELAENT: int64 = 9
    ELF_LK_DT_STRSZ: int64 = 10
    ELF_LK_DT_SYMENT: int64 = 11

    # Relocation types (AArch64)
    ELF_LK_R_AARCH64_ADR_PREL_PG_HI21: uint32 = 275
    ELF_LK_R_AARCH64_ADD_ABS_LO12_NC: uint32 = 277
    ELF_LK_R_AARCH64_CALL26: uint32 = 283

    # Dynamic relocation types (AArch64)
    ELF_LK_R_AARCH64_GLOB_DAT: uint32 = 1025

# -- uint8[] buffer helpers (mimic old obj_buf API) --

fn elfBufU8(out: var uint8[], value: uint8) =
    let idx = out.len
    setLen(out, idx + 1)
    out[idx] = value

fn elfBufU16(out: var uint8[], value: uint16) =
    let v = uint32(value)
    let idx = out.len
    setLen(out, idx + 2)
    out[idx] = uint8(v & 0xFF)
    out[idx + 1] = uint8((v >> 8) & 0xFF)

fn elfBufU32(out: var uint8[], value: uint32) =
    let idx = out.len
    setLen(out, idx + 4)
    for i in 0..<4:
        out[idx + i] = uint8((value >> uint32(i * 8)) & uint32(0xFF))

fn elfBufU64(out: var uint8[], value: uint64) =
    let idx = out.len
    setLen(out, idx + 8)
    for i in 0..<8:
        out[idx + i] = uint8((value >> uint64(i * 8)) & uint64(0xFF))

fn elfBufI64(out: var uint8[], value: int64) =
    elfBufU64(out, uint64(value))

fn elfBufStr0(out: var uint8[], s: str) =
    for i in 0..<len(s):
        let idx = out.len
        setLen(out, idx + 1)
        out[idx] = uint8(int32(s[i]) & 0xFF)
    let idx = out.len
    setLen(out, idx + 1)
    out[idx] = uint8(0)

fn elfBufAlign(out: var uint8[], align: uint64) =
    if align <= 1:
        return
    let mask = align - uint64(1)
    let aligned = (uint64(out.len) + mask) & ~mask
    let pad = aligned - uint64(out.len)
    if pad > 0:
        for _ in 0..<pad:
            elfBufU8(out, uint8(0))

fn elfBufBytes(out: var uint8[], data: uint8[]) =
    let n = data.len
    if n <= 0:
        return
    let start = out.len
    setLen(out, start + n)
    for i in 0..<n:
        out[start + i] = data[i]

fn elfBufU32At(buf: var uint8[], off: int32, value: uint32) =
    for i in 0..<4:
        buf[off + i] = uint8((value >> uint32(i * 8)) & uint32(0xFF))

fn elfBufU16At(buf: var uint8[], off: int32, value: uint16) =
    let v = uint32(value)
    buf[off] = uint8(v & 0xFF)
    buf[off + 1] = uint8((v >> 8) & 0xFF)

# -- end buffer helpers --

fn elfAlignUp(value: uint64, align: uint64): uint64 =
    return linkerCoreAlignUp(value, align)

fn elfBufU32AtRead(buf: bytes.ByteBuffer, off: int32): uint32 =
    return uint32(bytes.ReadU32LEAt(buf, off))

fn elfBufU16AtRead(buf: bytes.ByteBuffer, off: int32): uint16 =
    return uint16(bytes.ReadU16LEAt(buf, off) & 0xFFFF)

fn elfBufU8AtRead(buf: bytes.ByteBuffer, off: int32): uint8 =
    return uint8(bytes.BufByteAt(buf, off) & 0xFF)

fn elfBufU64AtRead(buf: bytes.ByteBuffer, off: int32): uint64 =
    let lo = uint64(elfBufU32AtRead(buf, off))
    let hi = uint64(elfBufU32AtRead(buf, off + 4))
    return lo | (hi << 32)

fn elfReadBytes(buf: bytes.ByteBuffer, off: uint64, size: uint64): uint8[] =
    var out: uint8[]
    if size == 0:
        return out
    if int64(off) < 0:
        return out
    if off + size > uint64(buf.len):
        return out
    for i in 0..<size:
        elfBufU8(out, uint8(bytes.BufByteAt(buf, int32(off + i))))
    return out

fn elfReadCStringAt(buf: bytes.ByteBuffer, strOff: uint64, strSize: uint64, off: uint32): str =
    if strSize == 0:
        return ""
    let base = strOff + uint64(off)
    if base < strOff || base >= strOff + strSize:
        return ""
    var n: uint64
    while base + n < strOff + strSize:
        if bytes.BufByteAt(buf, int32(base + n)) == 0:
            break
        n = n + 1
    if n == 0:
        return ""
    var pbuf: uint8[]
    pbuf.len = int(n + 1)
    for i in 0..<n:
        let b = bytes.BufByteAt(buf, int32(base + i))
        pbuf[int(i)] = uint8(b)
    return __cheng_str_from_bytes(pbuf, pbuf.len - 1)

fn elfStrContains(hay: str, needle: str): bool =
    return linkerCoreStrContains(hay, needle)

fn elfStrCmp(a: str, b: str): int32 =
    let aEmpty = len(a) == 0
    let bEmpty = len(b) == 0
    if aEmpty && bEmpty:
        return 0
    if aEmpty:
        return -1
    if bEmpty:
        return 1
    let na = len(a)
    let nb = len(b)
    let n = na < nb ? na : nb
    for i in 0..<n:
        let ca = int32(int64(a[i]) & int64(0xFF))
        let cb = int32(int64(b[i]) & int64(0xFF))
        if ca < cb:
            return -1
        if ca > cb:
            return 1
    if na < nb:
        return -1
    if na > nb:
        return 1
    return 0

fn elfTargetIsAndroid(target: str): bool =
    return linkerCoreTargetIsAndroid(target)

fn elfTargetIsLinux(target: str): bool =
    return linkerCoreTargetIsLinux(target)

fn elfReadStrPtr(items: var str[], idx: int32): str =
    return items[int(idx)]

fn elfWriteStrPtr(items: var str[], idx: int32, val: str) =
    items[int(idx)] = val

fn elfStrSeqAddPtr(items: var str[], value: str) =
    add(items, value)

fn elfSortStringsStable(items: var str[]) =
    for i in 1..<items.len:
        let key = elfReadStrPtr(items, i)
        var j = i - 1
        let __for_start_j = j
        for __for_rev_j in 0..(__for_start_j - 0):
            j = __for_start_j - __for_rev_j
            if !(elfStrCmp(elfReadStrPtr(items, j), key) > 0):
                break
            elfWriteStrPtr(items, j + 1, elfReadStrPtr(items, j))
        elfWriteStrPtr(items, j + 1, key)

fn elfAddImport(imports: var str[], importIndex: var hashmaps.HashMapStrInt, name: str) =
    if len(name) == 0:
        return
    let key = name + ""
    var exists = false
    let _existing = hashmaps.HashmapStrIntGetMut(importIndex, key, exists)
    if exists:
        return
    hashmaps.HashmapStrIntPut(importIndex, key, imports.len + 1)
    elfStrSeqAddPtr(imports, key)

fn elfResolveSymAddr(defs: ElfLinkDef[], defIndex: hashmaps.HashMapStrInt, objs: ElfObjFile[],
                     layouts: ElfLinkObjLayout[], objIndex: int32, sym: ElfObjSymbol,
                     textVaddr: uint64, rodataVaddr: uint64, dataVaddr: uint64, bssBase: uint64): Result[uint64] =
    if sym == nil:
        return Err[uint64]("elf_linker: nil symbol")
    if sym.shndx == ELF_LK_SHN_UNDEF:
        let diPlus1 = defIndex[sym.name]
        let di0 = diPlus1 - 1
        if diPlus1 > 0 && di0 >= 0 && di0 < defs.len:
            let d0 = defs[di0]
            if d0.kind == 0:
                return Ok[uint64](textVaddr + d0.off)
            if d0.kind == 1:
                return Ok[uint64](rodataVaddr + d0.off)
            if d0.kind == 2:
                return Ok[uint64](dataVaddr + d0.off)
            return Ok[uint64](bssBase + d0.off)
        return Err[uint64](Fmt"elf_linker: unresolved symbol: {sym.name}")

    let o = objs[objIndex]
    let lay = layouts[objIndex]
    if sym.shndx == o.textShndx:
        return Ok[uint64](textVaddr + lay.textOff + sym.value)
    if sym.shndx == o.rodataShndx:
        return Ok[uint64](rodataVaddr + lay.rodataOff + sym.value)
    if sym.shndx == o.dataShndx:
        return Ok[uint64](dataVaddr + lay.dataOff + sym.value)
    if sym.shndx == o.bssShndx:
        return Ok[uint64](bssBase + lay.bssOff + sym.value)
    return Err[uint64](Fmt"elf_linker: unsupported symbol section: {sym.name}")

fn elfIsSpaceChar(c: char): bool =
    return c == ' ' || c == '\t' || c == '\n' || c == '\r'

fn elfStrSlice(s: str, start: int32, end: int32): str =
    if len(s) == 0:
        return ""
    var a = start
    var b = end
    if a < 0:
        a = 0
    if b > len(s):
        b = len(s)
    if b <= a:
        return ""
    let n = b - a
    var out: uint8[]
    out.len = int(n + 1)
    for i in 0..<n:
        let ch = s[a + i]
        out[int(i)] = uint8(int8(int32(int64(ch) & int64(0xFF))))
    return __cheng_str_from_bytes(out, out.len - 1)

fn elfTrimSpaces(s: str): str =
    if len(s) == 0:
        return ""
    let n = len(s)
    var i = 0
    for __for_i in 0..<n:
        if !(elfIsSpaceChar(s[__for_i])):
            i = __for_i
            break
    var j = n - 1
    for __for_rev_j in 0..(j - i + 1):
        if !(elfIsSpaceChar(s[j])):
            break
        j = j - 1
    if j < i:
        return ""
    return elfStrSlice(s, i, j + 1)

fn elfReadRelObj(path: str): Result[ElfObjFile] =
    var out = new(ElfObjFile)
    out.path = path
    out.buf = bytes.ReadFileBytes(path)
    if out.buf.data == nil || out.buf.len <= 0:
        return Err[ElfObjFile](Fmt"elf_linker: failed to read obj: {path}")
    if out.buf.len < 64:
        return Err[ElfObjFile](Fmt"elf_linker: truncated header: {path}")
    # e_ident
    if bytes.BufByteAt(out.buf, 0) != 0x7F ||
       bytes.BufByteAt(out.buf, 1) != int32('E') ||
       bytes.BufByteAt(out.buf, 2) != int32('L') ||
       bytes.BufByteAt(out.buf, 3) != int32('F'):
        return Err[ElfObjFile](Fmt"elf_linker: invalid magic: {path}")
    if elfBufU8AtRead(out.buf, 4) != ELF_LK_ELFCLASS64 || elfBufU8AtRead(out.buf, 5) != ELF_LK_ELFDATA2LSB:
        return Err[ElfObjFile](Fmt"elf_linker: expected ELF64 LSB: {path}")

    let eType = elfBufU16AtRead(out.buf, 16)
    if eType != ELF_LK_ET_REL:
        return Err[ElfObjFile](Fmt"elf_linker: expected ET_REL input: {path}")
    let eMachine = elfBufU16AtRead(out.buf, 18)
    if eMachine != ELF_LK_EM_AARCH64:
        return Err[ElfObjFile](Fmt"elf_linker: expected EM_AARCH64 input: {path}")

    let eShoff = elfBufU64AtRead(out.buf, 40)
    let eShentsize = elfBufU16AtRead(out.buf, 58)
    let eShnum = elfBufU16AtRead(out.buf, 60)
    let eShstrndx = elfBufU16AtRead(out.buf, 62)

    if eShentsize == 0 || eShnum == 0 || eShoff == 0:
        return Err[ElfObjFile](Fmt"elf_linker: missing section headers: {path}")
    if eShoff + uint64(eShentsize) * uint64(eShnum) > uint64(out.buf.len):
        return Err[ElfObjFile](Fmt"elf_linker: section headers truncated: {path}")
    if eShstrndx >= eShnum:
        return Err[ElfObjFile](Fmt"elf_linker: invalid e_shstrndx: {path}")

    # Read shstrtab.
    let shstrOff = eShoff + uint64(eShentsize) * uint64(eShstrndx)
    let shstrType = elfBufU32AtRead(out.buf, int32(shstrOff + 4))
    if shstrType != ELF_LK_SHT_STRTAB:
        return Err[ElfObjFile](Fmt"elf_linker: invalid shstrtab type: {path}")
    let shstrDataOff = elfBufU64AtRead(out.buf, int32(shstrOff + 24))
    let shstrSize = elfBufU64AtRead(out.buf, int32(shstrOff + 32))
    if shstrDataOff + shstrSize > uint64(out.buf.len):
        return Err[ElfObjFile](Fmt"elf_linker: shstrtab truncated: {path}")

    var symtabShndx: uint16
    var strtabShndx: uint16
    var relaTextShndx: uint16

    # Scan sections.
    for si in 0..<eShnum:
        let shOff = eShoff + uint64(eShentsize) * uint64(si)
        let nameOff = elfBufU32AtRead(out.buf, int32(shOff + 0))
        let shType = elfBufU32AtRead(out.buf, int32(shOff + 4))
        let shFlags = elfBufU64AtRead(out.buf, int32(shOff + 8))
        let shDataOff = elfBufU64AtRead(out.buf, int32(shOff + 24))
        let shSize = elfBufU64AtRead(out.buf, int32(shOff + 32))
        let shLink = elfBufU32AtRead(out.buf, int32(shOff + 40))
        let shInfo = elfBufU32AtRead(out.buf, int32(shOff + 44))
        let shAlign = elfBufU64AtRead(out.buf, int32(shOff + 48))
        let shEnt = elfBufU64AtRead(out.buf, int32(shOff + 56))

        let nm = elfReadCStringAt(out.buf, shstrDataOff, shstrSize, nameOff)
        if nm == ".text":
            out.textShndx = si
            out.textAlign = shAlign == 0 ? uint64(1) : shAlign
            out.text = elfReadBytes(out.buf, shDataOff, shSize)
        elif nm == ".rodata":
            out.rodataShndx = si
            out.rodataAlign = shAlign == 0 ? uint64(1) : shAlign
            out.rodata = elfReadBytes(out.buf, shDataOff, shSize)
        elif nm == ".data":
            out.dataShndx = si
            out.dataAlign = shAlign == 0 ? uint64(1) : shAlign
            out.data = elfReadBytes(out.buf, shDataOff, shSize)
        elif nm == ".bss":
            out.bssShndx = si
            out.bssAlign = shAlign == 0 ? uint64(1) : shAlign
            out.bssSize = shSize
        elif nm == ".symtab" && shType == ELF_LK_SHT_SYMTAB:
            symtabShndx = si
        elif nm == ".strtab" && shType == ELF_LK_SHT_STRTAB:
            strtabShndx = si
        elif nm == ".rela.text" && shType == ELF_LK_SHT_RELA:
            relaTextShndx = si
        # ignore other sections for v1
        shFlags
        shLink
        shInfo
        shEnt

    if out.textAlign == 0:
        out.textAlign = 4
    if out.rodataAlign == 0:
        out.rodataAlign = 1
    if out.dataAlign == 0:
        out.dataAlign = 1
    if out.bssAlign == 0:
        out.bssAlign = 1

    if symtabShndx == 0 || strtabShndx == 0:
        return Err[ElfObjFile](Fmt"elf_linker: missing symtab/strtab: {path}")

    # Read strtab.
    let strShOff = eShoff + uint64(eShentsize) * uint64(strtabShndx)
    let strType = elfBufU32AtRead(out.buf, int32(strShOff + 4))
    if strType != ELF_LK_SHT_STRTAB:
        return Err[ElfObjFile](Fmt"elf_linker: invalid strtab type: {path}")
    let strOff = elfBufU64AtRead(out.buf, int32(strShOff + 24))
    let strSize = elfBufU64AtRead(out.buf, int32(strShOff + 32))
    if strOff + strSize > uint64(out.buf.len):
        return Err[ElfObjFile](Fmt"elf_linker: strtab truncated: {path}")

    # Read symtab.
    let symShOff = eShoff + uint64(eShentsize) * uint64(symtabShndx)
    let symType = elfBufU32AtRead(out.buf, int32(symShOff + 4))
    if symType != ELF_LK_SHT_SYMTAB:
        return Err[ElfObjFile](Fmt"elf_linker: invalid symtab type: {path}")
    let symOffInt = elfBufU64AtRead(out.buf, int32(symShOff + 24))
    let symSize = elfBufU64AtRead(out.buf, int32(symShOff + 32))
    let symEnt = elfBufU64AtRead(out.buf, int32(symShOff + 56))
    let symEntSize = symEnt == 0 ? uint64(24) : symEnt
    if symEntSize == 0 || symSize % symEntSize != 0:
        return Err[ElfObjFile](Fmt"elf_linker: invalid symtab entsize: {path}")
    if symOffInt + symSize > uint64(out.buf.len):
        return Err[ElfObjFile](Fmt"elf_linker: symtab truncated: {path}")

    for symi in 0..<symSize / symEntSize:
        let off0 = symOffInt + symi * symEntSize
        let stName = elfBufU32AtRead(out.buf, int32(off0 + 0))
        let stInfo = elfBufU8AtRead(out.buf, int32(off0 + 4))
        let stOther = elfBufU8AtRead(out.buf, int32(off0 + 5))
        let stShndx = elfBufU16AtRead(out.buf, int32(off0 + 6))
        let stValue = elfBufU64AtRead(out.buf, int32(off0 + 8))
        let stSize = elfBufU64AtRead(out.buf, int32(off0 + 16))
        stOther

        var s = new(ElfObjSymbol)
        s.name = elfReadCStringAt(out.buf, strOff, strSize, stName)
        s.bind = uint8((stInfo >> 4) & uint8(0xF))
        s.stType = uint8(stInfo & uint8(0xF))
        s.shndx = stShndx
        s.value = stValue
        s.size = stSize
        add(out.symbols, s)

    # Read .rela.text relocations.
    if relaTextShndx != 0:
        let relShOff = eShoff + uint64(eShentsize) * uint64(relaTextShndx)
        let relType = elfBufU32AtRead(out.buf, int32(relShOff + 4))
        if relType != ELF_LK_SHT_RELA:
            return Err[ElfObjFile](Fmt"elf_linker: invalid rela.text type: {path}")
        let relOff = elfBufU64AtRead(out.buf, int32(relShOff + 24))
        let relSize = elfBufU64AtRead(out.buf, int32(relShOff + 32))
        let relEnt = elfBufU64AtRead(out.buf, int32(relShOff + 56))
        let relEntSize = relEnt == 0 ? uint64(24) : relEnt
        if relEntSize == 0 || relSize % relEntSize != 0:
            return Err[ElfObjFile](Fmt"elf_linker: invalid rela.text entsize: {path}")
        if relOff + relSize > uint64(out.buf.len):
            return Err[ElfObjFile](Fmt"elf_linker: rela.text truncated: {path}")

        for ri in 0..<relSize / relEntSize:
            let roff = relOff + ri * relEntSize
            let rOffset = elfBufU64AtRead(out.buf, int32(roff + 0))
            let rInfo = elfBufU64AtRead(out.buf, int32(roff + 8))
            let rAddendU = elfBufU64AtRead(out.buf, int32(roff + 16))
            var r = new(ElfObjReloc)
            r.off = rOffset
            r.symIndex = uint32(rInfo >> 32)
            r.rtype = uint32(rInfo & uint64(0xFFFFFFFF))
            r.addend = int64(rAddendU)
            add(out.relocsText, r)
    return Ok[ElfObjFile](out)

fn elfReadU32LEAtSeq(buf: var uint8[], off: uint64): uint32 =
    if off + 4 > uint64(buf.len):
        return uint32(0)
    let b0 = uint32(buf[int32(off + 0)])
    let b1 = uint32(buf[int32(off + 1)])
    let b2 = uint32(buf[int32(off + 2)])
    let b3 = uint32(buf[int32(off + 3)])
    return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)

fn elfPatchBlImm(deltaBytes: int64): Result[uint32] =
    if deltaBytes % 4 != 0:
        return Err[uint32]("elf_linker: bl target misaligned")
    let deltaWords = deltaBytes / 4
    if deltaWords < -33554432 || deltaWords > 33554431:
        return Err[uint32]("elf_linker: bl target out of range")
    let imm26 = uint32(uint64(deltaWords) & uint64(0x03FFFFFF))
    return Ok[uint32](uint32(0x94000000) | imm26)

fn elfPatchAdrpAt(text: var uint8[], off: uint64, placeAddr: uint64, targetAddr: uint64): Result[bool] =
    if off + 4 > uint64(text.len):
        return Err[bool]("elf_linker: patch out of range")
    let insn = elfReadU32LEAtSeq(text, off)
    # Keep rd and opcode; patch immhi/immlo.
    let placePage = int64(placeAddr & ~uint64(0xFFF))
    let targetPage = int64(targetAddr & ~uint64(0xFFF))
    let deltaPages = (targetPage - placePage) / 4096
    if deltaPages < -1048576 || deltaPages > 1048575:
        return Err[bool]("elf_linker: adrp target out of range")
    let imm = uint64(deltaPages) & uint64(0x1FFFFF)
    let immlo = uint32(imm & uint64(3))
    let immhi = uint32((imm >> 2) & uint64(0x7FFFF))
    var patched = insn
    # Clear immlo (bits 30:29) and immhi (bits 23:5).
    patched = patched & ~uint32(3 << 29)
    patched = patched & ~uint32(0x7FFFF << 5)
    patched = patched | (immlo << 29)
    patched = patched | (immhi << 5)
    elfBufU32At(text, int32(off), patched)
    return Ok[bool](true)

fn elfPatchAddLo12At(text: var uint8[], off: uint64, targetAddr: uint64): Result[bool] =
    if off + 4 > uint64(text.len):
        return Err[bool]("elf_linker: patch out of range")
    let insn = elfReadU32LEAtSeq(text, off)
    let imm12 = uint32(targetAddr & uint64(0xFFF))
    var patched = insn
    patched = patched & ~uint32(0xFFF << 10)
    patched = patched | (imm12 << 10)
    elfBufU32At(text, int32(off), patched)
    return Ok[bool](true)

fn elfPatchLdrLo12At(text: var uint8[], off: uint64, targetAddr: uint64): Result[bool] =
    # Patch imm12 field of ldr (immediate) used in stubs.
    if off + 4 > uint64(text.len):
        return Err[bool]("elf_linker: patch out of range")
    let insn = elfReadU32LEAtSeq(text, off)
    let offBytes = targetAddr & uint64(0xFFF)
    if offBytes % 8 != 0:
        return Err[bool]("elf_linker: stub ldr target not 8-byte aligned")
    let imm12 = uint32(offBytes / 8)
    var patched = insn
    patched = patched & ~uint32(0xFFF << 10)
    patched = patched | (imm12 << 10)
    elfBufU32At(text, int32(off), patched)
    return Ok[bool](true)

fn elfPatchBlAt(text: var uint8[], off: uint64, placeAddr: uint64, targetAddr: uint64): Result[bool] =
    if off + 4 > uint64(text.len):
        return Err[bool]("elf_linker: patch out of range")
    let delta = int64(targetAddr) - int64(placeAddr)
    let encRes = elfPatchBlImm(delta)
    if !IsOk[uint32](encRes):
        return Err[bool](ErrorInfoOf[uint32](encRes))
    elfBufU32At(text, int32(off), Value[uint32](encRes))
    return Ok[bool](true)

fn elfEncBr(rn: int32): uint32 =
    return uint32(0xD61F0000) | (uint32(rn & 31) << 5)

fn elfHashSysV(name: str): uint32 =
    var h: uint32
    var g: uint32
    if len(name) == 0:
        return 0
    for i in 0..<len(name):
        h = (h << 4) + uint32(int32(name[i]) & 0xFF)
        g = h & uint32(0xF0000000)
        if g != 0:
            h = h ^ (g >> 24)
            h = h & ~g
    return h

fn elfDynStrAdd(strtab: var uint8[], s: str): uint32 =
    let off = uint32(strtab.len)
    elfBufStr0(strtab, s)
    return off

fn elfWritePhdr(out: var uint8[], pType: uint32, pFlags: uint32, pOffset: uint64, pVaddr: uint64,
                pFilesz: uint64, pMemsz: uint64, pAlign: uint64) =
    elfBufU32(out, pType)
    elfBufU32(out, pFlags)
    elfBufU64(out, pOffset)
    elfBufU64(out, pVaddr)
    elfBufU64(out, pVaddr)
    elfBufU64(out, pFilesz)
    elfBufU64(out, pMemsz)
    elfBufU64(out, pAlign)

fn elfLinkExeAarch64(objPaths: str[], outputPath: str, target: str): Result[bool] =
    if len(outputPath) == 0:
        return Err[bool]("elf_linker: missing output path")
    if objPaths.len == 0:
        return Err[bool]("elf_linker: no input objects")

    # Load and parse objects.
    var objs: ElfObjFile[]
    for li in 0..<objPaths.len:
        let p = objPaths[li]
        let res = elfReadRelObj(p)
        if !IsOk[ElfObjFile](res):
            return Err[bool](ErrorInfoOf[ElfObjFile](res))
        add(objs, Value[ElfObjFile](res))

    let elfProfile = os.GetEnv("BACKEND_ELF_PROFILE")
    let noLibc = (elfProfile == "nolibc") && elfTargetIsLinux(target)

    # Decide interpreter and DT_NEEDED defaults.
    let interpDefault = elfTargetIsAndroid(target) ? "/system/bin/linker64" : "/lib/ld-linux-aarch64.so.1"
    let neededDefault = elfTargetIsAndroid(target) ? "libc.so,libm.so" : "libc.so.6,libm.so.6"
    let interp = os.GetEnvDefault("BACKEND_ELF_INTERP", interpDefault)
    let neededCsv = os.GetEnvDefault("BACKEND_ELF_NEEDED", neededDefault)

    # Parse neededCsv into list.
    var needed: str[]
    if len(neededCsv) > 0:
        var start: int32
        for i in 0..len(neededCsv):
            if i == len(neededCsv) || neededCsv[i] == ',':
                if i > start:
                    let part = elfTrimSpaces(elfStrSlice(neededCsv, start, i))
                    if len(part) > 0:
                        add(needed, part)
                start = i + 1

    # Build combined sections.
    var layouts: ElfLinkObjLayout[]
    if objs.len > 0:
        layouts.cap = objs.len
        layouts.len = objs.len
    var text: uint8[]
    # _start stub: bl main; bl exit; b .
    elfBufU32(text, A64EncBlPlaceholder())
    elfBufU32(text, A64EncBlPlaceholder())
    elfBufU32(text, uint32(0x14000000))
    elfBufAlign(text, 4)

    var rodata: uint8[]
    var dataSeg: uint8[]
    var bssSize: uint64
    var maxBssAlign: uint64 = 1

    # Track defs for cross-object resolution.
    var defs: ElfLinkDef[]
    var defIndex: hashmaps.HashMapStrInt = hashmaps.HashmapStrIntInit(1024)

    for li in 0..<objs.len:
        let o = objs[li]
        var lay = new(ElfLinkObjLayout)

        elfBufAlign(text, o.textAlign)
        lay.textOff = uint64(text.len)
        elfBufBytes(text, o.text)

        elfBufAlign(rodata, o.rodataAlign)
        lay.rodataOff = uint64(rodata.len)
        elfBufBytes(rodata, o.rodata)

        elfBufAlign(dataSeg, o.dataAlign)
        lay.dataOff = uint64(dataSeg.len)
        elfBufBytes(dataSeg, o.data)

        if o.bssAlign > maxBssAlign:
            maxBssAlign = o.bssAlign
        bssSize = elfAlignUp(bssSize, o.bssAlign)
        lay.bssOff = bssSize
        bssSize = bssSize + o.bssSize

        layouts[li] = lay

        # Add global definitions.
        for si2 in 0..<o.symbols.len:
            let s = o.symbols[si2]
            if s == nil || len(s.name) == 0:
                continue
            if s.bind != ELF_LK_STB_GLOBAL:
                continue
            if s.shndx == ELF_LK_SHN_UNDEF:
                continue
            var kind: int32 = -1
            if s.shndx == o.textShndx:
                kind = 0
            elif s.shndx == o.rodataShndx:
                kind = 1
            elif s.shndx == o.dataShndx:
                kind = 2
            elif s.shndx == o.bssShndx:
                kind = 3
            if kind < 0:
                continue
            if defIndex[s.name] > 0:
                return Err[bool](Fmt"elf_linker: duplicate symbol: {s.name}")
            var d = new(ElfLinkDef)
            d.name = s.name
            d.kind = kind
            if kind == 0:
                d.off = lay.textOff + s.value
            elif kind == 1:
                d.off = lay.rodataOff + s.value
            elif kind == 2:
                d.off = lay.dataOff + s.value
            else:
                d.off = lay.bssOff + s.value
            add(defs, d)
            hashmaps.HashmapStrIntPut(defIndex, s.name, defs.len)


    # Collect imports from relocations.
    var imports: str[]
    var importIndex: hashmaps.HashMapStrInt = hashmaps.HashmapStrIntInit(1024)

    for li in 0..<objs.len:
        let o2 = objs[li]
        for ri2 in 0..<o2.relocsText.len:
            let r0 = o2.relocsText[ri2]
            if r0 == nil:
                continue
            if r0.symIndex >= uint32(o2.symbols.len):
                return Err[bool]("elf_linker: reloc symIndex out of range")
            let sym0 = o2.symbols[int32(r0.symIndex)]
            if sym0 == nil:
                continue
            if sym0.shndx == ELF_LK_SHN_UNDEF:
                let defIdxPlus1 = defIndex[sym0.name]
                if defIdxPlus1 <= 0:
                    if noLibc:
                        return Err[bool](Fmt"elf_linker: unresolved symbol in nolibc profile: {sym0.name}")
                    elif r0.rtype == ELF_LK_R_AARCH64_CALL26:
                        elfAddImport(imports, importIndex, sym0.name)
                    else:
                        return Err[bool](Fmt"elf_linker: unsupported undefined reloc type for {sym0.name}")

    # Ensure _start can call exit (dynamic profile only).
    if !noLibc:
        elfAddImport(imports, importIndex, "exit")
        # Keep ABI probes stable across fixtures by always materializing puts in dynsym.
        elfAddImport(imports, importIndex, "puts")

    var iimp: int32
    if !noLibc:
        elfSortStringsStable(imports)
        # Rebuild name.index map after sorting.
        importIndex = hashmaps.HashmapStrIntInit(1024)
        for iimp in 0..<imports.len:
            hashmaps.HashmapStrIntPut(importIndex, imports[iimp], iimp + 1)

    # Append import stubs to .text (one per import; dynamic profile only).
    var stubOffs: uint64[]
    stubOffs.len = int(imports.len)
    if !noLibc:
        for iimp in 0..<imports.len:
            elfBufAlign(text, 4)
            let off0 = uint64(text.len)
            stubOffs[iimp] = off0
            # adrp x16, imm; ldr x17, [x16, imm12]; br x17
            elfBufU32(text, A64EncAdrp(16))
            let ldrRes = A64EncLdrImm(true, 17, 16, 0)
            if !IsOk[int32](ldrRes):
                return Err[bool](ErrorInfoOf[int32](ldrRes))
            elfBufU32(text, uint32(Value[int32](ldrRes)))
            elfBufU32(text, elfEncBr(17))

    # File layout.
    let phnum: uint16 = noLibc ? uint16(4) : uint16(6)
    let ehdrSize: uint64 = 64
    let phdrSize: uint64 = 56
    let phdrTableSize: uint64 = uint64(phnum) * phdrSize
    var interpLen: uint64
    var interpOff: uint64
    var textFileOff: uint64
    if noLibc:
        textFileOff = elfAlignUp(ehdrSize + phdrTableSize, ELF_PAGE_SIZE)
    else:
        interpLen = uint64(len(interp) + 1)
        interpOff = elfAlignUp(ehdrSize + phdrTableSize, 8)
        textFileOff = elfAlignUp(interpOff + interpLen, ELF_PAGE_SIZE)
    let textVaddr = textFileOff
    let rodataFileOff = elfAlignUp(textFileOff + uint64(text.len), 16)
    let rodataVaddr = rodataFileOff
    let dataFileOff = elfAlignUp(rodataFileOff + uint64(rodata.len), ELF_PAGE_SIZE)
    let dataVaddr = dataFileOff

    var gotOff: uint64
    var dynamicOff: uint64
    var dynamicSize: uint64
    if !noLibc:
        # Data segment: append GOT + dyn tables after merged .data.
        elfBufAlign(dataSeg, 8)
        gotOff = uint64(dataSeg.len)
        for gi2 in 0..<imports.len * 8:
            elfBufU8(dataSeg, uint8(0))

        elfBufAlign(dataSeg, 8)
        let dynstrOff = uint64(dataSeg.len)
        var dynstr: uint8[]
        elfBufU8(dynstr, uint8(0)) # strtab[0] = ""
        # Needed libs.
        var neededOffs: uint32[]
        neededOffs.len = int(needed.len)
        for ni in 0..<needed.len:
            neededOffs[ni] = elfDynStrAdd(dynstr, needed[ni])
        # Symbol names.
        var symNameOffs: uint32[]
        symNameOffs.len = int(imports.len)
        for iimp in 0..<imports.len:
            symNameOffs[iimp] = elfDynStrAdd(dynstr, imports[iimp])

        elfBufBytes(dataSeg, dynstr)
        let dynstrSize = uint64(dynstr.len)

        elfBufAlign(dataSeg, 8)
        let dynsymOff = uint64(dataSeg.len)
        # dynsym[0] = null
        # Elf64_Sym: 24 bytes
        var dynsym: uint8[]
        for si3 in 0..<(imports.len + 1):
            if si3 == 0:
                # all zeros
                for z in 0..<24:
                    elfBufU8(dynsym, uint8(0))
            else:
                let nameOff2 = symNameOffs[si3 - 1]
                elfBufU32(dynsym, nameOff2)
                elfBufU8(dynsym, uint8((ELF_LK_STB_GLOBAL << 4) | ELF_LK_STT_FUNC))
                elfBufU8(dynsym, uint8(0))
                elfBufU16(dynsym, ELF_LK_SHN_UNDEF)
                elfBufU64(dynsym, uint64(0))
                elfBufU64(dynsym, uint64(0))
        elfBufBytes(dataSeg, dynsym)
        let dynsymCount = uint32(imports.len + 1)

        elfBufAlign(dataSeg, 8)
        let hashOff = uint64(dataSeg.len)
        # SysV hash table: nbucket, nchain, buckets[], chains[].
        let nbucket = dynsymCount
        let nchain = dynsymCount
        var hashTab: uint8[]
        elfBufU32(hashTab, nbucket)
        elfBufU32(hashTab, nchain)
        # buckets init
        for bi in 0..<nbucket:
            elfBufU32(hashTab, uint32(0))
        # chains init
        for ci in 0..<nchain:
            elfBufU32(hashTab, uint32(0))
        # Fill buckets/chains for symbols 1..nchain-1.
        for sidx in 1..<nchain:
            let nm2 = imports[int32(sidx - 1)]
            let h = elfHashSysV(nm2)
            let b = nbucket > 0 ? (h % nbucket) : uint32(0)
            let bucketsOff: uint64 = 8 + uint64(b) * 4
            let chainsOff: uint64 = 8 + uint64(nbucket) * 4
            let curHead = elfReadU32LEAtSeq(hashTab, bucketsOff)
            if curHead == 0:
                elfBufU32At(hashTab, int32(bucketsOff), sidx)
            else:
                var last = curHead
                while true:
                    let nextOff = chainsOff + uint64(last) * 4
                    let nxt = elfReadU32LEAtSeq(hashTab, nextOff)
                    if nxt == 0:
                        elfBufU32At(hashTab, int32(nextOff), sidx)
                        break
                    last = nxt

        elfBufBytes(dataSeg, hashTab)

        elfBufAlign(dataSeg, 8)
        let relaOff = uint64(dataSeg.len)
        var rela: uint8[]
        # One relocation per GOT slot: R_AARCH64_GLOB_DAT.
        iimp = 0
        let __for_start_iimp_1 = iimp
        for __for_iimp_1 in __for_start_iimp_1..<imports.len:
            iimp = __for_iimp_1
            let gotSlotAddr = dataVaddr + gotOff + uint64(iimp) * 8
            elfBufU64(rela, gotSlotAddr)
            let symIdx64 = uint64(iimp + 1)
            let info = (symIdx64 << 32) | uint64(ELF_LK_R_AARCH64_GLOB_DAT)
            elfBufU64(rela, info)
            elfBufI64(rela, int64(0))
            iimp = iimp + 1
        elfBufBytes(dataSeg, rela)
        let relaSize = uint64(rela.len)

        elfBufAlign(dataSeg, 8)
        dynamicOff = uint64(dataSeg.len)
        var dynamic: uint8[]
        # DT_NEEDED
        var ni = 0
        let __for_start_ni_2 = ni
        for __for_ni_2 in __for_start_ni_2..<needed.len:
            ni = __for_ni_2
            elfBufI64(dynamic, ELF_LK_DT_NEEDED)
            elfBufU64(dynamic, uint64(neededOffs[ni]))
            ni = ni + 1
        # DT_HASH / STRTAB / SYMTAB
        elfBufI64(dynamic, ELF_LK_DT_HASH)
        elfBufU64(dynamic, dataVaddr + hashOff)
        elfBufI64(dynamic, ELF_LK_DT_STRTAB)
        elfBufU64(dynamic, dataVaddr + dynstrOff)
        elfBufI64(dynamic, ELF_LK_DT_STRSZ)
        elfBufU64(dynamic, dynstrSize)
        elfBufI64(dynamic, ELF_LK_DT_SYMTAB)
        elfBufU64(dynamic, dataVaddr + dynsymOff)
        elfBufI64(dynamic, ELF_LK_DT_SYMENT)
        elfBufU64(dynamic, uint64(24))
        # relocations
        elfBufI64(dynamic, ELF_LK_DT_RELA)
        elfBufU64(dynamic, dataVaddr + relaOff)
        elfBufI64(dynamic, ELF_LK_DT_RELASZ)
        elfBufU64(dynamic, relaSize)
        elfBufI64(dynamic, ELF_LK_DT_RELAENT)
        elfBufU64(dynamic, uint64(24))
        # GOT (optional)
        elfBufI64(dynamic, ELF_LK_DT_PLTGOT)
        elfBufU64(dynamic, dataVaddr + gotOff)
        # end
        elfBufI64(dynamic, ELF_LK_DT_NULL)
        elfBufU64(dynamic, uint64(0))
        elfBufBytes(dataSeg, dynamic)
        dynamicSize = uint64(dynamic.len)

    let dataFileSize = uint64(dataSeg.len)
    let bssBase = elfAlignUp(dataVaddr + dataFileSize, maxBssAlign)
    let dataMemSize = (bssBase - dataVaddr) + bssSize

    # Patch stubs to reference GOT slots.
    if !noLibc:
        for iimp in 0..<imports.len:
            let stubOff = stubOffs[iimp]
            let stubAddr = textVaddr + stubOff
            let gotSlotAddr2 = dataVaddr + gotOff + uint64(iimp) * 8
            # adrp at stubOff, ldr at stubOff+4.
            let adrpRes = elfPatchAdrpAt(text, stubOff + 0, stubAddr + 0, gotSlotAddr2)
            if !IsOk[bool](adrpRes):
                return Err[bool](ErrorInfoOf[bool](adrpRes))
            let ldrRes2 = elfPatchLdrLo12At(text, stubOff + 4, gotSlotAddr2)
            if !IsOk[bool](ldrRes2):
                return Err[bool](ErrorInfoOf[bool](ldrRes2))

    # Helper: resolve symbol to vaddr (best-effort).
    # Patch relocations.
    for li in 0..<objs.len:
        let o4 = objs[li]
        let lay4 = layouts[li]
        for ri3 in 0..<o4.relocsText.len:
            let r1 = o4.relocsText[ri3]
            if r1 == nil:
                continue
            if r1.symIndex >= uint32(o4.symbols.len):
                return Err[bool]("elf_linker: reloc symIndex out of range")
            let sym1 = o4.symbols[int32(r1.symIndex)]
            let placeOff = lay4.textOff + r1.off
            let placeAddr = textVaddr + placeOff
            var targetAddr: uint64
            var unresolved = false
            if sym1 != nil && sym1.shndx == ELF_LK_SHN_UNDEF:
                let defIdxPlus1 = defIndex[sym1.name]
                if defIdxPlus1 <= 0:
                    unresolved = true
            if unresolved:
                if noLibc:
                    return Err[bool](Fmt"elf_linker: unresolved symbol in nolibc profile: {sym1.name}")
                if r1.rtype != ELF_LK_R_AARCH64_CALL26:
                    return Err[bool](Fmt"elf_linker: unsupported undefined reloc type for {sym1.name}")
                let idxImpPlus1 = importIndex[sym1.name]
                let idxImp = idxImpPlus1 - 1
                if idxImpPlus1 <= 0 || idxImp < 0 || idxImp >= imports.len:
                    return Err[bool](Fmt"elf_linker: missing import stub: {sym1.name}")
                targetAddr = textVaddr + stubOffs[idxImp]
                let blRes = elfPatchBlAt(text, placeOff, placeAddr, targetAddr)
                if !IsOk[bool](blRes):
                    return Err[bool](ErrorInfoOf[bool](blRes))
            else:
                let addrRes3 = elfResolveSymAddr(
                    defs, defIndex, objs, layouts, li, sym1, textVaddr, rodataVaddr, dataVaddr, bssBase)
                if !IsOk[uint64](addrRes3):
                    return Err[bool](ErrorInfoOf[uint64](addrRes3))
                targetAddr = Value[uint64](addrRes3) + uint64(r1.addend)
                if r1.rtype == ELF_LK_R_AARCH64_ADR_PREL_PG_HI21:
                    let adrpRes2 = elfPatchAdrpAt(text, placeOff, placeAddr, targetAddr)
                    if !IsOk[bool](adrpRes2):
                        return Err[bool](ErrorInfoOf[bool](adrpRes2))
                elif r1.rtype == ELF_LK_R_AARCH64_ADD_ABS_LO12_NC:
                    let addRes = elfPatchAddLo12At(text, placeOff, targetAddr)
                    if !IsOk[bool](addRes):
                        return Err[bool](ErrorInfoOf[bool](addRes))
                elif r1.rtype == ELF_LK_R_AARCH64_CALL26:
                    let blRes2 = elfPatchBlAt(text, placeOff, placeAddr, targetAddr)
                    if !IsOk[bool](blRes2):
                        return Err[bool](ErrorInfoOf[bool](blRes2))
                else:
                    return Err[bool](Fmt"elf_linker: unsupported reloc type: {intToStr(int32(r1.rtype))}")

    # Patch _start stub calls.
    let mainIdxPlus1 = defIndex["main"]
    let mainIdx = mainIdxPlus1 - 1
    if mainIdxPlus1 <= 0 || mainIdx < 0 || mainIdx >= defs.len:
        return Err[bool]("elf_linker: missing main symbol (required for _start)")
    let mainDef = defs[mainIdx]
    let mainAddr = textVaddr + mainDef.off

    var exitAddr: uint64
    if noLibc:
        let exitFnIdxPlus1 = defIndex["cheng_exit"]
        let exitFnIdx = exitFnIdxPlus1 - 1
        if exitFnIdxPlus1 <= 0 || exitFnIdx < 0 || exitFnIdx >= defs.len:
            return Err[bool]("elf_linker: nolibc profile requires `cheng_exit` symbol")
        let exitDef = defs[exitFnIdx]
        exitAddr = textVaddr + exitDef.off
    else:
        let exitImpIdxPlus1 = importIndex["exit"]
        let exitImpIdx = exitImpIdxPlus1 - 1
        if exitImpIdxPlus1 <= 0 || exitImpIdx < 0 || exitImpIdx >= stubOffs.len:
            return Err[bool]("elf_linker: missing exit import stub")
        exitAddr = textVaddr + stubOffs[exitImpIdx]

    let startAddr = textVaddr + uint64(0)
    let bl0 = elfPatchBlAt(text, uint64(0), startAddr + 0, mainAddr)
    if !IsOk[bool](bl0):
        return Err[bool](ErrorInfoOf[bool](bl0))
    let bl1 = elfPatchBlAt(text, uint64(4), startAddr + 4, exitAddr)
    if !IsOk[bool](bl1):
        return Err[bool](ErrorInfoOf[bool](bl1))

    # Final file size.
    let textEnd = rodataFileOff + uint64(rodata.len)
    let dataEnd = dataFileOff + dataFileSize
    let fileSize = dataEnd > textEnd ? dataEnd : textEnd

    # Build output bytes (zero-filled).
    var outBytes: uint8[]
    outBytes.len = int(fileSize)

    # Write ELF header + program headers.
    var hdr: uint8[]
    # e_ident[16]
    elfBufU8(hdr, uint8(0x7F))
    elfBufU8(hdr, uint8(int32('E')))
    elfBufU8(hdr, uint8(int32('L')))
    elfBufU8(hdr, uint8(int32('F')))
    elfBufU8(hdr, ELF_LK_ELFCLASS64)  # EI_CLASS
    elfBufU8(hdr, ELF_LK_ELFDATA2LSB) # EI_DATA
    elfBufU8(hdr, uint8(1))    # EI_VERSION
    elfBufU8(hdr, uint8(0))    # EI_OSABI
    elfBufU8(hdr, uint8(0))    # EI_ABIVERSION
    for pad in 0..<7:
        elfBufU8(hdr, uint8(0))

    elfBufU16(hdr, ELF_LK_ET_DYN)
    elfBufU16(hdr, ELF_LK_EM_AARCH64)
    elfBufU32(hdr, ELF_LK_EV_CURRENT)
    elfBufU64(hdr, startAddr)
    elfBufU64(hdr, ehdrSize) # e_phoff
    elfBufU64(hdr, uint64(0)) # e_shoff
    elfBufU32(hdr, uint32(0)) # e_flags
    elfBufU16(hdr, uint16(ehdrSize))
    elfBufU16(hdr, uint16(phdrSize))
    elfBufU16(hdr, phnum)
    elfBufU16(hdr, uint16(0))
    elfBufU16(hdr, uint16(0))
    elfBufU16(hdr, uint16(0))

    # Program headers follow.
    # PT_PHDR
    elfWritePhdr(hdr, ELF_LK_PT_PHDR, ELF_LK_PF_R, ehdrSize, ehdrSize, phdrTableSize, phdrTableSize, 8)
    # PT_INTERP
    if !noLibc:
        elfWritePhdr(hdr, ELF_LK_PT_INTERP, ELF_LK_PF_R, interpOff, interpOff, interpLen, interpLen, 1)
    # PT_LOAD (text+rodata + headers)
    elfWritePhdr(hdr, ELF_LK_PT_LOAD, ELF_LK_PF_R | ELF_LK_PF_X, 0, 0, textEnd, textEnd, ELF_PAGE_SIZE)
    # PT_LOAD (data)
    elfWritePhdr(hdr, ELF_LK_PT_LOAD, ELF_LK_PF_R | ELF_LK_PF_W, dataFileOff, dataVaddr, dataFileSize, dataMemSize, ELF_PAGE_SIZE)
    # PT_DYNAMIC
    if !noLibc:
        elfWritePhdr(hdr, ELF_LK_PT_DYNAMIC, ELF_LK_PF_R | ELF_LK_PF_W, dataFileOff + dynamicOff, dataVaddr + dynamicOff, dynamicSize, dynamicSize, 8)
    # PT_GNU_STACK
    elfWritePhdr(hdr, ELF_LK_PT_GNU_STACK, ELF_LK_PF_R | ELF_LK_PF_W, 0, 0, 0, 0, 16)

    # Copy header bytes into output.
    for hi in 0..<hdr.len:
        if !(hi < outBytes.len):
            break
        outBytes[hi] = hdr[hi]

    # Write interp string.
    if !noLibc:
        for ip in 0..<len(interp):
            let c = uint8(int32(int64(interp[ip]) & int64(0xFF)))
            outBytes[int32(interpOff) + ip] = c
        outBytes[int32(interpOff) + int32(interpLen - 1)] = uint8(0)

    # Write text, rodata, data segment.
    for ti in 0..<uint64(text.len):
        outBytes[int32(textFileOff + ti)] = text[int32(ti)]
    for ri4 in 0..<uint64(rodata.len):
        outBytes[int32(rodataFileOff + ri4)] = rodata[int32(ri4)]
    for di4 in 0..<uint64(dataSeg.len):
        outBytes[int32(dataFileOff + di4)] = dataSeg[int32(di4)]

    if !linkerCoreWriteFileAtomic(outputPath, outBytes):
        return Err[bool](Fmt"elf_linker: failed to write output atomically: {outputPath}")
    return Ok[bool](true)