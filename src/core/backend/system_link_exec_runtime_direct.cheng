@importc("cheng_monotime_ns")
fn SystemLinkExecRuntimeDirectMonoTimeNsBridge(): int64

type
    SystemLinkExecRuntimeDirectPlan =
        systemLinkPlan: slplan.SystemLinkPlanStub
        loweringPlan: lower.LoweringPlanStub
        primaryObjectPlan: pobj.PrimaryObjectPlan
        objectPlan: objplan.ObjectPlanStub
        nativeLinkPlan: nplan.NativeLinkPlanStub

    SystemLinkExecRuntimeDirectResult =
        providerCompilerPath: str
        primaryObjectPath: str
        providerObjectPaths: str[]
        providerCompileLogPaths: str[]
        nativeLinkLogPath: str
        lineMapPath: str
        primaryObjectNs: int64
        providerObjectsNs: int64
        nativeLinkNs: int64
        lineMapNs: int64
        standaloneDirectEntry: bool
        directObjectBytes: int32
        directObjectSymbolCount: int32
        directObjectRelocCount: int32

fn SystemLinkExecRuntimeDirectNowNs(): int64 =
    return SystemLinkExecRuntimeDirectMonoTimeNsBridge()

fn SystemLinkExecRuntimeDirectCurrentExecutablePath(rootDir: str): str =
    let raw = strutil.Strip(cmdline.ProgramName())
    if len(raw) <= 0:
        return ""
    let resolved = hostops.ResolveProgram(rootDir, raw)
    if len(resolved) > 0:
        return resolved
    return chengpath.PathAbsolute(rootDir, raw)

fn SystemLinkExecRuntimeDirectResolveProviderCompiler(rootDir: str,
                                                       requestedCompilerPath: str): Result[str] =
    let requested = strutil.Strip(requestedCompilerPath)
    if len(requested) > 0:
        let absolute = chengpath.PathAbsolute(rootDir, requested)
        if chengpath.FileExistsNonEmpty(rootDir, absolute):
            return Ok[str](absolute)
        return Err[str](Fmt" system link exec direct runtime: missing provider compiler: {absolute}")
    let current = SystemLinkExecRuntimeDirectCurrentExecutablePath(rootDir)
    if len(current) > 0 && chengpath.FileExistsNonEmpty(rootDir, current):
        return Ok[str](current)
    let stage3 = contracts.BootstrapStage3Path(rootDir)
    if chengpath.FileExistsNonEmpty(rootDir, stage3):
        return Ok[str](stage3)
    return Err[str](" system link exec direct runtime: missing provider compiler/current stage3")

fn SystemLinkExecRuntimeDirectReasonsError(label: str, reasons: str[]): str =
    return Fmt" system link exec direct runtime: {label}: missing_count={IntToStr(reasons.len)}"

fn SystemLinkExecRuntimeDirectValidateProviderPlan(plan: SystemLinkExecRuntimeDirectPlan): Result[bool] =
    if plan.objectPlan.providerSourcePaths.len != plan.objectPlan.providerObjectPaths.len:
        return Err[bool](" system link exec direct runtime: provider source/object count mismatch")
    if plan.objectPlan.providerModules.len != plan.objectPlan.providerSourcePaths.len:
        return Err[bool](" system link exec direct runtime: provider module/source count mismatch")
    return Ok[bool](true)

fn SystemLinkExecRuntimeDirectValidateExecutablePlan(rootDir: str,
                                                     plan: SystemLinkExecRuntimeDirectPlan): Result[bool] =
    if plan.systemLinkPlan.missingReasons.len > 0:
        return Err[bool](SystemLinkExecRuntimeDirectReasonsError("system link plan blocked",
                                                                 plan.systemLinkPlan.missingReasons))
    if plan.loweringPlan.missingReasons.len > 0:
        return Err[bool](SystemLinkExecRuntimeDirectReasonsError("lowering plan blocked",
                                                                 plan.loweringPlan.missingReasons))
    if plan.primaryObjectPlan.missingReasons.len > 0:
        return Err[bool](SystemLinkExecRuntimeDirectReasonsError("primary object plan blocked",
                                                                 plan.primaryObjectPlan.missingReasons))
    if plan.objectPlan.missingReasons.len > 0:
        return Err[bool](SystemLinkExecRuntimeDirectReasonsError("object plan blocked",
                                                                 plan.objectPlan.missingReasons))
    if plan.nativeLinkPlan.missingReasons.len > 0:
        return Err[bool](SystemLinkExecRuntimeDirectReasonsError("native link plan blocked",
                                                                 plan.nativeLinkPlan.missingReasons))
    let providerRes = SystemLinkExecRuntimeDirectValidateProviderPlan(plan)
    if IsErr(providerRes):
        return providerRes
    if len(plan.objectPlan.browserBridgeObjectPath) > 0 &&
       !chengpath.FileExistsNonEmpty(rootDir, plan.objectPlan.browserBridgeObjectPath):
        return Err[bool](Fmt" system link exec direct runtime: browser bridge object not materialized: {plan.objectPlan.browserBridgeObjectPath}")
    return Ok[bool](true)

fn SystemLinkExecRuntimeDirectAddUniqueText(out: var str[], value: str) =
    if len(value) <= 0:
        return
    for i in 0..<out.len:
        if out[i] == value:
            return
    add(out, value)

fn SystemLinkExecRuntimeDirectPlanHasProviderModule(plan: SystemLinkExecRuntimeDirectPlan,
                                                     modulePath: str): bool =
    for i in 0..<plan.objectPlan.providerModules.len:
        if plan.objectPlan.providerModules[i] == modulePath:
            return true
    return false

fn SystemLinkExecRuntimeDirectPlanRelocNeedsSymbol(plan: SystemLinkExecRuntimeDirectPlan,
                                                    rawSymbol: str): bool =
    let targetSymbol = pobj.PrimaryTargetSymbolName(plan.systemLinkPlan.targetTriple, rawSymbol)
    for i in 0..<plan.primaryObjectPlan.relocTargetSymbols.len:
        let symbol = plan.primaryObjectPlan.relocTargetSymbols[i]
        if symbol == rawSymbol || symbol == targetSymbol:
            return true
    return false

fn SystemLinkExecRuntimeDirectAddCoreRuntimeRootIfNeeded(plan: SystemLinkExecRuntimeDirectPlan,
                                                          out: var str[],
                                                          rawSymbol: str) =
    if SystemLinkExecRuntimeDirectPlanRelocNeedsSymbol(plan, rawSymbol):
        SystemLinkExecRuntimeDirectAddUniqueText(out, rawSymbol)

