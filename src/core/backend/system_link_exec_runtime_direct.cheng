fn SystemLinkExecRuntimeDirectProviderExportRoots(plan: SystemLinkExecRuntimeDirectPlan,
                                                   providerModule: str): str[] =
    var out: str[]
    if providerModule == "runtime/compiler_runtime":
        SystemLinkExecRuntimeDirectAddUniqueText(out, "main")
        return out
    if providerModule == "runtime/backend_driver_dispatch":
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_backend_driver_dispatch")
        return out
    if providerModule == "runtime/program_support":
        SystemLinkExecRuntimeDirectAddUniqueText(out, "__cheng_call_indirect_void")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "__cheng_call_indirect_i32")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "__cheng_setCmdLine")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_register_line_map_from_argv0")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_fopen")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_fclose")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_fread")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_fwrite")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_fseek")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_fflush")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_fgetc")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_file_size")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_dir_exists")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_list_dir")
        if SystemLinkExecRuntimeDirectPlanHasProviderModule(plan, "runtime/backend_driver_dispatch"):
            SystemLinkExecRuntimeDirectAddBackendDriverDispatchProgramSupportRoots(out)
        for i in 0..<plan.primaryObjectPlan.relocTargetSymbols.len:
            let symbol = plan.primaryObjectPlan.relocTargetSymbols[i]
            if symbol == pobj.PrimaryTargetSymbolName(plan.systemLinkPlan.targetTriple, "cheng_backend_driver_dispatch"):
                continue
            if symbol == pobj.PrimaryTargetSymbolName(plan.systemLinkPlan.targetTriple, "cheng_debug_profile_flush_from_argv0"):
                continue
            if symbol == pobj.PrimaryTargetSymbolName(plan.systemLinkPlan.targetTriple, "driver_c_get_env_bridge"):
                continue
            SystemLinkExecRuntimeDirectAddUniqueText(out, symbol)
        return out
    if providerModule == "runtime/program_support_get_env_bridge":
        SystemLinkExecRuntimeDirectAddUniqueText(out, "driver_c_get_env_bridge")
        return out
    if providerModule == "runtime/debug_runtime":
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_debug_profile_flush_from_argv0")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_native_register_line_map_from_argv0")
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_native_dump_backtrace_and_exit")
        return out
    if providerModule == "runtime/core_runtime":
        SystemLinkExecRuntimeDirectAddCoreRuntimeRoots(plan, out)
        return out
    if providerModule == "runtime/program_support_host_runtime":
        SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_program_support_host_trace")
        if SystemLinkExecRuntimeDirectPlanHasProviderModule(plan, "runtime/core_runtime"):
            SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_host_close")
            SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_host_open_runtime")
            SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_host_read_runtime")
            SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_host_statfs")
            SystemLinkExecRuntimeDirectAddUniqueText(out, "cheng_host_sysconf")
        if SystemLinkExecRuntimeDirectPlanHasProviderModule(plan, "runtime/backend_driver_dispatch"):
            SystemLinkExecRuntimeDirectAddBackendDriverHostRuntimeRoots(out)
        return out
    return out

fn SystemLinkExecRuntimeDirectProviderCompileArgs(plan: SystemLinkExecRuntimeDirectPlan,
                                                   providerModule: str,
                                                   sourcePath: str,
                                                   objectPath: str): str[] =
    var argv: str[]
    let reportPath = Fmt"{objectPath}.report.txt"
    add(argv, "system-link-exec")
    add(argv, Fmt"--root:{plan.systemLinkPlan.packageRoot}")
    add(argv, Fmt"--in:{sourcePath}")
    add(argv, "--emit:obj")
    add(argv, Fmt"--target:{plan.systemLinkPlan.targetTriple}")
    add(argv, Fmt"--out:{objectPath}")
    add(argv, Fmt"--report-out:{reportPath}")
    let exportRoots = SystemLinkExecRuntimeDirectProviderExportRoots(plan, providerModule)
    if exportRoots.len > 0:
        add(argv, "--symbol-visibility:internal")
        let rootText = strutil.Join(exportRoots, ",")
        add(argv, Fmt"--export-roots:{rootText}")
    return argv

fn SystemLinkExecRuntimeDirectRecordObject(rootDir: str,
                                            startNs: int64,
                                            object: direct.DirectObjectEmitResult,
                                            result: var SystemLinkExecRuntimeDirectResult): Result[bool] =
    result.primaryObjectNs = SystemLinkExecRuntimeDirectNowNs() - startNs
    result.primaryObjectPath =.objectPath
    result.directObjectBytes =.bytesWritten
    result.directObjectSymbolCount =.symbolCount
    result.directObjectRelocCount =.relocCount
    if !chengpath.FileExistsNonEmpty(rootDir, object.objectPath):
        return Err[bool](Fmt" system link exec direct runtime: primary object missing after direct emit: {object.objectPath}")
    return Ok[bool](true)

fn SystemLinkExecRuntimeDirectMaterializePrimaryObject(rootDir: str,
                                                        plan: pobj.PrimaryObjectPlan,
                                                        result: var SystemLinkExecRuntimeDirectResult): Result[bool] =
    let startNs = SystemLinkExecRuntimeDirectNowNs()
    if !direct.DirectObjectEmitCanPlanObject(plan):
        return Err[bool](" system link exec direct runtime: primary object plan is not direct-object ready")
    let directRes: Result[direct.DirectObjectEmitResult] = direct.DirectObjectEmitPlanObject(rootDir, plan)
    if IsErr(directRes):
        result.primaryObjectNs = SystemLinkExecRuntimeDirectNowNs() - startNs
        return Err[bool](Error(directRes))
    return SystemLinkExecRuntimeDirectRecordObject(rootDir,
                                                   startNs,
                                                   Value(directRes),
                                                   result)

fn SystemLinkExecRuntimeDirectMaterializeStandaloneObject(rootDir: str,
                                                           plan: pobj.PrimaryObjectPlan,
                                                           result: var SystemLinkExecRuntimeDirectResult): Result[bool] =
    let startNs = SystemLinkExecRuntimeDirectNowNs()
    let directRes: Result[direct.DirectObjectEmitResult] = direct.DirectObjectEmitStandaloneMain(rootDir, plan)
    if IsErr(directRes):
        result.primaryObjectNs = SystemLinkExecRuntimeDirectNowNs() - startNs
        return Err[bool](Error(directRes))
    result.standaloneDirectEntry = true
    return SystemLinkExecRuntimeDirectRecordObject(rootDir,
                                                   startNs,
                                                   Value(directRes),
                                                   result)

fn SystemLinkExecRuntimeDirectCompileProviderObject(rootDir: str,
                                                     compilerPath: str,
                                                     plan: SystemLinkExecRuntimeDirectPlan,
                                                     sourcePath: str,
                                                     objectPath: str,
                                                     index: int32): Result[hostops.LoggedRun] =
    let parent = chengpath.PathParentDir(objectPath)
    if len(parent) > 0 && !chengpath.MkdirP(rootDir, parent):
        return Err[hostops.LoggedRun](Fmt" system link exec direct runtime: failed to create provider object dir: {parent}")
    let objectAbs = chengpath.PathAbsolute(rootDir, objectPath)
    if os.FileExists(objectAbs):
        let _ = os.RemoveFile(objectAbs)
    let logPath = Fmt"{objectPath}.compile.log"
    let logAbs = chengpath.PathAbsolute(rootDir, logPath)
    if os.FileExists(logAbs):
        let _ = os.RemoveFile(logAbs)
    var providerModule = ""
    if index >= 0 && index < plan.objectPlan.providerModules.len:
        providerModule = plan.objectPlan.providerModules[index]
    let argv = SystemLinkExecRuntimeDirectProviderCompileArgs(plan, providerModule, sourcePath, objectPath)
    let run = hostops.RunFileLogged(rootDir,
                                    Fmt"system_link_exec_direct_provider_{strings.IntToStr(index)}",
                                    compilerPath,
                                    argv,
                                    [],
                                    rootDir,
                                    0,
                                    logPath)
    if run.exitCode != 0:
        return Err[hostops.LoggedRun](Fmt" system link exec direct runtime: provider compile failed rc={strings.IntToStr(run.exitCode)} source={sourcePath} log={run.logPath}\n{run.output}")
    if !chengpath.FileExistsNonEmpty(rootDir, objectPath):
        return Err[hostops.LoggedRun](Fmt" system link exec direct runtime: provider object missing after compile: {objectPath}")
    return Ok[hostops.LoggedRun](run)

fn SystemLinkExecRuntimeDirectMaterializeProviderObjects(rootDir: str,
                                                          compilerPath: str,
                                                          plan: SystemLinkExecRuntimeDirectPlan,
                                                          result: var SystemLinkExecRuntimeDirectResult): Result[bool] =
    let startNs = SystemLinkExecRuntimeDirectNowNs()
    for i in 0..<plan.objectPlan.providerSourcePaths.len:
        let sourcePath = plan.objectPlan.providerSourcePaths[i]
        let objectPath = plan.objectPlan.providerObjectPaths[i]
        var providerModule = ""
        if i >= 0 && i < plan.objectPlan.providerModules.len:
            providerModule = plan.objectPlan.providerModules[i]
        let runRes = SystemLinkExecRuntimeDirectCompileProviderObject(rootDir,
                                                                      compilerPath,
                                                                      plan,
                                                                      sourcePath,
                                                                      objectPath,
                                                                      i)
        if IsErr(runRes):
            result.providerObjectsNs = SystemLinkExecRuntimeDirectNowNs() - startNs
            return Err[bool](Error(runRes))
        let run = Value(runRes)
        add(result.providerObjectPaths, objectPath)
        add(result.providerCompileLogPaths, run.logPath)
    result.providerObjectsNs = SystemLinkExecRuntimeDirectNowNs() - startNs
    return Ok[bool](true)

fn SystemLinkExecRuntimeDirectRunNativeLink(rootDir: str,
                                             plan: SystemLinkExecRuntimeDirectPlan,
                                             nativePlan: nplan.NativeLinkPlanStub,
                                             result: var SystemLinkExecRuntimeDirectResult): Result[bool] =
    let startNs = SystemLinkExecRuntimeDirectNowNs()
    let logPath = Fmt"{plan.systemLinkPlan.outputPath}.native_link.log"
    let outputAbs = chengpath.PathAbsolute(rootDir, plan.systemLinkPlan.outputPath)
    if len(outputAbs) > 0 && os.FileExists(outputAbs):
        let _ = os.RemoveFile(outputAbs)
    let run = nlink.NativeLinkExecRunLogged(rootDir,
                                            "system_link_exec_direct_native_link",
                                            nativePlan,
                                            logPath)
    result.nativeLinkLogPath = run.logPath
    result.nativeLinkNs = SystemLinkExecRuntimeDirectNowNs() - startNs
    if run.exitCode != 0:
        return Err[bool](Fmt" system link exec direct runtime: native link failed rc={strings.IntToStr(run.exitCode)} log={run.logPath}\n{run.output}")
    if !chengpath.FileExistsNonEmpty(rootDir, plan.systemLinkPlan.outputPath):
        return Err[bool](Fmt" system link exec direct runtime: native output missing after link: {plan.systemLinkPlan.outputPath}")
    return Ok[bool](true)

fn SystemLinkExecRuntimeDirectWriteLineMap(rootDir: str,
                                            plan: SystemLinkExecRuntimeDirectPlan,
                                            result: var SystemLinkExecRuntimeDirectResult): Result[bool] =
    let startNs = SystemLinkExecRuntimeDirectNowNs()
    let lineMapRes = linemap.WriteExecutableLineMap(rootDir,
                                                    plan.systemLinkPlan,
                                                    plan.loweringPlan)
    result.lineMapNs = SystemLinkExecRuntimeDirectNowNs() - startNs
    if IsErr(lineMapRes):
        return Err[bool](Error(lineMapRes))
    result.lineMapPath = Value(lineMapRes)
    if plan.systemLinkPlan.emitKind == creq.EmitExe &&
       len(result.lineMapPath) > 0 &&
       !chengpath.FileExistsNonEmpty(rootDir, result.lineMapPath):
        return Err[bool](Fmt" system link exec direct runtime: line-map missing after write: {result.lineMapPath}")
    return Ok[bool](true)

fn SystemLinkExecRuntimeDirectStandaloneNativePlan(plan: SystemLinkExecRuntimeDirectPlan,
                                                    primaryObjectPath: str): nplan.NativeLinkPlanStub =
    var out: nplan.NativeLinkPlanStub
    var linkInputs: str[]
    add(linkInputs, primaryObjectPath)
    out.targetTriple = plan.systemLinkPlan.targetTriple
    out.emitKind = creq.EmitExe
    out.outputPath = plan.systemLinkPlan.outputPath
    out.objectFormat = tmat.TargetPrimaryObjectFormat(plan.systemLinkPlan.targetTriple)
    out.linkerProgram = tmat.TargetLinkerProgram(plan.systemLinkPlan.targetTriple)
    out.linkerFlavor = tmat.TargetLinkerFlavor(plan.systemLinkPlan.targetTriple)
    out.outputKind = nplan.NativeOutputExecutable
    out.entrySymbol = "main"
    out.primaryObjectPath = primaryObjectPath
    out.browserBridgeObjectPath = ""
    out.linkInputPaths = linkInputs
    out.missingReasons = []
    out.pipelineStage = "standalone_primary_object_to_native_link_plan"
    return out

fn SystemLinkExecRuntimeDirectCanUseStandaloneMain(plan: SystemLinkExecRuntimeDirectPlan): bool =
    if plan.systemLinkPlan.emitKind != creq.EmitExe:
        return false
    if plan.systemLinkPlan.providerModules.len > 0:
        return false
    if plan.objectPlan.providerModules.len > 0:
        return false
    if plan.objectPlan.providerSourcePaths.len > 0:
        return false
    if plan.objectPlan.providerObjectPaths.len > 0:
        return false
    return direct.DirectObjectEmitCanStandaloneMain(plan.primaryObjectPlan)

fn SystemLinkExecRuntimeDirectExecutePlanWithCompiler(rootDir: str,
                                                       plan: SystemLinkExecRuntimeDirectPlan,
                                                       requestedProviderCompilerPath: str): Result[SystemLinkExecRuntimeDirectResult] =
    var result: SystemLinkExecRuntimeDirectResult
    var standaloneMain = false
    standaloneMain = SystemLinkExecRuntimeDirectCanUseStandaloneMain(plan)
    var primaryRes: Result[bool]
    if standaloneMain:
        primaryRes = SystemLinkExecRuntimeDirectMaterializeStandaloneObject(rootDir,
                                                                            plan.primaryObjectPlan,
                                                                            result)
    else:
        primaryRes = SystemLinkExecRuntimeDirectMaterializePrimaryObject(rootDir,
                                                                         plan.primaryObjectPlan,
                                                                         result)
    if IsErr(primaryRes):
        return Err[SystemLinkExecRuntimeDirectResult](Error(primaryRes))
    if plan.systemLinkPlan.emitKind == creq.EmitObj:
        return Ok[SystemLinkExecRuntimeDirectResult](result)
    let validRes = SystemLinkExecRuntimeDirectValidateExecutablePlan(rootDir, plan)
    if IsErr(validRes):
        return Err[SystemLinkExecRuntimeDirectResult](Error(validRes))
    if !standaloneMain && plan.objectPlan.providerSourcePaths.len > 0:
        let compilerRes = SystemLinkExecRuntimeDirectResolveProviderCompiler(rootDir, requestedProviderCompilerPath)
        if IsErr(compilerRes):
            return Err[SystemLinkExecRuntimeDirectResult](Error(compilerRes))
        result.providerCompilerPath = Value(compilerRes)
        let providerRes = SystemLinkExecRuntimeDirectMaterializeProviderObjects(rootDir,
                                                                                result.providerCompilerPath,
                                                                                plan,
                                                                                result)
        if IsErr(providerRes):
            return Err[SystemLinkExecRuntimeDirectResult](Error(providerRes))
    var nativePlan = plan.nativeLinkPlan
    if standaloneMain:
        nativePlan = SystemLinkExecRuntimeDirectStandaloneNativePlan(plan, result.primaryObjectPath)
    let nativeRes = SystemLinkExecRuntimeDirectRunNativeLink(rootDir, plan, nativePlan, result)
    if IsErr(nativeRes):
        return Err[SystemLinkExecRuntimeDirectResult](Error(nativeRes))
    if plan.systemLinkPlan.emitKind == creq.EmitExe:
        let lineMapRes = SystemLinkExecRuntimeDirectWriteLineMap(rootDir, plan, result)
        if IsErr(lineMapRes):
            return Err[SystemLinkExecRuntimeDirectResult](Error(lineMapRes))
    return Ok[SystemLinkExecRuntimeDirectResult](result)
