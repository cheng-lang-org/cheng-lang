type
    PrimaryObjectIrCallOp =
        targetSymbol: str
        targetSourcePath: str
        importc: bool
        importcSymbol: str
        argCount: int32
        argsText: str
        resultType: str
        bindingName: str
        resultSlot: int32
        relocWordOffset: int32
        argSlots: int32[]

    PrimaryObjectIrStatement =
        sourcePath: str
        functionName: str
        statementIndex: int32
        lineNumber: int32
        columnNumber: int32
        lineIndent: int32
        enclosingIfLineNumber: int32
        enclosingIfConditionText: str
        kind: texpr.TypedExprIrStatementKind
        detailKind: parser.NormalizedExprDetailKind
        surfaceText: str
        bindingName: str
        resultType: str
        callTarget: str
        callTargetSourcePath: str
        callTargetImportc: bool
        callArgCount: int32
        callArgsText: str
        callImportcSymbol: str
        returnRoot: bool

    PrimaryObjectIrFunction =
        sourcePath: str
        functionName: str
        signatureLineNumber: int32
        bodyLineNumber: int32
        returnType: str
        bodyKind: str
        statementReturnMode: int32
        statementReturnI32Value: int32
        paramNames: str[]
        paramSlots: int32[]
        paramTypes: str[]
        statementCount: int32
        statements: PrimaryObjectIrStatement[]
        callTargetCount: int32
        callArgCounts: int32[]
        callTargets: str[]
        callTargetSourcePaths: str[]
        callTargetImportcFlags: bool[]
        callImportcSymbols: str[]
        bodyIR: coreir.BodyIR
        callSequence: PrimaryObjectIrCallOp[]
        returnStringLiteral: str

    PrimaryObjectIr =
        functions: PrimaryObjectIrFunction[]

    LoweringConstBinding =
        name: str
        typeText: str
        valueKind: int32
        hasI32: bool
        i32Value: int32
        textValue: str
        seqValues: int32[]
        resultOk: bool
        resultValue: int32
        resultError: str
        hasField: bool
        fieldName: str
        fieldValue: int32

    LoweringPlanStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entryPath: str
        entrySymbol: str
        targetTriple: str
        sourceBundleCid: layout.FixedBytes32
        compilerCsgCid: layout.FixedBytes32
        exprLayer: parser.NormalizedExprLayer
        typedExprFacts: ccsg.TypedExprFact[]
        exprSurfaceSourceCount: int32
        exprSurfaceExprCount: int32
        exprSurfaceIfCount: int32
        exprSurfaceRangeCount: int32
        exprSurfaceComprehensionCount: int32
        exprSurfaceFmtCount: int32
        exprSurfaceResultIntrinsicCount: int32
        exprSurfaceTryCount: int32
        exprSurfaceDefaultInitCount: int32
        exprSurfaceConstructorCount: int32
        exprSurfaceReturnCount: int32
        exprSurfaceAssignCount: int32
        exprSurfaceIfStmtCount: int32
        exprSurfaceElifStmtCount: int32
        exprSurfaceElseStmtCount: int32
        exprSurfaceForStmtCount: int32
        exprSurfaceQuestionResidualCount: int32
        typedExprFactCount: int32
        typedCallFactCount: int32
        loweringRuleCount: int32
        typedIrFunctionCount: int32
        typedIrStatementCount: int32
        typedIrNodeCount: int32
        typedReturnOpCount: int32
        typedIr: texpr.TypedExprIr
        typedReturnOps: texpr.TypedExprReturnOpFact[]
        primaryObjectIr: PrimaryObjectIr
        loweringRules: texpr.TypedExprLoweringRule[]
        functionSourcePaths: str[]
        functionOwnerModulePaths: str[]
        functionNames: str[]
        functionSymbolTexts: str[]
        functionExportedFlags: int32[]
        functionExportSymbolNames: str[]
        functionNameIds: int32[]
        functionEntryFlags: int32[]
        functionCallConvs: int32[]
        functionResultLayoutKinds: int32[]
        missingReasons: str[]
        pipelineStage: str

fn LoweringCallConvInternal(): int32 =
    return 1

fn LoweringLayoutKindInvalid(): int32 =
    return 0

fn LoweringLayoutKindI32(): int32 =
    return 5

fn LoweringAppendLine(out: var str, key: str, value: str) =
    if Len(out) > 0:
        out = Fmt"{out}\n"
    out = Fmt"{out}{key}={value}"

fn LoweringListText(items: str[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if Len(out) > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{items[i]}"
    return out

fn LoweringIntListText(items: int32[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if Len(out) > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{items[i]}"
    return out

fn LoweringFunctionSymbolText(ownerModulePath: str, functionName: str): str =
    return Fmt"{ownerModulePath}::{functionName}"

fn LoweringFunctionTailName(functionName: str): str =
    var tailStart = 0
    if Len(functionName) >= 2:
        for j in 0..<(Len(functionName) - 1):
            if functionName[j] == ':' && functionName[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < Len(functionName):
        return chengpath.TextSlice(functionName, tailStart, Len(functionName) - tailStart)
    return functionName

fn LoweringTypedIrFunctionIndex(ir: texpr.TypedExprIr,
                                 sourcePath: str,
                                 functionName: str): int32 =
    let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
    let tailName = LoweringFunctionTailName(functionName)
    for i in 0..<ir.functions.len:
        if parser.ParserNormalizePath(ir.functions[i].sourcePath) != normalizedSourcePath:
            continue
        if ir.functions[i].functionName == functionName ||
           ir.functions[i].functionName == tailName:
            return i
    return -1
fn LoweringFindResolvedCallFactIndex(facts: ccsg.TypedExprFact[],
                                      sourcePath: str,
                                      lineNumber: int32): int32 =
    if lineNumber <= 0:
        return -1
    for i in 0..<facts.len:
        if facts[i].lineNumber != lineNumber:
            continue
        if facts[i].sourcePath != sourcePath:
            continue
        if !facts[i].callResolved:
            continue
        if Len(facts[i].callTarget) <= 0:
            continue
        return i
    return -1

fn LoweringStatementResultTypeFromFacts(typedStmt: texpr.TypedExprIrStatement,
                                         facts: ccsg.TypedExprFact[]): str =
    let stmtType = texpr.TypedExprNormalizeTypeText(typedStmt.resultType)
    if texpr.TypedExprTypeTextIsConcrete(stmtType):
        return stmtType
    for i in 0..<facts.len:
        if facts[i].lineNumber != typedStmt.lineNumber ||
           facts[i].columnNumber != typedStmt.columnNumber:
            continue
        if facts[i].sourcePath != typedStmt.sourcePath:
            continue
        if facts[i].exprId != typedStmt.exprId:
            continue
        if facts[i].callTarget != typedStmt.callTarget ||
           facts[i].callArgsText != typedStmt.callArgsText:
            continue
        let factType = texpr.TypedExprNormalizeTypeText(facts[i].typeText)
        if texpr.TypedExprTypeTextIsConcrete(factType):
            return factType
    return stmtType

fn LoweringResolvedCallFactCount(facts: var ccsg.TypedExprFact[]): int32 =
    var count: int32
    for i in 0..<facts.len:
        if !facts[i].callResolved:
            continue
        if Len(facts[i].callTarget) <= 0:
            continue
        count = count + 1
    return count

fn LoweringPrimaryObjectIrBodyKindForCallArgCount(callArgCount: int32): str =
    if callArgCount == 0:
        return texpr.BodyKindReturnCallNoargI32
    if callArgCount == 1:
        return texpr.BodyKindReturnCallArg0I32
    if callArgCount == 2:
        return texpr.BodyKindReturnCallArg0Arg1I32
    if callArgCount == 3:
        return texpr.BodyKindReturnCallArg0Arg1Arg2I32
    return texpr.BodyKindUnsupported

fn LoweringSetStatementSequenceReturn(fnIr: var PrimaryObjectIrFunction,
                                       mode: int32,
                                       i32Value: int32) =
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    fnIr.statementReturnMode = mode
    fnIr.statementReturnI32Value = i32Value

fn LoweringPrimaryObjectIrParamSlotIndex(fnIr: PrimaryObjectIrFunction,
                                          paramSlot: int32): int32 =
    for i in 0..<fnIr.paramSlots.len:
        if fnIr.paramSlots[i] == paramSlot:
            return i
    return -1

fn LoweringPrimaryObjectIrParamNameSlot(fnIr: PrimaryObjectIrFunction,
                                         nameRaw: str): int32 =
    let name = chengpath.PathTrim(nameRaw)
    if Len(name) <= 0:
        return -1
    for i in 0..<fnIr.paramNames.len:
        if fnIr.paramNames[i] == name:
            return fnIr.paramSlots[i]
    return -1

fn LoweringPrimaryObjectIrParamSlotName(fnIr: PrimaryObjectIrFunction,
                                         paramSlot: int32): str =
    for i in 0..<fnIr.paramSlots.len:
        if fnIr.paramSlots[i] == paramSlot:
            return fnIr.paramNames[i]
    return ""

fn LoweringAppendPrimaryObjectIrParams(fnIr: var PrimaryObjectIrFunction,
                                        typedIr: texpr.TypedExprIr,
                                        typedFnIndex: int32) =
    if typedFnIndex < 0 || typedFnIndex >= typedIr.functions.len:
        return
    let typedFn = typedIr.functions[typedFnIndex]
    var nodeEnd = typedFn.nodeStart + typedFn.nodeCount
    if nodeEnd > typedIr.nodes.len:
        nodeEnd = typedIr.nodes.len
    for nodeIndex in typedFn.nodeStart..<nodeEnd:
        let node = typedIr.nodes[nodeIndex]
        if node.opKind != texpr.TypedExprIrOpParamRef:
            continue
        if node.paramSlot < 0:
            continue
        if LoweringPrimaryObjectIrParamSlotIndex(fnIr, node.paramSlot) >= 0:
            continue
        add(fnIr.paramNames, node.paramName)
        add(fnIr.paramSlots, node.paramSlot)
        add(fnIr.paramTypes, node.resultType)

fn LoweringCallArgNamesFromTypedText(callArgsText: str): str[] =
    var out: str[]
    let pieces = texpr.TypedExprSplitTopLevelCsv(callArgsText)
    for i in 0..<pieces.len:
        let name = chengpath.PathTrim(pieces[i])
        if Len(name) > 0:
            add(out, name)
    return out

fn LoweringReturnCallArgsPassThrough(fnIr: PrimaryObjectIrFunction,
                                      callArgsText: str,
                                      callArgCount: int32): bool =
    if callArgCount <= 0:
        return true
    let callArgNames = LoweringCallArgNamesFromTypedText(callArgsText)
    if callArgNames.len != callArgCount:
        return false
    for i in 0..<callArgCount:
        if LoweringPrimaryObjectIrParamNameSlot(fnIr, callArgNames[i]) != i:
            return false
    return true

fn LoweringReturnCallArg0Arg1TruePassThrough(fnIr: PrimaryObjectIrFunction,
                                              callArgsText: str,
                                              callArgCount: int32): bool =
    if callArgCount != 3:
        return false
    let callArgNames = LoweringCallArgNamesFromTypedText(callArgsText)
    if callArgNames.len != 3:
        return false
    return LoweringPrimaryObjectIrParamNameSlot(fnIr, callArgNames[0]) == 0 &&
           LoweringPrimaryObjectIrParamNameSlot(fnIr, callArgNames[1]) == 1 &&
           callArgNames[2] == "true"

fn LoweringAnnotationQuotedValue(lineRaw: str,
                                  annotationName: str): str =
    let trimmed = chengpath.PathTrim(lineRaw)
    let prefix = Fmt"@{annotationName}(\""
    if !chengpath.TextStartsWith(trimmed, prefix):
        return ""
    let start = Len(prefix)
    for i in start..<Len(trimmed):
        if trimmed[i] == '"':
            return chengpath.TextSlice(trimmed, start, i - start)
    return ""

fn LoweringFunctionDeclMatches(lineRaw: str,
                                functionName: str): bool =
    let trimmed = chengpath.PathTrim(lineRaw)
    if !chengpath.TextStartsWith(trimmed, "fn "):
        return false
    let tailName = LoweringFunctionTailName(functionName)
    let rest = chengpath.TextSlice(trimmed, 3, Len(trimmed) - 3)
    if !chengpath.TextStartsWith(rest, tailName):
        return false
    if Len(rest) == Len(tailName):
        return true
    let next = rest[Len(tailName)]
    return next == '(' || next == '[' || next == ':' || next == ' '

fn LoweringImportcTargetSymbol(sourceTexts: texpr.TypedExprSourceText[],
                                targetSourcePath: str,
                                functionName: str): str =
    let normalizedTargetSourcePath = parser.ParserNormalizePath(targetSourcePath)
    for sourceIndex in 0..<sourceTexts.len:
        if parser.ParserNormalizePath(sourceTexts[sourceIndex].sourcePath) != normalizedTargetSourcePath:
            continue
        let lines = parser.ParserSplitChar(sourceTexts[sourceIndex].text, '\n')
        var pendingImportc = ""
        for lineIndex in 0..<lines.len:
            let importcName = LoweringAnnotationQuotedValue(lines[lineIndex], "importc")
            if Len(importcName) > 0:
                pendingImportc = importcName
                continue
            if LoweringFunctionDeclMatches(lines[lineIndex], functionName):
                if Len(pendingImportc) > 0:
                    return pendingImportc
                return functionName
            let trimmed = chengpath.PathTrim(lines[lineIndex])
            if chengpath.TextStartsWith(trimmed, "fn "):
                pendingImportc = ""
        return functionName
    return functionName

fn LoweringAppendPrimaryObjectIrStatements(fnIr: var PrimaryObjectIrFunction,
                                            typedIr: texpr.TypedExprIr,
                                            typedFnIndex: int32,
                                            typedFacts: ccsg.TypedExprFact[],
                                            sourceTexts: texpr.TypedExprSourceText[]) =
    if typedFnIndex < 0 || typedFnIndex >= typedIr.functions.len:
        return
    let typedFn = typedIr.functions[typedFnIndex]
    var stmtStart = typedFn.statementStart
    if stmtStart < 0:
        return
    if stmtStart >= typedIr.statements.len:
        return
    var stmtEnd = stmtStart + typedFn.statementCount
    if stmtEnd > typedIr.statements.len:
        stmtEnd = typedIr.statements.len
    for stmtIndex in stmtStart..<stmtEnd:
        let typedStmt = typedIr.statements[stmtIndex]
        var stmt: PrimaryObjectIrStatement
        stmt.sourcePath = typedStmt.sourcePath
        stmt.functionName = typedStmt.functionName
        stmt.statementIndex = typedStmt.statementIndex
        stmt.lineNumber = typedStmt.lineNumber
        stmt.columnNumber = typedStmt.columnNumber
        stmt.lineIndent = typedStmt.lineIndent
        stmt.enclosingIfLineNumber = typedStmt.enclosingIfLineNumber
        stmt.enclosingIfConditionText = typedStmt.enclosingIfConditionText
        stmt.kind = typedStmt.kind
        stmt.detailKind = typedStmt.detailKind
        stmt.surfaceText = typedStmt.surfaceText
        stmt.bindingName = typedStmt.bindingName
        stmt.resultType = LoweringStatementResultTypeFromFacts(typedStmt, typedFacts)
        stmt.callTarget = typedStmt.callTarget
        stmt.callTargetSourcePath = typedStmt.callTargetSourcePath
        stmt.callTargetImportc = typedStmt.callTargetImportc
        stmt.callArgCount = typedStmt.callArgCount
        stmt.callArgsText = typedStmt.callArgsText
        stmt.returnRoot = typedStmt.returnRoot
        if typedStmt.callTargetImportc:
            stmt.callImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                 typedStmt.callTargetSourcePath,
                                                                 typedStmt.callTarget)
        add(fnIr.statements, stmt)
    fnIr.statementCount = fnIr.statements.len

fn LoweringAlignInt32(value: int32, align: int32): int32 =
    if align <= 1:
        return value
    let rem = value % align
    if rem == 0:
        return value
    return value + (align - rem)

fn LoweringMissingArgSlot(): int32 =
    return coreir.CallArgSlotMissing()

fn LoweringTextEndsWith(text: str,
                         suffix: str): bool =
    if Len(suffix) > Len(text):
        return false
    let start = Len(text) - Len(suffix)
    for i in 0..<Len(suffix):
        if text[start + i] != suffix[i]:
            return false
    return true

fn LoweringLocalTypeKind(typeTextRaw: str): int32 =
    let typeText = texpr.TypedExprNormalizeTypeText(typeTextRaw)
    if typeText == "int32" ||
       typeText == "bool" ||
       chengpath.TextContains(typeText, "CompilerEmit"):
        return coreir.LocalI32Tag
    if typeText == "float64":
        return coreir.LocalF64Tag
    if typeText == "str":
        return coreir.LocalStrTag
    if typeText == "cstring":
        return coreir.LocalPtrTag
    if chengpath.TextContains(typeText, "SystemLinkPlanStub") ||
       chengpath.TextContains(typeText, "LoweringPlanStub") ||
       chengpath.TextContains(typeText, "PrimaryObjectPlan") ||
       chengpath.TextContains(typeText, "CompilerCsg") ||
       chengpath.TextContains(typeText, "DirectObjectEmitResult") ||
       chengpath.TextContains(typeText, "ExecCmdResult") ||
       chengpath.TextContains(typeText, "FixedBytes32") ||
       chengpath.TextContains(typeText, "NormalizedExprLayer"):
        return coreir.LocalAggregateTag
    if Len(typeText) > 2 && LoweringTextEndsWith(typeText, "[]"):
        return coreir.LocalAggregateTag
    if chengpath.TextContains(typeText, "CompilerRequest"):
        return coreir.LocalAggregateTag
    if chengpath.TextStartsWith(typeText, "Result["):
        return coreir.LocalAggregateTag
    return coreir.LocalInvalidTag

fn LoweringLocalTypeSizeBytes(typeTextRaw: str,
                               typeKind: int32): int32 =
    let typeText = texpr.TypedExprNormalizeTypeText(typeTextRaw)
    if typeKind == coreir.LocalI32Tag:
        return 4
    if typeKind == coreir.LocalF64Tag:
        return 8
    if typeKind == coreir.LocalStrTag:
        return 24
    if typeKind == coreir.LocalPtrTag:
        return 8
    if typeKind == coreir.LocalAggregateTag:
        if chengpath.TextContains(typeText, "SystemLinkPlanStub"):
            return 512
        if chengpath.TextContains(typeText, "LoweringPlanStub"):
            return 768
        if chengpath.TextContains(typeText, "PrimaryObjectPlan"):
            return 768
        if chengpath.TextContains(typeText, "CompilerCsg"):
            return 192
        if chengpath.TextContains(typeText, "DirectObjectEmitResult"):
            return 64
        if chengpath.TextContains(typeText, "ExecCmdResult"):
            return 40
        if chengpath.TextContains(typeText, "FixedBytes32"):
            return 32
        if chengpath.TextContains(typeText, "NormalizedExprLayer"):
            return 64
        if Len(typeText) > 2 && LoweringTextEndsWith(typeText, "[]"):
            return 16
        if chengpath.TextContains(typeText, "CompilerRequest"):
            return 232
        if chengpath.TextStartsWith(typeText, "Result["):
            return 40
    return 0

fn LoweringLocalTypeAlignBytes(typeKind: int32): int32 =
    if typeKind == coreir.LocalI32Tag:
        return 4
    if typeKind == coreir.LocalF64Tag:
        return 8
    if typeKind == coreir.LocalStrTag:
        return 8
    if typeKind == coreir.LocalPtrTag:
        return 8
    if typeKind == coreir.LocalAggregateTag:
        return 16
    return 1

fn LoweringBodyIrNextLocalOffset(bodyIR: coreir.BodyIR,
                                  alignBytes: int32): int32 =
    var nextOffset: int32 = 16
    for i in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[i]
        var slotSize = slot.sizeBytes
        if slotSize <= 0:
            if slot.typeKind == coreir.LocalI32Tag:
                slotSize = 4
            elif slot.typeKind == coreir.LocalF64Tag:
                slotSize = 8
            elif slot.typeKind == coreir.LocalStrTag:
                slotSize = 24
            elif slot.typeKind == coreir.LocalPtrTag:
                slotSize = 8
            elif slot.typeKind == coreir.LocalAggregateTag:
                slotSize = slot.sizeBytes
        let slotEnd = slot.stackOffset + slotSize
        if slotEnd > nextOffset:
            nextOffset = slotEnd
    return LoweringAlignInt32(nextOffset, alignBytes)

fn LoweringBodyIrLocalSlotIndex(fnIr: PrimaryObjectIrFunction,
                                 nameRaw: str): int32 =
    let name = chengpath.PathTrim(nameRaw)
    if Len(name) <= 0:
        return -1
    for i in 0..<fnIr.bodyIR.localSlots.len:
        if fnIr.bodyIR.localSlots[i].name == name:
            return fnIr.bodyIR.localSlots[i].id
    return -1

fn LoweringBodyIrEnsureLocalSlot(fnIr: var PrimaryObjectIrFunction,
                                  nameRaw: str,
                                  typeTextRaw: str): int32 =
    let name = chengpath.PathTrim(nameRaw)
    if Len(name) <= 0:
        return -1
    let existing = LoweringBodyIrLocalSlotIndex(fnIr, name)
    if existing >= 0:
        return existing
    let typeKind = LoweringLocalTypeKind(typeTextRaw)
    if typeKind == coreir.LocalInvalidTag:
        return -1
    let sizeBytes = LoweringLocalTypeSizeBytes(typeTextRaw, typeKind)
    if sizeBytes <= 0:
        return -1
    let alignBytes = LoweringLocalTypeAlignBytes(typeKind)
    var slot: coreir.LocalSlot
    slot.id = fnIr.bodyIR.localSlots.len
    slot.name = name
    slot.typeKind = typeKind
    slot.sizeBytes = sizeBytes
    slot.alignBytes = alignBytes
    slot.stackOffset = LoweringBodyIrNextLocalOffset(fnIr.bodyIR, alignBytes)
    add(fnIr.bodyIR.localSlots, slot)
    return slot.id

fn LoweringSyntheticStatementSlotName(stmt: PrimaryObjectIrStatement): str =
    return Fmt"__stmt_{stmt.statementIndex}"

fn LoweringResultIntrinsicSlotName(stmt: PrimaryObjectIrStatement): str =
    if stmt.kind != texpr.TypedExprIrStmtResultIntrinsic:
        return ""
    if Len(stmt.bindingName) > 0:
        return stmt.bindingName
    return LoweringSyntheticStatementSlotName(stmt)

fn LoweringStructuredCallResultSlotName(stmt: PrimaryObjectIrStatement): str =
    if stmt.kind == texpr.TypedExprIrStmtLetCall:
        return stmt.bindingName
    if stmt.kind == texpr.TypedExprIrStmtIfCall:
        return LoweringSyntheticStatementSlotName(stmt)
    if stmt.kind == texpr.TypedExprIrStmtCall:
        let resultKind = LoweringLocalTypeKind(stmt.resultType)
        if stmt.returnRoot ||
           resultKind == coreir.LocalStrTag ||
           resultKind == coreir.LocalAggregateTag:
            return LoweringSyntheticStatementSlotName(stmt)
    return ""

fn LoweringCallArgIntrinsicCallee(textRaw: str,
                                   innerText: var str): str =
    innerText = ""
    let text = chengpath.PathTrim(textRaw)
    if Len(text) < 3:
        return ""
    if text[Len(text) - 1] != ')':
        return ""
    var openIndex = -1
    for i in 0..<Len(text):
        if text[i] == '(':
            openIndex = i
            break
    if openIndex <= 0:
        return ""
    let callee = chengpath.PathTrim(chengpath.TextSlice(text, 0, openIndex))
    let innerStart = openIndex + 1
    innerText = chengpath.PathTrim(chengpath.TextSlice(text,
                                                       innerStart,
                                                       Len(text) - innerStart - 1))
    return callee

fn LoweringResultIntrinsicArgSlot(fnIr: PrimaryObjectIrFunction,
                                   argText: str): int32 =
    var innerText = ""
    let callee = LoweringCallArgIntrinsicCallee(argText, innerText)
    if Len(callee) <= 0 || Len(innerText) <= 0:
        return -1
    let detailKind = parser.ParserResultIntrinsicDetailKind(callee)
    if detailKind == parser.NormalizedExprDetailNone:
        return -1
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind != texpr.TypedExprIrStmtResultIntrinsic:
            continue
        if stmt.detailKind != detailKind:
            continue
        if chengpath.PathTrim(stmt.callArgsText) != innerText:
            continue
        let slotName = LoweringResultIntrinsicSlotName(stmt)
        if Len(slotName) <= 0:
            return -1
        return LoweringBodyIrLocalSlotIndex(fnIr, slotName)
    return -1

fn LoweringCallArgSlots(fnIr: PrimaryObjectIrFunction,
                         callArgsText: str): int32[] =
    var out: int32[]
    let args = texpr.TypedExprSplitTopLevelCsv(callArgsText)
    for i in 0..<args.len:
        let argName = chengpath.PathTrim(args[i])
        if Len(argName) <= 0:
            continue
        var argSlot = LoweringMissingArgSlot()
        if argName == "true":
            argSlot = coreir.CallArgSlotConstTrue()
        elif argName == "false":
            argSlot = coreir.CallArgSlotConstFalse()
        else:
            let localSlot = LoweringBodyIrLocalSlotIndex(fnIr, argName)
            if localSlot >= 0:
                argSlot = localSlot
            else:
                let paramSlot = LoweringPrimaryObjectIrParamNameSlot(fnIr, argName)
                if paramSlot >= 0:
                    argSlot = 0 - paramSlot - 1
                else:
                    let intrinsicSlot = LoweringResultIntrinsicArgSlot(fnIr, argName)
                    if intrinsicSlot >= 0:
                        argSlot = intrinsicSlot
        add(out, argSlot)
    return out

fn LoweringStatementImportcSymbol(stmt: PrimaryObjectIrStatement,
                                   sourceTexts: texpr.TypedExprSourceText[]): str =
    if !stmt.callTargetImportc:
        return ""
    if Len(stmt.callImportcSymbol) > 0:
        return stmt.callImportcSymbol
    return LoweringImportcTargetSymbol(sourceTexts,
                                       stmt.callTargetSourcePath,
                                       stmt.callTarget)

fn LoweringPopulateSingleI32ReturnCall(fnIr: var PrimaryObjectIrFunction,
                                        sourceTexts: texpr.TypedExprSourceText[],
                                        returnExprRaw: str): bool =
    let returnExpr = chengpath.PathTrim(returnExprRaw)
    let normalizedReturnType = texpr.TypedExprNormalizeTypeText(fnIr.returnType)
    if normalizedReturnType != "int32" && normalizedReturnType != "bool":
        return false
    var returnStatementIndex: int32 = -1
    var explicitReturnCall = false
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtLocalDecl:
            continue
        if stmt.kind == texpr.TypedExprIrStmtReturn:
            continue
        if stmt.kind != texpr.TypedExprIrStmtCall:
            return false
        if stmt.enclosingIfLineNumber > 0:
            return false
        if Len(stmt.callTarget) <= 0:
            return false
        let resultType = texpr.TypedExprNormalizeTypeText(stmt.resultType)
        if resultType != "int32" &&
           resultType != "unknown" &&
           Len(resultType) > 0:
            return false
        var isReturnCall = stmt.returnRoot ||
                           LoweringReturnExprMatchesCallStatement(returnExpr, stmt)
        if !isReturnCall &&
           stmt.lineNumber == fnIr.bodyLineNumber:
            isReturnCall = true
        if isReturnCall:
            explicitReturnCall = true
        elif Len(returnExpr) > 0 || stmt.lineNumber != fnIr.bodyLineNumber:
            return false
        if returnStatementIndex >= 0:
            return false
        returnStatementIndex = stmtIndex
    if returnStatementIndex < 0:
        return false
    let stmt = fnIr.statements[returnStatementIndex]
    if stmt.kind != texpr.TypedExprIrStmtCall:
        return false
    if !LoweringReturnCallArgsPassThrough(fnIr,
                                          stmt.callArgsText,
                                          stmt.callArgCount):
        var returnStmt = stmt
        returnStmt.returnRoot = true
        if Len(returnStmt.resultType) <= 0 ||
           texpr.TypedExprNormalizeTypeText(returnStmt.resultType) == "unknown":
            returnStmt.resultType = fnIr.returnType
        LoweringClearStructuredCalls(fnIr)
        let ordinal = LoweringAppendStructuredCall(fnIr, returnStmt, sourceTexts)
        if ordinal < 0 || ordinal >= fnIr.callSequence.len:
            LoweringClearStructuredCalls(fnIr)
            return false
        let callOp = fnIr.callSequence[ordinal]
        if callOp.argSlots.len != returnStmt.callArgCount:
            LoweringClearStructuredCalls(fnIr)
            return false
        for argSlotIndex in 0..<callOp.argSlots.len:
            if callOp.argSlots[argSlotIndex] == LoweringMissingArgSlot():
                LoweringClearStructuredCalls(fnIr)
                return false
        LoweringAppendBodyIrReturnCall(fnIr, returnStmt)
        return fnIr.bodyKind == texpr.BodyKindStatementSequence
    let bodyKind = LoweringPrimaryObjectIrBodyKindForCallArgCount(stmt.callArgCount)
    if bodyKind == texpr.BodyKindUnsupported:
        var returnStmt = stmt
        returnStmt.returnRoot = true
        if Len(returnStmt.resultType) <= 0 ||
           texpr.TypedExprNormalizeTypeText(returnStmt.resultType) == "unknown":
            returnStmt.resultType = fnIr.returnType
        LoweringClearStructuredCalls(fnIr)
        let ordinal = LoweringAppendStructuredCall(fnIr, returnStmt, sourceTexts)
        if ordinal < 0 || ordinal >= fnIr.callSequence.len:
            LoweringClearStructuredCalls(fnIr)
            return false
        let callOp = fnIr.callSequence[ordinal]
        if callOp.argSlots.len != returnStmt.callArgCount:
            LoweringClearStructuredCalls(fnIr)
            return false
        for argSlotIndex in 0..<callOp.argSlots.len:
            if callOp.argSlots[argSlotIndex] == LoweringMissingArgSlot():
                LoweringClearStructuredCalls(fnIr)
                return false
        LoweringAppendBodyIrReturnCall(fnIr, returnStmt)
        return fnIr.bodyKind == texpr.BodyKindStatementSequence
    LoweringClearStructuredCalls(fnIr)
    var callOp: PrimaryObjectIrCallOp
    callOp.targetSymbol = stmt.callTarget
    callOp.targetSourcePath = stmt.callTargetSourcePath
    callOp.importc = stmt.callTargetImportc
    callOp.importcSymbol = LoweringStatementImportcSymbol(stmt, sourceTexts)
    callOp.argCount = stmt.callArgCount
    callOp.argsText = stmt.callArgsText
    callOp.resultType = stmt.resultType
    if Len(callOp.resultType) <= 0 ||
       texpr.TypedExprNormalizeTypeText(callOp.resultType) == "unknown":
        callOp.resultType = fnIr.returnType
    callOp.bindingName = stmt.bindingName
    callOp.resultSlot = -1
    callOp.relocWordOffset = -1
    callOp.argSlots = LoweringCallArgSlots(fnIr, stmt.callArgsText)
    add(fnIr.callSequence, callOp)
    add(fnIr.callArgCounts, stmt.callArgCount)
    add(fnIr.callTargets, stmt.callTarget)
    add(fnIr.callTargetSourcePaths, stmt.callTargetSourcePath)
    add(fnIr.callTargetImportcFlags, stmt.callTargetImportc)
    add(fnIr.callImportcSymbols, callOp.importcSymbol)
    fnIr.callTargetCount = 1
    fnIr.bodyKind = bodyKind
    return true

fn LoweringClearStructuredCalls(fnIr: var PrimaryObjectIrFunction) =
    fnIr.bodyIR = coreir.BodyIR()
    fnIr.callSequence = []
    fnIr.callArgCounts = []
    fnIr.callTargets = []
    fnIr.callTargetSourcePaths = []
    fnIr.callTargetImportcFlags = []
    fnIr.callImportcSymbols = []
    fnIr.callTargetCount = 0

fn LoweringClearStructuredCallSequence(fnIr: var PrimaryObjectIrFunction) =
    fnIr.callSequence = []
    fnIr.callArgCounts = []
    fnIr.callTargets = []
    fnIr.callTargetSourcePaths = []
    fnIr.callTargetImportcFlags = []
    fnIr.callImportcSymbols = []
    fnIr.callTargetCount = 0

fn LoweringStatementIsLowUirCall(stmt: PrimaryObjectIrStatement): bool =
    if stmt.enclosingIfLineNumber > 0:
        return false
    if Len(stmt.callTarget) <= 0:
        return false
    return stmt.kind == texpr.TypedExprIrStmtLetCall ||
           stmt.kind == texpr.TypedExprIrStmtCall

fn LoweringFunctionCanUseLowUirCalls(fnIr: PrimaryObjectIrFunction): bool =
    if fnIr.statements.len <= 0:
        return false
    var callCount: int32
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtReturn:
            continue
        if stmt.kind == texpr.TypedExprIrStmtAssign:
            continue
        if !LoweringStatementIsLowUirCall(stmt):
            return false
        callCount = callCount + 1
    return callCount > 0

fn LoweringFunctionHasControlFlowStatements(fnIr: PrimaryObjectIrFunction): bool =
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.enclosingIfLineNumber > 0:
            return true
        if stmt.kind == texpr.TypedExprIrStmtIf ||
           stmt.kind == texpr.TypedExprIrStmtElif ||
           stmt.kind == texpr.TypedExprIrStmtElse ||
           stmt.kind == texpr.TypedExprIrStmtFor:
            return true
    return false

fn LoweringReturnExprMatchesCallStatement(returnExprRaw: str,
                                           stmt: PrimaryObjectIrStatement): bool =
    let returnExpr = chengpath.PathTrim(returnExprRaw)
    if Len(returnExpr) <= 0:
        return false
    if stmt.kind != texpr.TypedExprIrStmtCall:
        return false
    if Len(stmt.callTarget) <= 0:
        return false
    let argsText = chengpath.PathTrim(stmt.callArgsText)
    let fullTargetCall = Fmt"{stmt.callTarget}({argsText})"
    if returnExpr == fullTargetCall:
        return true
    let tailTargetCall = Fmt"{LoweringFunctionTailName(stmt.callTarget)}({argsText})"
    if returnExpr == tailTargetCall:
        return true
    if Len(argsText) <= 0:
        if returnExpr == stmt.callTarget ||
           returnExpr == LoweringFunctionTailName(stmt.callTarget):
            return true
    let surfaceText = chengpath.PathTrim(stmt.surfaceText)
    if Len(surfaceText) > 0:
        if returnExpr == Fmt"{surfaceText}({argsText})":
            return true
        if Len(argsText) <= 0 && returnExpr == surfaceText:
            return true
    return false

fn LoweringFunctionHasReturnRootCall(fnIr: PrimaryObjectIrFunction,
                                      returnExprRaw: str): bool =
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.returnRoot ||
           LoweringReturnExprMatchesCallStatement(returnExprRaw, stmt):
            return true
    return false

fn LoweringFunctionReturnExprMatchesCallBinding(fnIr: PrimaryObjectIrFunction,
                                                 returnExprRaw: str): bool =
    let returnExpr = chengpath.PathTrim(returnExprRaw)
    if Len(returnExpr) <= 0:
        return false
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind != texpr.TypedExprIrStmtLetCall:
            continue
        if chengpath.PathTrim(stmt.bindingName) == returnExpr:
            return true
    return false

fn LoweringSimpleStringLiteralContent(textRaw: str,
                                       content: var str): bool =
    content = ""
    let text = chengpath.PathTrim(textRaw)
    if Len(text) < 2:
        return false
    if text[0] != Char(34) || text[Len(text) - 1] != Char(34):
        return false
    var escaped = false
    for i in 1..<(Len(text) - 1):
        let ch = text[i]
        if escaped:
            escaped = false
        elif ch == Char(92):
            escaped = true
        elif ch == Char(34):
            return false
    if escaped:
        return false
    content = chengpath.TextSlice(text, 1, Len(text) - 2)
    return true

fn LoweringReturnExprConstI32Value(returnTypeRaw: str,
                                    returnExprRaw: str,
                                    value: var int32): bool =
    let returnType = texpr.TypedExprNormalizeTypeText(returnTypeRaw)
    let returnExpr = chengpath.PathTrim(returnExprRaw)
    if returnType == "bool":
        if returnExpr == "true":
            value = 1
            return true
        if returnExpr == "false":
            value = 0
            return true
        return false
    if returnType != "int32":
        return false
    if !texpr.TypedExprIrIsI32ConstLiteral(returnExpr):
        return false
    let constRes = bkind.BodyKindParseReturnI32Const(Fmt"{texpr.BodyKindReturnI32ConstPrefix}{returnExpr}",
                                                     "lowering_statement_call_return_expr")
    if IsErr(constRes):
        return false
    value = Value(constRes)
    return true

fn LoweringLowUirStatements(fnIr: PrimaryObjectIrFunction,
                             returnExprRaw: str): lowuir.LowUirStatement[] =
    var out: lowuir.LowUirStatement[]
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if !LoweringStatementIsLowUirCall(stmt):
            continue
        let statementReturns = stmt.returnRoot ||
                               LoweringReturnExprMatchesCallStatement(returnExprRaw, stmt)
        var resultType = stmt.resultType
        if Len(resultType) <= 0 && statementReturns:
            resultType = fnIr.returnType
        var lowStmt: lowuir.LowUirStatement
        lowStmt.kind = stmt.kind
        lowStmt.callTarget = stmt.callTarget
        lowStmt.callArgsText = stmt.callArgsText
        lowStmt.bindingName = stmt.bindingName
        lowStmt.resultType = resultType
        lowStmt.returnRoot = statementReturns
        add(out, lowStmt)
    return out

fn LoweringSyncCallSequenceFromBodyIr(fnIr: var PrimaryObjectIrFunction,
                                       sourceTexts: texpr.TypedExprSourceText[]): bool =
    LoweringClearStructuredCallSequence(fnIr)
    var callOrdinal: int32
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if !LoweringStatementIsLowUirCall(stmt):
            continue
        if callOrdinal < 0 || callOrdinal >= fnIr.bodyIR.callSequence.len:
            return false
        let bodyCall = fnIr.bodyIR.callSequence[callOrdinal]
        var callOp: PrimaryObjectIrCallOp
        callOp.targetSymbol = stmt.callTarget
        callOp.targetSourcePath = stmt.callTargetSourcePath
        callOp.importc = stmt.callTargetImportc
        callOp.importcSymbol = LoweringStatementImportcSymbol(stmt, sourceTexts)
        callOp.argCount = stmt.callArgCount
        callOp.argsText = stmt.callArgsText
        callOp.resultType = stmt.resultType
        callOp.bindingName = stmt.bindingName
        callOp.resultSlot = bodyCall.resultSlot
        callOp.relocWordOffset = bodyCall.relocWordOffset
        callOp.argSlots = bodyCall.argSlots
        add(fnIr.callSequence, callOp)
        add(fnIr.callArgCounts, stmt.callArgCount)
        add(fnIr.callTargets, stmt.callTarget)
        add(fnIr.callTargetSourcePaths, stmt.callTargetSourcePath)
        add(fnIr.callTargetImportcFlags, stmt.callTargetImportc)
        add(fnIr.callImportcSymbols, callOp.importcSymbol)
        callOrdinal = callOrdinal + 1
    if callOrdinal != fnIr.bodyIR.callSequence.len:
        return false
    fnIr.callTargetCount = fnIr.callSequence.len
    return true

fn LoweringPopulateLowUirCalls(fnIr: var PrimaryObjectIrFunction,
                                sourceTexts: texpr.TypedExprSourceText[],
                                returnExprRaw: str): bool =
    let lowStmts = LoweringLowUirStatements(fnIr, returnExprRaw)
    var bodyIR: coreir.BodyIR
    let buildRes = lowuir.LowUirTryBuildCallsFromStatements(bodyIR,
                                                            lowStmts,
                                                            lowStmts.len,
                                                            fnIr.paramSlots,
                                                            fnIr.paramNames)
    if buildRes != lowuir.LowUirBuildOk:
        return false
    fnIr.bodyIR = bodyIR
    return LoweringSyncCallSequenceFromBodyIr(fnIr, sourceTexts)

fn LoweringEnsureLocalDeclSlots(fnIr: var PrimaryObjectIrFunction) =
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind != texpr.TypedExprIrStmtLocalDecl:
            continue
        let _ = LoweringBodyIrEnsureLocalSlot(fnIr,
                                              stmt.bindingName,
                                              stmt.resultType)

fn LoweringLocalDeclConstI32Value(stmt: PrimaryObjectIrStatement,
                                   value: var int32): bool =
    value = 0
    let typeText = texpr.TypedExprNormalizeTypeText(stmt.resultType)
    let exprText = chengpath.PathTrim(stmt.surfaceText)
    if exprText == "":
        return typeText == "int32" || typeText == "bool"
    if typeText == "bool":
        if exprText == "true":
            value = 1
            return true
        if exprText == "false":
            value = 0
            return true
        return false
    if typeText != "int32":
        return false
    if !texpr.TypedExprIrIsI32ConstLiteral(exprText):
        return false
    let constRes = bkind.BodyKindParseReturnI32Const(Fmt"{texpr.BodyKindReturnI32ConstPrefix}{exprText}",
                                                     "lowering_local_decl_const_i32")
    if IsErr(constRes):
        return false
    value = Value(constRes)
    return true

fn LoweringAppendBodyIrLoadConst(fnIr: var PrimaryObjectIrFunction,
                                  slotIndex: int32,
                                  value: int32) =
    if slotIndex < 0 || slotIndex >= fnIr.bodyIR.localSlots.len:
        return
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpLoadConstTag
    op.target = slotIndex
    add(op.operands, coreir.LocalI32Tag)
    add(op.operands, value)
    add(fnIr.bodyIR.ops, op)

fn LoweringAppendLocalDeclInitOps(fnIr: var PrimaryObjectIrFunction) =
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind != texpr.TypedExprIrStmtLocalDecl:
            continue
        let slotIndex = LoweringBodyIrLocalSlotIndex(fnIr, stmt.bindingName)
        if slotIndex < 0:
            continue
        var value: int32
        if !LoweringLocalDeclConstI32Value(stmt, value):
            continue
        LoweringAppendBodyIrLoadConst(fnIr, slotIndex, value)

fn LoweringConstValueNone(): int32 =
    return 0

fn LoweringConstValueI32(): int32 =
    return 1

fn LoweringConstValueBool(): int32 =
    return 2

fn LoweringConstValueStr(): int32 =
    return 3

fn LoweringConstValueBytes(): int32 =
    return 4

fn LoweringConstValueSeqI32(): int32 =
    return 5

fn LoweringConstValueResultI32(): int32 =
    return 6

fn LoweringConstBindingValueKind(binding: LoweringConstBinding): int32 =
    if binding.valueKind != LoweringConstValueNone():
        return binding.valueKind
    if binding.hasI32:
        return LoweringConstValueI32()
    if binding.hasField:
        return LoweringConstValueNone()
    return LoweringConstValueNone()

fn LoweringConstBindingIndex(bindings: LoweringConstBinding[],
                              nameRaw: str): int32 =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return -1
    for i in 0..<bindings.len:
        if bindings[i].name == name:
            return i
    return -1

fn LoweringConstSetI32(bindings: var LoweringConstBinding[],
                        nameRaw: str,
                        value: int32) =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return
    let existing = LoweringConstBindingIndex(bindings, name)
    var binding: LoweringConstBinding
    if existing >= 0:
        binding = bindings[existing]
    binding.name = name
    binding.typeText = "int32"
    binding.valueKind = LoweringConstValueI32()
    binding.hasI32 = true
    binding.i32Value = value
    binding.textValue = ""
    binding.seqValues = []
    binding.resultOk = false
    binding.resultValue = 0
    binding.resultError = ""
    binding.hasField = false
    binding.fieldName = ""
    binding.fieldValue = 0
    if existing >= 0:
        bindings[existing] = binding
    else:
        add(bindings, binding)

fn LoweringConstSetObjectField(bindings: var LoweringConstBinding[],
                                nameRaw: str,
                                typeTextRaw: str,
                                fieldNameRaw: str,
                                value: int32) =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    let fieldName = parser.ParserIdentPrefix(chengpath.PathTrim(fieldNameRaw))
    if name == "" || fieldName == "":
        return
    let existing = LoweringConstBindingIndex(bindings, name)
    var binding: LoweringConstBinding
    if existing >= 0:
        binding = bindings[existing]
    binding.name = name
    binding.typeText = texpr.TypedExprNormalizeTypeText(typeTextRaw)
    binding.valueKind = LoweringConstValueNone()
    binding.hasI32 = false
    binding.i32Value = 0
    binding.textValue = ""
    binding.seqValues = []
    binding.resultOk = false
    binding.resultValue = 0
    binding.resultError = ""
    binding.hasField = true
    binding.fieldName = fieldName
    binding.fieldValue = value
    if existing >= 0:
        bindings[existing] = binding
    else:
        add(bindings, binding)

fn LoweringConstSetBool(bindings: var LoweringConstBinding[],
                         nameRaw: str,
                         value: bool) =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return
    let existing = LoweringConstBindingIndex(bindings, name)
    var binding: LoweringConstBinding
    if existing >= 0:
        binding = bindings[existing]
    binding.name = name
    binding.typeText = "bool"
    binding.valueKind = LoweringConstValueBool()
    binding.hasI32 = true
    if value:
        binding.i32Value = 1
    else:
        binding.i32Value = 0
    binding.textValue = ""
    binding.seqValues = []
    binding.resultOk = false
    binding.resultValue = 0
    binding.resultError = ""
    binding.hasField = false
    binding.fieldName = ""
    binding.fieldValue = 0
    if existing >= 0:
        bindings[existing] = binding
    else:
        add(bindings, binding)

fn LoweringConstSetTextValue(bindings: var LoweringConstBinding[],
                              nameRaw: str,
                              typeTextRaw: str,
                              kind: int32,
                              value: str) =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return
    let existing = LoweringConstBindingIndex(bindings, name)
    var binding: LoweringConstBinding
    if existing >= 0:
        binding = bindings[existing]
    binding.name = name
    binding.typeText = texpr.TypedExprNormalizeTypeText(typeTextRaw)
    binding.valueKind = kind
    binding.hasI32 = false
    binding.i32Value = 0
    binding.textValue = value
    binding.seqValues = []
    binding.resultOk = false
    binding.resultValue = 0
    binding.resultError = ""
    binding.hasField = false
    binding.fieldName = ""
    binding.fieldValue = 0
    if existing >= 0:
        bindings[existing] = binding
    else:
        add(bindings, binding)

fn LoweringConstSetSeqI32(bindings: var LoweringConstBinding[],
                           nameRaw: str,
                           values: int32[]) =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return
    let existing = LoweringConstBindingIndex(bindings, name)
    var binding: LoweringConstBinding
    if existing >= 0:
        binding = bindings[existing]
    binding.name = name
    binding.typeText = "int32[]"
    binding.valueKind = LoweringConstValueSeqI32()
    binding.hasI32 = false
    binding.i32Value = 0
    binding.textValue = ""
    binding.seqValues = values
    binding.resultOk = false
    binding.resultValue = 0
    binding.resultError = ""
    binding.hasField = false
    binding.fieldName = ""
    binding.fieldValue = 0
    if existing >= 0:
        bindings[existing] = binding
    else:
        add(bindings, binding)

fn LoweringConstSetResultI32(bindings: var LoweringConstBinding[],
                              nameRaw: str,
                              ok: bool,
                              resultValue: int32,
                              resultError: str) =
    let name = parser.ParserIdentPrefix(chengpath.PathTrim(nameRaw))
    if name == "":
        return
    let existing = LoweringConstBindingIndex(bindings, name)
    var binding: LoweringConstBinding
    if existing >= 0:
        binding = bindings[existing]
    binding.name = name
    binding.typeText = "Result[int32]"
    binding.valueKind = LoweringConstValueResultI32()
    binding.hasI32 = false
    binding.i32Value = 0
    binding.textValue = ""
    binding.seqValues = []
    binding.resultOk = ok
    binding.resultValue = resultValue
    binding.resultError = resultError
    binding.hasField = false
    binding.fieldName = ""
    binding.fieldValue = 0
    if existing >= 0:
        bindings[existing] = binding
    else:
        add(bindings, binding)

fn LoweringConstLookupI32(bindings: LoweringConstBinding[],
                           nameRaw: str,
                           value: var int32): bool =
    let index = LoweringConstBindingIndex(bindings, nameRaw)
    if index < 0 || index >= bindings.len:
        return false
    let binding = bindings[index]
    if !binding.hasI32:
        return false
    value = binding.i32Value
    return true

fn LoweringConstLookupObjectField(bindings: LoweringConstBinding[],
                                   rootRaw: str,
                                   fieldRaw: str,
                                   value: var int32): bool =
    let index = LoweringConstBindingIndex(bindings, rootRaw)
    if index < 0 || index >= bindings.len:
        return false
    let binding = bindings[index]
    let fieldName = parser.ParserIdentPrefix(chengpath.PathTrim(fieldRaw))
    if !binding.hasField || fieldName == "" || binding.fieldName != fieldName:
        return false
    value = binding.fieldValue
    return true

fn LoweringConstValueSetI32(out: var LoweringConstBinding,
                             value: int32) =
    out.valueKind = LoweringConstValueI32()
    out.hasI32 = true
    out.i32Value = value
    out.textValue = ""
    out.seqValues = []
    out.resultOk = false
    out.resultValue = 0
    out.resultError = ""
    out.hasField = false
    out.fieldName = ""
    out.fieldValue = 0

fn LoweringConstValueSetBool(out: var LoweringConstBinding,
                              value: bool) =
    out.valueKind = LoweringConstValueBool()
    out.hasI32 = true
    if value:
        out.i32Value = 1
    else:
        out.i32Value = 0
    out.textValue = ""
    out.seqValues = []
    out.resultOk = false
    out.resultValue = 0
    out.resultError = ""
    out.hasField = false
    out.fieldName = ""
    out.fieldValue = 0

fn LoweringConstValueSetText(out: var LoweringConstBinding,
                              kind: int32,
                              value: str) =
    out.valueKind = kind
    out.hasI32 = false
    out.i32Value = 0
    out.textValue = value
    out.seqValues = []
    out.resultOk = false
    out.resultValue = 0
    out.resultError = ""
    out.hasField = false
    out.fieldName = ""
    out.fieldValue = 0

fn LoweringConstValueSetSeq(out: var LoweringConstBinding,
                             values: int32[]) =
    out.valueKind = LoweringConstValueSeqI32()
    out.hasI32 = false
    out.i32Value = 0
    out.textValue = ""
    out.seqValues = values
    out.resultOk = false
    out.resultValue = 0
    out.resultError = ""
    out.hasField = false
    out.fieldName = ""
    out.fieldValue = 0

fn LoweringConstValueSetResult(out: var LoweringConstBinding,
                                ok: bool,
                                resultValue: int32,
                                resultError: str) =
    out.valueKind = LoweringConstValueResultI32()
    out.hasI32 = false
    out.i32Value = 0
    out.textValue = ""
    out.seqValues = []
    out.resultOk = ok
    out.resultValue = resultValue
    out.resultError = resultError
    out.hasField = false
    out.fieldName = ""
    out.fieldValue = 0

fn LoweringConstLookupValue(bindings: LoweringConstBinding[],
                             nameRaw: str,
                             value: var LoweringConstBinding): bool =
    let index = LoweringConstBindingIndex(bindings, nameRaw)
    if index < 0 || index >= bindings.len:
        return false
    value = bindings[index]
    return LoweringConstBindingValueKind(value) != LoweringConstValueNone() ||
           value.hasField

fn LoweringConstSetValue(bindings: var LoweringConstBinding[],
                          nameRaw: str,
                          value: LoweringConstBinding) =
    let kind = LoweringConstBindingValueKind(value)
    if kind == LoweringConstValueI32():
        LoweringConstSetI32(bindings, nameRaw, value.i32Value)
    elif kind == LoweringConstValueBool():
        LoweringConstSetBool(bindings, nameRaw, value.i32Value != 0)
    elif kind == LoweringConstValueStr():
        LoweringConstSetTextValue(bindings, nameRaw, "str", kind, value.textValue)
    elif kind == LoweringConstValueBytes():
        LoweringConstSetTextValue(bindings, nameRaw, "Bytes", kind, value.textValue)
    elif kind == LoweringConstValueSeqI32():
        LoweringConstSetSeqI32(bindings, nameRaw, value.seqValues)
    elif kind == LoweringConstValueResultI32():
        LoweringConstSetResultI32(bindings,
                                  nameRaw,
                                  value.resultOk,
                                  value.resultValue,
                                  value.resultError)

fn LoweringConstStringLiteral(expr: str,
                               out: var str): bool =
    out = ""
    if Len(expr) < 2:
        return false
    if expr[0] != Char(34) || expr[Len(expr) - 1] != Char(34):
        return false
    out = chengpath.TextSlice(expr, 1, Len(expr) - 2)
    return true

fn LoweringConstCharLiteralValue(expr: str,
                                  out: var int32): bool =
    out = 0
    if Len(expr) < 3:
        return false
    if expr[0] != Char(39) || expr[Len(expr) - 1] != Char(39):
        return false
    out = int32(expr[1])
    return true

fn LoweringConstIndexOpen(expr: str): int32 =
    for i in 0..<Len(expr):
        if expr[i] != '[':
            continue
        let closePos = texpr.TypedExprFindMatchingBracket(expr, i)
        if closePos == Len(expr) - 1:
            return i
    return -1

fn LoweringConstEvalValue(bindings: LoweringConstBinding[],
                           exprRaw: str,
                           value: var LoweringConstBinding): bool

fn LoweringConstParseI32Literal(exprRaw: str,
                                 value: var int32): bool =
    let expr = chengpath.PathTrim(exprRaw)
    if expr == "true":
        value = 1
        return true
    if expr == "false":
        value = 0
        return true
    if !texpr.TypedExprIrIsI32ConstLiteral(expr):
        return false
    let constRes = bkind.BodyKindParseReturnI32Const(Fmt"{texpr.BodyKindReturnI32ConstPrefix}{expr}",
                                                     "lowering_const_i32_literal")
    if IsErr(constRes):
        return false
    value = Value(constRes)
    return true

fn LoweringConstEvalI32(bindings: LoweringConstBinding[],
                         exprRaw: str,
                         value: var int32): bool =
    let expr = chengpath.PathTrim(exprRaw)
    if expr == "":
        return false
    if LoweringConstParseI32Literal(expr, value):
        return true
    if LoweringConstCharLiteralValue(expr, value):
        return true
    let plusPos = texpr.TypedExprFindTopLevelToken(expr, "+")
    if plusPos > 0:
        var lhsValue: int32
        var rhsValue: int32
        if !LoweringConstEvalI32(bindings,
                                 chengpath.TextSlice(expr, 0, plusPos),
                                 lhsValue):
            return false
        if !LoweringConstEvalI32(bindings,
                                 chengpath.TextSlice(expr,
                                                     plusPos + 1,
                                                     expr.len - plusPos - 1),
                                 rhsValue):
            return false
        value = lhsValue + rhsValue
        return true
    let minusPos = texpr.TypedExprFindTopLevelToken(expr, "-")
    if minusPos > 0:
        var lhsValue: int32
        var rhsValue: int32
        if !LoweringConstEvalI32(bindings,
                                 chengpath.TextSlice(expr, 0, minusPos),
                                 lhsValue):
            return false
        if !LoweringConstEvalI32(bindings,
                                 chengpath.TextSlice(expr,
                                                     minusPos + 1,
                                                     expr.len - minusPos - 1),
                                 rhsValue):
            return false
        value = lhsValue - rhsValue
        return true
    var atomValue: LoweringConstBinding
    if LoweringConstEvalValue(bindings, expr, atomValue):
        let atomKind = LoweringConstBindingValueKind(atomValue)
        if atomKind == LoweringConstValueI32() ||
           atomKind == LoweringConstValueBool():
            value = atomValue.i32Value
            return true
    let dotPos = parser.ParserFindText(expr, ".")
    if dotPos > 0 && dotPos + 1 < expr.len:
        return LoweringConstLookupObjectField(bindings,
                                              chengpath.TextSlice(expr, 0, dotPos),
                                              chengpath.TextSlice(expr,
                                                                  dotPos + 1,
                                                                  expr.len - dotPos - 1),
                                              value)
    return LoweringConstLookupI32(bindings, expr, value)

fn LoweringConstEvalCallValue(bindings: LoweringConstBinding[],
                               calleeRaw: str,
                               argsText: str,
                               value: var LoweringConstBinding): bool =
    let callee = parser.ParserIdentPrefix(chengpath.PathTrim(calleeRaw))
    let args = texpr.TypedExprSplitTopLevelCsv(argsText)
    if callee == "int32":
        if args.len != 1:
            return false
        var intValue: int32
        if LoweringConstEvalI32(bindings, args[0], intValue):
            LoweringConstValueSetI32(value, intValue)
            return true
        return false
    if callee == "bytesFromString":
        if args.len != 1:
            return false
        var argValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, args[0], argValue):
            return false
        if LoweringConstBindingValueKind(argValue) != LoweringConstValueStr():
            return false
        LoweringConstValueSetText(value, LoweringConstValueBytes(), argValue.textValue)
        return true
    if callee == "bytesSlice" || callee == "BytesSlice":
        if args.len != 3:
            return false
        var bytesValue: LoweringConstBinding
        var startValue: int32
        var countValue: int32
        if !LoweringConstEvalValue(bindings, args[0], bytesValue):
            return false
        if LoweringConstBindingValueKind(bytesValue) != LoweringConstValueBytes():
            return false
        if !LoweringConstEvalI32(bindings, args[1], startValue):
            return false
        if !LoweringConstEvalI32(bindings, args[2], countValue):
            return false
        if countValue <= 0 || startValue < 0 || startValue >= Len(bytesValue.textValue):
            LoweringConstValueSetText(value, LoweringConstValueBytes(), "")
            return true
        var n = countValue
        if startValue + n > Len(bytesValue.textValue):
            n = Len(bytesValue.textValue) - startValue
        if n <= 0:
            LoweringConstValueSetText(value, LoweringConstValueBytes(), "")
            return true
        LoweringConstValueSetText(value,
                                  LoweringConstValueBytes(),
                                  chengpath.TextSlice(bytesValue.textValue, startValue, n))
        return true
    if callee == "bytesLen" || callee == "BytesLen":
        if args.len != 1:
            return false
        var bytesValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, args[0], bytesValue):
            return false
        if LoweringConstBindingValueKind(bytesValue) != LoweringConstValueBytes():
            return false
        LoweringConstValueSetI32(value, Len(bytesValue.textValue))
        return true
    if callee == "bytesGet" || callee == "BytesGet":
        if args.len != 2:
            return false
        var bytesValue: LoweringConstBinding
        var indexValue: int32
        if !LoweringConstEvalValue(bindings, args[0], bytesValue):
            return false
        if LoweringConstBindingValueKind(bytesValue) != LoweringConstValueBytes():
            return false
        if !LoweringConstEvalI32(bindings, args[1], indexValue):
            return false
        if indexValue < 0 || indexValue >= Len(bytesValue.textValue):
            LoweringConstValueSetI32(value, 0)
        else:
            LoweringConstValueSetI32(value, int32(bytesValue.textValue[indexValue]))
        return true
    if callee == "textLen":
        if args.len != 1:
            return false
        var textValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, args[0], textValue):
            return false
        if LoweringConstBindingValueKind(textValue) != LoweringConstValueStr():
            return false
        LoweringConstValueSetI32(value, Len(textValue.textValue))
        return true
    if callee == "seqLen":
        if args.len != 1:
            return false
        var seqValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, args[0], seqValue):
            return false
        if LoweringConstBindingValueKind(seqValue) != LoweringConstValueSeqI32():
            return false
        LoweringConstValueSetI32(value, seqValue.seqValues.len)
        return true
    if callee == "resultOk":
        if args.len != 1:
            return false
        var resultValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, args[0], resultValue):
            return false
        if LoweringConstBindingValueKind(resultValue) != LoweringConstValueResultI32():
            return false
        LoweringConstValueSetBool(value, resultValue.resultOk)
        return true
    if callee == "resultValue":
        if args.len != 1:
            return false
        var resultValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, args[0], resultValue):
            return false
        if LoweringConstBindingValueKind(resultValue) != LoweringConstValueResultI32():
            return false
        if !resultValue.resultOk:
            return false
        LoweringConstValueSetI32(value, resultValue.resultValue)
        return true
    if callee == "echoBytes" ||
       callee == "echoText" ||
       callee == "echoSeq" ||
       callee == "echoResult":
        if args.len != 1:
            return false
        return LoweringConstEvalValue(bindings, args[0], value)
    if callee == "Ok":
        if args.len != 1:
            return false
        var okValue: int32
        if !LoweringConstEvalI32(bindings, args[0], okValue):
            return false
        LoweringConstValueSetResult(value, true, okValue, "")
        return true
    if callee == "Err":
        if args.len != 1:
            return false
        var errValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, args[0], errValue):
            return false
        if LoweringConstBindingValueKind(errValue) != LoweringConstValueStr():
            return false
        LoweringConstValueSetResult(value, false, 0, errValue.textValue)
        return true
    if callee == "Error":
        if args.len != 1:
            return false
        var resultValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, args[0], resultValue):
            return false
        if LoweringConstBindingValueKind(resultValue) != LoweringConstValueResultI32():
            return false
        if resultValue.resultOk:
            return false
        LoweringConstValueSetText(value, LoweringConstValueStr(), resultValue.resultError)
        return true
    return false

fn LoweringConstEvalIndexValue(bindings: LoweringConstBinding[],
                                expr: str,
                                openPos: int32,
                                value: var LoweringConstBinding): bool =
    if openPos <= 0 || openPos >= Len(expr):
        return false
    let rootText = chengpath.TextSlice(expr, 0, openPos)
    let indexText = chengpath.TextSlice(expr, openPos + 1, Len(expr) - openPos - 2)
    var rootValue: LoweringConstBinding
    var indexValue: int32
    if !LoweringConstEvalValue(bindings, rootText, rootValue):
        return false
    if !LoweringConstEvalI32(bindings, indexText, indexValue):
        return false
    let rootKind = LoweringConstBindingValueKind(rootValue)
    if rootKind == LoweringConstValueStr() ||
       rootKind == LoweringConstValueBytes():
        if indexValue < 0 || indexValue >= Len(rootValue.textValue):
            return false
        LoweringConstValueSetI32(value, int32(rootValue.textValue[indexValue]))
        return true
    if rootKind == LoweringConstValueSeqI32():
        if indexValue < 0 || indexValue >= rootValue.seqValues.len:
            return false
        LoweringConstValueSetI32(value, rootValue.seqValues[indexValue])
        return true
    return false

fn LoweringConstEvalValue(bindings: LoweringConstBinding[],
                           exprRaw: str,
                           value: var LoweringConstBinding): bool =
    let expr = chengpath.PathTrim(exprRaw)
    if expr == "":
        return false
    var textLiteral = ""
    if LoweringConstStringLiteral(expr, textLiteral):
        LoweringConstValueSetText(value, LoweringConstValueStr(), textLiteral)
        return true
    if expr == "true":
        LoweringConstValueSetBool(value, true)
        return true
    if expr == "false":
        LoweringConstValueSetBool(value, false)
        return true
    if expr == "[]":
        var emptySeq: int32[]
        LoweringConstValueSetSeq(value, emptySeq)
        return true
    var charValue: int32
    if LoweringConstCharLiteralValue(expr, charValue):
        LoweringConstValueSetI32(value, charValue)
        return true
    let indexOpen = LoweringConstIndexOpen(expr)
    if indexOpen > 0:
        return LoweringConstEvalIndexValue(bindings, expr, indexOpen, value)
    let openPos = parser.ParserFindText(expr, "(")
    if openPos > 0:
        let closePos = texpr.TypedExprFindMatchingParen(expr, openPos)
        if closePos == Len(expr) - 1:
            return LoweringConstEvalCallValue(bindings,
                                              chengpath.TextSlice(expr, 0, openPos),
                                              chengpath.TextSlice(expr,
                                                                  openPos + 1,
                                                                  closePos - openPos - 1),
                                              value)
    let dotPos = parser.ParserFindText(expr, ".")
    if dotPos > 0 && dotPos + 1 < Len(expr):
        let rootText = chengpath.TextSlice(expr, 0, dotPos)
        let fieldName = parser.ParserIdentPrefix(chengpath.TextSlice(expr,
                                                                      dotPos + 1,
                                                                      Len(expr) - dotPos - 1))
        var rootValue: LoweringConstBinding
        if !LoweringConstEvalValue(bindings, rootText, rootValue):
            return false
        let rootKind = LoweringConstBindingValueKind(rootValue)
        if rootKind == LoweringConstValueResultI32():
            if fieldName == "ok":
                LoweringConstValueSetBool(value, rootValue.resultOk)
                return true
            if fieldName == "value":
                if !rootValue.resultOk:
                    return false
                LoweringConstValueSetI32(value, rootValue.resultValue)
                return true
        if rootValue.hasField:
            var fieldValue: int32
            if LoweringConstLookupObjectField(bindings, rootText, fieldName, fieldValue):
                LoweringConstValueSetI32(value, fieldValue)
                return true
        return false
    var intValue: int32
    if LoweringConstParseI32Literal(expr, intValue):
        LoweringConstValueSetI32(value, intValue)
        return true
    if LoweringConstLookupValue(bindings, expr, value):
        return true
    return false

fn LoweringConstEvalBool(bindings: LoweringConstBinding[],
                          exprRaw: str,
                          value: var bool): bool =
    let expr = chengpath.PathTrim(exprRaw)
    if expr == "true":
        value = true
        return true
    if expr == "false":
        value = false
        return true
    if expr.len > 1 && expr[0] == '!':
        var inner: bool
        if !LoweringConstEvalBool(bindings,
                                  chengpath.TextSlice(expr, 1, expr.len - 1),
                                  inner):
            return false
        value = !inner
        return true
    var op = ""
    var opPos = texpr.TypedExprFindTopLevelTextToken(expr, "==")
    if opPos >= 0:
        op = "=="
    if opPos < 0:
        opPos = texpr.TypedExprFindTopLevelTextToken(expr, "!=")
        if opPos >= 0:
            op = "!="
    if opPos < 0:
        opPos = texpr.TypedExprFindTopLevelTextToken(expr, "<=")
        if opPos >= 0:
            op = "<="
    if opPos < 0:
        opPos = texpr.TypedExprFindTopLevelTextToken(expr, ">=")
        if opPos >= 0:
            op = ">="
    if opPos < 0:
        opPos = texpr.TypedExprFindTopLevelToken(expr, "<")
        if opPos >= 0:
            op = "<"
    if opPos < 0:
        opPos = texpr.TypedExprFindTopLevelToken(expr, ">")
        if opPos >= 0:
            op = ">"
    if opPos >= 0 && op != "":
        let rhsStart = opPos + op.len
        if op == "==" || op == "!=":
            var lhsConst: LoweringConstBinding
            var rhsConst: LoweringConstBinding
            if LoweringConstEvalValue(bindings,
                                      chengpath.TextSlice(expr, 0, opPos),
                                      lhsConst) &&
               LoweringConstEvalValue(bindings,
                                      chengpath.TextSlice(expr,
                                                          rhsStart,
                                                          expr.len - rhsStart),
                                      rhsConst):
                let lhsKind = LoweringConstBindingValueKind(lhsConst)
                let rhsKind = LoweringConstBindingValueKind(rhsConst)
                if (lhsKind == LoweringConstValueI32() ||
                    lhsKind == LoweringConstValueBool()) &&
                   (rhsKind == LoweringConstValueI32() ||
                    rhsKind == LoweringConstValueBool()):
                    value = lhsConst.i32Value == rhsConst.i32Value
                    if op == "!=":
                        value = !value
                    return true
                if lhsKind == rhsKind &&
                   (lhsKind == LoweringConstValueStr() ||
                    lhsKind == LoweringConstValueBytes()):
                    value = lhsConst.textValue == rhsConst.textValue
                    if op == "!=":
                        value = !value
                    return true
        var lhsValue: int32
        var rhsValue: int32
        if !LoweringConstEvalI32(bindings,
                                 chengpath.TextSlice(expr, 0, opPos),
                                 lhsValue):
            return false
        if !LoweringConstEvalI32(bindings,
                                 chengpath.TextSlice(expr,
                                                     rhsStart,
                                                     expr.len - rhsStart),
                                 rhsValue):
            return false
        if op == "==":
            value = lhsValue == rhsValue
        elif op == "!=":
            value = lhsValue != rhsValue
        elif op == "<=":
            value = lhsValue <= rhsValue
        elif op == ">=":
            value = lhsValue >= rhsValue
        elif op == "<":
            value = lhsValue < rhsValue
        else:
            value = lhsValue > rhsValue
        return true
    var intValue: int32
    if !LoweringConstEvalI32(bindings, expr, intValue):
        return false
    value = intValue != 0
    return true

fn LoweringConstEvalConstructor(bindings: LoweringConstBinding[],
                                 exprRaw: str,
                                 typeText: var str,
                                 fieldName: var str,
                                 fieldValue: var int32): bool =
    typeText = ""
    fieldName = ""
    fieldValue = 0
    let expr = chengpath.PathTrim(exprRaw)
    let openPos = parser.ParserFindText(expr, "(")
    if openPos <= 0:
        return false
    let closePos = texpr.TypedExprFindMatchingParen(expr, openPos)
    if closePos <= openPos || closePos + 1 != expr.len:
        return false
    typeText = texpr.TypedExprNormalizeTypeText(parser.ParserIdentPrefix(chengpath.TextSlice(expr,
                                                                                              0,
                                                                                              openPos)))
    if typeText == "":
        return false
    let argsText = chengpath.TextSlice(expr, openPos + 1, closePos - openPos - 1)
    let args = texpr.TypedExprSplitTopLevelCsv(argsText)
    if args.len != 1:
        return false
    let argText = chengpath.PathTrim(args[0])
    let colonPos = texpr.TypedExprFindTopLevelToken(argText, ":")
    if colonPos <= 0:
        return false
    fieldName = parser.ParserIdentPrefix(chengpath.TextSlice(argText, 0, colonPos))
    if fieldName == "":
        return false
    return LoweringConstEvalI32(bindings,
                                chengpath.TextSlice(argText,
                                                    colonPos + 1,
                                                    argText.len - colonPos - 1),
                                fieldValue)

fn LoweringConstExecLocalDecl(bindings: var LoweringConstBinding[],
                               stmt: PrimaryObjectIrStatement): bool =
    let typeText = texpr.TypedExprNormalizeTypeText(stmt.resultType)
    let exprText = chengpath.PathTrim(stmt.surfaceText)
    if exprText == "":
        if typeText == "int32" || typeText == "bool":
            var value: int32
            if LoweringLocalDeclConstI32Value(stmt, value):
                LoweringConstSetI32(bindings, stmt.bindingName, value)
                return true
        if typeText == "str":
            LoweringConstSetTextValue(bindings,
                                      stmt.bindingName,
                                      "str",
                                      LoweringConstValueStr(),
                                      "")
            return true
        if typeText == "Bytes":
            LoweringConstSetTextValue(bindings,
                                      stmt.bindingName,
                                      "Bytes",
                                      LoweringConstValueBytes(),
                                      "")
            return true
        if typeText == "int32[]":
            var emptySeq: int32[]
            LoweringConstSetSeqI32(bindings, stmt.bindingName, emptySeq)
            return true
        return false
    var constValue: LoweringConstBinding
    if LoweringConstEvalValue(bindings, exprText, constValue):
        LoweringConstSetValue(bindings, stmt.bindingName, constValue)
        return true
    var value: int32
    if LoweringLocalDeclConstI32Value(stmt, value):
        LoweringConstSetI32(bindings, stmt.bindingName, value)
        return true
    var constructorType = ""
    var fieldName = ""
    var fieldValue: int32
    if LoweringConstEvalConstructor(bindings,
                                    stmt.surfaceText,
                                    constructorType,
                                    fieldName,
                                    fieldValue):
        if typeText != "" && constructorType != typeText:
            return false
        LoweringConstSetObjectField(bindings,
                                    stmt.bindingName,
                                    constructorType,
                                    fieldName,
                                    fieldValue)
        return true
    return false

fn LoweringConstExecAssign(bindings: var LoweringConstBinding[],
                            stmt: PrimaryObjectIrStatement): bool =
    let lhs = chengpath.PathTrim(stmt.bindingName)
    if lhs == "":
        return false
    let dotPos = parser.ParserFindText(lhs, ".")
    if dotPos <= 0:
        var constValue: LoweringConstBinding
        if LoweringConstEvalValue(bindings, stmt.surfaceText, constValue):
            LoweringConstSetValue(bindings, lhs, constValue)
            return true
    var value: int32
    if !LoweringConstEvalI32(bindings, stmt.surfaceText, value):
        return false
    if dotPos > 0:
        let rootName = chengpath.TextSlice(lhs, 0, dotPos)
        let fieldName = chengpath.TextSlice(lhs, dotPos + 1, lhs.len - dotPos - 1)
        let index = LoweringConstBindingIndex(bindings, rootName)
        if index < 0 || index >= bindings.len:
            return false
        LoweringConstSetObjectField(bindings,
                                    rootName,
                                    bindings[index].typeText,
                                    fieldName,
                                    value)
        return true
    LoweringConstSetI32(bindings, lhs, value)
    return true

fn LoweringConstExecCall(bindings: var LoweringConstBinding[],
                          stmt: PrimaryObjectIrStatement): bool =
    let callee = parser.ParserIdentPrefix(chengpath.PathTrim(stmt.surfaceText))
    if callee == "add":
        let args = texpr.TypedExprSplitTopLevelCsv(stmt.callArgsText)
        if args.len != 2:
            return false
        var seqValue: LoweringConstBinding
        var itemValue: int32
        if !LoweringConstLookupValue(bindings, args[0], seqValue):
            return false
        if LoweringConstBindingValueKind(seqValue) != LoweringConstValueSeqI32():
            return false
        if !LoweringConstEvalI32(bindings, args[1], itemValue):
            return false
        add(seqValue.seqValues, itemValue)
        LoweringConstSetSeqI32(bindings, args[0], seqValue.seqValues)
        return true
    if stmt.kind == texpr.TypedExprIrStmtLetCall ||
       stmt.kind == texpr.TypedExprIrStmtResultIntrinsic:
        if stmt.bindingName == "":
            return false
        var callValue: LoweringConstBinding
        let callText = Fmt"{stmt.surfaceText}({stmt.callArgsText})"
        if !LoweringConstEvalValue(bindings, callText, callValue):
            return false
        LoweringConstSetValue(bindings, stmt.bindingName, callValue)
        return true
    if stmt.kind == texpr.TypedExprIrStmtCall && stmt.returnRoot:
        return false
    return true

fn LoweringConstMaxStatementLine(fnIr: PrimaryObjectIrFunction): int32 =
    var maxLine: int32
    for i in 0..<fnIr.statements.len:
        if fnIr.statements[i].lineNumber > maxLine:
            maxLine = fnIr.statements[i].lineNumber
    return maxLine

fn LoweringConstBlockIndent(fnIr: PrimaryObjectIrFunction,
                             startLine: int32,
                             endLine: int32,
                             parentIndent: int32): int32 =
    var out: int32 = -1
    for i in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[i]
        if stmt.lineNumber < startLine || stmt.lineNumber >= endLine:
            continue
        if stmt.lineIndent <= parentIndent:
            continue
        if out < 0 || stmt.lineIndent < out:
            out = stmt.lineIndent
    return out

fn LoweringConstFindNextStatement(fnIr: PrimaryObjectIrFunction,
                                   startLine: int32,
                                   endLine: int32,
                                   indent: int32): int32 =
    var bestIndex: int32 = -1
    var bestLine: int32 = 2147483647
    var bestPriority: int32 = 2147483647
    for i in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[i]
        if stmt.lineNumber < startLine || stmt.lineNumber >= endLine:
            continue
        if stmt.lineIndent != indent:
            continue
        var priority: int32 = 20
        if stmt.kind == texpr.TypedExprIrStmtIf ||
           stmt.kind == texpr.TypedExprIrStmtElif ||
           stmt.kind == texpr.TypedExprIrStmtElse ||
           stmt.kind == texpr.TypedExprIrStmtFor:
            priority = 0
        elif stmt.kind == texpr.TypedExprIrStmtLocalDecl ||
             stmt.kind == texpr.TypedExprIrStmtAssign ||
             stmt.kind == texpr.TypedExprIrStmtReturn:
            priority = 1
        if stmt.lineNumber < bestLine ||
           (stmt.lineNumber == bestLine && priority < bestPriority):
            bestLine = stmt.lineNumber
            bestIndex = i
            bestPriority = priority
    return bestIndex

fn LoweringConstFindStatementAtLineIndent(fnIr: PrimaryObjectIrFunction,
                                           lineNumber: int32,
                                           indent: int32): int32 =
    for i in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[i]
        if stmt.lineNumber == lineNumber && stmt.lineIndent == indent:
            return i
    return -1

fn LoweringConstNextLineAtOrBelowIndent(fnIr: PrimaryObjectIrFunction,
                                         startLine: int32,
                                         endLine: int32,
                                         indent: int32): int32 =
    var bestLine = endLine
    for i in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[i]
        if stmt.lineNumber < startLine || stmt.lineNumber >= endLine:
            continue
        if stmt.lineIndent <= indent && stmt.lineNumber < bestLine:
            bestLine = stmt.lineNumber
    return bestLine

fn LoweringConstStmtIsIfChainKind(stmt: PrimaryObjectIrStatement): bool =
    return stmt.kind == texpr.TypedExprIrStmtElif ||
           stmt.kind == texpr.TypedExprIrStmtElse

fn LoweringConstSingleFieldConstructorType(exprRaw: str): str =
    let expr = chengpath.PathTrim(exprRaw)
    let openPos = parser.ParserFindText(expr, "(")
    if openPos <= 0:
        return ""
    let closePos = texpr.TypedExprFindMatchingParen(expr, openPos)
    if closePos <= openPos || closePos + 1 != expr.len:
        return ""
    let typeText = texpr.TypedExprNormalizeTypeText(parser.ParserIdentPrefix(chengpath.TextSlice(expr,
                                                                                                  0,
                                                                                                  openPos)))
    if typeText == "":
        return ""
    let argsText = chengpath.TextSlice(expr, openPos + 1, closePos - openPos - 1)
    let args = texpr.TypedExprSplitTopLevelCsv(argsText)
    if args.len != 1:
        return ""
    if texpr.TypedExprFindTopLevelToken(args[0], ":") <= 0:
        return ""
    return typeText

fn LoweringConstStatementIsSyntheticConstructorCall(fnIr: PrimaryObjectIrFunction,
                                                     stmt: PrimaryObjectIrStatement): bool =
    if stmt.kind != texpr.TypedExprIrStmtCall &&
       stmt.kind != texpr.TypedExprIrStmtLetCall &&
       stmt.kind != texpr.TypedExprIrStmtIfCall:
        return false
    let calleeTail = LoweringFunctionTailName(stmt.surfaceText)
    let targetTail = LoweringFunctionTailName(stmt.callTarget)
    if calleeTail == "" && targetTail == "":
        return false
    for i in 0..<fnIr.statements.len:
        let localStmt = fnIr.statements[i]
        if localStmt.kind != texpr.TypedExprIrStmtLocalDecl:
            continue
        if localStmt.lineNumber != stmt.lineNumber:
            continue
        if stmt.bindingName != "" && localStmt.bindingName != stmt.bindingName:
            continue
        let constructorType = LoweringConstSingleFieldConstructorType(localStmt.surfaceText)
        if constructorType == "":
            continue
        let constructorTail = LoweringFunctionTailName(constructorType)
        if calleeTail == constructorTail || targetTail == constructorTail:
            return true
    return false

fn LoweringConstExecuteBlock(fnIr: PrimaryObjectIrFunction,
                              bindings: var LoweringConstBinding[],
                              startLine: int32,
                              endLine: int32,
                              parentIndent: int32,
                              returned: var bool,
                              returnValue: var int32): bool

fn LoweringConstExecIfChain(fnIr: PrimaryObjectIrFunction,
                             bindings: var LoweringConstBinding[],
                             firstStmt: PrimaryObjectIrStatement,
                             endLine: int32,
                             returned: var bool,
                             returnValue: var int32,
                             chainEndLine: var int32): bool =
    let indent = firstStmt.lineIndent
    var currentStmt = firstStmt
    var branchTaken = false
    chainEndLine = firstStmt.lineNumber + 1
    while true:
        let bodyStart = currentStmt.lineNumber + 1
        let bodyEnd = LoweringConstNextLineAtOrBelowIndent(fnIr,
                                                           bodyStart,
                                                           endLine,
                                                           indent)
        var takeBranch = false
        if currentStmt.kind == texpr.TypedExprIrStmtElse:
            takeBranch = true
        else:
            if currentStmt.kind != texpr.TypedExprIrStmtIf &&
               currentStmt.kind != texpr.TypedExprIrStmtElif:
                return false
            if !LoweringConstEvalBool(bindings, currentStmt.surfaceText, takeBranch):
                return false
        if !branchTaken && takeBranch:
            if !LoweringConstExecuteBlock(fnIr,
                                          bindings,
                                          bodyStart,
                                          bodyEnd,
                                          indent,
                                          returned,
                                          returnValue):
                return false
            branchTaken = true
            if returned:
                chainEndLine = bodyEnd
                return true
        chainEndLine = bodyEnd
        if bodyEnd >= endLine:
            return true
        let nextIndex = LoweringConstFindStatementAtLineIndent(fnIr,
                                                               bodyEnd,
                                                               indent)
        if nextIndex < 0 || nextIndex >= fnIr.statements.len:
            return true
        let nextStmt = fnIr.statements[nextIndex]
        if !LoweringConstStmtIsIfChainKind(nextStmt):
            return true
        currentStmt = nextStmt

fn LoweringConstExecFor(fnIr: PrimaryObjectIrFunction,
                         bindings: var LoweringConstBinding[],
                         stmt: PrimaryObjectIrStatement,
                         endLine: int32,
                         returned: var bool,
                         returnValue: var int32,
                         nextLine: var int32): bool =
    let header = chengpath.PathTrim(stmt.surfaceText)
    let inPos = parser.ParserFindText(header, " in ")
    if inPos <= 0:
        return false
    let bindingName = stmt.bindingName
    if bindingName == "":
        return false
    let rangeText = chengpath.PathTrim(chengpath.TextSlice(header,
                                                           inPos + 4,
                                                           header.len - inPos - 4))
    var rangePos = parser.ParserFindText(rangeText, "..<")
    var exclusive = true
    if rangePos < 0:
        rangePos = parser.ParserFindText(rangeText, "..")
        exclusive = false
    if rangePos <= 0:
        return false
    var startValue: int32
    var stopValue: int32
    if !LoweringConstEvalI32(bindings,
                             chengpath.TextSlice(rangeText, 0, rangePos),
                             startValue):
        return false
    var rhsStart = rangePos + 2
    if exclusive:
        rhsStart = rangePos + 3
    if !LoweringConstEvalI32(bindings,
                             chengpath.TextSlice(rangeText,
                                                 rhsStart,
                                                 rangeText.len - rhsStart),
                             stopValue):
        return false
    if !exclusive:
        stopValue = stopValue + 1
    let bodyStart = stmt.lineNumber + 1
    let bodyEnd = LoweringConstNextLineAtOrBelowIndent(fnIr,
                                                       bodyStart,
                                                       endLine,
                                                       stmt.lineIndent)
    nextLine = bodyEnd
    if stopValue < startValue:
        return true
    let loopCount = stopValue - startValue
    if loopCount > 4096:
        return false
    for offset in 0..<loopCount:
        LoweringConstSetI32(bindings, bindingName, startValue + offset)
        if !LoweringConstExecuteBlock(fnIr,
                                      bindings,
                                      bodyStart,
                                      bodyEnd,
                                      stmt.lineIndent,
                                      returned,
                                      returnValue):
            return false
        if returned:
            return true
    return true

fn LoweringConstExecuteBlock(fnIr: PrimaryObjectIrFunction,
                              bindings: var LoweringConstBinding[],
                              startLine: int32,
                              endLine: int32,
                              parentIndent: int32,
                              returned: var bool,
                              returnValue: var int32): bool =
    let blockIndent = LoweringConstBlockIndent(fnIr,
                                               startLine,
                                               endLine,
                                               parentIndent)
    if blockIndent < 0:
        return true
    var currentLine = startLine
    while currentLine < endLine:
        if returned:
            return true
        let stmtIndex = LoweringConstFindNextStatement(fnIr,
                                                       currentLine,
                                                       endLine,
                                                       blockIndent)
        if stmtIndex < 0 || stmtIndex >= fnIr.statements.len:
            return true
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtLocalDecl:
            if !LoweringConstExecLocalDecl(bindings, stmt):
                return false
            currentLine = stmt.lineNumber + 1
        elif stmt.kind == texpr.TypedExprIrStmtAssign:
            if !LoweringConstExecAssign(bindings, stmt):
                return false
            currentLine = stmt.lineNumber + 1
        elif stmt.kind == texpr.TypedExprIrStmtReturn:
            if !LoweringConstEvalI32(bindings, stmt.surfaceText, returnValue):
                return false
            returned = true
            return true
        elif stmt.kind == texpr.TypedExprIrStmtIf:
            var chainEndLine: int32
            if !LoweringConstExecIfChain(fnIr,
                                         bindings,
                                         stmt,
                                         endLine,
                                         returned,
                                         returnValue,
                                         chainEndLine):
                return false
            currentLine = chainEndLine
        elif stmt.kind == texpr.TypedExprIrStmtElif ||
             stmt.kind == texpr.TypedExprIrStmtElse:
            return false
        elif stmt.kind == texpr.TypedExprIrStmtFor:
            var nextLine: int32
            if !LoweringConstExecFor(fnIr,
                                     bindings,
                                     stmt,
                                     endLine,
                                     returned,
                                     returnValue,
                                     nextLine):
                return false
            currentLine = nextLine
        elif stmt.kind == texpr.TypedExprIrStmtCall ||
             stmt.kind == texpr.TypedExprIrStmtLetCall ||
             stmt.kind == texpr.TypedExprIrStmtIfCall ||
             stmt.kind == texpr.TypedExprIrStmtResultIntrinsic:
            if !LoweringConstExecCall(bindings, stmt):
                return false
            currentLine = stmt.lineNumber + 1
        else:
            return false
    return true

fn LoweringTryFoldPureI32StructuredStatements(fnIr: var PrimaryObjectIrFunction): bool =
    if texpr.TypedExprNormalizeTypeText(fnIr.returnType) != "int32":
        return false
    if fnIr.statements.len <= 0:
        return false
    var bindings: LoweringConstBinding[]
    var returned = false
    var returnValue: int32
    let endLine = LoweringConstMaxStatementLine(fnIr) + 1
    if endLine <= fnIr.bodyLineNumber:
        return false
    if !LoweringConstExecuteBlock(fnIr,
                                  bindings,
                                  fnIr.bodyLineNumber,
                                  endLine,
                                  0,
                                  returned,
                                  returnValue):
        return false
    if !returned:
        return false
    LoweringClearStructuredCalls(fnIr)
    fnIr.bodyIR = coreir.BodyIR()
    fnIr.statementReturnMode = texpr.StatementReturnModeNone
    fnIr.statementReturnI32Value = 0
    if returnValue == 0:
        fnIr.bodyKind = texpr.BodyKindReturnZeroI32
    else:
        fnIr.bodyKind = Fmt"{texpr.BodyKindReturnI32ConstPrefix}{returnValue}"
    return true

fn LoweringAppendStructuredCall(fnIr: var PrimaryObjectIrFunction,
                                 stmt: PrimaryObjectIrStatement,
                                 sourceTexts: texpr.TypedExprSourceText[]): int32 =
    if Len(stmt.callTarget) <= 0:
        return -1
    var resultSlot: int32 = -1
    let resultSlotName = LoweringStructuredCallResultSlotName(stmt)
    if Len(resultSlotName) > 0:
        resultSlot = LoweringBodyIrEnsureLocalSlot(fnIr, resultSlotName, stmt.resultType)
    var callOp: PrimaryObjectIrCallOp
    callOp.targetSymbol = stmt.callTarget
    callOp.targetSourcePath = stmt.callTargetSourcePath
    callOp.importc = stmt.callTargetImportc
    callOp.importcSymbol = LoweringStatementImportcSymbol(stmt, sourceTexts)
    callOp.argCount = stmt.callArgCount
    callOp.argsText = stmt.callArgsText
    callOp.resultType = stmt.resultType
    callOp.bindingName = stmt.bindingName
    callOp.resultSlot = resultSlot
    callOp.relocWordOffset = -1
    callOp.argSlots = LoweringCallArgSlots(fnIr, stmt.callArgsText)
    let ordinal = fnIr.callSequence.len
    add(fnIr.callSequence, callOp)
    add(fnIr.callArgCounts, stmt.callArgCount)
    add(fnIr.callTargets, stmt.callTarget)
    add(fnIr.callTargetSourcePaths, stmt.callTargetSourcePath)
    add(fnIr.callTargetImportcFlags, stmt.callTargetImportc)
    add(fnIr.callImportcSymbols, callOp.importcSymbol)
    var bodyCall: coreir.CallOp
    bodyCall.targetSymbol = callOp.targetSymbol
    bodyCall.argSlots = callOp.argSlots
    bodyCall.resultSlot = resultSlot
    bodyCall.relocWordOffset = -1
    add(fnIr.bodyIR.callSequence, bodyCall)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    add(op.operands, ordinal)
    op.target = resultSlot
    add(fnIr.bodyIR.ops, op)
    fnIr.callTargetCount = fnIr.callSequence.len
    return ordinal

fn LoweringIfConditionTrueOnZero(stmt: PrimaryObjectIrStatement): bool =
    let text = chengpath.PathTrim(stmt.surfaceText)
    if chengpath.TextStartsWith(text, "!"):
        return true
    if chengpath.TextStartsWith(text, "if !"):
        return true
    if chengpath.TextStartsWith(text, "elif !"):
        return true
    return false

fn LoweringFindIfConditionCallIndex(fnIr: PrimaryObjectIrFunction,
                                     ifLineNumber: int32): int32 =
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.lineNumber != ifLineNumber:
            continue
        if stmt.kind != texpr.TypedExprIrStmtIfCall:
            continue
        if Len(stmt.callTarget) <= 0:
            continue
        return stmtIndex
    return -1

fn LoweringAppendCfgReturnTermForLastCall(fnIr: var PrimaryObjectIrFunction): int32 =
    if fnIr.callSequence.len <= 0:
        return -1
    let lastCallIndex = fnIr.callSequence.len - 1
    let returnSlot = fnIr.callSequence[lastCallIndex].resultSlot
    if returnSlot < 0 || returnSlot >= fnIr.bodyIR.localSlots.len:
        return -1
    if fnIr.bodyIR.localSlots[returnSlot].typeKind != coreir.LocalI32Tag:
        return -1
    var term: coreir.BodyTerm
    term.kind = coreir.BodyTermReturnTag
    term.resultSlot = returnSlot
    add(term.operands, coreir.LocalI32Tag)
    return coreir.BodyIRAppendTerm(fnIr.bodyIR, term)

fn LoweringAppendCfgCallsUntilReturn(fnIr: var PrimaryObjectIrFunction,
                                      sourceTexts: texpr.TypedExprSourceText[],
                                      ifLineNumber: int32,
                                      nested: bool,
                                      startAfterLine: int32): int32 =
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if nested:
            if stmt.enclosingIfLineNumber != ifLineNumber:
                continue
        else:
            if stmt.enclosingIfLineNumber > 0:
                continue
            if stmt.lineNumber <= startAfterLine:
                continue
            if stmt.kind == texpr.TypedExprIrStmtIf ||
               stmt.kind == texpr.TypedExprIrStmtElif ||
               stmt.kind == texpr.TypedExprIrStmtElse ||
               stmt.kind == texpr.TypedExprIrStmtFor:
                return -1
        if Len(stmt.callTarget) <= 0:
            continue
        let ordinal = LoweringAppendStructuredCall(fnIr, stmt, sourceTexts)
        if ordinal < 0:
            return -1
        if stmt.returnRoot:
            return LoweringAppendCfgReturnTermForLastCall(fnIr)
    return -1

fn LoweringPopulateSingleTopIfCallCfgReturnI32(fnIr: var PrimaryObjectIrFunction,
                                                sourceTexts: texpr.TypedExprSourceText[]): bool =
    if texpr.TypedExprNormalizeTypeText(fnIr.returnType) != "int32":
        return false
    var ifIndex: int32 = -1
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.enclosingIfLineNumber > 0:
            continue
        if stmt.kind == texpr.TypedExprIrStmtIf:
            if ifIndex >= 0:
                return false
            ifIndex = stmtIndex
        elif stmt.kind == texpr.TypedExprIrStmtElif ||
             stmt.kind == texpr.TypedExprIrStmtElse ||
             stmt.kind == texpr.TypedExprIrStmtFor:
            return false
    if ifIndex < 0:
        return false
    let ifStmt = fnIr.statements[ifIndex]
    let condIndex = LoweringFindIfConditionCallIndex(fnIr, ifStmt.lineNumber)
    if condIndex < 0:
        return false
    LoweringClearStructuredCalls(fnIr)
    LoweringEnsureLocalDeclSlots(fnIr)
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.enclosingIfLineNumber > 0:
            continue
        if stmt.lineNumber > ifStmt.lineNumber:
            break
        if stmt.kind == texpr.TypedExprIrStmtLocalDecl ||
           stmt.kind == texpr.TypedExprIrStmtIf:
            continue
        if stmtIndex == condIndex:
            continue
        if Len(stmt.callTarget) <= 0:
            continue
        let ordinal = LoweringAppendStructuredCall(fnIr, stmt, sourceTexts)
        if ordinal < 0:
            LoweringClearStructuredCalls(fnIr)
            return false
    let condOrdinal = LoweringAppendStructuredCall(fnIr,
                                                   fnIr.statements[condIndex],
                                                   sourceTexts)
    if condOrdinal < 0 ||
       fnIr.callSequence.len <= 0:
        LoweringClearStructuredCalls(fnIr)
        return false
    let condSlot = fnIr.callSequence[condOrdinal].resultSlot
    if condSlot < 0 || condSlot >= fnIr.bodyIR.localSlots.len:
        LoweringClearStructuredCalls(fnIr)
        return false
    let entryOpCount = fnIr.bodyIR.ops.len
    var entryTerm: coreir.BodyTerm
    entryTerm.kind = coreir.BodyTermCbrTag
    if LoweringIfConditionTrueOnZero(ifStmt):
        entryTerm.conditionKind = coreir.BodyCondLocalZeroTag
    else:
        entryTerm.conditionKind = coreir.BodyCondLocalNonZeroTag
    entryTerm.resultSlot = condSlot
    entryTerm.lhsSlot = condSlot
    entryTerm.trueBlock = 1
    entryTerm.falseBlock = 2
    let entryTermIndex = coreir.BodyIRAppendTerm(fnIr.bodyIR, entryTerm)
    let _ = coreir.BodyIRAppendBlock(fnIr.bodyIR, 0, entryOpCount, entryTermIndex)

    let trueStart = fnIr.bodyIR.ops.len
    let trueTermIndex = LoweringAppendCfgCallsUntilReturn(fnIr,
                                                          sourceTexts,
                                                          ifStmt.lineNumber,
                                                          true,
                                                          ifStmt.lineNumber)
    if trueTermIndex < 0:
        LoweringClearStructuredCalls(fnIr)
        return false
    let _ = coreir.BodyIRAppendBlock(fnIr.bodyIR,
                                     trueStart,
                                     fnIr.bodyIR.ops.len - trueStart,
                                     trueTermIndex)

    let falseStart = fnIr.bodyIR.ops.len
    let falseTermIndex = LoweringAppendCfgCallsUntilReturn(fnIr,
                                                           sourceTexts,
                                                           ifStmt.lineNumber,
                                                           false,
                                                           ifStmt.lineNumber)
    if falseTermIndex < 0:
        LoweringClearStructuredCalls(fnIr)
        return false
    let _ = coreir.BodyIRAppendBlock(fnIr.bodyIR,
                                     falseStart,
                                     fnIr.bodyIR.ops.len - falseStart,
                                     falseTermIndex)
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    return true

fn LoweringAppendStructuredConstI32Call(fnIr: var PrimaryObjectIrFunction,
                                         stmt: PrimaryObjectIrStatement,
                                         sourceTexts: texpr.TypedExprSourceText[],
                                         constValue: int32): int32 =
    if Len(stmt.callTarget) <= 0:
        return -1
    var resultSlot: int32 = -1
    let resultSlotName = LoweringStructuredCallResultSlotName(stmt)
    if Len(resultSlotName) > 0:
        resultSlot = LoweringBodyIrEnsureLocalSlot(fnIr, resultSlotName, stmt.resultType)
    var callOp: PrimaryObjectIrCallOp
    callOp.targetSymbol = stmt.callTarget
    callOp.targetSourcePath = stmt.callTargetSourcePath
    callOp.importc = stmt.callTargetImportc
    callOp.importcSymbol = LoweringStatementImportcSymbol(stmt, sourceTexts)
    callOp.argCount = stmt.callArgCount
    callOp.argsText = stmt.callArgsText
    callOp.resultType = stmt.resultType
    callOp.bindingName = stmt.bindingName
    callOp.resultSlot = resultSlot
    callOp.relocWordOffset = -1
    let ordinal = fnIr.callSequence.len
    add(fnIr.callSequence, callOp)
    add(fnIr.callArgCounts, stmt.callArgCount)
    add(fnIr.callTargets, stmt.callTarget)
    add(fnIr.callTargetSourcePaths, stmt.callTargetSourcePath)
    add(fnIr.callTargetImportcFlags, stmt.callTargetImportc)
    add(fnIr.callImportcSymbols, callOp.importcSymbol)
    var bodyCall: coreir.CallOp
    bodyCall.targetSymbol = callOp.targetSymbol
    bodyCall.argSlots = callOp.argSlots
    bodyCall.resultSlot = resultSlot
    bodyCall.relocWordOffset = -1
    add(fnIr.bodyIR.callSequence, bodyCall)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    add(op.operands, ordinal)
    add(op.operands, constValue)
    op.target = resultSlot
    add(fnIr.bodyIR.ops, op)
    fnIr.callTargetCount = fnIr.callSequence.len
    return ordinal

fn LoweringAppendStructuredArg0SlotCall(fnIr: var PrimaryObjectIrFunction,
                                         stmt: PrimaryObjectIrStatement,
                                         sourceTexts: texpr.TypedExprSourceText[],
                                         argSlot: int32): int32 =
    if Len(stmt.callTarget) <= 0 || argSlot < 0:
        return -1
    var callOp: PrimaryObjectIrCallOp
    callOp.targetSymbol = stmt.callTarget
    callOp.targetSourcePath = stmt.callTargetSourcePath
    callOp.importc = stmt.callTargetImportc
    callOp.importcSymbol = LoweringStatementImportcSymbol(stmt, sourceTexts)
    callOp.argCount = stmt.callArgCount
    callOp.argsText = stmt.callArgsText
    callOp.resultType = stmt.resultType
    callOp.bindingName = stmt.bindingName
    callOp.resultSlot = -1
    callOp.relocWordOffset = -1
    add(callOp.argSlots, argSlot)
    let ordinal = fnIr.callSequence.len
    add(fnIr.callSequence, callOp)
    add(fnIr.callArgCounts, stmt.callArgCount)
    add(fnIr.callTargets, stmt.callTarget)
    add(fnIr.callTargetSourcePaths, stmt.callTargetSourcePath)
    add(fnIr.callTargetImportcFlags, stmt.callTargetImportc)
    add(fnIr.callImportcSymbols, callOp.importcSymbol)
    var bodyCall: coreir.CallOp
    bodyCall.targetSymbol = callOp.targetSymbol
    bodyCall.argSlots = callOp.argSlots
    bodyCall.resultSlot = -1
    bodyCall.relocWordOffset = -1
    add(fnIr.bodyIR.callSequence, bodyCall)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    add(op.operands, ordinal)
    op.target = -1
    add(fnIr.bodyIR.ops, op)
    fnIr.callTargetCount = fnIr.callSequence.len
    return ordinal

fn LoweringPopulateStrCallConstThenCallArg0ReturnI32(fnIr: var PrimaryObjectIrFunction,
                                                      sourceTexts: texpr.TypedExprSourceText[]): bool =
    if texpr.TypedExprNormalizeTypeText(fnIr.returnType) != "int32":
        return false
    var innerIndex: int32 = -1
    var outerIndex: int32 = -1
    for stmtIndex in 0..<fnIr.statements.len:
        let outerStmt = fnIr.statements[stmtIndex]
        if outerStmt.kind != texpr.TypedExprIrStmtCall ||
           outerStmt.callArgCount != 1 ||
           outerStmt.enclosingIfLineNumber > 0:
            continue
        let outerType = texpr.TypedExprNormalizeTypeText(outerStmt.resultType)
        if outerType != "int32" && outerType != "unknown" && Len(outerType) > 0:
            continue
        if !outerStmt.returnRoot && outerStmt.lineNumber != fnIr.bodyLineNumber:
            continue
        for innerStmtIndex in 0..<fnIr.statements.len:
            if innerStmtIndex == stmtIndex:
                continue
            let innerStmt = fnIr.statements[innerStmtIndex]
            if innerStmt.callArgCount != 1 ||
               innerStmt.enclosingIfLineNumber > 0:
                continue
            let innerType = texpr.TypedExprNormalizeTypeText(innerStmt.resultType)
            if innerType != "str" && innerType != "unknown":
                continue
            if chengpath.PathTrim(innerStmt.callArgsText) != "1":
                continue
            var innerMatchesOuterArg = false
            if innerStmt.kind == texpr.TypedExprIrStmtCall &&
               innerStmt.lineNumber == outerStmt.lineNumber:
                innerMatchesOuterArg = LoweringReturnExprMatchesCallStatement(outerStmt.callArgsText, innerStmt)
            elif innerStmt.kind == texpr.TypedExprIrStmtLetCall &&
                 innerStmt.lineNumber < outerStmt.lineNumber:
                innerMatchesOuterArg = chengpath.PathTrim(outerStmt.callArgsText) ==
                                       chengpath.PathTrim(innerStmt.bindingName)
            if !innerMatchesOuterArg:
                continue
            innerIndex = innerStmtIndex
            outerIndex = stmtIndex
        if outerIndex >= 0:
            break
    if innerIndex < 0 || outerIndex < 0:
        return false
    LoweringClearStructuredCalls(fnIr)
    let firstOrdinal = LoweringAppendStructuredConstI32Call(fnIr,
                                                            fnIr.statements[innerIndex],
                                                            sourceTexts,
                                                            1)
    if firstOrdinal != 0 ||
       fnIr.callSequence.len <= 0 ||
       fnIr.callSequence[0].resultSlot < 0:
        LoweringClearStructuredCalls(fnIr)
        return false
    let secondOrdinal = LoweringAppendStructuredArg0SlotCall(fnIr,
                                                             fnIr.statements[outerIndex],
                                                             sourceTexts,
                                                             fnIr.callSequence[0].resultSlot)
    if secondOrdinal != 1:
        LoweringClearStructuredCalls(fnIr)
        return false
    var returnOp: coreir.BodyOp
    returnOp.kind = coreir.BodyOpReturnTag
    returnOp.target = -1
    add(returnOp.operands, coreir.LocalI32Tag)
    add(fnIr.bodyIR.ops, returnOp)
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    LoweringPopulateBodyIrBlocksTerms(fnIr)
    return true

fn LoweringBodyIrOpsAreCalls(bodyIR: coreir.BodyIR,
                              startIndex: int32,
                              stopExclusive: int32): bool =
    if startIndex < 0 || stopExclusive < startIndex || stopExclusive > bodyIR.ops.len:
        return false
    for opIndex in startIndex..<stopExclusive:
        if bodyIR.ops[opIndex].kind != coreir.BodyOpCallTag:
            return false
    return true

fn LoweringAppendBodyIrReturnTermFromOp(fnIr: var PrimaryObjectIrFunction,
                                         opIndex: int32): int32 =
    if opIndex < 0 || opIndex >= fnIr.bodyIR.ops.len:
        return -1
    let returnOp = fnIr.bodyIR.ops[opIndex]
    if returnOp.kind != coreir.BodyOpReturnTag:
        return -1
    var term: coreir.BodyTerm
    term.kind = coreir.BodyTermReturnTag
    term.resultSlot = returnOp.target
    for i in 0..<returnOp.operands.len:
        add(term.operands, returnOp.operands[i])
    return coreir.BodyIRAppendTerm(fnIr.bodyIR, term)

fn LoweringPopulateBodyIrLinearBlocksTerms(fnIr: var PrimaryObjectIrFunction,
                                            returnOpIndex: int32): bool =
    if returnOpIndex < 0:
        return false
    if !LoweringBodyIrOpsAreCalls(fnIr.bodyIR, 0, returnOpIndex):
        return false
    let returnTermIndex = LoweringAppendBodyIrReturnTermFromOp(fnIr, returnOpIndex)
    if returnTermIndex < 0:
        return false
    let _ = coreir.BodyIRAppendBlock(fnIr.bodyIR, 0, returnOpIndex, returnTermIndex)
    return true

fn LoweringPopulateBodyIrGuardBlocksTerms(fnIr: var PrimaryObjectIrFunction,
                                           branchIndex: int32,
                                           returnOpIndex: int32): bool =
    if branchIndex < 0 || returnOpIndex < 0 || branchIndex >= returnOpIndex:
        return false
    if !LoweringBodyIrOpsAreCalls(fnIr.bodyIR, 0, branchIndex):
        return false
    if !LoweringBodyIrOpsAreCalls(fnIr.bodyIR, branchIndex + 1, returnOpIndex):
        return false
    let branchOp = fnIr.bodyIR.ops[branchIndex]
    if branchOp.kind != coreir.BodyOpBranchTag || branchOp.operands.len < 3:
        return false
    if branchOp.operands[0] != coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag:
        return false
    var trueReturnTerm: coreir.BodyTerm
    trueReturnTerm.kind = coreir.BodyTermReturnTag
    trueReturnTerm.resultSlot = -1
    add(trueReturnTerm.operands, texpr.StatementReturnModeI32Const)
    add(trueReturnTerm.operands, branchOp.operands[2])
    let trueReturnTermIndex = coreir.BodyIRAppendTerm(fnIr.bodyIR, trueReturnTerm)
    let trueBlockIndex = coreir.BodyIRAppendBlock(fnIr.bodyIR, returnOpIndex, 0, trueReturnTermIndex)
    let finalReturnTermIndex = LoweringAppendBodyIrReturnTermFromOp(fnIr, returnOpIndex)
    if finalReturnTermIndex < 0:
        return false
    let falseBlockIndex = coreir.BodyIRAppendBlock(fnIr.bodyIR,
                                                   branchIndex + 1,
                                                   returnOpIndex - branchIndex - 1,
                                                   finalReturnTermIndex)
    var guardTerm: coreir.BodyTerm
    guardTerm.kind = coreir.BodyTermCbrTag
    guardTerm.conditionKind = coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag
    guardTerm.resultSlot = branchOp.operands[1]
    guardTerm.lhsSlot = branchOp.operands[1]
    guardTerm.trueBlock = trueBlockIndex
    guardTerm.falseBlock = falseBlockIndex
    let guardTermIndex = coreir.BodyIRAppendTerm(fnIr.bodyIR, guardTerm)
    let _ = coreir.BodyIRAppendBlock(fnIr.bodyIR, 0, branchIndex, guardTermIndex)
    return true

fn LoweringPopulateBodyIrBlocksTerms(fnIr: var PrimaryObjectIrFunction) =
    fnIr.bodyIR.blocks = []
    fnIr.bodyIR.terms = []
    if fnIr.bodyIR.ops.len <= 0:
        return
    let returnOpIndex = fnIr.bodyIR.ops.len - 1
    if fnIr.bodyIR.ops[returnOpIndex].kind != coreir.BodyOpReturnTag:
        return
    var branchIndex: int32 = -1
    for opIndex in 0..<returnOpIndex:
        if fnIr.bodyIR.ops[opIndex].kind == coreir.BodyOpBranchTag:
            if branchIndex >= 0:
                fnIr.bodyIR.blocks = []
                fnIr.bodyIR.terms = []
                return
            branchIndex = opIndex
    if branchIndex >= 0:
        if !LoweringPopulateBodyIrGuardBlocksTerms(fnIr, branchIndex, returnOpIndex):
            fnIr.bodyIR.blocks = []
            fnIr.bodyIR.terms = []
        return
    if !LoweringPopulateBodyIrLinearBlocksTerms(fnIr, returnOpIndex):
        fnIr.bodyIR.blocks = []
        fnIr.bodyIR.terms = []

fn LoweringBodyTermI32ConstReturn(term: coreir.BodyTerm,
                                   value: var int32): bool =
    if term.kind != coreir.BodyTermReturnTag:
        return false
    if term.resultSlot >= 0:
        return false
    if term.operands.len < 2:
        return false
    if term.operands[0] != texpr.StatementReturnModeI32Const:
        return false
    value = term.operands[1]
    return true

fn LoweringBodyTermReturnOp(bodyIR: coreir.BodyIR,
                             term: coreir.BodyTerm,
                             op: var coreir.BodyOp): bool =
    if term.kind != coreir.BodyTermReturnTag:
        return false
    op = coreir.BodyOp()
    op.kind = coreir.BodyOpReturnTag
    op.target = term.resultSlot
    for i in 0..<term.operands.len:
        add(op.operands, term.operands[i])
    if op.operands.len > 0:
        return true
    if term.resultSlot >= 0 && term.resultSlot < bodyIR.localSlots.len:
        add(op.operands, bodyIR.localSlots[term.resultSlot].typeKind)
        return true
    return false

fn LoweringBodyIrEntryBlockIndex(bodyIR: coreir.BodyIR): int32 =
    var fallback = -1
    for blockIndex in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[blockIndex]
        if block.opStart != 0:
            continue
        if fallback < 0:
            fallback = blockIndex
        if block.termIndex < 0 || block.termIndex >= bodyIR.terms.len:
            continue
        let term = bodyIR.terms[block.termIndex]
        if term.kind == coreir.BodyTermCbrTag ||
           term.kind == coreir.BodyTermBrTag:
            return blockIndex
    if fallback >= 0:
        return fallback
    return 0

fn LoweringOptimizeBodyIrFlattenBlocks(bodyIR: coreir.BodyIR): coreir.BodyIR =
    return biropt.BodyIrMergeLinearBlocks(bodyIR)

fn LoweringOptimizeBodyIrTrimAfterReturn(bodyIR: coreir.BodyIR): coreir.BodyIR =
    return biropt.BodyIrTrimAfterReturn(bodyIR)

fn LoweringOptimizeBodyIr(bodyIR: coreir.BodyIR): coreir.BodyIR =
    let loopInfo = birloop.BodyIrAnalyzeLoops(bodyIR)
    let _ = loopInfo.loopCount
    let flattened = LoweringOptimizeBodyIrFlattenBlocks(bodyIR)
    let forwarded = birnoalias.BodyIrNoAliasForwardLocals(flattened)
    let optimized = biropt.BodyIrOptimizeSimple(forwarded)
    return LoweringOptimizeBodyIrTrimAfterReturn(optimized)

fn LoweringAppendBodyIrStatementReturn(fnIr: var PrimaryObjectIrFunction) =
    if fnIr.statementReturnMode == texpr.StatementReturnModeNone:
        return
    if fnIr.bodyIR.ops.len <= 0:
        return
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpReturnTag
    op.target = -1
    add(op.operands, fnIr.statementReturnMode)
    if fnIr.statementReturnMode == texpr.StatementReturnModeI32Const ||
       fnIr.statementReturnMode == texpr.StatementReturnModeStrThenCallReturnI32Const0 ||
       fnIr.statementReturnMode == texpr.StatementReturnModeCstringLiteralCallsReturnI32Const0:
        add(op.operands, fnIr.statementReturnI32Value)
    add(fnIr.bodyIR.ops, op)
    LoweringPopulateBodyIrBlocksTerms(fnIr)

fn LoweringAppendBodyIrReturnCall(fnIr: var PrimaryObjectIrFunction,
                                   stmt: PrimaryObjectIrStatement) =
    if fnIr.callSequence.len <= 0:
        return
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpReturnTag
    op.target = -1
    let lastCallIndex = fnIr.callSequence.len - 1
    if lastCallIndex >= 0 && fnIr.callSequence[lastCallIndex].resultSlot >= 0:
        op.target = fnIr.callSequence[lastCallIndex].resultSlot
    var returnType = stmt.resultType
    if Len(returnType) <= 0:
        returnType = fnIr.returnType
    let typeKind = LoweringLocalTypeKind(returnType)
    if typeKind != coreir.LocalInvalidTag:
        add(op.operands, typeKind)
    add(fnIr.bodyIR.ops, op)
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    LoweringPopulateBodyIrBlocksTerms(fnIr)

fn LoweringAppendLastAggregateCallReturn(fnIr: var PrimaryObjectIrFunction): bool =
    if fnIr.callSequence.len <= 0:
        return false
    if fnIr.bodyIR.ops.len != fnIr.callSequence.len:
        return false
    if !LoweringBodyIrOpsAreCalls(fnIr.bodyIR, 0, fnIr.bodyIR.ops.len):
        return false
    let lastCallIndex = fnIr.callSequence.len - 1
    let resultSlot = fnIr.callSequence[lastCallIndex].resultSlot
    if resultSlot < 0 || resultSlot >= fnIr.bodyIR.localSlots.len:
        return false
    if fnIr.bodyIR.localSlots[resultSlot].typeKind != coreir.LocalAggregateTag:
        return false
    var returnOp: coreir.BodyOp
    returnOp.kind = coreir.BodyOpReturnTag
    returnOp.target = resultSlot
    add(returnOp.operands, coreir.LocalAggregateTag)
    add(fnIr.bodyIR.ops, returnOp)
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    LoweringPopulateBodyIrBlocksTerms(fnIr)
    return true

fn LoweringAppendI32GuardBranch(fnIr: var PrimaryObjectIrFunction,
                                 guardSlot: int32) =
    var branchOp: coreir.BodyOp
    branchOp.kind = coreir.BodyOpBranchTag
    add(branchOp.operands, coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag)
    add(branchOp.operands, guardSlot)
    add(branchOp.operands, 0)
    branchOp.target = -1
    add(fnIr.bodyIR.ops, branchOp)

fn LoweringAppendI32LocalReturn(fnIr: var PrimaryObjectIrFunction,
                                 returnSlot: int32) =
    var returnOp: coreir.BodyOp
    returnOp.kind = coreir.BodyOpReturnTag
    returnOp.target = returnSlot
    add(returnOp.operands, coreir.LocalI32Tag)
    add(fnIr.bodyIR.ops, returnOp)
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    LoweringPopulateBodyIrBlocksTerms(fnIr)

fn LoweringAppendI32CallReturn(fnIr: var PrimaryObjectIrFunction) =
    var returnOp: coreir.BodyOp
    returnOp.kind = coreir.BodyOpReturnTag
    returnOp.target = -1
    if fnIr.callSequence.len > 0:
        let lastCallIndex = fnIr.callSequence.len - 1
        returnOp.target = fnIr.callSequence[lastCallIndex].resultSlot
    add(returnOp.operands, coreir.LocalI32Tag)
    add(fnIr.bodyIR.ops, returnOp)
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    LoweringPopulateBodyIrBlocksTerms(fnIr)

fn LoweringPopulateI32LetCallGuardReturn(fnIr: var PrimaryObjectIrFunction,
                                          sourceTexts: texpr.TypedExprSourceText[],
                                          guardBindingRaw: str,
                                          returnExprRaw: str,
                                          ifLineNumber: int32): bool =
    let guardBinding = chengpath.PathTrim(guardBindingRaw)
    let returnExpr = chengpath.PathTrim(returnExprRaw)
    if texpr.TypedExprNormalizeTypeText(fnIr.returnType) != "int32":
        return false
    if Len(guardBinding) <= 0 || Len(returnExpr) <= 0 || ifLineNumber <= 0:
        return false
    LoweringClearStructuredCalls(fnIr)
    var guardSlot: int32 = -1
    var preGuardCallCount: int32
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.lineNumber >= ifLineNumber:
            continue
        if stmt.kind != texpr.TypedExprIrStmtLetCall:
            continue
        if stmt.enclosingIfLineNumber > 0:
            LoweringClearStructuredCalls(fnIr)
            return false
        if texpr.TypedExprNormalizeTypeText(stmt.resultType) != "int32":
            LoweringClearStructuredCalls(fnIr)
            return false
        let ordinal = LoweringAppendStructuredCall(fnIr, stmt, sourceTexts)
        if ordinal != preGuardCallCount:
            LoweringClearStructuredCalls(fnIr)
            return false
        if chengpath.PathTrim(stmt.bindingName) == guardBinding:
            guardSlot = fnIr.callSequence[ordinal].resultSlot
        preGuardCallCount = preGuardCallCount + 1
    if preGuardCallCount <= 0 || guardSlot < 0:
        LoweringClearStructuredCalls(fnIr)
        return false
    LoweringAppendI32GuardBranch(fnIr, guardSlot)
    let returnSlot = LoweringBodyIrLocalSlotIndex(fnIr, returnExpr)
    if returnSlot >= 0 && returnSlot < fnIr.bodyIR.localSlots.len:
        if fnIr.bodyIR.localSlots[returnSlot].typeKind != coreir.LocalI32Tag:
            LoweringClearStructuredCalls(fnIr)
            return false
        if fnIr.callSequence.len != 2:
            LoweringClearStructuredCalls(fnIr)
            return false
        LoweringAppendI32LocalReturn(fnIr, returnSlot)
        return true
    var returnStatementIndex: int32 = -1
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.lineNumber <= ifLineNumber:
            continue
        if stmt.kind != texpr.TypedExprIrStmtCall:
            continue
        if stmt.callArgCount != 0:
            continue
        if texpr.TypedExprNormalizeTypeText(stmt.resultType) != "int32":
            continue
        if stmt.returnRoot ||
           LoweringReturnExprMatchesCallStatement(returnExpr, stmt):
            returnStatementIndex = stmtIndex
            break
    if returnStatementIndex < 0:
        LoweringClearStructuredCalls(fnIr)
        return false
    let commandOrdinal = LoweringAppendStructuredCall(fnIr,
                                                      fnIr.statements[returnStatementIndex],
                                                      sourceTexts)
    if commandOrdinal != preGuardCallCount || fnIr.callSequence.len != 2:
        LoweringClearStructuredCalls(fnIr)
        return false
    LoweringAppendI32CallReturn(fnIr)
    return true

fn LoweringI32LeZeroGuardBinding(surfaceRaw: str): str =
    let text = chengpath.PathTrim(surfaceRaw)
    let suffix = " <= 0"
    if LoweringTextEndsWith(text, suffix):
        return parser.ParserIdentPrefix(chengpath.PathTrim(chengpath.TextSlice(text,
                                                                               0,
                                                                               Len(text) - Len(suffix))))
    let ifPrefix = "if "
    let ifSuffix = " <= 0:"
    if chengpath.TextStartsWith(text, ifPrefix) &&
       LoweringTextEndsWith(text, ifSuffix):
        let start = Len(ifPrefix)
        return parser.ParserIdentPrefix(chengpath.PathTrim(chengpath.TextSlice(text,
                                                                               start,
                                                                               Len(text) - start - Len(ifSuffix))))
    return ""

fn LoweringHasPreguardI32LetCallBinding(fnIr: PrimaryObjectIrFunction,
                                         ifLineNumber: int32,
                                         bindingRaw: str): bool =
    let binding = chengpath.PathTrim(bindingRaw)
    if Len(binding) <= 0:
        return false
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.lineNumber >= ifLineNumber:
            continue
        if stmt.enclosingIfLineNumber > 0:
            continue
        if stmt.kind != texpr.TypedExprIrStmtLetCall:
            continue
        if texpr.TypedExprNormalizeTypeText(stmt.resultType) != "int32":
            continue
        if chengpath.PathTrim(stmt.bindingName) == binding:
            return true
    return false

fn LoweringNestedReturnConstZeroForIf(fnIr: PrimaryObjectIrFunction,
                                       ifLineNumber: int32): bool =
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.enclosingIfLineNumber != ifLineNumber:
            continue
        if stmt.kind == texpr.TypedExprIrStmtReturn &&
           chengpath.PathTrim(stmt.surfaceText) == "0":
            return true
    return false

fn LoweringFirstTopReturnAfterLine(fnIr: PrimaryObjectIrFunction,
                                    lineNumber: int32): str =
    var bestLine = 2147483647
    var out = ""
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.lineNumber <= lineNumber:
            continue
        if stmt.enclosingIfLineNumber > 0:
            continue
        if stmt.kind != texpr.TypedExprIrStmtReturn:
            continue
        if stmt.lineNumber < bestLine:
            bestLine = stmt.lineNumber
            out = chengpath.PathTrim(stmt.surfaceText)
    return out

fn LoweringSingleLinearTopReturnExpr(fnIr: PrimaryObjectIrFunction): str =
    var returnCount: int32
    var out = ""
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.enclosingIfLineNumber > 0:
            continue
        if stmt.kind == texpr.TypedExprIrStmtIf ||
           stmt.kind == texpr.TypedExprIrStmtElif ||
           stmt.kind == texpr.TypedExprIrStmtElse ||
           stmt.kind == texpr.TypedExprIrStmtFor:
            return ""
        if stmt.kind == texpr.TypedExprIrStmtReturn:
            returnCount = returnCount + 1
            out = chengpath.PathTrim(stmt.surfaceText)
    if returnCount != 1:
        return ""
    return out

fn LoweringPopulateI32LetCallGuardReturnFromStatements(fnIr: var PrimaryObjectIrFunction,
                                                        sourceTexts: texpr.TypedExprSourceText[]): bool =
    if texpr.TypedExprNormalizeTypeText(fnIr.returnType) != "int32":
        return false
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind != texpr.TypedExprIrStmtIf:
            continue
        if stmt.enclosingIfLineNumber > 0:
            continue
        let guardBinding = LoweringI32LeZeroGuardBinding(stmt.surfaceText)
        if Len(guardBinding) <= 0:
            continue
        if !LoweringHasPreguardI32LetCallBinding(fnIr,
                                                 stmt.lineNumber,
                                                 guardBinding):
            continue
        if !LoweringNestedReturnConstZeroForIf(fnIr, stmt.lineNumber):
            continue
        let returnExpr = LoweringFirstTopReturnAfterLine(fnIr, stmt.lineNumber)
        if Len(returnExpr) <= 0:
            continue
        return LoweringPopulateI32LetCallGuardReturn(fnIr,
                                                     sourceTexts,
                                                     guardBinding,
                                                     returnExpr,
                                                     stmt.lineNumber)
    return false

fn LoweringPopulateResultRequestDispatchBodyIr(fnIr: var PrimaryObjectIrFunction,
                                                sourceTexts: texpr.TypedExprSourceText[]): bool =
    if fnIr.statements.len < 4:
        return false
    var isErrIndex: int32 = -1
    var errorIndex: int32 = -1
    var unsupportedIndex: int32 = -1
    var valueIndex: int32 = -1
    var dispatchIndex: int32 = -1
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtResultIntrinsic:
            if stmt.detailKind == parser.NormalizedExprDetailResultIsErr &&
               isErrIndex < 0:
                isErrIndex = stmtIndex
            elif stmt.detailKind == parser.NormalizedExprDetailResultError &&
                 errorIndex < 0:
                errorIndex = stmtIndex
            elif stmt.detailKind == parser.NormalizedExprDetailResultValue &&
                 valueIndex < 0:
                valueIndex = stmtIndex
        elif stmt.kind == texpr.TypedExprIrStmtCall ||
             stmt.kind == texpr.TypedExprIrStmtIfCall ||
             stmt.kind == texpr.TypedExprIrStmtLetCall:
            if LoweringFunctionTailName(stmt.callTarget) == "BackendDriverDispatchMinUnsupported" &&
               unsupportedIndex < 0:
                unsupportedIndex = stmtIndex
            elif LoweringFunctionTailName(stmt.callTarget) == "BackendDriverDispatchMinRunSystemLinkExecConcreteRequest" &&
                 dispatchIndex < 0:
                dispatchIndex = stmtIndex
    if isErrIndex < 0 ||
       unsupportedIndex < 0 ||
       valueIndex < 0 ||
       dispatchIndex < 0:
        return false
    let isErrStmt = fnIr.statements[isErrIndex]
    let unsupportedStmt = fnIr.statements[unsupportedIndex]
    let valueStmt = fnIr.statements[valueIndex]
    let dispatchStmt = fnIr.statements[dispatchIndex]
    var resultDispatchReady = true
    if isErrStmt.kind != texpr.TypedExprIrStmtResultIntrinsic ||
       (unsupportedStmt.kind != texpr.TypedExprIrStmtCall &&
        unsupportedStmt.kind != texpr.TypedExprIrStmtIfCall &&
        unsupportedStmt.kind != texpr.TypedExprIrStmtLetCall) ||
       valueStmt.kind != texpr.TypedExprIrStmtResultIntrinsic ||
       (dispatchStmt.kind != texpr.TypedExprIrStmtCall &&
        dispatchStmt.kind != texpr.TypedExprIrStmtIfCall &&
        dispatchStmt.kind != texpr.TypedExprIrStmtLetCall):
        resultDispatchReady = false
    if resultDispatchReady:
        if isErrStmt.detailKind != parser.NormalizedExprDetailResultIsErr ||
           valueStmt.detailKind != parser.NormalizedExprDetailResultValue:
            resultDispatchReady = false
        if errorIndex >= 0:
            let errorStmt = fnIr.statements[errorIndex]
            if errorStmt.kind != texpr.TypedExprIrStmtResultIntrinsic ||
               errorStmt.detailKind != parser.NormalizedExprDetailResultError:
                resultDispatchReady = false
    var resultParam = chengpath.PathTrim(isErrStmt.callArgsText)
    if Len(resultParam) <= 0:
        resultParam = LoweringPrimaryObjectIrParamSlotName(fnIr, 1)
    var valueName = chengpath.PathTrim(valueStmt.bindingName)
    let dispatchArgs = texpr.TypedExprSplitTopLevelCsv(dispatchStmt.callArgsText)
    if Len(valueName) <= 0 && dispatchArgs.len == 2:
        valueName = chengpath.PathTrim(dispatchArgs[1])
    if resultDispatchReady:
        if Len(resultParam) <= 0:
            resultDispatchReady = false
        if LoweringPrimaryObjectIrParamNameSlot(fnIr, resultParam) != 1:
            resultDispatchReady = false
        let valueArgText = chengpath.PathTrim(valueStmt.callArgsText)
        if Len(valueArgText) > 0 && valueArgText != resultParam:
            resultDispatchReady = false
        if errorIndex >= 0:
            let errorStmt = fnIr.statements[errorIndex]
            let errorArgText = chengpath.PathTrim(errorStmt.callArgsText)
            if Len(errorArgText) > 0 && errorArgText != resultParam:
                resultDispatchReady = false
        if LoweringFunctionTailName(unsupportedStmt.callTarget) != "BackendDriverDispatchMinUnsupported" ||
           LoweringFunctionTailName(dispatchStmt.callTarget) != "BackendDriverDispatchMinRunSystemLinkExecConcreteRequest":
            resultDispatchReady = false
        if unsupportedStmt.callArgCount != 1 || dispatchStmt.callArgCount != 2:
            resultDispatchReady = false
        if dispatchArgs.len != 2:
            resultDispatchReady = false
    if resultDispatchReady:
        if Len(valueName) <= 0:
            resultDispatchReady = false
        elif chengpath.PathTrim(dispatchArgs[1]) != valueName:
            resultDispatchReady = false
        if LoweringPrimaryObjectIrParamNameSlot(fnIr, chengpath.PathTrim(dispatchArgs[0])) != 0:
            resultDispatchReady = false
    if !resultDispatchReady:
        return false

    LoweringClearStructuredCalls(fnIr)
    let dispatchOrdinal = LoweringAppendStructuredCall(fnIr,
                                                       dispatchStmt,
                                                       sourceTexts)
    let unsupportedOrdinal = LoweringAppendStructuredCall(fnIr,
                                                          unsupportedStmt,
                                                          sourceTexts)
    if dispatchOrdinal != 0 ||
       unsupportedOrdinal != 1 ||
       fnIr.bodyIR.ops.len != 2 ||
       fnIr.callSequence.len != 2:
        LoweringClearStructuredCalls(fnIr)
        return false
    if fnIr.callSequence[0].resultSlot < 0 ||
       fnIr.callSequence[1].resultSlot < 0:
        LoweringClearStructuredCalls(fnIr)
        return false
    fnIr.bodyIR.blocks = []
    fnIr.bodyIR.terms = []
    var guardTerm: coreir.BodyTerm
    guardTerm.kind = coreir.BodyTermCbrTag
    guardTerm.conditionKind = coreir.BodyCondLocalZeroTag
    guardTerm.lhsSlot = 0 - 1 - 1
    guardTerm.resultSlot = guardTerm.lhsSlot
    guardTerm.trueBlock = 2
    guardTerm.falseBlock = 1
    add(guardTerm.operands, 0)
    add(guardTerm.operands, 8)
    add(guardTerm.operands, 208)
    let guardTermIndex = coreir.BodyIRAppendTerm(fnIr.bodyIR, guardTerm)
    let _ = coreir.BodyIRAppendBlock(fnIr.bodyIR, 0, 0, guardTermIndex)

    var dispatchReturnTerm: coreir.BodyTerm
    dispatchReturnTerm.kind = coreir.BodyTermReturnTag
    dispatchReturnTerm.resultSlot = fnIr.callSequence[0].resultSlot
    add(dispatchReturnTerm.operands, coreir.LocalI32Tag)
    let dispatchReturnTermIndex = coreir.BodyIRAppendTerm(fnIr.bodyIR, dispatchReturnTerm)
    let _ = coreir.BodyIRAppendBlock(fnIr.bodyIR, 0, 1, dispatchReturnTermIndex)

    var unsupportedReturnTerm: coreir.BodyTerm
    unsupportedReturnTerm.kind = coreir.BodyTermReturnTag
    unsupportedReturnTerm.resultSlot = fnIr.callSequence[1].resultSlot
    add(unsupportedReturnTerm.operands, coreir.LocalI32Tag)
    let unsupportedReturnTermIndex = coreir.BodyIRAppendTerm(fnIr.bodyIR, unsupportedReturnTerm)
    let _ = coreir.BodyIRAppendBlock(fnIr.bodyIR, 1, 1, unsupportedReturnTermIndex)
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    return true

fn LoweringCallTextTailName(textRaw: str): str =
    let text = chengpath.PathTrim(textRaw)
    var tailStart = 0
    if Len(text) >= 2:
        for i in 0..<(Len(text) - 1):
            if text[i] == ':' && text[i + 1] == ':':
                tailStart = i + 2
            elif text[i] == '.':
                tailStart = i + 1
    if tailStart > 0 && tailStart < Len(text):
        return chengpath.TextSlice(text, tailStart, Len(text) - tailStart)
    return text

fn LoweringNoargCallArgCallee(callArgsText: str): str =
    let text = chengpath.PathTrim(callArgsText)
    if Len(text) < 3:
        return ""
    if text[Len(text) - 1] != ')' || text[Len(text) - 2] != '(':
        return ""
    let callee = chengpath.PathTrim(chengpath.TextSlice(text, 0, Len(text) - 2))
    if Len(callee) <= 0:
        return ""
    for i in 0..<Len(callee):
        if parser.ParserIsInlineSpace(callee[i]) ||
           callee[i] == '(' ||
           callee[i] == ')' ||
           callee[i] == ',':
            return ""
    return callee

fn LoweringNoargCallArgMatchesStatement(callArgsText: str,
                                         stmt: PrimaryObjectIrStatement): bool =
    let callee = LoweringNoargCallArgCallee(callArgsText)
    if Len(callee) <= 0:
        return false
    if callee == stmt.surfaceText ||
       callee == stmt.callTarget:
        return true
    let calleeTail = LoweringCallTextTailName(callee)
    let targetTail = LoweringFunctionTailName(stmt.callTarget)
    return calleeTail == stmt.surfaceText ||
           calleeTail == targetTail ||
           callee == targetTail

fn LoweringAppendNestedNoargCallArgReturnCall(fnIr: var PrimaryObjectIrFunction,
                                               returnStmt: PrimaryObjectIrStatement,
                                               sourceTexts: texpr.TypedExprSourceText[]): bool =
    if !returnStmt.returnRoot ||
       returnStmt.kind != texpr.TypedExprIrStmtCall ||
       returnStmt.callArgCount != 1:
        return false
    if texpr.TypedExprNormalizeTypeText(returnStmt.resultType) != "str":
        return false
    var innerIndex: int32 = -1
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.lineNumber != returnStmt.lineNumber:
            continue
        if stmt.returnRoot ||
           stmt.kind != texpr.TypedExprIrStmtCall ||
           stmt.callArgCount != 0 ||
           Len(stmt.callTarget) <= 0:
            continue
        let innerType = texpr.TypedExprNormalizeTypeText(stmt.resultType)
        if innerType != "cstring" && innerType != "ptr":
            continue
        if !LoweringNoargCallArgMatchesStatement(returnStmt.callArgsText, stmt):
            continue
        innerIndex = stmtIndex
        break
    if innerIndex < 0:
        return false
    LoweringClearStructuredCalls(fnIr)
    let firstOrdinal = LoweringAppendStructuredCall(fnIr,
                                                    fnIr.statements[innerIndex],
                                                    sourceTexts)
    let secondOrdinal = LoweringAppendStructuredCall(fnIr,
                                                     returnStmt,
                                                     sourceTexts)
    if firstOrdinal != 0 || secondOrdinal != 1:
        LoweringClearStructuredCalls(fnIr)
        return false
    LoweringAppendBodyIrReturnCall(fnIr, returnStmt)
    if fnIr.bodyIR.ops.len != 3:
        LoweringClearStructuredCalls(fnIr)
        return false
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    return true

fn LoweringSourcePathForModule(workspaceRoot: str,
                                 packageRoot: str,
                                 externalPackageRoots: parser.ParserExternalPackageRoot[],
                                sourceClosurePaths: str[],
                                modulePath: str): str =
    let targetModulePath = chengpath.PathTrim(modulePath)
    for i in 0..<sourceClosurePaths.len:
        let sourcePath = parser.ParserNormalizePath(sourceClosurePaths[i])
        let sourceModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                                           packageRoot,
                                                                                           externalPackageRoots,
                                                                                           sourcePath)
        if sourceModulePath == targetModulePath:
            return sourcePath
    let fallbackSourcePath = parser.ParserModulePathToSourcePathWithExternalPackageRoots(workspaceRoot,
                                                                                         packageRoot,
                                                                                         externalPackageRoots,
                                                                                         targetModulePath)
    return parser.ParserNormalizePath(fallbackSourcePath)

fn LoweringBuildPrimaryObjectIr(plan: var LoweringPlanStub,
                                 sourceTexts: var texpr.TypedExprSourceText[],
                                 typedExprFacts: var ccsg.TypedExprFact[]): PrimaryObjectIr =
    var ir: PrimaryObjectIr
    for i in 0..<plan.functionNames.len:
        let sourcePath = plan.functionSourcePaths[i]
        let functionName = plan.functionNames[i]
        var fnIr: PrimaryObjectIrFunction
        fnIr.sourcePath = sourcePath
        fnIr.functionName = functionName
        let typedFnIndex = LoweringTypedIrFunctionIndex(plan.typedIr, sourcePath, functionName)
        var hasLetCall = false
        var letCallReturnKind = texpr.BodyKindUnsupported
        var leafBodyKind = texpr.BodyKindUnsupported
        var bodyLineNumber: int32
        if typedFnIndex >= 0:
            let typedFn = plan.typedIr.functions[typedFnIndex]
            fnIr.signatureLineNumber = typedFn.signatureLineNumber
            fnIr.returnType = typedFn.returnType
            LoweringAppendPrimaryObjectIrParams(fnIr,
                                                plan.typedIr,
                                                typedFnIndex)
            LoweringAppendPrimaryObjectIrStatements(fnIr,
                                                     plan.typedIr,
                                                     typedFnIndex,
                                                     typedExprFacts,
                                                     sourceTexts)
            bodyLineNumber = typedFn.bodyLineNumber
            var nodeEnd = typedFn.nodeStart + typedFn.nodeCount
            if nodeEnd > plan.typedIr.nodes.len:
                nodeEnd = plan.typedIr.nodes.len
            for nodeIndex in typedFn.nodeStart..<nodeEnd:
                if plan.typedIr.nodes[nodeIndex].opKind == texpr.TypedExprIrOpLetCall:
                    hasLetCall = true
                    break
            if typedFn.returnNodeIndex >= 0 && typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                if returnNode.opKind == texpr.TypedExprIrOpParamRef && returnNode.resultType == "int32":
                    if returnNode.paramSlot == 0:
                        leafBodyKind = texpr.BodyKindReturnI32Arg0
                    elif returnNode.paramSlot == 1:
                        leafBodyKind = texpr.BodyKindReturnI32Arg1
                    elif returnNode.paramSlot == 2:
                        leafBodyKind = texpr.BodyKindReturnI32Arg2
                    elif returnNode.paramSlot == 3:
                        leafBodyKind = texpr.BodyKindReturnI32Arg3
                elif returnNode.opKind == texpr.TypedExprIrOpI32Const:
                    if returnNode.literalText == "0":
                        leafBodyKind = texpr.BodyKindReturnZeroI32
                    else:
                        leafBodyKind = Fmt"{texpr.BodyKindReturnI32ConstPrefix}{returnNode.literalText}"
                    if hasLetCall:
                        letCallReturnKind = Fmt"{texpr.BodyKindLetCallReturnI32ConstPrefix}{returnNode.literalText}"
                elif returnNode.opKind == texpr.TypedExprIrOpI32Add:
                    leafBodyKind = texpr.BodyKindReturnI32AddArgs
                elif returnNode.opKind == texpr.TypedExprIrOpI32Sub:
                    leafBodyKind = texpr.BodyKindReturnI32SubArgs
                elif returnNode.opKind == texpr.TypedExprIrOpI32Mul:
                    leafBodyKind = texpr.BodyKindReturnI32MulArgs
                elif returnNode.opKind == texpr.TypedExprIrOpI32Asr:
                    leafBodyKind = texpr.BodyKindReturnI32AsrArgs
                elif returnNode.opKind == texpr.TypedExprIrOpI32Madd:
                    leafBodyKind = texpr.BodyKindReturnI32MaddArgs
                elif returnNode.opKind == texpr.TypedExprIrOpU64Arg0AndConst4NotZero:
                    leafBodyKind = texpr.BodyKindReturnU64Arg0AndConst4NotZero
                elif returnNode.opKind == texpr.TypedExprIrOpU64OrArg0Const4:
                    leafBodyKind = texpr.BodyKindReturnU64Arg0OrConst4
                elif returnNode.opKind == texpr.TypedExprIrOpI32IfArg0LeZeroConstElseConst:
                    var commaIndex = -1
                    for literalIndex in 0..<Len(returnNode.literalText):
                        if returnNode.literalText[literalIndex] == ',':
                            commaIndex = literalIndex
                            break
                    if commaIndex > 0 && commaIndex + 1 < Len(returnNode.literalText):
                        let thenText = chengpath.TextSlice(returnNode.literalText, 0, commaIndex)
                        let elseStart = commaIndex + 1
                        let elseText = chengpath.TextSlice(returnNode.literalText,
                                                           elseStart,
                                                           Len(returnNode.literalText) - elseStart)
                        leafBodyKind = Fmt"if_arg0_le_zero_return_i32_const_{thenText}_else_i32_const_{elseText}"
                elif returnNode.opKind == texpr.TypedExprIrOpF64Mul:
                    leafBodyKind = texpr.BodyKindReturnF64MulArgs
                elif returnNode.opKind == texpr.TypedExprIrOpStrLenFast:
                    leafBodyKind = texpr.BodyKindStrLenFastI32
                elif returnNode.opKind == texpr.TypedExprIrOpReturnStrArg0:
                    leafBodyKind = texpr.BodyKindReturnStrArg0
                elif returnNode.opKind == texpr.TypedExprIrOpStrEmptyReturn:
                    leafBodyKind = texpr.BodyKindReturnStrEmpty
                elif returnNode.opKind == texpr.TypedExprIrOpCstringToStrCopy:
                    leafBodyKind = texpr.BodyKindCstringToStrCopy
                elif returnNode.opKind == texpr.TypedExprIrOpMainF64MulCheckExit:
                    leafBodyKind = texpr.BodyKindMainF64MulCheckExit
                elif hasLetCall && returnNode.opKind == texpr.TypedExprIrOpLetCallResultI32:
                    letCallReturnKind = texpr.BodyKindLetCallReturnResultI32
                elif hasLetCall && returnNode.opKind == texpr.TypedExprIrOpLetCallI32IfResultLeZeroReturnZeroElseResultI32:
                    letCallReturnKind = texpr.BodyKindLetCallI32IfResultLeZeroReturnZeroElseResultI32
                elif hasLetCall && returnNode.opKind == texpr.TypedExprIrOpLetCallStrReturnLenI32:
                    letCallReturnKind = texpr.BodyKindLetCallReturnStrLenI32
                elif hasLetCall && returnNode.opKind == texpr.TypedExprIrOpLetCallStrThenCallArg0ReturnI32Const0:
                    letCallReturnKind = texpr.BodyKindLetCallStrThenCallArg0ReturnI32Const0
            if leafBodyKind == texpr.BodyKindUnsupported &&
               texpr.TypedExprNormalizeTypeText(typedFn.returnType) == "str":
                var literalContent = ""
                if LoweringSimpleStringLiteralContent(typedFn.returnExpr, literalContent):
                    leafBodyKind = texpr.BodyKindReturnStrLiteral
                    fnIr.returnStringLiteral = literalContent
        fnIr.bodyKind = leafBodyKind
        fnIr.bodyLineNumber = bodyLineNumber
        if fnIr.bodyKind == texpr.BodyKindUnsupported || hasLetCall:
            var callIndex = LoweringFindResolvedCallFactIndex(typedExprFacts,
                                                              sourcePath,
                                                              bodyLineNumber)
            if callIndex < 0:
                if letCallReturnKind == texpr.BodyKindLetCallStrThenCallArg0ReturnI32Const0:
                    if typedFnIndex >= 0 && typedFnIndex < plan.typedIr.functions.len:
                        let typedFn = plan.typedIr.functions[typedFnIndex]
                        if typedFn.returnNodeIndex >= 0 && typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                            let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                            for factIndex in 0..<typedExprFacts.len:
                                if parser.ParserNormalizePath(typedExprFacts[factIndex].sourcePath) != sourcePath:
                                    continue
                                if typedExprFacts[factIndex].lineNumber <= typedFn.signatureLineNumber ||
                                   typedExprFacts[factIndex].lineNumber >= returnNode.operand0NodeIndex:
                                    continue
                                if !typedExprFacts[factIndex].callResolved:
                                    continue
                                if Len(typedExprFacts[factIndex].callTarget) <= 0:
                                    continue
                                if typedExprFacts[factIndex].callArgCount != 0:
                                    continue
                                callIndex = factIndex
                                break
            if callIndex >= 0:
                let fact = typedExprFacts[callIndex]
                if fact.returnRoot && letCallReturnKind == texpr.BodyKindUnsupported:
                    if LoweringReturnCallArg0Arg1TruePassThrough(fnIr,
                                                                  fact.callArgsText,
                                                                  fact.callArgCount) ||
                       LoweringReturnCallArgsPassThrough(fnIr,
                                                         fact.callArgsText,
                                                         fact.callArgCount):
                        var firstImportcSymbol = ""
                        if fact.callTargetImportc:
                            firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                             fact.callTargetSourcePath,
                                                                             fact.callTarget)
                        add(fnIr.callArgCounts, fact.callArgCount)
                        add(fnIr.callTargets, fact.callTarget)
                        add(fnIr.callTargetSourcePaths, fact.callTargetSourcePath)
                        add(fnIr.callTargetImportcFlags, fact.callTargetImportc)
                        add(fnIr.callImportcSymbols, firstImportcSymbol)
                        var callOp: PrimaryObjectIrCallOp
                        callOp.targetSymbol = fact.callTarget
                        callOp.targetSourcePath = fact.callTargetSourcePath
                        callOp.importc = fact.callTargetImportc
                        callOp.importcSymbol = firstImportcSymbol
                        callOp.argCount = fact.callArgCount
                        callOp.argsText = fact.callArgsText
                        callOp.resultType = fact.typeText
                        callOp.resultSlot = -1
                        callOp.relocWordOffset = -1
                        callOp.argSlots = LoweringCallArgSlots(fnIr, fact.callArgsText)
                        add(fnIr.callSequence, callOp)
                        if LoweringReturnCallArg0Arg1TruePassThrough(fnIr,
                                                                      fact.callArgsText,
                                                                      fact.callArgCount):
                            fnIr.bodyKind = texpr.BodyKindReturnCallArg0Arg1TruePassthrough
                        else:
                            fnIr.bodyKind = LoweringPrimaryObjectIrBodyKindForCallArgCount(fact.callArgCount)
                else:
                    if letCallReturnKind == texpr.BodyKindLetCallStrThenCallArg0ReturnI32Const0:
                        if typedFnIndex >= 0 && typedFnIndex < plan.typedIr.functions.len:
                            let typedFn = plan.typedIr.functions[typedFnIndex]
                            if typedFn.returnNodeIndex >= 0 && typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                                let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                                var secondCallIndex = LoweringFindResolvedCallFactIndex(typedExprFacts,
                                                                                        sourcePath,
                                                                                        returnNode.operand0NodeIndex)
                                if secondCallIndex < 0:
                                    for factIndex in 0..<typedExprFacts.len:
                                        if typedExprFacts[factIndex].sourcePath != sourcePath:
                                            continue
                                        if typedExprFacts[factIndex].lineNumber <= bodyLineNumber ||
                                           typedExprFacts[factIndex].lineNumber > returnNode.lineNumber:
                                            continue
                                        if !typedExprFacts[factIndex].callResolved:
                                            continue
                                        if Len(typedExprFacts[factIndex].callTarget) <= 0:
                                            continue
                                        secondCallIndex = factIndex
                                        break
                                if secondCallIndex >= 0:
                                    let secondFact = typedExprFacts[secondCallIndex]
                                    let secondArgText = chengpath.PathTrim(secondFact.callArgsText)
                                    let firstFactType = texpr.TypedExprNormalizeTypeText(fact.typeText)
                                    if firstFactType == "str" &&
                                       fact.callArgCount == 0 &&
                                       secondFact.callArgCount == 1 &&
                                       secondArgText == returnNode.surfaceText:
                                        var firstImportcSymbol = ""
                                        if fact.callTargetImportc:
                                            firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                             fact.callTargetSourcePath,
                                                                                             fact.callTarget)
                                        var secondImportcSymbol = ""
                                        if secondFact.callTargetImportc:
                                            secondImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                               secondFact.callTargetSourcePath,
                                                                                               secondFact.callTarget)
                                        add(fnIr.callArgCounts, 0)
                                        add(fnIr.callTargets, fact.callTarget)
                                        add(fnIr.callTargetSourcePaths, fact.callTargetSourcePath)
                                        add(fnIr.callTargetImportcFlags, fact.callTargetImportc)
                                        add(fnIr.callImportcSymbols, firstImportcSymbol)
                                        add(fnIr.callArgCounts, 1)
                                        add(fnIr.callTargets, secondFact.callTarget)
                                        add(fnIr.callTargetSourcePaths, secondFact.callTargetSourcePath)
                                        add(fnIr.callTargetImportcFlags, secondFact.callTargetImportc)
                                        add(fnIr.callImportcSymbols, secondImportcSymbol)
                                        LoweringSetStatementSequenceReturn(fnIr,
                                                                           texpr.StatementReturnModeStrThenCallReturnI32Const0,
                                                                           0)
                    else:
                        if fact.callArgCount == 0:
                            let factType = texpr.TypedExprNormalizeTypeText(fact.typeText)
                            if factType == "int32":
                                var firstImportcSymbol = ""
                                if fact.callTargetImportc:
                                    firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                     fact.callTargetSourcePath,
                                                                                     fact.callTarget)
                                if letCallReturnKind == texpr.BodyKindLetCallReturnResultI32:
                                    LoweringSetStatementSequenceReturn(fnIr,
                                                                       texpr.StatementReturnModeCallResultI32,
                                                                       0)
                                else:
                                    if letCallReturnKind == texpr.BodyKindLetCallI32IfResultLeZeroReturnZeroElseResultI32:
                                        LoweringSetStatementSequenceReturn(fnIr,
                                                                           texpr.StatementReturnModeI32GuardResultLeZero,
                                                                           0)
                                    else:
                                        if chengpath.TextStartsWith(letCallReturnKind, texpr.BodyKindLetCallReturnI32ConstPrefix):
                                            let parseRes = bkind.BodyKindParseLetCallNoargReturnI32Const(letCallReturnKind,
                                                                                                          "lowering_plan")
                                            var literalValue: int32
                                            if IsOk(parseRes):
                                                literalValue = Value(parseRes)
                                            LoweringSetStatementSequenceReturn(fnIr,
                                                                               texpr.StatementReturnModeI32Const,
                                                                               literalValue)
                                if fnIr.bodyKind != texpr.BodyKindUnsupported:
                                    add(fnIr.callArgCounts, fact.callArgCount)
                                    add(fnIr.callTargets, fact.callTarget)
                                    add(fnIr.callTargetSourcePaths, fact.callTargetSourcePath)
                                    add(fnIr.callTargetImportcFlags, fact.callTargetImportc)
                                    add(fnIr.callImportcSymbols, firstImportcSymbol)
                            else:
                                if factType == "str":
                                    if letCallReturnKind == texpr.BodyKindLetCallReturnStrLenI32:
                                        var firstImportcSymbol = ""
                                        if fact.callTargetImportc:
                                            firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                             fact.callTargetSourcePath,
                                                                                             fact.callTarget)
                                        add(fnIr.callArgCounts, fact.callArgCount)
                                        add(fnIr.callTargets, fact.callTarget)
                                        add(fnIr.callTargetSourcePaths, fact.callTargetSourcePath)
                                        add(fnIr.callTargetImportcFlags, fact.callTargetImportc)
                                        add(fnIr.callImportcSymbols, firstImportcSymbol)
                                        LoweringSetStatementSequenceReturn(fnIr,
                                                                           texpr.StatementReturnModeStrLen,
                                                                           0)
        if hasLetCall && fnIr.bodyKind == texpr.BodyKindUnsupported && leafBodyKind != texpr.BodyKindUnsupported:
            fnIr.bodyKind = leafBodyKind
        if fnIr.bodyKind == texpr.BodyKindUnsupported && typedFnIndex >= 0 && typedFnIndex < plan.typedIr.functions.len:
            let typedFn = plan.typedIr.functions[typedFnIndex]
            if typedFn.returnNodeIndex >= 0 && typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                if returnNode.opKind == texpr.TypedExprIrOpLetCallStrThenCallArg0ReturnI32Const0:
                    var functionEndLine: int32 = typedFn.endLineNumber + 1
                    if functionEndLine <= bodyLineNumber:
                        functionEndLine = 2147483647
                    var firstCallIndex = LoweringFindResolvedCallFactIndex(typedExprFacts,
                                                                           sourcePath,
                                                                           bodyLineNumber)
                    if firstCallIndex < 0:
                        for factIndex in 0..<typedExprFacts.len:
                            if typedExprFacts[factIndex].sourcePath != sourcePath:
                                continue
                            if typedExprFacts[factIndex].lineNumber < bodyLineNumber ||
                               typedExprFacts[factIndex].lineNumber >= functionEndLine:
                                continue
                            if !typedExprFacts[factIndex].callResolved:
                                continue
                            if Len(typedExprFacts[factIndex].callTarget) <= 0:
                                continue
                            if typedExprFacts[factIndex].callArgCount != 0:
                                continue
                            firstCallIndex = factIndex
                            break
                    var secondCallIndex = LoweringFindResolvedCallFactIndex(typedExprFacts,
                                                                            sourcePath,
                                                                            returnNode.operand0NodeIndex)
                    if secondCallIndex < 0:
                        for factIndex in 0..<typedExprFacts.len:
                            if factIndex == firstCallIndex:
                                continue
                            if typedExprFacts[factIndex].sourcePath != sourcePath:
                                continue
                            if typedExprFacts[factIndex].lineNumber <= bodyLineNumber ||
                               typedExprFacts[factIndex].lineNumber >= functionEndLine:
                                continue
                            if !typedExprFacts[factIndex].callResolved:
                                continue
                            if Len(typedExprFacts[factIndex].callTarget) <= 0:
                                continue
                            if typedExprFacts[factIndex].callArgCount != 1:
                                continue
                            let argText = chengpath.PathTrim(typedExprFacts[factIndex].callArgsText)
                            if argText != returnNode.surfaceText:
                                continue
                            secondCallIndex = factIndex
                            break
                    if firstCallIndex >= 0 && secondCallIndex >= 0:
                        let firstFact = typedExprFacts[firstCallIndex]
                        let secondFact = typedExprFacts[secondCallIndex]
                        let secondArgText = chengpath.PathTrim(secondFact.callArgsText)
                        let firstFactType = texpr.TypedExprNormalizeTypeText(firstFact.typeText)
                        if firstFactType == "str" &&
                           firstFact.callArgCount == 0 &&
                           secondFact.callArgCount == 1 &&
                           secondArgText == returnNode.surfaceText:
                            var firstImportcSymbol = ""
                            if firstFact.callTargetImportc:
                                firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                 firstFact.callTargetSourcePath,
                                                                                 firstFact.callTarget)
                            var secondImportcSymbol = ""
                            if secondFact.callTargetImportc:
                                secondImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                  secondFact.callTargetSourcePath,
                                                                                  secondFact.callTarget)
                            add(fnIr.callArgCounts, 0)
                            add(fnIr.callTargets, firstFact.callTarget)
                            add(fnIr.callTargetSourcePaths, firstFact.callTargetSourcePath)
                            add(fnIr.callTargetImportcFlags, firstFact.callTargetImportc)
                            add(fnIr.callImportcSymbols, firstImportcSymbol)
                            add(fnIr.callArgCounts, 1)
                            add(fnIr.callTargets, secondFact.callTarget)
                            add(fnIr.callTargetSourcePaths, secondFact.callTargetSourcePath)
                            add(fnIr.callTargetImportcFlags, secondFact.callTargetImportc)
                            add(fnIr.callImportcSymbols, secondImportcSymbol)
                            LoweringSetStatementSequenceReturn(fnIr,
                                                               texpr.StatementReturnModeStrThenCallReturnI32Const0,
                                                               0)
        let functionTailName = LoweringFunctionTailName(functionName)
        var structuredPopulated = false
        if !structuredPopulated &&
           fnIr.statements.len > 0:
            if LoweringTryFoldPureI32StructuredStatements(fnIr):
                structuredPopulated = true
        if !structuredPopulated &&
           typedFnIndex >= 0 &&
           typedFnIndex < plan.typedIr.functions.len:
            let typedFn = plan.typedIr.functions[typedFnIndex]
            if LoweringPopulateSingleI32ReturnCall(fnIr,
                                                   sourceTexts,
                                                   typedFn.returnExpr):
                structuredPopulated = true
        if !structuredPopulated:
            if LoweringPopulateStrCallConstThenCallArg0ReturnI32(fnIr, sourceTexts):
                structuredPopulated = true
        if !structuredPopulated &&
           typedFnIndex >= 0 &&
           typedFnIndex < plan.typedIr.functions.len:
            let typedFn = plan.typedIr.functions[typedFnIndex]
            if typedFn.returnNodeIndex >= 0 &&
               typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                if returnNode.opKind == texpr.TypedExprIrOpI32LetCallGuardLeZeroReturnZeroElseI32:
                    if LoweringPopulateI32LetCallGuardReturn(fnIr,
                                                             sourceTexts,
                                                             returnNode.surfaceText,
                                                             typedFn.returnExpr,
                                                             returnNode.lineNumber):
                        structuredPopulated = true
        if !structuredPopulated:
            if LoweringPopulateI32LetCallGuardReturnFromStatements(fnIr, sourceTexts):
                structuredPopulated = true
        if !structuredPopulated &&
           (functionTailName == "BackendDriverDispatchMinRunSystemLinkExecConcreteFields" ||
            functionTailName == "BackendDriverDispatchMinRunSystemLinkExecConcretePlan" ||
            functionTailName == "BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterSourceBundle" ||
            functionTailName == "BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterCsg" ||
            functionTailName == "BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckSystemReady" ||
            functionTailName == "BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckLoweringReady" ||
            functionTailName == "BackendDriverDispatchMinRunSystemLinkExecConcretePlanCheckPrimaryReady" ||
            functionTailName == "BackendDriverDispatchMinRunSystemLinkExecConcretePlanAfterReady"):
            if LoweringPopulateSingleTopIfCallCfgReturnI32(fnIr, sourceTexts):
                structuredPopulated = true
        if fnIr.statements.len > 0 &&
           texpr.TypedExprNormalizeTypeText(fnIr.returnType) == "int32":
            var cstringReady = true
            for stmtIndex in 0..<fnIr.statements.len:
                let stmt = fnIr.statements[stmtIndex]
                let argsText = stmt.callArgsText
                if stmt.kind != texpr.TypedExprIrStmtCall ||
                   stmt.returnRoot ||
                   stmt.callArgCount != 1 ||
                   Len(argsText) < 2 ||
                   argsText[0] != Char(34) ||
                   argsText[Len(argsText) - 1] != Char(34):
                    cstringReady = false
                    break
            if cstringReady:
                LoweringClearStructuredCalls(fnIr)
                for stmtIndex in 0..<fnIr.statements.len:
                    let _ = LoweringAppendStructuredCall(fnIr,
                                                         fnIr.statements[stmtIndex],
                                                         sourceTexts)
                var returnOp: coreir.BodyOp
                returnOp.kind = coreir.BodyOpReturnTag
                returnOp.target = -1
                add(returnOp.operands, texpr.StatementReturnModeCstringLiteralCallsReturnI32Const0)
                add(returnOp.operands, 0)
                add(fnIr.bodyIR.ops, returnOp)
                fnIr.bodyKind = texpr.BodyKindStatementSequence
                fnIr.statementReturnMode = texpr.StatementReturnModeCstringLiteralCallsReturnI32Const0
                fnIr.statementReturnI32Value = 0
                LoweringPopulateBodyIrBlocksTerms(fnIr)
                structuredPopulated = true
        if !structuredPopulated &&
           functionTailName == "BackendDriverDispatchMinRunCommandWithCmd":
            var dispatchReady = true
            var dispatchCallCount: int32
            var helpStmt: PrimaryObjectIrStatement
            var statusStmt: PrimaryObjectIrStatement
            var buildPlanStmt: PrimaryObjectIrStatement
            var verifyStmt: PrimaryObjectIrStatement
            var verifyParallelStmt: PrimaryObjectIrStatement
            var systemLinkStmt: PrimaryObjectIrStatement
            for stmtIndex in 0..<fnIr.statements.len:
                let stmt = fnIr.statements[stmtIndex]
                let isReturnCall =
                    stmt.returnRoot &&
                    (stmt.kind == texpr.TypedExprIrStmtCall ||
                     stmt.kind == texpr.TypedExprIrStmtIfCall) &&
                    stmt.callArgCount == 0 &&
                    Len(stmt.callTarget) > 0
                if isReturnCall:
                    if dispatchCallCount == 0:
                        helpStmt = stmt
                    elif dispatchCallCount == 1:
                        statusStmt = stmt
                    elif dispatchCallCount == 2:
                        buildPlanStmt = stmt
                    elif dispatchCallCount == 3:
                        verifyStmt = stmt
                    elif dispatchCallCount == 4:
                        verifyParallelStmt = stmt
                    elif dispatchCallCount == 5:
                        systemLinkStmt = stmt
                    dispatchCallCount = dispatchCallCount + 1
            if dispatchReady && dispatchCallCount != 6:
                dispatchReady = false
            if dispatchReady &&
               LoweringFunctionTailName(helpStmt.callTarget) != "BackendDriverDispatchMinHelp":
                dispatchReady = false
            if dispatchReady &&
               LoweringFunctionTailName(statusStmt.callTarget) != "BackendDriverDispatchMinStatusFromCmdline":
                dispatchReady = false
            if dispatchReady &&
               LoweringFunctionTailName(buildPlanStmt.callTarget) != "BackendDriverDispatchMinPrintBuildPlanCommandFromCmdline":
                dispatchReady = false
            if dispatchReady &&
               LoweringFunctionTailName(verifyStmt.callTarget) != "BackendDriverDispatchMinVerifyExportVisibilityFromCmdline":
                dispatchReady = false
            if dispatchReady &&
               LoweringFunctionTailName(verifyParallelStmt.callTarget) != "BackendDriverDispatchMinVerifyExportVisibilityParallelFromCmdline":
                dispatchReady = false
            if dispatchReady &&
               LoweringFunctionTailName(systemLinkStmt.callTarget) != "BackendDriverDispatchMinRunSystemLinkExecCommandFromCmdline":
                dispatchReady = false
            if dispatchReady:
                LoweringClearStructuredCalls(fnIr)
                let _ = LoweringAppendStructuredCall(fnIr, helpStmt, sourceTexts)
                let _ = LoweringAppendStructuredCall(fnIr, statusStmt, sourceTexts)
                let _ = LoweringAppendStructuredCall(fnIr, buildPlanStmt, sourceTexts)
                let _ = LoweringAppendStructuredCall(fnIr, verifyStmt, sourceTexts)
                let _ = LoweringAppendStructuredCall(fnIr, verifyParallelStmt, sourceTexts)
                let _ = LoweringAppendStructuredCall(fnIr, systemLinkStmt, sourceTexts)
                fnIr.bodyIR = coreir.BodyIR()
                fnIr.bodyKind = texpr.BodyKindBackendDriverCommandDispatch
                structuredPopulated = true
        if !structuredPopulated &&
           functionTailName == "BackendDriverDispatchMinRun":
            var countStmtIndex: int32 = -1
            var commandStmtIndex: int32 = -1
            for stmtIndex in 0..<fnIr.statements.len:
                let stmt = fnIr.statements[stmtIndex]
                if countStmtIndex < 0 &&
                   (stmt.bindingName == "count" ||
                    stmt.lineNumber == bodyLineNumber):
                    countStmtIndex = stmtIndex
                if stmt.returnRoot &&
                   (stmt.lineNumber > bodyLineNumber ||
                    LoweringFunctionTailName(stmt.callTarget) == "BackendDriverDispatchMinRunCommand"):
                    commandStmtIndex = stmtIndex
            var runReady = countStmtIndex >= 0 && commandStmtIndex >= 0
            var countStmt: PrimaryObjectIrStatement
            var commandStmt: PrimaryObjectIrStatement
            if runReady:
                let countSourceStmt = fnIr.statements[countStmtIndex]
                countStmt.sourcePath = countSourceStmt.sourcePath
                countStmt.functionName = countSourceStmt.functionName
                countStmt.statementIndex = countSourceStmt.statementIndex
                countStmt.lineNumber = countSourceStmt.lineNumber
                countStmt.columnNumber = countSourceStmt.columnNumber
                countStmt.lineIndent = countSourceStmt.lineIndent
                countStmt.enclosingIfLineNumber = countSourceStmt.enclosingIfLineNumber
                countStmt.enclosingIfConditionText = countSourceStmt.enclosingIfConditionText
                countStmt.kind = texpr.TypedExprIrStmtLetCall
                countStmt.detailKind = countSourceStmt.detailKind
                countStmt.bindingName = countSourceStmt.bindingName
                countStmt.resultType = "int32"
                countStmt.callTarget = countSourceStmt.callTarget
                countStmt.callTargetSourcePath = countSourceStmt.callTargetSourcePath
                countStmt.callTargetImportc = countSourceStmt.callTargetImportc
                countStmt.callArgCount = countSourceStmt.callArgCount
                countStmt.callArgsText = countSourceStmt.callArgsText
                countStmt.callImportcSymbol = countSourceStmt.callImportcSymbol
                countStmt.returnRoot = false
                let commandSourceStmt = fnIr.statements[commandStmtIndex]
                commandStmt.sourcePath = commandSourceStmt.sourcePath
                commandStmt.functionName = commandSourceStmt.functionName
                commandStmt.statementIndex = commandSourceStmt.statementIndex
                commandStmt.lineNumber = commandSourceStmt.lineNumber
                commandStmt.columnNumber = commandSourceStmt.columnNumber
                commandStmt.lineIndent = commandSourceStmt.lineIndent
                commandStmt.enclosingIfLineNumber = commandSourceStmt.enclosingIfLineNumber
                commandStmt.enclosingIfConditionText = commandSourceStmt.enclosingIfConditionText
                commandStmt.kind = texpr.TypedExprIrStmtCall
                commandStmt.detailKind = commandSourceStmt.detailKind
                commandStmt.bindingName = commandSourceStmt.bindingName
                commandStmt.resultType = "int32"
                commandStmt.callTarget = commandSourceStmt.callTarget
                commandStmt.callTargetSourcePath = commandSourceStmt.callTargetSourcePath
                commandStmt.callTargetImportc = commandSourceStmt.callTargetImportc
                commandStmt.callArgCount = commandSourceStmt.callArgCount
                commandStmt.callArgsText = commandSourceStmt.callArgsText
                commandStmt.callImportcSymbol = commandSourceStmt.callImportcSymbol
                commandStmt.returnRoot = true
            if countStmt.kind != texpr.TypedExprIrStmtLetCall ||
               commandStmt.kind != texpr.TypedExprIrStmtCall:
                runReady = false
            if runReady && !commandStmt.returnRoot:
                runReady = false
            if runReady && (countStmt.callArgCount != 0 || commandStmt.callArgCount != 0):
                runReady = false
            if runReady && Len(countStmt.bindingName) <= 0:
                runReady = false
            if runReady &&
               (texpr.TypedExprNormalizeTypeText(countStmt.resultType) != "int32" ||
                texpr.TypedExprNormalizeTypeText(commandStmt.resultType) != "int32"):
                runReady = false
            if runReady:
                LoweringClearStructuredCalls(fnIr)
                let countOrdinal = LoweringAppendStructuredCall(fnIr, countStmt, sourceTexts)
                if countOrdinal != 0 || fnIr.callSequence.len <= 0 || fnIr.callSequence[0].resultSlot < 0:
                    LoweringClearStructuredCalls(fnIr)
                    runReady = false
            if runReady:
                var branchOp: coreir.BodyOp
                branchOp.kind = coreir.BodyOpBranchTag
                add(branchOp.operands, coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag)
                add(branchOp.operands, fnIr.callSequence[0].resultSlot)
                add(branchOp.operands, 0)
                branchOp.target = -1
                add(fnIr.bodyIR.ops, branchOp)
                let commandOrdinal = LoweringAppendStructuredCall(fnIr, commandStmt, sourceTexts)
                if commandOrdinal != 1:
                    LoweringClearStructuredCalls(fnIr)
                    runReady = false
            if runReady:
                var returnOp: coreir.BodyOp
                returnOp.kind = coreir.BodyOpReturnTag
                returnOp.target = -1
                add(returnOp.operands, coreir.LocalI32Tag)
                add(fnIr.bodyIR.ops, returnOp)
                fnIr.bodyKind = texpr.BodyKindStatementSequence
                LoweringPopulateBodyIrBlocksTerms(fnIr)
                structuredPopulated = true
        if !structuredPopulated &&
           functionTailName == "BackendDriverDispatchMinRunSystemLinkExecWithRequest" &&
           LoweringPopulateResultRequestDispatchBodyIr(fnIr, sourceTexts):
            structuredPopulated = true
        if !structuredPopulated:
            LoweringClearStructuredCalls(fnIr)
            var passThroughReturnReady = false
            for stmtIndex in 0..<fnIr.statements.len:
                let stmt = fnIr.statements[stmtIndex]
                if !stmt.returnRoot ||
                   stmt.kind != texpr.TypedExprIrStmtCall ||
                   stmt.callArgCount != 3 ||
                   Len(stmt.callTarget) <= 0:
                    continue
                if !LoweringReturnCallArg0Arg1TruePassThrough(fnIr,
                                                               stmt.callArgsText,
                                                               stmt.callArgCount):
                    continue
                var importcSymbol = ""
                if stmt.callTargetImportc:
                    importcSymbol = LoweringStatementImportcSymbol(stmt, sourceTexts)
                var callOp: PrimaryObjectIrCallOp
                callOp.targetSymbol = stmt.callTarget
                callOp.targetSourcePath = stmt.callTargetSourcePath
                callOp.importc = stmt.callTargetImportc
                callOp.importcSymbol = importcSymbol
                callOp.argCount = stmt.callArgCount
                callOp.argsText = stmt.callArgsText
                callOp.resultType = stmt.resultType
                callOp.bindingName = stmt.bindingName
                callOp.resultSlot = -1
                callOp.relocWordOffset = -1
                callOp.argSlots = LoweringCallArgSlots(fnIr, stmt.callArgsText)
                add(fnIr.callSequence, callOp)
                add(fnIr.callArgCounts, stmt.callArgCount)
                add(fnIr.callTargets, stmt.callTarget)
                add(fnIr.callTargetSourcePaths, stmt.callTargetSourcePath)
                add(fnIr.callTargetImportcFlags, stmt.callTargetImportc)
                add(fnIr.callImportcSymbols, importcSymbol)
                fnIr.callTargetCount = 1
                fnIr.bodyKind = texpr.BodyKindReturnCallArg0Arg1TruePassthrough
                passThroughReturnReady = true
                break
            if passThroughReturnReady:
                structuredPopulated = true
        if !structuredPopulated:
            LoweringClearStructuredCalls(fnIr)
            var nestedReturnReady = false
            for stmtIndex in 0..<fnIr.statements.len:
                let stmt = fnIr.statements[stmtIndex]
                if !stmt.returnRoot:
                    continue
                if LoweringAppendNestedNoargCallArgReturnCall(fnIr,
                                                               stmt,
                                                               sourceTexts):
                    nestedReturnReady = true
                    break
            if nestedReturnReady:
                structuredPopulated = true
        if !structuredPopulated:
            LoweringClearStructuredCalls(fnIr)
            var returnCallStatementIndex: int32 = -1
            var typedReturnExpr = ""
            if typedFnIndex >= 0 && typedFnIndex < plan.typedIr.functions.len:
                typedReturnExpr = chengpath.PathTrim(plan.typedIr.functions[typedFnIndex].returnExpr)
            if Len(typedReturnExpr) <= 0:
                typedReturnExpr = LoweringSingleLinearTopReturnExpr(fnIr)
            var returnConstI32Value: int32
            let lowUirCanProduceReturn =
                LoweringFunctionHasReturnRootCall(fnIr, typedReturnExpr) ||
                leafBodyKind == texpr.BodyKindReturnZeroI32 ||
                bkind.BodyKindIsReturnI32Const(leafBodyKind) ||
                LoweringReturnExprConstI32Value(fnIr.returnType, typedReturnExpr, returnConstI32Value) ||
                LoweringFunctionReturnExprMatchesCallBinding(fnIr, typedReturnExpr)
            let useLowUirCalls = LoweringFunctionCanUseLowUirCalls(fnIr) &&
                                 lowUirCanProduceReturn
            if useLowUirCalls:
                if !LoweringPopulateLowUirCalls(fnIr, sourceTexts, typedReturnExpr):
                    LoweringClearStructuredCalls(fnIr)
                    fnIr.bodyKind = texpr.BodyKindUnsupported
                for stmtIndex in 0..<fnIr.statements.len:
                    let stmt = fnIr.statements[stmtIndex]
                    if stmt.returnRoot ||
                       LoweringReturnExprMatchesCallStatement(typedReturnExpr, stmt):
                        returnCallStatementIndex = stmtIndex
            else:
                let allowGenericLinearCalls = !LoweringFunctionHasControlFlowStatements(fnIr)
                if allowGenericLinearCalls:
                    LoweringEnsureLocalDeclSlots(fnIr)
                    LoweringAppendLocalDeclInitOps(fnIr)
                    for stmtIndex in 0..<fnIr.statements.len:
                        let stmt = fnIr.statements[stmtIndex]
                        if stmt.kind == texpr.TypedExprIrStmtResultIntrinsic:
                            let resultSlotName = LoweringResultIntrinsicSlotName(stmt)
                            if Len(resultSlotName) > 0:
                                let _ = LoweringBodyIrEnsureLocalSlot(fnIr,
                                                                      resultSlotName,
                                                                      stmt.resultType)
                    for stmtIndex in 0..<fnIr.statements.len:
                        let stmt = fnIr.statements[stmtIndex]
                        if Len(stmt.callTarget) > 0:
                            let _ = LoweringAppendStructuredCall(fnIr, stmt, sourceTexts)
                            if stmt.returnRoot ||
                               LoweringReturnExprMatchesCallStatement(typedReturnExpr, stmt):
                                returnCallStatementIndex = stmtIndex
            if fnIr.statementReturnMode == texpr.StatementReturnModeNone &&
               fnIr.callSequence.len > 0:
                if leafBodyKind == texpr.BodyKindReturnZeroI32:
                    LoweringSetStatementSequenceReturn(fnIr,
                                                       texpr.StatementReturnModeI32Const,
                                                       0)
                    fnIr.bodyKind = texpr.BodyKindStatementSequence
                elif bkind.BodyKindIsReturnI32Const(leafBodyKind):
                    let constRes = bkind.BodyKindParseReturnI32Const(leafBodyKind,
                                                                     "lowering_statement_call_const_return")
                    if IsOk(constRes):
                        LoweringSetStatementSequenceReturn(fnIr,
                                                           texpr.StatementReturnModeI32Const,
                                                           Value(constRes))
                        fnIr.bodyKind = texpr.BodyKindStatementSequence
                elif typedFnIndex >= 0 && typedFnIndex < plan.typedIr.functions.len:
                    let returnExpr = typedReturnExpr
                    var constValue: int32
                    if LoweringReturnExprConstI32Value(fnIr.returnType, returnExpr, constValue):
                        LoweringSetStatementSequenceReturn(fnIr,
                                                           texpr.StatementReturnModeI32Const,
                                                           constValue)
                        fnIr.bodyKind = texpr.BodyKindStatementSequence
                    elif fnIr.bodyIR.ops.len == fnIr.callSequence.len:
                        let returnSlot = LoweringBodyIrLocalSlotIndex(fnIr, returnExpr)
                        if returnSlot >= 0 && returnSlot < fnIr.bodyIR.localSlots.len:
                            let returnTypeKind = fnIr.bodyIR.localSlots[returnSlot].typeKind
                            if returnTypeKind == coreir.LocalI32Tag ||
                               returnTypeKind == coreir.LocalStrTag ||
                               returnTypeKind == coreir.LocalAggregateTag:
                                var returnOp: coreir.BodyOp
                                returnOp.kind = coreir.BodyOpReturnTag
                                returnOp.target = returnSlot
                                add(returnOp.operands, returnTypeKind)
                                add(fnIr.bodyIR.ops, returnOp)
                                fnIr.bodyKind = texpr.BodyKindStatementSequence
                                LoweringPopulateBodyIrBlocksTerms(fnIr)
            if fnIr.statementReturnMode != texpr.StatementReturnModeNone:
                LoweringAppendBodyIrStatementReturn(fnIr)
            elif returnCallStatementIndex >= 0 && returnCallStatementIndex < fnIr.statements.len:
                LoweringAppendBodyIrReturnCall(fnIr, fnIr.statements[returnCallStatementIndex])
            else:
                var topReturnStatementCount: int32
                for stmtIndex in 0..<fnIr.statements.len:
                    let stmt = fnIr.statements[stmtIndex]
                    if stmt.kind == texpr.TypedExprIrStmtReturn &&
                       stmt.enclosingIfLineNumber <= 0:
                        topReturnStatementCount = topReturnStatementCount + 1
                let normalizedReturnType = texpr.TypedExprNormalizeTypeText(fnIr.returnType)
                if topReturnStatementCount == 1 &&
                   fnIr.callSequence.len > 0 &&
                   fnIr.bodyIR.ops.len == fnIr.callSequence.len &&
                   (normalizedReturnType == "int32" || normalizedReturnType == "bool"):
                    let lastCallIndex = fnIr.callSequence.len - 1
                    let resultSlot = fnIr.callSequence[lastCallIndex].resultSlot
                    if resultSlot >= 0 && resultSlot < fnIr.bodyIR.localSlots.len &&
                       fnIr.bodyIR.localSlots[resultSlot].typeKind == coreir.LocalI32Tag:
                        var returnOp: coreir.BodyOp
                        returnOp.kind = coreir.BodyOpReturnTag
                        returnOp.target = resultSlot
                        add(returnOp.operands, coreir.LocalI32Tag)
                        add(fnIr.bodyIR.ops, returnOp)
                        fnIr.bodyKind = texpr.BodyKindStatementSequence
                        LoweringPopulateBodyIrBlocksTerms(fnIr)
                if fnIr.bodyKind != texpr.BodyKindStatementSequence:
                    let _ = LoweringAppendLastAggregateCallReturn(fnIr)
        fnIr.bodyIR = LoweringOptimizeBodyIr(fnIr.bodyIR)
        fnIr.callTargetCount = fnIr.callTargets.len
        add(ir.functions, fnIr)
    return ir

fn LoweringIsImportcAnnotation(lineRaw: str): bool =
    let line = chengpath.PathTrim(lineRaw)
    if line == "":
        return false
    return chengpath.TextStartsWith(line, "@importc")

fn LoweringFunctionResultLayoutKind(functionName: str): int32 =
    if functionName == "main":
        return LoweringLayoutKindI32()
    return LoweringLayoutKindInvalid()

fn LoweringInternIdForSymbol(functionSymbolTexts: str[], functionNameIds: int32[], symbolText: str): int32 =
    for i in 0..<functionNameIds.len:
        if functionSymbolTexts[i] == symbolText:
            return functionNameIds[i]
    return functionSymbolTexts.len

fn LoweringCollectFunctionsFromSource(workspaceRoot: str,
                                        packageRoot: str,
                                        entryPath: str,
                                        entrySymbol: str,
                                        sourcePath: str,
                                        plan: var LoweringPlanStub): bool =
    if !parser.ParserSourceExists(sourcePath):
        return false
    let ownerModulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    let text = chengpath.ReadTextFile("", sourcePath)
    var decls: parser.NormalizedFunctionDecl[]
    var err = ""
    if !parser.ParserReadNormalizedFunctionDecls(text, decls, err):
        return false
    for i in 0..<decls.len:
        let decl = decls[i]
        let functionName = decl.name
        if decl.importc:
            continue
        var symbolText = LoweringFunctionSymbolText(ownerModulePath, functionName)
        if Len(decl.explicitExportName) > 0:
            symbolText = decl.explicitExportName
        var entryFlag: int32
        let callConv = LoweringCallConvInternal()
        let resultLayoutKind = LoweringFunctionResultLayoutKind(functionName)
        if sourcePath == entryPath && functionName == entrySymbol:
            entryFlag = 1
        add(plan.functionSourcePaths, sourcePath)
        add(plan.functionOwnerModulePaths, ownerModulePath)
        add(plan.functionNames, functionName)
        add(plan.functionSymbolTexts, symbolText)
        add(plan.functionExportedFlags, 0)
        add(plan.functionExportSymbolNames, "")
        add(plan.functionEntryFlags, entryFlag)
        add(plan.functionCallConvs, callConv)
        add(plan.functionResultLayoutKinds, resultLayoutKind)
    return true

fn LoweringFunctionListText(functionSymbolTexts: str[]): str =
    return LoweringListText(functionSymbolTexts)

fn LoweringPrimaryObjectIrBodyKindListText(ir: PrimaryObjectIr): str =
    if ir.functions.len <= 0:
        return "-"
    var out = ""
    for i in 0..<ir.functions.len:
        if i > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{ir.functions[i].bodyKind}"
    return out

fn LoweringPrimaryObjectIrCountBodyKind(ir: PrimaryObjectIr,
                                         bodyKind: str): int32 =
    var count: int32
    for i in 0..<ir.functions.len:
        if ir.functions[i].bodyKind == bodyKind:
            count = count + 1
    return count

fn LoweringBodyOpKindText(kind: int32): str =
    if kind == coreir.BodyOpLoadConstTag:
        return "load_const"
    if kind == coreir.BodyOpCallTag:
        return "call"
    if kind == coreir.BodyOpBinOpTag:
        return "bin_op"
    if kind == coreir.BodyOpCmpTag:
        return "cmp"
    if kind == coreir.BodyOpBranchTag:
        return "branch"
    if kind == coreir.BodyOpReturnTag:
        return "return"
    if kind == coreir.BodyOpLoadLocalTag:
        return "load_local"
    if kind == coreir.BodyOpStoreLocalTag:
        return "store_local"
    if kind == coreir.BodyOpCopyLocalTag:
        return "copy_local"
    return "invalid"

fn LoweringBodyIrReturnCount(bodyIR: coreir.BodyIR): int32 =
    var count: int32
    for i in 0..<bodyIR.ops.len:
        if bodyIR.ops[i].kind == coreir.BodyOpReturnTag:
            count = count + 1
    return count

fn LoweringBodyIrOpKindsText(bodyIR: coreir.BodyIR): str =
    if bodyIR.ops.len <= 0:
        return "-"
    var out = ""
    var limit = bodyIR.ops.len
    if limit > 7:
        limit = 7
    for i in 0..<limit:
        if i > 0:
            out = Fmt"{out}|"
        out = Fmt"{out}{LoweringBodyOpKindText(bodyIR.ops[i].kind)}"
    if bodyIR.ops.len > limit:
        out = Fmt"{out}|..."
    return out

fn LoweringPrimaryObjectIrReportText(ir: PrimaryObjectIr): str =
    var out = ""
    var callSequenceCounts = ""
    var callSequenceTargets = ""
    var bodyIrCallCounts = ""
    var bodyIrOpCounts = ""
    var bodyIrReturnCounts = ""
    var bodyIrOpKinds = ""
    var bodyIrLocalCounts = ""
    var statementSequenceCounts = ""
    var statementSequenceKinds = ""
    var statementSequenceTargets = ""
    var statementSequenceBindings = ""
    var statementSequenceResultTypes = ""
    var statementReturnModes = ""
    var statementReturnI32Values = ""
    var paramSlotCounts = ""
    var functionNames = ""
    for i in 0..<ir.functions.len:
        if i > 0:
            callSequenceCounts = Fmt"{callSequenceCounts},"
            callSequenceTargets = Fmt"{callSequenceTargets},"
            bodyIrCallCounts = Fmt"{bodyIrCallCounts},"
            bodyIrOpCounts = Fmt"{bodyIrOpCounts},"
            bodyIrReturnCounts = Fmt"{bodyIrReturnCounts},"
            bodyIrOpKinds = Fmt"{bodyIrOpKinds},"
            bodyIrLocalCounts = Fmt"{bodyIrLocalCounts},"
            statementSequenceCounts = Fmt"{statementSequenceCounts},"
            statementSequenceKinds = Fmt"{statementSequenceKinds},"
            statementSequenceTargets = Fmt"{statementSequenceTargets},"
            statementSequenceBindings = Fmt"{statementSequenceBindings},"
            statementSequenceResultTypes = Fmt"{statementSequenceResultTypes},"
            statementReturnModes = Fmt"{statementReturnModes},"
            statementReturnI32Values = Fmt"{statementReturnI32Values},"
            paramSlotCounts = Fmt"{paramSlotCounts},"
            functionNames = Fmt"{functionNames},"
        functionNames = Fmt"{functionNames}{ir.functions[i].functionName}"
        let targetCount: int32 = ir.functions[i].callSequence.len
        callSequenceCounts = Fmt"{callSequenceCounts}{targetCount}"
        paramSlotCounts = Fmt"{paramSlotCounts}{ir.functions[i].paramSlots.len}"
        if targetCount <= 0:
            callSequenceTargets = Fmt"{callSequenceTargets}-"
        else:
            var sequenceText = ir.functions[i].callSequence[0].targetSymbol
            if targetCount > 1:
                sequenceText = Fmt"{sequenceText}|{ir.functions[i].callSequence[1].targetSymbol}"
            if targetCount > 2:
                sequenceText = Fmt"{sequenceText}|{ir.functions[i].callSequence[2].targetSymbol}"
            if targetCount > 3:
                sequenceText = Fmt"{sequenceText}|{ir.functions[i].callSequence[3].targetSymbol}"
            if targetCount > 4:
                sequenceText = Fmt"{sequenceText}|..."
            callSequenceTargets = Fmt"{callSequenceTargets}{sequenceText}"
        bodyIrCallCounts = Fmt"{bodyIrCallCounts}{ir.functions[i].bodyIR.callSequence.len}"
        bodyIrOpCounts = Fmt"{bodyIrOpCounts}{ir.functions[i].bodyIR.ops.len}"
        bodyIrReturnCounts = Fmt"{bodyIrReturnCounts}{LoweringBodyIrReturnCount(ir.functions[i].bodyIR)}"
        bodyIrOpKinds = Fmt"{bodyIrOpKinds}{LoweringBodyIrOpKindsText(ir.functions[i].bodyIR)}"
        bodyIrLocalCounts = Fmt"{bodyIrLocalCounts}{ir.functions[i].bodyIR.localSlots.len}"
        let stmtCount: int32 = ir.functions[i].statements.len
        statementSequenceCounts = Fmt"{statementSequenceCounts}{stmtCount}"
        statementReturnModes = Fmt"{statementReturnModes}{ir.functions[i].statementReturnMode}"
        statementReturnI32Values = Fmt"{statementReturnI32Values}{ir.functions[i].statementReturnI32Value}"
        if stmtCount <= 0:
            statementSequenceKinds = Fmt"{statementSequenceKinds}-"
            statementSequenceTargets = Fmt"{statementSequenceTargets}-"
            statementSequenceBindings = Fmt"{statementSequenceBindings}-"
            statementSequenceResultTypes = Fmt"{statementSequenceResultTypes}-"
        else:
            var kindText = texpr.TypedExprIrStatementKindText(ir.functions[i].statements[0].kind)
            var targetText = ir.functions[i].statements[0].callTarget
            var bindingText = ""
            var resultTypeText = ""
            var stmtLimit = stmtCount
            if stmtLimit > 5:
                stmtLimit = 5
            for stmtIndex in 0..<stmtLimit:
                if stmtIndex > 0:
                    bindingText = Fmt"{bindingText}|"
                    resultTypeText = Fmt"{resultTypeText}|"
                var bindingName = ir.functions[i].statements[stmtIndex].bindingName
                if Len(bindingName) <= 0:
                    bindingName = "-"
                var resultType = ir.functions[i].statements[stmtIndex].resultType
                if Len(resultType) <= 0:
                    resultType = "-"
                bindingText = Fmt"{bindingText}{bindingName}"
                resultTypeText = Fmt"{resultTypeText}{resultType}"
            if stmtCount > stmtLimit:
                bindingText = Fmt"{bindingText}|..."
                resultTypeText = Fmt"{resultTypeText}|..."
            if Len(targetText) <= 0:
                targetText = "-"
            if stmtCount > 1:
                kindText = Fmt"{kindText}|{texpr.TypedExprIrStatementKindText(ir.functions[i].statements[1].kind)}"
                let nextTarget = ir.functions[i].statements[1].callTarget
                if Len(nextTarget) > 0:
                    targetText = Fmt"{targetText}|{nextTarget}"
                else:
                    targetText = Fmt"{targetText}|-"
            if stmtCount > 2:
                kindText = Fmt"{kindText}|{texpr.TypedExprIrStatementKindText(ir.functions[i].statements[2].kind)}"
                let nextTarget = ir.functions[i].statements[2].callTarget
                if Len(nextTarget) > 0:
                    targetText = Fmt"{targetText}|{nextTarget}"
                else:
                    targetText = Fmt"{targetText}|-"
            if stmtCount > 3:
                kindText = Fmt"{kindText}|{texpr.TypedExprIrStatementKindText(ir.functions[i].statements[3].kind)}"
                let nextTarget = ir.functions[i].statements[3].callTarget
                if Len(nextTarget) > 0:
                    targetText = Fmt"{targetText}|{nextTarget}"
                else:
                    targetText = Fmt"{targetText}|-"
            if stmtCount > 4:
                kindText = Fmt"{kindText}|{texpr.TypedExprIrStatementKindText(ir.functions[i].statements[4].kind)}"
                let fifthTarget = ir.functions[i].statements[4].callTarget
                if Len(fifthTarget) > 0:
                    targetText = Fmt"{targetText}|{fifthTarget}"
                else:
                    targetText = Fmt"{targetText}|-"
            if stmtCount > 5:
                kindText = Fmt"{kindText}|..."
                targetText = Fmt"{targetText}|..."
            statementSequenceKinds = Fmt"{statementSequenceKinds}{kindText}"
            statementSequenceTargets = Fmt"{statementSequenceTargets}{targetText}"
            statementSequenceBindings = Fmt"{statementSequenceBindings}{bindingText}"
            statementSequenceResultTypes = Fmt"{statementSequenceResultTypes}{resultTypeText}"
    LoweringAppendLine(out, "primary_object_ir_function_count", IntToStr(ir.functions.len))
    LoweringAppendLine(out, "primary_object_ir_functions", functionNames)
    LoweringAppendLine(out, "primary_object_ir_body_kinds", LoweringPrimaryObjectIrBodyKindListText(ir))
    LoweringAppendLine(out, "primary_object_ir_call_sequence_counts", callSequenceCounts)
    LoweringAppendLine(out, "primary_object_ir_call_sequence_targets", callSequenceTargets)
    LoweringAppendLine(out, "primary_object_ir_body_ir_call_counts", bodyIrCallCounts)
    LoweringAppendLine(out, "primary_object_ir_body_ir_op_counts", bodyIrOpCounts)
    LoweringAppendLine(out, "primary_object_ir_body_ir_return_counts", bodyIrReturnCounts)
    LoweringAppendLine(out, "primary_object_ir_body_ir_op_kinds", bodyIrOpKinds)
    LoweringAppendLine(out, "primary_object_ir_body_ir_local_counts", bodyIrLocalCounts)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_counts", statementSequenceCounts)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_kinds", statementSequenceKinds)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_targets", statementSequenceTargets)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_bindings", statementSequenceBindings)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_result_types", statementSequenceResultTypes)
    LoweringAppendLine(out, "primary_object_ir_statement_return_modes", statementReturnModes)
    LoweringAppendLine(out, "primary_object_ir_statement_return_i32_values", statementReturnI32Values)
    LoweringAppendLine(out, "primary_object_ir_param_slot_counts", paramSlotCounts)
    LoweringAppendLine(out, "primary_object_ir_return_zero_i32_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnZeroI32)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_add_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32AddArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_sub_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32SubArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_mul_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32MulArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_asr_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32AsrArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_madd_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32MaddArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_u64_arg0_and_const_4_not_zero_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnU64Arg0AndConst4NotZero)))
    LoweringAppendLine(out, "primary_object_ir_return_u64_arg0_or_const_4_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnU64Arg0OrConst4)))
    LoweringAppendLine(out, "primary_object_ir_return_f64_mul_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnF64MulArgs)))
    LoweringAppendLine(out, "primary_object_ir_str_len_fast_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindStrLenFastI32)))
    LoweringAppendLine(out, "primary_object_ir_return_str_arg0_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnStrArg0)))
    LoweringAppendLine(out, "primary_object_ir_return_str_empty_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnStrEmpty)))
    LoweringAppendLine(out, "primary_object_ir_let_call_noarg_i32_if_result_le_zero_return_zero_else_result_i32_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32)))
    LoweringAppendLine(out, "primary_object_ir_let_call_noarg_str_return_len_i32_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindLetCallNoargStrReturnLenI32)))
    LoweringAppendLine(out, "primary_object_ir_let_call_noarg_str_then_call_arg0_return_i32_const_0_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindLetCallNoargStrThenCallArg0ReturnI32Const0)))
    LoweringAppendLine(out, "primary_object_ir_cstring_to_str_copy_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindCstringToStrCopy)))
    LoweringAppendLine(out, "primary_object_ir_main_f64_mul_check_exit_count", IntToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindMainF64MulCheckExit)))
    return out

fn LoweringMissingReasons(functionNames: str[], functionEntryFlags: int32[], entrySymbol: str): str[] =
    var missing: str[]
    if functionNames.len <= 0:
        add(missing, "lowering_functions_missing")
        return missing
    if Len(entrySymbol) > 0:
        var entryLowered = false
        for i in 0..<functionEntryFlags.len:
            if functionEntryFlags[i] != 0:
                entryLowered = true
        if !entryLowered:
            add(missing, "lowering_entry_function_missing")
    return missing

fn LoweringSequentialNameIds(count: int32): int32[] =
    var out: int32[]
    out = []
    for i in 0..<count:
        add(out, i)
    return out

fn LoweringBoolIdentity(value: bool): bool =
    return value

fn BuildLoweringPlanStubFromCompilerCsg(linkPlan: slplan.SystemLinkPlanStub,
                                          compilerCsg: var ccsg.CompilerCsg,
                                          plan: var LoweringPlanStub,
                                          err: var str): bool =
    plan.functionSourcePaths = []
    plan.functionOwnerModulePaths = []
    plan.functionNames = []
    plan.functionSymbolTexts = []
    plan.functionExportedFlags = []
    plan.functionExportSymbolNames = []
    plan.functionNameIds = []
    plan.functionEntryFlags = []
    plan.functionCallConvs = []
    plan.functionResultLayoutKinds = []
    plan.typedExprFacts = []
    plan.typedIr = texpr.TypedExprIr()
    var emptyReturnOps: texpr.TypedExprReturnOpFact[]
    plan.typedReturnOps = emptyReturnOps
    plan.primaryObjectIr = PrimaryObjectIr()
    plan.loweringRules = []
    let workspaceRoot = slplan.SystemLinkPlanWorkspaceRoot(linkPlan)
    let packageRoot = slplan.SystemLinkPlanPackageRoot(linkPlan)
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    let packageId = slplan.SystemLinkPlanPackageId(linkPlan)
    let entryPath = slplan.SystemLinkPlanEntryPath(linkPlan)
    let entrySymbol = slplan.SystemLinkPlanEntrySymbol(linkPlan)
    let sourceClosurePaths = slplan.SystemLinkPlanSourceClosurePaths(linkPlan)
    for i in 0..<compilerCsg.nodes.len:
        let node = compilerCsg.nodes[i]
        if node.nodeKind != ccsg.CompilerCsgNodeKindSymbol:
            continue
        let sourcePath = LoweringSourcePathForModule(workspaceRoot,
                                                     packageRoot,
                                                     externalPackageRoots,
                                                     sourceClosurePaths,
                                                     node.modulePath)
        add(plan.functionSourcePaths, sourcePath)
        add(plan.functionOwnerModulePaths, node.modulePath)
        add(plan.functionNames, node.factText)
        add(plan.functionSymbolTexts, node.symbolText)
        add(plan.functionExportedFlags, node.exportedFlag)
        add(plan.functionExportSymbolNames, node.exportSymbolName)
        add(plan.functionEntryFlags, node.entryFlag)
        add(plan.functionCallConvs, node.callConv)
        add(plan.functionResultLayoutKinds, node.resultLayoutKind)
    compilerCsg.nodes = []
    compilerCsg.edges = []
    let functionSymbolTexts = LoweringPlanFunctionSymbolTexts(plan)
    let functionNameIds = LoweringSequentialNameIds(functionSymbolTexts.len)
    plan.functionNameIds = functionNameIds
    let functionNames = LoweringPlanFunctionNamesField(plan)
    let functionEntryFlags = LoweringPlanFunctionEntryFlagsField(plan)
    let missingReasons = LoweringMissingReasons(functionNames, functionEntryFlags, entrySymbol)
    plan.workspaceRoot = workspaceRoot
    plan.packageRoot = packageRoot
    plan.packageId = packageId
    plan.entryPath = entryPath
    plan.entrySymbol = entrySymbol
    plan.targetTriple = slplan.SystemLinkPlanTargetTriple(linkPlan)
    plan.sourceBundleCid = compilerCsg.sourceBundleCid
    plan.compilerCsgCid = compilerCsg.graphCid
    plan.exprSurfaceSourceCount = compilerCsg.exprLayer.sourceCount
    plan.exprSurfaceExprCount = parser.NormalizedExprLayerExprCount(compilerCsg.exprLayer)
    plan.exprSurfaceIfCount = parser.NormalizedExprLayerIfCount(compilerCsg.exprLayer)
    plan.exprSurfaceRangeCount = parser.NormalizedExprLayerRangeCount(compilerCsg.exprLayer)
    plan.exprSurfaceComprehensionCount = parser.NormalizedExprLayerComprehensionCount(compilerCsg.exprLayer)
    plan.exprSurfaceFmtCount = parser.NormalizedExprLayerStrFormatCount(compilerCsg.exprLayer)
    plan.exprSurfaceResultIntrinsicCount = parser.NormalizedExprLayerResultIntrinsicCount(compilerCsg.exprLayer)
    plan.exprSurfaceTryCount = parser.NormalizedExprLayerTryCount(compilerCsg.exprLayer)
    plan.exprSurfaceDefaultInitCount = parser.NormalizedExprLayerDefaultInitCount(compilerCsg.exprLayer)
    plan.exprSurfaceConstructorCount = parser.NormalizedExprLayerConstructorCount(compilerCsg.exprLayer)
    plan.exprSurfaceReturnCount = parser.NormalizedExprLayerReturnCount(compilerCsg.exprLayer)
    plan.exprSurfaceAssignCount = parser.NormalizedExprLayerAssignCount(compilerCsg.exprLayer)
    plan.exprSurfaceIfStmtCount = parser.NormalizedExprLayerIfStmtCount(compilerCsg.exprLayer)
    plan.exprSurfaceElifStmtCount = parser.NormalizedExprLayerElifStmtCount(compilerCsg.exprLayer)
    plan.exprSurfaceElseStmtCount = parser.NormalizedExprLayerElseStmtCount(compilerCsg.exprLayer)
    plan.exprSurfaceForStmtCount = parser.NormalizedExprLayerForStmtCount(compilerCsg.exprLayer)
    plan.exprSurfaceQuestionResidualCount = compilerCsg.exprLayer.questionResidualCount
    plan.typedExprFactCount = compilerCsg.typedExprFacts.len
    var callErr = ""
    if !texpr.TypedExprFactsValidateCallResolution(compilerCsg.exprLayer, compilerCsg.typedExprFacts, callErr):
        err = callErr
        return LoweringBoolIdentity(false)
    var loweringErr = ""
    var loweringRuleCount: int32
    if !texpr.TypedExprValidateLoweringRulesFromFacts(compilerCsg.typedExprFacts,
                                                       loweringRuleCount,
                                                       loweringErr):
        err = loweringErr
        return LoweringBoolIdentity(false)
    plan.loweringRuleCount = loweringRuleCount
    plan.typedCallFactCount = LoweringResolvedCallFactCount(compilerCsg.typedExprFacts)
    compilerCsg.exprLayer.exprLookup = parser.NormalizedExprLookup()
    var typedSourceTexts: texpr.TypedExprSourceText[]
    for i in 0..<sourceClosurePaths.len:
        let sourcePath = sourceClosurePaths[i]
        add(typedSourceTexts,
            texpr.TypedExprSourceTextNewWithExternalPackageRoots(workspaceRoot,
                                                                  packageRoot,
                                                                  externalPackageRoots,
                                                                  sourcePath,
                                                                  ""))
    var typedIrErr = ""
    if !texpr.TypedExprBuildIrFromExprLayer(typedSourceTexts, compilerCsg.exprLayer, plan.typedIr, typedIrErr):
        err = typedIrErr
        return LoweringBoolIdentity(false)
    plan.typedIrFunctionCount = plan.typedIr.functions.len
    plan.typedIrStatementCount = plan.typedIr.statements.len
    plan.typedIrNodeCount = plan.typedIr.nodes.len
    plan.typedReturnOps = texpr.TypedExprReturnOpFactsFromIr(plan.typedIr)
    plan.typedReturnOpCount = plan.typedReturnOps.len
    compilerCsg.exprLayer = parser.NormalizedExprLayer()
    for i in 0..<typedSourceTexts.len:
        let sourceText = chengpath.ReadTextFile("", typedSourceTexts[i].sourcePath)
        typedSourceTexts[i].text = sourceText
    plan.primaryObjectIr = LoweringBuildPrimaryObjectIr(plan, typedSourceTexts, compilerCsg.typedExprFacts)
    compilerCsg.typedExprFacts = []
    plan.typedIr = texpr.TypedExprIr()
    plan.typedReturnOps = emptyReturnOps
    typedSourceTexts = []
    plan.missingReasons = missingReasons
    plan.pipelineStage = "canonical_csg_to_lowering_plan"
    err = ""
    return LoweringBoolIdentity(true)

fn LoweringPlanFunctionSymbolTexts(plan: LoweringPlanStub): str[] =
    return plan.functionSymbolTexts

fn LoweringPlanFunctionNameIds(plan: LoweringPlanStub): int32[] =
    return plan.functionNameIds

fn LoweringPlanFunctionNamesField(plan: LoweringPlanStub): str[] =
    return plan.functionNames

fn LoweringPlanRulesForSource(plan: LoweringPlanStub,
                                sourcePathRaw: str): texpr.TypedExprLoweringRule[] =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    var out: texpr.TypedExprLoweringRule[]
    for i in 0..<plan.loweringRules.len:
        if plan.loweringRules[i].sourcePath != sourcePath:
            continue
        var rule: texpr.TypedExprLoweringRule
        rule.exprId = plan.loweringRules[i].exprId
        rule.sourcePath = plan.loweringRules[i].sourcePath
        rule.lineNumber = plan.loweringRules[i].lineNumber
        rule.columnNumber = plan.loweringRules[i].columnNumber
        rule.surfaceCallKind = plan.loweringRules[i].surfaceCallKind
        rule.callResolved = plan.loweringRules[i].callResolved
        rule.callReason = plan.loweringRules[i].callReason
        rule.callQualifier = plan.loweringRules[i].callQualifier
        rule.callCallee = plan.loweringRules[i].callCallee
        rule.callTarget = plan.loweringRules[i].callTarget
        rule.callTargetSourcePath = plan.loweringRules[i].callTargetSourcePath
        rule.callTargetImportc = plan.loweringRules[i].callTargetImportc
        rule.callPrefixStyle = plan.loweringRules[i].callPrefixStyle
        rule.callArgCount = plan.loweringRules[i].callArgCount
        rule.callArgsText = plan.loweringRules[i].callArgsText
        rule.typeText = plan.loweringRules[i].typeText
        rule.abiClass = plan.loweringRules[i].abiClass
        rule.valueKind = plan.loweringRules[i].valueKind
        rule.placeKind = plan.loweringRules[i].placeKind
        rule.loweringMode = plan.loweringRules[i].loweringMode
        rule.callKind = plan.loweringRules[i].callKind
        rule.typeCallKind = plan.loweringRules[i].typeCallKind
        rule.returnKind = plan.loweringRules[i].returnKind
        rule.argPassKind = plan.loweringRules[i].argPassKind
        rule.resultPassKind = plan.loweringRules[i].resultPassKind
        rule.materializeKind = plan.loweringRules[i].materializeKind
        rule.copyKind = plan.loweringRules[i].copyKind
        rule.importKind = plan.loweringRules[i].importKind
        add(out, rule)
    return out

fn LoweringPlanFunctionEntryFlagsField(plan: LoweringPlanStub): int32[] =
    return plan.functionEntryFlags

fn LoweringPlanMissingReasonsField(plan: LoweringPlanStub): str[] =
    return plan.missingReasons

fn LoweringPlanPipelineStage(plan: LoweringPlanStub): str =
    return plan.pipelineStage

fn BuildLoweringPlanStub(linkPlan: slplan.SystemLinkPlanStub,
                           plan: var LoweringPlanStub,
                           err: var str): bool =
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    if IsErr(sourceBundleRes):
        err = Error(sourceBundleRes)
        return false
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    if IsErr(csgRes):
        err = Error(csgRes)
        return false
    var csg = Value(csgRes)
    return BuildLoweringPlanStubFromCompilerCsg(linkPlan, csg, plan, err)

fn LoweringPlanStubReport(plan: LoweringPlanStub): str =
    var out: str
    var entryFunction = plan.entrySymbol
    let functionCount = IntToStr(plan.functionNames.len)
    let functionTexts = LoweringPlanFunctionSymbolTexts(plan)
    let functionList = LoweringFunctionListText(functionTexts)
    let missingField = LoweringPlanMissingReasonsField(plan)
    let missingReasons = slplan.SystemLinkPlanListText(missingField)
    let pipelineStage = LoweringPlanPipelineStage(plan)
    let primaryObjectIr = plan.primaryObjectIr
    if Len(entryFunction) <= 0:
        entryFunction = "-"
    LoweringAppendLine(out, "lowering_function_count", functionCount)
    LoweringAppendLine(out, "lowering_functions", functionList)
    LoweringAppendLine(out, "lowering_entry_function", entryFunction)
    LoweringAppendLine(out, "lowering_target", plan.targetTriple)
    LoweringAppendLine(out, "lowering_function_call_convs", LoweringIntListText(plan.functionCallConvs))
    LoweringAppendLine(out, "lowering_function_result_layout_kinds", LoweringIntListText(plan.functionResultLayoutKinds))
    LoweringAppendLine(out, "expr_surface_source_count", IntToStr(plan.exprSurfaceSourceCount))
    LoweringAppendLine(out, "expr_surface_expr_count", IntToStr(plan.exprSurfaceExprCount))
    LoweringAppendLine(out, "expr_surface_if_count", IntToStr(plan.exprSurfaceIfCount))
    LoweringAppendLine(out, "expr_surface_range_count", IntToStr(plan.exprSurfaceRangeCount))
    LoweringAppendLine(out, "expr_surface_comprehension_count", IntToStr(plan.exprSurfaceComprehensionCount))
    LoweringAppendLine(out, "expr_surface_fmt_count", IntToStr(plan.exprSurfaceFmtCount))
    LoweringAppendLine(out, "expr_surface_result_intrinsic_count", IntToStr(plan.exprSurfaceResultIntrinsicCount))
    LoweringAppendLine(out, "expr_surface_try_count", IntToStr(plan.exprSurfaceTryCount))
    LoweringAppendLine(out, "expr_surface_default_init_count", IntToStr(plan.exprSurfaceDefaultInitCount))
    LoweringAppendLine(out, "expr_surface_constructor_count", IntToStr(plan.exprSurfaceConstructorCount))
    LoweringAppendLine(out, "expr_surface_return_count", IntToStr(plan.exprSurfaceReturnCount))
    LoweringAppendLine(out, "expr_surface_assign_count", IntToStr(plan.exprSurfaceAssignCount))
    LoweringAppendLine(out, "expr_surface_if_stmt_count", IntToStr(plan.exprSurfaceIfStmtCount))
    LoweringAppendLine(out, "expr_surface_elif_stmt_count", IntToStr(plan.exprSurfaceElifStmtCount))
    LoweringAppendLine(out, "expr_surface_else_stmt_count", IntToStr(plan.exprSurfaceElseStmtCount))
    LoweringAppendLine(out, "expr_surface_for_stmt_count", IntToStr(plan.exprSurfaceForStmtCount))
    LoweringAppendLine(out, "expr_surface_question_residual_count", IntToStr(plan.exprSurfaceQuestionResidualCount))
    LoweringAppendLine(out, "typed_expr_fact_count", IntToStr(plan.typedExprFactCount))
    LoweringAppendLine(out, "typed_expr_call_fact_count", IntToStr(plan.typedCallFactCount))
    LoweringAppendLine(out, "typed_expr_lowering_rule_count", IntToStr(plan.loweringRuleCount))
    LoweringAppendLine(out, "typed_ir_function_count", IntToStr(plan.typedIrFunctionCount))
    LoweringAppendLine(out, "typed_ir_statement_count", IntToStr(plan.typedIrStatementCount))
    LoweringAppendLine(out, "typed_ir_node_count", IntToStr(plan.typedIrNodeCount))
    LoweringAppendLine(out, "typed_return_op_count", IntToStr(plan.typedReturnOpCount))
    let primaryObjectIrReport = LoweringPrimaryObjectIrReportText(primaryObjectIr)
    if Len(primaryObjectIrReport) > 0:
        if Len(out) > 0 && out[Len(out) - 1] != '\n':
            out = Fmt"{out}\n"
        out = Fmt"{out}{primaryObjectIrReport}"
    LoweringAppendLine(out, "lowering_source_bundle_cid", layout.FixedBytes32Hex(plan.sourceBundleCid))
    LoweringAppendLine(out, "lowering_compiler_csg_cid", layout.FixedBytes32Hex(plan.compilerCsgCid))
    LoweringAppendLine(out, "lowering_missing_reasons", missingReasons)
    LoweringAppendLine(out, "exec_pipeline_stage", pipelineStage)
    return out
