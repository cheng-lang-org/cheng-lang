import std/result
import std/strformat
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/lang/intern as langintern
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr
import cheng/core/ir/core_types as coreir
import cheng/core/backend/system_link_plan as slplan

type
    PrimaryObjectIrCallOp =
        targetSymbol: str
        targetSourcePath: str
        importc: bool
        importcSymbol: str
        argCount: int32
        argsText: str
        resultType: str
        bindingName: str
        resultSlot: int32
        relocWordOffset: int32
        argSlots: int32[]

    PrimaryObjectIrStatement =
        sourcePath: str
        functionName: str
        statementIndex: int32
        lineNumber: int32
        columnNumber: int32
        lineIndent: int32
        enclosingIfLineNumber: int32
        enclosingIfConditionText: str
        kind: texpr.TypedExprIrStatementKind
        detailKind: parser.NormalizedExprDetailKind
        bindingName: str
        resultType: str
        callTarget: str
        callTargetSourcePath: str
        callTargetImportc: bool
        callArgCount: int32
        callArgsText: str
        callImportcSymbol: str
        returnRoot: bool

    PrimaryObjectIrFunction =
        sourcePath: str
        functionName: str
        signatureLineNumber: int32
        bodyLineNumber: int32
        bodyKind: str
        statementReturnMode: int32
        statementReturnI32Value: int32
        statementCount: int32
        statements: PrimaryObjectIrStatement[]
        callTargetCount: int32
        callArgCounts: int32[]
        callTargets: str[]
        callTargetSourcePaths: str[]
        callTargetImportcFlags: bool[]
        callImportcSymbols: str[]
        bodyIR: coreir.BodyIR
        callSequence: PrimaryObjectIrCallOp[]

    PrimaryObjectIr =
        functions: PrimaryObjectIrFunction[]

    LoweringPlanStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entryPath: str
        entrySymbol: str
        sourceBundleCid: layout.FixedBytes32
        compilerCsgCid: layout.FixedBytes32
        exprLayer: parser.NormalizedExprLayer
        typedExprFacts: ccsg.TypedExprFact[]
        typedIr: texpr.TypedExprIr
        typedReturnOps: texpr.TypedExprReturnOpFact[]
        primaryObjectIr: PrimaryObjectIr
        loweringRules: texpr.TypedExprLoweringRule[]
        functionSourcePaths: str[]
        functionOwnerModulePaths: str[]
        functionNames: str[]
        functionSymbolTexts: str[]
        functionExportedFlags: int32[]
        functionExportSymbolNames: str[]
        functionNameIds: langintern.InternId[]
        functionEntryFlags: int32[]
        functionCallConvs: int32[]
        functionResultLayoutKinds: int32[]
        missingReasons: str[]
        pipelineStage: str

fn LoweringCallConvInternal(): int32 =
    return 1

fn LoweringLayoutKindInvalid(): int32 =
    return 0

fn LoweringLayoutKindI32(): int32 =
    return 5

fn LoweringAppendLine(out: var str, key: str, value: str) =
    if len(out) > 0:
        out = Fmt"{out}\n"
    out = Fmt"{out}{key}={value}"

fn LoweringListText(items: str[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if len(out) > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{items[i]}"
    return out

fn LoweringFunctionSymbolText(ownerModulePath: str, functionName: str): str =
    return Fmt"{ownerModulePath}::{functionName}"

fn LoweringFunctionTailName(functionName: str): str =
    var tailStart = 0
    if len(functionName) >= 2:
        for j in 0..<(len(functionName) - 1):
            if functionName[j] == ':' && functionName[j + 1] == ':':
                tailStart = j + 2
    if tailStart > 0 && tailStart < len(functionName):
        return chengpath.TextSlice(functionName, tailStart, len(functionName) - tailStart)
    return functionName

fn LoweringTypedIrFunctionIndex(ir: texpr.TypedExprIr,
                                 sourcePath: str,
                                 functionName: str): int32 =
    let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
    let tailName = LoweringFunctionTailName(functionName)
    for i in 0..<ir.functions.len:
        if parser.ParserNormalizePath(ir.functions[i].sourcePath) != normalizedSourcePath:
            continue
        if ir.functions[i].functionName == functionName ||
           ir.functions[i].functionName == tailName:
            return i
    return -1
fn LoweringFindResolvedCallFactIndex(facts: ccsg.TypedExprFact[],
                                      sourcePath: str,
                                      lineNumber: int32): int32 =
    if lineNumber <= 0:
        return -1
    let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
    for i in 0..<facts.len:
        if parser.ParserNormalizePath(facts[i].sourcePath) != normalizedSourcePath:
            continue
        if facts[i].lineNumber != lineNumber:
            continue
        if !facts[i].callResolved:
            continue
        if len(facts[i].callTarget) <= 0:
            continue
        return i
    return -1

fn LoweringStatementResultTypeFromFacts(typedStmt: texpr.TypedExprIrStatement,
                                         facts: ccsg.TypedExprFact[]): str =
    let stmtType = texpr.TypedExprNormalizeTypeText(typedStmt.resultType)
    if texpr.TypedExprTypeTextIsConcrete(stmtType):
        return stmtType
    let normalizedSourcePath = parser.ParserNormalizePath(typedStmt.sourcePath)
    for i in 0..<facts.len:
        if parser.ParserNormalizePath(facts[i].sourcePath) != normalizedSourcePath:
            continue
        if facts[i].lineNumber != typedStmt.lineNumber ||
           facts[i].columnNumber != typedStmt.columnNumber:
            continue
        if facts[i].exprId != typedStmt.exprId:
            continue
        if facts[i].callTarget != typedStmt.callTarget ||
           facts[i].callArgsText != typedStmt.callArgsText:
            continue
        let factType = texpr.TypedExprNormalizeTypeText(facts[i].typeText)
        if texpr.TypedExprTypeTextIsConcrete(factType):
            return factType
    return stmtType

fn LoweringPrimaryObjectIrBodyKindForCallArgCount(callArgCount: int32): str =
    if callArgCount == 0:
        return texpr.BodyKindReturnCallNoargI32
    if callArgCount == 1:
        return texpr.BodyKindReturnCallArg0I32
    if callArgCount == 2:
        return texpr.BodyKindReturnCallArg0Arg1I32
    if callArgCount == 3:
        return texpr.BodyKindReturnCallArg0Arg1Arg2I32
    return texpr.BodyKindUnsupported

fn LoweringSetStatementSequenceReturn(fnIr: var PrimaryObjectIrFunction,
                                       mode: int32,
                                       i32Value: int32) =
    fnIr.bodyKind = texpr.BodyKindStatementSequence
    fnIr.statementReturnMode = mode
    fnIr.statementReturnI32Value = i32Value

fn LoweringFunctionDeclLine(sourceTexts: texpr.TypedExprSourceText[],
                             sourcePath: str,
                             functionName: str): str =
    let normalizedSourcePath = parser.ParserNormalizePath(sourcePath)
    for sourceIndex in 0..<sourceTexts.len:
        if parser.ParserNormalizePath(sourceTexts[sourceIndex].sourcePath) != normalizedSourcePath:
            continue
        let lines = parser.ParserSplitChar(sourceTexts[sourceIndex].text, '\n')
        for lineIndex in 0..<lines.len:
            if LoweringFunctionDeclMatches(lines[lineIndex], functionName):
                return lines[lineIndex]
    return ""

fn LoweringFunctionParamNamesFromDeclLine(lineRaw: str): str[] =
    var out: str[]
    var openIndex = -1
    var closeIndex = -1
    for i in 0..<len(lineRaw):
        if lineRaw[i] == '(':
            openIndex = i
            break
    if openIndex < 0:
        return out
    for i in (openIndex + 1)..<len(lineRaw):
        if lineRaw[i] == ')':
            closeIndex = i
            break
    if closeIndex <= openIndex:
        return out
    let paramsText = chengpath.TextSlice(lineRaw, openIndex + 1, closeIndex - openIndex - 1)
    let pieces = parser.ParserSplitChar(paramsText, ',')
    for i in 0..<pieces.len:
        var piece = chengpath.PathTrim(pieces[i])
        if len(piece) <= 0:
            continue
        if chengpath.TextStartsWith(piece, "var "):
            piece = chengpath.PathTrim(chengpath.TextSlice(piece, 4, len(piece) - 4))
        var stop = len(piece)
        for j in 0..<len(piece):
            if piece[j] == ':':
                stop = j
                break
        let name = chengpath.PathTrim(chengpath.TextSlice(piece, 0, stop))
        if len(name) > 0:
            add(out, name)
    return out

fn LoweringCallArgNames(callArgsText: str): str[] =
    var out: str[]
    let pieces = parser.ParserSplitChar(callArgsText, ',')
    for i in 0..<pieces.len:
        let name = chengpath.PathTrim(pieces[i])
        if len(name) > 0:
            add(out, name)
    return out

fn LoweringReturnCallArgsPassThrough(sourceTexts: texpr.TypedExprSourceText[],
                                      sourcePath: str,
                                      functionName: str,
                                      callArgsText: str,
                                      callArgCount: int32): bool =
    if callArgCount <= 0:
        return true
    let declLine = LoweringFunctionDeclLine(sourceTexts, sourcePath, functionName)
    if len(declLine) <= 0:
        return false
    let paramNames = LoweringFunctionParamNamesFromDeclLine(declLine)
    let callArgNames = LoweringCallArgNames(callArgsText)
    if callArgNames.len != callArgCount:
        return false
    if paramNames.len < callArgCount:
        return false
    for i in 0..<callArgCount:
        if callArgNames[i] != paramNames[i]:
            return false
    return true

fn LoweringAnnotationQuotedValue(lineRaw: str,
                                  annotationName: str): str =
    let trimmed = chengpath.PathTrim(lineRaw)
    let prefix = Fmt"@{annotationName}(\""
    if !chengpath.TextStartsWith(trimmed, prefix):
        return ""
    let start = len(prefix)
    for i in start..<len(trimmed):
        if trimmed[i] == '"':
            return chengpath.TextSlice(trimmed, start, i - start)
    return ""

fn LoweringFunctionDeclMatches(lineRaw: str,
                                functionName: str): bool =
    let trimmed = chengpath.PathTrim(lineRaw)
    if !chengpath.TextStartsWith(trimmed, "fn "):
        return false
    let tailName = LoweringFunctionTailName(functionName)
    let rest = chengpath.TextSlice(trimmed, 3, len(trimmed) - 3)
    if !chengpath.TextStartsWith(rest, tailName):
        return false
    if len(rest) == len(tailName):
        return true
    let next = rest[len(tailName)]
    return next == '(' || next == '[' || next == ':' || next == ' '

fn LoweringImportcTargetSymbol(sourceTexts: texpr.TypedExprSourceText[],
                                targetSourcePath: str,
                                functionName: str): str =
    let normalizedTargetSourcePath = parser.ParserNormalizePath(targetSourcePath)
    for sourceIndex in 0..<sourceTexts.len:
        if parser.ParserNormalizePath(sourceTexts[sourceIndex].sourcePath) != normalizedTargetSourcePath:
            continue
        let lines = parser.ParserSplitChar(sourceTexts[sourceIndex].text, '\n')
        var pendingImportc = ""
        for lineIndex in 0..<lines.len:
            let importcName = LoweringAnnotationQuotedValue(lines[lineIndex], "importc")
            if len(importcName) > 0:
                pendingImportc = importcName
                continue
            if LoweringFunctionDeclMatches(lines[lineIndex], functionName):
                if len(pendingImportc) > 0:
                    return pendingImportc
                return functionName
            let trimmed = chengpath.PathTrim(lines[lineIndex])
            if chengpath.TextStartsWith(trimmed, "fn "):
                pendingImportc = ""
        return functionName
    return functionName

fn LoweringAppendPrimaryObjectIrStatements(fnIr: var PrimaryObjectIrFunction,
                                            typedIr: texpr.TypedExprIr,
                                            typedFnIndex: int32,
                                            typedFacts: ccsg.TypedExprFact[],
                                            sourceTexts: texpr.TypedExprSourceText[]) =
    if typedFnIndex < 0 || typedFnIndex >= typedIr.functions.len:
        return
    let typedFn = typedIr.functions[typedFnIndex]
    var stmtStart = typedFn.statementStart
    if stmtStart < 0:
        return
    if stmtStart >= typedIr.statements.len:
        return
    var stmtEnd = stmtStart + typedFn.statementCount
    if stmtEnd > typedIr.statements.len:
        stmtEnd = typedIr.statements.len
    for stmtIndex in stmtStart..<stmtEnd:
        let typedStmt = typedIr.statements[stmtIndex]
        var stmt: PrimaryObjectIrStatement
        stmt.sourcePath = typedStmt.sourcePath
        stmt.functionName = typedStmt.functionName
        stmt.statementIndex = typedStmt.statementIndex
        stmt.lineNumber = typedStmt.lineNumber
        stmt.columnNumber = typedStmt.columnNumber
        stmt.lineIndent = typedStmt.lineIndent
        stmt.enclosingIfLineNumber = typedStmt.enclosingIfLineNumber
        stmt.enclosingIfConditionText = typedStmt.enclosingIfConditionText
        stmt.kind = typedStmt.kind
        stmt.detailKind = typedStmt.detailKind
        stmt.bindingName = typedStmt.bindingName
        stmt.resultType = LoweringStatementResultTypeFromFacts(typedStmt, typedFacts)
        stmt.callTarget = typedStmt.callTarget
        stmt.callTargetSourcePath = typedStmt.callTargetSourcePath
        stmt.callTargetImportc = typedStmt.callTargetImportc
        stmt.callArgCount = typedStmt.callArgCount
        stmt.callArgsText = typedStmt.callArgsText
        stmt.returnRoot = typedStmt.returnRoot
        if typedStmt.callTargetImportc:
            stmt.callImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                 typedStmt.callTargetSourcePath,
                                                                 typedStmt.callTarget)
        add(fnIr.statements, stmt)
    fnIr.statementCount = fnIr.statements.len

fn LoweringAlignInt32(value: int32, align: int32): int32 =
    if align <= 1:
        return value
    let rem = value % align
    if rem == 0:
        return value
    return value + (align - rem)

fn LoweringTextEndsWith(text: str,
                         suffix: str): bool =
    if len(suffix) > len(text):
        return false
    let start = len(text) - len(suffix)
    for i in 0..<len(suffix):
        if text[start + i] != suffix[i]:
            return false
    return true

fn LoweringLocalTypeKind(typeTextRaw: str): int32 =
    let typeText = texpr.TypedExprNormalizeTypeText(typeTextRaw)
    if typeText == "int32" || typeText == "bool":
        return coreir.LocalI32Tag
    if typeText == "float64":
        return coreir.LocalF64Tag
    if typeText == "str":
        return coreir.LocalStrTag
    if typeText == "cstring":
        return coreir.LocalPtrTag
    if len(typeText) > 2 && LoweringTextEndsWith(typeText, "[]"):
        return coreir.LocalAggregateTag
    if chengpath.TextContains(typeText, "CompilerRequest"):
        return coreir.LocalAggregateTag
    if chengpath.TextStartsWith(typeText, "Result["):
        return coreir.LocalAggregateTag
    return coreir.LocalInvalidTag

fn LoweringLocalTypeSizeBytes(typeTextRaw: str,
                               typeKind: int32): int32 =
    let typeText = texpr.TypedExprNormalizeTypeText(typeTextRaw)
    if typeKind == coreir.LocalI32Tag:
        return 4
    if typeKind == coreir.LocalF64Tag:
        return 8
    if typeKind == coreir.LocalStrTag:
        return 24
    if typeKind == coreir.LocalPtrTag:
        return 8
    if typeKind == coreir.LocalAggregateTag:
        if len(typeText) > 2 && LoweringTextEndsWith(typeText, "[]"):
            return 16
        if chengpath.TextContains(typeText, "CompilerRequest"):
            return 232
    return 0

fn LoweringLocalTypeAlignBytes(typeKind: int32): int32 =
    if typeKind == coreir.LocalI32Tag:
        return 4
    if typeKind == coreir.LocalF64Tag:
        return 8
    if typeKind == coreir.LocalStrTag:
        return 8
    if typeKind == coreir.LocalPtrTag:
        return 8
    if typeKind == coreir.LocalAggregateTag:
        return 16
    return 1

fn LoweringBodyIrNextLocalOffset(bodyIR: coreir.BodyIR,
                                  alignBytes: int32): int32 =
    var nextOffset: int32 = 16
    for i in 0..<bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[i]
        var slotSize = slot.sizeBytes
        if slotSize <= 0:
            if slot.typeKind == coreir.LocalI32Tag:
                slotSize = 4
            elif slot.typeKind == coreir.LocalF64Tag:
                slotSize = 8
            elif slot.typeKind == coreir.LocalStrTag:
                slotSize = 24
            elif slot.typeKind == coreir.LocalPtrTag:
                slotSize = 8
            elif slot.typeKind == coreir.LocalAggregateTag:
                slotSize = slot.sizeBytes
        let slotEnd = slot.stackOffset + slotSize
        if slotEnd > nextOffset:
            nextOffset = slotEnd
    return LoweringAlignInt32(nextOffset, alignBytes)

fn LoweringBodyIrLocalSlotIndex(fnIr: PrimaryObjectIrFunction,
                                 nameRaw: str): int32 =
    let name = chengpath.PathTrim(nameRaw)
    if len(name) <= 0:
        return -1
    for i in 0..<fnIr.bodyIR.localSlots.len:
        if fnIr.bodyIR.localSlots[i].name == name:
            return fnIr.bodyIR.localSlots[i].id
    return -1

fn LoweringBodyIrEnsureLocalSlot(fnIr: var PrimaryObjectIrFunction,
                                  nameRaw: str,
                                  typeTextRaw: str): int32 =
    let name = chengpath.PathTrim(nameRaw)
    if len(name) <= 0:
        return -1
    let existing = LoweringBodyIrLocalSlotIndex(fnIr, name)
    if existing >= 0:
        return existing
    let typeKind = LoweringLocalTypeKind(typeTextRaw)
    if typeKind == coreir.LocalInvalidTag:
        return -1
    let sizeBytes = LoweringLocalTypeSizeBytes(typeTextRaw, typeKind)
    if sizeBytes <= 0:
        return -1
    let alignBytes = LoweringLocalTypeAlignBytes(typeKind)
    var slot: coreir.LocalSlot
    slot.id = fnIr.bodyIR.localSlots.len
    slot.name = name
    slot.typeKind = typeKind
    slot.sizeBytes = sizeBytes
    slot.alignBytes = alignBytes
    slot.stackOffset = LoweringBodyIrNextLocalOffset(fnIr.bodyIR, alignBytes)
    add(fnIr.bodyIR.localSlots, slot)
    return slot.id

fn LoweringCallArgSlots(fnIr: PrimaryObjectIrFunction,
                         callArgsText: str): int32[] =
    var out: int32[]
    let args = texpr.TypedExprSplitTopLevelCsv(callArgsText)
    for i in 0..<args.len:
        let argName = chengpath.PathTrim(args[i])
        if len(argName) <= 0:
            continue
        add(out, LoweringBodyIrLocalSlotIndex(fnIr, argName))
    return out

fn LoweringStatementImportcSymbol(stmt: PrimaryObjectIrStatement,
                                   sourceTexts: texpr.TypedExprSourceText[]): str =
    if !stmt.callTargetImportc:
        return ""
    if len(stmt.callImportcSymbol) > 0:
        return stmt.callImportcSymbol
    return LoweringImportcTargetSymbol(sourceTexts,
                                       stmt.callTargetSourcePath,
                                       stmt.callTarget)

fn LoweringClearStructuredCalls(fnIr: var PrimaryObjectIrFunction) =
    fnIr.bodyIR = coreir.BodyIR()
    fnIr.callSequence = []
    fnIr.callArgCounts = []
    fnIr.callTargets = []
    fnIr.callTargetSourcePaths = []
    fnIr.callTargetImportcFlags = []
    fnIr.callImportcSymbols = []
    fnIr.callTargetCount = 0

fn LoweringAppendStructuredCall(fnIr: var PrimaryObjectIrFunction,
                                 stmt: PrimaryObjectIrStatement,
                                 sourceTexts: texpr.TypedExprSourceText[]): int32 =
    if len(stmt.callTarget) <= 0:
        return -1
    var resultSlot: int32 = -1
    if stmt.kind == texpr.TypedExprIrStmtLetCall:
        resultSlot = LoweringBodyIrEnsureLocalSlot(fnIr, stmt.bindingName, stmt.resultType)
    var callOp: PrimaryObjectIrCallOp
    callOp.targetSymbol = stmt.callTarget
    callOp.targetSourcePath = stmt.callTargetSourcePath
    callOp.importc = stmt.callTargetImportc
    callOp.importcSymbol = LoweringStatementImportcSymbol(stmt, sourceTexts)
    callOp.argCount = stmt.callArgCount
    callOp.argsText = stmt.callArgsText
    callOp.resultType = stmt.resultType
    callOp.bindingName = stmt.bindingName
    callOp.resultSlot = resultSlot
    callOp.relocWordOffset = -1
    callOp.argSlots = LoweringCallArgSlots(fnIr, stmt.callArgsText)
    let ordinal = fnIr.callSequence.len
    add(fnIr.callSequence, callOp)
    add(fnIr.callArgCounts, stmt.callArgCount)
    add(fnIr.callTargets, stmt.callTarget)
    add(fnIr.callTargetSourcePaths, stmt.callTargetSourcePath)
    add(fnIr.callTargetImportcFlags, stmt.callTargetImportc)
    add(fnIr.callImportcSymbols, callOp.importcSymbol)
    var bodyCall: coreir.CallOp
    bodyCall.targetSymbol = callOp.targetSymbol
    bodyCall.argSlots = callOp.argSlots
    bodyCall.resultSlot = resultSlot
    bodyCall.relocWordOffset = -1
    add(fnIr.bodyIR.callSequence, bodyCall)
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpCallTag
    add(op.operands, ordinal)
    op.target = resultSlot
    add(fnIr.bodyIR.ops, op)
    fnIr.callTargetCount = fnIr.callSequence.len
    return ordinal

fn LoweringAppendBodyIrStatementReturn(fnIr: var PrimaryObjectIrFunction) =
    if fnIr.statementReturnMode == texpr.StatementReturnModeNone:
        return
    if fnIr.bodyIR.ops.len <= 0:
        return
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpReturnTag
    op.target = -1
    add(op.operands, fnIr.statementReturnMode)
    if fnIr.statementReturnMode == texpr.StatementReturnModeI32Const ||
       fnIr.statementReturnMode == texpr.StatementReturnModeStrThenCallReturnI32Const0 ||
       fnIr.statementReturnMode == texpr.StatementReturnModeCstringLiteralCallsReturnI32Const0:
        add(op.operands, fnIr.statementReturnI32Value)
    add(fnIr.bodyIR.ops, op)

fn LoweringAppendBodyIrReturnCall(fnIr: var PrimaryObjectIrFunction,
                                   stmt: PrimaryObjectIrStatement) =
    if !stmt.returnRoot:
        return
    if fnIr.callSequence.len <= 0:
        return
    var op: coreir.BodyOp
    op.kind = coreir.BodyOpReturnTag
    op.target = -1
    let typeKind = LoweringLocalTypeKind(stmt.resultType)
    if typeKind != coreir.LocalInvalidTag:
        add(op.operands, typeKind)
    add(fnIr.bodyIR.ops, op)

fn LoweringMaybePopulateResultRequestDispatch(fnIr: var PrimaryObjectIrFunction,
                                               sourceTexts: texpr.TypedExprSourceText[]): bool =
    if fnIr.statements.len < 5:
        return false
    let isErrStmt = fnIr.statements[0]
    let errorStmt = fnIr.statements[1]
    let unsupportedStmt = fnIr.statements[2]
    let valueStmt = fnIr.statements[3]
    let dispatchStmt = fnIr.statements[4]
    var ready = true
    if isErrStmt.kind != texpr.TypedExprIrStmtResultIntrinsic ||
       errorStmt.kind != texpr.TypedExprIrStmtResultIntrinsic ||
       unsupportedStmt.kind != texpr.TypedExprIrStmtCall ||
       valueStmt.kind != texpr.TypedExprIrStmtResultIntrinsic ||
       dispatchStmt.kind != texpr.TypedExprIrStmtCall:
        ready = false
    if ready:
        if isErrStmt.detailKind != parser.NormalizedExprDetailResultIsErr ||
           errorStmt.detailKind != parser.NormalizedExprDetailResultError ||
           valueStmt.detailKind != parser.NormalizedExprDetailResultValue:
            ready = false
    let resultParam = chengpath.PathTrim(isErrStmt.callArgsText)
    let valueName = chengpath.PathTrim(valueStmt.bindingName)
    let dispatchArgs = texpr.TypedExprSplitTopLevelCsv(dispatchStmt.callArgsText)
    if ready:
        if len(resultParam) <= 0 || len(valueName) <= 0:
            ready = false
        if chengpath.PathTrim(errorStmt.callArgsText) != resultParam ||
           chengpath.PathTrim(valueStmt.callArgsText) != resultParam:
            ready = false
        if errorStmt.enclosingIfLineNumber != isErrStmt.lineNumber ||
           unsupportedStmt.enclosingIfLineNumber != isErrStmt.lineNumber:
            ready = false
        if valueStmt.enclosingIfLineNumber > 0 ||
           dispatchStmt.enclosingIfLineNumber > 0:
            ready = false
        if !unsupportedStmt.returnRoot || !dispatchStmt.returnRoot:
            ready = false
        if LoweringFunctionTailName(unsupportedStmt.callTarget) != "BackendDriverDispatchMinUnsupported" ||
           LoweringFunctionTailName(dispatchStmt.callTarget) != "BackendDriverDispatchMinRunSystemLinkExecConcreteRequest":
            ready = false
        if unsupportedStmt.callArgCount != 1 || dispatchStmt.callArgCount != 2:
            ready = false
        if dispatchArgs.len != 2:
            ready = false
    if ready:
        if chengpath.PathTrim(dispatchArgs[1]) != valueName:
            ready = false
    if !ready:
        return false
    LoweringClearStructuredCalls(fnIr)
    let _ = LoweringBodyIrEnsureLocalSlot(fnIr, valueName, valueStmt.resultType)
    let _ = LoweringAppendStructuredCall(fnIr, dispatchStmt, sourceTexts)
    let _ = LoweringAppendStructuredCall(fnIr, unsupportedStmt, sourceTexts)
    fnIr.bodyKind = texpr.BodyKindResultRequestDispatch
    return true

fn LoweringPopulateStructuredFunctionIr(fnIr: var PrimaryObjectIrFunction,
                                         sourceTexts: texpr.TypedExprSourceText[]) =
    if LoweringMaybePopulateResultRequestDispatch(fnIr, sourceTexts):
        return
    LoweringClearStructuredCalls(fnIr)
    var returnCallStatementIndex: int32 = -1
    for stmtIndex in 0..<fnIr.statements.len:
        let stmt = fnIr.statements[stmtIndex]
        if stmt.kind == texpr.TypedExprIrStmtResultIntrinsic &&
           len(stmt.bindingName) > 0:
            let _ = LoweringBodyIrEnsureLocalSlot(fnIr, stmt.bindingName, stmt.resultType)
        if len(stmt.callTarget) > 0:
            let _ = LoweringAppendStructuredCall(fnIr, stmt, sourceTexts)
            if stmt.returnRoot:
                returnCallStatementIndex = stmtIndex
    if fnIr.statementReturnMode != texpr.StatementReturnModeNone:
        LoweringAppendBodyIrStatementReturn(fnIr)
    elif returnCallStatementIndex >= 0 && returnCallStatementIndex < fnIr.statements.len:
        LoweringAppendBodyIrReturnCall(fnIr, fnIr.statements[returnCallStatementIndex])

fn LoweringSourcePathForModule(workspaceRoot: str,
                                 packageRoot: str,
                                 externalPackageRoots: parser.ParserExternalPackageRoot[],
                                sourceClosurePaths: str[],
                                modulePath: str): str =
    let targetModulePath = chengpath.PathTrim(modulePath)
    for i in 0..<sourceClosurePaths.len:
        let sourcePath = parser.ParserNormalizePath(sourceClosurePaths[i])
        let sourceModulePath = parser.ParserSourcePathToModulePathWithExternalPackageRoots(workspaceRoot,
                                                                                           packageRoot,
                                                                                           externalPackageRoots,
                                                                                           sourcePath)
        if sourceModulePath == targetModulePath:
            return sourcePath
    let fallbackSourcePath = parser.ParserModulePathToSourcePathWithExternalPackageRoots(workspaceRoot,
                                                                                         packageRoot,
                                                                                         externalPackageRoots,
                                                                                         targetModulePath)
    return parser.ParserNormalizePath(fallbackSourcePath)

fn LoweringBuildPrimaryObjectIr(plan: LoweringPlanStub,
                                 sourceTexts: texpr.TypedExprSourceText[]): PrimaryObjectIr =
    var ir: PrimaryObjectIr
    let letCallReturnLiteralStart = texpr.BodyKindLetCallReturnI32ConstPrefixLen
    for i in 0..<plan.functionNames.len:
        let sourcePath = plan.functionSourcePaths[i]
        let functionName = plan.functionNames[i]
        var fnIr: PrimaryObjectIrFunction
        fnIr.sourcePath = sourcePath
        fnIr.functionName = functionName
        let typedFnIndex = LoweringTypedIrFunctionIndex(plan.typedIr, sourcePath, functionName)
        var hasLetCall = false
        var letCallReturnKind = texpr.BodyKindUnsupported
        var leafBodyKind = texpr.BodyKindUnsupported
        var bodyLineNumber: int32
        if typedFnIndex >= 0:
            let typedFn = plan.typedIr.functions[typedFnIndex]
            fnIr.signatureLineNumber = typedFn.signatureLineNumber
            LoweringAppendPrimaryObjectIrStatements(fnIr,
                                                     plan.typedIr,
                                                     typedFnIndex,
                                                     plan.typedExprFacts,
                                                     sourceTexts)
            bodyLineNumber = typedFn.bodyLineNumber
            var nodeEnd = typedFn.nodeStart + typedFn.nodeCount
            if nodeEnd > plan.typedIr.nodes.len:
                nodeEnd = plan.typedIr.nodes.len
            for nodeIndex in typedFn.nodeStart..<nodeEnd:
                if plan.typedIr.nodes[nodeIndex].opKind == texpr.TypedExprIrOpLetCall:
                    hasLetCall = true
                    break
            if typedFn.returnNodeIndex >= 0 && typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                if returnNode.opKind == texpr.TypedExprIrOpParamRef && returnNode.resultType == "int32":
                    if returnNode.paramSlot == 0:
                        leafBodyKind = texpr.BodyKindReturnI32Arg0
                    elif returnNode.paramSlot == 1:
                        leafBodyKind = texpr.BodyKindReturnI32Arg1
                    elif returnNode.paramSlot == 2:
                        leafBodyKind = texpr.BodyKindReturnI32Arg2
                    elif returnNode.paramSlot == 3:
                        leafBodyKind = texpr.BodyKindReturnI32Arg3
                elif returnNode.opKind == texpr.TypedExprIrOpI32Const:
                    if returnNode.literalText == "0":
                        leafBodyKind = texpr.BodyKindReturnZeroI32
                    else:
                        leafBodyKind = Fmt"{texpr.BodyKindReturnI32ConstPrefix}{returnNode.literalText}"
                    if hasLetCall:
                        letCallReturnKind = Fmt"{texpr.BodyKindLetCallReturnI32ConstPrefix}{returnNode.literalText}"
                elif returnNode.opKind == texpr.TypedExprIrOpI32Add:
                    leafBodyKind = texpr.BodyKindReturnI32AddArgs
                elif returnNode.opKind == texpr.TypedExprIrOpI32Sub:
                    leafBodyKind = texpr.BodyKindReturnI32SubArgs
                elif returnNode.opKind == texpr.TypedExprIrOpI32Mul:
                    leafBodyKind = texpr.BodyKindReturnI32MulArgs
                elif returnNode.opKind == texpr.TypedExprIrOpI32Asr:
                    leafBodyKind = texpr.BodyKindReturnI32AsrArgs
                elif returnNode.opKind == texpr.TypedExprIrOpI32Madd:
                    leafBodyKind = texpr.BodyKindReturnI32MaddArgs
                elif returnNode.opKind == texpr.TypedExprIrOpU64Arg0AndConst4NotZero:
                    leafBodyKind = texpr.BodyKindReturnU64Arg0AndConst4NotZero
                elif returnNode.opKind == texpr.TypedExprIrOpU64OrArg0Const4:
                    leafBodyKind = texpr.BodyKindReturnU64Arg0OrConst4
                elif returnNode.opKind == texpr.TypedExprIrOpI32IfArg0LeZeroConstElseConst:
                    var commaIndex = -1
                    for literalIndex in 0..<len(returnNode.literalText):
                        if returnNode.literalText[literalIndex] == ',':
                            commaIndex = literalIndex
                            break
                    if commaIndex > 0 && commaIndex + 1 < len(returnNode.literalText):
                        let thenText = chengpath.TextSlice(returnNode.literalText, 0, commaIndex)
                        let elseStart = commaIndex + 1
                        let elseText = chengpath.TextSlice(returnNode.literalText,
                                                           elseStart,
                                                           len(returnNode.literalText) - elseStart)
                        leafBodyKind = Fmt"if_arg0_le_zero_return_i32_const_{thenText}_else_i32_const_{elseText}"
                elif returnNode.opKind == texpr.TypedExprIrOpF64Mul:
                    leafBodyKind = texpr.BodyKindReturnF64MulArgs
                elif returnNode.opKind == texpr.TypedExprIrOpStrLenFast:
                    leafBodyKind = texpr.BodyKindStrLenFastI32
                elif returnNode.opKind == texpr.TypedExprIrOpReturnStrArg0:
                    leafBodyKind = texpr.BodyKindReturnStrArg0
                elif returnNode.opKind == texpr.TypedExprIrOpStrEmptyReturn:
                    leafBodyKind = texpr.BodyKindReturnStrEmpty
                elif returnNode.opKind == texpr.TypedExprIrOpCstringToStrCopy:
                    leafBodyKind = texpr.BodyKindCstringToStrCopy
                elif returnNode.opKind == texpr.TypedExprIrOpMainF64MulCheckExit:
                    leafBodyKind = texpr.BodyKindMainF64MulCheckExit
                elif hasLetCall && returnNode.opKind == texpr.TypedExprIrOpLetCallResultI32:
                    letCallReturnKind = texpr.BodyKindLetCallReturnResultI32
                elif hasLetCall && returnNode.opKind == texpr.TypedExprIrOpLetCallI32IfResultLeZeroReturnZeroElseResultI32:
                    letCallReturnKind = texpr.BodyKindLetCallI32IfResultLeZeroReturnZeroElseResultI32
                elif hasLetCall && returnNode.opKind == texpr.TypedExprIrOpLetCallStrReturnLenI32:
                    letCallReturnKind = texpr.BodyKindLetCallReturnStrLenI32
                elif hasLetCall && returnNode.opKind == texpr.TypedExprIrOpLetCallStrThenCallArg0ReturnI32Const0:
                    letCallReturnKind = texpr.BodyKindLetCallStrThenCallArg0ReturnI32Const0
        fnIr.bodyKind = leafBodyKind
        fnIr.bodyLineNumber = bodyLineNumber
        if fnIr.bodyKind == texpr.BodyKindUnsupported || hasLetCall:
            var callIndex = LoweringFindResolvedCallFactIndex(plan.typedExprFacts,
                                                              sourcePath,
                                                              bodyLineNumber)
            if callIndex < 0:
                if letCallReturnKind == texpr.BodyKindLetCallStrThenCallArg0ReturnI32Const0:
                    if typedFnIndex >= 0 && typedFnIndex < plan.typedIr.functions.len:
                        let typedFn = plan.typedIr.functions[typedFnIndex]
                        if typedFn.returnNodeIndex >= 0 && typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                            let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                            for factIndex in 0..<plan.typedExprFacts.len:
                                if parser.ParserNormalizePath(plan.typedExprFacts[factIndex].sourcePath) != sourcePath:
                                    continue
                                if plan.typedExprFacts[factIndex].lineNumber <= typedFn.signatureLineNumber ||
                                   plan.typedExprFacts[factIndex].lineNumber >= returnNode.operand0NodeIndex:
                                    continue
                                if !plan.typedExprFacts[factIndex].callResolved:
                                    continue
                                if len(plan.typedExprFacts[factIndex].callTarget) <= 0:
                                    continue
                                if plan.typedExprFacts[factIndex].callArgCount != 0:
                                    continue
                                callIndex = factIndex
                                break
            if callIndex >= 0:
                let fact = plan.typedExprFacts[callIndex]
                if fact.returnRoot && letCallReturnKind == texpr.BodyKindUnsupported:
                    if LoweringReturnCallArgsPassThrough(sourceTexts,
                                                         sourcePath,
                                                         functionName,
                                                         fact.callArgsText,
                                                         fact.callArgCount):
                        var firstImportcSymbol = ""
                        if fact.callTargetImportc:
                            firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                             fact.callTargetSourcePath,
                                                                             fact.callTarget)
                        add(fnIr.callArgCounts, fact.callArgCount)
                        add(fnIr.callTargets, fact.callTarget)
                        add(fnIr.callTargetSourcePaths, fact.callTargetSourcePath)
                        add(fnIr.callTargetImportcFlags, fact.callTargetImportc)
                        add(fnIr.callImportcSymbols, firstImportcSymbol)
                        fnIr.bodyKind = LoweringPrimaryObjectIrBodyKindForCallArgCount(fact.callArgCount)
                else:
                    if letCallReturnKind == texpr.BodyKindLetCallStrThenCallArg0ReturnI32Const0:
                        if typedFnIndex >= 0 && typedFnIndex < plan.typedIr.functions.len:
                            let typedFn = plan.typedIr.functions[typedFnIndex]
                            if typedFn.returnNodeIndex >= 0 && typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                                let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                                var secondCallIndex = LoweringFindResolvedCallFactIndex(plan.typedExprFacts,
                                                                                        sourcePath,
                                                                                        returnNode.operand0NodeIndex)
                                if secondCallIndex < 0:
                                    for factIndex in 0..<plan.typedExprFacts.len:
                                        if plan.typedExprFacts[factIndex].sourcePath != sourcePath:
                                            continue
                                        if plan.typedExprFacts[factIndex].lineNumber <= bodyLineNumber ||
                                           plan.typedExprFacts[factIndex].lineNumber > returnNode.lineNumber:
                                            continue
                                        if !plan.typedExprFacts[factIndex].callResolved:
                                            continue
                                        if len(plan.typedExprFacts[factIndex].callTarget) <= 0:
                                            continue
                                        secondCallIndex = factIndex
                                        break
                                if secondCallIndex >= 0:
                                    let secondFact = plan.typedExprFacts[secondCallIndex]
                                    let secondArgText = chengpath.PathTrim(secondFact.callArgsText)
                                    let firstFactType = texpr.TypedExprNormalizeTypeText(fact.typeText)
                                    if firstFactType == "str" &&
                                       fact.callArgCount == 0 &&
                                       secondFact.callArgCount == 1 &&
                                       secondArgText == returnNode.surfaceText:
                                        var firstImportcSymbol = ""
                                        if fact.callTargetImportc:
                                            firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                             fact.callTargetSourcePath,
                                                                                             fact.callTarget)
                                        var secondImportcSymbol = ""
                                        if secondFact.callTargetImportc:
                                            secondImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                               secondFact.callTargetSourcePath,
                                                                                               secondFact.callTarget)
                                        add(fnIr.callArgCounts, 0)
                                        add(fnIr.callTargets, fact.callTarget)
                                        add(fnIr.callTargetSourcePaths, fact.callTargetSourcePath)
                                        add(fnIr.callTargetImportcFlags, fact.callTargetImportc)
                                        add(fnIr.callImportcSymbols, firstImportcSymbol)
                                        add(fnIr.callArgCounts, 1)
                                        add(fnIr.callTargets, secondFact.callTarget)
                                        add(fnIr.callTargetSourcePaths, secondFact.callTargetSourcePath)
                                        add(fnIr.callTargetImportcFlags, secondFact.callTargetImportc)
                                        add(fnIr.callImportcSymbols, secondImportcSymbol)
                                        LoweringSetStatementSequenceReturn(fnIr,
                                                                           texpr.StatementReturnModeStrThenCallReturnI32Const0,
                                                                           0)
                    else:
                        if fact.callArgCount == 0:
                            let factType = texpr.TypedExprNormalizeTypeText(fact.typeText)
                            if factType == "int32":
                                var firstImportcSymbol = ""
                                if fact.callTargetImportc:
                                    firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                     fact.callTargetSourcePath,
                                                                                     fact.callTarget)
                                if letCallReturnKind == texpr.BodyKindLetCallReturnResultI32:
                                    LoweringSetStatementSequenceReturn(fnIr,
                                                                       texpr.StatementReturnModeCallResultI32,
                                                                       0)
                                else:
                                    if letCallReturnKind == texpr.BodyKindLetCallI32IfResultLeZeroReturnZeroElseResultI32:
                                        LoweringSetStatementSequenceReturn(fnIr,
                                                                           texpr.StatementReturnModeI32GuardResultLeZero,
                                                                           0)
                                    else:
                                        if chengpath.TextStartsWith(letCallReturnKind, texpr.BodyKindLetCallReturnI32ConstPrefix):
                                            let literalText = chengpath.TextSlice(letCallReturnKind,
                                                                                  letCallReturnLiteralStart,
                                                                                  len(letCallReturnKind) - letCallReturnLiteralStart)
                                            LoweringSetStatementSequenceReturn(fnIr,
                                                                               texpr.StatementReturnModeI32Const,
                                                                               int32(strutil.ParseInt(literalText)))
                                if fnIr.bodyKind != texpr.BodyKindUnsupported:
                                    add(fnIr.callArgCounts, fact.callArgCount)
                                    add(fnIr.callTargets, fact.callTarget)
                                    add(fnIr.callTargetSourcePaths, fact.callTargetSourcePath)
                                    add(fnIr.callTargetImportcFlags, fact.callTargetImportc)
                                    add(fnIr.callImportcSymbols, firstImportcSymbol)
                            else:
                                if factType == "str":
                                    if letCallReturnKind == texpr.BodyKindLetCallReturnStrLenI32:
                                        var firstImportcSymbol = ""
                                        if fact.callTargetImportc:
                                            firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                             fact.callTargetSourcePath,
                                                                                             fact.callTarget)
                                        add(fnIr.callArgCounts, fact.callArgCount)
                                        add(fnIr.callTargets, fact.callTarget)
                                        add(fnIr.callTargetSourcePaths, fact.callTargetSourcePath)
                                        add(fnIr.callTargetImportcFlags, fact.callTargetImportc)
                                        add(fnIr.callImportcSymbols, firstImportcSymbol)
                                        LoweringSetStatementSequenceReturn(fnIr,
                                                                           texpr.StatementReturnModeStrLen,
                                                                           0)
        if hasLetCall && fnIr.bodyKind == texpr.BodyKindUnsupported && leafBodyKind != texpr.BodyKindUnsupported:
            fnIr.bodyKind = leafBodyKind
        if fnIr.bodyKind == texpr.BodyKindUnsupported && typedFnIndex >= 0 && typedFnIndex < plan.typedIr.functions.len:
            let typedFn = plan.typedIr.functions[typedFnIndex]
            if typedFn.returnNodeIndex >= 0 && typedFn.returnNodeIndex < plan.typedIr.nodes.len:
                let returnNode = plan.typedIr.nodes[typedFn.returnNodeIndex]
                if returnNode.opKind == texpr.TypedExprIrOpLetCallStrThenCallArg0ReturnI32Const0:
                    var functionEndLine: int32 = typedFn.endLineNumber + 1
                    if functionEndLine <= bodyLineNumber:
                        functionEndLine = 2147483647
                    var firstCallIndex = LoweringFindResolvedCallFactIndex(plan.typedExprFacts,
                                                                           sourcePath,
                                                                           bodyLineNumber)
                    if firstCallIndex < 0:
                        for factIndex in 0..<plan.typedExprFacts.len:
                            if plan.typedExprFacts[factIndex].sourcePath != sourcePath:
                                continue
                            if plan.typedExprFacts[factIndex].lineNumber < bodyLineNumber ||
                               plan.typedExprFacts[factIndex].lineNumber >= functionEndLine:
                                continue
                            if !plan.typedExprFacts[factIndex].callResolved:
                                continue
                            if len(plan.typedExprFacts[factIndex].callTarget) <= 0:
                                continue
                            if plan.typedExprFacts[factIndex].callArgCount != 0:
                                continue
                            firstCallIndex = factIndex
                            break
                    var secondCallIndex = LoweringFindResolvedCallFactIndex(plan.typedExprFacts,
                                                                            sourcePath,
                                                                            returnNode.operand0NodeIndex)
                    if secondCallIndex < 0:
                        for factIndex in 0..<plan.typedExprFacts.len:
                            if factIndex == firstCallIndex:
                                continue
                            if plan.typedExprFacts[factIndex].sourcePath != sourcePath:
                                continue
                            if plan.typedExprFacts[factIndex].lineNumber <= bodyLineNumber ||
                               plan.typedExprFacts[factIndex].lineNumber >= functionEndLine:
                                continue
                            if !plan.typedExprFacts[factIndex].callResolved:
                                continue
                            if len(plan.typedExprFacts[factIndex].callTarget) <= 0:
                                continue
                            if plan.typedExprFacts[factIndex].callArgCount != 1:
                                continue
                            let argText = chengpath.PathTrim(plan.typedExprFacts[factIndex].callArgsText)
                            if argText != returnNode.surfaceText:
                                continue
                            secondCallIndex = factIndex
                            break
                    if firstCallIndex >= 0 && secondCallIndex >= 0:
                        let firstFact = plan.typedExprFacts[firstCallIndex]
                        let secondFact = plan.typedExprFacts[secondCallIndex]
                        let secondArgText = chengpath.PathTrim(secondFact.callArgsText)
                        let firstFactType = texpr.TypedExprNormalizeTypeText(firstFact.typeText)
                        if firstFactType == "str" &&
                           firstFact.callArgCount == 0 &&
                           secondFact.callArgCount == 1 &&
                           secondArgText == returnNode.surfaceText:
                            var firstImportcSymbol = ""
                            if firstFact.callTargetImportc:
                                firstImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                 firstFact.callTargetSourcePath,
                                                                                 firstFact.callTarget)
                            var secondImportcSymbol = ""
                            if secondFact.callTargetImportc:
                                secondImportcSymbol = LoweringImportcTargetSymbol(sourceTexts,
                                                                                  secondFact.callTargetSourcePath,
                                                                                  secondFact.callTarget)
                            add(fnIr.callArgCounts, 0)
                            add(fnIr.callTargets, firstFact.callTarget)
                            add(fnIr.callTargetSourcePaths, firstFact.callTargetSourcePath)
                            add(fnIr.callTargetImportcFlags, firstFact.callTargetImportc)
                            add(fnIr.callImportcSymbols, firstImportcSymbol)
                            add(fnIr.callArgCounts, 1)
                            add(fnIr.callTargets, secondFact.callTarget)
                            add(fnIr.callTargetSourcePaths, secondFact.callTargetSourcePath)
                            add(fnIr.callTargetImportcFlags, secondFact.callTargetImportc)
                            add(fnIr.callImportcSymbols, secondImportcSymbol)
                            LoweringSetStatementSequenceReturn(fnIr,
                                                               texpr.StatementReturnModeStrThenCallReturnI32Const0,
                                                               0)
        LoweringPopulateStructuredFunctionIr(fnIr, sourceTexts)
        fnIr.callTargetCount = fnIr.callTargets.len
        add(ir.functions, fnIr)
    return ir

fn LoweringIsImportcAnnotation(lineRaw: str): bool =
    let line = chengpath.PathTrim(lineRaw)
    if line == "":
        return false
    return chengpath.TextStartsWith(line, "@importc")

fn LoweringFunctionResultLayoutKind(functionName: str): int32 =
    if functionName == "main":
        return LoweringLayoutKindI32()
    return LoweringLayoutKindInvalid()

fn LoweringInternIdForSymbol(functionSymbolTexts: str[], functionNameIds: langintern.InternId[], symbolText: str): langintern.InternId =
    for i in 0..<functionNameIds.len:
        if functionSymbolTexts[i] == symbolText:
            return functionNameIds[i]
    return functionSymbolTexts.len

fn LoweringCollectFunctionsFromSource(workspaceRoot: str,
                                        packageRoot: str,
                                        entryPath: str,
                                        entrySymbol: str,
                                        sourcePath: str,
                                        plan: var LoweringPlanStub): bool =
    if !parser.ParserSourceExists(sourcePath):
        return false
    let ownerModulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    let text = chengpath.ReadTextFile("", sourcePath)
    var decls: parser.NormalizedFunctionDecl[]
    var err = ""
    if !parser.ParserReadNormalizedFunctionDecls(text, decls, err):
        return false
    for i in 0..<decls.len:
        let decl = decls[i]
        let functionName = decl.name
        if decl.importc:
            continue
        var symbolText = LoweringFunctionSymbolText(ownerModulePath, functionName)
        if len(decl.explicitExportName) > 0:
            symbolText = decl.explicitExportName
        var entryFlag: int32
        let callConv = LoweringCallConvInternal()
        let resultLayoutKind = LoweringFunctionResultLayoutKind(functionName)
        if sourcePath == entryPath && functionName == entrySymbol:
            entryFlag = 1
        add(plan.functionSourcePaths, sourcePath)
        add(plan.functionOwnerModulePaths, ownerModulePath)
        add(plan.functionNames, functionName)
        add(plan.functionSymbolTexts, symbolText)
        add(plan.functionExportedFlags, 0)
        add(plan.functionExportSymbolNames, "")
        add(plan.functionEntryFlags, entryFlag)
        add(plan.functionCallConvs, callConv)
        add(plan.functionResultLayoutKinds, resultLayoutKind)
    return true

fn LoweringFunctionListText(functionSymbolTexts: str[]): str =
    return LoweringListText(functionSymbolTexts)

fn LoweringPrimaryObjectIrBodyKindListText(ir: PrimaryObjectIr): str =
    if ir.functions.len <= 0:
        return "-"
    var out = ""
    for i in 0..<ir.functions.len:
        if i > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{ir.functions[i].bodyKind}"
    return out

fn LoweringPrimaryObjectIrCountBodyKind(ir: PrimaryObjectIr,
                                         bodyKind: str): int32 =
    var count: int32
    for i in 0..<ir.functions.len:
        if ir.functions[i].bodyKind == bodyKind:
            count = count + 1
    return count

fn LoweringBodyOpKindText(kind: int32): str =
    if kind == coreir.BodyOpLoadConstTag:
        return "load_const"
    if kind == coreir.BodyOpCallTag:
        return "call"
    if kind == coreir.BodyOpBinOpTag:
        return "bin_op"
    if kind == coreir.BodyOpCmpTag:
        return "cmp"
    if kind == coreir.BodyOpBranchTag:
        return "branch"
    if kind == coreir.BodyOpReturnTag:
        return "return"
    if kind == coreir.BodyOpLoadLocalTag:
        return "load_local"
    if kind == coreir.BodyOpStoreLocalTag:
        return "store_local"
    if kind == coreir.BodyOpCopyLocalTag:
        return "copy_local"
    return "invalid"

fn LoweringBodyIrReturnCount(bodyIR: coreir.BodyIR): int32 =
    var count: int32
    for i in 0..<bodyIR.ops.len:
        if bodyIR.ops[i].kind == coreir.BodyOpReturnTag:
            count = count + 1
    return count

fn LoweringBodyIrOpKindsText(bodyIR: coreir.BodyIR): str =
    if bodyIR.ops.len <= 0:
        return "-"
    var out = ""
    var limit = bodyIR.ops.len
    if limit > 7:
        limit = 7
    for i in 0..<limit:
        if i > 0:
            out = Fmt"{out}|"
        out = Fmt"{out}{LoweringBodyOpKindText(bodyIR.ops[i].kind)}"
    if bodyIR.ops.len > limit:
        out = Fmt"{out}|..."
    return out

fn LoweringPrimaryObjectIrReportText(ir: PrimaryObjectIr): str =
    var out = ""
    var callSequenceCounts = ""
    var callSequenceTargets = ""
    var bodyIrCallCounts = ""
    var bodyIrOpCounts = ""
    var bodyIrReturnCounts = ""
    var bodyIrOpKinds = ""
    var bodyIrLocalCounts = ""
    var statementSequenceCounts = ""
    var statementSequenceKinds = ""
    var statementSequenceTargets = ""
    var statementSequenceBindings = ""
    var statementSequenceResultTypes = ""
    var statementReturnModes = ""
    var statementReturnI32Values = ""
    for i in 0..<ir.functions.len:
        if i > 0:
            callSequenceCounts = Fmt"{callSequenceCounts},"
            callSequenceTargets = Fmt"{callSequenceTargets},"
            bodyIrCallCounts = Fmt"{bodyIrCallCounts},"
            bodyIrOpCounts = Fmt"{bodyIrOpCounts},"
            bodyIrReturnCounts = Fmt"{bodyIrReturnCounts},"
            bodyIrOpKinds = Fmt"{bodyIrOpKinds},"
            bodyIrLocalCounts = Fmt"{bodyIrLocalCounts},"
            statementSequenceCounts = Fmt"{statementSequenceCounts},"
            statementSequenceKinds = Fmt"{statementSequenceKinds},"
            statementSequenceTargets = Fmt"{statementSequenceTargets},"
            statementSequenceBindings = Fmt"{statementSequenceBindings},"
            statementSequenceResultTypes = Fmt"{statementSequenceResultTypes},"
            statementReturnModes = Fmt"{statementReturnModes},"
            statementReturnI32Values = Fmt"{statementReturnI32Values},"
        let targetCount: int32 = ir.functions[i].callSequence.len
        callSequenceCounts = Fmt"{callSequenceCounts}{intToStr(targetCount)}"
        if targetCount <= 0:
            callSequenceTargets = Fmt"{callSequenceTargets}-"
        else:
            var sequenceText = ir.functions[i].callSequence[0].targetSymbol
            if targetCount > 1:
                sequenceText = Fmt"{sequenceText}|{ir.functions[i].callSequence[1].targetSymbol}"
            if targetCount > 2:
                sequenceText = Fmt"{sequenceText}|{ir.functions[i].callSequence[2].targetSymbol}"
            if targetCount > 3:
                sequenceText = Fmt"{sequenceText}|{ir.functions[i].callSequence[3].targetSymbol}"
            if targetCount > 4:
                sequenceText = Fmt"{sequenceText}|..."
            callSequenceTargets = Fmt"{callSequenceTargets}{sequenceText}"
        bodyIrCallCounts = Fmt"{bodyIrCallCounts}{intToStr(ir.functions[i].bodyIR.callSequence.len)}"
        bodyIrOpCounts = Fmt"{bodyIrOpCounts}{intToStr(ir.functions[i].bodyIR.ops.len)}"
        bodyIrReturnCounts = Fmt"{bodyIrReturnCounts}{intToStr(LoweringBodyIrReturnCount(ir.functions[i].bodyIR))}"
        bodyIrOpKinds = Fmt"{bodyIrOpKinds}{LoweringBodyIrOpKindsText(ir.functions[i].bodyIR)}"
        bodyIrLocalCounts = Fmt"{bodyIrLocalCounts}{intToStr(ir.functions[i].bodyIR.localSlots.len)}"
        let stmtCount: int32 = ir.functions[i].statements.len
        statementSequenceCounts = Fmt"{statementSequenceCounts}{intToStr(stmtCount)}"
        statementReturnModes = Fmt"{statementReturnModes}{intToStr(ir.functions[i].statementReturnMode)}"
        statementReturnI32Values = Fmt"{statementReturnI32Values}{intToStr(ir.functions[i].statementReturnI32Value)}"
        if stmtCount <= 0:
            statementSequenceKinds = Fmt"{statementSequenceKinds}-"
            statementSequenceTargets = Fmt"{statementSequenceTargets}-"
            statementSequenceBindings = Fmt"{statementSequenceBindings}-"
            statementSequenceResultTypes = Fmt"{statementSequenceResultTypes}-"
        else:
            var kindText = texpr.TypedExprIrStatementKindText(ir.functions[i].statements[0].kind)
            var targetText = ir.functions[i].statements[0].callTarget
            var bindingText = ""
            var resultTypeText = ""
            var stmtLimit = stmtCount
            if stmtLimit > 5:
                stmtLimit = 5
            for stmtIndex in 0..<stmtLimit:
                if stmtIndex > 0:
                    bindingText = Fmt"{bindingText}|"
                    resultTypeText = Fmt"{resultTypeText}|"
                var bindingName = ir.functions[i].statements[stmtIndex].bindingName
                if len(bindingName) <= 0:
                    bindingName = "-"
                var resultType = ir.functions[i].statements[stmtIndex].resultType
                if len(resultType) <= 0:
                    resultType = "-"
                bindingText = Fmt"{bindingText}{bindingName}"
                resultTypeText = Fmt"{resultTypeText}{resultType}"
            if stmtCount > stmtLimit:
                bindingText = Fmt"{bindingText}|..."
                resultTypeText = Fmt"{resultTypeText}|..."
            if len(targetText) <= 0:
                targetText = "-"
            if stmtCount > 1:
                kindText = Fmt"{kindText}|{texpr.TypedExprIrStatementKindText(ir.functions[i].statements[1].kind)}"
                let nextTarget = ir.functions[i].statements[1].callTarget
                if len(nextTarget) > 0:
                    targetText = Fmt"{targetText}|{nextTarget}"
                else:
                    targetText = Fmt"{targetText}|-"
            if stmtCount > 2:
                kindText = Fmt"{kindText}|{texpr.TypedExprIrStatementKindText(ir.functions[i].statements[2].kind)}"
                let nextTarget = ir.functions[i].statements[2].callTarget
                if len(nextTarget) > 0:
                    targetText = Fmt"{targetText}|{nextTarget}"
                else:
                    targetText = Fmt"{targetText}|-"
            if stmtCount > 3:
                kindText = Fmt"{kindText}|{texpr.TypedExprIrStatementKindText(ir.functions[i].statements[3].kind)}"
                let nextTarget = ir.functions[i].statements[3].callTarget
                if len(nextTarget) > 0:
                    targetText = Fmt"{targetText}|{nextTarget}"
                else:
                    targetText = Fmt"{targetText}|-"
            if stmtCount > 4:
                kindText = Fmt"{kindText}|{texpr.TypedExprIrStatementKindText(ir.functions[i].statements[4].kind)}"
                let fifthTarget = ir.functions[i].statements[4].callTarget
                if len(fifthTarget) > 0:
                    targetText = Fmt"{targetText}|{fifthTarget}"
                else:
                    targetText = Fmt"{targetText}|-"
            if stmtCount > 5:
                kindText = Fmt"{kindText}|..."
                targetText = Fmt"{targetText}|..."
            statementSequenceKinds = Fmt"{statementSequenceKinds}{kindText}"
            statementSequenceTargets = Fmt"{statementSequenceTargets}{targetText}"
            statementSequenceBindings = Fmt"{statementSequenceBindings}{bindingText}"
            statementSequenceResultTypes = Fmt"{statementSequenceResultTypes}{resultTypeText}"
    LoweringAppendLine(out, "primary_object_ir_function_count", intToStr(ir.functions.len))
    LoweringAppendLine(out, "primary_object_ir_body_kinds", LoweringPrimaryObjectIrBodyKindListText(ir))
    LoweringAppendLine(out, "primary_object_ir_call_sequence_counts", callSequenceCounts)
    LoweringAppendLine(out, "primary_object_ir_call_sequence_targets", callSequenceTargets)
    LoweringAppendLine(out, "primary_object_ir_body_ir_call_counts", bodyIrCallCounts)
    LoweringAppendLine(out, "primary_object_ir_body_ir_op_counts", bodyIrOpCounts)
    LoweringAppendLine(out, "primary_object_ir_body_ir_return_counts", bodyIrReturnCounts)
    LoweringAppendLine(out, "primary_object_ir_body_ir_op_kinds", bodyIrOpKinds)
    LoweringAppendLine(out, "primary_object_ir_body_ir_local_counts", bodyIrLocalCounts)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_counts", statementSequenceCounts)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_kinds", statementSequenceKinds)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_targets", statementSequenceTargets)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_bindings", statementSequenceBindings)
    LoweringAppendLine(out, "primary_object_ir_statement_sequence_result_types", statementSequenceResultTypes)
    LoweringAppendLine(out, "primary_object_ir_statement_return_modes", statementReturnModes)
    LoweringAppendLine(out, "primary_object_ir_statement_return_i32_values", statementReturnI32Values)
    LoweringAppendLine(out, "primary_object_ir_return_zero_i32_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnZeroI32)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_add_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32AddArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_sub_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32SubArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_mul_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32MulArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_asr_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32AsrArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_i32_madd_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnI32MaddArgs)))
    LoweringAppendLine(out, "primary_object_ir_return_u64_arg0_and_const_4_not_zero_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnU64Arg0AndConst4NotZero)))
    LoweringAppendLine(out, "primary_object_ir_return_u64_arg0_or_const_4_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnU64Arg0OrConst4)))
    LoweringAppendLine(out, "primary_object_ir_return_f64_mul_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnF64MulArgs)))
    LoweringAppendLine(out, "primary_object_ir_str_len_fast_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindStrLenFastI32)))
    LoweringAppendLine(out, "primary_object_ir_return_str_arg0_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnStrArg0)))
    LoweringAppendLine(out, "primary_object_ir_return_str_empty_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindReturnStrEmpty)))
    LoweringAppendLine(out, "primary_object_ir_let_call_noarg_i32_if_result_le_zero_return_zero_else_result_i32_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32)))
    LoweringAppendLine(out, "primary_object_ir_let_call_noarg_str_return_len_i32_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindLetCallNoargStrReturnLenI32)))
    LoweringAppendLine(out, "primary_object_ir_let_call_noarg_str_then_call_arg0_return_i32_const_0_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindLetCallNoargStrThenCallArg0ReturnI32Const0)))
    LoweringAppendLine(out, "primary_object_ir_cstring_to_str_copy_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindCstringToStrCopy)))
    LoweringAppendLine(out, "primary_object_ir_main_f64_mul_check_exit_count", intToStr(LoweringPrimaryObjectIrCountBodyKind(ir, texpr.BodyKindMainF64MulCheckExit)))
    return out

fn LoweringMissingReasons(functionNames: str[], functionEntryFlags: int32[], entrySymbol: str): str[] =
    var missing: str[]
    if functionNames.len <= 0:
        add(missing, "lowering_functions_missing")
        return missing
    if len(entrySymbol) > 0:
        var entryLowered = false
        for i in 0..<functionEntryFlags.len:
            if functionEntryFlags[i] != 0:
                entryLowered = true
        if !entryLowered:
            add(missing, "lowering_entry_function_missing")
    return missing

fn LoweringSequentialNameIds(count: int32): langintern.InternId[] =
    var out: langintern.InternId[]
    out = []
    for i in 0..<count:
        add(out, i)
    return out

fn BuildLoweringPlanStubFromCompilerCsg(linkPlan: slplan.SystemLinkPlanStub,
                                          compilerCsg: var ccsg.CompilerCsg,
                                          plan: var LoweringPlanStub,
                                          err: var str): bool =
    plan.functionSourcePaths = []
    plan.functionOwnerModulePaths = []
    plan.functionNames = []
    plan.functionSymbolTexts = []
    plan.functionExportedFlags = []
    plan.functionExportSymbolNames = []
    plan.functionNameIds = []
    plan.functionEntryFlags = []
    plan.functionCallConvs = []
    plan.functionResultLayoutKinds = []
    plan.typedExprFacts = []
    plan.typedIr = texpr.TypedExprIr()
    var emptyReturnOps: texpr.TypedExprReturnOpFact[]
    plan.typedReturnOps = emptyReturnOps
    plan.primaryObjectIr = PrimaryObjectIr()
    plan.loweringRules = []
    let workspaceRoot = slplan.SystemLinkPlanWorkspaceRoot(linkPlan)
    let packageRoot = slplan.SystemLinkPlanPackageRoot(linkPlan)
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(linkPlan)
    let packageId = slplan.SystemLinkPlanPackageId(linkPlan)
    let entryPath = slplan.SystemLinkPlanEntryPath(linkPlan)
    let entrySymbol = slplan.SystemLinkPlanEntrySymbol(linkPlan)
    let sourceClosurePaths = slplan.SystemLinkPlanSourceClosurePaths(linkPlan)
    for i in 0..<compilerCsg.nodes.len:
        let node = compilerCsg.nodes[i]
        if node.nodeKind != ccsg.CompilerCsgNodeKindSymbol:
            continue
        let sourcePath = LoweringSourcePathForModule(workspaceRoot,
                                                     packageRoot,
                                                     externalPackageRoots,
                                                     sourceClosurePaths,
                                                     node.modulePath)
        add(plan.functionSourcePaths, sourcePath)
        add(plan.functionOwnerModulePaths, node.modulePath)
        add(plan.functionNames, node.factText)
        add(plan.functionSymbolTexts, node.symbolText)
        add(plan.functionExportedFlags, node.exportedFlag)
        add(plan.functionExportSymbolNames, node.exportSymbolName)
        add(plan.functionEntryFlags, node.entryFlag)
        add(plan.functionCallConvs, node.callConv)
        add(plan.functionResultLayoutKinds, node.resultLayoutKind)
    let functionSymbolTexts = LoweringPlanFunctionSymbolTexts(plan)
    let functionNameIds = LoweringSequentialNameIds(functionSymbolTexts.len)
    plan.functionNameIds = functionNameIds
    let functionNames = LoweringPlanFunctionNamesField(plan)
    let functionEntryFlags = LoweringPlanFunctionEntryFlagsField(plan)
    let missingReasons = LoweringMissingReasons(functionNames, functionEntryFlags, entrySymbol)
    plan.workspaceRoot = workspaceRoot
    plan.packageRoot = packageRoot
    plan.packageId = packageId
    plan.entryPath = entryPath
    plan.entrySymbol = entrySymbol
    plan.sourceBundleCid = compilerCsg.sourceBundleCid
    plan.compilerCsgCid = compilerCsg.graphCid
    plan.exprLayer = compilerCsg.exprLayer
    plan.typedExprFacts = compilerCsg.typedExprFacts
    var typedSourceTexts: texpr.TypedExprSourceText[]
    for i in 0..<sourceClosurePaths.len:
        let sourcePath = sourceClosurePaths[i]
        let sourceText = chengpath.ReadTextFile("", sourcePath)
        add(typedSourceTexts,
            texpr.TypedExprSourceTextNewWithExternalPackageRoots(workspaceRoot,
                                                                  packageRoot,
                                                                  externalPackageRoots,
                                                                  sourcePath,
                                                                  sourceText))
    var typedIrErr = ""
    if !texpr.TypedExprBuildIrWithFacts(typedSourceTexts, plan.typedExprFacts, plan.typedIr, typedIrErr):
        err = typedIrErr
        return false
    plan.typedReturnOps = texpr.TypedExprReturnOpFactsFromIr(plan.typedIr)
    var callErr = ""
    if !texpr.TypedExprFactsValidateCallResolution(plan.exprLayer, plan.typedExprFacts, callErr):
        err = callErr
        return false
    plan.primaryObjectIr = LoweringBuildPrimaryObjectIr(plan, typedSourceTexts)
    var loweringErr = ""
    if !texpr.TypedExprBuildLoweringRules(plan.typedExprFacts, plan.loweringRules, loweringErr):
        err = loweringErr
        return false
    plan.missingReasons = missingReasons
    plan.pipelineStage = "canonical_csg_to_lowering_plan"
    err = ""
    return true

fn LoweringPlanFunctionSymbolTexts(plan: LoweringPlanStub): str[] =
    return plan.functionSymbolTexts

fn LoweringPlanFunctionNameIds(plan: LoweringPlanStub): langintern.InternId[] =
    return plan.functionNameIds

fn LoweringPlanFunctionNamesField(plan: LoweringPlanStub): str[] =
    return plan.functionNames

fn LoweringPlanRulesForSource(plan: LoweringPlanStub,
                                sourcePathRaw: str): texpr.TypedExprLoweringRule[] =
    let sourcePath = parser.ParserNormalizePath(sourcePathRaw)
    var out: texpr.TypedExprLoweringRule[]
    for i in 0..<plan.loweringRules.len:
        if plan.loweringRules[i].sourcePath != sourcePath:
            continue
        var rule: texpr.TypedExprLoweringRule
        rule.exprId = plan.loweringRules[i].exprId
        rule.sourcePath = plan.loweringRules[i].sourcePath
        rule.lineNumber = plan.loweringRules[i].lineNumber
        rule.columnNumber = plan.loweringRules[i].columnNumber
        rule.surfaceCallKind = plan.loweringRules[i].surfaceCallKind
        rule.callResolved = plan.loweringRules[i].callResolved
        rule.callReason = plan.loweringRules[i].callReason
        rule.callQualifier = plan.loweringRules[i].callQualifier
        rule.callCallee = plan.loweringRules[i].callCallee
        rule.callTarget = plan.loweringRules[i].callTarget
        rule.callTargetSourcePath = plan.loweringRules[i].callTargetSourcePath
        rule.callTargetImportc = plan.loweringRules[i].callTargetImportc
        rule.callPrefixStyle = plan.loweringRules[i].callPrefixStyle
        rule.callArgCount = plan.loweringRules[i].callArgCount
        rule.callArgsText = plan.loweringRules[i].callArgsText
        rule.typeText = plan.loweringRules[i].typeText
        rule.abiClass = plan.loweringRules[i].abiClass
        rule.valueKind = plan.loweringRules[i].valueKind
        rule.placeKind = plan.loweringRules[i].placeKind
        rule.loweringMode = plan.loweringRules[i].loweringMode
        rule.callKind = plan.loweringRules[i].callKind
        rule.typeCallKind = plan.loweringRules[i].typeCallKind
        rule.returnKind = plan.loweringRules[i].returnKind
        rule.argPassKind = plan.loweringRules[i].argPassKind
        rule.resultPassKind = plan.loweringRules[i].resultPassKind
        rule.materializeKind = plan.loweringRules[i].materializeKind
        rule.copyKind = plan.loweringRules[i].copyKind
        rule.importKind = plan.loweringRules[i].importKind
        add(out, rule)
    return out

fn LoweringPlanFunctionEntryFlagsField(plan: LoweringPlanStub): int32[] =
    return plan.functionEntryFlags

fn LoweringPlanMissingReasonsField(plan: LoweringPlanStub): str[] =
    return plan.missingReasons

fn LoweringPlanPipelineStage(plan: LoweringPlanStub): str =
    return plan.pipelineStage

fn BuildLoweringPlanStub(linkPlan: slplan.SystemLinkPlanStub,
                           plan: var LoweringPlanStub,
                           err: var str): bool =
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    if IsErr(sourceBundleRes):
        err = Error(sourceBundleRes)
        return false
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    if IsErr(csgRes):
        err = Error(csgRes)
        return false
    var csg = Value(csgRes)
    return BuildLoweringPlanStubFromCompilerCsg(linkPlan, csg, plan, err)

fn LoweringPlanStubReport(plan: LoweringPlanStub): str =
    var out: str
    var entryFunction = plan.entrySymbol
    let functionCount = intToStr(plan.functionNames.len)
    let functionTexts = LoweringPlanFunctionSymbolTexts(plan)
    let functionList = LoweringFunctionListText(functionTexts)
    let missingField = LoweringPlanMissingReasonsField(plan)
    let missingReasons = slplan.SystemLinkPlanListText(missingField)
    let pipelineStage = LoweringPlanPipelineStage(plan)
    let typedIr = plan.typedIr
    let typedReturnOps: texpr.TypedExprReturnOpFact[] = plan.typedReturnOps
    let primaryObjectIr = plan.primaryObjectIr
    let loweringRules = plan.loweringRules
    if len(entryFunction) <= 0:
        entryFunction = "-"
    LoweringAppendLine(out, "lowering_function_count", functionCount)
    LoweringAppendLine(out, "lowering_functions", functionList)
    LoweringAppendLine(out, "lowering_entry_function", entryFunction)
    LoweringAppendLine(out, "expr_surface_source_count", intToStr(plan.exprLayer.sourceCount))
    LoweringAppendLine(out, "expr_surface_expr_count", intToStr(parser.NormalizedExprLayerExprCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_if_count", intToStr(parser.NormalizedExprLayerIfCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_range_count", intToStr(parser.NormalizedExprLayerRangeCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_comprehension_count", intToStr(parser.NormalizedExprLayerComprehensionCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_fmt_count", intToStr(parser.NormalizedExprLayerStrFormatCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_result_intrinsic_count", intToStr(parser.NormalizedExprLayerResultIntrinsicCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_try_count", intToStr(parser.NormalizedExprLayerTryCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_default_init_count", intToStr(parser.NormalizedExprLayerDefaultInitCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_constructor_count", intToStr(parser.NormalizedExprLayerConstructorCount(plan.exprLayer)))
    LoweringAppendLine(out, "expr_surface_question_residual_count", intToStr(plan.exprLayer.questionResidualCount))
    LoweringAppendLine(out, "typed_expr_fact_count", intToStr(plan.typedExprFacts.len))
    LoweringAppendLine(out, "typed_expr_lowering_rule_count", intToStr(loweringRules.len))
    let typedIrReport = texpr.TypedExprIrReportText(typedIr)
    if len(typedIrReport) > 0:
        if len(out) > 0 && out[len(out) - 1] != '\n':
            out = Fmt"{out}\n"
        out = Fmt"{out}{typedIrReport}"
    let returnOpReport = texpr.TypedExprReturnOpFactsReportText(typedReturnOps)
    if len(returnOpReport) > 0:
        if len(out) > 0 && out[len(out) - 1] != '\n':
            out = Fmt"{out}\n"
        out = Fmt"{out}{returnOpReport}"
    let primaryObjectIrReport = LoweringPrimaryObjectIrReportText(primaryObjectIr)
    if len(primaryObjectIrReport) > 0:
        if len(out) > 0 && out[len(out) - 1] != '\n':
            out = Fmt"{out}\n"
        out = Fmt"{out}{primaryObjectIrReport}"
    LoweringAppendLine(out, "lowering_source_bundle_cid", layout.FixedBytes32Hex(plan.sourceBundleCid))
    LoweringAppendLine(out, "lowering_compiler_csg_cid", layout.FixedBytes32Hex(plan.compilerCsgCid))
    LoweringAppendLine(out, "lowering_missing_reasons", missingReasons)
    LoweringAppendLine(out, "exec_pipeline_stage", pipelineStage)
    return out
