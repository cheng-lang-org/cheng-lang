type
    ObjectSymbol =
        name: str
        sectionIndex: int32 = -1
        offset: int64
        size: int64
        global: bool
        undefined: bool

    ObjectSymbolTable =
        items: ObjectSymbol[]

fn ObjectSymbolsInit(): ObjectSymbolTable =
    var out: ObjectSymbolTable
    return out

fn ObjectSymbolsCount(table: ObjectSymbolTable): int32 =
    return table.items.len

fn ObjectSymbolsAt(table: ObjectSymbolTable, index: int32): ObjectSymbol =
    return table.items[index]

fn ObjectSymbolsFind(table: ObjectSymbolTable, name: str): int32 =
    for i in 0..<table.items.len:
        if table.items[i].name == name:
            return i
    return -1

fn ObjectSymbolsAddDefined(table: var ObjectSymbolTable,
                            name: str,
                            sectionIndex: int32,
                            offset: int64,
                            size: int64,
                            global: bool): int32 =
    let existing = ObjectSymbolsFind(table, name)
    if existing >= 0:
        return existing
    add(table.items, ObjectSymbol(name: name,
                                  sectionIndex: sectionIndex,
                                  offset: offset,
                                  size: size,
                                  global: global,
                                  undefined: false))
    return table.items.len - 1

fn ObjectSymbolsAddUndefined(table: var ObjectSymbolTable,
                              name: str,
                              global: bool): int32 =
    let existing = ObjectSymbolsFind(table, name)
    if existing >= 0:
        return existing
    add(table.items, ObjectSymbol(name: name,
                                  sectionIndex: -1,
                                  global: global,
                                  undefined: true))
    return table.items.len - 1

fn ObjectSymbolsHas(table: ObjectSymbolTable, name: str): bool =
    return ObjectSymbolsFind(table, name) >= 0
