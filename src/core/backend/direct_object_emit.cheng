import std/result
import std/rawbytes as rawbytes
import std/strformat
import std/strings
import cheng/core/tooling/path as chengpath
import cheng/core/backend/macho_object_writer as macho
import cheng/core/backend/object_buffer as obuf
import cheng/core/backend/object_symbols as osym
import cheng/core/backend/object_relocs as orel
import cheng/core/backend/primary_object_plan as pobj
import cheng/core/lang/typed_expr as texpr

type
    DirectObjectEmitResult =
        objectPath: str
        bytesWritten: int32
        symbolCount: int32
        relocCount: int32
        directObjectLayoutMs: int64
        directObjectEmitMs: int64

fn DirectObjectEmitTargetSupported(plan: pobj.PrimaryObjectPlan): bool =
    return plan.targetTriple == "arm64-apple-darwin" && plan.objectFormat == "macho"

fn DirectObjectEmitRequireIndex(index: int32, label: str) =
    if index < 0:
        assert(false, label)

fn DirectObjectEmitIsReturnI32ConstBodyKind(bodyKind: str): bool =
    return chengpath.TextStartsWith(bodyKind, texpr.BodyKindReturnI32ConstPrefix)

fn DirectObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind: str): bool =
    return chengpath.TextStartsWith(bodyKind, texpr.BodyKindLetCallNoargReturnI32ConstPrefix)

fn DirectObjectEmitExpectedWordsForPlanFunction(plan: pobj.PrimaryObjectPlan,
                                                 functionIndex: int32): int32 =
    if functionIndex < 0 || functionIndex >= plan.functionBodyKinds.len:
        return 0
    if functionIndex >= plan.functionWordCounts.len:
        return 0
    return plan.functionWordCounts[functionIndex]

fn DirectObjectEmitParseSuffixI32(bodyKind: str,
                                   prefix: str): int32 =
    var value: int32
    for i in prefix.len..<bodyKind.len:
        let ch = bodyKind[i]
        if ch < '0' || ch > '9':
            return 0
        value = value * 10 + int32(ch) - int32('0')
    return value

fn DirectObjectEmitAlign(value: int32,
                         align: int32): int32 =
    if align <= 1:
        return value
    let remainder = value % align
    if remainder == 0:
        return value
    return value + (align - remainder)

fn DirectObjectEmitTextByteSize(plan: pobj.PrimaryObjectPlan): int32 =
    return plan.instructionWords.len * 4

fn DirectObjectEmitDataSectionAddr(plan: pobj.PrimaryObjectPlan): int32 =
    return DirectObjectEmitAlign(DirectObjectEmitTextByteSize(plan), 8)

fn DirectObjectEmitParsePositiveI32(text: str): int32 =
    var value: int32
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return value
        value = value * 10 + int32(ch) - int32('0')
    return value

fn DirectObjectEmitPayloadByteCount(payloadText: str): int32 =
    let zeroPrefix = "zero:"
    if chengpath.TextStartsWith(payloadText, zeroPrefix):
        let raw = strings.SliceBytes(payloadText, len(zeroPrefix), len(payloadText) - len(zeroPrefix))
        return DirectObjectEmitParsePositiveI32(raw)
    let cstringPrefix = "cstring:"
    if chengpath.TextStartsWith(payloadText, cstringPrefix):
        let raw = strings.SliceBytes(payloadText, len(cstringPrefix), len(payloadText) - len(cstringPrefix))
        var count: int32 = 1
        var escaped = false
        for i in 0..<len(raw):
            if escaped:
                escaped = false
                count = count + 1
            elif raw[i] == char(92):
                escaped = true
            else:
                count = count + 1
        if escaped:
            count = count + 1
        return count
    return 0

fn DirectObjectEmitCStringPayloadByte(raw: str,
                                       index: int32): int32 =
    if index < 0 || index >= len(raw):
        return 0
    let ch = raw[index]
    if ch == 'n':
        return 10
    if ch == 'r':
        return 13
    if ch == 't':
        return 9
    if ch == '0':
        return 0
    return int32(ch)

fn DirectObjectEmitWriteCStringPayload(data: var obuf.ObjectBuffer,
                                        payloadText: str) =
    let prefix = "cstring:"
    if !chengpath.TextStartsWith(payloadText, prefix):
        return
    let raw = strings.SliceBytes(payloadText, len(prefix), len(payloadText) - len(prefix))
    var escaped = false
    for i in 0..<len(raw):
        if escaped:
            obuf.ObjectBufferWriteU8(data, DirectObjectEmitCStringPayloadByte(raw, i))
            escaped = false
        elif raw[i] == char(92):
            escaped = true
        else:
            obuf.ObjectBufferWriteU8(data, int32(raw[i]))
    if escaped:
        obuf.ObjectBufferWriteU8(data, int32(char(92)))
    obuf.ObjectBufferWriteU8(data, 0)

fn DirectObjectEmitCStringLiteralDataLabel(functionSymbol: str,
                                           callOrdinal: int32): str =
    return pobj.PrimaryCStringLiteralDataLabel(functionSymbol, callOrdinal)

fn DirectObjectEmitCstringLiteralCallCount(plan: pobj.PrimaryObjectPlan,
                                            functionIndex: int32): int32 =
    if functionIndex >= 0 &&
       functionIndex < plan.functionStatementReturnModes.len &&
       plan.functionStatementReturnModes[functionIndex] == pobj.PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0() &&
       functionIndex < plan.functionStatementCallCounts.len:
        return plan.functionStatementCallCounts[functionIndex]
    return 0

fn DirectObjectEmitDataLabelByTail(plan: pobj.PrimaryObjectPlan,
                                    tail: str): str =
    for i in 0..<plan.dataLabels.len:
        let label = plan.dataLabels[i]
        if len(label) < len(tail):
            continue
        let start = len(label) - len(tail)
        var matches = true
        for j in 0..<len(tail):
            if label[start + j] != tail[j]:
                matches = false
                break
        if matches:
            return label
    return ""

fn DirectObjectEmitDataLabelExact(plan: pobj.PrimaryObjectPlan,
                                   label: str): str =
    for i in 0..<plan.dataLabels.len:
        if plan.dataLabels[i] == label:
            return plan.dataLabels[i]
    return ""

fn DirectObjectEmitFunctionLooksEntryBridgeWords(plan: pobj.PrimaryObjectPlan,
                                                  functionIndex: int32): bool =
    if len(plan.entryFunctionSymbol) <= 0:
        return false
    if functionIndex < 0 ||
       functionIndex >= plan.functionWordOffsets.len ||
       functionIndex >= plan.functionWordCounts.len:
        return false
    if plan.functionWordCounts[functionIndex] != texpr.BodyKindEntryBridgeWordCount:
        return false
    let wordOffset = plan.functionWordOffsets[functionIndex]
    if wordOffset + 16 >= plan.instructionWords.len:
        return false
    return plan.instructionWords[wordOffset] == -788495361 &&
           plan.instructionWords[wordOffset + 3] == -1811939328 &&
           plan.instructionWords[wordOffset + 6] == -1811939328 &&
           plan.instructionWords[wordOffset + 8] == -1811939328 &&
           plan.instructionWords[wordOffset + 12] == -1811939328 &&
           plan.instructionWords[wordOffset + 16] == -698416192

fn DirectObjectEmitInstructionWord(plan: pobj.PrimaryObjectPlan,
                                    wordOffset: int32): int32 =
    if wordOffset < 0 || wordOffset >= plan.instructionWords.len:
        return 0
    return plan.instructionWords[wordOffset]

fn DirectObjectEmitIsCstringAddressPair(plan: pobj.PrimaryObjectPlan,
                                         wordOffset: int32): bool =
    return DirectObjectEmitInstructionWord(plan, wordOffset) == -1879048192 &&
           DirectObjectEmitInstructionWord(plan, wordOffset + 1) == -1862270976

fn DirectObjectEmitIsRuntimeDataAddressPair(plan: pobj.PrimaryObjectPlan,
                                             wordOffset: int32): bool =
    return DirectObjectEmitInstructionWord(plan, wordOffset) == -1879048176 &&
           DirectObjectEmitInstructionWord(plan, wordOffset + 1) == -1862270448

fn DirectObjectEmitRelocTargetForItem(plan: pobj.PrimaryObjectPlan,
                                       itemId: int32): str =
    for i in 0..<plan.relocSourceItemIds.len:
        if plan.relocSourceItemIds[i] == itemId:
            return plan.relocTargetSymbols[i]
    return ""

fn DirectObjectEmitRelocTargetForItemOrdinal(plan: pobj.PrimaryObjectPlan,
                                              itemId: int32,
                                              ordinal: int32): str =
    var seen: int32
    for i in 0..<plan.relocSourceItemIds.len:
        if plan.relocSourceItemIds[i] != itemId:
            continue
        if seen == ordinal:
            return plan.relocTargetSymbols[i]
        seen = seen + 1
    return ""

fn DirectObjectEmitEntryBridgeSetCmdLineSymbol(plan: pobj.PrimaryObjectPlan): str =
    return pobj.PrimaryTargetSymbolName(plan.targetTriple, "__cheng_setCmdLine")

fn DirectObjectEmitEntryBridgeLineMapSymbol(plan: pobj.PrimaryObjectPlan): str =
    return pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_register_line_map_from_argv0")

fn DirectObjectEmitEntryBridgeProfileFlushSymbol(plan: pobj.PrimaryObjectPlan): str =
    return pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_debug_profile_flush_from_argv0")

fn DirectObjectEmitEntryBridgeTargetSymbol(plan: pobj.PrimaryObjectPlan): str =
    if len(plan.entryFunctionSymbol) > 0:
        return plan.entryFunctionSymbol
    if plan.symbolNames.len > 0:
        return plan.symbolNames[0]
    return ""

fn DirectObjectEmitEntryBridgeIndex(plan: pobj.PrimaryObjectPlan): int32 =
    for i in 0..<plan.functionBodyKinds.len:
        if plan.functionBodyKinds[i] == texpr.BodyKindEntryBridge:
            return i
    return -1

fn DirectObjectEmitRealFunctionLimit(plan: pobj.PrimaryObjectPlan): int32 =
    let bridgeIndex = DirectObjectEmitEntryBridgeIndex(plan)
    if bridgeIndex >= 0:
        return bridgeIndex
    return plan.functionBodyKinds.len

fn DirectObjectEmitEntryFunctionIndex(plan: pobj.PrimaryObjectPlan,
                                       functionLimit: int32): int32 =
    if len(plan.entryFunctionSymbol) <= 0:
        return -1
    for i in 0..<functionLimit:
        if plan.symbolNames[i] == plan.entryFunctionSymbol:
            return i
    return -1

fn DirectObjectEmitSymbolInRealFunctions(plan: pobj.PrimaryObjectPlan,
                                          functionLimit: int32,
                                          symbolName: str): bool =
    if len(symbolName) <= 0:
        return false
    for i in 0..<functionLimit:
        if plan.symbolNames[i] == symbolName:
            return true
    return false

fn DirectObjectEmitStandaloneNeedsMainWrapper(plan: pobj.PrimaryObjectPlan): bool =
    return false

fn DirectObjectEmitStandaloneEntryBodyKind(plan: pobj.PrimaryObjectPlan,
                                           functionLimit: int32): str =
    let entryIndex = DirectObjectEmitEntryFunctionIndex(plan, functionLimit)
    if entryIndex >= 0:
        return plan.functionBodyKinds[entryIndex]
    return ""

fn DirectObjectEmitStandaloneWrapperByteSize(plan: pobj.PrimaryObjectPlan,
                                             functionLimit: int32): int64 =
    if !DirectObjectEmitStandaloneNeedsMainWrapper(plan):
        return int64(0)
    let entryBodyKind = DirectObjectEmitStandaloneEntryBodyKind(plan, functionLimit)
    if entryBodyKind == texpr.BodyKindReturnZeroI32 ||
       DirectObjectEmitIsReturnI32ConstBodyKind(entryBodyKind) ||
       entryBodyKind == texpr.BodyKindMainF64MulCheckExit ||
       entryBodyKind == texpr.BodyKindReturnCallNoargI32 ||
       DirectObjectEmitIsLetCallNoargReturnI32ConstBodyKind(entryBodyKind) ||
       texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(entryBodyKind) ||
       entryBodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32 ||
       texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(entryBodyKind) ||
       texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(entryBodyKind) ||
       entryBodyKind == texpr.BodyKindResultRequestDispatch ||
       entryBodyKind == texpr.BodyKindStatementSequence:
        return int64(4)
    return int64(0)

fn DirectObjectEmitStandaloneTextByteSize(plan: pobj.PrimaryObjectPlan): int32 =
    return DirectObjectEmitTextByteSize(plan)

fn DirectObjectEmitStandaloneDataSectionAddr(plan: pobj.PrimaryObjectPlan): int32 =
    return DirectObjectEmitDataSectionAddr(plan)

fn DirectObjectEmitCanStandaloneMain(plan: pobj.PrimaryObjectPlan): bool =
    if !DirectObjectEmitTargetSupported(plan):
        return false
    if len(plan.outputPath) <= 0:
        return false
    if plan.missingReasons.len > 0:
        return false
    if plan.functionBodyKinds.len <= 0:
        return false
    if plan.functionBodyKinds.len != plan.functionWordCounts.len:
        return false
    if plan.symbolNames.len != plan.functionBodyKinds.len ||
       plan.symbolNames.len != plan.functionWordCounts.len ||
       plan.symbolNames.len != plan.functionWordOffsets.len ||
       plan.symbolNames.len != plan.itemIds.len:
        return false
    if plan.relocTargetSymbols.len != plan.relocSourceItemIds.len ||
       plan.relocTargetSymbols.len != plan.relocWordOffsets.len:
        return false
    let functionLimit = DirectObjectEmitRealFunctionLimit(plan)
    if functionLimit <= 0:
        return false
    let entryIndex = DirectObjectEmitEntryFunctionIndex(plan, functionLimit)
    if entryIndex < 0:
        return false
    let entryBodyKind = plan.functionBodyKinds[entryIndex]
    var entryBodyIrReady = false
    if entryIndex < plan.functionBodyIRs.len:
        let entryBodyIR = plan.functionBodyIRs[entryIndex]
        entryBodyIrReady = pobj.PrimaryBodyIrIsCallSequenceReturnInt32(entryBodyIR) ||
                           pobj.PrimaryBodyIrIsCallSequenceReturnI32Const(entryBodyIR) ||
                           pobj.PrimaryBodyIrIsCallSequenceReturnStr(entryBodyIR) ||
                           pobj.PrimaryBodyIrIsCallSequenceReturnAggregate(entryBodyIR)
    if entryBodyKind != texpr.BodyKindReturnZeroI32 &&
       !DirectObjectEmitIsReturnI32ConstBodyKind(entryBodyKind) &&
       entryBodyKind != texpr.BodyKindReturnCallNoargI32 &&
       !DirectObjectEmitIsLetCallNoargReturnI32ConstBodyKind(entryBodyKind) &&
       !texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(entryBodyKind) &&
       entryBodyKind != texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32 &&
       !texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(entryBodyKind) &&
       !texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(entryBodyKind) &&
       entryBodyKind != texpr.BodyKindResultRequestDispatch &&
       entryBodyKind != texpr.BodyKindStatementSequence &&
       entryBodyKind != texpr.BodyKindMainF64MulCheckExit &&
       !entryBodyIrReady:
        return false
    if DirectObjectEmitStandaloneNeedsMainWrapper(plan) &&
       DirectObjectEmitStandaloneWrapperByteSize(plan, functionLimit) <= int64(0):
        return false
    for i in 0..<plan.functionBodyKinds.len:
        let bodyKind = plan.functionBodyKinds[i]
        if i >= functionLimit:
            if bodyKind != texpr.BodyKindEntryBridge:
                return false
            if i != plan.functionBodyKinds.len - 1:
                return false
            if plan.functionWordCounts[i] != texpr.BodyKindEntryBridgeWordCount:
                return false
            continue
        if len(plan.symbolNames[i]) <= 0:
            return false
        let expectedWords = DirectObjectEmitExpectedWordsForPlanFunction(plan, i)
        if expectedWords <= 0 ||
           bodyKind == texpr.BodyKindEntryBridge:
            return false
        if plan.functionWordCounts[i] != expectedWords:
            return false
        if i == 0:
            if plan.functionWordOffsets[i] != 0:
                return false
        elif i > 0:
            let previousIndex = i - 1
            let expectedOffset = plan.functionWordOffsets[previousIndex] + plan.functionWordCounts[previousIndex]
            if plan.functionWordOffsets[i] != expectedOffset:
                return false
        var requiredStatementCallCount: int32
        if i < plan.functionStatementCallCounts.len:
            requiredStatementCallCount = plan.functionStatementCallCounts[i]
        let cstringCallCount = DirectObjectEmitCstringLiteralCallCount(plan, i)
        if cstringCallCount > 0:
            continue
        var bodyIrReady = false
        if i < plan.functionBodyIRs.len:
            let bodyIR = plan.functionBodyIRs[i]
            bodyIrReady = pobj.PrimaryBodyIrIsCallSequenceReturnInt32(bodyIR) ||
                          pobj.PrimaryBodyIrIsCallSequenceReturnI32Const(bodyIR) ||
                          pobj.PrimaryBodyIrIsCallSequenceReturnStr(bodyIR) ||
                          pobj.PrimaryBodyIrIsCallSequenceReturnAggregate(bodyIR)
        if bodyIrReady ||
           bodyKind == texpr.BodyKindStatementSequence ||
           texpr.TypedExprIsCallRelocBodyKind(bodyKind) ||
           DirectObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
            if bodyIrReady && i < plan.functionBodyIRs.len:
                requiredStatementCallCount = plan.functionBodyIRs[i].callSequence.len
            if requiredStatementCallCount <= 0:
                requiredStatementCallCount = 1
            for callOrdinal in 0..<requiredStatementCallCount:
                let targetSymbol = DirectObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[i], callOrdinal)
                if !DirectObjectEmitSymbolInRealFunctions(plan, functionLimit, targetSymbol):
                    return false
    return true

fn DirectObjectEmitStandaloneText(plan: pobj.PrimaryObjectPlan): rawbytes.Bytes =
    return DirectObjectEmitPlanText(plan)

fn DirectObjectEmitStandaloneSymbols(plan: pobj.PrimaryObjectPlan): osym.ObjectSymbolTable =
    let functionLimit = DirectObjectEmitRealFunctionLimit(plan)
    var symbols = osym.ObjectSymbolsInit()
    let entryIndex = DirectObjectEmitEntryFunctionIndex(plan, functionLimit)
    if entryIndex >= 0 && plan.entryFunctionSymbol != "_main":
        DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddDefined(symbols,
                                                                  "_main",
                                                                  0,
                                                                  int64(plan.functionWordOffsets[entryIndex] * 4),
                                                                  int64(plan.functionWordCounts[entryIndex] * 4),
                                                                  true),
                                     "direct object emit: add _main symbol")
    for i in 0..<functionLimit:
        let offset = int64(plan.functionWordOffsets[i] * 4)
        let size = int64(plan.functionWordCounts[i] * 4)
        DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddDefined(symbols,
                                                                  plan.symbolNames[i],
                                                                  0,
                                                                  offset,
                                                                  size,
                                                                  true),
                                     "direct object emit: add function symbol")
    var dataOffset: int32
    let dataAddr = DirectObjectEmitStandaloneDataSectionAddr(plan)
    for i in 0..<plan.dataLabels.len:
        var payloadSize: int32
        if i < plan.dataPayloadTexts.len:
            payloadSize = DirectObjectEmitPayloadByteCount(plan.dataPayloadTexts[i])
        DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddDefined(symbols,
                                                                  plan.dataLabels[i],
                                                                  1,
                                                                  int64(dataAddr + dataOffset),
                                                                  int64(payloadSize),
                                                                  false),
                                     "direct object emit: add data symbol")
        dataOffset = dataOffset + payloadSize
    for i in 0..<plan.relocTargetSymbols.len:
        if len(plan.relocTargetSymbols[i]) <= 0:
            continue
        if DirectObjectEmitSymbolInRealFunctions(plan, functionLimit, plan.relocTargetSymbols[i]):
            continue
        DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddUndefined(symbols,
                                                                    plan.relocTargetSymbols[i],
                                                                    true),
                                     "direct object emit: add undefined symbol")
    return symbols

fn DirectObjectEmitStandaloneRelocs(plan: pobj.PrimaryObjectPlan,
                                     symbols: osym.ObjectSymbolTable): orel.ObjectRelocTable =
    let functionLimit = DirectObjectEmitRealFunctionLimit(plan)
    var relocs = orel.ObjectRelocsInit()
    for relocIndex in 0..<plan.relocTargetSymbols.len:
        if relocIndex >= plan.relocSourceItemIds.len || relocIndex >= plan.relocWordOffsets.len:
            continue
        var sourceInStandalone = false
        for i in 0..<functionLimit:
            if plan.itemIds[i] == plan.relocSourceItemIds[relocIndex]:
                sourceInStandalone = true
                break
        if !sourceInStandalone:
            continue
        DirectObjectEmitAddBranchReloc(relocs,
                                       symbols,
                                       int64(plan.relocWordOffsets[relocIndex] * 4),
                                       plan.relocTargetSymbols[relocIndex])
    for i in 0..<functionLimit:
        let cstringCallCount = DirectObjectEmitCstringLiteralCallCount(plan, i)
        if cstringCallCount <= 0:
            continue
        let functionByteOffset = int64(plan.functionWordOffsets[i] * 4)
        for callOrdinal in 0..<cstringCallCount:
            let literalSymbol = DirectObjectEmitDataLabelExact(plan,
                                                               DirectObjectEmitCStringLiteralDataLabel(plan.symbolNames[i],
                                                                                                       callOrdinal))
            let callByteOffset = functionByteOffset + int64((2 + callOrdinal * 3) * 4)
            DirectObjectEmitAddPageRelocPair(relocs,
                                             symbols,
                                             callByteOffset,
                                             literalSymbol,
                                             "direct object emit: add cstring page reloc")
    return relocs

fn DirectObjectEmitWriteStandaloneMain(rootDir: str,
                                        plan: pobj.PrimaryObjectPlan): Result[DirectObjectEmitResult] =
    let text = DirectObjectEmitStandaloneText(plan)
    let data = DirectObjectEmitPlanData(plan, DirectObjectEmitRealFunctionLimit(plan))
    let symbols = DirectObjectEmitStandaloneSymbols(plan)
    let relocs = DirectObjectEmitStandaloneRelocs(plan, symbols)
    let writeRes = macho.MachOTextDataObjectWrite(rootDir,
                                                  plan.outputPath,
                                                  text,
                                                  data,
                                                  symbols,
                                                  relocs)
    if IsErr(writeRes):
        return Err[DirectObjectEmitResult](Error(writeRes))
    let write = Value(writeRes)
    var out: DirectObjectEmitResult
    out.objectPath = write.objectPath
    out.bytesWritten = write.bytesWritten
    out.symbolCount = write.symbolCount
    out.relocCount = write.relocCount
    return Ok[DirectObjectEmitResult](out)

fn DirectObjectEmitValidateStandaloneShape(plan: pobj.PrimaryObjectPlan): Result[bool] =
    if DirectObjectEmitCanStandaloneMain(plan):
        return Ok[bool](true)
    if !DirectObjectEmitTargetSupported(plan):
        return Err[bool](Fmt" direct object emit: unsupported target: {plan.targetTriple}")
    if len(plan.outputPath) <= 0:
        return Err[bool](" direct object emit: missing output path")
    if plan.missingReasons.len > 0:
        return Err[bool](" direct object emit: plan has missing reasons")
    if plan.functionBodyKinds.len <= 0:
        return Err[bool](" direct object emit: missing function body kind")
    let functionLimit = DirectObjectEmitRealFunctionLimit(plan)
    let entryIndex = DirectObjectEmitEntryFunctionIndex(plan, functionLimit)
    if entryIndex < 0:
        return Err[bool](" direct object emit: standalone missing entry function")
    let entryBodyKind = plan.functionBodyKinds[entryIndex]
    var entryBodyIrReady = false
    if entryIndex < plan.functionBodyIRs.len:
        let entryBodyIR = plan.functionBodyIRs[entryIndex]
        entryBodyIrReady = pobj.PrimaryBodyIrIsCallSequenceReturnInt32(entryBodyIR) ||
                           pobj.PrimaryBodyIrIsCallSequenceReturnI32Const(entryBodyIR) ||
                           pobj.PrimaryBodyIrIsCallSequenceReturnStr(entryBodyIR) ||
                           pobj.PrimaryBodyIrIsCallSequenceReturnAggregate(entryBodyIR)
    if entryBodyKind != texpr.BodyKindReturnZeroI32 &&
       !DirectObjectEmitIsReturnI32ConstBodyKind(entryBodyKind) &&
       entryBodyKind != texpr.BodyKindReturnCallNoargI32 &&
       !DirectObjectEmitIsLetCallNoargReturnI32ConstBodyKind(entryBodyKind) &&
       !texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(entryBodyKind) &&
       entryBodyKind != texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32 &&
       !texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(entryBodyKind) &&
       !texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(entryBodyKind) &&
       entryBodyKind != texpr.BodyKindResultRequestDispatch &&
       entryBodyKind != texpr.BodyKindStatementSequence &&
       entryBodyKind != texpr.BodyKindMainF64MulCheckExit &&
       !entryBodyIrReady:
        return Err[bool](" direct object emit: standalone entry must be direct-provider-free")
    for i in 0..<functionLimit:
        let bodyKind = plan.functionBodyKinds[i]
        if DirectObjectEmitExpectedWordsForPlanFunction(plan, i) <= 0 ||
           bodyKind == texpr.BodyKindEntryBridge:
            return Err[bool](Fmt" direct object emit: standalone unsupported body kind: {bodyKind}")
    return Err[bool](" direct object emit: standalone object requires unsupported codegen")

fn DirectObjectEmitValidateStandaloneMain(plan: pobj.PrimaryObjectPlan): Result[bool] =
    let shapeRes = DirectObjectEmitValidateStandaloneShape(plan)
    if IsErr(shapeRes):
        return shapeRes
    return Ok[bool](true)

fn DirectObjectEmitCanPlanObject(plan: pobj.PrimaryObjectPlan): bool =
    return plan.objectFormat == "macho" &&
           plan.instructionWords.len > 0 &&
           len(plan.outputPath) > 0 &&
           plan.missingReasons.len <= 0

fn DirectObjectEmitCanReturnZeroObject(plan: pobj.PrimaryObjectPlan): bool =
    if !DirectObjectEmitCanPlanObject(plan):
        return false
    for i in 0..<plan.functionBodyKinds.len:
        if plan.functionBodyKinds[i] != texpr.BodyKindReturnZeroI32:
            return false
    return true

fn DirectObjectEmitValidatePlanObject(plan: pobj.PrimaryObjectPlan): Result[bool] =
    if DirectObjectEmitCanPlanObject(plan):
        return Ok[bool](true)
    if !DirectObjectEmitTargetSupported(plan):
        return Err[bool](Fmt" direct object emit: unsupported target: {plan.targetTriple}")
    if len(plan.outputPath) <= 0:
        return Err[bool](" direct object emit: missing output path")
    if plan.missingReasons.len > 0:
        return Err[bool](" direct object emit: plan has missing reasons")
    if plan.symbolNames.len <= 0:
        return Err[bool](" direct object emit: missing symbols")
    return Err[bool](" direct object emit: object requires unsupported codegen")

fn DirectObjectEmitReturnZeroText(symbolNames: str[]): rawbytes.Bytes =
    var text = obuf.ObjectBufferInit(symbolNames.len * 8 + 16)
    for _ in 0..<symbolNames.len:
        obuf.ObjectBufferWriteU32LE(text, uint64(0x52800000))  ; MOVZ W0, #0
        obuf.ObjectBufferWriteU32LE(text, uint64(0xd65f03c0))  ; RET
    return obuf.ObjectBufferToBytes(text)

fn DirectObjectEmitReturnZeroSymbols(symbolNames: str[]): osym.ObjectSymbolTable =
    var symbols = osym.ObjectSymbolsInit()
    var offset: int64
    for i in 0..<symbolNames.len:
        DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddDefined(symbols,
                                                                  symbolNames[i],
                                                                  0,
                                                                  offset,
                                                                  int64(8),
                                                                  true),
                                     "direct object emit: add return-zero symbol")
        offset = offset + int64(8)
    return symbols

fn DirectObjectEmitPlanText(plan: pobj.PrimaryObjectPlan): rawbytes.Bytes =
    var text = obuf.ObjectBufferInit(plan.instructionWords.len * 4 + 16)
    for i in 0..<plan.instructionWords.len:
        let word = plan.instructionWords[i]
        obuf.ObjectBufferWriteU8(text, word & 255)
        obuf.ObjectBufferWriteU8(text, (word >> 8) & 255)
        obuf.ObjectBufferWriteU8(text, (word >> 16) & 255)
        obuf.ObjectBufferWriteU8(text, (word >> 24) & 255)
    return obuf.ObjectBufferToBytes(text)

fn DirectObjectEmitPlanData(plan: pobj.PrimaryObjectPlan,
                             functionLimit: int32): rawbytes.Bytes =
    var data = obuf.ObjectBufferInit(64)
    for i in 0..<plan.dataLabels.len:
        var payloadText = ""
        if i < plan.dataPayloadTexts.len:
            payloadText = plan.dataPayloadTexts[i]
        if chengpath.TextStartsWith(payloadText, "cstring:"):
            DirectObjectEmitWriteCStringPayload(data, payloadText)
        else:
            let count = DirectObjectEmitPayloadByteCount(payloadText)
            obuf.ObjectBufferWriteZeros(data, count)
    return obuf.ObjectBufferToBytes(data)

fn DirectObjectEmitPlanSymbols(plan: pobj.PrimaryObjectPlan): osym.ObjectSymbolTable =
    var symbols = osym.ObjectSymbolsInit()
    for i in 0..<plan.symbolNames.len:
        let offset = int64(plan.functionWordOffsets[i] * 4)
        let size = int64(plan.functionWordCounts[i] * 4)
        DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddDefined(symbols,
                                                                  plan.symbolNames[i],
                                                                  0,
                                                                  offset,
                                                                  size,
                                                                  true),
                                     "direct object emit: add plan function symbol")
    var dataOffset: int32
    let dataAddr = DirectObjectEmitDataSectionAddr(plan)
    for i in 0..<plan.dataLabels.len:
        var payloadSize: int32
        if i < plan.dataPayloadTexts.len:
            payloadSize = DirectObjectEmitPayloadByteCount(plan.dataPayloadTexts[i])
        DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddDefined(symbols,
                                                                  plan.dataLabels[i],
                                                                  1,
                                                                  int64(dataAddr + dataOffset),
                                                                  int64(payloadSize),
                                                                  false),
                                     "direct object emit: add plan data symbol")
        dataOffset = dataOffset + payloadSize
    for i in 0..<plan.symbolNames.len:
        if DirectObjectEmitFunctionLooksEntryBridgeWords(plan, i):
            DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddUndefined(symbols,
                                                                        DirectObjectEmitEntryBridgeSetCmdLineSymbol(plan),
                                                                        true),
                                         "direct object emit: add entry argv symbol")
            DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddUndefined(symbols,
                                                                        DirectObjectEmitEntryBridgeLineMapSymbol(plan),
                                                                        true),
                                         "direct object emit: add entry line-map symbol")
            DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddUndefined(symbols,
                                                                        DirectObjectEmitEntryBridgeTargetSymbol(plan),
                                                                        true),
                                         "direct object emit: add entry target symbol")
            DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddUndefined(symbols,
                                                                        DirectObjectEmitEntryBridgeProfileFlushSymbol(plan),
                                                                        true),
                                         "direct object emit: add entry profile symbol")
    for i in 0..<plan.relocTargetSymbols.len:
        if len(plan.relocTargetSymbols[i]) > 0:
            DirectObjectEmitRequireIndex(osym.ObjectSymbolsAddUndefined(symbols,
                                                                        plan.relocTargetSymbols[i],
                                                                        true),
                                         "direct object emit: add plan undefined symbol")
    return symbols

fn DirectObjectEmitAddBranchReloc(relocs: var orel.ObjectRelocTable,
                                   symbols: osym.ObjectSymbolTable,
                                   byteOffset: int64,
                                   targetSymbol: str) =
    let targetIndex = osym.ObjectSymbolsFind(symbols, targetSymbol)
    if targetIndex >= 0:
        DirectObjectEmitRequireIndex(orel.ObjectRelocsAdd(relocs,
                                                          0,
                                                          byteOffset,
                                                          targetIndex,
                                                          orel.ObjectRelocBranch26,
                                                          int64(0),
                                                          true),
                                     "direct object emit: add branch reloc")

fn DirectObjectEmitAddPageRelocPair(relocs: var orel.ObjectRelocTable,
                                     symbols: osym.ObjectSymbolTable,
                                     byteOffset: int64,
                                     targetSymbol: str,
                                     label: str) =
    let targetIndex = osym.ObjectSymbolsFind(symbols, targetSymbol)
    if targetIndex < 0:
        assert(false, label)
        return
    DirectObjectEmitRequireIndex(orel.ObjectRelocsAdd(relocs,
                                                      0,
                                                      byteOffset,
                                                      targetIndex,
                                                      orel.ObjectRelocPage21,
                                                      int64(0),
                                                      true),
                                 label)
    DirectObjectEmitRequireIndex(orel.ObjectRelocsAdd(relocs,
                                                      0,
                                                      byteOffset + int64(4),
                                                      targetIndex,
                                                      orel.ObjectRelocPageOff12,
                                                      int64(0),
                                                      false),
                                 label)

fn DirectObjectEmitRuntimeDataLabelForOrdinal(plan: pobj.PrimaryObjectPlan,
                                               ordinal: int32): str =
    if ordinal == 0:
        return DirectObjectEmitDataLabelByTail(plan, "__cheng_saved_argc")
    if ordinal == 1:
        return DirectObjectEmitDataLabelByTail(plan, "__cheng_saved_argv")
    return ""

fn DirectObjectEmitPlanRelocs(plan: pobj.PrimaryObjectPlan,
                               symbols: osym.ObjectSymbolTable): orel.ObjectRelocTable =
    var relocs = orel.ObjectRelocsInit()
    for relocIndex in 0..<plan.relocTargetSymbols.len:
        if relocIndex >= plan.relocWordOffsets.len:
            continue
        DirectObjectEmitAddBranchReloc(relocs,
                                       symbols,
                                       int64(plan.relocWordOffsets[relocIndex] * 4),
                                       plan.relocTargetSymbols[relocIndex])
    for i in 0..<plan.symbolNames.len:
        if i >= plan.functionWordOffsets.len || i >= plan.functionWordCounts.len:
            continue
        let functionByteOffset = int64(plan.functionWordOffsets[i] * 4)
        let cstringCallCount = DirectObjectEmitCstringLiteralCallCount(plan, i)
        for callOrdinal in 0..<cstringCallCount:
            let literalSymbol = DirectObjectEmitDataLabelExact(plan,
                                                               DirectObjectEmitCStringLiteralDataLabel(plan.symbolNames[i],
                                                                                                       callOrdinal))
            let callByteOffset = functionByteOffset + int64((2 + callOrdinal * 3) * 4)
            DirectObjectEmitAddPageRelocPair(relocs,
                                             symbols,
                                             callByteOffset,
                                             literalSymbol,
                                             "direct object emit: add plan cstring page reloc")
        if plan.functionBodyKinds[i] == texpr.BodyKindRuntimeSetCmdLine:
            DirectObjectEmitAddPageRelocPair(relocs,
                                             symbols,
                                             functionByteOffset,
                                             DirectObjectEmitRuntimeDataLabelForOrdinal(plan, 0),
                                             "direct object emit: add plan argc page reloc")
            DirectObjectEmitAddPageRelocPair(relocs,
                                             symbols,
                                             functionByteOffset + int64(12),
                                             DirectObjectEmitRuntimeDataLabelForOrdinal(plan, 1),
                                             "direct object emit: add plan argv page reloc")
        if DirectObjectEmitFunctionLooksEntryBridgeWords(plan, i):
            let baseByteOffset = plan.functionWordOffsets[i] * 4
            DirectObjectEmitAddBranchReloc(relocs,
                                           symbols,
                                           int64(baseByteOffset + 12),
                                           DirectObjectEmitEntryBridgeSetCmdLineSymbol(plan))
            DirectObjectEmitAddBranchReloc(relocs,
                                           symbols,
                                           int64(baseByteOffset + 24),
                                           DirectObjectEmitEntryBridgeLineMapSymbol(plan))
            DirectObjectEmitAddBranchReloc(relocs,
                                           symbols,
                                           int64(baseByteOffset + 32),
                                           DirectObjectEmitEntryBridgeTargetSymbol(plan))
            DirectObjectEmitAddBranchReloc(relocs,
                                           symbols,
                                           int64(baseByteOffset + 48),
                                           DirectObjectEmitEntryBridgeProfileFlushSymbol(plan))
    return relocs

fn DirectObjectEmitReturnZeroObject(rootDir: str,
                                     outputPath: str,
                                     symbolNames: str[]): Result[DirectObjectEmitResult] =
    if symbolNames.len <= 0:
        return Err[DirectObjectEmitResult](" direct object emit: missing symbols")
    let text = DirectObjectEmitReturnZeroText(symbolNames)
    let symbols = DirectObjectEmitReturnZeroSymbols(symbolNames)
    var relocs = orel.ObjectRelocsInit()
    let writeRes = macho.MachOTextObjectWrite(rootDir,
                                              outputPath,
                                              text,
                                              symbols,
                                              relocs)
    if IsErr(writeRes):
        return Err[DirectObjectEmitResult](Error(writeRes))
    let write = Value(writeRes)
    var out: DirectObjectEmitResult
    out.objectPath = write.objectPath
    out.bytesWritten = write.bytesWritten
    out.symbolCount = write.symbolCount
    out.relocCount = write.relocCount
    return Ok[DirectObjectEmitResult](out)

fn DirectObjectEmitPlanObject(rootDir: str,
                              plan: pobj.PrimaryObjectPlan): Result[DirectObjectEmitResult] =
    let validRes = DirectObjectEmitValidatePlanObject(plan)
    if IsErr(validRes):
        return Err[DirectObjectEmitResult](Error(validRes))
    let text = DirectObjectEmitPlanText(plan)
    let data = DirectObjectEmitPlanData(plan, plan.functionBodyKinds.len)
    let symbols = DirectObjectEmitPlanSymbols(plan)
    let relocs = DirectObjectEmitPlanRelocs(plan, symbols)
    let writeRes = macho.MachOTextDataObjectWrite(rootDir,
                                                  plan.outputPath,
                                                  text,
                                                  data,
                                                  symbols,
                                                  relocs)
    if IsErr(writeRes):
        return Err[DirectObjectEmitResult](Error(writeRes))
    let write = Value(writeRes)
    var out: DirectObjectEmitResult
    out.objectPath = write.objectPath
    out.bytesWritten = write.bytesWritten
    out.symbolCount = write.symbolCount
    out.relocCount = write.relocCount
    return Ok[DirectObjectEmitResult](out)

fn DirectObjectEmitStandaloneMain(rootDir: str,
                                   plan: pobj.PrimaryObjectPlan): Result[DirectObjectEmitResult] =
    let validRes = DirectObjectEmitValidateStandaloneMain(plan)
    if IsErr(validRes):
        return Err[DirectObjectEmitResult](Error(validRes))
    return DirectObjectEmitWriteStandaloneMain(rootDir, plan)
