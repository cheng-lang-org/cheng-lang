fn TargetIsDarwinArm64(targetTriple: str): bool =
    return targetTriple == "arm64-apple-darwin" ||
           targetTriple == "aarch64-apple-ios" ||
           targetTriple == "arm64-apple-ios"

fn TargetIsWasm(targetTriple: str): bool =
    return targetTriple == "wasm32-unknown-unknown"

fn TargetIsLinuxX8664(targetTriple: str): bool =
    return targetTriple == "x86_64-unknown-linux-gnu"

fn TargetIsLinuxAarch64(targetTriple: str): bool =
    return targetTriple == "aarch64-unknown-linux-gnu" || targetTriple == "arm64-unknown-linux-gnu"

fn TargetIsAndroidAarch64(targetTriple: str): bool =
    return targetTriple == "aarch64-linux-android"

fn TargetIsOhosAarch64(targetTriple: str): bool =
    return targetTriple == "aarch64-linux-ohos" ||
           targetTriple == "aarch64-unknown-linux-ohos"

fn TargetIsLinuxRiscv64(targetTriple: str): bool =
    return targetTriple == "riscv64-unknown-linux-gnu"

fn TargetIsWindowsAarch64(targetTriple: str): bool =
    return targetTriple == "aarch64-pc-windows-msvc" || targetTriple == "arm64-pc-windows-msvc"

fn TargetIsWindowsX8664(targetTriple: str): bool =
    return targetTriple == "x86_64-pc-windows-msvc"

fn TargetIsWindows(targetTriple: str): bool =
    return TargetIsWindowsAarch64(targetTriple) ||
           TargetIsWindowsX8664(targetTriple)

fn TargetIsElfObject(targetTriple: str): bool =
    return TargetIsLinuxAarch64(targetTriple) ||
           TargetIsAndroidAarch64(targetTriple) ||
           TargetIsOhosAarch64(targetTriple) ||
           TargetIsLinuxX8664(targetTriple) ||
           TargetIsLinuxRiscv64(targetTriple)

fn TargetIsCoffObject(targetTriple: str): bool =
    return TargetIsWindows(targetTriple)

fn TargetUsesLinuxNolibcRuntime(targetTriple: str): bool =
    return TargetIsLinuxAarch64(targetTriple)

fn TargetNeedsNativeProviders(targetTriple: str): bool =
    return !TargetIsWasm(targetTriple)

fn TargetRequiresNativeProviderModules(targetTriple: str): bool =
    return TargetNeedsNativeProviders(targetTriple) &&
           !TargetUsesLinuxNolibcRuntime(targetTriple)

fn TargetPrimaryObjectFormat(targetTriple: str): str =
    if TargetIsDarwinArm64(targetTriple):
        return "macho"
    if TargetIsWasm(targetTriple):
        return "wasm"
    if TargetIsCoffObject(targetTriple):
        return "coff"
    if TargetIsElfObject(targetTriple):
        return "elf"
    return "unknown"

fn TargetLinkerFlavor(targetTriple: str): str =
    if TargetIsDarwinArm64(targetTriple):
        return "ld64"
    if TargetUsesLinuxNolibcRuntime(targetTriple):
        return "elf_aarch64_nolibc_internal"
    if TargetIsLinuxRiscv64(targetTriple):
        return "elf_riscv64_builtin"
    if TargetIsWindows(targetTriple):
        return "coff_pe_builtin"
    return "system_linker"

fn TargetLinkerProgram(targetTriple: str): str =
    if TargetUsesLinuxNolibcRuntime(targetTriple):
        return "internal_elf_linker"
    if TargetIsLinuxRiscv64(targetTriple):
        return "builtin_elf_linker_riscv64"
    if TargetIsWindows(targetTriple):
        return "builtin_coff_linker"
    return "cc"
