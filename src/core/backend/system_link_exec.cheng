import cheng/core/runtime/compiler_runtime as comprun
import cheng/core/runtime/debug_runtime as debrun
import cheng/core/runtime/program_support as prun

@importc("cheng_monotime_ns")
fn SystemLinkExecMonoTimeNsBridge(): int64

type
    SystemLinkExecPhaseProfile =
        systemLinkPlanNs: int64
        sourceBundleNs: int64
        compilerCsgNs: int64
        worldNs: int64
        lockNs: int64
        baselineNs: int64
        loweringPlanNs: int64
        primaryObjectPlanNs: int64
        providerSourcesNs: int64
        objectPlanNs: int64
        nativeLinkPlanNs: int64
        compileReceiptNs: int64
        totalNs: int64

    SystemLinkExecPlan =
        compilerEntrySource: str
        sourceBundleCid: layout.FixedBytes32
        systemLinkPlan: slplan.SystemLinkPlanStub
        compilerCsg: ccsg.CompilerCsg
        exportSurface: ccsg.CsgExportSurface
        localUniverse: cworld.CompilerLocalUniverse
        compileReceipt: ccsg.CompileReceipt
        worldHeadPinned: bool
        lockCheckEnabled: bool
        lockVerified: bool
        baselineSurfaceChecked: bool
        baselineSurfaceCompatible: bool
        lockPath: str
        baselineSurfacePath: str
        phaseProfile: SystemLinkExecPhaseProfile
        loweringPlan: lower.LoweringPlanStub
        primaryObjectPlan: pobj.PrimaryObjectPlan
        objectPlan: objplan.ObjectPlanStub
        nativeLinkPlan: nplan.NativeLinkPlanStub

fn SystemLinkExecNowNs(): int64 =
    return SystemLinkExecMonoTimeNsBridge()

fn SystemLinkExecPhaseMsText(ns: int64): str =
    if ns <= 0:
        return "0"
    return int64ToStr(ns / 1000000)

fn SystemLinkExecProgressStdErrEnabled(): bool =
    let raw = strutil.Strip(os.GetEnv("CHENG_PROGRESS"))
    return len(raw) > 0 && raw != "0" && raw != "false"

fn SystemLinkExecProgressPath(): str =
    return strutil.Strip(os.GetEnv("CHENG_PROGRESS_OUT"))

fn SystemLinkExecProgressAppendEnabled(): bool =
    let raw = strutil.Strip(os.GetEnv("CHENG_PROGRESS_APPEND"))
    return len(raw) > 0 && raw != "0" && raw != "false"

fn SystemLinkExecProgressLine(phase: str,
                                status: str,
                                phaseNs: int64,
                                totalNs: int64): str =
    var out = "compile_progress phase=" + phase + " status=" + status
    if phaseNs >= int64(0):
        out = out + " phase_ms=" + SystemLinkExecPhaseMsText(phaseNs)
    if totalNs >= int64(0):
        out = out + " total_ms=" + SystemLinkExecPhaseMsText(totalNs)
    return out

fn SystemLinkExecProgressWriteGuardLine(rootDir: str,
                                          progressPath: str,
                                          progressText: var str,
                                          line: str) =
    os.WriteLine(os.Get_stderr(), line)
    if len(progressPath) <= 0:
        return
    if len(progressText) <= 0 && SystemLinkExecProgressAppendEnabled() && os.FileExists(progressPath):
        progressText = chengpath.ReadTextFile("", progressPath)
        if len(progressText) > 0 && progressText[len(progressText) - 1] == '\n':
            progressText = strings.SliceBytes(progressText, 0, len(progressText) - 1)
    if len(progressText) > 0:
        progressText = progressText + "\n"
    progressText = progressText + line
    let _ = chengpath.WriteTextFile(rootDir, progressPath, progressText + "\n")

fn SystemLinkExecProgressResourceGuardCheck(rootDir: str,
                                              progressPath: str,
                                              progressText: var str) =
    let maxRssBytes: int64 = hostops.HostOpsConfiguredMaxRssBytes([])
    if maxRssBytes == int64(0):
        return
    if maxRssBytes < int64(0):
        SystemLinkExecProgressWriteGuardLine(rootDir,
                                             progressPath,
                                             progressText,
                                             "compile_progress phase=resource_guard status=invalid_max_rss")
        hostops.HostOpsExitProcess(2)
    let rssBytes: int64 = hostops.HostOpsCurrentRssBytes()
    if rssBytes <= maxRssBytes || rssBytes <= int64(0):
        return
    SystemLinkExecProgressWriteGuardLine(rootDir,
                                         progressPath,
                                         progressText,
                                         hostops.HostOpsMemoryLimitExceededLine(rssBytes, maxRssBytes))
    hostops.HostOpsExitProcess(hostops.ProcessMemoryExceeded)

fn SystemLinkExecProgressEmit(rootDir: str,
                                stderrEnabled: bool,
                                progressPath: str,
                                progressText: var str,
                                phase: str,
                                status: str,
                                phaseNs: int64,
                                totalNs: int64) =
    SystemLinkExecProgressResourceGuardCheck(rootDir, progressPath, progressText)
    if !stderrEnabled && len(progressPath) <= 0:
        return
    let line = SystemLinkExecProgressLine(phase, status, phaseNs, totalNs)
    if stderrEnabled:
        os.WriteLine(os.Get_stderr(), line)
    if len(progressPath) > 0:
        if len(progressText) <= 0 && SystemLinkExecProgressAppendEnabled() && os.FileExists(progressPath):
            progressText = chengpath.ReadTextFile("", progressPath)
            if len(progressText) > 0 && progressText[len(progressText) - 1] == '\n':
                progressText = strings.SliceBytes(progressText, 0, len(progressText) - 1)
        if len(progressText) > 0:
            progressText = progressText + "\n"
        progressText = progressText + line
        let _ = chengpath.WriteTextFile(rootDir, progressPath, progressText + "\n")

fn SystemLinkExecBrowserBridgeArtifactBasePath(outputPath: str): str =
    if len(outputPath) <= 0:
        return ""
    return outputPath + ".browser_bridge_plan.txt"

fn SystemLinkExecBrowserBridgeSourceBasePath(outputPath: str): str =
    if len(outputPath) <= 0:
        return ""
    return outputPath + ".browser_bridge.generated.cheng"

fn SystemLinkExecBrowserBridgeObjectBasePath(outputPath: str): str =
    if len(outputPath) <= 0:
        return ""
    return outputPath + ".browser_bridge.generated.o"

fn SystemLinkExecBrowserBridgeObjectPathForLinkPlan(linkPlan: slplan.SystemLinkPlanStub): str =
    let explicitPath = slplan.SystemLinkPlanBrowserBridgeObjectPath(linkPlan)
    if len(explicitPath) > 0:
        return explicitPath
    let bridgePlans = ccsg.CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan)
    if bridgePlans.len <= 0:
        return ""
    return SystemLinkExecBrowserBridgeObjectBasePath(linkPlan.outputPath)

fn SystemLinkExecBrowserBridgeArtifactPath(plan: SystemLinkExecPlan): str =
    let plans = ccsg.CompilerBrowserAbiBridgePlansForLinkPlan(plan.systemLinkPlan)
    if plans.len <= 0:
        return ""
    return SystemLinkExecBrowserBridgeArtifactBasePath(plan.systemLinkPlan.outputPath)

fn SystemLinkExecBrowserBridgeArtifactText(plan: SystemLinkExecPlan): str =
    let plans = ccsg.CompilerBrowserAbiBridgePlansForLinkPlan(plan.systemLinkPlan)
    return barule.BrowserAbiBridgePlanManifestText(plans)

fn SystemLinkExecBrowserBridgeSourcePath(plan: SystemLinkExecPlan): str =
    let plans = ccsg.CompilerBrowserAbiBridgePlansForLinkPlan(plan.systemLinkPlan)
    if plans.len <= 0:
        return ""
    return SystemLinkExecBrowserBridgeSourceBasePath(plan.systemLinkPlan.outputPath)

fn SystemLinkExecBrowserBridgeObjectPath(plan: SystemLinkExecPlan): str =
    let plans = ccsg.CompilerBrowserAbiBridgePlansForLinkPlan(plan.systemLinkPlan)
    if plans.len <= 0:
        return ""
    return SystemLinkExecBrowserBridgeObjectBasePath(plan.systemLinkPlan.outputPath)

fn SystemLinkExecBrowserBridgeSourceText(plan: SystemLinkExecPlan): str =
    let plans = ccsg.CompilerBrowserAbiBridgePlansForLinkPlan(plan.systemLinkPlan)
    return barule.BrowserAbiBridgeSourceText(plans)

fn SystemLinkExecWriteBrowserBridgeArtifact(rootDir: str,
                                              plan: SystemLinkExecPlan): bool =
    let artifactBasePath = SystemLinkExecBrowserBridgeArtifactBasePath(plan.systemLinkPlan.outputPath)
    if len(artifactBasePath) <= 0:
        return true
    let artifactPath = SystemLinkExecBrowserBridgeArtifactPath(plan)
    if len(artifactPath) <= 0:
        if os.FileExists(artifactBasePath):
            let _ = os.RemoveFile(artifactBasePath)
        return true
    let artifactText = SystemLinkExecBrowserBridgeArtifactText(plan) + "\n"
    return chengpath.WriteTextFile(rootDir, artifactPath, artifactText)

fn SystemLinkExecWriteBrowserBridgeSource(rootDir: str,
                                            plan: SystemLinkExecPlan): bool =
    let sourceBasePath = SystemLinkExecBrowserBridgeSourceBasePath(plan.systemLinkPlan.outputPath)
    if len(sourceBasePath) <= 0:
        return true
    let sourcePath = SystemLinkExecBrowserBridgeSourcePath(plan)
    if len(sourcePath) <= 0:
        if os.FileExists(sourceBasePath):
            let _ = os.RemoveFile(sourceBasePath)
        return true
    let sourceText = SystemLinkExecBrowserBridgeSourceText(plan) + "\n"
    return chengpath.WriteTextFile(rootDir, sourcePath, sourceText)

fn ProviderSourcesForPlan(rootDir: str, linkPlan: slplan.SystemLinkPlanStub): Result[str[]] =
    var out: str[]
    out = []
    for i in 0..<linkPlan.providerModules.len:
        let modulePath = linkPlan.providerModules[i]
        if modulePath == "runtime/core_runtime":
            var providerSource = ""
            providerSource = corun.CoreRuntimeProviderSourcePath(rootDir, linkPlan.targetTriple)
            add(out, providerSource)
        elif modulePath == "runtime/debug_runtime":
            var providerSource = ""
            providerSource = debrun.DebugRuntimeProviderSourcePath(rootDir)
            add(out, providerSource)
        elif modulePath == "runtime/compiler_runtime":
            var providerSource = ""
            if linkPlan.moduleKind == slplan.SystemCompilerControlPlane:
                providerSource = comprun.CompilerRuntimeProviderSourcePath(rootDir,
                                                                             comprun.CompilerRuntimeTrackTooling)
            else:
                providerSource = comprun.CompilerRuntimeProviderSourcePath(rootDir,
                                                                             comprun.CompilerRuntimeTrackProgram)
            add(out, providerSource)
        elif modulePath == "runtime/program_support":
            var providerSource = ""
            providerSource = prun.ProgramSupportProviderSourcePath(rootDir)
            add(out, providerSource)
        elif modulePath == "runtime/program_support_host_runtime":
            var providerSource = ""
            providerSource = prun.ProgramSupportHostProviderSourcePath(rootDir)
            add(out, providerSource)
        else:
            return Err[str[]](" provider source: unsupported module " + modulePath)
    return Ok[str[]](out)

fn SystemLinkExecLockCompilerProofCid(lock: cworld.CompilerLockSnapshot): layout.FixedBytes32 =
    for i in 0..<lock.entries.len:
        if lock.entries[i].packageId == "cheng/compiler":
            return lock.entries[i].migrationProofCid
    return layout.FixedBytes32()

fn SystemLinkExecBuiltinPackage(packageId: str): bool =
    if packageId == "cheng/compiler":
        return true
    if packageId == "cheng/std":
        return true
    return packageId == "cheng/runtime"

fn SystemLinkExecExtraManifestEntries(lock: cworld.CompilerLockSnapshot): cworld.CompilerUniverseManifestEntry[] =
    var out: cworld.CompilerUniverseManifestEntry[]
    for i in 0..<lock.entries.len:
        if SystemLinkExecBuiltinPackage(lock.entries[i].packageId):
            continue
        add(out, lock.entries[i])
    return out

fn SystemLinkExecExternalPackageRoots(rootDir: str,
                                        lock: cworld.CompilerLockSnapshot): parser.ParserExternalPackageRoot[] =
    var out: parser.ParserExternalPackageRoot[]
    for i in 0..<lock.entries.len:
        let entry = lock.entries[i]
        if SystemLinkExecBuiltinPackage(entry.packageId):
            continue
        let mirrorRoot = cworld.CompilerManagedMirrorRoot(rootDir,
                                                            lock.channel,
                                                            entry.packageId,
                                                            entry.migrationProofCid)
        let sourceRoot = chengpath.PathJoin(mirrorRoot, "src")
        if !chengpath.PathDirExists(sourceRoot):
            continue
        add(out, parser.ParserExternalPackageRootNew(entry.packageId, mirrorRoot))
    return out

fn BuildSystemLinkExecPlanWithWorldAndChannel(rootDir: str,
                                                req: creq.CompilerRequest,
                                                requestedWorldHead: str,
                                                lockPath: str,
                                                baselineSurfacePath: str,
                                                channelRaw: str): Result[SystemLinkExecPlan] =
    var phaseProfile: SystemLinkExecPhaseProfile
    let totalStartNs: int64 = SystemLinkExecNowNs()
    let progressStdErrEnabled = SystemLinkExecProgressStdErrEnabled()
    let progressPath = SystemLinkExecProgressPath()
    var progressText = ""
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "plan_build",
                                 "begin",
                                 int64(-1),
                                 int64(0))
    let lockCheckEnabled = len(lockPath) > 0
    let worldHeadPinned = len(requestedWorldHead) > 0
    if worldHeadPinned && !lockCheckEnabled:
        SystemLinkExecProgressEmit(rootDir,
                                     progressStdErrEnabled,
                                     progressPath,
                                     progressText,
                                     "plan_build",
                                     "error",
                                     int64(-1),
                                     SystemLinkExecNowNs() - totalStartNs)
        return Err[SystemLinkExecPlan](" compiler world: pinned --world-head requires --lock")
    var lockSnapshot: cworld.CompilerLockSnapshot
    var lockVerified = false
    var compilerProofCid = layout.FixedBytes32()
    var extraManifestEntries: cworld.CompilerUniverseManifestEntry[]
    var externalPackageRoots: parser.ParserExternalPackageRoot[]
    let lockStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "lock",
                                 "begin",
                                 int64(-1),
                                 lockStartNs - totalStartNs)
    if lockCheckEnabled:
        let lockRes = cworld.CompilerLockSnapshotRead(rootDir, lockPath)
        if IsErr(lockRes):
            SystemLinkExecProgressEmit(rootDir,
                                         progressStdErrEnabled,
                                         progressPath,
                                         progressText,
                                         "lock",
                                         "error",
                                         int64(-1),
                                         SystemLinkExecNowNs() - totalStartNs)
            return Err[SystemLinkExecPlan](Error(lockRes))
        lockSnapshot = Value(lockRes)
        compilerProofCid = SystemLinkExecLockCompilerProofCid(lockSnapshot)
        extraManifestEntries = SystemLinkExecExtraManifestEntries(lockSnapshot)
        externalPackageRoots = SystemLinkExecExternalPackageRoots(rootDir, lockSnapshot)
    phaseProfile.lockNs = SystemLinkExecNowNs() - lockStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "lock",
                                 "done",
                                 phaseProfile.lockNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    let systemLinkPlanStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "system_link_plan",
                                 "begin",
                                 int64(-1),
                                 systemLinkPlanStartNs - totalStartNs)
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    if !slplan.BuildSystemLinkPlanStubWithExternalPackageRoots(rootDir,
                                                                 req,
                                                                 externalPackageRoots,
                                                                 linkPlan,
                                                                 err):
        SystemLinkExecProgressEmit(rootDir,
                                     progressStdErrEnabled,
                                     progressPath,
                                     progressText,
                                     "system_link_plan",
                                     "error",
                                     int64(-1),
                                     SystemLinkExecNowNs() - totalStartNs)
        return Err[SystemLinkExecPlan](err)
    phaseProfile.systemLinkPlanNs = SystemLinkExecNowNs() - systemLinkPlanStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "system_link_plan",
                                 "done",
                                 phaseProfile.systemLinkPlanNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    let sourceBundleStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "source_bundle",
                                 "begin",
                                 int64(-1),
                                 sourceBundleStartNs - totalStartNs)
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    if IsErr(sourceBundleRes):
        SystemLinkExecProgressEmit(rootDir,
                                     progressStdErrEnabled,
                                     progressPath,
                                     progressText,
                                     "source_bundle",
                                     "error",
                                     int64(-1),
                                     SystemLinkExecNowNs() - totalStartNs)
        return Err[SystemLinkExecPlan](Error(sourceBundleRes))
    let sourceBundleCid = Value(sourceBundleRes)
    phaseProfile.sourceBundleNs = SystemLinkExecNowNs() - sourceBundleStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "source_bundle",
                                 "done",
                                 phaseProfile.sourceBundleNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    let compilerCsgStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "compiler_csg",
                                 "begin",
                                 int64(-1),
                                 compilerCsgStartNs - totalStartNs)
    let compilerCsgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    if IsErr(compilerCsgRes):
        SystemLinkExecProgressEmit(rootDir,
                                     progressStdErrEnabled,
                                     progressPath,
                                     progressText,
                                     "compiler_csg",
                                     "error",
                                     int64(-1),
                                     SystemLinkExecNowNs() - totalStartNs)
        return Err[SystemLinkExecPlan](Error(compilerCsgRes))
    let compilerCsg = ccsg.CompilerCsgClone(Value(compilerCsgRes))
    phaseProfile.compilerCsgNs = SystemLinkExecNowNs() - compilerCsgStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "compiler_csg",
                                 "done",
                                 phaseProfile.compilerCsgNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    let exportSurface = ccsg.CompilerExportSurfaceFromCsg(compilerCsg)
    let worldStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "world",
                                 "begin",
                                 int64(-1),
                                 worldStartNs - totalStartNs)
    let universeRes = cworld.CompilerLocalUniverseBuildForChannelWithManifestEntries(channelRaw,
                                                                                       sourceBundleCid,
                                                                                       compilerCsg.canonicalGraphCid,
                                                                                       exportSurface.surfaceCid,
                                                                                       compilerProofCid,
                                                                                       extraManifestEntries)
    if IsErr(universeRes):
        SystemLinkExecProgressEmit(rootDir,
                                     progressStdErrEnabled,
                                     progressPath,
                                     progressText,
                                     "world",
                                     "error",
                                     int64(-1),
                                     SystemLinkExecNowNs() - totalStartNs)
        return Err[SystemLinkExecPlan](Error(universeRes))
    let localUniverse = Value(universeRes)
    if worldHeadPinned:
        let pinRes = cworld.CompilerWorldHeadMatchesHex(localUniverse.worldHead, requestedWorldHead)
        if IsErr(pinRes):
            SystemLinkExecProgressEmit(rootDir,
                                         progressStdErrEnabled,
                                         progressPath,
                                         progressText,
                                         "world",
                                         "error",
                                         int64(-1),
                                         SystemLinkExecNowNs() - totalStartNs)
            return Err[SystemLinkExecPlan](Error(pinRes))
    phaseProfile.worldNs = SystemLinkExecNowNs() - worldStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "world",
                                 "done",
                                 phaseProfile.worldNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    if lockCheckEnabled:
        let verifyLockRes = cworld.CompilerWorldVerifyLock(localUniverse, lockSnapshot)
        if IsErr(verifyLockRes):
            SystemLinkExecProgressEmit(rootDir,
                                         progressStdErrEnabled,
                                         progressPath,
                                         progressText,
                                         "world",
                                         "error",
                                         int64(-1),
                                         SystemLinkExecNowNs() - totalStartNs)
            return Err[SystemLinkExecPlan](Error(verifyLockRes))
        lockVerified = true
    let baselineSurfaceChecked = len(baselineSurfacePath) > 0
    var baselineSurfaceCompatible = false
    let baselineStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "baseline",
                                 "begin",
                                 int64(-1),
                                 baselineStartNs - totalStartNs)
    if baselineSurfaceChecked:
        let baselinePath = chengpath.PathAbsolute(rootDir, baselineSurfacePath)
        if !chengpath.PathFileExists(baselinePath):
            SystemLinkExecProgressEmit(rootDir,
                                         progressStdErrEnabled,
                                         progressPath,
                                         progressText,
                                         "baseline",
                                         "error",
                                         int64(-1),
                                         SystemLinkExecNowNs() - totalStartNs)
            return Err[SystemLinkExecPlan](" compiler world: missing baseline surface path: " + baselinePath)
        let baselineText = chengpath.ReadTextFile("", baselinePath)
        var baselineSurface: ccsg.CsgExportSurface
        let baselineRes = ccsg.CompilerExportSurfaceFromReportText(baselineText, baselineSurface)
        if IsErr(baselineRes):
            SystemLinkExecProgressEmit(rootDir,
                                         progressStdErrEnabled,
                                         progressPath,
                                         progressText,
                                         "baseline",
                                         "error",
                                         int64(-1),
                                         SystemLinkExecNowNs() - totalStartNs)
            return Err[SystemLinkExecPlan](Error(baselineRes))
        if !ccsg.CompilerExportSurfaceCompatible(baselineSurface, exportSurface):
            SystemLinkExecProgressEmit(rootDir,
                                         progressStdErrEnabled,
                                         progressPath,
                                         progressText,
                                         "baseline",
                                         "error",
                                         int64(-1),
                                         SystemLinkExecNowNs() - totalStartNs)
            return Err[SystemLinkExecPlan](" compiler world: baseline export surface incompatible")
        baselineSurfaceCompatible = true
    phaseProfile.baselineNs = SystemLinkExecNowNs() - baselineStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "baseline",
                                 "done",
                                 phaseProfile.baselineNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    let loweringStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "lowering_plan",
                                 "begin",
                                 int64(-1),
                                 loweringStartNs - totalStartNs)
    var loweringPlan: lower.LoweringPlanStub
    if !lower.BuildLoweringPlanStubFromCompilerCsg(linkPlan, compilerCsg, loweringPlan, err):
        SystemLinkExecProgressEmit(rootDir,
                                     progressStdErrEnabled,
                                     progressPath,
                                     progressText,
                                     "lowering_plan",
                                     "error",
                                     int64(-1),
                                     SystemLinkExecNowNs() - totalStartNs)
        return Err[SystemLinkExecPlan](err)
    phaseProfile.loweringPlanNs = SystemLinkExecNowNs() - loweringStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "lowering_plan",
                                 "done",
                                 phaseProfile.loweringPlanNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    let primaryObjectStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "primary_object_plan",
                                 "begin",
                                 int64(-1),
                                 primaryObjectStartNs - totalStartNs)
    let primaryRes = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    if IsErr(primaryRes):
        SystemLinkExecProgressEmit(rootDir,
                                     progressStdErrEnabled,
                                     progressPath,
                                     progressText,
                                     "primary_object_plan",
                                     "error",
                                     int64(-1),
                                     SystemLinkExecNowNs() - totalStartNs)
        return Err[SystemLinkExecPlan](Error(primaryRes))
    phaseProfile.primaryObjectPlanNs = SystemLinkExecNowNs() - primaryObjectStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "primary_object_plan",
                                 "done",
                                 phaseProfile.primaryObjectPlanNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    let providerSourcesStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "provider_sources",
                                 "begin",
                                 int64(-1),
                                 providerSourcesStartNs - totalStartNs)
    let providerSourcesRes = ProviderSourcesForPlan(rootDir, linkPlan)
    if IsErr(providerSourcesRes):
        SystemLinkExecProgressEmit(rootDir,
                                     progressStdErrEnabled,
                                     progressPath,
                                     progressText,
                                     "provider_sources",
                                     "error",
                                     int64(-1),
                                     SystemLinkExecNowNs() - totalStartNs)
        return Err[SystemLinkExecPlan](Error(providerSourcesRes))
    phaseProfile.providerSourcesNs = SystemLinkExecNowNs() - providerSourcesStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "provider_sources",
                                 "done",
                                 phaseProfile.providerSourcesNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    var providerObjectPaths: str[]
    var linkInputs: str[]
    var objectMissing: str[]
    var nativeMissing: str[]
    var providerSourcePaths: str[]
    providerObjectPaths = []
    linkInputs = []
    objectMissing = []
    nativeMissing = []
    providerSourcePaths = []
    let primaryPlan = Value(primaryRes)
    providerSourcePaths = Value(providerSourcesRes)
    let primaryObjectPath = primaryPlan.outputPath
    let browserBridgeObjectPath = SystemLinkExecBrowserBridgeObjectPathForLinkPlan(linkPlan)
    if len(primaryObjectPath) > 0:
        add(linkInputs, primaryObjectPath)
    if len(browserBridgeObjectPath) > 0:
        add(linkInputs, browserBridgeObjectPath)
    var linuxNolibcSupportEnabled = false
    var linuxNolibcRuntimeSourcePath = ""
    var linuxNolibcRuntimeObjectPath = ""
    var linuxNolibcStartupSourcePath = ""
    var linuxNolibcStartupObjectPath = ""
    if linkPlan.emitKind == creq.EmitExe &&
       tmat.TargetUsesLinuxNolibcRuntime(linkPlan.targetTriple):
        linuxNolibcSupportEnabled = true
        linuxNolibcRuntimeSourcePath = chengpath.PathAbsolute(rootDir, "src/std/system_helpers_backend_nolibc_linux_aarch64.cheng")
        linuxNolibcRuntimeObjectPath = linkPlan.outputPath + ".runtime.system_helpers_backend_nolibc_linux_aarch64.o"
        linuxNolibcStartupSourcePath = chengpath.PathAbsolute(rootDir, "src/core/runtime/cheng_linux_nolibc_aarch64_entry.S")
        linuxNolibcStartupObjectPath = linkPlan.outputPath + ".startup.cheng_linux_nolibc_aarch64_entry.o"
        add(linkInputs, linuxNolibcStartupObjectPath)
        add(linkInputs, linuxNolibcRuntimeObjectPath)
    for i in 0..<linkPlan.providerModules.len:
        let providerModule = linkPlan.providerModules[i]
        var safe = ""
        for j in 0..<len(providerModule):
            let ch = providerModule[j]
            let digit = ch >= '0' && ch <= '9'
            let upper = ch >= 'A' && ch <= 'Z'
            let lower = ch >= 'a' && ch <= 'z'
            if digit || upper || lower:
                safe = safe + strings.SliceBytes(providerModule, j, 1)
            else:
                safe = safe + "_"
        let providerObjectPath = linkPlan.outputPath + ".provider." + safe + ".o"
        add(providerObjectPaths, providerObjectPath)
        add(linkInputs, providerObjectPath)
    if linkPlan.missingReasons.len > 0:
        add(objectMissing, "system_link_plan_not_ready_for_object_plan")
    if loweringPlan.missingReasons.len > 0:
        add(objectMissing, "lowering_plan_not_ready_for_object_plan")
    if primaryPlan.missingReasons.len > 0:
        add(objectMissing, "primary_object_not_ready_for_object_plan")
    if len(primaryObjectPath) <= 0:
        add(objectMissing, "primary_object_path_missing")
    if loweringPlan.functionSymbolTexts.len <= 0:
        add(objectMissing, "primary_object_functions_missing")
    if linkPlan.providerModules.len > 0 && providerObjectPaths.len != linkPlan.providerModules.len:
        add(objectMissing, "provider_object_paths_incomplete")
    if linkPlan.providerModules.len > 0 && providerSourcePaths.len != linkPlan.providerModules.len:
        add(objectMissing, "provider_source_paths_incomplete")
    if linuxNolibcSupportEnabled:
        if len(linuxNolibcRuntimeSourcePath) <= 0 || !chengpath.PathFileExists(linuxNolibcRuntimeSourcePath):
            add(objectMissing, "linux_nolibc_runtime_source_missing")
        if len(linuxNolibcStartupSourcePath) <= 0 || !chengpath.PathFileExists(linuxNolibcStartupSourcePath):
            add(objectMissing, "linux_nolibc_startup_source_missing")
        if len(linuxNolibcRuntimeObjectPath) <= 0:
            add(objectMissing, "linux_nolibc_runtime_object_path_missing")
        if len(linuxNolibcStartupObjectPath) <= 0:
            add(objectMissing, "linux_nolibc_startup_object_path_missing")
    let objectPlanStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "object_plan",
                                 "begin",
                                 int64(-1),
                                 objectPlanStartNs - totalStartNs)
    var objectPlan: objplan.ObjectPlanStub
    objectPlan.workspaceRoot = linkPlan.workspaceRoot
    objectPlan.packageRoot = linkPlan.packageRoot
    objectPlan.packageId = linkPlan.packageId
    objectPlan.entryPath = linkPlan.entryPath
    objectPlan.outputPath = linkPlan.outputPath
    objectPlan.targetTriple = linkPlan.targetTriple
    objectPlan.primaryObjectPath = primaryObjectPath
    objectPlan.browserBridgeObjectPath = browserBridgeObjectPath
    objectPlan.linuxNolibcSupportEnabled = linuxNolibcSupportEnabled
    objectPlan.linuxNolibcRuntimeSourcePath = linuxNolibcRuntimeSourcePath
    objectPlan.linuxNolibcRuntimeObjectPath = linuxNolibcRuntimeObjectPath
    objectPlan.linuxNolibcStartupSourcePath = linuxNolibcStartupSourcePath
    objectPlan.linuxNolibcStartupObjectPath = linuxNolibcStartupObjectPath
    objectPlan.providerModules = linkPlan.providerModules
    objectPlan.providerSourcePaths = providerSourcePaths
    objectPlan.providerObjectPaths = providerObjectPaths
    objectPlan.linkInputPaths = linkInputs
    objectPlan.loweredFunctionSymbols = loweringPlan.functionSymbolTexts
    objectPlan.entrySymbol = linkPlan.entrySymbol
    objectPlan.missingReasons = objectMissing
    objectPlan.pipelineStage = "lowering_plan_to_object_plan"
    phaseProfile.objectPlanNs = SystemLinkExecNowNs() - objectPlanStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "object_plan",
                                 "done",
                                 phaseProfile.objectPlanNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    if linkPlan.missingReasons.len > 0:
        add(nativeMissing, "system_link_plan_not_ready_for_native_link")
    if objectPlan.missingReasons.len > 0:
        add(nativeMissing, "object_plan_not_ready_for_native_link")
    if objectPlan.linkInputPaths.len <= 0:
        add(nativeMissing, "native_link_inputs_missing")
    if len(linkPlan.outputPath) <= 0:
        add(nativeMissing, "native_link_output_missing")
    if linkPlan.emitKind == creq.EmitExe && len(linkPlan.entrySymbol) <= 0:
        add(nativeMissing, "native_link_entry_symbol_missing")
    let linkerFlavor = tmat.TargetLinkerFlavor(linkPlan.targetTriple)
    let linkerProgram = tmat.TargetLinkerProgram(linkPlan.targetTriple)
    var outputKind = nplan.NativeOutputArtifact
    if linkPlan.emitKind == creq.EmitExe:
        outputKind = nplan.NativeOutputExecutable
    let nativeLinkStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "native_link_plan",
                                 "begin",
                                 int64(-1),
                                 nativeLinkStartNs - totalStartNs)
    var nativePlan: nplan.NativeLinkPlanStub
    nativePlan.targetTriple = linkPlan.targetTriple
    nativePlan.emitKind = linkPlan.emitKind
    nativePlan.outputPath = linkPlan.outputPath
    nativePlan.linkerProgram = linkerProgram
    nativePlan.linkerFlavor = linkerFlavor
    nativePlan.outputKind = outputKind
    nativePlan.entrySymbol = linkPlan.entrySymbol
    nativePlan.primaryObjectPath = objectPlan.primaryObjectPath
    nativePlan.browserBridgeObjectPath = objectPlan.browserBridgeObjectPath
    nativePlan.linkInputPaths = objectPlan.linkInputPaths
    nativePlan.missingReasons = nativeMissing
    nativePlan.pipelineStage = "object_plan_to_native_link_plan"
    phaseProfile.nativeLinkPlanNs = SystemLinkExecNowNs() - nativeLinkStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "native_link_plan",
                                 "done",
                                 phaseProfile.nativeLinkPlanNs,
                                 SystemLinkExecNowNs() - totalStartNs)
    let compileReceiptStartNs: int64 = SystemLinkExecNowNs()
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "compile_receipt",
                                 "begin",
                                 int64(-1),
                                 compileReceiptStartNs - totalStartNs)
    let outputDigest = ccsg.CompileOutputDigest(linkPlan.outputPath,
                                                  linkPlan.targetTriple,
                                                  linkPlan.providerModules,
                                                  compilerCsg.graphCid)
    let canonicalOutputDigest = ccsg.CompileOutputDigest(linkPlan.outputPath,
                                                           linkPlan.targetTriple,
                                                           linkPlan.providerModules,
                                                           compilerCsg.canonicalGraphCid)
    let compileReceipt = ccsg.CompileReceiptMake(localUniverse.worldHead.headCid,
                                                   compilerCsg.graphCid,
                                                   compilerCsg.canonicalGraphCid,
                                                   linkPlan.targetTriple,
                                                   outputDigest,
                                                   canonicalOutputDigest,
                                                   "stage3_local",
                                                   linkPlan.providerModules)
    phaseProfile.compileReceiptNs = SystemLinkExecNowNs() - compileReceiptStartNs
    phaseProfile.totalNs = SystemLinkExecNowNs() - totalStartNs
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "compile_receipt",
                                 "done",
                                 phaseProfile.compileReceiptNs,
                                 phaseProfile.totalNs)
    SystemLinkExecProgressEmit(rootDir,
                                 progressStdErrEnabled,
                                 progressPath,
                                 progressText,
                                 "plan_build",
                                 "done",
                                 phaseProfile.totalNs,
                                 phaseProfile.totalNs)
    var execPlan: SystemLinkExecPlan
    execPlan.compilerEntrySource = linkPlan.buildEntryPath
    execPlan.sourceBundleCid = sourceBundleCid
    execPlan.systemLinkPlan = linkPlan
    execPlan.compilerCsg = compilerCsg
    execPlan.exportSurface = exportSurface
    execPlan.localUniverse = localUniverse
    execPlan.compileReceipt = compileReceipt
    execPlan.worldHeadPinned = worldHeadPinned
    execPlan.lockCheckEnabled = lockCheckEnabled
    execPlan.lockVerified = lockVerified
    execPlan.baselineSurfaceChecked = baselineSurfaceChecked
    execPlan.baselineSurfaceCompatible = baselineSurfaceCompatible
    execPlan.lockPath = lockPath
    execPlan.baselineSurfacePath = baselineSurfacePath
    execPlan.phaseProfile = phaseProfile
    execPlan.loweringPlan = loweringPlan
    execPlan.primaryObjectPlan = primaryPlan
    execPlan.objectPlan = objectPlan
    execPlan.nativeLinkPlan = nativePlan
    return Ok[SystemLinkExecPlan](execPlan)

fn BuildSystemLinkExecPlanWithWorld(rootDir: str,
                                      req: creq.CompilerRequest,
                                      requestedWorldHead: str,
                                      lockPath: str,
                                      baselineSurfacePath: str): Result[SystemLinkExecPlan] =
    return BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                        req,
                                                        requestedWorldHead,
                                                        lockPath,
                                                        baselineSurfacePath,
                                                        cworld.CompilerWorldDefaultChannel())

fn BuildSystemLinkExecPlan(rootDir: str,
                             req: creq.CompilerRequest): Result[SystemLinkExecPlan] =
    return BuildSystemLinkExecPlanWithWorld(rootDir,
                                              req,
                                              "",
                                              "",
                                              "")

fn BuildSystemLinkExecReportWithWorld(rootDir: str,
                                        req: creq.CompilerRequest,
                                        requestedWorldHead: str,
                                        lockPath: str,
                                        baselineSurfacePath: str): Result[str] =
    let planRes = BuildSystemLinkExecPlanWithWorld(rootDir,
                                                     req,
                                                     requestedWorldHead,
                                                     lockPath,
                                                     baselineSurfacePath)
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](SystemLinkExecPlanReport(Value(planRes)))

fn BuildSystemLinkExecReport(rootDir: str,
                               req: creq.CompilerRequest): Result[str] =
    return BuildSystemLinkExecReportWithWorld(rootDir, req, "", "", "")

fn SystemLinkExecPlanReady(plan: SystemLinkExecPlan): bool =
    return plan.systemLinkPlan.missingReasons.len <= 0 &&
           plan.loweringPlan.missingReasons.len <= 0 &&
           plan.primaryObjectPlan.missingReasons.len <= 0 &&
           plan.objectPlan.missingReasons.len <= 0 &&
           plan.nativeLinkPlan.missingReasons.len <= 0

fn SystemLinkExecBrowserBridgeReport(plan: SystemLinkExecPlan): str =
    let bridgePlans = ccsg.CompilerBrowserAbiBridgePlansForLinkPlan(plan.systemLinkPlan)
    let bridgeArtifactPath = SystemLinkExecBrowserBridgeArtifactPath(plan)
    let bridgeSourcePath = SystemLinkExecBrowserBridgeSourcePath(plan)
    let bridgeObjectPath = SystemLinkExecBrowserBridgeObjectPath(plan)
    var bridgeArtifactPathText = "-"
    var bridgeSourcePathText = "-"
    var bridgeObjectPathText = "-"
    var bridgeObjectCount: int32
    if len(bridgeArtifactPath) > 0:
        bridgeArtifactPathText = bridgeArtifactPath
    if len(bridgeSourcePath) > 0:
        bridgeSourcePathText = bridgeSourcePath
    if len(bridgeObjectPath) > 0:
        bridgeObjectPathText = bridgeObjectPath
        bridgeObjectCount = 1
    var lines = ""
    for i in 0..<bridgePlans.len:
        lines = lines + "browser_bridge_plan["
        lines = lines + intToStr(i)
        lines = lines + "]="
        lines = lines + bridgePlans[i].emitLine
        lines = lines + "\n"
    var out = ""
    out = out + "browser_bridge_artifact_path=" + bridgeArtifactPathText + "\n"
    out = out + "browser_bridge_artifact_format=" + barule.BrowserAbiBridgePlanManifestFormat() + "\n"
    out = out + "browser_bridge_artifact_count=" + intToStr(bridgePlans.len) + "\n"
    out = out + "browser_bridge_artifact_unique_key_count=" + intToStr(barule.BrowserAbiBridgePlanUniqueKeyCount(bridgePlans)) + "\n"
    out = out + "browser_bridge_source_path=" + bridgeSourcePathText + "\n"
    out = out + "browser_bridge_source_format=" + barule.BrowserAbiBridgeSourceFormat() + "\n"
    out = out + "browser_bridge_source_count=" + intToStr(bridgePlans.len) + "\n"
    out = out + "browser_bridge_object_path=" + bridgeObjectPathText + "\n"
    out = out + "browser_bridge_object_count=" + intToStr(bridgeObjectCount) + "\n"
    out = out + "browser_bridge_plan_count=" + intToStr(bridgePlans.len) + "\n"
    out = out + "browser_bridge_plan_unique_key_count=" + intToStr(barule.BrowserAbiBridgePlanUniqueKeyCount(bridgePlans)) + "\n"
    out = out + lines
    return out

fn SystemLinkExecPlanReport(plan: SystemLinkExecPlan): str =
    var worldHeadPinned = "0"
    var lockCheckEnabled = "0"
    var lockVerified = "0"
    var baselineSurfaceChecked = "0"
    var baselineSurfaceCompatible = "0"
    var lockPath = "-"
    var baselineSurfacePath = "-"
    var primaryObjectPath = "-"
    var nativeOutputKind = "artifact"
    var nativePrimaryObject = "-"
    var browserBridgeObject = "-"
    var nativeEntrySymbol = "-"
    if plan.worldHeadPinned:
        worldHeadPinned = "1"
    if plan.lockCheckEnabled:
        lockCheckEnabled = "1"
    if plan.lockVerified:
        lockVerified = "1"
    if plan.baselineSurfaceChecked:
        baselineSurfaceChecked = "1"
    if plan.baselineSurfaceCompatible:
        baselineSurfaceCompatible = "1"
    if len(plan.lockPath) > 0:
        lockPath = plan.lockPath
    if len(plan.baselineSurfacePath) > 0:
        baselineSurfacePath = plan.baselineSurfacePath
    if len(plan.objectPlan.primaryObjectPath) > 0:
        primaryObjectPath = plan.objectPlan.primaryObjectPath
    if plan.nativeLinkPlan.outputKind == nplan.NativeOutputExecutable:
        nativeOutputKind = "executable"
    if len(plan.nativeLinkPlan.primaryObjectPath) > 0:
        nativePrimaryObject = plan.nativeLinkPlan.primaryObjectPath
    if len(plan.nativeLinkPlan.browserBridgeObjectPath) > 0:
        browserBridgeObject = plan.nativeLinkPlan.browserBridgeObjectPath
    if len(plan.nativeLinkPlan.entrySymbol) > 0:
        nativeEntrySymbol = plan.nativeLinkPlan.entrySymbol
    var linuxNolibcSupportEnabled = "0"
    var linuxNolibcRuntimeSource = "-"
    var linuxNolibcRuntimeObject = "-"
    var linuxNolibcStartupSource = "-"
    var linuxNolibcStartupObject = "-"
    if plan.objectPlan.linuxNolibcSupportEnabled:
        linuxNolibcSupportEnabled = "1"
    if len(plan.objectPlan.linuxNolibcRuntimeSourcePath) > 0:
        linuxNolibcRuntimeSource = plan.objectPlan.linuxNolibcRuntimeSourcePath
    if len(plan.objectPlan.linuxNolibcRuntimeObjectPath) > 0:
        linuxNolibcRuntimeObject = plan.objectPlan.linuxNolibcRuntimeObjectPath
    if len(plan.objectPlan.linuxNolibcStartupSourcePath) > 0:
        linuxNolibcStartupSource = plan.objectPlan.linuxNolibcStartupSourcePath
    if len(plan.objectPlan.linuxNolibcStartupObjectPath) > 0:
        linuxNolibcStartupObject = plan.objectPlan.linuxNolibcStartupObjectPath
    let browserBridgeReport = SystemLinkExecBrowserBridgeReport(plan)
    var out = ""
    out = out + "entry=" + plan.compilerEntrySource + "\n"
    out = out + "source_bundle_cid=" + layout.fixedBytes32Hex(plan.sourceBundleCid) + "\n"
    out = out + "canonical_compiler_csg_cid=" + layout.fixedBytes32Hex(plan.compilerCsg.canonicalGraphCid) + "\n"
    out = out + "compiler_csg_cid=" + layout.fixedBytes32Hex(plan.compilerCsg.graphCid) + "\n"
    out = out + "compiler_csg_node_count=" + intToStr(plan.compilerCsg.nodeCount) + "\n"
    out = out + "compiler_csg_edge_count=" + intToStr(plan.compilerCsg.edgeCount) + "\n"
    out = out + "export_surface_cid=" + layout.fixedBytes32Hex(plan.exportSurface.surfaceCid) + "\n"
    out = out + "export_surface_symbol_count=" + intToStr(plan.exportSurface.exportedSymbolCount) + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(plan.localUniverse.worldHead.headCid) + "\n"
    out = out + "compiler_pkg_cid=" + layout.fixedBytes32Hex(plan.localUniverse.compilerSnapshot.snapshotCid) + "\n"
    out = out + "std_pkg_cid=" + layout.fixedBytes32Hex(plan.localUniverse.stdSnapshot.snapshotCid) + "\n"
    out = out + "runtime_pkg_cid=" + layout.fixedBytes32Hex(plan.localUniverse.runtimeSnapshot.snapshotCid) + "\n"
    out = out + "world_head_pinned=" + worldHeadPinned + "\n"
    out = out + "lock_check_enabled=" + lockCheckEnabled + "\n"
    out = out + "lock_verified=" + lockVerified + "\n"
    out = out + "lock_path=" + lockPath + "\n"
    out = out + "baseline_surface_checked=" + baselineSurfaceChecked + "\n"
    out = out + "baseline_surface_compatible=" + baselineSurfaceCompatible + "\n"
    out = out + "baseline_surface_path=" + baselineSurfacePath + "\n"
    out = out + "compile_receipt_cid=" + layout.fixedBytes32Hex(plan.compileReceipt.receiptCid) + "\n"
    out = out + "compile_canonical_output_digest=" + layout.fixedBytes32Hex(plan.compileReceipt.canonicalOutputDigest) + "\n"
    out = out + "compile_output_digest=" + layout.fixedBytes32Hex(plan.compileReceipt.outputDigest) + "\n"
    out = out + "compile_bootstrap_stage=" + plan.compileReceipt.bootstrapStage + "\n"
    out = out + "exec_phase_system_link_plan_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.systemLinkPlanNs) + "\n"
    out = out + "exec_phase_source_bundle_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.sourceBundleNs) + "\n"
    out = out + "exec_phase_compiler_csg_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.compilerCsgNs) + "\n"
    out = out + "exec_phase_world_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.worldNs) + "\n"
    out = out + "exec_phase_lock_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.lockNs) + "\n"
    out = out + "exec_phase_baseline_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.baselineNs) + "\n"
    out = out + "exec_phase_lowering_plan_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.loweringPlanNs) + "\n"
    out = out + "exec_phase_primary_object_plan_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.primaryObjectPlanNs) + "\n"
    out = out + "exec_phase_provider_sources_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.providerSourcesNs) + "\n"
    out = out + "exec_phase_object_plan_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.objectPlanNs) + "\n"
    out = out + "exec_phase_native_link_plan_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.nativeLinkPlanNs) + "\n"
    out = out + "exec_phase_compile_receipt_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.compileReceiptNs) + "\n"
    out = out + "exec_phase_total_ms=" + SystemLinkExecPhaseMsText(plan.phaseProfile.totalNs) + "\n"
    out = out + slplan.SystemLinkPlanStubReport(plan.systemLinkPlan) + "\n"
    out = out + lower.LoweringPlanStubReport(plan.loweringPlan) + "\n"
    out = out + browserBridgeReport
    out = out + pobj.PrimaryObjectPlanReport(plan.primaryObjectPlan) + "\n"
    out = out + "primary_object_path=" + primaryObjectPath + "\n"
    out = out + "provider_object_count=" + intToStr(plan.objectPlan.providerObjectPaths.len) + "\n"
    out = out + "provider_source_paths=" + slplan.SystemLinkPlanListText(plan.objectPlan.providerSourcePaths) + "\n"
    out = out + "provider_object_paths=" + slplan.SystemLinkPlanListText(plan.objectPlan.providerObjectPaths) + "\n"
    out = out + "linux_nolibc_support_enabled=" + linuxNolibcSupportEnabled + "\n"
    out = out + "linux_nolibc_runtime_source=" + linuxNolibcRuntimeSource + "\n"
    out = out + "linux_nolibc_runtime_object=" + linuxNolibcRuntimeObject + "\n"
    out = out + "linux_nolibc_startup_source=" + linuxNolibcStartupSource + "\n"
    out = out + "linux_nolibc_startup_object=" + linuxNolibcStartupObject + "\n"
    out = out + "browser_bridge_object=" + browserBridgeObject + "\n"
    out = out + "object_link_input_count=" + intToStr(plan.objectPlan.linkInputPaths.len) + "\n"
    out = out + "object_link_inputs=" + slplan.SystemLinkPlanListText(plan.objectPlan.linkInputPaths) + "\n"
    out = out + "object_missing_reasons=" + slplan.SystemLinkPlanListText(plan.objectPlan.missingReasons) + "\n"
    out = out + "object_pipeline_stage=" + plan.objectPlan.pipelineStage + "\n"
    out = out + "native_linker_program=" + plan.nativeLinkPlan.linkerProgram + "\n"
    out = out + "native_linker_flavor=" + plan.nativeLinkPlan.linkerFlavor + "\n"
    out = out + "native_output_kind=" + nativeOutputKind + "\n"
    out = out + "native_primary_object=" + nativePrimaryObject + "\n"
    out = out + "native_link_input_count=" + intToStr(plan.nativeLinkPlan.linkInputPaths.len) + "\n"
    out = out + "native_link_inputs=" + slplan.SystemLinkPlanListText(plan.nativeLinkPlan.linkInputPaths) + "\n"
    out = out + "native_link_entry_symbol=" + nativeEntrySymbol + "\n"
    out = out + "native_link_missing_reasons=" + slplan.SystemLinkPlanListText(plan.nativeLinkPlan.missingReasons) + "\n"
    out = out + "native_link_pipeline_stage=" + plan.nativeLinkPlan.pipelineStage + "\n"
    out = out + "exec_pipeline_stage=primary_object_plan_to_native_link_plan"
    return out
