import std/result
import std/strformat
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj
import cheng/core/backend/system_link_plan as slplan
import std/strutils as strutil

fn LineMapPathForOutput(outputPath: str): str =
    if len(outputPath) <= 0:
        return ""
    return strutil.Join([outputPath, ".map"], "")

fn LineMapFindEntryFunctionIndex(lowering: lower.LoweringPlanStub): int32 =
    for i in 0..<lowering.functionEntryFlags.len:
        if lowering.functionEntryFlags[i] != 0:
            return i
    return -1

fn LineMapLoweredFunctionEntryText(linkPlan: slplan.SystemLinkPlanStub,
                                     lowering: lower.LoweringPlanStub,
                                     index: int32): str =
    return strutil.Join(["entry\t",
                pobj.PrimarySymbolNameForFunction(linkPlan.targetTriple,
                                                  lowering.functionSymbolTexts[index],
                                                  lowering.primaryObjectIr.functions[index].signatureLineNumber,
                                                  linkPlan.emitKind),
                "\t", lowering.functionNames[index],
                "\t", lowering.functionSourcePaths[index],
                "\t", intToStr(lowering.primaryObjectIr.functions[index].signatureLineNumber),
                "\t", intToStr(lowering.primaryObjectIr.functions[index].bodyLineNumber),
                "\t", intToStr(lowering.primaryObjectIr.functions[index].bodyLineNumber)], "")

fn LineMapRuntimeBridgeEntryText(linkPlan: slplan.SystemLinkPlanStub,
                                   lowering: lower.LoweringPlanStub,
                                   entryIndex: int32): str =
    return strutil.Join(["entry\t", pobj.PrimaryRuntimeEntryBridgeSymbol(linkPlan),
                "\t", lowering.functionNames[entryIndex],
                "\t", lowering.functionSourcePaths[entryIndex],
                "\t", intToStr(lowering.primaryObjectIr.functions[entryIndex].signatureLineNumber),
                "\t", intToStr(lowering.primaryObjectIr.functions[entryIndex].bodyLineNumber),
                "\t", intToStr(lowering.primaryObjectIr.functions[entryIndex].bodyLineNumber)], "")

fn LineMapText(linkPlan: slplan.SystemLinkPlanStub,
                 lowering: lower.LoweringPlanStub): str =
    let entryIndex = LineMapFindEntryFunctionIndex(lowering)
    var entryCount = lowering.functionNames.len
    if entryIndex >= 0:
        entryCount = entryCount + 1
    var out = Lines(["cheng_line_map_v1",
                     strutil.Join(["entry_count=", intToStr(entryCount)], "")])
    out = strutil.Join([out, "\n"], "")
    for i in 0..<lowering.functionNames.len:
        out = strutil.Join([out,
                   LineMapLoweredFunctionEntryText(linkPlan,
                                                   lowering,
                                                   i),
                   "\n"], "")
    if entryIndex >= 0:
        out = strutil.Join([out,
                   LineMapRuntimeBridgeEntryText(linkPlan,
                                                lowering,
                                                entryIndex),
                   "\n"], "")
    return out

fn WriteExecutableLineMap(rootDir: str,
                            linkPlan: slplan.SystemLinkPlanStub,
                            lowering: lower.LoweringPlanStub): Result[str] =
    if linkPlan.emitKind != creq.EmitExe:
        return Ok[str]("")
    let path = LineMapPathForOutput(linkPlan.outputPath)
    if len(path) <= 0:
        return Ok[str]("")
    let text = LineMapText(linkPlan, lowering)
    if !chengpath.WriteTextFile(rootDir, path, text):
        return Err[str](strutil.Join([" compiler: failed to write line-map: ", path], ""))
    return Ok[str](path)
