import std/result
import std/strformat
import cheng/std/bytes_layout as layout
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser as parser
import cheng/core/backend/target_matrix as tmat

type
    SystemModuleKind = enum
        SystemOrdinaryProgram
        SystemCompilerControlPlane

    SystemLinkPlanStub =
        entryPath: str
        outputPath: str
        targetTriple: str
        emitKind: creq.CompilerEmit
        symbolVisibility: str
        browserBridgeObjectPath: str
        exportRootSymbols: str[]
        packageRoot: str
        externalPackageRoots: parser.ParserExternalPackageRoot[]
        workspaceRoot: str
        packageId: str
        moduleStem: str
        moduleKind: SystemModuleKind
        sourceBundleCid: Result[layout.FixedBytes32]
        sourceBundleCidValue: layout.FixedBytes32
        sourceClosurePaths: str[]
        ownerModulePaths: str[]
        importEdges: parser.ImportEdge[]
        importEdgeCount: int32
        unresolvedImportCount: int32
        exprLayer: parser.NormalizedExprLayer
        hasCompilerTopLevel: bool
        mainFunctionPresent: bool
        runtimeTargets: str[]
        providerModules: str[]
        entrySymbol: str
        missingReasons: str[]
        parserSyntaxTag: str
        parserSourceKind: int32
        buildEntryPath: str
        buildSourceUnitCount: int32
        linkMode: str
        pipelineStage: str
        jobCount: int32

fn SystemModuleKindText(kind: SystemModuleKind): str =
    if kind == SystemCompilerControlPlane:
        return "compiler_control_plane"
    return "ordinary_program"

fn SystemLinkPlanListText(items: str[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if Len(out) > 0:
            out = Fmt"{out},"
        out = Fmt"{out}{items[i]}"
    return out

fn SystemLinkPlanAppendLine(out: var str, key: str, value: str) =
    if Len(out) > 0:
        out = Fmt"{out}\n"
    out = Fmt"{out}{key}={value}"

fn SystemLinkPlanWorkspaceRoot(plan: SystemLinkPlanStub): str =
    return plan.workspaceRoot

fn SystemLinkPlanPackageRoot(plan: SystemLinkPlanStub): str =
    return plan.packageRoot

fn SystemLinkPlanExternalPackageRoots(plan: SystemLinkPlanStub): parser.ParserExternalPackageRoot[] =
    return parser.ParserExternalPackageRootsClone(plan.externalPackageRoots)

fn SystemLinkPlanPackageId(plan: SystemLinkPlanStub): str =
    return plan.packageId

fn SystemLinkPlanEntryPath(plan: SystemLinkPlanStub): str =
    return plan.entryPath

fn SystemLinkPlanOutputPath(plan: SystemLinkPlanStub): str =
    return plan.outputPath

fn SystemLinkPlanTargetTriple(plan: SystemLinkPlanStub): str =
    return plan.targetTriple

fn SystemLinkPlanEmitKind(plan: SystemLinkPlanStub): creq.CompilerEmit =
    return plan.emitKind

fn SystemLinkPlanSymbolVisibility(plan: SystemLinkPlanStub): str =
    return plan.symbolVisibility

fn SystemLinkPlanBrowserBridgeObjectPath(plan: SystemLinkPlanStub): str =
    return plan.browserBridgeObjectPath

fn SystemLinkPlanModuleStem(plan: SystemLinkPlanStub): str =
    return plan.moduleStem

fn SystemLinkPlanModuleKind(plan: SystemLinkPlanStub): SystemModuleKind =
    return plan.moduleKind

fn SystemLinkPlanOwnerModulePaths(plan: SystemLinkPlanStub): str[] =
    return plan.ownerModulePaths

fn SystemLinkPlanImportEdges(plan: SystemLinkPlanStub): parser.ImportEdge[] =
    return plan.importEdges

fn SystemLinkPlanImportEdgeCount(plan: SystemLinkPlanStub): int32 =
    return plan.importEdgeCount

fn SystemLinkPlanUnresolvedImportCount(plan: SystemLinkPlanStub): int32 =
    return plan.unresolvedImportCount

fn SystemLinkPlanExprLayer(plan: SystemLinkPlanStub): parser.NormalizedExprLayer =
    return plan.exprLayer

fn SystemLinkPlanHasCompilerTopLevel(plan: SystemLinkPlanStub): bool =
    return plan.hasCompilerTopLevel

fn SystemLinkPlanMainFunctionPresent(plan: SystemLinkPlanStub): bool =
    return plan.mainFunctionPresent

fn SystemLinkPlanRuntimeTargets(plan: SystemLinkPlanStub): str[] =
    return plan.runtimeTargets

fn SystemLinkPlanProviderModules(plan: SystemLinkPlanStub): str[] =
    return plan.providerModules

fn SystemLinkPlanEntrySymbol(plan: SystemLinkPlanStub): str =
    return plan.entrySymbol

fn SystemLinkPlanSourceClosurePaths(plan: SystemLinkPlanStub): str[] =
    return plan.sourceClosurePaths

fn SystemLinkPlanExportRootSymbols(plan: SystemLinkPlanStub): str[] =
    return plan.exportRootSymbols

fn SystemLinkPlanSourceBundleCid(plan: SystemLinkPlanStub): Result[layout.FixedBytes32] =
    return plan.sourceBundleCid

