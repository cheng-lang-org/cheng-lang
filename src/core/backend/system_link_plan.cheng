import std/result
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_runtime as crun
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser as parser
import cheng/core/backend/build_plan as buildplan
import cheng/core/backend/target_matrix as tmat

type
    SystemModuleKind = enum
        SystemOrdinaryProgram
        SystemCompilerControlPlane

    SystemLinkPlanStub =
        entryPath: str
        outputPath: str
        targetTriple: str
        emitKind: creq.CompilerEmit
        symbolVisibility: str
        browserBridgeObjectPath: str
        packageRoot: str
        externalPackageRoots: parser.ParserExternalPackageRoot[]
        workspaceRoot: str
        packageId: str
        moduleStem: str
        moduleKind: SystemModuleKind
        sourceClosurePaths: str[]
        ownerModulePaths: str[]
        importEdges: parser.ImportEdge[]
        importEdgeCount: int32
        unresolvedImportCount: int32
        exprLayer: parser.NormalizedExprLayer
        hasCompilerTopLevel: bool
        mainFunctionPresent: bool
        runtimeTargets: str[]
        providerModules: str[]
        entrySymbol: str
        missingReasons: str[]
        parserSyntaxTag: str
        parserSourceKind: int32
        buildEntryPath: str
        buildSourceUnitCount: int32
        linkMode: str
        pipelineStage: str

fn SystemModuleKindText(kind: SystemModuleKind): str =
    if kind == SystemCompilerControlPlane:
        return "compiler_control_plane"
    return "ordinary_program"

fn SystemLinkPlanListText(items: str[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if len(out) > 0:
            out = strutil.Join([out, ","], "")
        out = strutil.Join([out, items[i]], "")
    return out

fn SystemLinkPlanAppendLine(out: var str, key: str, value: str) =
    if len(out) > 0:
        out = strutil.Join([out, "\n"], "")
    out = strutil.Join([out, key, "=", value], "")

fn SystemLinkPlanDeriveModuleKind(parsed: parser.ParsedSourceStub): SystemModuleKind =
    for i in 0..<parsed.ownerModulePaths.len:
        if parsed.ownerModulePaths[i] == "cheng/core/tooling/compiler_main":
            return SystemCompilerControlPlane
    return SystemOrdinaryProgram

fn SystemLinkPlanDeriveEntrySymbol(parsed: parser.ParsedSourceStub, emitKind: creq.CompilerEmit): str =
    if emitKind == creq.EmitExe && parsed.mainFunctionPresent:
        return "main"
    return ""

fn SystemLinkPlanDeriveExecutionTrack(moduleKind: SystemModuleKind): crun.CompilerExecutionTrack =
    if moduleKind == SystemCompilerControlPlane:
        return crun.CompilerTrackTooling
    return crun.CompilerTrackProgram

fn SystemLinkPlanWorkspaceRoot(plan: SystemLinkPlanStub): str =
    return plan.workspaceRoot

fn SystemLinkPlanPackageRoot(plan: SystemLinkPlanStub): str =
    return plan.packageRoot

fn SystemLinkPlanExternalPackageRoots(plan: SystemLinkPlanStub): parser.ParserExternalPackageRoot[] =
    return parser.ParserExternalPackageRootsClone(plan.externalPackageRoots)

fn SystemLinkPlanPackageId(plan: SystemLinkPlanStub): str =
    return plan.packageId

fn SystemLinkPlanEntryPath(plan: SystemLinkPlanStub): str =
    return plan.entryPath

fn SystemLinkPlanOutputPath(plan: SystemLinkPlanStub): str =
    return plan.outputPath

fn SystemLinkPlanTargetTriple(plan: SystemLinkPlanStub): str =
    return plan.targetTriple

fn SystemLinkPlanEmitKind(plan: SystemLinkPlanStub): creq.CompilerEmit =
    return plan.emitKind

fn SystemLinkPlanSymbolVisibility(plan: SystemLinkPlanStub): str =
    return plan.symbolVisibility

fn SystemLinkPlanBrowserBridgeObjectPath(plan: SystemLinkPlanStub): str =
    return plan.browserBridgeObjectPath

fn SystemLinkPlanModuleStem(plan: SystemLinkPlanStub): str =
    return plan.moduleStem

fn SystemLinkPlanModuleKind(plan: SystemLinkPlanStub): SystemModuleKind =
    return plan.moduleKind

fn SystemLinkPlanOwnerModulePaths(plan: SystemLinkPlanStub): str[] =
    return plan.ownerModulePaths

fn SystemLinkPlanImportEdges(plan: SystemLinkPlanStub): parser.ImportEdge[] =
    return plan.importEdges

fn SystemLinkPlanImportEdgeCount(plan: SystemLinkPlanStub): int32 =
    return plan.importEdgeCount

fn SystemLinkPlanUnresolvedImportCount(plan: SystemLinkPlanStub): int32 =
    return plan.unresolvedImportCount

fn SystemLinkPlanExprLayer(plan: SystemLinkPlanStub): parser.NormalizedExprLayer =
    return plan.exprLayer

fn SystemLinkPlanHasCompilerTopLevel(plan: SystemLinkPlanStub): bool =
    return plan.hasCompilerTopLevel

fn SystemLinkPlanMainFunctionPresent(plan: SystemLinkPlanStub): bool =
    return plan.mainFunctionPresent

fn SystemLinkPlanRuntimeTargets(plan: SystemLinkPlanStub): str[] =
    return plan.runtimeTargets

fn SystemLinkPlanProviderModules(plan: SystemLinkPlanStub): str[] =
    return plan.providerModules

fn SystemLinkPlanEntrySymbol(plan: SystemLinkPlanStub): str =
    return plan.entrySymbol

fn SystemLinkPlanSourceClosurePaths(plan: SystemLinkPlanStub): str[] =
    return plan.sourceClosurePaths

fn SystemLinkPlanSourceBundleCid(plan: SystemLinkPlanStub): Result[layout.FixedBytes32] =
    return cworld.CompilerWorldSourceBundleCidWithExternalPackageRoots(plan.packageId,
                                                                         plan.workspaceRoot,
                                                                         plan.packageRoot,
                                                                         plan.externalPackageRoots,
                                                                         plan.sourceClosurePaths)

fn SystemLinkPlanMissingReasonsField(plan: SystemLinkPlanStub): str[] =
    return plan.missingReasons

fn SystemLinkPlanParserSyntaxTag(plan: SystemLinkPlanStub): str =
    return plan.parserSyntaxTag

fn SystemLinkPlanParserSourceKind(plan: SystemLinkPlanStub): int32 =
    return plan.parserSourceKind

fn SystemLinkPlanBuildEntryPath(plan: SystemLinkPlanStub): str =
    return plan.buildEntryPath

fn SystemLinkPlanBuildSourceUnitCount(plan: SystemLinkPlanStub): int32 =
    return plan.buildSourceUnitCount

fn SystemLinkPlanLinkMode(plan: SystemLinkPlanStub): str =
    return plan.linkMode

fn SystemLinkPlanPipelineStage(plan: SystemLinkPlanStub): str =
    return plan.pipelineStage

fn SystemLinkPlanMissingReasons(parsed: parser.ParsedSourceStub,
                                  emitKind: creq.CompilerEmit,
                                  targetTriple: str,
                                  runtimeTargets: str[],
                                  providerModules: str[],
                                  entrySymbol: str): str[] =
    var missing: str[]
    if parsed.orderedClosureSourcePaths.len <= 0:
        add(missing, "source_closure_missing")
    if parsed.unresolvedImportCount > 0:
        add(missing, "source_closure_unresolved_imports")
    if !parsed.hasCompilerTopLevel:
        add(missing, "compiler_top_level_missing")
    if emitKind == creq.EmitExe && len(entrySymbol) <= 0:
        add(missing, "program_entry_symbol_missing")
    if emitKind == creq.EmitExe && runtimeTargets.len <= 0:
        add(missing, "runtime_targets_not_lowered")
    if emitKind == creq.EmitExe &&
       tmat.TargetRequiresNativeProviderModules(targetTriple) &&
       providerModules.len <= 0:
        add(missing, "runtime_provider_modules_not_selected")
    return missing

fn BuildSystemLinkPlanStubWithExternalPackageRoots(rootDir: str,
                                                     req: creq.CompilerRequest,
                                                     externalPackageRoots: parser.ParserExternalPackageRoot[],
                                                     plan: var SystemLinkPlanStub,
                                                     err: var str): bool =
    let requestPackageRoot = creq.CompilerRequestRootDir(req)
    let requestSourcePath = creq.CompilerRequestSourcePath(req)
    let requestOutputPath = creq.CompilerRequestOutputPath(req)
    let requestTargetTriple = creq.CompilerRequestTargetTriple(req)
    let requestEmitKind = creq.CompilerRequestEmitKind(req)
    var parsed: parser.ParsedSourceStub
    if !parser.ParseOrdinarySourceStubWithExternalPackageRoots(requestPackageRoot,
                                                                 requestSourcePath,
                                                                 externalPackageRoots,
                                                                 parsed,
                                                                 err):
        return false
    var toolingTrack = false
    for i in 0..<parsed.ownerModulePaths.len:
        if parsed.ownerModulePaths[i] == "cheng/core/tooling/compiler_main":
            toolingTrack = true
    var runtimeTargets: str[]
    var providerModules: str[]
    if requestTargetTriple == "wasm32-unknown-unknown":
        add(runtimeTargets, "runtime/compiler.program_wasm_entry")
    elif toolingTrack:
        add(runtimeTargets, crun.CompilerToolingArgvRuntimeTarget())
    else:
        add(runtimeTargets, crun.CompilerProgramArgvRuntimeTarget())
    if tmat.TargetRequiresNativeProviderModules(requestTargetTriple):
        if toolingTrack:
            crun.RuntimeProviderModulesForTrack(crun.CompilerTrackTooling, providerModules)
        else:
            crun.RuntimeProviderModulesForTrack(crun.CompilerTrackProgram, providerModules)
    let entrySymbol = SystemLinkPlanDeriveEntrySymbol(parsed, requestEmitKind)
    var missing = SystemLinkPlanMissingReasons(parsed,
                                                 requestEmitKind,
                                                 requestTargetTriple,
                                                 runtimeTargets,
                                                 providerModules,
                                                 entrySymbol)
    let linkMode = buildplan.BackendBuildPlanDefaultLinkMode()
    let buildSourceUnitCount = buildplan.BackendBuildPlanDefaultSourceUnitCount()
    let parsedWorkspaceRoot = parser.ParsedSourceWorkspaceRoot(parsed)
    let buildEntryPath = buildplan.BackendBuildPlanDefaultEntryPath(parsedWorkspaceRoot)
    plan.entryPath = requestSourcePath
    plan.outputPath = requestOutputPath
    plan.targetTriple = requestTargetTriple
    plan.emitKind = requestEmitKind
    plan.symbolVisibility = creq.CompilerRequestSymbolVisibility(req)
    plan.browserBridgeObjectPath = creq.CompilerRequestBrowserBridgeObjectPath(req)
    plan.packageRoot = parsed.packageRoot
    plan.externalPackageRoots = parser.ParserExternalPackageRootsClone(externalPackageRoots)
    plan.workspaceRoot = parsed.workspaceRoot
    plan.packageId = parsed.packageId
    plan.moduleStem = parsed.moduleStem
    plan.moduleKind = SystemOrdinaryProgram
    if toolingTrack:
        plan.moduleKind = SystemCompilerControlPlane
    plan.sourceClosurePaths = parsed.orderedClosureSourcePaths
    plan.ownerModulePaths = parsed.ownerModulePaths
    plan.importEdges = parsed.importEdges
    plan.importEdgeCount = parsed.importEdges.len
    plan.unresolvedImportCount = parsed.unresolvedImportCount
    plan.exprLayer = parser.NormalizedExprLayerClone(parsed.normalizedExprLayer)
    plan.hasCompilerTopLevel = parsed.hasCompilerTopLevel
    plan.mainFunctionPresent = parsed.mainFunctionPresent
    plan.runtimeTargets = runtimeTargets
    plan.providerModules = providerModules
    plan.entrySymbol = entrySymbol
    plan.missingReasons = missing
    plan.parserSyntaxTag = parsed.syntaxTag
    plan.parserSourceKind = int32(parsed.sourceKind)
    plan.buildEntryPath = buildEntryPath
    plan.buildSourceUnitCount = buildSourceUnitCount
    plan.linkMode = linkMode
    plan.pipelineStage = "parser_to_system_link_plan"
    err = ""
    return true

fn BuildSystemLinkPlanStub(rootDir: str,
                             req: creq.CompilerRequest,
                             plan: var SystemLinkPlanStub,
                             err: var str): bool =
    var externalPackageRoots: parser.ParserExternalPackageRoot[]
    return BuildSystemLinkPlanStubWithExternalPackageRoots(rootDir,
                                                             req,
                                                             externalPackageRoots,
                                                             plan,
                                                             err)

fn SystemLinkPlanStubReport(plan: SystemLinkPlanStub): str =
    var out: str
    let entryPath = SystemLinkPlanEntryPath(plan)
    let outputPath = SystemLinkPlanOutputPath(plan)
    let targetTriple = SystemLinkPlanTargetTriple(plan)
    let emitKind = SystemLinkPlanEmitKind(plan)
    let emitText = creq.CompilerEmitText(emitKind)
    let symbolVisibility = SystemLinkPlanSymbolVisibility(plan)
    let browserBridgeObjectPathRaw = SystemLinkPlanBrowserBridgeObjectPath(plan)
    let browserBridgeObjectPath = len(browserBridgeObjectPathRaw) > 0 ? browserBridgeObjectPathRaw : "-"
    let workspaceRoot = SystemLinkPlanWorkspaceRoot(plan)
    let packageRoot = SystemLinkPlanPackageRoot(plan)
    let packageId = SystemLinkPlanPackageId(plan)
    let moduleStem = SystemLinkPlanModuleStem(plan)
    let moduleKind = SystemLinkPlanModuleKind(plan)
    let moduleKindText = SystemModuleKindText(moduleKind)
    let sourceClosurePaths = SystemLinkPlanSourceClosurePaths(plan)
    let sourceClosureCount = intToStr(sourceClosurePaths.len)
    let sourceClosureList = SystemLinkPlanListText(sourceClosurePaths)
    let ownerModulePaths = SystemLinkPlanOwnerModulePaths(plan)
    let ownerModuleList = SystemLinkPlanListText(ownerModulePaths)
    let importEdgeCount = intToStr(SystemLinkPlanImportEdgeCount(plan))
    let unresolvedImportCount = intToStr(SystemLinkPlanUnresolvedImportCount(plan))
    let exprLayer = SystemLinkPlanExprLayer(plan)
    var hasCompilerTopLevel = "0"
    if SystemLinkPlanHasCompilerTopLevel(plan):
        hasCompilerTopLevel = "1"
    var mainFunctionPresent = "0"
    if SystemLinkPlanMainFunctionPresent(plan):
        mainFunctionPresent = "1"
    let runtimeTargets = SystemLinkPlanRuntimeTargets(plan)
    let runtimeTargetList = SystemLinkPlanListText(runtimeTargets)
    let providerModules = SystemLinkPlanProviderModules(plan)
    let providerModuleList = SystemLinkPlanListText(providerModules)
    var entrySymbol = SystemLinkPlanEntrySymbol(plan)
    let missingField = SystemLinkPlanMissingReasonsField(plan)
    let missingReasons = SystemLinkPlanListText(missingField)
    let parserSyntax = SystemLinkPlanParserSyntaxTag(plan)
    let parserSourceKind = SystemLinkPlanParserSourceKind(plan)
    let parserSourceKindText = SystemLinkPlanParserSourceKindText(parserSourceKind)
    let buildEntry = SystemLinkPlanBuildEntryPath(plan)
    let buildSourceUnitCount = intToStr(SystemLinkPlanBuildSourceUnitCount(plan))
    let linkMode = SystemLinkPlanLinkMode(plan)
    let pipelineStage = SystemLinkPlanPipelineStage(plan)
    if len(entrySymbol) <= 0:
        entrySymbol = "-"
    SystemLinkPlanAppendLine(out, "entry", entryPath)
    SystemLinkPlanAppendLine(out, "output", outputPath)
    SystemLinkPlanAppendLine(out, "target", targetTriple)
    SystemLinkPlanAppendLine(out, "emit", emitText)
    SystemLinkPlanAppendLine(out, "symbol_visibility", symbolVisibility)
    SystemLinkPlanAppendLine(out, "browser_bridge_object", browserBridgeObjectPath)
    SystemLinkPlanAppendLine(out, "workspace_root", workspaceRoot)
    SystemLinkPlanAppendLine(out, "package_root", packageRoot)
    SystemLinkPlanAppendLine(out, "package_id", packageId)
    SystemLinkPlanAppendLine(out, "module_stem", moduleStem)
    SystemLinkPlanAppendLine(out, "module_kind", moduleKindText)
    SystemLinkPlanAppendLine(out, "source_closure_count", sourceClosureCount)
    SystemLinkPlanAppendLine(out, "source_closure_paths", sourceClosureList)
    SystemLinkPlanAppendLine(out, "owner_modules", ownerModuleList)
    SystemLinkPlanAppendLine(out, "import_edge_count", importEdgeCount)
    SystemLinkPlanAppendLine(out, "unresolved_import_count", unresolvedImportCount)
    SystemLinkPlanAppendLine(out, "expr_surface_source_count", intToStr(exprLayer.sourceCount))
    SystemLinkPlanAppendLine(out, "expr_surface_expr_count", intToStr(parser.NormalizedExprLayerExprCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_if_count", intToStr(parser.NormalizedExprLayerIfCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_range_count", intToStr(parser.NormalizedExprLayerRangeCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_comprehension_count", intToStr(parser.NormalizedExprLayerComprehensionCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_fmt_count", intToStr(parser.NormalizedExprLayerStrFormatCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_result_intrinsic_count", intToStr(parser.NormalizedExprLayerResultIntrinsicCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_try_count", intToStr(parser.NormalizedExprLayerTryCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_default_init_count", intToStr(parser.NormalizedExprLayerDefaultInitCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_constructor_count", intToStr(parser.NormalizedExprLayerConstructorCount(exprLayer)))
    SystemLinkPlanAppendLine(out, "expr_surface_question_residual_count", intToStr(exprLayer.questionResidualCount))
    SystemLinkPlanAppendLine(out, "has_compiler_top_level", hasCompilerTopLevel)
    SystemLinkPlanAppendLine(out, "main_function_present", mainFunctionPresent)
    SystemLinkPlanAppendLine(out, "runtime_targets", runtimeTargetList)
    SystemLinkPlanAppendLine(out, "provider_modules", providerModuleList)
    SystemLinkPlanAppendLine(out, "entry_symbol", entrySymbol)
    SystemLinkPlanAppendLine(out, "missing_reasons", missingReasons)
    SystemLinkPlanAppendLine(out, "parser_syntax", parserSyntax)
    SystemLinkPlanAppendLine(out, "parser_source_kind", parserSourceKindText)
    SystemLinkPlanAppendLine(out, "build_entry", buildEntry)
    SystemLinkPlanAppendLine(out, "build_source_unit_count", buildSourceUnitCount)
    SystemLinkPlanAppendLine(out, "link_mode", linkMode)
    SystemLinkPlanAppendLine(out, "pipeline_stage", pipelineStage)
    return out
fn SystemLinkPlanParserSourceKindText(kind: int32): str =
    if kind == int32(parser.ParsedOrdinarySource):
        return parser.ParsedSourceKindText(parser.ParsedOrdinarySource)
    return "unknown"
