fn PrimaryObjectEmitCstringToStrCopyFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                 functionIndex: int32,
                                                 ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let lenSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 0)
    let copySymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 1)
    if len(lenSymbol) <= 0:
        return Err[str](" primary object emit: missing cstring copy len target")
    if len(copySymbol) <= 0:
        return Err[str](" primary object emit: missing cstring copy runtime target")
    let labelOrdinal = IntToStr(ordinal)
    let emptyLabel = strutil.Join(["L_cheng_cstring_copy_empty_", labelOrdinal], "")
    let framedEmptyLabel = strutil.Join(["L_cheng_cstring_copy_framed_empty_", labelOrdinal], "")
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, lenSymbol):
        out = strutil.Join([out, Fmt".extern {lenSymbol}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, copySymbol):
        out = strutil.Join([out, Fmt".extern {copySymbol}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    out = strutil.Join([out, Fmt"  cbz x0, {emptyLabel}\n"], "")
    out = strutil.Join([out, "  stp x29, x30, [sp, #-48]!\n"], "")
    out = strutil.Join([out, "  mov x29, sp\n"], "")
    out = strutil.Join([out, "  str x8, [sp, #16]\n"], "")
    out = strutil.Join([out, "  str x0, [sp, #24]\n"], "")
    out = strutil.Join([out, Fmt"  bl {lenSymbol}\n"], "")
    out = strutil.Join([out, "  cmp w0, #0\n"], "")
    out = strutil.Join([out, Fmt"  b.le {framedEmptyLabel}\n"], "")
    out = strutil.Join([out, "  str w0, [sp, #32]\n"], "")
    out = strutil.Join([out, "  mov w1, w0\n"], "")
    out = strutil.Join([out, "  ldr x0, [sp, #24]\n"], "")
    out = strutil.Join([out, Fmt"  bl {copySymbol}\n"], "")
    out = strutil.Join([out, Fmt"  cbz x0, {framedEmptyLabel}\n"], "")
    out = strutil.Join([out, "  ldr x8, [sp, #16]\n"], "")
    out = strutil.Join([out, "  ldr w9, [sp, #32]\n"], "")
    out = strutil.Join([out, "  str x0, [x8]\n"], "")
    out = strutil.Join([out, "  str xzr, [x8, #8]\n"], "")
    out = strutil.Join([out, "  str w9, [x8, #8]\n"], "")
    out = strutil.Join([out, "  mov w10, #1\n"], "")
    out = strutil.Join([out, "  str w10, [x8, #16]\n"], "")
    out = strutil.Join([out, "  ldp x29, x30, [sp], #48\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"{framedEmptyLabel}:\n"], "")
    out = strutil.Join([out, "  ldr x8, [sp, #16]\n"], "")
    out = strutil.Join([out, "  str xzr, [x8]\n"], "")
    out = strutil.Join([out, "  str xzr, [x8, #8]\n"], "")
    out = strutil.Join([out, "  str xzr, [x8, #16]\n"], "")
    out = strutil.Join([out, "  ldp x29, x30, [sp], #48\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"{emptyLabel}:\n"], "")
    out = strutil.Join([out, "  str xzr, [x8]\n"], "")
    out = strutil.Join([out, "  str xzr, [x8, #8]\n"], "")
    out = strutil.Join([out, "  str xzr, [x8, #16]\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitF64MulCheckExitFunctionAsm(symbolName: str, ordinal: int32): str =
    let labelOrdinal = IntToStr(ordinal)
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    out = strutil.Join([out, "  movz x0, #0x0000\n"], "")
    out = strutil.Join([out, "  movk x0, #0x0000, lsl #16\n"], "")
    out = strutil.Join([out, "  movk x0, #0x0000, lsl #32\n"], "")
    out = strutil.Join([out, "  movk x0, #0x3ff8, lsl #48\n"], "")
    out = strutil.Join([out, "  fmov d0, x0\n"], "")
    out = strutil.Join([out, "  movz x1, #0x0000\n"], "")
    out = strutil.Join([out, "  movk x1, #0x0000, lsl #16\n"], "")
    out = strutil.Join([out, "  movk x1, #0x0000, lsl #32\n"], "")
    out = strutil.Join([out, "  movk x1, #0x4000, lsl #48\n"], "")
    out = strutil.Join([out, "  fmov d1, x1\n"], "")
    out = strutil.Join([out, "  fmul d0, d0, d1\n"], "")
    out = strutil.Join([out, "  movz x2, #0x0000\n"], "")
    out = strutil.Join([out, "  movk x2, #0x0000, lsl #16\n"], "")
    out = strutil.Join([out, "  movk x2, #0x0000, lsl #32\n"], "")
    out = strutil.Join([out, "  movk x2, #0x4008, lsl #48\n"], "")
    out = strutil.Join([out, "  fmov d2, x2\n"], "")
    out = strutil.Join([out, "  fcmp d0, d2\n"], "")
    out = strutil.Join([out, Fmt"  b.ne L_cheng_f64_mul_check_fail_{labelOrdinal}\n"], "")
    out = strutil.Join([out, "  mov w0, #0\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_f64_mul_check_fail_{labelOrdinal}:\n"], "")
    out = strutil.Join([out, "  mov w0, #1\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return out

fn PrimaryObjectEmitRelocTargetForItem(plan: pobj.PrimaryObjectPlan,
                                        itemId: int32): str =
    for i in 0..<plan.relocSourceItemIds.len:
        if plan.relocSourceItemIds[i] == itemId:
            return plan.relocTargetSymbols[i]
    return ""

fn PrimaryObjectEmitRelocTargetForItemOrdinal(plan: pobj.PrimaryObjectPlan,
                                               itemId: int32,
                                               ordinal: int32): str =
    var seen: int32
    for i in 0..<plan.relocSourceItemIds.len:
        if plan.relocSourceItemIds[i] != itemId:
            continue
        if seen == ordinal:
            return plan.relocTargetSymbols[i]
        seen = seen + 1
    return ""

fn PrimaryObjectEmitSymbolInPlan(plan: pobj.PrimaryObjectPlan,
                                  symbolName: str): bool =
    for i in 0..<plan.symbolNames.len:
        if plan.symbolNames[i] == symbolName:
            return true
    return false

fn PrimaryObjectEmitCstringLiteralCallCount(plan: pobj.PrimaryObjectPlan,
                                             functionIndex: int32): int32 =
    if functionIndex >= 0 && functionIndex < plan.functionBodyIRs.len:
        let bodyIR = plan.functionBodyIRs[functionIndex]
        if pobj.PrimaryBodyIrStatementReturnMode(bodyIR) == pobj.PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
            return bodyIR.callSequence.len
    if functionIndex >= 0 &&
       functionIndex < plan.functionStatementReturnModes.len &&
       plan.functionStatementReturnModes[functionIndex] == pobj.PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0() &&
       functionIndex < plan.functionStatementCallCounts.len:
        return plan.functionStatementCallCounts[functionIndex]
    return 0

fn PrimaryObjectEmitHasData(plan: pobj.PrimaryObjectPlan): bool =
    return plan.dataLabels.len > 0

fn PrimaryObjectEmitBackendDriverCommandDispatchWordAsm(plan: pobj.PrimaryObjectPlan,
                                                         functionIndex: int32,
                                                         localWordIndex: int32): str =
    if functionIndex < 0 || functionIndex >= plan.functionWordOffsets.len:
        return "  .long 0\n"
    let wordIndex = plan.functionWordOffsets[functionIndex] + localWordIndex
    if wordIndex < 0 || wordIndex >= plan.instructionWords.len:
        return "  .long 0\n"
    return Fmt"  .long {IntToStr(plan.instructionWords[wordIndex])}\n"

fn PrimaryObjectEmitBackendDriverCommandDispatchFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                             functionIndex: int32,
                                                             ordinal: int32): Result[str] =
    if functionIndex < 0 || functionIndex >= plan.symbolNames.len:
        return Err[str](" primary object emit: missing backend driver command dispatch symbol")
    let helpTarget = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 0)
    let statusTarget = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 1)
    let printTarget = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 2)
    let verifyTarget = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 3)
    let parallelTarget = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 4)
    let systemTarget = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 5)
    if !PrimaryObjectEmitSymbolInPlan(plan, helpTarget) ||
       !PrimaryObjectEmitSymbolInPlan(plan, statusTarget) ||
       !PrimaryObjectEmitSymbolInPlan(plan, printTarget) ||
       !PrimaryObjectEmitSymbolInPlan(plan, verifyTarget) ||
       !PrimaryObjectEmitSymbolInPlan(plan, parallelTarget) ||
       !PrimaryObjectEmitSymbolInPlan(plan, systemTarget):
        return Err[str](" primary object emit: missing backend driver command dispatch target")
    let symbolName = plan.symbolNames[functionIndex]
    let labelOrdinal = IntToStr(ordinal)
    var chunks: str[]
    add(chunks, Fmt".globl {symbolName}\n")
    add(chunks, Fmt"{symbolName}:\n")
    for wordIndex in 0..<144:
        if wordIndex == 131:
            add(chunks, Fmt"  bl {helpTarget}\n")
        elif wordIndex == 133:
            add(chunks, Fmt"  bl {statusTarget}\n")
        elif wordIndex == 135:
            add(chunks, Fmt"  bl {printTarget}\n")
        elif wordIndex == 137:
            add(chunks, Fmt"  bl {verifyTarget}\n")
        elif wordIndex == 139:
            add(chunks, Fmt"  bl {parallelTarget}\n")
        elif wordIndex == 141:
            add(chunks, Fmt"  bl {systemTarget}\n")
        else:
            add(chunks, PrimaryObjectEmitBackendDriverCommandDispatchWordAsm(plan,
                                                                             functionIndex,
                                                                             wordIndex))
    add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitResultRequestDispatchFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                      functionIndex: int32,
                                                      ordinal: int32): Result[str] =
    if functionIndex < 0 || functionIndex >= plan.symbolNames.len:
        return Err[str](" primary object emit: missing result request dispatch symbol")
    let dispatchTarget = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 0)
    let unsupportedTarget = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 1)
    if len(dispatchTarget) <= 0 ||
       len(unsupportedTarget) <= 0:
        return Err[str](" primary object emit: missing result request dispatch target")
    let symbolName = plan.symbolNames[functionIndex]
    let labelOrdinal = IntToStr(ordinal)
    var chunks: str[]
    add(chunks, Fmt".globl {symbolName}\n")
    if !PrimaryObjectEmitSymbolInPlan(plan, dispatchTarget):
        add(chunks, Fmt".extern {dispatchTarget}\n")
    if !PrimaryObjectEmitSymbolInPlan(plan, unsupportedTarget):
        add(chunks, Fmt".extern {unsupportedTarget}\n")
    add(chunks, Fmt"{symbolName}:\n")
    for wordIndex in 0..<12:
        if wordIndex == 5:
            add(chunks, Fmt"  bl {dispatchTarget}\n")
        elif wordIndex == 9:
            add(chunks, Fmt"  bl {unsupportedTarget}\n")
        else:
            add(chunks, PrimaryObjectEmitBackendDriverCommandDispatchWordAsm(plan,
                                                                             functionIndex,
                                                                             wordIndex))
    add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitCfgBlockLabel(ordinal: int32,
                                   blockIndex: int32): str =
    return Fmt"L_cheng_body_ir_cfg_{IntToStr(ordinal)}_{IntToStr(blockIndex)}"

fn PrimaryObjectEmitStackAddrAsm(reg: int32,
                                  offset: int32): str =
    if offset == 0:
        return Fmt"  mov x{IntToStr(reg)}, sp\n"
    return Fmt"  add x{IntToStr(reg)}, sp, #{IntToStr(offset)}\n"

fn PrimaryObjectEmitLoadSlotToRegAsm(bodyIR: coreir.BodyIR,
                                      slotIndex: int32,
                                      reg: int32,
                                      frameBytes: int32,
                                      paramSaveOffset: int32,
                                      paramSaveCount: int32): Result[str] =
    if slotIndex >= 0:
        if slotIndex >= bodyIR.localSlots.len:
            return Err[str](" primary object emit: cfg arg local slot out of range")
        let slot = bodyIR.localSlots[slotIndex]
        if slot.typeKind == coreir.LocalI32Tag:
            return Ok[str](Fmt"  ldr w{IntToStr(reg)}, [sp, #{IntToStr(slot.stackOffset)}]\n")
        if slot.typeKind == coreir.LocalPtrTag:
            return Ok[str](Fmt"  ldr x{IntToStr(reg)}, [sp, #{IntToStr(slot.stackOffset)}]\n")
        if slot.typeKind == coreir.LocalStrTag ||
           slot.typeKind == coreir.LocalAggregateTag:
            return Ok[str](PrimaryObjectEmitStackAddrAsm(reg, slot.stackOffset))
        return Err[str](" primary object emit: cfg arg local slot type unsupported")
    let paramSlot = 0 - slotIndex - 1
    if paramSlot < 0:
        return Err[str](" primary object emit: cfg arg param slot invalid")
    var paramOffset = pobj.PrimaryIncomingParamStackOffset(frameBytes, paramSlot)
    if paramSlot < 8:
        if paramSlot >= paramSaveCount:
            return Err[str](" primary object emit: cfg arg param not saved")
        paramOffset = paramSaveOffset + paramSlot * 8
    if paramOffset < 0:
        return Err[str](" primary object emit: cfg arg param offset invalid")
    return Ok[str](Fmt"  ldr x{IntToStr(reg)}, [sp, #{IntToStr(paramOffset)}]\n")

fn PrimaryObjectEmitCfgCallAsm(plan: pobj.PrimaryObjectPlan,
                                bodyIR: coreir.BodyIR,
                                functionIndex: int32,
                                callOrdinal: int32,
                                frameBytes: int32,
                                paramSaveOffset: int32,
                                paramSaveCount: int32): Result[str] =
    if callOrdinal < 0 || callOrdinal >= bodyIR.callSequence.len:
        return Err[str](" primary object emit: cfg call ordinal out of range")
    let callOp = bodyIR.callSequence[callOrdinal]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan,
                                                                  plan.itemIds[functionIndex],
                                                                  callOrdinal)
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: cfg call target missing")
    var chunks: str[]
    let stackArgBytes = pobj.PrimaryCallOpStackArgBytes(callOp)
    if stackArgBytes > 0:
        add(chunks, Fmt"  sub sp, sp, #{IntToStr(stackArgBytes)}\n")
    let registerArgCount = pobj.PrimaryCallOpRegisterArgCount(callOp)
    for argIndex in 0..<registerArgCount:
        let loadRes = PrimaryObjectEmitLoadSlotToRegAsm(bodyIR,
                                                        callOp.argSlots[argIndex],
                                                        argIndex,
                                                        frameBytes,
                                                        paramSaveOffset,
                                                        paramSaveCount)
        if IsErr(loadRes):
            return Err[str](Error(loadRes))
        add(chunks, Value(loadRes))
    if stackArgBytes > 0:
        for stackArgIndex in 0..<pobj.PrimaryCallOpStackArgCount(callOp):
            let argIndex = stackArgIndex + 8
            if argIndex >= callOp.argSlots.len:
                return Err[str](" primary object emit: cfg stack arg index invalid")
            let loadRes = PrimaryObjectEmitLoadSlotToRegAsm(bodyIR,
                                                            callOp.argSlots[argIndex],
                                                            16,
                                                            frameBytes,
                                                            paramSaveOffset,
                                                            paramSaveCount)
            if IsErr(loadRes):
                return Err[str](Error(loadRes))
            add(chunks, Value(loadRes))
            add(chunks, Fmt"  str x16, [sp, #{IntToStr(stackArgIndex * 8)}]\n")
        if stackArgBytes % 16 != 0:
            return Err[str](" primary object emit: cfg stack arg alignment invalid")
    if callOp.resultSlot >= 0:
        if callOp.resultSlot >= bodyIR.localSlots.len:
            return Err[str](" primary object emit: cfg result slot out of range")
        let resultSlot = bodyIR.localSlots[callOp.resultSlot]
        if resultSlot.typeKind == coreir.LocalStrTag ||
           resultSlot.typeKind == coreir.LocalAggregateTag:
            add(chunks, PrimaryObjectEmitStackAddrAsm(8, resultSlot.stackOffset))
    add(chunks, Fmt"  bl {targetSymbol}\n")
    if stackArgBytes > 0:
        add(chunks, Fmt"  add sp, sp, #{IntToStr(stackArgBytes)}\n")
    if callOp.resultSlot >= 0:
        let resultSlot = bodyIR.localSlots[callOp.resultSlot]
        if resultSlot.typeKind == coreir.LocalI32Tag:
            add(chunks, Fmt"  str w0, [sp, #{IntToStr(resultSlot.stackOffset)}]\n")
        elif resultSlot.typeKind == coreir.LocalPtrTag:
            add(chunks, Fmt"  str x0, [sp, #{IntToStr(resultSlot.stackOffset)}]\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitCfgEpilogueAsm(frameBytes: int32): str =
    var out = ""
    out = strutil.Join([out, "  ldp x29, x30, [sp]\n"], "")
    out = strutil.Join([out, Fmt"  add sp, sp, #{IntToStr(frameBytes)}\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    return out

fn PrimaryObjectEmitCfgReturnAsm(bodyIR: coreir.BodyIR,
                                  term: coreir.BodyTerm,
                                  frameBytes: int32): Result[str] =
    var out = ""
    if term.operands.len >= 2 &&
       term.operands[0] == pobj.PrimaryStatementReturnModeI32Const():
        out = strutil.Join([out, Fmt"  mov w0, #{IntToStr(term.operands[1])}\n"], "")
    elif term.resultSlot >= 0 && term.resultSlot < bodyIR.localSlots.len:
        let slot = bodyIR.localSlots[term.resultSlot]
        if slot.typeKind != coreir.LocalI32Tag:
            return Err[str](" primary object emit: cfg return slot type unsupported")
        out = strutil.Join([out, Fmt"  ldr w0, [sp, #{IntToStr(slot.stackOffset)}]\n"], "")
    else:
        return Err[str](" primary object emit: cfg return unsupported")
    out = strutil.Join([out, PrimaryObjectEmitCfgEpilogueAsm(frameBytes)], "")
    return Ok[str](out)

fn PrimaryObjectEmitCfgTermAsm(bodyIR: coreir.BodyIR,
                                term: coreir.BodyTerm,
                                frameBytes: int32,
                                ordinal: int32): Result[str] =
    if term.kind == coreir.BodyTermReturnTag:
        return PrimaryObjectEmitCfgReturnAsm(bodyIR, term, frameBytes)
    if term.kind == coreir.BodyTermBrTag:
        return Ok[str](Fmt"  b {PrimaryObjectEmitCfgBlockLabel(ordinal, term.trueBlock)}\n")
    if term.kind != coreir.BodyTermCbrTag:
        return Err[str](" primary object emit: cfg term unsupported")
    var slotIndex = term.lhsSlot
    if slotIndex < 0:
        slotIndex = term.resultSlot
    if slotIndex < 0 || slotIndex >= bodyIR.localSlots.len:
        return Err[str](" primary object emit: cfg condition slot invalid")
    let slot = bodyIR.localSlots[slotIndex]
    if slot.typeKind != coreir.LocalI32Tag:
        return Err[str](" primary object emit: cfg condition slot type unsupported")
    let trueLabel = PrimaryObjectEmitCfgBlockLabel(ordinal, term.trueBlock)
    let falseLabel = PrimaryObjectEmitCfgBlockLabel(ordinal, term.falseBlock)
    var out = Fmt"  ldr w9, [sp, #{IntToStr(slot.stackOffset)}]\n"
    if term.conditionKind == coreir.BodyCondLocalZeroTag:
        out = strutil.Join([out, Fmt"  cbz w9, {trueLabel}\n"], "")
    elif term.conditionKind == coreir.BodyCondLocalNonZeroTag:
        out = strutil.Join([out, Fmt"  cbnz w9, {trueLabel}\n"], "")
    elif term.conditionKind == coreir.BodyBranchIfLocalLeZeroReturnI32ConstTag:
        out = strutil.Join([out, "  cmp w9, #0\n"], "")
        out = strutil.Join([out, Fmt"  b.le {trueLabel}\n"], "")
    else:
        return Err[str](" primary object emit: cfg condition unsupported")
    out = strutil.Join([out, Fmt"  b {falseLabel}\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitCallCfgReturnInt32FunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                   functionIndex: int32,
                                                   ordinal: int32): Result[str] =
    if functionIndex < 0 ||
       functionIndex >= plan.symbolNames.len ||
       functionIndex >= plan.functionBodyIRs.len:
        return Err[str](" primary object emit: missing cfg function")
    let bodyIR = plan.functionBodyIRs[functionIndex]
    if !pobj.PrimaryBodyIrIsCallCfgReturnInt32(bodyIR):
        return Err[str](" primary object emit: cfg shape unsupported")
    var localFrameBytes = pobj.PrimaryBodyIrStackByteCount(bodyIR)
    if localFrameBytes < 16:
        localFrameBytes = 16
    let paramSaveCount = pobj.PrimaryBodyIrParamSaveCount(bodyIR)
    if paramSaveCount < 0:
        return Err[str](" primary object emit: cfg param save unsupported")
    let paramSaveOffset = localFrameBytes
    var frameBytes = localFrameBytes
    if paramSaveCount > 0:
        frameBytes = pobj.PrimaryAlignStackBytes(frameBytes + paramSaveCount * 8, 16)
    if frameBytes <= 0 || frameBytes > 4095:
        return Err[str](" primary object emit: cfg frame unsupported")
    let symbolName = plan.symbolNames[functionIndex]
    var chunks: str[]
    add(chunks, Fmt".globl {symbolName}\n")
    for callOrdinal in 0..<bodyIR.callSequence.len:
        let targetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan,
                                                                      plan.itemIds[functionIndex],
                                                                      callOrdinal)
        if len(targetSymbol) <= 0:
            return Err[str](" primary object emit: cfg target missing")
        if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
            add(chunks, Fmt".extern {targetSymbol}\n")
    add(chunks, Fmt"{symbolName}:\n")
    add(chunks, Fmt"  sub sp, sp, #{IntToStr(frameBytes)}\n")
    add(chunks, "  stp x29, x30, [sp]\n")
    add(chunks, "  mov x29, sp\n")
    for paramIndex in 0..<paramSaveCount:
        add(chunks, Fmt"  str x{IntToStr(paramIndex)}, [sp, #{IntToStr(paramSaveOffset + paramIndex * 8)}]\n")
    for blockIndex in 0..<bodyIR.blocks.len:
        let block = bodyIR.blocks[blockIndex]
        add(chunks, Fmt"{PrimaryObjectEmitCfgBlockLabel(ordinal, blockIndex)}:\n")
        for opIndex in block.opStart..<(block.opStart + block.opCount):
            let op = bodyIR.ops[opIndex]
            if op.kind != coreir.BodyOpCallTag || op.operands.len < 1:
                return Err[str](" primary object emit: cfg op unsupported")
            let callAsmRes = PrimaryObjectEmitCfgCallAsm(plan,
                                                         bodyIR,
                                                         functionIndex,
                                                         op.operands[0],
                                                         frameBytes,
                                                         paramSaveOffset,
                                                         paramSaveCount)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        if block.termIndex < 0 || block.termIndex >= bodyIR.terms.len:
            return Err[str](" primary object emit: cfg term missing")
        let termAsmRes = PrimaryObjectEmitCfgTermAsm(bodyIR,
                                                     bodyIR.terms[block.termIndex],
                                                     frameBytes,
                                                     ordinal)
        if IsErr(termAsmRes):
            return Err[str](Error(termAsmRes))
        add(chunks, Value(termAsmRes))
    add(chunks, Fmt"L_cheng_embedded_line_map_end_{IntToStr(ordinal)}:\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitReturnCallFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                           functionIndex: int32,
                                           ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing return-call target")
    let labelOrdinal = IntToStr(ordinal)
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = strutil.Join([out, Fmt".extern {targetSymbol}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    if plan.functionBodyKinds[functionIndex] == texpr.BodyKindReturnCallArg0TruePassthrough:
        out = strutil.Join([out, "  mov w1, #1\n"], "")
    if plan.functionBodyKinds[functionIndex] == texpr.BodyKindReturnCallArg0Arg1TruePassthrough:
        out = strutil.Join([out, "  mov w2, #1\n"], "")
    out = strutil.Join([out, Fmt"  b {targetSymbol}\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitLetCallNoargReturnI32ConstFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                           functionIndex: int32,
                                                           ordinal: int32,
                                                           imm: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing let-call target")
    let labelOrdinal = IntToStr(ordinal)
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = strutil.Join([out, Fmt".extern {targetSymbol}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    out = strutil.Join([out, "  stp x29, x30, [sp, #-16]!\n"], "")
    out = strutil.Join([out, "  mov x29, sp\n"], "")
    out = strutil.Join([out, Fmt"  bl {targetSymbol}\n"], "")
    out = strutil.Join([out, Fmt"  mov w0, #{IntToStr(imm)}\n"], "")
    out = strutil.Join([out, "  ldp x29, x30, [sp], #16\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitLetCallNoargReturnResultI32FunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                            functionIndex: int32,
                                                            ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing let-call result target")
    let labelOrdinal = IntToStr(ordinal)
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = strutil.Join([out, Fmt".extern {targetSymbol}\n"], "")
