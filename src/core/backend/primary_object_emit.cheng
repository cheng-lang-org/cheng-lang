import cheng/core/lang/typed_expr as texpr

type
    PrimaryObjectEmitResult =
        asmPath: str
        objectPath: str
        compileLogPath: str
        commandText: str
        exitCode: int32
        asmText: str
        compilerOutput: str

fn PrimaryObjectEmitAsmPath(plan: pobj.PrimaryObjectPlan): str =
    return strutil.Join([plan.outputPath, ".s"], "")

fn PrimaryObjectEmitCompileLogPath(plan: pobj.PrimaryObjectPlan): str =
    return strutil.Join([plan.outputPath, ".compile.log"], "")

fn PrimaryObjectEmitTargetIsAarch64Elf(plan: pobj.PrimaryObjectPlan): bool =
    return plan.objectFormat == "elf" &&
           (tmat.TargetIsLinuxAarch64(plan.targetTriple) ||
            tmat.TargetIsAndroidAarch64(plan.targetTriple) ||
            tmat.TargetIsOhosAarch64(plan.targetTriple))

fn PrimaryObjectEmitTargetSupported(plan: pobj.PrimaryObjectPlan): bool =
    if tmat.TargetIsDarwinArm64(plan.targetTriple) && plan.objectFormat == "macho":
        return true
    return PrimaryObjectEmitTargetIsAarch64Elf(plan)

fn PrimaryObjectEmitAppendTargetCompileArgs(plan: pobj.PrimaryObjectPlan,
                                             argv: var str[]): Result[bool] =
    if tmat.TargetIsDarwinArm64(plan.targetTriple):
        add(argv, "-arch")
        add(argv, "arm64")
        return Ok[bool](true)
    if PrimaryObjectEmitTargetIsAarch64Elf(plan):
        add(argv, "-target")
        add(argv, plan.targetTriple)
        return Ok[bool](true)
    return Err[bool](strutil.Join([" primary object emit: unsupported target: ", plan.targetTriple], ""))

fn PrimaryObjectEmitHasEntryBridge(plan: pobj.PrimaryObjectPlan): bool =
    if len(plan.entryFunctionSymbol) <= 0:
        return false
    if plan.symbolNames.len <= 0:
        return false
    if plan.functionBodyKinds.len != plan.symbolNames.len:
        return false
    for i in 0..<plan.functionBodyKinds.len:
        if plan.functionBodyKinds[i] == texpr.BodyKindEntryBridge:
            return true
    return false

fn PrimaryObjectEmitEntryBridgeIndex(plan: pobj.PrimaryObjectPlan): int32 =
    if len(plan.entryFunctionSymbol) <= 0:
        return -1
    if plan.symbolNames.len <= 0:
        return -1
    if plan.functionBodyKinds.len != plan.symbolNames.len:
        return -1
    if plan.functionBodyKinds.len == 2:
        if plan.functionBodyKinds[1] == texpr.BodyKindEntryBridge:
            return 1
    for i in 0..<plan.functionBodyKinds.len:
        if plan.functionBodyKinds[i] == texpr.BodyKindEntryBridge:
            return i
    return -1

fn PrimaryObjectEmitFunctionCount(plan: pobj.PrimaryObjectPlan): int32 =
    let bridgeIndex = PrimaryObjectEmitEntryBridgeIndex(plan)
    if bridgeIndex >= 0:
        return bridgeIndex
    return plan.symbolNames.len

fn PrimaryObjectEmitParseSuffixI32(bodyKind: str,
                                    prefix: str): int32 =
    var value: int32
    for i in prefix.len..<bodyKind.len:
        let ch = bodyKind[i]
        if ch < '0' || ch > '9':
            return 0
        value = value * 10 + int32(ch) - int32('0')
    return value

fn PrimaryObjectEmitIsReturnI32ConstBodyKind(bodyKind: str): bool =
    return strutil.StartsWith(bodyKind, texpr.BodyKindReturnI32ConstPrefix)

fn PrimaryObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind: str): bool =
    return strutil.StartsWith(bodyKind, texpr.BodyKindLetCallNoargReturnI32ConstPrefix)

fn PrimaryObjectEmitPayloadByteCount(payloadText: str): int32 =
    let zeroPrefix = "zero:"
    if strutil.StartsWith(payloadText, zeroPrefix):
        let raw = strings.SliceBytes(payloadText, len(zeroPrefix), len(payloadText) - len(zeroPrefix))
        return int32(strutil.ParseInt(raw))
    let cstringPrefix = "cstring:"
    if strutil.StartsWith(payloadText, cstringPrefix):
        let raw = strings.SliceBytes(payloadText, len(cstringPrefix), len(payloadText) - len(cstringPrefix))
        var count: int32 = 1
        var escaped = false
        for i in 0..<len(raw):
            if escaped:
                escaped = false
                count = count + 1
            elif raw[i] == char(92):
                escaped = true
            else:
                count = count + 1
        if escaped:
            count = count + 1
        return count
    return 0

fn PrimaryObjectEmitCStringPayloadByte(raw: str,
                                        index: int32): int32 =
    if index < 0 || index >= len(raw):
        return 0
    let ch = raw[index]
    if ch == 'n':
        return 10
    if ch == 'r':
        return 13
    if ch == 't':
        return 9
    if ch == '0':
        return 0
    return int32(ch)

fn PrimaryObjectEmitCStringPayloadByteList(payloadText: str): str =
    let prefix = "cstring:"
    if !strutil.StartsWith(payloadText, prefix):
        return "0"
    let raw = strings.SliceBytes(payloadText, len(prefix), len(payloadText) - len(prefix))
    var parts: str[]
    var escaped = false
    for i in 0..<len(raw):
        if escaped:
            add(parts, IntToStr(PrimaryObjectEmitCStringPayloadByte(raw, i)))
            escaped = false
        elif raw[i] == char(92):
            escaped = true
        else:
            add(parts, IntToStr(int32(raw[i])))
    if escaped:
        add(parts, IntToStr(int32(char(92))))
    add(parts, "0")
    return strutil.Join(parts, ", ")

fn PrimaryObjectEmitDataLabelByTail(plan: pobj.PrimaryObjectPlan,
                                     tail: str): str =
    for i in 0..<plan.dataLabels.len:
        let label = plan.dataLabels[i]
        if len(label) < len(tail):
            continue
        let start = len(label) - len(tail)
        var matches = true
        for j in 0..<len(tail):
            if label[start + j] != tail[j]:
                matches = false
                break
        if matches:
            return label
    return ""

fn PrimaryObjectEmitExpectedWordsForBodyKind(bodyKind: str): int32 =
    return bkind.BodyKindExpectedWordCount(bodyKind)

fn PrimaryObjectEmitExpectedWordsForPlanFunction(plan: pobj.PrimaryObjectPlan,
                                                  functionIndex: int32): int32 =
    if functionIndex < 0 || functionIndex >= plan.functionBodyKinds.len:
        return 0
    if functionIndex < plan.functionBodyIRs.len &&
       (pobj.PrimaryBodyIrIsCallSequenceReturnInt32(plan.functionBodyIRs[functionIndex]) ||
        pobj.PrimaryBodyIrIsCallSequenceReturnI32Const(plan.functionBodyIRs[functionIndex]) ||
        pobj.PrimaryBodyIrIsCallSequenceReturnStr(plan.functionBodyIRs[functionIndex]) ||
        pobj.PrimaryBodyIrIsCallSequenceReturnAggregate(plan.functionBodyIRs[functionIndex]) ||
        plan.functionBodyIRs[functionIndex].ops.len == 4):
        if functionIndex >= plan.functionWordCounts.len:
            return 0
        return plan.functionWordCounts[functionIndex]
    let bodyKind = plan.functionBodyKinds[functionIndex]
    if bodyKind == texpr.BodyKindStatementSequence:
        if functionIndex >= plan.functionWordCounts.len:
            return 0
        return plan.functionWordCounts[functionIndex]
    return PrimaryObjectEmitExpectedWordsForBodyKind(bodyKind)

fn PrimaryObjectEmitValidateReturnZeroShape(plan: pobj.PrimaryObjectPlan): Result[bool] =
    if !PrimaryObjectEmitTargetSupported(plan):
        return Err[bool](Fmt" primary object emit: unsupported target: {plan.targetTriple}")
    if len(plan.outputPath) <= 0:
        return Err[bool](" primary object emit: missing output path")
    if plan.missingReasons.len > 0:
        return Err[bool](" primary object emit: plan has missing reasons")
    if plan.symbolNames.len <= 0:
        return Err[bool](" primary object emit: missing symbols")
    if len(plan.entryFunctionSymbol) > 0 && plan.symbolNames.len < 2:
        return Err[bool](" primary object emit: executable entry bridge missing")
    if plan.symbolNames.len != plan.functionWordCounts.len ||
       plan.symbolNames.len != plan.functionWordOffsets.len ||
       plan.symbolNames.len != plan.functionBodyKinds.len ||
       plan.symbolNames.len != plan.itemIds.len:
        return Err[bool](" primary object emit: malformed function table")
    var bridgeIndex = PrimaryObjectEmitEntryBridgeIndex(plan)
    if bridgeIndex < 1 && plan.functionBodyKinds.len == 2:
        if plan.functionBodyKinds[0] == texpr.BodyKindReturnZeroI32 ||
           PrimaryObjectEmitIsReturnI32ConstBodyKind(plan.functionBodyKinds[0]):
            if plan.functionBodyKinds[1] == texpr.BodyKindEntryBridge:
                bridgeIndex = 1
    if len(plan.entryFunctionSymbol) > 0:
        if bridgeIndex < 0:
            return Err[bool](" primary object emit: executable entry bridge missing")
    var functionLimit = plan.symbolNames.len
    if bridgeIndex >= 0:
        functionLimit = bridgeIndex
    if functionLimit <= 0:
        return Err[bool](" primary object emit: missing primary function")
    for i in 0..<functionLimit:
        if len(plan.symbolNames[i]) <= 0:
            return Err[bool](" primary object emit: empty function symbol")
        if i >= plan.functionBodyKinds.len:
            return Err[bool](" primary object emit: missing function body kind")
        if plan.functionWordCounts[i] <= 0:
            return Err[bool](Fmt" primary object emit: unsupported function word count: {IntToStr(plan.functionWordCounts[i])}")
        if plan.functionWordOffsets[i] < 0:
            return Err[bool](" primary object emit: negative function word offset")
        if plan.functionWordOffsets[i] + plan.functionWordCounts[i] > plan.instructionWords.len:
            return Err[bool](" primary object emit: function instruction words missing")
        if i == 0 && plan.functionWordOffsets[i] != 0:
            return Err[bool](" primary object emit: first function word offset mismatch")
        if i > 0:
            let previousIndex = i - 1
            let expectedOffset = plan.functionWordOffsets[previousIndex] + plan.functionWordCounts[previousIndex]
            if plan.functionWordOffsets[i] != expectedOffset:
                return Err[bool](" primary object emit: function word offset mismatch")
    if bridgeIndex >= 0:
        if len(plan.symbolNames[bridgeIndex]) <= 0:
            return Err[bool](" primary object emit: empty entry bridge symbol")
        let lastFunctionIndex = bridgeIndex - 1
        if lastFunctionIndex < 0:
            return Err[bool](" primary object emit: missing primary function before entry bridge")
        let expectedBridgeOffset = plan.functionWordOffsets[lastFunctionIndex] + plan.functionWordCounts[lastFunctionIndex]
        if plan.functionWordOffsets[bridgeIndex] != expectedBridgeOffset:
            return Err[bool](strutil.Join([" primary object emit: entry bridge word offset mismatch expected=",
                                  IntToStr(expectedBridgeOffset),
                                  " actual=",
                                  IntToStr(plan.functionWordOffsets[bridgeIndex]),
                                  " symbol_count=",
                                  IntToStr(plan.symbolNames.len),
                                  " function_count=",
                                  IntToStr(PrimaryObjectEmitFunctionCount(plan))], ""))
    return Ok[bool](true)

fn PrimaryObjectEmitValidateObjectShape(plan: pobj.PrimaryObjectPlan): Result[bool] =
    if !PrimaryObjectEmitTargetSupported(plan):
        return Err[bool](Fmt" primary object emit: unsupported target: {plan.targetTriple}")
    if len(plan.outputPath) <= 0:
        return Err[bool](" primary object emit: missing output path")
    if plan.missingReasons.len > 0:
        return Err[bool](" primary object emit: object plan has missing reasons")
    if plan.symbolNames.len <= 0:
        return Err[bool](" primary object emit: object plan missing symbols")
    if plan.symbolNames.len != plan.functionWordCounts.len ||
       plan.symbolNames.len != plan.functionWordOffsets.len ||
       plan.symbolNames.len != plan.functionBodyKinds.len ||
       plan.symbolNames.len != plan.itemIds.len:
        return Err[bool](" primary object emit: object plan malformed function table")
    for i in 0..<plan.symbolNames.len:
        if len(plan.symbolNames[i]) <= 0:
            return Err[bool](" primary object emit: object plan empty function symbol")
        if plan.functionWordCounts[i] <= 0:
            return Err[bool](Fmt" primary object emit: object plan unsupported function word count: {IntToStr(plan.functionWordCounts[i])}")
        if plan.functionWordOffsets[i] < 0:
            return Err[bool](" primary object emit: object plan negative function word offset")
        if plan.functionWordOffsets[i] + plan.functionWordCounts[i] > plan.instructionWords.len:
            return Err[bool](" primary object emit: object plan instruction words missing")
        if i == 0 && plan.functionWordOffsets[i] != 0:
            return Err[bool](" primary object emit: object plan first function word offset mismatch")
        if i > 0:
            let previousIndex = i - 1
            let expectedOffset = plan.functionWordOffsets[previousIndex] + plan.functionWordCounts[previousIndex]
            if plan.functionWordOffsets[i] != expectedOffset:
                return Err[bool](" primary object emit: object plan function word offset mismatch")
    return Ok[bool](true)

fn PrimaryObjectEmitReturnZeroFunctionAsm(symbolName: str, ordinal: int32): str =
    let labelOrdinal = IntToStr(ordinal)
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    out = strutil.Join([out, "  mov w0, #0\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return out

