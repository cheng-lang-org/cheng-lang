fn PrimaryObjectEmitCstringLiteralCallsReturnI32Const0FunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                                   functionIndex: int32,
                                                                   ordinal: int32,
                                                                   callCount: int32): Result[str] =
    if functionIndex < 0 || functionIndex >= plan.symbolNames.len:
        return Err[str](" primary object emit: missing cstring literal call symbol")
    let symbolName = plan.symbolNames[functionIndex]
    let labelOrdinal = IntToStr(ordinal)
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    for callOrdinal in 0..<callCount:
        let targetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan,
                                                                      plan.itemIds[functionIndex],
                                                                      callOrdinal)
        if len(targetSymbol) <= 0:
            return Err[str](" primary object emit: missing cstring literal call target")
        if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
            out = strutil.Join([out, Fmt".extern {targetSymbol}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    out = strutil.Join([out, "  stp x29, x30, [sp, #-16]!\n"], "")
    out = strutil.Join([out, "  mov x29, sp\n"], "")
    for callOrdinal in 0..<callCount:
        let targetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan,
                                                                      plan.itemIds[functionIndex],
                                                                      callOrdinal)
        let literalLabel = pobj.PrimaryCStringLiteralDataLabel(symbolName, callOrdinal)
        out = strutil.Join([out, Fmt"  adrp x0, {literalLabel}@PAGE\n"], "")
        out = strutil.Join([out, Fmt"  add x0, x0, {literalLabel}@PAGEOFF\n"], "")
        out = strutil.Join([out, Fmt"  bl {targetSymbol}\n"], "")
    out = strutil.Join([out, "  mov w0, #0\n"], "")
    out = strutil.Join([out, "  ldp x29, x30, [sp], #16\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitStatementSequenceFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                  functionIndex: int32,
                                                  ordinal: int32): Result[str] =
    if functionIndex < 0 || functionIndex >= plan.functionStatementReturnModes.len:
        return Err[str](" primary object emit: missing statement sequence return mode")
    var mode = plan.functionStatementReturnModes[functionIndex]
    var imm: int32
    if functionIndex < plan.functionStatementReturnI32Values.len:
        imm = plan.functionStatementReturnI32Values[functionIndex]
    if functionIndex < plan.functionBodyIRs.len:
        let bodyIR = plan.functionBodyIRs[functionIndex]
        if bodyIR.ops.len > 0:
            let returnOp = bodyIR.ops[bodyIR.ops.len - 1]
            if returnOp.kind == coreir.BodyOpReturnTag && returnOp.operands.len > 0:
                mode = returnOp.operands[0]
                if returnOp.operands.len > 1:
                    imm = returnOp.operands[1]
    if mode == pobj.PrimaryStatementReturnModeI32Const():
        return PrimaryObjectEmitLetCallNoargReturnI32ConstFunctionAsm(plan, functionIndex, ordinal, imm)
    if mode == pobj.PrimaryStatementReturnModeCallResultI32():
        return PrimaryObjectEmitLetCallNoargReturnResultI32FunctionAsm(plan, functionIndex, ordinal)
    if mode == pobj.PrimaryStatementReturnModeI32GuardResultLeZero():
        return PrimaryObjectEmitLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32FunctionAsm(plan,
                                                                                                functionIndex,
                                                                                                ordinal)
    if mode == pobj.PrimaryStatementReturnModeStrLen():
        return PrimaryObjectEmitLetCallNoargStrReturnLenI32FunctionAsm(plan, functionIndex, ordinal)
    if mode == pobj.PrimaryStatementReturnModeStrThenCallReturnI32Const0():
        return PrimaryObjectEmitLetCallNoargStrThenCallArg0ReturnI32Const0FunctionAsm(plan, functionIndex, ordinal)
    if mode == pobj.PrimaryStatementReturnModeCstringLiteralCallsReturnI32Const0():
        var callCount: int32
        if functionIndex < plan.functionStatementCallCounts.len:
            callCount = plan.functionStatementCallCounts[functionIndex]
        if functionIndex < plan.functionBodyIRs.len:
            let bodyIR = plan.functionBodyIRs[functionIndex]
            if pobj.PrimaryBodyIrStatementReturnMode(bodyIR) == mode:
                callCount = bodyIR.callSequence.len
        return PrimaryObjectEmitCstringLiteralCallsReturnI32Const0FunctionAsm(plan,
                                                                              functionIndex,
                                                                              ordinal,
                                                                              callCount)
    return Err[str](" primary object emit: unsupported statement sequence return mode")

