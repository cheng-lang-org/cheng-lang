import std/result
import std/os_host_process as hostos
import std/strformat
import std/strutils as strutil
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/core/backend/primary_object_plan as pobj

type
    PrimaryObjectEmitResult =
        asmPath: str
        objectPath: str
        compileLogPath: str
        commandText: str
        exitCode: int32
        asmText: str
        compilerOutput: str

const
    PrimaryObjectEmitReturnI32ConstPrefix = "return_i32_const_"
    PrimaryObjectEmitLetCallNoargReturnI32ConstPrefix = "let_call_noarg_return_i32_const_"
    PrimaryObjectEmitLetCallNoargReturnResultI32Kind = "let_call_noarg_return_result_i32"
    PrimaryObjectEmitLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32Kind = "let_call_noarg_i32_if_result_le_zero_return_zero_else_result_i32"
    PrimaryObjectEmitLetCallNoargStrReturnLenI32Kind = "let_call_noarg_str_return_len_i32"
    PrimaryObjectEmitLetCallNoargStrThenCallArg0ReturnI32Const0Kind = "let_call_noarg_str_then_call_arg0_return_i32_const_0"
    PrimaryObjectEmitReturnI32ConstMax = 65535

fn PrimaryObjectEmitParseReturnI32ConstBodyKind(bodyKind: str): Result[int32] =
    let prefix = PrimaryObjectEmitReturnI32ConstPrefix
    if len(bodyKind) <= len(prefix):
        return Err[int32](Fmt([" primary object emit: unsupported return_i32_const body kind: ", bodyKind]))
    let maxBeforeDigit = PrimaryObjectEmitReturnI32ConstMax / 10
    let maxLastDigit = PrimaryObjectEmitReturnI32ConstMax % 10
    for i in 0..<len(prefix):
        if bodyKind[i] != prefix[i]:
            return Err[int32](Fmt([" primary object emit: unsupported body kind: ", bodyKind]))
    var value: int32
    for i in len(prefix)..<len(bodyKind):
        let ch = bodyKind[i]
        if ch < '0' || ch > '9':
            return Err[int32](Fmt([" primary object emit: invalid return_i32_const immediate: ", bodyKind]))
        let digit = int32(ch) - int32('0')
        if value > maxBeforeDigit || (value == maxBeforeDigit && digit > maxLastDigit):
            return Err[int32](Fmt([" primary object emit: return_i32_const immediate out of range: ", bodyKind]))
        value = value * 10 + digit
    return Ok[int32](value)

fn PrimaryObjectEmitIsReturnI32ConstBodyKind(bodyKind: str): bool =
    return IsOk(PrimaryObjectEmitParseReturnI32ConstBodyKind(bodyKind))

fn PrimaryObjectEmitParseLetCallNoargReturnI32ConstBodyKind(bodyKind: str): Result[int32] =
    let prefix = PrimaryObjectEmitLetCallNoargReturnI32ConstPrefix
    if len(bodyKind) <= len(prefix):
        return Err[int32](Fmt([" primary object emit: unsupported let_call_noarg_return_i32_const body kind: ", bodyKind]))
    let maxBeforeDigit = PrimaryObjectEmitReturnI32ConstMax / 10
    let maxLastDigit = PrimaryObjectEmitReturnI32ConstMax % 10
    for i in 0..<len(prefix):
        if bodyKind[i] != prefix[i]:
            return Err[int32](Fmt([" primary object emit: unsupported body kind: ", bodyKind]))
    var value: int32
    for i in len(prefix)..<len(bodyKind):
        let ch = bodyKind[i]
        if ch < '0' || ch > '9':
            return Err[int32](Fmt([" primary object emit: invalid let-call immediate: ", bodyKind]))
        let digit = int32(ch) - int32('0')
        if value > maxBeforeDigit || (value == maxBeforeDigit && digit > maxLastDigit):
            return Err[int32](Fmt([" primary object emit: let-call immediate out of range: ", bodyKind]))
        value = value * 10 + digit
    return Ok[int32](value)

fn PrimaryObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind: str): bool =
    return IsOk(PrimaryObjectEmitParseLetCallNoargReturnI32ConstBodyKind(bodyKind))

fn PrimaryObjectEmitIsLetCallNoargReturnResultI32BodyKind(bodyKind: str): bool =
    return bodyKind == PrimaryObjectEmitLetCallNoargReturnResultI32Kind

fn PrimaryObjectEmitIsLetCallNoargStrReturnLenI32BodyKind(bodyKind: str): bool =
    return bodyKind == PrimaryObjectEmitLetCallNoargStrReturnLenI32Kind

fn PrimaryObjectEmitIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind: str): bool =
    return bodyKind == PrimaryObjectEmitLetCallNoargStrThenCallArg0ReturnI32Const0Kind

fn PrimaryObjectEmitAsmPath(plan: pobj.PrimaryObjectPlan): str =
    return Fmt([plan.outputPath, ".s"])

fn PrimaryObjectEmitCompileLogPath(plan: pobj.PrimaryObjectPlan): str =
    return Fmt([plan.outputPath, ".compile.log"])

fn PrimaryObjectEmitTargetSupported(plan: pobj.PrimaryObjectPlan): bool =
    return plan.targetTriple == "arm64-apple-darwin" && plan.objectFormat == "macho"

fn PrimaryObjectEmitHasEntryBridge(plan: pobj.PrimaryObjectPlan): bool =
    if len(plan.entryFunctionSymbol) <= 0:
        return false
    if plan.symbolNames.len <= 0:
        return false
    if plan.functionBodyKinds.len != plan.symbolNames.len:
        return false
    for i in 0..<plan.functionBodyKinds.len:
        if plan.functionBodyKinds[i] == "entry_bridge":
            return true
    return false

fn PrimaryObjectEmitEntryBridgeIndex(plan: pobj.PrimaryObjectPlan): int32 =
    if len(plan.entryFunctionSymbol) <= 0:
        return -1
    if plan.symbolNames.len <= 0:
        return -1
    if plan.functionBodyKinds.len != plan.symbolNames.len:
        return -1
    if plan.functionBodyKinds.len == 2:
        if plan.functionBodyKinds[1] == "entry_bridge":
            return 1
    for i in 0..<plan.functionBodyKinds.len:
        if plan.functionBodyKinds[i] == "entry_bridge":
            return i
    return -1

fn PrimaryObjectEmitFunctionCount(plan: pobj.PrimaryObjectPlan): int32 =
    let bridgeIndex = PrimaryObjectEmitEntryBridgeIndex(plan)
    if bridgeIndex >= 0:
        return bridgeIndex
    return plan.symbolNames.len

fn PrimaryObjectEmitExpectedWordsForBodyKind(bodyKind: str): int32 =
    if bodyKind == "return_zero_i32":
        return 2
    if PrimaryObjectEmitIsReturnI32ConstBodyKind(bodyKind):
        return 2
    if bodyKind == "return_call_noarg_i32" ||
       bodyKind == "return_call_arg0_i32" ||
       bodyKind == "return_call_arg0_arg1_i32" ||
       bodyKind == "return_call_arg0_arg1_arg2_i32":
        return 1
    if PrimaryObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
        return 6
    if PrimaryObjectEmitIsLetCallNoargReturnResultI32BodyKind(bodyKind):
        return 5
    if bodyKind == PrimaryObjectEmitLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32Kind:
        return 10
    if PrimaryObjectEmitIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
        return 12
    if PrimaryObjectEmitIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
        return 9
    if bodyKind == "return_str_empty":
        return 4
    if bodyKind == "return_f64_mul_args":
        return 2
    if bodyKind == "return_i32_add_args":
        return 2
    if bodyKind == "return_i32_sub_args":
        return 2
    if bodyKind == "return_i32_mul_args":
        return 2
    if bodyKind == "return_i32_asr_args":
        return 2
    if bodyKind == "return_i32_madd_args":
        return 2
    if bodyKind == pobj.PrimaryI32IfArg0LeZeroConst0Else7BodyKind:
        return 6
    if bodyKind == "str_len_fast_i32":
        return 7
    if bodyKind == "main_f64_mul_check_exit":
        return 22
    return 0

fn PrimaryObjectEmitIsReturnCallBodyKind(bodyKind: str): bool =
    return bodyKind == "return_call_noarg_i32" ||
           bodyKind == "return_call_arg0_i32" ||
           bodyKind == "return_call_arg0_arg1_i32" ||
           bodyKind == "return_call_arg0_arg1_arg2_i32"

fn PrimaryObjectEmitValidateReturnZeroShape(plan: pobj.PrimaryObjectPlan): Result[bool] =
    if !PrimaryObjectEmitTargetSupported(plan):
        return Err[bool](Fmt" primary object emit: unsupported target: {plan.targetTriple}")
    if len(plan.outputPath) <= 0:
        return Err[bool](" primary object emit: missing output path")
    if plan.missingReasons.len > 0:
        return Err[bool](Fmt([" primary object emit: plan has missing reasons: ", pobj.PrimaryObjectPlanReport(plan)]))
    if plan.symbolNames.len <= 0:
        return Err[bool](" primary object emit: missing symbols")
    if len(plan.entryFunctionSymbol) > 0 && plan.symbolNames.len < 2:
        return Err[bool](" primary object emit: executable entry bridge missing")
    if plan.symbolNames.len != plan.functionWordCounts.len ||
       plan.symbolNames.len != plan.functionWordOffsets.len ||
       plan.symbolNames.len != plan.functionBodyKinds.len ||
       plan.symbolNames.len != plan.itemIds.len:
        return Err[bool](" primary object emit: malformed function table")
    var bridgeIndex = PrimaryObjectEmitEntryBridgeIndex(plan)
    if bridgeIndex < 1 && plan.functionBodyKinds.len == 2:
        if plan.functionBodyKinds[0] == "return_zero_i32" ||
           PrimaryObjectEmitIsReturnI32ConstBodyKind(plan.functionBodyKinds[0]):
            if plan.functionBodyKinds[1] == "entry_bridge":
                bridgeIndex = 1
    if len(plan.entryFunctionSymbol) > 0:
        if bridgeIndex < 0:
            return Err[bool](" primary object emit: executable entry bridge missing")
    var functionLimit = plan.symbolNames.len
    if bridgeIndex >= 0:
        functionLimit = bridgeIndex
    if functionLimit <= 0:
        return Err[bool](" primary object emit: missing primary function")
    for i in 0..<functionLimit:
        if len(plan.symbolNames[i]) <= 0:
            return Err[bool](" primary object emit: empty function symbol")
        if i >= plan.functionBodyKinds.len:
            return Err[bool](" primary object emit: missing function body kind")
        let bodyKind = plan.functionBodyKinds[i]
        let expectedFunctionWords = PrimaryObjectEmitExpectedWordsForBodyKind(bodyKind)
        if expectedFunctionWords <= 0:
            return Err[bool](Fmt([" primary object emit: unsupported function body kind kind=",
                                  bodyKind,
                                  " index=",
                                  intToStr(i),
                                  " bridge_index=",
                                  intToStr(bridgeIndex)]))
        if plan.functionWordCounts[i] != expectedFunctionWords:
            return Err[bool](Fmt" primary object emit: unsupported function word count: {intToStr(plan.functionWordCounts[i])}")
        if i > 0:
            let previousIndex = i - 1
            let expectedOffset = plan.functionWordOffsets[previousIndex] + plan.functionWordCounts[previousIndex]
            if plan.functionWordOffsets[i] != expectedOffset:
                return Err[bool](" primary object emit: function word offset mismatch")
    if bridgeIndex >= 0:
        if len(plan.symbolNames[bridgeIndex]) <= 0:
            return Err[bool](" primary object emit: empty entry bridge symbol")
        let lastFunctionIndex = bridgeIndex - 1
        if lastFunctionIndex < 0:
            return Err[bool](" primary object emit: missing primary function before entry bridge")
        let expectedBridgeOffset = plan.functionWordOffsets[lastFunctionIndex] + plan.functionWordCounts[lastFunctionIndex]
        if plan.functionWordOffsets[bridgeIndex] != expectedBridgeOffset:
            return Err[bool](Fmt([" primary object emit: entry bridge word offset mismatch expected=",
                                  intToStr(expectedBridgeOffset),
                                  " actual=",
                                  intToStr(plan.functionWordOffsets[bridgeIndex]),
                                  " symbol_count=",
                                  intToStr(plan.symbolNames.len),
                                  " function_count=",
                                  intToStr(PrimaryObjectEmitFunctionCount(plan))]))
    return Ok[bool](true)

fn PrimaryObjectEmitValidateObjectShape(plan: pobj.PrimaryObjectPlan): Result[bool] =
    if !PrimaryObjectEmitTargetSupported(plan):
        return Err[bool](Fmt" primary object emit: unsupported target: {plan.targetTriple}")
    if len(plan.outputPath) <= 0:
        return Err[bool](" primary object emit: missing output path")
    if plan.missingReasons.len > 0:
        return Err[bool](Fmt([" primary object emit: object plan has missing reasons: ", pobj.PrimaryObjectPlanReport(plan)]))
    if plan.symbolNames.len <= 0:
        return Err[bool](" primary object emit: object plan missing symbols")
    if plan.symbolNames.len != plan.functionWordCounts.len ||
       plan.symbolNames.len != plan.functionWordOffsets.len ||
       plan.symbolNames.len != plan.functionBodyKinds.len ||
       plan.symbolNames.len != plan.itemIds.len:
        return Err[bool](" primary object emit: object plan malformed function table")
    for i in 0..<plan.symbolNames.len:
        if len(plan.symbolNames[i]) <= 0:
            return Err[bool](" primary object emit: object plan empty function symbol")
        let bodyKind = plan.functionBodyKinds[i]
        let expectedFunctionWords = PrimaryObjectEmitExpectedWordsForBodyKind(bodyKind)
        if expectedFunctionWords <= 0:
            return Err[bool](Fmt([" primary object emit: object plan unsupported function body kind kind=",
                                  bodyKind,
                                  " index=",
                                  intToStr(i)]))
        if plan.functionWordCounts[i] != expectedFunctionWords:
            return Err[bool](Fmt" primary object emit: object plan unsupported function word count: {intToStr(plan.functionWordCounts[i])}")
        if i > 0:
            let previousIndex = i - 1
            let expectedOffset = plan.functionWordOffsets[previousIndex] + plan.functionWordCounts[previousIndex]
            if plan.functionWordOffsets[i] != expectedOffset:
                return Err[bool](" primary object emit: object plan function word offset mismatch")
    return Ok[bool](true)

fn PrimaryObjectEmitReturnZeroFunctionAsm(symbolName: str, ordinal: int32): str =
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  mov w0, #0\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return out

