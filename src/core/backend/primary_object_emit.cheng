fn PrimaryObjectEmitI32IfArg0LeZeroConstElseFunctionAsm(symbolName: str,
                                                         ordinal: int32,
                                                         thenImm: int32,
                                                         elseImm: int32): str =
    let labelOrdinal = intToStr(ordinal)
    let elseLabel = Fmt(["L_cheng_if_arg0_gt_zero_", labelOrdinal])
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  cmp w0, #0\n"])
    out = Fmt([out, Fmt"  b.gt {elseLabel}\n"])
    out = Fmt([out, Fmt"  mov w0, #{intToStr(thenImm)}\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"{elseLabel}:\n"])
    out = Fmt([out, Fmt"  mov w0, #{intToStr(elseImm)}\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return out

fn PrimaryObjectEmitStrLenFastFunctionAsm(symbolName: str, ordinal: int32): str =
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  ldr x9, [x0]\n"])
    out = Fmt([out, "  ldr w0, [x0, #8]\n"])
    out = Fmt([out, "  cmp x9, #0\n"])
    out = Fmt([out, "  csel w0, wzr, w0, eq\n"])
    out = Fmt([out, "  cmp w0, #0\n"])
    out = Fmt([out, "  csel w0, wzr, w0, le\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return out

fn PrimaryObjectEmitReturnStrEmptyFunctionAsm(symbolName: str, ordinal: int32): str =
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  str xzr, [x8]\n"])
    out = Fmt([out, "  str xzr, [x8, #8]\n"])
    out = Fmt([out, "  str xzr, [x8, #16]\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return out

fn PrimaryObjectEmitF64MulCheckExitFunctionAsm(symbolName: str, ordinal: int32): str =
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  movz x0, #0x0000\n"])
    out = Fmt([out, "  movk x0, #0x0000, lsl #16\n"])
    out = Fmt([out, "  movk x0, #0x0000, lsl #32\n"])
    out = Fmt([out, "  movk x0, #0x3ff8, lsl #48\n"])
    out = Fmt([out, "  fmov d0, x0\n"])
    out = Fmt([out, "  movz x1, #0x0000\n"])
    out = Fmt([out, "  movk x1, #0x0000, lsl #16\n"])
    out = Fmt([out, "  movk x1, #0x0000, lsl #32\n"])
    out = Fmt([out, "  movk x1, #0x4000, lsl #48\n"])
    out = Fmt([out, "  fmov d1, x1\n"])
    out = Fmt([out, "  fmul d0, d0, d1\n"])
    out = Fmt([out, "  movz x2, #0x0000\n"])
    out = Fmt([out, "  movk x2, #0x0000, lsl #16\n"])
    out = Fmt([out, "  movk x2, #0x0000, lsl #32\n"])
    out = Fmt([out, "  movk x2, #0x4008, lsl #48\n"])
    out = Fmt([out, "  fmov d2, x2\n"])
    out = Fmt([out, "  fcmp d0, d2\n"])
    out = Fmt([out, Fmt"  b.ne L_cheng_f64_mul_check_fail_{labelOrdinal}\n"])
    out = Fmt([out, "  mov w0, #0\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_f64_mul_check_fail_{labelOrdinal}:\n"])
    out = Fmt([out, "  mov w0, #1\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return out

fn PrimaryObjectEmitRelocTargetForItem(plan: pobj.PrimaryObjectPlan,
                                        itemId: int32): str =
    for i in 0..<plan.relocSourceItemIds.len:
        if plan.relocSourceItemIds[i] == itemId:
            return plan.relocTargetSymbols[i]
    return ""

fn PrimaryObjectEmitRelocTargetForItemOrdinal(plan: pobj.PrimaryObjectPlan,
                                               itemId: int32,
                                               ordinal: int32): str =
    var seen: int32
    for i in 0..<plan.relocSourceItemIds.len:
        if plan.relocSourceItemIds[i] != itemId:
            continue
        if seen == ordinal:
            return plan.relocTargetSymbols[i]
        seen = seen + 1
    return ""

fn PrimaryObjectEmitSymbolInPlan(plan: pobj.PrimaryObjectPlan,
                                  symbolName: str): bool =
    for i in 0..<plan.symbolNames.len:
        if plan.symbolNames[i] == symbolName:
            return true
    return false

fn PrimaryObjectEmitReturnCallFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                           functionIndex: int32,
                                           ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing return-call target")
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = Fmt([out, Fmt".extern {targetSymbol}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, Fmt"  b {targetSymbol}\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return Ok[str](out)

fn PrimaryObjectEmitLetCallNoargReturnI32ConstFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                           functionIndex: int32,
                                                           ordinal: int32,
                                                           imm: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing let-call target")
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = Fmt([out, Fmt".extern {targetSymbol}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  stp x29, x30, [sp, #-16]!\n"])
    out = Fmt([out, "  mov x29, sp\n"])
    out = Fmt([out, Fmt"  bl {targetSymbol}\n"])
    out = Fmt([out, Fmt"  mov w0, #{intToStr(imm)}\n"])
    out = Fmt([out, "  ldp x29, x30, [sp], #16\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return Ok[str](out)

fn PrimaryObjectEmitLetCallNoargReturnResultI32FunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                            functionIndex: int32,
                                                            ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing let-call result target")
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = Fmt([out, Fmt".extern {targetSymbol}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  stp x29, x30, [sp, #-16]!\n"])
    out = Fmt([out, "  mov x29, sp\n"])
    out = Fmt([out, Fmt"  bl {targetSymbol}\n"])
    out = Fmt([out, "  ldp x29, x30, [sp], #16\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return Ok[str](out)

fn PrimaryObjectEmitLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32FunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                                                     functionIndex: int32,
                                                                                     ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing let-call guarded result target")
    let labelOrdinal = intToStr(ordinal)
    let elseLabel = Fmt(["L_cheng_let_call_i32_result_gt_zero_", labelOrdinal])
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = Fmt([out, Fmt".extern {targetSymbol}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  stp x29, x30, [sp, #-16]!\n"])
    out = Fmt([out, "  mov x29, sp\n"])
    out = Fmt([out, Fmt"  bl {targetSymbol}\n"])
    out = Fmt([out, "  cmp w0, #0\n"])
    out = Fmt([out, Fmt"  b.gt {elseLabel}\n"])
    out = Fmt([out, "  mov w0, #0\n"])
    out = Fmt([out, "  ldp x29, x30, [sp], #16\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"{elseLabel}:\n"])
    out = Fmt([out, "  ldp x29, x30, [sp], #16\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return Ok[str](out)

fn PrimaryObjectEmitLetCallNoargStrReturnLenI32FunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                            functionIndex: int32,
                                                            ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing let-call str result target")
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = Fmt([out, Fmt".extern {targetSymbol}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  stp x29, x30, [sp, #-48]!\n"])
    out = Fmt([out, "  mov x29, sp\n"])
    out = Fmt([out, "  add x8, sp, #16\n"])
    out = Fmt([out, Fmt"  bl {targetSymbol}\n"])
    out = Fmt([out, "  ldr x9, [sp, #16]\n"])
    out = Fmt([out, "  ldr w0, [sp, #24]\n"])
    out = Fmt([out, "  cmp x9, #0\n"])
    out = Fmt([out, "  csel w0, wzr, w0, eq\n"])
    out = Fmt([out, "  cmp w0, #0\n"])
    out = Fmt([out, "  csel w0, wzr, w0, le\n"])
    out = Fmt([out, "  ldp x29, x30, [sp], #48\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return Ok[str](out)

fn PrimaryObjectEmitLetCallNoargStrThenCallArg0ReturnI32Const0FunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                                           functionIndex: int32,
                                                                           ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
    let secondTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 1)
    if len(targetSymbol) <= 0:
        return Err[str](" primary object emit: missing first let-call str target")
    if len(secondTargetSymbol) <= 0:
        return Err[str](" primary object emit: missing second let-call str consumer target")
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {symbolName}\n"])
    if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
        out = Fmt([out, Fmt".extern {targetSymbol}\n"])
    if !PrimaryObjectEmitSymbolInPlan(plan, secondTargetSymbol):
        out = Fmt([out, Fmt".extern {secondTargetSymbol}\n"])
    out = Fmt([out, Fmt"{symbolName}:\n"])
    out = Fmt([out, "  stp x29, x30, [sp, #-48]!\n"])
    out = Fmt([out, "  mov x29, sp\n"])
    out = Fmt([out, "  add x8, sp, #16\n"])
    out = Fmt([out, Fmt"  bl {targetSymbol}\n"])
    out = Fmt([out, "  add x0, sp, #16\n"])
    out = Fmt([out, Fmt"  bl {secondTargetSymbol}\n"])
    out = Fmt([out, "  mov w0, #0\n"])
    out = Fmt([out, "  ldp x29, x30, [sp], #48\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return Ok[str](out)

fn PrimaryObjectEmitEntryBridgeAsm(plan: pobj.PrimaryObjectPlan,
                                    bridgeSymbol: str,
                                    entrySymbol: str,
                                    ordinal: int32): str =
    let setCmdLine = pobj.PrimaryTargetSymbolName(plan.targetTriple, "__cheng_setCmdLine")
    let lineMap = pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_register_line_map_from_argv0")
    let profileFlush = pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_debug_profile_flush_from_argv0")
    let labelOrdinal = intToStr(ordinal)
    var out = ""
    out = Fmt([out, Fmt".globl {bridgeSymbol}\n"])
    out = Fmt([out, Fmt".extern {setCmdLine}\n"])
    out = Fmt([out, Fmt".extern {lineMap}\n"])
    out = Fmt([out, Fmt".extern {profileFlush}\n"])
    out = Fmt([out, Fmt"{bridgeSymbol}:\n"])
    out = Fmt([out, "  sub sp, sp, #32\n"])
    out = Fmt([out, "  stp x0, x1, [sp]\n"])
    out = Fmt([out, "  str x30, [sp, #24]\n"])
    out = Fmt([out, Fmt"  bl {setCmdLine}\n"])
    out = Fmt([out, "  ldr x1, [sp, #8]\n"])
    out = Fmt([out, "  ldr x0, [x1]\n"])
    out = Fmt([out, Fmt"  bl {lineMap}\n"])
    out = Fmt([out, "  ldp x0, x1, [sp]\n"])
    out = Fmt([out, Fmt"  bl {entrySymbol}\n"])
    out = Fmt([out, "  str w0, [sp, #16]\n"])
    out = Fmt([out, "  ldr x1, [sp, #8]\n"])
    out = Fmt([out, "  ldr x0, [x1]\n"])
    out = Fmt([out, Fmt"  bl {profileFlush}\n"])
    out = Fmt([out, "  ldr w0, [sp, #16]\n"])
    out = Fmt([out, "  ldr x30, [sp, #24]\n"])
    out = Fmt([out, "  add sp, sp, #32\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"])
    return out

fn PrimaryObjectEmitObjectAsmText(plan: pobj.PrimaryObjectPlan): Result[str] =
    let validRes = PrimaryObjectEmitValidateObjectShape(plan)
    if !IsOk(validRes):
        return Err[str](Error(validRes))
    var chunks: str[]
    add(chunks, ".text\n.p2align 2\n")
    for i in 0..<plan.symbolNames.len:
        let bodyKind = plan.functionBodyKinds[i]
        if bodyKind == "return_zero_i32":
            add(chunks, PrimaryObjectEmitReturnZeroFunctionAsm(plan.symbolNames[i], i))
        elif PrimaryObjectEmitIsReturnI32ConstBodyKind(bodyKind):
            let imm = Value(PrimaryObjectEmitParseReturnI32ConstBodyKind(bodyKind))
            add(chunks, PrimaryObjectEmitReturnI32ConstFunctionAsm(plan.symbolNames[i], i, imm))
        elif bodyKind == "return_f64_mul_args":
            add(chunks, PrimaryObjectEmitF64MulArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_add_args":
            add(chunks, PrimaryObjectEmitI32AddArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_sub_args":
            add(chunks, PrimaryObjectEmitI32SubArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_mul_args":
            add(chunks, PrimaryObjectEmitI32MulArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_asr_args":
            add(chunks, PrimaryObjectEmitI32AsrArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_madd_args":
            let labelOrdinal = intToStr(i)
            add(chunks, Fmt".globl {plan.symbolNames[i]}\n")
            add(chunks, Fmt"{plan.symbolNames[i]}:\n")
            add(chunks, "  madd w0, w0, w1, w2\n")
            add(chunks, "  ret\n")
            add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
        elif bodyKind == pobj.PrimaryI32IfArg0LeZeroConst0Else7BodyKind:
            add(chunks, PrimaryObjectEmitI32IfArg0LeZeroConstElseFunctionAsm(plan.symbolNames[i], i, 0, 7))
        elif bodyKind == "str_len_fast_i32":
            add(chunks, PrimaryObjectEmitStrLenFastFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_str_empty":
            add(chunks, PrimaryObjectEmitReturnStrEmptyFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "main_f64_mul_check_exit":
            add(chunks, PrimaryObjectEmitF64MulCheckExitFunctionAsm(plan.symbolNames[i], i))
        elif PrimaryObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
            let imm = Value(PrimaryObjectEmitParseLetCallNoargReturnI32ConstBodyKind(bodyKind))
            let callAsmRes = PrimaryObjectEmitLetCallNoargReturnI32ConstFunctionAsm(plan, i, i, imm)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsLetCallNoargReturnResultI32BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargReturnResultI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif bodyKind == PrimaryObjectEmitLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32Kind:
            let callAsmRes = PrimaryObjectEmitLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargStrReturnLenI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargStrThenCallArg0ReturnI32Const0FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsReturnCallBodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitReturnCallFunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        else:
            return Err[str](" primary object emit: object plan unsupported function body kind")
    add(chunks, ".subsections_via_symbols\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitAsmText(plan: pobj.PrimaryObjectPlan): Result[str] =
    let validRes = PrimaryObjectEmitValidateReturnZeroShape(plan)
    if !IsOk(validRes):
        return Err[str](Error(validRes))
    var bridgeIndex = PrimaryObjectEmitEntryBridgeIndex(plan)
    if bridgeIndex < 1 && plan.functionBodyKinds.len == 2:
        if plan.functionBodyKinds[0] == "return_zero_i32" ||
           PrimaryObjectEmitIsReturnI32ConstBodyKind(plan.functionBodyKinds[0]):
            if plan.functionBodyKinds[1] == "entry_bridge":
                bridgeIndex = 1
    var functionLimit = plan.symbolNames.len
    if bridgeIndex >= 0:
        functionLimit = bridgeIndex
    var chunks: str[]
    add(chunks, ".text\n.p2align 2\n")
    for i in 0..<functionLimit:
        let bodyKind = plan.functionBodyKinds[i]
        if bodyKind == "return_zero_i32":
            add(chunks, PrimaryObjectEmitReturnZeroFunctionAsm(plan.symbolNames[i], i))
        elif PrimaryObjectEmitIsReturnI32ConstBodyKind(bodyKind):
            let imm = Value(PrimaryObjectEmitParseReturnI32ConstBodyKind(bodyKind))
            add(chunks, PrimaryObjectEmitReturnI32ConstFunctionAsm(plan.symbolNames[i], i, imm))
        elif bodyKind == "return_f64_mul_args":
            add(chunks, PrimaryObjectEmitF64MulArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_add_args":
            add(chunks, PrimaryObjectEmitI32AddArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_sub_args":
            add(chunks, PrimaryObjectEmitI32SubArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_mul_args":
            add(chunks, PrimaryObjectEmitI32MulArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_asr_args":
            add(chunks, PrimaryObjectEmitI32AsrArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_i32_madd_args":
            let labelOrdinal = intToStr(i)
            add(chunks, Fmt".globl {plan.symbolNames[i]}\n")
            add(chunks, Fmt"{plan.symbolNames[i]}:\n")
            add(chunks, "  madd w0, w0, w1, w2\n")
            add(chunks, "  ret\n")
            add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
        elif bodyKind == pobj.PrimaryI32IfArg0LeZeroConst0Else7BodyKind:
            add(chunks, PrimaryObjectEmitI32IfArg0LeZeroConstElseFunctionAsm(plan.symbolNames[i], i, 0, 7))
        elif bodyKind == "str_len_fast_i32":
            add(chunks, PrimaryObjectEmitStrLenFastFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "return_str_empty":
            add(chunks, PrimaryObjectEmitReturnStrEmptyFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == "main_f64_mul_check_exit":
            add(chunks, PrimaryObjectEmitF64MulCheckExitFunctionAsm(plan.symbolNames[i], i))
        elif PrimaryObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
            let imm = Value(PrimaryObjectEmitParseLetCallNoargReturnI32ConstBodyKind(bodyKind))
            let callAsmRes = PrimaryObjectEmitLetCallNoargReturnI32ConstFunctionAsm(plan, i, i, imm)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsLetCallNoargReturnResultI32BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargReturnResultI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargStrReturnLenI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargStrThenCallArg0ReturnI32Const0FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsReturnCallBodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitReturnCallFunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        else:
            return Err[str](" primary object emit: unsupported function body kind")
    if bridgeIndex >= 0:
        var entryTargetSymbol = plan.entryFunctionSymbol
        if len(entryTargetSymbol) <= 0:
            entryTargetSymbol = plan.symbolNames[0]
        let bridgeAsm = PrimaryObjectEmitEntryBridgeAsm(plan,
                                                        plan.symbolNames[bridgeIndex],
                                                        entryTargetSymbol,
                                                        bridgeIndex)
        add(chunks, bridgeAsm)
    add(chunks, ".subsections_via_symbols\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitCompileArgv(plan: pobj.PrimaryObjectPlan,
                                 asmPath: str): Result[str[]] =
    let validRes = PrimaryObjectEmitValidateReturnZeroShape(plan)
    if !IsOk(validRes):
        return Err[str[]](Error(validRes))
    var argv: str[]
    add(argv, "-arch")
    add(argv, "arm64")
    add(argv, "-c")
    add(argv, asmPath)
    add(argv, "-o")
    add(argv, plan.outputPath)
    return Ok[str[]](argv)

fn PrimaryObjectEmitObjectCompileArgv(plan: pobj.PrimaryObjectPlan,
                                       asmPath: str): Result[str[]] =
    let validRes = PrimaryObjectEmitValidateObjectShape(plan)
    if !IsOk(validRes):
        return Err[str[]](Error(validRes))
    var argv: str[]
    add(argv, "-arch")
    add(argv, "arm64")
    add(argv, "-c")
    add(argv, asmPath)
    add(argv, "-o")
    add(argv, plan.outputPath)
    return Ok[str[]](argv)

fn PrimaryObjectEmitRunObjectLogged(rootDir: str,
                                     label: str,
                                     plan: pobj.PrimaryObjectPlan): Result[PrimaryObjectEmitResult] =
    let asmRes = PrimaryObjectEmitObjectAsmText(plan)
    if !IsOk(asmRes):
        return Err[PrimaryObjectEmitResult](Error(asmRes))
    let asmPath = PrimaryObjectEmitAsmPath(plan)
    let compileLogPath = PrimaryObjectEmitCompileLogPath(plan)
    let asmText = Value(asmRes)
    if !chengpath.WriteTextFile(rootDir, asmPath, asmText):
        return Err[PrimaryObjectEmitResult](Fmt([" primary object emit: failed to write object asm: ", asmPath]))
    let argvRes = PrimaryObjectEmitObjectCompileArgv(plan, asmPath)
    if !IsOk(argvRes):
        return Err[PrimaryObjectEmitResult](Error(argvRes))
    let argv = Value(argvRes)
    let commandText = hostos.OsHostProcessCommandText("cc", argv, [])
    let run = hostops.RunProgramLogged(rootDir,
                                       label,
                                       "cc",
                                       argv,
                                       [],
                                       rootDir,
                                       0,
                                       compileLogPath)
    var out: PrimaryObjectEmitResult
    out.asmPath = asmPath
    out.objectPath = plan.outputPath
    out.compileLogPath = compileLogPath
    out.commandText = commandText
    out.exitCode = run.exitCode
    out.asmText = asmText
    out.compilerOutput = run.output
    if run.exitCode != 0:
        return Err[PrimaryObjectEmitResult](Fmt" primary object emit: object cc failed rc={intToStr(run.exitCode)} command={commandText}")
    if !chengpath.FileExistsNonEmpty(rootDir, plan.outputPath):
        return Err[PrimaryObjectEmitResult](Fmt([" primary object emit: missing object output: ", plan.outputPath]))
    return Ok[PrimaryObjectEmitResult](out)

fn PrimaryObjectEmitStandaloneEntryBodyKind(plan: pobj.PrimaryObjectPlan): str =
    let functionLimit = PrimaryObjectEmitFunctionCount(plan)
    if len(plan.entryFunctionSymbol) > 0:
        for i in 0..<functionLimit:
            if plan.symbolNames[i] == plan.entryFunctionSymbol:
                return plan.functionBodyKinds[i]
        return ""
    if functionLimit > 0:
        return plan.functionBodyKinds[0]
    return ""

fn PrimaryObjectEmitValidateStandaloneMainShape(plan: pobj.PrimaryObjectPlan): Result[bool] =
    if !PrimaryObjectEmitTargetSupported(plan):
        return Err[bool](Fmt" primary object emit: unsupported standalone target: {plan.targetTriple}")
    if len(plan.outputPath) <= 0:
        return Err[bool](" primary object emit: missing standalone output path")
    if plan.missingReasons.len > 0:
        return Err[bool](" primary object emit: standalone plan has missing reasons")
    if plan.symbolNames.len < 1 || plan.functionBodyKinds.len < 1:
        return Err[bool](" primary object emit: standalone function missing")
    if plan.symbolNames.len != plan.functionBodyKinds.len:
        return Err[bool](" primary object emit: standalone malformed function table")
    let entryBodyKind = PrimaryObjectEmitStandaloneEntryBodyKind(plan)
    if entryBodyKind != "return_zero_i32" &&
       !PrimaryObjectEmitIsReturnI32ConstBodyKind(entryBodyKind):
        return Err[bool](" primary object emit: standalone only supports constant i32 entry")
    return Ok[bool](true)

fn PrimaryObjectEmitStandaloneCompileArgv(plan: pobj.PrimaryObjectPlan,
                                           asmPath: str): Result[str[]] =
    let validRes = PrimaryObjectEmitValidateStandaloneMainShape(plan)
    if !IsOk(validRes):
        return Err[str[]](Error(validRes))
    var argv: str[]
    add(argv, "-arch")
    add(argv, "arm64")
    add(argv, "-c")
    add(argv, asmPath)
    add(argv, "-o")
    add(argv, plan.outputPath)
    return Ok[str[]](argv)

fn PrimaryObjectEmitStandaloneMainAsmText(plan: pobj.PrimaryObjectPlan): Result[str] =
    let validRes = PrimaryObjectEmitValidateStandaloneMainShape(plan)
    if !IsOk(validRes):
        return Err[str](Error(validRes))
    let entryBodyKind = PrimaryObjectEmitStandaloneEntryBodyKind(plan)
    var imm: int32
    if PrimaryObjectEmitIsReturnI32ConstBodyKind(entryBodyKind):
        imm = Value(PrimaryObjectEmitParseReturnI32ConstBodyKind(entryBodyKind))
    var out = ".text\n.p2align 2\n"
    out = Fmt([out, ".globl _main\n"])
    out = Fmt([out, "_main:\n"])
    out = Fmt([out, Fmt"  mov w0, #{intToStr(imm)}\n"])
    out = Fmt([out, "  ret\n"])
    out = Fmt([out, "L_cheng_embedded_line_map_end_0:\n"])
    out = Fmt([out, ".subsections_via_symbols\n"])
    return Ok[str](out)

fn PrimaryObjectEmitRunStandaloneMainLogged(rootDir: str,
                                             label: str,
                                             plan: pobj.PrimaryObjectPlan): Result[PrimaryObjectEmitResult] =
    let asmRes = PrimaryObjectEmitStandaloneMainAsmText(plan)
    if !IsOk(asmRes):
        return Err[PrimaryObjectEmitResult](Error(asmRes))
    let asmPath = PrimaryObjectEmitAsmPath(plan)
    let compileLogPath = PrimaryObjectEmitCompileLogPath(plan)
    let asmText = Value(asmRes)
    if !chengpath.WriteTextFile(rootDir, asmPath, asmText):
        return Err[PrimaryObjectEmitResult](Fmt([" primary object emit: failed to write standalone asm: ", asmPath]))
    let argvRes = PrimaryObjectEmitStandaloneCompileArgv(plan, asmPath)
    if !IsOk(argvRes):
        return Err[PrimaryObjectEmitResult](Error(argvRes))
    let argv = Value(argvRes)
    let commandText = hostos.OsHostProcessCommandText("cc", argv, [])
    let run = hostops.RunProgramLogged(rootDir,
                                       label,
                                       "cc",
                                       argv,
                                       [],
                                       rootDir,
                                       0,
                                       compileLogPath)
    var out: PrimaryObjectEmitResult
    out.asmPath = asmPath
    out.objectPath = plan.outputPath
    out.compileLogPath = compileLogPath
    out.commandText = commandText
    out.exitCode = run.exitCode
    out.asmText = asmText
    out.compilerOutput = run.output
    if run.exitCode != 0:
        return Err[PrimaryObjectEmitResult](Fmt" primary object emit: standalone cc failed rc={intToStr(run.exitCode)} command={commandText}")
    if !chengpath.FileExistsNonEmpty(rootDir, plan.outputPath):
        return Err[PrimaryObjectEmitResult](Fmt([" primary object emit: missing standalone output object: ", plan.outputPath]))
    return Ok[PrimaryObjectEmitResult](out)

fn PrimaryObjectEmitRunLogged(rootDir: str,
                               label: str,
                               plan: pobj.PrimaryObjectPlan): Result[PrimaryObjectEmitResult] =
    let asmRes = PrimaryObjectEmitAsmText(plan)
    if !IsOk(asmRes):
        return Err[PrimaryObjectEmitResult](Error(asmRes))
    let asmPath = PrimaryObjectEmitAsmPath(plan)
    let compileLogPath = PrimaryObjectEmitCompileLogPath(plan)
    let asmText = Value(asmRes)
    if !chengpath.WriteTextFile(rootDir, asmPath, asmText):
        return Err[PrimaryObjectEmitResult](Fmt([" primary object emit: failed to write asm: ", asmPath]))
    let argvRes = PrimaryObjectEmitCompileArgv(plan, asmPath)
    if !IsOk(argvRes):
        return Err[PrimaryObjectEmitResult](Error(argvRes))
    let argv = Value(argvRes)
    let commandText = hostos.OsHostProcessCommandText("cc", argv, [])
    let run = hostops.RunProgramLogged(rootDir,
                                       label,
                                       "cc",
                                       argv,
                                       [],
                                       rootDir,
                                       0,
                                       compileLogPath)
    var out: PrimaryObjectEmitResult
    out.asmPath = asmPath
    out.objectPath = plan.outputPath
    out.compileLogPath = compileLogPath
    out.commandText = commandText
    out.exitCode = run.exitCode
    out.asmText = asmText
    out.compilerOutput = run.output
    if run.exitCode != 0:
        return Err[PrimaryObjectEmitResult](Fmt" primary object emit: cc failed rc={intToStr(run.exitCode)} command={commandText}")
    if !chengpath.FileExistsNonEmpty(rootDir, plan.outputPath):
        return Err[PrimaryObjectEmitResult](Fmt([" primary object emit: missing output object: ", plan.outputPath]))
    return Ok[PrimaryObjectEmitResult](out)
