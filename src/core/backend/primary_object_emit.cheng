fn PrimaryObjectEmitStrI32GuardCallArg0ThenDispatchReturnI32FunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                                         functionIndex: int32,
                                                                         ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let strTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 0)
    let useTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 1)
    let countTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 2)
    let guardUseTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 3)
    let dispatchTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 4)
    if len(strTargetSymbol) <= 0 ||
       len(useTargetSymbol) <= 0 ||
       len(countTargetSymbol) <= 0 ||
       len(guardUseTargetSymbol) <= 0 ||
       len(dispatchTargetSymbol) <= 0:
        return Err[str](" primary object emit: missing str i32 guard dispatch target")
    let labelOrdinal = IntToStr(ordinal)
    let dispatchLabel = Fmt"L_cheng_body_ir_str_i32_guard_dispatch_{labelOrdinal}"
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, strTargetSymbol):
        out = strutil.Join([out, Fmt".extern {strTargetSymbol}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, useTargetSymbol):
        out = strutil.Join([out, Fmt".extern {useTargetSymbol}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, countTargetSymbol):
        out = strutil.Join([out, Fmt".extern {countTargetSymbol}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, guardUseTargetSymbol):
        out = strutil.Join([out, Fmt".extern {guardUseTargetSymbol}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, dispatchTargetSymbol):
        out = strutil.Join([out, Fmt".extern {dispatchTargetSymbol}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    out = strutil.Join([out, "  stp x29, x30, [sp, #-48]!\n"], "")
    out = strutil.Join([out, "  mov x29, sp\n"], "")
    out = strutil.Join([out, "  add x8, sp, #16\n"], "")
    out = strutil.Join([out, Fmt"  bl {strTargetSymbol}\n"], "")
    out = strutil.Join([out, "  add x0, sp, #16\n"], "")
    out = strutil.Join([out, Fmt"  bl {useTargetSymbol}\n"], "")
    out = strutil.Join([out, Fmt"  bl {countTargetSymbol}\n"], "")
    out = strutil.Join([out, "  cmp w0, #0\n"], "")
    out = strutil.Join([out, Fmt"  b.gt {dispatchLabel}\n"], "")
    out = strutil.Join([out, "  add x0, sp, #16\n"], "")
    out = strutil.Join([out, Fmt"  bl {guardUseTargetSymbol}\n"], "")
    out = strutil.Join([out, "  mov w0, #0\n"], "")
    out = strutil.Join([out, "  ldp x29, x30, [sp], #48\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"{dispatchLabel}:\n"], "")
    out = strutil.Join([out, "  mov w1, w0\n"], "")
    out = strutil.Join([out, "  add x0, sp, #16\n"], "")
    out = strutil.Join([out, Fmt"  bl {dispatchTargetSymbol}\n"], "")
    out = strutil.Join([out, "  ldp x29, x30, [sp], #48\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitI32GuardHelpThenCommandReturnFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                              functionIndex: int32,
                                                              ordinal: int32): Result[str] =
    let symbolName = plan.symbolNames[functionIndex]
    let countTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 0)
    let helpTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 1)
    let commandTargetSymbol = PrimaryObjectEmitRelocTargetForItemOrdinal(plan, plan.itemIds[functionIndex], 2)
    if len(countTargetSymbol) <= 0:
        return Err[str](" primary object emit: missing i32 guard help count target")
    if len(helpTargetSymbol) <= 0:
        return Err[str](" primary object emit: missing i32 guard help target")
    if len(commandTargetSymbol) <= 0:
        return Err[str](" primary object emit: missing i32 guard help command target")
    let labelOrdinal = IntToStr(ordinal)
    let commandLabel = Fmt"L_cheng_body_ir_i32_guard_help_command_{labelOrdinal}"
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, countTargetSymbol):
        out = strutil.Join([out, Fmt".extern {countTargetSymbol}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, helpTargetSymbol):
        out = strutil.Join([out, Fmt".extern {helpTargetSymbol}\n"], "")
    if !PrimaryObjectEmitSymbolInPlan(plan, commandTargetSymbol):
        out = strutil.Join([out, Fmt".extern {commandTargetSymbol}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    out = strutil.Join([out, "  stp x29, x30, [sp, #-16]!\n"], "")
    out = strutil.Join([out, "  mov x29, sp\n"], "")
    out = strutil.Join([out, Fmt"  bl {countTargetSymbol}\n"], "")
    out = strutil.Join([out, "  cmp w0, #0\n"], "")
    out = strutil.Join([out, Fmt"  b.gt {commandLabel}\n"], "")
    out = strutil.Join([out, Fmt"  bl {helpTargetSymbol}\n"], "")
    out = strutil.Join([out, "  ldp x29, x30, [sp], #16\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"{commandLabel}:\n"], "")
    out = strutil.Join([out, Fmt"  bl {commandTargetSymbol}\n"], "")
    out = strutil.Join([out, "  ldp x29, x30, [sp], #16\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitLeafBodyIRFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                           functionIndex: int32,
                                           ordinal: int32): Result[str] =
    if functionIndex < 0 ||
       functionIndex >= plan.functionBodyIRs.len ||
       functionIndex >= plan.symbolNames.len:
        return Err[str](" primary object emit: missing body ir function")
    let bodyIR = plan.functionBodyIRs[functionIndex]
    let symbolName = plan.symbolNames[functionIndex]
    if pobj.PrimaryBodyIrIsCallCfgReturnInt32(bodyIR):
        return PrimaryObjectEmitCallCfgReturnInt32FunctionAsm(plan,
                                                              functionIndex,
                                                              ordinal)
    if pobj.PrimaryBodyIrIsResultRequestDispatch(bodyIR):
        return PrimaryObjectEmitResultRequestDispatchFunctionAsm(plan,
                                                                 functionIndex,
                                                                 ordinal)
    if bodyIR.ops.len == 1:
        let returnOp = bodyIR.ops[0]
        if returnOp.kind != coreir.BodyOpReturnTag:
            return Err[str](" primary object emit: body ir leaf unsupported")
        if returnOp.operands.len < 3:
            return Err[str](" primary object emit: body ir return operands missing")
        if returnOp.operands[0] != coreir.LocalI32Tag:
            return Err[str](" primary object emit: body ir return type unsupported")
        if returnOp.operands[1] != int32(texpr.TypedExprIrOpParamRef):
            return Err[str](" primary object emit: body ir return source unsupported")
        let paramSlot = returnOp.operands[2]
        if paramSlot == 0:
            return Ok[str](PrimaryObjectEmitReturnI32Arg0FunctionAsm(symbolName, ordinal))
        if paramSlot == 1:
            return Ok[str](PrimaryObjectEmitReturnI32Arg1FunctionAsm(symbolName, ordinal))
        if paramSlot == 2:
            return Ok[str](PrimaryObjectEmitReturnI32Arg2FunctionAsm(symbolName, ordinal))
        if paramSlot == 3:
            return Ok[str](PrimaryObjectEmitReturnI32Arg3FunctionAsm(symbolName, ordinal))
        return Err[str](" primary object emit: body ir return param unsupported")
    if bodyIR.ops.len == 3:
        if pobj.PrimaryBodyIrIsStrCallConstThenCallArg0ReturnI32(bodyIR):
            return PrimaryObjectEmitStrCallConstThenCallArg0ReturnI32FunctionAsm(plan, functionIndex, ordinal)
        if pobj.PrimaryBodyIrIsStrLetCallThenCallArg0ReturnI32(bodyIR):
            return PrimaryObjectEmitStrLetCallThenCallArg0ReturnI32FunctionAsm(plan, functionIndex, ordinal)
        if pobj.PrimaryBodyIrIsArg0I32LetCallThenReturnCallArg0Arg1(bodyIR):
            return PrimaryObjectEmitArg0I32LetCallThenReturnCallArg0Arg1FunctionAsm(plan, functionIndex, ordinal)
        if pobj.PrimaryBodyIrIsArg0AggregateCallThenReturnCallArg0Arg1(bodyIR):
            return PrimaryObjectEmitArg0AggregateCallThenReturnCallArg0Arg1FunctionAsm(plan, functionIndex, ordinal)
        if pobj.PrimaryBodyIrIsI32LetCallThenReturnCallArg0(bodyIR):
            return PrimaryObjectEmitI32LetCallThenReturnCallArg0FunctionAsm(plan, functionIndex, ordinal)
        return Err[str](" primary object emit: body ir call chain unsupported")
    if bodyIR.ops.len == 4:
        if pobj.PrimaryBodyIrIsI32TwoCallGuardFirstReturn(bodyIR):
            return PrimaryObjectEmitI32TwoCallGuardFirstReturnFunctionAsm(plan, functionIndex, ordinal)
        if pobj.PrimaryBodyIrIsI32GuardThenCommandReturn(bodyIR):
            return PrimaryObjectEmitI32GuardThenCommandReturnFunctionAsm(plan, functionIndex, ordinal)
        if pobj.PrimaryBodyIrIsI32GuardHelpThenCommandReturn(bodyIR):
            return PrimaryObjectEmitI32GuardHelpThenCommandReturnFunctionAsm(plan, functionIndex, ordinal)
        if bodyIR.callSequence.len != 1:
            return Err[str](" primary object emit: body ir pointer guard call missing")
        let callOp = bodyIR.ops[0]
        let branchOp = bodyIR.ops[1]
        let loadOp = bodyIR.ops[2]
        let returnOp = bodyIR.ops[3]
        if callOp.kind != coreir.BodyOpCallTag ||
           branchOp.kind != coreir.BodyOpBranchTag ||
           loadOp.kind != coreir.BodyOpLoadLocalTag ||
           returnOp.kind != coreir.BodyOpReturnTag:
            return Err[str](" primary object emit: body ir pointer guard unsupported")
        if branchOp.operands.len < 3 ||
           loadOp.operands.len < 3 ||
           returnOp.operands.len < 1:
            return Err[str](" primary object emit: body ir pointer guard operands missing")
        let resultSlot = bodyIR.callSequence[0].resultSlot
        if branchOp.operands[0] != coreir.BodyBranchIfLocalNilReturnI32ConstTag ||
           branchOp.operands[1] != resultSlot ||
           branchOp.operands[2] != 0 ||
           loadOp.operands[0] != coreir.BodyLoadLocalPtrDerefI32Tag ||
           loadOp.operands[1] != resultSlot ||
           loadOp.operands[2] != coreir.LocalI32Tag ||
           returnOp.target != resultSlot ||
           returnOp.operands[0] != coreir.LocalI32Tag:
            return Err[str](" primary object emit: body ir pointer guard shape mismatch")
        let targetSymbol = PrimaryObjectEmitRelocTargetForItem(plan, plan.itemIds[functionIndex])
        if len(targetSymbol) <= 0:
            return Err[str](" primary object emit: missing pointer guard target")
        let labelOrdinal = IntToStr(ordinal)
        let zeroLabel = Fmt"L_cheng_body_ir_ptr_nil_zero_{labelOrdinal}"
        var out = ""
        out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
        if !PrimaryObjectEmitSymbolInPlan(plan, targetSymbol):
            out = strutil.Join([out, Fmt".extern {targetSymbol}\n"], "")
        out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
        out = strutil.Join([out, "  stp x29, x30, [sp, #-16]!\n"], "")
        out = strutil.Join([out, "  mov x29, sp\n"], "")
        out = strutil.Join([out, Fmt"  bl {targetSymbol}\n"], "")
        out = strutil.Join([out, Fmt"  cbz x0, {zeroLabel}\n"], "")
        out = strutil.Join([out, "  ldr w0, [x0]\n"], "")
        out = strutil.Join([out, "  ldp x29, x30, [sp], #16\n"], "")
        out = strutil.Join([out, "  ret\n"], "")
        out = strutil.Join([out, Fmt"{zeroLabel}:\n"], "")
        out = strutil.Join([out, "  mov w0, #0\n"], "")
        out = strutil.Join([out, "  ldp x29, x30, [sp], #16\n"], "")
        out = strutil.Join([out, "  ret\n"], "")
        out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
        return Ok[str](out)
    if bodyIR.ops.len == 7:
        if pobj.PrimaryBodyIrIsStrI32GuardCallArg0ThenDispatchReturnI32(bodyIR):
            return PrimaryObjectEmitStrI32GuardCallArg0ThenDispatchReturnI32FunctionAsm(plan, functionIndex, ordinal)
        return Err[str](" primary object emit: body ir str i32 guard dispatch unsupported")
    if bodyIR.ops.len != 2:
        return Err[str](" primary object emit: body ir leaf op count unsupported")
    let firstOp = bodyIR.ops[0]
    let returnOp = bodyIR.ops[1]
    if returnOp.kind != coreir.BodyOpReturnTag:
        return Err[str](" primary object emit: body ir leaf missing return")
    if returnOp.target != firstOp.target:
        return Err[str](" primary object emit: body ir return target mismatch")
    if firstOp.kind == coreir.BodyOpLoadConstTag:
        if firstOp.operands.len < 2:
            return Err[str](" primary object emit: body ir const operands missing")
        if firstOp.operands[0] != coreir.LocalI32Tag:
            return Err[str](" primary object emit: body ir const type unsupported")
        return Ok[str](PrimaryObjectEmitReturnI32ConstFunctionAsm(symbolName,
                                                                  ordinal,
                                                                  firstOp.operands[1]))
    if firstOp.kind != coreir.BodyOpBinOpTag:
        return Err[str](" primary object emit: body ir leaf op unsupported")
    if firstOp.operands.len < 2:
        return Err[str](" primary object emit: body ir bin operands missing")
    let localType = firstOp.operands[0]
    let opKind = firstOp.operands[1]
    if localType == coreir.LocalF64Tag &&
       opKind == int32(texpr.TypedExprIrOpF64Mul):
        return Ok[str](PrimaryObjectEmitF64MulArgsFunctionAsm(symbolName, ordinal))
    if localType != coreir.LocalI32Tag:
        return Err[str](" primary object emit: body ir bin type unsupported")
    if opKind == int32(texpr.TypedExprIrOpI32Add):
        return Ok[str](PrimaryObjectEmitI32AddArgsFunctionAsm(symbolName, ordinal))
    if opKind == int32(texpr.TypedExprIrOpI32Sub):
        return Ok[str](PrimaryObjectEmitI32SubArgsFunctionAsm(symbolName, ordinal))
    if opKind == int32(texpr.TypedExprIrOpI32Mul):
        return Ok[str](PrimaryObjectEmitI32MulArgsFunctionAsm(symbolName, ordinal))
    if opKind == int32(texpr.TypedExprIrOpI32Asr):
        return Ok[str](PrimaryObjectEmitI32AsrArgsFunctionAsm(symbolName, ordinal))
    if opKind == int32(texpr.TypedExprIrOpI32Madd):
        let labelOrdinal = IntToStr(ordinal)
        var out = ""
        out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
        out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
        out = strutil.Join([out, "  madd w0, w0, w1, w2\n"], "")
        out = strutil.Join([out, "  ret\n"], "")
        out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
        return Ok[str](out)
    return Err[str](" primary object emit: body ir bin op unsupported")

fn PrimaryObjectEmitEntryBridgeAsm(plan: pobj.PrimaryObjectPlan,
                                    bridgeSymbol: str,
                                    entrySymbol: str,
                                    ordinal: int32): str =
    let setCmdLine = pobj.PrimaryTargetSymbolName(plan.targetTriple, "__cheng_setCmdLine")
    let lineMap = pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_register_line_map_from_argv0")
    let profileFlush = pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_debug_profile_flush_from_argv0")
    let labelOrdinal = IntToStr(ordinal)
    var out = ""
    out = strutil.Join([out, Fmt".globl {bridgeSymbol}\n"], "")
    out = strutil.Join([out, Fmt".extern {setCmdLine}\n"], "")
    out = strutil.Join([out, Fmt".extern {lineMap}\n"], "")
    out = strutil.Join([out, Fmt".extern {profileFlush}\n"], "")
    out = strutil.Join([out, Fmt"{bridgeSymbol}:\n"], "")
    out = strutil.Join([out, "  sub sp, sp, #32\n"], "")
    out = strutil.Join([out, "  stp x0, x1, [sp]\n"], "")
    out = strutil.Join([out, "  str x30, [sp, #24]\n"], "")
    out = strutil.Join([out, Fmt"  bl {setCmdLine}\n"], "")
    out = strutil.Join([out, "  ldr x1, [sp, #8]\n"], "")
    out = strutil.Join([out, "  ldr x0, [x1]\n"], "")
    out = strutil.Join([out, Fmt"  bl {lineMap}\n"], "")
    out = strutil.Join([out, "  ldp x0, x1, [sp]\n"], "")
    out = strutil.Join([out, Fmt"  bl {entrySymbol}\n"], "")
    out = strutil.Join([out, "  str w0, [sp, #16]\n"], "")
    out = strutil.Join([out, "  ldr x1, [sp, #8]\n"], "")
    out = strutil.Join([out, "  ldr x0, [x1]\n"], "")
    out = strutil.Join([out, Fmt"  bl {profileFlush}\n"], "")
    out = strutil.Join([out, "  ldr w0, [sp, #16]\n"], "")
    out = strutil.Join([out, "  ldr x30, [sp, #24]\n"], "")
    out = strutil.Join([out, "  add sp, sp, #32\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return out

fn PrimaryObjectEmitRuntimeSetCmdLineFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                                 functionIndex: int32,
                                                 ordinal: int32): Result[str] =
    if functionIndex < 0 || functionIndex >= plan.symbolNames.len:
        return Err[str](" primary object emit: missing runtime set command line symbol")
    let argcSymbol = PrimaryObjectEmitDataLabelByTail(plan, "__cheng_saved_argc")
    let argvSymbol = PrimaryObjectEmitDataLabelByTail(plan, "__cheng_saved_argv")
    if len(argcSymbol) <= 0 || len(argvSymbol) <= 0:
        return Err[str](" primary object emit: runtime set command line globals missing")
    let symbolName = plan.symbolNames[functionIndex]
    let labelOrdinal = IntToStr(ordinal)
    var out = ""
    out = strutil.Join([out, Fmt".globl {symbolName}\n"], "")
    out = strutil.Join([out, Fmt"{symbolName}:\n"], "")
    out = strutil.Join([out, Fmt"  adrp x16, {argcSymbol}@PAGE\n"], "")
    out = strutil.Join([out, Fmt"  add x16, x16, {argcSymbol}@PAGEOFF\n"], "")
    out = strutil.Join([out, "  str w0, [x16]\n"], "")
    out = strutil.Join([out, Fmt"  adrp x16, {argvSymbol}@PAGE\n"], "")
    out = strutil.Join([out, Fmt"  add x16, x16, {argvSymbol}@PAGEOFF\n"], "")
    out = strutil.Join([out, "  str x1, [x16]\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitDataLabelExact(plan: pobj.PrimaryObjectPlan,
                                    label: str): str =
    for i in 0..<plan.dataLabels.len:
        if plan.dataLabels[i] == label:
            return plan.dataLabels[i]
    return ""

fn PrimaryObjectEmitRelocTargetAtWordOffset(plan: pobj.PrimaryObjectPlan,
                                             wordOffset: int32): str =
    for i in 0..<plan.relocWordOffsets.len:
        if plan.relocWordOffsets[i] != wordOffset:
            continue
        if i < plan.relocTargetSymbols.len:
            return plan.relocTargetSymbols[i]
        return ""
    return ""

fn PrimaryObjectEmitFunctionLooksEntryBridgeWords(plan: pobj.PrimaryObjectPlan,
                                                   functionIndex: int32): bool =
    if len(plan.entryFunctionSymbol) <= 0:
        return false
    if functionIndex < 0 ||
       functionIndex >= plan.functionWordOffsets.len ||
       functionIndex >= plan.functionWordCounts.len:
        return false
    if plan.functionWordCounts[functionIndex] != texpr.BodyKindEntryBridgeWordCount:
        return false
    let wordOffset = plan.functionWordOffsets[functionIndex]
    if wordOffset + 16 >= plan.instructionWords.len:
        return false
    return plan.instructionWords[wordOffset] == -788495361 &&
           plan.instructionWords[wordOffset + 3] == -1811939328 &&
           plan.instructionWords[wordOffset + 6] == -1811939328 &&
           plan.instructionWords[wordOffset + 8] == -1811939328 &&
           plan.instructionWords[wordOffset + 12] == -1811939328 &&
           plan.instructionWords[wordOffset + 16] == -698416192

fn PrimaryObjectEmitEntryBridgeTargetSymbol(plan: pobj.PrimaryObjectPlan): str =
    if len(plan.entryFunctionSymbol) > 0:
        return plan.entryFunctionSymbol
    if plan.symbolNames.len > 0:
        return plan.symbolNames[0]
    return ""

fn PrimaryObjectEmitEntryBridgeRelocTargetAtLocalWord(plan: pobj.PrimaryObjectPlan,
                                                       functionIndex: int32,
                                                       localWordIndex: int32): str =
    if !PrimaryObjectEmitFunctionLooksEntryBridgeWords(plan, functionIndex):
        return ""
    if localWordIndex == 3:
        return pobj.PrimaryTargetSymbolName(plan.targetTriple, "__cheng_setCmdLine")
    if localWordIndex == 6:
        return pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_register_line_map_from_argv0")
    if localWordIndex == 8:
        return PrimaryObjectEmitEntryBridgeTargetSymbol(plan)
    if localWordIndex == 12:
        return pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_debug_profile_flush_from_argv0")
    return ""

fn PrimaryObjectEmitPlanBranchTarget(plan: pobj.PrimaryObjectPlan,
                                      functionIndex: int32,
                                      localWordIndex: int32): str =
    let wordOffset = plan.functionWordOffsets[functionIndex] + localWordIndex
    let target = PrimaryObjectEmitRelocTargetAtWordOffset(plan, wordOffset)
    if len(target) > 0:
        return target
    return PrimaryObjectEmitEntryBridgeRelocTargetAtLocalWord(plan, functionIndex, localWordIndex)

fn PrimaryObjectEmitPlanDataPairAsm(plan: pobj.PrimaryObjectPlan,
                                     functionIndex: int32,
                                     localWordIndex: int32,
                                     cstringOrdinal: var int32,
                                     runtimePairOrdinal: var int32): Result[str] =
    if functionIndex < 0 ||
       functionIndex >= plan.symbolNames.len ||
       functionIndex >= plan.functionWordOffsets.len ||
       functionIndex >= plan.functionWordCounts.len:
        return Err[str](" primary object emit: malformed data pair function")
    if localWordIndex + 1 >= plan.functionWordCounts[functionIndex]:
        return Ok[str]("")
    let wordOffset = plan.functionWordOffsets[functionIndex] + localWordIndex
    if wordOffset + 1 >= plan.instructionWords.len:
        return Err[str](" primary object emit: data pair instruction words missing")
    let word = plan.instructionWords[wordOffset]
    let nextWord = plan.instructionWords[wordOffset + 1]
    if word == -1879048192 && nextWord == -1862270976:
        let literalLabel = PrimaryObjectEmitDataLabelExact(plan,
                                                           pobj.PrimaryCStringLiteralDataLabel(plan.symbolNames[functionIndex],
                                                                                               cstringOrdinal))
        if len(literalLabel) <= 0:
            return Err[str](" primary object emit: missing cstring data label")
        cstringOrdinal = cstringOrdinal + 1
        return Ok[str](Fmt"  adrp x0, {literalLabel}@PAGE\n  add x0, x0, {literalLabel}@PAGEOFF\n")
    if word == -1879048176 && nextWord == -1862270448:
        var dataLabel = ""
        if runtimePairOrdinal == 0:
            dataLabel = PrimaryObjectEmitDataLabelByTail(plan, "__cheng_saved_argc")
        elif runtimePairOrdinal == 1:
            dataLabel = PrimaryObjectEmitDataLabelByTail(plan, "__cheng_saved_argv")
        if len(dataLabel) <= 0:
            return Err[str](" primary object emit: missing runtime data label")
        runtimePairOrdinal = runtimePairOrdinal + 1
        return Ok[str](Fmt"  adrp x16, {dataLabel}@PAGE\n  add x16, x16, {dataLabel}@PAGEOFF\n")
    return Ok[str]("")

fn PrimaryObjectEmitPlanInstructionWordAsm(plan: pobj.PrimaryObjectPlan,
                                            functionIndex: int32,
                                            localWordIndex: int32): Result[str] =
    let wordOffset = plan.functionWordOffsets[functionIndex] + localWordIndex
    if wordOffset < 0 || wordOffset >= plan.instructionWords.len:
        return Err[str](" primary object emit: instruction word missing")
    let word = plan.instructionWords[wordOffset]
    let target = PrimaryObjectEmitPlanBranchTarget(plan, functionIndex, localWordIndex)
    if len(target) > 0:
        if word == -1811939328:
            return Ok[str](Fmt"  bl {target}\n")
        if word == 335544320:
            return Ok[str](Fmt"  b {target}\n")
        return Err[str](" primary object emit: branch reloc word mismatch")
    if word == -1811939328 || word == 335544320:
        return Err[str](" primary object emit: branch instruction missing reloc target")
    return Ok[str](Fmt"  .long {IntToStr(word)}\n")

fn PrimaryObjectEmitPlanFunctionAsm(plan: pobj.PrimaryObjectPlan,
                                     functionIndex: int32): Result[str] =
    if functionIndex < 0 ||
       functionIndex >= plan.symbolNames.len ||
       functionIndex >= plan.functionWordCounts.len:
        return Err[str](" primary object emit: missing plan function")
    if functionIndex < plan.functionBodyIRs.len &&
       pobj.PrimaryBodyIrIsCallCfgReturnInt32(plan.functionBodyIRs[functionIndex]):
        return PrimaryObjectEmitCallCfgReturnInt32FunctionAsm(plan,
                                                              functionIndex,
                                                              functionIndex)
    var chunks: str[]
    add(chunks, Fmt".globl {plan.symbolNames[functionIndex]}\n")
    add(chunks, Fmt"{plan.symbolNames[functionIndex]}:\n")
    var skipNext = false
    var cstringOrdinal: int32
    var runtimePairOrdinal: int32
    for localWordIndex in 0..<plan.functionWordCounts[functionIndex]:
        if skipNext:
            skipNext = false
            continue
        let dataPairRes = PrimaryObjectEmitPlanDataPairAsm(plan,
                                                           functionIndex,
                                                           localWordIndex,
                                                           cstringOrdinal,
                                                           runtimePairOrdinal)
        if IsErr(dataPairRes):
            return dataPairRes
        let dataPair = Value(dataPairRes)
        if len(dataPair) > 0:
            add(chunks, dataPair)
            skipNext = true
            continue
        let wordRes = PrimaryObjectEmitPlanInstructionWordAsm(plan, functionIndex, localWordIndex)
        if IsErr(wordRes):
            return wordRes
        add(chunks, Value(wordRes))
    add(chunks, Fmt"L_cheng_embedded_line_map_end_{IntToStr(functionIndex)}:\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitPlanExternAsm(plan: pobj.PrimaryObjectPlan): str =
    var chunks: str[]
    for i in 0..<plan.relocTargetSymbols.len:
        if len(plan.relocTargetSymbols[i]) <= 0:
            continue
        if !PrimaryObjectEmitSymbolInPlan(plan, plan.relocTargetSymbols[i]):
            add(chunks, Fmt".extern {plan.relocTargetSymbols[i]}\n")
    for i in 0..<plan.symbolNames.len:
        if !PrimaryObjectEmitFunctionLooksEntryBridgeWords(plan, i):
            continue
        let setCmdLine = pobj.PrimaryTargetSymbolName(plan.targetTriple, "__cheng_setCmdLine")
        let lineMap = pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_register_line_map_from_argv0")
        let profileFlush = pobj.PrimaryTargetSymbolName(plan.targetTriple, "cheng_debug_profile_flush_from_argv0")
        if !PrimaryObjectEmitSymbolInPlan(plan, setCmdLine):
            add(chunks, Fmt".extern {setCmdLine}\n")
        if !PrimaryObjectEmitSymbolInPlan(plan, lineMap):
            add(chunks, Fmt".extern {lineMap}\n")
        if !PrimaryObjectEmitSymbolInPlan(plan, PrimaryObjectEmitEntryBridgeTargetSymbol(plan)):
            add(chunks, Fmt".extern {PrimaryObjectEmitEntryBridgeTargetSymbol(plan)}\n")
        if !PrimaryObjectEmitSymbolInPlan(plan, profileFlush):
            add(chunks, Fmt".extern {profileFlush}\n")
    return strutil.Join(chunks, "")

fn PrimaryObjectEmitPlanAsmText(plan: pobj.PrimaryObjectPlan): Result[str] =
    let validRes = PrimaryObjectEmitValidateObjectShape(plan)
    if IsErr(validRes):
        return Err[str](Error(validRes))
    var chunks: str[]
    add(chunks, ".text\n.p2align 2\n")
    add(chunks, PrimaryObjectEmitPlanExternAsm(plan))
    for i in 0..<plan.symbolNames.len:
        let functionAsmRes = PrimaryObjectEmitPlanFunctionAsm(plan, i)
        if IsErr(functionAsmRes):
            return functionAsmRes
        add(chunks, Value(functionAsmRes))
    add(chunks, PrimaryObjectEmitDataAsm(plan))
    if plan.objectFormat == "macho":
        add(chunks, ".subsections_via_symbols\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitDataAsm(plan: pobj.PrimaryObjectPlan): str =
    if !PrimaryObjectEmitHasData(plan):
        return ""
    var chunks: str[]
    add(chunks, ".data\n")
    for i in 0..<plan.dataLabels.len:
        var count: int32
        if i < plan.dataPayloadTexts.len:
            count = PrimaryObjectEmitPayloadByteCount(plan.dataPayloadTexts[i])
        if count <= 0:
            count = 1
        add(chunks, ".p2align 3\n")
        add(chunks, Fmt"{plan.dataLabels[i]}:\n")
        if i < plan.dataPayloadTexts.len && strutil.StartsWith(plan.dataPayloadTexts[i], "cstring:"):
            add(chunks, Fmt"  .byte {PrimaryObjectEmitCStringPayloadByteList(plan.dataPayloadTexts[i])}\n")
        else:
            add(chunks, Fmt"  .space {IntToStr(count)}\n")
    return strutil.Join(chunks, "")

fn PrimaryObjectEmitObjectAsmText(plan: pobj.PrimaryObjectPlan): Result[str] =
    return PrimaryObjectEmitPlanAsmText(plan)
    let validRes = PrimaryObjectEmitValidateObjectShape(plan)
    if !IsOk(validRes):
        return Err[str](Error(validRes))
    var chunks: str[]
    add(chunks, ".text\n.p2align 2\n")
    for i in 0..<plan.symbolNames.len:
        let bodyKind = plan.functionBodyKinds[i]
        if i < plan.functionBodyIRs.len:
            let bodyIrAsmRes = PrimaryObjectEmitLeafBodyIRFunctionAsm(plan, i, i)
            if IsOk(bodyIrAsmRes):
                add(chunks, Value(bodyIrAsmRes))
                continue
        if bodyKind == texpr.BodyKindReturnZeroI32:
            add(chunks, PrimaryObjectEmitReturnZeroFunctionAsm(plan.symbolNames[i], i))
        elif PrimaryObjectEmitIsReturnI32ConstBodyKind(bodyKind):
            let imm = PrimaryObjectEmitParseSuffixI32(bodyKind, texpr.BodyKindReturnI32ConstPrefix)
            add(chunks, PrimaryObjectEmitReturnI32ConstFunctionAsm(plan.symbolNames[i], i, imm))
        elif bodyKind == texpr.BodyKindReturnI32Arg0:
            add(chunks, PrimaryObjectEmitReturnI32Arg0FunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32Arg1:
            add(chunks, PrimaryObjectEmitReturnI32Arg1FunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32Arg2:
            add(chunks, PrimaryObjectEmitReturnI32Arg2FunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32Arg3:
            add(chunks, PrimaryObjectEmitReturnI32Arg3FunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnF64MulArgs:
            add(chunks, PrimaryObjectEmitF64MulArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32AddArgs:
            add(chunks, PrimaryObjectEmitI32AddArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32SubArgs:
            add(chunks, PrimaryObjectEmitI32SubArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32MulArgs:
            add(chunks, PrimaryObjectEmitI32MulArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32AsrArgs:
            add(chunks, PrimaryObjectEmitI32AsrArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32MaddArgs:
            let labelOrdinal = IntToStr(i)
            add(chunks, Fmt".globl {plan.symbolNames[i]}\n")
            add(chunks, Fmt"{plan.symbolNames[i]}:\n")
            add(chunks, "  madd w0, w0, w1, w2\n")
            add(chunks, "  ret\n")
            add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
        elif bodyKind == texpr.BodyKindReturnU64Arg0AndConst4NotZero:
            let labelOrdinal = IntToStr(i)
            add(chunks, Fmt".globl {plan.symbolNames[i]}\n")
            add(chunks, Fmt"{plan.symbolNames[i]}:\n")
            add(chunks, "  tst x0, #4\n")
            add(chunks, "  cset w0, ne\n")
            add(chunks, "  ret\n")
            add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
        elif bodyKind == texpr.BodyKindReturnU64Arg0OrConst4:
            let labelOrdinal = IntToStr(i)
            add(chunks, Fmt".globl {plan.symbolNames[i]}\n")
            add(chunks, Fmt"{plan.symbolNames[i]}:\n")
            add(chunks, "  orr x0, x0, #4\n")
            add(chunks, "  ret\n")
            add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
        elif bodyKind == texpr.BodyKindIfArg0LeZeroReturnI32Const0ElseI32Const7:
            add(chunks, PrimaryObjectEmitI32IfArg0LeZeroConstElseFunctionAsm(plan.symbolNames[i], i, 0, 7))
        elif bodyKind == texpr.BodyKindStrLenFastI32:
            add(chunks, PrimaryObjectEmitStrLenFastFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnStrEmpty:
            add(chunks, PrimaryObjectEmitReturnStrEmptyFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnStrArg0:
            add(chunks, PrimaryObjectEmitReturnStrArg0FunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindCstringToStrCopy:
            let cstringAsmRes = PrimaryObjectEmitCstringToStrCopyFunctionAsm(plan, i, i)
            if IsErr(cstringAsmRes):
                return Err[str](Error(cstringAsmRes))
            add(chunks, Value(cstringAsmRes))
        elif bodyKind == texpr.BodyKindMainF64MulCheckExit:
            add(chunks, PrimaryObjectEmitF64MulCheckExitFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindStatementSequence:
            let callAsmRes = PrimaryObjectEmitStatementSequenceFunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
            let imm = Value(PrimaryObjectEmitParseLetCallNoargReturnI32ConstBodyKind(bodyKind))
            let callAsmRes = PrimaryObjectEmitLetCallNoargReturnI32ConstFunctionAsm(plan, i, i, imm)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargReturnResultI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif bodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32:
            let callAsmRes = PrimaryObjectEmitLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargStrReturnLenI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargStrThenCallArg0ReturnI32Const0FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif texpr.TypedExprIsReturnCallBodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitReturnCallFunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif bodyKind == texpr.BodyKindRuntimeSetCmdLine:
            let setCmdRes = PrimaryObjectEmitRuntimeSetCmdLineFunctionAsm(plan, i, i)
            if IsErr(setCmdRes):
                return Err[str](Error(setCmdRes))
            add(chunks, Value(setCmdRes))
        elif bodyKind == texpr.BodyKindBackendDriverCommandDispatch:
            let dispatchRes = PrimaryObjectEmitBackendDriverCommandDispatchFunctionAsm(plan, i, i)
            if IsErr(dispatchRes):
                return Err[str](Error(dispatchRes))
            add(chunks, Value(dispatchRes))
        elif bodyKind == texpr.BodyKindResultRequestDispatch:
            let resultDispatchRes = PrimaryObjectEmitResultRequestDispatchFunctionAsm(plan, i, i)
            if IsErr(resultDispatchRes):
                return Err[str](Error(resultDispatchRes))
            add(chunks, Value(resultDispatchRes))
        else:
            return Err[str](" primary object emit: object plan unsupported function body kind")
    add(chunks, PrimaryObjectEmitDataAsm(plan))
    if plan.objectFormat == "macho":
        add(chunks, ".subsections_via_symbols\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitAsmText(plan: pobj.PrimaryObjectPlan): Result[str] =
    return PrimaryObjectEmitPlanAsmText(plan)
    let validRes = PrimaryObjectEmitValidateReturnZeroShape(plan)
    if !IsOk(validRes):
        return Err[str](Error(validRes))
    var bridgeIndex = PrimaryObjectEmitEntryBridgeIndex(plan)
    if bridgeIndex < 1 && plan.functionBodyKinds.len == 2:
        if plan.functionBodyKinds[0] == texpr.BodyKindReturnZeroI32 ||
           PrimaryObjectEmitIsReturnI32ConstBodyKind(plan.functionBodyKinds[0]):
            if plan.functionBodyKinds[1] == texpr.BodyKindEntryBridge:
                bridgeIndex = 1
    var functionLimit = plan.symbolNames.len
    if bridgeIndex >= 0:
        functionLimit = bridgeIndex
    var chunks: str[]
    add(chunks, ".text\n.p2align 2\n")
    for i in 0..<functionLimit:
        let bodyKind = plan.functionBodyKinds[i]
        if i < plan.functionBodyIRs.len:
            let bodyIrAsmRes = PrimaryObjectEmitLeafBodyIRFunctionAsm(plan, i, i)
            if IsOk(bodyIrAsmRes):
                add(chunks, Value(bodyIrAsmRes))
                continue
        if bodyKind == texpr.BodyKindReturnZeroI32:
            add(chunks, PrimaryObjectEmitReturnZeroFunctionAsm(plan.symbolNames[i], i))
        elif PrimaryObjectEmitIsReturnI32ConstBodyKind(bodyKind):
            let imm = PrimaryObjectEmitParseSuffixI32(bodyKind, texpr.BodyKindReturnI32ConstPrefix)
            add(chunks, PrimaryObjectEmitReturnI32ConstFunctionAsm(plan.symbolNames[i], i, imm))
        elif bodyKind == texpr.BodyKindReturnF64MulArgs:
            add(chunks, PrimaryObjectEmitF64MulArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32AddArgs:
            add(chunks, PrimaryObjectEmitI32AddArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32SubArgs:
            add(chunks, PrimaryObjectEmitI32SubArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32MulArgs:
            add(chunks, PrimaryObjectEmitI32MulArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32AsrArgs:
            add(chunks, PrimaryObjectEmitI32AsrArgsFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnI32MaddArgs:
            let labelOrdinal = IntToStr(i)
            add(chunks, Fmt".globl {plan.symbolNames[i]}\n")
            add(chunks, Fmt"{plan.symbolNames[i]}:\n")
            add(chunks, "  madd w0, w0, w1, w2\n")
            add(chunks, "  ret\n")
            add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
        elif bodyKind == texpr.BodyKindReturnU64Arg0AndConst4NotZero:
            let labelOrdinal = IntToStr(i)
            add(chunks, Fmt".globl {plan.symbolNames[i]}\n")
            add(chunks, Fmt"{plan.symbolNames[i]}:\n")
            add(chunks, "  tst x0, #4\n")
            add(chunks, "  cset w0, ne\n")
            add(chunks, "  ret\n")
            add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
        elif bodyKind == texpr.BodyKindReturnU64Arg0OrConst4:
            let labelOrdinal = IntToStr(i)
            add(chunks, Fmt".globl {plan.symbolNames[i]}\n")
            add(chunks, Fmt"{plan.symbolNames[i]}:\n")
            add(chunks, "  orr x0, x0, #4\n")
            add(chunks, "  ret\n")
            add(chunks, Fmt"L_cheng_embedded_line_map_end_{labelOrdinal}:\n")
        elif bodyKind == texpr.BodyKindIfArg0LeZeroReturnI32Const0ElseI32Const7:
            add(chunks, PrimaryObjectEmitI32IfArg0LeZeroConstElseFunctionAsm(plan.symbolNames[i], i, 0, 7))
        elif bodyKind == texpr.BodyKindStrLenFastI32:
            add(chunks, PrimaryObjectEmitStrLenFastFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnStrEmpty:
            add(chunks, PrimaryObjectEmitReturnStrEmptyFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindReturnStrArg0:
            add(chunks, PrimaryObjectEmitReturnStrArg0FunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindCstringToStrCopy:
            let cstringAsmRes = PrimaryObjectEmitCstringToStrCopyFunctionAsm(plan, i, i)
            if IsErr(cstringAsmRes):
                return Err[str](Error(cstringAsmRes))
            add(chunks, Value(cstringAsmRes))
        elif bodyKind == texpr.BodyKindMainF64MulCheckExit:
            add(chunks, PrimaryObjectEmitF64MulCheckExitFunctionAsm(plan.symbolNames[i], i))
        elif bodyKind == texpr.BodyKindStatementSequence:
            let callAsmRes = PrimaryObjectEmitStatementSequenceFunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif PrimaryObjectEmitIsLetCallNoargReturnI32ConstBodyKind(bodyKind):
            let imm = Value(PrimaryObjectEmitParseLetCallNoargReturnI32ConstBodyKind(bodyKind))
            let callAsmRes = PrimaryObjectEmitLetCallNoargReturnI32ConstFunctionAsm(plan, i, i, imm)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif texpr.TypedExprIsLetCallNoargReturnResultI32BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargReturnResultI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif bodyKind == texpr.BodyKindLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32:
            let callAsmRes = PrimaryObjectEmitLetCallNoargI32IfResultLeZeroReturnZeroElseResultI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif texpr.TypedExprIsLetCallNoargStrReturnLenI32BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargStrReturnLenI32FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif texpr.TypedExprIsLetCallNoargStrThenCallArg0ReturnI32Const0BodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitLetCallNoargStrThenCallArg0ReturnI32Const0FunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif texpr.TypedExprIsReturnCallBodyKind(bodyKind):
            let callAsmRes = PrimaryObjectEmitReturnCallFunctionAsm(plan, i, i)
            if IsErr(callAsmRes):
                return Err[str](Error(callAsmRes))
            add(chunks, Value(callAsmRes))
        elif bodyKind == texpr.BodyKindRuntimeSetCmdLine:
            let setCmdRes = PrimaryObjectEmitRuntimeSetCmdLineFunctionAsm(plan, i, i)
            if IsErr(setCmdRes):
                return Err[str](Error(setCmdRes))
            add(chunks, Value(setCmdRes))
        elif bodyKind == texpr.BodyKindBackendDriverCommandDispatch:
            let dispatchRes = PrimaryObjectEmitBackendDriverCommandDispatchFunctionAsm(plan, i, i)
            if IsErr(dispatchRes):
                return Err[str](Error(dispatchRes))
            add(chunks, Value(dispatchRes))
        elif bodyKind == texpr.BodyKindResultRequestDispatch:
            let resultDispatchRes = PrimaryObjectEmitResultRequestDispatchFunctionAsm(plan, i, i)
            if IsErr(resultDispatchRes):
                return Err[str](Error(resultDispatchRes))
            add(chunks, Value(resultDispatchRes))
        else:
            return Err[str](" primary object emit: unsupported function body kind")
    if bridgeIndex >= 0:
        var entryTargetSymbol = plan.entryFunctionSymbol
        if len(entryTargetSymbol) <= 0:
            entryTargetSymbol = plan.symbolNames[0]
        let bridgeAsm = PrimaryObjectEmitEntryBridgeAsm(plan,
                                                        plan.symbolNames[bridgeIndex],
                                                        entryTargetSymbol,
                                                        bridgeIndex)
        add(chunks, bridgeAsm)
    add(chunks, PrimaryObjectEmitDataAsm(plan))
    if plan.objectFormat == "macho":
        add(chunks, ".subsections_via_symbols\n")
    return Ok[str](strutil.Join(chunks, ""))

fn PrimaryObjectEmitCompileArgv(plan: pobj.PrimaryObjectPlan,
                                 asmPath: str): Result[str[]] =
    let validRes = PrimaryObjectEmitValidateReturnZeroShape(plan)
    if !IsOk(validRes):
        return Err[str[]](Error(validRes))
    var argv: str[]
    let targetArgRes = PrimaryObjectEmitAppendTargetCompileArgs(plan, argv)
    if IsErr(targetArgRes):
        return Err[str[]](Error(targetArgRes))
    add(argv, "-c")
    add(argv, asmPath)
    add(argv, "-o")
    add(argv, plan.outputPath)
    return Ok[str[]](argv)

fn PrimaryObjectEmitObjectCompileArgv(plan: pobj.PrimaryObjectPlan,
                                       asmPath: str): Result[str[]] =
    let validRes = PrimaryObjectEmitValidateObjectShape(plan)
    if !IsOk(validRes):
        return Err[str[]](Error(validRes))
    var argv: str[]
    let targetArgRes = PrimaryObjectEmitAppendTargetCompileArgs(plan, argv)
    if IsErr(targetArgRes):
        return Err[str[]](Error(targetArgRes))
    add(argv, "-c")
    add(argv, asmPath)
    add(argv, "-o")
    add(argv, plan.outputPath)
    return Ok[str[]](argv)

fn PrimaryObjectEmitRunObjectLogged(rootDir: str,
                                     label: str,
                                     plan: pobj.PrimaryObjectPlan): Result[PrimaryObjectEmitResult] =
    let asmRes = PrimaryObjectEmitObjectAsmText(plan)
    if !IsOk(asmRes):
        return Err[PrimaryObjectEmitResult](Error(asmRes))
    let asmPath = PrimaryObjectEmitAsmPath(plan)
    let compileLogPath = PrimaryObjectEmitCompileLogPath(plan)
    let asmText = Value(asmRes)
    if !chengpath.WriteTextFile(rootDir, asmPath, asmText):
        return Err[PrimaryObjectEmitResult](strutil.Join([" primary object emit: failed to write object asm: ", asmPath], ""))
    let argvRes = PrimaryObjectEmitObjectCompileArgv(plan, asmPath)
    if !IsOk(argvRes):
        return Err[PrimaryObjectEmitResult](Error(argvRes))
    let argv = Value(argvRes)
    let commandText = hostos.OsHostProcessCommandText("cc", argv, [])
    let run = hostops.RunProgramLogged(rootDir,
                                       label,
                                       "cc",
                                       argv,
                                       [],
                                       rootDir,
                                       0,
                                       compileLogPath)
    var out: PrimaryObjectEmitResult
    out.asmPath = asmPath
    out.objectPath = plan.outputPath
    out.compileLogPath = compileLogPath
    out.commandText = commandText
    out.exitCode = run.exitCode
    out.asmText = asmText
    out.compilerOutput = run.output
    if run.exitCode != 0:
        return Err[PrimaryObjectEmitResult](Fmt" primary object emit: object cc failed rc={IntToStr(run.exitCode)} command={commandText}")
    if !chengpath.FileExistsNonEmpty(rootDir, plan.outputPath):
        return Err[PrimaryObjectEmitResult](strutil.Join([" primary object emit: missing object output: ", plan.outputPath], ""))
    return Ok[PrimaryObjectEmitResult](out)

fn PrimaryObjectEmitStandaloneEntryBodyKind(plan: pobj.PrimaryObjectPlan): str =
    let functionLimit = PrimaryObjectEmitFunctionCount(plan)
    if len(plan.entryFunctionSymbol) > 0:
        for i in 0..<functionLimit:
            if plan.symbolNames[i] == plan.entryFunctionSymbol:
                return plan.functionBodyKinds[i]
        return ""
    if functionLimit > 0:
        return plan.functionBodyKinds[0]
    return ""

fn PrimaryObjectEmitValidateStandaloneMainShape(plan: pobj.PrimaryObjectPlan): Result[bool] =
    if !PrimaryObjectEmitTargetSupported(plan):
        return Err[bool](Fmt" primary object emit: unsupported standalone target: {plan.targetTriple}")
    if len(plan.outputPath) <= 0:
        return Err[bool](" primary object emit: missing standalone output path")
    if plan.missingReasons.len > 0:
        return Err[bool](" primary object emit: standalone plan has missing reasons")
    if plan.symbolNames.len < 1 || plan.functionBodyKinds.len < 1:
        return Err[bool](" primary object emit: standalone function missing")
    if plan.symbolNames.len != plan.functionBodyKinds.len:
        return Err[bool](" primary object emit: standalone malformed function table")
    let entryBodyKind = PrimaryObjectEmitStandaloneEntryBodyKind(plan)
    if entryBodyKind != texpr.BodyKindReturnZeroI32 &&
       !PrimaryObjectEmitIsReturnI32ConstBodyKind(entryBodyKind):
        return Err[bool](" primary object emit: standalone only supports constant i32 entry")
    return Ok[bool](true)

fn PrimaryObjectEmitStandaloneCompileArgv(plan: pobj.PrimaryObjectPlan,
                                           asmPath: str): Result[str[]] =
    let validRes = PrimaryObjectEmitValidateStandaloneMainShape(plan)
    if !IsOk(validRes):
        return Err[str[]](Error(validRes))
    var argv: str[]
    let targetArgRes = PrimaryObjectEmitAppendTargetCompileArgs(plan, argv)
    if IsErr(targetArgRes):
        return Err[str[]](Error(targetArgRes))
    add(argv, "-c")
    add(argv, asmPath)
    add(argv, "-o")
    add(argv, plan.outputPath)
    return Ok[str[]](argv)

fn PrimaryObjectEmitStandaloneMainAsmText(plan: pobj.PrimaryObjectPlan): Result[str] =
    let validRes = PrimaryObjectEmitValidateStandaloneMainShape(plan)
    if !IsOk(validRes):
        return Err[str](Error(validRes))
    let entryBodyKind = PrimaryObjectEmitStandaloneEntryBodyKind(plan)
    var imm: int32
    if PrimaryObjectEmitIsReturnI32ConstBodyKind(entryBodyKind):
        imm = PrimaryObjectEmitParseSuffixI32(entryBodyKind, texpr.BodyKindReturnI32ConstPrefix)
    var mainSymbol = "main"
    if plan.objectFormat == "macho":
        mainSymbol = "_main"
    var out = ".text\n.p2align 2\n"
    out = strutil.Join([out, ".globl ", mainSymbol, "\n"], "")
    out = strutil.Join([out, mainSymbol, ":\n"], "")
    out = strutil.Join([out, Fmt"  mov w0, #{IntToStr(imm)}\n"], "")
    out = strutil.Join([out, "  ret\n"], "")
    out = strutil.Join([out, "L_cheng_embedded_line_map_end_0:\n"], "")
    if plan.objectFormat == "macho":
        out = strutil.Join([out, ".subsections_via_symbols\n"], "")
    return Ok[str](out)

fn PrimaryObjectEmitRunStandaloneMainLogged(rootDir: str,
                                             label: str,
                                             plan: pobj.PrimaryObjectPlan): Result[PrimaryObjectEmitResult] =
    let asmRes = PrimaryObjectEmitStandaloneMainAsmText(plan)
    if !IsOk(asmRes):
        return Err[PrimaryObjectEmitResult](Error(asmRes))
    let asmPath = PrimaryObjectEmitAsmPath(plan)
    let compileLogPath = PrimaryObjectEmitCompileLogPath(plan)
    let asmText = Value(asmRes)
    if !chengpath.WriteTextFile(rootDir, asmPath, asmText):
        return Err[PrimaryObjectEmitResult](strutil.Join([" primary object emit: failed to write standalone asm: ", asmPath], ""))
    let argvRes = PrimaryObjectEmitStandaloneCompileArgv(plan, asmPath)
    if !IsOk(argvRes):
        return Err[PrimaryObjectEmitResult](Error(argvRes))
    let argv = Value(argvRes)
    let commandText = hostos.OsHostProcessCommandText("cc", argv, [])
    let run = hostops.RunProgramLogged(rootDir,
                                       label,
                                       "cc",
                                       argv,
                                       [],
                                       rootDir,
                                       0,
                                       compileLogPath)
    var out: PrimaryObjectEmitResult
    out.asmPath = asmPath
    out.objectPath = plan.outputPath
    out.compileLogPath = compileLogPath
    out.commandText = commandText
    out.exitCode = run.exitCode
    out.asmText = asmText
    out.compilerOutput = run.output
    if run.exitCode != 0:
        return Err[PrimaryObjectEmitResult](Fmt" primary object emit: standalone cc failed rc={IntToStr(run.exitCode)} command={commandText}")
    if !chengpath.FileExistsNonEmpty(rootDir, plan.outputPath):
        return Err[PrimaryObjectEmitResult](strutil.Join([" primary object emit: missing standalone output object: ", plan.outputPath], ""))
    return Ok[PrimaryObjectEmitResult](out)

fn PrimaryObjectEmitRunLogged(rootDir: str,
                               label: str,
                               plan: pobj.PrimaryObjectPlan): Result[PrimaryObjectEmitResult] =
    let asmRes = PrimaryObjectEmitAsmText(plan)
    if !IsOk(asmRes):
        return Err[PrimaryObjectEmitResult](Error(asmRes))
    let asmPath = PrimaryObjectEmitAsmPath(plan)
    let compileLogPath = PrimaryObjectEmitCompileLogPath(plan)
    let asmText = Value(asmRes)
    if !chengpath.WriteTextFile(rootDir, asmPath, asmText):
        return Err[PrimaryObjectEmitResult](strutil.Join([" primary object emit: failed to write asm: ", asmPath], ""))
    let argvRes = PrimaryObjectEmitCompileArgv(plan, asmPath)
    if !IsOk(argvRes):
        return Err[PrimaryObjectEmitResult](Error(argvRes))
    let argv = Value(argvRes)
    let commandText = hostos.OsHostProcessCommandText("cc", argv, [])
    let run = hostops.RunProgramLogged(rootDir,
                                       label,
                                       "cc",
                                       argv,
                                       [],
                                       rootDir,
                                       0,
                                       compileLogPath)
    var out: PrimaryObjectEmitResult
    out.asmPath = asmPath
    out.objectPath = plan.outputPath
    out.compileLogPath = compileLogPath
    out.commandText = commandText
    out.exitCode = run.exitCode
    out.asmText = asmText
    out.compilerOutput = run.output
    if run.exitCode != 0:
        return Err[PrimaryObjectEmitResult](Fmt" primary object emit: cc failed rc={IntToStr(run.exitCode)} command={commandText}")
    if !chengpath.FileExistsNonEmpty(rootDir, plan.outputPath):
        return Err[PrimaryObjectEmitResult](strutil.Join([" primary object emit: missing output object: ", plan.outputPath], ""))
    return Ok[PrimaryObjectEmitResult](out)
