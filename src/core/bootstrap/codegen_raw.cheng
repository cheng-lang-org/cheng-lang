// codegen_raw.cheng — Write raw ARM64 instructions to binary file
// Template-free: just instruction words, to be wrapped externally

import libc

fn main(): int32 =
    let fd: int32 = cold_open("/tmp/raw_code.bin", 1)
    if fd < 0: return 1

    var code: int32[2]
    // mov w0, #42 = 0x52800540
    code[0] = 0x52800540
    // ret = 0xD65F03C0
    code[1] = 0xD65F03C0

    let n: int32 = cold_write(fd, code, 8)
    let _: int32 = cold_close(fd)
    if n == 8: return 42
    return n
