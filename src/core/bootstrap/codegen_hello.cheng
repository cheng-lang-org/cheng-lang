// codegen_hello.cheng — Complete ARM64 assembly output
// Writes valid .s file, assembles to return 42

import libc

fn main(): int32 =
    let fd: int32 = cold_open("/tmp/hello_cg.s", 1)
    if fd < 0: return 1

    // ".global _main\n_main:\n    mov w0, #42\n    ret\n" = 46 bytes
    // Pack into int32[12] (48 bytes, last 2 zero-padded)
    var buf: int32[12]
    // ".glo" = '.' 'g' 'l' 'o'
    buf[0] = 46 + (103 << 8) + (108 << 16) + (111 << 24)
    // "bal " = 'b' 'a' 'l' ' '
    buf[1] = 98 + (97 << 8) + (108 << 16) + (32 << 24)
    // "_mai" = '_' 'm' 'a' 'i'
    buf[2] = 95 + (109 << 8) + (97 << 16) + (105 << 24)
    // "n\n_m" = 'n' '\n' '_' 'm'
    buf[3] = 110 + (10 << 8) + (95 << 16) + (109 << 24)
    // "ain:" = 'a' 'i' 'n' ':'
    buf[4] = 97 + (105 << 8) + (110 << 16) + (58 << 24)
    // "\n   " = '\n' ' ' ' ' ' '
    buf[5] = 10 + (32 << 8) + (32 << 16) + (32 << 24)
    // " mov" = ' ' 'm' 'o' 'v'
    buf[6] = 32 + (109 << 8) + (111 << 16) + (118 << 24)
    // " w0," = ' ' 'w' '0' ','
    buf[7] = 32 + (119 << 8) + (48 << 16) + (44 << 24)
    // " #42" = ' ' '#' '4' '2'
    buf[8] = 32 + (35 << 8) + (52 << 16) + (50 << 24)
    // "\n   " = '\n' ' ' ' ' ' '
    buf[9] = 10 + (32 << 8) + (32 << 16) + (32 << 24)
    // " ret" = ' ' 'r' 'e' 't'
    buf[10] = 32 + (114 << 8) + (101 << 16) + (116 << 24)
    // "\n\0\0\0" = '\n' + padding
    buf[11] = 10

    let n: int32 = cold_write(fd, buf, 46)
    let _: int32 = cold_close(fd)
    if n == 46: return 42
    return n
