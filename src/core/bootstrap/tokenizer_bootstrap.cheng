// Bootstrap lexer v9 — byte-level access + word counting (fixed array params)
// Verified: byte_at via >>/&, cold_open/read/close, array param indexing

import libc

fn is_space(c: int32): int32 =
    if c == 32: return 1
    if c == 9: return 1
    if c == 10: return 1
    return 0

fn byte_at(buf: int32[1024], word: int32, byte_idx: int32): int32 =
    let w: int32 = buf[word]
    if byte_idx == 0: return w & 255
    if byte_idx == 1: return (w >> 8) & 255
    if byte_idx == 2: return (w >> 16) & 255
    return (w >> 24) & 255

fn count_words(buf: int32[1024], len: int32): int32 =
    var count: int32 = 0
    var in_word: int32 = 0
    var i: int32 = 0
    while i < len / 4:
        let c: int32 = buf[i]
        if c == 0: break
        if is_space(c) != 0:
            in_word = 0
        else:
            if in_word == 0:
                count = count + 1
                in_word = 1
        i = i + 1
    return count

fn main(): int32 =
    let fd: int32 = cold_open("README.md", 0)
    if fd < 0: return 1
    var buf: int32[1024]
    let n: int32 = cold_read(fd, buf, 4096)
    let _: int32 = cold_close(fd)
    if n <= 0: return 2
    let c0: int32 = byte_at(buf, 0, 0)
    if c0 != 35: return c0
    let count: int32 = count_words(buf, n)
    if count > 0: return 42
    return count
