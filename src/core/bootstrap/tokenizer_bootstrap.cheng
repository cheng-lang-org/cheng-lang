// Bootstrap tokenizer v6 — direct array access (no pointer arithmetic)
// Cold-compiler compatible: int32/str/while/if/array only

import libc

fn is_alpha(c: int32): int32 =
    if c >= 65:
        if c <= 90: return 1
    if c >= 97:
        if c <= 122: return 1
    return 0

fn is_digit(c: int32): int32 =
    if c >= 48:
        if c <= 57: return 1
    return 0

fn is_space(c: int32): int32 =
    if c == 32: return 1
    if c == 9: return 1
    if c == 10: return 1
    return 0

// Count word-like tokens (alpha sequences) in buffer
fn count_words(buf: int32[], len: int32): int32 =
    var count: int32 = 0
    var in_word: int32 = 0
    var i: int32 = 0
    while i < len / 4:
        let c: int32 = buf[i]
        if c == 0: break
        if is_space(c) != 0:
            in_word = 0
        else:
            if in_word == 0:
                count = count + 1
                in_word = 1
        i = i + 1
    return count

fn main(): int32 =
    let fd: int32 = cold_open("README.md", 0)
    if fd < 0: return 1
    var buf: int32[1024]
    let n: int32 = cold_read(fd, buf, 4096)
    let _: int32 = cold_close(fd)
    if n <= 0: return 2
    let count: int32 = count_words(buf, n)
    if count > 0: return 42
    return count
