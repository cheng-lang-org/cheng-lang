// Bootstrap tokenizer v2 — minimal file read + byte counting
// Self-hosting proof: compiles with cold compiler

import libc

fn main(): int32 =
    let fd: int32 = cold_open("README.md", 0)
    if fd < 0: return 1
    var buf: int32[1024]
    let n: int32 = cold_read(fd, buf, 4096)
    let _: int32 = cold_close(fd)
    if n <= 0: return 2
    return n
