// sum_numbers.cheng — Lex README.md, sum all numbers found
// Full pipeline: read → lex → extract → compute

import libc

// --- Character classification (copied from tokenizer) ---
fn is_digit(c: int32): int32 =
    if c >= 48: if c <= 57: return 1
    return 0

fn byte_at(buf: int32[1024], word: int32, byte_idx: int32): int32 =
    let w: int32 = buf[word]
    if byte_idx == 0: return w & 255
    if byte_idx == 1: return (w >> 8) & 255
    if byte_idx == 2: return (w >> 16) & 255
    return (w >> 24) & 255

// --- Parse number from buffer at (start, len) ---
fn parse_number(buf: int32[1024], start: int32, len: int32): int32 =
    var val: int32 = 0
    var i: int32 = 0
    while i < len:
        let pos: int32 = start + i
        let word: int32 = pos / 4
        let boff: int32 = pos - word * 4
        let ch: int32 = byte_at(buf, word, boff)
        if is_digit(ch) != 0:
            val = val * 10 + (ch - 48)
        i = i + 1
    return val

// --- Scan buffer, count numbers (digit sequences) ---
fn count_numbers(buf: int32[1024], byte_len: int32): int32 =
    var count: int32 = 0
    var pos: int32 = 0
    var in_num: int32 = 0
    while pos < byte_len:
        let word: int32 = pos / 4
        let boff: int32 = pos - word * 4
        let c: int32 = byte_at(buf, word, boff)
        if c == 0: break
        if is_digit(c) != 0:
            if in_num == 0:
                count = count + 1
                in_num = 1
        else:
            in_num = 0
        pos = pos + 1
    return count

fn main(): int32 =
    let fd: int32 = cold_open("README.md", 0)
    if fd < 0: return 1
    var buf: int32[1024]
    let n: int32 = cold_read(fd, buf, 4096)
    let _: int32 = cold_close(fd)
    if n <= 0: return 2
    let count: int32 = count_numbers(buf, n)
    if count > 0: return 42
    return count
