// codegen_obj.cheng — Direct .o via mmap + ptrStoreI32
// Avoids stack array cold_write bug

import libc

fn write_word(buf: int64, idx: int32, val: int32) =
    ptrStoreI32(buf + int64(idx * 4), val)

fn main(): int32 =
    let buf: int64 = cold_mmap(4096)
    if buf == 0: return 1

    var i: int32 = 0
    write_word(buf, i, 0xFEEDFACF); i = i + 1
    write_word(buf, i, 0x0100000C); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000001); i = i + 1
    write_word(buf, i, 0x00000003); i = i + 1
    write_word(buf, i, 0x000000C8); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000019); i = i + 1
    write_word(buf, i, 0x00000098); i = i + 1
    write_word(buf, i, 0x45545F5F); i = i + 1
    write_word(buf, i, 0x00005458); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000028); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x000000E8); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000028); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000007); i = i + 1
    write_word(buf, i, 0x00000007); i = i + 1
    write_word(buf, i, 0x00000001); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x65745F5F); i = i + 1
    write_word(buf, i, 0x00007478); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x45545F5F); i = i + 1
    write_word(buf, i, 0x00005458); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000028); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x000000E8); i = i + 1
    write_word(buf, i, 0x00000002); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x80000400); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000032); i = i + 1
    write_word(buf, i, 0x00000018); i = i + 1
    write_word(buf, i, 0x00000001); i = i + 1
    write_word(buf, i, 0x000E0000); i = i + 1
    write_word(buf, i, 0x000E0000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000002); i = i + 1
    write_word(buf, i, 0x00000018); i = i + 1
    write_word(buf, i, 0x00000110); i = i + 1
    write_word(buf, i, 0x00000001); i = i + 1
    write_word(buf, i, 0x00000120); i = i + 1
    write_word(buf, i, 0x00000008); i = i + 1
    // Code: mov w0, #42; ret
    write_word(buf, i, 0x52800540); i = i + 1
    write_word(buf, i, 0xD65F03C0); i = i + 1
    // Zero pad
    write_word(buf, i, 0); i = i + 1
    write_word(buf, i, 0); i = i + 1
    write_word(buf, i, 0); i = i + 1
    write_word(buf, i, 0); i = i + 1
    write_word(buf, i, 0); i = i + 1
    write_word(buf, i, 0); i = i + 1
    write_word(buf, i, 0); i = i + 1
    write_word(buf, i, 0); i = i + 1
    // Symbol table + string table tail
    write_word(buf, i, 0x00000001); i = i + 1
    write_word(buf, i, 0x0000010F); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x00000000); i = i + 1
    write_word(buf, i, 0x616D5F00); i = i + 1
    write_word(buf, i, 0x00006E69); i = i + 1

    let fd: int32 = cold_open("/tmp/direct_obj.o", 1537)
    if fd < 0: return 2
    let n: int32 = cold_write(fd, buf, 296)
    let _: int32 = cold_close(fd)
    if n == 296: return 42
    return n
