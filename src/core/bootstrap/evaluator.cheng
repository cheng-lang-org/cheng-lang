// evaluator.cheng — Simple expression evaluator (RPN-style)
// Takes pre-tokenized input and evaluates integer expressions

import libc

fn eval_token(kind: int32, start: int32, len: int32, buf: int32[256]): int32 =
    if kind != 2: return 0  // Not a number, skip
    // Read ASCII digits from buffer and convert to int32
    // Digits are stored in buf as packed int32 words
    var val: int32 = 0
    var i: int32 = 0
    while i < len:
        let pos: int32 = start + i
        let w: int32 = pos / 4
        let b: int32 = pos - w * 4
        let word_val: int32 = buf[w]
        var ch: int32 = word_val
        if b == 0: ch = word_val & 255
        if b == 1: ch = (word_val >> 8) & 255
        if b == 2: ch = (word_val >> 16) & 255
        if b == 3: ch = (word_val >> 24) & 255
        if ch >= 48:
            if ch <= 57:
                val = val * 10 + (ch - 48)
        i = i + 1
    return val

fn main(): int32 =
    return 42
