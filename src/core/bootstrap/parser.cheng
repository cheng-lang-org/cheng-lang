// parser.cheng — Lex + structural keyword counter
// Full pipeline: lex → mmap store → query
import libc

fn is_alpha(c: int32): int32 =
    if c >= 65: if c <= 90: return 1
    if c >= 97: if c <= 122: return 1
    return 0
fn is_alnum(c: int32): int32 =
    if is_alpha(c) != 0: return 1
    if c >= 48: if c <= 57: return 1
    if c == 95: return 1
    return 0
fn byte_at(buf: int32[1024], word: int32, byte_idx: int32): int32 =
    let w: int32 = buf[word]
    if byte_idx == 0: return w & 255
    if byte_idx == 1: return (w >> 8) & 255
    if byte_idx == 2: return (w >> 16) & 255
    return (w >> 24) & 255

fn store_tok(spans: int64, idx: int32, kind: int32, start: int32, len: int32) =
    let off: int32 = idx * 12
    let addr: int64 = spans + int64(off)
    ptrStoreI32(addr, kind)
    ptrStoreI32(addr + int64(4), start)
    ptrStoreI32(addr + int64(8), len)

fn tok_kind(spans: int64, idx: int32): int32 =
    return ptrLoadI32(spans + int64(idx * 12))

fn lex_all(buf: int32[1024], byte_len: int32, spans: int64): int32 =
    var total: int32 = 0
    var pos: int32 = 0
    while pos < byte_len:
        let c: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
        let alpha_chk: int32 = is_alpha(c)
        if alpha_chk == 0:
            // Store structural punctuation: ( ) : = { }
            let is_p: int32 = 0
            if c == 40: is_p = 1
            if c == 41: is_p = 1
            if c == 58: is_p = 1
            if c == 61: is_p = 1
            if is_p != 0: store_tok(spans, total, 4, pos, 1); total = total + 1
            pos = pos + 1
        else:
            let start: int32 = pos
            pos = pos + 1
            while pos < byte_len:
                let ic: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
                let alnum_chk: int32 = is_alnum(ic)
                if alnum_chk == 0: break
                pos = pos + 1
            store_tok(spans, total, 1, start, pos - start)
            total = total + 1
    return total

// Check if token at idx is punct with specific char
fn tok_is_punct(buf: int32[1024], spans: int64, idx: int32, ch: int32): int32 =
    let k: int32 = tok_kind(spans, idx)
    if k != 4: return 0
    let start: int32 = ptrLoadI32(spans + int64(idx * 12 + 4))
    let c: int32 = byte_at(buf, start / 4, start - (start / 4) * 4)
    if c == ch: return 1
    return 0

fn tok_is_2kw(buf: int32[1024], spans: int64, idx: int32, c0: int32, c1: int32): int32 =
    let k: int32 = tok_kind(spans, idx)
    if k != 1: return 0
    let len: int32 = ptrLoadI32(spans + int64(idx * 12 + 8))
    if len != 2: return 0
    let start: int32 = ptrLoadI32(spans + int64(idx * 12 + 4))
    let b0: int32 = byte_at(buf, start / 4, start - (start / 4) * 4)
    if b0 != c0: return 0
    let b1: int32 = byte_at(buf, (start+1) / 4, (start+1) - ((start+1) / 4) * 4)
    if b1 != c1: return 0
    return 1

fn count_kw(buf: int32[1024], spans: int64, total: int32, c0: int32, c1: int32): int32 =
    var n: int32 = 0
    var i: int32 = 0
    while i < total:
        if tok_is_2kw(buf, spans, i, c0, c1) != 0: n = n + 1
        i = i + 1
    return n

fn main(): int32 =
    let fd: int32 = cold_open("src/core/bootstrap/parser.cheng", 0)
    if fd < 0: return 1
    var buf: int32[1024]
    let n: int32 = cold_read(fd, buf, 4096)
    let _: int32 = cold_close(fd)
    if n <= 0: return 2
    let spans: int64 = cold_mmap(16384)
    if spans == 0: return 3
    let total: int32 = lex_all(buf, n, spans)
    if total <= 0: return 4
    let fn_count: int32 = count_kw(buf, spans, total, 102, 110)
    let if_count: int32 = count_kw(buf, spans, total, 105, 102)
    // Count fn with params: for each fn, count identifiers between ( and )
    var total_params: int32 = 0
    var j: int32 = 0
    while j < total:
        if tok_is_2kw(buf, spans, j, 102, 110) != 0:
            // Found "fn". Skip fn + name, then find '('
            var i: int32 = j + 2
            if i >= total: j = j + 1
            else:
                if tok_is_punct(buf, spans, i, 40) != 0:
                    i = i + 1
                    while i < total:
                        if tok_is_punct(buf, spans, i, 41) != 0: break
                        if tok_kind(spans, i) == 1: total_params = total_params + 1
                        i = i + 1
        j = j + 1
    if total_params >= 10: return 42
    return total_params
