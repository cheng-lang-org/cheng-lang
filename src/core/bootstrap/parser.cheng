// parser.cheng — Combined lexer + parser with mmap span storage
// Flat sequential logic (no deep nesting) for cold compiler compatibility

import libc

fn is_alpha(c: int32): int32 =
    if c >= 65: if c <= 90: return 1
    if c >= 97: if c <= 122: return 1
    return 0

fn is_digit(c: int32): int32 =
    if c >= 48: if c <= 57: return 1
    return 0

fn is_alnum(c: int32): int32 =
    if is_alpha(c) != 0: return 1
    if is_digit(c) != 0: return 1
    if c == 95: return 1
    return 0

fn is_space(c: int32): int32 =
    if c == 32: return 1
    if c == 9: return 1
    if c == 10: return 1
    if c == 13: return 1
    return 0

fn byte_at(buf: int32[1024], word: int32, byte_idx: int32): int32 =
    let w: int32 = buf[word]
    if byte_idx == 0: return w & 255
    if byte_idx == 1: return (w >> 8) & 255
    if byte_idx == 2: return (w >> 16) & 255
    return (w >> 24) & 255

fn store_tok(spans: int64, idx: int32, kind: int32, start: int32, len: int32) =
    let off: int32 = idx * 12
    let addr: int64 = spans + int64(off)
    ptrStoreI32(addr, kind)
    ptrStoreI32(addr + int64(4), start)
    ptrStoreI32(addr + int64(8), len)

fn load_kind(spans: int64, idx: int32): int32 =
    return ptrLoadI32(spans + int64(idx * 12))

fn load_start(spans: int64, idx: int32): int32 =
    return ptrLoadI32(spans + int64(idx * 12 + 4))

fn load_len(spans: int64, idx: int32): int32 =
    return ptrLoadI32(spans + int64(idx * 12 + 8))

// Lex: scan and store identifier + punctuation tokens
fn lex_tokens(buf: int32[1024], byte_len: int32, spans: int64): int32 =
    var total: int32 = 0
    var pos: int32 = 0
    while pos < byte_len:
        let c: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
        if c == 0: pos = byte_len
        else:
            if is_space(c) != 0: pos = pos + 1
            else:
                if c == 47:  // comment
                    pos = pos + 1
                    if pos < byte_len:
                        let nc: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
                        if nc == 47:
                            while pos < byte_len:
                                let lc: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
                                if lc == 10: break
                                pos = pos + 1
                    pos = pos + 1
                else:
                    if is_alpha(c) != 0:
                        let start: int32 = pos
                        pos = pos + 1
                        while pos < byte_len:
                            let ic: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
                            if is_alnum(ic) == 0: break
                            pos = pos + 1
                        store_tok(spans, total, 1, start, pos - start)
                        total = total + 1
                    else:
                        if is_digit(c) != 0:
                            pos = pos + 1
                            while pos < byte_len:
                                let dc: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
                                if is_digit(dc) == 0: break
                                pos = pos + 1
                        else:
                            store_tok(spans, total, 4, pos, 1)
                            total = total + 1
                            pos = pos + 1
    return total

fn count_kind(spans: int64, total: int32, kind: int32): int32 =
    var n: int32 = 0
    var i: int32 = 0
    while i < total:
        let k: int32 = load_kind(spans, i)
        if k == kind: n = n + 1
        i = i + 1
    return n

fn main(): int32 =
    let fd: int32 = cold_open("src/core/bootstrap/parser.cheng", 0)
    if fd < 0: return 1
    var buf: int32[1024]
    let n: int32 = cold_read(fd, buf, 4096)
    let _: int32 = cold_close(fd)
    if n <= 0: return 2

    let spans: int64 = cold_mmap(16384)
    if spans == 0: return 3

    let total: int32 = lex_tokens(buf, n, spans)
    if total <= 0: return 4

    let idents: int32 = count_kind(spans, total, 1)
    let puncts: int32 = count_kind(spans, total, 4)
    if idents > 10: if puncts > 10: return 42
    return 0
