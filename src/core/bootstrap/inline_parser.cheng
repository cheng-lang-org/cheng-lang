// inline_parser.cheng — Inline lex+parse: count fn definitions
// Avoids mmap token storage (int64 ptrStore bug workaround)
// Cold-compiler: int32/while/if/bitwise/array only

import libc

fn is_alpha(c: int32): int32 =
    if c >= 65: if c <= 90: return 1
    if c >= 97: if c <= 122: return 1
    return 0

fn is_alnum(c: int32): int32 =
    if is_alpha(c) != 0: return 1
    if c >= 48: if c <= 57: return 1
    if c == 95: return 1
    return 0

fn is_space(c: int32): int32 =
    if c == 32: return 1
    if c == 9: return 1
    if c == 10: return 1
    if c == 13: return 1
    return 0

fn byte_at(buf: int32[1024], word: int32, byte_idx: int32): int32 =
    let w: int32 = buf[word]
    if byte_idx == 0: return w & 255
    if byte_idx == 1: return (w >> 8) & 255
    if byte_idx == 2: return (w >> 16) & 255
    return (w >> 24) & 255

// Count "fn <ident>" patterns (function definitions)
fn count_functions(buf: int32[1024], byte_len: int32): int32 =
    var count: int32 = 0
    var pos: int32 = 0
    while pos < byte_len:
        let c: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
        // Look for 'f' followed by 'n' followed by non-alnum
        if c == 102:
            let npos: int32 = pos + 1
            if npos < byte_len:
                let nc: int32 = byte_at(buf, npos / 4, npos - (npos / 4) * 4)
                if nc == 110:
                    let apos: int32 = pos + 2
                    if apos < byte_len:
                        let ac: int32 = byte_at(buf, apos / 4, apos - (apos / 4) * 4)
                        // 'fn' must be followed by non-alnum (space, punct, etc.)
                        let is_follow: int32 = is_alnum(ac)
                        if is_follow == 0:
                            // Skip whitespace after 'fn'
                            var sp: int32 = apos
                            while sp < byte_len:
                                let sc: int32 = byte_at(buf, sp / 4, sp - (sp / 4) * 4)
                                let space_chk: int32 = is_space(sc)
                                if space_chk == 0: break
                                sp = sp + 1
                            // Check next char is alpha (start of function name)
                            if sp < byte_len:
                                let fc: int32 = byte_at(buf, sp / 4, sp - (sp / 4) * 4)
                                let alpha_chk: int32 = is_alpha(fc)
                                if alpha_chk != 0:
                                    count = count + 1
                            pos = sp
        pos = pos + 1
    return count

// Count "return" keyword occurrences (flat logic)
fn count_returns(buf: int32[1024], byte_len: int32): int32 =
    var count: int32 = 0
    var pos: int32 = 0
    while pos < byte_len:
        // Check if "return" at pos
        if pos + 6 > byte_len: pos = pos + 1
        else:
            let c0: int32 = byte_at(buf, pos / 4, pos - (pos / 4) * 4)
            if c0 == 114:  // 'r'
                let c1: int32 = byte_at(buf, (pos+1) / 4, (pos+1) - ((pos+1) / 4) * 4)
                if c1 == 101:  // 'e'
                    let c2: int32 = byte_at(buf, (pos+2) / 4, (pos+2) - ((pos+2) / 4) * 4)
                    if c2 == 116:  // 't'
                        let c3: int32 = byte_at(buf, (pos+3) / 4, (pos+3) - ((pos+3) / 4) * 4)
                        if c3 == 117:  // 'u'
                            let c4: int32 = byte_at(buf, (pos+4) / 4, (pos+4) - ((pos+4) / 4) * 4)
                            if c4 == 114:  // 'r'
                                let c5: int32 = byte_at(buf, (pos+5) / 4, (pos+5) - ((pos+5) / 4) * 4)
                                if c5 == 110: count = count + 1
            pos = pos + 1
    return count

fn main(): int32 =
    let fd: int32 = cold_open("src/core/bootstrap/inline_parser.cheng", 0)
    if fd < 0: return 1
    var buf: int32[1024]
    let n: int32 = cold_read(fd, buf, 4096)
    let _: int32 = cold_close(fd)
    if n <= 0: return 2

    let fn_count: int32 = count_functions(buf, n)
    // This file should have 7 fn definitions (self-check)
    if fn_count >= 5: return 42
    return fn_count
