// span.cheng — Span utilities (start, len as separate int32)
// Cold-compiler compatible: no int64 packing needed

fn span_len(start: int32, len: int32): int32 = return len
fn span_end(start: int32, len: int32): int32 = return start + len
fn span_empty(start: int32, len: int32): int32 =
    if len <= 0: return 1
    return 0
