import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import std/strutils as strutil

type
    CompilerEquivalenceProof =
        version: int32
        packageId: str
        channel: str
        baselineGraphCid: layout.FixedBytes32
        migratedGraphCid: layout.FixedBytes32
        baselineSurfaceCid: layout.FixedBytes32
        migratedSurfaceCid: layout.FixedBytes32
        baselineReceiptCid: layout.FixedBytes32
        migratedReceiptCid: layout.FixedBytes32
        targetTriple: str
        graphEquivalent: int32
        exportSurfaceCompatible: int32
        compileReceiptEquivalent: int32
        equivalenceLabel: str
        proofCid: layout.FixedBytes32

fn CompilerEquivalenceAppendText(buf: var layout.ByteBuf, text: str) =
    lt.AppendU32BE(buf, len(text))
    for i in 0..<len(text):
        layout.ByteBufAppendByte(buf, int32(text[i]) & 255)

fn CompilerEquivalenceFlag(value: bool): int32 =
    if value:
        return 1
    return 0

fn CompilerEquivalenceKind(graphEquivalent: bool,
                             exportSurfaceCompatible: bool,
                             compileReceiptEquivalent: bool): str =
    if graphEquivalent:
        if exportSurfaceCompatible:
            if compileReceiptEquivalent:
                return "canonical_semantic_identity"
    return "incompatible"

fn CompilerEquivalenceProofMake(packageId: str,
                                  channelRaw: str,
                                  baselineGraphCid: layout.FixedBytes32,
                                  migratedGraphCid: layout.FixedBytes32,
                                  baselineSurfaceCid: layout.FixedBytes32,
                                  migratedSurfaceCid: layout.FixedBytes32,
                                  baselineReceiptCid: layout.FixedBytes32,
                                  migratedReceiptCid: layout.FixedBytes32,
                                  targetTriple: str,
                                  graphEquivalent: int32,
                                  exportSurfaceCompatible: int32,
                                  compileReceiptEquivalent: int32,
                                  out: var CompilerEquivalenceProof): Result[bool] =
    let channelRes = cworld.CompilerWorldNormalizeChannel(channelRaw)
    if IsErr(channelRes):
        return Err[bool](Error(channelRes))
    let equivalenceLabel = CompilerEquivalenceKind(graphEquivalent != 0,
                                                     exportSurfaceCompatible != 0,
                                                     compileReceiptEquivalent != 0)
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    CompilerEquivalenceAppendText(buf, "cheng.compiler.equivalence_proof")
    CompilerEquivalenceAppendText(buf, packageId)
    CompilerEquivalenceAppendText(buf, Value(channelRes))
    lt.AppendFixed32(buf, baselineGraphCid)
    lt.AppendFixed32(buf, migratedGraphCid)
    lt.AppendFixed32(buf, baselineSurfaceCid)
    lt.AppendFixed32(buf, migratedSurfaceCid)
    lt.AppendFixed32(buf, baselineReceiptCid)
    lt.AppendFixed32(buf, migratedReceiptCid)
    CompilerEquivalenceAppendText(buf, targetTriple)
    lt.AppendU32BE(buf, graphEquivalent)
    lt.AppendU32BE(buf, exportSurfaceCompatible)
    lt.AppendU32BE(buf, compileReceiptEquivalent)
    CompilerEquivalenceAppendText(buf, equivalenceLabel)
    out.version = 1
    out.packageId = packageId
    out.channel = Value(channelRes)
    out.baselineGraphCid = baselineGraphCid
    out.migratedGraphCid = migratedGraphCid
    out.baselineSurfaceCid = baselineSurfaceCid
    out.migratedSurfaceCid = migratedSurfaceCid
    out.baselineReceiptCid = baselineReceiptCid
    out.migratedReceiptCid = migratedReceiptCid
    out.targetTriple = targetTriple
    out.graphEquivalent = graphEquivalent
    out.exportSurfaceCompatible = exportSurfaceCompatible
    out.compileReceiptEquivalent = compileReceiptEquivalent
    out.equivalenceLabel = equivalenceLabel
    out.proofCid = lt.FixedCidFromBuf(buf)
    return Ok[bool](true)

fn CompilerEquivalenceGraphCidFromText(text: str,
                                         out: var layout.FixedBytes32): Result[bool] =
    let cidRes = ccsg.CompilerCsgCanonicalGraphCidFromReportText(text)
    if IsErr(cidRes):
        return Err[bool](Error(cidRes))
    out = Value(cidRes)
    return Ok[bool](true)

fn CompilerEquivalenceGraphCompareTexts(baselineCsgText: str,
                                          migratedCsgText: str,
                                          outBaselineCid: var layout.FixedBytes32,
                                          outMigratedCid: var layout.FixedBytes32,
                                          outEquivalent: var int32): Result[bool] =
    let baselineCidRes = CompilerEquivalenceGraphCidFromText(baselineCsgText, outBaselineCid)
    if IsErr(baselineCidRes):
        return Err[bool](Error(baselineCidRes))
    let migratedCidRes = CompilerEquivalenceGraphCidFromText(migratedCsgText, outMigratedCid)
    if IsErr(migratedCidRes):
        return Err[bool](Error(migratedCidRes))
    outEquivalent = CompilerEquivalenceFlag(layout.FixedBytes32Equal(outBaselineCid, outMigratedCid))
    return Ok[bool](true)

fn CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText: str,
                                            migratedSurfaceText: str,
                                            outBaselineCid: var layout.FixedBytes32,
                                            outMigratedCid: var layout.FixedBytes32,
                                            outCompatible: var int32): Result[bool] =
    var baselineSurface: ccsg.CsgExportSurface
    let baselineSurfaceRes = ccsg.CompilerExportSurfaceFromReportText(baselineSurfaceText, baselineSurface)
    if IsErr(baselineSurfaceRes):
        return Err[bool](Error(baselineSurfaceRes))
    var migratedSurface: ccsg.CsgExportSurface
    let migratedSurfaceRes = ccsg.CompilerExportSurfaceFromReportText(migratedSurfaceText, migratedSurface)
    if IsErr(migratedSurfaceRes):
        return Err[bool](Error(migratedSurfaceRes))
    outBaselineCid = baselineSurface.surfaceCid
    outMigratedCid = migratedSurface.surfaceCid
    outCompatible = CompilerEquivalenceFlag(ccsg.CompilerExportSurfaceCompatible(baselineSurface, migratedSurface))
    return Ok[bool](true)

fn CompilerEquivalenceReceiptCompareTexts(baselineReceiptText: str,
                                            migratedReceiptText: str,
                                            outBaselineCid: var layout.FixedBytes32,
                                            outMigratedCid: var layout.FixedBytes32,
                                            outTargetTriple: var str,
                                            outEquivalent: var int32): Result[bool] =
    var baselineReceipt: ccsg.CompileReceipt
    let baselineReceiptRes = ccsg.CompileReceiptFromReportText(baselineReceiptText, baselineReceipt)
    if IsErr(baselineReceiptRes):
        return Err[bool](Error(baselineReceiptRes))
    var migratedReceipt: ccsg.CompileReceipt
    let migratedReceiptRes = ccsg.CompileReceiptFromReportText(migratedReceiptText, migratedReceipt)
    if IsErr(migratedReceiptRes):
        return Err[bool](Error(migratedReceiptRes))
    outBaselineCid = baselineReceipt.receiptCid
    outMigratedCid = migratedReceipt.receiptCid
    outTargetTriple = migratedReceipt.targetTriple
    outEquivalent = CompilerEquivalenceFlag(ccsg.CompileReceiptEquivalent(baselineReceipt, migratedReceipt))
    return Ok[bool](true)

fn CompilerEquivalencePassed(proof: CompilerEquivalenceProof): bool =
    return proof.graphEquivalent != 0 &&
           proof.exportSurfaceCompatible != 0 &&
           proof.compileReceiptEquivalent != 0 &&
           proof.equivalenceLabel == "canonical_semantic_identity"

fn CompilerEquivalenceProofReport(proof: CompilerEquivalenceProof): str =
    var out = ""
    out = strutil.Join([out, "version=1\n"], "")
    out = strutil.Join([out, "package_id=", proof.packageId, "\n"], "")
    out = strutil.Join([out, "channel=", proof.channel, "\n"], "")
    out = strutil.Join([out, ccsg.CompilerCsgEgraphActiveContractReport(), "\n"], "")
    out = strutil.Join([out, "baseline_graph_cid=", layout.FixedBytes32Hex(proof.baselineGraphCid), "\n"], "")
    out = strutil.Join([out, "migrated_graph_cid=", layout.FixedBytes32Hex(proof.migratedGraphCid), "\n"], "")
    out = strutil.Join([out, "baseline_surface_cid=", layout.FixedBytes32Hex(proof.baselineSurfaceCid), "\n"], "")
    out = strutil.Join([out, "migrated_surface_cid=", layout.FixedBytes32Hex(proof.migratedSurfaceCid), "\n"], "")
    out = strutil.Join([out, "baseline_receipt_cid=", layout.FixedBytes32Hex(proof.baselineReceiptCid), "\n"], "")
    out = strutil.Join([out, "migrated_receipt_cid=", layout.FixedBytes32Hex(proof.migratedReceiptCid), "\n"], "")
    out = strutil.Join([out, "target=", proof.targetTriple, "\n"], "")
    out = strutil.Join([out, "graph_equivalent=", IntToStr(proof.graphEquivalent), "\n"], "")
    out = strutil.Join([out, "export_surface_compatible=", IntToStr(proof.exportSurfaceCompatible), "\n"], "")
    out = strutil.Join([out, "compile_receipt_equivalent=", IntToStr(proof.compileReceiptEquivalent), "\n"], "")
    out = strutil.Join([out, "equivalence_kind=", proof.equivalenceLabel, "\n"], "")
    out = strutil.Join([out, "proof_cid=", layout.FixedBytes32Hex(proof.proofCid)], "")
    return out
