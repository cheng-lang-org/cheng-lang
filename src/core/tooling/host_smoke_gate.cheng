import std/os
import std/parseutils
import std/strings
import std/strutils as strutil
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn HostSmokePrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn HostSmokePrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn HostSmokeStartsWith(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    return strings.SliceBytes(text, 0, len(prefix)) == prefix

fn HostSmokeReadFlag(args: str[],
                       key: str,
                       defaultValue: str): str =
    for i in 0..<args.len:
        let arg = args[i]
        if arg == key && i + 1 < args.len:
            return args[i + 1]
        if HostSmokeStartsWith(arg, strutil.Join([key, ":"], "")):
            return strings.SliceBytes(arg, len(key) + 1, len(arg) - len(key) - 1)
        if HostSmokeStartsWith(arg, strutil.Join([key, "="], "")):
            return strings.SliceBytes(arg, len(key) + 1, len(arg) - len(key) - 1)
    return defaultValue

fn HostSmokeHasFlag(args: str[], key: str): bool =
    for i in 0..<args.len:
        let arg = args[i]
        if arg == key || HostSmokeStartsWith(arg, strutil.Join([key, ":"], "")) || HostSmokeStartsWith(arg, strutil.Join([key, "="], "")):
            return true
    return false

fn HostSmokeCollectPositionals(args: str[]): str[] =
    var out: str[]
    var i: int32
    while i < args.len:
        let arg = args[i]
        if arg == "--compiler" || arg == "--label" || arg == "--tail-only":
            i = i + 2
        elif HostSmokeStartsWith(arg, "--compiler:") ||
             HostSmokeStartsWith(arg, "--compiler=") ||
             HostSmokeStartsWith(arg, "--label:") ||
             HostSmokeStartsWith(arg, "--label=") ||
             HostSmokeStartsWith(arg, "--tail-only:") ||
             HostSmokeStartsWith(arg, "--tail-only="):
            i = i + 1
        elif len(arg) > 0 && arg[0] == '-':
            i = i + 1
        else:
            add(out, arg)
            i = i + 1
    return out

