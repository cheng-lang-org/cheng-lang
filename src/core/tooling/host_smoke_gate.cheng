    ]

fn HostSmokeResolveCompiler(root: str,
                              args: str[],
                              outCompiler: var str): int32 =
    outCompiler = strutil.Strip(HostSmokeReadFlag(args, "--compiler", ""))
    if len(outCompiler) <= 0:
        outCompiler = strutil.Strip(os.GetEnvDefault("CHENG_SMOKE_COMPILER", ""))
    if len(outCompiler) <= 0:
        outCompiler = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    else:
        outCompiler = chengpath.PathAbsolute(root, outCompiler)
    if !chengpath.FileExistsNonEmpty(root, outCompiler):
        HostSmokePrintErr(strutil.Join(["host smokes: missing compiler: ", outCompiler], ""))
        return 1
    return 0

fn HostSmokeLabel(args: str[]): str =
    let explicit = strutil.Strip(HostSmokeReadFlag(args, "--label", ""))
    if len(explicit) > 0:
        return explicit
    let envLabel = strutil.Strip(os.GetEnvDefault("CHENG_SMOKE_LABEL", ""))
    if len(envLabel) > 0:
        return envLabel
    return "host"

fn HostSmokeRunTimeoutSec(smokeName: str): int32 =
    if smokeName == "backend_driver_command_surface_smoke":
        return 420
    if smokeName == "backend_driver_selfhost_progress_smoke":
        return 240
    if smokeName == "wow_export_root_install_smoke":
        return 240
    if smokeName == "compiler_world_fresh_node_selfhost_smoke":
        return 420
    if smokeName == "compiler_world_libp2p_smoke" ||
       smokeName == "compiler_world_manifest_closure_smoke" ||
       smokeName == "compiler_migration_publish_smoke" ||
       smokeName == "compiler_managed_dependency_mirror_smoke":
        return 180
    if smokeName == "perf_memory_contract_smoke":
        return 600
    if smokeName == "thread_atomic_orc_runtime_gate_smoke":
        return 420
    return 90

fn HostSmokeReportValue(reportText: str,
                         key: str): str =
    let prefix = strutil.Join([key, "="], "")
    let lines = strutil.Split(reportText, '\n')
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if strutil.StartsWith(line, prefix):
            return chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
    return ""

fn HostSmokeReportPositiveInt(reportText: str,
                               key: str,
                               outValue: var int32): bool =
    let valueText = HostSmokeReportValue(reportText, key)
    if len(valueText) <= 0:
        HostSmokePrintErr(strutil.Join(["host smokes: missing report field: ", key], ""))
        return false
    let parsed = parseutils.ParseInt32(valueText, outValue)
    if parsed != len(valueText):
        HostSmokePrintErr(strutil.Join(["host smokes: invalid integer report field: ", key], ""))
        return false
    if outValue <= 0:
        HostSmokePrintErr(strutil.Join(["host smokes: non-positive report field: ", key], ""))
        return false
    return true

fn HostSmokeCompileReportOk(root: str,
                              smokeName: str,
                              reportPath: str): bool =
    if smokeName != "thread_atomic_orc_runtime_gate_smoke":
        return true
    if !chengpath.FileExistsNonEmpty(root, reportPath):
        HostSmokePrintErr(strutil.Join(["host smokes: missing compile report: ", reportPath], ""))
        return false
    let reportText = os.ReadFile(reportPath)
    if HostSmokeReportValue(reportText, "system_link_exec_runtime_execute") != "1":
        HostSmokePrintErr("host smokes: thread/atomic/ORC gate missing runtime execute marker")
        return false
    if HostSmokeReportValue(reportText, "system_link_exec_runtime_standalone_no_runtime") == "1":
        HostSmokePrintErr("host smokes: thread/atomic/ORC gate compiled through standalone no-runtime path")
        return false
    var providerCount: int32
    if !HostSmokeReportPositiveInt(reportText, "provider_object_count", providerCount):
        HostSmokePrintErr("host smokes: thread/atomic/ORC gate compiled without runtime providers")
        return false
    return true

fn HostSmokeCompileEnv(): str[] =
    var out: str[]
    add(out, "BACKEND_INCREMENTAL=0")
    add(out, "BACKEND_MULTI_MODULE_CACHE=0")
    add(out, "CHENG_DISABLE_PRIMARY_OBJECT_CACHE=1")
    add(out, "BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0")
    add(out, "BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0")
    add(out, "CHENG_PROGRESS=1")
    add(out, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")
    return out

fn HostSmokeExpectedRunMarker(smokeName: str): str =
    if smokeName == "host_smoke_gate_contract_smoke":
        return " host_smoke_gate_contract_smoke ok"
    if smokeName == "thread_atomic_orc_runtime_gate_smoke":
        return " thread_atomic_orc_runtime_gate_smoke ok"
    if smokeName == "function_task_contract_smoke":
        return " function_task_contract_smoke ok"
    if smokeName == "function_task_executor_contract_smoke":
        return " function_task_executor_contract_smoke ok"
    if smokeName == "body_ir_dod_soa_contract_smoke":
        return " body_ir_dod_soa_contract_smoke ok"
    if smokeName == "body_ir_noalias_proof_smoke":
        return " body_ir_noalias_proof_smoke ok"
    if smokeName == "cfg_body_ir_contract_smoke":
        return " cfg_body_ir_contract_smoke ok"
    if smokeName == "cold_csg_facts_exporter_smoke":
        return " cold_csg_facts_exporter_smoke ok"
    if smokeName == "compiler_csg_egraph_active_contract_smoke":
        return " compiler_csg_egraph_active_contract_smoke ok"
    return ""

fn HostSmokeExpectContains(label: str,
                            text: str,
                            needle: str): bool =
    if strings.StrContains(text, needle):
        return true
    HostSmokePrintErr(strutil.Join([label, ": missing marker: ", needle], ""))
    return false

fn HostSmokeExpectNotContains(label: str,
                               text: str,
                               needle: str): bool =
    if !strings.StrContains(text, needle):
        return true
    HostSmokePrintErr(strutil.Join([label, ": forbidden marker: ", needle], ""))
    return false

fn HostSmokeRunMarkerOk(smokeName: str, outputText: str): bool =
    let marker = HostSmokeExpectedRunMarker(smokeName)
    if len(marker) <= 0:
        return true
    if strings.StrContains(outputText, marker):
        return true
    HostSmokePrintErr(strutil.Join(["host smokes: missing run marker for ", smokeName, ": ", marker], ""))
    return false

fn HostSmokeRunColdCsgSidecarSmoke(root: str,
                                    compiler: str,
                                    outDir: str): int32 =
    let smokeName = "cold_csg_sidecar_smoke"
    let src = chengpath.PathAbsolute(root, "src/tests/backend_matrix_cfg_if_guard.cheng")
    if !chengpath.FileExistsNonEmpty(root, src):
        HostSmokePrintErr(strutil.Join(["host smokes: missing source: ", src], ""))
        return 1
    let matchSrc = chengpath.PathAbsolute(root, "src/tests/cold_csg_match_fixture.cheng")
    if !chengpath.FileExistsNonEmpty(root, matchSrc):
        HostSmokePrintErr(strutil.Join(["host smokes: missing source: ", matchSrc], ""))
        return 1
    let outBin = os.JoinPath(outDir, smokeName)
    let factsPath = strutil.Join([outBin, ".cold.csg"], "")
    let reportPath = strutil.Join([outBin, ".compile.report.txt"], "")
    let compileLog = strutil.Join([outBin, ".compile.log"], "")
    let runLog = strutil.Join([outBin, ".run.log"], "")
    let coldCompiler = os.JoinPath(outDir, "cheng_cold_sidecar_probe")
    let coldBuildLog = strutil.Join([coldCompiler, ".build.log"], "")
    let coldOut = strutil.Join([outBin, ".from_facts"], "")
    let coldReport = strutil.Join([coldOut, ".report.txt"], "")
    let coldCompileLog = strutil.Join([coldOut, ".compile.log"], "")
    let coldRunLog = strutil.Join([coldOut, ".run.log"], "")
    let matchBin = os.JoinPath(outDir, "cold_csg_match_smoke")
    let matchFactsPath = strutil.Join([matchBin, ".cold.csg"], "")
    let matchReportPath = strutil.Join([matchBin, ".compile.report.txt"], "")
    let matchCompileLog = strutil.Join([matchBin, ".compile.log"], "")
    let matchColdOut = strutil.Join([matchBin, ".from_facts"], "")
    let matchColdReport = strutil.Join([matchColdOut, ".report.txt"], "")
    let matchColdCompileLog = strutil.Join([matchColdOut, ".compile.log"], "")
    let matchColdRunLog = strutil.Join([matchColdOut, ".run.log"], "")
    let paths: str[] = [
        outBin,
        factsPath,
        reportPath,
        compileLog,
        runLog,
        coldCompiler,
        coldBuildLog,
        coldOut,
        coldReport,
        coldCompileLog,
        coldRunLog,
        strutil.Join([outBin, ".map"], ""),
        strutil.Join([coldOut, ".map"], ""),
        matchBin,
        matchFactsPath,
        matchReportPath,
        matchCompileLog,
        matchColdOut,
        matchColdReport,
        matchColdCompileLog,
        matchColdRunLog,
        strutil.Join([matchBin, ".map"], ""),
        strutil.Join([matchColdOut, ".map"], "")
    ]
    for i in 0..<paths.len:
        if chengpath.PathFileExists(paths[i]):
            os.RemoveFile(paths[i])
    HostSmokePrintLine("[cheng host smokes] cold csg sidecar")
    let compileRun = hostops.RunFileLogged(root,
                                             "host_smokes_compile_cold_csg_sidecar",
                                             compiler,
                                             [
                                                 "system-link-exec",
                                                 "--root", root,
                                                 "--in", src,
                                                 "--emit", "exe",
                                                 "--target", "arm64-apple-darwin",
                                                 "--out", outBin,
                                                 "--report-out", reportPath,
                                                 "--cold-csg-out", factsPath
                                             ],
                                             HostSmokeCompileEnv(),
                                             root,
                                             300,
                                             compileLog)
    if !hostops.LoggedRunOk(compileRun):
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg sidecar compile failed: ", hostops.LoggedRunSummary(compileRun)], ""))
        return compileRun.exitCode
    if !chengpath.FileExistsNonEmpty(root, factsPath):
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg sidecar missing facts: ", factsPath], ""))
        return 1
    let facts = chengpath.ReadTextFile(root, factsPath)
    if !HostSmokeExpectContains(smokeName, facts, "cold_csg_entry=main"):
        return 1
    if !HostSmokeExpectContains(smokeName, facts, "cold_csg_stmt\t2\t4\tvar_t\tcount\tint32\tCount()"):
        return 1
    if !HostSmokeExpectContains(smokeName, facts, "cold_csg_stmt\t2\t4\tif\tcount <= 0"):
        return 1
    if !HostSmokeExpectContains(smokeName, facts, "cold_csg_stmt\t2\t4\treturn\tCall()"):
        return 1
    let run = hostops.RunFileLogged(root,
                                      "host_smokes_run_cold_csg_sidecar",
                                      outBin,
                                      [],
                                      [],
                                      root,
                                      30,
                                      runLog)
    if run.exitCode != 13:
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg sidecar executable exit mismatch: ", hostops.LoggedRunSummary(run)], ""))
        return 1
    let coldBuild = hostops.RunProgramLogged(root,
                                             "host_smokes_build_cold_csg_sidecar_compiler",
                                             "cc",
                                             [
                                                 "-std=c11",
                                                 "-Wall",
                                                 "-Wextra",
                                                 "-O2",
                                                 "bootstrap/cheng_cold.c",
                                                 "-o",
                                                 coldCompiler
                                             ],
                                             [],
                                             root,
                                             60,
                                             coldBuildLog)
    if !hostops.LoggedRunOk(coldBuild):
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg sidecar cold compiler build failed: ", hostops.LoggedRunSummary(coldBuild)], ""))
        return coldBuild.exitCode
    let coldCompile = hostops.RunFileLogged(root,
                                            "host_smokes_compile_cold_csg_sidecar_facts",
                                            coldCompiler,
                                            [
                                                "system-link-exec",
                                                strutil.Join(["--csg-in:", factsPath], ""),
                                                strutil.Join(["--out:", coldOut], ""),
                                                strutil.Join(["--report-out:", coldReport], "")
                                            ],
                                            [],
                                            root,
                                            30,
                                            coldCompileLog)
    if !hostops.LoggedRunOk(coldCompile):
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg sidecar facts compile failed: ", hostops.LoggedRunSummary(coldCompile)], ""))
        return coldCompile.exitCode
    let coldRun = hostops.RunFileLogged(root,
                                        "host_smokes_run_cold_csg_sidecar_facts",
                                        coldOut,
                                        [],
                                        [],
                                        root,
                                        30,
                                        coldRunLog)
    if coldRun.exitCode != 13:
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg sidecar facts executable exit mismatch: ", hostops.LoggedRunSummary(coldRun)], ""))
        return 1
    let coldReportText = chengpath.ReadTextFile(root, coldReport)
    if !HostSmokeExpectContains(smokeName, coldReportText, "cold_compile_elapsed_ms="):
        return 1
    if !HostSmokeExpectNotContains(smokeName, coldReportText, "elapsed_us"):
        return 1
    let matchCompile = hostops.RunFileLogged(root,
                                             "host_smokes_compile_cold_csg_match_sidecar",
                                             compiler,
                                             [
                                                 "system-link-exec",
                                                 "--root", root,
                                                 "--in", matchSrc,
                                                 "--emit", "exe",
                                                 "--target", "arm64-apple-darwin",
                                                 "--out", matchBin,
                                                 "--report-out", matchReportPath,
                                                 "--cold-csg-out", matchFactsPath
                                             ],
                                             HostSmokeCompileEnv(),
                                             root,
                                             300,
                                             matchCompileLog)
    if !hostops.LoggedRunOk(matchCompile):
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg match compile failed: ", hostops.LoggedRunSummary(matchCompile)], ""))
        return matchCompile.exitCode
    if !chengpath.FileExistsNonEmpty(root, matchFactsPath):
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg match missing facts: ", matchFactsPath], ""))
        return 1
    let matchFacts = chengpath.ReadTextFile(root, matchFactsPath)
    if !HostSmokeExpectContains(smokeName, matchFacts, "cold_csg_type\tOption\tSome:1:i:T,None:0\tT"):
        return 1
    if !HostSmokeExpectContains(smokeName, matchFacts, "cold_csg_stmt\t0\t4\tmatch\tresult"):
        return 1
    if !HostSmokeExpectContains(smokeName, matchFacts, "cold_csg_stmt\t0\t8\tcase\tSome\tvalue"):
        return 1
    if !HostSmokeExpectContains(smokeName, matchFacts, "cold_csg_stmt\t0\t8\tcase\tNone\t"):
        return 1
    let matchColdCompile = hostops.RunFileLogged(root,
                                                 "host_smokes_compile_cold_csg_match_facts",
                                                 coldCompiler,
                                                 [
                                                     "system-link-exec",
                                                     strutil.Join(["--csg-in:", matchFactsPath], ""),
                                                     strutil.Join(["--out:", matchColdOut], ""),
                                                     strutil.Join(["--report-out:", matchColdReport], "")
                                                 ],
                                                 [],
                                                 root,
                                                 30,
                                                 matchColdCompileLog)
    if !hostops.LoggedRunOk(matchColdCompile):
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg match facts compile failed: ", hostops.LoggedRunSummary(matchColdCompile)], ""))
        return matchColdCompile.exitCode
    let matchColdRun = hostops.RunFileLogged(root,
                                             "host_smokes_run_cold_csg_match_facts",
                                             matchColdOut,
                                             [],
                                             [],
                                             root,
                                             30,
                                             matchColdRunLog)
    if matchColdRun.exitCode != 7:
        HostSmokePrintErr(strutil.Join(["host smokes: cold csg match facts executable exit mismatch: ", hostops.LoggedRunSummary(matchColdRun)], ""))
        return 1
    let matchColdReportText = chengpath.ReadTextFile(root, matchColdReport)
    if !HostSmokeExpectContains(smokeName, matchColdReportText, "cold_csg_lowering=1"):
        return 1
    if !HostSmokeExpectContains(smokeName, matchColdReportText, "cold_body_switch_count="):
        return 1
    HostSmokePrintLine(" cold_csg_sidecar_smoke ok")
    return 0

fn HostSmokeRunOne(root: str,
                     compiler: str,
                     outDir: str,
                     smokeName: str): int32 =
    if smokeName == "cold_csg_sidecar_smoke":
        return HostSmokeRunColdCsgSidecarSmoke(root, compiler, outDir)
    let src = chengpath.PathAbsolute(root, strutil.Join(["src/tests/", smokeName, ".cheng"], ""))
    if !chengpath.FileExistsNonEmpty(root, src):
        HostSmokePrintErr(strutil.Join(["host smokes: missing source: ", src], ""))
        return 1
    let outBin = os.JoinPath(outDir, smokeName)
    let compileLog = strutil.Join([outBin, ".compile.log"], "")
    let reportPath = strutil.Join([outBin, ".compile.report.txt"], "")
    let runLog = strutil.Join([outBin, ".run.log"], "")
    if chengpath.PathFileExists(outBin):
        os.RemoveFile(outBin)
    if chengpath.PathFileExists(strutil.Join([outBin, ".map"], "")):
        os.RemoveFile(strutil.Join([outBin, ".map"], ""))
    if chengpath.PathFileExists(compileLog):
        os.RemoveFile(compileLog)
    if chengpath.PathFileExists(reportPath):
        os.RemoveFile(reportPath)
    if chengpath.PathFileExists(runLog):
        os.RemoveFile(runLog)
    HostSmokePrintLine(strutil.Join(["[cheng host smokes] compile ", smokeName], ""))
    let compileRun = hostops.RunFileLogged(root,
                                             strutil.Join(["host_smokes_compile_", smokeName], ""),
                                             compiler,
                                             [
                                                 "system-link-exec",
                                                 "--root", root,
                                                 "--in", src,
                                                 "--emit", "exe",
                                                 "--target", "arm64-apple-darwin",
                                                 "--out", outBin,
                                                 "--report-out", reportPath
                                             ],
                                             HostSmokeCompileEnv(),
                                             root,
                                             300,
                                             compileLog)
    if !hostops.LoggedRunOk(compileRun):
        let outputText = strutil.Strip(compileRun.output)
        if len(outputText) > 0:
            HostSmokePrintErr(outputText)
        return compileRun.exitCode
    if !chengpath.FileExistsNonEmpty(root, outBin):
        HostSmokePrintErr(strutil.Join(["host smokes: compile missing output: ", outBin], ""))
        return 1
    if !HostSmokeCompileReportOk(root, smokeName, reportPath):
        return 1
    HostSmokePrintLine(strutil.Join(["[cheng host smokes] run ", smokeName], ""))
    let run = hostops.RunFileLogged(root,
                                      strutil.Join(["host_smokes_run_", smokeName], ""),
                                      outBin,
                                      [],
                                      [],
                                      root,
                                      HostSmokeRunTimeoutSec(smokeName),
                                      runLog)
    let runOutput = strutil.Strip(run.output)
    if len(runOutput) > 0:
        if !hostops.LoggedRunOk(run):
            HostSmokePrintErr(runOutput)
        else:
            HostSmokePrintLine(runOutput)
    if !hostops.LoggedRunOk(run):
        return run.exitCode
    if !HostSmokeRunMarkerOk(smokeName, run.output):
        return 1
    return 0

fn HostSmokeCanRun(args: str[]): bool =
    return !HostSmokeHasFlag(args, "--tail-only")

fn HostSmokeRun(root: str, args: str[]): int32 =
    if !HostSmokeCanRun(args):
        HostSmokePrintErr("host smokes: --tail-only belongs to explicit domain gates, not core host smoke gate")
        return 2
    var compiler = ""
    if HostSmokeResolveCompiler(root, args, compiler) != 0:
        return 1
    var tests = HostSmokeCollectPositionals(args)
    if tests.len <= 0:
        tests = HostSmokeDefaultSmokes()
    let label = HostSmokeLabel(args)
    var outDir = chengpath.PathAbsolute(root, "artifacts/hostrun")
    if label != "host":
        outDir = os.JoinPath(outDir, label)
    if !chengpath.MkdirP(root, outDir):
        HostSmokePrintErr(strutil.Join(["host smokes: failed to create output dir: ", outDir], ""))
        return 1
    for i in 0..<tests.len:
        if HostSmokeRunOne(root, compiler, outDir, tests[i]) != 0:
            return 1
    HostSmokePrintLine("cheng host smokes: ok")
    return 0
