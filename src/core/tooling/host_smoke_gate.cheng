        "compiler_budget_contract_smoke",
        "host_smoke_gate_contract_smoke",
        "runtime_c_baseline_contract_smoke",
        "thread_atomic_orc_runtime_gate_smoke",
        "runtime_link_input_surface_smoke",
        "runtime_zero_c_surface_smoke",
        "composite_call_regression_smoke",
        "large_dispatch_callee_smoke",
        "parser_path_smoke",
        "compiler_pipeline_smoke",
        "lowering_plan_smoke",
        "primary_object_plan_smoke",
        "object_native_link_plan_smoke",
        "function_task_contract_smoke",
        "function_task_executor_contract_smoke",
        "body_ir_dod_soa_contract_smoke",
        "body_ir_noalias_proof_smoke",
        "cfg_body_ir_contract_smoke",
        "cold_csg_sidecar_smoke",
        "compiler_world_manifest_closure_smoke",
        "compiler_migration_publish_smoke",
        "compiler_csg_egraph_active_contract_smoke",
        "compiler_managed_dependency_mirror_smoke",
