import std/os
import std/strings
import std/strutils as strutil
import std/result
import cheng/core/lang/intern as langintern

type
    BenchSample =
        benchId: langintern.InternId
        nsPerOpMilli: int64

    BenchDataset =
        samples: BenchSample[]

    BenchCompareRow =
        benchId: langintern.InternId
        baseNsPerOpMilli: int64
        candidateNsPerOpMilli: int64
        ratioMilli: int64
        missingCandidate: bool
        missingBaseline: bool
        tooSlow: bool

    BenchCompare =
        rows: BenchCompareRow[]
        ok: bool

fn BenchIsSpace(ch: char): bool =
    let code = int32(ch)
    if code == 32:
        return true
    if code == 9:
        return true
    if code == 10:
        return true
    if code == 13:
        return true
    return false

fn BenchFirstField(line: str): str =
    let n: int32 = len(line)
    var stop: int32
    while stop < n:
        if BenchIsSpace(line[stop]):
            break
        stop = stop + 1
    if stop <= 0:
        return ""
    return strings.SliceBytes(line, 0, stop)

fn BenchFindValue(line: str, key: str): str =
    let n: int32 = len(line)
    let keyLen: int32 = len(key)
    if n <= 0 || keyLen <= 0 || keyLen > n:
        return ""
    var i: int32
    while i <= n - keyLen:
        if strings.SliceBytes(line, i, keyLen) == key:
            let start: int32 = i + keyLen
            var stop: int32 = start
            while stop < n:
                let ch: char = line[stop]
                if (ch >= '0' && ch <= '9') || ch == '.':
                    stop = stop + 1
                else:
                    break
            if stop > start:
                return strings.SliceBytes(line, start, stop - start)
            return ""
        i = i + 1
    return ""

fn BenchParseDecimalMilli(raw: str): int64 =
    if len(raw) <= 0:
        return -1
    var whole: int64
    var frac: int64
    var fracDigits: int32
    var seenDot: bool
    for i in 0..<len(raw):
        let ch: char = raw[i]
        if ch == '.':
            if seenDot:
                return -1
            seenDot = true
        elif ch >= '0' && ch <= '9':
            let digit: int64 = int64(int32(ch) - int32('0'))
            if !seenDot:
                whole = whole * int64(10) + digit
            elif fracDigits < 3:
                frac = frac * int64(10) + digit
                fracDigits = fracDigits + 1
        else:
            return -1
    while fracDigits < 3:
        frac = frac * int64(10)
        fracDigits = fracDigits + 1
    return whole * int64(1000) + frac

fn BenchDatasetLookup(dataset: BenchDataset, benchId: langintern.InternId): int64 =
    for i in 0..<dataset.samples.len:
        let sample: BenchSample = dataset.samples[i]
        if sample.benchId == benchId:
            return sample.nsPerOpMilli
    return -1

fn BenchDatasetLoadText(pool: langintern.InternPool, text: str): BenchDataset =
    var samples: BenchSample[]
    var out: BenchDataset
    let lines: str[] = strutil.Split(text, '\n')
    var i: int32
    while i < lines.len:
        let line: str = strutil.Strip(lines[i])
        if len(line) <= 0:
            i = i + 1
            continue
        if strutil.StartsWith(line, "sink="):
            i = i + 1
            continue
        let name: str = BenchFirstField(line)
        let nsText: str = BenchFindValue(line, "ns_per_op=")
        let nsMilli: int64 = BenchParseDecimalMilli(nsText)
        if len(name) <= 0 || nsMilli < int64(0):
            i = i + 1
            continue
        let benchId: langintern.InternId = langintern.Intern(pool, name)
        add(samples, BenchSample(benchId: benchId, nsPerOpMilli: nsMilli))
        i = i + 1
    out.samples.len = samples.len
    out.samples.cap = samples.cap
    out.samples.buffer = samples.buffer
    return out

fn BenchDatasetLoadFile(pool: langintern.InternPool, path: str): BenchDataset =
    if !os.FileExists(path):
        return BenchDataset(samples: [])
    return BenchDatasetLoadText(pool, os.ReadFile(path))

fn BenchCompare(base: BenchDataset, candidate: BenchDataset, maxRatioMilli: int64): BenchCompare =
    var rows: BenchCompareRow[]
    var out: BenchCompare
    out.ok = true
    var i: int32
    while i < base.samples.len:
        let sample: BenchSample = base.samples[i]
        let candidateMilli: int64 = BenchDatasetLookup(candidate, sample.benchId)
        var row: BenchCompareRow
        row.benchId = sample.benchId
        row.baseNsPerOpMilli = sample.nsPerOpMilli
        row.candidateNsPerOpMilli = candidateMilli
        row.ratioMilli = -1
        row.missingCandidate = candidateMilli < int64(0)
        row.missingBaseline = false
        row.tooSlow = false
        if row.missingCandidate:
            out.ok = false
        else:
            let ratioMilli: int64 = (candidateMilli * int64(1000)) / sample.nsPerOpMilli
            row.ratioMilli = ratioMilli
            if maxRatioMilli > int64(0):
                if ratioMilli > maxRatioMilli:
                    row.tooSlow = true
                    out.ok = false
        add(rows, row)
        i = i + 1
    i = 0
    while i < candidate.samples.len:
        let sample: BenchSample = candidate.samples[i]
        if BenchDatasetLookup(base, sample.benchId) < int64(0):
            add(rows, BenchCompareRow(
                benchId: sample.benchId,
                baseNsPerOpMilli: -1,
                candidateNsPerOpMilli: sample.nsPerOpMilli,
                ratioMilli: -1,
                missingCandidate: false,
                missingBaseline: true,
                tooSlow: false
            ))
            out.ok = false
        i = i + 1
    out.rows.len = rows.len
    out.rows.cap = rows.cap
    out.rows.buffer = rows.buffer
    return out

fn BenchMilliText(milliValue: int64): str =
    if milliValue < 0:
        return "missing"
    let wholePart: int64 = milliValue / int64(1000)
    let fracPart: int64 = milliValue % int64(1000)
    let wholeText: str = strings.Int64ToStr(wholePart)
    var fracText: str = strings.Int64ToStr(fracPart)
    if len(fracText) == 1:
        fracText = strutil.Join(["00", fracText], "")
    elif len(fracText) == 2:
        fracText = strutil.Join(["0", fracText], "")
    return strutil.Join([wholeText, ".", fracText], "")

fn BenchCompareReport(pool: langintern.InternPool, compare: BenchCompare): str =
    var rows: str[]
    add(rows, "bench base_ns cand_ns ratio")
    for i in 0..<compare.rows.len:
        let row: BenchCompareRow = compare.rows[i]
        let benchNameRes = langintern.LookupIntern(pool, row.benchId)
        var benchName: str = "unknown"
        if IsOk(benchNameRes):
            benchName = Value(benchNameRes)
        var ratioText: str = "NA"
        if row.ratioMilli >= int64(0):
            ratioText = BenchMilliText(row.ratioMilli)
        add(rows,
            strutil.Join([benchName, " ", BenchMilliText(row.baseNsPerOpMilli), " ", BenchMilliText(row.candidateNsPerOpMilli), " ", ratioText], "")
        )
    if compare.ok:
        add(rows, " compare: ok")
    else:
        add(rows, " compare: failed")
    return strutil.Join([strutil.Join(rows, "\n"), "\n"], "")
