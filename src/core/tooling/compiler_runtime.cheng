import cheng/core/runtime/core_runtime as corun
import cheng/core/runtime/compiler_runtime as comprun

type
    CompilerExecutionTrack = enum
        CompilerTrackProgram
        CompilerTrackTooling

    CompilerRuntimeContract =
        version: str
        executionModel: str
        bootstrapMode: str
        compilerEntry: str
        ordinaryCommand: str
        ordinaryPipelineState: str

fn CompilerRuntimePath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    if rootDir[rootDir.len - 1] == '/':
        return rootDir + rel
    return rootDir + "/" + rel

fn CompilerExecutionTrackText(track: CompilerExecutionTrack): str =
    if track == CompilerTrackTooling:
        return "tooling"
    return "program"

fn CoreRuntimeProviderModule(): str =
    let out = "runtime/core_runtime"
    return out

fn CompilerRuntimeProviderModule(): str =
    let out = "runtime/compiler_runtime"
    return out

fn ProgramSupportProviderModule(): str =
    let out = "runtime/program_support"
    return out

fn ProgramSupportHostProviderModule(): str =
    let out = "runtime/program_support_host_runtime"
    return out

fn DebugRuntimeProviderModule(): str =
    let out = "runtime/debug_runtime"
    return out

fn CompilerProgramArgvRuntimeTarget(): str =
    let out = "runtime/compiler.program_argv_entry"
    return out

fn CompilerToolingArgvRuntimeTarget(): str =
    let out = "runtime/compiler.tooling_argv_entry"
    return out

fn CoreRuntimeTargets(): str[] =
    let out = corun.CoreRuntimeTargets()
    return out

fn CompilerRuntimeTargetsForTrack(track: CompilerExecutionTrack, out: var str[]) =
    out = []
    if track == CompilerTrackTooling:
        let toolingTarget = CompilerToolingArgvRuntimeTarget()
        add(out, toolingTarget)
        return
    let programTarget = CompilerProgramArgvRuntimeTarget()
    add(out, programTarget)

fn RuntimeProviderModulesForTrack(track: CompilerExecutionTrack, out: var str[]) =
    let _ = track
    out = []
    add(out, "runtime/compiler_runtime")
    add(out, "runtime/core_runtime")
    add(out, "runtime/debug_runtime")
    add(out, "runtime/program_support")
    add(out, "runtime/program_support_host_runtime")

fn CompilerRuntimeContract(rootDir: str): CompilerRuntimeContract =
    var out: CompilerRuntimeContract
    out.version = "cheng.compiler_runtime.v1"
    out.executionModel = "argv_control_plane"
    out.bootstrapMode = "selfhost"
    out.compilerEntry = CompilerRuntimePath(rootDir, "src/core/tooling/compiler_main.cheng")
    out.ordinaryCommand = "system-link-exec"
    out.ordinaryPipelineState = "canonical_csg_verified_primary_object_codegen_ready"
    return out

fn CompilerUsageLines(rootDir: str): str[] =
    let contract = CompilerRuntimeContract(rootDir)
    var out: str[]
    out = []
    add(out, "cheng")
    add(out, "usage: cheng <command> [args]")
    add(out, "       cheng <input.cheng> --output:<path> [legacy backend_driver flags]")
    add(out, "")
    add(out, "commands:")
    add(out, "  help                         show this message")
    add(out, "  status                       print the current cheng compiler control-plane contract")
    add(out, "  support-matrix               print the current language/target support matrix")
    add(out, "  print-build-plan             print the current backend build plan")
    add(out, "  print-bootstrap              print the current bootstrap snapshot")
    add(out, "  bootstrap-bridge             rebuild and install bootstrap stage0-stage3 via candidate artifacts")
    add(out, "  build-backend-driver         rebuild and verify the ordinary backend driver")
    add(out, "  run-production-regression    build driver + command-surface/perf/skill/cross/libp2p live regression bundle")
    add(out, "  run-smokes                   self-check stage0/stage1/stage2/stage3 bootstrap compilers")
    add(out, "  scan-hotpath                 scan src for forbidden hotpath regressions")
    add(out, "  verify-x86-linux-remote     rebuild x86 backend on dmit/64, run x86 smoke suite, and self-test chain_node")
    add(out, "  verify-bft-validator-three-node deploy, sign off, and stop the 3-validator BFT cluster")
    add(out, "  host-bridge-audit            fail if legacy host-bridge surfaces leak back into the live path")
    add(out, "  slice-gate                  run the full cheng gate through stage3 forwarding, incl. chain_node/bft/x86 mainline")
    add(out, "  debug-report                emit the stable ordinary pipeline debug report")
    add(out, "  print-symbols               print lowering/primary/provider/link symbols")
    add(out, "  print-line-map              print source line mappings for the build output")
    add(out, "  print-object                inspect Mach-O/ELF/PE objects")
    add(out, "  print-elf                   compatibility alias of print-object")
    add(out, "  print-asm                   print the real emitted assembly text")
