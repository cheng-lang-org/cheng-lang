    add(out, "  r2c-react <subcommand>    zero-script r2c controller entry")
    add(out, "  vpn-gui [flags]              pure Cheng local Web GUI for vpn-proxy")
    add(out, "  vpn-proxy <subcommand>       QUIC+TLS dual-exit SOCKS5 proxy entry")
    add(out, "  mobile-shell <subcommand>    pure Cheng native shell generator for android/ios/harmony")
    add(out, "  run-shared-emit-smokes       verify emit:shared builds a real shared library from a mainless fixture")
    add(out, "  system-link-exec             ordinary AOT compile entry (canonical CSG + provider object plan)")
    add(out, "  emit-csg                     emit the canonical compiler CSG report for a source closure")
    add(out, "  migrate-csg                  migrate legacy source text into the current canonical CSG")
    add(out, "  verify-world                 verify world-head, full-closure manifest, lock, and export-surface compatibility")
    add(out, "  world-sync                   materialize a full world bundle report set for sync/distribution")
    add(out, "  materialize-world-mirrors    materialize managed dependency mirrors from a world-sync bundle prefix")
    add(out, "  prove-equivalence            prove old world reports are canonically equivalent to the current CSG")
    add(out, "  prove-migration             prove legacy source migrates into a canonically equivalent CSG")
    add(out, "  publish-world                publish a full world bundle with stable/edge gate enforcement")
    add(out, "  fresh-node-selfhost          sync a full published world bundle into a fresh node and re-verify the receipt")
    add(out, "  follow-world                 sync/verify a world bundle or bundle-prefix, rebuild backend_driver.next, and atomically install on receipt match")
    add(out, "  selfhost-build               run the selfhost build gate pinned to a world head")
    add(out, "  progress flags               plan-building commands accept --progress [--progress-out:<path>]")
    add(out, "")
    add(out, "compiler_entry=" + contract.compilerEntry)
    add(out, "ordinary_pipeline=" + contract.ordinaryPipelineState)
    return out

fn CompilerRuntimeGetContract(rootDir: str): CompilerRuntimeContract =
    return CompilerRuntimeContract(rootDir)
