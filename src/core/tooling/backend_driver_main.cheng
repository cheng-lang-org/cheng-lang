    if !BackendDriverExpectContains("direct object writer i32 madd otool", i32MaddOtoolRun.output, "madd"):
        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd otool", i32MaddOtoolRun.output, "w0, w0, w1, w2"):
        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd otool", i32MaddOtoolRun.output, "MaddI32Commuted"):
        return 1
    let callChainSrc = chengpath.PathAbsolute(rootDir, "src/tests/int32_const_return_direct_fixture.cheng")
    let callChainOut = os.JoinPath(outDir, "int32_const_return_direct_fixture")
    let callChainPrimaryObject = strutil.Join([callChainOut, ".primary.o"], "")
    let callChainReport = strutil.Join([callChainOut, ".report.txt"], "")
    let callChainCompileLog = strutil.Join([callChainOut, ".compile.log"], "")
    let callChainPrimaryAsm = strutil.Join([callChainPrimaryObject, ".s"], "")
    let callChainPrimaryCompileLog = strutil.Join([callChainPrimaryObject, ".compile.log"], "")
    let callChainOtoolLog = strutil.Join([callChainPrimaryObject, ".otool.log"], "")
    let callChainRunLog = strutil.Join([callChainOut, ".run.log"], "")
    BackendDriverRemoveFileIfPresent(callChainOut)
    BackendDriverRemoveFileIfPresent(callChainPrimaryObject)
    BackendDriverRemoveFileIfPresent(strutil.Join([callChainOut, ".map"], ""))
    BackendDriverRemoveFileIfPresent(callChainReport)
    BackendDriverRemoveFileIfPresent(callChainCompileLog)
    BackendDriverRemoveFileIfPresent(callChainPrimaryAsm)
    BackendDriverRemoveFileIfPresent(callChainPrimaryCompileLog)
    BackendDriverRemoveFileIfPresent(callChainOtoolLog)
    BackendDriverRemoveFileIfPresent(callChainRunLog)
    var callChainCompileArgs: str[]
    add(callChainCompileArgs, "system-link-exec")
    add(callChainCompileArgs, strutil.Join(["--root:", rootDir], ""))
    add(callChainCompileArgs, strutil.Join(["--in:", callChainSrc], ""))
    add(callChainCompileArgs, "--emit:exe")
    add(callChainCompileArgs, "--target:arm64-apple-darwin")
    add(callChainCompileArgs, strutil.Join(["--out:", callChainOut], ""))
    add(callChainCompileArgs, strutil.Join(["--report-out:", callChainReport], ""))
    let callChainCompileRun = hostops.RunFileLogged(rootDir,
                                                     strutil.Join(["backend_driver_direct_object_call_chain_compile_", label], ""),
                                                     compilerPath,
                                                     callChainCompileArgs,
                                                     compileEnv,
                                                     rootDir,
                                                     420,
                                                     callChainCompileLog)
    if !hostops.LoggedRunOk(callChainCompileRun):
        let outputText = strutil.Strip(callChainCompileRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return callChainCompileRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, callChainOut):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing call chain exe: ", callChainOut], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, callChainPrimaryObject):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing call chain primary object: ", callChainPrimaryObject], ""))
        return 1
    if chengpath.PathFileExists(callChainPrimaryAsm):
