fn BackendDriverBuildCrashTrace(rootDir: str,
                                  commandName: str,
                                  artifactDirRel: str,
                                  sourceRel: str,
                                  outputName: str,
                                  requiredRuntimeText: str,
                                  requiredReasonText: str): int32 =
    let compilerPath = BackendDriverSelfCompiler(rootDir)
    let outDir = chengpath.PathAbsolute(rootDir, artifactDirRel)
    let sourcePath = chengpath.PathAbsolute(rootDir, sourceRel)
    let outputPath = os.JoinPath(outDir, outputName)
    let reportPath = os.JoinPath(outDir, strutil.Join([outputName, ".report.txt"], ""))
    let compileLog = os.JoinPath(outDir, strutil.Join([outputName, ".compile.log"], ""))
    let runLog = os.JoinPath(outDir, strutil.Join([outputName, ".run.log"], ""))
    let reportLog = os.JoinPath(outDir, strutil.Join([outputName, ".crash-report.log"], ""))
    let compileRc = BackendDriverCompileDarwinExe(rootDir,
                                                   commandName,
                                                   sourcePath,
                                                   outputPath,
                                                   compileLog)
    if compileRc != 0:
        return compileRc
    if !chengpath.FileExistsNonEmpty(rootDir, strutil.Join([outputPath, ".map"], "")):
        BackendDriverPrintErr(strutil.Join([commandName, ": missing line-map"], ""))
        return 1
    BackendDriverRemoveFileIfExists(reportPath)
    BackendDriverRemoveFileIfExists(reportLog)
    let run = BackendDriverRunCompiled(rootDir,
                                        commandName,
                                        outputPath,
                                        runLog,
                                        false)
    if hostops.LoggedRunOk(run):
        BackendDriverPrintErr(strutil.Join([commandName, ": expected non-zero exit"], ""))
        return 1
    let reportRun = hostops.RunFileLogged(rootDir,
                                           strutil.Join([commandName, "_crash_report"], ""),
                                           compilerPath,
                                           [
                                               "crash-report",
                                               strutil.Join(["--in:", run.logPath], ""),
                                               strutil.Join(["--out:", reportPath], "")
                                           ],
                                           [],
                                           rootDir,
                                           20,
                                           reportLog)
    if !hostops.LoggedRunOk(reportRun):
        let outputText = strutil.Strip(reportRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return reportRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, reportPath):
        BackendDriverPrintErr(strutil.Join([commandName, ": missing report"], ""))
        return 1
    let reportText = chengpath.ReadTextFile(rootDir, reportPath)
    if !BackendDriverRequireOutput(run.output, requiredRuntimeText, commandName) ||
       !BackendDriverRequireOutput(run.output, "cheng_crash_raw_v1", commandName) ||
       !BackendDriverRequireOutput(run.output, requiredReasonText, commandName) ||
       !BackendDriverRequireOutput(run.output, strutil.Join([outputName, ".cheng:"], ""), commandName) ||
       !BackendDriverRequireOutput(reportText, "[cheng] cheng_crash_report_v1", commandName) ||
       !BackendDriverRequireOutput(reportText, strutil.Join(["[cheng] ", requiredReasonText], ""), commandName) ||
       !BackendDriverRequireOutput(reportText, strutil.Join([outputName, ".cheng:"], ""), commandName):
        return 1
    BackendDriverPrintLine(strutil.Strip(reportText))
    return 0

