        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd smoke", i32MaddReportText, "typed_return_op_count=2"):
        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd smoke", i32MaddReportText, "typed_return_op_kinds=i32_madd_args,i32_madd_args"):
        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd smoke", i32MaddReportText, "typed_ir_return_kinds=i32_madd,i32_madd"):
        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd smoke", i32MaddReportText, "primary_object_ir_body_kinds=return_i32_madd_args,return_i32_madd_args"):
        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd smoke", i32MaddReportText, "primary_object_body_kinds=return_i32_madd_args,return_i32_madd_args"):
        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd smoke", i32MaddReportText, "primary_object_direct=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer i32 madd smoke", i32MaddReportText, "direct_object_reloc_count=0"):
        return 1
    let i32MaddOtoolRun = hostops.RunProgramLogged(rootDir,
                                                   strutil.Join(["backend_driver_direct_object_i32_madd_otool_", label], ""),
                                                   "otool",
                                                   ["-tV", i32MaddObj],
                                                   [],
