fn BackendDriverRunR2cReactSurface(rootDir: str): int32 =
    var smokes: str[]
    add(smokes, "--label:verify_r2c_react_surface")
    if os.GetEnv("R2C_REACT_HEAVY_CONTROLLER_SMOKE") == "1":
        add(smokes, "r2c_react_surface_smoke")
        add(smokes, "r2c_react_publish_selector_bundle_smoke")
        add(smokes, "r2c_react_run_native_gui_controller_smoke")
        add(smokes, "r2c_react_discover_truth_routes_controller_smoke")
        add(smokes, "r2c_react_truth_compare_controller_smoke")
        add(smokes, "r2c_react_exec_route_matrix_controller_smoke")
    add(smokes, "r2c_react_render_compare_direct_smoke")
    if os.GetEnv("R2C_REACT_HEAVY_CONTROLLER_SMOKE") == "1":
        add(smokes, "r2c_react_render_compare_controller_smoke")
        add(smokes, "r2c_react_render_compare_matrix_controller_smoke")
    return BackendDriverRunHostSmokesWithR2cController(rootDir, smokes, "")

fn BackendDriverCacheAppendU32BE(buf: var layout.ByteBuf,
                                   value: int32) =
    layout.ByteBufAppendByte(buf, (value >> 24) & 255)
    layout.ByteBufAppendByte(buf, (value >> 16) & 255)
    layout.ByteBufAppendByte(buf, (value >> 8) & 255)
    layout.ByteBufAppendByte(buf, value & 255)

fn BackendDriverCacheAppendText(buf: var layout.ByteBuf,
                                  text: str) =
    let data = bytesFromString(text)
    BackendDriverCacheAppendU32BE(buf, bytesLen(data))
    layout.ByteBufAppendBytes(buf, data)

fn BackendDriverCacheAppendFixed32(buf: var layout.ByteBuf,
                                     value: layout.FixedBytes32) =
    layout.ByteBufAppendBytes(buf, layout.FixedBytes32ToBytes(value))

fn BackendDriverCacheHashText(text: str): layout.FixedBytes32 =
    return hash256.Sha256Fixed(layout.ByteSpanFromBytes(bytesFromString(text)))

fn BackendDriverCacheSourceFileCid(pathRaw: str): Result[layout.FixedBytes32] =
    let path = chengpath.PathTrim(pathRaw)
    if len(path) <= 0:
        return Err[layout.FixedBytes32](" backend driver system-link-exec cache: empty source path")
    if !chengpath.PathFileExists(path):
        return Err[layout.FixedBytes32](Fmt" backend driver system-link-exec cache: missing source path: {path}")
    return Ok[layout.FixedBytes32](BackendDriverCacheHashText(chengpath.ReadTextFile("", path)))

fn BackendDriverCacheAppendSourceFile(buf: var layout.ByteBuf,
                                        rootDir: str,
                                        relPath: str): Result[bool] =
    let path = chengpath.PathAbsolute(rootDir, relPath)
    let cidRes = BackendDriverCacheSourceFileCid(path)
    if IsErr(cidRes):
        return Err[bool](Error(cidRes))
    BackendDriverCacheAppendText(buf, relPath)
    BackendDriverCacheAppendFixed32(buf, Value(cidRes))
    return Ok[bool](true)

fn BackendDriverCacheCodegenCid(rootDir: str): Result[layout.FixedBytes32] =
    var buf = layout.ByteBufInit(4096)
    BackendDriverCacheAppendText(buf, "backend-driver-system-link-exec-codegen-v4")
    let seedRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "bootstrap/cheng_seed.c")
    if IsErr(seedRes):
        return Err[layout.FixedBytes32](Error(seedRes))
    let driverRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/tooling/backend_driver_main.cheng")
    if IsErr(driverRes):
        return Err[layout.FixedBytes32](Error(driverRes))
    let systemPlanRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/system_link_plan.cheng")
    if IsErr(systemPlanRes):
        return Err[layout.FixedBytes32](Error(systemPlanRes))
    let systemExecRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/system_link_exec.cheng")
    if IsErr(systemExecRes):
        return Err[layout.FixedBytes32](Error(systemExecRes))
    let primaryPlanRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/primary_object_plan.cheng")
    if IsErr(primaryPlanRes):
        return Err[layout.FixedBytes32](Error(primaryPlanRes))
    let aarch64EncodeRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/aarch64_encode.cheng")
    if IsErr(aarch64EncodeRes):
        return Err[layout.FixedBytes32](Error(aarch64EncodeRes))
    let nativePlanRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/native_link_plan.cheng")
    if IsErr(nativePlanRes):
        return Err[layout.FixedBytes32](Error(nativePlanRes))
    let runtimeRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/system_link_exec_runtime.cheng")
    if IsErr(runtimeRes):
        return Err[layout.FixedBytes32](Error(runtimeRes))
    let runtimeDirectRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/system_link_exec_runtime_direct.cheng")
    if IsErr(runtimeDirectRes):
        return Err[layout.FixedBytes32](Error(runtimeDirectRes))
    let nativeLinkRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/native_link_exec.cheng")
    if IsErr(nativeLinkRes):
        return Err[layout.FixedBytes32](Error(nativeLinkRes))
    let lineMapRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/line_map.cheng")
    if IsErr(lineMapRes):
        return Err[layout.FixedBytes32](Error(lineMapRes))
    let buildPlanRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/build_plan.cheng")
    if IsErr(buildPlanRes):
        return Err[layout.FixedBytes32](Error(buildPlanRes))
    let targetMatrixRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/target_matrix.cheng")
    if IsErr(targetMatrixRes):
        return Err[layout.FixedBytes32](Error(targetMatrixRes))
    let typeAbiRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/ir/type_abi.cheng")
    if IsErr(typeAbiRes):
        return Err[layout.FixedBytes32](Error(typeAbiRes))
    let directEmitRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/direct_object_emit.cheng")
    if IsErr(directEmitRes):
        return Err[layout.FixedBytes32](Error(directEmitRes))
    let machoWriterRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/macho_object_writer.cheng")
    if IsErr(machoWriterRes):
        return Err[layout.FixedBytes32](Error(machoWriterRes))
    let objectBufferRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/object_buffer.cheng")
    if IsErr(objectBufferRes):
        return Err[layout.FixedBytes32](Error(objectBufferRes))
    let objectSymbolsRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/object_symbols.cheng")
    if IsErr(objectSymbolsRes):
        return Err[layout.FixedBytes32](Error(objectSymbolsRes))
    let objectRelocsRes = BackendDriverCacheAppendSourceFile(buf, rootDir, "src/core/backend/object_relocs.cheng")
    if IsErr(objectRelocsRes):
        return Err[layout.FixedBytes32](Error(objectRelocsRes))
    return Ok[layout.FixedBytes32](hash256.Sha256Fixed(layout.ByteBufView(buf)))

fn BackendDriverCacheResolveTargetCc(targetTriple: str): Result[str] =
    if targetTriple == "wasm32-unknown-unknown":
        return Ok[str]("wasm32-internal-primary-writer")
    if strings.StrContains(targetTriple, "android") ||
       strings.StrContains(targetTriple, "ohos"):
        return Err[str](Fmt" backend driver system-link-exec cache: target cc resolver not available in driver: {targetTriple}")
    let cc = os.GetEnv("CC")
    if len(cc) > 0:
        return Ok[str](cc)
    return Ok[str]("cc")

fn BackendDriverCacheSafeTarget(targetTriple: str): str =
    var out = ""
    for i in 0..<len(targetTriple):
        let ch = targetTriple[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower:
            out = Fmt"{out}{chengpath.TextSlice(targetTriple, i, 1)}"
        else:
            out = Fmt"{out}_"
    return out

fn BackendDriverSystemLinkExecCacheEnabled(): bool =
    return BackendDriverTruthyEnv("CHENG_ENABLE_SYSTEM_LINK_EXEC_CACHE") &&
        !BackendDriverTruthyEnv("CHENG_DISABLE_SYSTEM_LINK_EXEC_CACHE")

fn BackendDriverSystemLinkExecCacheSupported(plan: slplan.SystemLinkPlanStub): bool =
    if !BackendDriverSystemLinkExecCacheEnabled():
        return false
    if slplan.SystemLinkPlanEmitKind(plan) != creq.EmitExe:
        return false
    let outputPath = slplan.SystemLinkPlanOutputPath(plan)
    if len(outputPath) <= 0:
        return false
    if BackendDriverTruthyEnv("CHENG_SKIP_SEED_NATIVE_LINK"):
        return false
    return true

fn BackendDriverSystemLinkExecNeedMap(plan: slplan.SystemLinkPlanStub): bool =
    if slplan.SystemLinkPlanEmitKind(plan) != creq.EmitExe:
        return false
    return !BackendDriverTruthyEnv("CHENG_SKIP_SEED_LINE_MAP")

fn BackendDriverSystemLinkExecMapPath(outputPath: str): str =
    return Fmt"{outputPath}.map"

fn BackendDriverSystemLinkExecCacheKey(rootDir: str,
                                         plan: slplan.SystemLinkPlanStub,
                                         sourceBundleCid: layout.FixedBytes32): Result[str] =
    let codegenRes = BackendDriverCacheCodegenCid(rootDir)
    if IsErr(codegenRes):
        return Err[str](Error(codegenRes))
    let ccRes = BackendDriverCacheResolveTargetCc(slplan.SystemLinkPlanTargetTriple(plan))
    if IsErr(ccRes):
        return Err[str](Error(ccRes))
    var buf = layout.ByteBufInit(65536)
    BackendDriverCacheAppendText(buf, BackendDriverSystemLinkExecCacheVersion)
    BackendDriverCacheAppendText(buf, slplan.SystemLinkPlanWorkspaceRoot(plan))
    BackendDriverCacheAppendText(buf, slplan.SystemLinkPlanPackageRoot(plan))
    BackendDriverCacheAppendText(buf, slplan.SystemLinkPlanPackageId(plan))
    BackendDriverCacheAppendText(buf, slplan.SystemLinkPlanTargetTriple(plan))
    BackendDriverCacheAppendText(buf, slplan.SystemModuleKindText(slplan.SystemLinkPlanModuleKind(plan)))
    BackendDriverCacheAppendText(buf, creq.CompilerEmitText(slplan.SystemLinkPlanEmitKind(plan)))
    BackendDriverCacheAppendText(buf, slplan.SystemLinkPlanSymbolVisibility(plan))
    BackendDriverCacheAppendText(buf, slplan.SystemLinkPlanEntryPath(plan))
    BackendDriverCacheAppendText(buf, slplan.SystemLinkPlanEntrySymbol(plan))
    BackendDriverCacheAppendText(buf, Value(ccRes))
    BackendDriverCacheAppendFixed32(buf, Value(codegenRes))
    BackendDriverCacheAppendFixed32(buf, sourceBundleCid)
    BackendDriverCacheAppendU32BE(buf, BackendDriverTruthyEnv("CHENG_SKIP_SEED_LINE_MAP") ? 1 : 0)
    let runtimeTargets = slplan.SystemLinkPlanRuntimeTargets(plan)
    BackendDriverCacheAppendU32BE(buf, runtimeTargets.len)
    for i in 0..<runtimeTargets.len:
        BackendDriverCacheAppendText(buf, runtimeTargets[i])
    let providerModules = slplan.SystemLinkPlanProviderModules(plan)
    BackendDriverCacheAppendU32BE(buf, providerModules.len)
    for i in 0..<providerModules.len:
        BackendDriverCacheAppendText(buf, providerModules[i])
    let sourceClosurePaths = slplan.SystemLinkPlanSourceClosurePaths(plan)
    BackendDriverCacheAppendU32BE(buf, sourceClosurePaths.len)
    for i in 0..<sourceClosurePaths.len:
        let sourceCidRes = BackendDriverCacheSourceFileCid(sourceClosurePaths[i])
        if IsErr(sourceCidRes):
            return Err[str](Error(sourceCidRes))
        BackendDriverCacheAppendText(buf, sourceClosurePaths[i])
        BackendDriverCacheAppendFixed32(buf, Value(sourceCidRes))
    let keyCid = hash256.Sha256Fixed(layout.ByteBufView(buf))
    return Ok[str](layout.FixedBytes32Hex(keyCid))

fn BackendDriverSystemLinkExecCacheSourceBundleCid(plan: slplan.SystemLinkPlanStub): Result[layout.FixedBytes32] =
    let sourceClosurePaths = slplan.SystemLinkPlanSourceClosurePaths(plan)
    var buf = layout.ByteBufInit(512)
    BackendDriverCacheAppendText(buf, "cheng.compiler.source_bundle")
    BackendDriverCacheAppendText(buf, slplan.SystemLinkPlanPackageId(plan))
    BackendDriverCacheAppendU32BE(buf, sourceClosurePaths.len)
    for i in 0..<sourceClosurePaths.len:
        let sourcePath = sourceClosurePaths[i]
        if !chengpath.PathFileExists(sourcePath):
            return Err[layout.FixedBytes32](Fmt" backend driver system-link-exec cache: missing source path: {sourcePath}")
        BackendDriverCacheAppendText(buf, sourcePath)
        BackendDriverCacheAppendText(buf, chengpath.ReadTextFile("", sourcePath))
    return Ok[layout.FixedBytes32](hash256.Sha256Fixed(layout.ByteBufView(buf)))

fn BackendDriverSystemLinkExecCacheDir(rootDir: str,
                                         plan: slplan.SystemLinkPlanStub): str =
    let cacheRoot = chengpath.PathAbsolute(rootDir, "artifacts/system_link_exec_cache")
    return chengpath.PathJoin(cacheRoot,
                              BackendDriverCacheSafeTarget(slplan.SystemLinkPlanTargetTriple(plan)))

fn BackendDriverSystemLinkExecCacheExePath(rootDir: str,
                                             plan: slplan.SystemLinkPlanStub,
                                             key: str): str =
    return chengpath.PathJoin(BackendDriverSystemLinkExecCacheDir(rootDir, plan), Fmt"{key}.exe")

fn BackendDriverSystemLinkExecCacheMapPath(rootDir: str,
                                             plan: slplan.SystemLinkPlanStub,
                                             key: str): str =
    return chengpath.PathJoin(BackendDriverSystemLinkExecCacheDir(rootDir, plan), Fmt"{key}.map")

fn BackendDriverCopyFileBytes(rootDir: str,
                                sourcePath: str,
                                outputPath: str): bool =
    let parent = chengpath.PathParentDir(outputPath)
    if len(parent) > 0:
        if !chengpath.MkdirP(rootDir, parent):
            return false
    if !chengpath.PathFileExists(sourcePath):
        return false
    let bytes = os.ReadFile(sourcePath)
    if len(bytes) <= 0:
        return false
    os.WriteFile(outputPath, bytes)
    return chengpath.FileExistsNonEmpty(rootDir, outputPath)

fn BackendDriverChmodExecutable(rootDir: str,
                                  outputPath: str): bool =
    let logPath = Fmt"{outputPath}.cache_chmod.log"
    let run = hostops.RunProgramLogged(rootDir,
                                        "backend_driver_system_link_exec_cache_chmod",
                                        "chmod",
                                        ["755", outputPath],
                                        [],
                                        rootDir,
                                        30,
                                        logPath)
    return run.exitCode == 0

fn BackendDriverSystemLinkExecCacheHitReport(plan: slplan.SystemLinkPlanStub,
                                               sourceBundleCid: layout.FixedBytes32,
                                               key: str,
                                               cacheExePath: str,
                                               cacheMapPath: str,
                                               outputPath: str): str =
    var out = slplan.SystemLinkPlanStubReport(plan)
    out = Fmt"{out}\nsource_bundle_cid={layout.FixedBytes32Hex(sourceBundleCid)}"
    out = Fmt"{out}\nbackend_driver_system_link_exec_cache_restore=1"
    out = Fmt"{out}\nsystem_link_exec_cache_version={BackendDriverSystemLinkExecCacheVersion}"
    out = Fmt"{out}\nsystem_link_exec_cache_key={key}"
    out = Fmt"{out}\nsystem_link_exec_cache_output={cacheExePath}"
    out = Fmt"{out}\nsystem_link_exec_cache_map={cacheMapPath}"
    out = Fmt"{out}\nsystem_link_exec_cache_hit_count=1"
    out = Fmt"{out}\nsystem_link_exec_cache_miss_count=0"
    out = Fmt"{out}\nexec_phase_system_link_exec_cache_lookup_ms=0"
    out = Fmt"{out}\nexec_phase_system_link_exec_cache_copy_ms=0"
    out = Fmt"{out}\nexec_phase_lowering_plan_ms=0"
    out = Fmt"{out}\nexec_phase_primary_object_plan_ms=0"
    out = Fmt"{out}\nexec_phase_provider_objects_ms=0"
    out = Fmt"{out}\nexec_phase_primary_object_emit_ms=0"
    out = Fmt"{out}\nexec_phase_primary_object_asm_compile_ms=0"
    out = Fmt"{out}\nexec_phase_native_link_ms=0"
    out = Fmt"{out}\nexec_phase_line_map_ms=0"
    out = Fmt"{out}\nexec_pipeline_stage=system_link_exec_cache_hit"
    if len(outputPath) > 0:
        out = Fmt"{out}\ndebug_line_map_path={BackendDriverSystemLinkExecMapPath(outputPath)}"
    return out

fn BackendDriverSystemLinkExecCacheMiss(rootDir: str,
                                          reason: str): int32 =
    if BackendDriverTruthyEnv(BackendDriverSystemLinkExecCacheRequireHitEnv):
        BackendDriverPrintErr(Fmt"backend driver system-link-exec cache miss: {reason}")
        return 2
    return -1

fn BackendDriverRequestWithAbsoluteSourcePath(rootDir: str,
                                               req: creq.CompilerRequest): creq.CompilerRequest =
    var out = req
    out.sourcePath = chengpath.PathAbsolute(rootDir, req.sourcePath)
    return out

fn BackendDriverTryRestoreSystemLinkExecCache(rootDir: str,
                                                args: str[]): int32 =
    if !BackendDriverSystemLinkExecCacheEnabled():
        return -1
    let reqRes = creq.CompilerRequestFromArgs(rootDir, args)
    if IsErr(reqRes):
        return BackendDriverSystemLinkExecCacheMiss(rootDir, Error(reqRes))
    let req = BackendDriverRequestWithAbsoluteSourcePath(rootDir, Value(reqRes))
    var plan: slplan.SystemLinkPlanStub
    var err = ""
    if !slplan.BuildSystemLinkPlanStub(rootDir, req, plan, err):
        return BackendDriverSystemLinkExecCacheMiss(rootDir, err)
    if !BackendDriverSystemLinkExecCacheSupported(plan):
        return BackendDriverSystemLinkExecCacheMiss(rootDir, "unsupported request")
    let sourceBundleRes = BackendDriverSystemLinkExecCacheSourceBundleCid(plan)
    if IsErr(sourceBundleRes):
        return BackendDriverSystemLinkExecCacheMiss(rootDir, Error(sourceBundleRes))
    let keyRes = BackendDriverSystemLinkExecCacheKey(rootDir, plan, Value(sourceBundleRes))
    if IsErr(keyRes):
        return BackendDriverSystemLinkExecCacheMiss(rootDir, Error(keyRes))
    let key = Value(keyRes)
    let cacheExePath = BackendDriverSystemLinkExecCacheExePath(rootDir, plan, key)
    let cacheMapPath = BackendDriverSystemLinkExecCacheMapPath(rootDir, plan, key)
    let outputPath = chengpath.PathAbsolute(rootDir, slplan.SystemLinkPlanOutputPath(plan))
    let outputMapPath = BackendDriverSystemLinkExecMapPath(outputPath)
    if !chengpath.FileExistsNonEmpty(rootDir, cacheExePath):
        var reason = Fmt"missing cached exe: {cacheExePath}"
        if BackendDriverTruthyEnv(BackendDriverSystemLinkExecCacheRequireHitEnv):
            let codegenDebugRes = BackendDriverCacheCodegenCid(rootDir)
            reason = Fmt"{reason} key={key}"
            reason = Fmt"{reason} source_bundle={layout.FixedBytes32Hex(Value(sourceBundleRes))}"
            if !IsErr(codegenDebugRes):
                reason = Fmt"{reason} codegen={layout.FixedBytes32Hex(Value(codegenDebugRes))}"
            reason = Fmt"{reason} package_id={slplan.SystemLinkPlanPackageId(plan)}"
            reason = Fmt"{reason} source_paths={slplan.SystemLinkPlanListText(slplan.SystemLinkPlanSourceClosurePaths(plan))}"
        return BackendDriverSystemLinkExecCacheMiss(rootDir, reason)
    if BackendDriverSystemLinkExecNeedMap(plan) &&
       !chengpath.FileExistsNonEmpty(rootDir, cacheMapPath):
        return BackendDriverSystemLinkExecCacheMiss(rootDir, Fmt"missing cached map: {cacheMapPath}")
    if !BackendDriverCopyFileBytes(rootDir, cacheExePath, outputPath):
        BackendDriverPrintErr("backend driver system-link-exec cache: failed to copy exe")
        return 1
    if !BackendDriverChmodExecutable(rootDir, outputPath):
        BackendDriverPrintErr("backend driver system-link-exec cache: failed to chmod exe")
        return 1
    if BackendDriverSystemLinkExecNeedMap(plan):
        if !BackendDriverCopyFileBytes(rootDir, cacheMapPath, outputMapPath):
            BackendDriverPrintErr("backend driver system-link-exec cache: failed to copy map")
            return 1
    if len(req.reportPath) > 0:
        let report = BackendDriverSystemLinkExecCacheHitReport(plan,
                                                               Value(sourceBundleRes),
                                                               key,
                                                               cacheExePath,
                                                               cacheMapPath,
                                                               outputPath)
        if !chengpath.WriteTextFile(rootDir, req.reportPath, report):
            BackendDriverPrintErr(Fmt"backend driver system-link-exec cache: failed to write report: {req.reportPath}")
            return 1
    return 0

fn BackendDriverStoreSystemLinkExecCacheForRequest(rootDir: str,
                                                    reqRaw: creq.CompilerRequest): bool =
    if !BackendDriverSystemLinkExecCacheEnabled():
        return true
    let req = BackendDriverRequestWithAbsoluteSourcePath(rootDir, reqRaw)
    var plan: slplan.SystemLinkPlanStub
    var err = ""
    if !slplan.BuildSystemLinkPlanStub(rootDir, req, plan, err):
        BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: {err}")
        return false
    if !BackendDriverSystemLinkExecCacheSupported(plan):
        return true
    let sourceBundleRes = BackendDriverSystemLinkExecCacheSourceBundleCid(plan)
    if IsErr(sourceBundleRes):
        BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: {Error(sourceBundleRes)}")
        return false
    let keyRes = BackendDriverSystemLinkExecCacheKey(rootDir, plan, Value(sourceBundleRes))
    if IsErr(keyRes):
        BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: {Error(keyRes)}")
        return false
    let key = Value(keyRes)
    let outputPath = chengpath.PathAbsolute(rootDir, slplan.SystemLinkPlanOutputPath(plan))
    let outputMapPath = BackendDriverSystemLinkExecMapPath(outputPath)
    let cacheDir = BackendDriverSystemLinkExecCacheDir(rootDir, plan)
    let cacheExePath = BackendDriverSystemLinkExecCacheExePath(rootDir, plan, key)
    let cacheMapPath = BackendDriverSystemLinkExecCacheMapPath(rootDir, plan, key)
    if !chengpath.MkdirP(rootDir, cacheDir):
        BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: failed to create cache dir: {cacheDir}")
        return false
    if !chengpath.FileExistsNonEmpty(rootDir, outputPath):
        BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: missing output: {outputPath}")
        return false
    if !BackendDriverCopyFileBytes(rootDir, outputPath, cacheExePath):
        BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: failed to copy exe: {cacheExePath}")
        return false
    if BackendDriverSystemLinkExecNeedMap(plan):
        if !chengpath.FileExistsNonEmpty(rootDir, outputMapPath):
            BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: missing map: {outputMapPath}")
            return false
        if !BackendDriverCopyFileBytes(rootDir, outputMapPath, cacheMapPath):
            BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: failed to copy map: {cacheMapPath}")
            return false
    if len(req.reportPath) > 0 && chengpath.PathFileExists(req.reportPath):
        var report = chengpath.ReadTextFile("", req.reportPath)
        report = Fmt"{report}\nbackend_driver_system_link_exec_cache_store=1"
        report = Fmt"{report}\nsystem_link_exec_cache_version={BackendDriverSystemLinkExecCacheVersion}"
        report = Fmt"{report}\nsystem_link_exec_cache_key={key}"
        report = Fmt"{report}\nsystem_link_exec_cache_output={cacheExePath}"
        report = Fmt"{report}\nsystem_link_exec_cache_map={cacheMapPath}"
        if !chengpath.WriteTextFile(rootDir, req.reportPath, report):
            BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: failed to update report: {req.reportPath}")
            return false
    return true

fn BackendDriverStoreSystemLinkExecCache(rootDir: str,
                                           args: str[]): bool =
    let reqRes = creq.CompilerRequestFromArgs(rootDir, args)
    if IsErr(reqRes):
        BackendDriverPrintErr(Fmt"backend driver system-link-exec cache store: {Error(reqRes)}")
        return false
    return BackendDriverStoreSystemLinkExecCacheForRequest(rootDir, Value(reqRes))

fn BackendDriverRequirePureSystemLinkExec(): bool =
    return BackendDriverTruthyEnv("CHENG_REQUIRE_PURE_SYSTEM_LINK_EXEC")

fn BackendDriverWritePureSystemLinkExecReport(rootDir: str,
                                                reportPath: str,
                                                plan: sexec.SystemLinkExecPlan,
                                                runtimeReport: str): bool =
    if len(reportPath) <= 0:
        return true
    let tracePath = strutil.Strip(os.GetEnv("CHENG_SYSTEM_LINK_EXEC_REPORT_TRACE"))
    if len(tracePath) > 0:
        let _ = chengpath.WriteTextFile(rootDir, tracePath, "before_plan_report")
    if !BackendDriverEnsureParentDir(rootDir, reportPath):
        return false
    var report = sexec.SystemLinkExecPlanReport(plan)
    if len(tracePath) > 0:
        let _ = chengpath.WriteTextFile(rootDir, tracePath, "after_plan_report")
    if len(runtimeReport) > 0:
        if len(report) > 0 && report[len(report) - 1] != '\n':
            report = Fmt"{report}\n"
        report = Fmt"{report}{runtimeReport}"
    if len(tracePath) > 0:
        let _ = chengpath.WriteTextFile(rootDir, tracePath, "before_write_report")
    return chengpath.WriteTextFile(rootDir, reportPath, report)

fn BackendDriverPureSystemLinkExecUnsupported(rootDir: str,
                                               reason: str): int32 =
    BackendDriverPrintErr(reason)
    return 2

fn BackendDriverTryRunPureSystemLinkExec(rootDir: str,
                                           args: str[]): int32 =
    let reqRes = creq.CompilerRequestFromArgs(rootDir, args)
    if IsErr(reqRes):
        return BackendDriverPureSystemLinkExecUnsupported(rootDir, Error(reqRes))
    let req = BackendDriverRequestWithAbsoluteSourcePath(rootDir, Value(reqRes))
    let requestedWorldHead = creq.CompilerWorldHeadFromArgs(args)
    let lockPath = creq.CompilerLockPathFromArgs(args)
    let baselineSurfacePath = creq.CompilerBaselineSurfacePathFromArgs(args)
    let channel = creq.CompilerChannelFromArgs(args)
    let planRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                    req,
                                                                    requestedWorldHead,
                                                                    lockPath,
                                                                    baselineSurfacePath,
                                                                    channel)
    if IsErr(planRes):
        return BackendDriverPureSystemLinkExecUnsupported(rootDir, Error(planRes))
    let plan = Value(planRes)
    if !sexec.SystemLinkExecPlanReady(plan):
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: system missing={slplan.SystemLinkPlanListText(plan.systemLinkPlan.missingReasons)}")
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: lowering missing={slplan.SystemLinkPlanListText(plan.loweringPlan.missingReasons)}")
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: primary missing={slplan.SystemLinkPlanListText(plan.primaryObjectPlan.missingReasons)}")
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: primary first_missing_function={plan.primaryObjectPlan.error.functionName}")
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: primary first_missing_body_kind={plan.primaryObjectPlan.error.bodyKind}")
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: primary first_missing_typed_ir_kind={plan.primaryObjectPlan.error.typedIrKind}")
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: primary first_missing_line_number={IntToStr(plan.primaryObjectPlan.error.lineNumber)}")
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: object missing={slplan.SystemLinkPlanListText(plan.objectPlan.missingReasons)}")
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: native missing={slplan.SystemLinkPlanListText(plan.nativeLinkPlan.missingReasons)}")
        let _ = BackendDriverWritePureSystemLinkExecReport(rootDir,
                                                           req.reportPath,
                                                           plan,
                                                           "system_link_exec_runtime_execute=0")
        BackendDriverPrintErr("backend driver pure system-link-exec: plan not ready")
        return 2
    let browserBridgeObjectPath = sexec.SystemLinkExecBrowserBridgeObjectPath(plan)
    if len(browserBridgeObjectPath) > 0:
        BackendDriverPrintErr("backend driver pure system-link-exec: browser bridge object not yet in pure runtime")
        return 2
    let providerCompilerPath: str = BackendDriverCurrentExecutablePath(rootDir)
    let execRes = sexecrt.SystemLinkExecRuntimeExecutePlanWithCompiler(rootDir,
                                                                       plan,
                                                                       providerCompilerPath)
    if IsErr(execRes):
        let _ = BackendDriverWritePureSystemLinkExecReport(rootDir,
                                                           req.reportPath,
                                                           plan,
                                                           Fmt"system_link_exec_runtime_execute=error\n{Error(execRes)}")
        BackendDriverPrintErr(Error(execRes))
        return 2
    let runtimeReport = sexecrt.SystemLinkExecRuntimeResultReport(Value(execRes))
    if !BackendDriverWritePureSystemLinkExecReport(rootDir, req.reportPath, plan, runtimeReport):
        BackendDriverPrintErr(Fmt"backend driver pure system-link-exec: failed to write report: {req.reportPath}")
        return 1
    return 0

fn BackendDriverForward(rootDir: str,
                          cmd: str,
                          args: str[]): int32 =
    let stage3Path = BackendDriverStage3Path(rootDir)
    let logDir = chengpath.PathAbsolute(rootDir, "artifacts/forward")
    let _ = chengpath.MkdirP(rootDir, logDir)
    let logPath = chengpath.PathAbsolute(rootDir, "artifacts/forward/backend_driver.forward.log")
    var forwardArgs: str[]
    var forwardEnv: str[]
    add(forwardEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(forwardArgs, cmd)
    for i in 0..<args.len:
        add(forwardArgs, args[i])
    let run = hostops.RunFileLogged(rootDir,
                                      "backend_driver_forward",
                                      stage3Path,
                                      forwardArgs,
                                      forwardEnv,
                                      rootDir,
                                      0,
                                      logPath)
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        if run.exitCode != 0:
            BackendDriverPrintErr(outputText)
        else:
            BackendDriverPrintLine(outputText)
    elif run.exitCode != 0:
        BackendDriverPrintErr(" backend driver: forward failed")
    return run.exitCode

fn BackendDriverStatus(rootDir: str) =
    let contract = crun.CompilerRuntimeGetContract(rootDir)
    BackendDriverPrintLine("cheng")
    BackendDriverPrintKeyValue("version", contract.version)
    BackendDriverPrintKeyValue("execution", contract.executionModel)
    BackendDriverPrintKeyValue("bootstrap_mode", contract.bootstrapMode)
    BackendDriverPrintKeyValue("compiler_entry",
                               chengpath.PathAbsolute(rootDir, "src/core/tooling/backend_driver_main.cheng"))
    BackendDriverPrintKeyValue("ordinary_command", contract.ordinaryCommand)
    BackendDriverPrintKeyValue("ordinary_pipeline", contract.ordinaryPipelineState)
    BackendDriverPrintKeyValue("stage3", BackendDriverStage3Path(rootDir))

fn BackendDriverMainDispatch(rootDir: str,
                              count: int32): int32 =
    return BackendDriverToolDispatch(rootDir, count)

fn BackendDriverToolDispatch(rootDir: str,
                              count: int32): int32 =
    let cmd = BackendDriverParamStr(1)
    let args = BackendDriverCollectArgsFrom(2, count)
    if len(cmd) > 0:
        if count <= 2 && (cmd == "help" || cmd == "-h" || cmd == "--help"):
            BackendDriverUsage(rootDir)
            return 0
        if count <= 2 && cmd == "status":
            BackendDriverStatus(rootDir)
            return 0
        if cmd == "print-build-plan":
            BackendDriverPrintBuildPlan(rootDir, args)
            return 0
        if cmd == "print-bootstrap":
            BackendDriverPrintBootstrap(rootDir)
            return 0
        if cmd == "support-matrix":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "scan-hotpath":
            return BackendDriverScanHotpath(rootDir)
        if cmd == "host-bridge-audit":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-smokes":
            return BackendDriverRunSmokes(rootDir)
        if cmd == "run-host-smokes":
            return BackendDriverRunHostSmokes(rootDir, args)
        if cmd == "run-stage23-libp2p-smokes":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "slice-gate":
            return BackendDriverSliceGate(rootDir)
        if cmd == "debug-report":
            return BackendDriverRunDebugTextCommand(rootDir, args, cmd)
        if cmd == "print-symbols":
            return BackendDriverRunDebugTextCommand(rootDir, args, cmd)
        if cmd == "print-line-map":
            return BackendDriverRunDebugTextCommand(rootDir, args, cmd)
        if cmd == "print-asm":
            return BackendDriverRunDebugTextCommand(rootDir, args, cmd)
        if cmd == "print-object":
            return BackendDriverRunObjectReportCommand(rootDir, args)
        if cmd == "print-elf":
            return BackendDriverRunObjectReportCommand(rootDir, args)
        if cmd == "profile-run":
            return BackendDriverRunProfileRun(rootDir, args)
        if cmd == "profile-report":
            return BackendDriverRunProfileReport(rootDir, args)
        if cmd == "crash-report":
            return BackendDriverRunCrashReport(rootDir, args)
        if cmd == "run-browser-host-wasm-smoke":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-wasm-smokes":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "build-browser-host-wasm":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "build-linux-nolibc-exe":
            return BackendDriverBuildLinuxNolibcExe(rootDir)
        if cmd == "build-zero-exit":
            return BackendDriverBuildZeroExit(rootDir)
        if cmd == "build-panic-trace":
            return BackendDriverBuildPanicTrace(rootDir)
        if cmd == "build-bounds-trace":
            return BackendDriverBuildBoundsTrace(rootDir)
        if cmd == "build-signal-trace":
            return BackendDriverBuildSignalTrace(rootDir)
        if cmd == "build-call-chain":
            return BackendDriverBuildCallChain(rootDir)
        if cmd == "build-ffi-handle":
            return BackendDriverBuildFfiHandle(rootDir)
        if cmd == "build-program-selfhost":
            return BackendDriverBuildProgramSelfhost(rootDir)
        if cmd == "build-bft-state-machine":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "deploy-bft-validator-three-node":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "verify-bft-validator-three-node":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "status-bft-validator-three-node":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "stop-bft-validator-three-node":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "bench-bft-validator-three-node":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "build-rwad-bft-state-machine":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-udp-importc-smoke":
            return BackendDriverRunUdpImportcSmoke(rootDir, args)
        if cmd == "run-tcp-twoproc-smoke":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-quic-twoproc-smoke":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-tailnet-control-smoke":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-fresh-node-selfhost-gate":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-migration-gate":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-browser-webrtc-smokes":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "r2c-react":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "verify-export-visibility":
            return evgate.ExportVisibilityGateRun(rootDir)
        if cmd == "verify-export-visibility-parallel":
            return evgate.ExportVisibilityGateRunParallel(rootDir)
        if cmd == "verify-orphan-guard":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "verify-backend-driver-command-surface":
            return BackendDriverRunBuiltinHostSmoke(rootDir,
                                                     "verify_backend_driver_command_surface",
                                                     "backend_driver_command_surface_smoke")
        if cmd == "verify-backend-egraph-cost" || cmd == "verify_backend_egraph_cost":
            return BackendDriverVerifyBackendEgraphCost(rootDir, args)
        if cmd == "verify-mobile-shell-build-probe":
            return BackendDriverRunBuiltinHostSmoke(rootDir,
                                                     "verify_mobile_shell_build_probe",
                                                     "mobile_shell_build_probe_smoke")
        if cmd == "verify-r2c-react-surface":
            return BackendDriverRunR2cReactSurface(rootDir)
        if cmd == "verify-debug-profile":
            return BackendDriverVerifyDebugProfile(rootDir)
        if cmd == "verify-debug-tools":
            return BackendDriverVerifyDebugTools(rootDir)
        if cmd == "verify-debug-runtime":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "verify-diloco":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "verify-windows-builtin":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "verify-riscv64-builtin":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "run-cross-target-smokes":
            return BackendDriverForward(rootDir, cmd, args)
        if cmd == "system-link-exec":
            let pureRc = BackendDriverTryRunPureSystemLinkExec(rootDir, args)
            if pureRc == 0 && !BackendDriverStoreSystemLinkExecCache(rootDir, args):
                return 1
            return pureRc
    return BackendDriverForward(rootDir, cmd, args)

fn BackendDriverMain(): int32 =
    let rootDir = BackendDriverRoot()
    BackendDriverEnsureRootEnv(rootDir)
    let count = BackendDriverParamCountBridge()
    if count <= 0:
        BackendDriverUsage(rootDir)
        return 0
    return BackendDriverMainDispatch(rootDir, count)

fn main(argc: int32, argv: str*): int32 =
    return BackendDriverMain()
