        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: unexpected i32 madd asm compile log: ", i32MaddObjectCompileLog], ""))
        return 1
    let i32MaddReportText = chengpath.ReadTextFile("", i32MaddReport)
