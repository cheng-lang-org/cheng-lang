        return 1
    if chengpath.PathFileExists(callChainPrimaryCompileLog):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: unexpected call chain asm compile log: ", callChainPrimaryCompileLog], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, callChainReport):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing call chain report: ", callChainReport], ""))
        return 1
    let callChainReportText = chengpath.ReadTextFile("", callChainReport)
    if !BackendDriverExpectContains("direct object writer call chain smoke", callChainReportText, "system_link_exec_runtime_execute=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer call chain smoke", callChainReportText, "system_link_exec_runtime_standalone_no_runtime=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer call chain smoke", callChainReportText, "primary_object_body_kinds=return_i32_const_7,return_call_noarg_i32,entry_bridge"):
        return 1
    if !BackendDriverExpectContains("direct object writer call chain smoke", callChainReportText, "primary_object_direct=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer call chain smoke", callChainReportText, "direct_object_symbol_count=3"):
        return 1
    if !BackendDriverExpectContains("direct object writer call chain smoke", callChainReportText, "direct_object_reloc_count=2"):
        return 1
    if !BackendDriverExpectContains("direct object writer call chain smoke", callChainReportText, "provider_object_count=0"):
        return 1
    let callChainOtoolRun = hostops.RunProgramLogged(rootDir,
                                                     strutil.Join(["backend_driver_direct_object_call_chain_otool_", label], ""),
                                                     "otool",
                                                     ["-r", "-v", callChainPrimaryObject],
                                                     [],
                                                     rootDir,
                                                     30,
                                                     callChainOtoolLog)
    if callChainOtoolRun.exitCode != 0:
        BackendDriverPrintErr("direct object writer smoke: call chain otool failed")
        return callChainOtoolRun.exitCode
    if !BackendDriverExpectContains("direct object writer call chain otool", callChainOtoolRun.output, "BR26"):
        return 1
    let callChainRun = hostops.RunFileLogged(rootDir,
                                             strutil.Join(["backend_driver_direct_object_call_chain_run_", label], ""),
                                             callChainOut,
                                             [],
                                             [],
                                             rootDir,
                                             30,
                                             callChainRunLog)
    if callChainRun.exitCode != 7:
        let outputText = strutil.Strip(callChainRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: call chain rc=", strings.IntToStr(callChainRun.exitCode)], ""))
        return 1
    let deadF64Src = chengpath.PathAbsolute(rootDir, "src/tests/zero_exit_with_f64_dead_function_fixture.cheng")
    let deadF64Out = os.JoinPath(outDir, "zero_exit_with_f64_dead_function_fixture")
    let deadF64PrimaryObject = strutil.Join([deadF64Out, ".primary.o"], "")
    let deadF64Report = strutil.Join([deadF64Out, ".report.txt"], "")
    let deadF64CompileLog = strutil.Join([deadF64Out, ".compile.log"], "")
    let deadF64PrimaryAsm = strutil.Join([deadF64PrimaryObject, ".s"], "")
    let deadF64PrimaryCompileLog = strutil.Join([deadF64PrimaryObject, ".compile.log"], "")
    let deadF64OtoolLog = strutil.Join([deadF64PrimaryObject, ".otool.log"], "")
    let deadF64RunLog = strutil.Join([deadF64Out, ".run.log"], "")
    BackendDriverRemoveFileIfPresent(deadF64Out)
    BackendDriverRemoveFileIfPresent(deadF64PrimaryObject)
    BackendDriverRemoveFileIfPresent(strutil.Join([deadF64Out, ".map"], ""))
    BackendDriverRemoveFileIfPresent(deadF64Report)
    BackendDriverRemoveFileIfPresent(deadF64CompileLog)
    BackendDriverRemoveFileIfPresent(deadF64PrimaryAsm)
    BackendDriverRemoveFileIfPresent(deadF64PrimaryCompileLog)
    BackendDriverRemoveFileIfPresent(deadF64OtoolLog)
    BackendDriverRemoveFileIfPresent(deadF64RunLog)
    var deadF64CompileArgs: str[]
    add(deadF64CompileArgs, "system-link-exec")
    add(deadF64CompileArgs, strutil.Join(["--root:", rootDir], ""))
    add(deadF64CompileArgs, strutil.Join(["--in:", deadF64Src], ""))
    add(deadF64CompileArgs, "--emit:exe")
    add(deadF64CompileArgs, "--target:arm64-apple-darwin")
    add(deadF64CompileArgs, strutil.Join(["--out:", deadF64Out], ""))
    add(deadF64CompileArgs, strutil.Join(["--report-out:", deadF64Report], ""))
    let deadF64CompileRun = hostops.RunFileLogged(rootDir,
                                                   strutil.Join(["backend_driver_direct_object_dead_f64_compile_", label], ""),
                                                   compilerPath,
                                                   deadF64CompileArgs,
                                                   compileEnv,
                                                   rootDir,
                                                   420,
                                                   deadF64CompileLog)
    if !hostops.LoggedRunOk(deadF64CompileRun):
        let outputText = strutil.Strip(deadF64CompileRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return deadF64CompileRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, deadF64Out):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing dead f64 exe: ", deadF64Out], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, deadF64PrimaryObject):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing dead f64 primary object: ", deadF64PrimaryObject], ""))
        return 1
    if chengpath.PathFileExists(deadF64PrimaryAsm):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: unexpected dead f64 asm: ", deadF64PrimaryAsm], ""))
        return 1
    if chengpath.PathFileExists(deadF64PrimaryCompileLog):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: unexpected dead f64 asm compile log: ", deadF64PrimaryCompileLog], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, deadF64Report):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing dead f64 report: ", deadF64Report], ""))
        return 1
    let deadF64ReportText = chengpath.ReadTextFile("", deadF64Report)
    if !BackendDriverExpectContains("direct object writer dead f64 smoke", deadF64ReportText, "system_link_exec_runtime_execute=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer dead f64 smoke", deadF64ReportText, "system_link_exec_runtime_standalone_no_runtime=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer dead f64 smoke", deadF64ReportText, "system_link_exec_runtime_standalone_direct_entry=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer dead f64 smoke", deadF64ReportText, "primary_object_body_kinds=return_zero_i32,return_f64_mul_args,entry_bridge"):
        return 1
    if !BackendDriverExpectContains("direct object writer dead f64 smoke", deadF64ReportText, "primary_object_direct=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer dead f64 smoke", deadF64ReportText, "direct_object_symbol_count=3"):
        return 1
    let deadF64OtoolRun = hostops.RunProgramLogged(rootDir,
                                                   strutil.Join(["backend_driver_direct_object_dead_f64_otool_", label], ""),
                                                   "otool",
                                                   ["-tV", deadF64PrimaryObject],
                                                   [],
                                                   rootDir,
                                                   30,
                                                   deadF64OtoolLog)
    if deadF64OtoolRun.exitCode != 0:
        BackendDriverPrintErr("direct object writer smoke: dead f64 otool failed")
        return deadF64OtoolRun.exitCode
    if !BackendDriverExpectContains("direct object writer dead f64 otool", deadF64OtoolRun.output, "fmul"):
        return 1
    if !BackendDriverExpectContains("direct object writer dead f64 otool", deadF64OtoolRun.output, "d0, d0, d1"):
        return 1
    let deadF64Run = hostops.RunFileLogged(rootDir,
                                           strutil.Join(["backend_driver_direct_object_dead_f64_run_", label], ""),
                                           deadF64Out,
                                           [],
                                           [],
                                           rootDir,
                                           30,
                                           deadF64RunLog)
    if !hostops.LoggedRunOk(deadF64Run):
        let outputText = strutil.Strip(deadF64Run.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return deadF64Run.exitCode
    let run = hostops.RunFileLogged(rootDir,
                                      strutil.Join(["backend_driver_direct_object_writer_run_", label], ""),
                                      outBin,
                                      [],
                                      [],
                                      rootDir,
                                      30,
                                      runLog)
    if !hostops.LoggedRunOk(run):
        let outputText = strutil.Strip(run.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return run.exitCode
    BackendDriverPrintLine("direct_object_writer_smoke ok")
    return 0

fn BackendDriverRunFloat64DirectObjectSmoke(rootDir: str,
                                             compilerPath: str,
                                             outDir: str,
                                             label: str): int32 =
    let src = chengpath.PathAbsolute(rootDir, "src/tests/float64_mul_direct_object_smoke.cheng")
    let objPath = os.JoinPath(outDir, "float64_mul_direct_object_smoke.o")
    let reportPath = strutil.Join([objPath, ".report.txt"], "")
    let hostLog = strutil.Join([objPath, ".host.log"], "")
    let asmPath = strutil.Join([objPath, ".s"], "")
    let objectCompileLog = strutil.Join([objPath, ".compile.log"], "")
    let otoolLog = strutil.Join([objPath, ".otool.log"], "")
    BackendDriverRemoveFileIfPresent(objPath)
    BackendDriverRemoveFileIfPresent(reportPath)
    BackendDriverRemoveFileIfPresent(hostLog)
    BackendDriverRemoveFileIfPresent(asmPath)
    BackendDriverRemoveFileIfPresent(objectCompileLog)
    BackendDriverRemoveFileIfPresent(otoolLog)
    var compileArgs: str[]
    add(compileArgs, "system-link-exec")
    add(compileArgs, strutil.Join(["--root:", rootDir], ""))
    add(compileArgs, strutil.Join(["--in:", src], ""))
    add(compileArgs, "--emit:obj")
    add(compileArgs, "--target:arm64-apple-darwin")
    add(compileArgs, strutil.Join(["--out:", objPath], ""))
    add(compileArgs, strutil.Join(["--report-out:", reportPath], ""))
    var compileEnv = BackendDriverHostSmokeCompileEnv()
    add(compileEnv, "CHENG_REQUIRE_PURE_SYSTEM_LINK_EXEC=1")
    let compileRun = hostops.RunFileLogged(rootDir,
                                            strutil.Join(["backend_driver_float64_direct_object_compile_", label], ""),
                                            compilerPath,
                                            compileArgs,
                                            compileEnv,
                                            rootDir,
                                            420,
                                            hostLog)
    if !hostops.LoggedRunOk(compileRun):
        let outputText = strutil.Strip(compileRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return compileRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, objPath):
        BackendDriverPrintErr(strutil.Join(["float64 direct object smoke: missing object: ", objPath], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, reportPath):
        BackendDriverPrintErr(strutil.Join(["float64 direct object smoke: missing report: ", reportPath], ""))
        return 1
    if chengpath.PathFileExists(asmPath):
        BackendDriverPrintErr(strutil.Join(["float64 direct object smoke: unexpected asm: ", asmPath], ""))
        return 1
    if chengpath.PathFileExists(objectCompileLog):
        BackendDriverPrintErr(strutil.Join(["float64 direct object smoke: unexpected asm compile log: ", objectCompileLog], ""))
        return 1
    let reportText = chengpath.ReadTextFile("", reportPath)
    if !BackendDriverExpectContains("float64 direct object smoke", reportText, "system_link_exec_runtime_execute=1"):
        return 1
    if !BackendDriverExpectContains("float64 direct object smoke", reportText, "primary_object_body_kinds=return_f64_mul_args"):
        return 1
    if !BackendDriverExpectContains("float64 direct object smoke", reportText, "primary_object_direct=1"):
        return 1
    if !BackendDriverExpectContains("float64 direct object smoke", reportText, "direct_object_reloc_count=0"):
        return 1
    let otoolRun = hostops.RunProgramLogged(rootDir,
                                            strutil.Join(["backend_driver_float64_direct_object_otool_", label], ""),
                                            "otool",
                                            ["-tV", objPath],
                                            [],
                                            rootDir,
                                            30,
                                            otoolLog)
    if otoolRun.exitCode != 0:
        BackendDriverPrintErr("float64 direct object smoke: otool failed")
        return otoolRun.exitCode
    if !BackendDriverExpectContains("float64 direct object otool", otoolRun.output, "fmul"):
        return 1
    if !BackendDriverExpectContains("float64 direct object otool", otoolRun.output, "d0, d0, d1"):
        return 1
    BackendDriverPrintLine("float64_mul_direct_object_smoke ok")
    return 0

fn BackendDriverRunSeedMinimizationBoundarySmoke(rootDir: str,
                                                  compilerPath: str,
                                                  outDir: str,
                                                  label: str): int32 =
    let stage3 = BackendDriverStage3Path(rootDir)
    if !chengpath.FileExistsNonEmpty(rootDir, compilerPath):
        BackendDriverPrintErr(strutil.Join(["seed minimization boundary: missing backend driver: ", compilerPath], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, stage3):
        BackendDriverPrintErr(strutil.Join(["seed minimization boundary: missing stage3: ", stage3], ""))
        return 1
    let smokeDir = os.JoinPath(outDir, "seed_minimization_boundary_smoke_artifacts")
    if !chengpath.MkdirP(rootDir, smokeDir):
        BackendDriverPrintErr(strutil.Join(["seed minimization boundary: mkdir failed: ", smokeDir], ""))
        return 1
    let helpLog = os.JoinPath(smokeDir, "help.log")
    BackendDriverRemoveFileIfPresent(helpLog)
    let helpRun = hostops.RunFileLogged(rootDir,
                                         strutil.Join(["seed_minimization_boundary_help_", label], ""),
                                         compilerPath,
                                         ["help"],
                                         [],
                                         rootDir,
                                         30,
                                         helpLog)
    if helpRun.exitCode != 0:
        BackendDriverPrintErr("seed minimization boundary: help failed")
        return helpRun.exitCode
    if !BackendDriverExpectContains("seed minimization boundary help", helpRun.output, "core commands: status, print-build-plan, host-bridge-audit, system-link-exec"):
        return 1
    if !BackendDriverExpectContains("seed minimization boundary help", helpRun.output, "world/proof commands: world-receipt"):
        return 1
    if !BackendDriverExpectContains("seed minimization boundary help", helpRun.output, "debug-report"):
        return 1
    if !BackendDriverExpectContains("seed minimization boundary help", helpRun.output, "verify-debug-tools"):
        return 1
    if !BackendDriverExpectNotContains("seed minimization boundary help", helpRun.output, "core commands: status, print-build-plan, system-link-exec, world-receipt"):
        return 1
    if !BackendDriverAssertNoSeedHiddenSurface("seed minimization boundary help", helpRun.output):
        return 1

    let backendDriverMainText = chengpath.ReadTextFile(rootDir, "src/core/tooling/backend_driver_main.cheng")
    let compilerMainText = chengpath.ReadTextFile(rootDir, "src/core/tooling/compiler_main.cheng")
    let seedText = chengpath.ReadTextFile(rootDir, "bootstrap/cheng_seed.c")
    if !BackendDriverAssertNoSeedHiddenSurface("seed minimization boundary backend driver source", backendDriverMainText):
        return 1
    if !BackendDriverAssertNoSeedHiddenSurface("seed minimization boundary compiler source", compilerMainText):
        return 1
    if !BackendDriverAssertNoSeedHiddenSurface("seed minimization boundary c seed source", seedText):
        return 1
    if !BackendDriverExpectNotContains("seed minimization boundary c seed source",
                                       seedText,
                                       "cheng_seed_invoke_with_fresh_compile_env(cheng_seed_cmd_system_link_exec"):
        return 1

    let contractLog = os.JoinPath(smokeDir, "seed_print_contract.log")
    BackendDriverRemoveFileIfPresent(contractLog)
    let contractRun = hostops.RunFileLogged(rootDir,
                                             strutil.Join(["seed_minimization_boundary_contract_", label], ""),
                                             stage3,
                                             ["print-contract"],
                                             [],
                                             rootDir,
                                             30,
                                             contractLog)
    if contractRun.exitCode != 0:
        BackendDriverPrintErr("seed minimization boundary: print-contract failed")
        return contractRun.exitCode
    if !BackendDriverExpectContains("seed minimization boundary contract",
                                    contractRun.output,
                                    "supported_commands=print-contract,self-check,compile-bootstrap,bootstrap-bridge,build-backend-driver"):
        return 1
    if !BackendDriverExpectNotContains("seed minimization boundary contract",
                                       contractRun.output,
                                       "supported_commands=print-contract,self-check,compile-bootstrap,bootstrap-bridge,status"):
        return 1

    let hiddenCommand = strutil.Join(["__seed-system", "-link-exec"], "")
    let hiddenLog = os.JoinPath(smokeDir, "hidden_system_link_exec.log")
    BackendDriverRemoveFileIfPresent(hiddenLog)
    let hiddenRun = hostops.RunFileLogged(rootDir,
                                           strutil.Join(["seed_minimization_boundary_hidden_", label], ""),
                                           stage3,
                                           [hiddenCommand],
                                           [],
                                           rootDir,
                                           30,
                                           hiddenLog)
    if hiddenRun.exitCode != 2:
        BackendDriverPrintErr("seed minimization boundary: hidden system-link-exec returned wrong rc")
        return 1
    if !BackendDriverExpectContains("seed minimization boundary hidden command",
                                    hiddenRun.output,
                                    strutil.Join(["[cheng_seed] unknown command: ", hiddenCommand], "")):
        return 1
    let noHandoffLog = os.JoinPath(smokeDir, "no_handoff_non_bootstrap.log")
    BackendDriverRemoveFileIfPresent(noHandoffLog)
    let noHandoffRun = hostops.RunFileLogged(rootDir,
                                              strutil.Join(["seed_minimization_boundary_no_handoff_", label], ""),
                                              stage3,
                                              ["print-asm"],
                                              [],
                                              rootDir,
                                              30,
                                              noHandoffLog)
    if noHandoffRun.exitCode != 2:
        BackendDriverPrintErr("seed minimization boundary: no-handoff non-bootstrap command returned wrong rc")
        return 1
    if !BackendDriverExpectContains("seed minimization boundary no-handoff command",
                                    noHandoffRun.output,
                                    "non-bootstrap command requires backend driver handoff: print-asm"):
        return 1

    let nonce = strutil.Join([strings.Int64ToStr(os.Time()), "_", strings.Int64ToStr(hostops.HostOpsCurrentPid())], "")
    let cacheSource = chengpath.PathAbsolute(rootDir,
                                             strutil.Join(["src/tests/backend_driver_cache_restore_fixture_",
                                                  nonce,
                                                  ".cheng"], ""))
    BackendDriverRemoveFileIfPresent(cacheSource)
    if !chengpath.WriteTextFile(rootDir, cacheSource, "fn main(): int32 =\n    return 0\n"):
        BackendDriverPrintErr("seed minimization boundary: failed to write cache fixture")
        return 1
    let cacheOut = os.JoinPath(smokeDir, "backend_driver_cache_restore_zero")
    let cacheMap = strutil.Join([cacheOut, ".map"], "")
    let cachePrimeReport = os.JoinPath(smokeDir, "backend_driver_cache_restore.prime.report.txt")
    let cachePrimeLog = os.JoinPath(smokeDir, "backend_driver_cache_restore.prime.log")
    let cacheRestoreReport = os.JoinPath(smokeDir, "backend_driver_cache_restore.report.txt")
    let cacheRestoreLog = os.JoinPath(smokeDir, "backend_driver_cache_restore.log")
    BackendDriverRemoveFileIfPresent(cacheOut)
    BackendDriverRemoveFileIfPresent(cacheMap)
    BackendDriverRemoveFileIfPresent(cachePrimeReport)
    BackendDriverRemoveFileIfPresent(cacheRestoreReport)

    var cacheArgs: str[]
    add(cacheArgs, "system-link-exec")
    add(cacheArgs, strutil.Join(["--root:", rootDir], ""))
    add(cacheArgs, strutil.Join(["--in:", cacheSource], ""))
    add(cacheArgs, "--emit:exe")
    add(cacheArgs, "--target:arm64-apple-darwin")
    add(cacheArgs, strutil.Join(["--out:", cacheOut], ""))
    var cachePrimeArgs = cacheArgs
    add(cachePrimeArgs, strutil.Join(["--report-out:", cachePrimeReport], ""))
    let cachePrimeRun = hostops.RunFileLogged(rootDir,
                                               strutil.Join(["seed_minimization_boundary_cache_prime_", label], ""),
                                               compilerPath,
                                               cachePrimeArgs,
                                               [
                                                   "CHENG_ENABLE_SYSTEM_LINK_EXEC_CACHE=1",
                                                   "CHENG_REQUIRE_PURE_SYSTEM_LINK_EXEC=1",
                                                   "CHENG_PROGRESS=1",
                                                   "CHENG_PROCESS_MAX_RSS_BYTES=8589934592"
                                               ],
                                               rootDir,
                                               120,
                                               cachePrimeLog)
    if cachePrimeRun.exitCode != 0:
        let outputText = strutil.Strip(cachePrimeRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return cachePrimeRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, cacheOut) || !chengpath.FileExistsNonEmpty(rootDir, cacheMap):
        BackendDriverPrintErr("seed minimization boundary: cache prime missing output")
        return 1
    let cachePrimeReportText = chengpath.ReadTextFile("", cachePrimeReport)
    if !BackendDriverExpectContains("seed minimization boundary cache prime", cachePrimeReportText, "system_link_exec_runtime_execute=1"):
        return 1
    if !BackendDriverExpectContains("seed minimization boundary cache prime", cachePrimeReportText, "system_link_exec_runtime_standalone_direct_entry=1"):
        return 1
    if !BackendDriverExpectContains("seed minimization boundary cache prime", cachePrimeReportText, "primary_object_direct=1"):
        return 1
    if !BackendDriverExpectContains("seed minimization boundary cache prime", cachePrimeReportText, "direct_object_bytes="):
        return 1
    if !BackendDriverExpectContains("seed minimization boundary cache prime", cachePrimeReportText, "backend_driver_system_link_exec_cache_store=1"):
        return 1
    if !BackendDriverExpectNotContains("seed minimization boundary cache prime", cachePrimeReportText, "backend_driver_system_link_exec_cache_restore=1"):
        return 1

    BackendDriverRemoveFileIfPresent(cacheOut)
    BackendDriverRemoveFileIfPresent(cacheMap)
    var cacheRestoreArgs = cacheArgs
    add(cacheRestoreArgs, strutil.Join(["--report-out:", cacheRestoreReport], ""))
    let cacheRestoreRun = hostops.RunFileLogged(rootDir,
                                                 strutil.Join(["seed_minimization_boundary_cache_restore_", label], ""),
                                                 compilerPath,
                                                 cacheRestoreArgs,
                                                 [
                                                     "CHENG_ENABLE_SYSTEM_LINK_EXEC_CACHE=1",
                                                     "CHENG_BACKEND_DRIVER_REQUIRE_SYSTEM_LINK_EXEC_CACHE_HIT=1",
                                                     "CHENG_PROCESS_MAX_RSS_BYTES=8589934592"
                                                 ],
                                                 rootDir,
                                                 120,
                                                 cacheRestoreLog)
    if cacheRestoreRun.exitCode != 0:
        let outputText = strutil.Strip(cacheRestoreRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return cacheRestoreRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, cacheOut) || !chengpath.FileExistsNonEmpty(rootDir, cacheMap):
        BackendDriverPrintErr("seed minimization boundary: cache restore missing output")
        return 1
    let cacheRestoreReportText = chengpath.ReadTextFile("", cacheRestoreReport)
    if !BackendDriverExpectContains("seed minimization boundary cache restore", cacheRestoreReportText, "backend_driver_system_link_exec_cache_restore=1"):
        return 1
    if !BackendDriverExpectContains("seed minimization boundary cache restore", cacheRestoreReportText, "exec_pipeline_stage=system_link_exec_cache_hit"):
        return 1
    let cacheRunLog = os.JoinPath(smokeDir, "backend_driver_cache_restore.run.log")
    let cacheRun = hostops.RunFileLogged(rootDir,
                                          strutil.Join(["seed_minimization_boundary_cache_run_", label], ""),
                                          cacheOut,
                                          [],
                                          [],
                                          rootDir,
                                          30,
                                          cacheRunLog)
    if cacheRun.exitCode != 0:
        BackendDriverPrintErr("seed minimization boundary: restored exe failed")
        BackendDriverRemoveFileIfPresent(cacheSource)
        return cacheRun.exitCode
    BackendDriverRemoveFileIfPresent(cacheSource)
    BackendDriverPrintLine("seed_minimization_boundary_smoke ok")
    return 0

fn BackendDriverRunCommandSurfaceSmoke(rootDir: str,
                                        compilerPath: str,
                                        outDir: str,
                                        label: str): int32 =
    if !chengpath.FileExistsNonEmpty(rootDir, compilerPath):
        BackendDriverPrintErr(strutil.Join(["backend driver command surface: missing backend driver: ", compilerPath], ""))
        return 1
    let smokeDir = os.JoinPath(outDir, "backend_driver_command_surface_smoke_artifacts")
    if !chengpath.MkdirP(rootDir, smokeDir):
        BackendDriverPrintErr(strutil.Join(["backend driver command surface: mkdir failed: ", smokeDir], ""))
        return 1
    let helpLog = os.JoinPath(smokeDir, "help.log")
    BackendDriverRemoveFileIfPresent(helpLog)
    let helpRun = hostops.RunFileLogged(rootDir,
                                         strutil.Join(["backend_driver_surface_help_", label], ""),
                                         compilerPath,
                                         ["help"],
                                         [],
                                         rootDir,
                                         30,
                                         helpLog)
    if helpRun.exitCode != 0:
        BackendDriverPrintErr("backend driver command surface: help failed")
        return helpRun.exitCode
    if !BackendDriverExpectContains("backend driver command surface help", helpRun.output, "usage: cheng <command> [args]"):
        return 1
    if !BackendDriverExpectContains("backend driver command surface help", helpRun.output, "core commands: status, print-build-plan, host-bridge-audit, system-link-exec"):
        return 1
    if !BackendDriverExpectContains("backend driver command surface help", helpRun.output, "world/proof commands: world-receipt"):
        return 1
    if !BackendDriverExpectContains("backend driver command surface help", helpRun.output, "debug commands:"):
        return 1
    if !BackendDriverExpectContains("backend driver command surface help", helpRun.output, "verify-export-visibility"):
        return 1
    if !BackendDriverExpectContains("backend driver command surface help", helpRun.output, "run-host-smokes"):
        return 1
    let statusLog = os.JoinPath(smokeDir, "status.log")
    BackendDriverRemoveFileIfPresent(statusLog)
    let statusRun = hostops.RunFileLogged(rootDir,
                                           strutil.Join(["backend_driver_surface_status_", label], ""),
                                           compilerPath,
                                           ["status"],
                                           [],
                                           rootDir,
                                           30,
                                           statusLog)
    if statusRun.exitCode != 0:
        BackendDriverPrintErr("backend driver command surface: status failed")
        return statusRun.exitCode
    if !BackendDriverExpectContains("backend driver command surface status", statusRun.output, "compiler_entry="):
        return 1
    if !BackendDriverExpectContains("backend driver command surface status", statusRun.output, "/src/core/tooling/backend_driver_main.cheng"):
        return 1
    BackendDriverPrintLine("cheng backend_driver_command_surface_smoke ok")
    return 0

fn BackendDriverRunBuildPlanReportSmoke(rootDir: str): int32 =
    let plan: buildplan.BackendBuildPlan = buildplan.BackendBuildPlanBackendDriverForTarget(rootDir,
                                                                                             "arm64-apple-darwin")
    let report: str = buildplan.BackendBuildPlanReport(plan)
    if !BackendDriverExpectContains("build plan report smoke", report, "target=arm64-apple-darwin"):
        return 1
    if !BackendDriverExpectContains("build plan report smoke", report, "/src/core/tooling/backend_driver_main.cheng"):
        return 1
    if !BackendDriverExpectContains("build plan report smoke", report, "/src/core/tooling/export_visibility_gate.cheng"):
        return 1
    if !BackendDriverExpectNotContains("build plan report smoke", report, "/src/core/tooling/host_bridge_audit_gate.cheng"):
        return 1
    if !BackendDriverExpectNotContains("build plan report smoke", report, "/src/core/tooling/hotpath_scan.cheng"):
        return 1
    if !BackendDriverExpectNotContains("build plan report smoke", report, "/src/core/tooling/host_smoke_gate.cheng"):
        return 1
    if !BackendDriverExpectNotContains("build plan report smoke", report, "/src/core/tooling/support_matrix.cheng"):
        return 1
    if !BackendDriverExpectContains("build plan report smoke", report, "/src/core/backend/build_plan.cheng"):
        return 1
    if !BackendDriverExpectNotContains("build plan report smoke", report, "/src/core/tooling/wasm_binary_audit.cheng"):
        return 1
    if !BackendDriverExpectNotContains("build plan report smoke", report, "/src/core/tooling/wasm_smoke_gate.cheng"):
        return 1
    BackendDriverPrintLine("build_plan_report_smoke ok")
    return 0

fn BackendDriverRunOneHostSmoke(rootDir: str,
                                  compilerPath: str,
                                  outDir: str,
                                  label: str,
                                  smokeName: str,
                                  r2cControllerExe: str): int32 =
    if smokeName == "direct_object_writer_smoke":
        return BackendDriverRunDirectObjectWriterSmoke(rootDir, compilerPath, outDir, label)
    if smokeName == "float64_mul_direct_object_smoke":
        return BackendDriverRunFloat64DirectObjectSmoke(rootDir, compilerPath, outDir, label)
    if smokeName == "seed_minimization_boundary_smoke":
        return BackendDriverRunSeedMinimizationBoundarySmoke(rootDir, compilerPath, outDir, label)
    if smokeName == "backend_driver_command_surface_smoke":
        return BackendDriverRunCommandSurfaceSmoke(rootDir, compilerPath, outDir, label)
    if smokeName == "build_plan_report_smoke":
        return BackendDriverRunBuildPlanReportSmoke(rootDir)
    let src = chengpath.PathAbsolute(rootDir, strutil.Join(["src/tests/", smokeName, ".cheng"], ""))
    if !chengpath.FileExistsNonEmpty(rootDir, src):
        BackendDriverPrintErr(strutil.Join(["backend driver host smokes: missing source: ", src], ""))
        return 1
    let outBin = os.JoinPath(outDir, smokeName)
    let compileLog = strutil.Join([outBin, ".compile.log"], "")
    let runLog = strutil.Join([outBin, ".run.log"], "")
    if chengpath.PathFileExists(outBin):
        os.RemoveFile(outBin)
    if chengpath.PathFileExists(strutil.Join([outBin, ".map"], "")):
        os.RemoveFile(strutil.Join([outBin, ".map"], ""))
    if chengpath.PathFileExists(compileLog):
        os.RemoveFile(compileLog)
    if chengpath.PathFileExists(runLog):
        os.RemoveFile(runLog)
    var compileArgs: str[]
    add(compileArgs, "system-link-exec")
    add(compileArgs, strutil.Join(["--root:", rootDir], ""))
    add(compileArgs, strutil.Join(["--in:", src], ""))
    add(compileArgs, "--emit:exe")
    add(compileArgs, "--target:arm64-apple-darwin")
    add(compileArgs, strutil.Join(["--out:", outBin], ""))
    let compileRun = hostops.RunFileLogged(rootDir,
                                             strutil.Join(["backend_driver_host_smoke_compile_", label, "_", smokeName], ""),
                                             compilerPath,
                                             compileArgs,
                                             BackendDriverHostSmokeCompileEnv(),
                                             rootDir,
                                             420,
                                             compileLog)
    if !hostops.LoggedRunOk(compileRun):
        let outputText = strutil.Strip(compileRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return compileRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, outBin):
        BackendDriverPrintErr(strutil.Join(["backend driver host smokes: compile missing output: ", outBin], ""))
        return 1
    let run = hostops.RunFileLogged(rootDir,
                                      strutil.Join(["backend_driver_host_smoke_run_", label, "_", smokeName], ""),
                                      outBin,
                                      [],
                                      BackendDriverHostSmokeRunEnv(smokeName, r2cControllerExe),
                                      rootDir,
                                      BackendDriverHostSmokeRunTimeoutSec(smokeName),
                                      runLog)
    let runOutput = strutil.Strip(run.output)
    if len(runOutput) > 0:
        if hostops.LoggedRunOk(run):
            BackendDriverPrintLine(runOutput)
        else:
            BackendDriverPrintErr(runOutput)
    if !hostops.LoggedRunOk(run):
        return run.exitCode
    return 0

fn BackendDriverRunHostSmokesWithR2cController(rootDir: str,
                                                args: str[],
                                                r2cControllerExe: str): int32 =
    let tailOnly = strutil.Strip(BackendDriverReadFlag(args, "--tail-only", ""))
    if len(tailOnly) > 0:
        BackendDriverPrintErr("backend driver host smokes: --tail-only is not part of the minimal direct gate")
        return 2
    let compilerPath = BackendDriverHostSmokeCompiler(rootDir, args)
    if !chengpath.FileExistsNonEmpty(rootDir, compilerPath):
        BackendDriverPrintErr(strutil.Join(["backend driver host smokes: missing compiler: ", compilerPath], ""))
        return 1
    let tests = BackendDriverCollectHostSmokeNames(args)
    if tests.len <= 0:
        return BackendDriverForward(rootDir, "run-host-smokes", args)
    let label = BackendDriverHostSmokeLabel(args)
    var outDir = chengpath.PathAbsolute(rootDir, "artifacts/hostrun")
    if label != "host":
        outDir = os.JoinPath(outDir, label)
    if !chengpath.MkdirP(rootDir, outDir):
        BackendDriverPrintErr(strutil.Join(["backend driver host smokes: mkdir failed: ", outDir], ""))
        return 1
    var effectiveR2cControllerExe = r2cControllerExe
    if len(effectiveR2cControllerExe) <= 0 && BackendDriverHostSmokesNeedR2cController(tests):
        effectiveR2cControllerExe = BackendDriverResolveR2cReactController(rootDir,
                                                                           compilerPath,
                                                                           outDir)
        if len(effectiveR2cControllerExe) <= 0:
            return 1
    for i in 0..<tests.len:
        if BackendDriverRunOneHostSmoke(rootDir, compilerPath, outDir, label, tests[i], effectiveR2cControllerExe) != 0:
            return 1
    BackendDriverPrintLine("cheng backend driver host smokes: ok")
    return 0

fn BackendDriverRunHostSmokes(rootDir: str, args: str[]): int32 =
    return BackendDriverRunHostSmokesWithR2cController(rootDir, args, "")

fn BackendDriverRunBuiltinHostSmoke(rootDir: str,
                                      label: str,
                                      smokeName: str): int32 =
    return BackendDriverRunHostSmokes(rootDir, [strutil.Join(["--label:", label], ""), smokeName])

type
    BackendDriverDebugPlans =
        linkPlan: slplan.SystemLinkPlanStub
        loweringPlan: lower.LoweringPlanStub
        primaryPlan: pobj.PrimaryObjectPlan

fn BackendDriverWriteOptionalReport(rootDir: str,
                                      reportPath: str,
                                      text: str): bool =
    let trimmedPath = strutil.Strip(reportPath)
    if len(trimmedPath) <= 0:
        return true
    return chengpath.WriteTextFile(rootDir, trimmedPath, text)

fn BackendDriverBuildDebugPlans(rootDir: str,
                                  args: str[],
                                  outPlans: var BackendDriverDebugPlans): bool =
    let reqRes = creq.CompilerRequestFromArgsForCommand(rootDir, args, false)
    if IsErr(reqRes):
        BackendDriverPrintErr(Error(reqRes))
        return false
    let req = Value(reqRes)
    var linkPlan: slplan.SystemLinkPlanStub
    var linkErr = ""
    if !slplan.BuildSystemLinkPlanStub(rootDir, req, linkPlan, linkErr):
        BackendDriverPrintErr(linkErr)
        return false
    var loweringPlan: lower.LoweringPlanStub
    var loweringErr = ""
    if !lower.BuildLoweringPlanStub(linkPlan, loweringPlan, loweringErr):
        BackendDriverPrintErr(loweringErr)
        return false
    let primaryPlan = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    outPlans.linkPlan = linkPlan
    outPlans.loweringPlan = loweringPlan
    outPlans.primaryPlan = primaryPlan
    return true

fn BackendDriverRunDebugTextCommand(rootDir: str,
                                      args: str[],
                                      commandName: str): int32 =
    var plans: BackendDriverDebugPlans
    if !BackendDriverBuildDebugPlans(rootDir, args, plans):
        return 2
    var report = ""
    if commandName == "debug-report":
        report = debuggate.DebugToolsDebugReportText(plans.linkPlan,
                                                       plans.loweringPlan,
                                                       plans.primaryPlan)
    elif commandName == "print-symbols":
        report = debuggate.DebugToolsSymbolsReportText(plans.linkPlan,
                                                        plans.loweringPlan,
                                                        plans.primaryPlan)
    elif commandName == "print-line-map":
        report = linemap.LineMapText(plans.linkPlan, plans.loweringPlan)
    elif commandName == "print-asm":
        let asmReport = debuggate.DebugToolsAsmReportText(plans.linkPlan,
                                                          plans.loweringPlan,
                                                          plans.primaryPlan)
        if IsErr(asmReport):
            BackendDriverPrintErr(Error(asmReport))
            return 1
        report = Value(asmReport)
    else:
        BackendDriverPrintErr(strutil.Join(["backend driver debug: unsupported direct command: ", commandName], ""))
        return 2
    let reportPath = creq.CompilerReadFlagOrDefault(args, "--report-out", "")
    if !BackendDriverWriteOptionalReport(rootDir, reportPath, strutil.Join([report, "\n"], "")):
        BackendDriverPrintErr(strutil.Join(["backend driver debug: failed to write report: ", reportPath], ""))
        return 1
    BackendDriverPrintLine(strutil.Strip(report))
    return 0

fn BackendDriverRunObjectReportCommand(rootDir: str,
                                         args: str[]): int32 =
    let objectPathRaw = creq.CompilerReadFlagOrDefault(args, "--object", "")
    let objectPath = chengpath.PathAbsolute(rootDir, objectPathRaw)
    if len(objectPathRaw) <= 0:
        BackendDriverPrintErr("backend driver print-object: missing --object")
        return 2
    if !chengpath.FileExistsNonEmpty(rootDir, objectPath):
        BackendDriverPrintErr(strutil.Join(["backend driver print-object: missing object: ", objectPath], ""))
        return 1
    let reportRes = objectreport.ObjectDebugReportText(objectPath)
    if IsErr(reportRes):
        BackendDriverPrintErr(Error(reportRes))
        return 1
    let report = Value(reportRes)
    let reportPath = creq.CompilerReadFlagOrDefault(args, "--report-out", "")
    if !BackendDriverWriteOptionalReport(rootDir, reportPath, strutil.Join([report, "\n"], "")):
        BackendDriverPrintErr(strutil.Join(["backend driver print-object: failed to write report: ", reportPath], ""))
        return 1
    BackendDriverPrintLine(strutil.Strip(report))
    return 0

fn BackendDriverRunProfileReport(rootDir: str,
                                   args: str[]): int32 =
    let rawPath = creq.CompilerReadFlagOrDefault(args, "--in", "")
    if len(rawPath) <= 0:
        BackendDriverPrintErr("backend driver profile-report: missing --in")
        return 2
    if !chengpath.FileExistsNonEmpty(rootDir, rawPath):
        BackendDriverPrintErr(strutil.Join(["backend driver profile-report: missing raw profile: ", rawPath], ""))
        return 1
    var outPath = creq.CompilerReadFlagOrDefault(args, "--out", "")
    if len(outPath) <= 0:
        outPath = debuggate.DebugToolsProfileReportPathFromRaw(rawPath)
    let reportRes = debuggate.DebugToolsProfileReportText(chengpath.ReadTextFile(rootDir, rawPath))
    if IsErr(reportRes):
        BackendDriverPrintErr(Error(reportRes))
        return 1
    let report = Value(reportRes)
    if !chengpath.WriteTextFile(rootDir, outPath, report):
        BackendDriverPrintErr(strutil.Join(["backend driver profile-report: failed to write report: ", outPath], ""))
        return 1
    BackendDriverPrintLine(strutil.Strip(report))
    return 0

fn BackendDriverRunCrashReport(rootDir: str,
                                 args: str[]): int32 =
    let rawPath = creq.CompilerReadFlagOrDefault(args, "--in", "")
    if len(rawPath) <= 0:
        BackendDriverPrintErr("backend driver crash-report: missing --in")
        return 2
    if !chengpath.FileExistsNonEmpty(rootDir, rawPath):
        BackendDriverPrintErr(strutil.Join(["backend driver crash-report: missing raw log: ", rawPath], ""))
        return 1
    var outPath = creq.CompilerReadFlagOrDefault(args, "--out", "")
    if len(outPath) <= 0:
        outPath = debuggate.DebugToolsCrashReportPathFromRaw(rawPath)
    let reportRes = debuggate.DebugToolsCrashReportText(chengpath.ReadTextFile(rootDir, rawPath))
    if IsErr(reportRes):
        BackendDriverPrintErr(Error(reportRes))
        return 1
    let report = Value(reportRes)
    if !chengpath.WriteTextFile(rootDir, outPath, report):
        BackendDriverPrintErr(strutil.Join(["backend driver crash-report: failed to write report: ", outPath], ""))
        return 1
    BackendDriverPrintLine(strutil.Strip(report))
    return 0

fn BackendDriverProfileRunDefaultOut(rootDir: str,
                                      sourcePath: str): str =
    let split = chengpath.PathSplitFile(sourcePath)
    var name = split.name
    if len(name) <= 0:
        name = "profile_run"
    return os.JoinPath(chengpath.PathAbsolute(rootDir, "artifacts/debug_profile"), name)

fn BackendDriverEnsureParentDir(rootDir: str,
                                  path: str): bool =
    let parent = chengpath.PathParentDir(path)
    if len(parent) <= 0:
        return true
    return chengpath.MkdirP(rootDir, parent)

fn BackendDriverRemoveFileIfExists(path: str) =
    if chengpath.PathFileExists(path):
        os.RemoveFile(path)

fn BackendDriverBuildLinuxNolibcExe(rootDir: str): int32 =
    let targetRaw = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_TARGET", "aarch64-unknown-linux-gnu"))
    let sourceRaw = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_SOURCE", ""))
    let outRaw = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_OUT", ""))
    if len(sourceRaw) <= 0:
        BackendDriverPrintErr(" linux exe: missing CHENG_LINUX_EXE_SOURCE")
        return 1
    if len(outRaw) <= 0:
        BackendDriverPrintErr(" linux exe: missing CHENG_LINUX_EXE_OUT")
        return 1
    var target = targetRaw
    if target == "arm64-unknown-linux-gnu":
        target = "aarch64-unknown-linux-gnu"
    if target != "aarch64-unknown-linux-gnu":
        BackendDriverPrintErr(strutil.Join([" linux exe: unsupported target=", targetRaw], ""))
        return 1
    let compilerRaw = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_COMPILER", "artifacts/backend_driver/cheng"))
    let compilerPath = chengpath.PathAbsolute(rootDir, compilerRaw)
    if !chengpath.FileExistsNonEmpty(rootDir, compilerPath):
        BackendDriverPrintErr(strutil.Join([" linux exe: missing compiler: ", compilerPath], ""))
        return 1
    let sourcePath = chengpath.PathAbsolute(rootDir, sourceRaw)
    let outPath = chengpath.PathAbsolute(rootDir, outRaw)
    let reportRaw = strutil.Strip(os.GetEnvDefault("CHENG_LINUX_EXE_REPORT", ""))
    let compileLog = strutil.Join([outPath, ".compile.log"], "")
    if !chengpath.FileExistsNonEmpty(rootDir, sourcePath):
        BackendDriverPrintErr(strutil.Join([" linux exe: missing source: ", sourcePath], ""))
        return 1
    if !BackendDriverEnsureParentDir(rootDir, outPath):
        BackendDriverPrintErr(strutil.Join([" linux exe: failed to create output dir: ", outPath], ""))
        return 1
    if len(reportRaw) > 0:
        let reportPath = chengpath.PathAbsolute(rootDir, reportRaw)
        if !BackendDriverEnsureParentDir(rootDir, reportPath):
            BackendDriverPrintErr(strutil.Join([" linux exe: failed to create report dir: ", reportPath], ""))
            return 1
    BackendDriverRemoveFileIfExists(outPath)
    BackendDriverRemoveFileIfExists(strutil.Join([outPath, ".map"], ""))
    BackendDriverRemoveFileIfExists(compileLog)
    var compileArgs: str[]
    add(compileArgs, "system-link-exec")
    add(compileArgs, strutil.Join(["--root:", rootDir], ""))
    add(compileArgs, strutil.Join(["--in:", sourcePath], ""))
    add(compileArgs, "--emit:exe")
    add(compileArgs, strutil.Join(["--target:", target], ""))
    add(compileArgs, strutil.Join(["--out:", outPath], ""))
    if len(reportRaw) > 0:
        add(compileArgs, strutil.Join(["--report-out:", chengpath.PathAbsolute(rootDir, reportRaw)], ""))
    let run = hostops.RunFileLogged(rootDir,
                                      "backend_driver_linux_nolibc_exe",
                                      compilerPath,
                                      compileArgs,
                                      BackendDriverHostSmokeCompileEnv(),
                                      rootDir,
                                      int32(strutil.ParseInt(os.GetEnvDefault("CHENG_COMPILE_TIMEOUT_SEC", "300"))),
                                      compileLog)
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        if hostops.LoggedRunOk(run):
            BackendDriverPrintLine(outputText)
        else:
            BackendDriverPrintErr(outputText)
    if !hostops.LoggedRunOk(run):
        return run.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, outPath):
        BackendDriverPrintErr(strutil.Join([" linux exe: missing output: ", outPath], ""))
        return 1
    BackendDriverPrintLine(strutil.Join(["cheng linux exe: build ok target=", target, " out=", outPath], ""))
    return 0

fn BackendDriverSelfCompiler(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng")

fn BackendDriverCurrentExecutablePath(rootDir: str): str =
    let raw = strutil.Strip(BackendDriverParamStr(0))
    if len(raw) <= 0:
        return ""
    let resolved = hostops.ResolveProgram(rootDir, raw)
    if len(resolved) > 0:
        return resolved
    return chengpath.PathAbsolute(rootDir, raw)

fn BackendDriverRequireOutput(text: str,
                                needle: str,
                                label: str): bool =
    if strutil.Contains(text, needle):
        return true
    BackendDriverPrintErr(strutil.Join([label, ": missing output: ", needle], ""))
    return false

fn BackendDriverCompileDarwinExe(rootDir: str,
                                   label: str,
                                   sourcePath: str,
                                   outputPath: str,
                                   compileLog: str): int32 =
    return BackendDriverCompileDarwinExeWithCompiler(rootDir,
                                                     label,
                                                     BackendDriverSelfCompiler(rootDir),
                                                     sourcePath,
                                                     outputPath,
                                                     compileLog)

fn BackendDriverCompileDarwinExeWithCompiler(rootDir: str,
                                               label: str,
                                               compilerPath: str,
                                   sourcePath: str,
                                   outputPath: str,
                                   compileLog: str): int32 =
    if !chengpath.FileExistsNonEmpty(rootDir, compilerPath):
        BackendDriverPrintErr(strutil.Join([label, ": missing compiler: ", compilerPath], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, sourcePath):
        BackendDriverPrintErr(strutil.Join([label, ": missing source: ", sourcePath], ""))
        return 1
    if !BackendDriverEnsureParentDir(rootDir, outputPath) ||
       !BackendDriverEnsureParentDir(rootDir, compileLog):
        BackendDriverPrintErr(strutil.Join([label, ": failed to create output dirs"], ""))
        return 1
    BackendDriverRemoveFileIfExists(outputPath)
    BackendDriverRemoveFileIfExists(strutil.Join([outputPath, ".map"], ""))
    BackendDriverRemoveFileIfExists(compileLog)
    var compileArgs: str[]
    add(compileArgs, "system-link-exec")
    add(compileArgs, strutil.Join(["--root:", rootDir], ""))
    add(compileArgs, strutil.Join(["--in:", sourcePath], ""))
    add(compileArgs, "--emit:exe")
    add(compileArgs, "--target:arm64-apple-darwin")
    add(compileArgs, strutil.Join(["--out:", outputPath], ""))
    let run = hostops.RunFileLogged(rootDir,
                                      strutil.Join([label, "_compile"], ""),
                                      compilerPath,
                                      compileArgs,
                                      BackendDriverHostSmokeCompileEnv(),
                                      rootDir,
                                      420,
                                      compileLog)
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        if hostops.LoggedRunOk(run):
            BackendDriverPrintLine(outputText)
        else:
            BackendDriverPrintErr(outputText)
    if !hostops.LoggedRunOk(run):
        return run.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, outputPath):
        BackendDriverPrintErr(strutil.Join([label, ": missing output: ", outputPath], ""))
        return 1
    return 0

fn BackendDriverRunCompiled(rootDir: str,
                              label: str,
                              outputPath: str,
                              runLog: str,
                              expectSuccess: bool): hostops.LoggedRun =
    BackendDriverRemoveFileIfExists(runLog)
    let run = hostops.RunFileLogged(rootDir,
                                      strutil.Join([label, "_run"], ""),
                                      outputPath,
                                      [],
                                      [],
                                      rootDir,
                                      20,
                                      runLog)
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        if expectSuccess:
            if hostops.LoggedRunOk(run):
                BackendDriverPrintLine(outputText)
            else:
                BackendDriverPrintErr(outputText)
        else:
            if hostops.LoggedRunOk(run):
                BackendDriverPrintErr(outputText)
            else:
                BackendDriverPrintLine(outputText)
    return run

fn BackendDriverBuildRunSuccessFixture(rootDir: str,
                                         commandName: str,
                                         artifactDirRel: str,
                                         sourceRel: str,
                                         outputName: str): int32 =
    let outDir = chengpath.PathAbsolute(rootDir, artifactDirRel)
    let sourcePath = chengpath.PathAbsolute(rootDir, sourceRel)
    let outputPath = os.JoinPath(outDir, outputName)
    let compileLog = os.JoinPath(outDir, strutil.Join([outputName, ".compile.log"], ""))
    let runLog = os.JoinPath(outDir, strutil.Join([outputName, ".run.log"], ""))
    let compileRc = BackendDriverCompileDarwinExe(rootDir,
                                                   commandName,
                                                   sourcePath,
                                                   outputPath,
                                                   compileLog)
    if compileRc != 0:
        return compileRc
    if commandName == "build-zero-exit" &&
       !chengpath.FileExistsNonEmpty(rootDir, strutil.Join([outputPath, ".map"], "")):
        BackendDriverPrintErr("zero-exit: missing line-map")
        return 1
    let run = BackendDriverRunCompiled(rootDir,
                                        commandName,
                                        outputPath,
                                        runLog,
                                        true)
    if !hostops.LoggedRunOk(run):
        return run.exitCode
    return 0

