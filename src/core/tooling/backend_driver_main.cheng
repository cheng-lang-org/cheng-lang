const
    BackendDriverSystemLinkExecCacheVersion = "system-link-exec-cache-v3"
    BackendDriverSystemLinkExecCacheRequireHitEnv = "CHENG_BACKEND_DRIVER_REQUIRE_SYSTEM_LINK_EXEC_CACHE_HIT"

@importc("get_stdout")
fn BackendDriverStdoutBridge(): os.File

@importc("get_stderr")
fn BackendDriverStderrBridge(): os.File

@importc("paramCount")
fn BackendDriverParamCountBridge(): int32

@importc("__cheng_rt_paramStr")
fn BackendDriverParamStrRawBridge(i: int32): cstring

@importc("cheng_backend_driver_root")
fn BackendDriverRoot(): str

@importc("cheng_backend_driver_ensure_root_env")
fn BackendDriverEnsureRootEnv(rootDir: str)

@importc("cheng_backend_driver_usage")
fn BackendDriverUsage(rootDir: str)

fn BackendDriverPrintLine(text: str) =
    os.WriteLine(BackendDriverStdoutBridge(), text)

fn BackendDriverPrintErr(text: str) =
    os.WriteLine(BackendDriverStderrBridge(), text)

fn BackendDriverPrintKeyValue(key: str,
                                value: str) =
    os.Write(BackendDriverStdoutBridge(), key)
    os.Write(BackendDriverStdoutBridge(), "=")
    os.WriteLine(BackendDriverStdoutBridge(), value)

fn BackendDriverTruthyEnv(name: str): bool =
    let raw = os.GetEnv(name)
    return len(raw) > 0 && raw != "0" && raw != "false"

fn BackendDriverStage3Path(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage3")

fn BackendDriverCollectArgsFrom(startIndex: int32,
                                  count: int32): str[] =
    var out: str[]
    if startIndex > count:
        return out
    for i in startIndex..count:
        let arg = BackendDriverParamStr(i)
        if len(arg) > 0:
            add(out, arg)
    return out

fn BackendDriverStartsWith(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    return strings.SliceBytes(text, 0, len(prefix)) == prefix

fn BackendDriverReadFlag(args: str[],
                           key: str,
                           defaultValue: str): str =
    for i in 0..<args.len:
        let arg = args[i]
        if arg == key && i + 1 < args.len:
            return args[i + 1]
        if BackendDriverStartsWith(arg, strutil.Join([key, ":"], "")):
            return strings.SliceBytes(arg, len(key) + 1, len(arg) - len(key) - 1)
        if BackendDriverStartsWith(arg, strutil.Join([key, "="], "")):
            return strings.SliceBytes(arg, len(key) + 1, len(arg) - len(key) - 1)
    return defaultValue

fn BackendDriverEgraphActiveContractReport(): str =
    return econtract.CompilerCsgEgraphActiveContractReport()

fn BackendDriverVerifyBackendEgraphCost(rootDir: str,
                                         args: str[]): int32 =
    let report = BackendDriverEgraphActiveContractReport()
    let reportPath = BackendDriverReadFlag(args, "--report-out", "")
    if !BackendDriverWriteOptionalReport(rootDir, reportPath, report):
        BackendDriverPrintErr(strutil.Join(["backend driver verify-backend-egraph-cost: failed to write report: ", reportPath], ""))
        return econtract.CompilerCsgUirEgraphUnavailableExitCode()
    BackendDriverPrintErr(report)
    return econtract.CompilerCsgUirEgraphUnavailableExitCode()

fn BackendDriverPrintBuildPlan(rootDir: str,
                                 args: str[]) =
    let target = strutil.Strip(BackendDriverReadFlag(args, "--target", ""))
    if len(target) > 0:
        let plan: buildplan.BackendBuildPlan = buildplan.BackendBuildPlanBackendDriverForTarget(rootDir, target)
        BackendDriverPrintLine(strutil.Strip(buildplan.BackendBuildPlanReport(plan)))
        return
    let plan: buildplan.BackendBuildPlan = buildplan.BackendBuildPlanBackendDriver(rootDir)
    BackendDriverPrintLine(strutil.Strip(buildplan.BackendBuildPlanReport(plan)))

fn BackendDriverPrintBootstrap(rootDir: str) =
    let snapshot: contracts.BootstrapSnapshot = contracts.BootstrapSnapshotDefault(rootDir)
    BackendDriverPrintLine(strutil.Strip(contracts.BootstrapSnapshotReport(snapshot)))

fn BackendDriverScanHotpath(rootDir: str): int32 =
    return BackendDriverForward(rootDir, "scan-hotpath", [])

fn BackendDriverRunSmokes(rootDir: str): int32 =
    let stage1Source = contracts.BootstrapStage1SourcePath(rootDir)
    if !chengpath.FileExistsNonEmpty(rootDir, stage1Source):
        BackendDriverPrintErr(strutil.Join(["backend driver run-smokes: missing stage1 source: ", stage1Source], ""))
        return 1
    let logDir = chengpath.PathAbsolute(rootDir, "artifacts/gate")
    if !chengpath.MkdirP(rootDir, logDir):
        BackendDriverPrintErr(strutil.Join(["backend driver run-smokes: mkdir failed: ", logDir], ""))
        return 1
    var names: str[]
    add(names, "cheng.stage0")
    add(names, "cheng.stage1")
    add(names, "cheng.stage2")
    add(names, "cheng.stage3")
    var bins: str[]
    add(bins, contracts.BootstrapStage0Path(rootDir))
    add(bins, contracts.BootstrapStage1Path(rootDir))
    add(bins, contracts.BootstrapStage2Path(rootDir))
    add(bins, contracts.BootstrapStage3Path(rootDir))
    for i in 0..<bins.len:
        let bin = bins[i]
        if !chengpath.FileExistsNonEmpty(rootDir, bin):
            BackendDriverPrintErr(strutil.Join(["backend driver run-smokes: missing bootstrap compiler: ", bin], ""))
            return 1
        let logPath = os.JoinPath(logDir, strutil.Join([names[i], ".self-check.log"], ""))
        var args: str[]
        add(args, "self-check")
        add(args, strutil.Join(["--in:", stage1Source], ""))
        let run = hostops.RunFileLogged(rootDir,
                                          strutil.Join(["backend_driver_run_smokes_", names[i]], ""),
                                          bin,
                                          args,
                                          [],
                                          rootDir,
                                          120,
                                          logPath)
        if !hostops.LoggedRunOk(run):
            let outputText = strutil.Strip(run.output)
            if len(outputText) > 0:
                BackendDriverPrintErr(outputText)
            return run.exitCode
    return 0

fn BackendDriverCollectHostSmokeNames(args: str[]): str[] =
    var out: str[]
    var skipNext = false
    for i in 0..<args.len:
        if skipNext:
            skipNext = false
            continue
        let arg = args[i]
        if arg == "--compiler" || arg == "--label" || arg == "--tail-only":
            skipNext = true
        elif BackendDriverStartsWith(arg, "--compiler:") ||
             BackendDriverStartsWith(arg, "--compiler=") ||
             BackendDriverStartsWith(arg, "--label:") ||
             BackendDriverStartsWith(arg, "--label=") ||
             BackendDriverStartsWith(arg, "--tail-only:") ||
             BackendDriverStartsWith(arg, "--tail-only="):
            skipNext = false
        elif len(arg) > 0 && arg[0] == '-':
            skipNext = false
        else:
            add(out, arg)
    return out

fn BackendDriverParamStr(i: int32): str =
    let raw = BackendDriverParamStrRawBridge(i)
    if raw == nil:
        return ""
    return system.StrFromCStringBorrow(raw)

fn BackendDriverHostSmokeCompiler(rootDir: str, args: str[]): str =
    var compiler = strutil.Strip(BackendDriverReadFlag(args, "--compiler", ""))
    if len(compiler) <= 0:
        compiler = strutil.Strip(os.GetEnvDefault("CHENG_SMOKE_COMPILER", ""))
    if len(compiler) <= 0:
        compiler = "artifacts/backend_driver/cheng"
    return chengpath.PathAbsolute(rootDir, compiler)

fn BackendDriverHostSmokeLabel(args: str[]): str =
    let explicit = strutil.Strip(BackendDriverReadFlag(args, "--label", ""))
    if len(explicit) > 0:
        return explicit
    let envLabel = strutil.Strip(os.GetEnvDefault("CHENG_SMOKE_LABEL", ""))
    if len(envLabel) > 0:
        return envLabel
    return "host"

fn BackendDriverHostSmokeRunTimeoutSec(smokeName: str): int32 =
    if smokeName == "runtime_zero_c_surface_smoke":
        return 600
    if smokeName == "backend_driver_command_surface_smoke":
        return 420
    if BackendDriverStartsWith(smokeName, "r2c_react_"):
        return 420
    if smokeName == "compiler_world_fresh_node_selfhost_smoke":
        return 420
    if smokeName == "perf_memory_contract_smoke":
        return 600
    return 120

fn BackendDriverHostSmokeCompileEnv(): str[] =
    var out: str[]
    add(out, "BACKEND_INCREMENTAL=0")
    add(out, "BACKEND_MULTI_MODULE_CACHE=0")
    add(out, "CHENG_DISABLE_PRIMARY_OBJECT_CACHE=1")
    add(out, "BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0")
    add(out, "BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0")
    add(out, "CHENG_PROGRESS=1")
    add(out, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")
    add(out, "CHENG_COMPILE_TIMEOUT_SEC=420")
    return out

fn BackendDriverRemovePrefixedFiles(dir: str,
                                      prefix: str) =
    let names: str[] = os.ListDir(dir)
    for i in 0..<names.len:
        let name: str = names[i]
        if BackendDriverStartsWith(name, prefix):
            let path: str = os.JoinPath(dir, name)
            if chengpath.PathFileExists(path):
                os.RemoveFile(path)

fn BackendDriverHostSmokeRunEnv(smokeName: str,
                                  r2cControllerExe: str): str[] =
    var out: str[]
    if BackendDriverStartsWith(smokeName, "r2c_react_"):
        add(out, "CHENG_PROGRESS=1")
        add(out, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")
        add(out, "CHENG_COMPILE_TIMEOUT_SEC=420")
        if len(r2cControllerExe) > 0:
            add(out, strutil.Join(["R2C_REACT_CONTROLLER_EXE=", r2cControllerExe], ""))
        else:
            add(out, "R2C_REACT_ALLOW_CONTROLLER_COMPILE=1")
    return out

fn BackendDriverCompileR2cReactController(rootDir: str,
                                           compilerPath: str,
                                           outDir: str): str =
    let controllerSource = chengpath.PathAbsolute(rootDir, "src/r2c/r2c_react.cheng")
    let controllerExe = os.JoinPath(outDir, "r2c_react_controller_shared")
    let controllerCompileLog = strutil.Join([controllerExe, ".compile.log"], "")
    let controllerCompileReport = strutil.Join([controllerExe, ".report.txt"], "")
    BackendDriverRemovePrefixedFiles(outDir, "r2c_react_controller_shared")
    if chengpath.PathFileExists(controllerExe):
        os.RemoveFile(controllerExe)
    if chengpath.PathFileExists(strutil.Join([controllerExe, ".map"], "")):
        os.RemoveFile(strutil.Join([controllerExe, ".map"], ""))
    if chengpath.PathFileExists(controllerCompileLog):
        os.RemoveFile(controllerCompileLog)
    if chengpath.PathFileExists(controllerCompileReport):
        os.RemoveFile(controllerCompileReport)
    var controllerCompileArgs: str[]
    add(controllerCompileArgs, "system-link-exec")
    add(controllerCompileArgs, strutil.Join(["--root:", rootDir], ""))
    add(controllerCompileArgs, strutil.Join(["--in:", controllerSource], ""))
    add(controllerCompileArgs, "--emit:exe")
    add(controllerCompileArgs, "--target:arm64-apple-darwin")
    add(controllerCompileArgs, strutil.Join(["--out:", controllerExe], ""))
    add(controllerCompileArgs, strutil.Join(["--report-out:", controllerCompileReport], ""))
    let controllerCompileRun = hostops.RunFileLogged(rootDir,
                                                       "backend_driver_r2c_controller_shared_compile",
                                                       compilerPath,
                                                       controllerCompileArgs,
                                                       BackendDriverHostSmokeCompileEnv(),
                                                       rootDir,
                                                       420,
                                                       controllerCompileLog)
    if !hostops.LoggedRunOk(controllerCompileRun):
        let outputText = strutil.Strip(controllerCompileRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return ""
    if !chengpath.FileExistsNonEmpty(rootDir, controllerExe):
        BackendDriverPrintErr(strutil.Join(["backend driver r2c controller: compile missing output: ", controllerExe], ""))
        return ""
    if !chengpath.FileExistsNonEmpty(rootDir, controllerCompileReport):
        BackendDriverPrintErr(strutil.Join(["backend driver r2c controller: compile missing report: ", controllerCompileReport], ""))
        return ""
    return controllerExe

fn BackendDriverResolveR2cReactController(rootDir: str,
                                           compilerPath: str,
                                           outDir: str): str =
    let explicitRaw = strutil.Strip(os.GetEnv("R2C_REACT_CONTROLLER_EXE"))
    if len(explicitRaw) > 0:
        let explicitPath = chengpath.PathAbsolute(rootDir, explicitRaw)
        if !chengpath.FileExistsNonEmpty(rootDir, explicitPath):
            BackendDriverPrintErr(strutil.Join(["backend driver r2c controller: missing R2C_REACT_CONTROLLER_EXE: ", explicitPath], ""))
            return ""
        return explicitPath
    return BackendDriverCompileR2cReactController(rootDir, compilerPath, outDir)

fn BackendDriverHostSmokesNeedR2cController(tests: str[]): bool =
    for i in 0..<tests.len:
        if BackendDriverStartsWith(tests[i], "r2c_react_"):
            return true
    return false

fn BackendDriverExpectContains(label: str,
                                text: str,
                                needle: str): bool =
    if strings.StrContains(text, needle):
        return true
    BackendDriverPrintErr(strutil.Join([label, ": missing marker: ", needle], ""))
    return false

fn BackendDriverExpectNotContains(label: str,
                                   text: str,
                                   needle: str): bool =
    if !strings.StrContains(text, needle):
        return true
    BackendDriverPrintErr(strutil.Join([label, ": forbidden marker: ", needle], ""))
    return false

fn BackendDriverAssertNoSeedHiddenSurface(label: str,
                                           text: str): bool =
    let hiddenCommand = strutil.Join(["__seed-system", "-link-exec"], "")
    let hiddenEnv = strutil.Join(["CHENG_SEED_INTERNAL", "_SYSTEM_LINK_EXEC"], "")
    if !BackendDriverExpectNotContains(label, text, hiddenCommand):
        return false
    if !BackendDriverExpectNotContains(label, text, hiddenEnv):
        return false
    return true

fn BackendDriverRemoveFileIfPresent(path: str) =
    if chengpath.PathFileExists(path):
        os.RemoveFile(path)

fn BackendDriverRunDirectObjectWriterSmoke(rootDir: str,
                                            compilerPath: str,
                                            outDir: str,
                                            label: str): int32 =
    let src = chengpath.PathAbsolute(rootDir, "src/tests/ordinary_zero_exit_fixture.cheng")
    let outBin = os.JoinPath(outDir, "direct_object_writer_smoke")
    let reportPath = strutil.Join([outBin, ".report.txt"], "")
    let compileLog = strutil.Join([outBin, ".compile.log"], "")
    let runLog = strutil.Join([outBin, ".run.log"], "")
    BackendDriverRemoveFileIfPresent(outBin)
    BackendDriverRemoveFileIfPresent(strutil.Join([outBin, ".map"], ""))
    BackendDriverRemoveFileIfPresent(reportPath)
    BackendDriverRemoveFileIfPresent(compileLog)
    BackendDriverRemoveFileIfPresent(runLog)
    var compileArgs: str[]
    add(compileArgs, "system-link-exec")
    add(compileArgs, strutil.Join(["--root:", rootDir], ""))
    add(compileArgs, strutil.Join(["--in:", src], ""))
    add(compileArgs, "--emit:exe")
    add(compileArgs, "--target:arm64-apple-darwin")
    add(compileArgs, strutil.Join(["--out:", outBin], ""))
    add(compileArgs, strutil.Join(["--report-out:", reportPath], ""))
    var compileEnv = BackendDriverHostSmokeCompileEnv()
    add(compileEnv, "CHENG_REQUIRE_PURE_SYSTEM_LINK_EXEC=1")
    let compileRun = hostops.RunFileLogged(rootDir,
                                             strutil.Join(["backend_driver_direct_object_writer_compile_", label], ""),
                                             compilerPath,
                                             compileArgs,
                                             compileEnv,
                                             rootDir,
                                             420,
                                             compileLog)
    if !hostops.LoggedRunOk(compileRun):
        let outputText = strutil.Strip(compileRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return compileRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, outBin):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing exe: ", outBin], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, reportPath):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing report: ", reportPath], ""))
        return 1
    let reportText = chengpath.ReadTextFile("", reportPath)
    if !BackendDriverExpectContains("direct object writer smoke", reportText, "system_link_exec_runtime_execute=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer smoke", reportText, "system_link_exec_runtime_standalone_no_runtime=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer smoke", reportText, "system_link_exec_runtime_standalone_direct_entry=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer smoke", reportText, "primary_object_direct=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer smoke", reportText, "direct_object_bytes="):
        return 1
    if !BackendDriverExpectContains("direct object writer smoke", reportText, "direct_object_reloc_count=0"):
        return 1
    let f64Src = chengpath.PathAbsolute(rootDir, "src/tests/float64_mul_direct_object_smoke.cheng")
    let f64Obj = os.JoinPath(outDir, "float64_mul_direct_object_smoke.o")
    let f64Report = strutil.Join([f64Obj, ".report.txt"], "")
    let f64CompileLog = strutil.Join([f64Obj, ".host.log"], "")
    let f64Asm = strutil.Join([f64Obj, ".s"], "")
    let f64ObjectCompileLog = strutil.Join([f64Obj, ".compile.log"], "")
    let f64OtoolLog = strutil.Join([f64Obj, ".otool.log"], "")
    BackendDriverRemoveFileIfPresent(f64Obj)
    BackendDriverRemoveFileIfPresent(f64Report)
    BackendDriverRemoveFileIfPresent(f64CompileLog)
    BackendDriverRemoveFileIfPresent(f64Asm)
    BackendDriverRemoveFileIfPresent(f64ObjectCompileLog)
    BackendDriverRemoveFileIfPresent(f64OtoolLog)
    var f64CompileArgs: str[]
    add(f64CompileArgs, "system-link-exec")
    add(f64CompileArgs, strutil.Join(["--root:", rootDir], ""))
    add(f64CompileArgs, strutil.Join(["--in:", f64Src], ""))
    add(f64CompileArgs, "--emit:obj")
    add(f64CompileArgs, "--target:arm64-apple-darwin")
    add(f64CompileArgs, strutil.Join(["--out:", f64Obj], ""))
    add(f64CompileArgs, strutil.Join(["--report-out:", f64Report], ""))
    let f64CompileRun = hostops.RunFileLogged(rootDir,
                                               strutil.Join(["backend_driver_direct_object_f64_compile_", label], ""),
                                               compilerPath,
                                               f64CompileArgs,
                                               compileEnv,
                                               rootDir,
                                               420,
                                               f64CompileLog)
    if !hostops.LoggedRunOk(f64CompileRun):
        let outputText = strutil.Strip(f64CompileRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return f64CompileRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, f64Obj):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing f64 object: ", f64Obj], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, f64Report):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing f64 report: ", f64Report], ""))
        return 1
    if chengpath.PathFileExists(f64Asm):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: unexpected f64 asm: ", f64Asm], ""))
        return 1
    if chengpath.PathFileExists(f64ObjectCompileLog):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: unexpected f64 asm compile log: ", f64ObjectCompileLog], ""))
        return 1
    let f64ReportText = chengpath.ReadTextFile("", f64Report)
    if !BackendDriverExpectContains("direct object writer f64 smoke", f64ReportText, "system_link_exec_runtime_execute=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer f64 smoke", f64ReportText, "typed_return_op_count=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer f64 smoke", f64ReportText, "typed_return_op_kinds=f64_mul_args"):
        return 1
    if !BackendDriverExpectContains("direct object writer f64 smoke", f64ReportText, "typed_ir_return_kinds=f64_mul"):
        return 1
    if !BackendDriverExpectContains("direct object writer f64 smoke", f64ReportText, "primary_object_ir_body_kinds=return_f64_mul_args"):
        return 1
    if !BackendDriverExpectContains("direct object writer f64 smoke", f64ReportText, "primary_object_body_kinds=return_f64_mul_args"):
        return 1
    if !BackendDriverExpectContains("direct object writer f64 smoke", f64ReportText, "primary_object_direct=1"):
        return 1
    if !BackendDriverExpectContains("direct object writer f64 smoke", f64ReportText, "direct_object_reloc_count=0"):
        return 1
    let f64OtoolRun = hostops.RunProgramLogged(rootDir,
                                               strutil.Join(["backend_driver_direct_object_f64_otool_", label], ""),
                                               "otool",
                                               ["-tV", f64Obj],
                                               [],
                                               rootDir,
                                               30,
                                               f64OtoolLog)
    if f64OtoolRun.exitCode != 0:
        BackendDriverPrintErr("direct object writer smoke: f64 otool failed")
        return f64OtoolRun.exitCode
    if !BackendDriverExpectContains("direct object writer f64 otool", f64OtoolRun.output, "fmul"):
        return 1
    if !BackendDriverExpectContains("direct object writer f64 otool", f64OtoolRun.output, "d0, d0, d1"):
        return 1
    let i32AddSrc = chengpath.PathAbsolute(rootDir, "src/tests/int32_add_direct_object_smoke.cheng")
    let i32AddObj = os.JoinPath(outDir, "int32_add_direct_object_smoke.o")
    let i32AddReport = strutil.Join([i32AddObj, ".report.txt"], "")
    let i32AddCompileLog = strutil.Join([i32AddObj, ".host.log"], "")
    let i32AddAsm = strutil.Join([i32AddObj, ".s"], "")
    let i32AddObjectCompileLog = strutil.Join([i32AddObj, ".compile.log"], "")
    let i32AddOtoolLog = strutil.Join([i32AddObj, ".otool.log"], "")
    BackendDriverRemoveFileIfPresent(i32AddObj)
    BackendDriverRemoveFileIfPresent(i32AddReport)
    BackendDriverRemoveFileIfPresent(i32AddCompileLog)
    BackendDriverRemoveFileIfPresent(i32AddAsm)
    BackendDriverRemoveFileIfPresent(i32AddObjectCompileLog)
    BackendDriverRemoveFileIfPresent(i32AddOtoolLog)
    var i32AddCompileArgs: str[]
    add(i32AddCompileArgs, "system-link-exec")
    add(i32AddCompileArgs, strutil.Join(["--root:", rootDir], ""))
    add(i32AddCompileArgs, strutil.Join(["--in:", i32AddSrc], ""))
    add(i32AddCompileArgs, "--emit:obj")
    add(i32AddCompileArgs, "--target:arm64-apple-darwin")
    add(i32AddCompileArgs, strutil.Join(["--out:", i32AddObj], ""))
    add(i32AddCompileArgs, strutil.Join(["--report-out:", i32AddReport], ""))
    let i32AddCompileRun = hostops.RunFileLogged(rootDir,
                                                  strutil.Join(["backend_driver_direct_object_i32_add_compile_", label], ""),
                                                  compilerPath,
                                                  i32AddCompileArgs,
                                                  compileEnv,
                                                  rootDir,
                                                  420,
                                                  i32AddCompileLog)
    if !hostops.LoggedRunOk(i32AddCompileRun):
        let outputText = strutil.Strip(i32AddCompileRun.output)
        if len(outputText) > 0:
            BackendDriverPrintErr(outputText)
        return i32AddCompileRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, i32AddObj):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing i32 add object: ", i32AddObj], ""))
        return 1
    if !chengpath.FileExistsNonEmpty(rootDir, i32AddReport):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: missing i32 add report: ", i32AddReport], ""))
        return 1
    if chengpath.PathFileExists(i32AddAsm):
        BackendDriverPrintErr(strutil.Join(["direct object writer smoke: unexpected i32 add asm: ", i32AddAsm], ""))
