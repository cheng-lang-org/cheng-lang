type
    BftThreeNodeDeploy =
        appId: str
        serverSsh: str
        relaySsh: str
        serverAddress: str
        serverRepoRoot: str
        relayRepoRoot: str
        localDeployDir: str
        remoteDeployRel: str
        proposalPort: int32
        commitPort: int32
        votePort: int32
        statePort: int32
        proposerIntervalMs: int32
        followerIntervalMs: int32
        proposalWindowMs: int32
        voteWindowMs: int32
        commitWindowMs: int32
        defaultMaxTxs: int32
        assetId: int32
        aliceId: int32
        bobId: int32
        mintAmount: int64
        transferAmount: int64

    BftNodeStatus =
        name: str
        summary: str
        aliceQuery: str
        bobQuery: str
        height: str
        appHash: str
        aliceBalance: str
        bobBalance: str

fn GatePrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn GatePrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn GatePrintKv(prefix: str, value: str) =
    GatePrintLine(strutil.Join([prefix, value], ""))

fn GateReadFlag(args: str[], key: str, defaultValue: str): str =
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.StartsWith(arg, strutil.Join([key, ":"], "")):
            return strings.DropPrefix(arg, strutil.Join([key, ":"], ""))
        if strutil.StartsWith(arg, strutil.Join([key, "="], "")):
            return strings.DropPrefix(arg, strutil.Join([key, "="], ""))
    return defaultValue

fn GateRunFailed(run: hostops.LoggedRun): bool =
    if hostops.LoggedRunOk(run):
        return false
    GatePrintErr(hostops.LoggedRunSummary(run))
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        GatePrintErr(outputText)
    return true

fn GateMaybePrintRunOutput(run: hostops.LoggedRun) =
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        GatePrintLine(outputText)

fn GateShellArgv(args: str[]): str =
    var out = ""
    for i in 0..<args.len:
        if i > 0:
            out = strutil.Join([out, " "], "")
        out = strutil.Join([out, os.QuoteShell(args[i])], "")
    return out

fn GateTextValue(text: str, key: str): str =
    let prefix = strutil.Join([key, "="], "")
    var start = 0
    while start < len(text):
        var end = start
        while end < len(text):
            if text[end] == '\n':
                break
            if text[end] == '\r':
                break
            end = end + 1
        let line = chengpath.TextSlice(text, start, end - start)
        if chengpath.TextStartsWith(line, prefix):
            return chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
        start = end + 1
        for start in start..<len(text):
            if text[start] != '\n':
                if text[start] != '\r':
                    break
    return ""

fn GateRunShellLogged(root: str,
                        label: str,
                        command: str,
                        logPath: str,
                        timeoutSec: int32): hostops.LoggedRun =
    return hostops.RunProgramLogged(root,
                                      label,
                                      "sh",
                                      ["-lc", command],
                                      [],
                                      root,
                                      timeoutSec,
                                      logPath)

fn GateRemoteTransportRetryable(text: str): bool =
    let trimmed = strutil.Strip(text)
    return strutil.Contains(trimmed, "Connection timed out during banner exchange") ||
           (strutil.Contains(trimmed, "Connection to ") && strutil.Contains(trimmed, " timed out")) ||
           strutil.Contains(trimmed, "No route to host") ||
           strutil.Contains(trimmed, "Connection reset by peer") ||
           strutil.Contains(trimmed, "kex_exchange_identification") ||
           strutil.Contains(trimmed, "Connection closed by remote host")

fn GateRemoteSshArgv(sshHost: str, remoteCmd: str): str[] =
    return [
        "-n",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=20",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=3",
        sshHost,
        remoteCmd
    ]

fn GateRemoteScriptSafeToken(text: str): str =
    if len(text) == 0:
        return "x"
    var out = ""
    for i in 0..<len(text):
        let part = strings.SliceBytes(text, i, 1)
        let ch = part[0]
        if (ch >= 'a' && ch <= 'z') ||
           (ch >= 'A' && ch <= 'Z') ||
           (ch >= '0' && ch <= '9'):
            out = strutil.Join([out, part], "")
        else:
            out = strutil.Join([out, "_"], "")
    if len(out) == 0:
        return "x"
    return out

fn GateRemoteScriptLocalPath(root: str, logPath: str): str =
    let localPath = chengpath.PathAbsolute(root, strutil.Join([logPath, ".remote.sh"], ""))
    let _ = chengpath.MkdirP(root, chengpath.PathParentDir(localPath))
    return localPath

fn GateRemoteScriptPath(label: str): str =
    return strutil.Join(["/tmp/cheng_gate_", GateRemoteScriptSafeToken(label), ".sh"], "")

fn GateRemoteScpArgv(sshHost: str, localPath: str, remotePath: str): str[] =
    return [
        "-q",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=20",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=3",
        localPath,
        strutil.Join([sshHost, ":", remotePath], "")
    ]

fn GateRunRemoteShellLogged(root: str,
                              label: str,
                              sshHost: str,
                              command: str,
                              logPath: str,
                              timeoutSec: int32): hostops.LoggedRun =
    let localScript = GateRemoteScriptLocalPath(root, logPath)
    let scriptText = strutil.Join(["#!/bin/sh\n", command, "\n"], "")
    if !chengpath.WriteTextFile(root, localScript, scriptText):
        return hostops.LoggedRunZero(label,
                                       "ssh",
                                       chengpath.PathAbsolute(root, logPath),
                                       1,
                                       strutil.Join([" gate: remote script write failed: ", localScript, "\n"], ""))
    var lastRun = hostops.LoggedRunZero(label, "ssh", logPath, 255, "")
    for attempt in 0..<3:
        let run = hostops.RunProgramLoggedWithInputText(root,
                                                          label,
                                                          "ssh",
                                                          [
                                                              "-T",
                                                              "-o", "BatchMode=yes",
                                                              "-o", "ConnectTimeout=20",
                                                              "-o", "ServerAliveInterval=5",
                                                              "-o", "ServerAliveCountMax=3",
                                                              sshHost,
                                                              "sh"
                                                          ],
                                                          [],
                                                          root,
                                                          timeoutSec,
                                                          logPath,
                                                          scriptText)
        lastRun = run
        if !GateRunFailed(run):
            return run
        if attempt >= 2 || !GateRemoteTransportRetryable(run.output):
            return run
        GatePrintLine(strutil.Join(["[ gate] remote ssh retry ", IntToStr(attempt + 1), " ", label], ""))
        os.SleepMs((attempt + 1) * 1000)
    return lastRun

fn GateShellCheckOk(root: str, command: str): bool =
    let run = hostops.RunProgramLogged(root,
                                         "gate_shell_check",
                                         "sh",
                                         ["-lc", command],
                                         [],
                                         root,
                                         7,
                                         "/tmp/cheng_gate_shell_check.log")
    return hostops.LoggedRunOk(run)

fn GateBftBuildReady(root: str,
                       compiler: str,
                       src: str,
                       outBin: str,
                       runLog: str,
                       runSelfTest: str): bool =
    if !os.FileExists(outBin):
        return false
    var command = strutil.Join(["test -x ", os.QuoteShell(outBin), " && test ", os.QuoteShell(compiler), " -ot ", os.QuoteShell(outBin), " && test ", os.QuoteShell(src), " -ot ", os.QuoteShell(outBin)], "")
    if runSelfTest != "0":
        if !os.FileExists(runLog):
            return false
        command = strutil.Join([command, " && test ", os.QuoteShell(outBin), " -ot ", os.QuoteShell(runLog), " && test ", os.QuoteShell(compiler), " -ot ", os.QuoteShell(runLog), " && test ", os.QuoteShell(src), " -ot ", os.QuoteShell(runLog), " && grep -q ", os.QuoteShell(" bft_state_machine self-test ok"), " ", os.QuoteShell(runLog)], "")
    return GateShellCheckOk(root, command)

