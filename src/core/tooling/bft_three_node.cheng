fn GateBftServerProposerShell(binPath: str,
                                cfg: BftThreeNodeDeploy,
                                serverDir: str,
                                maxTxsOverride: int32,
                                pidPath: str,
                                logPath: str,
                                readyPath: str,
                                useSetsid: bool): str =
    var args: str[]
    add(args, "validator-proposer-daemon")
    add(args, strutil.Join(["--state:", os.JoinPath(serverDir, "server.state")], ""))
    add(args, strutil.Join(["--queue:", os.JoinPath(serverDir, "server.queue")], ""))
    add(args, "--proposal-host:0.0.0.0")
    add(args, strutil.Join(["--proposal-port:", IntToStr(cfg.proposalPort)], ""))
    add(args, "--vote-host:0.0.0.0")
    add(args, strutil.Join(["--vote-port:", IntToStr(cfg.votePort)], ""))
    add(args, "--commit-host:0.0.0.0")
    add(args, strutil.Join(["--commit-port:", IntToStr(cfg.commitPort)], ""))
    add(args, strutil.Join(["--proposal-file:", os.JoinPath(serverDir, "server.proposal.hex")], ""))
    add(args, strutil.Join(["--commit-file:", os.JoinPath(serverDir, "server.commit.hex")], ""))
    add(args, strutil.Join(["--state-sync-file:", os.JoinPath(serverDir, "server.machine.hex")], ""))
    add(args, strutil.Join(["--proposal-ready-path:", os.JoinPath(serverDir, "server.proposal.ready")], ""))
    add(args, strutil.Join(["--vote-ready-path:", os.JoinPath(serverDir, "server.vote.ready")], ""))
    add(args, strutil.Join(["--commit-ready-path:", os.JoinPath(serverDir, "server.commit.ready")], ""))
    add(args, strutil.Join(["--interval-ms:", IntToStr(cfg.proposerIntervalMs)], ""))
    add(args, strutil.Join(["--proposal-window-ms:", IntToStr(cfg.proposalWindowMs)], ""))
    add(args, strutil.Join(["--vote-window-ms:", IntToStr(cfg.voteWindowMs)], ""))
    add(args, strutil.Join(["--commit-window-ms:", IntToStr(cfg.commitWindowMs)], ""))
    add(args, strutil.Join(["--max-txs:", IntToStr(GateBftDaemonMaxTxs(cfg, maxTxsOverride))], ""))
    return GateBftStartDetachedShell(binPath, args, pidPath, logPath, readyPath, useSetsid)

