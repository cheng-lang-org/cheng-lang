    add(args, strutil.Join(["--sync-port:", IntToStr(cfg.statePort)], ""))
    add(args, strutil.Join(["--interval-ms:", IntToStr(cfg.followerIntervalMs)], ""))
    return GateBftStartDetachedShell(binPath, args, pidPath, logPath, "", useSetsid)

fn GateBftServerInitShell(serverDir: str,
                            initCommand: str): str =
    let proposalReady = os.JoinPath(serverDir, "server.proposal.ready")
    let commitReady = os.JoinPath(serverDir, "server.commit.ready")
    let voteReady = os.JoinPath(serverDir, "server.vote.ready")
    let stateReady = os.JoinPath(serverDir, "server.state.ready")
    let voteLock = os.JoinPath(serverDir, "server.state.vote_lock")
    let queueCursor = os.JoinPath(serverDir, "server.queue.cursor")
    let machineHex = os.JoinPath(serverDir, "server.machine.hex")
    let statePid = os.JoinPath(serverDir, "server_state.pid")
    let snapshotDir = os.JoinPath(serverDir, "server.machine.hex.snapshots")
    let queuePath = os.JoinPath(serverDir, "server.queue")
    let proposalHex = os.JoinPath(serverDir, "server.proposal.hex")
    let commitHex = os.JoinPath(serverDir, "server.commit.hex")
    let votesPath = os.JoinPath(serverDir, "server.votes")
    var out = strutil.Join(["set -eu && mkdir -p ", os.QuoteShell(serverDir)], "")
    out = strutil.Join([out, " && rm -f ", os.QuoteShell(proposalReady)], "")
    out = strutil.Join([out, " ", os.QuoteShell(commitReady)], "")
    out = strutil.Join([out, " ", os.QuoteShell(voteReady)], "")
    out = strutil.Join([out, " ", os.QuoteShell(stateReady)], "")
    out = strutil.Join([out, " ", os.QuoteShell(voteLock)], "")
    out = strutil.Join([out, " ", os.QuoteShell(queueCursor)], "")
    out = strutil.Join([out, " ", os.QuoteShell(machineHex)], "")
    out = strutil.Join([out, " ", os.QuoteShell(statePid)], "")
    out = strutil.Join([out, " && rm -rf ", os.QuoteShell(snapshotDir)], "")
    out = strutil.Join([out, " && : > ", os.QuoteShell(queuePath)], "")
    out = strutil.Join([out, " && : > ", os.QuoteShell(proposalHex)], "")
    out = strutil.Join([out, " && : > ", os.QuoteShell(commitHex)], "")
    out = strutil.Join([out, " && : > ", os.QuoteShell(votesPath)], "")
    out = strutil.Join([out, " && ", initCommand], "")
    return out

fn GateBftBenchStartServer(root: str,
                             cfg: BftThreeNodeDeploy,
                             serverDir: str,
                             serverBin: str,
                             localBin: str,
                             maxTxsOverride: int32,
                             logPrefix: str): int32 =
    let proposerShell = GateBftServerProposerShell(serverBin,
                                                     cfg,
                                                     serverDir,
                                                     maxTxsOverride,
                                                     os.JoinPath(serverDir, "server_proposer.pid"),
                                                     os.JoinPath(serverDir, "server.proposer.log"),
                                                     os.JoinPath(serverDir, "server.proposal.ready"),
                                                     true)
    let proposerRun = GateRunRemoteShellLogged(root,
                                                 "bft_bench_start_server_proposer",
                                                 cfg.serverSsh,
                                                 proposerShell,
                                                 strutil.Join([logPrefix, ".server_proposer.log"], ""),
                                                 30)
    if GateRunFailed(proposerRun):
        return proposerRun.exitCode
    let stateShell = GateBftServerStateShell(serverBin,
                                               cfg,
                                               serverDir,
                                               os.JoinPath(serverDir, "server_state.pid"),
                                               os.JoinPath(serverDir, "server.state.log"),
                                               true)
    let stateRun = GateRunRemoteShellLogged(root,
                                              "bft_bench_start_server_state",
                                              cfg.serverSsh,
                                              stateShell,
                                              strutil.Join([logPrefix, ".server_state.log"], ""),
                                              30)
    if GateRunFailed(stateRun):
        return stateRun.exitCode
    let probeCommand = GateBftProbeProposalCommand(localBin,
                                                     cfg.serverAddress,
                                                     cfg.proposalPort)
    let probeRun = GateRunShellLogged(root,
                                        "bft_bench_probe_server_proposal",
                                        probeCommand,
                                        strutil.Join([logPrefix, ".server_probe.log"], ""),
                                        30)
    if GateRunFailed(probeRun):
        return probeRun.exitCode
    return 0

fn GateBftBenchStartRelay(root: str,
                            cfg: BftThreeNodeDeploy,
                            relayDir: str,
                            relayBin: str,
                            logPrefix: str): int32 =
    let relayShell = GateBftFollowerShell(relayBin,
                                            cfg,
                                            os.JoinPath(relayDir, "relay.state"),
                                            os.JoinPath(relayDir, "relay_follower.pid"),
                                            os.JoinPath(relayDir, "relay.follower.log"),
                                            true)
    let relayRun = GateRunRemoteShellLogged(root,
                                              "bft_bench_start_relay_follower",
                                              cfg.relaySsh,
                                              relayShell,
                                              strutil.Join([logPrefix, ".relay_start.log"], ""),
                                              30)
    if GateRunFailed(relayRun):
        return relayRun.exitCode
    return 0

fn GateBftBenchStartLocal(root: str,
                            cfg: BftThreeNodeDeploy,
                            localDir: str,
                            localBin: str,
                            logPrefix: str): int32 =
    let localShell = GateBftFollowerShell(localBin,
                                            cfg,
                                            os.JoinPath(localDir, "local.state"),
                                            os.JoinPath(localDir, "local_follower.pid"),
                                            os.JoinPath(localDir, "local.follower.log"),
                                            false)
    let localRun = GateRunShellLogged(root,
                                        "bft_bench_start_local_follower",
                                        localShell,
                                        strutil.Join([logPrefix, ".local_start.log"], ""),
                                        30)
    if GateRunFailed(localRun):
        return localRun.exitCode
    return 0

fn GateBftBenchRestartNode(root: str,
                             cfg: BftThreeNodeDeploy,
                             serverDir: str,
                             relayDir: str,
                             localDir: str,
                             serverBin: str,
                             relayBin: str,
                             localBin: str,
                             restartNode: str,
                             maxTxsOverride: int32,
                             restartPauseMs: int32,
                             logPrefix: str): int32 =
    if restartNode == "none":
        return 0
    if restartNode == "server":
        let stopRun = GateRunRemoteShellLogged(root,
                                                 "bft_bench_restart_server_stop",
                                                 cfg.serverSsh,
                                                 GateBftStopShell([
                                                     os.JoinPath(serverDir, "server_proposer.pid"),
                                                     os.JoinPath(serverDir, "server_state.pid")
                                                 ], [
                                                     strutil.Join(["[v]alidator-proposer-daemon --state:", os.JoinPath(serverDir, "server.state")], ""),
                                                     strutil.Join(["[s]tate-serve-daemon --file:", os.JoinPath(serverDir, "server.machine.hex")], "")
                                                 ]),
                                                 strutil.Join([logPrefix, ".server_stop.log"], ""),
                                                 30)
        if GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return GateBftBenchStartServer(root,
                                         cfg,
                                         serverDir,
                                         serverBin,
                                         localBin,
                                         maxTxsOverride,
                                         logPrefix)
    if restartNode == "relay":
        let stopRun = GateRunRemoteShellLogged(root,
                                                 "bft_bench_restart_relay_stop",
                                                 cfg.relaySsh,
                                                 GateBftStopShell([os.JoinPath(relayDir, "relay_follower.pid")],
                                                                    [
                                                                        strutil.Join(["[v]alidator-follower-daemon --state:", os.JoinPath(relayDir, "relay.state")], "")
                                                                    ]),
                                                 strutil.Join([logPrefix, ".relay_stop.log"], ""),
                                                 30)
        if GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return GateBftBenchStartRelay(root, cfg, relayDir, relayBin, logPrefix)
    if restartNode == "local":
        let stopRun = GateRunShellLogged(root,
                                           "bft_bench_restart_local_stop",
                                           GateBftStopShell([os.JoinPath(localDir, "local_follower.pid")],
                                                              [
                                                                  strutil.Join(["[v]alidator-follower-daemon --state:", os.JoinPath(localDir, "local.state")], "")
                                                              ]),
                                           strutil.Join([logPrefix, ".local_stop.log"], ""),
                                           30)
        if GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return GateBftBenchStartLocal(root, cfg, localDir, localBin, logPrefix)
    GatePrintErr(strutil.Join([" bft bench: invalid restart node: ", restartNode], ""))
    return 1

fn GateBftBenchReportText(cfg: BftThreeNodeDeploy,
                            txCountPerWave: int64,
                            waveCount: int32,
                            transferAmount: int64,
                            maxTxsPerBlock: int32,
                            restartNode: str,
                            restartWave: int32,
                            restartPauseMs: int32,
                            totalTxCount: int64,
                            txWireBytes: int64,
                            committedBytes: int64,
                            blockCount: int64,
                            elapsedMs: int64,
                            tpsMilli: int64,
                            bytesPerSec: int64,
                            kibPerSecMilli: int64,
                            waveElapsed: int64[],
                            waveTps: int64[],
                            waveBlocks: int64[],
                            waveRestarted: bool[],
                            finalServer: BftNodeStatus,
                            out: var str) =
    out = ""
    out = strutil.Join([out, "version=cheng.bft_three_node_bench.v2\n"], "")
    out = strutil.Join([out, "app_id=", cfg.appId, "\n"], "")
    out = strutil.Join([out, "tx_count_per_wave=", strings.Int64ToStr(txCountPerWave), "\n"], "")
    out = strutil.Join([out, "wave_count=", IntToStr(waveCount), "\n"], "")
    out = strutil.Join([out, "transfer_amount=", strings.Int64ToStr(transferAmount), "\n"], "")
    out = strutil.Join([out, "max_txs_per_block=", IntToStr(maxTxsPerBlock), "\n"], "")
    out = strutil.Join([out, "restart_node=", restartNode, "\n"], "")
    out = strutil.Join([out, "restart_wave=", IntToStr(restartWave), "\n"], "")
    out = strutil.Join([out, "restart_pause_ms=", IntToStr(restartPauseMs), "\n"], "")
    out = strutil.Join([out, "tx_count=", strings.Int64ToStr(totalTxCount), "\n"], "")
    out = strutil.Join([out, "tx_wire_bytes=", strings.Int64ToStr(txWireBytes), "\n"], "")
    out = strutil.Join([out, "committed_bytes=", strings.Int64ToStr(committedBytes), "\n"], "")
    out = strutil.Join([out, "block_count=", strings.Int64ToStr(blockCount), "\n"], "")
    out = strutil.Join([out, "elapsed_ms=", strings.Int64ToStr(elapsedMs), "\n"], "")
    out = strutil.Join([out, "tps=", GateFormatMilli(tpsMilli), "\n"], "")
    out = strutil.Join([out, "throughput_bytes_per_sec=", strings.Int64ToStr(bytesPerSec), "\n"], "")
    out = strutil.Join([out, "throughput_kib_per_sec=", GateFormatMilli(kibPerSecMilli), "\n"], "")
    out = strutil.Join([out, "final_height=", finalServer.height, "\n"], "")
    out = strutil.Join([out, "app_hash=", finalServer.appHash, "\n"], "")
    out = strutil.Join([out, "alice_balance=", finalServer.aliceBalance, "\n"], "")
    out = strutil.Join([out, "bob_balance=", finalServer.bobBalance, "\n"], "")
    for i in 0..<waveElapsed.len:
        let waveIndex = IntToStr(i + 1)
        out = strutil.Join([out, "wave_", waveIndex, "_elapsed_ms=", strings.Int64ToStr(waveElapsed[i]), "\n"], "")
        out = strutil.Join([out, "wave_", waveIndex, "_tps=", GateFormatMilli(waveTps[i]), "\n"], "")
        out = strutil.Join([out, "wave_", waveIndex, "_block_count=", strings.Int64ToStr(waveBlocks[i]), "\n"], "")
        out = strutil.Join([out, "wave_", waveIndex, "_restarted=", (waveRestarted[i] ? "true" : "false"), "\n"], "")
fn GateBftStopShell(pidPaths: str[], killPatterns: str[]): str =
    var out = "set -u"
    for i in 0..<pidPaths.len:
        let pidPath = pidPaths[i]
        out = strutil.Join([out, " ; if [ -f ", os.QuoteShell(pidPath), " ]; then", " pid=$(cat ", os.QuoteShell(pidPath), ");", " if [ -n \"$pid\" ]; then", " kill \"$pid\" >/dev/null 2>&1 || true;", " sleep 1;", " kill -9 \"$pid\" >/dev/null 2>&1 || true;", " fi;", " rm -f ", os.QuoteShell(pidPath), ";", " fi"], "")
    for i in 0..<killPatterns.len:
        out = strutil.Join([out, " ; pkill -f -- ", os.QuoteShell(killPatterns[i]), " >/dev/null 2>&1 || true"], "")
    return out

fn GateBftStartDetachedShell(binPath: str,
                               args: str[],
                               pidPath: str,
                               logPath: str,
                               readyPath: str,
                               useSetsid: bool): str =
    var out = strutil.Join(["set -eu && mkdir -p ", os.QuoteShell(chengpath.PathParentDir(logPath))], "")
    var binArgv: str[]
    add(binArgv, binPath)
    var inner = strutil.Join(["echo $$ > ", os.QuoteShell(pidPath), " && exec ", GateShellArgv(binArgv), " ", GateShellArgv(args)], "")
    inner = strutil.Join([inner, " > ", os.QuoteShell(logPath), " 2>&1 < /dev/null"], "")
    if len(readyPath) > 0:
        out = strutil.Join([out, " && rm -f ", os.QuoteShell(readyPath)], "")
    out = strutil.Join([out, " && rm -f ", os.QuoteShell(pidPath)], "")
    if useSetsid:
        out = strutil.Join([out, " && setsid -f sh -lc ", os.QuoteShell(inner)], "")
    else:
        out = strutil.Join([out, " && sh -lc ", os.QuoteShell(inner), " &"], "")
    out = strutil.Join([out, " && i=0 && while [ ! -f ", os.QuoteShell(pidPath), " ] && [ \"$i\" -lt 50 ]; do i=$((i + 1)); sleep 0.1; done"], "")
    out = strutil.Join([out, " && test -f ", os.QuoteShell(pidPath)], "")
    return out

fn GateBftWaitReadyShell(paths: str[], timeoutSec: int32): str =
    var out = strutil.Join(["set -eu && i=0 && while [ \"$i\" -lt ", IntToStr(timeoutSec * 10), " ]; do"], "")
    var checks = ""
    for i in 0..<paths.len:
        if i > 0:
            checks = strutil.Join([checks, " && "], "")
        checks = strutil.Join([checks, "[ -f ", os.QuoteShell(paths[i]), " ]"], "")
    out = strutil.Join([out, " if ", checks, "; then exit 0; fi; i=$((i + 1)); sleep 0.1; done; exit 1"], "")
    return out

fn GateBftSyncRemoteRepo(root: str,
                           sshHost: str,
                           remoteRoot: str,
                           logPath: str): int32 =
    let ensureRun = GateRunRemoteShellLogged(root,
                                               "bft_remote_repo_mkdir",
                                               sshHost,
                                               strutil.Join(["set -eu && mkdir -p ", os.QuoteShell(remoteRoot)], ""),
                                               strutil.Join([logPath, ".mkdir.log"], ""),
                                               20)
    if GateRunFailed(ensureRun):
        return ensureRun.exitCode
    let remoteShell = "ssh -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=5 -o ServerAliveCountMax=3"
    var lastRun = hostops.LoggedRunZero("bft_remote_rsync", "rsync", logPath, 255, "")
    for attempt in 0..<3:
        let run = hostops.RunProgramLogged(root,
                                             "bft_remote_rsync",
                                             "rsync",
                                             ["-az",
                                              "-e", remoteShell,
                                              "--delete",
                                              "--exclude", ".git",
                                              "--exclude", "artifacts",
                                              "--exclude", "chengcache",
                                              "--exclude", "node_modules",
                                              strutil.Join([root, "/"], ""),
                                              strutil.Join([sshHost, ":", remoteRoot, "/"], "")],
                                             [],
                                             root,
                                             0,
                                             logPath)
        lastRun = run
        if !GateRunFailed(run):
            return 0
        if attempt >= 2 || !GateRemoteTransportRetryable(run.output):
            return run.exitCode
        GatePrintLine(strutil.Join(["[ gate] remote rsync retry ", IntToStr(attempt + 1), " ", sshHost], ""))
        os.SleepMs((attempt + 1) * 1000)
    return lastRun.exitCode

fn GateBftBuildRemote(root: str,
                        sshHost: str,
                        remoteRoot: str,
                        logPath: str): int32 =
    let readyRun = GateRunRemoteShellLogged(root,
                                              "bft_remote_ready",
                                              sshHost,
                                              strutil.Join(["set -eu && ", GateBftRemoteBuildReadyCommand(remoteRoot)], ""),
                                              strutil.Join([logPath, ".ready.log"], ""),
                                              30)
    if !GateRunFailed(readyRun):
        GatePrintLine(strutil.Join(["[ gate] remote bft reuse ", sshHost], ""))
        return 0
    let stage3FreshRun = GateRunRemoteShellLogged(root,
                                                    "bft_remote_stage3_fresh",
                                                    sshHost,
                                                    strutil.Join(["set -eu && ", GateBftRemoteStage3FreshCommand(remoteRoot)], ""),
                                                    strutil.Join([logPath, ".stage3.log"], ""),
                                                    30)
    if !GateRunFailed(stage3FreshRun):
        let incrementalCommand = GateBftRemoteLockedShell(
            remoteRoot,
            strutil.Join(["BFT_STATE_TARGET=x86_64-unknown-linux-gnu", " BFT_STATE_RUN_SELF_TEST=1", " artifacts/bootstrap/cheng.stage3 build-bft-state-machine"], ""))
        let incrementalRun = GateRunRemoteShellLogged(root,
                                                        "bft_remote_build_incremental",
                                                        sshHost,
                                                        incrementalCommand,
                                                        logPath,
                                                        900)
        if GateRunFailed(incrementalRun):
            return incrementalRun.exitCode
        GatePrintLine(strutil.Join(["[ gate] remote bft incremental ", sshHost], ""))
        return 0
    let fullCommand = GateBftRemoteLockedShell(
        remoteRoot,
        strutil.Join(["mkdir -p artifacts/bootstrap", " && cc -std=c11 -O2 -Wall -Wextra -pedantic", " bootstrap/cheng_seed.c -o artifacts/bootstrap/cheng.stage0", " && CHENG_ROOT=", os.QuoteShell(remoteRoot), " CHENG_TARGET=x86_64-unknown-linux-gnu", " artifacts/bootstrap/cheng.stage0 bootstrap-bridge >/dev/null", " && BFT_STATE_TARGET=x86_64-unknown-linux-gnu", " BFT_STATE_RUN_SELF_TEST=1", " artifacts/bootstrap/cheng.stage3 build-bft-state-machine"], ""))
    let run = GateRunRemoteShellLogged(root, "bft_remote_build", sshHost, fullCommand, logPath, 900)
    if GateRunFailed(run):
        return run.exitCode
    GatePrintLine(strutil.Join(["[ gate] remote bft rebuild ", sshHost], ""))
    return 0

fn GateStatusBftValidatorThreeNode(root: str): int32 =
    let cfg = GateBftConfigLoad(root)
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                     cfg,
                                                     "server",
                                                     cfg.serverSsh,
                                                     cfg.serverRepoRoot,
                                                     os.JoinPath(serverDir, "server.state"),
                                                     "artifacts/gate/bft_server_status")
    if IsErr(serverRes):
        GatePrintErr(" bft deploy: server status failed")
        GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                    cfg,
                                                    "relay",
                                                    cfg.relaySsh,
                                                    cfg.relayRepoRoot,
                                                    os.JoinPath(relayDir, "relay.state"),
                                                    "artifacts/gate/bft_relay_status")
    if IsErr(relayRes):
        GatePrintErr(" bft deploy: relay status failed")
        GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    let localRes = GateBftCollectLocalNodeStatus(root,
                                                   cfg,
                                                   "local",
                                                   os.JoinPath(localDir, "local.state"),
                                                   "artifacts/gate/bft_local_status")
    if IsErr(localRes):
        GatePrintErr(" bft deploy: local status failed")
        GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    GateBftPrintNodeStatus(Value(serverRes))
    GatePrintLine("---")
    GateBftPrintNodeStatus(Value(relayRes))
    GatePrintLine("---")
    GateBftPrintNodeStatus(Value(localRes))
    return 0

fn GateStopBftValidatorThreeNode(root: str): int32 =
    let cfg = GateBftConfigLoad(root)
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRun = GateRunRemoteShellLogged(root,
                                               "bft_stop_server",
                                               cfg.serverSsh,
                                               GateBftStopShell([
                                                   os.JoinPath(serverDir, "server_proposer.pid"),
                                                   os.JoinPath(serverDir, "server_state.pid")
                                               ], [
                                                   strutil.Join(["[v]alidator-proposer-daemon --state:", os.JoinPath(serverDir, "server.state")], ""),
                                                   strutil.Join(["[s]tate-serve-daemon --file:", os.JoinPath(serverDir, "server.machine.hex")], "")
                                               ]),
                                               "artifacts/gate/bft_stop_server.log",
                                               30)
    if GateRunFailed(serverRun):
        return serverRun.exitCode
    let relayRun = GateRunRemoteShellLogged(root,
                                              "bft_stop_relay",
                                              cfg.relaySsh,
                                              GateBftStopShell([os.JoinPath(relayDir, "relay_follower.pid")],
                                                                 [
                                                                     strutil.Join(["[v]alidator-follower-daemon --state:", os.JoinPath(relayDir, "relay.state")], "")
                                                                 ]),
                                              "artifacts/gate/bft_stop_relay.log",
                                              30)
    if GateRunFailed(relayRun):
        return relayRun.exitCode
    let localRun = GateRunShellLogged(root,
                                        "bft_stop_local",
                                        GateBftStopShell([os.JoinPath(localDir, "local_follower.pid")],
                                                           [
                                                               strutil.Join(["[v]alidator-follower-daemon --state:", os.JoinPath(localDir, "local.state")], "")
                                                           ]),
                                        "artifacts/gate/bft_stop_local.log",
                                        30)
    if GateRunFailed(localRun):
        return localRun.exitCode
    GatePrintLine(" bft deploy: stopped")
    return 0

fn GateBftEnsureNoUe(root: str,
                       label: str,
                       logPath: str,
                       context: str): bool =
    let run = GateRunShellLogged(root,
                                   label,
                                   strutil.Join(["ps -Ao pid=,ppid=,state=,etime=,command= |", " awk '$2==1 && $3 ~ /^U/ && $5 ~ /bft_state_machine/'"], ""),
                                   logPath,
                                   10)
    if GateRunFailed(run):
        return false
    let ueText = strutil.Strip(run.output)
    if len(ueText) > 0:
        GatePrintErr(context)
        GatePrintErr(ueText)
        return false
    return true

fn GateDeployBftValidatorThreeNode(root: str,
                                     compilerPath: str,
                                     maxTxsOverride: int32): int32 =
    let cfg = GateBftThreeNodeConfig(root)
    if !chengpath.MkdirP(root, cfg.localDeployDir):
        GatePrintErr(" bft deploy: failed to create local deploy dir")
        return 1
    if !chengpath.WriteTextFile(root, GateBftManifestPath(cfg), GateBftManifestText(cfg)):
        GatePrintErr(" bft deploy: failed to write manifest")
        return 1
    if GateStopBftValidatorThreeNode(root) != 0:
        return 1
    if GateBftSyncRemoteRepo(root,
                               cfg.serverSsh,
                               cfg.serverRepoRoot,
                               "artifacts/gate/bft_sync_server.log") != 0:
        return 1
    if GateBftSyncRemoteRepo(root,
                               cfg.relaySsh,
                               cfg.relayRepoRoot,
                               "artifacts/gate/bft_sync_relay.log") != 0:
        return 1
    if GateBuildBftStateMachine(root, compilerPath) != 0:
        return 1
    if GateBftBuildRemote(root,
                            cfg.serverSsh,
                            cfg.serverRepoRoot,
                            "artifacts/gate/bft_build_server.log") != 0:
        return 1
    if GateBftBuildRemote(root,
                            cfg.relaySsh,
                            cfg.relayRepoRoot,
                            "artifacts/gate/bft_build_relay.log") != 0:
        return 1
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverBin = GateBftRemoteBin(cfg.serverRepoRoot)
    let relayBin = GateBftRemoteBin(cfg.relayRepoRoot)
    let localBin = GateBftLocalBin(root)
    let serverInitCommand = GateBftInitCommand(serverBin,
                                                 os.JoinPath(serverDir, "server.state"),
                                                 cfg.appId,
                                                 1)
    let serverInitShell = GateBftServerInitShell(serverDir, serverInitCommand)
    let serverInit = GateRunRemoteShellLogged(root,
                                                "bft_init_server",
                                                cfg.serverSsh,
                                                serverInitShell,
                                                "artifacts/gate/bft_init_server.log",
                                                30)
    if GateRunFailed(serverInit):
        return serverInit.exitCode
    let relayInitCommand = GateBftInitCommand(relayBin,
                                                os.JoinPath(relayDir, "relay.state"),
                                                cfg.appId,
                                                2)
    let relayInit = GateRunRemoteShellLogged(root,
                                               "bft_init_relay",
                                               cfg.relaySsh,
                                               strutil.Join(["set -eu && mkdir -p ", os.QuoteShell(relayDir), " && ", relayInitCommand], ""),
                                               "artifacts/gate/bft_init_relay.log",
                                               30)
    if GateRunFailed(relayInit):
        return relayInit.exitCode
    let localInitCommand = GateBftInitCommand(localBin,
                                                os.JoinPath(localDir, "local.state"),
                                                cfg.appId,
                                                3)
    let localInit = GateRunShellLogged(root,
                                         "bft_init_local",
                                         strutil.Join(["set -eu && mkdir -p ", os.QuoteShell(localDir), " && ", localInitCommand], ""),
                                         "artifacts/gate/bft_init_local.log",
                                         30)
    if GateRunFailed(localInit):
        return localInit.exitCode
    let seedQueuePath = os.JoinPath(serverDir, "server.queue")
    let seedMintCommand = GateBftSubmitMintCommand(serverBin,
                                                     seedQueuePath,
                                                     cfg.assetId,
                                                     cfg.aliceId,
                                                     cfg.mintAmount)
    let seedTransferCommand = GateBftSubmitTransferCommand(serverBin,
                                                             seedQueuePath,
                                                             cfg.assetId,
                                                             cfg.aliceId,
                                                             cfg.bobId,
                                                             cfg.transferAmount)
    let queueRun = GateRunRemoteShellLogged(root,
                                              "bft_seed_queue",
                                              cfg.serverSsh,
                                              strutil.Join(["set -eu && ", seedMintCommand, " && ", seedTransferCommand], ""),
                                              "artifacts/gate/bft_seed_queue.log",
                                              30)
    if GateRunFailed(queueRun):
        return queueRun.exitCode
    let serverProposerShell = GateBftServerProposerShell(serverBin,
                                                           cfg,
                                                           serverDir,
                                                           maxTxsOverride,
                                                           os.JoinPath(serverDir, "server_proposer.pid"),
                                                           os.JoinPath(serverDir, "server.proposer.log"),
                                                           os.JoinPath(serverDir, "server.proposal.ready"),
                                                           true)
    let serverProposerRun = GateRunRemoteShellLogged(root,
                                                       "bft_start_server_proposer",
                                                       cfg.serverSsh,
                                                       serverProposerShell,
                                                       "artifacts/gate/bft_start_server_proposer.log",
                                                       30)
    if GateRunFailed(serverProposerRun):
        return serverProposerRun.exitCode
    let serverStateShell = GateBftServerStateShell(serverBin,
                                                     cfg,
                                                     serverDir,
                                                     os.JoinPath(serverDir, "server_state.pid"),
                                                     os.JoinPath(serverDir, "server.state.log"),
                                                     true)
    let serverStateRun = GateRunRemoteShellLogged(root,
                                                    "bft_start_server_state",
                                                    cfg.serverSsh,
                                                    serverStateShell,
                                                    "artifacts/gate/bft_start_server_state.log",
                                                    30)
    if GateRunFailed(serverStateRun):
        return serverStateRun.exitCode
    let serverReadyRun = GateRunRemoteShellLogged(root,
                                                    "bft_wait_server_ready",
                                                    cfg.serverSsh,
                                                    strutil.Join(["set -eu && i=0 && while { [ ! -f ", os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.proposal.ready")), " ] || [ ! -f ", os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.vote.ready")), " ]; } && [ \"$i\" -lt 200 ]; do i=$((i + 1)); sleep 0.05; done && test -f ", os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.proposal.ready")), " && test -f ", os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.vote.ready"))], ""),
                                                    "artifacts/gate/bft_wait_server_ready.log",
                                                    30)
    if GateRunFailed(serverReadyRun):
        return serverReadyRun.exitCode
    let relayFollowerShell = GateBftFollowerShell(relayBin,
                                                    cfg,
                                                    os.JoinPath(relayDir, "relay.state"),
                                                    os.JoinPath(relayDir, "relay_follower.pid"),
                                                    os.JoinPath(relayDir, "relay.follower.log"),
                                                    true)
    let relayFollowerRun = GateRunRemoteShellLogged(root,
                                                      "bft_start_relay_follower",
                                                      cfg.relaySsh,
                                                      relayFollowerShell,
                                                      "artifacts/gate/bft_start_relay_follower.log",
                                                      30)
    if GateRunFailed(relayFollowerRun):
        return relayFollowerRun.exitCode
    let localFollowerShell = GateBftFollowerShell(localBin,
                                                    cfg,
                                                    os.JoinPath(localDir, "local.state"),
                                                    os.JoinPath(localDir, "local_follower.pid"),
                                                    os.JoinPath(localDir, "local.follower.log"),
                                                    false)
    let localFollowerRun = GateRunShellLogged(root,
                                                "bft_start_local_follower",
                                                localFollowerShell,
                                                "artifacts/gate/bft_start_local_follower.log",
                                                30)
    if GateRunFailed(localFollowerRun):
        return localFollowerRun.exitCode
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var converged = false
    var lastServer = GateBftNodeStatusZero("server")
    var lastRelay = GateBftNodeStatusZero("relay")
    var lastLocal = GateBftNodeStatusZero("local")
    for i in 0..<200:
        i
        let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                         cfg,
                                                         "server",
                                                         cfg.serverSsh,
                                                         cfg.serverRepoRoot,
                                                         os.JoinPath(serverDir, "server.state"),
                                                         "artifacts/gate/bft_server_wait")
        if IsErr(serverRes):
            os.SleepMs(200)
            continue
        let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                        cfg,
                                                        "relay",
                                                        cfg.relaySsh,
                                                        cfg.relayRepoRoot,
                                                        os.JoinPath(relayDir, "relay.state"),
                                                        "artifacts/gate/bft_relay_wait")
        if IsErr(relayRes):
            os.SleepMs(200)
            continue
        let localRes = GateBftCollectLocalNodeStatus(root,
                                                       cfg,
                                                       "local",
                                                       os.JoinPath(localDir, "local.state"),
                                                       "artifacts/gate/bft_local_wait")
        if IsErr(localRes):
            os.SleepMs(200)
            continue
        lastServer = Value(serverRes)
        lastRelay = Value(relayRes)
        lastLocal = Value(localRes)
        if lastServer.height == wantHeight &&
           lastRelay.height == wantHeight &&
           lastLocal.height == wantHeight &&
           len(lastServer.appHash) > 0 &&
           lastServer.appHash == lastRelay.appHash &&
           lastServer.appHash == lastLocal.appHash &&
           lastServer.aliceBalance == wantAlice &&
           lastRelay.aliceBalance == wantAlice &&
           lastLocal.aliceBalance == wantAlice &&
           lastServer.bobBalance == wantBob &&
           lastRelay.bobBalance == wantBob &&
           lastLocal.bobBalance == wantBob:
            converged = true
            break
        os.SleepMs(200)
    if !converged:
        let convergeErr = " bft deploy: three-node cluster did not converge"
        GatePrintErr(convergeErr)
        GateBftPrintNodeStatus(lastServer)
        GatePrintLine("---")
        GateBftPrintNodeStatus(lastRelay)
        GatePrintLine("---")
        GateBftPrintNodeStatus(lastLocal)
        return 1
    GateBftPrintNodeStatus(lastServer)
    GatePrintLine("---")
    GateBftPrintNodeStatus(lastRelay)
    GatePrintLine("---")
    GateBftPrintNodeStatus(lastLocal)
    if !GateBftEnsureNoUe(root,
                            "bft_ue_check",
                            "artifacts/gate/bft_ue_check.log",
                            " bft deploy: unexpected UE process"):
        return 1
    return 0

fn GateVerifyBftValidatorThreeNode(root: str,
                                     compilerPath: str): int32 =
    if GateDeployBftValidatorThreeNode(root, compilerPath, 0) != 0:
        return 1
    let cfg = GateBftConfigLoad(root)
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var serverStatus = GateBftNodeStatusZero("server")
    var relayStatus = GateBftNodeStatusZero("relay")
    var localStatus = GateBftNodeStatusZero("local")
    var verified = false
    let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                     cfg,
                                                     "server",
                                                     cfg.serverSsh,
                                                     cfg.serverRepoRoot,
                                                     os.JoinPath(serverDir, "server.state"),
                                                     "artifacts/gate/bft_verify_server")
    let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                    cfg,
                                                    "relay",
                                                    cfg.relaySsh,
                                                    cfg.relayRepoRoot,
                                                    os.JoinPath(relayDir, "relay.state"),
                                                    "artifacts/gate/bft_verify_relay")
    let localRes = GateBftCollectLocalNodeStatus(root,
                                                   cfg,
                                                   "local",
                                                   os.JoinPath(localDir, "local.state"),
                                                   "artifacts/gate/bft_verify_local")
    if !IsErr(serverRes):
        serverStatus = Value(serverRes)
    if !IsErr(relayRes):
        relayStatus = Value(relayRes)
    if !IsErr(localRes):
        localStatus = Value(localRes)
    if !IsErr(serverRes) && !IsErr(relayRes) && !IsErr(localRes):
        verified = GateBftClusterMatches(serverStatus,
                                           relayStatus,
                                           localStatus,
                                           wantHeight,
                                           wantAlice,
                                           wantBob)
    let reportPath = GateBftVerifyReportPath(root)
    let reportText = GateBftVerifyReportText(cfg,
                                               verified,
                                               serverStatus,
                                               relayStatus,
                                               localStatus)
    if !chengpath.WriteTextFile(root, reportPath, reportText):
        GatePrintErr(strutil.Join([" bft verify: failed to write report: ", reportPath], ""))
        let _ = GateStopBftValidatorThreeNode(root)
        return 1
    let stopCode = GateStopBftValidatorThreeNode(root)
    if IsErr(serverRes):
        GatePrintErr(" bft verify: server status failed")
        GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    if IsErr(relayRes):
        GatePrintErr(" bft verify: relay status failed")
        GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    if IsErr(localRes):
        GatePrintErr(" bft verify: local status failed")
        GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    if !verified:
        GatePrintErr(" bft verify: three-node cluster drifted")
        GateBftPrintNodeStatus(serverStatus)
        GatePrintLine("---")
        GateBftPrintNodeStatus(relayStatus)
        GatePrintLine("---")
        GateBftPrintNodeStatus(localStatus)
        return 1
    if stopCode != 0:
        GatePrintErr(" bft verify: stop failed after verification")
        return stopCode
    GatePrintLine(" bft verify ok")
    GatePrintLine(strutil.Join(["report=", reportPath], ""))
    return 0

fn GateBenchBftValidatorThreeNode(root: str,
                                    compilerPath: str,
                                    args: str[]): int32 =
    var txCountText = GateReadFlag(args, "--tx-count", "64")
    var waveCountText = GateReadFlag(args, "--wave-count", "1")
    var transferAmountText = GateReadFlag(args, "--transfer-amount", "1")
    var txCount = int32(strutil.ParseInt(txCountText))
    var waveCount = int32(strutil.ParseInt(waveCountText))
    var transferAmount = int64(strutil.ParseInt(transferAmountText))
    var maxTxsText = GateReadFlag(args, "--max-txs-per-block", IntToStr(txCount))
    var maxTxsPerBlock = int32(strutil.ParseInt(maxTxsText))
    var restartNode = strutil.Strip(GateReadFlag(args, "--restart-node", "none"))
    var restartPauseMsText = GateReadFlag(args, "--restart-pause-ms", "1000")
    var restartPauseMs = int32(strutil.ParseInt(restartPauseMsText))
    var defaultRestartWave = waveCount >= 2 ? 2 : 1
    var restartWaveText = GateReadFlag(args, "--restart-wave", IntToStr(defaultRestartWave))
    var restartWave = int32(strutil.ParseInt(restartWaveText))
    if txCount <= 0 || waveCount <= 0 || transferAmount <= int64(0) || maxTxsPerBlock <= 0 || restartPauseMs < 0:
        GatePrintErr(" bft bench: --tx-count --wave-count --transfer-amount --max-txs-per-block must be positive, --restart-pause-ms must be non-negative")
        return 1
    if !GateBftBenchRestartTargetValid(restartNode):
        GatePrintErr(" bft bench: --restart-node must be none/server/relay/local")
        return 1
    if restartNode == "none":
        restartWave = 0
    elif restartWave <= 0 || restartWave > waveCount:
        GatePrintErr(" bft bench: --restart-wave must be within 1..wave-count when restart is enabled")
        return 1
    if GateDeployBftValidatorThreeNode(root, compilerPath, maxTxsPerBlock) != 0:
        return 1
    let cfg = GateBftConfigLoad(root)
    let serverDir = GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverBin = GateBftRemoteBin(cfg.serverRepoRoot)
    let relayBin = GateBftRemoteBin(cfg.relayRepoRoot)
    let localBin = GateBftLocalBin(root)
    var baseServer = GateBftNodeStatusZero("server")
    var baseRelay = GateBftNodeStatusZero("relay")
    var baseLocal = GateBftNodeStatusZero("local")
    if !GateBftWaitClusterState(root,
                                  cfg,
                                  serverDir,
                                  relayDir,
                                  localDir,
                                  "1",
                                  strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount),
                                  strings.Int64ToStr(cfg.transferAmount),
                                  "artifacts/gate/bft_bench_bootstrap_wait",
                                  baseServer,
                                  baseRelay,
                                  baseLocal):
        GatePrintErr(" bft bench: baseline cluster wait failed")
        return 1
    var baseHeight = int64(strutil.ParseInt(baseServer.height))
    var baseAlice = int64(strutil.ParseInt(baseServer.aliceBalance))
    var baseBob = int64(strutil.ParseInt(baseServer.bobBalance))
    let totalRequiredAmount = int64(txCount) * int64(waveCount) * transferAmount
    if baseAlice < totalRequiredAmount:
        let topupAmount = totalRequiredAmount - baseAlice + transferAmount
        let topupCommand = GateBftSubmitMintCommand(serverBin,
                                                      os.JoinPath(serverDir, "server.queue"),
                                                      cfg.assetId,
                                                      cfg.aliceId,
                                                      topupAmount)
        let topupRun = GateRunRemoteShellLogged(root,
                                                  "bft_bench_topup",
                                                  cfg.serverSsh,
                                                  strutil.Join(["set -eu && ", topupCommand], ""),
                                                  "artifacts/gate/bft_bench_topup.log",
                                                  30)
        if GateRunFailed(topupRun):
            return topupRun.exitCode
        baseHeight = baseHeight + int64(1)
        baseAlice = baseAlice + topupAmount
        if !GateBftWaitClusterState(root,
                                      cfg,
                                      serverDir,
                                      relayDir,
                                      localDir,
                                      strings.Int64ToStr(baseHeight),
                                      strings.Int64ToStr(baseAlice),
                                      strings.Int64ToStr(baseBob),
                                      "artifacts/gate/bft_bench_topup_wait",
                                      baseServer,
                                      baseRelay,
                                      baseLocal):
            GatePrintErr(" bft bench: topup did not converge")
            return 1
    let benchStart = monotimes.GetMonoTime()
    var waveElapsedMs: int64[]
    var waveTpsMilli: int64[]
    var waveBlockCounts: int64[]
    var waveRestarted: bool[]
    var totalQueuedCount = int64(0)
    var totalQueuedBytes = int64(0)
    var txWireBytes = int64(0)
    var totalBlocks = int64(0)
    var expectedHeight = baseHeight
    var expectedAlice = baseAlice
    var expectedBob = baseBob
    var finalServer = baseServer
    var finalRelay = baseRelay
    var finalLocal = baseLocal
    let requiredPerWave = int64(txCount) * transferAmount
    for wave in 0..<waveCount:
        let waveIndex = wave + 1
        let waveStart = monotimes.GetMonoTime()
        let wavePrefix = strutil.Join(["artifacts/gate/bft_bench_wave_", IntToStr(waveIndex)], "")
        let submitSeriesCommand = GateBftSubmitTransferSeriesCommand(serverBin,
                                                                       os.JoinPath(serverDir,
                                                                                   "server.queue"),
                                                                       cfg.assetId,
                                                                       cfg.aliceId,
                                                                       cfg.bobId,
                                                                       transferAmount,
                                                                       txCount)
        let queueRun = GateRunRemoteShellLogged(root,
                                                  strutil.Join(["bft_bench_submit_series_wave_", IntToStr(waveIndex)], ""),
                                                  cfg.serverSsh,
                                                  strutil.Join(["set -eu && ", submitSeriesCommand], ""),
                                                  strutil.Join([wavePrefix, ".submit.log"], ""),
                                                  30)
        if GateRunFailed(queueRun):
            return queueRun.exitCode
        let queuedCount = int64(strutil.ParseInt(GateTextValue(queueRun.output, "queued_count")))
        let queuedBytes = int64(strutil.ParseInt(GateTextValue(queueRun.output, "queued_bytes")))
        let txWireBytesWave = int64(strutil.ParseInt(GateTextValue(queueRun.output, "tx_wire_bytes")))
        if queuedCount != int64(txCount) || queuedBytes <= 0 || txWireBytesWave <= 0:
            GatePrintErr(" bft bench: invalid submit-transfer-series report")
            GatePrintErr(strutil.Strip(queueRun.output))
            return 1
        if txWireBytes <= int64(0):
            txWireBytes = txWireBytesWave
        let blocksNeeded = int64((txCount + maxTxsPerBlock - 1) / maxTxsPerBlock)
        totalQueuedCount = totalQueuedCount + queuedCount
        totalQueuedBytes = totalQueuedBytes + queuedBytes
        totalBlocks = totalBlocks + blocksNeeded
        expectedHeight = expectedHeight + blocksNeeded
        expectedAlice = expectedAlice - requiredPerWave
        expectedBob = expectedBob + requiredPerWave
        var restarted = false
        if restartNode != "none" && waveIndex == restartWave:
            if GateBftBenchRestartNode(root,
                                         cfg,
                                         serverDir,
                                         relayDir,
                                         localDir,
                                         serverBin,
                                         relayBin,
                                         localBin,
                                         restartNode,
                                         maxTxsPerBlock,
                                         restartPauseMs,
                                         strutil.Join([wavePrefix, ".restart"], "")) != 0:
                return 1
            restarted = true
        if !GateBftWaitClusterState(root,
                                      cfg,
                                      serverDir,
                                      relayDir,
                                      localDir,
                                      strings.Int64ToStr(expectedHeight),
                                      strings.Int64ToStr(expectedAlice),
                                      strings.Int64ToStr(expectedBob),
                                      strutil.Join([wavePrefix, ".wait"], ""),
                                      finalServer,
                                      finalRelay,
                                      finalLocal):
            GatePrintErr(" bft bench: benchmark transactions did not converge")
            GatePrintErr(strutil.Join(["wave=", IntToStr(waveIndex)], ""))
            return 1
        let waveElapsedNs: int64 = monotimes.MonoTimeNs(monotimes.GetMonoTime()) - monotimes.MonoTimeNs(waveStart)
        var waveElapsed = waveElapsedNs / int64(1000000)
        if waveElapsed <= int64(0):
            waveElapsed = int64(1)
        let waveTps = queuedCount * int64(1000000) / waveElapsed
        add(waveElapsedMs, waveElapsed)
        add(waveTpsMilli, waveTps)
        add(waveBlockCounts, blocksNeeded)
        add(waveRestarted, restarted)
    let elapsedNs: int64 = monotimes.MonoTimeNs(monotimes.GetMonoTime()) - monotimes.MonoTimeNs(benchStart)
    var elapsedMs = elapsedNs / int64(1000000)
    if elapsedMs <= int64(0):
        elapsedMs = int64(1)
    let tpsMilli = totalQueuedCount * int64(1000000) / elapsedMs
    let bytesPerSec = totalQueuedBytes * int64(1000) / elapsedMs
    let kibPerSecMilli = totalQueuedBytes * int64(1000 * 1000) / (elapsedMs * int64(1024))
    if !GateBftEnsureNoUe(root,
                            "bft_bench_ue_check",
                            "artifacts/gate/bft_bench_ue_check.log",
                            " bft bench: unexpected UE process"):
        return 1
    let reportPath = GateBftBenchReportPath(root)
    var reportText = ""
    reportText = strutil.Join([reportText, "version=cheng.bft_three_node_bench.v2\n"], "")
    reportText = strutil.Join([reportText, "app_id=", cfg.appId, "\n"], "")
    reportText = strutil.Join([reportText, "tx_count_per_wave=", strings.Int64ToStr(int64(txCount)), "\n"], "")
    reportText = strutil.Join([reportText, "wave_count=", IntToStr(waveCount), "\n"], "")
    reportText = strutil.Join([reportText, "transfer_amount=", strings.Int64ToStr(transferAmount), "\n"], "")
    reportText = strutil.Join([reportText, "max_txs_per_block=", IntToStr(maxTxsPerBlock), "\n"], "")
    reportText = strutil.Join([reportText, "restart_node=", restartNode, "\n"], "")
    reportText = strutil.Join([reportText, "restart_wave=", IntToStr(restartWave), "\n"], "")
    reportText = strutil.Join([reportText, "restart_pause_ms=", IntToStr(restartPauseMs), "\n"], "")
    reportText = strutil.Join([reportText, "tx_count=", strings.Int64ToStr(totalQueuedCount), "\n"], "")
    reportText = strutil.Join([reportText, "tx_wire_bytes=", strings.Int64ToStr(txWireBytes), "\n"], "")
    reportText = strutil.Join([reportText, "committed_bytes=", strings.Int64ToStr(totalQueuedBytes), "\n"], "")
    reportText = strutil.Join([reportText, "block_count=", strings.Int64ToStr(totalBlocks), "\n"], "")
    reportText = strutil.Join([reportText, "elapsed_ms=", strings.Int64ToStr(elapsedMs), "\n"], "")
    reportText = strutil.Join([reportText, "tps=", GateFormatMilli(tpsMilli), "\n"], "")
    reportText = strutil.Join([reportText, "throughput_bytes_per_sec=", strings.Int64ToStr(bytesPerSec), "\n"], "")
    reportText = strutil.Join([reportText, "throughput_kib_per_sec=", GateFormatMilli(kibPerSecMilli), "\n"], "")
    reportText = strutil.Join([reportText, "final_height=", finalServer.height, "\n"], "")
    reportText = strutil.Join([reportText, "app_hash=", finalServer.appHash, "\n"], "")
    reportText = strutil.Join([reportText, "alice_balance=", finalServer.aliceBalance, "\n"], "")
    reportText = strutil.Join([reportText, "bob_balance=", finalServer.bobBalance, "\n"], "")
    GatePrintKv("tx_count_per_wave=", strings.Int64ToStr(int64(txCount)))
    GatePrintKv("wave_count=", IntToStr(waveCount))
    GatePrintKv("restart_node=", restartNode)
    GatePrintKv("restart_wave=", IntToStr(restartWave))
    GatePrintKv("restart_pause_ms=", IntToStr(restartPauseMs))
    GatePrintKv("tx_count=", strings.Int64ToStr(totalQueuedCount))
    GatePrintKv("tx_wire_bytes=", strings.Int64ToStr(txWireBytes))
    GatePrintKv("committed_bytes=", strings.Int64ToStr(totalQueuedBytes))
    GatePrintKv("block_count=", strings.Int64ToStr(totalBlocks))
    GatePrintKv("elapsed_ms=", strings.Int64ToStr(elapsedMs))
    GatePrintKv("tps=", GateFormatMilli(tpsMilli))
    GatePrintKv("throughput_bytes_per_sec=", strings.Int64ToStr(bytesPerSec))
    GatePrintKv("throughput_kib_per_sec=", GateFormatMilli(kibPerSecMilli))
    GatePrintKv("final_height=", finalServer.height)
    GatePrintKv("app_hash=", finalServer.appHash)
    GatePrintKv("alice_balance=", finalServer.aliceBalance)
    GatePrintKv("bob_balance=", finalServer.bobBalance)
    GateBftBenchAppendWaveReport(reportText,
                                   waveElapsedMs,
                                   waveTpsMilli,
                                   waveBlockCounts,
                                   waveRestarted)
    if !chengpath.WriteTextFile(root, reportPath, reportText):
        let writeErr = strutil.Join([" bft bench: failed to write report: ", reportPath], "")
        GatePrintErr(writeErr)
        return 1
    GatePrintKv("report=", reportPath)
    return 0
