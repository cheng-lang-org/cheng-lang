    return os.JoinPath(cfg.localDeployDir, "deploy.env")

fn GateBftRemoteDeployDir(repoRoot: str, cfg: BftThreeNodeDeploy): str =
    return chengpath.PathAbsolute(repoRoot, cfg.remoteDeployRel)

fn GateBftRemoteBin(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_bft_state_machine"),
                       os.JoinPath("x86_64-unknown-linux-gnu", "bft_state_machine"))

fn GateBftLocalBin(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/bft_state_machine/bft_state_machine")

fn GateBftRemoteRunLog(repoRoot: str): str =
    let outDir = os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_bft_state_machine"),
                             "x86_64-unknown-linux-gnu")
    return os.JoinPath(outDir, "bft_state_machine.self-test.log")

fn GateBftRemoteBackendDriver(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_backend_driver"), "cheng")

fn GateBftRemoteStage3(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_bootstrap"), "cheng.stage3")

fn GateBftRemoteSnapshot(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "cheng_bootstrap"), "bootstrap_snapshot.txt")

fn GateBftRemoteBuildReadyCommand(repoRoot: str): str =
    let compiler = GateBftRemoteBackendDriver(repoRoot)
    let src = os.JoinPath(repoRoot, "src/apps/bft/bft_state_machine_main.cheng")
    let outBin = GateBftRemoteBin(repoRoot)
    let runLog = GateBftRemoteRunLog(repoRoot)
    return strutil.Join(["test -x ", os.QuoteShell(outBin), " && test -x ", os.QuoteShell(compiler), " && test ", os.QuoteShell(compiler), " -ot ", os.QuoteShell(outBin), " && test ", os.QuoteShell(src), " -ot ", os.QuoteShell(outBin), " && test ", os.QuoteShell(outBin), " -ot ", os.QuoteShell(runLog), " && test ", os.QuoteShell(compiler), " -ot ", os.QuoteShell(runLog), " && test ", os.QuoteShell(src), " -ot ", os.QuoteShell(runLog), " && grep -qF ", os.QuoteShell(" bft_state_machine self-test ok"), " ", os.QuoteShell(runLog)], "")

fn GateBftRemoteStage3FreshCommand(repoRoot: str): str =
    let stage3 = GateBftRemoteStage3(repoRoot)
    let snapshot = GateBftRemoteSnapshot(repoRoot)
    let seed = os.JoinPath(repoRoot, "bootstrap/cheng_seed.c")
    let stage1 = contracts.BootstrapStage1SourcePath(repoRoot)
    let compilerMain = os.JoinPath(repoRoot, "src/core/tooling/compiler_main.cheng")
    let compilerRuntime = os.JoinPath(repoRoot, "src/core/tooling/compiler_runtime.cheng")
    let compilerRequest = os.JoinPath(repoRoot, "src/core/tooling/compiler_request.cheng")
    let gateMain = os.JoinPath(repoRoot, "src/core/tooling/gate_main.cheng")
    var command = ""
    command = strutil.Join([command, "test -x ", os.QuoteShell(stage3)], "")
    command = strutil.Join([command, " && snapshot=", os.QuoteShell(snapshot)], "")
    command = strutil.Join([command, " && stage3=", os.QuoteShell(stage3)], "")
    command = strutil.Join([command, " && if [ -f \"$snapshot\" ]; then"], "")
    command = strutil.Join([command, " fresh=$(grep \"^fresh_input_paths=\" \"$snapshot\" | tail -n 1 | cut -d= -f2-);"], "")
    command = strutil.Join([command, " if [ -n \"$fresh\" ]; then"], "")
    command = strutil.Join([command, " old_ifs=\"$IFS\"; IFS=,; set -- $fresh; IFS=\"$old_ifs\";"], "")
    command = strutil.Join([command, " for input in \"$@\"; do"], "")
    command = strutil.Join([command, " if [ -n \"$input\" ] && ! test \"$input\" -ot \"$stage3\"; then exit 1; fi;"], "")
    command = strutil.Join([command, " done; exit 0; fi; fi"], "")
    command = strutil.Join([command, " && test ", os.QuoteShell(seed), " -ot \"$stage3\""], "")
    command = strutil.Join([command, " && test ", os.QuoteShell(stage1), " -ot \"$stage3\""], "")
    command = strutil.Join([command, " && test ", os.QuoteShell(compilerMain), " -ot \"$stage3\""], "")
    command = strutil.Join([command, " && test ", os.QuoteShell(compilerRuntime), " -ot \"$stage3\""], "")
    command = strutil.Join([command, " && test ", os.QuoteShell(compilerRequest), " -ot \"$stage3\""], "")
    command = strutil.Join([command, " && test ", os.QuoteShell(gateMain), " -ot \"$stage3\""], "")
    return command

fn GateBftRemoteLockedShell(repoRoot: str,
                              innerCommand: str): str =
    var command = ""
    command = strutil.Join([command, "set -eu && cd ", os.QuoteShell(repoRoot)], "")
    command = strutil.Join([command, " && mkdir -p artifacts/gate"], "")
    command = strutil.Join([command, " && lock_dir=artifacts/gate/bft_remote_build.lock"], "")
    command = strutil.Join([command, " && lock_pid=\"$lock_dir/pid\""], "")
    command = strutil.Join([command, " && while ! mkdir \"$lock_dir\" 2>/dev/null; do holder=\"\";"], "")
    command = strutil.Join([command, " if [ -f \"$lock_pid\" ]; then holder=$(cat \"$lock_pid\" 2>/dev/null || true); fi;"], "")
    command = strutil.Join([command, " if [ -z \"$holder\" ] || ! kill -0 \"$holder\" 2>/dev/null; then"], "")
    command = strutil.Join([command, " rm -f \"$lock_pid\" 2>/dev/null || true; rmdir \"$lock_dir\" 2>/dev/null || true; continue;"], "")
    command = strutil.Join([command, " fi; sleep 0.1; done"], "")
    command = strutil.Join([command, " && printf \"%s\\n\" \"$$\" > \"$lock_pid\""], "")
    command = strutil.Join([command, " && trap 'rm -f \"$lock_pid\" 2>/dev/null || true; rmdir \"$lock_dir\" 2>/dev/null || true' EXIT INT TERM"], "")
    command = strutil.Join([command, " && ", innerCommand], "")
    return command

fn GateBftManifestText(cfg: BftThreeNodeDeploy): str =
    var out = ""
    out = strutil.Join([out, "app_id=", cfg.appId, "\n"], "")
    out = strutil.Join([out, "server_ssh=", cfg.serverSsh, "\n"], "")
    out = strutil.Join([out, "relay_ssh=", cfg.relaySsh, "\n"], "")
    out = strutil.Join([out, "server_addr=", cfg.serverAddress, "\n"], "")
    out = strutil.Join([out, "server_root=", cfg.serverRepoRoot, "\n"], "")
    out = strutil.Join([out, "relay_root=", cfg.relayRepoRoot, "\n"], "")
    out = strutil.Join([out, "local_deploy_dir=", cfg.localDeployDir, "\n"], "")
    out = strutil.Join([out, "remote_deploy_rel=", cfg.remoteDeployRel, "\n"], "")
    out = strutil.Join([out, "proposal_port=", IntToStr(cfg.proposalPort), "\n"], "")
    out = strutil.Join([out, "commit_port=", IntToStr(cfg.commitPort), "\n"], "")
    out = strutil.Join([out, "vote_port=", IntToStr(cfg.votePort), "\n"], "")
    out = strutil.Join([out, "state_port=", IntToStr(cfg.statePort), "\n"], "")
    out = strutil.Join([out, "proposer_interval_ms=", IntToStr(cfg.proposerIntervalMs), "\n"], "")
    out = strutil.Join([out, "follower_interval_ms=", IntToStr(cfg.followerIntervalMs), "\n"], "")
    out = strutil.Join([out, "proposal_window_ms=", IntToStr(cfg.proposalWindowMs), "\n"], "")
    out = strutil.Join([out, "vote_window_ms=", IntToStr(cfg.voteWindowMs), "\n"], "")
    out = strutil.Join([out, "commit_window_ms=", IntToStr(cfg.commitWindowMs), "\n"], "")
    out = strutil.Join([out, "default_max_txs=", IntToStr(cfg.defaultMaxTxs), "\n"], "")
    out = strutil.Join([out, "asset_id=", IntToStr(cfg.assetId), "\n"], "")
    out = strutil.Join([out, "alice_id=", IntToStr(cfg.aliceId), "\n"], "")
    out = strutil.Join([out, "bob_id=", IntToStr(cfg.bobId), "\n"], "")
    out = strutil.Join([out, "mint_amount=", strings.Int64ToStr(cfg.mintAmount), "\n"], "")
    out = strutil.Join([out, "transfer_amount=", strings.Int64ToStr(cfg.transferAmount), "\n"], "")
    return out

fn GateBftConfigLoad(root: str): BftThreeNodeDeploy =
    var cfg = GateBftThreeNodeConfig(root)
    let manifestPath = GateBftManifestPath(cfg)
    if !os.FileExists(manifestPath):
        return cfg
    let text = chengpath.ReadTextFile("", manifestPath)
    let appId = GateTextValue(text, "app_id")
    if len(appId) > 0:
        cfg.appId = appId
    let serverSsh = GateTextValue(text, "server_ssh")
    if len(serverSsh) > 0:
        cfg.serverSsh = serverSsh
    let relaySsh = GateTextValue(text, "relay_ssh")
    if len(relaySsh) > 0:
        cfg.relaySsh = relaySsh
    let serverAddr = GateTextValue(text, "server_addr")
    if len(serverAddr) > 0:
        cfg.serverAddress = serverAddr
    let serverRoot = GateTextValue(text, "server_root")
    if len(serverRoot) > 0:
        cfg.serverRepoRoot = serverRoot
    let relayRoot = GateTextValue(text, "relay_root")
    if len(relayRoot) > 0:
        cfg.relayRepoRoot = relayRoot
    let localDir = GateTextValue(text, "local_deploy_dir")
    if len(localDir) > 0:
        cfg.localDeployDir = localDir
    let remoteRel = GateTextValue(text, "remote_deploy_rel")
    if len(remoteRel) > 0:
        cfg.remoteDeployRel = remoteRel
    let proposalPort = GateTextValue(text, "proposal_port")
    if len(proposalPort) > 0:
        cfg.proposalPort = int32(strutil.ParseInt(proposalPort))
    let commitPort = GateTextValue(text, "commit_port")
    if len(commitPort) > 0:
        cfg.commitPort = int32(strutil.ParseInt(commitPort))
    let votePort = GateTextValue(text, "vote_port")
    if len(votePort) > 0:
        cfg.votePort = int32(strutil.ParseInt(votePort))
    let statePort = GateTextValue(text, "state_port")
    if len(statePort) > 0:
        cfg.statePort = int32(strutil.ParseInt(statePort))
    let proposerIntervalMs = GateTextValue(text, "proposer_interval_ms")
    if len(proposerIntervalMs) > 0:
        cfg.proposerIntervalMs = int32(strutil.ParseInt(proposerIntervalMs))
    let followerIntervalMs = GateTextValue(text, "follower_interval_ms")
    if len(followerIntervalMs) > 0:
        cfg.followerIntervalMs = int32(strutil.ParseInt(followerIntervalMs))
    let proposalWindowMs = GateTextValue(text, "proposal_window_ms")
    if len(proposalWindowMs) > 0:
        cfg.proposalWindowMs = int32(strutil.ParseInt(proposalWindowMs))
    let voteWindowMs = GateTextValue(text, "vote_window_ms")
    if len(voteWindowMs) > 0:
        cfg.voteWindowMs = int32(strutil.ParseInt(voteWindowMs))
    let commitWindowMs = GateTextValue(text, "commit_window_ms")
    if len(commitWindowMs) > 0:
        cfg.commitWindowMs = int32(strutil.ParseInt(commitWindowMs))
    let defaultMaxTxs = GateTextValue(text, "default_max_txs")
    if len(defaultMaxTxs) > 0:
        cfg.defaultMaxTxs = int32(strutil.ParseInt(defaultMaxTxs))
    let assetId = GateTextValue(text, "asset_id")
    if len(assetId) > 0:
        cfg.assetId = int32(strutil.ParseInt(assetId))
    let aliceId = GateTextValue(text, "alice_id")
    if len(aliceId) > 0:
        cfg.aliceId = int32(strutil.ParseInt(aliceId))
    let bobId = GateTextValue(text, "bob_id")
    if len(bobId) > 0:
        cfg.bobId = int32(strutil.ParseInt(bobId))
    let mintAmount = GateTextValue(text, "mint_amount")
    if len(mintAmount) > 0:
        cfg.mintAmount = int64(strutil.ParseInt(mintAmount))
    let transferAmount = GateTextValue(text, "transfer_amount")
    if len(transferAmount) > 0:
        cfg.transferAmount = int64(strutil.ParseInt(transferAmount))
    return cfg

fn GateBftNodeStatusZero(name: str): BftNodeStatus =
    return BftNodeStatus(name: name,
                           summary: "",
                           aliceQuery: "",
                           bobQuery: "",
                           height: "",
                           appHash: "",
                           aliceBalance: "",
                           bobBalance: "")

fn GateBftCollectLocalNodeStatus(root: str,
                                   cfg: BftThreeNodeDeploy,
                                   nodeName: str,
                                   statePath: str,
                                   logPrefix: str): Result[BftNodeStatus] =
    let binPath = GateBftLocalBin(root)
    let summaryRun = hostops.RunFileLogged(root,
                                             strutil.Join([nodeName, "_show_state"], ""),
                                             binPath,
                                             ["show-state", strutil.Join(["--state:", statePath], "")],
                                             [],
                                             root,
                                             20,
                                             strutil.Join([logPrefix, ".show.log"], ""))
    if !hostops.LoggedRunOk(summaryRun):
        return Err[BftNodeStatus](summaryRun.output)
    let aliceRun = hostops.RunFileLogged(root,
                                           strutil.Join([nodeName, "_alice_balance"], ""),
                                           binPath,
                                           ["query-balance",
                                            strutil.Join(["--state:", statePath], ""),
                                            strutil.Join(["--asset:", IntToStr(cfg.assetId)], ""),
                                            strutil.Join(["--account:", IntToStr(cfg.aliceId)], "")],
                                           [],
                                           root,
                                           20,
                                           strutil.Join([logPrefix, ".alice.log"], ""))
    if !hostops.LoggedRunOk(aliceRun):
        return Err[BftNodeStatus](aliceRun.output)
    let bobRun = hostops.RunFileLogged(root,
                                         strutil.Join([nodeName, "_bob_balance"], ""),
                                         binPath,
                                         ["query-balance",
                                          strutil.Join(["--state:", statePath], ""),
                                          strutil.Join(["--asset:", IntToStr(cfg.assetId)], ""),
                                          strutil.Join(["--account:", IntToStr(cfg.bobId)], "")],
                                         [],
                                         root,
                                         20,
                                         strutil.Join([logPrefix, ".bob.log"], ""))
    if !hostops.LoggedRunOk(bobRun):
        return Err[BftNodeStatus](bobRun.output)
    return Ok[BftNodeStatus](BftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        aliceQuery: aliceRun.output,
        bobQuery: bobRun.output,
        height: strutil.Strip(GateTextValue(summaryRun.output, "height")),
        appHash: strutil.Strip(GateTextValue(summaryRun.output, "app_hash")),
        aliceBalance: strutil.Strip(GateTextValue(aliceRun.output, "balance")),
        bobBalance: strutil.Strip(GateTextValue(bobRun.output, "balance"))
    ))

fn GateBftCollectRemoteNodeStatus(root: str,
                                    cfg: BftThreeNodeDeploy,
                                    nodeName: str,
                                    sshHost: str,
                                    repoRoot: str,
                                    statePath: str,
                                    logPrefix: str): Result[BftNodeStatus] =
    let binPath = GateBftRemoteBin(repoRoot)
    let summaryRun = GateRunRemoteShellLogged(root,
                                                strutil.Join([nodeName, "_show_state"], ""),
                                                sshHost,
                                                strutil.Join(["set -eu && ", GateShellArgv([binPath,
                                                                     "show-state",
                                                                     strutil.Join(["--state:", statePath], "")])], ""),
                                                strutil.Join([logPrefix, ".show.log"], ""),
                                                20)
    if !hostops.LoggedRunOk(summaryRun):
        return Err[BftNodeStatus](summaryRun.output)
    let aliceRun = GateRunRemoteShellLogged(root,
                                              strutil.Join([nodeName, "_alice_balance"], ""),
                                              sshHost,
                                              strutil.Join(["set -eu && ", GateShellArgv([binPath,
                                                                               "query-balance",
                                                                               strutil.Join(["--state:", statePath], ""),
                                                                               strutil.Join(["--asset:", IntToStr(cfg.assetId)], ""),
                                                                               strutil.Join(["--account:", IntToStr(cfg.aliceId)], "")])], ""),
                                              strutil.Join([logPrefix, ".alice.log"], ""),
                                              20)
    if !hostops.LoggedRunOk(aliceRun):
        return Err[BftNodeStatus](aliceRun.output)
    let bobRun = GateRunRemoteShellLogged(root,
                                            strutil.Join([nodeName, "_bob_balance"], ""),
                                            sshHost,
                                            strutil.Join(["set -eu && ", GateShellArgv([binPath,
                                                                             "query-balance",
                                                                             strutil.Join(["--state:", statePath], ""),
                                                                             strutil.Join(["--asset:", IntToStr(cfg.assetId)], ""),
                                                                             strutil.Join(["--account:", IntToStr(cfg.bobId)], "")])], ""),
                                            strutil.Join([logPrefix, ".bob.log"], ""),
                                            20)
    if !hostops.LoggedRunOk(bobRun):
        return Err[BftNodeStatus](bobRun.output)
    return Ok[BftNodeStatus](BftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        aliceQuery: aliceRun.output,
        bobQuery: bobRun.output,
        height: strutil.Strip(GateTextValue(summaryRun.output, "height")),
        appHash: strutil.Strip(GateTextValue(summaryRun.output, "app_hash")),
        aliceBalance: strutil.Strip(GateTextValue(aliceRun.output, "balance")),
        bobBalance: strutil.Strip(GateTextValue(bobRun.output, "balance"))
    ))

fn GateBftPrintNodeStatus(status: BftNodeStatus) =
    GatePrintLine(strutil.Join(["node=", status.name], ""))
    GatePrintLine(strutil.Join(["height=", status.height], ""))
    GatePrintLine(strutil.Join(["app_hash=", status.appHash], ""))
    GatePrintLine(strutil.Join(["alice_balance=", status.aliceBalance], ""))
    GatePrintLine(strutil.Join(["bob_balance=", status.bobBalance], ""))

fn GateBftClusterMatches(serverStatus: BftNodeStatus,
                           relayStatus: BftNodeStatus,
                           localStatus: BftNodeStatus,
                           wantHeight: str,
                           wantAlice: str,
                           wantBob: str): bool =
    return serverStatus.height == wantHeight &&
           relayStatus.height == wantHeight &&
           localStatus.height == wantHeight &&
           len(serverStatus.appHash) > 0 &&
           serverStatus.appHash == relayStatus.appHash &&
           serverStatus.appHash == localStatus.appHash &&
           serverStatus.aliceBalance == wantAlice &&
           relayStatus.aliceBalance == wantAlice &&
           localStatus.aliceBalance == wantAlice &&
           serverStatus.bobBalance == wantBob &&
           relayStatus.bobBalance == wantBob &&
           localStatus.bobBalance == wantBob

fn GateBftVerifyReportPath(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/gate/verify_bft_validator_three_node.report.txt")

fn GateBftVerifyReportAppendNode(out: var str,
                                   prefix: str,
                                   status: BftNodeStatus) =
    out = strutil.Join([out, prefix, "_name=", status.name, "\n"], "")
    out = strutil.Join([out, prefix, "_height=", status.height, "\n"], "")
    out = strutil.Join([out, prefix, "_app_hash=", status.appHash, "\n"], "")
    out = strutil.Join([out, prefix, "_alice_balance=", status.aliceBalance, "\n"], "")
    out = strutil.Join([out, prefix, "_bob_balance=", status.bobBalance, "\n"], "")

fn GateBftVerifyReportText(cfg: BftThreeNodeDeploy,
                             verified: bool,
                             serverStatus: BftNodeStatus,
                             relayStatus: BftNodeStatus,
                             localStatus: BftNodeStatus): str =
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var out = ""
    out = strutil.Join([out, "version=cheng.bft_three_node_verify.v1\n"], "")
    out = strutil.Join([out, "app_id=", cfg.appId, "\n"], "")
    out = strutil.Join([out, "server_ssh=", cfg.serverSsh, "\n"], "")
    out = strutil.Join([out, "relay_ssh=", cfg.relaySsh, "\n"], "")
    out = strutil.Join([out, "want_height=", wantHeight, "\n"], "")
    out = strutil.Join([out, "want_alice_balance=", wantAlice, "\n"], "")
    out = strutil.Join([out, "want_bob_balance=", wantBob, "\n"], "")
    GateBftVerifyReportAppendNode(out, "server", serverStatus)
    GateBftVerifyReportAppendNode(out, "relay", relayStatus)
    GateBftVerifyReportAppendNode(out, "local", localStatus)
    out = strutil.Join([out, "verified=", (verified ? "true" : "false"), "\n"], "")
    return out

fn GateFormatMilli(valueMilli: int64): str =
    let whole = valueMilli / int64(1000)
    let frac = valueMilli % int64(1000)
    var fracText = strings.Int64ToStr(frac)
    if len(fracText) == 1:
        fracText = strutil.Join(["00", fracText], "")
    elif len(fracText) == 2:
        fracText = strutil.Join(["0", fracText], "")
    return strutil.Join([strings.Int64ToStr(whole), ".", fracText], "")

fn GateBftDaemonMaxTxs(cfg: BftThreeNodeDeploy,
                         overrideMaxTxs: int32): int32 =
    if overrideMaxTxs > 0:
        return overrideMaxTxs
    return cfg.defaultMaxTxs

fn GateBftWaitClusterState(root: str,
                             cfg: BftThreeNodeDeploy,
                             serverDir: str,
                             relayDir: str,
                             localDir: str,
                             wantHeight: str,
                             wantAlice: str,
                             wantBob: str,
                             logPrefix: str,
                             serverStatus: var BftNodeStatus,
                             relayStatus: var BftNodeStatus,
                             localStatus: var BftNodeStatus): bool =
    for i in 0..<300:
        i
        let serverRes = GateBftCollectRemoteNodeStatus(root,
                                                         cfg,
                                                         "server",
                                                         cfg.serverSsh,
                                                         cfg.serverRepoRoot,
                                                         os.JoinPath(serverDir, "server.state"),
                                                         strutil.Join([logPrefix, "_server"], ""))
        if IsErr(serverRes):
            os.SleepMs(200)
            continue
        let relayRes = GateBftCollectRemoteNodeStatus(root,
                                                        cfg,
                                                        "relay",
                                                        cfg.relaySsh,
                                                        cfg.relayRepoRoot,
                                                        os.JoinPath(relayDir, "relay.state"),
                                                        strutil.Join([logPrefix, "_relay"], ""))
        if IsErr(relayRes):
            os.SleepMs(200)
            continue
        let localRes = GateBftCollectLocalNodeStatus(root,
                                                       cfg,
                                                       "local",
                                                       os.JoinPath(localDir, "local.state"),
                                                       strutil.Join([logPrefix, "_local"], ""))
        if IsErr(localRes):
            os.SleepMs(200)
            continue
        serverStatus = Value(serverRes)
        relayStatus = Value(relayRes)
        localStatus = Value(localRes)
        if GateBftClusterMatches(serverStatus,
                                   relayStatus,
                                   localStatus,
                                   wantHeight,
                                   wantAlice,
                                   wantBob):
            return true
        os.SleepMs(200)
    return false

fn GateBftBenchReportPath(root: str): str =
    return chengpath.PathAbsolute(root, "artifacts/gate/bench_bft_validator_three_node.report.txt")

fn GateBftBenchRestartTargetValid(target: str): bool =
    return target == "none" || target == "server" || target == "relay" || target == "local"

fn GateBftBenchAppendWaveReport(reportText: var str,
                                  waveElapsedMs: int64[],
                                  waveTpsMilli: int64[],
                                  waveBlockCounts: int64[],
                                  waveRestarted: bool[]) =
    var i: int32
    for i in i..<waveElapsedMs.len:
        let waveIndexText = IntToStr(i + 1)
        let waveElapsedLine = strutil.Join(["wave_", waveIndexText, "_elapsed_ms=", strings.Int64ToStr(waveElapsedMs[i])], "")
        GatePrintLine(waveElapsedLine)
        reportText = strutil.Join([reportText, waveElapsedLine, "\n"], "")
        let waveTpsLine = strutil.Join(["wave_", waveIndexText, "_tps=", GateFormatMilli(waveTpsMilli[i])], "")
        GatePrintLine(waveTpsLine)
        reportText = strutil.Join([reportText, waveTpsLine, "\n"], "")
        let waveBlockLine = strutil.Join(["wave_", waveIndexText, "_block_count=", strings.Int64ToStr(waveBlockCounts[i])], "")
        GatePrintLine(waveBlockLine)
        reportText = strutil.Join([reportText, waveBlockLine, "\n"], "")
        let waveRestartLine = strutil.Join(["wave_", waveIndexText, "_restarted=", (waveRestarted[i] ? "true" : "false")], "")
        GatePrintLine(waveRestartLine)
        reportText = strutil.Join([reportText, waveRestartLine, "\n"], "")

