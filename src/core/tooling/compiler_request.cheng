import std/os
import std/result
import std/strings
import std/strutils as strutil
import cheng/core/tooling/bootstrap_contracts as contracts
import cheng/core/tooling/path as v3path

type
    V3CompilerEmit = enum
        v3EmitExe
        v3EmitObj
        v3EmitShared

    V3CompilerRequest =
        rootDir: str
        sourcePath: str
        outputPath: str
        targetTriple: str
        emitKind: V3CompilerEmit
        reportPath: str
        symbolVisibility: str
        browserBridgeObjectPath: str

fn v3CompilerSymbolVisibilityPublic(): str =
    return "public"

fn v3CompilerSymbolVisibilityInternal(): str =
    return "internal"

fn v3CompilerSymbolVisibilityFromText(raw: str): Result[str] =
    let trimmed = strutil.Strip(raw)
    if len(trimmed) <= 0:
        return Ok[str](v3CompilerSymbolVisibilityPublic())
    if trimmed == v3CompilerSymbolVisibilityPublic():
        return Ok[str](trimmed)
    if trimmed == v3CompilerSymbolVisibilityInternal():
        return Ok[str](trimmed)
    return Err[str]("v3 compiler: unsupported --symbol-visibility: " + trimmed)

fn v3CompilerRequestNew(rootDir: str,
                        sourcePath: str,
                        outputPath: str,
                        targetTriple: str,
                        emitKind: V3CompilerEmit,
                        reportPath: str): V3CompilerRequest =
    return V3CompilerRequest(
        rootDir: rootDir,
        sourcePath: sourcePath,
        outputPath: outputPath,
        targetTriple: targetTriple,
        emitKind: emitKind,
        reportPath: reportPath,
        symbolVisibility: v3CompilerSymbolVisibilityPublic(),
        browserBridgeObjectPath: ""
    )

fn v3CompilerRequestWithSymbolVisibility(req: V3CompilerRequest,
                                         symbolVisibility: str): V3CompilerRequest =
    var out = req
    out.symbolVisibility = symbolVisibility
    return out

fn v3CompilerRequestWithBrowserBridgeObject(req: V3CompilerRequest,
                                            browserBridgeObjectPath: str): V3CompilerRequest =
    var out = req
    out.browserBridgeObjectPath = strutil.Strip(browserBridgeObjectPath)
    return out

fn v3CompilerRequestSourcePath(req: V3CompilerRequest): str =
    return req.sourcePath

fn v3CompilerRequestRootDir(req: V3CompilerRequest): str =
    return req.rootDir

fn v3CompilerRequestOutputPath(req: V3CompilerRequest): str =
    return req.outputPath

fn v3CompilerRequestTargetTriple(req: V3CompilerRequest): str =
    return req.targetTriple

fn v3CompilerRequestEmitKind(req: V3CompilerRequest): V3CompilerEmit =
    return req.emitKind

fn v3CompilerRequestSymbolVisibility(req: V3CompilerRequest): str =
    return req.symbolVisibility

fn v3CompilerRequestBrowserBridgeObjectPath(req: V3CompilerRequest): str =
    return req.browserBridgeObjectPath

fn v3CompilerReadFlagOrDefault(args: str[],
                               key: str,
                               defaultValue: str): str =
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.StartsWith(arg, key + ":"):
            return strings.DropPrefix(arg, key + ":")
        if strutil.StartsWith(arg, key + "="):
            return strings.DropPrefix(arg, key + "=")
        if arg == key && i + 1 < args.len:
            return args[i + 1]
    return defaultValue

fn v3CompilerReadFlagAliasOrDefault(args: str[],
                                    key: str,
                                    aliasKey: str,
                                    defaultValue: str): str =
    let value = v3CompilerReadFlagOrDefault(args, key, "")
    if len(value) > 0:
        return value
    if len(aliasKey) > 0:
        let aliasValue = v3CompilerReadFlagOrDefault(args, aliasKey, "")
        if len(aliasValue) > 0:
            return aliasValue
    return defaultValue

fn v3CompilerReadEnvPair(primaryKey: str,
                         aliasKey: str): str =
    let primaryValue = os.GetEnv(primaryKey)
    if len(primaryValue) > 0:
        return primaryValue
    if len(aliasKey) > 0:
        return os.GetEnv(aliasKey)
    return ""

fn v3CompilerTextStartsWith(text: str,
                            prefix: str): bool =
    if len(prefix) <= 0:
        return true
    if len(text) < len(prefix):
        return false
    return strings.SliceBytes(text, 0, len(prefix)) == prefix

fn v3CompilerFlagMatches(arg: str,
                         key: str): bool =
    if arg == key:
        return true
    if v3CompilerTextStartsWith(arg, key + ":"):
        return true
    if v3CompilerTextStartsWith(arg, key + "="):
        return true
    return false

fn v3CompilerLegacyBackendCompatLooksLikeCompile(args: str[]): bool =
    let envInput = v3CompilerReadEnvPair("BACKEND_INPUT", "CHENG_BACKEND_INPUT")
    if len(envInput) > 0:
        return true
    for i in 0..<args.len:
        let arg = args[i]
        if strings.HasSuffix(arg, ".cheng"):
            return true
        if v3CompilerFlagMatches(arg, "--in") ||
           v3CompilerFlagMatches(arg, "--out") ||
           v3CompilerFlagMatches(arg, "--output") ||
           v3CompilerFlagMatches(arg, "--emit") ||
           v3CompilerFlagMatches(arg, "--target") ||
           v3CompilerFlagMatches(arg, "--report-out") ||
           v3CompilerFlagMatches(arg, "--report") ||
           v3CompilerFlagMatches(arg, "--root"):
            return true
    return false

fn v3CompilerLegacyBackendCompatIgnoredFlag(arg: str): bool =
    if v3CompilerFlagMatches(arg, "--frontend") ||
       v3CompilerFlagMatches(arg, "--linker") ||
       v3CompilerFlagMatches(arg, "--build-track") ||
       v3CompilerFlagMatches(arg, "--mm") ||
       v3CompilerFlagMatches(arg, "--generic-mode") ||
       v3CompilerFlagMatches(arg, "--generic-spec-budget") ||
       v3CompilerFlagMatches(arg, "--generic-lowering") ||
       v3CompilerFlagMatches(arg, "--jobs") ||
       v3CompilerFlagMatches(arg, "--fn-jobs") ||
       v3CompilerFlagMatches(arg, "--opt-level") ||
       v3CompilerFlagMatches(arg, "--runtime-obj") ||
       v3CompilerFlagMatches(arg, "--sidecar-mode") ||
       v3CompilerFlagMatches(arg, "--sidecar-bundle") ||
       v3CompilerFlagMatches(arg, "--sidecar-compiler") ||
       v3CompilerFlagMatches(arg, "--sidecar-child-mode") ||
       v3CompilerFlagMatches(arg, "--sidecar-outer-compiler") ||
       v3CompilerFlagMatches(arg, "--module-cache") ||
       v3CompilerFlagMatches(arg, "--multi-module-cache") ||
       v3CompilerFlagMatches(arg, "--module-cache-unstable-allow"):
        return true
    if arg == "--allow-no-main" ||
       arg == "--whole-program" ||
       arg == "--no-whole-program" ||
       arg == "--multi" ||
       arg == "--no-multi" ||
       arg == "--multi-force" ||
       arg == "--no-multi-force" ||
       arg == "--incremental" ||
       arg == "--no-incremental" ||
       arg == "--opt" ||
       arg == "--no-opt" ||
       arg == "--opt2" ||
       arg == "--no-opt2":
        return true
    return false

fn v3CompilerLegacyBackendCompatAllowedFlag(arg: str): bool =
    if v3CompilerFlagMatches(arg, "--in") ||
       v3CompilerFlagMatches(arg, "--root") ||
       v3CompilerFlagMatches(arg, "--out") ||
       v3CompilerFlagMatches(arg, "--output") ||
       v3CompilerFlagMatches(arg, "--emit") ||
       v3CompilerFlagMatches(arg, "--target") ||
       v3CompilerFlagMatches(arg, "--browser-bridge-object") ||
       v3CompilerFlagMatches(arg, "--symbol-visibility") ||
       v3CompilerFlagMatches(arg, "--report-out") ||
       v3CompilerFlagMatches(arg, "--report"):
        return true
    return v3CompilerLegacyBackendCompatIgnoredFlag(arg)

fn v3CompilerReadArgFlagValue(args: str[],
                              index: int32,
                              key: str,
                              outValue: var str,
                              outNextIndex: var int32): bool =
    outValue = ""
    outNextIndex = index
    if index < 0 || index >= args.len:
        return false
    let arg = args[index]
    if v3CompilerTextStartsWith(arg, key + ":"):
        outValue = strings.DropPrefix(arg, key + ":")
        return true
    if v3CompilerTextStartsWith(arg, key + "="):
        outValue = strings.DropPrefix(arg, key + "=")
        return true
    if arg == key && index + 1 < args.len:
        outValue = args[index + 1]
        outNextIndex = index + 1
        return true
    return false

fn v3CompilerEmitText(kind: V3CompilerEmit): str =
    if kind == v3EmitExe:
        return "exe"
    if kind == v3EmitObj:
        return "obj"
    if kind == v3EmitShared:
        return "shared"
    return "unknown"

fn v3CompilerEmitFromText(raw: str): Result[V3CompilerEmit] =
    if raw == "exe":
        return Ok[V3CompilerEmit](v3EmitExe)
    if raw == "obj":
        return Ok[V3CompilerEmit](v3EmitObj)
    if raw == "shared":
        return Ok[V3CompilerEmit](v3EmitShared)
    return Err[V3CompilerEmit]("v3 compiler: unsupported --emit: " + raw)

fn v3CompilerDefaultPackageRoot(workspaceRoot: str): str =
    return workspaceRoot

fn v3CompilerPathIsWithinDir(pathRaw: str,
                             dirRaw: str): bool =
    let path = v3path.V3PathTrim(pathRaw)
    var dir = v3path.V3PathTrim(dirRaw)
    if len(path) <= 0 || len(dir) <= 0:
        return false
    while strings.HasSuffix(dir, "/"):
        dir = v3path.V3TextSlice(dir, 0, dir.len - 1)
    if path == dir:
        return true
    let dirPrefix = dir + "/"
    return strutil.StartsWith(path, dirPrefix)

fn v3CompilerPackageManifestExists(dirRaw: str): bool =
    let dir = v3path.V3PathTrim(dirRaw)
    if len(dir) <= 0:
        return false
    let manifestPath = v3path.V3PathJoin(dir, "cheng-package.toml")
    return v3path.V3PathFileExists(manifestPath)

fn v3CompilerFindNearestPackageRoot(baseRootRaw: str,
                                    sourcePathRaw: str): str =
    let baseRoot = v3path.V3PathTrim(baseRootRaw)
    let sourcePath = v3path.V3PathTrim(sourcePathRaw)
    if len(baseRoot) <= 0 || len(sourcePath) <= 0:
        return ""
    var cursor = v3path.V3PathParentDir(sourcePath)
    while len(cursor) > 0:
        if cursor != baseRoot && !v3CompilerPathIsWithinDir(cursor, baseRoot):
            break
        if v3CompilerPackageManifestExists(cursor):
            return cursor
        let parent = v3path.V3PathParentDir(cursor)
        if len(parent) <= 0 || parent == cursor:
            break
        cursor = parent
    if v3CompilerPackageManifestExists(baseRoot):
        return baseRoot
    return ""

fn v3CompilerResolvePackageRoot(workspaceRoot: str,
                                sourcePathRaw: str,
                                packageRootRaw: str): str =
    let packageRoot = v3path.V3PathAbsolute(workspaceRoot, packageRootRaw)
    if len(packageRoot) <= 0:
        return packageRoot
    let baseRoot = packageRoot
    let sourcePath = v3path.V3PathAbsolute(workspaceRoot, sourcePathRaw)
    if len(sourcePath) <= 0 || !v3CompilerPathIsWithinDir(sourcePath, baseRoot):
        return baseRoot
    let nearestPackageRoot = v3CompilerFindNearestPackageRoot(baseRoot, sourcePath)
    if len(nearestPackageRoot) > 0:
        return nearestPackageRoot
    return baseRoot

fn v3CompilerWorldHeadFromArgs(args: str[]): str =
    return v3CompilerReadFlagOrDefault(args, "--world-head", "")

fn v3CompilerLockPathFromArgs(args: str[]): str =
    return v3CompilerReadFlagOrDefault(args, "--lock", "")

fn v3CompilerBaselineSurfacePathFromArgs(args: str[]): str =
    return v3CompilerReadFlagOrDefault(args, "--baseline-surface", "")

fn v3CompilerBaselineReceiptPathFromArgs(args: str[]): str =
    return v3CompilerReadFlagOrDefault(args, "--baseline-receipt", "")

fn v3CompilerBaselineCsgPathFromArgs(args: str[]): str =
    return v3CompilerReadFlagOrDefault(args, "--baseline-csg", "")

fn v3CompilerLegacyInPathFromArgs(args: str[]): str =
    return v3CompilerReadFlagOrDefault(args, "--legacy-in", "")

fn v3CompilerChannelFromArgs(args: str[]): str =
    let channel = v3CompilerReadFlagOrDefault(args, "--channel", "")
    if len(channel) > 0:
        return channel
    return "stable"

fn v3CompilerRequestFromArgsForCommand(workspaceRoot: str,
                                       args: str[],
                                       requireOutput: bool): Result[V3CompilerRequest] =
    let sourcePath = v3CompilerReadFlagOrDefault(args, "--in", "")
    if len(sourcePath) <= 0:
        return Err[V3CompilerRequest]("v3 compiler: missing --in")
    var packageRootRaw = v3CompilerReadFlagOrDefault(args, "--root", "")
    if len(packageRootRaw) <= 0:
        packageRootRaw = v3CompilerDefaultPackageRoot(workspaceRoot)
    let packageRoot = v3CompilerResolvePackageRoot(workspaceRoot, sourcePath, packageRootRaw)
    let outputPath = v3CompilerReadFlagOrDefault(args, "--out", "")
    if requireOutput && len(outputPath) <= 0:
        return Err[V3CompilerRequest]("v3 compiler: missing --out")
    var targetTriple = v3CompilerReadFlagOrDefault(args, "--target", "")
    if len(targetTriple) <= 0:
        targetTriple = contracts.V3BootstrapDefaultTarget()
    var emitText = v3CompilerReadFlagOrDefault(args, "--emit", "")
    if len(emitText) <= 0:
        emitText = "exe"
    let emitKindRes = v3CompilerEmitFromText(emitText)
    if IsErr(emitKindRes):
        return Err[V3CompilerRequest](Error(emitKindRes))
    let reportPath = v3CompilerReadFlagOrDefault(args, "--report-out", "")
    let symbolVisibilityRes = v3CompilerSymbolVisibilityFromText(v3CompilerReadFlagOrDefault(args,
                                                                                             "--symbol-visibility",
                                                                                             ""))
    if IsErr(symbolVisibilityRes):
        return Err[V3CompilerRequest](Error(symbolVisibilityRes))
    let browserBridgeObjectPath = v3CompilerReadFlagOrDefault(args, "--browser-bridge-object", "")
    return Ok[V3CompilerRequest](v3CompilerRequestWithBrowserBridgeObject(v3CompilerRequestWithSymbolVisibility(v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        targetTriple,
        Value(emitKindRes),
        reportPath
    ),
    Value(symbolVisibilityRes)),
    browserBridgeObjectPath))

fn v3CompilerRequestFromArgs(workspaceRoot: str,
                             args: str[]): Result[V3CompilerRequest] =
    return v3CompilerRequestFromArgsForCommand(workspaceRoot, args, true)

fn v3CompilerLegacyBackendCompatRequest(workspaceRoot: str,
                                        args: str[]): Result[V3CompilerRequest] =
    var sourcePath = ""
    var packageRootRaw = ""
    var outputPath = ""
    var emitText = ""
    var targetTriple = ""
    var reportPath = ""
    var i = 0
    while i < args.len:
        let arg = args[i]
        if len(arg) <= 0:
            i = i + 1
            continue
        var value = ""
        var nextIndex = i
        if v3CompilerReadArgFlagValue(args, i, "--in", value, nextIndex):
            if len(sourcePath) > 0:
                return Err[V3CompilerRequest]("[backend_driver_exec] multiple input paths are not supported: " + value)
            sourcePath = value
            i = nextIndex + 1
            continue
        if v3CompilerReadArgFlagValue(args, i, "--root", value, nextIndex):
            packageRootRaw = value
            i = nextIndex + 1
            continue
        if v3CompilerReadArgFlagValue(args, i, "--out", value, nextIndex):
            outputPath = value
            i = nextIndex + 1
            continue
        if v3CompilerReadArgFlagValue(args, i, "--output", value, nextIndex):
            outputPath = value
            i = nextIndex + 1
            continue
        if v3CompilerReadArgFlagValue(args, i, "--emit", value, nextIndex):
            emitText = value
            i = nextIndex + 1
            continue
        if v3CompilerReadArgFlagValue(args, i, "--target", value, nextIndex):
            targetTriple = value
            i = nextIndex + 1
            continue
        if v3CompilerReadArgFlagValue(args, i, "--report-out", value, nextIndex):
            reportPath = value
            i = nextIndex + 1
            continue
        if v3CompilerReadArgFlagValue(args, i, "--report", value, nextIndex):
            reportPath = value
            i = nextIndex + 1
            continue
        if v3CompilerTextStartsWith(arg, "--"):
            if v3CompilerLegacyBackendCompatAllowedFlag(arg):
                i = i + 1
                continue
            return Err[V3CompilerRequest]("[backend_driver_exec] unsupported legacy flag after old backend_driver removal: " + arg)
        if len(sourcePath) > 0:
            return Err[V3CompilerRequest]("[backend_driver_exec] multiple input paths are not supported: " + arg)
        sourcePath = arg
        i = i + 1
    if len(sourcePath) <= 0:
        let envSourcePath = v3CompilerReadEnvPair("BACKEND_INPUT", "CHENG_BACKEND_INPUT")
        sourcePath = envSourcePath
    if len(sourcePath) <= 0:
        return Err[V3CompilerRequest]("[backend_driver_exec] missing input source")
    if len(packageRootRaw) <= 0:
        packageRootRaw = v3CompilerDefaultPackageRoot(workspaceRoot)
    let packageRoot = v3CompilerResolvePackageRoot(workspaceRoot, sourcePath, packageRootRaw)
    let envOutputPath = v3CompilerReadEnvPair("BACKEND_OUTPUT", "CHENG_BACKEND_OUTPUT")
    if len(outputPath) <= 0:
        outputPath = envOutputPath
    if len(outputPath) <= 0:
        return Err[V3CompilerRequest]("[backend_driver_exec] missing output path")
    let envEmitText = v3CompilerReadEnvPair("BACKEND_EMIT", "CHENG_BACKEND_EMIT")
    if len(emitText) <= 0:
        emitText = envEmitText
    if len(emitText) <= 0:
        emitText = "exe"
    let emitKindRes = v3CompilerEmitFromText(emitText)
    if IsErr(emitKindRes):
        return Err[V3CompilerRequest](Error(emitKindRes))
    let envTargetTriple = v3CompilerReadEnvPair("BACKEND_TARGET", "CHENG_BACKEND_TARGET")
    if len(targetTriple) <= 0:
        targetTriple = envTargetTriple
    if len(targetTriple) <= 0 || targetTriple == "auto":
        targetTriple = contracts.V3BootstrapDefaultTarget()
    let envReportPath = v3CompilerReadEnvPair("BACKEND_REPORT_OUT", "CHENG_BACKEND_REPORT_OUT")
    if len(reportPath) <= 0:
        reportPath = envReportPath
    let symbolVisibilityRes = v3CompilerSymbolVisibilityFromText(v3CompilerReadFlagOrDefault(args,
                                                                                             "--symbol-visibility",
                                                                                             ""))
    if IsErr(symbolVisibilityRes):
        return Err[V3CompilerRequest](Error(symbolVisibilityRes))
    let browserBridgeObjectPath = v3CompilerReadFlagOrDefault(args, "--browser-bridge-object", "")
    return Ok[V3CompilerRequest](v3CompilerRequestWithBrowserBridgeObject(v3CompilerRequestWithSymbolVisibility(v3CompilerRequestNew(packageRoot,
                                                     sourcePath,
                                                     outputPath,
                                                     targetTriple,
                                                     Value(emitKindRes),
                                                     reportPath),
                                                     Value(symbolVisibilityRes)),
                                                     browserBridgeObjectPath))

fn v3CompilerSystemLinkCompatArgs(req: V3CompilerRequest): str[] =
    var out: str[]
    add(out, "--root:" + req.rootDir)
    add(out, "--in:" + req.sourcePath)
    add(out, "--emit:" + v3CompilerEmitText(req.emitKind))
    add(out, "--target:" + req.targetTriple)
    add(out, "--out:" + req.outputPath)
    if len(req.reportPath) > 0:
        add(out, "--report-out:" + req.reportPath)
    if len(req.browserBridgeObjectPath) > 0:
        add(out, "--browser-bridge-object:" + req.browserBridgeObjectPath)
    if req.symbolVisibility == v3CompilerSymbolVisibilityInternal():
        add(out, "--symbol-visibility:" + req.symbolVisibility)
    return out

fn V3CompilerWorldHeadFromArgs(args: str[]): str =
    return v3CompilerWorldHeadFromArgs(args)

fn V3CompilerLockPathFromArgs(args: str[]): str =
    return v3CompilerLockPathFromArgs(args)

fn V3CompilerBaselineSurfacePathFromArgs(args: str[]): str =
    return v3CompilerBaselineSurfacePathFromArgs(args)

fn V3CompilerChannelFromArgs(args: str[]): str =
    return v3CompilerChannelFromArgs(args)

fn V3CompilerRequestFromArgs(workspaceRoot: str,
                             args: str[]): Result[V3CompilerRequest] =
    return v3CompilerRequestFromArgs(workspaceRoot, args)
