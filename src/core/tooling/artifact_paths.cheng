import cheng/core/tooling/path as chengpath

const
    ArtifactStage0Relative = "artifacts/bootstrap/cheng.stage0"
    ArtifactStage3Relative = "artifacts/bootstrap/cheng.stage3"
    ArtifactBootstrapDirRelative = "artifacts/bootstrap"
    ArtifactBackendDriverRelative = "artifacts/backend_driver"
    ArtifactBackendDriverExeRelative = "artifacts/backend_driver/cheng"
    ArtifactHostrunDirRelative = "artifacts/hostrun"
    ArtifactGateDirRelative = "artifacts/gate"
    BootstrapManifestRelative = "bootstrap/compiler_bootstrap_manifest.cheng"
    BootstrapStage1Relative = "bootstrap/stage1_bootstrap.cheng"

fn ArtifactStage0Path(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, ArtifactStage0Relative)

fn ArtifactStage3Path(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, ArtifactStage3Relative)

fn ArtifactBackendDriverExePath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, ArtifactBackendDriverExeRelative)

fn ArtifactBootstrapDirPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, ArtifactBootstrapDirRelative)

fn ArtifactBackendDriverDirPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, ArtifactBackendDriverRelative)

fn ArtifactHostrunDirPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, ArtifactHostrunDirRelative)

fn ArtifactGateDirPath(rootDir: str): str =
    return chengpath.PathAbsolute(rootDir, ArtifactGateDirRelative)
